# 2D Engine — Apple Metal GPU Backend
#
# Hardware-accelerated 2D rendering using Metal compute shaders.
# Each draw operation launches a compute kernel operating on a
# device-side framebuffer. present() copies the GPU framebuffer
# back to host memory for display.
#
# Requires macOS/iOS with Metal-capable hardware.
#
# Usage:
#   use std.gpu.engine2d.backend_metal.{MetalBackend}

use std.gpu.engine2d.metal_session.{MetalSession}
use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, render_text_to_buffer}
use std.gpu.engine2d.backend_metal_helpers.{
    GridDim, BlockDim,
    _grid_for_rect, _block_for_rect,
    _pack_clear_params, _pack_rect_params, _pack_line_params,
    _pack_circle_params, _pack_rounded_rect_params, _pack_triangle_params,
    _pack_gradient_params, _pack_blit_params,
    _pixels_to_bytes, _i64, _i64_from_u32, _to_u32, _to_i32,
    _i32_to_u8, _u8_to_i32
}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.nogc_sync_mut.io.metal_ffi.{
    metal_ffi_is_available,
    metal_ffi_alloc_buffer, metal_ffi_free_buffer,
    metal_ffi_buffer_upload,
    metal_ffi_create_command_buffer, metal_ffi_commit_command_buffer,
    metal_ffi_wait_completed, metal_ffi_create_compute_encoder,
    metal_ffi_end_compute_encoder, metal_ffi_set_buffer, metal_ffi_set_bytes,
    metal_ffi_dispatch_compute, metal_ffi_buffer_download
}

extern fn rt_time_now_monotonic_ms() -> i64

# ============================================================================
# Metal Backend
# ============================================================================

class MetalBackend:
    """GPU-accelerated 2D renderer using Apple Metal compute shaders.

    Architecture:
    - Framebuffer lives in GPU device memory (d_framebuffer)
    - Each draw call creates a command buffer, encodes a compute kernel,
      and commits it synchronously
    - present() copies GPU framebuffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line, etc.) has a
    dedicated MSL compute kernel. Grid/threadgroup dimensions cover the
    bounding box of the primitive being drawn.
    """

    host_buf: [u32]
    w: i32
    h: i32
    session: MetalSession       # Shared GPU context (device + queue + shaders + pipelines)
    d_framebuffer: i64          # Per-surface device buffer for framebuffer
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    initialized: bool
    dirty: bool                # True when GPU has changes not yet copied to host
    init_ms: i64               # Milliseconds taken by init() (device + queue + shader compile)
    command_ms: i64            # Milliseconds taken by the most recent compute dispatch

    static fn create() -> MetalBackend:
        """Create an uninitialized Metal backend. Call init() before drawing."""
        MetalBackend(
            host_buf: [],
            w: 0,
            h: 0,
            session: MetalSession.create(),
            d_framebuffer: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            initialized: false,
            dirty: false,
            init_ms: 0,
            command_ms: 0
        )

impl RenderBackend for MetalBackend:

    fn name() -> text:
        "metal"

    me init(width: i32, height: i32) -> bool:
        """Initialize with an internally-created session (LegacyNoSession mode)."""
        val t0 = rt_time_now_monotonic_ms()
        self.session = MetalSession.create()
        if self.session.init_status() != 0:
            return false
        self._init_surface(width, height, t0)

    me shutdown():
        # Free per-surface framebuffer
        if self.d_framebuffer != 0:
            metal_ffi_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0

        # Release our reference to the shared session; cleans up GPU resources
        # (device/queue/shaders/pipelines) when refcount hits zero
        self.session.release()

        self.host_buf = []
        self.w = 0
        self.h = 0
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.initialized = false

    me clear(color: u32):
        val params = _pack_clear_params(color, self.w, self.h)
        val total = _i64(self.w) * _i64(self.h)
        val block_size: i64 = 256
        val grid_size = (total + block_size - 1) / block_size
        self._dispatch_1d(self.session.pipe_clear, grid_size * block_size, block_size, params)
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val params = _pack_rect_params(x, y, w, h, color, self.w, self.h)
        val grid_dim = _grid_for_rect(w, h)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_rect_outline, grid_dim, block, params)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val params = _pack_rect_params(x, y, w, h, color, self.w, self.h)
        val grid_dim = _grid_for_rect(w, h)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_rect_filled, grid_dim, block, params)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val params = _pack_line_params(x1, y1, x2, y2, color, thickness, self.w, self.h)
        val block_size: i64 = 256
        val grid_size = (_i64(line_len) + block_size - 1) / block_size
        self._dispatch_1d(self.session.pipe_line, grid_size * block_size, block_size, params)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val params = _pack_circle_params(cx, cy, r, color, self.w, self.h, 0)
        val grid_dim = _grid_for_rect(bw, bh)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_circle, grid_dim, block, params)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val params = _pack_circle_params(cx, cy, r, color, self.w, self.h, 1)
        val grid_dim = _grid_for_rect(bw, bh)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_circle_filled, grid_dim, block, params)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        val params = _pack_rounded_rect_params(x, y, w, h, radius, color, self.w, self.h)
        val grid_dim = _grid_for_rect(w, h)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_rounded_rect, grid_dim, block, params)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val params = _pack_triangle_params(x1, y1, x2, y2, x3, y3, color, self.w, self.h, min_x, min_y)
        val grid_dim = _grid_for_rect(bw, bh)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_triangle, grid_dim, block, params)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        val params = _pack_gradient_params(x, y, w, h, top_color, bottom_color, self.w, self.h)
        val grid_dim = _grid_for_rect(w, h)
        val block = _block_for_rect()
        self._dispatch_2d(self.session.pipe_gradient, grid_dim, block, params)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering on GPU is complex; fall back to CPU-side rendering
        # then upload the affected region. For production, a glyph atlas
        # texture would be uploaded and sampled by a kernel.
        self._metal_draw_text_fallback(x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Upload pixel data to a temporary device buffer, then launch
        # a blit kernel to copy it into the framebuffer
        val pixel_count = _i64(w) * _i64(h)
        val byte_size = pixel_count * 4
        val d_src = metal_ffi_alloc_buffer(self.session.device, byte_size)
        if d_src != 0:
            # Upload source pixels to device
            val upload_data = _pixels_to_bytes(pixels, pixel_count)
            metal_ffi_buffer_upload(d_src, upload_data, byte_size)
            # Launch blit kernel
            val params = _pack_blit_params(x, y, w, h, self.w, self.h)
            val grid_dim = _grid_for_rect(w, h)
            val block = _block_for_rect()
            self._dispatch_blit(self.session.pipe_blit, grid_dim, block, params, d_src)
            metal_ffi_free_buffer(d_src)
        self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Copy GPU framebuffer to host memory
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            self._download_framebuffer(fb_size)
            self.dirty = false

    fn read_pixels() -> [u32]:
        # Ensure host buffer is up to date
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            self._download_framebuffer(fb_size)
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)
        self.dirty = true

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)
        self.dirty = true

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)
        self.dirty = true

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)
        self.dirty = true

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)
        self.dirty = true

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)
        self.dirty = true

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)
        self.dirty = true

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)
        self.dirty = true

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)
        self.dirty = true

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)
        self.dirty = true

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)
        self.dirty = true

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)
        self.dirty = true

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)
        self.dirty = true

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        self.dirty = true

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)
        self.dirty = true

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)
        self.dirty = true

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)
        self.dirty = true

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)
        self.dirty = true

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)
        self.dirty = true

impl Engine2DExtended for MetalBackend:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = text_val.len().to_i32() * advance
        val text_h = gh * scale
        if text_w <= 0 or text_h <= 0:
            return
        var buf: [u32] = []
        var _i = 0
        val buf_size = text_w * text_h
        while _i < buf_size:
            buf.push(bg)
            _i = _i + 1
        render_text_to_buffer(buf, text_w, text_h, 0, 0, text_val, fg, font_size)
        self.draw_image(x, y, text_w, text_h, buf)

# ============================================================================
# Metal Compute Dispatch Helpers
#
# These implement the actual MTLComputePipelineState + dispatchThreadgroups
# path that the RenderBackend impl methods call.
# ============================================================================

fn _metal_run_kernel_1d(backend: MetalBackend, pipeline: i64, total_threads: i64, block_size: i64, params: [u8]):
    """Encode + commit a 1-D Metal compute dispatch and wait until completed."""
    val cmd_buf = metal_ffi_create_command_buffer(backend.session.command_queue)
    if cmd_buf == 0:
        return
    val encoder = metal_ffi_create_compute_encoder(cmd_buf)
    if encoder == 0:
        metal_ffi_commit_command_buffer(cmd_buf)
        metal_ffi_wait_completed(cmd_buf)
        return
    metal_ffi_set_buffer(encoder, backend.d_framebuffer, 0, 0)
    metal_ffi_set_bytes(encoder, params, params.len() as i64, 1)
    metal_ffi_dispatch_compute(encoder, pipeline, total_threads, 1, 1, block_size, 1, 1)
    metal_ffi_end_compute_encoder(encoder)
    metal_ffi_commit_command_buffer(cmd_buf)
    metal_ffi_wait_completed(cmd_buf)

fn _metal_run_kernel_2d(backend: MetalBackend, pipeline: i64, grid_dim: GridDim, block_dim: BlockDim, params: [u8]):
    """Encode + commit a 2-D Metal compute dispatch and wait until completed."""
    val cmd_buf = metal_ffi_create_command_buffer(backend.session.command_queue)
    if cmd_buf == 0:
        return
    val encoder = metal_ffi_create_compute_encoder(cmd_buf)
    if encoder == 0:
        metal_ffi_commit_command_buffer(cmd_buf)
        metal_ffi_wait_completed(cmd_buf)
        return
    metal_ffi_set_buffer(encoder, backend.d_framebuffer, 0, 0)
    metal_ffi_set_bytes(encoder, params, params.len() as i64, 1)
    metal_ffi_dispatch_compute(encoder, pipeline, grid_dim.x, grid_dim.y, 1, block_dim.x, block_dim.y, 1)
    metal_ffi_end_compute_encoder(encoder)
    metal_ffi_commit_command_buffer(cmd_buf)
    metal_ffi_wait_completed(cmd_buf)

fn _metal_run_blit_kernel(backend: MetalBackend, pipeline: i64, grid_dim: GridDim, block_dim: BlockDim, params: [u8], d_src: i64):
    """Encode + commit a blit kernel with an extra source buffer binding."""
    val cmd_buf = metal_ffi_create_command_buffer(backend.session.command_queue)
    if cmd_buf == 0:
        return
    val encoder = metal_ffi_create_compute_encoder(cmd_buf)
    if encoder == 0:
        metal_ffi_commit_command_buffer(cmd_buf)
        metal_ffi_wait_completed(cmd_buf)
        return
    metal_ffi_set_buffer(encoder, backend.d_framebuffer, 0, 0)
    metal_ffi_set_buffer(encoder, d_src, 0, 1)
    metal_ffi_set_bytes(encoder, params, params.len() as i64, 2)
    metal_ffi_dispatch_compute(encoder, pipeline, grid_dim.x, grid_dim.y, 1, block_dim.x, block_dim.y, 1)
    metal_ffi_end_compute_encoder(encoder)
    metal_ffi_commit_command_buffer(cmd_buf)
    metal_ffi_wait_completed(cmd_buf)

fn _metal_download_fb(backend: MetalBackend, fb_size: i64):
    """Read back the device framebuffer into host_buf via contents() / buffer_download."""
    val byte_count = fb_size
    var raw: [u8] = [0u8; byte_count as i32]
    metal_ffi_buffer_download(raw, backend.d_framebuffer, byte_count)
    # Reinterpret [u8] as [u32] — 4 bytes per pixel (ARGB)
    val pixel_count = backend.w * backend.h
    var i = 0
    while i < pixel_count:
        val base = i * 4
        val b0 = raw[base] as u32
        val b1 = raw[base + 1] as u32
        val b2 = raw[base + 2] as u32
        val b3 = raw[base + 3] as u32
        backend.host_buf[i] = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
        i = i + 1

fn _metal_draw_text_cpu_upload(backend: MetalBackend, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render text on CPU and re-upload the full framebuffer to device memory.

    Metal has no native text kernel; we render into the host buffer and
    re-upload. For production a glyph atlas texture would be used instead.
    """
    # Ensure host buffer is current before CPU-side text render
    if backend.dirty:
        val fb_size = _i64(backend.w) * _i64(backend.h) * 4
        _metal_download_fb(backend, fb_size)

    render_text_to_buffer(backend.host_buf, backend.w, backend.h, x, y, text_val, color, font_size)

    # Re-upload: convert [u32] host_buf back to [u8] and upload
    val pixel_count = backend.w * backend.h
    var raw: [u8] = [0u8; pixel_count * 4]
    var i = 0
    while i < pixel_count:
        val pix = backend.host_buf[i]
        raw[i * 4]     = (pix & 0xFFu32) as u8
        raw[i * 4 + 1] = ((pix >> 8) & 0xFFu32) as u8
        raw[i * 4 + 2] = ((pix >> 16) & 0xFFu32) as u8
        raw[i * 4 + 3] = ((pix >> 24) & 0xFFu32) as u8
        i = i + 1
    val fb_size = _i64(backend.w) * _i64(backend.h) * 4
    metal_ffi_buffer_upload(backend.d_framebuffer, raw, fb_size)

# ---- Trampoline methods wired into the impl block calls ----
# Simple does not allow plain functions to be called as `self._foo(...)` unless
# they are impl methods.  Add them here as free functions with `backend` arg,
# matching each call site's invocation pattern.

impl MetalBackend:

    me init_with_session(width: i32, height: i32, session: MetalSession) -> bool:
        """Initialize using an externally-provided shared session (ManagedShared mode).

        The session's refcount is incremented so this backend holds its own
        reference.  Call shutdown() to release it.
        """
        if not session.is_valid():
            return false
        val t0 = rt_time_now_monotonic_ms()
        self.session = session.retain()
        self._init_surface(width, height, t0)

    me _init_surface(width: i32, height: i32, t0: i64) -> bool:
        """Allocate the per-surface framebuffer and finish surface-level setup."""
        self.w = width
        self.h = height

        # Allocate device framebuffer (4 bytes per pixel = u32 ARGB)
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = metal_ffi_alloc_buffer(self.session.device, fb_size)
        if self.d_framebuffer == 0:
            self.session.release()
            return false

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        self.init_ms = rt_time_now_monotonic_ms() - t0
        self.command_ms = 0
        true

    me _dispatch_1d(pipeline: i64, total_threads: i64, block_size: i64, params: [u8]):
        val tc0 = rt_time_now_monotonic_ms()
        _metal_run_kernel_1d(self, pipeline, total_threads, block_size, params)
        self.command_ms = rt_time_now_monotonic_ms() - tc0

    me _dispatch_2d(pipeline: i64, grid_dim: GridDim, block_dim: BlockDim, params: [u8]):
        val tc0 = rt_time_now_monotonic_ms()
        _metal_run_kernel_2d(self, pipeline, grid_dim, block_dim, params)
        self.command_ms = rt_time_now_monotonic_ms() - tc0

    me _dispatch_blit(pipeline: i64, grid_dim: GridDim, block_dim: BlockDim, params: [u8], d_src: i64):
        val tc0 = rt_time_now_monotonic_ms()
        _metal_run_blit_kernel(self, pipeline, grid_dim, block_dim, params, d_src)
        self.command_ms = rt_time_now_monotonic_ms() - tc0

    me _download_framebuffer(fb_size: i64):
        _metal_download_fb(self, fb_size)

    me _metal_draw_text_fallback(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        _metal_draw_text_cpu_upload(self, x, y, text_val, color, font_size)

# ============================================================================
# Timing Accessors
# ============================================================================

fn metal_backend_init_ms(b: MetalBackend) -> i64:
    """Milliseconds taken by init() — MTLCreateSystemDefaultDevice + newCommandQueue + shader compile."""
    b.init_ms

fn metal_backend_command_ms(b: MetalBackend) -> i64:
    """Milliseconds taken by the most recent dispatchThreadgroups + waitUntilCompleted."""
    b.command_ms

# ============================================================================
# MetalUnavailable typed error
# ============================================================================

class MetalUnavailableError:
    """Returned by metal_backend_probe() when Metal is not available.

    On non-macOS hosts rt_metal_is_available() returns false and init()
    returns false immediately; callers should check this before calling init().
    """
    reason: text

fn metal_backend_probe() -> MetalUnavailableError:
    """Return a typed unavailability descriptor for non-macOS hosts.

    status == "Failed" mirrors BackendProbeResult for consistency.
    """
    if metal_ffi_is_available():
        MetalUnavailableError(reason: "")
    else:
        MetalUnavailableError(reason: "Metal not available on this platform")
