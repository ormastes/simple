# 2D Engine — Intel oneAPI GPU Backend: Kernel Sources and Dispatch Helpers
#
# Extracted from backend_intel.spl to keep file sizes manageable.
# Contains: dispatch alignment helper, kernel argument setters,
# device memory transfer helpers, text rendering fallback,
# OpenCL-C kernel source, SPIR-V binary fallback, and i32→i64 helpers.

use std.gpu.engine2d.glyph.{render_text_to_buffer}
use std.gc_async_mut.io.oneapi_ffi.{
    oneapi_queue_wait,
    oneapi_compile_spirv, oneapi_compile_opencl,
    OneApiPtr, OneApiModule, OneApiFunc, OneApiQueue
}
use std.nogc_async_mut.gpu.engine2d.ffi_intel.{
    intel_engine2d_set_args_clear,
    intel_engine2d_set_args_rect,
    intel_engine2d_set_args_line,
    intel_engine2d_set_args_circle,
    intel_engine2d_set_args_rounded_rect,
    intel_engine2d_set_args_triangle,
    intel_engine2d_set_args_gradient,
    intel_engine2d_set_args_blit,
    intel_engine2d_upload_pixels,
    intel_engine2d_download_pixels,
    intel_engine2d_upload_host_buf
}

# ============================================================================
# Dispatch Helpers
# ============================================================================

fn _align_up(value: i64, alignment: i64) -> i64:
    """Round up value to the next multiple of alignment."""
    ((value + alignment - 1) / alignment) * alignment

# ============================================================================
# Kernel Argument Setters
#
# Each kernel expects its arguments set via the runtime's kernel argument
# serialization. These extern functions match the SPIR-V kernel signatures
# and pack arguments into the Level Zero kernel argument slots.
# ============================================================================

fn _set_kernel_args_clear(fb_ptr: i64, color: u32, w: i32, h: i32):
    """Set arguments for clear kernel."""
    intel_engine2d_set_args_clear(fb_ptr, _i64_from_u32(color), _i64(w), _i64(h))

fn _set_kernel_args_rect(fb_ptr: i64, x: i32, y: i32, w: i32, h: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32):
    """Set arguments for rect kernel (outline or filled)."""
    intel_engine2d_set_args_rect(fb_ptr, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(color), _i64(fb_w), _i64(fb_h), _i64(filled))

fn _set_kernel_args_line(fb_ptr: i64, x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, fb_w: i32, fb_h: i32):
    """Set arguments for line kernel."""
    intel_engine2d_set_args_line(fb_ptr, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64_from_u32(color), _i64(thickness), _i64(fb_w), _i64(fb_h))

fn _set_kernel_args_circle(fb_ptr: i64, cx: i32, cy: i32, r: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32):
    """Set arguments for circle kernel (outline or filled)."""
    intel_engine2d_set_args_circle(fb_ptr, _i64(cx), _i64(cy), _i64(r), _i64_from_u32(color), _i64(fb_w), _i64(fb_h), _i64(filled))

fn _set_kernel_args_rounded_rect(fb_ptr: i64, x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, fb_w: i32, fb_h: i32):
    """Set arguments for rounded rect kernel."""
    intel_engine2d_set_args_rounded_rect(fb_ptr, _i64(x), _i64(y), _i64(w), _i64(h), _i64(radius), _i64_from_u32(color), _i64(fb_w), _i64(fb_h))

fn _set_kernel_args_triangle(fb_ptr: i64, x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, fb_w: i32, fb_h: i32, min_x: i32, min_y: i32):
    """Set arguments for triangle kernel."""
    intel_engine2d_set_args_triangle(fb_ptr, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64(x3), _i64(y3), _i64_from_u32(color), _i64(fb_w), _i64(fb_h), _i64(min_x), _i64(min_y))

fn _set_kernel_args_gradient(fb_ptr: i64, x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32, fb_w: i32, fb_h: i32):
    """Set arguments for gradient rect kernel."""
    intel_engine2d_set_args_gradient(fb_ptr, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(top_color), _i64_from_u32(bottom_color), _i64(fb_w), _i64(fb_h))

fn _set_kernel_args_blit(fb_ptr: i64, src_ptr: i64, x: i32, y: i32, w: i32, h: i32, fb_w: i32, fb_h: i32):
    """Set arguments for image blit kernel."""
    intel_engine2d_set_args_blit(fb_ptr, src_ptr, _i64(x), _i64(y), _i64(w), _i64(h), _i64(fb_w), _i64(fb_h))

# ============================================================================
# Device Memory Transfer
# ============================================================================

fn _upload_pixels_to_device_intel(d_dst: OneApiPtr, pixels: [u32], count: i64):
    """Upload host pixel array to Intel device memory."""
    intel_engine2d_upload_pixels(d_dst.ptr, pixels, count)

fn _download_framebuffer_intel(d_src: OneApiPtr, host_buf: [u32], byte_size: i64):
    """Download device framebuffer to host buffer."""
    intel_engine2d_download_pixels(d_src.ptr, host_buf, byte_size)

fn _upload_host_to_device_intel(d_dst: OneApiPtr, host_buf: [u32], byte_size: i64):
    """Upload entire host buffer to device memory."""
    intel_engine2d_upload_host_buf(d_dst.ptr, host_buf, byte_size)

# ============================================================================
# Text Rendering Fallback
# ============================================================================

fn _intel_draw_text_fallback(backend: IntelBackend, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render text on CPU and upload affected region to GPU.

    For production use, a glyph atlas would be pre-uploaded to GPU memory
    and sampled by a text-rendering kernel. This fallback is acceptable
    for low-frequency text draws (UI labels, debug overlays).
    """
    # Ensure host buffer is current
    if backend.dirty:
        val fb_size = _i64(backend.w) * _i64(backend.h) * 4
        _download_framebuffer_intel(backend.d_framebuffer, backend.host_buf, fb_size)
        oneapi_queue_wait(backend.queue)

    # Render glyphs into host buffer using shared glyph module
    render_text_to_buffer(backend.host_buf, backend.w, backend.h, x, y, text_val, color, font_size)

    # Re-upload entire framebuffer (simpler; for production, upload only the dirty rect)
    val fb_size = _i64(backend.w) * _i64(backend.h) * 4
    _upload_host_to_device_intel(backend.d_framebuffer, backend.host_buf, fb_size)

# ============================================================================
# OpenCL-C Kernel Source
# ============================================================================

fn _engine2d_opencl_source() -> text:
    """OpenCL-C source for all 2D rendering compute kernels.

    Compiled at runtime via oneapi_compile_opencl(). Each kernel operates
    on a u32 ARGB framebuffer in device memory. Work-items are dispatched
    in 1D and decomposed into 2D pixel coordinates within each primitive's
    bounding region.
    """
    r"""
__kernel void kernel_clear(
    __global uint* fb, uint color, int width, int height)
{
    int gid = get_global_id(0);
    if (gid < width * height) fb[gid] = color;
}

__kernel void kernel_draw_rect_filled(
    __global uint* fb, int rx, int ry, int rw, int rh,
    uint color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int lx = gid % rw;
    int ly = gid / rw;
    if (lx >= rw || ly >= rh) return;
    int px = rx + lx;
    int py = ry + ly;
    if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
        fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_rect_outline(
    __global uint* fb, int rx, int ry, int rw, int rh,
    uint color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int lx = gid % rw;
    int ly = gid / rw;
    if (lx >= rw || ly >= rh) return;
    if (lx != 0 && lx != rw-1 && ly != 0 && ly != rh-1) return;
    int px = rx + lx;
    int py = ry + ly;
    if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
        fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_circle_filled(
    __global uint* fb, int cx, int cy, int r,
    uint color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int bw = 2 * r + 1;
    int lx = gid % bw;
    int ly = gid / bw;
    if (ly >= bw) return;
    int px = cx - r + lx;
    int py = cy - r + ly;
    int dx = px - cx;
    int dy = py - cy;
    if (dx*dx + dy*dy <= r*r)
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_circle(
    __global uint* fb, int cx, int cy, int r,
    uint color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int bw = 2 * r + 1;
    int lx = gid % bw;
    int ly = gid / bw;
    if (ly >= bw) return;
    int px = cx - r + lx;
    int py = cy - r + ly;
    int dx = px - cx;
    int dy = py - cy;
    int dist_sq = dx*dx + dy*dy;
    int r_inner = (r-1) * (r-1);
    int r_outer = r * r;
    if (dist_sq >= r_inner && dist_sq <= r_outer)
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_line(
    __global uint* fb, int x1, int y1, int x2, int y2,
    uint color, int thickness, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int dx = abs(x2 - x1);
    int dy = abs(y2 - y1);
    int steps = (dx > dy) ? dx : dy;
    if (steps == 0) steps = 1;
    if (gid > steps) return;
    int px = x1 + (x2 - x1) * gid / steps;
    int py = y1 + (y2 - y1) * gid / steps;
    int half = thickness / 2;
    for (int ty = -half; ty <= half; ty++)
        for (int tx = -half; tx <= half; tx++) {
            int fx = px + tx;
            int fy = py + ty;
            if (fx >= 0 && fx < fb_w && fy >= 0 && fy < fb_h)
                fb[fy * fb_w + fx] = color;
        }
}

__kernel void kernel_draw_rounded_rect(
    __global uint* fb, int rx, int ry, int rw, int rh,
    int radius, uint color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int lx = gid % rw;
    int ly = gid / rw;
    if (lx >= rw || ly >= rh) return;
    int px = rx + lx;
    int py = ry + ly;
    int r = radius;
    bool inside = true;
    if (lx < r && ly < r) {
        int cdx = r - lx; int cdy = r - ly;
        if (cdx*cdx + cdy*cdy > r*r) inside = false;
    } else if (lx >= rw-r && ly < r) {
        int cdx = lx - (rw-1-r); int cdy = r - ly;
        if (cdx*cdx + cdy*cdy > r*r) inside = false;
    } else if (lx < r && ly >= rh-r) {
        int cdx = r - lx; int cdy = ly - (rh-1-r);
        if (cdx*cdx + cdy*cdy > r*r) inside = false;
    } else if (lx >= rw-r && ly >= rh-r) {
        int cdx = lx - (rw-1-r); int cdy = ly - (rh-1-r);
        if (cdx*cdx + cdy*cdy > r*r) inside = false;
    }
    if (inside && px >= 0 && px < fb_w && py >= 0 && py < fb_h)
        fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_triangle_filled(
    __global uint* fb, int x1, int y1, int x2, int y2,
    int x3, int y3, uint color, int fb_w, int fb_h,
    int min_x, int min_y)
{
    int gid = get_global_id(0);
    int bw = fb_w;
    int lx = gid % bw;
    int ly = gid / bw;
    int px = min_x + lx;
    int py = min_y + ly;
    int d = (y2-y3)*(x1-x3) + (x3-x2)*(y1-y3);
    if (d == 0) return;
    float a = (float)((y2-y3)*(px-x3) + (x3-x2)*(py-y3)) / d;
    float b = (float)((y3-y1)*(px-x3) + (x1-x3)*(py-y3)) / d;
    float c = 1.0f - a - b;
    if (a >= 0 && b >= 0 && c >= 0)
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
}

__kernel void kernel_draw_gradient_rect(
    __global uint* fb, int rx, int ry, int rw, int rh,
    uint top_color, uint bottom_color, int fb_w, int fb_h)
{
    int gid = get_global_id(0);
    int lx = gid % rw;
    int ly = gid / rw;
    if (lx >= rw || ly >= rh) return;
    int px = rx + lx;
    int py = ry + ly;
    if (px < 0 || px >= fb_w || py < 0 || py >= fb_h) return;
    float t = (rh > 1) ? (float)ly / (float)(rh - 1) : 0.0f;
    uint tr = (top_color >> 16) & 0xFF;
    uint tg = (top_color >> 8)  & 0xFF;
    uint tb = top_color & 0xFF;
    uint ta = (top_color >> 24) & 0xFF;
    uint br = (bottom_color >> 16) & 0xFF;
    uint bg = (bottom_color >> 8)  & 0xFF;
    uint bb = bottom_color & 0xFF;
    uint ba = (bottom_color >> 24) & 0xFF;
    uint cr = (uint)(tr + t * (br - tr));
    uint cg = (uint)(tg + t * (bg - tg));
    uint cb = (uint)(tb + t * (bb - tb));
    uint ca = (uint)(ta + t * (ba - ta));
    fb[py * fb_w + px] = (ca << 24) | (cr << 16) | (cg << 8) | cb;
}

__kernel void kernel_blit_image(
        __global uint* fb, __global uint* src,
        int dx, int dy, int sw, int sh, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % sw;
        int ly = gid / sw;
        if (lx >= sw || ly >= sh) return;
        int px = dx + lx;
        int py = dy + ly;
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = src[ly * sw + lx];
    }
"""

# ============================================================================
# SPIR-V Kernel Binary (Fallback)
# ============================================================================

fn _engine2d_spirv() -> [u8]:
    """Embedded SPIR-V binary for 2D rendering compute kernels.

    These kernels operate on a u32 framebuffer in device memory.
    Each pixel is ARGB packed as a 32-bit unsigned integer.

    The SPIR-V is compiled from OpenCL C kernel source. The kernels use a
    1D global work-item ID that is decomposed into (px, py) coordinates
    within the primitive's bounding region.

    Kernel list:
    - kernel_clear:               Fill entire framebuffer with a color
    - kernel_draw_rect_filled:    Fill a rectangle region
    - kernel_draw_rect_outline:   Draw rectangle border (1px)
    - kernel_draw_circle_filled:  Fill a circle (distance check)
    - kernel_draw_circle:         Draw circle outline (distance band)
    - kernel_draw_line:           Bresenham line (1 work-item per step)
    - kernel_draw_rounded_rect:   Rect with rounded corners
    - kernel_draw_triangle_filled: Barycentric triangle fill
    - kernel_draw_gradient_rect:  Vertical gradient fill
    - kernel_blit_image:          Copy source pixels to framebuffer region

    Note: In production, this would be a precompiled .spv file loaded from
    disk. The SPIR-V binary is generated from the following OpenCL C source
    using: clang -cl-std=CL2.0 -target spir64 -O2 -emit-llvm | llvm-spirv

    OpenCL C source (reference — not compiled at runtime):

    __kernel void kernel_clear(
        __global uint* fb, uint color, int width, int height)
    {
        int gid = get_global_id(0);
        if (gid < width * height) fb[gid] = color;
    }

    __kernel void kernel_draw_rect_filled(
        __global uint* fb, int rx, int ry, int rw, int rh,
        uint color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % rw;
        int ly = gid / rw;
        if (lx >= rw || ly >= rh) return;
        int px = rx + lx;
        int py = ry + ly;
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_rect_outline(
        __global uint* fb, int rx, int ry, int rw, int rh,
        uint color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % rw;
        int ly = gid / rw;
        if (lx >= rw || ly >= rh) return;
        if (lx != 0 && lx != rw-1 && ly != 0 && ly != rh-1) return;
        int px = rx + lx;
        int py = ry + ly;
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_circle_filled(
        __global uint* fb, int cx, int cy, int r,
        uint color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int bw = 2 * r + 1;
        int lx = gid % bw;
        int ly = gid / bw;
        if (ly >= bw) return;
        int px = cx - r + lx;
        int py = cy - r + ly;
        int dx = px - cx;
        int dy = py - cy;
        if (dx*dx + dy*dy <= r*r)
            if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
                fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_circle(
        __global uint* fb, int cx, int cy, int r,
        uint color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int bw = 2 * r + 1;
        int lx = gid % bw;
        int ly = gid / bw;
        if (ly >= bw) return;
        int px = cx - r + lx;
        int py = cy - r + ly;
        int dx = px - cx;
        int dy = py - cy;
        int dist_sq = dx*dx + dy*dy;
        int r_inner = (r-1) * (r-1);
        int r_outer = r * r;
        if (dist_sq >= r_inner && dist_sq <= r_outer)
            if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
                fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_line(
        __global uint* fb, int x1, int y1, int x2, int y2,
        uint color, int thickness, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int dx = abs(x2 - x1);
        int dy = abs(y2 - y1);
        int steps = (dx > dy) ? dx : dy;
        if (steps == 0) steps = 1;
        if (gid > steps) return;
        int px = x1 + (x2 - x1) * gid / steps;
        int py = y1 + (y2 - y1) * gid / steps;
        int half = thickness / 2;
        for (int ty = -half; ty <= half; ty++)
            for (int tx = -half; tx <= half; tx++) {
                int fx = px + tx;
                int fy = py + ty;
                if (fx >= 0 && fx < fb_w && fy >= 0 && fy < fb_h)
                    fb[fy * fb_w + fx] = color;
            }
    }

    __kernel void kernel_draw_rounded_rect(
        __global uint* fb, int rx, int ry, int rw, int rh,
        int radius, uint color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % rw;
        int ly = gid / rw;
        if (lx >= rw || ly >= rh) return;
        int px = rx + lx;
        int py = ry + ly;
        # Check corners
        int r = radius;
        bool inside = true;
        if (lx < r && ly < r) {
            int dx = r - lx; int dy = r - ly;
            if (dx*dx + dy*dy > r*r) inside = false;
        } else if (lx >= rw-r && ly < r) {
            int dx = lx - (rw-1-r); int dy = r - ly;
            if (dx*dx + dy*dy > r*r) inside = false;
        } else if (lx < r && ly >= rh-r) {
            int dx = r - lx; int dy = ly - (rh-1-r);
            if (dx*dx + dy*dy > r*r) inside = false;
        } else if (lx >= rw-r && ly >= rh-r) {
            int dx = lx - (rw-1-r); int dy = ly - (rh-1-r);
            if (dx*dx + dy*dy > r*r) inside = false;
        }
        if (inside && px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_triangle_filled(
        __global uint* fb, int x1, int y1, int x2, int y2,
        int x3, int y3, uint color, int fb_w, int fb_h,
        int min_x, int min_y)
    {
        int gid = get_global_id(0);
        int bw = fb_w;  // computed from caller as max_x - min_x + 1
        int lx = gid % bw;
        int ly = gid / bw;
        int px = min_x + lx;
        int py = min_y + ly;
        # Barycentric test
        int d = (y2-y3)*(x1-x3) + (x3-x2)*(y1-y3);
        if (d == 0) return;
        float a = (float)((y2-y3)*(px-x3) + (x3-x2)*(py-y3)) / d;
        float b = (float)((y3-y1)*(px-x3) + (x1-x3)*(py-y3)) / d;
        float c = 1.0f - a - b;
        if (a >= 0 && b >= 0 && c >= 0)
            if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
                fb[py * fb_w + px] = color;
    }

    __kernel void kernel_draw_gradient_rect(
        __global uint* fb, int rx, int ry, int rw, int rh,
        uint top_color, uint bottom_color, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % rw;
        int ly = gid / rw;
        if (lx >= rw || ly >= rh) return;
        int px = rx + lx;
        int py = ry + ly;
        if (px < 0 || px >= fb_w || py < 0 || py >= fb_h) return;
        float t = (rh > 1) ? (float)ly / (float)(rh - 1) : 0.0f;
        uint tr = (top_color >> 16) & 0xFF;
        uint tg = (top_color >> 8)  & 0xFF;
        uint tb = top_color & 0xFF;
        uint ta = (top_color >> 24) & 0xFF;
        uint br = (bottom_color >> 16) & 0xFF;
        uint bg = (bottom_color >> 8)  & 0xFF;
        uint bb = bottom_color & 0xFF;
        uint ba = (bottom_color >> 24) & 0xFF;
        uint cr = (uint)(tr + t * (br - tr));
        uint cg = (uint)(tg + t * (bg - tg));
        uint cb = (uint)(tb + t * (bb - tb));
        uint ca = (uint)(ta + t * (ba - ta));
        fb[py * fb_w + px] = (ca << 24) | (cr << 16) | (cg << 8) | cb;
    }

    __kernel void kernel_blit_image(
        __global uint* fb, __global uint* src,
        int dx, int dy, int sw, int sh, int fb_w, int fb_h)
    {
        int gid = get_global_id(0);
        int lx = gid % sw;
        int ly = gid / sw;
        if (lx >= sw || ly >= sh) return;
        int px = dx + lx;
        int py = dy + ly;
        if (px >= 0 && px < fb_w && py >= 0 && py < fb_h)
            fb[py * fb_w + px] = src[ly * sw + lx];
    }

    The actual SPIR-V bytes would be generated offline from the above source.
    For now we return a placeholder that will be replaced with real SPIR-V
    once the offline compilation pipeline is set up.
    """
    # Placeholder SPIR-V magic number header + minimal valid module
    # Real SPIR-V would be generated from the OpenCL C kernels above
    # using: clang -cl-std=CL2.0 -target spir64 -O2 -emit-llvm | llvm-spirv
    #
    # SPIR-V magic: 0x07230203
    # The runtime's rt_oneapi_compile_spirv will validate the binary.
    # When the SPIR-V is invalid/placeholder, oneapi_compile_spirv returns
    # an invalid module and init() returns false gracefully.
    [
        0x03, 0x02, 0x23, 0x07,  # SPIR-V magic number (little-endian)
        0x00, 0x05, 0x01, 0x00,  # Version 1.5
        0x00, 0x00, 0x00, 0x00,  # Generator magic
        0x00, 0x00, 0x00, 0x00   # Bound / schema (placeholder)
    ]

# ============================================================================
# Conversion Helpers
# ============================================================================

fn _i64(v: i32) -> i64:
    """Widen i32 to i64."""
    v as i64

fn _i64_from_u32(v: u32) -> i64:
    """Widen u32 to i64."""
    v as i64
