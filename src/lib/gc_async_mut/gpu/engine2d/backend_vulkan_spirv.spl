# ============================================================================
# Line kernel SPIR-V
# Push constants: x0,y0,x1,y1 (i32), color (u32), fb_w,fb_h (i32),
#                 clip_x,clip_y,clip_w,clip_h (i32), clip_enabled (i32)
# ============================================================================

fn spirv_line() -> [u8]:
    """SPIR-V bytecode for the line (Bresenham) compute kernel.

    Dispatch: 1D, local_size_x=256.
    """
    [
        0x03u8, 0x02u8, 0x23u8, 0x07u8,
        0x00u8, 0x03u8, 0x01u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
