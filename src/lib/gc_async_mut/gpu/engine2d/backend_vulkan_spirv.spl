fn spirv_clear() -> [u8]:
    """Validated SPIR-V bytecode for the clear/fill compute kernel.

    Push constants: color (u32), fb_w (i32), fb_h (i32).
    Dispatch: 1D, ceil(fb_w*fb_h / 256) workgroups of 256 threads.
    """
    [
        0x03u8, 0x02u8, 0x23u8, 0x07u8, 0x00u8, 0x03u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x07u8, 0x00u8,
        0x28u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x11u8, 0x00u8, 0x02u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x0Eu8, 0x00u8, 0x03u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x0Fu8, 0x00u8, 0x06u8, 0x00u8, 0x05u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x6Du8, 0x61u8, 0x69u8, 0x6Eu8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8, 0x10u8, 0x00u8, 0x06u8, 0x00u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x01u8, 0x00u8, 0x00u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x47u8, 0x00u8, 0x04u8, 0x00u8, 0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Bu8, 0x00u8, 0x00u8, 0x00u8, 0x1Cu8, 0x00u8, 0x00u8, 0x00u8, 0x47u8, 0x00u8, 0x04u8, 0x00u8,
