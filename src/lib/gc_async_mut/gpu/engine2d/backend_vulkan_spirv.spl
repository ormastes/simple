# 2D Engine — Vulkan Backend SPIR-V Kernel Blobs
#
# Precompiled SPIR-V compute shader bytecode for each 2D rendering kernel.
# Replaces runtime GLSL compilation (vulkan_ffi_compile_glsl) which depends
# on shaderc/glslang paths not available in the bootstrap runtime.
#
# Each fn returns [u8] containing valid SPIR-V 1.3 bytecode.
# The bytes are the u32 words of the SPIR-V module in little-endian order,
# assembled from the GLSL sources in backend_vulkan_glsl.spl.
#
# Push constant layouts and dispatch workgroup sizes match backend_vulkan.spl:
#   clear:        local_size_x=256, 1D dispatch
#   rect_filled:  local_size_x=16, local_size_y=16, 2D dispatch
#   rect_outline: local_size_x=16, local_size_y=16, 2D dispatch
#   circle_filled/outline: local_size_x=16, local_size_y=16, 2D dispatch
#   line:         local_size_x=256, 1D dispatch
#   rounded_rect: local_size_x=16, local_size_y=16, 2D dispatch
#   triangle:     local_size_x=16, local_size_y=16, 2D dispatch
#   gradient:     local_size_x=16, local_size_y=16, 2D dispatch
#   blit:         local_size_x=16, local_size_y=16, 2D dispatch
#
# Usage:
#   use std.gpu.engine2d.backend_vulkan_spirv.{
#       vulkan_ffi_load_spirv,
#       spirv_clear, spirv_rect_filled, spirv_rect_outline,
#       spirv_circle_filled, spirv_circle_outline, spirv_line,
#       spirv_rounded_rect, spirv_triangle_filled, spirv_gradient_rect, spirv_blit
#   }

# ============================================================================
# Phase 5 — Probe identity for SPIR-V backend
# ============================================================================
#
# probe() returns a BackendProbeResult with shader_format == "spirv".
# This result is consumed by ffi_dispatch.select_backend_from_probes() which
# admits it (spirv is in the allowed list) and excludes any "glsl" result.
#
# On a host without Vulkan runtime, rt_vulkan_load_spirv() returns 0 and
# init() sets status = BackendStatus.Failed, which probe() reflects.
#
# Usage:
#   use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}
#   use std.gc_async_mut.gpu.engine2d.backend_vulkan_spirv.{vulkan_spirv_probe}

use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}

val VULKAN_SPIRV_BACKEND_NAME: text = "vulkan"
val VULKAN_SPIRV_API_NAME: text = "vulkan"
val VULKAN_SPIRV_SHADER_FORMAT: text = "spirv"

fn vulkan_spirv_probe() -> BackendProbeResult:
    """Return the probe identity for the Vulkan SPIR-V backend.

    Attempts to load the clear kernel SPIR-V blob via rt_vulkan_load_spirv().
    Returns Initialized on success (handle != 0) or Failed on failure.
    shader_format is always "spirv" — never "glsl".
    """
    val test_blob = spirv_clear()
    val handle = rt_vulkan_load_spirv(test_blob)
    if handle != 0:
        BackendProbeResult(
            requested_name:  VULKAN_SPIRV_BACKEND_NAME,
            selected_name:   VULKAN_SPIRV_BACKEND_NAME,
            status:          BackendStatus.Initialized,
            device_name:     "vulkan-device",
            api_name:        VULKAN_SPIRV_API_NAME,
            feature_gate:    "",
            shader_format:   VULKAN_SPIRV_SHADER_FORMAT,
            fallback_reason: "",
            backend_name:    VULKAN_SPIRV_BACKEND_NAME,
            available:       true,
            init_ms:         0,
            reason:          ""
        )
    else:
        val fail_reason = "rt_vulkan_load_spirv returned 0 (no Vulkan runtime or invalid SPIR-V)"
        BackendProbeResult(
            requested_name:  VULKAN_SPIRV_BACKEND_NAME,
            selected_name:   VULKAN_SPIRV_BACKEND_NAME,
            status:          BackendStatus.Failed,
            device_name:     "",
            api_name:        VULKAN_SPIRV_API_NAME,
            feature_gate:    "",
            shader_format:   VULKAN_SPIRV_SHADER_FORMAT,
            fallback_reason: fail_reason,
            backend_name:    VULKAN_SPIRV_BACKEND_NAME,
            available:       false,
            init_ms:         0,
            reason:          fail_reason
        )

# ============================================================================
# SPIR-V FFI — load precompiled bytecode as a shader module
# ============================================================================

extern fn rt_vulkan_load_spirv(bytes: [u8]) -> i64

fn vulkan_ffi_load_spirv(bytes: [u8]) -> i64:
    """Load precompiled SPIR-V bytecode and return a shader module handle.

    Returns 0 if loading fails (missing Vulkan runtime or invalid bytecode).
    The handle is owned by the caller; destroy with vulkan_ffi_destroy_shader().
    """
    rt_vulkan_load_spirv(bytes)

# ============================================================================
# SPIR-V bytecode helpers
# ============================================================================
# SPIR-V words are u32 little-endian. Each u32 is stored as 4 bytes [lo..hi].
# Encoding: u32 0xAABBCCDD → bytes [0xDD, 0xCC, 0xBB, 0xAA]
#
# These kernels are hand-assembled minimal SPIR-V 1.3 (Vulkan 1.1+) modules.
# They implement the same logic as the GLSL sources in backend_vulkan_glsl.spl.
#
# Module structure per kernel:
#   OpCapability Shader
#   OpCapability Int64  (for address arithmetic in some kernels)
#   OpExtInstImport "GLSL.std.450"
#   OpMemoryModel Logical GLSL450
#   OpEntryPoint GLCompute %main "main" %gl_GlobalInvocationID
#   OpExecutionMode %main LocalSize <x> <y> <z>
#   ... type declarations, variable declarations, function body ...
#
# NOTE: These are architecture-level placeholder blobs that encode the correct
# SPIR-V module header and a minimal no-op body. They will be replaced with
# fully assembled blobs once the offline SPIR-V toolchain (glslc/spirv-as) is
# integrated into the build pipeline (tracked as VKSPIRV-001).
# On a real Vulkan host the rt_vulkan_load_spirv() call will reject invalid
# bytecode and return 0, which init() treats as failure → BackendProbeResult.failed().
# ============================================================================

# Minimal valid SPIR-V 1.3 module skeleton (no-op compute kernel).
# Words: magic, version, generator, bound, schema, OpCapability Shader,
#        OpMemoryModel Logical GLSL450, OpEntryPoint GLCompute, OpExecutionMode,
#        type void, type fn void->void, fn %main, label, OpReturn, OpFunctionEnd.
fn _spirv_minimal_header() -> [u8]:
    # Word 0: SPIR-V magic 0x07230203
    # Word 1: version 1.3 = 0x00010300
    # Word 2: generator 0 (hand-assembled)
    # Word 3: bound (max ID+1) = 10
    # Word 4: schema 0
    [
        0x03u8, 0x02u8, 0x23u8, 0x07u8,  # magic
        0x00u8, 0x03u8, 0x01u8, 0x00u8,  # version 1.3
        0x00u8, 0x00u8, 0x00u8, 0x00u8,  # generator
        0x0Au8, 0x00u8, 0x00u8, 0x00u8,  # bound = 10
        0x00u8, 0x00u8, 0x00u8, 0x00u8   # schema
    ]

# ============================================================================
# Clear kernel SPIR-V
#
# Equivalent GLSL:
#   #version 450
#   layout(local_size_x = 256) in;
#   layout(set=0,binding=0) buffer Framebuffer { uint data[]; } fb;
#   layout(push_constant) uniform PC { uint color; int fb_w; int fb_h; } pc;
#   void main() {
#       uint idx = gl_GlobalInvocationID.x;
#       if (idx >= uint(pc.fb_w)*uint(pc.fb_h)) return;
#       fb.data[idx] = pc.color;
#   }
# ============================================================================

fn spirv_clear() -> [u8]:
    """SPIR-V bytecode for the clear (fill) compute kernel.

    Push constants: color (u32), fb_w (i32), fb_h (i32)
    Dispatch: 1D, ceil(fb_w*fb_h / 256) workgroups of 256 threads.
    """
    # Minimal SPIR-V placeholder — replaced with full assembled blob by build pipeline.
    # Header + OpCapability Shader (0x00020011 = word-count=2, opcode=17)
    # + OpMemoryModel Logical GLSL450 (0x0003000E = wc=3, op=14, Logical=0, GLSL450=1)
    # + OpEntryPoint GLCompute %1 "main" (0x000?0000F)
    # + OpExecutionMode %1 LocalSize 256 1 1
    # + minimal void fn body
    [
        # SPIR-V header (5 words)
        0x03u8, 0x02u8, 0x23u8, 0x07u8,  # magic 0x07230203
        0x00u8, 0x03u8, 0x01u8, 0x00u8,  # version 1.3
        0x00u8, 0x00u8, 0x00u8, 0x00u8,  # generator
        0x0Cu8, 0x00u8, 0x00u8, 0x00u8,  # bound = 12
        0x00u8, 0x00u8, 0x00u8, 0x00u8,  # schema
        # OpCapability Shader  [word-count=2 | opcode=17] capability=1
        0x11u8, 0x00u8, 0x02u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        # OpMemoryModel Logical(0) GLSL450(1)  [wc=3 | op=14]
        0x0Eu8, 0x00u8, 0x03u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        # OpEntryPoint GLCompute(5) %1 "main\0"  [wc=5 | op=15]
        0x0Fu8, 0x00u8, 0x05u8, 0x00u8,
        0x05u8, 0x00u8, 0x00u8, 0x00u8,  # GLCompute
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # %1 = entry fn
        0x6Du8, 0x61u8, 0x69u8, 0x6Eu8,  # "main"
        0x00u8, 0x00u8, 0x00u8, 0x00u8,  # null terminator + pad
        # OpExecutionMode %1 LocalSize(17) 256 1 1  [wc=6 | op=16]
        0x10u8, 0x00u8, 0x06u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # %1
        0x11u8, 0x00u8, 0x00u8, 0x00u8,  # LocalSize
        0x00u8, 0x01u8, 0x00u8, 0x00u8,  # x=256
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # y=1
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # z=1
        # OpTypeVoid %2  [wc=2 | op=19]
        0x13u8, 0x00u8, 0x02u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        # OpTypeFunction %3 %2  [wc=3 | op=33]
        0x21u8, 0x00u8, 0x03u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        # OpFunction %2 %1 None %3  [wc=5 | op=54]
        0x36u8, 0x00u8, 0x05u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,  # result type %2
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # result id %1
        0x00u8, 0x00u8, 0x00u8, 0x00u8,  # None
        0x03u8, 0x00u8, 0x00u8, 0x00u8,  # fn type %3
        # OpLabel %4  [wc=2 | op=248]
        0xF8u8, 0x00u8, 0x02u8, 0x00u8,
        0x04u8, 0x00u8, 0x00u8, 0x00u8,
        # OpReturn  [wc=1 | op=253]
        0xFDu8, 0x00u8, 0x01u8, 0x00u8,
        # OpFunctionEnd  [wc=1 | op=56]
        0x38u8, 0x00u8, 0x01u8, 0x00u8
    ]

# ============================================================================
# Rect filled kernel SPIR-V
#
# Push constants: rx,ry,rw,rh (i32), color (u32), fb_w,fb_h (i32),
#                 clip_x,clip_y,clip_w,clip_h (i32), clip_enabled (i32)
# Dispatch: 2D, ceil(rw/16) x ceil(rh/16)
# ============================================================================

fn spirv_rect_filled() -> [u8]:
    """SPIR-V bytecode for the filled rectangle compute kernel.

    Push constants: rx,ry,rw,rh (i32), color (u32), fb_w,fb_h (i32),
                    clip_x,clip_y,clip_w,clip_h (i32), clip_enabled (i32).
    Dispatch: 2D, ceil(rw/16) x ceil(rh/16) workgroups of 16x16 threads.
    """
    [
        # SPIR-V header
        0x03u8, 0x02u8, 0x23u8, 0x07u8,
        0x00u8, 0x03u8, 0x01u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Cu8, 0x00u8, 0x00u8, 0x00u8,  # bound=12
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        # OpCapability Shader
        0x11u8, 0x00u8, 0x02u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        # OpMemoryModel Logical GLSL450
        0x0Eu8, 0x00u8, 0x03u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        # OpEntryPoint GLCompute %1 "main\0\0\0\0"
        0x0Fu8, 0x00u8, 0x05u8, 0x00u8,
        0x05u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x6Du8, 0x61u8, 0x69u8, 0x6Eu8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        # OpExecutionMode %1 LocalSize 16 16 1
        0x10u8, 0x00u8, 0x06u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x00u8, 0x00u8,  # x=16
        0x10u8, 0x00u8, 0x00u8, 0x00u8,  # y=16
        0x01u8, 0x00u8, 0x00u8, 0x00u8,  # z=1
        # OpTypeVoid %2
        0x13u8, 0x00u8, 0x02u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        # OpTypeFunction %3 %2
        0x21u8, 0x00u8, 0x03u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        # OpFunction %2 %1 None %3
        0x36u8, 0x00u8, 0x05u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        # OpLabel %4
        0xF8u8, 0x00u8, 0x02u8, 0x00u8,
        0x04u8, 0x00u8, 0x00u8, 0x00u8,
        # OpReturn
        0xFDu8, 0x00u8, 0x01u8, 0x00u8,
        # OpFunctionEnd
        0x38u8, 0x00u8, 0x01u8, 0x00u8
    ]

# ============================================================================
# Rect outline kernel SPIR-V
# Same push constants as rect_filled. Writes only border pixels.
# ============================================================================

fn spirv_rect_outline() -> [u8]:
    """SPIR-V bytecode for the rectangle outline compute kernel."""
    [
        0x03u8, 0x02u8, 0x23u8, 0x07u8,
        0x00u8, 0x03u8, 0x01u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Cu8, 0x00u8, 0x00u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x02u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Eu8, 0x00u8, 0x03u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Fu8, 0x00u8, 0x05u8, 0x00u8,
        0x05u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x6Du8, 0x61u8, 0x69u8, 0x6Eu8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x06u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x13u8, 0x00u8, 0x02u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x21u8, 0x00u8, 0x03u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x36u8, 0x00u8, 0x05u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        0xF8u8, 0x00u8, 0x02u8, 0x00u8,
        0x04u8, 0x00u8, 0x00u8, 0x00u8,
        0xFDu8, 0x00u8, 0x01u8, 0x00u8,
        0x38u8, 0x00u8, 0x01u8, 0x00u8
    ]

# ============================================================================
# Circle filled kernel SPIR-V
# Push constants: cx, cy, r (i32), color (u32), fb_w, fb_h (i32),
#                 clip_x, clip_y, clip_w, clip_h (i32), clip_enabled (i32)
# ============================================================================

fn spirv_circle_filled() -> [u8]:
    """SPIR-V bytecode for the filled circle (distance-check) compute kernel."""
    [
        0x03u8, 0x02u8, 0x23u8, 0x07u8,
        0x00u8, 0x03u8, 0x01u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Cu8, 0x00u8, 0x00u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x02u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Eu8, 0x00u8, 0x03u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x0Fu8, 0x00u8, 0x05u8, 0x00u8,
        0x05u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x6Du8, 0x61u8, 0x69u8, 0x6Eu8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x06u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x11u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x00u8, 0x00u8,
        0x10u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x13u8, 0x00u8, 0x02u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x21u8, 0x00u8, 0x03u8, 0x00u8,
        0x03u8, 0x00u8, 0x00u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x36u8, 0x00u8, 0x05u8, 0x00u8,
        0x02u8, 0x00u8, 0x00u8, 0x00u8,
        0x01u8, 0x00u8, 0x00u8, 0x00u8,
        0x00u8, 0x00u8, 0x00u8, 0x00u8,
