# Shared framebuffer runtime hooks for GC async 2D engine backends.

extern fn rt_fb_blit32(dst_addr: u64, dst_stride_pixels: u64,
                       src_addr: u64, src_stride_pixels: u64,
                       copy_w: u64, copy_h: u64)
extern fn rt_fb_fill32(dst_addr: u64, pixel_count: u64, color: u64)

fn framebuffer_host_blit32(dst_addr: u64, dst_stride_pixels: u64,
                           src_addr: u64, src_stride_pixels: u64,
                           copy_w: u64, copy_h: u64):
    rt_fb_blit32(dst_addr, dst_stride_pixels, src_addr, src_stride_pixels, copy_w, copy_h)

fn framebuffer_host_fill32(dst_addr: u64, pixel_count: u64, color: u64):
    rt_fb_fill32(dst_addr, pixel_count, color)

fn framebuffer_blit32(dst_addr: u64, dst_stride_pixels: u64,
                      src_addr: u64, src_stride_pixels: u64,
                      copy_w: u64, copy_h: u64):
    framebuffer_host_blit32(dst_addr, dst_stride_pixels, src_addr, src_stride_pixels, copy_w, copy_h)

fn framebuffer_fill32(dst_addr: u64, pixel_count: u64, color: u64):
    framebuffer_host_fill32(dst_addr, pixel_count, color)
