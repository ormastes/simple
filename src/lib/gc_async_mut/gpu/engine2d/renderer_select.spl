# Renderer-variant selection seam (variants/ ui.renderer overlay).
#
# This is the CANONICAL (`default`) implementation, living in src. It returns
# the full backend preference order — identical to the historic
# backend_default_priority_order() body — so a `default`/`auto` build behaves
# exactly as before.
#
# The module name `std.gpu.engine2d.renderer_select` is the STABLE import. When
# config selects a non-default ui.renderer variant (e.g. `cpu`, `vulkan`,
# `metal`, `webgpu`), the resolver picks the mirrored file under
# variants/ui/renderer/<value>/std/gpu/engine2d/renderer_select.spl instead,
# which returns a target-specific order. All backends remain compiled in and the
# SIMPLE_2D_BACKEND env override + runtime fallback are unaffected; only the
# auto-detect preference order changes per build target.

fn renderer_priority_order() -> [text]:
    """Build-target backend preference order (default = full auto-detect)."""
    ["metal", "cuda", "rocm", "qualcomm", "vulkan", "directx", "opencl", "opengl", "intel", "webgpu", "cpu_simd", "software", "cpu"]
