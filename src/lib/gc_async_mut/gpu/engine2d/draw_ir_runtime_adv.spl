# Runtime host-queue companion for the core Draw IR executor.

use common.ui.draw_ir.{DrawIrBatch, simple_2d_draw_ir_adv_plan}
use common.ui.draw_ir_sdn.{sdn_to_draw_ir}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{Engine2dDrawIrAdvResult, engine2d_draw_ir_adv_batch, engine2d_draw_ir_adv_composition}
use std.gc_async_mut.gpu.engine2d.host_gpu_event_queue.{
    Engine2dHostGpuRuntimeDispatchResult,
    Engine2dHostGpuRuntimeDrainResult,
    Engine2dHostGpuRuntimeQueue,
    Engine2dHostGpuRuntimeSubmitResult
}
use std.gc_async_mut.gpu.engine2d.draw_ir_runtime_queue.{
    Engine2dDrawIrPayloadSummary,
    engine2d_draw_ir_payload_summary,
    engine2d_draw_ir_runtime_queue_dispatch
}

struct Engine2dDrawIrRuntimeQueueResult:
    render: Engine2dDrawIrAdvResult
    runtime_submit: Engine2dHostGpuRuntimeSubmitResult
    runtime_drain: Engine2dHostGpuRuntimeDrainResult
    runtime_dispatch: Engine2dHostGpuRuntimeDispatchResult
    queued_for_gpu: bool
    payload: Engine2dDrawIrPayloadSummary

fn engine2d_draw_ir_adv_apply_runtime_dispatch(engine: Engine2D, dispatch: Engine2dHostGpuRuntimeDispatchResult) -> Engine2dDrawIrAdvResult:
    if not dispatch.dispatched:
        return Engine2dDrawIrAdvResult(schema: "simple-draw-ir-v2", unit_id: "runtime-dispatch", selected_backend: "host", fallback_required: true, fallback_reason: dispatch.diagnostic, rendered_command_count: 0, skipped_command_count: 0, pixels: engine.read_pixels(), readback_source: "none", backend_handle: 0, device_identity: 0, readback_checksum: 0)
    engine2d_draw_ir_adv_composition(engine, sdn_to_draw_ir(dispatch.payload_text), true)

fn _engine2d_draw_ir_runtime_queue_submit_dispatch(batch: DrawIrBatch, selected_backend: text, command_count: i64, packet_bytes: i64, payload: Engine2dDrawIrPayloadSummary, queue: Engine2dHostGpuRuntimeQueue) -> Engine2dDrawIrRuntimeQueueResult:
    val dispatch_result = engine2d_draw_ir_runtime_queue_dispatch(batch, selected_backend, command_count, packet_bytes, payload, queue)
    val render = Engine2dDrawIrAdvResult(schema: batch.schema, unit_id: batch.batch_id, selected_backend: selected_backend, fallback_required: false, fallback_reason: dispatch_result.runtime_dispatch.diagnostic, rendered_command_count: 0, skipped_command_count: 0, pixels: [], readback_source: "none", backend_handle: 0, device_identity: 0, readback_checksum: 0)
    Engine2dDrawIrRuntimeQueueResult(render: render, runtime_submit: dispatch_result.runtime_submit, runtime_drain: dispatch_result.runtime_drain, runtime_dispatch: dispatch_result.runtime_dispatch, queued_for_gpu: dispatch_result.queued_for_gpu, payload: dispatch_result.payload)

fn engine2d_draw_ir_adv_batch_runtime_queue(engine: Engine2D, batch: DrawIrBatch, gpu_available: bool, queue: Engine2dHostGpuRuntimeQueue) -> Engine2dDrawIrRuntimeQueueResult:
    val plan = simple_2d_draw_ir_adv_plan(batch, gpu_available)
    val packet_bytes = plan.command_count * 64
    val payload = engine2d_draw_ir_payload_summary(batch, packet_bytes)
    val queue_result = _engine2d_draw_ir_runtime_queue_submit_dispatch(batch, plan.selected_backend, plan.command_count, packet_bytes, payload, queue)
    var render = Engine2dDrawIrAdvResult(schema: batch.schema, unit_id: batch.batch_id, selected_backend: "host", fallback_required: true, fallback_reason: "runtime queue pending", rendered_command_count: 0, skipped_command_count: 0, pixels: engine.read_pixels(), readback_source: "none", backend_handle: 0, device_identity: 0, readback_checksum: 0)
    if queue_result.queued_for_gpu:
        render = engine2d_draw_ir_adv_apply_runtime_dispatch(engine, queue_result.runtime_dispatch)
    else:
        render = engine2d_draw_ir_adv_batch(engine, batch, gpu_available)
    Engine2dDrawIrRuntimeQueueResult(render: render, runtime_submit: queue_result.runtime_submit, runtime_drain: queue_result.runtime_drain, runtime_dispatch: queue_result.runtime_dispatch, queued_for_gpu: queue_result.queued_for_gpu, payload: payload)

fn engine2d_draw_ir_adv_batch_runtime_queue_dispatch_only(batch: DrawIrBatch, gpu_available: bool, queue: Engine2dHostGpuRuntimeQueue) -> Engine2dDrawIrRuntimeQueueResult:
    val plan = simple_2d_draw_ir_adv_plan(batch, gpu_available)
    val packet_bytes = plan.command_count * 64
    val payload = engine2d_draw_ir_payload_summary(batch, packet_bytes)
    _engine2d_draw_ir_runtime_queue_submit_dispatch(batch, plan.selected_backend, plan.command_count, packet_bytes, payload, queue)

export Engine2dDrawIrRuntimeQueueResult
export engine2d_draw_ir_adv_apply_runtime_dispatch
export engine2d_draw_ir_adv_batch_runtime_queue
export engine2d_draw_ir_adv_batch_runtime_queue_dispatch_only
