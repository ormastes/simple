# CUDA PTX companion for the shared font-atlas composite contract.

fn cuda_font_atlas_composite_ptx_source() -> text:
    "\n.visible .entry simple_font_atlas_composite_v1_u32(\n" +
    "    .param .u64 param_atlas,\n    .param .u64 param_dst,\n" +
    "    .param .s64 param_atlas_width,\n    .param .s64 param_atlas_height,\n    .param .s64 param_atlas_count,\n" +
    "    .param .s64 param_atlas_x,\n    .param .s64 param_atlas_y,\n    .param .s64 param_quad_width,\n    .param .s64 param_quad_height,\n" +
    "    .param .s64 param_dst_width,\n    .param .s64 param_dst_height,\n    .param .s64 param_dst_count,\n" +
    "    .param .s64 param_dst_x,\n    .param .s64 param_dst_y,\n    .param .s64 param_color\n) {\n" +
    "    .reg .pred %p<12>;\n    .reg .u32 %r<28>;\n    .reg .s64 %rd<32>;\n" +
    "    mov.u32 %r0, %ctaid.x;\n    mov.u32 %r1, %ntid.x;\n    mov.u32 %r2, %tid.x;\n    mad.lo.u32 %r3, %r0, %r1, %r2;\n    cvt.s64.u32 %rd0, %r3;\n" +
    "    ld.param.u64 %rd1, [param_atlas];\n    ld.param.u64 %rd2, [param_dst];\n" +
    "    ld.param.s64 %rd3, [param_atlas_width];\n    ld.param.s64 %rd4, [param_atlas_height];\n    ld.param.s64 %rd5, [param_atlas_count];\n" +
    "    ld.param.s64 %rd6, [param_atlas_x];\n    ld.param.s64 %rd7, [param_atlas_y];\n    ld.param.s64 %rd8, [param_quad_width];\n    ld.param.s64 %rd9, [param_quad_height];\n" +
    "    ld.param.s64 %rd10, [param_dst_width];\n    ld.param.s64 %rd11, [param_dst_height];\n    ld.param.s64 %rd12, [param_dst_count];\n" +
    "    ld.param.s64 %rd13, [param_dst_x];\n    ld.param.s64 %rd14, [param_dst_y];\n    ld.param.s64 %rd15, [param_color];\n" +
    "    setp.le.s64 %p0, %rd3, 0;\n    setp.le.s64 %p1, %rd4, 0;\n    or.pred %p0, %p0, %p1;\n    setp.le.s64 %p1, %rd5, 0;\n    or.pred %p0, %p0, %p1;\n" +
    "    setp.le.s64 %p1, %rd8, 0;\n    or.pred %p0, %p0, %p1;\n    setp.le.s64 %p1, %rd9, 0;\n    or.pred %p0, %p0, %p1;\n" +
    "    setp.le.s64 %p1, %rd10, 0;\n    or.pred %p0, %p0, %p1;\n    setp.le.s64 %p1, %rd11, 0;\n    or.pred %p0, %p0, %p1;\n    setp.le.s64 %p1, %rd12, 0;\n    or.pred %p0, %p0, %p1;\n" +
    "    setp.lt.s64 %p1, %rd6, 0;\n    or.pred %p0, %p0, %p1;\n    setp.lt.s64 %p1, %rd7, 0;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    setp.gt.s64 %p0, %rd3, 2147483647;\n    setp.gt.s64 %p1, %rd4, 2147483647;\n    or.pred %p0, %p0, %p1;\n    setp.gt.s64 %p1, %rd8, 2147483647;\n    or.pred %p0, %p0, %p1;\n    setp.gt.s64 %p1, %rd9, 2147483647;\n    or.pred %p0, %p0, %p1;\n    setp.gt.s64 %p1, %rd10, 2147483647;\n    or.pred %p0, %p0, %p1;\n    setp.gt.s64 %p1, %rd11, 2147483647;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    mul.lo.s64 %rd16, %rd3, %rd4;\n    setp.ne.s64 %p0, %rd5, %rd16;\n    mul.lo.s64 %rd17, %rd10, %rd11;\n    setp.ne.s64 %p1, %rd12, %rd17;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    neg.s64 %rd18, %rd8;\n    setp.lt.s64 %p0, %rd13, %rd18;\n    neg.s64 %rd19, %rd9;\n    setp.lt.s64 %p1, %rd14, %rd19;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd13, %rd10;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd14, %rd11;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    mul.lo.s64 %rd20, %rd8, %rd9;\n    setp.ge.s64 %p0, %rd0, %rd20;\n    @%p0 bra done_font;\n" +
    "    rem.s64 %rd21, %rd0, %rd8;\n    div.s64 %rd22, %rd0, %rd8;\n    add.s64 %rd23, %rd6, %rd21;\n    add.s64 %rd24, %rd7, %rd22;\n" +
    "    setp.lt.s64 %p0, %rd23, 0;\n    setp.lt.s64 %p1, %rd24, 0;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd23, %rd3;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd24, %rd4;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    mad.lo.s64 %rd25, %rd24, %rd3, %rd23;\n    setp.lt.s64 %p0, %rd25, 0;\n    setp.ge.s64 %p1, %rd25, %rd5;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    add.s64 %rd26, %rd21, %rd13;\n    add.s64 %rd27, %rd22, %rd14;\n    setp.lt.s64 %p0, %rd26, 0;\n    setp.lt.s64 %p1, %rd27, 0;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd26, %rd10;\n    or.pred %p0, %p0, %p1;\n    setp.ge.s64 %p1, %rd27, %rd11;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    mad.lo.s64 %rd28, %rd27, %rd10, %rd26;\n    setp.lt.s64 %p0, %rd28, 0;\n    setp.ge.s64 %p1, %rd28, %rd12;\n    or.pred %p0, %p0, %p1;\n    @%p0 bra done_font;\n" +
    "    mul.lo.s64 %rd29, %rd25, 4;\n    add.s64 %rd29, %rd1, %rd29;\n    ld.global.u32 %r4, [%rd29];\n    shr.u32 %r5, %r4, 24;\n" +
    "    cvt.u32.u64 %r6, %rd15;\n    shr.u32 %r7, %r6, 24;\n    mul.lo.u32 %r8, %r5, %r7;\n    add.u32 %r8, %r8, 127;\n    div.u32 %r8, %r8, 255;\n    setp.eq.u32 %p0, %r8, 0;\n    @%p0 bra done_font;\n" +
    "    mul.lo.s64 %rd30, %rd28, 4;\n    add.s64 %rd30, %rd2, %rd30;\n    ld.global.u32 %r9, [%rd30];\n    shr.u32 %r10, %r9, 24;\n    sub.u32 %r11, 255, %r8;\n" +
    "    mul.lo.u32 %r12, %r10, %r11;\n    div.u32 %r12, %r12, 255;\n    add.u32 %r12, %r12, %r8;\n" +
    "    shr.u32 %r13, %r6, 16;\n    and.b32 %r13, %r13, 255;\n    mul.lo.u32 %r13, %r13, %r8;\n    shr.u32 %r14, %r9, 16;\n    and.b32 %r14, %r14, 255;\n    mad.lo.u32 %r13, %r14, %r11, %r13;\n    div.u32 %r13, %r13, 255;\n" +
    "    shr.u32 %r14, %r6, 8;\n    and.b32 %r14, %r14, 255;\n    mul.lo.u32 %r14, %r14, %r8;\n    shr.u32 %r15, %r9, 8;\n    and.b32 %r15, %r15, 255;\n    mad.lo.u32 %r14, %r15, %r11, %r14;\n    div.u32 %r14, %r14, 255;\n" +
    "    and.b32 %r15, %r6, 255;\n    mul.lo.u32 %r15, %r15, %r8;\n    and.b32 %r16, %r9, 255;\n    mad.lo.u32 %r15, %r16, %r11, %r15;\n    div.u32 %r15, %r15, 255;\n" +
    "    shl.b32 %r12, %r12, 24;\n    shl.b32 %r13, %r13, 16;\n    shl.b32 %r14, %r14, 8;\n    or.b32 %r17, %r12, %r13;\n    or.b32 %r17, %r17, %r14;\n    or.b32 %r17, %r17, %r15;\n    st.global.u32 [%rd30], %r17;\n" +
    "done_font:\n    ret;\n}\n"

