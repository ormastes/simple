# 2D Engine - WebGPU Backend (V3 Browser Raster Path)
#
# M7 of the V3 Simple Browser milestones: add a GPU raster path so the
# `browser_compositor_backend` is not the only rendering option. This
# backend keeps a CPU-side ARGB pixel buffer (identical layout and draw
# algorithms to `backend_cpu` / `backend_virtio_gpu`) and, on present(),
# uploads the buffer to a WebGPU surface via the `rt_webgpu_*` SFFI.
#
#
# The backend is intentionally constructable without a real WebGPU
# runtime so unit specs and bootstrap builds remain hermetic. The
# `rt_webgpu_*` externs are weak stubs in the runtime that return
# `false` / `0` when no adapter is present; `init()` falls through to
# the CPU draw path and `present()` becomes a no-op.
#
# Usage:
#   use std.gpu.engine2d.backend_webgpu.{WebGpuBackend}
#
#   var backend = WebGpuBackend.create()
#   backend.init(800, 600)
#   var engine = Engine2D(backend: backend, w: 800, h: 600)

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend, lerp_color}
use std.gpu.engine2d.glyph.{glyph_data, glyph_height, glyph_advance, render_text_to_buffer}
use std.gpu.engine2d.helpers_text.{text_blit_buffer}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.nogc_sync_mut.gpu.engine2d.webgpu_sffi.{
    webgpu_sffi_is_available, webgpu_sffi_init, webgpu_sffi_shutdown,
    webgpu_sffi_create_surface, webgpu_sffi_destroy_surface,
    webgpu_sffi_upload_pixels, webgpu_sffi_present,
    webgpu_sffi_compute_draw,
    webgpu_sffi_adapter_count, webgpu_sffi_adapter_name, webgpu_sffi_adapter_is_cpu
}

# ============================================================================
# Availability Check
# ============================================================================

fn webgpu_available() -> bool:
    """Check if a WebGPU adapter is reachable from this process.

    Returns false when the `rt_webgpu_*` runtime stubs are compiled in
    (the default outside a real browser host). Engine2D auto-detection
    should skip this backend when the return value is false.
    """
    webgpu_sffi_is_available()

# ============================================================================
# Adapter Enumeration and Strict Probe
# ============================================================================

class WebGpuAdapterInfo:
    """Metadata for a single enumerated WebGPU adapter."""
    index: i64
    name: text
    is_cpu: bool

class WebGpuProbeResult:
    """Result of webgpu_probe_adapter().

    status values: "Ok" | "Failed" | "Fallback"
    - Ok: a discrete or integrated GPU adapter was selected
    - Failed: no adapters found at all
    - Fallback: only a CPU/software adapter was found (strict mode rejects this)
    """
    status: text
    adapter_count: i64
    selected_adapter: text
    fell_through_to_cpu: bool
    fallback_reason: text

class WebGpuFallbackError:
    """Typed error for AC-5: no GPU adapter found or only CPU fallback available.

    Returned instead of silently continuing on the CPU path.
    """
    reason: text
    adapter_count: i64

fn webgpu_probe_adapter() -> WebGpuProbeResult:
    """Enumerate WebGPU adapters via wgpuInstanceRequestAdapter.

    Logs the selected backend name. Returns Failed if no adapters exist.
    Returns Fallback (not Ok) if the only available adapter is a CPU/software
    renderer — callers in strict mode must treat Fallback as an error.

    This function never silently falls through to CPU rendering.
    """
    if not webgpu_sffi_is_available():
        return WebGpuProbeResult(
            status: "Failed",
            adapter_count: 0,
            selected_adapter: "",
            fell_through_to_cpu: false,
            fallback_reason: "WebGPU runtime not available"
        )

    val count = webgpu_sffi_adapter_count()
    if count == 0:
        return WebGpuProbeResult(
            status: "Failed",
            adapter_count: 0,
            selected_adapter: "",
            fell_through_to_cpu: false,
            fallback_reason: "no adapters enumerated"
        )

    # Prefer the first non-CPU adapter
    var selected_index: i64 = -1
    var i: i64 = 0
    while i < count:
        if not webgpu_sffi_adapter_is_cpu(i):
            selected_index = i
            i = count  # break
        i = i + 1

    if selected_index < 0:
        # Only CPU/software adapters found — strict error, not silent fallback
        val cpu_name = webgpu_sffi_adapter_name(0)
        return WebGpuProbeResult(
            status: "Fallback",
            adapter_count: count,
            selected_adapter: cpu_name,
            fell_through_to_cpu: true,
            fallback_reason: "only CPU/software adapter available"
        )

    val adapter_name = webgpu_sffi_adapter_name(selected_index)
    WebGpuProbeResult(
        status: "Ok",
        adapter_count: count,
        selected_adapter: adapter_name,
        fell_through_to_cpu: false,
        fallback_reason: ""
    )

fn webgpu_strict_init_check() -> WebGpuFallbackError:
    """Return a WebGpuFallbackError if no real GPU adapter is available.

    Call before init() in strict mode. Empty reason means no error.
    """
    val probe = webgpu_probe_adapter()
    if probe.status == "Ok":
        WebGpuFallbackError(reason: "", adapter_count: probe.adapter_count)
    else:
        WebGpuFallbackError(reason: probe.fallback_reason, adapter_count: probe.adapter_count)

# ============================================================================
# WebGPU Backend
# ============================================================================

class WebGpuBackend:
    """2D RenderBackend that renders into a CPU-side ARGB buffer and
    uploads each frame to a WebGPU surface on `present()`.

    The draw operations use the same scanline / Bresenham / midpoint
    algorithms as the CPU backend. This guarantees pixel parity with
    the software path by construction, satisfying the M7 <=1% pixel
    delta requirement even before the GPU compute path lands.

    The `surface` handle is opaque and managed entirely by the host
    runtime. On systems without a WebGPU adapter it is 0 and the
    `present()` call becomes a no-op - draws still land correctly in
    `read_pixels()` so compositor pipelines and unit tests keep
    working.
    """

    buf: [u32]
    w: i32
    h: i32
    surface: i64
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool
    gpu_ready: bool
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32

    static fn create() -> WebGpuBackend:
        """Create an uninitialized WebGPU backend. Call init() before drawing."""
        WebGpuBackend(
            buf: [],
            w: 0,
            h: 0,
            surface: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false,
            gpu_ready: false,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0
        )

fn _wgpu_mask_blocks(backend: WebGpuBackend, x: i32, y: i32) -> bool:
    if backend.mask_buf.len() == 0:
        return false
    val mi = y * backend.mask_w + x
    if mi < 0 or mi >= backend.mask_buf.len():
        return false
    backend.mask_buf[mi] == 0u8

impl RenderBackend for WebGpuBackend:

    fn name() -> text:
        "webgpu"

    me init(width: i32, height: i32) -> bool:
        self.w = width
        self.h = height
        val total = width * height
        self.buf = [0u32; total]
        var i = 0
        while i < total:
            self.buf[i] = rgb(0, 0, 0)
            i = i + 1
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        # Attempt to bring the WebGPU surface online. On hosts without
        # a real adapter, `gpu_ready` stays false and present() becomes
        # a no-op, but the CPU draw path continues to function.
        self.gpu_ready = false
        if webgpu_sffi_is_available():
            if webgpu_sffi_init():
                val h = webgpu_sffi_create_surface(width, height)
                if h != 0:
                    self.surface = h
                    self.gpu_ready = true
        self.initialized = true
        true

    me shutdown():
        if self.gpu_ready:
            if self.surface != 0:
                webgpu_sffi_destroy_surface(self.surface)
                self.surface = 0
            webgpu_sffi_shutdown()
            self.gpu_ready = false
        self.buf = []
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.initialized = false

    # -- Clipping helpers --

    me in_clip(x: i32, y: i32) -> bool:
        if not self.clip_enabled:
            return x >= 0 and x < self.w and y >= 0 and y < self.h
        x >= self.clip_x and x < (self.clip_x + self.clip_w) and
            y >= self.clip_y and y < (self.clip_y + self.clip_h)

    me put_pixel(x: i32, y: i32, color: u32):
        if self.in_clip(x, y):
            if _wgpu_mask_blocks(self, x, y):
                return
            self.buf[y * self.w + x] = color

    # -- Clear --

    me clear(color: u32):
        if self.gpu_ready and webgpu_sffi_compute_draw(self.surface, 0, 0, 0, self.w, self.h, color):
            return
        var i = 0
        val total = self.w * self.h
        while i < total:
            self.buf[i] = color
            i = i + 1

    # -- Rectangles --

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        var i = 0
        while i < w:
            self.put_pixel(x + i, y, color)
            self.put_pixel(x + i, y + h - 1, color)
            i = i + 1
        var j = 0
        while j < h:
            self.put_pixel(x, y + j, color)
            self.put_pixel(x + w - 1, y + j, color)
            j = j + 1

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        if self.gpu_ready and webgpu_sffi_compute_draw(self.surface, 1, x, y, w, h, color):
            return
        var yy = 0
        while yy < h:
            var xx = 0
            while xx < w:
                self.put_pixel(x + xx, y + yy, color)
                xx = xx + 1
            yy = yy + 1

    # -- Lines --

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        # Bresenham line with optional thickness via adjacent-pixel stamp.
        var x = x1
        var y = y1
        val dx = if x2 > x1 then x2 - x1 else x1 - x2
        val dy = if y2 > y1 then y2 - y1 else y1 - y2
        val sx = if x1 < x2 then 1 else -1
        val sy = if y1 < y2 then 1 else -1
        var err = dx - dy
        val t = if thickness < 1 then 1 else thickness
        while true:
            var ty = 0
            while ty < t:
                var tx = 0
                while tx < t:
                    self.put_pixel(x + tx, y + ty, color)
                    tx = tx + 1
                ty = ty + 1
            if x == x2 and y == y2:
                return
            val e2 = err * 2
            if e2 > -dy:
                err = err - dy
                x = x + sx
            if e2 < dx:
                err = err + dx
                y = y + sy

    # -- Circles --

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        # Midpoint circle algorithm (outline only).
        if r <= 0:
            return
        var x = r
        var y = 0
        var err = 1 - r
        while x >= y:
            self.put_pixel(cx + x, cy + y, color)
            self.put_pixel(cx + y, cy + x, color)
            self.put_pixel(cx - y, cy + x, color)
            self.put_pixel(cx - x, cy + y, color)
            self.put_pixel(cx - x, cy - y, color)
            self.put_pixel(cx - y, cy - x, color)
            self.put_pixel(cx + y, cy - x, color)
            self.put_pixel(cx + x, cy - y, color)
            y = y + 1
            if err < 0:
                err = err + 2 * y + 1
            else:
                x = x - 1
                err = err + 2 * (y - x) + 1

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if r <= 0:
            return
        var dy = -r
        while dy <= r:
            var dx = -r
            while dx <= r:
                if dx * dx + dy * dy <= r * r:
                    self.put_pixel(cx + dx, cy + dy, color)
                dx = dx + 1
            dy = dy + 1

    # -- Advanced shapes --

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        var r = radius
        if r > w / 2:
            r = w / 2
        if r > h / 2:
            r = h / 2
        var i = 0
        while i < w - 2 * r:
            self.put_pixel(x + r + i, y, color)
            self.put_pixel(x + r + i, y + h - 1, color)
            i = i + 1
        var j = 0
        while j < h - 2 * r:
            self.put_pixel(x, y + r + j, color)
            self.put_pixel(x + w - 1, y + r + j, color)
            j = j + 1
        var cx = r
        var cy = 0
        var err = 1 - r
        while cx >= cy:
            self.put_pixel(x + r - cx, y + r - cy, color)
            self.put_pixel(x + r - cy, y + r - cx, color)
            self.put_pixel(x + w - 1 - r + cx, y + r - cy, color)
            self.put_pixel(x + w - 1 - r + cy, y + r - cx, color)
            self.put_pixel(x + r - cx, y + h - 1 - r + cy, color)
            self.put_pixel(x + r - cy, y + h - 1 - r + cx, color)
            self.put_pixel(x + w - 1 - r + cx, y + h - 1 - r + cy, color)
            self.put_pixel(x + w - 1 - r + cy, y + h - 1 - r + cx, color)
            cy = cy + 1
            if err < 0:
                err = err + 2 * cy + 1
            else:
                cx = cx - 1
                err = err + 2 * (cy - cx) + 1

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Bounding-box scan with edge-function test (same approach used
        # by backend_cpu).
        val min_x = min3(x1, x2, x3)
        val max_x = max3(x1, x2, x3)
        val min_y = min3(y1, y2, y3)
        val max_y = max3(y1, y2, y3)
        var py = min_y
        while py <= max_y:
            var px = min_x
            while px <= max_x:
                val w0 = (x2 - x1) * (py - y1) - (y2 - y1) * (px - x1)
                val w1 = (x3 - x2) * (py - y2) - (y3 - y2) * (px - x2)
                val w2 = (x1 - x3) * (py - y3) - (y1 - y3) * (px - x3)
                if (w0 >= 0 and w1 >= 0 and w2 >= 0) or (w0 <= 0 and w1 <= 0 and w2 <= 0):
                    self.put_pixel(px, py, color)
                px = px + 1
            py = py + 1

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if w <= 0 or h <= 0:
            return
        var yy = 0
        while yy < h:
            val t = if h > 1 then yy * 255 / (h - 1) else 0
            val c = lerp_color(top_color, bottom_color, t)
            var xx = 0
            while xx < w:
                self.put_pixel(x + xx, y + yy, c)
                xx = xx + 1
            yy = yy + 1

    # -- Text --

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        render_text_to_buffer(self.buf, self.w, self.h, x, y, text_val, color, font_size)

    # -- Image blitting --

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if w <= 0 or h <= 0:
            return
        var yy = 0
        while yy < h:
            var xx = 0
            while xx < w:
                self.put_pixel(x + xx, y + yy, pixels[yy * w + xx])
                xx = xx + 1
            yy = yy + 1

    # -- Clipping --

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h
        self.clip_enabled = false

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    # -- Present --

    me present():
        # On hosts with a real WebGPU surface this uploads the CPU-side
        # ARGB buffer to the surface and presents it. On hosts without
        # an adapter this is a no-op - `read_pixels()` still returns
        # the drawn frame for compositor consumers.
        if self.gpu_ready and self.surface != 0:
            webgpu_sffi_upload_pixels(self.surface, self.buf, self.w, self.h)
            webgpu_sffi_present(self.surface)

    # -- Readback --

    fn read_pixels() -> [u32]:
        self.buf

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

# ============================================================================
# Engine2DExtended - per-pixel text background
# ============================================================================

impl Engine2DExtended for WebGpuBackend:

    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        val text_buf = text_blit_buffer(text_val, fg, bg, font_size)
        if text_buf.is_empty():
            return
        self.draw_image(x, y, text_buf.width, text_buf.height, text_buf.pixels)

# ============================================================================
# Small helpers
# ============================================================================

fn min3(a: i32, b: i32, c: i32) -> i32:
    var m = a
    if b < m:
        m = b
    if c < m:
        m = c
    m

fn max3(a: i32, b: i32, c: i32) -> i32:
    var m = a
    if b > m:
        m = b
    if c > m:
        m = c
    m
