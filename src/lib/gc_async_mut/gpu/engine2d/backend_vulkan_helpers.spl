# 2D Engine — Vulkan Backend Helpers
#
# Extension impl for VulkanBackend: compute dispatch methods and text fallback.
# Free functions: push-constant packing, pixel/byte conversion, type helpers.
#
# Depends on: backend_vulkan.spl (VulkanBackend class)
#             backend_vulkan_glsl.spl (shader sources, accessed via main init)

use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gpu.engine2d.glyph.{render_text_to_buffer}
use std.nogc_async_mut.gpu.engine2d.ffi_vulkan.{
    vulkan_ffi_create_descriptor_set, vulkan_ffi_bind_buffer,
    vulkan_ffi_destroy_descriptor_set, vulkan_ffi_begin_compute,
    vulkan_ffi_bind_pipeline, vulkan_ffi_bind_descriptors,
    vulkan_ffi_push_constants, vulkan_ffi_dispatch,
    vulkan_ffi_end_compute, vulkan_ffi_submit_and_wait,
    vulkan_ffi_copy_from_buffer, vulkan_ffi_copy_to_buffer,
    vulkan_ffi_wait_idle
}

# ============================================================================
# Vulkan FFI (re-declared for use in this module)
# ============================================================================

# ============================================================================
# Push Constant Size (must match backend_vulkan.spl)
# ============================================================================

val VK_PUSH_CONSTANT_SIZE: i64 = 64

# ============================================================================
# Compute Dispatch Methods
# ============================================================================

impl VulkanBackend:

    me _dispatch_compute(pipe: i64, push_data: [u8], gx: i64, gy: i64, gz: i64):
        """Dispatch a compute shader with the framebuffer bound at binding 0."""
        val desc = vulkan_ffi_create_descriptor_set(pipe)
        vulkan_ffi_bind_buffer(desc, 0, self.d_framebuffer)
        val cmd = vulkan_ffi_begin_compute()
        vulkan_ffi_bind_pipeline(cmd, pipe)
        vulkan_ffi_bind_descriptors(cmd, desc)
        vulkan_ffi_push_constants(cmd, pipe, push_data)
        vulkan_ffi_dispatch(cmd, gx, gy, gz)
        vulkan_ffi_end_compute(cmd)
        vulkan_ffi_submit_and_wait(cmd)
        vulkan_ffi_destroy_descriptor_set(desc)

    me _dispatch_blit_compute(pipe: i64, d_src: i64, push_data: [u8], gx: i64, gy: i64, gz: i64):
        """Dispatch blit compute shader with framebuffer at binding 0 and source at binding 1."""
        val desc = vulkan_ffi_create_descriptor_set(pipe)
        vulkan_ffi_bind_buffer(desc, 0, self.d_framebuffer)
        vulkan_ffi_bind_buffer(desc, 1, d_src)
        val cmd = vulkan_ffi_begin_compute()
        vulkan_ffi_bind_pipeline(cmd, pipe)
        vulkan_ffi_bind_descriptors(cmd, desc)
        vulkan_ffi_push_constants(cmd, pipe, push_data)
        vulkan_ffi_dispatch(cmd, gx, gy, gz)
        vulkan_ffi_end_compute(cmd)
        vulkan_ffi_submit_and_wait(cmd)
        vulkan_ffi_destroy_descriptor_set(desc)

    me _gpu_draw_text_fallback(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        """Render text on CPU and upload affected region to GPU.

        For production use, a glyph atlas would be pre-uploaded to GPU memory
        and sampled by a compute shader. This fallback is acceptable
        for low-frequency text draws (UI labels, debug overlays).
        """
        # Ensure host buffer is current
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes: [u8] = [0u8; fb_size]
            vulkan_ffi_copy_from_buffer(fb_bytes, self.d_framebuffer, 0)
            vulkan_ffi_wait_idle()
            _bytes_to_pixels(fb_bytes, self.host_buf, self.w * self.h)

        # Render glyphs into host buffer using shared glyph module
        render_text_to_buffer(self.host_buf, self.w, self.h, x, y, text_val, color, font_size)

        # Upload entire host buffer back to GPU
        val fb_size = _i64(self.w) * _i64(self.h) * 4
        val upload_bytes = _pixels_to_bytes(self.host_buf, _i64(self.w) * _i64(self.h))
        vulkan_ffi_copy_to_buffer(self.d_framebuffer, upload_bytes, 0)

# ============================================================================
# Type Conversion Helpers
# ============================================================================

fn _i64(v: i32) -> i64:
    v as i64

fn _i32_to_u32(v: i32) -> u32:
    v as u32

fn _u32_to_u8(v: u32) -> u8:
    v as u8

fn _u8_to_u32(v: u8) -> u32:
    v as u32

fn _bool_to_i32(v: bool) -> i32:
    if v: 1
    else: 0

# ============================================================================
# Push Constant Packing
#
# Push constants are packed as [u8] arrays of i32 values in little-endian.
# Each kernel's push constant layout is documented in the GLSL source.
# ============================================================================

fn _pack_i32_le(buf: [u8], offset: i32, value: i32):
    """Pack an i32 into buf at byte offset in little-endian order."""
    val v = _i32_to_u32(value)
    buf[offset] = _u32_to_u8(v & 0xFF)
    buf[offset + 1] = _u32_to_u8((v >> 8) & 0xFF)
    buf[offset + 2] = _u32_to_u8((v >> 16) & 0xFF)
    buf[offset + 3] = _u32_to_u8((v >> 24) & 0xFF)

fn _pack_u32_le(buf: [u8], offset: i32, value: u32):
    """Pack a u32 into buf at byte offset in little-endian order."""
    buf[offset] = _u32_to_u8(value & 0xFF)
    buf[offset + 1] = _u32_to_u8((value >> 8) & 0xFF)
    buf[offset + 2] = _u32_to_u8((value >> 16) & 0xFF)
    buf[offset + 3] = _u32_to_u8((value >> 24) & 0xFF)

fn _pack_clear_pc(color: u32, fb_w: i32, fb_h: i32) -> [u8]:
    """Push constants for clear kernel: color, fb_w, fb_h."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_u32_le(buf, 0, color)
    _pack_i32_le(buf, 4, fb_w)
    _pack_i32_le(buf, 8, fb_h)
    buf

fn _pack_rect_pc(x: i32, y: i32, w: i32, h: i32, color: u32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for rect kernels."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x)
    _pack_i32_le(buf, 4, y)
    _pack_i32_le(buf, 8, w)
    _pack_i32_le(buf, 12, h)
    _pack_u32_le(buf, 16, color)
    _pack_i32_le(buf, 20, fb_w)
    _pack_i32_le(buf, 24, fb_h)
    _pack_i32_le(buf, 28, clip_x)
    _pack_i32_le(buf, 32, clip_y)
    _pack_i32_le(buf, 36, clip_w)
    _pack_i32_le(buf, 40, clip_h)
    _pack_i32_le(buf, 44, _bool_to_i32(clip_enabled))
    buf

fn _pack_line_pc(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for line kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x1)
    _pack_i32_le(buf, 4, y1)
    _pack_i32_le(buf, 8, x2)
    _pack_i32_le(buf, 12, y2)
    _pack_u32_le(buf, 16, color)
    _pack_i32_le(buf, 20, thickness)
    _pack_i32_le(buf, 24, fb_w)
    _pack_i32_le(buf, 28, fb_h)
    _pack_i32_le(buf, 32, clip_x)
    _pack_i32_le(buf, 36, clip_y)
    _pack_i32_le(buf, 40, clip_w)
    _pack_i32_le(buf, 44, clip_h)
    _pack_i32_le(buf, 48, _bool_to_i32(clip_enabled))
    buf

fn _pack_circle_pc(cx: i32, cy: i32, r: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for circle kernels."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, cx)
    _pack_i32_le(buf, 4, cy)
    _pack_i32_le(buf, 8, r)
    _pack_u32_le(buf, 12, color)
    _pack_i32_le(buf, 16, fb_w)
    _pack_i32_le(buf, 20, fb_h)
    _pack_i32_le(buf, 24, filled)
    _pack_i32_le(buf, 28, clip_x)
    _pack_i32_le(buf, 32, clip_y)
    _pack_i32_le(buf, 36, clip_w)
    _pack_i32_le(buf, 40, clip_h)
    _pack_i32_le(buf, 44, _bool_to_i32(clip_enabled))
    buf

fn _pack_rounded_rect_pc(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for rounded rect kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x)
    _pack_i32_le(buf, 4, y)
    _pack_i32_le(buf, 8, w)
    _pack_i32_le(buf, 12, h)
    _pack_i32_le(buf, 16, radius)
    _pack_u32_le(buf, 20, color)
    _pack_i32_le(buf, 24, fb_w)
    _pack_i32_le(buf, 28, fb_h)
    _pack_i32_le(buf, 32, clip_x)
    _pack_i32_le(buf, 36, clip_y)
    _pack_i32_le(buf, 40, clip_w)
    _pack_i32_le(buf, 44, clip_h)
    _pack_i32_le(buf, 48, _bool_to_i32(clip_enabled))
    buf

fn _pack_triangle_pc(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, fb_w: i32, fb_h: i32, min_x: i32, min_y: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for triangle kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x1)
    _pack_i32_le(buf, 4, y1)
    _pack_i32_le(buf, 8, x2)
    _pack_i32_le(buf, 12, y2)
    _pack_i32_le(buf, 16, x3)
    _pack_i32_le(buf, 20, y3)
    _pack_u32_le(buf, 24, color)
    _pack_i32_le(buf, 28, fb_w)
    _pack_i32_le(buf, 32, fb_h)
    _pack_i32_le(buf, 36, min_x)
    _pack_i32_le(buf, 40, min_y)
    _pack_i32_le(buf, 44, clip_x)
    _pack_i32_le(buf, 48, clip_y)
    _pack_i32_le(buf, 52, clip_w)
    _pack_i32_le(buf, 56, clip_h)
    _pack_i32_le(buf, 60, _bool_to_i32(clip_enabled))
    buf

fn _pack_gradient_pc(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for gradient rect kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x)
    _pack_i32_le(buf, 4, y)
    _pack_i32_le(buf, 8, w)
    _pack_i32_le(buf, 12, h)
    _pack_u32_le(buf, 16, top_color)
    _pack_u32_le(buf, 20, bottom_color)
    _pack_i32_le(buf, 24, fb_w)
    _pack_i32_le(buf, 28, fb_h)
    _pack_i32_le(buf, 32, clip_x)
    _pack_i32_le(buf, 36, clip_y)
    _pack_i32_le(buf, 40, clip_w)
    _pack_i32_le(buf, 44, clip_h)
    _pack_i32_le(buf, 48, _bool_to_i32(clip_enabled))
    buf

fn _pack_blit_pc(x: i32, y: i32, w: i32, h: i32, fb_w: i32, fb_h: i32) -> [u8]:
    """Push constants for blit kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x)
    _pack_i32_le(buf, 4, y)
    _pack_i32_le(buf, 8, w)
    _pack_i32_le(buf, 12, h)
    _pack_i32_le(buf, 16, fb_w)
    _pack_i32_le(buf, 20, fb_h)
    buf

# ============================================================================
# Byte / Pixel Conversion
# ============================================================================

fn _pixels_to_bytes(pixels: [u32], count: i64) -> [u8]:
    """Convert a [u32] pixel array to [u8] little-endian byte array."""
    var bytes: [u8] = [0u8; count * 4]
    var i: i64 = 0
    while i < count:
        val p = pixels[i]
        val off = i * 4
        bytes[off] = _u32_to_u8(p & 0xFF)
        bytes[off + 1] = _u32_to_u8((p >> 8) & 0xFF)
        bytes[off + 2] = _u32_to_u8((p >> 16) & 0xFF)
        bytes[off + 3] = _u32_to_u8((p >> 24) & 0xFF)
        i = i + 1
    bytes

fn _bytes_to_pixels(bytes: [u8], pixels: [u32], count: i32):
    """Convert a [u8] little-endian byte array back to [u32] pixel array."""
    var i = 0
    while i < count:
        val off = i * 4
        val b0 = _u8_to_u32(bytes[off])
        val b1 = _u8_to_u32(bytes[off + 1])
        val b2 = _u8_to_u32(bytes[off + 2])
        val b3 = _u8_to_u32(bytes[off + 3])
        pixels[i] = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
        i = i + 1
