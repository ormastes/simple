"""2D Engine — DirectX Backend (DXVK compatibility on Linux, native D3D11 on Windows).

On Linux: routes D3D11 device/swapchain semantics through dxvk_d3d11
(DXVK → Vulkan translation) using the local build/dx/prefix or system
Vulkan ICD. Platform probe selects the expected leaf evidence string.

On Windows: queues the receipt-eligible CLEAR/FILL_RECT/opaque IMAGE subset
and executes it through one checked native D3D11 frame/readback
hook. Every other operation remains available through SoftwareBackend but
poisons native receipt eligibility for that frame.

The SoftwareBackend mirror preserves the complete RenderBackend surface. On
Windows, only a bounded clear/fill/opaque-image subset is eligible; an image
may initialize the target only when full-sized, while a prior clear permits
bounded partial images. Both image and opaque image-blend entrypoints share
the same receipt validator; one canonical SFFI facade executes that frame once on
D3D11 and returns blocking staging-readback evidence. Any other operation or
mutation after execution invalidates the receipt. Linux remains the existing
DXVK-structured CPU-raster compatibility path and reports
"directx-software-emulation"; Windows reports "directx" only after a hardware
adapter probe succeeds.

Usage:
    use std.gc_async_mut.gpu.engine2d.backend_directx.{DirectXBackend, dx_platform_probe}
    var b = DirectXBackend.create()
    val ok = b.init(800, 600)
    b.clear(0xFFFFFFFF)
    b.draw_rect_filled(0, 0, 100, 100, 0xFFFF0000)
    val pixels = b.read_pixels()
"""

use std.gc_async_mut.gpu.engine2d.backend.{RenderBackend, Engine2DExtended, Engine2DReadback, engine2d_readback, engine2d_readback_with_handle, engine2d_readback_with_identity}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.platform.{get_host_os}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendStatus, BackendProbeResult}
use std.nogc_async_mut.gpu.dxvk_d3d11.{
    dxvk_d3d11_create_device,
    dxvk_d3d11_probe_device,
    dxvk_d3d11_create_swapchain,
    dxvk_d3d11_create_readback_target,
    dxvk_d3d11_present_readback,
    dxvk_d3d11_readback_pixels,
    dxvk_d3d11_destroy_readback_target,
    dxvk_d3d11_destroy_device
}
use std.nogc_async_mut.gpu.vulkan_icd_sffi.{vk_icd_probe_leaf}
use std.nogc_sync_mut.gpu.engine2d.sffi_directx.{directx_execute_readback_checked, directx_hardware_adapter_identity}

val DIRECTX_FRAME_MAGIC: u32 = 0x44583131u32
val DIRECTX_FRAME_VERSION: u32 = 1u32
val DIRECTX_FRAME_HEADER_WORDS: i32 = 4
val DIRECTX_FRAME_RECORD_WORDS: u32 = 8u32
val DIRECTX_FRAME_OP_CLEAR: u32 = 1u32
val DIRECTX_FRAME_OP_FILL_RECT: u32 = 2u32
val DIRECTX_FRAME_OP_IMAGE: u32 = 3u32

# ============================================================================
# Platform probe
# ============================================================================

class DxPlatformProbe:
    platform:   text
    leaf:       text
    device_ok:  bool
    evidence:   text

impl DxPlatformProbe:
    static fn create(plat: text, leaf_tag: text, dev_ok: bool) -> DxPlatformProbe:
        DxPlatformProbe(
            platform: plat,
            leaf: leaf_tag,
            device_ok: dev_ok,
            evidence: "platform=" + plat + " " + leaf_tag + " device=" + dev_ok.to_text()
        )

export DxPlatformProbe

pub fn dx_platform_probe() -> DxPlatformProbe:
    """Probe DirectX availability on the current host.

    On Linux: attempts dxvk_d3d11_create_device; reports DXVK leaf evidence.
    On Windows: the same device path loads the native d3d11.dll, so the
    probe reports windows-native (validated on windows-latest CI).

    Returns:
        DxPlatformProbe with platform, leaf evidence string, and device_ok.
    """
    if get_host_os() == "windows":
        val identity = directx_hardware_adapter_identity()
        return DxPlatformProbe.create("windows-native", "leaf=native-d3d11", identity > 0)
    val leaf = vk_icd_probe_leaf()
    val dev_result = dxvk_d3d11_probe_device()
    DxPlatformProbe.create("linux-dxvk", leaf, dev_result.is_ok)

export dx_platform_probe

# ============================================================================
# DirectX Backend
# ============================================================================

class DirectXBackend:
    sw:              SoftwareBackend
    device_handle:   i64
    swapchain_handle: i64
    readback_handle: i64
    last_readback_ok: bool
    last_readback_pixel_count: i64
    last_readback_checksum: i64
    initialized:     bool
    last_error:      text
    leaf:            text
    native_hardware: bool
    native_receipt_eligible: bool
    native_has_frame: bool
    native_words: [u32]
    native_device_identity: i64
    native_attempted: bool
    native_completion_known: bool
    native_cached_handle: i64
    native_cached_pixels: [u32]

impl Engine2DExtended for DirectXBackend:
    static fn create() -> DirectXBackend:
        """Create an uninitialized DirectX backend. Call init() before drawing."""
        DirectXBackend(
            sw: SoftwareBackend.create(),
            device_handle: 0,
            swapchain_handle: 0,
            readback_handle: 0,
            last_readback_ok: false,
            last_readback_pixel_count: 0,
            last_readback_checksum: 0,
            initialized: false,
            last_error: "",
            leaf: "structured",
            native_hardware: false,
            native_receipt_eligible: false,
            native_has_frame: false,
            native_words: [],
            native_device_identity: 0,
            native_attempted: false,
            native_completion_known: true,
            native_cached_handle: 0,
            native_cached_pixels: []
        )

    me _native_reset():
        if not self.native_receipt_eligible:
            return
        self.native_words = [DIRECTX_FRAME_MAGIC, DIRECTX_FRAME_VERSION, 0u32, DIRECTX_FRAME_HEADER_WORDS.to_u32()]
        self.native_has_frame = false

    me _native_finish_record():
        self.native_words[2] = self.native_words[2] + 1u32
        self.native_words[3] = self.native_words.len().to_u32()

    me _native_append_record(op: u32, x: i32, y: i32, w: i32, h: i32, arg: u32):
        self.native_words.push(op)
        self.native_words.push(DIRECTX_FRAME_RECORD_WORDS)
        self.native_words.push(x as u32)
        self.native_words.push(y as u32)
        self.native_words.push(w as u32)
        self.native_words.push(h as u32)
        self.native_words.push(arg)
        self.native_words.push(0u32)
        self._native_finish_record()
        self.native_has_frame = true

    me _native_append_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        val payload_words = pixels.len().to_u32()
        self.native_words.push(DIRECTX_FRAME_OP_IMAGE)
        self.native_words.push(DIRECTX_FRAME_RECORD_WORDS + payload_words)
        self.native_words.push(x.to_u32())
        self.native_words.push(y.to_u32())
        self.native_words.push(w.to_u32())
        self.native_words.push(h.to_u32())
        self.native_words.push(0u32)
        self.native_words.push(payload_words)
        for pixel in pixels:
            self.native_words.push(pixel)
        self._native_finish_record()
        self.native_has_frame = true

    me _native_queue_opaque_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if not self.native_hardware:
            return
        val in_bounds = x >= 0 and y >= 0 and w > 0 and h > 0 and x <= self.width() - w and y <= self.height() - h
        var opaque = in_bounds and pixels.len().to_i64() == w.to_i64() * h.to_i64()
        var i = 0
        while i < pixels.len() and opaque:
            opaque = ((pixels[i] >> 24u32) & 0xFFu32) == 0xFFu32
            i = i + 1
        val can_initialize = self.native_has_frame or (x == 0 and y == 0 and w == self.width() and h == self.height())
        if self.native_receipt_eligible and not self.native_attempted and opaque and can_initialize:
            if not self.native_has_frame:
                self._native_reset()
            self._native_append_image(x, y, w, h, pixels)
        else:
            self._poison_native_receipt()

    me _poison_native_receipt():
        if self.native_hardware:
            self.native_receipt_eligible = false
            self.native_cached_handle = 0
            self.native_cached_pixels = []

    fn _native_execute_once():
        if self.native_attempted or not self.native_receipt_eligible or not self.native_has_frame:
            return
        self.native_attempted = true
        val native = directx_execute_readback_checked(self.width(), self.height(), self.native_words)
        self.native_completion_known = native.completion_known
        if (native.completed and native.backend_handle > 0 and
            native.device_identity == self.native_device_identity and
            native.pixels.len() == self.width() * self.height()):
            self.native_cached_handle = native.backend_handle
            self.native_cached_pixels = native.pixels
        else:
            self.native_receipt_eligible = false

    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        self.sw.draw_text_bg(x, y, text_val, fg, bg, font_size)
        self._poison_native_receipt()

export DirectXBackend

impl RenderBackend for DirectXBackend:

    fn name() -> text:
        if get_host_os() == "windows":
            return "directx"
        "directx-software-emulation"

    me init(width: i32, height: i32) -> bool:
        self.last_error = ""
        self.device_handle = 0
        self.swapchain_handle = 0
        self.readback_handle = 0
        self.last_readback_ok = false
        self.last_readback_pixel_count = 0
        self.last_readback_checksum = 0
        self.native_hardware = false
        self.native_device_identity = 0
        self.native_receipt_eligible = true
        self.native_has_frame = false
        self.native_words = []
        self.native_attempted = false
        self.native_completion_known = true
        self.native_cached_handle = 0
        self.native_cached_pixels = []

        val sw_ok = self.sw.init(width, height)
        if sw_ok == false:
            self.last_error = "software framebuffer init failed"
            self.initialized = false
            return false

        if get_host_os() == "windows":
            val identity = directx_hardware_adapter_identity()
            if identity <= 0:
                self.last_error = "native D3D11 hardware adapter unavailable"
                self.sw.shutdown()
                self.initialized = false
                return false
            self.native_hardware = true
            self.native_device_identity = identity
            self.leaf = "leaf=native-d3d11"
            self.initialized = true
            self._native_reset()
            return true

        # Probe leaf first
        val probed = vk_icd_probe_leaf()
        self.leaf = probed

        # Create D3D11 device via DXVK dispatch chain
        val dev_result = dxvk_d3d11_create_device()
        if dev_result.is_ok == false:
            self.last_error = "dxvk_d3d11_create_device failed"
            self.sw.shutdown()
            self.initialized = false
            return false

        self.device_handle = dev_result.device_handle

        # Create swapchain
        val sc_result = dxvk_d3d11_create_swapchain(dev_result.device_handle, width, height)
        if sc_result.is_ok == false:
            self.last_error = "dxvk_d3d11_create_swapchain failed"
            if self.device_handle > 0:
                dxvk_d3d11_destroy_device(self.device_handle)
            self.device_handle = 0
            self.sw.shutdown()
            self.initialized = false
            return false

        self.swapchain_handle = sc_result.swapchain_handle

        val rb_handle = dxvk_d3d11_create_readback_target(dev_result.device_handle, width.to_i64(), height.to_i64())
        if rb_handle <= 0:
            self.last_error = "dxvk_d3d11_create_readback_target failed"
            if self.device_handle > 0:
                dxvk_d3d11_destroy_device(self.device_handle)
            self.device_handle = 0
            self.swapchain_handle = 0
            self.sw.shutdown()
            self.initialized = false
            return false
        self.readback_handle = rb_handle

        self.initialized = true
        true

    me shutdown():
        if self.initialized:
            self.sw.shutdown()
            if not self.native_hardware:
                if self.readback_handle > 0:
                    dxvk_d3d11_destroy_readback_target(self.readback_handle)
                if self.device_handle > 0:
                    dxvk_d3d11_destroy_device(self.device_handle)
            self.device_handle = 0
            self.swapchain_handle = 0
            self.readback_handle = 0
            self.last_readback_ok = false
            self.last_readback_pixel_count = 0
            self.last_readback_checksum = 0
            self.initialized = false
            self.native_receipt_eligible = false
            self.native_has_frame = false
            self.native_words = []
            self.native_attempted = false
            self.native_completion_known = true
            self.native_cached_handle = 0
            self.native_cached_pixels = []

    me clear(color: u32):
        self.sw.clear(color)
        if self.native_hardware:
            if self.native_receipt_eligible and not self.native_attempted:
                self._native_reset()
                self._native_append_record(DIRECTX_FRAME_OP_CLEAR, 0, 0, 0, 0, color)
            else:
                self._poison_native_receipt()

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.sw.draw_rect(x, y, w, h, color)
        self._poison_native_receipt()

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.sw.draw_rect_filled(x, y, w, h, color)
        if self.native_hardware:
            if self.native_receipt_eligible and not self.native_attempted and self.native_has_frame and w > 0 and h > 0:
                self._native_append_record(DIRECTX_FRAME_OP_FILL_RECT, x, y, w, h, color)
            else:
                self._poison_native_receipt()

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        self.sw.draw_line(x1, y1, x2, y2, color, thickness)
        self._poison_native_receipt()

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        self.sw.draw_circle(cx, cy, r, color)
        self._poison_native_receipt()

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        self.sw.draw_circle_filled(cx, cy, r, color)
        self._poison_native_receipt()

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        self.sw.draw_rounded_rect(x, y, w, h, radius, color)
        self._poison_native_receipt()

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        self.sw.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        self._poison_native_receipt()

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        self.sw.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        self._poison_native_receipt()

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        self.sw.draw_text(x, y, text_val, color, font_size)
        self._poison_native_receipt()

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.sw.draw_image(x, y, w, h, pixels)
        self._native_queue_opaque_image(x, y, w, h, pixels)
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.sw.draw_image_blend(x, y, w, h, pixels)
        self._native_queue_opaque_image(x, y, w, h, pixels)

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.sw.set_clip(x, y, w, h)
        self._poison_native_receipt()

    me clear_clip():
        self.sw.clear_clip()
        self._poison_native_receipt()

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.sw.set_mask(mask_pixels, w, h)
        self._poison_native_receipt()

    me clear_mask():
        self.sw.clear_mask()
        self._poison_native_receipt()

    me present():
        if self.native_hardware:
            self._native_execute_once()
            self.sw.present()
            return
        if self.readback_handle > 0:
            val pixels = self.sw.read_pixels()
            val readback = dxvk_d3d11_present_readback(self.swapchain_handle, self.readback_handle, pixels, self.width().to_i64(), self.height().to_i64())
            self.last_readback_ok = readback.readback_ok
            self.last_readback_pixel_count = readback.pixel_count
            self.last_readback_checksum = readback.checksum
        # Software backend present flushes the host pixel buffer
        self.sw.present()

    fn read_pixels() -> [u32]:
        if self.native_hardware:
            self._native_execute_once()
            if self.native_cached_handle > 0:
                return self.native_cached_pixels
            if not self.native_completion_known:
                return []
        if self.last_readback_ok:
            val expected_count = self.width().to_i64() * self.height().to_i64()
            val readback = dxvk_d3d11_readback_pixels(self.readback_handle)
            if readback.is_ok and readback.pixel_count == expected_count:
                return readback.pixels
        self.sw.read_pixels()
    fn read_pixels_with_source() -> Engine2DReadback:
        if self.native_hardware:
            self._native_execute_once()
            if self.native_cached_handle > 0:
                return engine2d_readback_with_identity(self.native_cached_pixels, "device_readback", self.native_cached_handle, self.native_device_identity)
            if not self.native_completion_known:
                return engine2d_readback([], "completion_unknown")
            return engine2d_readback(self.sw.read_pixels(), "cpu_mirror")
        if self.initialized and self.last_readback_ok and self.readback_handle > 0:
            val expected_count = self.width().to_i64() * self.height().to_i64()
            val readback = dxvk_d3d11_readback_pixels(self.readback_handle)
            if readback.is_ok and readback.pixel_count == expected_count:
                return engine2d_readback_with_handle(readback.pixels, "device_readback", self.readback_handle)
        if self.initialized and self.swapchain_handle > 0:
            return engine2d_readback_with_handle(self.sw.read_pixels(), "swapchain_present", self.swapchain_handle)
        engine2d_readback(self.sw.read_pixels(), "cpu_mirror")

    fn width() -> i32:
        self.sw.width()

    fn height() -> i32:
        self.sw.height()

impl DirectXBackend:
    # Parity with the checked Metal/Vulkan drawing surface: every extended
    # primitive those backends expose is forwarded here to the same internal
    # SoftwareBackend that already rasterizes every RenderBackend op above —
    # the honest, contained mechanism this backend reports itself by
    # ("directx-software-emulation"). No new abstraction, no silent no-op.
    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        self.sw.draw_ellipse(cx, cy, rx, ry, color)
        self._poison_native_receipt()

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        self.sw.draw_ellipse_filled(cx, cy, rx, ry, color)
        self._poison_native_receipt()

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        self.sw.draw_arc(cx, cy, r, start_deg, end_deg, color, thickness)
        self._poison_native_receipt()

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        self.sw.draw_bezier(x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)
        self._poison_native_receipt()

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        self.sw.draw_polygon_filled(xs, ys, count, color)
        self._poison_native_receipt()

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        self.sw.draw_polyline(xs, ys, count, color, thickness)
        self._poison_native_receipt()

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        self.sw.draw_rect_thick(x, y, w, h, color, thickness)
        self._poison_native_receipt()

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        self.sw.draw_circle_thick(cx, cy, r, color, thickness)
        self._poison_native_receipt()

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        self.sw.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
        self._poison_native_receipt()

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        self.sw.draw_gradient_rect_h(x, y, w, h, left_color, right_color)
        self._poison_native_receipt()

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        self.sw.draw_radial_gradient(cx, cy, r, center_color, edge_color)
        self._poison_native_receipt()

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.sw.draw_rect_blend(x, y, w, h, color)
        self._poison_native_receipt()

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.sw.draw_image_blend(x, y, w, h, pixels)
        self._native_queue_opaque_image(x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        self.sw.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
        self._poison_native_receipt()

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        self.sw.draw_triangle_outline(x1, y1, x2, y2, x3, y3, color, thickness)
        self._poison_native_receipt()

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        self.sw.draw_blur_rect(x, y, w, h, radius)
        self._poison_native_receipt()

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        self.sw.draw_shadow_rect(x, y, w, h, offset_x, offset_y, blur_r, color)
        self._poison_native_receipt()

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        self.sw.draw_image_transform(dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)
        self._poison_native_receipt()

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        self.sw.draw_rect_blend(x, y, w, h, color)
        self._poison_native_receipt()

# ============================================================================
# Probe function for backend_probe integration
# ============================================================================

pub fn probe_directx() -> BackendProbeResult:
    """Probe DirectX availability and return a typed BackendProbeResult.

    On Linux: DXVK/vkd3d must be reachable (local prefix or system Vulkan).
    Reports the leaf evidence string so callers can assert which path ran.

    Linux reports the honest "directx-software-emulation" compatibility path.
    Windows reports "directx" only for the native hardware D3D11 owner.

    Returns:
        BackendProbeResult with status=Initialized on success, or
        status=Unavailable with reason on failure.
    """
    if get_host_os() == "windows":
        if directx_hardware_adapter_identity() > 0:
            return BackendProbeResult.success("directx", "leaf=native-d3d11 hardware adapter available")
        return BackendProbeResult.unavailable("directx", "leaf=native-d3d11 hardware adapter unavailable")
    val dev_result = dxvk_d3d11_probe_device()
    val leaf = vk_icd_probe_leaf()
    if dev_result.is_ok:
        BackendProbeResult.success("directx-software-emulation", "dxvk-d3d11 device created " + leaf)
    else:
        BackendProbeResult.failed("directx-software-emulation", "dxvk-d3d11-unavailable " + leaf)

export probe_directx
