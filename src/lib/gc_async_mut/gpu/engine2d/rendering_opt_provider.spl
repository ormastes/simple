# 2D Engine — Rendering Optimization Provider Registry
#
# Tracks hit/miss/change counters per optimization provider (SIMD,
# shader specialization, pipeline cache, layout opt).
# RenderingOptReport aggregates up to 3 providers for inline reporting.
#
# Usage:
#   use std.gpu.engine2d.rendering_opt_provider.{RenderingOptProvider, RenderingOptReport}

use std.gpu.engine2d.simd_provider.{SimdHitCounts, simd_hit_counts, has_registered_provider, registered_provider_name}

# ============================================================================
# RenderingOptProvider
# ============================================================================

class RenderingOptProvider:
    """Metadata and counters for one rendering optimization provider."""

    provider_id:     text  # unique identifier
    provider_kind:   text  # "simd_vectorization", "shader_specialization", "pipeline_cache", "layout_opt"
    target_arch:     text
    target_features: text  # e.g. "sse4,avx2" or "neon"
    hit_count:       i64
    miss_count:      i64
    change_count:    i64
    active:          bool

    static fn create(kind: text, arch: text, features: text) -> RenderingOptProvider:
        val pid = kind + "." + arch
        RenderingOptProvider(
            provider_id:     pid,
            provider_kind:   kind,
            target_arch:     arch,
            target_features: features,
            hit_count:       0,
            miss_count:      0,
            change_count:    0,
            active:          true
        )

    static fn simd_provider(arch: text) -> RenderingOptProvider:
        var features = ""
        if arch == "x86_64":
            features = "sse4,avx2"
        elif arch == "aarch64":
            features = "neon"
        elif arch == "riscv64":
            features = "rvv"
        else:
            features = "none"
        RenderingOptProvider.create("simd_vectorization", arch, features)

    static fn shader_provider(backend: text) -> RenderingOptProvider:
        RenderingOptProvider.create("shader_specialization", backend, "spirv")

    me record_hit():
        self.hit_count = self.hit_count + 1

    me record_miss():
        self.miss_count = self.miss_count + 1

    me record_change():
        self.change_count = self.change_count + 1

    me hit_rate_pct() -> i64:
        val total = self.hit_count + self.miss_count
        if total == 0:
            return 0
        return (self.hit_count * 100) / total

    me is_effective() -> bool:
        return self.hit_rate_pct() > 50

    me stats() -> text:
        val active_text = if self.active: "true" else: "false"
        var parts: [text] = [
            "Provider[id=", self.provider_id,
            " kind=", self.provider_kind,
            " arch=", self.target_arch,
            " features=", self.target_features,
            " hits=", self.hit_count.to_text(),
            " misses=", self.miss_count.to_text(),
            " changes=", self.change_count.to_text(),
            " hit_rate=", self.hit_rate_pct().to_text(),
            "% active=", active_text,
            "]"
        ]
        parts.join("")

    me reset_counters():
        self.hit_count   = 0
        self.miss_count  = 0
        self.change_count = 0

# ============================================================================
# RenderingOptReport
# ============================================================================

class RenderingOptReport:
    """Inline aggregate of up to 3 rendering optimization providers."""

    provider_count: i64
    total_hits:     i64
    total_misses:   i64
    total_changes:  i64
    p0_id:     text
    p0_kind:   text
    p0_hits:   i64
    p0_misses: i64
    p0_active: bool
    p1_id:     text
    p1_kind:   text
    p1_hits:   i64
    p1_misses: i64
    p1_active: bool
    p2_id:     text
    p2_kind:   text
    p2_hits:   i64
    p2_misses: i64
    p2_active: bool

    static fn create() -> RenderingOptReport:
        RenderingOptReport(
            provider_count: 0,
            total_hits:     0,
            total_misses:   0,
            total_changes:  0,
            p0_id:     "", p0_kind: "", p0_hits: 0, p0_misses: 0, p0_active: false,
            p1_id:     "", p1_kind: "", p1_hits: 0, p1_misses: 0, p1_active: false,
            p2_id:     "", p2_kind: "", p2_hits: 0, p2_misses: 0, p2_active: false
        )

    me add_provider(p: RenderingOptProvider) -> text:
        if self.provider_count >= 3:
            "error: report full (max 3 providers)"
        else:
            self.total_hits    = self.total_hits    + p.hit_count
            self.total_misses  = self.total_misses  + p.miss_count
            self.total_changes = self.total_changes + p.change_count
            if self.provider_count == 0:
                self.p0_id     = p.provider_id
                self.p0_kind   = p.provider_kind
                self.p0_hits   = p.hit_count
                self.p0_misses = p.miss_count
                self.p0_active = p.active
            elif self.provider_count == 1:
                self.p1_id     = p.provider_id
                self.p1_kind   = p.provider_kind
                self.p1_hits   = p.hit_count
                self.p1_misses = p.miss_count
                self.p1_active = p.active
            else:
                self.p2_id     = p.provider_id
                self.p2_kind   = p.provider_kind
                self.p2_hits   = p.hit_count
                self.p2_misses = p.miss_count
                self.p2_active = p.active
            self.provider_count = self.provider_count + 1
            "ok"

    me summary() -> text:
        var p0 = ""
        var p1 = ""
        var p2 = ""
        if self.provider_count > 0:
            p0 = " p0=[" + self.p0_id + " " + self.p0_kind + " h=" + self.p0_hits.to_text() + " m=" + self.p0_misses.to_text() + "]"
        if self.provider_count > 1:
            p1 = " p1=[" + self.p1_id + " " + self.p1_kind + " h=" + self.p1_hits.to_text() + " m=" + self.p1_misses.to_text() + "]"
        if self.provider_count > 2:
            p2 = " p2=[" + self.p2_id + " " + self.p2_kind + " h=" + self.p2_hits.to_text() + " m=" + self.p2_misses.to_text() + "]"
        var parts: [text] = [
            "RenderingOptReport[providers=", self.provider_count.to_text(),
            " total_hits=", self.total_hits.to_text(),
            " total_misses=", self.total_misses.to_text(),
            " total_changes=", self.total_changes.to_text(),
            p0,
            p1,
            p2,
            "]"
        ]
        parts.join("")

fn rendering_opt_provider_from_simd_counts(arch: text, features: text, counts: SimdHitCounts) -> RenderingOptProvider:
    var p = RenderingOptProvider.simd_provider(arch)
    if features != "":
        p.target_features = features
    if has_registered_provider():
        p.provider_id = registered_provider_name()
    p.hit_count = counts.fill_hits + counts.copy_hits + counts.alpha_hits + counts.blit_hits + counts.scroll_hits
    p.miss_count = 0
    p.change_count = counts.vectorize_changes
    p.active = true
    p

fn current_simd_rendering_opt_provider(arch: text, features: text) -> RenderingOptProvider:
    rendering_opt_provider_from_simd_counts(arch, features, simd_hit_counts())

fn rendering_opt_report_from_simd(arch: text, features: text) -> RenderingOptReport:
    val provider = current_simd_rendering_opt_provider(arch, features)
    var report = RenderingOptReport.create()
    report.provider_count = 1
    report.total_hits = provider.hit_count
    report.total_misses = provider.miss_count
    report.total_changes = provider.change_count
    report.p0_id = provider.provider_id
    report.p0_kind = provider.provider_kind
    report.p0_hits = provider.hit_count
    report.p0_misses = provider.miss_count
    report.p0_active = provider.active
    report
