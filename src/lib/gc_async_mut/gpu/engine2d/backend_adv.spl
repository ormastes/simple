"""2D Engine — Advanced Backend Trait (Optimized Operations)

@tag:stdlib
@tag:api
@tag:gpu

Operations that backends SHOULD implement natively for performance, but
CAN omit — the stateless emulation layer (backend_emu.spl) provides
correct implementations using only RenderBackendCore methods.

GPU backends (Vulkan, CUDA, ROCm, Intel) implement these natively with
dedicated compute kernels. CPU/Software backends implement them with
optimized scalar or SIMD code. New or minimal backends can skip this
trait entirely and rely on emulation.

See: backend_core.spl (core trait), backend_emu.spl (stateless emulation)
"""

# ============================================================================
# Advanced Backend Trait
# ============================================================================

trait RenderBackendAdv:
    """Optimized 2D rendering operations.

    Every method in this trait can be emulated statelessly using only
    RenderBackendCore methods. Backends implement this trait to replace
    emulation with hardware-accelerated or algorithmically optimized paths.
    """

    # -- Rectangles --
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32)

    # -- Lines --
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32)

    # -- Circles --
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32)
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32)

    # -- Complex shapes --
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32)
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32)
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32)

    # -- Text --
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32)
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32)
