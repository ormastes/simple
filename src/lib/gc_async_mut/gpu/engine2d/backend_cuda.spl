            _write_gradient_launch_args(self.rect_val_ptr, self.rect_args_ptr, self.d_framebuffer, x, y, w, h, top_color, bottom_color, self.width(), self.height())
            val total = _i64(w) * _i64(h)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_gradient_rect", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
