    rt_ptr_write_i64(val_ptr, 40, _i64_from_u32(color))
    rt_ptr_write_i64(val_ptr, 48, _i64(stride))
    rt_ptr_write_i64(val_ptr, 56, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
