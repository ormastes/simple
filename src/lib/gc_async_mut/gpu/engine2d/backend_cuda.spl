@allow(primitive_api)
# 2D Engine — CUDA GPU Backend
#
# Hardware-accelerated 2D rendering using CUDA kernels. Each draw operation
# is a kernel launch operating on a device-side framebuffer. Present() copies
# the GPU framebuffer back to host memory for display.
#
# Requires NVIDIA GPU with CUDA support.
#
# Usage:
#   use std.gpu.engine2d.backend_cuda.{CudaBackend}

use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gc_async_mut.cuda.{
    cuda_available, cuda_init, cuda_device_count,
    cuda_mem_alloc, cuda_mem_free,
    cuda_memcpy_htod, cuda_memcpy_dtoh,
    cuda_memset, cuda_sync,
    cuda_module_load_data, cuda_module_unload,
    cuda_launch_kernel,
    CUDA_SUCCESS
}

# ============================================================================
# CUDA Backend
# ============================================================================

class CudaBackend:
    """GPU-accelerated 2D renderer using CUDA kernels.

    Architecture:
    - Framebuffer lives in GPU device memory (d_framebuffer)
    - Each draw call launches a CUDA kernel
    - present() copies GPU framebuffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line) has a dedicated
    kernel. Grid/block dimensions are chosen to cover the bounding box
    of the primitive being drawn.
    """

    host_buf: [u32]
    w: i32
    h: i32
    d_framebuffer: i64      # Device pointer to GPU framebuffer
    ptx_module: i64          # Handle to loaded PTX module
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool
    dirty: bool              # True when GPU has changes not yet copied to host

    static fn create() -> CudaBackend:
        """Create an uninitialized CUDA backend. Call init() before drawing."""
        CudaBackend(
            host_buf: [],
            w: 0,
            h: 0,
            d_framebuffer: 0,
            ptx_module: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false,
            dirty: false
        )

impl RenderBackend for CudaBackend:

    fn name() -> text:
        "cuda"

    fn init(width: i32, height: i32) -> bool:
        # Check CUDA availability
        if not cuda_available():
            return false

        val init_result = cuda_init()
        if init_result != CUDA_SUCCESS:
            return false

        if cuda_device_count() < 1:
            return false

        self.w = width
        self.h = height

        # Allocate device framebuffer (4 bytes per pixel = u32)
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = cuda_mem_alloc(fb_size)
        if self.d_framebuffer == 0:
            return false

        # Clear device framebuffer to black
        cuda_memset(self.d_framebuffer, 0, fb_size)

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        # Load PTX module with 2D rendering kernels
        self.ptx_module = cuda_module_load_data(_engine2d_ptx())

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    fn shutdown():
        if self.d_framebuffer != 0:
            cuda_mem_free(self.d_framebuffer)
            self.d_framebuffer = 0
        if self.ptx_module != 0:
            cuda_module_unload(self.ptx_module)
            self.ptx_module = 0
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        # Launch clear kernel: one thread per pixel
        val block_size = 256
        val total = _i64(self.w) * _i64(self.h)
        val grid_size = (total + _i64(block_size) - 1) / _i64(block_size)
        _launch_kernel_1d(self, "kernel_clear", grid_size, _i64(block_size), _pack_clear_args(self.d_framebuffer, color, self.w, self.h))
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val args = _pack_rect_args(self.d_framebuffer, x, y, w, h, color, self.w, self.h, 0)
        val grid = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        _launch_kernel_2d(self, "kernel_draw_rect_outline", grid, block_dim, args)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val args = _pack_rect_args(self.d_framebuffer, x, y, w, h, color, self.w, self.h, 1)
        val grid = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        _launch_kernel_2d(self, "kernel_draw_rect_filled", grid, block_dim, args)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        # Line kernel: launch one thread per pixel along the line length
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val block_size: i64 = 256
        val grid_size = (_i64(line_len) + block_size - 1) / block_size
        val args = _pack_line_args(self.d_framebuffer, x1, y1, x2, y2, color, thickness, self.w, self.h)
        _launch_kernel_1d(self, "kernel_draw_line", grid_size, block_size, args)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        # Circle outline: launch kernel covering bounding box
        val bx = cx - r
        val by = cy - r
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val grid = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args = _pack_circle_args(self.d_framebuffer, cx, cy, r, color, self.w, self.h, 0)
        _launch_kernel_2d(self, "kernel_draw_circle", grid, block_dim, args)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val grid = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args = _pack_circle_args(self.d_framebuffer, cx, cy, r, color, self.w, self.h, 1)
        _launch_kernel_2d(self, "kernel_draw_circle_filled", grid, block_dim, args)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        # Rounded rect kernel: each thread checks corner distance
        val grid = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        val args = _pack_rounded_rect_args(self.d_framebuffer, x, y, w, h, radius, color, self.w, self.h)
        _launch_kernel_2d(self, "kernel_draw_rounded_rect", grid, block_dim, args)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val grid = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args = _pack_triangle_args(self.d_framebuffer, x1, y1, x2, y2, x3, y3, color, self.w, self.h, min_x, min_y)
        _launch_kernel_2d(self, "kernel_draw_triangle_filled", grid, block_dim, args)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        val grid = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        val args = _pack_gradient_args(self.d_framebuffer, x, y, w, h, top_color, bottom_color, self.w, self.h)
        _launch_kernel_2d(self, "kernel_draw_gradient_rect", grid, block_dim, args)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering on GPU is complex; fall back to CPU-side rendering
        # then upload the affected region. For production, a glyph atlas
        # texture would be uploaded and sampled by a kernel.
        #
        # Current approach: render text to a temporary host buffer, then
        # upload the bounding region to the device framebuffer.
        _gpu_draw_text_fallback(self, x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Upload pixel data to a temporary device buffer, then launch
        # a blit kernel to copy it into the framebuffer
        val pixel_count = _i64(w) * _i64(h)
        val byte_size = pixel_count * 4
        val d_src = cuda_mem_alloc(byte_size)
        if d_src != 0:
            # Upload source pixels to device
            _upload_pixels_to_device(d_src, pixels, pixel_count)
            # Launch blit kernel
            val grid = _grid_for_rect(w, h)
            val block_dim = _block_for_rect()
            val args = _pack_blit_args(self.d_framebuffer, d_src, x, y, w, h, self.w, self.h)
            _launch_kernel_2d(self, "kernel_blit_image", grid, block_dim, args)
            cuda_mem_free(d_src)
        self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me present():
        # Copy GPU framebuffer to host memory
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer(self.d_framebuffer, self.host_buf, fb_size)
            cuda_sync()
            self.dirty = false

    fn read_pixels() -> [u32]:
        # Ensure host buffer is up to date
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer(self.d_framebuffer, self.host_buf, fb_size)
            cuda_sync()
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

# ============================================================================
# Kernel Launch Helpers
# ============================================================================

fn _launch_kernel_1d(backend: CudaBackend, kernel_name: text, grid_x: i64, block_x: i64, args_ptr: i64):
    """Launch a 1D CUDA kernel."""
    cuda_launch_kernel(
        backend.ptx_module, kernel_name,
        grid_x, 1, 1,    # grid dims
        block_x, 1, 1,   # block dims
        args_ptr
    )

fn _launch_kernel_2d(backend: CudaBackend, kernel_name: text, grid: GridDim, block_dim: BlockDim, args_ptr: i64):
    """Launch a 2D CUDA kernel."""
    cuda_launch_kernel(
        backend.ptx_module, kernel_name,
        grid.x, grid.y, 1,     # grid dims
        block_dim.x, block_dim.y, 1,   # block dims
        args_ptr
    )

# ============================================================================
# Grid / Block Dimension Helpers
# ============================================================================

struct GridDim:
    x: i64
    y: i64

struct BlockDim:
    x: i64
    y: i64

fn _grid_for_rect(w: i32, h: i32) -> GridDim:
    """Compute grid dimensions for a rectangular region with 16x16 blocks."""
    val bx: i64 = 16
    val by: i64 = 16
    GridDim(
        x: (_i64(w) + bx - 1) / bx,
        y: (_i64(h) + by - 1) / by
    )

fn _block_for_rect() -> BlockDim:
    """Standard 16x16 thread block for 2D operations."""
    BlockDim(x: 16, y: 16)

# ============================================================================
# Argument Packing
#
# Each kernel expects its arguments packed into a contiguous buffer at
# args_ptr. In production, this would be a device-accessible struct.
# Here we use the runtime's argument packing mechanism.
# ============================================================================

fn _pack_clear_args(d_fb: i64, color: u32, w: i32, h: i32) -> i64:
    """Pack arguments for clear kernel: (framebuffer_ptr, color, width, height)."""
    # Runtime packs arguments into a temporary buffer and returns its address
    _pack_args_4(d_fb, _i64_from_u32(color), _i64(w), _i64(h))

fn _pack_rect_args(d_fb: i64, x: i32, y: i32, w: i32, h: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32) -> i64:
    _pack_args_8(d_fb, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(color), _i64(fb_w), _i64(fb_h))

fn _pack_line_args(d_fb: i64, x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, fb_w: i32, fb_h: i32) -> i64:
    _pack_args_8(d_fb, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64_from_u32(color), _i64(fb_w), _i64(fb_h))

fn _pack_circle_args(d_fb: i64, cx: i32, cy: i32, r: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32) -> i64:
    _pack_args_8(d_fb, _i64(cx), _i64(cy), _i64(r), _i64_from_u32(color), _i64(fb_w), _i64(fb_h), _i64(filled))

fn _pack_rounded_rect_args(d_fb: i64, x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, fb_w: i32, fb_h: i32) -> i64:
    _pack_args_8(d_fb, _i64(x), _i64(y), _i64(w), _i64(h), _i64(radius), _i64_from_u32(color), _i64(fb_w))

fn _pack_triangle_args(d_fb: i64, x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, fb_w: i32, fb_h: i32, min_x: i32, min_y: i32) -> i64:
    _pack_args_8(d_fb, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64(x3), _i64(y3), _i64_from_u32(color))

fn _pack_gradient_args(d_fb: i64, x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32, fb_w: i32, fb_h: i32) -> i64:
    _pack_args_8(d_fb, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(top_color), _i64_from_u32(bottom_color), _i64(fb_w))

fn _pack_blit_args(d_fb: i64, d_src: i64, x: i32, y: i32, w: i32, h: i32, fb_w: i32, fb_h: i32) -> i64:
    _pack_args_8(d_fb, d_src, _i64(x), _i64(y), _i64(w), _i64(h), _i64(fb_w), _i64(fb_h))

# ============================================================================
# Runtime Argument Packing Stubs
#
# These map to the runtime's kernel argument serialization.
# The actual implementation packs i64 values into a contiguous buffer
# and returns the buffer address for CUDA's cuLaunchKernel.
# ============================================================================

extern fn rt_engine2d_pack_args_4(a: i64, b: i64, c: i64, d: i64) -> i64
extern fn rt_engine2d_pack_args_8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64

fn _pack_args_4(a: i64, b: i64, c: i64, d: i64) -> i64:
    rt_engine2d_pack_args_4(a, b, c, d)

fn _pack_args_8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64:
    rt_engine2d_pack_args_8(a, b, c, d, e, f, g, h)

# ============================================================================
# Device Memory Transfer
# ============================================================================

extern fn rt_engine2d_upload_pixels(d_dst: i64, pixels: [u32], count: i64) -> i64
extern fn rt_engine2d_download_pixels(d_src: i64, pixels: [u32], byte_size: i64) -> i64

fn _upload_pixels_to_device(d_dst: i64, pixels: [u32], count: i64):
    """Upload host pixel array to device memory."""
    rt_engine2d_upload_pixels(d_dst, pixels, count)

fn _download_framebuffer(d_src: i64, host_buf: [u32], byte_size: i64):
    """Download device framebuffer to host buffer."""
    rt_engine2d_download_pixels(d_src, host_buf, byte_size)

# ============================================================================
# Text Rendering Fallback
# ============================================================================

fn _gpu_draw_text_fallback(backend: CudaBackend, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render text on CPU and upload affected region to GPU.

    For production use, a glyph atlas would be pre-uploaded to GPU memory
    and sampled by a text-rendering kernel. This fallback is acceptable
    for low-frequency text draws (UI labels, debug overlays).
    """
    # Use CPU backend's bitmap font implementation via direct pixel writes
    # to host buffer, then upload the dirty region
    var scale = font_size / 7
    if scale < 1:
        scale = 1

    val text_w = text_val.len() * 6 * scale
    val text_h = 7 * scale

    # Ensure host buffer is current
    if backend.dirty:
        val fb_size = _i64(backend.w) * _i64(backend.h) * 4
        _download_framebuffer(backend.d_framebuffer, backend.host_buf, fb_size)
        cuda_sync()

    # Render glyphs into host buffer
    var cursor_x = x
    var idx = 0
    while idx < text_val.len():
        val ch = text_val.slice(idx, idx + 1)
        _render_glyph_to_host(backend, cursor_x, y, ch, color, scale)
        cursor_x = cursor_x + 6 * scale
        idx = idx + 1

    # Upload the modified text region back to GPU
    val region_size = _i64(text_w) * _i64(text_h) * 4
    val fb_size = _i64(backend.w) * _i64(backend.h) * 4
    # Re-upload entire framebuffer (simpler; for production, upload only the dirty rect)
    _upload_host_to_device(backend.d_framebuffer, backend.host_buf, fb_size)

fn _render_glyph_to_host(backend: CudaBackend, x: i32, y: i32, ch: text, color: u32, scale: i32):
    """Render a single glyph into the host buffer."""
    val bitmap = _get_glyph(ch)
    var row = 0
    while row < 7:
        val row_data = bitmap[row]
        var col = 0
        while col < 5:
            val bit = (row_data >> (4 - col)) & 1
            if bit != 0:
                var sy = 0
                while sy < scale:
                    var sx = 0
                    while sx < scale:
                        val px = x + col * scale + sx
                        val py = y + row * scale + sy
                        if (px >= 0 and px < backend.w and
                            py >= 0 and py < backend.h):
                            val idx = py * backend.w + px
                            backend.host_buf[idx] = color
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1

extern fn rt_engine2d_upload_host_buf(d_dst: i64, host_buf: [u32], byte_size: i64) -> i64

fn _upload_host_to_device(d_dst: i64, host_buf: [u32], byte_size: i64):
    rt_engine2d_upload_host_buf(d_dst, host_buf, byte_size)

# ============================================================================
# Minimal Glyph Data (shared with CPU backend pattern)
# ============================================================================

fn _get_glyph(ch: text) -> [i32]:
    """5x7 bitmap glyph lookup. Returns 7-row array, each row 5 bits wide."""
    if ch == "A" or ch == "a":
        return [0b01110, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]
    if ch == "B" or ch == "b":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10001, 0b10001, 0b11110]
    if ch == "C" or ch == "c":
        return [0b01110, 0b10001, 0b10000, 0b10000, 0b10000, 0b10001, 0b01110]
    if ch == "D" or ch == "d":
        return [0b11100, 0b10010, 0b10001, 0b10001, 0b10001, 0b10010, 0b11100]
    if ch == "E" or ch == "e":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b11111]
    if ch == "F" or ch == "f":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000]
    if ch == " ":
        return [0, 0, 0, 0, 0, 0, 0]
    if ch == "0":
        return [0b01110, 0b10001, 0b10011, 0b10101, 0b11001, 0b10001, 0b01110]
    if ch == "1":
        return [0b00100, 0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    # Default: filled block for unknown chars
    [0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111]

# ============================================================================
# PTX Kernel Source
# ============================================================================

fn _engine2d_ptx() -> text:
    """Embedded PTX source for 2D rendering kernels.

    These kernels operate on a u32 framebuffer in device memory.
    Each pixel is ARGB packed as a 32-bit unsigned integer.

    Kernel list:
    - kernel_clear: Fill entire framebuffer with a color
    - kernel_draw_rect_filled: Fill a rectangle region
    - kernel_draw_rect_outline: Draw rectangle border
    - kernel_draw_circle_filled: Fill a circle (distance check)
    - kernel_draw_circle: Draw circle outline
    - kernel_draw_line: Bresenham line on GPU (1 thread per step)
    - kernel_draw_rounded_rect: Rect with rounded corners
    - kernel_draw_triangle_filled: Barycentric triangle fill
    - kernel_draw_gradient_rect: Vertical gradient fill
    - kernel_blit_image: Copy source pixels to framebuffer region
    """
    # The PTX is loaded via cuda_module_load_data(). In production this
    # would be a precompiled .ptx file. The kernel signatures match the
    # argument packing functions above.
    r"
.version 7.0
.target sm_50
.address_size 64

// kernel_clear(u32* framebuffer, u32 color, i32 width, i32 height)
.visible .entry kernel_clear(
    .param .u64 fb_ptr,
    .param .u32 color,
    .param .s32 width,
    .param .s32 height
)
{
    .reg .u64 %fb, %offset;
    .reg .u32 %c, %idx;
    .reg .s32 %w, %h, %total, %tid;
    .reg .pred %p;

    ld.param.u64 %fb, [fb_ptr];
    ld.param.u32 %c, [color];
    ld.param.s32 %w, [width];
    ld.param.s32 %h, [height];

    mul.lo.s32 %total, %w, %h;
    mov.u32 %tid, %ctaid.x;
    mul.lo.u32 %tid, %tid, %ntid.x;
    add.u32 %tid, %tid, %tid.x;

    setp.ge.s32 %p, %tid, %total;
    @%p bra done;

    mul.wide.u32 %offset, %tid, 4;
    add.u64 %offset, %fb, %offset;
    st.global.u32 [%offset], %c;

done:
    ret;
}

// kernel_draw_rect_filled(u32* fb, i32 x, i32 y, i32 w, i32 h, u32 color, i32 fb_w, i32 fb_h)
.visible .entry kernel_draw_rect_filled(
    .param .u64 fb_ptr,
    .param .s32 rx,
    .param .s32 ry,
    .param .s32 rw,
    .param .s32 rh,
    .param .u32 color,
    .param .s32 fb_w,
    .param .s32 fb_h
)
{
    .reg .u64 %fb, %offset;
    .reg .u32 %c;
    .reg .s32 %x, %y, %w, %h, %fw, %fh, %px, %py, %fidx;
    .reg .pred %p1, %p2, %p3, %p4;

    ld.param.u64 %fb, [fb_ptr];
    ld.param.s32 %x, [rx];
    ld.param.s32 %y, [ry];
    ld.param.s32 %w, [rw];
    ld.param.s32 %h, [rh];
    ld.param.u32 %c, [color];
    ld.param.s32 %fw, [fb_w];
    ld.param.s32 %fh, [fb_h];

    // Thread position within the rect
    mov.u32 %px, %ctaid.x;
    mul.lo.u32 %px, %px, %ntid.x;
    add.u32 %px, %px, %tid.x;

    mov.u32 %py, %ctaid.y;
    mul.lo.u32 %py, %py, %ntid.y;
    add.u32 %py, %py, %tid.y;

    // Bounds check
    setp.ge.s32 %p1, %px, %w;
    setp.ge.s32 %p2, %py, %h;
    @%p1 bra done;
    @%p2 bra done;

    add.s32 %px, %px, %x;
    add.s32 %py, %py, %y;

    setp.ge.s32 %p3, %px, %fw;
    setp.ge.s32 %p4, %py, %fh;
    @%p3 bra done;
    @%p4 bra done;

    // Write pixel
    mul.lo.s32 %fidx, %py, %fw;
    add.s32 %fidx, %fidx, %px;
    mul.wide.s32 %offset, %fidx, 4;
    add.u64 %offset, %fb, %offset;
    st.global.u32 [%offset], %c;

done:
    ret;
}
"

# ============================================================================
# Conversion Helpers
# ============================================================================

fn _i64(v: i32) -> i64:
    v as i64

fn _i64_from_u32(v: u32) -> i64:
    v as i64
