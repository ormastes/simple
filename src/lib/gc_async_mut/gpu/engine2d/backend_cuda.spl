fn _write_u32_pixels_to_host(ptr: i64, pixels: [u32], count: i32):
    var idx = 0
    while idx < count:
        val pixel = pixels[idx] as i64
        val base = _i64(idx) * 4
        rt_ptr_write_u8(ptr, base, pixel & 0xFF)
        rt_ptr_write_u8(ptr, base + 1, (pixel >> 8) & 0xFF)
        rt_ptr_write_u8(ptr, base + 2, (pixel >> 16) & 0xFF)
        rt_ptr_write_u8(ptr, base + 3, (pixel >> 24) & 0xFF)
        idx = idx + 1

fn _cuda_2d_verify_pixels(host_ptr: i64) -> text:
    val bg = 0x11223344 as u32
    val fg = 0xAABBCCDD as u32
    val edge = 0x55667788 as u32
    val img_a = 0x01020304 as u32
    val img_b = 0x05060708 as u32
    val grad_top = 0x10203040 as u32
    val grad_bottom = 0x20304050 as u32
    val line = 0x31415926 as u32
    val circle = 0x27182818 as u32
    val filled_circle = 0xFEEDC0DE as u32
    var idx = 0
    while idx < 16:
        val x = idx % 4
        val y = idx / 4
        val border = x == 0 or x == 3 or y == 0 or y == 3
        var expected = if border: edge else: fg
        if x == 1 and y == 1:
            expected = img_a
        if x == 2 and y == 1:
            expected = img_b
        if (x == 1 or x == 2) and y == 2:
            expected = grad_top
        if (x == 1 or x == 2) and y == 3:
            expected = grad_bottom
        if y == 0:
            expected = line
        val circle_dx = x - 1
        val circle_dy = y - 1
        val circle_distance = circle_dx * circle_dx + circle_dy * circle_dy
        if circle_distance <= 4 and circle_distance >= 1:
            expected = circle
        val filled_dx = x - 2
        val filled_dy = y - 2
        val filled_distance = filled_dx * filled_dx + filled_dy * filled_dy
        if filled_distance <= 1:
            expected = filled_circle
        val actual = rt_ptr_read_i32(host_ptr, _i64(idx) * 4) as u32
        if actual != expected:
            return "readback mismatch at pixel " + idx.to_text()
        idx = idx + 1
    ""

fn _cuda_2d_run_self_test(session: CudaSession, module: i64, device_name: text) -> BackendProbeResult:
    val bytes = 64
    val image_bytes = 8
    val d_framebuffer = session.alloc(bytes)
    if d_framebuffer == 0:
        return _cuda_2d_self_test_failed(device_name, "device allocation failed")
    val d_image = session.alloc(image_bytes)
    if d_image == 0:
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "image device allocation failed")
    val clear_val_ptr = rt_alloc(CUDA_2D_CLEAR_ARG_BYTES)
    val clear_args_ptr = rt_alloc(CUDA_2D_CLEAR_ARG_BYTES)
    val rect_val_ptr = rt_alloc(72)
    val rect_args_ptr = rt_alloc(72)
    val image_host_ptr = rt_alloc(image_bytes)
    val readback_ptr = rt_alloc(bytes)
    if clear_val_ptr == 0 or clear_args_ptr == 0 or rect_val_ptr == 0 or rect_args_ptr == 0 or image_host_ptr == 0 or readback_ptr == 0:
        if clear_val_ptr != 0:
            rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        if clear_args_ptr != 0:
            rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        if rect_val_ptr != 0:
            rt_free(rect_val_ptr, 72)
        if rect_args_ptr != 0:
            rt_free(rect_args_ptr, 72)
        if image_host_ptr != 0:
            rt_free(image_host_ptr, image_bytes)
        if readback_ptr != 0:
            rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "host staging allocation failed")
    val bg = 0x11223344 as u32
    val fg = 0xAABBCCDD as u32
    val edge = 0x55667788 as u32
    val grad_top = 0x10203040 as u32
    val grad_bottom = 0x20304050 as u32
    val line = 0x31415926 as u32
    val circle = 0x27182818 as u32
    val filled_circle = 0xFEEDC0DE as u32
    _write_clear_launch_args(clear_val_ptr, clear_args_ptr, d_framebuffer, bg, 4, 4)
    val clear_rc = session.fill_kernel(4, 4, clear_args_ptr)
    if clear_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "simple_2d_fill_u32 launch failed with rc " + clear_rc.to_text())
    _write_rect_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 1, 1, 2, 2, fg, 4, 4)
    val rect_rc = cuda_launch_kernel(module, "kernel_draw_rect_filled", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if rect_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_rect_filled launch failed with rc " + rect_rc.to_text())
    _write_rect_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 0, 0, 4, 4, edge, 4, 4)
    val outline_rc = cuda_launch_kernel(module, "kernel_draw_rect_outline", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if outline_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_rect_outline launch failed with rc " + outline_rc.to_text())
    _write_u32_pixels_to_host(image_host_ptr, [0x01020304 as u32, 0x05060708 as u32], 2)
    val upload_rc = cuda_memcpy_htod(d_image, image_host_ptr, image_bytes)
    if upload_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "image upload failed with rc " + upload_rc.to_text())
    _write_image_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, d_image, 1, 1, 2, 1, 4, 4)
    val image_rc = cuda_launch_kernel(module, "kernel_draw_image", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if image_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_image launch failed with rc " + image_rc.to_text())
    _write_gradient_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 1, 2, 2, 2, grad_top, grad_bottom, 4, 4)
    val gradient_rc = cuda_launch_kernel(module, "kernel_draw_gradient_rect", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if gradient_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_gradient_rect launch failed with rc " + gradient_rc.to_text())
    _write_line_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 0, 0, 3, 0, line, 1, 4, 4)
    val line_rc = cuda_launch_kernel(module, "kernel_draw_line", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if line_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_line launch failed with rc " + line_rc.to_text())
    _write_circle_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 1, 1, 2, circle, 4, 4, 0)
    val circle_rc = cuda_launch_kernel(module, "kernel_draw_circle", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if circle_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_circle launch failed with rc " + circle_rc.to_text())
    _write_circle_launch_args(rect_val_ptr, rect_args_ptr, d_framebuffer, 2, 2, 1, filled_circle, 4, 4, 1)
    val filled_circle_rc = cuda_launch_kernel(module, "kernel_draw_circle_filled", 1, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, rect_args_ptr)
    if filled_circle_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "kernel_draw_circle_filled launch failed with rc " + filled_circle_rc.to_text())
    val sync_rc = session.sync()
    if sync_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "device sync failed with rc " + sync_rc.to_text())
    val copy_rc = cuda_memcpy_dtoh(readback_ptr, d_framebuffer, bytes)
    if copy_rc != CUDA_SUCCESS:
        rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
        rt_free(rect_val_ptr, 72)
        rt_free(rect_args_ptr, 72)
        rt_free(image_host_ptr, image_bytes)
        rt_free(readback_ptr, bytes)
        session.free(d_image)
        session.free(d_framebuffer)
        return _cuda_2d_self_test_failed(device_name, "device readback failed with rc " + copy_rc.to_text())
    val mismatch = _cuda_2d_verify_pixels(readback_ptr)
    rt_free(clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
    rt_free(clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
    rt_free(rect_val_ptr, 72)
    rt_free(rect_args_ptr, 72)
    rt_free(image_host_ptr, image_bytes)
    rt_free(readback_ptr, bytes)
    session.free(d_image)
    session.free(d_framebuffer)
    if mismatch != "":
        return _cuda_2d_self_test_failed(device_name, mismatch)
    _cuda_2d_kernel_ready(device_name)

fn probe_cuda_2d() -> BackendProbeResult:
    if not cuda_available():
        var unavailable = BackendProbeResult.unavailable("cuda", "CUDA runtime unavailable")
        unavailable.api_name = "cuda"
        unavailable.feature_gate = "cuda_runtime"
        unavailable.shader_format = "ptx"
        return unavailable
    val init_result = cuda_init()
    if init_result != CUDA_SUCCESS:
        var failed = BackendProbeResult.failed("cuda", "CUDA init failed")
        failed.api_name = "cuda"
        failed.feature_gate = "cuda_init"
        failed.shader_format = "ptx"
        return failed
    if cuda_device_count() < 1:
        var no_device = BackendProbeResult.unavailable("cuda", "no CUDA device")
        no_device.api_name = "cuda"
        no_device.feature_gate = "cuda_device"
        no_device.shader_format = "ptx"
        return no_device
    var session = CudaSession.create()
    val session_status = session.init()
    if session_status != CUDA_SUCCESS:
        return _cuda_context_failure("CUDA context creation failed before 2D render kernel load")
    val device_name = cuda_device_name(0)
    val module = session.load_module(cuda_2d_ptx_source())
    if module == 0:
        session.release()
        return _cuda_2d_kernel_gap(device_name)
    session.module_cache = module
    val self_test = _cuda_2d_run_self_test(session, module, device_name)
    session.release()
    self_test

fn probe_cuda() -> BackendProbeResult:
    probe_cuda_2d()

class CudaBackend:
    mirror: SoftwareBackend
    session: CudaSession
    owns_session: bool
    initialized: bool
    d_framebuffer: i64
    framebuffer_bytes: i64
    clear_val_ptr: i64
    clear_args_ptr: i64
    rect_val_ptr: i64
    rect_args_ptr: i64
    readback_ptr: i64
    last_probe: BackendProbeResult

    static fn create() -> CudaBackend:
        CudaBackend(
            mirror: SoftwareBackend.create(),
            session: CudaSession.create(),
            owns_session: false,
            initialized: false,
            d_framebuffer: 0,
            framebuffer_bytes: 0,
            clear_val_ptr: 0,
            clear_args_ptr: 0,
            rect_val_ptr: 0,
            rect_args_ptr: 0,
            readback_ptr: 0,
            last_probe: BackendProbeResult.unavailable("cuda", "not probed")
        )

    me init_with_session(width: i32, height: i32, session: CudaSession) -> bool:
        if width <= 0 or height <= 0:
            self.last_probe = _cuda_context_failure("invalid CUDA framebuffer dimensions")
            self.initialized = false
            return false
        if not session.is_valid():
            self.last_probe = _cuda_context_failure("CUDA shared session is not initialized")
            self.initialized = false
            return false
        self._cleanup_cuda_surface()
        self.session = session.retain()
        self.owns_session = true
        if self.session.module_cache == 0:
            val loaded = self.session.load_module(cuda_2d_ptx_source())
            if loaded == 0:
                self.last_probe = _cuda_2d_kernel_gap(cuda_device_name(0))
                self.session.release()
                self.owns_session = false
                self.initialized = false
                return false
            self.session.module_cache = loaded
            self.last_probe = _cuda_2d_run_self_test(self.session, loaded, cuda_device_name(0))
            if self.last_probe.status != BackendStatus.Initialized:
                self.session.release()
                self.owns_session = false
                self.initialized = false
                return false
        else:
            self.last_probe = _cuda_2d_run_self_test(self.session, self.session.module_cache, cuda_device_name(0))
            if self.last_probe.status != BackendStatus.Initialized:
                self.session.release()
                self.owns_session = false
                self.initialized = false
                return false
        val bytes = _i64(width) * _i64(height) * 4
        self.d_framebuffer = self.session.alloc(bytes)
        if self.d_framebuffer == 0:
            self.last_probe = _cuda_context_failure("CUDA device framebuffer allocation failed")
            self.session.release()
            self.owns_session = false
            self.initialized = false
            return false
        self.framebuffer_bytes = bytes
        if not self._alloc_launch_buffers(bytes):
            self.last_probe = _cuda_context_failure("CUDA launch argument buffer allocation failed")
            self._cleanup_cuda_surface()
            self.session.release()
            self.owns_session = false
            self.initialized = false
            return false
        if not self.mirror.init(width, height):
            self.last_probe = BackendProbeResult.failed("cuda", "CUDA host mirror surface allocation failed")
            self.last_probe.api_name = "cuda"
            self.last_probe.feature_gate = "cuda_surface"
            self.last_probe.shader_format = "ptx"
            self._cleanup_cuda_surface()
            self.session.release()
            self.owns_session = false
            self.initialized = false
            return false
        self.last_probe = _cuda_2d_kernel_ready(cuda_device_name(0))
        self.initialized = true
        true

    me _alloc_launch_buffers(bytes: i64) -> bool:
        self.clear_val_ptr = rt_alloc(CUDA_2D_CLEAR_ARG_BYTES)
        self.clear_args_ptr = rt_alloc(CUDA_2D_CLEAR_ARG_BYTES)
        self.rect_val_ptr = rt_alloc(72)
        self.rect_args_ptr = rt_alloc(72)
        self.readback_ptr = rt_alloc(bytes)
        if self.clear_val_ptr == 0 or self.clear_args_ptr == 0 or self.rect_val_ptr == 0 or self.rect_args_ptr == 0 or self.readback_ptr == 0:
            self._free_launch_buffers()
            return false
        rt_ptr_write_i64(self.clear_args_ptr, 0, self.clear_val_ptr)
        rt_ptr_write_i64(self.clear_args_ptr, 8, self.clear_val_ptr + 8)
        rt_ptr_write_i64(self.clear_args_ptr, 16, self.clear_val_ptr + 16)
        rt_ptr_write_i64(self.clear_args_ptr, 24, self.clear_val_ptr + 24)
        rt_ptr_write_i64(self.rect_args_ptr, 0, self.rect_val_ptr)
        rt_ptr_write_i64(self.rect_args_ptr, 8, self.rect_val_ptr + 8)
        rt_ptr_write_i64(self.rect_args_ptr, 16, self.rect_val_ptr + 16)
        rt_ptr_write_i64(self.rect_args_ptr, 24, self.rect_val_ptr + 24)
        rt_ptr_write_i64(self.rect_args_ptr, 32, self.rect_val_ptr + 32)
        rt_ptr_write_i64(self.rect_args_ptr, 40, self.rect_val_ptr + 40)
        rt_ptr_write_i64(self.rect_args_ptr, 48, self.rect_val_ptr + 48)
        rt_ptr_write_i64(self.rect_args_ptr, 56, self.rect_val_ptr + 56)
        true

    me _free_launch_buffers():
        if self.clear_val_ptr != 0:
            rt_free(self.clear_val_ptr, CUDA_2D_CLEAR_ARG_BYTES)
            self.clear_val_ptr = 0
        if self.clear_args_ptr != 0:
            rt_free(self.clear_args_ptr, CUDA_2D_CLEAR_ARG_BYTES)
            self.clear_args_ptr = 0
        if self.rect_val_ptr != 0:
            rt_free(self.rect_val_ptr, 72)
            self.rect_val_ptr = 0
        if self.rect_args_ptr != 0:
            rt_free(self.rect_args_ptr, 72)
            self.rect_args_ptr = 0
        if self.readback_ptr != 0:
            rt_free(self.readback_ptr, self.framebuffer_bytes)
            self.readback_ptr = 0

    me _cleanup_cuda_surface():
        self._free_launch_buffers()
        if self.d_framebuffer != 0:
            self.session.free(self.d_framebuffer)
            self.d_framebuffer = 0
        self.framebuffer_bytes = 0

    me _copy_mirror_to_device() -> bool:
        if not self.initialized or self.d_framebuffer == 0 or self.framebuffer_bytes <= 0:
            return false
        val pixels = self.mirror.read_pixels()
        val expected_pixels = self.width() * self.height()
        if pixels.len() != expected_pixels:
            return false
        val host_pixels = rt_alloc(self.framebuffer_bytes)
        if host_pixels == 0:
            return false
        _write_u32_pixels_to_host(host_pixels, pixels, expected_pixels)
        val upload_rc = cuda_memcpy_htod(self.d_framebuffer, host_pixels, self.framebuffer_bytes)
        rt_free(host_pixels, self.framebuffer_bytes)
        upload_rc == CUDA_SUCCESS

    me _disable_device_readback_after_mirror_sync_failure():
        self.last_probe = _cuda_context_failure("CUDA mirror-to-device synchronization failed")
        self.initialized = false

    me _sync_mirror_to_device_after_cpu_path():
        if self.initialized:
            if not self._copy_mirror_to_device():
                self._disable_device_readback_after_mirror_sync_failure()

impl RenderBackend for CudaBackend:
    fn name() -> text:
        "cuda"

    me init(width: i32, height: i32) -> bool:
        self.last_probe = probe_cuda_2d()
        if self.last_probe.status != BackendStatus.Initialized:
            self.initialized = false
            return false
        var session = CudaSession.create()
        val session_status = session.init()
        if session_status != CUDA_SUCCESS:
            self.last_probe = _cuda_context_failure("CUDA shared session initialization failed")
            self.initialized = false
            return false
        if not self.init_with_session(width, height, session):
            session.release()
            self.owns_session = false
            return false
        session.release()
        true

    me shutdown():
        self._cleanup_cuda_surface()
        self.mirror.shutdown()
        if self.owns_session:
            self.session.release()
            self.owns_session = false
        self.initialized = false

    me clear(color: u32):
        if self.initialized:
            _write_clear_launch_args(self.clear_val_ptr, self.clear_args_ptr, self.d_framebuffer, color, self.width(), self.height())
            val rc = self.session.fill_kernel(_i64(self.width()), _i64(self.height()), self.clear_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.clear(color)
                return
        self.mirror.clear(color)
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if (self.initialized and not self.mirror.clip_enabled and
                self.mirror.mask_buf.len() == 0):
            if w <= 0 or h <= 0:
                return
            rt_ptr_write_i64(self.rect_val_ptr, 0, self.d_framebuffer)
            rt_ptr_write_i64(self.rect_val_ptr, 8, _i64(x))
            rt_ptr_write_i64(self.rect_val_ptr, 16, _i64(y))
            rt_ptr_write_i64(self.rect_val_ptr, 24, _i64(w))
            rt_ptr_write_i64(self.rect_val_ptr, 32, _i64(h))
            rt_ptr_write_i64(self.rect_val_ptr, 40, _i64_from_u32(color))
            rt_ptr_write_i64(self.rect_val_ptr, 48, _i64(self.width()))
            rt_ptr_write_i64(self.rect_val_ptr, 56, _i64(self.height()))
            val total = _i64(w) * _i64(h)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_rect_outline", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.draw_rect(x, y, w, h, color)
                return
        self.mirror.draw_rect(x, y, w, h, color)
        self._sync_mirror_to_device_after_cpu_path()
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if (self.initialized and not self.mirror.clip_enabled and
                self.mirror.mask_buf.len() == 0):
            if w <= 0 or h <= 0:
                return
            rt_ptr_write_i64(self.rect_val_ptr, 0, self.d_framebuffer)
            rt_ptr_write_i64(self.rect_val_ptr, 8, _i64(x))
            rt_ptr_write_i64(self.rect_val_ptr, 16, _i64(y))
            rt_ptr_write_i64(self.rect_val_ptr, 24, _i64(w))
            rt_ptr_write_i64(self.rect_val_ptr, 32, _i64(h))
            rt_ptr_write_i64(self.rect_val_ptr, 40, _i64_from_u32(color))
            rt_ptr_write_i64(self.rect_val_ptr, 48, _i64(self.width()))
            rt_ptr_write_i64(self.rect_val_ptr, 56, _i64(self.height()))
            val total = _i64(w) * _i64(h)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_rect_filled", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.draw_rect_filled(x, y, w, h, color)
                return
        self.mirror.draw_rect_filled(x, y, w, h, color)
        self._sync_mirror_to_device_after_cpu_path()
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if (self.initialized and thickness > 0 and
                not self.mirror.clip_enabled and self.mirror.mask_buf.len() == 0):
            _write_line_launch_args(self.rect_val_ptr, self.rect_args_ptr, self.d_framebuffer, x1, y1, x2, y2, color, thickness, self.width(), self.height())
            var dx = x2 - x1
            if dx < 0:
                dx = -dx
            var dy = y2 - y1
            if dy < 0:
                dy = -dy
            val steps = if dx > dy: dx else: dy
            val total = _i64(steps + 1) * _i64(thickness) * _i64(thickness)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_line", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.draw_line(x1, y1, x2, y2, color, thickness)
                return
        self.mirror.draw_line(x1, y1, x2, y2, color, thickness)
        self._sync_mirror_to_device_after_cpu_path()
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        if r == 0:
            self.draw_rect_filled(cx, cy, 1, 1, color)
            return
        if (self.initialized and r > 0 and
                not self.mirror.clip_enabled and self.mirror.mask_buf.len() == 0):
            _write_circle_launch_args(self.rect_val_ptr, self.rect_args_ptr, self.d_framebuffer, cx, cy, r, color, self.width(), self.height(), 0)
            val diameter = 2 * r + 1
            val total = _i64(diameter) * _i64(diameter)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_circle", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.draw_circle(cx, cy, r, color)
                return
        self.mirror.draw_circle(cx, cy, r, color)
        self._sync_mirror_to_device_after_cpu_path()
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if r == 0:
            self.draw_rect_filled(cx, cy, 1, 1, color)
            return
        if (self.initialized and r > 0 and
                not self.mirror.clip_enabled and self.mirror.mask_buf.len() == 0):
            _write_circle_launch_args(self.rect_val_ptr, self.rect_args_ptr, self.d_framebuffer, cx, cy, r, color, self.width(), self.height(), 1)
            val diameter = 2 * r + 1
            val total = _i64(diameter) * _i64(diameter)
            val grid_x = (total + CUDA_2D_BLOCK_SIZE - 1) / CUDA_2D_BLOCK_SIZE
            val rc = self.session.launch_kernel_args("kernel_draw_circle_filled", grid_x, 1, 1, CUDA_2D_BLOCK_SIZE, 1, 1, self.rect_args_ptr)
            if rc == CUDA_SUCCESS:
                self.mirror.draw_circle_filled(cx, cy, r, color)
