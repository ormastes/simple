    me _cleanup():
        if self.ffi != nil:
            if self.kernel_cache != 0:
                self.ffi.release_kernel(self.kernel_cache)
            if self.program != 0:
                self.ffi.release_program(self.program)
            if self.queue != 0:
                self.ffi.release_queue(self.queue)
            if self.context != 0:
                self.ffi.release_context(self.context)
        self.ref_count = 0
        self.platform = 0
        self.context = 0
        self.queue = 0
        self.program = 0
        self.kernel_cache = 0
        self.is_initialized = false
        self.generation = self.generation + 1

    fn _evidence(operation: text, success: bool, status_code: text, reason: text, kernel: i64, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> OpenClSessionEvidence:
        OpenClSessionEvidence.create(
            operation,
            success,
            status_code,
            reason,
            self.platform,
            self.context,
            self.queue,
            self.program,
            kernel,
            self.generation,
            readback_available,
            expected_checksum,
            actual_checksum
        )

fn _ceil_div_i64(value: i64, divisor: i64) -> i64:
    (value + divisor - 1) / divisor
