# OpenCL Session
#
# Shared generic OpenCL ICD state boundary for Engine2D compute sessions.

use std.gc_async_mut.gpu.engine2d.backend_session.{BackendSessionKind}
use std.gc_async_mut.gpu.engine2d.generated_kernel_dispatch.{
    GENERATED_2D_ALPHA, GENERATED_2D_COPY, GENERATED_2D_FILL, GENERATED_2D_GLYPH, GENERATED_2D_SCROLL,
    Generated2DSessionRuntimeProvenance,
    generated_2d_launch_plan,
    generated_2d_session_launch_gate,
    generated_2d_session_runtime_provenance
}
use std.gc_async_mut.gpu.engine2d.session_support.{gpu_session_launch_gate_status, gpu_session_readback_status}
use std.gc_async_mut.gpu.engine2d.sffi_opencl.{OpenClFfi}

extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64

class OpenClSessionEvidence:
    operation: text
    success: bool
    status_code: text
    reason: text
    platform: i64
    context: i64
    queue: i64
    program: i64
    kernel: i64
    generation: i64
    readback_available: bool
    expected_checksum: i64
    actual_checksum: i64

    static fn create(operation: text, success: bool, status_code: text, reason: text, platform: i64, context: i64, queue: i64, program: i64, kernel: i64, generation: i64, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> OpenClSessionEvidence:
        OpenClSessionEvidence(
            operation: operation,
            success: success,
            status_code: status_code,
            reason: reason,
            platform: platform,
            context: context,
            queue: queue,
            program: program,
            kernel: kernel,
            generation: generation,
            readback_available: readback_available,
            expected_checksum: expected_checksum,
            actual_checksum: actual_checksum
        )

    fn diagnostic_text() -> text:
        "OpenClSessionEvidence[op={self.operation} success={self.success.to_text()} status={self.status_code} reason={self.reason} platform={self.platform} context={self.context} queue={self.queue} program={self.program} kernel={self.kernel} generation={self.generation} readback={self.readback_available.to_text()} expected={self.expected_checksum} actual={self.actual_checksum}]"

class OpenClSession:
    platform: i64
    context: i64
    queue: i64
    program: i64
    kernel_cache: i64
    ref_count: i64
    is_initialized: bool
    generation: i64
    ffi: OpenClFfi?

    static fn create() -> OpenClSession:
        OpenClSession(
            platform: 0,
            context: 0,
            queue: 0,
            program: 0,
            kernel_cache: 0,
            ref_count: 0,
            is_initialized: false,
            generation: 0,
            ffi: nil
        )

    static fn create_with_ffi(ffi: OpenClFfi) -> OpenClSession:
        val session = OpenClSession.create()
        session.ffi = ffi
        session

    fn kind() -> BackendSessionKind:
        BackendSessionKind.OpenCl

    fn is_available() -> bool:
        if self.ffi == nil:
            return false
        self.ffi.is_available()

    me init() -> i64:
        if self.ffi == nil:
            return 1
        if not self.ffi.is_available():
            return 1
        if self.ffi.platform_count() < 1:
            return 1
        self.platform = 1
        self.context = self.ffi.create_context(self.platform)
        if self.context == 0:
            return 1
        self.queue = self.ffi.create_queue(self.context)
        if self.queue == 0:
            return 1
        self.ref_count = 1
        self.is_initialized = true
        self.generation = self.generation + 1
        0

    me init_evidence() -> OpenClSessionEvidence:
        val rc = self.init()
        if rc == 0:
            return self._evidence("init", true, "initialized", "opencl-session-initialized", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("init", false, "missing-ffi", "missing-opencl-ffi", 0, false, 0, 0)
        if not self.ffi.is_available():
            return self._evidence("init", false, "runtime-unavailable", "opencl-runtime-unavailable", 0, false, 0, 0)
        if self.ffi.platform_count() < 1:
            return self._evidence("init", false, "platform-unavailable", "opencl-platform-unavailable", 0, false, 0, 0)
        if self.context == 0:
            return self._evidence("init", false, "context-unavailable", "opencl-context-create-failed", 0, false, 0, 0)
        if self.queue == 0:
            return self._evidence("init", false, "queue-unavailable", "opencl-queue-create-failed", 0, false, 0, 0)
        self._evidence("init", false, "init-failed", "opencl-init-failed", 0, false, 0, 0)

    me is_valid() -> bool:
        self.is_initialized and self.queue != 0

    me retain() -> OpenClSession:
        self.ref_count = self.ref_count + 1
        self

    me release():
        if self.ref_count <= 0:
            return
        self.ref_count = self.ref_count - 1
        if self.ref_count == 0:
            self._cleanup()

    me load_module(source: text) -> i64:
        if self.ffi == nil or self.context == 0:
            return 0
        val program = self.ffi.create_program(self.context, source)
        if program == 0:
            return 0
        if not self.ffi.build_program(program):
            return 0
        self.program = program
        program

    me load_module_evidence(source: text) -> OpenClSessionEvidence:
        val program = self.load_module(source)
        if program != 0:
            return self._evidence("load_module", true, "loaded", "opencl-program-built", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("load_module", false, "missing-ffi", "missing-opencl-ffi", 0, false, 0, 0)
        if self.context == 0:
            return self._evidence("load_module", false, "missing-context", "missing-opencl-context", 0, false, 0, 0)
        if source == "":
            return self._evidence("load_module", false, "empty-source", "missing-opencl-program-source", 0, false, 0, 0)
        self._evidence("load_module", false, "build-failed", "opencl-program-build-failed", 0, false, 0, 0)

    me launch_kernel(name: text, gx: i64, gy: i64, lx: i64, ly: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if self.ffi.enqueue_ndrange(self.queue, kernel, gx, gy, 1, lx, ly, 1):
            0
        else:
            1

    me launch_kernel_evidence(name: text, gx: i64, gy: i64, lx: i64, ly: i64) -> OpenClSessionEvidence:
        val rc = self.launch_kernel(name, gx, gy, lx, ly)
        if rc == 0:
            return self._evidence("launch_kernel", true, "submitted", "opencl-kernel-submitted", self.kernel_cache, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("launch_kernel", false, "missing-ffi", "missing-opencl-ffi", 0, false, 0, 0)
        if self.queue == 0 or self.program == 0:
            return self._evidence("launch_kernel", false, "missing-program-or-queue", "missing-opencl-program-or-queue", 0, false, 0, 0)
        if self.kernel_cache == 0:
            return self._evidence("launch_kernel", false, "missing-kernel", "opencl-kernel-create-failed", 0, false, 0, 0)
        self._evidence("launch_kernel", false, "submit-failed", "opencl-kernel-submit-failed", self.kernel_cache, false, 0, 0)

    me launch_generated_2d(op: text, width: i64, height: i64, args_ptr: i64) -> i64:
        val gate = generated_2d_session_launch_gate("opencl", op, width, height, self.ffi != nil and self.queue != 0, self.program != 0, args_ptr)
        if not gate.ready:
            return 1
        if op == GENERATED_2D_FILL:
            return self._launch_generated_fill_u32(gate.plan.entry_name, args_ptr, width, height, gate.plan.grid_x, gate.plan.grid_y, gate.plan.block_x, gate.plan.block_y)
        if op == GENERATED_2D_GLYPH:
            return self._launch_generated_glyph_u32(gate.plan.entry_name, args_ptr, width, height, gate.plan.grid_x, gate.plan.grid_y, gate.plan.block_x, gate.plan.block_y)
        self.launch_kernel(gate.plan.entry_name, gate.plan.grid_x, gate.plan.grid_y, gate.plan.block_x, gate.plan.block_y)

    me launch_generated_2d_evidence(op: text, width: i64, height: i64, args_ptr: i64) -> OpenClSessionEvidence:
        val operation = "launch_generated_2d:{op}"
        val gate = generated_2d_session_launch_gate("opencl", op, width, height, self.ffi != nil and self.queue != 0, self.program != 0, args_ptr)
        val status = gpu_session_launch_gate_status(
            "opencl",
            gate,
            self.ffi == nil,
            "missing-opencl-ffi",
            "missing-program-or-queue",
            "missing-opencl-program-or-queue",
            "missing-program-or-queue",
            "missing-opencl-program-or-queue"
        )
        if not status.ready:
            return self._evidence(operation, false, status.status_code, status.reason, 0, false, 0, 0)
        if op == GENERATED_2D_GLYPH:
            val args_status = self._generated_glyph_args_status(args_ptr, width, height)
            if args_status != "ready":
                return self._evidence(operation, false, "invalid-args", args_status, 0, false, 0, 0)
        val rc = self.launch_generated_2d(op, width, height, args_ptr)
        if rc == 0:
            return self._evidence(operation, true, "submitted", "opencl-generated-2d-kernel-submitted", self.kernel_cache, true, 0, 0)
        if self.kernel_cache == 0:
            return self._evidence(operation, false, "missing-kernel", "opencl-generated-2d-kernel-create-failed", 0, false, 0, 0)
        self._evidence(operation, false, "submit-failed", "opencl-generated-2d-kernel-submit-failed", self.kernel_cache, false, 0, 0)

    me launch_generated_2d_runtime_provenance(op: text, width: i64, height: i64, args_ptr: i64) -> Generated2DSessionRuntimeProvenance:
        generated_2d_session_runtime_provenance("opencl", op, width, height, self.ffi != nil and self.queue != 0, self.program != 0, args_ptr)

    me launch_fill_u32(dst: i64, width: i64, height: i64, color: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or dst == 0 or width <= 0 or height <= 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, "simple_2d_fill_u32")
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if not self.set_kernel_arg_buffer(kernel, 0, dst):
            return 1
        if not self.set_kernel_arg_i64(kernel, 1, width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 2, height):
            return 1
        if not self.set_kernel_arg_i64(kernel, 3, color):
            return 1
        val local_size = 256
        val global_size = _ceil_div_i64(width * height, local_size)
        if self.ffi.enqueue_ndrange(self.queue, kernel, global_size, 1, 1, local_size, 1, 1):
            0
        else:
            1

    me _launch_generated_fill_u32(entry_name: text, args_ptr: i64, width: i64, height: i64, grid_x: i64, grid_y: i64, block_x: i64, block_y: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or args_ptr == 0 or width <= 0 or height <= 0:
            return 1
        val dst = rt_ptr_read_i64(args_ptr, 0)
        val arg_width = rt_ptr_read_i64(args_ptr, 8)
        val arg_height = rt_ptr_read_i64(args_ptr, 16)
        val color = rt_ptr_read_i64(args_ptr, 24)
        if dst == 0 or arg_width != width or arg_height != height:
            return 1
        val kernel = self.ffi.create_kernel(self.program, entry_name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if not self.set_kernel_arg_buffer(kernel, 0, dst):
            return 1
        if not self.set_kernel_arg_i64(kernel, 1, width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 2, height):
            return 1
        if not self.set_kernel_arg_i64(kernel, 3, color):
            return 1
        if self.ffi.enqueue_ndrange(self.queue, kernel, grid_x, grid_y, 1, block_x, block_y, 1):
            0
        else:
            1

    me _generated_glyph_args_status(args_ptr: i64, width: i64, height: i64) -> text:
        if args_ptr == 0:
            return "missing-generated-2d-args-pointer"
        if width <= 0 or height <= 0:
            return "invalid-generated-glyph-dimensions"
        val glyph_plan = rt_ptr_read_i64(args_ptr, 0)
        val dst = rt_ptr_read_i64(args_ptr, 8)
        val arg_width = rt_ptr_read_i64(args_ptr, 16)
        val arg_height = rt_ptr_read_i64(args_ptr, 24)
        val font_size = rt_ptr_read_i64(args_ptr, 32)
        if glyph_plan == 0:
            return "missing-opencl-glyph-plan"
        if dst == 0:
            return "missing-opencl-glyph-dst"
        if arg_width != width or arg_height != height:
            return "opencl-glyph-dimensions-mismatch"
        if font_size <= 0:
            return "invalid-opencl-glyph-font-size"
        "ready"

    me _launch_generated_glyph_u32(entry_name: text, args_ptr: i64, width: i64, height: i64, grid_x: i64, grid_y: i64, block_x: i64, block_y: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0:
            return 1
        if self._generated_glyph_args_status(args_ptr, width, height) != "ready":
            return 1
        val glyph_plan = rt_ptr_read_i64(args_ptr, 0)
        val dst = rt_ptr_read_i64(args_ptr, 8)
        val font_size = rt_ptr_read_i64(args_ptr, 32)
        val kernel = self.ffi.create_kernel(self.program, entry_name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if not self.set_kernel_arg_buffer(kernel, 0, glyph_plan):
            return 1
        if not self.set_kernel_arg_buffer(kernel, 1, dst):
            return 1
        if not self.set_kernel_arg_i64(kernel, 2, width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 3, height):
            return 1
        if not self.set_kernel_arg_i64(kernel, 4, font_size):
            return 1
        if self.ffi.enqueue_ndrange(self.queue, kernel, grid_x, grid_y, 1, block_x, block_y, 1):
            0
        else:
            1

    me launch_rect_filled_u32(dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> i64:
        self._launch_rect_u32("simple_2d_rect_filled_u32", dst, surface_width, surface_height, x, y, w, h, color)

    me launch_rect_outline_u32(dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> i64:
        self._launch_rect_u32("simple_2d_rect_outline_u32", dst, surface_width, surface_height, x, y, w, h, color)

    me launch_line_u32(dst: i64, surface_width: i64, surface_height: i64, x1: i64, y1: i64, x2: i64, y2: i64, color: i64, thickness: i64) -> i64:
        self._launch_line_u32("simple_2d_line_u32", dst, surface_width, surface_height, x1, y1, x2, y2, color, thickness)

    me launch_gradient_rect_u32(dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, top_color: i64, bottom_color: i64) -> i64:
        self._launch_gradient_rect_u32("simple_2d_gradient_rect_u32", dst, surface_width, surface_height, x, y, w, h, top_color, bottom_color)

    me launch_circle_u32(dst: i64, surface_width: i64, surface_height: i64, cx: i64, cy: i64, r: i64, color: i64, filled: bool) -> i64:
        if filled:
            return self._launch_circle_u32("simple_2d_circle_filled_u32", dst, surface_width, surface_height, cx, cy, r, color)
        self._launch_circle_u32("simple_2d_circle_u32", dst, surface_width, surface_height, cx, cy, r, color)

    me launch_rounded_rect_u32(dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, radius: i64, color: i64) -> i64:
        self._launch_rounded_rect_u32("simple_2d_rounded_rect_u32", dst, surface_width, surface_height, x, y, w, h, radius, color)

    me launch_triangle_filled_u32(dst: i64, surface_width: i64, surface_height: i64, x1: i64, y1: i64, x2: i64, y2: i64, x3: i64, y3: i64, color: i64) -> i64:
        self._launch_triangle_filled_u32("simple_2d_triangle_filled_u32", dst, surface_width, surface_height, x1, y1, x2, y2, x3, y3, color)

    me launch_blit_image_u32(dst: i64, src: i64, x: i64, y: i64, w: i64, h: i64, surface_width: i64, surface_height: i64) -> i64:
        self._launch_blit_u32("simple_2d_blit_image_u32", dst, src, x, y, w, h, surface_width, surface_height)

    me launch_blit_nonzero_u32(dst: i64, src: i64, x: i64, y: i64, w: i64, h: i64, surface_width: i64, surface_height: i64) -> i64:
        self._launch_blit_u32("simple_2d_blit_nonzero_u32", dst, src, x, y, w, h, surface_width, surface_height)

    me fill_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_FILL, width, height, args_ptr)

    me copy_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_COPY, width, height, args_ptr)

    me alpha_blend_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_ALPHA, width, height, args_ptr)

    me scroll_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_SCROLL, width, height, args_ptr)

    me glyph_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_GLYPH, width, height, args_ptr)

    me alloc(size: i64) -> i64:
        if self.ffi == nil or self.context == 0 or size <= 0:
            return 0
        self.ffi.mem_alloc(self.context, size)

    me free(buffer: i64):
        if self.ffi == nil or buffer == 0:
            return
        self.ffi.mem_free(buffer)

    me write_buffer(buffer: i64, host_ptr: i64, size: i64) -> bool:
        if self.ffi == nil or self.queue == 0 or buffer == 0 or host_ptr == 0 or size <= 0:
            return false
        self.ffi.write_buffer(self.queue, buffer, host_ptr, size)

    me read_buffer(buffer: i64, host_ptr: i64, size: i64) -> bool:
        if self.ffi == nil or self.queue == 0 or buffer == 0 or host_ptr == 0 or size <= 0:
            return false
        self.ffi.read_buffer(self.queue, buffer, host_ptr, size)

    me read_buffer_evidence(buffer: i64, host_ptr: i64, size: i64, expected_checksum: i64, actual_checksum: i64) -> OpenClSessionEvidence:
        if self.ffi == nil:
            return self._evidence("read_buffer", false, "missing-ffi", "missing-opencl-ffi", 0, false, expected_checksum, actual_checksum)
        if self.queue == 0:
            return self._evidence("read_buffer", false, "missing-queue", "missing-opencl-queue", 0, false, expected_checksum, actual_checksum)
        if buffer == 0:
            return self._evidence("read_buffer", false, "missing-buffer", "missing-opencl-device-buffer", 0, false, expected_checksum, actual_checksum)
        if host_ptr == 0:
            return self._evidence("read_buffer", false, "missing-host-buffer", "missing-opencl-host-readback-buffer", 0, false, expected_checksum, actual_checksum)
        if size <= 0:
            return self._evidence("read_buffer", false, "invalid-size", "invalid-opencl-readback-size", 0, false, expected_checksum, actual_checksum)
        if not self.read_buffer(buffer, host_ptr, size):
            return self._evidence("read_buffer", false, "readback-failed", "opencl-buffer-read-failed", 0, false, expected_checksum, actual_checksum)
        self.readback_evidence(true, expected_checksum, actual_checksum)

    me set_kernel_arg_i64(kernel: i64, index: i64, value: i64) -> bool:
        if self.ffi == nil or kernel == 0 or index < 0:
            return false
        self.ffi.set_kernel_arg_i64(kernel, index, value)

    me set_kernel_arg_buffer(kernel: i64, index: i64, buffer: i64) -> bool:
        if self.ffi == nil or kernel == 0 or buffer == 0 or index < 0:
            return false
        self.ffi.set_kernel_arg_buffer(kernel, index, buffer)

    me synchronize() -> i64:
        if self.ffi == nil or self.queue == 0:
            return 1
        if self.ffi.finish(self.queue):
            0
        else:
            1

    me synchronize_evidence() -> OpenClSessionEvidence:
        val rc = self.synchronize()
        if rc == 0:
            return self._evidence("synchronize", true, "synchronized", "opencl-queue-finished", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("synchronize", false, "missing-ffi", "missing-opencl-ffi", 0, false, 0, 0)
        if self.queue == 0:
            return self._evidence("synchronize", false, "missing-queue", "missing-opencl-queue", 0, false, 0, 0)
        self._evidence("synchronize", false, "sync-failed", "opencl-queue-finish-failed", 0, false, 0, 0)

    fn readback_evidence(readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> OpenClSessionEvidence:
        val status = gpu_session_readback_status(
            "opencl",
            readback_available,
            expected_checksum,
            actual_checksum,
            "device-readback-required",
            "device-readback-checksum-required",
            "readback-checksum-matched",
            "device-readback-checksum-mismatch"
        )
        self._evidence("readback", status.success, status.status_code, status.reason, 0, status.readback_available, expected_checksum, actual_checksum)

    me shutdown():
        self.ref_count = 0
        self._cleanup()

    me _cache_kernel(kernel: i64):
        if self.ffi != nil and self.kernel_cache != 0:
            self.ffi.release_kernel(self.kernel_cache)
        self.kernel_cache = kernel

    me _launch_rect_u32(name: text, dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or dst == 0 or surface_width <= 0 or surface_height <= 0 or w <= 0 or h <= 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if not self.set_kernel_arg_buffer(kernel, 0, dst):
            return 1
        if not self.set_kernel_arg_i64(kernel, 1, surface_width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 2, surface_height):
            return 1
        if not self.set_kernel_arg_i64(kernel, 3, x):
            return 1
        if not self.set_kernel_arg_i64(kernel, 4, y):
            return 1
        if not self.set_kernel_arg_i64(kernel, 5, w):
            return 1
        if not self.set_kernel_arg_i64(kernel, 6, h):
            return 1
        if not self.set_kernel_arg_i64(kernel, 7, color):
            return 1
        val local_size = 256
        val global_size = _ceil_div_i64(w * h, local_size)
        if self.ffi.enqueue_ndrange(self.queue, kernel, global_size, 1, 1, local_size, 1, 1):
            0
        else:
            1

    me _launch_line_u32(name: text, dst: i64, surface_width: i64, surface_height: i64, x1: i64, y1: i64, x2: i64, y2: i64, color: i64, thickness: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or dst == 0 or surface_width <= 0 or surface_height <= 0 or thickness <= 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
        if not self.set_kernel_arg_buffer(kernel, 0, dst):
            return 1
        if not self.set_kernel_arg_i64(kernel, 1, surface_width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 2, surface_height):
            return 1
        if not self.set_kernel_arg_i64(kernel, 3, x1):
            return 1
        if not self.set_kernel_arg_i64(kernel, 4, y1):
