    me _launch_triangle_filled_u32(name: text, dst: i64, surface_width: i64, surface_height: i64, x1: i64, y1: i64, x2: i64, y2: i64, x3: i64, y3: i64, color: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or dst == 0 or surface_width <= 0 or surface_height <= 0:
            return 1
        var min_x = x1
        if x2 < min_x:
            min_x = x2
        if x3 < min_x:
            min_x = x3
        var min_y = y1
        if y2 < min_y:
            min_y = y2
        if y3 < min_y:
            min_y = y3
        var max_x = x1
        if x2 > max_x:
            max_x = x2
        if x3 > max_x:
            max_x = x3
        var max_y = y1
        if y2 > max_y:
            max_y = y2
        if y3 > max_y:
            max_y = y3
        val w = max_x - min_x + 1
        val h = max_y - min_y + 1
        if w <= 0 or h <= 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
            return 1
        self._cache_kernel(kernel)
