# OpenCL Session
#
# Shared generic OpenCL ICD state boundary for Engine2D compute sessions.

use std.gc_async_mut.gpu.engine2d.backend_session.{BackendSessionKind}
use std.gc_async_mut.gpu.engine2d.generated_kernel_dispatch.{
    GENERATED_2D_ALPHA, GENERATED_2D_COPY, GENERATED_2D_FILL, GENERATED_2D_SCROLL,
    generated_2d_launch_plan
}
use std.gc_async_mut.gpu.engine2d.sffi_opencl.{OpenClFfi}

class OpenClSession:
    platform: i64
    context: i64
    queue: i64
    program: i64
    kernel_cache: i64
    ref_count: i64
    is_initialized: bool
    generation: i64
    ffi: OpenClFfi?

    static fn create() -> OpenClSession:
        OpenClSession(
            platform: 0,
            context: 0,
            queue: 0,
            program: 0,
            kernel_cache: 0,
            ref_count: 0,
            is_initialized: false,
            generation: 0,
            ffi: nil
        )

    static fn create_with_ffi(ffi: OpenClFfi) -> OpenClSession:
        val session = OpenClSession.create()
        session.ffi = ffi
        session

    fn kind() -> BackendSessionKind:
        BackendSessionKind.OpenCl

    fn is_available() -> bool:
        if self.ffi == nil:
            return false
        self.ffi.is_available()

    me init() -> i64:
        if self.ffi == nil:
            return 1
        if not self.ffi.is_available():
            return 1
        if self.ffi.platform_count() < 1:
            return 1
        self.platform = 1
        self.context = self.ffi.create_context(self.platform)
        if self.context == 0:
            return 1
        self.queue = self.ffi.create_queue(self.context)
        if self.queue == 0:
            return 1
        self.ref_count = 1
        self.is_initialized = true
        self.generation = self.generation + 1
        0

    me is_valid() -> bool:
        self.is_initialized and self.queue != 0

    me load_module(source: text) -> i64:
        if self.ffi == nil or self.context == 0:
            return 0
        val program = self.ffi.create_program(self.context, source)
        if program == 0:
            return 0
        if not self.ffi.build_program(program):
            return 0
        self.program = program
        program

    me launch_kernel(name: text, gx: i64, gy: i64, lx: i64, ly: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
            return 1
        self.kernel_cache = kernel
        if self.ffi.enqueue_ndrange(self.queue, kernel, gx, gy, 1, lx, ly, 1):
            0
        else:
            1

    me launch_generated_2d(op: text, width: i64, height: i64, args_ptr: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0:
            return 1
        if args_ptr == 0:
            return 1
        val plan = generated_2d_launch_plan("opencl", op, width, height)
        if not plan.dispatch_ready:
            return 1
        self.launch_kernel(plan.entry_name, plan.grid_x, plan.grid_y, plan.block_x, plan.block_y)

    me fill_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_FILL, width, height, args_ptr)

    me copy_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_COPY, width, height, args_ptr)

    me alpha_blend_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_ALPHA, width, height, args_ptr)

    me scroll_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_SCROLL, width, height, args_ptr)

    me synchronize() -> i64:
        if self.ffi == nil or self.queue == 0:
            return 1
        if self.ffi.finish(self.queue):
            0
        else:
            1

    me shutdown():
        self.ref_count = 0
        self.platform = 0
        self.context = 0
        self.queue = 0
        self.program = 0
        self.kernel_cache = 0
        self.is_initialized = false
        self.generation = self.generation + 1
