        if not self.set_kernel_arg_i64(kernel, 6, surface_width):
            return 1
        if not self.set_kernel_arg_i64(kernel, 7, surface_height):
            return 1
        val local_size = 256
        val global_size = _ceil_div_i64(w * h, local_size)
        if self.ffi.enqueue_ndrange(self.queue, kernel, global_size, 1, 1, local_size, 1, 1):
            0
        else:
