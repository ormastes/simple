        if not self.set_kernel_arg_i64(kernel, 5, x2):
            return 1
        if not self.set_kernel_arg_i64(kernel, 6, y2):
            return 1
        if not self.set_kernel_arg_i64(kernel, 7, color):
            return 1
        if not self.set_kernel_arg_i64(kernel, 8, thickness):
            return 1
        var dx = x2 - x1
        if dx < 0:
            dx = -dx
        var dy = y2 - y1
        if dy < 0:
            dy = -dy
        var steps = dx
        if dy > steps:
            steps = dy
        if steps == 0:
            steps = 1
        val local_size = 256
        val global_size = _ceil_div_i64(steps + 1, local_size)
        if self.ffi.enqueue_ndrange(self.queue, kernel, global_size, 1, 1, local_size, 1, 1):
            0
        else:
            1

    me _launch_gradient_rect_u32(name: text, dst: i64, surface_width: i64, surface_height: i64, x: i64, y: i64, w: i64, h: i64, top_color: i64, bottom_color: i64) -> i64:
