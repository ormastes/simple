            return 1
        if not self.set_kernel_arg_i64(kernel, 12, w):
            return 1
        if not self.set_kernel_arg_i64(kernel, 13, h):
            return 1
        val local_size = 256
        val global_size = _ceil_div_i64(w * h, local_size)
        if self.ffi.enqueue_ndrange(self.queue, kernel, global_size, 1, 1, local_size, 1, 1):
            0
        else:
            1

    me _launch_blit_u32(name: text, dst: i64, src: i64, x: i64, y: i64, w: i64, h: i64, surface_width: i64, surface_height: i64) -> i64:
        if self.ffi == nil or self.queue == 0 or self.program == 0 or dst == 0 or src == 0 or surface_width <= 0 or surface_height <= 0 or w <= 0 or h <= 0:
            return 1
        val kernel = self.ffi.create_kernel(self.program, name)
        if kernel == 0:
