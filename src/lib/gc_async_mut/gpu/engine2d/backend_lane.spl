# Engine2D backend lane contract.
#
# Drawing backends own framebuffer-visible primitive rendering. Processing
# backends own compute/offload work that may prepare or transform draw data.

val ENGINE2D_BACKEND_LANE_DRAWING: text = "drawing"
val ENGINE2D_BACKEND_LANE_PROCESSING: text = "processing"
val ENGINE2D_BACKEND_LANE_COMBINED: text = "combined"

struct Engine2dBackendLane:
    lane: text
    backend_name: text
    responsibility: text
    owns_framebuffer: bool
    owns_kernel_dispatch: bool
    requires_readback: bool

struct Engine2dBackendLanePlan:
    drawing_backend: Engine2dBackendLane
    processing_backend: Engine2dBackendLane
    processing_required: bool
    shared_device_preferred: bool
    split_required: bool
    fallback_reason: text

fn engine2d_drawing_backend_lane(backend_name: text) -> Engine2dBackendLane:
    Engine2dBackendLane(
        lane: ENGINE2D_BACKEND_LANE_DRAWING,
        backend_name: backend_name,
        responsibility: "primitive draw, framebuffer ownership, present, readback",
        owns_framebuffer: true,
        owns_kernel_dispatch: false,
        requires_readback: true
    )

fn engine2d_processing_backend_lane(backend_name: text) -> Engine2dBackendLane:
    Engine2dBackendLane(
        lane: ENGINE2D_BACKEND_LANE_PROCESSING,
        backend_name: backend_name,
        responsibility: "compute kernels, generated artifacts, filters, offload, sync evidence",
        owns_framebuffer: false,
        owns_kernel_dispatch: true,
        requires_readback: false
    )

fn engine2d_combined_backend_lane(backend_name: text) -> Engine2dBackendLane:
    Engine2dBackendLane(
        lane: ENGINE2D_BACKEND_LANE_COMBINED,
        backend_name: backend_name,
        responsibility: "drawing and processing on one backend/device",
        owns_framebuffer: true,
        owns_kernel_dispatch: true,
        requires_readback: true
    )

fn engine2d_backend_lane_summary(lane: Engine2dBackendLane) -> text:
    "lane={lane.lane};backend={lane.backend_name};framebuffer={lane.owns_framebuffer};kernels={lane.owns_kernel_dispatch};readback={lane.requires_readback}"

fn engine2d_backend_lane_plan(drawing_backend_name: text, processing_backend_name: text, processing_required: bool, shared_device_preferred: bool) -> Engine2dBackendLanePlan:
    val drawing = engine2d_drawing_backend_lane(drawing_backend_name)
    val processing_name = if processing_backend_name == "": drawing_backend_name else: processing_backend_name
    val processing = engine2d_processing_backend_lane(processing_name)
    var split_required = processing_required and drawing_backend_name != processing_name
    var fallback_reason = ""
    if processing_required and processing_backend_name == "":
        split_required = false
        fallback_reason = "processing backend not specified; using drawing backend for combined fallback"
    Engine2dBackendLanePlan(
        drawing_backend: drawing,
        processing_backend: processing,
        processing_required: processing_required,
        shared_device_preferred: shared_device_preferred,
        split_required: split_required,
        fallback_reason: fallback_reason
    )

fn engine2d_operation_lane(operation: text) -> text:
    if operation == "draw_ir" or operation == "primitive_draw" or operation == "present" or operation == "readback":
        return ENGINE2D_BACKEND_LANE_DRAWING
    if operation == "generated_kernel" or operation == "filter" or operation == "layout_compute" or operation == "simd_offload":
        return ENGINE2D_BACKEND_LANE_PROCESSING
    ENGINE2D_BACKEND_LANE_COMBINED
