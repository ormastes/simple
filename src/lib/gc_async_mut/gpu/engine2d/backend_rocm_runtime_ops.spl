#[runtime_intrinsics]
use std.gc_async_mut.io.rocm_sffi.{
    rt_rocm_is_available, rt_rocm_init, rt_rocm_device_count,
    rt_rocm_get_device, rt_rocm_device_identity,
    rt_rocm_device_name, rt_rocm_device_memory,
    rt_rocm_malloc, rt_rocm_free,
    rt_rocm_memset, rt_rocm_synchronize,
    rt_rocm_compile_hsaco, rt_rocm_get_function,
    rt_rocm_launch_kernel, rt_rocm_unload_module
}

pub fn rocm_backend_is_available() -> bool:
    rt_rocm_is_available()

pub fn rocm_backend_init_runtime() -> bool:
    rt_rocm_init()

pub fn rocm_backend_device_count() -> i64:
    rt_rocm_device_count()

pub fn rocm_backend_device_identity() -> i64:
    val device = rt_rocm_get_device()
    if device < 0:
        return 0
    rt_rocm_device_identity(device)

pub fn rocm_backend_device_name(device: i64) -> text:
    rt_rocm_device_name(device)

pub fn rocm_backend_device_memory(device: i64) -> i64:
    rt_rocm_device_memory(device)

pub fn rocm_backend_compile_hsaco(source: text) -> i64:
    rt_rocm_compile_hsaco(source)

pub fn rocm_backend_unload_module(module: i64):
    rt_rocm_unload_module(module)

pub fn rocm_backend_malloc(size: i64) -> i64:
    rt_rocm_malloc(size)

pub fn rocm_backend_free(ptr: i64):
    rt_rocm_free(ptr)

pub fn rocm_backend_memset(ptr: i64, value: i32, size: i64) -> bool:
    rt_rocm_memset(ptr, value, size)

pub fn rocm_backend_get_function(module: i64, name: text) -> i64:
    rt_rocm_get_function(module, name)

pub fn rocm_backend_synchronize() -> bool:
    rt_rocm_synchronize()

pub fn rocm_backend_launch_kernel(func: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64, shared_mem: i64, args: [i64]) -> bool:
    rt_rocm_launch_kernel(func, gx, gy, gz, bx, by, bz, shared_mem, args)
