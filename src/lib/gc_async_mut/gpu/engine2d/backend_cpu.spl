#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# 2D Engine — CPU Software Backend
#
# Pure software rendering backend using a [u32] pixel buffer.
# Always available as the fallback — no external dependencies.
#
# Implements:
#   - Bresenham line drawing
#   - Scanline rect/circle fill
#   - Midpoint circle algorithm
#   - Text rendering via shared 5x7 bitmap font (glyph.spl)
#   - Porter-Duff alpha blending
#
# Usage:
#   use std.gpu.engine2d.backend_cpu.{CpuBackend}

use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend, lerp_color}
use std.gpu.engine2d.glyph.{render_text_to_buffer}

# ============================================================================
# CPU Backend
# ============================================================================

class CpuBackend:
    """Software renderer backed by a flat [u32] pixel buffer.

    This backend requires no GPU or external libraries. It is always available
    and serves as the universal fallback when no hardware-accelerated backend
    can be initialized.
    """

    buf: [u32]
    w: i32
    h: i32
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool

    static fn create() -> CpuBackend:
        """Create an uninitialized CPU backend. Call init() before drawing."""
        CpuBackend(
            buf: [],
            w: 0,
            h: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false
        )

impl RenderBackend for CpuBackend:

    fn name() -> text:
        "cpu"

    fn init(width: i32, height: i32) -> bool:
        self.w = width
        self.h = height
        val total = width * height
        self.buf = [0u32; total]
        # Fill with opaque black
        var i = 0
        while i < total:
            self.buf[i] = rgb(0, 0, 0)
            i = i + 1
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        true

    fn shutdown():
        self.buf = []
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        val total = self.w * self.h
        var i = 0
        while i < total:
            self.buf[i] = color
            i = i + 1

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Top edge
        _hline(self, x, y, w, color)
        # Bottom edge
        _hline(self, x, y + h - 1, w, color)
        # Left edge
        _vline(self, x, y, h, color)
        # Right edge
        _vline(self, x + w - 1, y, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        var row = y
        while row < y + h:
            _hline(self, x, row, w, color)
            row = row + 1

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if thickness <= 1:
            _bresenham(self, x1, y1, x2, y2, color)
        else:
            # Thick line: draw multiple parallel Bresenham lines
            val half = thickness / 2
            var offset = -half
            # Determine if line is more horizontal or vertical
            var adx = x2 - x1
            if adx < 0:
                adx = -adx
            var ady = y2 - y1
            if ady < 0:
                ady = -ady
            while offset <= half:
                if adx >= ady:
                    # More horizontal: offset in y
                    _bresenham(self, x1, y1 + offset, x2, y2 + offset, color)
                else:
                    # More vertical: offset in x
                    _bresenham(self, x1 + offset, y1, x2 + offset, y2, color)
                offset = offset + 1

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        # Midpoint circle algorithm (outline only)
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            _set_pixel(self, cx + px, cy + py, color)
            _set_pixel(self, cx - px, cy + py, color)
            _set_pixel(self, cx + px, cy - py, color)
            _set_pixel(self, cx - px, cy - py, color)
            _set_pixel(self, cx + py, cy + px, color)
            _set_pixel(self, cx - py, cy + px, color)
            _set_pixel(self, cx + py, cy - px, color)
            _set_pixel(self, cx - py, cy - px, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        # Scanline filled circle using midpoint algorithm
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            # Fill horizontal scanlines for each octant pair
            _hline(self, cx - px, cy + py, 2 * px + 1, color)
            _hline(self, cx - px, cy - py, 2 * px + 1, color)
            _hline(self, cx - py, cy + px, 2 * py + 1, color)
            _hline(self, cx - py, cy - px, 2 * py + 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        var r = radius
        if r > w / 2:
            r = w / 2
        if r > h / 2:
            r = h / 2

        # Top edge (between corners)
        _hline(self, x + r, y, w - 2 * r, color)
        # Bottom edge
        _hline(self, x + r, y + h - 1, w - 2 * r, color)
        # Left edge
        _vline(self, x, y + r, h - 2 * r, color)
        # Right edge
        _vline(self, x + w - 1, y + r, h - 2 * r, color)

        # Four corner arcs using midpoint circle
        _draw_corner_arc(self, x + r, y + r, r, color, -1, -1)
        _draw_corner_arc(self, x + w - 1 - r, y + r, r, color, 1, -1)
        _draw_corner_arc(self, x + r, y + h - 1 - r, r, color, -1, 1)
        _draw_corner_arc(self, x + w - 1 - r, y + h - 1 - r, r, color, 1, 1)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Sort vertices by y coordinate (bubble sort 3 elements)
        var vx1 = x1
        var vy1 = y1
        var vx2 = x2
        var vy2 = y2
        var vx3 = x3
        var vy3 = y3

        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty
        if vy2 > vy3:
            var tx = vx2
            var ty = vy2
            vx2 = vx3
            vy2 = vy3
            vx3 = tx
            vy3 = ty
        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty

        # Scanline fill using edge interpolation
        _fill_triangle_scanlines(self, vx1, vy1, vx2, vy2, vx3, vy3, color)

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if h <= 0:
            return
        var row = 0
        while row < h:
            val t = _i32_to_f32(row) / _i32_to_f32(h - 1)
            val c = lerp_color(top_color, bottom_color, t)
            _hline(self, x, y + row, w, c)
            row = row + 1

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        render_text_to_buffer(self.buf, self.w, self.h, x, y, text_val, color, font_size)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row = 0
        while row < h:
            var col = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx < pixels.len():
                    val px = x + col
                    val py = y + row
                    val c = pixels[src_idx]
                    if color_a(c) == 255:
                        _set_pixel(self, px, py, c)
                    else if color_a(c) > 0:
                        val dst = _get_pixel(self, px, py)
                        _set_pixel(self, px, py, blend(c, dst))
                col = col + 1
            row = row + 1

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me present():
        # CPU backend: framebuffer is already in memory, nothing to flush
        pass_do_nothing

    fn read_pixels() -> [u32]:
        # Return a copy of the pixel buffer
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

# ============================================================================
# Pixel Operations (Internal)
# ============================================================================

fn _set_pixel(backend: CpuBackend, x: i32, y: i32, color: u32):
    """Set a single pixel, respecting clip rect and bounds."""
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return

    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return

    val idx = y * backend.w + x
    backend.buf[idx] = color

fn _set_pixel_blend(backend: CpuBackend, x: i32, y: i32, color: u32):
    """Set a pixel with alpha blending."""
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return

    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return

    val idx = y * backend.w + x
    val dst = backend.buf[idx]
    backend.buf[idx] = blend(color, dst)

fn _get_pixel(backend: CpuBackend, x: i32, y: i32) -> u32:
    """Read a pixel value at (x, y). Returns 0 if out of bounds."""
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return 0u32
    val idx = y * backend.w + x
    backend.buf[idx]

# ============================================================================
# Line Drawing (Bresenham)
# ============================================================================

fn _bresenham(backend: CpuBackend, x1: i32, y1: i32, x2: i32, y2: i32, color: u32):
    """Bresenham line algorithm."""
    var dx = x2 - x1
    var dy = y2 - y1
    var sx: i32 = 1
    var sy: i32 = 1
    if dx < 0:
        dx = -dx
        sx = -1
    if dy < 0:
        dy = -dy
        sy = -1

    var err = dx - dy
    var cx = x1
    var cy = y1

    while true:
        _set_pixel(backend, cx, cy, color)
        if cx == x2 and cy == y2:
            return
        val e2 = 2 * err
        if e2 > -dy:
            err = err - dy
            cx = cx + sx
        if e2 < dx:
            err = err + dx
            cy = cy + sy

# ============================================================================
# Horizontal / Vertical Lines
# ============================================================================

fn _hline(backend: CpuBackend, x: i32, y: i32, length: i32, color: u32):
    """Draw a horizontal line from (x, y) for `length` pixels."""
    var i = 0
    while i < length:
        _set_pixel(backend, x + i, y, color)
        i = i + 1

fn _vline(backend: CpuBackend, x: i32, y: i32, length: i32, color: u32):
    """Draw a vertical line from (x, y) for `length` pixels."""
    var i = 0
    while i < length:
        _set_pixel(backend, x, y + i, color)
        i = i + 1

# ============================================================================
# Corner Arc (for rounded rectangles)
# ============================================================================

fn _draw_corner_arc(backend: CpuBackend, cx: i32, cy: i32, r: i32, color: u32, sx: i32, sy: i32):
    """Draw a quarter-circle arc at corner (cx, cy) with direction (sx, sy)."""
    var px = r
    var py = 0
    var d = 1 - r
    while px >= py:
        _set_pixel(backend, cx + px * sx, cy + py * sy, color)
        _set_pixel(backend, cx + py * sx, cy + px * sy, color)
        py = py + 1
        if d <= 0:
            d = d + 2 * py + 1
        else:
            px = px - 1
            d = d + 2 * py - 2 * px + 1

# ============================================================================
# Triangle Scanline Fill
# ============================================================================

fn _fill_triangle_scanlines(backend: CpuBackend, x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
    """Fill triangle with scanlines. Vertices must be sorted by y (y1 <= y2 <= y3)."""
    # Upper half: y1 to y2
    var y = y1
    while y <= y2:
        val xa = _edge_x(x1, y1, x3, y3, y)
        val xb = _edge_x(x1, y1, x2, y2, y)
        var left = xa
        var right = xb
        if left > right:
            left = xb
            right = xa
        _hline(backend, left, y, right - left + 1, color)
        y = y + 1

    # Lower half: y2 to y3
    y = y2 + 1
    while y <= y3:
        val xa = _edge_x(x1, y1, x3, y3, y)
        val xb = _edge_x(x2, y2, x3, y3, y)
        var left = xa
        var right = xb
        if left > right:
            left = xb
            right = xa
        _hline(backend, left, y, right - left + 1, color)
        y = y + 1

fn _edge_x(x1: i32, y1: i32, x2: i32, y2: i32, y: i32) -> i32:
    """Compute x coordinate on edge from (x1,y1)-(x2,y2) at scanline y."""
    val dy = y2 - y1
    if dy == 0:
        return x1
    x1 + (x2 - x1) * (y - y1) / dy

# ============================================================================
# Internal Conversion Helpers
# ============================================================================

fn _i32_to_f32(v: i32) -> f32:
    v as f32
