# 2D Engine — CPU SIMD backend.
#
# Uses the optimized software renderer as the raster surface and exposes it as
# the explicit "cpu" backend. Its hot rows route through simd_kernels.

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended, Engine2DReadback, engine2d_readback}
use std.gpu.engine2d.backend_software.{SoftwareBackend}

class CpuBackend:
    sw: SoftwareBackend
    initialized: bool

    static fn create() -> CpuBackend:
        CpuBackend(sw: SoftwareBackend.create(), initialized: false)

    static fn create_simd() -> CpuBackend:
        CpuBackend(sw: SoftwareBackend.create_cpu_simd(), initialized: false)

impl RenderBackend for CpuBackend:
    fn name() -> text:
        "cpu"
    me init(width: i32, height: i32) -> bool:
        self.initialized = self.sw.init(width, height)
        self.initialized
    me shutdown():
        self.sw.shutdown()
        self.initialized = false
    me clear(color: u32):
        self.sw.clear(color)
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.sw.draw_rect(x, y, w, h, color)
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.sw.draw_rect_filled(x, y, w, h, color)
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        self.sw.draw_line(x1, y1, x2, y2, color, thickness)
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        self.sw.draw_circle(cx, cy, r, color)
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        self.sw.draw_circle_filled(cx, cy, r, color)
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        self.sw.draw_rounded_rect(x, y, w, h, radius, color)
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        self.sw.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        self.sw.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        self.sw.draw_text(x, y, text_val, color, font_size)
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.sw.draw_image(x, y, w, h, pixels)
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.sw.draw_image_blend(x, y, w, h, pixels)
    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.sw.set_clip(x, y, w, h)
    me clear_clip():
        self.sw.clear_clip()
    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.sw.set_mask(mask_pixels, w, h)
    me clear_mask():
        self.sw.clear_mask()
    me present():
        self.sw.present()
    me read_pixels() -> [u32]:
        self.sw.read_pixels()
    me read_pixels_with_source() -> Engine2DReadback:
        engine2d_readback(self.sw.read_pixels(), "cpu_mirror")
    me width() -> i32:
        self.sw.width()
    me height() -> i32:
        self.sw.height()

impl Engine2DExtended for CpuBackend:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32): self.sw.draw_text_bg(x, y, text_val, fg, bg, font_size)
    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32): self.sw.draw_ellipse(cx, cy, rx, ry, color)
    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32): self.sw.draw_ellipse_filled(cx, cy, rx, ry, color)
    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32): self.sw.draw_arc(cx, cy, r, start_deg, end_deg, color, thickness)
    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32): self.sw.draw_bezier(x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)
    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32): self.sw.draw_polygon_filled(xs, ys, count, color)
    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32): self.sw.draw_polyline(xs, ys, count, color, thickness)
    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32): self.sw.draw_rect_thick(x, y, w, h, color, thickness)
    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32): self.sw.draw_circle_thick(cx, cy, r, color, thickness)
    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32): self.sw.draw_rounded_rect_outline(x, y, w, h, radius, color, thickness)
    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32): self.sw.draw_gradient_rect_h(x, y, w, h, left_color, right_color)
    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32): self.sw.draw_radial_gradient(cx, cy, r, center_color, edge_color)
    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32): self.sw.draw_rect_blend(x, y, w, h, color)
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]): self.sw.draw_image_blend(x, y, w, h, pixels)
    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]): self.sw.draw_image_scaled(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)
    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32): self.sw.draw_triangle_outline(x1, y1, x2, y2, x3, y3, color, thickness)
    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32): self.sw.draw_blur_rect(x, y, w, h, radius)
    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32): self.sw.draw_shadow_rect(x, y, w, h, offset_x, offset_y, blur_r, color)
    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]): self.sw.draw_image_transform(dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)
    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32): self.sw.draw_rect_blend_mode(x, y, w, h, color, mode)
