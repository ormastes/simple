# 2D Engine — ROCm/HIP GPU Backend
#
# Hardware-accelerated 2D rendering using ROCm HIP kernels on AMD GPUs.
# Each draw operation is a kernel launch operating on a device-side
# framebuffer. present() copies the GPU framebuffer back to host memory
# for display.
#
# Requires AMD GPU with ROCm/HIP support.
#
# Usage:
#   use std.gpu.engine2d.backend_rocm.{RocmBackend}

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended, Engine2DReadback, engine2d_readback, engine2d_readback_with_handle}
use std.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{render_text_to_buffer}
use std.gpu.engine2d.helpers_text.{text_blit_buffer, text_transparent_blit_buffer}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.gc_async_mut.gpu.engine2d.sffi_rocm.{
    rocm_engine2d_upload_pixels, rocm_engine2d_download_pixels,
    rocm_engine2d_upload_host_buf
}
use std.gpu.engine2d.backend_rocm_runtime_ops.{
    rocm_backend_is_available, rocm_backend_init_runtime, rocm_backend_device_count,
    rocm_backend_compile_hsaco, rocm_backend_unload_module,
    rocm_backend_malloc, rocm_backend_free, rocm_backend_memset,
    rocm_backend_get_function, rocm_backend_synchronize,
    rocm_backend_launch_kernel
}
use std.gpu.engine2d.backend_rocm_kernels.{_engine2d_hip_source}
use std.common.gpu.font_atlas_composite.{FONT_ATLAS_COMPOSITE_ENTRY, font_atlas_composite_program_version_valid, font_destination_origin}
use std.gc_async_mut.text_layout.font_renderer.{FontRenderBatch}

fn rocm_font_atlas_composite_args(atlas: i64, framebuffer: i64,
                                  atlas_width: i64, atlas_height: i64, atlas_count: i64,
                                  atlas_x: i64, atlas_y: i64, quad_width: i64, quad_height: i64,
                                  dst_width: i64, dst_height: i64, dst_count: i64,
                                  dst_x: i64, dst_y: i64, color: i64) -> [i64]:
    [atlas, framebuffer, atlas_width, atlas_height, atlas_count,
     atlas_x, atlas_y, quad_width, quad_height,
     dst_width, dst_height, dst_count, dst_x, dst_y, color]

# ============================================================================
# ROCm/HIP Probe
#
# probe_rocm() returns a typed BackendProbeResult. On this Linux host hipcc is
# absent so the dynamic path (amdhip64) is unavailable and the result carries
# feature_gate = "hip-toolchain-missing". Callers must assert this evidence
# string rather than treating absence as a silent pass.
# ============================================================================

fn _rocm_probe_unavailable(gate: text, message: text) -> BackendProbeResult:
    var result = BackendProbeResult.unavailable("rocm", message)
    result.api_name = "rocm"
    result.feature_gate = gate
    result.shader_format = "hsaco"
    result.has_compute = false
    result.has_graphics = false
    result.has_present = false
    result

fn _rocm_probe_failed(gate: text, message: text) -> BackendProbeResult:
    var result = BackendProbeResult.failed("rocm", message)
    result.api_name = "rocm"
    result.feature_gate = gate
    result.shader_format = "hsaco"
    result.has_compute = false
    result.has_graphics = false
    result.has_present = false
    result

fn _rocm_probe_ready(device_name: text) -> BackendProbeResult:
    var result = BackendProbeResult.success("rocm", "ROCm/HIP runtime ready")
    result.api_name = "rocm"
    result.feature_gate = "rocm-device-ready"
    result.shader_format = "hsaco"
    result.device_name = device_name
    result.has_compute = true
    result.has_graphics = true
    result.has_present = true
    result

fn probe_rocm() -> BackendProbeResult:
    # Step 1: check if the HIP toolchain / runtime library is loadable.
    # On hosts without AMD GPU drivers or hipcc the rocm_is_available facade
    # returns false. We report "hip-toolchain-missing" as a
    # structured evidence gate so specs can assert this exact string.
    if not rocm_backend_is_available():
        return _rocm_probe_unavailable("hip-toolchain-missing", "ROCm/HIP runtime library unavailable — hipcc and amdhip64 not found on this host")
    # Step 2: attempt runtime init
    val init_ok = rocm_backend_init_runtime()
    if not init_ok:
        return _rocm_probe_failed("rocm-init-failed", "ROCm runtime init failed")
    # Step 3: check device count
    val dev_count = rocm_backend_device_count()
    if dev_count < 1:
        return _rocm_probe_unavailable("rocm-device-unavailable", "ROCm init succeeded but no AMD GPU device found")
    # Step 4: try to compile the kernel module from HIP source as a self-test
    val module = rocm_backend_compile_hsaco(_engine2d_hip_source())
    if module == 0:
        return _rocm_probe_failed("rocm-kernel-gap", "ROCm device present but HIP kernel compilation failed (hip-toolchain-missing or driver mismatch)")
    rocm_backend_unload_module(module)
    _rocm_probe_ready("amd-gpu")

# ============================================================================
# ROCm Backend
# ============================================================================

class RocmBackend:
    """GPU-accelerated 2D renderer using ROCm HIP kernels on AMD GPUs.

    Architecture:
    - Framebuffer lives in GPU device memory (d_framebuffer)
    - Each draw call launches a HIP kernel
    - present() copies GPU framebuffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line) has a dedicated
    HIP kernel. Grid/block dimensions are chosen to cover the bounding box
    of the primitive being drawn. Kernels are compiled from HIP C++ source
    via the rocm_compile_hsaco facade.

    Hardening contract:
    - Every draw method is a no-op when initialized is false.
    - last_probe carries a typed BackendProbeResult after init(); callers
      can inspect feature_gate to distinguish unavailable, init-failed,
      and kernel-gap failure modes without parsing error strings.
    - read_pixels() returns an empty array (not a stale pointer deref)
      when d_framebuffer == 0.
    """

    host_buf: [u32]
    w: i32
    h: i32
    d_framebuffer: i64      # Device pointer to GPU framebuffer
    hip_module: i64          # Handle to compiled HIP module
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool
    dirty: bool              # True when GPU has changes not yet copied to host
    last_probe: BackendProbeResult   # Typed result from most recent probe/init

    # Cached kernel function handles
    fn_clear: i64
    fn_rect_filled: i64
    fn_rect_outline: i64
    fn_line: i64
    fn_circle: i64
    fn_circle_filled: i64
    fn_rounded_rect: i64
    fn_triangle_filled: i64
    fn_gradient_rect: i64
    fn_blit_image: i64
    fn_blit_image_nonzero: i64
    fn_font_atlas_composite: i64
    d_font_atlas: i64
    font_atlas_bytes: i64
    font_atlas_generation: i64
    font_atlas_owner_identity: text

    static fn create() -> RocmBackend:
        """Create an uninitialized ROCm backend. Call init() before drawing."""
        RocmBackend(
            host_buf: [],
            w: 0,
            h: 0,
            d_framebuffer: 0,
            hip_module: 0,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false,
            dirty: false,
            last_probe: BackendProbeResult.unavailable("rocm", "not probed"),
            fn_clear: 0,
            fn_rect_filled: 0,
            fn_rect_outline: 0,
            fn_line: 0,
            fn_circle: 0,
            fn_circle_filled: 0,
            fn_rounded_rect: 0,
            fn_triangle_filled: 0,
            fn_gradient_rect: 0,
            fn_blit_image: 0,
            fn_blit_image_nonzero: 0,
            fn_font_atlas_composite: 0,
            d_font_atlas: 0,
            font_atlas_bytes: 0,
            font_atlas_generation: -1,
            font_atlas_owner_identity: ""
        )

    me invalidate_font_atlas():
        self.font_atlas_generation = -1
        self.font_atlas_owner_identity = ""

    me _upload_font_atlas(batch: FontRenderBatch) -> bool:
        if not batch.valid or batch.atlas_width <= 0 or batch.atlas_height <= 0:
            return false
        val pixel_count = _i64(batch.atlas_width) * _i64(batch.atlas_height)
        if pixel_count <= 0 or pixel_count > 2147483647 or batch.atlas_pixels.len() != pixel_count:
            return false
        val required_bytes = pixel_count * 4
        val owner_identity = batch.atlas_owner_identity()
        if (self.d_font_atlas != 0 and self.font_atlas_bytes == required_bytes and
            self.font_atlas_owner_identity == owner_identity and self.font_atlas_generation == batch.atlas_generation):
            return true
        var target = self.d_font_atlas
        var allocated = false
        if target == 0 or self.font_atlas_bytes != required_bytes:
            target = rocm_backend_malloc(required_bytes)
            if target == 0:
                return false
            allocated = true
        if rocm_engine2d_upload_pixels(target, batch.atlas_pixels, pixel_count) != 0:
            if allocated:
                rocm_backend_free(target)
            else:
                self.invalidate_font_atlas()
            return false
        if allocated:
            if self.d_font_atlas != 0:
                rocm_backend_free(self.d_font_atlas)
            self.d_font_atlas = target
            self.font_atlas_bytes = required_bytes
        self.font_atlas_generation = batch.atlas_generation
        self.font_atlas_owner_identity = owner_identity
        true

    me draw_font_batch(origin_x: i32, origin_y: i32, batch: FontRenderBatch) -> i64:
        if not font_atlas_composite_program_version_valid(batch.program_version):
            return 0
        if not batch.material_supported() or batch.quads.len() == 0 or not self.initialized:
            return 0
        if self.d_framebuffer == 0 or self.fn_font_atlas_composite == 0 or self.clip_enabled or self.mask_buf.len() != 0:
            return 0
        if not self._upload_font_atlas(batch):
            return 0
        val atlas_count = _i64(batch.atlas_width) * _i64(batch.atlas_height)
        val dst_count = _i64(self.w) * _i64(self.h)
        if atlas_count <= 0 or atlas_count > 2147483647 or dst_count <= 0 or dst_count > 2147483647:
            return 0
        var submitted: i64 = 0
        while submitted < batch.quads.len():
            val quad = batch.quads[submitted]
            if (quad.width <= 0 or quad.height <= 0 or quad.atlas_x < 0 or quad.atlas_y < 0 or
                quad.width > batch.atlas_width - quad.atlas_x or quad.height > batch.atlas_height - quad.atlas_y):
                return submitted
            val dst_x = font_destination_origin(origin_x, quad.dst_x, quad.width)
            val dst_y = font_destination_origin(origin_y, quad.dst_y, quad.height)
            if dst_x == nil or dst_y == nil:
                return submitted
            val total = _i64(quad.width) * _i64(quad.height)
            if total <= 0 or total > 2147483647:
                return submitted
            val args = rocm_font_atlas_composite_args(
                self.d_font_atlas, self.d_framebuffer,
                _i64(batch.atlas_width), _i64(batch.atlas_height), atlas_count,
                _i64(quad.atlas_x), _i64(quad.atlas_y), _i64(quad.width), _i64(quad.height),
                _i64(self.w), _i64(self.h), dst_count,
                _i64(dst_x.?), _i64(dst_y.?), _i64_from_u32(quad.color)
            )
            val grid_size = (total + 255) / 256
            if not _launch_kernel_1d(self, self.fn_font_atlas_composite, grid_size, 256, args):
                return submitted
            if not rocm_backend_synchronize():
                return submitted
            self.dirty = true
            submitted = submitted + 1
        submitted

impl RenderBackend for RocmBackend:

    fn name() -> text:
        "rocm"

    me init(width: i32, height: i32) -> bool:
        # Check ROCm availability — record typed probe so callers can inspect
        # feature_gate without parsing error strings.
        self.last_probe = probe_rocm()
        if self.last_probe.status != BackendStatus.Initialized:
            self.initialized = false
            return false

        if width <= 0 or height <= 0:
            self.last_probe = _rocm_probe_failed("rocm-invalid-dimensions", "ROCm framebuffer dimensions must be positive")
            self.initialized = false
            return false

        self.w = width
        self.h = height

        # Allocate device framebuffer (4 bytes per pixel = u32)
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = rocm_backend_malloc(fb_size)
        if self.d_framebuffer == 0:
            self.last_probe = _rocm_probe_failed("rocm-alloc-failed", "ROCm device framebuffer allocation failed")
            self.initialized = false
            return false

        # Clear device framebuffer to black
        rocm_backend_memset(self.d_framebuffer, 0, fb_size)

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        # Compile HIP C++ kernels into module
        self.hip_module = rocm_backend_compile_hsaco(_engine2d_hip_source())
        if self.hip_module == 0:
            rocm_backend_free(self.d_framebuffer)
            self.d_framebuffer = 0
            self.last_probe = _rocm_probe_failed("rocm-kernel-gap", "ROCm HIP kernel compilation failed during surface init")
            self.initialized = false
            return false

        # Cache kernel function handles
        self.fn_clear = rocm_backend_get_function(self.hip_module, "kernel_clear")
        self.fn_rect_filled = rocm_backend_get_function(self.hip_module, "kernel_draw_rect_filled")
        self.fn_rect_outline = rocm_backend_get_function(self.hip_module, "kernel_draw_rect_outline")
        self.fn_line = rocm_backend_get_function(self.hip_module, "kernel_draw_line")
        self.fn_circle = rocm_backend_get_function(self.hip_module, "kernel_draw_circle")
        self.fn_circle_filled = rocm_backend_get_function(self.hip_module, "kernel_draw_circle_filled")
        self.fn_rounded_rect = rocm_backend_get_function(self.hip_module, "kernel_draw_rounded_rect")
        self.fn_triangle_filled = rocm_backend_get_function(self.hip_module, "kernel_draw_triangle_filled")
        self.fn_gradient_rect = rocm_backend_get_function(self.hip_module, "kernel_draw_gradient_rect")
        self.fn_blit_image = rocm_backend_get_function(self.hip_module, "kernel_blit_image")
        self.fn_blit_image_nonzero = rocm_backend_get_function(self.hip_module, "kernel_blit_image_nonzero")
        self.fn_font_atlas_composite = rocm_backend_get_function(self.hip_module, FONT_ATLAS_COMPOSITE_ENTRY)
        if self.fn_font_atlas_composite == 0:
            rocm_backend_unload_module(self.hip_module)
            self.hip_module = 0
            rocm_backend_free(self.d_framebuffer)
            self.d_framebuffer = 0
            self.last_probe = _rocm_probe_failed("rocm-font-kernel-gap", "ROCm font-atlas composite kernel lookup failed")
            self.initialized = false
            return false

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    me shutdown():
        if self.d_font_atlas != 0:
            rocm_backend_free(self.d_font_atlas)
            self.d_font_atlas = 0
        self.font_atlas_bytes = 0
        self.invalidate_font_atlas()
        if self.d_framebuffer != 0:
            rocm_backend_free(self.d_framebuffer)
            self.d_framebuffer = 0
        if self.hip_module != 0:
            rocm_backend_unload_module(self.hip_module)
            self.hip_module = 0
        self.fn_clear = 0
        self.fn_rect_filled = 0
        self.fn_rect_outline = 0
        self.fn_line = 0
        self.fn_circle = 0
        self.fn_circle_filled = 0
        self.fn_rounded_rect = 0
        self.fn_triangle_filled = 0
        self.fn_gradient_rect = 0
        self.fn_blit_image = 0
        self.fn_blit_image_nonzero = 0
        self.fn_font_atlas_composite = 0
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.initialized = false

    me clear(color: u32):
        if not self.initialized:
            return
        # Launch clear kernel: one thread per pixel
        val block_size: i64 = 256
        val total = _i64(self.w) * _i64(self.h)
        val grid_size = (total + block_size - 1) / block_size
        val args: [i64] = [self.d_framebuffer, _i64_from_u32(color), _i64(self.w), _i64(self.h)]
        _launch_kernel_1d(self, self.fn_clear, grid_size, block_size, args)
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.initialized:
            return
        val args: [i64] = [self.d_framebuffer, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(color), _i64(self.w), _i64(self.h)]
        val grid_dim = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        _launch_kernel_2d(self, self.fn_rect_outline, grid_dim, block_dim, args)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.initialized:
            return
        val args: [i64] = [self.d_framebuffer, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(color), _i64(self.w), _i64(self.h)]
        val grid_dim = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        _launch_kernel_2d(self, self.fn_rect_filled, grid_dim, block_dim, args)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if not self.initialized:
            return
        # Line kernel: launch one thread per pixel along the line length
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val block_size: i64 = 256
        val grid_size = (_i64(line_len) + block_size - 1) / block_size
        val args: [i64] = [self.d_framebuffer, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64_from_u32(color), _i64(thickness), _i64(self.w), _i64(self.h)]
        _launch_kernel_1d(self, self.fn_line, grid_size, block_size, args)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        if not self.initialized:
            return
        # Circle outline: launch kernel covering bounding box
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val grid_dim = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args: [i64] = [self.d_framebuffer, _i64(cx), _i64(cy), _i64(r), _i64_from_u32(color), _i64(self.w), _i64(self.h), 0]
        _launch_kernel_2d(self, self.fn_circle, grid_dim, block_dim, args)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if not self.initialized:
            return
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val grid_dim = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args: [i64] = [self.d_framebuffer, _i64(cx), _i64(cy), _i64(r), _i64_from_u32(color), _i64(self.w), _i64(self.h), 1]
        _launch_kernel_2d(self, self.fn_circle_filled, grid_dim, block_dim, args)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        if not self.initialized:
            return
        # Rounded rect kernel: each thread checks corner distance
        val grid_dim = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        val args: [i64] = [self.d_framebuffer, _i64(x), _i64(y), _i64(w), _i64(h), _i64(radius), _i64_from_u32(color), _i64(self.w), _i64(self.h)]
        _launch_kernel_2d(self, self.fn_rounded_rect, grid_dim, block_dim, args)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        if not self.initialized:
            return
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val grid_dim = _grid_for_rect(bw, bh)
        val block_dim = _block_for_rect()
        val args: [i64] = [self.d_framebuffer, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64(x3), _i64(y3), _i64_from_u32(color), _i64(self.w), _i64(self.h), _i64(min_x), _i64(min_y)]
        _launch_kernel_2d(self, self.fn_triangle_filled, grid_dim, block_dim, args)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if not self.initialized:
            return
        val grid_dim = _grid_for_rect(w, h)
        val block_dim = _block_for_rect()
        val args: [i64] = [self.d_framebuffer, _i64(x), _i64(y), _i64(w), _i64(h), _i64_from_u32(top_color), _i64_from_u32(bottom_color), _i64(self.w), _i64(self.h)]
        _launch_kernel_2d(self, self.fn_gradient_rect, grid_dim, block_dim, args)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        if not self.initialized:
            return
        val text_buf = text_transparent_blit_buffer(text_val, color, font_size)
        if text_buf.is_empty():
            return
        if _draw_image_with_kernel(self, self.fn_blit_image_nonzero, x, y, text_buf.width, text_buf.height, text_buf.pixels):
            self.dirty = true
            return
        _gpu_draw_text_fallback(self, x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if not self.initialized:
            return
        if _draw_image_with_kernel(self, self.fn_blit_image, x, y, w, h, pixels):
            self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Copy GPU framebuffer to host memory; guard against uninitialized state
        if self.initialized and self.dirty and self.d_framebuffer != 0:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer(self.d_framebuffer, self.host_buf, fb_size)
            rocm_backend_synchronize()
            self.dirty = false

    fn read_pixels() -> [u32]:
        self.read_pixels_with_source().pixels

    fn read_pixels_with_source() -> Engine2DReadback:
        # Guard: if not initialized or framebuffer pointer is null, return empty
        # to avoid a null-pointer device-memory read.
        if not self.initialized or self.d_framebuffer == 0:
            return engine2d_readback([], "not_requested")
        # Ensure host buffer is up to date
        var source = "host_cache_after_device_present"
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            _download_framebuffer(self.d_framebuffer, self.host_buf, fb_size)
            rocm_backend_synchronize()
            source = "device_readback"
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        if source == "device_readback":
            return engine2d_readback_with_handle(copy, source, self.d_framebuffer)
        engine2d_readback(copy, source)

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

impl Engine2DExtended for RocmBackend:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        if not self.initialized:
            self.dirty = true
            return
        val text_buf = text_blit_buffer(text_val, fg, bg, font_size)
        if text_buf.is_empty():
            return
        self.draw_image(x, y, text_buf.width, text_buf.height, text_buf.pixels)

# ============================================================================
# Kernel Launch Helpers
# ============================================================================

fn _launch_kernel_1d(backend: RocmBackend, func: i64, grid_x: i64, block_x: i64, args: [i64]) -> bool:
    """Launch a 1D HIP kernel via ROCm."""
    rocm_backend_launch_kernel(
        func,
        grid_x, 1, 1,    # grid dims
        block_x, 1, 1,   # block dims
        0,                # shared memory
        args
    )

fn _launch_kernel_2d(backend: RocmBackend, func: i64, grid_dim: RocmGridDim, block_dim: RocmBlockDim, args: [i64]) -> bool:
    """Launch a 2D HIP kernel via ROCm."""
    rocm_backend_launch_kernel(
        func,
        grid_dim.x, grid_dim.y, 1,     # grid dims
        block_dim.x, block_dim.y, 1,   # block dims
        0,                              # shared memory
        args
    )

# ============================================================================
# Grid / Block Dimension Helpers
# ============================================================================

struct RocmGridDim:
    x: i64
    y: i64

struct RocmBlockDim:
    x: i64
    y: i64

fn _grid_for_rect(w: i32, h: i32) -> RocmGridDim:
    """Compute grid dimensions for a rectangular region with 16x16 blocks."""
    val bx: i64 = 16
    val by: i64 = 16
    RocmGridDim(
        x: (_i64(w) + bx - 1) / bx,
        y: (_i64(h) + by - 1) / by
    )

fn _block_for_rect() -> RocmBlockDim:
    """Standard 16x16 thread block for 2D operations."""
    RocmBlockDim(x: 16, y: 16)

# ============================================================================
# Device Memory Transfer
#
# ROCm SFFI uses [u8] byte arrays for host-device transfers. These helpers
# handle the u32-to-u8 conversion needed for pixel data.
# ============================================================================

fn _upload_pixels_to_device(d_dst: i64, pixels: [u32], count: i64):
    """Upload host pixel array to device memory."""
    rocm_engine2d_upload_pixels(d_dst, pixels, count)

fn _download_framebuffer(d_src: i64, host_buf: [u32], byte_size: i64):
    """Download device framebuffer to host buffer."""
    rocm_engine2d_download_pixels(d_src, host_buf, byte_size)

fn _upload_host_to_device(d_dst: i64, host_buf: [u32], byte_size: i64):
    """Upload host buffer to device memory."""
    rocm_engine2d_upload_host_buf(d_dst, host_buf, byte_size)

fn _draw_image_with_kernel(backend: RocmBackend, func: i64, x: i32, y: i32, w: i32, h: i32, pixels: [u32]) -> bool:
    if not backend.initialized:
        return false
    if func == 0:
        return false
    if w <= 0 or h <= 0:
        return false
    val pixel_count = _i64(w) * _i64(h)
    if pixel_count > pixels.len() as i64:
        return false
    val byte_size = pixel_count * 4
    val d_src = rocm_backend_malloc(byte_size)
    if d_src == 0:
        return false
    _upload_pixels_to_device(d_src, pixels, pixel_count)
    val grid_dim = _grid_for_rect(w, h)
    val block_dim = _block_for_rect()
    val args: [i64] = [backend.d_framebuffer, d_src, _i64(x), _i64(y), _i64(w), _i64(h), _i64(backend.w), _i64(backend.h)]
    _launch_kernel_2d(backend, func, grid_dim, block_dim, args)
    rocm_backend_free(d_src)
    true

# ============================================================================
# Text Rendering Fallback
# ============================================================================

fn _gpu_draw_text_fallback(backend: RocmBackend, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render text on CPU and upload affected region to GPU.

    For production use, a glyph atlas would be pre-uploaded to GPU memory
    and sampled by a text-rendering kernel. This fallback is acceptable
    for low-frequency text draws (UI labels, debug overlays).
    """
    # Guard: caller already checked initialized; guard d_framebuffer here too
    if backend.d_framebuffer == 0:
        return
    # Ensure host buffer is current
    if backend.dirty:
        val fb_size = _i64(backend.w) * _i64(backend.h) * 4
        _download_framebuffer(backend.d_framebuffer, backend.host_buf, fb_size)
        rocm_backend_synchronize()

    # Render glyphs into host buffer using shared glyph module
    render_text_to_buffer(backend.host_buf, backend.w, backend.h, x, y, text_val, color, font_size)

    # Re-upload entire framebuffer (simpler; for production, upload only the dirty rect)
    val fb_size = _i64(backend.w) * _i64(backend.h) * 4
    _upload_host_to_device(backend.d_framebuffer, backend.host_buf, fb_size)

# Conversion Helpers
# ============================================================================

fn _i64(v: i32) -> i64:
    v as i64

fn _i64_from_u32(v: u32) -> i64:
    v as i64
