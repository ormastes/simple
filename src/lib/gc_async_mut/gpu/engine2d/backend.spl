# 2D Engine backend traits.

class Engine2DReadback:
    pixels: [u32]
    source: text
    backend_handle: i64
    device_identity: i64
    pixel_count: i64
    checksum: i64

fn engine2d_readback(pixels: [u32], source: text) -> Engine2DReadback:
    engine2d_readback_with_handle(pixels, source, 0)

fn engine2d_readback_with_handle(pixels: [u32], source: text, backend_handle: i64) -> Engine2DReadback:
    engine2d_readback_with_identity(pixels, source, backend_handle, 0)

fn engine2d_readback_with_identity(pixels: [u32], source: text, backend_handle: i64, device_identity: i64) -> Engine2DReadback:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = (checksum + pixels[i].to_i64()) % 2147483647
        i = i + 1
    Engine2DReadback(pixels: pixels, source: source, backend_handle: backend_handle, device_identity: device_identity, pixel_count: pixels.len().to_i64(), checksum: checksum)

# ============================================================================
# ReadbackSource — typed classification of where readback pixels came from.
#
# Engine2DReadback.source remains free-text for now (a hard field-type change
# ripples across ~15 files / 6+ distinct labels, several outside these three
# variants) — this enum plus the bidirectional text mapping gives callers a
# typed view without that churn. `readback_source_label` is the canonical
# string producer used at the readback construction sites.
# ============================================================================

enum ReadbackSource:
    """Where a readback's pixels physically came from."""
    DeviceReadback  # copied back from a real GPU device framebuffer
    CpuMirror       # a CPU-side mirror / cached copy of a presented frame
    Software        # produced entirely by the software rasterizer

impl ReadbackSource:
    fn to_text() -> text:
        match self:
            case DeviceReadback: "device_readback"
            case CpuMirror: "cpu_mirror"
            case Software: "software"

fn readback_source_label(src: ReadbackSource) -> text:
    """Canonical source string for a typed ReadbackSource."""
    src.to_text()

fn readback_source_from_text(source: text) -> ReadbackSource:
    """Classify a free-text readback source into its typed variant."""
    if source == "device_readback":
        ReadbackSource.DeviceReadback
    else if source == "cpu_mirror" or source == "cpu_fallback" or source == "host_cache_after_device_present" or source == "swapchain_present":
        ReadbackSource.CpuMirror
    else:
        ReadbackSource.Software

trait RenderBackend:
    fn name() -> text
    me init(width: i32, height: i32) -> bool
    me shutdown()
    me clear(color: u32)
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32)
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32)
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32)
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32)
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32)
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32)
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32)
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32)
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32)
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32])
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32])
    me set_clip(x: i32, y: i32, w: i32, h: i32)
    me clear_clip()
    me set_mask(mask_pixels: [u8], w: i32, h: i32)
    me clear_mask()
    me present()
    fn read_pixels() -> [u32]
    fn read_pixels_with_source() -> Engine2DReadback
    fn width() -> i32
    fn height() -> i32

trait Engine2DExtended:
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32)
