@allow(primitive_api)
# 2D Engine — Backend Trait (Abstract Rendering Interface)
#
# Every rendering backend must implement this trait. The Engine2D facade
# delegates all drawing to whichever backend is active.
#
# Usage:
#   use std.gpu.engine2d.backend.{RenderBackend}

# ============================================================================
# Render Backend Trait
# ============================================================================

trait RenderBackend:
    """Abstract 2D rendering interface.

    Backends implement this trait to provide hardware-accelerated or
    software rendering. The Engine2D facade selects the best backend
    at runtime and delegates all operations through this interface.

    Coordinate system: origin at top-left, x increases right, y increases down.
    Colors: packed u32 in ARGB layout (0xAARRGGBB).
    """

    # -- Identity --
    fn name() -> text

    # -- Lifecycle --
    fn init(width: i32, height: i32) -> bool
    fn shutdown()

    # -- Clear --
    me clear(color: u32)

    # -- Rectangles --
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32)
    # Paints columns [x, x+w) and rows [y, y+h). Right/bottom edge EXCLUSIVE.
    # A zero-width or zero-height rect is a no-op. Negative w/h is undefined
    # (implementations may silently no-op, wrap, or overrun — do not rely).
    # See doc/03_plan/sys_gui/d1_fill_rect_contract_doctest.md.
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32)

    # -- Lines --
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32)

    # -- Circles --
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32)
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32)

    # -- Advanced shapes --
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32)
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32)
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32)

    # -- Text --
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32)

    # -- Image blitting --
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32])

    # -- Clipping --
    me set_clip(x: i32, y: i32, w: i32, h: i32)
    me clear_clip()

    # -- Present --
    me present()

    # -- Readback --
    fn read_pixels() -> [u32]
    fn width() -> i32
    fn height() -> i32
