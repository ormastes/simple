# 2D Engine — Vulkan Backend GLSL Shader Sources
#
# Pure functions returning GLSL compute shader source strings.
# No imports required — all fns return text.
#
# Each shader operates on a storage buffer bound at set=0, binding=0
# which is the u32 framebuffer. Parameters come via push constants.
# Colors are ARGB packed u32.
#
# ============================================================================
# FEATURE GATE — this backend is EXCLUDED from the selection path by default.
# ============================================================================
#
# Architecture Decision D-3: GLSL exclusion is enforced at ffi_dispatch
# selection time. This file exists to preserve shader source history and
# to support optional opt-in via the VULKAN_GLSL_ENABLED env var.
#
# Default: excluded. ffi_dispatch.is_glsl_format("glsl") returns true,
# which causes select_backend_from_probes() to skip this backend.
#
# Opt-in (not recommended for production):
#   Set env var VULKAN_GLSL_ENABLED=1 before starting the process.
#   The ffi_dispatch layer must be explicitly configured to use this backend.
#   Requires shaderc/glslang to be available at runtime.
#
# Query the gate status:
val VULKAN_GLSL_SHADER_FORMAT: text = "glsl"  # always "glsl" — never admitted by default
val VULKAN_GLSL_BACKEND_NAME: text = "vulkan_glsl"

extern fn rt_env_get(key: text) -> text

fn vulkan_glsl_is_enabled() -> bool:
    """Return true only if VULKAN_GLSL_ENABLED env var is set to "1".

    This backend is off by default. The caller (ffi_dispatch) must check
    this before admitting the GLSL backend into the selection path.
    Even when enabled, ffi_dispatch.select_backend_strict() will still
    return a typed error when shader_format == "glsl" for a Vulkan probe.
    This fn exists to make the gate explicit and testable.
    """
    val flag = rt_env_get("VULKAN_GLSL_ENABLED")
    flag == "1"

fn vulkan_glsl_backend_name() -> text:
    VULKAN_GLSL_BACKEND_NAME

fn vulkan_glsl_shader_format() -> text:
    VULKAN_GLSL_SHADER_FORMAT

# ============================================================================
# GLSL Compute Shader Sources
# ============================================================================

fn _glsl_clear() -> text:
    """Clear kernel: fill entire framebuffer with a single color.

    Push constants: color (u32), fb_w (int), fb_h (int)
    Dispatch: 1D, ceil(fb_w*fb_h / 256) workgroups
    """
    r"""#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    uint color;
    int fb_w;
    int fb_h;
} pc;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    uint total = uint(pc.fb_w) * uint(pc.fb_h);
    if (idx >= total) return;
    fb.data[idx] = pc.color;
}
"""

fn _glsl_rect_filled() -> text:
    """Filled rectangle kernel.

    Push constants: x, y, w, h (int), color (u32), fb_w, fb_h (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 2D, ceil(w/16) x ceil(h/16) workgroups
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int rx;
    int ry;
    int rw;
    int rh;
    uint color;
    int fb_w;
    int fb_h;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    if (lx >= pc.rw || ly >= pc.rh) return;

    int px = pc.rx + lx;
    int py = pc.ry + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    uint idx = uint(py) * uint(pc.fb_w) + uint(px);
    fb.data[idx] = pc.color;
}
"""

fn _glsl_rect_outline() -> text:
    """Rectangle outline kernel.

    Same push constants as filled rect.
    Only writes pixels on the border (first/last row or first/last column).
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int rx;
    int ry;
    int rw;
    int rh;
    uint color;
    int fb_w;
    int fb_h;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    if (lx >= pc.rw || ly >= pc.rh) return;

    # Only draw border pixels
    bool on_border = (lx == 0 || lx == pc.rw - 1 || ly == 0 || ly == pc.rh - 1);
    if (!on_border) return;

    int px = pc.rx + lx;
    int py = pc.ry + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    uint idx = uint(py) * uint(pc.fb_w) + uint(px);
    fb.data[idx] = pc.color;
}
"""

fn _glsl_circle_filled() -> text:
    """Filled circle kernel (distance check).

    Push constants: cx, cy, r (int), color (u32), fb_w, fb_h, filled (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 2D over bounding box, ceil((2r+1)/16) x ceil((2r+1)/16)
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int cx;
    int cy;
    int radius;
    uint color;
    int fb_w;
    int fb_h;
    int filled;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    int diam = 2 * pc.radius + 1;
    if (lx >= diam || ly >= diam) return;

    int px = pc.cx - pc.radius + lx;
    int py = pc.cy - pc.radius + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    int dx = px - pc.cx;
    int dy = py - pc.cy;
    int dist_sq = dx * dx + dy * dy;
    int r_sq = pc.radius * pc.radius;

    if (dist_sq <= r_sq) {
        uint idx = uint(py) * uint(pc.fb_w) + uint(px);
        fb.data[idx] = pc.color;
    }
}
"""

fn _glsl_circle_outline() -> text:
    """Circle outline kernel.

    Same push constants as circle_filled.
    Only writes pixels near the circle boundary (anti-aliased ring).
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int cx;
    int cy;
    int radius;
    uint color;
    int fb_w;
    int fb_h;
    int filled;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    int diam = 2 * pc.radius + 1;
    if (lx >= diam || ly >= diam) return;

    int px = pc.cx - pc.radius + lx;
    int py = pc.cy - pc.radius + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    int dx = px - pc.cx;
    int dy = py - pc.cy;
    int dist_sq = dx * dx + dy * dy;
    int r_sq = pc.radius * pc.radius;
    int r_inner = (pc.radius - 1) * (pc.radius - 1);

    # Outline: within ring between (r-1)^2 and r^2
    if (dist_sq <= r_sq && dist_sq >= r_inner) {
        uint idx = uint(py) * uint(pc.fb_w) + uint(px);
        fb.data[idx] = pc.color;
    }
}
"""

fn _glsl_line() -> text:
    """Line kernel (Bresenham-style on GPU, 1 thread per step).

    Push constants: x1, y1, x2, y2 (int), color (u32), thickness, fb_w, fb_h (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 1D, ceil(line_length / 256) workgroups
    """
    r"""#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int x1;
    int y1;
    int x2;
    int y2;
    uint color;
    int thickness;
    int fb_w;
    int fb_h;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int step = int(gl_GlobalInvocationID.x);

    int dx = pc.x2 - pc.x1;
    int dy = pc.y2 - pc.y1;
    int adx = abs(dx);
    int ady = abs(dy);
    int steps = max(adx, ady);
    if (steps == 0) steps = 1;
    if (step >= steps) return;

    # Interpolate position along line
    int px = pc.x1 + (dx * step) / steps;
    int py = pc.y1 + (dy * step) / steps;

    # Draw thickness by expanding around center pixel
    int half_t = pc.thickness / 2;
    for (int ty = -half_t; ty <= half_t; ty++) {
        for (int tx = -half_t; tx <= half_t; tx++) {
            int fx = px + tx;
            int fy = py + ty;
            if (fx < 0 || fx >= pc.fb_w || fy < 0 || fy >= pc.fb_h) continue;
            if (pc.clip_enabled != 0) {
                if (fx < pc.clip_x || fx >= pc.clip_x + pc.clip_w ||
                    fy < pc.clip_y || fy >= pc.clip_y + pc.clip_h) continue;
            }
            uint idx = uint(fy) * uint(pc.fb_w) + uint(fx);
            fb.data[idx] = pc.color;
        }
    }
}
"""

fn _glsl_rounded_rect() -> text:
    """Rounded rectangle kernel.

    Push constants: x, y, w, h, radius (int), color (u32), fb_w, fb_h (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 2D, ceil(w/16) x ceil(h/16) workgroups
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int rx;
    int ry;
    int rw;
    int rh;
    int radius;
    uint color;
    int fb_w;
    int fb_h;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    if (lx >= pc.rw || ly >= pc.rh) return;

    int px = pc.rx + lx;
    int py = pc.ry + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    # Check corner rounding
    int r = pc.radius;
    int r_sq = r * r;
    bool inside = true;

    # Top-left corner
    if (lx < r && ly < r) {
        int dx = r - lx - 1;
        int dy = r - ly - 1;
        if (dx * dx + dy * dy > r_sq) inside = false;
    }
    # Top-right corner
    if (lx >= pc.rw - r && ly < r) {
        int dx = lx - (pc.rw - r);
        int dy = r - ly - 1;
        if (dx * dx + dy * dy > r_sq) inside = false;
    }
    # Bottom-left corner
    if (lx < r && ly >= pc.rh - r) {
        int dx = r - lx - 1;
        int dy = ly - (pc.rh - r);
        if (dx * dx + dy * dy > r_sq) inside = false;
    }
    # Bottom-right corner
    if (lx >= pc.rw - r && ly >= pc.rh - r) {
        int dx = lx - (pc.rw - r);
        int dy = ly - (pc.rh - r);
        if (dx * dx + dy * dy > r_sq) inside = false;
    }

    if (inside) {
        uint idx = uint(py) * uint(pc.fb_w) + uint(px);
        fb.data[idx] = pc.color;
    }
}
"""

fn _glsl_triangle_filled() -> text:
    """Filled triangle kernel (barycentric test).

    Push constants: x1, y1, x2, y2, x3, y3 (int), color (u32),
                    fb_w, fb_h, min_x, min_y (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 2D over bounding box
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int x1;
    int y1;
    int x2;
    int y2;
    int x3;
    int y3;
    uint color;
    int fb_w;
    int fb_h;
    int min_x;
    int min_y;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);

    int px = pc.min_x + lx;
    int py = pc.min_y + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    # Barycentric / edge function test
    int e0 = (pc.x2 - pc.x1) * (py - pc.y1) - (pc.y2 - pc.y1) * (px - pc.x1);
    int e1 = (pc.x3 - pc.x2) * (py - pc.y2) - (pc.y3 - pc.y2) * (px - pc.x2);
    int e2 = (pc.x1 - pc.x3) * (py - pc.y3) - (pc.y1 - pc.y3) * (px - pc.x3);

    bool inside = (e0 >= 0 && e1 >= 0 && e2 >= 0) ||
                  (e0 <= 0 && e1 <= 0 && e2 <= 0);

    if (inside) {
        uint idx = uint(py) * uint(pc.fb_w) + uint(px);
        fb.data[idx] = pc.color;
    }
}
"""

fn _glsl_gradient_rect() -> text:
    """Vertical gradient rectangle kernel.

    Push constants: x, y, w, h (int), top_color, bottom_color (u32),
                    fb_w, fb_h (int),
                    clip_x, clip_y, clip_w, clip_h (int), clip_enabled (int)
    Dispatch: 2D, ceil(w/16) x ceil(h/16) workgroups
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(push_constant) uniform PushConstants {
    int rx;
    int ry;
    int rw;
    int rh;
    uint top_color;
    uint bottom_color;
    int fb_w;
    int fb_h;
    int clip_x;
    int clip_y;
    int clip_w;
    int clip_h;
    int clip_enabled;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    if (lx >= pc.rw || ly >= pc.rh) return;

    int px = pc.rx + lx;
    int py = pc.ry + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    if (pc.clip_enabled != 0) {
        if (px < pc.clip_x || px >= pc.clip_x + pc.clip_w ||
            py < pc.clip_y || py >= pc.clip_y + pc.clip_h) return;
    }

    # Interpolate between top and bottom color based on row position
    float t = (pc.rh > 1) ? float(ly) / float(pc.rh - 1) : 0.0;

    # Unpack top color (ARGB)
    uint ta = (pc.top_color >> 24) & 0xFFu;
    uint tr = (pc.top_color >> 16) & 0xFFu;
    uint tg = (pc.top_color >> 8) & 0xFFu;
    uint tb = pc.top_color & 0xFFu;

    # Unpack bottom color (ARGB)
    uint ba = (pc.bottom_color >> 24) & 0xFFu;
    uint br = (pc.bottom_color >> 16) & 0xFFu;
    uint bg = (pc.bottom_color >> 8) & 0xFFu;
    uint bb = pc.bottom_color & 0xFFu;

    # Lerp each channel
    uint oa = uint(mix(float(ta), float(ba), t));
    uint or_ = uint(mix(float(tr), float(br), t));
    uint og = uint(mix(float(tg), float(bg), t));
    uint ob = uint(mix(float(tb), float(bb), t));

    uint result = (oa << 24) | (or_ << 16) | (og << 8) | ob;
    uint idx = uint(py) * uint(pc.fb_w) + uint(px);
    fb.data[idx] = result;
}
"""

fn _glsl_blit() -> text:
    """Blit (image copy) kernel.

    Framebuffer at binding 0, source pixels at binding 1.
    Push constants: x, y, w, h, fb_w, fb_h (int)
    Dispatch: 2D, ceil(w/16) x ceil(h/16) workgroups
    """
    r"""#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer Framebuffer {
    uint data[];
} fb;

layout(set = 0, binding = 1) buffer SourcePixels {
    uint data[];
} src;

layout(push_constant) uniform PushConstants {
    int rx;
    int ry;
    int rw;
    int rh;
    int fb_w;
    int fb_h;
} pc;

void main() {
    int lx = int(gl_GlobalInvocationID.x);
    int ly = int(gl_GlobalInvocationID.y);
    if (lx >= pc.rw || ly >= pc.rh) return;

    int px = pc.rx + lx;
    int py = pc.ry + ly;

    if (px < 0 || px >= pc.fb_w || py < 0 || py >= pc.fb_h) return;

    uint src_idx = uint(ly) * uint(pc.rw) + uint(lx);
    uint dst_idx = uint(py) * uint(pc.fb_w) + uint(px);
    fb.data[dst_idx] = src.data[src_idx];
}
"""
