# Metal Session
#
# Shared GPU state extracted from MetalBackend so multiple Engine2D surfaces
# can share one Metal device, command queue, shader library, and compute
# pipelines.  Each surface still owns its own per-surface d_framebuffer.
#
# `class` in Simple uses reference semantics (like most OO classes), so
# MetalSession instances can be retained by multiple MetalBackend surfaces
# and the ref_count field correctly tracks live references. The pure-Simple
# phase deliberately does not import raw rt_metal_* externs; native binding
# is left to the Rust/runtime phase while Engine2D keeps deterministic CPU
# mirror rendering.
#
# Usage:
#   use std.gpu.engine2d.metal_session.{MetalSession}

use std.nogc_sync_mut.env.platform.{is_macos}

# ============================================================================
# MetalSession
# ============================================================================

class MetalSession:
    """Shared Metal GPU context: device + command queue + shader library + pipelines.

    Multiple MetalBackend surfaces can share a single MetalSession, avoiding
    the cost of redundant device creation and shader compilation.

    Lifecycle:
      val s = MetalSession.create()
      if s.init():
          # hand s (or s.retain()) to each MetalBackend via init_with_session()
          ...
          s.release()   # each backend calls release() in shutdown()

    init_status() follows the same 0-success/non-zero-error convention used by
    CUDA/Vulkan sessions. init() remains as a bool compatibility wrapper for
    older MetalBackend callers.
    """

    device: i64               # MTLDevice handle
    command_queue: i64        # MTLCommandQueue handle
    shader_lib: i64           # Compiled MSL shader library handle
    pipe_clear: i64           # Compute pipeline: clear
    pipe_rect_filled: i64     # Compute pipeline: filled rect
    pipe_rect_outline: i64    # Compute pipeline: rect outline
    pipe_line: i64            # Compute pipeline: line
    pipe_circle: i64          # Compute pipeline: circle outline
    pipe_circle_filled: i64   # Compute pipeline: filled circle
    pipe_rounded_rect: i64    # Compute pipeline: rounded rect
    pipe_triangle: i64        # Compute pipeline: filled triangle
    pipe_gradient: i64        # Compute pipeline: gradient rect
    pipe_blit: i64            # Compute pipeline: image blit
    ref_count: i64            # Live reference count (i64 matches CUDA/Vulkan/CPU)
    is_initialized: bool      # True after a successful init() (matches CUDA/Vulkan/CPU naming)
    generation: i64           # Stale-resource detection; incremented on init and cleanup
    last_error: i64            # Last init_status() code; 0 means success

    static fn create() -> MetalSession:
        """Return a zero-initialised, uninitialised session. Call init() before use."""
        MetalSession(
            device: 0,
            command_queue: 0,
            shader_lib: 0,
            pipe_clear: 0,
            pipe_rect_filled: 0,
            pipe_rect_outline: 0,
            pipe_line: 0,
            pipe_circle: 0,
            pipe_circle_filled: 0,
            pipe_rounded_rect: 0,
            pipe_triangle: 0,
            pipe_gradient: 0,
            pipe_blit: 0,
            ref_count: 0,
            is_initialized: false,
            generation: 0,
            last_error: 0
        )

    me init() -> bool:
        """Compatibility bool wrapper for legacy Metal callers."""
        self.init_status() == 0

    me init_status() -> i64:
        """Create device, command queue, compile shaders, and compute pipelines.

        Returns 0 on success, non-zero error code on failure.
        Error codes:
          1 — Metal SFFI not available
          2 — metal_sffi_init() failed
          3 — no Metal devices found
          4 — device creation failed
          5 — command queue creation failed
          6 — shader library compilation failed
          7 — one or more pipeline creations failed
        """
        if not is_macos():
            self.last_error = 1
            return 1

        # Pure-Simple phase: strict Metal probing is typed and non-panicking,
        # but native rt_metal_* dispatch is intentionally not imported here.
        self.last_error = 1
        1

    me retain() -> MetalSession:
        """Increment the reference count and return self for convenient assignment."""
        self.ref_count = self.ref_count + 1
        self

    me release():
        """Decrement the reference count; destroy GPU resources when it reaches zero."""
        if self.ref_count <= 0:
            return
        self.ref_count = self.ref_count - 1
        if self.ref_count == 0:
            self._cleanup()

    me is_valid() -> bool:
        self.is_initialized and self.device != 0 and self.command_queue != 0

    me error_code() -> i64:
        self.last_error

    me _cleanup():
        """Destroy all GPU objects. Called automatically by release() on zero refcount."""
        self.pipe_clear = 0
        self.pipe_rect_filled = 0
        self.pipe_rect_outline = 0
        self.pipe_line = 0
        self.pipe_circle = 0
        self.pipe_circle_filled = 0
        self.pipe_rounded_rect = 0
        self.pipe_triangle = 0
        self.pipe_gradient = 0
        self.pipe_blit = 0
        self.shader_lib = 0
        self.command_queue = 0
        self.device = 0
        self.is_initialized = false
        self.generation = self.generation + 1
