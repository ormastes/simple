@allow(primitive_api)
# 2D Engine — OpenGL GPU Backend
#
# Hardware-accelerated 2D rendering using OpenGL 3.3+ core profile.
# Each draw operation maps directly to an OpenGL FFI call. The runtime
# (Rust side) manages the GL context, shader programs, VAO/VBO, and
# orthographic projection internally.
#
# Architecture:
#   - Headless GL context created at init (EGL/CGL/WGL per platform)
#   - FBO (Framebuffer Object) for offscreen rendering
#   - Each draw_*() call issues a single FFI call to the runtime
#   - present() flushes pending GL commands
#   - read_pixels() reads the FBO contents via glReadPixels
#   - Text: CPU-side bitmap font fallback, uploaded via draw_image
#
# Usage:
#   use std.gpu.engine2d.backend_opengl.{OpenGLBackend, opengl_available}

use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{render_text_to_buffer}
use std.gc_async_mut.io.opengl_ffi.{
    opengl_available,
    opengl_init, opengl_destroy,
    opengl_create_fbo, opengl_destroy_fbo, opengl_bind_fbo,
    opengl_read_pixels, opengl_clear, opengl_draw_rect,
    opengl_draw_line, opengl_draw_circle, opengl_draw_triangle,
    opengl_draw_rounded_rect, opengl_draw_gradient_rect,
    opengl_draw_image, opengl_set_scissor, opengl_clear_scissor,
    opengl_flush, opengl_last_error,
    OpenGLContext, OpenGLFBO
}

# ============================================================================
# OpenGL Backend
# ============================================================================

class OpenGLBackend:
    """GPU-accelerated 2D renderer using OpenGL 3.3+ core profile.

    Architecture:
    - Headless GL context for offscreen rendering (no window required)
    - FBO-backed framebuffer for pixel readback
    - Each draw call is a single FFI call; runtime handles shaders/geometry
    - Scissor test for clip rectangles
    - CPU-side text rendering uploaded as image data

    The runtime internally manages:
    - Shader programs (solid color, gradient, textured quad)
    - VAO/VBO for immediate-mode geometry submission
    - Orthographic projection matrix matching pixel coordinates
    - GL state (blending, scissor, FBO binding)
    """

    ctx: OpenGLContext
    fbo: OpenGLFBO
    host_buf: [u32]
    w: i32
    h: i32
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool

    static fn create() -> OpenGLBackend:
        """Create an uninitialized OpenGL backend. Call init() before drawing."""
        OpenGLBackend(
            ctx: OpenGLContext(handle: 0, width: 0, height: 0, is_valid: false),
            fbo: OpenGLFBO(handle: 0, ctx_handle: 0, width: 0, height: 0, is_valid: false),
            host_buf: [],
            w: 0,
            h: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false
        )

impl RenderBackend for OpenGLBackend:

    fn name() -> text:
        "opengl"

    fn init(width: i32, height: i32) -> bool:
        if not opengl_available():
            return false

        # Create headless GL context
        val ctx = opengl_init(_i64(width), _i64(height))
        if not ctx.is_valid:
            return false

        # Create FBO for offscreen rendering
        val fbo = opengl_create_fbo(ctx, _i64(width), _i64(height))
        if not fbo.is_valid:
            opengl_destroy(ctx)
            return false

        # Bind FBO as render target
        if not opengl_bind_fbo(ctx, fbo):
            opengl_destroy_fbo(ctx, fbo)
            opengl_destroy(ctx)
            return false

        self.ctx = ctx
        self.fbo = fbo
        self.w = width
        self.h = height

        # Allocate host readback buffer
        val total = width * height
        self.host_buf = [0u32; total]

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true

        # Clear to opaque black
        opengl_clear(self.ctx, rgb(0, 0, 0))
        true

    fn shutdown():
        if self.initialized:
            opengl_destroy_fbo(self.ctx, self.fbo)
            opengl_destroy(self.ctx)
        self.ctx = OpenGLContext(handle: 0, width: 0, height: 0, is_valid: false)
        self.fbo = OpenGLFBO(handle: 0, ctx_handle: 0, width: 0, height: 0, is_valid: false)
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        opengl_clear(self.ctx, color)

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        opengl_draw_rect(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h), color, false)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        opengl_draw_rect(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h), color, true)

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        opengl_draw_line(self.ctx, _i64(x1), _i64(y1), _i64(x2), _i64(y2), color, _i64(thickness))

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        opengl_draw_circle(self.ctx, _i64(cx), _i64(cy), _i64(r), color, false)

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        opengl_draw_circle(self.ctx, _i64(cx), _i64(cy), _i64(r), color, true)

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        opengl_draw_rounded_rect(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h), _i64(radius), color)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        opengl_draw_triangle(self.ctx, _i64(x1), _i64(y1), _i64(x2), _i64(y2), _i64(x3), _i64(y3), color)

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        opengl_draw_gradient_rect(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h), top_color, bottom_color)

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering via CPU-side bitmap font, then upload as image.
        # For production use, a glyph atlas texture would be pre-uploaded
        # to GPU memory. This fallback is acceptable for low-frequency
        # text draws (UI labels, debug overlays).
        _gl_draw_text_fallback(self, x, y, text_val, color, font_size)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        opengl_draw_image(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h), pixels, _i64(w), _i64(h))

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true
        opengl_set_scissor(self.ctx, _i64(x), _i64(y), _i64(w), _i64(h))

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h
        opengl_clear_scissor(self.ctx)

    me present():
        opengl_flush(self.ctx)

    fn read_pixels() -> [u32]:
        # Read FBO contents into host buffer via glReadPixels
        opengl_read_pixels(self.ctx, self.host_buf, _i64(self.w), _i64(self.h))
        # Return a copy so caller cannot mutate our internal buffer
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

# ============================================================================
# Text Rendering Fallback
# ============================================================================

fn _gl_draw_text_fallback(backend: OpenGLBackend, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render text on CPU using bitmap font, then upload as a textured quad.

    The text is rendered into a temporary pixel buffer at the exact bounding
    size, then uploaded to the GPU via opengl_draw_image. This avoids
    reading back the entire framebuffer (unlike the CUDA fallback).
    """
    var scale = font_size / 7
    if scale < 1:
        scale = 1

    val text_w = text_val.len() * 6 * scale
    val text_h = 7 * scale

    if text_w <= 0 or text_h <= 0:
        return

    # Allocate a transparent pixel buffer for the text region
    val total = text_w * text_h
    var text_buf: [u32] = [0u32; total]

    # Render glyphs into the temporary buffer
    var cursor_x = 0
    var idx = 0
    while idx < text_val.len():
        val ch = text_val.slice(idx, idx + 1)
        _render_glyph_to_buf(text_buf, text_w, text_h, cursor_x, 0, ch, color, scale)
        cursor_x = cursor_x + 6 * scale
        idx = idx + 1

    # Upload the text region as an image to the GPU
    opengl_draw_image(backend.ctx, _i64(x), _i64(y), _i64(text_w), _i64(text_h), text_buf, _i64(text_w), _i64(text_h))

fn _render_glyph_to_buf(buf: [u32], buf_w: i32, buf_h: i32, x: i32, y: i32, ch: text, color: u32, scale: i32):
    """Render a single glyph into a pixel buffer."""
    val bitmap = _get_glyph(ch)
    var row = 0
    while row < 7:
        val row_data = bitmap[row]
        var col = 0
        while col < 5:
            val bit = (row_data >> (4 - col)) & 1
            if bit != 0:
                var sy = 0
                while sy < scale:
                    var sx = 0
                    while sx < scale:
                        val px = x + col * scale + sx
                        val py = y + row * scale + sy
                        if (px >= 0 and px < buf_w and
                            py >= 0 and py < buf_h):
                            val pidx = py * buf_w + px
                            buf[pidx] = color
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1

# ============================================================================
# Minimal Glyph Data (5x7 bitmap font)
# ============================================================================

fn _get_glyph(ch: text) -> [i32]:
    """5x7 bitmap glyph lookup. Returns 7-row array, each row 5 bits wide."""
    if ch == "A" or ch == "a":
        return [0b01110, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]
    if ch == "B" or ch == "b":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10001, 0b10001, 0b11110]
    if ch == "C" or ch == "c":
        return [0b01110, 0b10001, 0b10000, 0b10000, 0b10000, 0b10001, 0b01110]
    if ch == "D" or ch == "d":
        return [0b11100, 0b10010, 0b10001, 0b10001, 0b10001, 0b10010, 0b11100]
    if ch == "E" or ch == "e":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b11111]
    if ch == "F" or ch == "f":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000]
    if ch == "G" or ch == "g":
        return [0b01110, 0b10001, 0b10000, 0b10111, 0b10001, 0b10001, 0b01110]
    if ch == "H" or ch == "h":
        return [0b10001, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]
    if ch == "I" or ch == "i":
        return [0b01110, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "J" or ch == "j":
        return [0b00111, 0b00010, 0b00010, 0b00010, 0b00010, 0b10010, 0b01100]
    if ch == "K" or ch == "k":
        return [0b10001, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b10001]
    if ch == "L" or ch == "l":
        return [0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b11111]
    if ch == "M" or ch == "m":
        return [0b10001, 0b11011, 0b10101, 0b10101, 0b10001, 0b10001, 0b10001]
    if ch == "N" or ch == "n":
        return [0b10001, 0b11001, 0b10101, 0b10011, 0b10001, 0b10001, 0b10001]
    if ch == "O" or ch == "o":
        return [0b01110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]
    if ch == "P" or ch == "p":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10000, 0b10000, 0b10000]
    if ch == "Q" or ch == "q":
        return [0b01110, 0b10001, 0b10001, 0b10001, 0b10101, 0b10010, 0b01101]
    if ch == "R" or ch == "r":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10100, 0b10010, 0b10001]
    if ch == "S" or ch == "s":
        return [0b01110, 0b10001, 0b10000, 0b01110, 0b00001, 0b10001, 0b01110]
    if ch == "T" or ch == "t":
        return [0b11111, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]
    if ch == "U" or ch == "u":
        return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]
    if ch == "V" or ch == "v":
        return [0b10001, 0b10001, 0b10001, 0b10001, 0b01010, 0b01010, 0b00100]
    if ch == "W" or ch == "w":
        return [0b10001, 0b10001, 0b10001, 0b10101, 0b10101, 0b11011, 0b10001]
    if ch == "X" or ch == "x":
        return [0b10001, 0b10001, 0b01010, 0b00100, 0b01010, 0b10001, 0b10001]
    if ch == "Y" or ch == "y":
        return [0b10001, 0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b00100]
    if ch == "Z" or ch == "z":
        return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b10000, 0b11111]
    if ch == "0":
        return [0b01110, 0b10001, 0b10011, 0b10101, 0b11001, 0b10001, 0b01110]
    if ch == "1":
        return [0b00100, 0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "2":
        return [0b01110, 0b10001, 0b00001, 0b00110, 0b01000, 0b10000, 0b11111]
    if ch == "3":
        return [0b01110, 0b10001, 0b00001, 0b00110, 0b00001, 0b10001, 0b01110]
    if ch == "4":
        return [0b00010, 0b00110, 0b01010, 0b10010, 0b11111, 0b00010, 0b00010]
    if ch == "5":
        return [0b11111, 0b10000, 0b11110, 0b00001, 0b00001, 0b10001, 0b01110]
    if ch == "6":
        return [0b01110, 0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b01110]
    if ch == "7":
        return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b01000, 0b01000]
    if ch == "8":
        return [0b01110, 0b10001, 0b10001, 0b01110, 0b10001, 0b10001, 0b01110]
    if ch == "9":
        return [0b01110, 0b10001, 0b10001, 0b01111, 0b00001, 0b00001, 0b01110]
    if ch == " ":
        return [0, 0, 0, 0, 0, 0, 0]
    if ch == ".":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100]
    if ch == ",":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]
    if ch == "!":
        return [0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00000, 0b00100]
    if ch == ":":
        return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b00000]
    if ch == "-":
        return [0b00000, 0b00000, 0b00000, 0b11111, 0b00000, 0b00000, 0b00000]
    if ch == "+":
        return [0b00000, 0b00100, 0b00100, 0b11111, 0b00100, 0b00100, 0b00000]
    if ch == "=":
        return [0b00000, 0b00000, 0b11111, 0b00000, 0b11111, 0b00000, 0b00000]
    if ch == "(":
        return [0b00010, 0b00100, 0b01000, 0b01000, 0b01000, 0b00100, 0b00010]
    if ch == ")":
        return [0b01000, 0b00100, 0b00010, 0b00010, 0b00010, 0b00100, 0b01000]
    if ch == "/":
        return [0b00001, 0b00010, 0b00010, 0b00100, 0b01000, 0b01000, 0b10000]
    if ch == "_":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b11111]
    # Unknown character: filled block
    [0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111]

# ============================================================================
# Conversion Helpers
# ============================================================================

fn _i64(v: i32) -> i64:
    v as i64
