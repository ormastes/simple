@allow(primitive_api)
# 2D Engine — OpenGL Backend (Stub)
#
# Stub implementation of the RenderBackend trait for OpenGL.
# Returns false from init() when OpenGL is not available.
# Provides the full interface for future implementation.
#
# OpenGL Pipeline Stages Needed:
#   1. GL context creation (via platform window: GLX/WGL/EGL)
#   2. Shader program: simple 2D vertex + fragment shaders
#   3. VAO/VBO for rect/triangle vertices
#   4. Uniform for color, projection matrix (orthographic)
#   5. glScissor for clip rect
#   6. Framebuffer object for offscreen rendering
#   7. glReadPixels for read_pixels() support
#   8. Texture for draw_image() and text atlas
#   9. Blending: glEnable(GL_BLEND), GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA
#  10. SwapBuffers for present()
#
# Usage:
#   use std.gpu.engine2d.backend_opengl.{OpenGLBackend}

use std.gpu.engine2d.backend.{RenderBackend}

# ============================================================================
# OpenGL Availability Check
# ============================================================================

extern fn rt_opengl_available() -> i64

fn opengl_available() -> bool:
    """Check if OpenGL runtime is available on this system."""
    rt_opengl_available() != 0

# ============================================================================
# OpenGL Backend
# ============================================================================

class OpenGLBackend:
    """OpenGL-based 2D renderer (stub).

    This backend will use OpenGL 3.3+ core profile for hardware-accelerated
    2D rendering. Currently returns false from init() since the OpenGL
    pipeline setup is not yet implemented.

    Future implementation plan:
    - OpenGL 3.3 core profile (widest hardware support)
    - Single orthographic projection for 2D coordinate space
    - Batch draw calls: accumulate vertices, flush on present()
    - Texture atlas for bitmap font glyphs
    - FBO for offscreen rendering + read_pixels() via glReadPixels
    """

    w: i32
    h: i32
    initialized: bool

    static fn create() -> OpenGLBackend:
        """Create an uninitialized OpenGL backend."""
        OpenGLBackend(
            w: 0,
            h: 0,
            initialized: false
        )

impl RenderBackend for OpenGLBackend:

    fn name() -> text:
        "opengl"

    fn init(width: i32, height: i32) -> bool:
        if not opengl_available():
            return false

        # TODO: GL context, shaders, VAO/VBO, FBO setup
        # For now, return false to indicate unavailability
        false

    fn shutdown():
        self.initialized = false

    me clear(color: u32):
        pass_do_nothing

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        pass_do_nothing

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        pass_do_nothing

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        pass_do_nothing

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        pass_do_nothing

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        pass_do_nothing

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        pass_do_nothing

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        pass_do_nothing

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        pass_do_nothing

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        pass_do_nothing

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        pass_do_nothing

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        pass_do_nothing

    me clear_clip():
        pass_do_nothing

    me present():
        pass_do_nothing

    fn read_pixels() -> [u32]:
        []

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h
