@allow(primitive_api)
# 2D Engine — Vulkan Backend (Stub)
#
# Stub implementation of the RenderBackend trait for Vulkan.
# Returns false from init() when Vulkan is not available.
# Provides the full interface for future implementation.
#
# Vulkan Pipeline Stages Needed:
#   1. VkInstance creation with validation layers
#   2. Physical/logical device selection
#   3. Swapchain for presentation
#   4. Render pass with single color attachment (RGBA8)
#   5. Graphics pipeline with 2D vertex/fragment shaders
#   6. Command buffer recording per frame
#   7. Vertex buffer for rect/triangle primitives
#   8. Push constants for color, transform, clip rect
#   9. Framebuffer attachments for offscreen rendering
#  10. Fence/semaphore synchronization for present
#
# Usage:
#   use std.gpu.engine2d.backend_vulkan.{VulkanBackend}

use std.gpu.engine2d.backend.{RenderBackend}

# ============================================================================
# Vulkan Availability Check
# ============================================================================

extern fn rt_vulkan_available() -> i64

fn vulkan_available() -> bool:
    """Check if Vulkan runtime is available on this system."""
    rt_vulkan_available() != 0

# ============================================================================
# Vulkan Backend
# ============================================================================

class VulkanBackend:
    """Vulkan-based 2D renderer (stub).

    This backend will use Vulkan's graphics pipeline for hardware-accelerated
    2D rendering. Currently returns false from init() since the Vulkan
    pipeline setup is not yet implemented.

    Future implementation plan:
    - Use a single render pass with RGBA8 color attachment
    - Batch draw calls into a single command buffer per frame
    - Use push constants for per-primitive color and transform
    - Instanced rendering for repeated shapes (rects, circles)
    - Compute shader path for filled circles and gradients
    """

    w: i32
    h: i32
    initialized: bool

    static fn create() -> VulkanBackend:
        """Create an uninitialized Vulkan backend."""
        VulkanBackend(
            w: 0,
            h: 0,
            initialized: false
        )

impl RenderBackend for VulkanBackend:

    fn name() -> text:
        "vulkan"

    fn init(width: i32, height: i32) -> bool:
        # Vulkan backend not yet implemented
        if not vulkan_available():
            return false

        # TODO: VkInstance, device, swapchain, render pass, pipeline setup
        # For now, return false to indicate unavailability
        false

    fn shutdown():
        self.initialized = false

    me clear(color: u32):
        pass_do_nothing

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        pass_do_nothing

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        pass_do_nothing

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        pass_do_nothing

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        pass_do_nothing

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        pass_do_nothing

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        pass_do_nothing

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        pass_do_nothing

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        pass_do_nothing

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        pass_do_nothing

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        pass_do_nothing

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        pass_do_nothing

    me clear_clip():
        pass_do_nothing

    me present():
        pass_do_nothing

    fn read_pixels() -> [u32]:
        []

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h
