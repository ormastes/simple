# 2D Engine — Vulkan Backend (Compute Shader)
#
# Hardware-accelerated 2D rendering using Vulkan compute shaders. Each draw
# operation dispatches a compute shader operating on a storage buffer
# framebuffer. present() copies the GPU buffer back to host memory.
#
# Requires Vulkan runtime with compute shader support.
#
# Architecture:
#   - Framebuffer is a Vulkan storage buffer (usage 0x80)
#   - SPIR-V compute shaders for validated kernels; descriptor-compatible
#     no-op SPIR-V placeholders for unsupported kernels.
#   - Push constants carry per-primitive parameters
#   - Each draw call: begin_compute -> bind_pipeline -> bind_descriptors ->
#     push_constants -> dispatch -> end_compute -> submit_and_wait
#
# Usage:
#   use std.gpu.engine2d.backend_vulkan.{VulkanBackend}

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, render_text_to_buffer}
use std.gpu.engine2d.helpers_text.{text_blit_buffer}
use std.gpu.engine2d.backend_vulkan_helpers.{
    _pack_clear_pc, _pack_rect_pc, _pack_line_pc, _pack_circle_pc,
    _pack_rounded_rect_pc, _pack_triangle_pc, _pack_gradient_pc, _pack_blit_pc,
    _pixels_to_bytes, _bytes_to_pixels, _bytes_to_pixel_array, _i64, _i32_to_u32, _u32_to_u8,
    _u8_to_u32, _bool_to_i32, vulkan_dispatch_compute,
    vulkan_dispatch_blit_compute
}
use std.gpu.engine2d.backend_vulkan_spirv.{
    spirv_clear, spirv_rect_filled, spirv_noop_storage
}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.nogc_sync_mut.gpu.engine2d.sffi_vulkan.{
    vulkan_sffi_init, vulkan_sffi_shutdown, vulkan_sffi_is_available,
    vulkan_sffi_device_count, vulkan_sffi_select_device,
    vulkan_sffi_alloc_buffer, vulkan_sffi_free_buffer,
    vulkan_sffi_copy_to_buffer, vulkan_sffi_copy_from_buffer,
    vulkan_sffi_read_buffer_bytes,
    vulkan_sffi_compile_spirv, vulkan_sffi_destroy_shader,
    vulkan_sffi_create_compute_pipeline, vulkan_sffi_destroy_pipeline,
    vulkan_sffi_wait_idle, vulkan_sffi_last_error,
    vulkan_sffi_find_headless_device, vulkan_sffi_select_headless
}
use std.gc_async_mut.gpu.engine2d.vulkan_session.{VulkanSession}

# ============================================================================
# Vulkan Availability Check
# ============================================================================

fn vulkan_available() -> bool:
    """Check if Vulkan runtime is available on this system."""
    vulkan_sffi_is_available()

# ============================================================================
# Push Constant Size (in bytes)
#
# All shaders use at most 64 bytes of push constants (16 x i32).
# This accommodates the largest kernel (triangle: 13 ints + padding).
# ============================================================================

val VK_PUSH_CONSTANT_SIZE: i64 = 64

# ============================================================================
# Structured error classification
# ============================================================================
#
# VulkanErrorKind classifies the failure category returned in last_error so
# callers can react appropriately without string-parsing.
#
# Usage:
#   val kind = vulkan_classify_error(backend.last_error)
#   if kind == VulkanErrorKind.DeviceLost: ...

enum VulkanErrorKind:
    """Classification of Vulkan runtime errors."""
    # Vulkan device was lost (VK_ERROR_DEVICE_LOST or similar).
    DeviceLost
    # A required Vulkan extension was not available on the selected device.
    MissingExtension
    # SPIR-V or GLSL shader compilation failed at pipeline creation time.
    ShaderCompile
    # The Vulkan runtime is not present or not initialised on this host.
    NotAvailable
    # No Vulkan device enumerated (or selection of a specific device failed).
    NoDevice
    # Catch-all for other runtime errors not classified above.
    Other
    # Not an error (last_error is empty).
    None

fn _err_is_device_lost(err: text) -> bool:
    err.contains("device lost") or err.contains("DEVICE_LOST")

fn _err_is_missing_ext(err: text) -> bool:
    err.contains("extension") or err.contains("Extension")

fn _err_is_shader_compile(err: text) -> bool:
    val has_shader = err.contains("shader") or err.contains("SPIR-V")
    val has_compile = err.contains("compile") or err.contains("pipeline")
    has_shader or has_compile

fn _err_is_not_available(err: text) -> bool:
    err.contains("unavailable") or err.contains("rt_vulkan_init")

fn _err_is_no_device(err: text) -> bool:
    err.contains("no Vulkan devices") or err.contains("select_device")

fn vulkan_classify_error(err: text) -> VulkanErrorKind:
    """Classify a Vulkan error string into a VulkanErrorKind variant.

    Uses substring matching against known error prefixes emitted by the
    Simple Vulkan SFFI layer.  Returns VulkanErrorKind.None when err is "".
    """
    if err == "":
        VulkanErrorKind.None
    elif _err_is_device_lost(err):
        VulkanErrorKind.DeviceLost
    elif _err_is_missing_ext(err):
        VulkanErrorKind.MissingExtension
    elif _err_is_shader_compile(err):
        VulkanErrorKind.ShaderCompile
    elif _err_is_not_available(err):
        VulkanErrorKind.NotAvailable
    elif _err_is_no_device(err):
        VulkanErrorKind.NoDevice
    else:
        VulkanErrorKind.Other

# ============================================================================
# Vulkan Backend
# ============================================================================

class VulkanBackend:
    """Vulkan compute shader 2D renderer.

    Architecture:
    - Framebuffer lives in a Vulkan storage buffer (d_framebuffer)
    - Each draw call dispatches a compute shader
    - present() copies GPU storage buffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line) has a dedicated
    compute shader. Workgroup sizes are chosen to cover the bounding box
    of the primitive being drawn.
    """

    host_buf: [u32]
    w: i32
    h: i32
    d_framebuffer: i64          # Vulkan storage buffer handle
    # Shader module handles
    shader_clear: i64
    shader_rect_filled: i64
    shader_rect_outline: i64
    shader_circle_filled: i64
    shader_circle_outline: i64
    shader_line: i64
    shader_rounded_rect: i64
    shader_triangle: i64
    shader_gradient: i64
    shader_blit: i64
    # Pipeline handles
    pipe_clear: i64
    pipe_rect_filled: i64
    pipe_rect_outline: i64
    pipe_circle_filled: i64
    pipe_circle_outline: i64
    pipe_line: i64
    pipe_rounded_rect: i64
    pipe_triangle: i64
    pipe_gradient: i64
    pipe_blit: i64
    # Mask buffer storage
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    # Clipping state
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool
    dirty: bool                  # True when GPU has changes not yet copied to host
    session: VulkanSession       # Shared session (null-like when not session-owned)
    owns_session: bool           # True when this backend must release the session
    last_error: text             # Most recent init/runtime failure for strict probes

    static fn create() -> VulkanBackend:
        """Create an uninitialized Vulkan backend. Call init() before drawing."""
        VulkanBackend(
            host_buf: [],
            w: 0,
            h: 0,
            d_framebuffer: 0,
            shader_clear: 0,
            shader_rect_filled: 0,
            shader_rect_outline: 0,
            shader_circle_filled: 0,
            shader_circle_outline: 0,
            shader_line: 0,
            shader_rounded_rect: 0,
            shader_triangle: 0,
            shader_gradient: 0,
            shader_blit: 0,
            pipe_clear: 0,
            pipe_rect_filled: 0,
            pipe_rect_outline: 0,
            pipe_circle_filled: 0,
            pipe_circle_outline: 0,
            pipe_line: 0,
            pipe_rounded_rect: 0,
            pipe_triangle: 0,
            pipe_gradient: 0,
            pipe_blit: 0,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false,
            dirty: false,
            session: VulkanSession.create(),
            owns_session: false,
            last_error: ""
        )

impl RenderBackend for VulkanBackend:

    fn name() -> text:
        "vulkan"

    me init(width: i32, height: i32) -> bool:
        self.last_error = ""

        # Check Vulkan availability
        if not vulkan_available():
            self.last_error = "Vulkan runtime unavailable"
            return false

        if not vulkan_sffi_init():
            self.last_error = "rt_vulkan_init failed: " + vulkan_sffi_last_error()
            return false

        if vulkan_sffi_device_count() < 1:
            self.last_error = "no Vulkan devices"
            return false

        # Select first device
        if not vulkan_sffi_select_device(0):
            self.last_error = "rt_vulkan_select_device(0) failed: " + vulkan_sffi_last_error()
            return false

        self.w = width
        self.h = height

        # Allocate device framebuffer storage buffer (4 bytes per pixel = u32)
        # Usage 0x80 = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = vulkan_sffi_alloc_buffer(fb_size, 0x80)
        if self.d_framebuffer == 0:
            self.last_error = "rt_vulkan_alloc_buffer failed: " + vulkan_sffi_last_error()
            return false

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        # Compile validated SPIR-V kernels. Unsupported kernels use a
        # descriptor-compatible no-op SPIR-V module so init does not depend on
        # the unsupported GLSL compiler path.
        val noop_spirv = spirv_noop_storage()
        self.shader_clear = vulkan_sffi_compile_spirv(spirv_clear())
        self.shader_rect_filled = vulkan_sffi_compile_spirv(spirv_rect_filled())
        self.shader_rect_outline = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_circle_filled = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_circle_outline = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_line = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_rounded_rect = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_triangle = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_gradient = vulkan_sffi_compile_spirv(noop_spirv)
        self.shader_blit = vulkan_sffi_compile_spirv(noop_spirv)

        if (self.shader_clear == 0 or self.shader_rect_filled == 0 or
            self.shader_rect_outline == 0 or self.shader_circle_filled == 0 or
            self.shader_circle_outline == 0 or self.shader_line == 0 or
            self.shader_rounded_rect == 0 or self.shader_triangle == 0 or
            self.shader_gradient == 0 or self.shader_blit == 0):
            self.last_error = "Vulkan SPIR-V shader compilation failed: " + vulkan_sffi_last_error()
            self.shutdown()
            return false

        # Create compute pipelines (all use push constants)
        self.pipe_clear = vulkan_sffi_create_compute_pipeline(self.shader_clear, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rect_filled = vulkan_sffi_create_compute_pipeline(self.shader_rect_filled, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rect_outline = vulkan_sffi_create_compute_pipeline(self.shader_rect_outline, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_circle_filled = vulkan_sffi_create_compute_pipeline(self.shader_circle_filled, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_circle_outline = vulkan_sffi_create_compute_pipeline(self.shader_circle_outline, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_line = vulkan_sffi_create_compute_pipeline(self.shader_line, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rounded_rect = vulkan_sffi_create_compute_pipeline(self.shader_rounded_rect, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_triangle = vulkan_sffi_create_compute_pipeline(self.shader_triangle, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_gradient = vulkan_sffi_create_compute_pipeline(self.shader_gradient, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_blit = vulkan_sffi_create_compute_pipeline(self.shader_blit, "main", VK_PUSH_CONSTANT_SIZE)

        # Verify all pipelines were created
        if (self.pipe_clear == 0 or self.pipe_rect_filled == 0 or
            self.pipe_rect_outline == 0 or self.pipe_circle_filled == 0 or
            self.pipe_circle_outline == 0 or self.pipe_line == 0 or
            self.pipe_rounded_rect == 0 or self.pipe_triangle == 0 or
            self.pipe_gradient == 0 or self.pipe_blit == 0):
            self.last_error = "Vulkan compute pipeline creation failed: " + vulkan_sffi_last_error()
            self.shutdown()
            return false

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    me init_with_session(width: i32, height: i32, session: VulkanSession) -> bool:
        """Initialise this backend surface using a pre-initialised shared VulkanSession.

        The session must already have been successfully init()ed.  This backend
        borrows the session's pipelines (no shader recompilation) and retains
        the session so it stays alive for the lifetime of this surface.
        shutdown() will call session.release().

        Per-surface state (framebuffer, host buffer, clip region) is still
        owned exclusively by this backend.
        """
        if not session.is_valid():
            self.last_error = "Vulkan session is invalid"
            return false

        # Retain the shared session; we will release it in shutdown()
        val retained = session.retain()
        self.session = retained
        self.owns_session = true

        # Borrow shared pipeline handles from the session
        self.shader_clear         = session.shader_clear
        self.shader_rect_filled   = session.shader_rect_filled
        self.shader_rect_outline  = session.shader_rect_outline
        self.shader_circle_filled = session.shader_circle_filled
        self.shader_circle_outline = session.shader_circle_outline
        self.shader_line          = session.shader_line
        self.shader_rounded_rect  = session.shader_rounded_rect
        self.shader_triangle      = session.shader_triangle
        self.shader_gradient      = session.shader_gradient
        self.shader_blit          = session.shader_blit

        self.pipe_clear          = session.pipe_clear
        self.pipe_rect_filled    = session.pipe_rect_filled
        self.pipe_rect_outline   = session.pipe_rect_outline
        self.pipe_circle_filled  = session.pipe_circle_filled
        self.pipe_circle_outline = session.pipe_circle_outline
        self.pipe_line           = session.pipe_line
        self.pipe_rounded_rect   = session.pipe_rounded_rect
        self.pipe_triangle       = session.pipe_triangle
        self.pipe_gradient       = session.pipe_gradient
        self.pipe_blit           = session.pipe_blit

        self.w = width
        self.h = height

        # Allocate per-surface device framebuffer storage buffer
        # Usage 0x80 = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = vulkan_sffi_alloc_buffer(fb_size, 0x80)
        if self.d_framebuffer == 0:
            self.last_error = "rt_vulkan_alloc_buffer failed: " + vulkan_sffi_last_error()
            self.session.release()
            self.owns_session = false
            return false

        # Allocate host readback buffer
        val total = width * height
        self.host_buf = [0u32; total]

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    me shutdown():
        if self.owns_session:
            # Session owns shaders/pipelines — do not destroy them here
            if self.d_framebuffer != 0:
                vulkan_sffi_free_buffer(self.d_framebuffer)
                self.d_framebuffer = 0
            self.host_buf = []
            self.w = 0
            self.h = 0
            self.mask_buf = []
            self.mask_w = 0
            self.mask_h = 0
            self.initialized = false
            self.session.release()
            self.owns_session = false
            return

        # Standalone (no shared session): destroy pipelines and shaders here
        # Destroy pipelines
        if self.pipe_clear != 0: vulkan_sffi_destroy_pipeline(self.pipe_clear)
        if self.pipe_rect_filled != 0: vulkan_sffi_destroy_pipeline(self.pipe_rect_filled)
        if self.pipe_rect_outline != 0: vulkan_sffi_destroy_pipeline(self.pipe_rect_outline)
        if self.pipe_circle_filled != 0: vulkan_sffi_destroy_pipeline(self.pipe_circle_filled)
        if self.pipe_circle_outline != 0: vulkan_sffi_destroy_pipeline(self.pipe_circle_outline)
        if self.pipe_line != 0: vulkan_sffi_destroy_pipeline(self.pipe_line)
        if self.pipe_rounded_rect != 0: vulkan_sffi_destroy_pipeline(self.pipe_rounded_rect)
        if self.pipe_triangle != 0: vulkan_sffi_destroy_pipeline(self.pipe_triangle)
        if self.pipe_gradient != 0: vulkan_sffi_destroy_pipeline(self.pipe_gradient)
        if self.pipe_blit != 0: vulkan_sffi_destroy_pipeline(self.pipe_blit)
        # Destroy shader modules
        if self.shader_clear != 0: vulkan_sffi_destroy_shader(self.shader_clear)
        if self.shader_rect_filled != 0: vulkan_sffi_destroy_shader(self.shader_rect_filled)
        if self.shader_rect_outline != 0: vulkan_sffi_destroy_shader(self.shader_rect_outline)
        if self.shader_circle_filled != 0: vulkan_sffi_destroy_shader(self.shader_circle_filled)
        if self.shader_circle_outline != 0: vulkan_sffi_destroy_shader(self.shader_circle_outline)
        if self.shader_line != 0: vulkan_sffi_destroy_shader(self.shader_line)
        if self.shader_rounded_rect != 0: vulkan_sffi_destroy_shader(self.shader_rounded_rect)
        if self.shader_triangle != 0: vulkan_sffi_destroy_shader(self.shader_triangle)
        if self.shader_gradient != 0: vulkan_sffi_destroy_shader(self.shader_gradient)
        if self.shader_blit != 0: vulkan_sffi_destroy_shader(self.shader_blit)
        # Free framebuffer
        if self.d_framebuffer != 0:
            vulkan_sffi_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.initialized = false

    me clear(color: u32):
        if not self.initialized:
            return
        val total = _i64(self.w) * _i64(self.h)
        val workgroups = (total + 255) / 256
        val pc = _pack_clear_pc(color, self.w, self.h)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_clear, pc, workgroups, 1, 1)
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.initialized:
            return
        val pc = _pack_rect_pc(x, y, w, h, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_rect_outline, pc, gx, gy, 1)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.initialized:
            return
        val pc = _pack_rect_pc(x, y, w, h, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_rect_filled, pc, gx, gy, 1)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if not self.initialized:
            return
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val workgroups = (_i64(line_len) + 255) / 256
        val pc = _pack_line_pc(x1, y1, x2, y2, color, thickness, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_line, pc, workgroups, 1, 1)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        if not self.initialized:
            return
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_circle_pc(cx, cy, r, color, self.w, self.h, 0, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_circle_outline, pc, gx, gy, 1)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if not self.initialized:
            return
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_circle_pc(cx, cy, r, color, self.w, self.h, 1, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_circle_filled, pc, gx, gy, 1)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        if not self.initialized:
            return
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        val pc = _pack_rounded_rect_pc(x, y, w, h, radius, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_rounded_rect, pc, gx, gy, 1)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        if not self.initialized:
            return
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_triangle_pc(x1, y1, x2, y2, x3, y3, color, self.w, self.h, min_x, min_y, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_triangle, pc, gx, gy, 1)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if not self.initialized:
            return
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        val pc = _pack_gradient_pc(x, y, w, h, top_color, bottom_color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        vulkan_dispatch_compute(self.d_framebuffer, self.pipe_gradient, pc, gx, gy, 1)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering on GPU is complex; fall back to CPU-side rendering
        # then upload the affected region. For production, a glyph atlas
        # texture would be uploaded and sampled by a kernel.
        self._gpu_draw_text_fallback(x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if not self.initialized:
            return
        # Upload pixel data to a temporary Vulkan storage buffer, then
        # dispatch a blit compute shader to copy it into the framebuffer
        val pixel_count = _i64(w) * _i64(h)
        val byte_size = pixel_count * 4
        val d_src = vulkan_sffi_alloc_buffer(byte_size, 0x80)
        if d_src != 0:
            # Upload source pixels to device buffer
            val src_bytes = _pixels_to_bytes(pixels, pixel_count)
            vulkan_sffi_copy_to_buffer(d_src, src_bytes, 0)
            # Dispatch blit kernel
            val gx = (_i64(w) + 15) / 16
            val gy = (_i64(h) + 15) / 16
            val pc = _pack_blit_pc(x, y, w, h, self.w, self.h)
            vulkan_dispatch_blit_compute(self.d_framebuffer, self.pipe_blit, d_src, pc, gx, gy, 1)
            vulkan_sffi_free_buffer(d_src)
        self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Copy GPU storage buffer to host memory
        if not self.initialized:
            return
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes = vulkan_sffi_read_buffer_bytes(self.d_framebuffer, fb_size, 0)
            vulkan_sffi_wait_idle()
            self.host_buf = _bytes_to_pixel_array(fb_bytes, self.w * self.h)
            self.dirty = false

    fn read_pixels() -> [u32]:
        # fn contract forbids self mutation: dirty reads fetch straight from the
        # device; present() owns the host_buf cache refresh.
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes = vulkan_sffi_read_buffer_bytes(self.d_framebuffer, fb_size, 0)
            vulkan_sffi_wait_idle()
            return _bytes_to_pixel_array(fb_bytes, self.w * self.h)
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
