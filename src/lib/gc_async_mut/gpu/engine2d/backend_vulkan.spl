    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        if self.completion_unknown: return
        if self.mask_buf.len() > 0 and w > 0 and h > 0:
            var pixels: [u32] = [0u32; w * h]
            var py = 0
            while py < h:
                var px = 0
                while px < w:
                    val denom = if w > 1: w - 1 else: 1
                    val rr = color_r(left_color) + (color_r(right_color) - color_r(left_color)) * px / denom
                    val gg = color_g(left_color) + (color_g(right_color) - color_g(left_color)) * px / denom
                    val bb = color_b(left_color) + (color_b(right_color) - color_b(left_color)) * px / denom
                    val aa = color_a(left_color) + (color_a(right_color) - color_a(left_color)) * px / denom
                    val dx = x + px
                    val dy = y + py
                    val mask_index = dy * self.mask_w + dx
                    if (dx >= 0 and dy >= 0 and mask_index >= 0 and
                            mask_index < self.mask_buf.len() and
                            self.mask_buf[mask_index] != 0u8):
                        pixels[py * w + px] = rgba(rr, gg, bb, aa)
                    px = px + 1
                py = py + 1
            val saved_mask = self.mask_buf
            val saved_mask_w = self.mask_w
            val saved_mask_h = self.mask_h
            self.mask_buf = []
            self.mask_w = 0
            self.mask_h = 0
            self.draw_image_blend(x, y, w, h, pixels)
            self.mask_buf = saved_mask
            self.mask_w = saved_mask_w
            self.mask_h = saved_mask_h
            return
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

