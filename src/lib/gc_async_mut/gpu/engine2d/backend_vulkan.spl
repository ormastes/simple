        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        if self.cpu_fallback_used:
            engine2d_readback(copy, "cpu_fallback")
        else:
            engine2d_readback(copy, "host_cache_after_device_present")

