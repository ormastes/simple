    me _draw_image_composite_native(x: i32, y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32], opacity_milli: i32, composite_mode: i32, require_wholly_bounded: bool) -> i64:
        if self.completion_unknown or not self.initialized or self.d_framebuffer <= 0 or self.pipe_blit <= 0:
            return 0
        if (dst_w <= 0 or dst_h <= 0 or src_w <= 0 or src_h <= 0 or self.mask_buf.len() > 0 or
            opacity_milli <= 0 or opacity_milli > 1000 or
            (composite_mode != VK_IMAGE_COMPOSITE_COPY and composite_mode != VK_IMAGE_COMPOSITE_SRC_OVER)):
            return 0

        val pixel_count = _i64(src_w) * _i64(src_h)
        val scale_x_product = (_i64(dst_w) - 1) * _i64(src_w)
        val scale_y_product = (_i64(dst_h) - 1) * _i64(src_h)
        if (pixel_count <= 0 or pixel_count > 4294967295 or pixel_count > 9223372036854775807 / 4 or
            pixels.len().to_i64() != pixel_count or
            scale_x_product > 2147483647 or scale_y_product > 2147483647):
            return 0
        val right = _i64(x) + _i64(dst_w)
        val bottom = _i64(y) + _i64(dst_h)
        if right - 1 > 2147483647 or bottom - 1 > 2147483647:
            return 0
        if require_wholly_bounded and (_i64(x) < 0 or _i64(y) < 0 or right > _i64(self.w) or bottom > _i64(self.h)):
            return 0
        if self.clip_enabled:
            val clip_right = _i64(self.clip_x) + _i64(self.clip_w)
            val clip_bottom = _i64(self.clip_y) + _i64(self.clip_h)
            if self.clip_w <= 0 or self.clip_h <= 0 or clip_right > 2147483647 or clip_bottom > 2147483647:
                return 0
            if require_wholly_bounded and (_i64(x) < _i64(self.clip_x) or _i64(y) < _i64(self.clip_y) or
                right > clip_right or bottom > clip_bottom):
                return 0

        val src_size = pixel_count * 4
        val d_src = vulkan_sffi_alloc_buffer(src_size, 0x80)
        if d_src <= 0:
            return 0
        val source_bytes = _pixels_to_bytes(pixels, pixel_count)
        if source_bytes.len().to_i64() != src_size or not vulkan_sffi_copy_to_buffer(d_src, source_bytes, 0):
            vulkan_sffi_free_buffer(d_src)
            return 0
        val pc = _pack_image_composite_pc(x, y, dst_w, dst_h, self.w, self.h,
            self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled,
            opacity_milli, composite_mode, src_w, src_h)
        val gx = (_i64(dst_w) + 15) / 16
        val gy = (_i64(dst_h) + 15) / 16
        val dispatched = vulkan_dispatch_image_composite_checked(self.d_framebuffer, self.pipe_blit, d_src, pc, gx, gy, 1)
        if dispatched > 0:
            self.dirty = true
            if dispatched == VK_DISPATCH_COMPLETED_INELIGIBLE:
