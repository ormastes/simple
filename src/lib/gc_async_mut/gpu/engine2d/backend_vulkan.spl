        self.mask_w = 0
        self.mask_h = 0

    me present():
        if self.completion_unknown:
            return
        # Copy GPU storage buffer to host memory
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes = vulkan_sffi_read_buffer_bytes(self.d_framebuffer, fb_size, 0)
            vulkan_sffi_wait_idle()
            self.host_buf = _bytes_to_pixel_array(fb_bytes, self.w * self.h)
            self.dirty = false

    me read_pixels() -> [u32]:
        self.read_pixels_with_source().pixels

    me read_pixels_with_source() -> Engine2DReadback:
        if self.completion_unknown:
            return engine2d_readback([], "completion_unknown")
        # fn contract forbids self mutation: dirty reads fetch straight from the
        # device; present() owns the host_buf cache refresh.
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes = vulkan_sffi_read_buffer_bytes(self.d_framebuffer, fb_size, 0)
            vulkan_sffi_wait_idle()
            val pixels = _bytes_to_pixel_array(fb_bytes, self.w * self.h)
            if self.cpu_fallback_used:
                return engine2d_readback(pixels, "cpu_fallback")
            return engine2d_readback_with_identity(
                pixels, "device_readback", self.d_framebuffer, self.session.device
            )
