    me _draw_image_native(x: i32, y: i32, w: i32, h: i32, pixels: [u32]) -> i64:
        """Copy an exact-size image, clipped by the Vulkan target bounds."""
        self._draw_image_composite_native(x, y, w, h, w, h, pixels, 1000, VK_IMAGE_COMPOSITE_COPY, false)

    me _draw_image_scaled_native(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]) -> i64:
        """Nearest-neighbor scale and copy an image on the Vulkan device."""
        self._draw_image_composite_native(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels, 1000, VK_IMAGE_COMPOSITE_COPY, false)

    me _draw_image_scaled_blend_native(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]) -> i64:
        """Nearest-neighbor scale and src-over an image on the Vulkan device."""
        self._draw_image_composite_native(dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels, 1000, VK_IMAGE_COMPOSITE_SRC_OVER, false)

    me _draw_image_blend_native(x: i32, y: i32, w: i32, h: i32, pixels: [u32], opacity_milli: i32) -> i64:
        """Composite a clipped straight-ARGB image on the Vulkan device."""
        self._draw_image_composite_native(x, y, w, h, w, h, pixels, opacity_milli, VK_IMAGE_COMPOSITE_SRC_OVER, false)

    me draw_image_blend_checked(x: i32, y: i32, w: i32, h: i32, pixels: [u32], opacity_milli: i32) -> bool:
        """Composite only when fenced native Vulkan completion is proven."""
        if self.completion_unknown:
            return false
        val status = self._draw_image_blend_native(x, y, w, h, pixels, opacity_milli)
        if status == 1:
            return true
        self.mark_cpu_fallback("checked-image-blend-failed")
        if status < 0:
            self.completion_unknown = true
        false

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if self.completion_unknown: return
        val native_status = self._draw_image_native(x, y, w, h, pixels)
        if native_status > 0:
            return
        if native_status < 0:
            self.mark_cpu_fallback("image-copy-completion-unknown")
            self.completion_unknown = true
            return
        self.mark_cpu_fallback("image-copy-host-fallback")
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes = vulkan_sffi_read_buffer_bytes(self.d_framebuffer, fb_size, 0)
            vulkan_sffi_wait_idle()
            self.host_buf = _bytes_to_pixel_array(fb_bytes, self.w * self.h)

        val clip_end_x = self.clip_x + self.clip_w
        val clip_end_y = self.clip_y + self.clip_h
        val mask_active = self.mask_buf.len() > 0
        var py = 0
        while py < h:
            var px = 0
            while px < w:
                val dx = x + px
                val dy = y + py
                val src_idx = py * w + px
                var writable = dx >= 0 and dx < self.w and dy >= 0 and dy < self.h and src_idx < pixels.len()
                if writable and self.clip_enabled:
                    writable = dx >= self.clip_x and dx < clip_end_x and dy >= self.clip_y and dy < clip_end_y
                if writable and mask_active:
                    val mask_idx = dy * self.mask_w + dx
                    if mask_idx >= 0 and mask_idx < self.mask_buf.len():
                        writable = self.mask_buf[mask_idx] != 0u8
                if writable:
                    self.host_buf[dy * self.w + dx] = pixels[src_idx]
                px = px + 1
            py = py + 1
