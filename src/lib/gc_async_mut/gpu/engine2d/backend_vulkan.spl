#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# 2D Engine — Vulkan Backend (Compute Shader)
#
# Hardware-accelerated 2D rendering using Vulkan compute shaders. Each draw
# operation dispatches a compute shader operating on a storage buffer
# framebuffer. present() copies the GPU buffer back to host memory.
#
# Requires Vulkan runtime with compute shader support.
#
# Architecture:
#   - Framebuffer is a Vulkan storage buffer (usage 0x80)
#   - One GLSL compute shader per kernel type (clear, rect, circle, etc.)
#   - Shaders compiled at init() via rt_vulkan_compile_glsl()
#   - Push constants carry per-primitive parameters
#   - Each draw call: begin_compute -> bind_pipeline -> bind_descriptors ->
#     push_constants -> dispatch -> end_compute -> submit_and_wait
#
# Usage:
#   use std.gpu.engine2d.backend_vulkan.{VulkanBackend}

use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a}
use std.gpu.engine2d.glyph.{render_text_to_buffer}

# ============================================================================
# Vulkan FFI Declarations
# ============================================================================

extern fn rt_vulkan_init() -> bool
extern fn rt_vulkan_shutdown() -> bool
extern fn rt_vulkan_is_available() -> bool
extern fn rt_vulkan_device_count() -> i64
extern fn rt_vulkan_select_device(id: i64) -> bool
extern fn rt_vulkan_alloc_buffer(size: i64, usage: i64) -> i64
extern fn rt_vulkan_free_buffer(handle: i64) -> bool
extern fn rt_vulkan_copy_to_buffer(handle: i64, data: [u8], offset: i64) -> bool
extern fn rt_vulkan_copy_from_buffer(data: [u8], handle: i64, offset: i64) -> bool
extern fn rt_vulkan_compile_glsl(glsl_source: text) -> i64
extern fn rt_vulkan_destroy_shader(module: i64) -> bool
extern fn rt_vulkan_create_compute_pipeline(shader_module: i64, entry_point: text, push_constant_size: i64) -> i64
extern fn rt_vulkan_destroy_pipeline(pipe: i64) -> bool
extern fn rt_vulkan_create_descriptor_set(pipe: i64) -> i64
extern fn rt_vulkan_bind_buffer(descriptor_set: i64, binding: i64, buf: i64) -> bool
extern fn rt_vulkan_destroy_descriptor_set(descriptor_set: i64) -> bool
extern fn rt_vulkan_begin_compute() -> i64
extern fn rt_vulkan_bind_pipeline(cmd: i64, pipe: i64) -> bool
extern fn rt_vulkan_bind_descriptors(cmd: i64, descriptor_set: i64) -> bool
extern fn rt_vulkan_push_constants(cmd: i64, pipe: i64, data: [u8]) -> bool
extern fn rt_vulkan_dispatch(cmd: i64, x: i64, y: i64, z: i64) -> bool
extern fn rt_vulkan_end_compute(cmd: i64) -> bool
extern fn rt_vulkan_submit_and_wait(cmd: i64) -> bool
extern fn rt_vulkan_wait_idle() -> bool

# ============================================================================
# Vulkan Availability Check
# ============================================================================

fn vulkan_available() -> bool:
    """Check if Vulkan runtime is available on this system."""
    rt_vulkan_is_available()

# ============================================================================
# Push Constant Size (in bytes)
#
# All shaders use at most 64 bytes of push constants (16 x i32).
# This accommodates the largest kernel (triangle: 13 ints + padding).
# ============================================================================

val VK_PUSH_CONSTANT_SIZE: i64 = 64

# ============================================================================
# Vulkan Backend
# ============================================================================

class VulkanBackend:
    """Vulkan compute shader 2D renderer.

    Architecture:
    - Framebuffer lives in a Vulkan storage buffer (d_framebuffer)
    - Each draw call dispatches a compute shader
    - present() copies GPU storage buffer to host buffer
    - Host buffer is returned by read_pixels()

    Kernel dispatch: Each primitive (rect, circle, line) has a dedicated
    compute shader. Workgroup sizes are chosen to cover the bounding box
    of the primitive being drawn.
    """

    host_buf: [u32]
    w: i32
    h: i32
    d_framebuffer: i64          # Vulkan storage buffer handle
    # Shader module handles
    shader_clear: i64
    shader_rect_filled: i64
    shader_rect_outline: i64
    shader_circle_filled: i64
    shader_circle_outline: i64
    shader_line: i64
    shader_rounded_rect: i64
    shader_triangle: i64
    shader_gradient: i64
    shader_blit: i64
    # Pipeline handles
    pipe_clear: i64
    pipe_rect_filled: i64
    pipe_rect_outline: i64
    pipe_circle_filled: i64
    pipe_circle_outline: i64
    pipe_line: i64
    pipe_rounded_rect: i64
    pipe_triangle: i64
    pipe_gradient: i64
    pipe_blit: i64
    # Clipping state
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool
    dirty: bool                  # True when GPU has changes not yet copied to host

    static fn create() -> VulkanBackend:
        """Create an uninitialized Vulkan backend. Call init() before drawing."""
        VulkanBackend(
            host_buf: [],
            w: 0,
            h: 0,
            d_framebuffer: 0,
            shader_clear: 0,
            shader_rect_filled: 0,
            shader_rect_outline: 0,
            shader_circle_filled: 0,
            shader_circle_outline: 0,
            shader_line: 0,
            shader_rounded_rect: 0,
            shader_triangle: 0,
            shader_gradient: 0,
            shader_blit: 0,
            pipe_clear: 0,
            pipe_rect_filled: 0,
            pipe_rect_outline: 0,
            pipe_circle_filled: 0,
            pipe_circle_outline: 0,
            pipe_line: 0,
            pipe_rounded_rect: 0,
            pipe_triangle: 0,
            pipe_gradient: 0,
            pipe_blit: 0,
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false,
            dirty: false
        )

impl RenderBackend for VulkanBackend:

    fn name() -> text:
        "vulkan"

    fn init(width: i32, height: i32) -> bool:
        # Check Vulkan availability
        if not vulkan_available():
            return false

        if not rt_vulkan_init():
            return false

        if rt_vulkan_device_count() < 1:
            return false

        # Select first device
        if not rt_vulkan_select_device(0):
            return false

        self.w = width
        self.h = height

        # Allocate device framebuffer storage buffer (4 bytes per pixel = u32)
        # Usage 0x80 = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT
        val fb_size = _i64(width) * _i64(height) * 4
        self.d_framebuffer = rt_vulkan_alloc_buffer(fb_size, 0x80)
        if self.d_framebuffer == 0:
            return false

        # Allocate host buffer
        val total = width * height
        self.host_buf = [0u32; total]

        # Compile all GLSL compute shaders
        self.shader_clear = rt_vulkan_compile_glsl(_glsl_clear())
        self.shader_rect_filled = rt_vulkan_compile_glsl(_glsl_rect_filled())
        self.shader_rect_outline = rt_vulkan_compile_glsl(_glsl_rect_outline())
        self.shader_circle_filled = rt_vulkan_compile_glsl(_glsl_circle_filled())
        self.shader_circle_outline = rt_vulkan_compile_glsl(_glsl_circle_outline())
        self.shader_line = rt_vulkan_compile_glsl(_glsl_line())
        self.shader_rounded_rect = rt_vulkan_compile_glsl(_glsl_rounded_rect())
        self.shader_triangle = rt_vulkan_compile_glsl(_glsl_triangle_filled())
        self.shader_gradient = rt_vulkan_compile_glsl(_glsl_gradient_rect())
        self.shader_blit = rt_vulkan_compile_glsl(_glsl_blit())

        # Create compute pipelines (all use push constants)
        self.pipe_clear = rt_vulkan_create_compute_pipeline(self.shader_clear, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rect_filled = rt_vulkan_create_compute_pipeline(self.shader_rect_filled, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rect_outline = rt_vulkan_create_compute_pipeline(self.shader_rect_outline, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_circle_filled = rt_vulkan_create_compute_pipeline(self.shader_circle_filled, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_circle_outline = rt_vulkan_create_compute_pipeline(self.shader_circle_outline, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_line = rt_vulkan_create_compute_pipeline(self.shader_line, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_rounded_rect = rt_vulkan_create_compute_pipeline(self.shader_rounded_rect, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_triangle = rt_vulkan_create_compute_pipeline(self.shader_triangle, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_gradient = rt_vulkan_create_compute_pipeline(self.shader_gradient, "main", VK_PUSH_CONSTANT_SIZE)
        self.pipe_blit = rt_vulkan_create_compute_pipeline(self.shader_blit, "main", VK_PUSH_CONSTANT_SIZE)

        # Verify all pipelines were created
        if (self.pipe_clear == 0 or self.pipe_rect_filled == 0 or
            self.pipe_rect_outline == 0 or self.pipe_circle_filled == 0 or
            self.pipe_circle_outline == 0 or self.pipe_line == 0 or
            self.pipe_rounded_rect == 0 or self.pipe_triangle == 0 or
            self.pipe_gradient == 0 or self.pipe_blit == 0):
            self.shutdown()
            return false

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        self.dirty = false
        true

    fn shutdown():
        # Destroy pipelines
        if self.pipe_clear != 0: rt_vulkan_destroy_pipeline(self.pipe_clear)
        if self.pipe_rect_filled != 0: rt_vulkan_destroy_pipeline(self.pipe_rect_filled)
        if self.pipe_rect_outline != 0: rt_vulkan_destroy_pipeline(self.pipe_rect_outline)
        if self.pipe_circle_filled != 0: rt_vulkan_destroy_pipeline(self.pipe_circle_filled)
        if self.pipe_circle_outline != 0: rt_vulkan_destroy_pipeline(self.pipe_circle_outline)
        if self.pipe_line != 0: rt_vulkan_destroy_pipeline(self.pipe_line)
        if self.pipe_rounded_rect != 0: rt_vulkan_destroy_pipeline(self.pipe_rounded_rect)
        if self.pipe_triangle != 0: rt_vulkan_destroy_pipeline(self.pipe_triangle)
        if self.pipe_gradient != 0: rt_vulkan_destroy_pipeline(self.pipe_gradient)
        if self.pipe_blit != 0: rt_vulkan_destroy_pipeline(self.pipe_blit)
        # Destroy shader modules
        if self.shader_clear != 0: rt_vulkan_destroy_shader(self.shader_clear)
        if self.shader_rect_filled != 0: rt_vulkan_destroy_shader(self.shader_rect_filled)
        if self.shader_rect_outline != 0: rt_vulkan_destroy_shader(self.shader_rect_outline)
        if self.shader_circle_filled != 0: rt_vulkan_destroy_shader(self.shader_circle_filled)
        if self.shader_circle_outline != 0: rt_vulkan_destroy_shader(self.shader_circle_outline)
        if self.shader_line != 0: rt_vulkan_destroy_shader(self.shader_line)
        if self.shader_rounded_rect != 0: rt_vulkan_destroy_shader(self.shader_rounded_rect)
        if self.shader_triangle != 0: rt_vulkan_destroy_shader(self.shader_triangle)
        if self.shader_gradient != 0: rt_vulkan_destroy_shader(self.shader_gradient)
        if self.shader_blit != 0: rt_vulkan_destroy_shader(self.shader_blit)
        # Free framebuffer
        if self.d_framebuffer != 0:
            rt_vulkan_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0
        self.host_buf = []
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        val total = _i64(self.w) * _i64(self.h)
        val workgroups = (total + 255) / 256
        val pc = _pack_clear_pc(color, self.w, self.h)
        _dispatch_compute(self, self.pipe_clear, pc, workgroups, 1, 1)
        self.dirty = true

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val pc = _pack_rect_pc(x, y, w, h, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        _dispatch_compute(self, self.pipe_rect_outline, pc, gx, gy, 1)
        self.dirty = true

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val pc = _pack_rect_pc(x, y, w, h, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        _dispatch_compute(self, self.pipe_rect_filled, pc, gx, gy, 1)
        self.dirty = true

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        var dx = x2 - x1
        var dy = y2 - y1
        if dx < 0:
            dx = -dx
        if dy < 0:
            dy = -dy
        var line_len = dx
        if dy > dx:
            line_len = dy
        if line_len == 0:
            line_len = 1
        val workgroups = (_i64(line_len) + 255) / 256
        val pc = _pack_line_pc(x1, y1, x2, y2, color, thickness, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_line, pc, workgroups, 1, 1)
        self.dirty = true

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_circle_pc(cx, cy, r, color, self.w, self.h, 0, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_circle_outline, pc, gx, gy, 1)
        self.dirty = true

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val bw = 2 * r + 1
        val bh = 2 * r + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_circle_pc(cx, cy, r, color, self.w, self.h, 1, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_circle_filled, pc, gx, gy, 1)
        self.dirty = true

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        val pc = _pack_rounded_rect_pc(x, y, w, h, radius, color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_rounded_rect, pc, gx, gy, 1)
        self.dirty = true

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Compute bounding box of triangle
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3

        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        val gx = (_i64(bw) + 15) / 16
        val gy = (_i64(bh) + 15) / 16
        val pc = _pack_triangle_pc(x1, y1, x2, y2, x3, y3, color, self.w, self.h, min_x, min_y, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_triangle, pc, gx, gy, 1)
        self.dirty = true

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        val gx = (_i64(w) + 15) / 16
        val gy = (_i64(h) + 15) / 16
        val pc = _pack_gradient_pc(x, y, w, h, top_color, bottom_color, self.w, self.h, self.clip_x, self.clip_y, self.clip_w, self.clip_h, self.clip_enabled)
        _dispatch_compute(self, self.pipe_gradient, pc, gx, gy, 1)
        self.dirty = true

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Text rendering on GPU is complex; fall back to CPU-side rendering
        # then upload the affected region. For production, a glyph atlas
        # texture would be uploaded and sampled by a kernel.
        _gpu_draw_text_fallback(self, x, y, text_val, color, font_size)
        self.dirty = true

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Upload pixel data to a temporary Vulkan storage buffer, then
        # dispatch a blit compute shader to copy it into the framebuffer
        val pixel_count = _i64(w) * _i64(h)
        val byte_size = pixel_count * 4
        val d_src = rt_vulkan_alloc_buffer(byte_size, 0x80)
        if d_src != 0:
            # Upload source pixels to device buffer
            val src_bytes = _pixels_to_bytes(pixels, pixel_count)
            rt_vulkan_copy_to_buffer(d_src, src_bytes, 0)
            # Dispatch blit kernel
            val gx = (_i64(w) + 15) / 16
            val gy = (_i64(h) + 15) / 16
            val pc = _pack_blit_pc(x, y, w, h, self.w, self.h)
            _dispatch_blit_compute(self, self.pipe_blit, d_src, pc, gx, gy, 1)
            rt_vulkan_free_buffer(d_src)
        self.dirty = true

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me present():
        # Copy GPU storage buffer to host memory
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes: [u8] = [0u8; fb_size]
            rt_vulkan_copy_from_buffer(fb_bytes, self.d_framebuffer, 0)
            rt_vulkan_wait_idle()
            _bytes_to_pixels(fb_bytes, self.host_buf, self.w * self.h)
            self.dirty = false

    fn read_pixels() -> [u32]:
        # Ensure host buffer is up to date
        if self.dirty:
            val fb_size = _i64(self.w) * _i64(self.h) * 4
            val fb_bytes: [u8] = [0u8; fb_size]
            rt_vulkan_copy_from_buffer(fb_bytes, self.d_framebuffer, 0)
            rt_vulkan_wait_idle()
            _bytes_to_pixels(fb_bytes, self.host_buf, self.w * self.h)
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.host_buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

# ============================================================================
# Compute Dispatch Helper
# ============================================================================

fn _dispatch_compute(backend: VulkanBackend, pipe: i64, push_data: [u8], gx: i64, gy: i64, gz: i64):
    """Dispatch a compute shader with the framebuffer bound at binding 0."""
    val desc = rt_vulkan_create_descriptor_set(pipe)
    rt_vulkan_bind_buffer(desc, 0, backend.d_framebuffer)
    val cmd = rt_vulkan_begin_compute()
    rt_vulkan_bind_pipeline(cmd, pipe)
    rt_vulkan_bind_descriptors(cmd, desc)
    rt_vulkan_push_constants(cmd, pipe, push_data)
    rt_vulkan_dispatch(cmd, gx, gy, gz)
    rt_vulkan_end_compute(cmd)
    rt_vulkan_submit_and_wait(cmd)
    rt_vulkan_destroy_descriptor_set(desc)

fn _dispatch_blit_compute(backend: VulkanBackend, pipe: i64, d_src: i64, push_data: [u8], gx: i64, gy: i64, gz: i64):
    """Dispatch blit compute shader with framebuffer at binding 0 and source at binding 1."""
    val desc = rt_vulkan_create_descriptor_set(pipe)
    rt_vulkan_bind_buffer(desc, 0, backend.d_framebuffer)
    rt_vulkan_bind_buffer(desc, 1, d_src)
    val cmd = rt_vulkan_begin_compute()
    rt_vulkan_bind_pipeline(cmd, pipe)
    rt_vulkan_bind_descriptors(cmd, desc)
    rt_vulkan_push_constants(cmd, pipe, push_data)
    rt_vulkan_dispatch(cmd, gx, gy, gz)
    rt_vulkan_end_compute(cmd)
    rt_vulkan_submit_and_wait(cmd)
    rt_vulkan_destroy_descriptor_set(desc)

# ============================================================================
# Push Constant Packing
#
# Push constants are packed as [u8] arrays of i32 values in little-endian.
# Each kernel's push constant layout is documented in the GLSL source.
# ============================================================================

fn _pack_i32_le(buf: [u8], offset: i32, value: i32):
    """Pack an i32 into buf at byte offset in little-endian order."""
    val v = _i32_to_u32(value)
    buf[offset] = _u32_to_u8(v & 0xFF)
    buf[offset + 1] = _u32_to_u8((v >> 8) & 0xFF)
    buf[offset + 2] = _u32_to_u8((v >> 16) & 0xFF)
    buf[offset + 3] = _u32_to_u8((v >> 24) & 0xFF)

fn _pack_u32_le(buf: [u8], offset: i32, value: u32):
    """Pack a u32 into buf at byte offset in little-endian order."""
    buf[offset] = _u32_to_u8(value & 0xFF)
    buf[offset + 1] = _u32_to_u8((value >> 8) & 0xFF)
    buf[offset + 2] = _u32_to_u8((value >> 16) & 0xFF)
    buf[offset + 3] = _u32_to_u8((value >> 24) & 0xFF)

fn _pack_clear_pc(color: u32, fb_w: i32, fb_h: i32) -> [u8]:
    """Push constants for clear kernel: color, fb_w, fb_h."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_u32_le(buf, 0, color)
    _pack_i32_le(buf, 4, fb_w)
    _pack_i32_le(buf, 8, fb_h)
    buf

fn _pack_rect_pc(x: i32, y: i32, w: i32, h: i32, color: u32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for rect kernels."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x)
    _pack_i32_le(buf, 4, y)
    _pack_i32_le(buf, 8, w)
    _pack_i32_le(buf, 12, h)
    _pack_u32_le(buf, 16, color)
    _pack_i32_le(buf, 20, fb_w)
    _pack_i32_le(buf, 24, fb_h)
    _pack_i32_le(buf, 28, clip_x)
    _pack_i32_le(buf, 32, clip_y)
    _pack_i32_le(buf, 36, clip_w)
    _pack_i32_le(buf, 40, clip_h)
    _pack_i32_le(buf, 44, _bool_to_i32(clip_enabled))
    buf

fn _pack_line_pc(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, fb_w: i32, fb_h: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for line kernel."""
    var buf: [u8] = [0u8; VK_PUSH_CONSTANT_SIZE]
    _pack_i32_le(buf, 0, x1)
    _pack_i32_le(buf, 4, y1)
    _pack_i32_le(buf, 8, x2)
    _pack_i32_le(buf, 12, y2)
    _pack_u32_le(buf, 16, color)
    _pack_i32_le(buf, 20, thickness)
    _pack_i32_le(buf, 24, fb_w)
    _pack_i32_le(buf, 28, fb_h)
    _pack_i32_le(buf, 32, clip_x)
    _pack_i32_le(buf, 36, clip_y)
    _pack_i32_le(buf, 40, clip_w)
    _pack_i32_le(buf, 44, clip_h)
    _pack_i32_le(buf, 48, _bool_to_i32(clip_enabled))
    buf

fn _pack_circle_pc(cx: i32, cy: i32, r: i32, color: u32, fb_w: i32, fb_h: i32, filled: i32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, clip_enabled: bool) -> [u8]:
    """Push constants for circle kernels."""
