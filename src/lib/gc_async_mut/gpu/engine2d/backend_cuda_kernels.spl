fn cuda_2d_generated_fill_ptx_source() -> text:
    "\n.visible .entry simple_2d_fill_u32(\n    .param .u64 param_fb,\n    .param .u64 param_width,\n    .param .u64 param_height,\n    .param .u32 param_color\n) {\n    .reg .u64  %rd<7>;\n    .reg .u32  %r<8>;\n    .reg .pred %p0;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u64  %rd0, [param_width];\n    ld.param.u64  %rd1, [param_height];\n    cvt.u32.u64   %r4, %rd0;\n    cvt.u32.u64   %r5, %rd1;\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_simple_fill;\n    ld.param.u64  %rd2, [param_fb];\n    mul.wide.u32  %rd3, %r3, 4;\n    add.u64       %rd4, %rd2, %rd3;\n    ld.param.u32  %r7, [param_color];\n    st.global.u32 [%rd4], %r7;\ndone_simple_fill:\n    ret;\n}\n"

fn cuda_2d_base_ptx_source() -> text:
    ".version 7.0\n.target sm_52\n.address_size 64\n\n.visible .entry kernel_clear(\n    .param .u64 param_fb,\n    .param .u32 param_color,\n    .param .u32 param_count\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<6>;\n    .reg .pred %p0;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_count];\n    setp.ge.u32   %p0, %r3, %r4;\n    @%p0 bra done_clear;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r3, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r5, [param_color];\n    st.global.u32 [%rd2], %r5;\ndone_clear:\n    ret;\n}\n\n.visible .entry kernel_draw_rect_filled(\n    .param .u64 param_fb,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<18>;\n    .reg .pred %p0;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_w];\n    ld.param.u32  %r5, [param_h];\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_rect;\n    div.u32  %r7, %r3, %r4;\n    rem.u32  %r8, %r3, %r4;\n    ld.param.u32  %r9,  [param_x];\n    ld.param.u32  %r10, [param_y];\n    add.u32  %r11, %r9,  %r8;\n    add.u32  %r12, %r10, %r7;\n    ld.param.u32  %r13, [param_stride];\n    ld.param.u32  %r14, [param_surface_h];\n    setp.ge.u32   %p0, %r11, %r13;\n    @%p0 bra done_rect;\n    setp.ge.u32   %p0, %r12, %r14;\n    @%p0 bra done_rect;\n    mad.lo.u32    %r15, %r12, %r13, %r11;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r15, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r16, [param_color];\n    st.global.u32 [%rd2], %r16;\ndone_rect:\n    ret;\n}\n\n.visible .entry kernel_draw_rect_outline(\n    .param .u64 param_fb,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<20>;\n    .reg .pred %p<7>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_w];\n    ld.param.u32  %r5, [param_h];\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_outline;\n    div.u32  %r7, %r3, %r4;\n    rem.u32  %r8, %r3, %r4;\n    setp.eq.u32   %p1, %r8, 0;\n    setp.eq.u32   %p2, %r7, 0;\n    sub.u32       %r17, %r4, 1;\n    setp.eq.u32   %p3, %r8, %r17;\n    sub.u32       %r18, %r5, 1;\n    setp.eq.u32   %p4, %r7, %r18;\n    or.pred       %p5, %p1, %p2;\n    or.pred       %p5, %p5, %p3;\n    or.pred       %p5, %p5, %p4;\n    @!%p5 bra done_outline;\n    ld.param.u32  %r9,  [param_x];\n    ld.param.u32  %r10, [param_y];\n    add.u32  %r11, %r9,  %r8;\n    add.u32  %r12, %r10, %r7;\n    ld.param.u32  %r13, [param_stride];\n    ld.param.u32  %r14, [param_surface_h];\n    setp.ge.u32   %p0, %r11, %r13;\n    @%p0 bra done_outline;\n    setp.ge.u32   %p0, %r12, %r14;\n    @%p0 bra done_outline;\n    mad.lo.u32    %r15, %r12, %r13, %r11;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r15, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r16, [param_color];\n    st.global.u32 [%rd2], %r16;\ndone_outline:\n    ret;\n}\n\n.visible .entry kernel_draw_image(\n    .param .u64 param_fb,\n    .param .u64 param_src,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<6>;\n    .reg .u32  %r<20>;\n    .reg .pred %p0;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_w];\n    ld.param.u32  %r5, [param_h];\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_image;\n    div.u32  %r7, %r3, %r4;\n    rem.u32  %r8, %r3, %r4;\n    ld.param.u32  %r9,  [param_x];\n    ld.param.u32  %r10, [param_y];\n    add.u32  %r11, %r9,  %r8;\n    add.u32  %r12, %r10, %r7;\n    ld.param.u32  %r13, [param_stride];\n    ld.param.u32  %r14, [param_surface_h];\n    setp.ge.u32   %p0, %r11, %r13;\n    @%p0 bra done_image;\n    setp.ge.u32   %p0, %r12, %r14;\n    @%p0 bra done_image;\n    ld.param.u64  %rd0, [param_src];\n    mul.wide.u32  %rd1, %r3, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.global.u32 %r15, [%rd2];\n    mad.lo.u32    %r16, %r12, %r13, %r11;\n    ld.param.u64  %rd3, [param_fb];\n    mul.wide.u32  %rd4, %r16, 4;\n    add.u64       %rd5, %rd3, %rd4;\n    st.global.u32 [%rd5], %r15;\ndone_image:\n    ret;\n}\n"

fn cuda_2d_gradient_ptx_source() -> text:
    "\n.visible .entry kernel_draw_gradient_rect(\n    .param .u64 param_fb,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_top_color,\n    .param .u32 param_bottom_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<40>;\n    .reg .s32  %s<16>;\n    .reg .pred %p<2>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_w];\n    ld.param.u32  %r5, [param_h];\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_gradient;\n    div.u32  %r7, %r3, %r4;\n    rem.u32  %r8, %r3, %r4;\n    ld.param.u32  %r9,  [param_x];\n    ld.param.u32  %r10, [param_y];\n    add.u32  %r11, %r9,  %r8;\n    add.u32  %r12, %r10, %r7;\n    ld.param.u32  %r13, [param_stride];\n    ld.param.u32  %r14, [param_surface_h];\n    setp.ge.u32   %p0, %r11, %r13;\n    @%p0 bra done_gradient;\n    setp.ge.u32   %p0, %r12, %r14;\n    @%p0 bra done_gradient;\n    ld.param.u32  %r15, [param_top_color];\n    ld.param.u32  %r16, [param_bottom_color];\n    sub.u32       %r17, %r5, 1;\n    setp.eq.u32   %p1, %r17, 0;\n    @%p1 bra use_top_gradient;\n    shr.u32       %r18, %r15, 16;\n    and.b32       %r18, %r18, 255;\n    shr.u32       %r19, %r15, 8;\n    and.b32       %r19, %r19, 255;\n    and.b32       %r20, %r15, 255;\n    shr.u32       %r21, %r15, 24;\n    and.b32       %r21, %r21, 255;\n    shr.u32       %r22, %r16, 16;\n    and.b32       %r22, %r22, 255;\n    shr.u32       %r23, %r16, 8;\n    and.b32       %r23, %r23, 255;\n    and.b32       %r24, %r16, 255;\n    shr.u32       %r25, %r16, 24;\n    and.b32       %r25, %r25, 255;\n    cvt.s32.u32   %s0, %r18;\n    cvt.s32.u32   %s1, %r19;\n    cvt.s32.u32   %s2, %r20;\n    cvt.s32.u32   %s3, %r21;\n    cvt.s32.u32   %s4, %r22;\n    cvt.s32.u32   %s5, %r23;\n    cvt.s32.u32   %s6, %r24;\n    cvt.s32.u32   %s7, %r25;\n    cvt.s32.u32   %s8, %r7;\n    cvt.s32.u32   %s9, %r17;\n    sub.s32       %s10, %s4, %s0;\n    mul.lo.s32    %s10, %s10, %s8;\n    div.s32       %s10, %s10, %s9;\n    add.s32       %s10, %s10, %s0;\n    sub.s32       %s11, %s5, %s1;\n    mul.lo.s32    %s11, %s11, %s8;\n    div.s32       %s11, %s11, %s9;\n    add.s32       %s11, %s11, %s1;\n    sub.s32       %s12, %s6, %s2;\n    mul.lo.s32    %s12, %s12, %s8;\n    div.s32       %s12, %s12, %s9;\n    add.s32       %s12, %s12, %s2;\n    sub.s32       %s13, %s7, %s3;\n    mul.lo.s32    %s13, %s13, %s8;\n    div.s32       %s13, %s13, %s9;\n    add.s32       %s13, %s13, %s3;\n    cvt.u32.s32   %r26, %s10;\n    cvt.u32.s32   %r27, %s11;\n    cvt.u32.s32   %r28, %s12;\n    cvt.u32.s32   %r29, %s13;\n    shl.b32       %r29, %r29, 24;\n    shl.b32       %r26, %r26, 16;\n    shl.b32       %r27, %r27, 8;\n    or.b32        %r30, %r29, %r26;\n    or.b32        %r30, %r30, %r27;\n    or.b32        %r30, %r30, %r28;\n    bra store_gradient;\nuse_top_gradient:\n    mov.u32       %r30, %r15;\nstore_gradient:\n    mad.lo.u32    %r31, %r12, %r13, %r11;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r31, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    st.global.u32 [%rd2], %r30;\ndone_gradient:\n    ret;\n}\n"

fn cuda_2d_line_ptx_source() -> text:
    "\n.visible .entry kernel_draw_line(\n    .param .u64 param_fb,\n    .param .u32 param_x1,\n    .param .u32 param_y1,\n    .param .u32 param_x2,\n    .param .u32 param_y2,\n    .param .u32 param_color,\n    .param .u32 param_thickness,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<9>;\n    .reg .s32  %s<18>;\n    .reg .pred %p<8>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    cvt.s32.u32 %s0, %r3;\n    ld.param.u32  %r4, [param_x1];\n    ld.param.u32  %r5, [param_y1];\n    ld.param.u32  %r6, [param_x2];\n    ld.param.u32  %r7, [param_y2];\n    cvt.s32.u32 %s1, %r4;\n    cvt.s32.u32 %s2, %r5;\n    cvt.s32.u32 %s3, %r6;\n    cvt.s32.u32 %s4, %r7;\n    sub.s32     %s5, %s3, %s1;\n    sub.s32     %s6, %s4, %s2;\n    abs.s32     %s7, %s5;\n    abs.s32     %s8, %s6;\n    max.s32     %s9, %s7, %s8;\n    setp.eq.s32 %p0, %s9, 0;\n    @%p0 mov.s32 %s9, 1;\n    setp.gt.s32 %p1, %s0, %s9;\n    @%p1 bra done_line;\n    mul.lo.s32  %s10, %s5, %s0;\n    div.s32     %s10, %s10, %s9;\n    add.s32     %s11, %s1, %s10;\n    mul.lo.s32  %s12, %s6, %s0;\n    div.s32     %s12, %s12, %s9;\n    add.s32     %s13, %s2, %s12;\n    ld.param.u32 %r8, [param_stride];\n    cvt.s32.u32 %s14, %r8;\n    ld.param.u32 %r4, [param_surface_h];\n    cvt.s32.u32 %s15, %r4;\n    setp.lt.s32 %p2, %s11, 0;\n    @%p2 bra done_line;\n    setp.lt.s32 %p3, %s13, 0;\n    @%p3 bra done_line;\n    setp.ge.s32 %p4, %s11, %s14;\n    @%p4 bra done_line;\n    setp.ge.s32 %p5, %s13, %s15;\n    @%p5 bra done_line;\n    mad.lo.s32  %s16, %s13, %s14, %s11;\n    cvt.u32.s32 %r5, %s16;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r5, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r6, [param_color];\n    st.global.u32 [%rd2], %r6;\ndone_line:\n    ret;\n}\n"

fn cuda_2d_circle_ptx_source() -> text:
    "\n.visible .entry kernel_draw_circle(\n    .param .u64 param_fb,\n    .param .u32 param_cx,\n    .param .u32 param_cy,\n    .param .u32 param_r,\n    .param .u32 param_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h,\n    .param .u32 param_filled\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<10>;\n    .reg .s32  %s<24>;\n    .reg .pred %p<10>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    cvt.s32.u32 %s0, %r3;\n    ld.param.u32 %r4, [param_cx];\n    ld.param.u32 %r5, [param_cy];\n    ld.param.u32 %r6, [param_r];\n    cvt.s32.u32 %s1, %r4;\n    cvt.s32.u32 %s2, %r5;\n    cvt.s32.u32 %s3, %r6;\n    add.s32     %s4, %s3, %s3;\n    add.s32     %s4, %s4, 1;\n    mul.lo.s32  %s5, %s4, %s4;\n    setp.ge.s32 %p0, %s0, %s5;\n    @%p0 bra done_circle;\n    rem.s32     %s6, %s0, %s4;\n    div.s32     %s7, %s0, %s4;\n    sub.s32     %s8, %s6, %s3;\n    sub.s32     %s9, %s7, %s3;\n    add.s32     %s10, %s1, %s8;\n    add.s32     %s11, %s2, %s9;\n    mul.lo.s32  %s12, %s8, %s8;\n    mul.lo.s32  %s13, %s9, %s9;\n    add.s32     %s14, %s12, %s13;\n    mul.lo.s32  %s15, %s3, %s3;\n    setp.gt.s32 %p1, %s14, %s15;\n    @%p1 bra done_circle;\n    sub.s32     %s16, %s3, 1;\n    mul.lo.s32  %s17, %s16, %s16;\n    setp.lt.s32 %p2, %s14, %s17;\n    @%p2 bra done_circle;\n    ld.param.u32 %r7, [param_stride];\n    cvt.s32.u32 %s18, %r7;\n    ld.param.u32 %r8, [param_surface_h];\n    cvt.s32.u32 %s19, %r8;\n    setp.lt.s32 %p3, %s10, 0;\n    @%p3 bra done_circle;\n    setp.lt.s32 %p4, %s11, 0;\n    @%p4 bra done_circle;\n    setp.ge.s32 %p5, %s10, %s18;\n    @%p5 bra done_circle;\n    setp.ge.s32 %p6, %s11, %s19;\n    @%p6 bra done_circle;\n    mad.lo.s32  %s20, %s11, %s18, %s10;\n    cvt.u32.s32 %r9, %s20;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r9, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r4, [param_color];\n    st.global.u32 [%rd2], %r4;\ndone_circle:\n    ret;\n}\n\n.visible .entry kernel_draw_circle_filled(\n    .param .u64 param_fb,\n    .param .u32 param_cx,\n    .param .u32 param_cy,\n    .param .u32 param_r,\n    .param .u32 param_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h,\n    .param .u32 param_filled\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<10>;\n    .reg .s32  %s<22>;\n    .reg .pred %p<8>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    cvt.s32.u32 %s0, %r3;\n    ld.param.u32 %r4, [param_cx];\n    ld.param.u32 %r5, [param_cy];\n    ld.param.u32 %r6, [param_r];\n    cvt.s32.u32 %s1, %r4;\n    cvt.s32.u32 %s2, %r5;\n    cvt.s32.u32 %s3, %r6;\n    add.s32     %s4, %s3, %s3;\n    add.s32     %s4, %s4, 1;\n    mul.lo.s32  %s5, %s4, %s4;\n    setp.ge.s32 %p0, %s0, %s5;\n    @%p0 bra done_circle_filled;\n    rem.s32     %s6, %s0, %s4;\n    div.s32     %s7, %s0, %s4;\n    sub.s32     %s8, %s6, %s3;\n    sub.s32     %s9, %s7, %s3;\n    add.s32     %s10, %s1, %s8;\n    add.s32     %s11, %s2, %s9;\n    mul.lo.s32  %s12, %s8, %s8;\n    mul.lo.s32  %s13, %s9, %s9;\n    add.s32     %s14, %s12, %s13;\n    mul.lo.s32  %s15, %s3, %s3;\n    setp.gt.s32 %p1, %s14, %s15;\n    @%p1 bra done_circle_filled;\n    ld.param.u32 %r7, [param_stride];\n    cvt.s32.u32 %s16, %r7;\n    ld.param.u32 %r8, [param_surface_h];\n    cvt.s32.u32 %s17, %r8;\n    setp.lt.s32 %p2, %s10, 0;\n    @%p2 bra done_circle_filled;\n    setp.lt.s32 %p3, %s11, 0;\n    @%p3 bra done_circle_filled;\n    setp.ge.s32 %p4, %s10, %s16;\n    @%p4 bra done_circle_filled;\n    setp.ge.s32 %p5, %s11, %s17;\n    @%p5 bra done_circle_filled;\n    mad.lo.s32  %s18, %s11, %s16, %s10;\n    cvt.u32.s32 %r9, %s18;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r9, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r4, [param_color];\n    st.global.u32 [%rd2], %r4;\ndone_circle_filled:\n    ret;\n}\n"

fn cuda_2d_rounded_rect_ptx_source() -> text:
    "\n.visible .entry kernel_draw_rounded_rect(\n    .param .u64 param_fb,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_radius,\n    .param .u32 param_color,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<3>;\n    .reg .u32  %r<12>;\n    .reg .s32  %s<32>;\n    .reg .pred %p<18>;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    cvt.s32.u32 %s0, %r3;\n    ld.param.u32 %r4, [param_w];\n    ld.param.u32 %r5, [param_h];\n    cvt.s32.u32 %s1, %r4;\n    cvt.s32.u32 %s2, %r5;\n    mul.lo.s32  %s3, %s1, %s2;\n    setp.ge.s32 %p0, %s0, %s3;\n    @%p0 bra done_rounded_rect;\n    rem.s32     %s4, %s0, %s1;\n    div.s32     %s5, %s0, %s1;\n    ld.param.u32 %r6, [param_x];\n    ld.param.u32 %r7, [param_y];\n    cvt.s32.u32 %s6, %r6;\n    cvt.s32.u32 %s7, %r7;\n    add.s32     %s8, %s6, %s4;\n    add.s32     %s9, %s7, %s5;\n    ld.param.u32 %r8, [param_radius];\n    cvt.s32.u32 %s10, %r8;\n    setp.le.s32 %p1, %s10, 0;\n    @%p1 bra rounded_rect_bounds;\n    setp.lt.s32 %p2, %s4, %s10;\n    setp.lt.s32 %p3, %s5, %s10;\n    and.pred    %p4, %p2, %p3;\n    @%p4 bra rounded_rect_top_left;\n    sub.s32     %s11, %s1, %s10;\n    setp.ge.s32 %p5, %s4, %s11;\n    and.pred    %p6, %p5, %p3;\n    @%p6 bra rounded_rect_top_right;\n    sub.s32     %s12, %s2, %s10;\n    setp.ge.s32 %p7, %s5, %s12;\n    and.pred    %p8, %p2, %p7;\n    @%p8 bra rounded_rect_bottom_left;\n    and.pred    %p9, %p5, %p7;\n    @%p9 bra rounded_rect_bottom_right;\n    bra rounded_rect_bounds;\nrounded_rect_top_left:\n    sub.s32     %s13, %s4, %s10;\n    sub.s32     %s14, %s5, %s10;\n    bra rounded_rect_corner_check;\nrounded_rect_top_right:\n    sub.s32     %s15, %s1, 1;\n    sub.s32     %s15, %s15, %s10;\n    sub.s32     %s13, %s4, %s15;\n    sub.s32     %s14, %s5, %s10;\n    bra rounded_rect_corner_check;\nrounded_rect_bottom_left:\n    sub.s32     %s16, %s2, 1;\n    sub.s32     %s16, %s16, %s10;\n    sub.s32     %s13, %s4, %s10;\n    sub.s32     %s14, %s5, %s16;\n    bra rounded_rect_corner_check;\nrounded_rect_bottom_right:\n    sub.s32     %s15, %s1, 1;\n    sub.s32     %s15, %s15, %s10;\n    sub.s32     %s16, %s2, 1;\n    sub.s32     %s16, %s16, %s10;\n    sub.s32     %s13, %s4, %s15;\n    sub.s32     %s14, %s5, %s16;\nrounded_rect_corner_check:\n    mul.lo.s32  %s17, %s13, %s13;\n    mul.lo.s32  %s18, %s14, %s14;\n    add.s32     %s19, %s17, %s18;\n    mul.lo.s32  %s20, %s10, %s10;\n    setp.gt.s32 %p10, %s19, %s20;\n    @%p10 bra done_rounded_rect;\nrounded_rect_bounds:\n    ld.param.u32 %r9, [param_stride];\n    cvt.s32.u32 %s21, %r9;\n    ld.param.u32 %r10, [param_surface_h];\n    cvt.s32.u32 %s22, %r10;\n    setp.lt.s32 %p11, %s8, 0;\n    @%p11 bra done_rounded_rect;\n    setp.lt.s32 %p12, %s9, 0;\n    @%p12 bra done_rounded_rect;\n    setp.ge.s32 %p13, %s8, %s21;\n    @%p13 bra done_rounded_rect;\n    setp.ge.s32 %p14, %s9, %s22;\n    @%p14 bra done_rounded_rect;\n    mad.lo.s32  %s23, %s9, %s21, %s8;\n    cvt.u32.s32 %r11, %s23;\n    ld.param.u64  %rd0, [param_fb];\n    mul.wide.u32  %rd1, %r11, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.param.u32  %r4, [param_color];\n    st.global.u32 [%rd2], %r4;\ndone_rounded_rect:\n    ret;\n}\n"

fn cuda_2d_image_nonzero_ptx_source() -> text:
    "\n.visible .entry kernel_draw_image_nonzero(\n    .param .u64 param_fb,\n    .param .u64 param_src,\n    .param .u32 param_x,\n    .param .u32 param_y,\n    .param .u32 param_w,\n    .param .u32 param_h,\n    .param .u32 param_stride,\n    .param .u32 param_surface_h\n) {\n    .reg .u64  %rd<6>;\n    .reg .u32  %r<20>;\n    .reg .pred %p0;\n    mov.u32     %r0, %ctaid.x;\n    mov.u32     %r1, %ntid.x;\n    mov.u32     %r2, %tid.x;\n    mad.lo.u32  %r3, %r0, %r1, %r2;\n    ld.param.u32  %r4, [param_w];\n    ld.param.u32  %r5, [param_h];\n    mul.lo.u32    %r6, %r4, %r5;\n    setp.ge.u32   %p0, %r3, %r6;\n    @%p0 bra done_image_nonzero;\n    div.u32  %r7, %r3, %r4;\n    rem.u32  %r8, %r3, %r4;\n    ld.param.u32  %r9,  [param_x];\n    ld.param.u32  %r10, [param_y];\n    add.u32  %r11, %r9,  %r8;\n    add.u32  %r12, %r10, %r7;\n    ld.param.u32  %r13, [param_stride];\n    ld.param.u32  %r14, [param_surface_h];\n    setp.ge.u32   %p0, %r11, %r13;\n    @%p0 bra done_image_nonzero;\n    setp.ge.u32   %p0, %r12, %r14;\n    @%p0 bra done_image_nonzero;\n    ld.param.u64  %rd0, [param_src];\n    mul.wide.u32  %rd1, %r3, 4;\n    add.u64       %rd2, %rd0, %rd1;\n    ld.global.u32 %r15, [%rd2];\n    setp.eq.u32   %p0, %r15, 0;\n    @%p0 bra done_image_nonzero;\n    mad.lo.u32    %r16, %r12, %r13, %r11;\n    ld.param.u64  %rd3, [param_fb];\n    mul.wide.u32  %rd4, %r16, 4;\n    add.u64       %rd5, %rd3, %rd4;\n    st.global.u32 [%rd5], %r15;\ndone_image_nonzero:\n    ret;\n}\n"

