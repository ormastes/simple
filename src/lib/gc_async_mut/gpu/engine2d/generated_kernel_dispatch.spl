# Engine2D generated 2D kernel dispatch metadata.
#
# This module is the stdlib-side bridge for compiler-emitted portable 2D
# kernels. It intentionally stores names and artifact formats only, avoiding a
# dependency from std.gpu back into compiler.backend.

use std.gpu.engine2d.rendering_opt_provider.{RenderingOptProvider}

val GENERATED_2D_FILL: text = "fill"
val GENERATED_2D_COPY: text = "copy"
val GENERATED_2D_ALPHA: text = "alpha_blend"
val GENERATED_2D_SCROLL: text = "scroll"
val GENERATED_2D_BITMAP_GLYPH_RASTER: text = "bitmap_glyph_raster"

class Generated2DKernelLaunchPlan:
    backend_name: text
    compute_target: text
    operation: text
    entry_name: text
    artifact_name: text
    required_entries: text
    binary_format: text
    compile_tool: text
    launch_api: text
    grid_x: i64
    grid_y: i64
    grid_z: i64
    block_x: i64
    block_y: i64
    block_z: i64
    args_layout: text
    dispatch_ready: bool
    reason: text

    static fn unavailable(backend: text, op: text, reason: text) -> Generated2DKernelLaunchPlan:
        Generated2DKernelLaunchPlan(
            backend_name: backend,
            compute_target: "unsupported",
            operation: op,
            entry_name: "",
            artifact_name: "",
            required_entries: "",
            binary_format: "none",
            compile_tool: "none",
            launch_api: "none",
            grid_x: 0,
            grid_y: 0,
            grid_z: 0,
            block_x: 0,
            block_y: 0,
            block_z: 0,
            args_layout: "",
            dispatch_ready: false,
            reason: reason
        )

    fn summary() -> text:
        "Generated2DKernelLaunchPlan[backend={self.backend_name} target={self.compute_target} op={self.operation} entry={self.entry_name} artifact={self.artifact_name} required={self.required_entries} launch={self.launch_api} grid={self.grid_x}x{self.grid_y}x{self.grid_z} block={self.block_x}x{self.block_y}x{self.block_z} ready={self.dispatch_ready.to_text()} reason={self.reason}]"

class Generated2DKernelExecutionRequest:
    plan: Generated2DKernelLaunchPlan
    module_or_queue_handle: i64
    kernel_or_pipeline_handle: i64
    args_ptr: i64
    shared_mem: i64
    handle_kind: text
    can_submit: bool
    reason: text

    static fn create(plan: Generated2DKernelLaunchPlan, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, args_ptr: i64, shared_mem: i64) -> Generated2DKernelExecutionRequest:
        val handle_kind = _execution_handle_kind(plan)
        val reason = _execution_request_reason(plan, module_or_queue_handle, kernel_or_pipeline_handle, args_ptr)
        Generated2DKernelExecutionRequest(
            plan: plan,
            module_or_queue_handle: module_or_queue_handle,
            kernel_or_pipeline_handle: kernel_or_pipeline_handle,
            args_ptr: args_ptr,
            shared_mem: shared_mem,
            handle_kind: handle_kind,
            can_submit: reason == "ready",
            reason: reason
        )

    fn call_shape() -> text:
        if not self.can_submit:
            return "none"
        if self.plan.compute_target == "cuda":
            return "cuda_launch_api"
        if self.plan.compute_target == "hip":
            return "hip_launch_api"
        if self.plan.compute_target == "opencl":
            return "opencl_ndrange_api"
        if self.plan.compute_target == "metal":
            return "metal_compute_api"
        "none"

    fn summary() -> text:
        "Generated2DKernelExecutionRequest[backend={self.plan.backend_name} op={self.plan.operation} handle={self.handle_kind} call={self.call_shape()} submit={self.can_submit.to_text()} reason={self.reason}]"

class Generated2DSessionLaunchGate:
    """Shared generated-kernel preflight for concrete CUDA/HIP/OpenCL sessions."""
    plan: Generated2DKernelLaunchPlan
    runtime_ready: bool
    module_ready: bool
    args_ptr: i64
    ready: bool
    status_code: text
    reason: text

    static fn create(plan: Generated2DKernelLaunchPlan, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DSessionLaunchGate:
        val reason = _session_launch_gate_reason(plan, runtime_ready, module_ready, args_ptr)
        Generated2DSessionLaunchGate(
            plan: plan,
            runtime_ready: runtime_ready,
            module_ready: module_ready,
            args_ptr: args_ptr,
            ready: reason == "ready",
            status_code: if reason == "ready": "ready" else: "not-ready",
            reason: reason
        )

    fn summary() -> text:
        "Generated2DSessionLaunchGate[backend={self.plan.backend_name} op={self.plan.operation} runtime={self.runtime_ready.to_text()} module={self.module_ready.to_text()} args={self.args_ptr} ready={self.ready.to_text()} reason={self.reason}]"

class Generated2DSessionRuntimeProvenance:
    """Shared runtime provenance for CUDA/HIP/OpenCL generated Engine2D sessions."""
    gate: Generated2DSessionLaunchGate
    backend_name: text
    compute_target: text
    operation: text
    width: i64
    height: i64
    launch_api: text
    entry_name: text
    artifact_name: text
    typed_status: text
    ready: bool
    reason: text

    static fn create(backend: text, op: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DSessionRuntimeProvenance:
        val gate = generated_2d_session_launch_gate(backend, op, width, height, runtime_ready, module_ready, args_ptr)
        val typed_status = _session_runtime_provenance_status(gate)
        Generated2DSessionRuntimeProvenance(
            gate: gate,
            backend_name: gate.plan.backend_name,
            compute_target: gate.plan.compute_target,
            operation: gate.plan.operation,
            width: width,
            height: height,
            launch_api: gate.plan.launch_api,
            entry_name: gate.plan.entry_name,
            artifact_name: gate.plan.artifact_name,
            typed_status: typed_status,
            ready: gate.ready,
            reason: gate.reason
        )

    fn diagnostic_text() -> text:
        "Generated2DSessionRuntimeProvenance[backend={self.backend_name} target={self.compute_target} op={self.operation} size={self.width}x{self.height} launch={self.launch_api} entry={self.entry_name} artifact={self.artifact_name} runtime={self.gate.runtime_ready.to_text()} module={self.gate.module_ready.to_text()} args={self.gate.args_ptr} ready={self.ready.to_text()} status={self.typed_status} reason={self.reason}]"

    fn summary() -> text:
        self.diagnostic_text()

class Generated2DOperationProvenance:
    """Comparable CPU/CUDA/OpenCL operation evidence for renderer measurements."""
    backend_name: text
    operation_family: text
    generated_operation: text
    width: i64
    height: i64
    compute_target: text
    execution_path: text
    launch_api: text
    entry_name: text
    artifact_name: text
    runtime_ready: bool
    module_ready: bool
    args_ready: bool
    ready: bool
    generated_artifact_required: bool
    cpu_preprocess_required: bool
    typed_status: text
    reason: text

    static fn create(backend: text, operation_family: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DOperationProvenance:
        val op = _operation_family_generated_op(operation_family)
        if op == "":
            return Generated2DOperationProvenance.unavailable(backend, operation_family, width, height, "unsupported-operation-family")
        if width <= 0 or height <= 0:
            return Generated2DOperationProvenance.unavailable(backend, operation_family, width, height, "invalid-dimensions")
        if _is_cpu_operation_backend(backend):
            val target = _cpu_operation_target(backend)
            val status = if target == "cpu_simd": "cpu-simd-baseline-ready" else: "cpu-scalar-baseline-ready"
            return Generated2DOperationProvenance(
                backend_name: backend,
                operation_family: operation_family,
                generated_operation: op,
                width: width,
                height: height,
                compute_target: target,
                execution_path: "engine2d-" + target,
                launch_api: "RenderBackend",
                entry_name: _cpu_operation_entry(operation_family),
                artifact_name: "",
                runtime_ready: true,
                module_ready: true,
                args_ready: true,
                ready: true,
                generated_artifact_required: false,
                cpu_preprocess_required: _operation_family_needs_cpu_preprocess(operation_family),
                typed_status: status,
                reason: "ready"
            )
        val runtime = generated_2d_session_runtime_provenance(backend, op, width, height, runtime_ready, module_ready, args_ptr)
        Generated2DOperationProvenance(
            backend_name: runtime.backend_name,
            operation_family: operation_family,
            generated_operation: op,
            width: width,
            height: height,
            compute_target: runtime.compute_target,
            execution_path: "generated_2d_kernel",
            launch_api: runtime.launch_api,
            entry_name: runtime.entry_name,
            artifact_name: runtime.artifact_name,
            runtime_ready: runtime.gate.runtime_ready,
            module_ready: runtime.gate.module_ready,
            args_ready: runtime.gate.args_ptr != 0,
            ready: runtime.ready,
            generated_artifact_required: true,
            cpu_preprocess_required: _operation_family_needs_cpu_preprocess(operation_family),
            typed_status: runtime.typed_status,
            reason: runtime.reason
        )

    static fn unavailable(backend: text, operation_family: text, width: i64, height: i64, reason: text) -> Generated2DOperationProvenance:
        Generated2DOperationProvenance(
            backend_name: backend,
            operation_family: operation_family,
            generated_operation: "",
            width: width,
            height: height,
            compute_target: "unsupported",
            execution_path: "none",
            launch_api: "none",
            entry_name: "",
            artifact_name: "",
            runtime_ready: false,
            module_ready: false,
            args_ready: false,
            ready: false,
            generated_artifact_required: false,
            cpu_preprocess_required: false,
            typed_status: "plan-not-ready:" + reason,
            reason: reason
        )

    fn diagnostic_text() -> text:
        "Generated2DOperationProvenance[backend={self.backend_name} family={self.operation_family} op={self.generated_operation} target={self.compute_target} path={self.execution_path} launch={self.launch_api} entry={self.entry_name} artifact={self.artifact_name} runtime={self.runtime_ready.to_text()} module={self.module_ready.to_text()} args={self.args_ready.to_text()} generated_artifact={self.generated_artifact_required.to_text()} cpu_preprocess={self.cpu_preprocess_required.to_text()} ready={self.ready.to_text()} status={self.typed_status} reason={self.reason}]"

    fn summary() -> text:
        self.diagnostic_text()

class Generated2DModuleArtifactEvidence:
    plan: Generated2DKernelLaunchPlan
    artifact_magic: text
    exported_entries: text
    byte_count: i64
    artifact_valid: bool
    status_code: text
    reason: text

    static fn create(plan: Generated2DKernelLaunchPlan, artifact_magic: text, exported_entries: text, byte_count: i64) -> Generated2DModuleArtifactEvidence:
        val reason = _module_artifact_reason(plan, artifact_magic, exported_entries, byte_count)
        Generated2DModuleArtifactEvidence(
            plan: plan,
            artifact_magic: artifact_magic,
            exported_entries: exported_entries,
            byte_count: byte_count,
            artifact_valid: reason == "pass",
            status_code: if reason == "pass": "valid" else: "invalid",
            reason: reason
        )

    fn summary() -> text:
        "Generated2DModuleArtifactEvidence[backend={self.plan.backend_name} artifact={self.plan.artifact_name} bytes={self.byte_count} valid={self.artifact_valid.to_text()} reason={self.reason}]"

class Generated2DKernelArtifactLoadEvidence:
    plan: Generated2DKernelLaunchPlan
    artifact_valid: bool
    runtime_available: bool
    module_or_queue_handle: i64
    kernel_or_pipeline_handle: i64
    loaded: bool
    status_code: text
    reason: text

    static fn create(plan: Generated2DKernelLaunchPlan, artifact_valid: bool, runtime_available: bool, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64) -> Generated2DKernelArtifactLoadEvidence:
        val reason = _artifact_load_reason(plan, artifact_valid, runtime_available, module_or_queue_handle, kernel_or_pipeline_handle)
        Generated2DKernelArtifactLoadEvidence(
            plan: plan,
            artifact_valid: artifact_valid,
            runtime_available: runtime_available,
            module_or_queue_handle: module_or_queue_handle,
            kernel_or_pipeline_handle: kernel_or_pipeline_handle,
            loaded: reason == "loaded",
            status_code: if reason == "loaded": "loaded" else: "not-loaded",
            reason: reason
        )

    fn execution_request(args_ptr: i64) -> Generated2DKernelExecutionRequest:
        if not self.loaded:
            return Generated2DKernelExecutionRequest.create(Generated2DKernelLaunchPlan.unavailable(self.plan.backend_name, self.plan.operation, self.reason), self.module_or_queue_handle, self.kernel_or_pipeline_handle, args_ptr, 0)
        Generated2DKernelExecutionRequest.create(self.plan, self.module_or_queue_handle, self.kernel_or_pipeline_handle, args_ptr, 0)

    fn summary() -> text:
        "Generated2DKernelArtifactLoadEvidence[backend={self.plan.backend_name} op={self.plan.operation} artifact={self.artifact_valid.to_text()} runtime={self.runtime_available.to_text()} loaded={self.loaded.to_text()} module_or_queue={self.module_or_queue_handle} kernel_or_pipeline={self.kernel_or_pipeline_handle} reason={self.reason}]"

class Generated2DKernelSubmitResult:
    request: Generated2DKernelExecutionRequest
    attempted: bool
    submitted: bool
    runtime_available: bool
    status_code: text
    reason: text

    static fn create(request: Generated2DKernelExecutionRequest, runtime_available: bool, backend_submit_ok: bool) -> Generated2DKernelSubmitResult:
        if not request.can_submit:
            return Generated2DKernelSubmitResult(
                request: request,
                attempted: false,
                submitted: false,
                runtime_available: runtime_available,
                status_code: "not-ready",
                reason: request.reason
            )
        if not runtime_available:
            return Generated2DKernelSubmitResult(
                request: request,
                attempted: false,
                submitted: false,
                runtime_available: false,
                status_code: "runtime-unavailable",
                reason: "runtime-unavailable"
            )
        if not backend_submit_ok:
            return Generated2DKernelSubmitResult(
                request: request,
                attempted: true,
                submitted: false,
                runtime_available: true,
                status_code: "submit-failed",
                reason: "backend-submit-failed"
            )
        Generated2DKernelSubmitResult(
            request: request,
            attempted: true,
            submitted: true,
            runtime_available: true,
            status_code: "submitted",
            reason: "submitted"
        )

    fn summary() -> text:
        "Generated2DKernelSubmitResult[backend={self.request.plan.backend_name} op={self.request.plan.operation} attempted={self.attempted.to_text()} submitted={self.submitted.to_text()} runtime={self.runtime_available.to_text()} status={self.status_code} reason={self.reason}]"

class Generated2DKernelExecutionEvidence:
    submit: Generated2DKernelSubmitResult
    readback_available: bool
    expected_checksum: i64
    actual_checksum: i64
    device_executed: bool
    status_code: text
    reason: text

    static fn create(submit: Generated2DKernelSubmitResult, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> Generated2DKernelExecutionEvidence:
        if not submit.submitted:
            return Generated2DKernelExecutionEvidence(
                submit: submit,
                readback_available: readback_available,
                expected_checksum: expected_checksum,
                actual_checksum: actual_checksum,
                device_executed: false,
                status_code: "not-submitted",
                reason: submit.reason
            )
        if not readback_available:
            return Generated2DKernelExecutionEvidence(
                submit: submit,
                readback_available: false,
                expected_checksum: expected_checksum,
                actual_checksum: actual_checksum,
                device_executed: false,
                status_code: "readback-unavailable",
                reason: "device-readback-required"
            )
        if expected_checksum <= 0:
            return Generated2DKernelExecutionEvidence(
                submit: submit,
                readback_available: true,
                expected_checksum: expected_checksum,
                actual_checksum: actual_checksum,
                device_executed: false,
                status_code: "invalid-expected-checksum",
                reason: "expected-checksum-required"
            )
        if actual_checksum != expected_checksum:
            return Generated2DKernelExecutionEvidence(
                submit: submit,
                readback_available: true,
                expected_checksum: expected_checksum,
                actual_checksum: actual_checksum,
                device_executed: false,
                status_code: "readback-mismatch",
                reason: "device-readback-checksum-mismatch"
            )
        Generated2DKernelExecutionEvidence(
            submit: submit,
            readback_available: true,
            expected_checksum: expected_checksum,
            actual_checksum: actual_checksum,
            device_executed: true,
            status_code: "device-executed",
            reason: "readback-checksum-matched"
        )

    fn summary() -> text:
        "Generated2DKernelExecutionEvidence[backend={self.submit.request.plan.backend_name} op={self.submit.request.plan.operation} submitted={self.submit.submitted.to_text()} readback={self.readback_available.to_text()} executed={self.device_executed.to_text()} expected={self.expected_checksum} actual={self.actual_checksum} status={self.status_code} reason={self.reason}]"

class Generated2DKernelDispatch:
    backend_name: text
    compute_target: text
    source_format: text
    binary_format: text
    tool_hint: text
    kernel_count: i64
    active: bool

    static fn for_backend(backend: text) -> Generated2DKernelDispatch:
        if backend == "cuda":
            return Generated2DKernelDispatch.create("cuda", "cuda", "cuda-c", "ptx", "nvrtc-or-nvcc")
        if backend == "hip" or backend == "rocm":
            return Generated2DKernelDispatch.create(backend, "hip", "hip-cpp", "hsaco", "hiprtc-or-hipcc")
        if backend == "opencl":
            return Generated2DKernelDispatch.create("opencl", "opencl", "opencl-c", "spirv", "opencl-c-to-spirv")
        if backend == "metal":
            return Generated2DKernelDispatch.create("metal", "metal", "metal-shading-language", "metallib", "metal-and-metallib")
        Generated2DKernelDispatch(
            backend_name: backend,
            compute_target: "unsupported",
            source_format: "none",
            binary_format: "none",
            tool_hint: "none",
            kernel_count: 0,
            active: false
        )

    static fn create(backend: text, target: text, source_fmt: text, binary_fmt: text, tool: text) -> Generated2DKernelDispatch:
        Generated2DKernelDispatch(
            backend_name: backend,
            compute_target: target,
            source_format: source_fmt,
            binary_format: binary_fmt,
            tool_hint: tool,
            kernel_count: 5,
            active: true
        )

    fn supports_kernel(op: text) -> bool:
        if not self.active:
            return false
        op == GENERATED_2D_FILL or op == GENERATED_2D_COPY or op == GENERATED_2D_ALPHA or op == GENERATED_2D_SCROLL or op == GENERATED_2D_BITMAP_GLYPH_RASTER

    fn kernel_entry(op: text) -> text:
        if op == GENERATED_2D_FILL:
            return "simple_2d_fill_u32"
        if op == GENERATED_2D_COPY:
            return "simple_2d_copy_u32"
        if op == GENERATED_2D_ALPHA:
            return "simple_2d_alpha_u32"
        if op == GENERATED_2D_SCROLL:
            return "simple_2d_scroll_u32"
        if op == GENERATED_2D_BITMAP_GLYPH_RASTER:
            return "simple_2d_bitmap_glyph_raster_u32"
        ""

    fn artifact_suffix(op: text) -> text:
        val entry = self.kernel_entry(op)
        if entry == "" or not self.active:
            return ""
        "{entry}.{self.binary_format}"

    fn module_artifact_name() -> text:
        if not self.active:
            return ""
        "simple_2d_optimization.{self.binary_format}"

    fn required_entries() -> text:
        if not self.active:
            return ""
        "simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32"

    fn launch_api() -> text:
        if self.compute_target == "cuda":
            return "rt_cuda_launch_kernel"
        if self.compute_target == "hip":
            return "rt_rocm_launch_kernel"
        if self.compute_target == "opencl":
            return "clEnqueueNDRangeKernel"
        if self.compute_target == "metal":
            return "MTLComputeCommandEncoder.dispatchThreads"
        "none"

    fn launch_plan(op: text, width: i64, height: i64) -> Generated2DKernelLaunchPlan:
        if not self.active:
            return Generated2DKernelLaunchPlan.unavailable(self.backend_name, op, "backend-inactive")
        if not self.supports_kernel(op):
            return Generated2DKernelLaunchPlan.unavailable(self.backend_name, op, "unsupported-operation")
        if width <= 0 or height <= 0:
            return Generated2DKernelLaunchPlan.unavailable(self.backend_name, op, "invalid-dimensions")

        val pixels = width * height
        val block = 256
        val grid_size = _ceil_div_i64(pixels, block)
        val entry = self.kernel_entry(op)
        val artifact = self.module_artifact_name()
        val api = self.launch_api()
        val args = _kernel_args_layout(op)
        Generated2DKernelLaunchPlan(
            backend_name: self.backend_name,
            compute_target: self.compute_target,
            operation: op,
            entry_name: entry,
            artifact_name: artifact,
            required_entries: self.required_entries(),
            binary_format: self.binary_format,
            compile_tool: self.tool_hint,
            launch_api: api,
            grid_x: grid_size,
            grid_y: 1,
            grid_z: 1,
            block_x: block,
            block_y: 1,
            block_z: 1,
            args_layout: args,
            dispatch_ready: true,
            reason: "ready"
        )

    fn summary() -> text:
        "Generated2DKernelDispatch[backend={self.backend_name} target={self.compute_target} source={self.source_format} binary={self.binary_format} kernels={self.kernel_count} active={self.active.to_text()}]"

fn _ceil_div_i64(value: i64, divisor: i64) -> i64:
    (value + divisor - 1) / divisor

fn _kernel_args_layout(op: text) -> text:
    if op == GENERATED_2D_FILL:
        return "dst,width,height,color_u32"
    if op == GENERATED_2D_COPY:
        return "src,dst,width,height"
    if op == GENERATED_2D_ALPHA:
        return "src,dst,width,height,alpha_u8"
    if op == GENERATED_2D_SCROLL:
        return "src,dst,width,height,delta_y"
    if op == GENERATED_2D_BITMAP_GLYPH_RASTER:
        return "glyph_bits,dst,width,height,glyph_count,font_size,color_u32"
    ""

fn _operation_family_generated_op(operation_family: text) -> text:
    val clean = operation_family.lower()
    if _operation_family_is_bitmap_font_raster(clean):
        return GENERATED_2D_BITMAP_GLYPH_RASTER
    if clean == "vector" or clean == "rect" or clean == "rect_filled" or clean == "fill":
        return GENERATED_2D_FILL
    if clean == "image" or clean == "image_blit" or clean == "copy" or clean == "font" or clean == "text" or clean == "text_blit" or _operation_family_is_bitmap_font(clean) or _operation_family_is_vector_font(clean):
        return GENERATED_2D_COPY
    if clean == "alpha" or clean == "alpha_blend" or clean == "image_alpha":
        return GENERATED_2D_ALPHA
    if clean == "scroll":
        return GENERATED_2D_SCROLL
    ""

fn _operation_family_needs_cpu_preprocess(operation_family: text) -> bool:
    val clean = operation_family.lower()
    if _operation_family_is_bitmap_font_raster(clean):
        return false
    clean == "font" or clean == "text" or clean == "text_blit" or _operation_family_is_bitmap_font(clean) or _operation_family_is_vector_font(clean)

fn _operation_family_is_vector_font(clean: text) -> bool:
    clean == "vector_font" or clean == "vector_glyph" or clean == "font_vector" or clean == "glyph_raster" or clean == "glyph_blit"

fn _operation_family_is_bitmap_font(clean: text) -> bool:
    clean == "bitmap_font" or clean == "bitmap_glyph" or clean == "font_bitmap" or clean == "glyph_bitmap"

fn _operation_family_is_bitmap_font_raster(clean: text) -> bool:
    clean == "bitmap_glyph_raster" or clean == "bitmap_font_raster" or clean == "gpu_bitmap_glyph" or clean == "glyph_bitmap_raster"

fn _is_cpu_operation_backend(backend: text) -> bool:
    backend == "cpu" or backend == "software" or backend == "cpu_simd" or backend == "simd_cpu" or backend == "cpu_simd_x86" or backend == "cpu_simd_arm" or backend == "cpu_simd_riscv"

fn _cpu_operation_target(backend: text) -> text:
    if backend == "cpu" or backend == "software":
        return "cpu_scalar"
    "cpu_simd"

fn _cpu_operation_entry(operation_family: text) -> text:
    val clean = operation_family.lower()
    if _operation_family_is_vector_font(clean):
        return "FontRasterizer.rasterize_vector_accelerated"
    if clean == "font" or clean == "text" or clean == "text_blit" or _operation_family_is_bitmap_font(clean):
        return "RenderBackend.draw_text_or_text_blit"
    if clean == "image" or clean == "image_blit" or clean == "copy":
        return "RenderBackend.draw_image"
    if clean == "alpha" or clean == "alpha_blend" or clean == "image_alpha":
        return "RenderBackend.draw_image_blend"
    if clean == "scroll":
        return "RenderBackend.scroll_or_copy"
    "RenderBackend.draw_rect_filled"

fn _execution_handle_kind(plan: Generated2DKernelLaunchPlan) -> text:
    if plan.compute_target == "cuda":
        return "cuda-kernel-args"
    if plan.compute_target == "hip":
        return "rocm-kernel-args"
    if plan.compute_target == "opencl":
        return "opencl-queue-kernel"
    if plan.compute_target == "metal":
        return "metal-encoder-pipeline"
    "unsupported"

fn _execution_request_reason(plan: Generated2DKernelLaunchPlan, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, args_ptr: i64) -> text:
    if not plan.dispatch_ready:
        return plan.reason
    if kernel_or_pipeline_handle <= 0:
        return "missing-kernel-or-pipeline-handle"
    if plan.compute_target == "opencl" or plan.compute_target == "metal":
        if module_or_queue_handle <= 0:
            return "missing-queue-or-encoder-handle"
    else:
        if args_ptr <= 0:
            return "missing-args-pointer"
    "ready"

fn _session_launch_gate_reason(plan: Generated2DKernelLaunchPlan, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> text:
    if not plan.dispatch_ready:
        return plan.reason
    if not runtime_ready:
        return "runtime-not-ready"
    if not module_ready:
        return "module-not-loaded"
    if args_ptr == 0:
        return "missing-args-pointer"
    "ready"

fn _artifact_load_reason(plan: Generated2DKernelLaunchPlan, artifact_valid: bool, runtime_available: bool, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64) -> text:
    if not plan.dispatch_ready:
        return plan.reason
    if not artifact_valid:
        return "artifact-not-verified"
    if not runtime_available:
        return "runtime-unavailable"
    if kernel_or_pipeline_handle <= 0:
        return "missing-kernel-or-pipeline-handle"
    if plan.compute_target == "opencl" or plan.compute_target == "metal":
        if module_or_queue_handle <= 0:
            return "missing-queue-or-encoder-handle"
    "loaded"

fn _module_artifact_expected_magic(plan: Generated2DKernelLaunchPlan) -> text:
    if plan.binary_format == "ptx":
        return ".version"
    if plan.binary_format == "hsaco":
        return "ELF"
    if plan.binary_format == "spirv":
        return "SPIR-V"
    if plan.binary_format == "metallib":
        return "MTLB"
    ""

fn _module_artifact_reason(plan: Generated2DKernelLaunchPlan, artifact_magic: text, exported_entries: text, byte_count: i64) -> text:
    if not plan.dispatch_ready:
        return plan.reason
    if plan.artifact_name == "":
        return "missing-module-artifact-name"
    if plan.required_entries == "":
        return "missing-required-entries"
    if byte_count <= 0:
        return "missing-artifact-bytes"
    if artifact_magic == "":
        return "missing-artifact-magic"
    if not artifact_magic.contains(_module_artifact_expected_magic(plan)):
        return "artifact-magic-mismatch"
    if exported_entries == "":
        return "missing-exported-entries"
    if plan.required_entries.contains("simple_2d_fill_u32") and not exported_entries.contains("simple_2d_fill_u32"):
        return "missing-entry-symbol:simple_2d_fill_u32"
    if plan.required_entries.contains("simple_2d_copy_u32") and not exported_entries.contains("simple_2d_copy_u32"):
        return "missing-entry-symbol:simple_2d_copy_u32"
    if plan.required_entries.contains("simple_2d_alpha_u32") and not exported_entries.contains("simple_2d_alpha_u32"):
        return "missing-entry-symbol:simple_2d_alpha_u32"
    if plan.required_entries.contains("simple_2d_scroll_u32") and not exported_entries.contains("simple_2d_scroll_u32"):
        return "missing-entry-symbol:simple_2d_scroll_u32"
    "pass"

fn _session_runtime_provenance_status(gate: Generated2DSessionLaunchGate) -> text:
    if gate.ready:
        return "ready"
    if not gate.plan.dispatch_ready:
        return "plan-not-ready:" + gate.plan.reason
    if not gate.runtime_ready:
        if gate.plan.backend_name == "cuda":
            return "cuda-runtime-unavailable"
        if gate.plan.backend_name == "rocm":
            return "hip-runtime-unavailable"
        if gate.plan.backend_name == "opencl":
            return "opencl-runtime-or-queue-unavailable"
        return "runtime-unavailable"
    if not gate.module_ready:
        if gate.plan.backend_name == "cuda":
            return "cuda-module-unavailable"
        if gate.plan.backend_name == "rocm":
            return "hip-module-unavailable"
        if gate.plan.backend_name == "opencl":
            return "opencl-program-unavailable"
        return "module-unavailable"
    if gate.args_ptr == 0:
        return "args-unavailable"
    "not-ready:" + gate.reason

fn generated_2d_dispatch_for_backend(backend: text) -> Generated2DKernelDispatch:
    Generated2DKernelDispatch.for_backend(backend)

fn generated_2d_launch_plan(backend: text, op: text, width: i64, height: i64) -> Generated2DKernelLaunchPlan:
    generated_2d_dispatch_for_backend(backend).launch_plan(op, width, height)

fn generated_2d_execution_request(backend: text, op: text, width: i64, height: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, args_ptr: i64) -> Generated2DKernelExecutionRequest:
    val plan = generated_2d_launch_plan(backend, op, width, height)
    Generated2DKernelExecutionRequest.create(plan, module_or_queue_handle, kernel_or_pipeline_handle, args_ptr, 0)

fn generated_2d_session_launch_gate(backend: text, op: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DSessionLaunchGate:
    val plan = generated_2d_launch_plan(backend, op, width, height)
    Generated2DSessionLaunchGate.create(plan, runtime_ready, module_ready, args_ptr)

fn generated_2d_session_runtime_provenance(backend: text, op: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DSessionRuntimeProvenance:
    Generated2DSessionRuntimeProvenance.create(backend, op, width, height, runtime_ready, module_ready, args_ptr)

fn generated_2d_operation_provenance(backend: text, operation_family: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> Generated2DOperationProvenance:
    Generated2DOperationProvenance.create(backend, operation_family, width, height, runtime_ready, module_ready, args_ptr)

fn generated_2d_artifact_load_evidence(backend: text, op: text, width: i64, height: i64, artifact_valid: bool, runtime_available: bool, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64) -> Generated2DKernelArtifactLoadEvidence:
    val plan = generated_2d_launch_plan(backend, op, width, height)
    Generated2DKernelArtifactLoadEvidence.create(plan, artifact_valid, runtime_available, module_or_queue_handle, kernel_or_pipeline_handle)

fn generated_2d_module_artifact_evidence(backend: text, op: text, width: i64, height: i64, artifact_magic: text, exported_entries: text, byte_count: i64) -> Generated2DModuleArtifactEvidence:
    val plan = generated_2d_launch_plan(backend, op, width, height)
    Generated2DModuleArtifactEvidence.create(plan, artifact_magic, exported_entries, byte_count)

fn generated_2d_artifact_load_evidence_from_module(module: Generated2DModuleArtifactEvidence, runtime_available: bool, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64) -> Generated2DKernelArtifactLoadEvidence:
    Generated2DKernelArtifactLoadEvidence.create(module.plan, module.artifact_valid, runtime_available, module_or_queue_handle, kernel_or_pipeline_handle)

fn generated_2d_execution_request_from_load(load: Generated2DKernelArtifactLoadEvidence, args_ptr: i64) -> Generated2DKernelExecutionRequest:
    load.execution_request(args_ptr)

fn generated_2d_submit_result(request: Generated2DKernelExecutionRequest, runtime_available: bool, backend_submit_ok: bool) -> Generated2DKernelSubmitResult:
    Generated2DKernelSubmitResult.create(request, runtime_available, backend_submit_ok)

fn generated_2d_execution_evidence(submit: Generated2DKernelSubmitResult, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> Generated2DKernelExecutionEvidence:
    Generated2DKernelExecutionEvidence.create(submit, readback_available, expected_checksum, actual_checksum)

fn generated_2d_dispatch_provider(dispatch: Generated2DKernelDispatch) -> RenderingOptProvider:
    val p = RenderingOptProvider.create("generated_2d_kernel_dispatch", dispatch.backend_name, dispatch.binary_format)
    p.hit_count = dispatch.kernel_count
    p.change_count = if dispatch.active: 1 else: 0
    p.active = dispatch.active
    p

export GENERATED_2D_FILL, GENERATED_2D_COPY, GENERATED_2D_ALPHA, GENERATED_2D_SCROLL, GENERATED_2D_BITMAP_GLYPH_RASTER
export Generated2DKernelLaunchPlan, Generated2DKernelExecutionRequest, Generated2DSessionLaunchGate
export Generated2DSessionRuntimeProvenance, Generated2DOperationProvenance
export Generated2DModuleArtifactEvidence, Generated2DKernelArtifactLoadEvidence
export Generated2DKernelSubmitResult, Generated2DKernelExecutionEvidence, Generated2DKernelDispatch
export generated_2d_dispatch_for_backend, generated_2d_launch_plan, generated_2d_execution_request
export generated_2d_session_launch_gate, generated_2d_session_runtime_provenance
export generated_2d_operation_provenance, generated_2d_artifact_load_evidence
export generated_2d_module_artifact_evidence, generated_2d_artifact_load_evidence_from_module
export generated_2d_execution_request_from_load, generated_2d_submit_result
export generated_2d_execution_evidence, generated_2d_dispatch_provider
