# CUDA Engine2D launch argument and host pixel helpers.
#
# Shared by the CUDA backend self-test and runtime draw paths.

extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
extern fn rt_ptr_write_u8(addr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)

fn _i64(v: i32) -> i64:
    v as i64

fn _i64_from_u32(v: u32) -> i64:
    v as i64

fn _read_u32_pixels_from_host(ptr: i64, count: i32) -> [u32]:
    var out: [u32] = [0u32; count]
    var idx = 0
    while idx < count:
        out[idx] = rt_ptr_read_i32(ptr, _i64(idx) * 4) as u32
        idx = idx + 1
    out

fn _write_clear_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, color: u32, width: i32, height: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(width))
    rt_ptr_write_i64(val_ptr, 16, _i64(height))
    rt_ptr_write_i64(val_ptr, 24, _i64_from_u32(color))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)

fn _write_rect_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, color: u32, stride: i32, surface_h: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(x))
    rt_ptr_write_i64(val_ptr, 16, _i64(y))
    rt_ptr_write_i64(val_ptr, 24, _i64(w))
    rt_ptr_write_i64(val_ptr, 32, _i64(h))
    rt_ptr_write_i64(val_ptr, 40, _i64_from_u32(color))
    rt_ptr_write_i64(val_ptr, 48, _i64(stride))
    rt_ptr_write_i64(val_ptr, 56, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_image_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, d_pixels: i64, x: i32, y: i32, w: i32, h: i32, stride: i32, surface_h: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, d_pixels)
    rt_ptr_write_i64(val_ptr, 16, _i64(x))
    rt_ptr_write_i64(val_ptr, 24, _i64(y))
    rt_ptr_write_i64(val_ptr, 32, _i64(w))
    rt_ptr_write_i64(val_ptr, 40, _i64(h))
    rt_ptr_write_i64(val_ptr, 48, _i64(stride))
    rt_ptr_write_i64(val_ptr, 56, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_gradient_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32, stride: i32, surface_h: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(x))
    rt_ptr_write_i64(val_ptr, 16, _i64(y))
    rt_ptr_write_i64(val_ptr, 24, _i64(w))
    rt_ptr_write_i64(val_ptr, 32, _i64(h))
    rt_ptr_write_i64(val_ptr, 40, _i64_from_u32(top_color))
    rt_ptr_write_i64(val_ptr, 48, _i64_from_u32(bottom_color))
    rt_ptr_write_i64(val_ptr, 56, _i64(stride))
    rt_ptr_write_i64(val_ptr, 64, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)
    rt_ptr_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_line_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32, stride: i32, surface_h: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(x1))
    rt_ptr_write_i64(val_ptr, 16, _i64(y1))
    rt_ptr_write_i64(val_ptr, 24, _i64(x2))
    rt_ptr_write_i64(val_ptr, 32, _i64(y2))
    rt_ptr_write_i64(val_ptr, 40, _i64_from_u32(color))
    rt_ptr_write_i64(val_ptr, 48, _i64(thickness))
    rt_ptr_write_i64(val_ptr, 56, _i64(stride))
    rt_ptr_write_i64(val_ptr, 64, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)
    rt_ptr_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_circle_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, cx: i32, cy: i32, r: i32, color: u32, stride: i32, surface_h: i32, filled: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(cx))
    rt_ptr_write_i64(val_ptr, 16, _i64(cy))
    rt_ptr_write_i64(val_ptr, 24, _i64(r))
    rt_ptr_write_i64(val_ptr, 32, _i64_from_u32(color))
    rt_ptr_write_i64(val_ptr, 40, _i64(stride))
    rt_ptr_write_i64(val_ptr, 48, _i64(surface_h))
    rt_ptr_write_i64(val_ptr, 56, _i64(filled))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)

fn _write_rounded_rect_launch_args(val_ptr: i64, args_ptr: i64, d_framebuffer: i64, x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, stride: i32, surface_h: i32):
    rt_ptr_write_i64(val_ptr, 0, d_framebuffer)
    rt_ptr_write_i64(val_ptr, 8, _i64(x))
    rt_ptr_write_i64(val_ptr, 16, _i64(y))
    rt_ptr_write_i64(val_ptr, 24, _i64(w))
    rt_ptr_write_i64(val_ptr, 32, _i64(h))
    rt_ptr_write_i64(val_ptr, 40, _i64(radius))
    rt_ptr_write_i64(val_ptr, 48, _i64_from_u32(color))
    rt_ptr_write_i64(val_ptr, 56, _i64(stride))
    rt_ptr_write_i64(val_ptr, 64, _i64(surface_h))
    rt_ptr_write_i64(args_ptr, 0, val_ptr)
    rt_ptr_write_i64(args_ptr, 8, val_ptr + 8)
    rt_ptr_write_i64(args_ptr, 16, val_ptr + 16)
    rt_ptr_write_i64(args_ptr, 24, val_ptr + 24)
    rt_ptr_write_i64(args_ptr, 32, val_ptr + 32)
    rt_ptr_write_i64(args_ptr, 40, val_ptr + 40)
    rt_ptr_write_i64(args_ptr, 48, val_ptr + 48)
    rt_ptr_write_i64(args_ptr, 56, val_ptr + 56)
    rt_ptr_write_i64(args_ptr, 64, val_ptr + 64)

fn _write_u32_pixels_to_host(ptr: i64, pixels: [u32], count: i32):
    var idx = 0
    while idx < count:
        val pixel = pixels[idx] as i64
        val base = _i64(idx) * 4
        rt_ptr_write_u8(ptr, base, pixel & 0xFF)
        rt_ptr_write_u8(ptr, base + 1, (pixel >> 8) & 0xFF)
        rt_ptr_write_u8(ptr, base + 2, (pixel >> 16) & 0xFF)
        rt_ptr_write_u8(ptr, base + 3, (pixel >> 24) & 0xFF)
        idx = idx + 1
