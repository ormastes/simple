"""2D Engine — Shared Text Rendering Helpers

Pure functions for the glyph-buffer fallback path used by GPU backends
(CUDA, Vulkan, WebGPU) and the CPU backend's draw_text_bg implementation.

The identical `draw_text_bg` body is duplicated across every backend.
This module extracts the shared buffer-fill + render_text step so each
backend can delegate instead of copy-pasting the same ~20-line block.

Usage:
    use std.gpu.engine2d.helpers_text.{
        text_render_to_buf, text_buf_width, text_buf_height
    }

@tag:stdlib
@tag:gpu
"""

use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, render_text_to_buffer}

# ============================================================================
# Text Buffer Dimensions
# ============================================================================

fn text_buf_width(text_val: text, font_size: i32) -> i32:
    """Compute the pixel width of a rendered text string.

    Uses the same scale/advance calculation as draw_text_bg across all
    backends. Returns 0 for empty strings.
    """
    val char_count = text_val.len().to_i32()
    if char_count <= 0:
        return 0
    val gh = glyph_height()
    var scale = font_size / gh
    if scale < 1:
        scale = 1
    val advance = glyph_advance(scale)
    char_count * advance

fn text_buf_height(font_size: i32) -> i32:
    """Compute the pixel height of a rendered text string."""
    val gh = glyph_height()
    var scale = font_size / gh
    if scale < 1:
        scale = 1
    gh * scale

fn text_scale(font_size: i32) -> i32:
    """Integer scale factor derived from font_size vs glyph_height."""
    val gh = glyph_height()
    var scale = font_size / gh
    if scale < 1:
        scale = 1
    scale

# ============================================================================
# Text-to-Buffer Fallback
# ============================================================================

fn text_render_to_buf(text_val: text, fg: u32, bg: u32, font_size: i32) -> [u32]:
    """Rasterize `text_val` into a fresh pixel buffer filled with `bg`.

    This is the shared body of `draw_text_bg` present in every backend.
    Returns an empty slice if the text string is empty or dimensions are
    degenerate. The returned buffer has dimensions
    (text_buf_width(text_val, font_size), text_buf_height(font_size)).

    Backends blit this buffer with `draw_image(x, y, text_w, text_h, buf)`.
    """
    val text_w = text_buf_width(text_val, font_size)
    val text_h = text_buf_height(font_size)
    if text_w <= 0 or text_h <= 0:
        var empty: [u32] = []
        return empty
    var buf: [u32] = []
    var fill_i = 0
    val buf_size = text_w * text_h
    while fill_i < buf_size:
        buf.push(bg)
        fill_i = fill_i + 1
    render_text_to_buffer(buf, text_w, text_h, 0, 0, text_val, fg, font_size)
    buf

fn text_render_width(text_val: text, font_size: i32) -> i32:
    """Pixel width of text string — alias kept for callers that prefer explicit naming."""
    text_buf_width(text_val, font_size)

fn text_render_height(font_size: i32) -> i32:
    """Pixel height of text string — alias kept for callers that prefer explicit naming."""
    text_buf_height(font_size)
