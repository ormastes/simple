"""2D Engine — Text Rendering Fallback Helpers

Lightweight fallback text renderer used when a proper font backend is
unavailable. Estimates glyph metrics and emits placement strings for
debug overlays and headless test environments.

Usage:
    use std.gpu.engine2d.helpers.text_fallback.TextFallback

@tag:stdlib
@tag:gpu
"""

# ============================================================================
# TextFallback
# ============================================================================

class TextFallback:
    """Fallback text renderer: no real glyph rasterisation, best-effort metrics."""
    font_name: text
    font_size: i64
    available: bool
    render_count: i64

    static fn create(font_name: text, size: i64) -> TextFallback:
        """Create a TextFallback instance for the given font name and pixel size."""
        TextFallback(
            font_name: font_name,
            font_size: size,
            available: true,
            render_count: 0
        )

    me measure_text(msg: text) -> i64:
        """Estimate text width in pixels using a fixed-width approximation.

        Uses font_size * 0.6 per character, rounded to whole pixels.
        This is a best-effort estimate suitable for layout hints only.
        """
        val char_width = self.font_size * 6 / 10
        msg.len() as i64 * char_width

    me render_text(msg: text, x: i64, y: i64) -> text:
        """Return a placement descriptor for the given text at (x, y).

        The fallback does not rasterise glyphs; callers receive a string
        that can be logged or forwarded to a higher-level renderer.
        """
        self.render_count = self.render_count + 1
        "text[" + self.font_name + "@" + self.font_size.to_text() + "px x=" + x.to_text() + " y=" + y.to_text() + "]: " + msg

    me is_available() -> bool:
        """Return true if this fallback renderer is considered operational."""
        self.available

    me stats() -> text:
        """Return a one-line summary of renderer state and usage."""
        "TextFallback(font=" + self.font_name + " size=" + self.font_size.to_text() + " available=" + self.available.to_text() + " renders=" + self.render_count.to_text() + ")"
