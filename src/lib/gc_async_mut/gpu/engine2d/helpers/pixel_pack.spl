"""2D Engine — Pixel Packing and Unpacking Helpers

PixelFormat descriptor plus pure functions for RGBA pack/unpack and
alpha blending. All values are passed as i64 for GPU argument compatibility.

Usage:
    use std.gpu.engine2d.helpers.pixel_pack.{
        PixelFormat, pack_rgba, unpack_r, unpack_g, unpack_b, unpack_a,
        blend_alpha
    }

@tag:stdlib
@tag:gpu
"""

# ============================================================================
# PixelFormat
# ============================================================================

class PixelFormat:
    """Describes a pixel memory layout (channel order and bit depth)."""
    name: text
    channels: i64
    bits_per_pixel: i64

    static fn rgba8() -> PixelFormat:
        """RGBA, 8 bits per channel, 32 bpp."""
        PixelFormat(name: "rgba8", channels: 4, bits_per_pixel: 32)

    static fn bgra8() -> PixelFormat:
        """BGRA, 8 bits per channel, 32 bpp."""
        PixelFormat(name: "bgra8", channels: 4, bits_per_pixel: 32)

    static fn rgb8() -> PixelFormat:
        """RGB, 8 bits per channel, 24 bpp."""
        PixelFormat(name: "rgb8", channels: 3, bits_per_pixel: 24)

    static fn r8() -> PixelFormat:
        """Single red channel, 8 bpp."""
        PixelFormat(name: "r8", channels: 1, bits_per_pixel: 8)

# ============================================================================
# Pack / Unpack
# ============================================================================

fn pack_rgba(r: i64, g: i64, b: i64, a: i64) -> i64:
    """Pack RGBA components (0–255 each) into a single i64 word (RGBA byte order)."""
    ((r & 255) << 24) | ((g & 255) << 16) | ((b & 255) << 8) | (a & 255)

fn unpack_r(packed: i64) -> i64:
    """Extract the red channel from a packed RGBA pixel."""
    (packed >> 24) & 255

fn unpack_g(packed: i64) -> i64:
    """Extract the green channel from a packed RGBA pixel."""
    (packed >> 16) & 255

fn unpack_b(packed: i64) -> i64:
    """Extract the blue channel from a packed RGBA pixel."""
    (packed >> 8) & 255

fn unpack_a(packed: i64) -> i64:
    """Extract the alpha channel from a packed RGBA pixel."""
    packed & 255

# ============================================================================
# Alpha Blending
# ============================================================================

fn blend_alpha(fg: i64, bg: i64, alpha: i64) -> i64:
    """Linear blend: result = fg * alpha/255 + bg * (1 - alpha/255).

    alpha must be in [0, 255]. Returns a value in the same range as fg/bg.
    """
    fg * alpha / 255 + bg * (255 - alpha) / 255
