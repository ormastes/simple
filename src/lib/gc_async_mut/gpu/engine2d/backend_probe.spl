# 2D Engine — Backend Probe Contract

use std.gc_async_mut.cuda.{cuda_available, cuda_init, cuda_device_count, cuda_device_name, CUDA_SUCCESS}
use std.gc_async_mut.gpu.engine2d.cuda_session.{CudaSession}
use std.gpu.engine2d.sffi_opencl.{OpenClFfi}
use std.gpu.engine2d.simd_kernels.{CpuSimdRuntimeEvidence, cpu_simd_runtime_evidence}

val BACKEND_CPU: text = "cpu"
val BACKEND_SOFTWARE: text = "software"
val BACKEND_VULKAN: text = "vulkan"
val BACKEND_CUDA: text = "cuda"
val BACKEND_METAL: text = "metal"
val BACKEND_OPENCL: text = "opencl"
val BACKEND_WEBGPU: text = "webgpu"
val BACKEND_ROCM: text = "rocm"
val BACKEND_CPU_SIMD: text = "cpu_simd"
val BACKEND_CPU_SIMD_X86: text = "cpu_simd_x86"
val BACKEND_CPU_SIMD_ARM: text = "cpu_simd_arm"
val BACKEND_CPU_SIMD_RISCV: text = "cpu_simd_riscv"
val BACKEND_OPTIX: text = "optix"

val STATUS_OK: text = "Initialized"
val STATUS_FAILED: text = "Failed"
val STATUS_UNAVAILABLE: text = "Unavailable"
val STATUS_FALLBACK: text = "Fallback"

enum BackendStatus:
    Initialized
    Failed
    Unavailable
    Fallback

fn backend_status_text(status: BackendStatus) -> text:
    match status:
        case Initialized: "Initialized"
        case Failed: "Failed"
        case Unavailable: "Unavailable"
        case Fallback: "Fallback"

class BackendProbeResult:
    requested_name: text
    selected_name: text
    status: BackendStatus
    device_name: text
    api_name: text
    feature_gate: text
    shader_format: text
    fallback_reason: text
    backend_name: text
    available: bool
    init_ms: i64
    reason: text
    driver_version: text
    has_compute: bool
    has_graphics: bool
    has_present: bool
    init_time_us: i64
    memory_mb: i64

    static fn success(name: text, message: text) -> BackendProbeResult:
        BackendProbeResult(
            requested_name: name, selected_name: name, status: BackendStatus.Initialized,
            device_name: name, api_name: name, feature_gate: "", shader_format: "none",
            fallback_reason: "", backend_name: name, available: true, init_ms: 0,
            reason: message, driver_version: "", has_compute: true, has_graphics: true,
            has_present: true, init_time_us: 0, memory_mb: 0
        )

    static fn unavailable(name: text, message: text) -> BackendProbeResult:
        BackendProbeResult(
            requested_name: name, selected_name: name, status: BackendStatus.Unavailable,
            device_name: "", api_name: name, feature_gate: "", shader_format: "none",
            fallback_reason: message, backend_name: name, available: false, init_ms: 0,
            reason: message, driver_version: "", has_compute: false, has_graphics: false,
            has_present: false, init_time_us: 0, memory_mb: 0
        )

    static fn failed(name: text, message: text) -> BackendProbeResult:
        BackendProbeResult(
            requested_name: name, selected_name: name, status: BackendStatus.Failed,
            device_name: "", api_name: name, feature_gate: "", shader_format: "none",
            fallback_reason: message, backend_name: name, available: false, init_ms: 0,
            reason: message, driver_version: "", has_compute: false, has_graphics: false,
            has_present: false, init_time_us: 0, memory_mb: 0
        )

    fn is_usable(self) -> bool:
        self.status == BackendStatus.Initialized

    fn is_ok(self) -> bool:
        self.is_usable()

    fn is_hardware(self) -> bool:
        if self.selected_name == BACKEND_CPU:
            return false
        if self.selected_name == BACKEND_SOFTWARE:
            return false
        if self.selected_name == BACKEND_CPU_SIMD or self.selected_name == BACKEND_CPU_SIMD_X86 or self.selected_name == BACKEND_CPU_SIMD_ARM or self.selected_name == BACKEND_CPU_SIMD_RISCV:
            return false
        self.is_usable()

    fn strict_failure_without_fallback(self) -> bool:
        if self.status == BackendStatus.Fallback:
            return false
        if self.selected_name == BACKEND_CPU and self.requested_name != BACKEND_CPU:
            return false
        if self.selected_name == BACKEND_SOFTWARE and self.requested_name != BACKEND_SOFTWARE:
            return false
        true

    fn diagnostic_text(self) -> text:
        val msg = if self.fallback_reason != "": self.fallback_reason else: self.reason
        "requested={self.requested_name};selected={self.selected_name};status={backend_status_text(self.status)};api={self.api_name};gate={self.feature_gate};shader={self.shader_format};reason={msg}"

    fn summary(self) -> text:
        self.diagnostic_text()

class BackendProber:
    probe_count: i64
    last_error: text

    static fn create() -> BackendProber:
        BackendProber(probe_count: 0, last_error: "")

    fn probe_cpu(self) -> BackendProbeResult:
        var r = BackendProbeResult.success(BACKEND_CPU, "software renderer always present")
        r.api_name = "cpu"
        r.feature_gate = "cpu_scalar"
        r.shader_format = "none"
        r.has_compute = true
        r.has_graphics = true
        r.has_present = true
        r

    fn probe_software(self) -> BackendProbeResult:
        var r = BackendProbeResult.success(BACKEND_SOFTWARE, "software renderer always present")
        r.api_name = "software"
        r.feature_gate = "software_raster"
        r.shader_format = "none"
        r.has_compute = true
        r.has_graphics = true
        r.has_present = true
        r

    fn probe_vulkan(self) -> BackendProbeResult:
        var r = BackendProbeResult.unavailable(BACKEND_VULKAN, "vulkan probe unavailable in interpreter")
        r.api_name = "vulkan"
        r.feature_gate = "vulkan_runtime"
        r.shader_format = "spirv"
        r

    fn probe_cuda(self) -> BackendProbeResult:
        if not cuda_available():
            var unavailable = BackendProbeResult.unavailable(BACKEND_CUDA, "CUDA runtime unavailable")
            unavailable.api_name = "cuda"
            unavailable.feature_gate = "cuda_runtime"
            unavailable.shader_format = "ptx"
            unavailable.has_compute = true
            return unavailable
        val init_result = cuda_init()
        if init_result != CUDA_SUCCESS:
            var failed = BackendProbeResult.failed(BACKEND_CUDA, "CUDA init failed")
            failed.api_name = "cuda"
            failed.feature_gate = "cuda_init"
            failed.shader_format = "ptx"
            failed.has_compute = true
            return failed
        if cuda_device_count() < 1:
            var no_device = BackendProbeResult.unavailable(BACKEND_CUDA, "no CUDA device")
            no_device.api_name = "cuda"
            no_device.feature_gate = "cuda_device"
            no_device.shader_format = "ptx"
            no_device.has_compute = true
            return no_device
        var session = CudaSession.create()
        val session_status = session.init()
        if session_status != CUDA_SUCCESS:
            var context_failed = BackendProbeResult.failed(BACKEND_CUDA, "CUDA context creation failed")
            context_failed.api_name = "cuda"
            context_failed.feature_gate = "cuda_context"
            context_failed.shader_format = "ptx"
            context_failed.has_compute = true
            return context_failed
        val device_name = cuda_device_name(0)
        session.release()
        var r = BackendProbeResult.success(BACKEND_CUDA, "CUDA runtime, device, and context initialized")
        r.api_name = "cuda"
        r.feature_gate = "cuda_context"
        r.shader_format = "ptx"
        r.has_compute = true
        r.has_graphics = false
        r.has_present = false
        r.device_name = device_name
        r.memory_mb = 1
        r

    fn probe_metal(self) -> BackendProbeResult:
        var r = BackendProbeResult.unavailable(BACKEND_METAL, "Metal requires macOS")
        r.api_name = "metal"
        r.feature_gate = "macos_metal_runtime"
        r.shader_format = "msl"
        r

    fn probe_opencl(self) -> BackendProbeResult:
        val maybe_ffi = OpenClFfi.create_dynamic()
        if maybe_ffi == nil:
            var unavailable = BackendProbeResult.unavailable(BACKEND_OPENCL, "OpenCL ICD library unavailable")
            unavailable.api_name = "opencl"
            unavailable.feature_gate = "opencl_icd_platform"
            unavailable.shader_format = "opencl-c"
            unavailable.has_compute = true
            unavailable.has_graphics = false
            unavailable.has_present = false
            return unavailable
        val ffi = maybe_ffi
        if not ffi.is_available():
            var missing_symbol = BackendProbeResult.unavailable(BACKEND_OPENCL, "OpenCL ICD missing clGetPlatformIDs")
            missing_symbol.api_name = "opencl"
            missing_symbol.feature_gate = "opencl_icd_platform"
            missing_symbol.shader_format = "opencl-c"
            missing_symbol.has_compute = true
            missing_symbol.has_graphics = false
            missing_symbol.has_present = false
            return missing_symbol
        val platform_count = ffi.platform_count()
        if platform_count < 1:
            var no_platform = BackendProbeResult.unavailable(BACKEND_OPENCL, "OpenCL ICD returned zero platforms")
            no_platform.api_name = "opencl"
            no_platform.feature_gate = "opencl_platform"
            no_platform.shader_format = "opencl-c"
            no_platform.has_compute = true
            no_platform.has_graphics = false
            no_platform.has_present = false
            return no_platform
        var r = BackendProbeResult.success(BACKEND_OPENCL, "OpenCL ICD loaded and reported {platform_count} platform(s)")
        r.api_name = "opencl"
        r.feature_gate = "opencl_icd_platform"
        r.shader_format = "opencl-c"
        r.has_compute = true
        r.has_graphics = false
        r.has_present = false
        r.memory_mb = platform_count
        r

    fn probe_webgpu(self) -> BackendProbeResult:
        var r = BackendProbeResult.unavailable(BACKEND_WEBGPU, "webgpu probe unavailable in interpreter")
        r.api_name = "webgpu"
        r.feature_gate = "wgpu_runtime"
        r.shader_format = "wgsl"
        r

    fn probe_rocm(self) -> BackendProbeResult:
        var r = BackendProbeResult.unavailable(BACKEND_ROCM, "ROCm/HIP probe unavailable in interpreter")
        r.api_name = "rocm"
        r.feature_gate = "rocm_hip_runtime"
        r.shader_format = "hsaco"
        r.has_compute = true
        r

    fn probe_cpu_simd(self) -> BackendProbeResult:
        val evidence = cpu_simd_runtime_evidence()
        var r = BackendProbeResult.success(BACKEND_CPU_SIMD, "CPU SIMD runtime evidence: {evidence.diagnostic_text()}")
        r.api_name = "cpu-simd"
        r.feature_gate = "runtime_cpu_features"
        r.shader_format = "none"
        r.has_compute = true
        r.has_graphics = true
        r.has_present = true
        r

    fn _cpu_simd_arch_result(self, backend_name: text, api_name: text, gate: text, available: bool, evidence: CpuSimdRuntimeEvidence) -> BackendProbeResult:
        var r = if available:
            BackendProbeResult.success(backend_name, "CPU SIMD runtime evidence: {evidence.diagnostic_text()}")
        else:
            BackendProbeResult.unavailable(backend_name, "CPU SIMD runtime evidence unavailable for {backend_name}: {evidence.diagnostic_text()}")
        r.api_name = api_name
        r.feature_gate = gate
        r.shader_format = "none"
        r.device_name = evidence.arch
        r.driver_version = evidence.feature
        r.has_compute = true
        r.has_graphics = true
        r.has_present = true
        r.memory_mb = evidence.checksum
        r

    fn probe_cpu_simd_x86(self) -> BackendProbeResult:
        val evidence = cpu_simd_runtime_evidence()
        self._cpu_simd_arch_result(BACKEND_CPU_SIMD_X86, "cpu-simd-x86", "x86_sse42_avx2_avx512", evidence.x86_available and evidence.executed_all(), evidence)

    fn probe_cpu_simd_arm(self) -> BackendProbeResult:
        val evidence = cpu_simd_runtime_evidence()
        self._cpu_simd_arch_result(BACKEND_CPU_SIMD_ARM, "cpu-simd-arm", "arm_neon_sve", evidence.arm_available and evidence.executed_all(), evidence)

    fn probe_cpu_simd_riscv(self) -> BackendProbeResult:
        val evidence = cpu_simd_runtime_evidence()
        self._cpu_simd_arch_result(BACKEND_CPU_SIMD_RISCV, "cpu-simd-riscv", "riscv_vector_extension", evidence.riscv_available and evidence.executed_all(), evidence)

    fn probe_cpu_simd_arch_summary(self) -> text:
        self.probe_cpu_simd_x86().summary() + " | " + self.probe_cpu_simd_arm().summary() + " | " + self.probe_cpu_simd_riscv().summary()

    fn probe_runtime_evidence_summary(self) -> text:
        val cuda = self.probe_cuda()
        val rocm = self.probe_rocm()
        val opencl = self.probe_opencl()
        val cpu_x86 = self.probe_cpu_simd_x86()
        val cpu_arm = self.probe_cpu_simd_arm()
        val cpu_riscv = self.probe_cpu_simd_riscv()
        val cpu = self.probe_cpu()
        var selected = cpu
        if cuda.status == BackendStatus.Initialized:
            selected = cuda
        elif rocm.status == BackendStatus.Initialized:
            selected = rocm
        elif opencl.status == BackendStatus.Initialized:
            selected = opencl
        elif cpu_x86.status == BackendStatus.Initialized:
            selected = cpu_x86
        elif cpu_arm.status == BackendStatus.Initialized:
            selected = cpu_arm
        elif cpu_riscv.status == BackendStatus.Initialized:
            selected = cpu_riscv
        "runtime_evidence selected={selected.selected_name};status={backend_status_text(selected.status)};compute={selected.has_compute};graphics={selected.has_graphics};present={selected.has_present};device={selected.device_name};driver={selected.driver_version};memory_mb={selected.memory_mb};reason={selected.reason}"

    fn probe_optix(self) -> BackendProbeResult:
        var r = BackendProbeResult.unavailable(BACKEND_OPTIX, "OptiX is ray tracing only and has no Engine2D raster backend")
        r.api_name = "optix"
        r.feature_gate = "optix_2d_raster_unsupported"
        r.shader_format = "ptx"
        r.has_compute = true
        r.has_graphics = false
        r.has_present = false
        r

    fn probe_all_summary(self) -> text:
        self.probe_cpu().summary() + " | " + self.probe_cpu_simd().summary() + " | " + self.probe_cpu_simd_arch_summary() + " | " + self.probe_vulkan().summary() + " | " + self.probe_cuda().summary() + " | " + self.probe_metal().summary() + " | " + self.probe_opencl().summary() + " | " + self.probe_rocm().summary() + " | " + self.probe_webgpu().summary() + " | " + self.probe_optix().summary() + " | " + self.probe_runtime_evidence_summary()

class StrictBackendFactory:
    allow_fallback: bool

    static fn strict() -> StrictBackendFactory:
        StrictBackendFactory(allow_fallback: false)

    static fn with_fallback() -> StrictBackendFactory:
        StrictBackendFactory(allow_fallback: true)

    fn create_backend(self, name: text) -> BackendProbeResult:
        val prober = BackendProber.create()
        if name == "cpu":
            return prober.probe_cpu()
        if name == "software":
            return prober.probe_software()
        if name == "cpu_simd":
            return prober.probe_cpu_simd()
        if name == "cpu_simd_x86":
            return prober.probe_cpu_simd_x86()
        if name == "cpu_simd_arm":
            return prober.probe_cpu_simd_arm()
        if name == "cpu_simd_riscv":
            return prober.probe_cpu_simd_riscv()
        if name == "vulkan":
            return prober.probe_vulkan()
        if name == "cuda":
            return prober.probe_cuda()
        if name == "metal":
            return prober.probe_metal()
        if name == "opencl":
            return prober.probe_opencl()
        if name == "rocm":
            return prober.probe_rocm()
        if name == "webgpu":
            return prober.probe_webgpu()
        if name == "optix":
            return prober.probe_optix()
        BackendProbeResult.failed(name, "unknown backend: " + name)
