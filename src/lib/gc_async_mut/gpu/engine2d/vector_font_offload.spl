# Engine2D vector-font offload evidence.
#
# Keeps GPU/session provenance in Engine2D while the shared font rasterizer stays
# usable from nogc text-layout modules.

use std.gpu.engine2d.generated_kernel_dispatch.{
    GENERATED_2D_COPY,
    Generated2DOperationProvenance,
    Generated2DKernelExecutionEvidence,
    Generated2DKernelSubmitResult,
    generated_2d_execution_evidence,
    generated_2d_execution_request,
    generated_2d_operation_provenance,
    generated_2d_submit_result
}
use std.nogc_sync_mut.text_layout.font_rasterizer.{VectorFontAcceleratorStats, vector_font_accelerator_stats}

class VectorFontOffloadEvidence:
    backend_name: text
    width: i64
    height: i64
    generated: Generated2DOperationProvenance
    accelerator: VectorFontAcceleratorStats
    generated_ready: bool
    cpu_preprocess_required: bool
    gpu_glyph_returned: bool
    production_ready: bool
    status_code: text
    reason: text

    static fn create(backend: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64, accelerator: VectorFontAcceleratorStats) -> VectorFontOffloadEvidence:
        val generated = generated_2d_operation_provenance(backend, "vector_font", width, height, runtime_ready, module_ready, args_ptr)
        val gpu_glyph_returned = accelerator.gpu_returned_glyphs > 0 and accelerator.gpu_returned_glyph_pixels > 0
        val status = _vector_font_offload_status(generated, accelerator, gpu_glyph_returned)
        VectorFontOffloadEvidence(
            backend_name: backend,
            width: width,
            height: height,
            generated: generated,
            accelerator: accelerator,
            generated_ready: generated.ready,
            cpu_preprocess_required: generated.cpu_preprocess_required,
            gpu_glyph_returned: gpu_glyph_returned,
            production_ready: status == "gpu-glyph-returned",
            status_code: status,
            reason: _vector_font_offload_reason(generated, accelerator, gpu_glyph_returned)
        )

    fn diagnostic_text() -> text:
        "VectorFontOffloadEvidence[backend={self.backend_name} size={self.width}x{self.height} generated_ready={self.generated_ready.to_text()} cpu_preprocess={self.cpu_preprocess_required.to_text()} gpu_glyph_returned={self.gpu_glyph_returned.to_text()} production_ready={self.production_ready.to_text()} status={self.status_code} reason={self.reason} generated={self.generated.diagnostic_text()}]"

class VectorFontGlyphReadbackEvidence:
    backend_name: text
    width: i64
    height: i64
    args_ptr: i64
    accelerator: VectorFontAcceleratorStats
    submit: Generated2DKernelSubmitResult
    execution: Generated2DKernelExecutionEvidence
    gpu_glyph_returned: bool
    gpu_glyph_readback_matched: bool
    production_ready: bool
    status_code: text
    reason: text

    static fn create(backend: text, width: i64, height: i64, args_ptr: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, runtime_available: bool, backend_submit_ok: bool, readback_available: bool, accelerator: VectorFontAcceleratorStats, glyph_pixels: [u8], actual_checksum: i64) -> VectorFontGlyphReadbackEvidence:
        val request = generated_2d_execution_request(backend, GENERATED_2D_COPY, width, height, module_or_queue_handle, kernel_or_pipeline_handle, args_ptr)
        val submit = generated_2d_submit_result(request, runtime_available, backend_submit_ok)
        val expected_checksum = vector_font_glyph_pixels_checksum(glyph_pixels)
        val execution = generated_2d_execution_evidence(submit, readback_available, expected_checksum, actual_checksum)
        val gpu_glyph_returned = accelerator.gpu_returned_glyphs > 0 and accelerator.gpu_returned_glyph_pixels > 0
        val matched = gpu_glyph_returned and execution.device_executed
        VectorFontGlyphReadbackEvidence(
            backend_name: backend,
            width: width,
            height: height,
            args_ptr: args_ptr,
            accelerator: accelerator,
            submit: submit,
            execution: execution,
            gpu_glyph_returned: gpu_glyph_returned,
            gpu_glyph_readback_matched: matched,
            production_ready: matched,
            status_code: _vector_font_glyph_readback_status(execution, gpu_glyph_returned),
            reason: _vector_font_glyph_readback_reason(execution, gpu_glyph_returned)
        )

    fn diagnostic_text() -> text:
        "VectorFontGlyphReadbackEvidence[backend={self.backend_name} size={self.width}x{self.height} args={self.args_ptr} gpu_glyph_returned={self.gpu_glyph_returned.to_text()} gpu_glyph_readback_matched={self.gpu_glyph_readback_matched.to_text()} production_ready={self.production_ready.to_text()} status={self.status_code} reason={self.reason} execution={self.execution.summary()}]"

fn _vector_font_offload_status(generated: Generated2DOperationProvenance, accelerator: VectorFontAcceleratorStats, gpu_glyph_returned: bool) -> text:
    if not generated.ready:
        return generated.typed_status
    if gpu_glyph_returned:
        return "gpu-glyph-returned"
    if accelerator.cuda_hits > 0 or accelerator.opencl_hits > 0:
        return "gpu-proof-with-cpu-glyph"
    if accelerator.cpu_fallback_hits > 0:
        return "cpu-fallback"
    "awaiting-rasterizer-evidence"

fn _vector_font_offload_reason(generated: Generated2DOperationProvenance, accelerator: VectorFontAcceleratorStats, gpu_glyph_returned: bool) -> text:
    if not generated.ready:
        return generated.reason
    if gpu_glyph_returned:
        return accelerator.unavailable_reason
    if accelerator.unavailable_reason != "":
        return accelerator.unavailable_reason
    if accelerator.cpu_fallback_hits > 0:
        return "vector-font-gpu-glyph-return-missing"
    "vector-font-rasterizer-not-yet-observed"

fn _vector_font_glyph_readback_status(execution: Generated2DKernelExecutionEvidence, gpu_glyph_returned: bool) -> text:
    if not gpu_glyph_returned:
        return "vector-font-glyph-return-missing"
    if execution.device_executed:
        return "vector-font-glyph-readback-matched"
    "vector-font-glyph-" + execution.status_code

fn _vector_font_glyph_readback_reason(execution: Generated2DKernelExecutionEvidence, gpu_glyph_returned: bool) -> text:
    if not gpu_glyph_returned:
        return "vector-font-gpu-glyph-return-missing"
    if execution.device_executed:
        return "vector-font-gpu-readback-matched"
    execution.reason

fn vector_font_glyph_pixels_checksum(glyph_pixels: [u8]) -> i64:
    val pixel_len = glyph_pixels.len()
    if pixel_len == 0:
        return 0
    var checksum: i64 = 0
    var idx: i64 = 0
    while idx < pixel_len:
        val pixel = glyph_pixels[idx] as i64
        checksum = checksum + ((idx + 1) * (pixel + 1))
        idx = idx + 1
    checksum

fn vector_font_offload_evidence(backend: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64, accelerator: VectorFontAcceleratorStats) -> VectorFontOffloadEvidence:
    VectorFontOffloadEvidence.create(backend, width, height, runtime_ready, module_ready, args_ptr, accelerator)

fn vector_font_current_offload_evidence(backend: text, width: i64, height: i64, runtime_ready: bool, module_ready: bool, args_ptr: i64) -> VectorFontOffloadEvidence:
    vector_font_offload_evidence(backend, width, height, runtime_ready, module_ready, args_ptr, vector_font_accelerator_stats())

fn vector_font_glyph_readback_evidence(backend: text, width: i64, height: i64, args_ptr: i64, module_or_queue_handle: i64, kernel_or_pipeline_handle: i64, runtime_available: bool, backend_submit_ok: bool, readback_available: bool, accelerator: VectorFontAcceleratorStats, glyph_pixels: [u8], actual_checksum: i64) -> VectorFontGlyphReadbackEvidence:
    VectorFontGlyphReadbackEvidence.create(backend, width, height, args_ptr, module_or_queue_handle, kernel_or_pipeline_handle, runtime_available, backend_submit_ok, readback_available, accelerator, glyph_pixels, actual_checksum)
