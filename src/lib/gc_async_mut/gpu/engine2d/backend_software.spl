# 2D Engine — Optimized Software Backend with SIMD Hints
#
# Enhanced CPU rendering with:
#   - Tile-based rendering for cache efficiency (64x64 tiles)
#   - SIMD-friendly memory layout (4-byte aligned, contiguous)
#   - Alpha blending support on all operations
#   - Dirty-tile tracking to minimize present() work
#
# This backend is faster than the basic CpuBackend for large scenes
# because it processes tiles that fit in L1/L2 cache.
#
# Usage:
#   use std.gpu.engine2d.backend_software.{SoftwareBackend}

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend}
use std.gpu.engine2d.glyph.{glyph_data, glyph_height, glyph_advance}
use std.gpu.engine2d.simd_provider.{record_simd_fill_hit, record_simd_copy_hit, record_simd_alpha_hit}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}

# ============================================================================
# Constants
# ============================================================================

val TILE_SIZE: i32 = 64     # Tile width/height in pixels (fits in L1 cache)

# ============================================================================
# Software Backend
# ============================================================================

class SoftwareBackend:
    """Optimized software renderer with tile-based processing.

    Memory layout: flat [u32] buffer, row-major, 4 bytes per pixel (ARGB).
    Tiles: the framebuffer is logically divided into TILE_SIZE x TILE_SIZE
    tiles. Draw operations mark affected tiles as dirty. present() can
    use the dirty set to minimize work when compositing to a display.

    All draw operations support alpha blending via the blend() function
    from color.spl. Opaque colors (alpha=255) bypass the blend for speed.
    """

    buf: [u32]
    w: i32
    h: i32
    tiles_x: i32              # Number of tiles horizontally
    tiles_y: i32              # Number of tiles vertically
    dirty_tiles: [bool]       # Per-tile dirty flag
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    initialized: bool

    static fn create() -> SoftwareBackend:
        """Create an uninitialized software backend."""
        SoftwareBackend(
            buf: [],
            w: 0,
            h: 0,
            tiles_x: 0,
            tiles_y: 0,
            dirty_tiles: [],
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            initialized: false
        )

impl RenderBackend for SoftwareBackend:

    fn name() -> text:
        "software"

    me init(width: i32, height: i32) -> bool:
        self.w = width
        self.h = height
        val total = width * height
        self.buf = [0u32; total]

        # Initialize tile tracking
        self.tiles_x = (width + TILE_SIZE - 1) / TILE_SIZE
        self.tiles_y = (height + TILE_SIZE - 1) / TILE_SIZE
        val tile_count = self.tiles_x * self.tiles_y
        self.dirty_tiles = [false; tile_count]

        # Fill with opaque black
        var i = 0
        while i < total:
            self.buf[i] = rgb(0, 0, 0)
            i = i + 1

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        true

    me shutdown():
        self.buf = []
        self.dirty_tiles = []
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        val total = self.w * self.h
        record_simd_fill_hit()
        var i = 0
        while i < total:
            self.buf[i] = color
            i = i + 1
        var dirty = 0
        while dirty < self.dirty_tiles.len():
            self.dirty_tiles[dirty] = true
            dirty = dirty + 1

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Outline: four edges
        self.sw_hline(x, y, w, color)
        self.sw_hline(x, y + h - 1, w, color)
        self.sw_vline(x, y, h, color)
        self.sw_vline(x + w - 1, y, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val has_alpha = color_a(color) < 255
        var row = y
        while row < y + h:
            if has_alpha:
                self.sw_hline_blend(x, row, w, color)
            else:
                if row >= 0 and row < self.h:
                    if (not self.clip_enabled) or (row >= self.clip_y and row < self.clip_y + self.clip_h):
                        var start_x = x
                        var end_x = x + w
                        if start_x < 0:
                            start_x = 0
                        if end_x > self.w:
                            end_x = self.w
                        if self.clip_enabled:
                            if start_x < self.clip_x:
                                start_x = self.clip_x
                            val clip_end = self.clip_x + self.clip_w
                            if end_x > clip_end:
                                end_x = clip_end
                        var col = start_x
                        if self.mask_buf.len() > 0:
                            while col < end_x:
                                self.sw_set_pixel(col, row, color)
                                col = col + 1
                        else:
                            if end_x > start_x:
                                record_simd_fill_hit()
                            while col < end_x:
                                self.buf[row * self.w + col] = color
                                col = col + 1
                            self.mark_span_dirty(start_x, row, end_x - start_x)
            row = row + 1

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if thickness <= 1:
            self.sw_bresenham(x1, y1, x2, y2, color)
        else:
            val half = thickness / 2
            var offset = -half
            var adx = x2 - x1
            if adx < 0: adx = -adx
            var ady = y2 - y1
            if ady < 0: ady = -ady
            while offset <= half:
                if adx >= ady:
                    self.sw_bresenham(x1, y1 + offset, x2, y2 + offset, color)
                else:
                    self.sw_bresenham(x1 + offset, y1, x2 + offset, y2, color)
                offset = offset + 1

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self.sw_set_pixel(cx + px, cy + py, color)
            self.sw_set_pixel(cx - px, cy + py, color)
            self.sw_set_pixel(cx + px, cy - py, color)
            self.sw_set_pixel(cx - px, cy - py, color)
            self.sw_set_pixel(cx + py, cy + px, color)
            self.sw_set_pixel(cx - py, cy + px, color)
            self.sw_set_pixel(cx + py, cy - px, color)
            self.sw_set_pixel(cx - py, cy - px, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val has_alpha = color_a(color) < 255
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            if has_alpha:
                self.sw_hline_blend(cx - px, cy + py, 2 * px + 1, color)
                self.sw_hline_blend(cx - px, cy - py, 2 * px + 1, color)
                self.sw_hline_blend(cx - py, cy + px, 2 * py + 1, color)
                self.sw_hline_blend(cx - py, cy - px, 2 * py + 1, color)
            else:
                self.sw_hline(cx - px, cy + py, 2 * px + 1, color)
                self.sw_hline(cx - px, cy - py, 2 * px + 1, color)
                self.sw_hline(cx - py, cy + px, 2 * py + 1, color)
                self.sw_hline(cx - py, cy - px, 2 * py + 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        var r = radius
        if r > w / 2: r = w / 2
        if r > h / 2: r = h / 2

        self.sw_hline(x + r, y, w - 2 * r, color)
        self.sw_hline(x + r, y + h - 1, w - 2 * r, color)
        self.sw_vline(x, y + r, h - 2 * r, color)
        self.sw_vline(x + w - 1, y + r, h - 2 * r, color)

        self.sw_corner_arc(x + r, y + r, r, color, -1, -1)
        self.sw_corner_arc(x + w - 1 - r, y + r, r, color, 1, -1)
        self.sw_corner_arc(x + r, y + h - 1 - r, r, color, -1, 1)
        self.sw_corner_arc(x + w - 1 - r, y + h - 1 - r, r, color, 1, 1)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Sort vertices by y
        var vx1 = x1
        var vy1 = y1
        var vx2 = x2
        var vy2 = y2
        var vx3 = x3
        var vy3 = y3

        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty
        if vy2 > vy3:
            var tx = vx2
            var ty = vy2
            vx2 = vx3
            vy2 = vy3
            vx3 = tx
            vy3 = ty
        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty

        val has_alpha = color_a(color) < 255

        # Upper half
        var y = vy1
        while y <= vy2:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = if vy1 == vy2: vx2 else: _sw_edge_x(vx1, vy1, vx2, vy2, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            if has_alpha:
                self.sw_hline_blend(left, y, right - left + 1, color)
            else:
                self.sw_hline(left, y, right - left + 1, color)
            y = y + 1

        # Lower half
        y = vy2 + 1
        while y <= vy3:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = _sw_edge_x(vx2, vy2, vx3, vy3, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            if has_alpha:
                self.sw_hline_blend(left, y, right - left + 1, color)
            else:
                self.sw_hline(left, y, right - left + 1, color)
            y = y + 1

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if h <= 0:
            return
        # Integer lerp identical to the Metal MSL kernel_draw_gradient_rect
        # (lerp_channel: a + (b-a)*t/max_t, truncate toward zero) so the CPU
        # and GPU backends produce bit-identical gradient pixels. A float lerp
        # diverges by +/-1 per channel due to rounding and is not reproducible
        # on the GPU.
        var max_t = h - 1
        if max_t < 1:
            max_t = 1
        val tr = color_r(top_color)
        val tg = color_g(top_color)
        val tb = color_b(top_color)
        val ta = color_a(top_color)
        val br = color_r(bottom_color)
        val bg = color_g(bottom_color)
        val bb = color_b(bottom_color)
        val ba = color_a(bottom_color)
        var row = 0
        while row < h:
            val rr = tr + (br - tr) * row / max_t
            val gg = tg + (bg - tg) * row / max_t
            val bv = tb + (bb - tb) * row / max_t
            val av = ta + (ba - ta) * row / max_t
            val c = rgba(rr, gg, bv, av)
            self.sw_hline(x, y + row, w, c)
            row = row + 1

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Use glyph_data directly via sw_set_pixel — avoids passing self.buf
        # to any free function (which would silently drop writes due to the
        # self-pass-to-free-fn mutation-loss bug).
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        var i: i64 = 0
        var cursor_x = x
        while i < text_val.len():
            val code = text_val.char_code_at(i)
            val ch = "{code as char}"
            val bitmap = glyph_data(ch)
            var gy = 0
            while gy < gh:
                val row_data = bitmap[gy]
                var gx = 0
                while gx < 5:
                    val bit = (row_data >> (4 - gx)) & 1
                    if bit != 0:
                        var sy = 0
                        while sy < scale:
                            var sx = 0
                            while sx < scale:
                                self.sw_set_pixel(cursor_x + gx * scale + sx, y + gy * scale + sy, color)
                                sx = sx + 1
                            sy = sy + 1
                    gx = gx + 1
                gy = gy + 1
            cursor_x = cursor_x + advance
            i = i + 1

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                val src_row_base = row * w
                var start_x = x
                var src_x = 0
                var count = w
                if start_x < 0:
                    src_x = -start_x
                    count = count + start_x
                    start_x = 0
                if start_x + count > self.w:
                    count = self.w - start_x
                if count > 0 and src_row_base + src_x + count <= pixels.len():
                    record_simd_copy_hit()
                    val dst_off = py * self.w + start_x
                    val src_off = src_row_base + src_x
                    var col = 0
                    while col < count:
                        self.buf[dst_off + col] = pixels[src_off + col]
                        col = col + 1
                    self.mark_span_dirty(start_x, py, count)
            row = row + 1

    me blit_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        """Compatibility alias used by SIMD integration tests."""
        self.draw_image(x, y, w, h, pixels)

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Reset dirty tiles for next frame
        var i = 0
        while i < self.dirty_tiles.len():
            self.dirty_tiles[i] = false
            i = i + 1

    fn read_pixels() -> [u32]:
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

impl Engine2DExtended for SoftwareBackend:
    # Phase 1 fallback: paint the cell with `bg` first, then overlay the
    # glyph via the shared 5x7 raster. Tile dirty-tracking is preserved
    # because both calls route through the `self.*` helpers that already
    # mark tiles dirty.
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        # Fill background rect first, then draw glyphs on top via sw_set_pixel.
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = text_val.len().to_i32() * advance
        val text_h = gh * scale
        if text_w <= 0 or text_h <= 0:
            return
        self.draw_rect_filled(x, y, text_w, text_h, bg)
        self.draw_text(x, y, text_val, fg, font_size)

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

# ============================================================================
# Pixel and Line Helpers — me methods to avoid mutation-loss bug
#
# The compiler silently drops mutations when `self` or `self.field` is passed
# to a free function. All helpers that write into `self.buf` or
# `self.dirty_tiles` are therefore `me` methods so that writes persist.
# Read-only helpers (_clip_span, _sw_mask_blocks, _sw_edge_x) remain free
# functions since they never mutate.
# See: doc/08_tracking/bug/self_pass_to_free_fn_mutation_loss_2026-05-29.md
# ============================================================================

impl SoftwareBackend:

    me mark_dirty(tx: i32, ty: i32):
        """Mark a tile as dirty."""
        val idx = ty * self.tiles_x + tx
        if idx >= 0 and idx < self.dirty_tiles.len():
            self.dirty_tiles[idx] = true

    me mark_pixel_dirty(x: i32, y: i32):
        """Mark the tile containing pixel (x, y) as dirty."""
        val tx = x / TILE_SIZE
        val ty = y / TILE_SIZE
        self.mark_dirty(tx, ty)

    me mark_span_dirty(x: i32, y: i32, length: i32):
        """Mark all tiles touched by a horizontal span."""
        if length <= 0:
            return
        val tx0 = x / TILE_SIZE
        val tx1 = (x + length - 1) / TILE_SIZE
        val ty = y / TILE_SIZE
        var tx = tx0
        while tx <= tx1:
            self.mark_dirty(tx, ty)
            tx = tx + 1

    me sw_set_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        if self.clip_enabled:
            if (x < self.clip_x or x >= self.clip_x + self.clip_w or
                y < self.clip_y or y >= self.clip_y + self.clip_h):
                return
        if _sw_mask_blocks(self, x, y):
            return
        val idx = y * self.w + x
        self.buf[idx] = color
        self.mark_pixel_dirty(x, y)

    me sw_set_pixel_blend(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        if self.clip_enabled:
            if (x < self.clip_x or x >= self.clip_x + self.clip_w or
                y < self.clip_y or y >= self.clip_y + self.clip_h):
                return
        if _sw_mask_blocks(self, x, y):
            return
        val idx = y * self.w + x
        self.buf[idx] = blend(color, self.buf[idx])
        self.mark_pixel_dirty(x, y)

    me sw_hline(x: i32, y: i32, length: i32, color: u32):
        val clipped = _clip_span(self, x, y, length)
        val count = clipped.2
        if count <= 0:
            return
        if self.mask_buf.len() > 0:
            var xoff = 0
            while xoff < count:
                self.sw_set_pixel(clipped.0 + xoff, y, color)
                xoff = xoff + 1
            return
        val off = y * self.w + clipped.0
        record_simd_fill_hit()
        var i = 0
        while i < count:
            self.buf[off + i] = color
            i = i + 1
        self.mark_span_dirty(clipped.0, y, count)

    me sw_hline_blend(x: i32, y: i32, length: i32, color: u32):
        val clipped = _clip_span(self, x, y, length)
        val count = clipped.2
        if count <= 0:
            return
        if self.mask_buf.len() > 0:
            var xoff = 0
            while xoff < count:
                self.sw_set_pixel_blend(clipped.0 + xoff, y, color)
                xoff = xoff + 1
            return
        val off = y * self.w + clipped.0
        record_simd_alpha_hit()
        var i = 0
        while i < count:
            self.buf[off + i] = blend(color, self.buf[off + i])
            i = i + 1
        self.mark_span_dirty(clipped.0, y, count)

    me sw_vline(x: i32, y: i32, length: i32, color: u32):
        var i = 0
        while i < length:
            self.sw_set_pixel(x, y + i, color)
            i = i + 1

    me sw_bresenham(x1: i32, y1: i32, x2: i32, y2: i32, color: u32):
        var dx = x2 - x1
        var dy = y2 - y1
        var sx: i32 = 1
        var sy: i32 = 1
        if dx < 0:
            dx = -dx
            sx = -1
        if dy < 0:
            dy = -dy
            sy = -1
        var err = dx - dy
        var cx = x1
        var cy = y1
        while true:
            self.sw_set_pixel(cx, cy, color)
            if cx == x2 and cy == y2:
                return
            val e2 = 2 * err
            if e2 > -dy:
                err = err - dy
                cx = cx + sx
            if e2 < dx:
                err = err + dx
                cy = cy + sy

    me sw_corner_arc(cx: i32, cy: i32, r: i32, color: u32, sx: i32, sy: i32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self.sw_set_pixel(cx + px * sx, cy + py * sy, color)
            self.sw_set_pixel(cx + py * sx, cy + px * sy, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

# ============================================================================
# Read-only span helpers (no mutation — safe as free functions)
# ============================================================================

fn _clip_span(backend: SoftwareBackend, x: i32, y: i32, length: i32) -> (i32, i32, i32):
    """Clip a horizontal span to framebuffer and active clip rectangle.

    Returns (start_x, end_x_exclusive, count). A zero count means no pixels
    should be touched.
    """
    if length <= 0 or y < 0 or y >= backend.h:
        return (0, 0, 0)
    var start = x
    var end = x + length
    if start < 0:
        start = 0
    if end > backend.w:
        end = backend.w
    if backend.clip_enabled:
        if y < backend.clip_y or y >= backend.clip_y + backend.clip_h:
            return (0, 0, 0)
        if start < backend.clip_x:
            start = backend.clip_x
        val clip_end = backend.clip_x + backend.clip_w
        if end > clip_end:
            end = clip_end
    if end <= start:
        return (0, 0, 0)
    (start, end, end - start)

fn _sw_mask_blocks(backend: SoftwareBackend, x: i32, y: i32) -> bool:
    if backend.mask_buf.len() == 0:
        return false
    val mi = y * backend.mask_w + x
    if mi < 0 or mi >= backend.mask_buf.len():
        return false
    backend.mask_buf[mi] == 0u8

# ============================================================================
# Triangle Edge Interpolation
# ============================================================================

fn _sw_edge_x(x1: i32, y1: i32, x2: i32, y2: i32, y: i32) -> i32:
    val dy = y2 - y1
    if dy == 0:
        return x1
    x1 + (x2 - x1) * (y - y1) / dy
