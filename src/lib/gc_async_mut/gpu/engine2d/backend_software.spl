#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# 2D Engine — Optimized Software Backend with SIMD Hints
#
# Enhanced CPU rendering with:
#   - Tile-based rendering for cache efficiency (64x64 tiles)
#   - SIMD-friendly memory layout (4-byte aligned, contiguous)
#   - Alpha blending support on all operations
#   - Dirty-tile tracking to minimize present() work
#
# This backend is faster than the basic CpuBackend for large scenes
# because it processes tiles that fit in L1/L2 cache.
#
# Usage:
#   use std.gpu.engine2d.backend_software.{SoftwareBackend}

use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend, lerp_color}
use std.gpu.engine2d.glyph.{render_text_to_buffer}

# ============================================================================
# Constants
# ============================================================================

val TILE_SIZE: i32 = 64     # Tile width/height in pixels (fits in L1 cache)

# ============================================================================
# Software Backend
# ============================================================================

class SoftwareBackend:
    """Optimized software renderer with tile-based processing.

    Memory layout: flat [u32] buffer, row-major, 4 bytes per pixel (ARGB).
    Tiles: the framebuffer is logically divided into TILE_SIZE x TILE_SIZE
    tiles. Draw operations mark affected tiles as dirty. present() can
    use the dirty set to minimize work when compositing to a display.

    All draw operations support alpha blending via the blend() function
    from color.spl. Opaque colors (alpha=255) bypass the blend for speed.
    """

    buf: [u32]
    w: i32
    h: i32
    tiles_x: i32              # Number of tiles horizontally
    tiles_y: i32              # Number of tiles vertically
    dirty_tiles: [bool]       # Per-tile dirty flag
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    initialized: bool

    static fn create() -> SoftwareBackend:
        """Create an uninitialized software backend."""
        SoftwareBackend(
            buf: [],
            w: 0,
            h: 0,
            tiles_x: 0,
            tiles_y: 0,
            dirty_tiles: [],
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            initialized: false
        )

impl RenderBackend for SoftwareBackend:

    fn name() -> text:
        "software"

    fn init(width: i32, height: i32) -> bool:
        self.w = width
        self.h = height
        val total = width * height
        self.buf = [0u32; total]

        # Initialize tile tracking
        self.tiles_x = (width + TILE_SIZE - 1) / TILE_SIZE
        self.tiles_y = (height + TILE_SIZE - 1) / TILE_SIZE
        val tile_count = self.tiles_x * self.tiles_y
        self.dirty_tiles = [false; tile_count]

        # Fill with opaque black
        var i = 0
        while i < total:
            self.buf[i] = rgb(0, 0, 0)
            i = i + 1

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        true

    fn shutdown():
        self.buf = []
        self.dirty_tiles = []
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        # Tile-based clear: process each tile as a contiguous block
        var ty = 0
        while ty < self.tiles_y:
            var tx = 0
            while tx < self.tiles_x:
                _clear_tile(self, tx, ty, color)
                _mark_dirty(self, tx, ty)
                tx = tx + 1
            ty = ty + 1

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Outline: four edges
        _sw_hline(self, x, y, w, color)
        _sw_hline(self, x, y + h - 1, w, color)
        _sw_vline(self, x, y, h, color)
        _sw_vline(self, x + w - 1, y, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val has_alpha = color_a(color) < 255
        var row = y
        while row < y + h:
            if has_alpha:
                _sw_hline_blend(self, x, row, w, color)
            else:
                _sw_hline(self, x, row, w, color)
            row = row + 1

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if thickness <= 1:
            _sw_bresenham(self, x1, y1, x2, y2, color)
        else:
            val half = thickness / 2
            var offset = -half
            var adx = x2 - x1
            if adx < 0: adx = -adx
            var ady = y2 - y1
            if ady < 0: ady = -ady
            while offset <= half:
                if adx >= ady:
                    _sw_bresenham(self, x1, y1 + offset, x2, y2 + offset, color)
                else:
                    _sw_bresenham(self, x1 + offset, y1, x2 + offset, y2, color)
                offset = offset + 1

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            _sw_set_pixel(self, cx + px, cy + py, color)
            _sw_set_pixel(self, cx - px, cy + py, color)
            _sw_set_pixel(self, cx + px, cy - py, color)
            _sw_set_pixel(self, cx - px, cy - py, color)
            _sw_set_pixel(self, cx + py, cy + px, color)
            _sw_set_pixel(self, cx - py, cy + px, color)
            _sw_set_pixel(self, cx + py, cy - px, color)
            _sw_set_pixel(self, cx - py, cy - px, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        val has_alpha = color_a(color) < 255
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            if has_alpha:
                _sw_hline_blend(self, cx - px, cy + py, 2 * px + 1, color)
                _sw_hline_blend(self, cx - px, cy - py, 2 * px + 1, color)
                _sw_hline_blend(self, cx - py, cy + px, 2 * py + 1, color)
                _sw_hline_blend(self, cx - py, cy - px, 2 * py + 1, color)
            else:
                _sw_hline(self, cx - px, cy + py, 2 * px + 1, color)
                _sw_hline(self, cx - px, cy - py, 2 * px + 1, color)
                _sw_hline(self, cx - py, cy + px, 2 * py + 1, color)
                _sw_hline(self, cx - py, cy - px, 2 * py + 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        var r = radius
        if r > w / 2: r = w / 2
        if r > h / 2: r = h / 2

        _sw_hline(self, x + r, y, w - 2 * r, color)
        _sw_hline(self, x + r, y + h - 1, w - 2 * r, color)
        _sw_vline(self, x, y + r, h - 2 * r, color)
        _sw_vline(self, x + w - 1, y + r, h - 2 * r, color)

        _sw_corner_arc(self, x + r, y + r, r, color, -1, -1)
        _sw_corner_arc(self, x + w - 1 - r, y + r, r, color, 1, -1)
        _sw_corner_arc(self, x + r, y + h - 1 - r, r, color, -1, 1)
        _sw_corner_arc(self, x + w - 1 - r, y + h - 1 - r, r, color, 1, 1)

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Sort vertices by y
        var vx1 = x1
        var vy1 = y1
        var vx2 = x2
        var vy2 = y2
        var vx3 = x3
        var vy3 = y3

        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty
        if vy2 > vy3:
            var tx = vx2
            var ty = vy2
            vx2 = vx3
            vy2 = vy3
            vx3 = tx
            vy3 = ty
        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty

        val has_alpha = color_a(color) < 255

        # Upper half
        var y = vy1
        while y <= vy2:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = _sw_edge_x(vx1, vy1, vx2, vy2, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            if has_alpha:
                _sw_hline_blend(self, left, y, right - left + 1, color)
            else:
                _sw_hline(self, left, y, right - left + 1, color)
            y = y + 1

        # Lower half
        y = vy2 + 1
        while y <= vy3:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = _sw_edge_x(vx2, vy2, vx3, vy3, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            if has_alpha:
                _sw_hline_blend(self, left, y, right - left + 1, color)
            else:
                _sw_hline(self, left, y, right - left + 1, color)
            y = y + 1

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if h <= 0:
            return
        var row = 0
        while row < h:
            val t = _i32_to_f32(row) / _i32_to_f32(h - 1)
            val c = lerp_color(top_color, bottom_color, t)
            _sw_hline(self, x, y + row, w, c)
            row = row + 1

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        render_text_to_buffer(self.buf, self.w, self.h, x, y, text_val, color, font_size)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row = 0
        while row < h:
            var col = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx < pixels.len():
                    val px = x + col
                    val py = y + row
                    val c = pixels[src_idx]
                    val a = color_a(c)
                    if a == 255:
                        _sw_set_pixel(self, px, py, c)
                    else if a > 0:
                        _sw_set_pixel_blend(self, px, py, c)
                col = col + 1
            row = row + 1

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me present():
        # Reset dirty tiles for next frame
        var i = 0
        while i < self.dirty_tiles.len():
            self.dirty_tiles[i] = false
            i = i + 1

    fn read_pixels() -> [u32]:
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

# ============================================================================
# Tile Operations
# ============================================================================

fn _clear_tile(backend: SoftwareBackend, tx: i32, ty: i32, color: u32):
    """Clear a single tile to a solid color (cache-friendly)."""
    val start_x = tx * TILE_SIZE
    val start_y = ty * TILE_SIZE
    var end_x = start_x + TILE_SIZE
    var end_y = start_y + TILE_SIZE
    if end_x > backend.w: end_x = backend.w
    if end_y > backend.h: end_y = backend.h

    var y = start_y
    while y < end_y:
        val row_base = y * backend.w
        var x = start_x
        while x < end_x:
            backend.buf[row_base + x] = color
            x = x + 1
        y = y + 1

fn _mark_dirty(backend: SoftwareBackend, tx: i32, ty: i32):
    """Mark a tile as dirty."""
    val idx = ty * backend.tiles_x + tx
    if idx >= 0 and idx < backend.dirty_tiles.len():
        backend.dirty_tiles[idx] = true

fn _mark_pixel_dirty(backend: SoftwareBackend, x: i32, y: i32):
    """Mark the tile containing pixel (x, y) as dirty."""
    val tx = x / TILE_SIZE
    val ty = y / TILE_SIZE
    _mark_dirty(backend, tx, ty)

# ============================================================================
# Pixel Operations
# ============================================================================

fn _sw_set_pixel(backend: SoftwareBackend, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return
    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return
    val idx = y * backend.w + x
    backend.buf[idx] = color
    _mark_pixel_dirty(backend, x, y)

fn _sw_set_pixel_blend(backend: SoftwareBackend, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return
    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return
    val idx = y * backend.w + x
    backend.buf[idx] = blend(color, backend.buf[idx])
    _mark_pixel_dirty(backend, x, y)

# ============================================================================
# Line Drawing
# ============================================================================

fn _sw_hline(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    var i = 0
    while i < length:
        _sw_set_pixel(backend, x + i, y, color)
        i = i + 1

fn _sw_hline_blend(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    var i = 0
    while i < length:
        _sw_set_pixel_blend(backend, x + i, y, color)
        i = i + 1

fn _sw_vline(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    var i = 0
    while i < length:
        _sw_set_pixel(backend, x, y + i, color)
        i = i + 1

fn _sw_bresenham(backend: SoftwareBackend, x1: i32, y1: i32, x2: i32, y2: i32, color: u32):
    var dx = x2 - x1
    var dy = y2 - y1
    var sx: i32 = 1
    var sy: i32 = 1
    if dx < 0:
        dx = -dx
        sx = -1
    if dy < 0:
        dy = -dy
        sy = -1
    var err = dx - dy
    var cx = x1
    var cy = y1
    while true:
        _sw_set_pixel(backend, cx, cy, color)
        if cx == x2 and cy == y2:
            return
        val e2 = 2 * err
        if e2 > -dy:
            err = err - dy
            cx = cx + sx
        if e2 < dx:
            err = err + dx
            cy = cy + sy

# ============================================================================
# Corner Arc
# ============================================================================

fn _sw_corner_arc(backend: SoftwareBackend, cx: i32, cy: i32, r: i32, color: u32, sx: i32, sy: i32):
    var px = r
    var py = 0
    var d = 1 - r
    while px >= py:
        _sw_set_pixel(backend, cx + px * sx, cy + py * sy, color)
        _sw_set_pixel(backend, cx + py * sx, cy + px * sy, color)
        py = py + 1
        if d <= 0:
            d = d + 2 * py + 1
        else:
            px = px - 1
            d = d + 2 * py - 2 * px + 1

# ============================================================================
# Triangle Edge Interpolation
# ============================================================================

fn _sw_edge_x(x1: i32, y1: i32, x2: i32, y2: i32, y: i32) -> i32:
    val dy = y2 - y1
    if dy == 0:
        return x1
    x1 + (x2 - x1) * (y - y1) / dy

# ============================================================================
# Conversion Helpers
# ============================================================================

fn _i32_to_f32(v: i32) -> f32:
    v as f32
