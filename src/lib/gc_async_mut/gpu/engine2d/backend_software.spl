# 2D Engine — Optimized Software Backend with SIMD Hints
#
# Enhanced CPU rendering with:
#   - Tile-based rendering for cache efficiency (64x64 tiles)
#   - SIMD-friendly memory layout (4-byte aligned, contiguous)
#   - Alpha blending support on all operations
#   - Dirty-tile tracking to minimize present() work
#
# This backend is faster than the basic CpuBackend for large scenes
# because it processes tiles that fit in L1/L2 cache.
#
# Usage:
#   use std.gpu.engine2d.backend_software.{SoftwareBackend}

use std.gpu.engine2d.backend.{RenderBackend, Engine2DExtended}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend, lerp_color}
use std.gpu.engine2d.glyph.{glyph_data, glyph_height, glyph_advance, render_text_to_buffer}
use std.gpu.engine2d.simd_kernels.{fill_span, copy_span, alpha_blend_span}
use std.gpu.engine2d.backend_emu.{
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}

# ============================================================================
# Constants
# ============================================================================

val TILE_SIZE: i32 = 64     # Tile width/height in pixels (fits in L1 cache)

# ============================================================================
# Software Backend
# ============================================================================

class SoftwareBackend:
    """Optimized software renderer with tile-based processing.

    Memory layout: flat [u32] buffer, row-major, 4 bytes per pixel (ARGB).
    Tiles: the framebuffer is logically divided into TILE_SIZE x TILE_SIZE
    tiles. Draw operations mark affected tiles as dirty. present() can
    use the dirty set to minimize work when compositing to a display.

    All draw operations support alpha blending via the blend() function
    from color.spl. Opaque colors (alpha=255) bypass the blend for speed.
    """

    buf: [u32]
    w: i32
    h: i32
    tiles_x: i32              # Number of tiles horizontally
    tiles_y: i32              # Number of tiles vertically
    dirty_tiles: [bool]       # Per-tile dirty flag
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    mask_buf: [u8]
    mask_w: i32
    mask_h: i32
    initialized: bool

    static fn create() -> SoftwareBackend:
        """Create an uninitialized software backend."""
        SoftwareBackend(
            buf: [],
            w: 0,
            h: 0,
            tiles_x: 0,
            tiles_y: 0,
            dirty_tiles: [],
            clip_x: 0,
            clip_y: 0,
            clip_w: 0,
            clip_h: 0,
            clip_enabled: false,
            mask_buf: [],
            mask_w: 0,
            mask_h: 0,
            initialized: false
        )

impl RenderBackend for SoftwareBackend:

    fn name() -> text:
        "software"

    me init(width: i32, height: i32) -> bool:
        self.w = width
        self.h = height
        val total = width * height
        self.buf = [0u32; total]

        # Initialize tile tracking
        self.tiles_x = (width + TILE_SIZE - 1) / TILE_SIZE
        self.tiles_y = (height + TILE_SIZE - 1) / TILE_SIZE
        val tile_count = self.tiles_x * self.tiles_y
        self.dirty_tiles = [false; tile_count]

        # Fill with opaque black
        var i = 0
        while i < total:
            self.buf[i] = rgb(0, 0, 0)
            i = i + 1

        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.initialized = true
        true

    me shutdown():
        self.buf = []
        self.dirty_tiles = []
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0
        self.w = 0
        self.h = 0
        self.initialized = false

    me clear(color: u32):
        var i = 0
        val total = self.w * self.h
        while i < total:
            self.buf[i] = color
            i = i + 1
        var dirty = 0
        while dirty < self.dirty_tiles.len():
            self.dirty_tiles[dirty] = true
            dirty = dirty + 1

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Outline: four edges
        self.draw_rect_filled(x, y, w, 1, color)
        self.draw_rect_filled(x, y + h - 1, w, 1, color)
        self.draw_rect_filled(x, y, 1, h, color)
        self.draw_rect_filled(x + w - 1, y, 1, h, color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        val has_alpha = color_a(color) < 255
        var row = y
        while row < y + h:
            if row >= 0 and row < self.h:
                if (not self.clip_enabled) or (row >= self.clip_y and row < self.clip_y + self.clip_h):
                    var start_x = x
                    var end_x = x + w
                    if start_x < 0:
                        start_x = 0
                    if end_x > self.w:
                        end_x = self.w
                    if self.clip_enabled:
                        if start_x < self.clip_x:
                            start_x = self.clip_x
                        val clip_end = self.clip_x + self.clip_w
                        if end_x > clip_end:
                            end_x = clip_end
                    var col = start_x
                    while col < end_x:
                        val idx = row * self.w + col
                        if has_alpha:
                            self.buf[idx] = blend(color, self.buf[idx])
                        else:
                            self.buf[idx] = color
                        col = col + 1
                    _mark_span_dirty(self, start_x, row, end_x - start_x)
            row = row + 1

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        var dx = x2 - x1
        var dy = y2 - y1
        var sx: i32 = 1
        var sy: i32 = 1
        if dx < 0:
            dx = -dx
            sx = -1
        if dy < 0:
            dy = -dy
            sy = -1
        var err = dx - dy
        var cx = x1
        var cy = y1
        val size = if thickness > 1 then thickness else 1
        val half = size / 2
        while true:
            self.draw_rect_filled(cx - half, cy - half, size, size, color)
            if cx == x2 and cy == y2:
                return
            val e2 = 2 * err
            if e2 > -dy:
                err = err - dy
                cx = cx + sx
            if e2 < dx:
                err = err + dx
                cy = cy + sy

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self.draw_rect_filled(cx + px, cy + py, 1, 1, color)
            self.draw_rect_filled(cx - px, cy + py, 1, 1, color)
            self.draw_rect_filled(cx + px, cy - py, 1, 1, color)
            self.draw_rect_filled(cx - px, cy - py, 1, 1, color)
            self.draw_rect_filled(cx + py, cy + px, 1, 1, color)
            self.draw_rect_filled(cx - py, cy + px, 1, 1, color)
            self.draw_rect_filled(cx + py, cy - px, 1, 1, color)
            self.draw_rect_filled(cx - py, cy - px, 1, 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self.draw_rect_filled(cx - px, cy + py, 2 * px + 1, 1, color)
            self.draw_rect_filled(cx - px, cy - py, 2 * px + 1, 1, color)
            self.draw_rect_filled(cx - py, cy + px, 2 * py + 1, 1, color)
            self.draw_rect_filled(cx - py, cy - px, 2 * py + 1, 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        var r = radius
        if r > w / 2: r = w / 2
        if r > h / 2: r = h / 2

        self.draw_rect_filled(x + r, y, w - 2 * r, 1, color)
        self.draw_rect_filled(x + r, y + h - 1, w - 2 * r, 1, color)
        self.draw_rect_filled(x, y + r, 1, h - 2 * r, color)
        self.draw_rect_filled(x + w - 1, y + r, 1, h - 2 * r, color)

        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self.draw_rect_filled(x + r - px, y + r - py, 1, 1, color)
            self.draw_rect_filled(x + r - py, y + r - px, 1, 1, color)
            self.draw_rect_filled(x + w - 1 - r + px, y + r - py, 1, 1, color)
            self.draw_rect_filled(x + w - 1 - r + py, y + r - px, 1, 1, color)
            self.draw_rect_filled(x + r - px, y + h - 1 - r + py, 1, 1, color)
            self.draw_rect_filled(x + r - py, y + h - 1 - r + px, 1, 1, color)
            self.draw_rect_filled(x + w - 1 - r + px, y + h - 1 - r + py, 1, 1, color)
            self.draw_rect_filled(x + w - 1 - r + py, y + h - 1 - r + px, 1, 1, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        # Sort vertices by y
        var vx1 = x1
        var vy1 = y1
        var vx2 = x2
        var vy2 = y2
        var vx3 = x3
        var vy3 = y3

        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty
        if vy2 > vy3:
            var tx = vx2
            var ty = vy2
            vx2 = vx3
            vy2 = vy3
            vx3 = tx
            vy3 = ty
        if vy1 > vy2:
            var tx = vx1
            var ty = vy1
            vx1 = vx2
            vy1 = vy2
            vx2 = tx
            vy2 = ty

        # Upper half
        var y = vy1
        while y <= vy2:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = _sw_edge_x(vx1, vy1, vx2, vy2, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            self.draw_rect_filled(left, y, right - left + 1, 1, color)
            y = y + 1

        # Lower half
        y = vy2 + 1
        while y <= vy3:
            val xa = _sw_edge_x(vx1, vy1, vx3, vy3, y)
            val xb = _sw_edge_x(vx2, vy2, vx3, vy3, y)
            var left = xa
            var right = xb
            if left > right:
                left = xb
                right = xa
            self.draw_rect_filled(left, y, right - left + 1, 1, color)
            y = y + 1

    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if h <= 0:
            return
        var row = 0
        while row < h:
            val t = _i32_to_f32(row) / _i32_to_f32(h - 1)
            val c = lerp_color(top_color, bottom_color, t)
            self.draw_rect_filled(x, y + row, w, 1, c)
            row = row + 1

    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        # Paint glyph bits through draw_rect_filled so writes stay on self.buf.
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val tw = text_val.len().to_i32() * advance
        val th = gh * scale
        if tw <= 0 or th <= 0:
            return
        var i: i64 = 0
        var cursor_x = x
        while i < text_val.len():
            val code = text_val.char_code_at(i)
            val ch = "{code as char}"
            val bitmap = glyph_data(ch)
            var gy = 0
            while gy < 7:
                val row_data = bitmap[gy]
                var gx = 0
                while gx < 5:
                    val bit = (row_data >> (4 - gx)) & 1
                    if bit != 0:
                        self.draw_rect_filled(cursor_x + gx * scale, y + gy * scale, scale, scale, color)
                    gx = gx + 1
                gy = gy + 1
            cursor_x = cursor_x + advance
            i = i + 1

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                val clipped = _clip_span(self, x, py, w)
                val count = clipped.2
                if count > 0:
                    var k = 0
                    while k < count:
                        val dst_x = clipped.0 + k
                        val src_off = row * w + (clipped.0 - x) + k
                        if src_off >= 0 and src_off < pixels.len():
                            self.buf[py * self.w + dst_x] = pixels[src_off]
                        k = k + 1
            row = row + 1

    me blit_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        """Compatibility alias used by SIMD integration tests."""
        self.draw_image(x, y, w, h, pixels)

    me set_clip(x: i32, y: i32, w: i32, h: i32):
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true

    me clear_clip():
        self.clip_enabled = false
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h

    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        self.mask_buf = mask_pixels
        self.mask_w = w
        self.mask_h = h

    me clear_mask():
        self.mask_buf = []
        self.mask_w = 0
        self.mask_h = 0

    me present():
        # Reset dirty tiles for next frame
        var i = 0
        while i < self.dirty_tiles.len():
            self.dirty_tiles[i] = false
            i = i + 1

    fn read_pixels() -> [u32]:
        var copy: [u32] = [0u32; self.w * self.h]
        var i = 0
        while i < self.w * self.h:
            copy[i] = self.buf[i]
            i = i + 1
        copy

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32):
        emu_draw_arc(self, cx, cy, r, start_deg, end_deg, color, thickness)

    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        emu_draw_bezier(self, x1, y1, cx1, cy1, cx2, cy2, x2, y2, color, thickness)

    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32):
        emu_draw_polygon_filled(self, xs, ys, count, color)

    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32):
        emu_draw_polyline(self, xs, ys, count, color, thickness)

    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32):
        emu_draw_rect_thick(self, x, y, w, h, color, thickness)

    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32):
        emu_draw_circle_thick(self, cx, cy, r, color, thickness)

    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32):
        emu_draw_rounded_rect_outline(self, x, y, w, h, radius, color, thickness)

    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32):
        emu_draw_gradient_rect_h(self, x, y, w, h, left_color, right_color)

    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32):
        emu_draw_radial_gradient(self, cx, cy, r, center_color, edge_color)

    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32):
        emu_draw_rect_blend(self, x, y, w, h, color)

    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        emu_draw_image_blend(self, x, y, w, h, pixels)

    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32]):
        emu_draw_image_scaled(self, dst_x, dst_y, dst_w, dst_h, src_w, src_h, pixels)

    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32):
        emu_draw_triangle_outline(self, x1, y1, x2, y2, x3, y3, color, thickness)

    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32):
        emu_draw_blur_rect(self, x, y, w, h, radius)

    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32):
        emu_draw_shadow_rect(self, x, y, w, h, offset_x, offset_y, blur_r, color)

    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32]):
        emu_draw_image_transform(self, dst_x, dst_y, src_w, src_h, a, b, c, d, tx, ty, pixels)

    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32):
        emu_draw_rect_blend_mode(self, x, y, w, h, color, mode)

impl Engine2DExtended for SoftwareBackend:
    # Phase 1 fallback: paint the cell with `bg` first, then overlay the
    # glyph via the shared 5x7 raster. Tile dirty-tracking is preserved
    # because both calls route through the `self.*` helpers that already
    # mark tiles dirty.
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32):
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = text_val.len().to_i32() * advance
        val text_h = gh * scale
        if text_w <= 0 or text_h <= 0:
            return
        var buf: [u32] = []
        var _i = 0
        val buf_size = text_w * text_h
        while _i < buf_size:
            buf.push(bg)
            _i = _i + 1
        render_text_to_buffer(buf, text_w, text_h, 0, 0, text_val, fg, font_size)
        self.draw_image(x, y, text_w, text_h, buf)

    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse(self, cx, cy, rx, ry, color)

    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32):
        emu_draw_ellipse_filled(self, cx, cy, rx, ry, color)

# ============================================================================
# Pixel-write helpers (me methods)
#
# These MUST be `me` methods that write `self.buf` inline. Writes performed by
# a free function that receives `self` or `self.buf` as a parameter are silently
# dropped (the receiver is copied) — see
# doc/08_tracking/bug/self_pass_to_free_fn_mutation_loss_2026-05-29.md. That is
# why every primitive other than draw_rect_filled rendered nothing before this
# change. Read-only helpers (_clip_span, _sw_mask_blocks) may stay free fns.
# ============================================================================

impl SoftwareBackend:
    me _set_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        if self.clip_enabled:
            if (x < self.clip_x or x >= self.clip_x + self.clip_w or
                y < self.clip_y or y >= self.clip_y + self.clip_h):
                return
        if _sw_mask_blocks(self, x, y):
            return
        self.buf[y * self.w + x] = color

    me _set_pixel_blend(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        if self.clip_enabled:
            if (x < self.clip_x or x >= self.clip_x + self.clip_w or
                y < self.clip_y or y >= self.clip_y + self.clip_h):
                return
        if _sw_mask_blocks(self, x, y):
            return
        val idx = y * self.w + x
        self.buf[idx] = blend(color, self.buf[idx])

    me _hline(x: i32, y: i32, length: i32, color: u32):
        val clipped = _clip_span(self, x, y, length)
        if clipped.2 <= 0:
            return
        var col = clipped.0
        val end_col = clipped.1
        while col < end_col:
            self.buf[y * self.w + col] = color
            col = col + 1

    me _hline_blend(x: i32, y: i32, length: i32, color: u32):
        val clipped = _clip_span(self, x, y, length)
        if clipped.2 <= 0:
            return
        var col = clipped.0
        val end_col = clipped.1
        while col < end_col:
            val idx = y * self.w + col
            self.buf[idx] = blend(color, self.buf[idx])
            col = col + 1

    me _vline(x: i32, y: i32, length: i32, color: u32):
        var i = 0
        while i < length:
            self._set_pixel(x, y + i, color)
            i = i + 1

    me _bresenham(x1: i32, y1: i32, x2: i32, y2: i32, color: u32):
        var dx = x2 - x1
        var dy = y2 - y1
        var sx: i32 = 1
        var sy: i32 = 1
        if dx < 0:
            dx = -dx
            sx = -1
        if dy < 0:
            dy = -dy
            sy = -1
        var err = dx - dy
        var cx = x1
        var cy = y1
        while true:
            self._set_pixel(cx, cy, color)
            if cx == x2 and cy == y2:
                return
            val e2 = 2 * err
            if e2 > -dy:
                err = err - dy
                cx = cx + sx
            if e2 < dx:
                err = err + dx
                cy = cy + sy

    me _corner_arc(cx: i32, cy: i32, r: i32, color: u32, sx: i32, sy: i32):
        var px = r
        var py = 0
        var d = 1 - r
        while px >= py:
            self._set_pixel(cx + px * sx, cy + py * sy, color)
            self._set_pixel(cx + py * sx, cy + px * sy, color)
            py = py + 1
            if d <= 0:
                d = d + 2 * py + 1
            else:
                px = px - 1
                d = d + 2 * py - 2 * px + 1

# ============================================================================
# Tile Operations
# ============================================================================

fn _clear_tile(backend: SoftwareBackend, tx: i32, ty: i32, color: u32):
    """Clear a single tile to a solid color (cache-friendly)."""
    val start_x = tx * TILE_SIZE
    val start_y = ty * TILE_SIZE
    var end_x = start_x + TILE_SIZE
    var end_y = start_y + TILE_SIZE
    if end_x > backend.w: end_x = backend.w
    if end_y > backend.h: end_y = backend.h

    var y = start_y
    while y < end_y:
        val row_base = y * backend.w
        fill_span(backend.buf, (row_base + start_x).to_i64(), (end_x - start_x).to_i64(), color)
        y = y + 1

fn _mark_dirty(backend: SoftwareBackend, tx: i32, ty: i32):
    """Mark a tile as dirty."""
    val idx = ty * backend.tiles_x + tx
    if idx >= 0 and idx < backend.dirty_tiles.len():
        backend.dirty_tiles[idx] = true

fn _mark_pixel_dirty(backend: SoftwareBackend, x: i32, y: i32):
    """Mark the tile containing pixel (x, y) as dirty."""
    val tx = x / TILE_SIZE
    val ty = y / TILE_SIZE
    _mark_dirty(backend, tx, ty)

fn _mark_span_dirty(backend: SoftwareBackend, x: i32, y: i32, length: i32):
    """Mark all tiles touched by a horizontal span."""
    if length <= 0:
        return
    val tx0 = x / TILE_SIZE
    val tx1 = (x + length - 1) / TILE_SIZE
    val ty = y / TILE_SIZE
    var tx = tx0
    while tx <= tx1:
        _mark_dirty(backend, tx, ty)
        tx = tx + 1

fn _clip_span(backend: SoftwareBackend, x: i32, y: i32, length: i32) -> (i32, i32, i32):
    """Clip a horizontal span to framebuffer and active clip rectangle.

    Returns (start_x, end_x_exclusive, count). A zero count means no pixels
    should be touched.
    """
    if length <= 0 or y < 0 or y >= backend.h:
        return (0, 0, 0)
    var start = x
    var end = x + length
    if start < 0:
        start = 0
    if end > backend.w:
        end = backend.w
    if backend.clip_enabled:
        if y < backend.clip_y or y >= backend.clip_y + backend.clip_h:
            return (0, 0, 0)
        if start < backend.clip_x:
            start = backend.clip_x
        val clip_end = backend.clip_x + backend.clip_w
        if end > clip_end:
            end = clip_end
    if end <= start:
        return (0, 0, 0)
    (start, end, end - start)

# ============================================================================
# Pixel Operations
# ============================================================================

fn _sw_mask_blocks(backend: SoftwareBackend, x: i32, y: i32) -> bool:
    if backend.mask_buf.len() == 0:
        return false
    val mi = y * backend.mask_w + x
    if mi < 0 or mi >= backend.mask_buf.len():
        return false
    backend.mask_buf[mi] == 0u8

fn _sw_set_pixel(backend: SoftwareBackend, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return
    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return
    if _sw_mask_blocks(backend, x, y):
        return
    val idx = y * backend.w + x
    backend.buf[idx] = color
    _mark_pixel_dirty(backend, x, y)

fn _sw_set_pixel_blend(backend: SoftwareBackend, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= backend.w or y >= backend.h:
        return
    if backend.clip_enabled:
        if (x < backend.clip_x or x >= backend.clip_x + backend.clip_w or
            y < backend.clip_y or y >= backend.clip_y + backend.clip_h):
            return
    if _sw_mask_blocks(backend, x, y):
        return
    val idx = y * backend.w + x
    backend.buf[idx] = blend(color, backend.buf[idx])
    _mark_pixel_dirty(backend, x, y)

# ============================================================================
# Line Drawing
# ============================================================================

fn _sw_hline(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    val clipped = _clip_span(backend, x, y, length)
    val count = clipped.2
    if count <= 0:
        return
    val off = y * backend.w + clipped.0
    fill_span(backend.buf, off.to_i64(), count.to_i64(), color)
    _mark_span_dirty(backend, clipped.0, y, count)

fn _sw_hline_blend(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    val clipped = _clip_span(backend, x, y, length)
    val count = clipped.2
    if count <= 0:
        return
    val off = y * backend.w + clipped.0
    var src: [u32] = [0u32; off + count]
    fill_span(src, off.to_i64(), count.to_i64(), color)
    alpha_blend_span(backend.buf, src, off.to_i64(), count.to_i64())
    _mark_span_dirty(backend, clipped.0, y, count)

fn _sw_vline(backend: SoftwareBackend, x: i32, y: i32, length: i32, color: u32):
    var i = 0
    while i < length:
        _sw_set_pixel(backend, x, y + i, color)
        i = i + 1

fn _sw_bresenham(backend: SoftwareBackend, x1: i32, y1: i32, x2: i32, y2: i32, color: u32):
    var dx = x2 - x1
    var dy = y2 - y1
    var sx: i32 = 1
    var sy: i32 = 1
    if dx < 0:
        dx = -dx
        sx = -1
    if dy < 0:
        dy = -dy
        sy = -1
    var err = dx - dy
    var cx = x1
    var cy = y1
    while true:
        _sw_set_pixel(backend, cx, cy, color)
        if cx == x2 and cy == y2:
            return
        val e2 = 2 * err
        if e2 > -dy:
            err = err - dy
            cx = cx + sx
        if e2 < dx:
            err = err + dx
            cy = cy + sy

# ============================================================================
# Corner Arc
# ============================================================================

fn _sw_corner_arc(backend: SoftwareBackend, cx: i32, cy: i32, r: i32, color: u32, sx: i32, sy: i32):
    var px = r
    var py = 0
    var d = 1 - r
    while px >= py:
        _sw_set_pixel(backend, cx + px * sx, cy + py * sy, color)
        _sw_set_pixel(backend, cx + py * sx, cy + px * sy, color)
        py = py + 1
        if d <= 0:
            d = d + 2 * py + 1
        else:
            px = px - 1
            d = d + 2 * py - 2 * px + 1

# ============================================================================
# Triangle Edge Interpolation
# ============================================================================

fn _sw_edge_x(x1: i32, y1: i32, x2: i32, y2: i32, y: i32) -> i32:
    val dy = y2 - y1
    if dy == 0:
        return x1
    x1 + (x2 - x1) * (y - y1) / dy

# ============================================================================
# Conversion Helpers
# ============================================================================

fn _i32_to_f32(v: i32) -> f32:
    v as f32
