# GPU Graphics Types
#
# Backend-agnostic abstraction over render passes, textures, pipelines,
# swapchains, and vertex layouts. Pure data types — no FFI calls.
#
# Usage:
#   use std.gpu.graphics.{GpuFormat, GpuTexture, GpuRenderPassDesc, GpuPipelineDesc, ...}

# ============================================================================
# Texture Formats
# ============================================================================

enum GpuFormat:
    """GPU texture / framebuffer pixel format."""
    RGBA8
    BGRA8
    RGB8
    R8
    Depth32F
    Depth24Stencil8

impl GpuFormat:
    fn bytes_per_pixel() -> i64:
        """Number of bytes per pixel for this format."""
        match self:
            case RGBA8: 4
            case BGRA8: 4
            case RGB8: 3
            case R8: 1
            case Depth32F: 4
            case Depth24Stencil8: 4

    fn is_depth() -> bool:
        """Whether this format is a depth/stencil format."""
        match self:
            case Depth32F: true
            case Depth24Stencil8: true
            case _: false

    fn to_text() -> text:
        match self:
            case RGBA8: "RGBA8"
            case BGRA8: "BGRA8"
            case RGB8: "RGB8"
            case R8: "R8"
            case Depth32F: "Depth32F"
            case Depth24Stencil8: "Depth24Stencil8"

# ============================================================================
# Texture Usage
# ============================================================================

enum GpuTextureUsage:
    """How a texture may be used in the pipeline."""
    Sampled        # Can be sampled in shaders
    RenderTarget   # Can be used as render target
    TransferSrc    # Can be source of copy
    TransferDst    # Can be destination of copy
    Storage        # Can be used as storage image

impl GpuTextureUsage:
    fn to_text() -> text:
        match self:
            case Sampled: "Sampled"
            case RenderTarget: "RenderTarget"
            case TransferSrc: "TransferSrc"
            case TransferDst: "TransferDst"
            case Storage: "Storage"

# ============================================================================
# Texture Descriptor & Handle
# ============================================================================

struct GpuTextureDesc:
    """Descriptor for creating a GPU texture."""
    width: i64
    height: i64
    format: GpuFormat
    usage: GpuTextureUsage

struct GpuTexture:
    """Handle to a GPU texture resource."""
    handle: i64
    width: i64
    height: i64
    format: GpuFormat

impl GpuTexture:
    fn is_valid() -> bool:
        self.handle > 0

    fn size_bytes() -> i64:
        """Total size in bytes."""
        self.width * self.height * self.format.bytes_per_pixel()

# ============================================================================
# Load / Store Operations
# ============================================================================

enum GpuLoadOp:
    """What to do with existing content at render pass start."""
    Clear
    Load
    DontCare

impl GpuLoadOp:
    fn to_text() -> text:
        match self:
            case Clear: "Clear"
            case Load: "Load"
            case DontCare: "DontCare"

enum GpuStoreOp:
    """What to do with rendered content at render pass end."""
    Store
    DontCare

impl GpuStoreOp:
    fn to_text() -> text:
        match self:
            case Store: "Store"
            case DontCare: "DontCare"

# ============================================================================
# Render Pass
# ============================================================================

struct GpuRenderPassDesc:
    """Descriptor for creating a render pass."""
    color_format: GpuFormat
    has_depth: bool
    depth_format: GpuFormat
    clear_r: f64
    clear_g: f64
    clear_b: f64
    clear_a: f64
    load_op: GpuLoadOp
    store_op: GpuStoreOp

struct GpuRenderPass:
    """Handle to a render pass."""
    handle: i64

impl GpuRenderPass:
    fn is_valid() -> bool:
        self.handle > 0

# ============================================================================
# Blend Modes
# ============================================================================

enum GpuBlendMode:
    """Color blending mode for the output merger."""
    Opaque
    AlphaBlend
    Additive
    Multiply

impl GpuBlendMode:
    fn to_text() -> text:
        match self:
            case Opaque: "Opaque"
            case AlphaBlend: "AlphaBlend"
            case Additive: "Additive"
            case Multiply: "Multiply"

# ============================================================================
# Primitive Topology
# ============================================================================

enum GpuTopology:
    """How vertices are assembled into primitives."""
    TriangleList
    TriangleStrip
    LineList
    LineStrip
    PointList

impl GpuTopology:
    fn to_text() -> text:
        match self:
            case TriangleList: "TriangleList"
            case TriangleStrip: "TriangleStrip"
            case LineList: "LineList"
            case LineStrip: "LineStrip"
            case PointList: "PointList"

# ============================================================================
# Vertex Layout
# ============================================================================

enum GpuVertexFormat:
    """Per-attribute vertex data format."""
    Float2    # 2x f32
    Float3    # 3x f32
    Float4    # 4x f32
    UByte4    # 4x u8 normalized

impl GpuVertexFormat:
    fn size_bytes() -> i64:
        match self:
            case Float2: 8
            case Float3: 12
            case Float4: 16
            case UByte4: 4

    fn to_text() -> text:
        match self:
            case Float2: "Float2"
            case Float3: "Float3"
            case Float4: "Float4"
            case UByte4: "UByte4"

struct GpuVertexAttribute:
    """Single vertex attribute within a vertex layout."""
    location: i64
    format: GpuVertexFormat
    offset: i64

struct GpuVertexLayout:
    """Describes the memory layout of a vertex buffer."""
    stride: i64
    attributes: [GpuVertexAttribute]

# ============================================================================
# Shaders
# ============================================================================

enum GpuShaderStage:
    """Which pipeline stage a shader runs in."""
    Vertex
    Fragment
    Compute

impl GpuShaderStage:
    fn to_text() -> text:
        match self:
            case Vertex: "Vertex"
            case Fragment: "Fragment"
            case Compute: "Compute"

struct GpuShader:
    """Handle to a compiled shader module."""
    handle: i64
    stage: GpuShaderStage

impl GpuShader:
    fn is_valid() -> bool:
        self.handle > 0

# ============================================================================
# Graphics Pipeline
# ============================================================================

struct GpuPipelineDesc:
    """Descriptor for creating a graphics pipeline."""
    vertex_shader: GpuShader
    fragment_shader: GpuShader
    blend_mode: GpuBlendMode
    vertex_layout: GpuVertexLayout
    topology: GpuTopology
    render_pass: GpuRenderPass

struct GpuGraphicsPipeline:
    """Handle to a compiled graphics pipeline."""
    handle: i64

impl GpuGraphicsPipeline:
    fn is_valid() -> bool:
        self.handle > 0

# ============================================================================
# Swapchain
# ============================================================================

struct GpuSwapchainDesc:
    """Descriptor for creating a swapchain (window presentation)."""
    window_handle: i64
    width: i64
    height: i64
    format: GpuFormat
    vsync: bool

struct GpuSwapchain:
    """Handle to a presentation swapchain."""
    handle: i64
    width: i64
    height: i64
    format: GpuFormat

impl GpuSwapchain:
    fn is_valid() -> bool:
        self.handle > 0

# ============================================================================
# Framebuffer
# ============================================================================

struct GpuFramebuffer:
    """Handle to a framebuffer (render target collection)."""
    handle: i64
    width: i64
    height: i64

impl GpuFramebuffer:
    fn is_valid() -> bool:
        self.handle > 0

    fn size_pixels() -> i64:
        self.width * self.height

# ============================================================================
# Exports
# ============================================================================
