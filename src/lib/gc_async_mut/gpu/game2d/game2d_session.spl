# Game2DSession — 2D game session with sprite, tile-layer, and particle support
#
# Wraps GraphicsSession lifecycle for 2D games.
# Modes: "managed_shared" (default), "legacy_no_session"

use std.io

val GAME2D_ID_BASE: i64 = 2000

class Game2DSession:
    """2D game session tracking frames, sprites, tile layers, and particles."""

    session_id: i64
    mode: text
    width: i64
    height: i64
    frame_count: i64
    sprite_count: i64
    tile_layer_count: i64
    particle_count: i64
    fps_target: i64
    frame_time_us: i64
    active: bool

    static fn create(width: i64, height: i64, mode: text) -> Game2DSession:
        val fps = 60
        val frame_us = 1000000 / fps
        return Game2DSession(
            session_id: GAME2D_ID_BASE,
            mode: mode,
            width: width,
            height: height,
            frame_count: 0,
            sprite_count: 0,
            tile_layer_count: 0,
            particle_count: 0,
            fps_target: fps,
            frame_time_us: frame_us,
            active: true
        )

    static fn create_managed(width: i64, height: i64) -> Game2DSession:
        return Game2DSession.create(width, height, "managed_shared")

    static fn create_legacy(width: i64, height: i64) -> Game2DSession:
        return Game2DSession.create(width, height, "legacy_no_session")

    me begin_frame() -> i64:
        self.frame_count = self.frame_count + 1
        return self.frame_count

    me end_frame(frame_id: i64) -> text:
        return "frame_done:{frame_id}"

    me add_sprite(x: i64, y: i64, w: i64, h: i64, texture_id: i64) -> i64:
        self.sprite_count = self.sprite_count + 1
        return self.sprite_count

    me add_tile_layer(tile_w: i64, tile_h: i64, cols: i64, rows: i64) -> i64:
        self.tile_layer_count = self.tile_layer_count + 1
        return self.tile_layer_count

    me add_particles(x: i64, y: i64, count: i64) -> i64:
        self.particle_count = self.particle_count + count
        return self.particle_count

    me set_fps_target(fps: i64):
        self.fps_target = fps
        if fps > 0:
            self.frame_time_us = 1000000 / fps

    me stats() -> text:
        return "game2d mode={self.mode} frames={self.frame_count} sprites={self.sprite_count} layers={self.tile_layer_count} particles={self.particle_count} fps={self.fps_target}"

    me cleanup() -> text:
        self.active = false
        return "game2d_session cleaned up id={self.session_id}"
