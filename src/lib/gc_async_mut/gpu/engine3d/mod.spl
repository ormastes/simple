"""3D Rendering Engine — Multi-Backend 3D Graphics

@tag:stdlib
@tag:api
@tag:gpu

A multi-backend 3D rendering engine providing an abstract rendering interface.
Each backend implements the same RenderBackend3D trait. The engine auto-selects
the best available backend at runtime.

## Architecture

    Apps -> Game Engine -> 3D Engine -> Backend

Backends (in priority order):
  1. CUDA   — GPU-accelerated via CUDA kernels (NVIDIA)
  2. ROCm   — GPU-accelerated via HIP (AMD)
  3. Metal  — GPU-accelerated via Metal compute (Apple)
  4. Vulkan — Cross-platform GPU compute shaders
  5. OpenGL — OpenGL 3.3+ with FBO offscreen rendering
  6. Intel  — GPU-accelerated via oneAPI Level Zero (Intel)
  7. Software — Optimized CPU with tile-based rendering
  8. CPU    — Pure software fallback (always available)
  9. Baremetal — OS framebuffer driver bridge (explicit only)

## Quick Start

    use std.gpu.engine3d.engine.{Engine3D}
    use std.gpu.engine3d.types3d.{vertex3d_pos_color, material_unlit, mat4_identity}

    var engine = Engine3D.create(800, 600)
    engine.begin_frame()
    engine.clear(0xFF000000)

    val v0 = vertex3d_pos_color(0.0, 1.0, 0.0, 0xFFFF0000)
    val v1 = vertex3d_pos_color(-1.0, -1.0, 0.0, 0xFF00FF00)
    val v2 = vertex3d_pos_color(1.0, -1.0, 0.0, 0xFF0000FF)
    engine.submit_triangle(v0, v1, v2, material_unlit(0xFFFFFFFF), mat4_identity())

    engine.end_frame()
    engine.present()

## Submodules

  - types3d:          Vertex3D, Material3DParams, LightParams3D, mat4 math
  - backend:          RenderBackend3D trait (combined Core + Adv)
  - backend_core:     RenderBackend3DCore trait (minimum required interface)
  - backend_adv:      RenderBackend3DAdv trait (optimized operations)
  - backend_emu:      Stateless emulation layer (Core → Adv, no internal state)
  - backend_cpu:      Pure software CPU renderer (always available)
  - backend_cuda:     CUDA GPU renderer (NVIDIA GPUs)
  - backend_rocm:     ROCm/HIP GPU renderer (AMD GPUs)
  - backend_metal:    Metal GPU renderer (Apple GPUs)
  - backend_vulkan:   Vulkan GPU renderer (compute shaders)
  - backend_opengl:   OpenGL GPU renderer (FBO offscreen)
  - backend_intel:    Intel oneAPI GPU renderer (Intel GPUs)
  - backend_software: Optimized software renderer (tile-based)
  - backend_baremetal: OS framebuffer driver bridge (explicit selection only)
  - backend_virtio_gpu: VirtIO-GPU backend for QEMU (OS/baremetal only)
  - backend_webgpu:   WebGPU GPU renderer (Chrome WebGPU features)
  - backend_qualcomm: Qualcomm Adreno backend (Vulkan delegate, Linux arm64)
  - engine:           Engine3D facade with auto-detection
"""

use std.gpu.engine3d.types3d.{
    Vertex3D, Material3DParams, LightParams3D, RenderStats3D,
    vertex3d, vertex3d_pos, vertex3d_pos_color, vertex3d_pos_normal,
    material_unlit, material_phong, material_pbr,
    light_directional, light_point, light_spot,
    render_stats3d_new,
    CULL_NONE, CULL_BACK, CULL_FRONT,
    BLEND_OPAQUE, BLEND_ALPHA, BLEND_ADDITIVE,
    MATERIAL_UNLIT, MATERIAL_PHONG, MATERIAL_PBR,
    LIGHT_DIRECTIONAL, LIGHT_POINT, LIGHT_SPOT,
    mat4_identity, mat4_translate, mat4_scale,
    mat4_rotate_x, mat4_rotate_y, mat4_rotate_z,
    mat4_mul, mat4_transform_point, mat4_transform_dir,
    mat4_perspective, mat4_ortho, mat4_look_at,
    vec3_dot, vec3_length, vec3_normalize, vec3_cross,
    color3d_r, color3d_g, color3d_b, color3d_a,
    color3d_pack, color3d_pack_rgb
}
use std.gpu.engine3d.backend.{RenderBackend3D, Engine3DExtended}
use std.gpu.engine3d.backend_core.{RenderBackend3DCore}
use std.gpu.engine3d.backend_adv.{RenderBackend3DAdv}
