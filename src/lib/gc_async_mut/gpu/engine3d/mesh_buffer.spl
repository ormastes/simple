# mesh_buffer.spl — GPU mesh buffer resource skeleton
# Tracks vertex/index buffer allocation for the 3D engine.
# Format codes: "pos3_norm3_uv2", "pos3_norm3", "pos3"

use std.io

class MeshBuffer:
    buffer_id: i64
    vertex_count: i64
    index_count: i64
    stride_bytes: i64
    format: text
    allocated: bool
    session_id: i64

    static fn create(format: text, vertex_count: i64, index_count: i64) -> MeshBuffer:
        val stride = if format == "pos3_norm3_uv2": 32
                     else if format == "pos3_norm3": 24
                     else: 12
        return MeshBuffer(
            buffer_id: -1,
            vertex_count: vertex_count,
            index_count: index_count,
            stride_bytes: stride,
            format: format,
            allocated: false,
            session_id: -1
        )

    me allocate(session_id: i64) -> text:
        if self.allocated:
            return "error: already allocated"
        if self.vertex_count <= 0:
            return "error: vertex_count must be > 0"
        self.session_id = session_id
        self.buffer_id = session_id * 1000 + self.vertex_count
        self.allocated = true
        return ""

    me release() -> text:
        if !self.allocated:
            return "error: not allocated"
        self.allocated = false
        self.buffer_id = -1
        self.session_id = -1
        return ""

    me is_allocated() -> bool:
        return self.allocated

    me byte_size() -> i64:
        val vertex_bytes = self.vertex_count * self.stride_bytes
        val index_bytes = self.index_count * 4
        return vertex_bytes + index_bytes

    me info() -> text:
        val alloc_str = if self.allocated: "allocated" else: "free"
        return "MeshBuffer(id=" + self.buffer_id.to_text() +
               " fmt=" + self.format +
               " verts=" + self.vertex_count.to_text() +
               " idxs=" + self.index_count.to_text() +
               " bytes=" + self.byte_size().to_text() +
               " " + alloc_str + ")"
