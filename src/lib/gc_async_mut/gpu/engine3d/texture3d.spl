"""3D Engine — Texture Type System

@tag:stdlib
@tag:api
@tag:gpu

Defines texture dimension, format, usage, descriptor, sampler, and view types
mirroring the Chrome WebGPU GPUTexture API. Supports 2D, 3D (volume), cube,
2D-array, and cube-array textures.

Usage:
    use std.gpu.engine3d.texture3d.{TextureDescriptor3D, SamplerDescriptor3D, TextureView3D}
"""

# ============================================================================
# Texture Dimension Constants
# ============================================================================

val TEX_DIM_2D: i32 = 0
val TEX_DIM_3D: i32 = 1
val TEX_DIM_CUBE: i32 = 2
val TEX_DIM_2D_ARRAY: i32 = 3
val TEX_DIM_CUBE_ARRAY: i32 = 4

# ============================================================================
# Texture Format Constants (Chrome WebGPU compatible)
# ============================================================================

val TEX_FMT_RGBA8_UNORM: i32 = 0
val TEX_FMT_RGBA8_SRGB: i32 = 1
val TEX_FMT_BGRA8_UNORM: i32 = 2
val TEX_FMT_R8_UNORM: i32 = 3
val TEX_FMT_RG8_UNORM: i32 = 4
val TEX_FMT_RGBA16_FLOAT: i32 = 10
val TEX_FMT_RGBA32_FLOAT: i32 = 11
val TEX_FMT_R32_FLOAT: i32 = 12
val TEX_FMT_RG32_FLOAT: i32 = 13
val TEX_FMT_DEPTH24_PLUS: i32 = 20
val TEX_FMT_DEPTH32_FLOAT: i32 = 21
val TEX_FMT_DEPTH24_PLUS_STENCIL8: i32 = 22
val TEX_FMT_BC1_UNORM: i32 = 30
val TEX_FMT_BC3_UNORM: i32 = 31
val TEX_FMT_BC7_UNORM: i32 = 32
val TEX_FMT_ETC2_RGB8: i32 = 40
val TEX_FMT_ASTC_4X4: i32 = 50

# ============================================================================
# Texture Usage Flags
# ============================================================================

val TEX_USAGE_TEXTURE_BINDING: i32 = 1
val TEX_USAGE_STORAGE_BINDING: i32 = 2
val TEX_USAGE_RENDER_ATTACHMENT: i32 = 4
val TEX_USAGE_COPY_SRC: i32 = 8
val TEX_USAGE_COPY_DST: i32 = 16

# ============================================================================
# Filter / Address / Compare Constants
# ============================================================================

val FILTER_NEAREST: i32 = 0
val FILTER_LINEAR: i32 = 1

val ADDRESS_CLAMP: i32 = 0
val ADDRESS_REPEAT: i32 = 1
val ADDRESS_MIRROR: i32 = 2

val COMPARE_NONE: i32 = 0
val COMPARE_LESS: i32 = 1
val COMPARE_LESS_EQUAL: i32 = 2
val COMPARE_GREATER: i32 = 3
val COMPARE_GREATER_EQUAL: i32 = 4
val COMPARE_EQUAL: i32 = 5
val COMPARE_NOT_EQUAL: i32 = 6
val COMPARE_ALWAYS: i32 = 7

# ============================================================================
# Texture Descriptor
# ============================================================================

class TextureDescriptor3D:
    dimension: i32
    format: i32
    width: i32
    height: i32
    depth_or_layers: i32
    mip_level_count: i32
    sample_count: i32
    usage: i32

    static fn create_2d(width: i32, height: i32, format: i32) -> TextureDescriptor3D:
        TextureDescriptor3D(
            dimension: TEX_DIM_2D, format: format,
            width: width, height: height, depth_or_layers: 1,
            mip_level_count: 1, sample_count: 1,
            usage: TEX_USAGE_TEXTURE_BINDING | TEX_USAGE_COPY_DST
        )

    static fn create_3d(width: i32, height: i32, depth: i32, format: i32) -> TextureDescriptor3D:
        TextureDescriptor3D(
            dimension: TEX_DIM_3D, format: format,
            width: width, height: height, depth_or_layers: depth,
            mip_level_count: 1, sample_count: 1,
            usage: TEX_USAGE_TEXTURE_BINDING | TEX_USAGE_COPY_DST
        )

    static fn create_cube(size: i32, format: i32) -> TextureDescriptor3D:
        TextureDescriptor3D(
            dimension: TEX_DIM_CUBE, format: format,
            width: size, height: size, depth_or_layers: 6,
            mip_level_count: 1, sample_count: 1,
            usage: TEX_USAGE_TEXTURE_BINDING | TEX_USAGE_COPY_DST
        )

    static fn create_depth(width: i32, height: i32) -> TextureDescriptor3D:
        TextureDescriptor3D(
            dimension: TEX_DIM_2D, format: TEX_FMT_DEPTH32_FLOAT,
            width: width, height: height, depth_or_layers: 1,
            mip_level_count: 1, sample_count: 1,
            usage: TEX_USAGE_RENDER_ATTACHMENT
        )

    static fn create_2d_array(width: i32, height: i32, layers: i32, format: i32) -> TextureDescriptor3D:
        TextureDescriptor3D(
            dimension: TEX_DIM_2D_ARRAY, format: format,
            width: width, height: height, depth_or_layers: layers,
            mip_level_count: 1, sample_count: 1,
            usage: TEX_USAGE_TEXTURE_BINDING | TEX_USAGE_COPY_DST
        )

# ============================================================================
# Format Utilities
# ============================================================================

fn bytes_per_pixel_3d(format: i32) -> i32:
    if format == TEX_FMT_RGBA8_UNORM or format == TEX_FMT_RGBA8_SRGB or format == TEX_FMT_BGRA8_UNORM:
        4
    else if format == TEX_FMT_R8_UNORM:
        1
    else if format == TEX_FMT_RG8_UNORM:
        2
    else if format == TEX_FMT_RGBA16_FLOAT:
        8
    else if format == TEX_FMT_RGBA32_FLOAT:
        16
    else if format == TEX_FMT_R32_FLOAT or format == TEX_FMT_DEPTH32_FLOAT or format == TEX_FMT_DEPTH24_PLUS:
        4
    else if format == TEX_FMT_RG32_FLOAT:
        8
    else if format == TEX_FMT_DEPTH24_PLUS_STENCIL8:
        4
    else:
        4

fn is_depth_format(format: i32) -> bool:
    format == TEX_FMT_DEPTH24_PLUS or format == TEX_FMT_DEPTH32_FLOAT or format == TEX_FMT_DEPTH24_PLUS_STENCIL8

fn is_compressed_format(format: i32) -> bool:
    format == TEX_FMT_BC1_UNORM or format == TEX_FMT_BC3_UNORM or format == TEX_FMT_BC7_UNORM or format == TEX_FMT_ETC2_RGB8 or format == TEX_FMT_ASTC_4X4

# ============================================================================
# Sampler Descriptor
# ============================================================================

class SamplerDescriptor3D:
    mag_filter: i32
    min_filter: i32
    mipmap_filter: i32
    address_mode_u: i32
    address_mode_v: i32
    address_mode_w: i32
    max_anisotropy: i32
    compare: i32

    static fn create_default() -> SamplerDescriptor3D:
        SamplerDescriptor3D(
            mag_filter: FILTER_LINEAR, min_filter: FILTER_LINEAR, mipmap_filter: FILTER_LINEAR,
            address_mode_u: ADDRESS_REPEAT, address_mode_v: ADDRESS_REPEAT, address_mode_w: ADDRESS_REPEAT,
            max_anisotropy: 1, compare: COMPARE_NONE
        )

    static fn create_nearest() -> SamplerDescriptor3D:
        SamplerDescriptor3D(
            mag_filter: FILTER_NEAREST, min_filter: FILTER_NEAREST, mipmap_filter: FILTER_NEAREST,
            address_mode_u: ADDRESS_CLAMP, address_mode_v: ADDRESS_CLAMP, address_mode_w: ADDRESS_CLAMP,
            max_anisotropy: 1, compare: COMPARE_NONE
        )

    static fn create_shadow() -> SamplerDescriptor3D:
        SamplerDescriptor3D(
            mag_filter: FILTER_LINEAR, min_filter: FILTER_LINEAR, mipmap_filter: FILTER_NEAREST,
            address_mode_u: ADDRESS_CLAMP, address_mode_v: ADDRESS_CLAMP, address_mode_w: ADDRESS_CLAMP,
            max_anisotropy: 1, compare: COMPARE_LESS
        )

# ============================================================================
# Texture View
# ============================================================================

class TextureView3D:
    texture_id: i32
    dimension: i32
    format: i32
    base_mip: i32
    mip_count: i32
    base_layer: i32
    layer_count: i32

    static fn create_full(texture_id: i32, dimension: i32, format: i32) -> TextureView3D:
        TextureView3D(
            texture_id: texture_id, dimension: dimension, format: format,
            base_mip: 0, mip_count: 1, base_layer: 0, layer_count: 1
        )

    static fn create_layer(texture_id: i32, format: i32, layer: i32) -> TextureView3D:
        TextureView3D(
            texture_id: texture_id, dimension: TEX_DIM_2D, format: format,
            base_mip: 0, mip_count: 1, base_layer: layer, layer_count: 1
        )

    static fn create_mip(texture_id: i32, dimension: i32, format: i32, mip: i32) -> TextureView3D:
        TextureView3D(
            texture_id: texture_id, dimension: dimension, format: format,
            base_mip: mip, mip_count: 1, base_layer: 0, layer_count: 1
        )
