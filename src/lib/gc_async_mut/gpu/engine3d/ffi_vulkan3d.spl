"""Vulkan FFI — 3D Engine

@tag:stdlib
@tag:gpu

Vulkan extern declarations for 3D rendering: device setup, command buffers,
render pass, pipeline state, descriptor sets.

Usage:
    val ffi = VulkanFfi3D.create_static()
"""

use std.gpu.engine3d.ffi_dispatch3d.{GpuFfiMode3D, FfiDispatchBase3D, try_load_gpu_lib_3d}
use std.ffi.dynamic.{DynLib}

# ============================================================================
# Static extern declarations
# ============================================================================

extern fn rt_vk3d_available() -> bool
extern fn rt_vk3d_init() -> bool
extern fn rt_vk3d_shutdown() -> bool
extern fn rt_vk3d_create_device(gpu_index: i64) -> i64
extern fn rt_vk3d_destroy_device(device: i64) -> bool
extern fn rt_vk3d_create_swapchain(device: i64, width: i64, height: i64) -> i64
extern fn rt_vk3d_create_render_pass(device: i64, color_format: i64, depth_format: i64) -> i64
extern fn rt_vk3d_create_pipeline(device: i64, render_pass: i64, vert_spv: [u8], frag_spv: [u8]) -> i64
extern fn rt_vk3d_begin_frame(device: i64) -> i64
extern fn rt_vk3d_end_frame(device: i64, cmd: i64) -> bool
extern fn rt_vk3d_cmd_draw(cmd: i64, vertex_count: i64, instance_count: i64) -> bool

# ============================================================================
# VulkanFfi3D
# ============================================================================

class VulkanFfi3D:
    _mode: GpuFfiMode3D
    _dyn_lib: DynLib?

impl VulkanFfi3D: FfiDispatchBase3D

    fn mode() -> GpuFfiMode3D:
        self._mode

    fn is_available() -> bool:
        if self._mode == GpuFfiMode3D.Static:
            rt_vk3d_available()
        else:
            self._dyn_lib != nil

    static fn create_static() -> VulkanFfi3D:
        VulkanFfi3D(_mode: GpuFfiMode3D.Static, _dyn_lib: nil)

    static fn create_dynamic() -> VulkanFfi3D?:
        val lib = try_load_gpu_lib_3d("vulkan")
        if lib == nil:
            return nil
        VulkanFfi3D(_mode: GpuFfiMode3D.Dynamic, _dyn_lib: lib)

    static fn create(mode_pref: GpuFfiMode3D) -> VulkanFfi3D:
        if mode_pref == GpuFfiMode3D.Dynamic:
            val dyn_result = VulkanFfi3D.create_dynamic()
            if dyn_result != nil:
                return dyn_result
        VulkanFfi3D.create_static()

    me init() -> bool:
        rt_vk3d_init()

    me shutdown() -> bool:
        rt_vk3d_shutdown()
