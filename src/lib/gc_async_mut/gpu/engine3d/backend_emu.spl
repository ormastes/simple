# ============================================================================
# Post-Processing — SSAO, FXAA, SSR
# ============================================================================

fn emu_apply_ssao(core: RenderBackend3DCore, radius: f32, bias: f32, intensity: f32):
    val w = core.width()
    val h = core.height()
    val pixels = core.read_pixels()
    val depth = core.read_depth()
    var result: [u32] = []
    var i = 0
    while i < pixels.len():
        result.push(pixels[i])
        i = i + 1
    var y = 1
    while y < h - 1:
        var x = 1
        while x < w - 1:
            val idx = y * w + x
            val d = depth[idx]
            val dl = depth[idx - 1]
            val dr = depth[idx + 1]
            val du = depth[idx - w]
            val dd = depth[idx + w]
            val diff = ((d - dl) * (d - dl) + (d - dr) * (d - dr) + (d - du) * (d - du) + (d - dd) * (d - dd)) * intensity * 1000.0
            val occ = _emu3_clamp_f32(1.0 - diff, 0.3, 1.0)
            val p = pixels[idx]
            val rr = _emu3_clamp_i32((color3d_r(p) as f32 * occ) as i32, 0, 255)
            val rg = _emu3_clamp_i32((color3d_g(p) as f32 * occ) as i32, 0, 255)
            val rb = _emu3_clamp_i32((color3d_b(p) as f32 * occ) as i32, 0, 255)
            result[idx] = color3d_pack(rr, rg, rb, color3d_a(p))
            x = x + 1
        y = y + 1
    core.draw_image(0, 0, w, h, result)

fn emu_apply_fxaa(core: RenderBackend3DCore):
    val w = core.width()
    val h = core.height()
    val pixels = core.read_pixels()
    var result: [u32] = []
    var i = 0
    while i < pixels.len():
        result.push(pixels[i])
        i = i + 1
    var y = 1
    while y < h - 1:
        var x = 1
        while x < w - 1:
            val idx = y * w + x
            val c = pixels[idx]
            val l = pixels[idx - 1]
            val r = pixels[idx + 1]
            val cr = color3d_r(c)
            val lr = color3d_r(l)
            val rr = color3d_r(r)
            val edge = (cr - lr) * (cr - lr) + (cr - rr) * (cr - rr)
            if edge > 1000:
                val ar = (cr + lr + rr) / 3
                val ag = (color3d_g(c) + color3d_g(l) + color3d_g(r)) / 3
                val ab = (color3d_b(c) + color3d_b(l) + color3d_b(r)) / 3
                result[idx] = color3d_pack(ar, ag, ab, color3d_a(c))
            x = x + 1
        y = y + 1
    core.draw_image(0, 0, w, h, result)

fn emu_apply_ssr(core: RenderBackend3DCore, max_steps: i32, thickness: f32):
    val w = core.width()
    val h = core.height()
    if w <= 0 or h <= 0:
        return
    val steps = if max_steps < 4: 4 else: max_steps
    val pixels = core.read_pixels()
    val depth = core.read_depth()
    var result: [u32] = []
    var i = 0
    while i < pixels.len():
        result.push(pixels[i])
        i = i + 1

    var y = 1
    while y < h - 1:
        var x = 1
        while x < w - 1:
            val idx = y * w + x
            val d = depth[idx]
            if d >= 0.9999:
                x = x + 1
                continue
            val dl = depth[idx - 1]
            val dr = depth[idx + 1]
            val du = depth[idx - w]
            val dd = depth[idx + w]
            val ndx = dl - dr
            val ndy = du - dd
            val ndz = 0.1
            val nlen = _emu3_sqrt(ndx * ndx + ndy * ndy + ndz * ndz)
            var nx: f32 = 0.0
            var ny: f32 = 0.0
            var nz: f32 = 1.0
            if nlen > 0.0001:
                nx = ndx / nlen
                ny = ndy / nlen
                nz = ndz / nlen

            val vx: f32 = 0.0
            val vy: f32 = 0.0
            val vz: f32 = 1.0

            val vdn = vx * nx + vy * ny + vz * nz
            val rx = vx - 2.0 * vdn * nx
            val ry = vy - 2.0 * vdn * ny

            val fresnel = _emu3_clamp_f32(1.0 - (vdn * vdn), 0.0, 1.0)
            if fresnel < 0.05:
                x = x + 1
                continue

            val step_scale = 2.0
            var hit_color: u32 = 0xFF000000
            var found = false
            var s = 1
            while s <= steps:
                val sf = (s as f32) * step_scale
                val sx = x + (rx * sf) as i32
                val sy = y + (ry * sf) as i32
                if sx >= 0 and sx < w and sy >= 0 and sy < h:
                    val sidx = sy * w + sx
                    val sd = depth[sidx]
                    val ray_d = d - sf * 0.01
                    if sd < ray_d and (ray_d - sd) < thickness:
                        hit_color = pixels[sidx]
                        found = true
                        s = steps + 1
                s = s + 1

            if found:
                val p = pixels[idx]
                val fi = (fresnel * 200.0) as i32
                val inv = 255 - fi
                val rr = _emu3_clamp_i32((color3d_r(p) * inv + color3d_r(hit_color) * fi) / 255, 0, 255)
                val rg = _emu3_clamp_i32((color3d_g(p) * inv + color3d_g(hit_color) * fi) / 255, 0, 255)
                val rb = _emu3_clamp_i32((color3d_b(p) * inv + color3d_b(hit_color) * fi) / 255, 0, 255)
                result[idx] = color3d_pack(rr, rg, rb, color3d_a(p))
            x = x + 1
        y = y + 1
    core.draw_image(0, 0, w, h, result)

# ============================================================================
# Occlusion Query — Brute-force emulation
# ============================================================================

fn emu_occlusion_query(core: RenderBackend3DCore, x: i32, y: i32, w: i32, h: i32) -> i32:
    val fw = core.width()
    val pixels = core.read_pixels()
    var count = 0
    var row = y
    while row < y + h:
        var col = x
        while col < x + w:
            if row >= 0 and row < core.height() and col >= 0 and col < fw:
                val idx = row * fw + col
                if idx >= 0 and idx < pixels.len():
                    if pixels[idx] != 0xFF000000:
                        count = count + 1
            col = col + 1
        row = row + 1
    count

