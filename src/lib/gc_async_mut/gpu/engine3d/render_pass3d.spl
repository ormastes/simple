# render_pass3d.spl — Render pass descriptor and draw-call recorder
# pass_type: "color", "depth", "shadow", "postprocess"
# Clear color components are 0-255.

use std.io

class RenderPass3D:
    pass_id: i64
    name: text
    pass_type: text
    width: i64
    height: i64
    clear_color_r: i64
    clear_color_g: i64
    clear_color_b: i64
    clear_color_a: i64
    depth_enabled: bool
    stencil_enabled: bool
    draw_call_count: i64

    static fn create(name: text, pass_type: text, width: i64, height: i64) -> RenderPass3D:
        return RenderPass3D(
            pass_id: -1,
            name: name,
            pass_type: pass_type,
            width: width,
            height: height,
            clear_color_r: 0,
            clear_color_g: 0,
            clear_color_b: 0,
            clear_color_a: 255,
            depth_enabled: true,
            stencil_enabled: false,
            draw_call_count: 0
        )

    static fn shadow_pass(width: i64, height: i64) -> RenderPass3D:
        return RenderPass3D(
            pass_id: -1,
            name: "shadow",
            pass_type: "shadow",
            width: width,
            height: height,
            clear_color_r: 255,
            clear_color_g: 255,
            clear_color_b: 255,
            clear_color_a: 255,
            depth_enabled: true,
            stencil_enabled: false,
            draw_call_count: 0
        )

    me begin() -> text:
        if self.width <= 0 || self.height <= 0:
            return "error: invalid dimensions"
        self.draw_call_count = 0
        return ""

    me draw(mesh_id: i64, material_id: i64, transform_id: i64) -> text:
        if mesh_id < 0:
            return "error: invalid mesh_id"
        if material_id < 0:
            return "error: invalid material_id"
        self.draw_call_count = self.draw_call_count + 1
        return ""

    me end_pass() -> text:
        return ""

    me info() -> text:
        return "RenderPass3D(id=" + self.pass_id.to_text() +
               " name=" + self.name +
               " type=" + self.pass_type +
               " size=" + self.width.to_text() + "x" + self.height.to_text() +
               " draws=" + self.draw_call_count.to_text() + ")"
