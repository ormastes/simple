# engine3d — Multi-Backend 3D Rendering Engine
#
# @tag:stdlib
# @tag:api
# @tag:gpu
#
# Abstract 3D rendering with automatic backend selection.
# Supports CUDA, Vulkan, OpenGL, optimized software, and CPU fallback.
#
# Public API
# ----------
#
# Engine:
#   use std.gpu.engine3d.engine.{Engine3D}
#
# Backends:
#   use std.gpu.engine3d.backend.{RenderBackend3D}
#   use std.gpu.engine3d.backend_cpu.{CpuBackend3D}
#
# Types:
#   use std.gpu.engine3d.types3d.{Vertex3D, Material3DParams, LightParams3D}
#   use std.gpu.engine3d.types3d.{mat4_identity, mat4_perspective, mat4_look_at}
#
# Submodules
# ----------
#
# - types3d:          Vertex3D, Material3DParams, LightParams3D, mat4 utilities
# - backend:          RenderBackend3D trait
# - backend_cpu:      Pure CPU software renderer
# - engine:           Engine3D facade with auto-detection

# Types
export Vertex3D, Material3DParams, LightParams3D, RenderStats3D
export vertex3d, vertex3d_pos, vertex3d_pos_color, vertex3d_pos_normal
export material_unlit, material_phong, material_pbr
export light_directional, light_point, light_spot
export render_stats3d_new

# Constants
export CULL_NONE, CULL_BACK, CULL_FRONT
export BLEND_OPAQUE, BLEND_ALPHA, BLEND_ADDITIVE
export MATERIAL_UNLIT, MATERIAL_PHONG, MATERIAL_PBR
export LIGHT_DIRECTIONAL, LIGHT_POINT, LIGHT_SPOT

# Matrix math
export mat4_identity, mat4_translate, mat4_scale
export mat4_rotate_x, mat4_rotate_y, mat4_rotate_z
export mat4_mul, mat4_transform_point, mat4_transform_dir
export mat4_perspective, mat4_ortho, mat4_look_at

# Vector math
export vec3_dot, vec3_length, vec3_normalize, vec3_cross

# Color helpers
export color3d_r, color3d_g, color3d_b, color3d_a
export color3d_pack, color3d_pack_rgb

# Traits
export RenderBackend3D, Engine3DExtended
export RenderBackend3DCore
export RenderBackend3DAdv
