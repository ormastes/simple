"""3D Engine — Core Backend Trait (Minimum Required Interface)

@tag:stdlib
@tag:api
@tag:gpu

The minimal set of operations every 3D rendering backend MUST implement.
Any backend implementing only RenderBackend3DCore gets all advanced operations
for free via the stateless emulation layer (backend_emu.spl).

Core operations are chosen to be:
  - Irreducible: cannot be composed from other Core operations
  - GPU-friendly: each maps to a single GPU dispatch or state change
  - Sufficient: the emulation layer can build ALL advanced operations from these

See: backend_adv.spl (advanced trait), backend_emu.spl (stateless emulation)
"""

use std.gpu.engine3d.types3d.{Vertex3D, Material3DParams, LightParams3D}
use std.gpu.engine3d.texture3d.{TextureDescriptor3D, SamplerDescriptor3D}

# ============================================================================
# Core Backend Trait
# ============================================================================

trait RenderBackend3DCore:
    """Minimum 3D rendering interface.

    Coordinate system: right-handed, Y-up. Depth: 0.0 (near) to 1.0 (far).
    Colors: packed u32 in ARGB layout (0xAARRGGBB).
    Matrices: column-major [f32; 16].

    A backend that implements ONLY this trait gets full RenderBackend3DAdv
    behavior through the stateless emulation layer.
    """

    # -- Identity --
    fn name() -> text

    # -- Lifecycle --
    me init(width: i32, height: i32) -> bool
    me shutdown()
    me begin_frame()
    me end_frame()
    me present()

    # -- View --
    me set_camera(view: [f32], proj: [f32])
    me set_viewport(x: i32, y: i32, w: i32, h: i32)

    # -- Clear --
    me clear(color: u32)
    me clear_depth()

    # -- Core drawing primitive --
    me submit_triangle(v0: Vertex3D, v1: Vertex3D, v2: Vertex3D, material: Material3DParams, model: [f32])

    # -- Lighting --
    me set_lights(lights: [LightParams3D])
    me set_ambient(color: u32, intensity: f32)

    # -- Render state --
    me set_depth_test(enabled: bool)
    me set_cull_mode(mode: i32)
    me set_blend_mode(mode: i32)
    me set_stencil_mask(mask: [u8], w: i32, h: i32)
    me clear_stencil_mask()

    # -- Render targets --
    me set_render_target(pixels: [u32], w: i32, h: i32)
    me reset_render_target()

    # -- Pixel transfer --
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32])

    # -- Readback --
    fn read_pixels() -> [u32]
    fn read_depth() -> [f32]
    fn width() -> i32
    fn height() -> i32

    # -- Extended texture ops (Chrome WebGPU parity) --
    me create_texture_ex(desc: TextureDescriptor3D, data: [u8]) -> i32
    me create_sampler(desc: SamplerDescriptor3D) -> i32
    me create_texture_view(texture_id: i32, dimension: i32, format: i32, base_mip: i32, mip_count: i32, base_layer: i32, layer_count: i32) -> i32
    me destroy_texture_ex(texture_id: i32)
    me destroy_sampler(sampler_id: i32)
    me write_texture(texture_id: i32, x: i32, y: i32, z: i32, w: i32, h: i32, d: i32, data: [u8])
    me copy_texture_to_texture(src_id: i32, dst_id: i32, src_origin: [i32], dst_origin: [i32], copy_size: [i32])
