"""ROCm/HIP FFI — 3D Engine

@tag:stdlib
@tag:gpu

ROCm/HIP extern declarations for 3D GPU kernels on AMD GPUs.

Usage:
    val ffi = RocmFfi3D.create_static()
"""

use std.gpu.engine3d.ffi_dispatch3d.{GpuFfiMode3D, FfiDispatchBase3D, try_load_gpu_lib_3d}
use std.ffi.dynamic.{DynLib}

# ============================================================================
# Static extern declarations
# ============================================================================

extern fn rt_rocm3d_available() -> bool
extern fn rt_rocm3d_init() -> bool
extern fn rt_rocm3d_shutdown() -> bool
extern fn rt_rocm3d_device_count() -> i64
extern fn rt_rocm3d_transform_vertices(device_ptr: i64, count: i64, mvp: [f32]) -> bool
extern fn rt_rocm3d_rasterize_triangles(verts: i64, tri_count: i64, fb: i64, depth: i64, w: i64, h: i64) -> bool
extern fn rt_rocm3d_clear_framebuffer(fb: i64, w: i64, h: i64, color: u32) -> bool

# ============================================================================
# RocmFfi3D
# ============================================================================

class RocmFfi3D:
    _mode: GpuFfiMode3D
    _dyn_lib: DynLib?

impl RocmFfi3D: FfiDispatchBase3D

    fn mode() -> GpuFfiMode3D:
        self._mode

    fn is_available() -> bool:
        if self._mode == GpuFfiMode3D.Static:
            rt_rocm3d_available()
        else:
            self._dyn_lib != nil

    static fn create_static() -> RocmFfi3D:
        RocmFfi3D(_mode: GpuFfiMode3D.Static, _dyn_lib: nil)

    static fn create_dynamic() -> RocmFfi3D?:
        val lib = try_load_gpu_lib_3d("amdhip64")
        if lib == nil:
            return nil
        RocmFfi3D(_mode: GpuFfiMode3D.Dynamic, _dyn_lib: lib)

    static fn create(mode_pref: GpuFfiMode3D) -> RocmFfi3D:
        if mode_pref == GpuFfiMode3D.Dynamic:
            val dyn_result = RocmFfi3D.create_dynamic()
            if dyn_result != nil:
                return dyn_result
        RocmFfi3D.create_static()

    me init() -> bool:
        rt_rocm3d_init()

    me shutdown() -> bool:
        rt_rocm3d_shutdown()
