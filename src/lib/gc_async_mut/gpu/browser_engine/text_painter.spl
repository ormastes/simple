"""
Browser Engine Text Painter

Provides text layout utilities for the browser engine's block paint pipeline.
Consumed by app.wm_compare.site_corpus_layout_report for corpus analysis.

Functions:
  br_famous_site_corpus_layout_lines(html, font_size, layout_width) -> [text]
      Extract and line-wrap visible text from HTML for corpus comparison.

  br_famous_site_corpus_layout_line_widths_sdn(html, font_size, layout_width) -> text
      Return an SDN-encoded list of line widths for chrome metric comparison.
"""

# ============================================================================
# Text extraction helpers
# ============================================================================

fn _strip_tags(html: text) -> text:
    """Remove all HTML tags, returning raw text content."""
    var result: [text] = []
    var in_tag = false
    var i = 0
    while i < html.len():
        val ch = html.char_at(i)
        if ch == '<':
            in_tag = true
        else if ch == '>':
            in_tag = false
            result.push(" ")
        else if not in_tag:
            result.push(ch.to_text())
        i = i + 1
    result.join("")

fn _normalize_whitespace(s: text) -> text:
    """Collapse runs of whitespace to single spaces and trim."""
    var result: [text] = []
    var prev_space = true   # start true to trim leading
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        val is_ws = ch == ' ' or ch == '\t' or ch == '\n' or ch == '\r'
        if is_ws:
            if not prev_space:
                result.push(" ")
                prev_space = true
        else:
            result.push(ch.to_text())
            prev_space = false
        i = i + 1
    result.join("").trim()

# ============================================================================
# Character width estimation
# ============================================================================

fn _estimate_char_width(font_size: i64) -> f64:
    """Estimate average character width as 0.6 × font_size (monospace-ish)."""
    font_size.to_f64() * 0.6

fn _wrap_text(text_content: text, font_size: i64, layout_width: i32) -> [text]:
    """Wrap text_content into lines no wider than layout_width columns.

    Uses a simple greedy word-wrap algorithm. layout_width is treated as
    character columns (approximately), matching Chrome's metrics format.
    """
    val words = text_content.split(" ")
    var lines: [text] = []
    var current: [text] = []
    var current_len = 0
    val max_cols = layout_width.to_i64()

    var i = 0
    while i < words.len():
        val word = words[i]
        if word.len() == 0:
            i = i + 1
            continue
        val sep = if current_len > 0: 1 else: 0
        if current_len + sep + word.len() <= max_cols:
            current.push(word)
            current_len = current_len + sep + word.len()
        else:
            if current.len() > 0:
                lines.push(current.join(" "))
            current = [word]
            current_len = word.len()
        i = i + 1

    if current.len() > 0:
        lines.push(current.join(" "))

    lines

# ============================================================================
# Public API
# ============================================================================

pub fn br_famous_site_corpus_layout_lines(html: text, font_size: i64, layout_width: i32) -> [text]:
    """Extract visible text from HTML and return wrapped lines.

    Strips tags, normalises whitespace, then wraps to layout_width columns
    at the given font_size. Returns an ordered list of line strings, matching
    the 'text' fields in Chrome's JSON metrics for corpus comparison.
    """
    val raw = _strip_tags(html)
    val normalized = _normalize_whitespace(raw)
    if normalized.len() == 0:
        return []
    _wrap_text(normalized, font_size, layout_width)

pub fn br_famous_site_corpus_layout_line_widths_sdn(html: text, font_size: i64, layout_width: i32) -> text:
    """Return an SDN-encoded list of (line, width_px) pairs.

    Each entry records the visible text of a wrapped line and its estimated
    pixel width for comparison with Chrome's layout metrics JSON.
    """
    val lines = br_famous_site_corpus_layout_lines(html, font_size, layout_width)
    val char_w = _estimate_char_width(font_size)
    var entries: [text] = []
    var i = 0
    while i < lines.len():
        val line = lines[i]
        val width_px = (line.len().to_f64() * char_w).to_i64()
        entries.push("    (line text: \"{line}\" width: {width_px})")
        i = i + 1
    "(text_lines count: {lines.len()}\n" + entries.join("\n") + "\n)"

pub fn br_famous_site_corpus_layout_lines_sdn(html: text, font_size: i64, layout_width: i32) -> text:
    val lines = br_famous_site_corpus_layout_lines(html, font_size, layout_width)
    var entries: [text] = []
    var i = 0
    while i < lines.len():
        val line = lines[i]
        entries.push("    (line text: \"{line}\")")
        i = i + 1
    "(text_lines count: {lines.len()}\n" + entries.join("\n") + "\n)"
