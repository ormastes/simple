use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, StyleProps}

enum BeBoxKind:
    """Layout box type discriminant."""
    Block
    Inline
    InlineBlock
    Flex
    Text
    Anonymous

class BeLayoutBox:
    """A computed layout box: geometry, children, and source node reference."""
    node_id: i64          # corresponding BeDomNode.node_id, or -1 for anonymous
    kind: BeBoxKind
    # Computed geometry (pixels from content-area origin)
    x: f64
    y: f64
    width: f64
    height: f64
    # Box model
    margin_top: f64
    margin_right: f64
    margin_bottom: f64
    margin_left: f64
    padding_top: f64
    padding_right: f64
    padding_bottom: f64
    padding_left: f64
    border_width: f64
    # Content
    text_content: text    # non-empty for text boxes
    tag_name: text
    style: StyleProps
    children: [BeLayoutBox]

impl BeLayoutBox:
    static fn block_for(node: BeDomNode, x: f64, y: f64, width: f64, height: f64) -> BeLayoutBox:
        """Construct a block box for a DOM element."""
        BeLayoutBox(
            node_id: node.node_id,
            kind: BeBoxKind.Block,
            x: x,
            y: y,
            width: width,
            height: height,
            margin_top: node.style.margin_top,
            margin_right: node.style.margin_right,
            margin_bottom: node.style.margin_bottom,
            margin_left: node.style.margin_left,
            padding_top: node.style.padding_top,
            padding_right: node.style.padding_right,
            padding_bottom: node.style.padding_bottom,
            padding_left: node.style.padding_left,
            border_width: node.style.border_width,
            text_content: "",
            tag_name: node.tag_name,
            style: node.style,
            children: []
        )

    static fn text_box(node: BeDomNode, data: text, x: f64, y: f64, width: f64, height: f64) -> BeLayoutBox:
        """Construct a text layout box."""
        BeLayoutBox(
            node_id: node.node_id,
            kind: BeBoxKind.Text,
            x: x,
            y: y,
            width: width,
            height: height,
            margin_top: 0.0,
            margin_right: 0.0,
            margin_bottom: 0.0,
            margin_left: 0.0,
            padding_top: 0.0,
            padding_right: 0.0,
            padding_bottom: 0.0,
            padding_left: 0.0,
            border_width: 0.0,
            text_content: data,
            tag_name: "#text",
            style: node.style,
            children: []
        )

    fn content_width() -> f64:
        self.width - self.padding_left - self.padding_right - self.border_width * 2.0

    fn content_height() -> f64:
        self.height - self.padding_top - self.padding_bottom - self.border_width * 2.0

    fn content_x() -> f64:
        self.x + self.padding_left + self.border_width

    fn content_y() -> f64:
        self.y + self.padding_top + self.border_width
