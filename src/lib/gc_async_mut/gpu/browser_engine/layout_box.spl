
# CSS Layout Box Types
#
# BeLayoutBox — the primary positioned box in the layout tree.
# BePointerActivationDispatch — pointer event sequence result.
#
# Placed in a separate module so layout_flex.spl, layout_block_be.spl,
# layout_paint.spl, and layout.spl can all import BeLayoutBox without
# circular dependencies.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, BeDomEventDispatch}

# =========================================================================
# Layout Box
# =========================================================================

pub class BeLayoutBox:
    """A positioned box in the layout tree.

    The outer box (x, y, width, height) includes margin.
    The content box (content_x, content_y, content_width, content_height)
    is inset by margin + border + padding.

    Fields:
        x, y              - top-left corner of the margin box
        width, height     - total size including margin
        content_x, content_y     - top-left corner of the content area
        content_width, content_height - size of the content area
        node              - the DOM node this box corresponds to
        children          - child layout boxes
    """
    x: i32
    y: i32
    width: i32
    height: i32
    content_x: i32
    content_y: i32
    content_width: i32
    content_height: i32
    node: BeDomNode
    children: [BeLayoutBox]

    static fn empty(node: BeDomNode) -> BeLayoutBox:
        return BeLayoutBox(
            x: 0, y: 0, width: 0, height: 0,
            content_x: 0, content_y: 0,
            content_width: 0, content_height: 0,
            node: node, children: []
        )

pub class BePointerActivationDispatch:
    """Simplified pointer activation sequence result for hit-tested input."""
    down: BeDomEventDispatch
    up: BeDomEventDispatch
    click: BeDomEventDispatch
    click_synthesized: bool

    static fn create(down: BeDomEventDispatch, up: BeDomEventDispatch,
                     click: BeDomEventDispatch, click_synthesized: bool) -> BePointerActivationDispatch:
        BePointerActivationDispatch(
            down: down,
            up: up,
            click: click,
            click_synthesized: click_synthesized
        )
