
# CSS Layout — M14 Public API Types
#
# Public types and utilities for M14 spec-facing layout API.
# No BeLayoutBox field access — safe to import cross-module.

# =========================================================================
# M14 Public Layout Types
# =========================================================================

# LayoutContext — passed by specs to control available space
pub class LayoutContext:
    """Layout context carrying available width and height for M14 layout functions."""
    available_width: i32
    available_height: i32

pub fn layout_context_new(width: i32, height: i32) -> LayoutContext:
    """Create a LayoutContext with the given available dimensions."""
    LayoutContext(available_width: width, available_height: height)

# InlineFragment — a single laid-out inline piece (text run or inline element)
pub class InlineFragment:
    """A positioned fragment in an inline formatting context."""
    x: i32
    y: i32
    width: i32
    height: i32
    baseline_offset: i32
    text_run: text

# LineBox — one line in an IFC
pub class LineBox:
    """A single line box in an inline formatting context."""
    x: i32
    y: i32
    width: i32
    height: i32
    baseline: i32
    fragments: [InlineFragment]

# LayoutBox — M14 public layout result (parallel to BeLayoutBox for specs)
pub class LayoutBox:
    """Public layout result used by M14 specs."""
    x: i32
    y: i32
    width: i32
    height: i32
    is_anonymous: bool
    line_boxes: [LineBox]
    children: [LayoutBox]

fn _layout_box_empty() -> LayoutBox:
    LayoutBox(x: 0, y: 0, width: 0, height: 0, is_anonymous: false, line_boxes: [], children: [])

# =========================================================================
# collapse_margins_signed — CSS 2.2 §8.3.1
# =========================================================================

pub fn collapse_margins_signed(a: i32, b: i32) -> i32:
    """Collapse two margins per CSS 2.2 §8.3.1: max(positives) + min(negatives)."""
    var max_pos = 0
    var min_neg = 0
    if a > 0:
        max_pos = a
    else:
        min_neg = a
    if b > 0:
        if b > max_pos:
            max_pos = b
    else:
        if b < min_neg:
            min_neg = b
    max_pos + min_neg
