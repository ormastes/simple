use std.gc_async_mut.gpu.browser_engine.browser_script_execute.{execute_scripts_in_html}
use std.gc_async_mut.gpu.browser_engine.simple_web_file_renderer.{
    simple_web_render_html_to_rgba_bytes,
    simple_web_render_url_to_pixels
}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

pub fn simple_web_render_url_to_pixels_with_scripts(url: text, width: i64, height: i64) -> [u8]:
    if url.starts_with("about:"):
        return simple_web_render_url_to_pixels(url, width, height)

    if url.starts_with("file://"):
        val path = url.substring(7, url.len())
        if rt_file_exists(path):
            val html_str = rt_file_read_text(path)
            execute_scripts_in_html(html_str)
            return simple_web_render_html_to_rgba_bytes(html_str, width, height)
        return simple_web_render_url_to_pixels("about:blank", width, height)

    simple_web_render_url_to_pixels("about:blank", width, height)
