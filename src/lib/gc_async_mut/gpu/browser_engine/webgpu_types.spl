"""Browser WebGPU API types.

These mirror the browser-facing WebGPU object model closely enough for
secure-context negotiation, WGSL validation, and deterministic MVP tests.
"""

pub val GPU_FEATURE_DEPTH_CLIP_CONTROL: text = "depth-clip-control"
pub val GPU_FEATURE_DEPTH32FLOAT_STENCIL8: text = "depth32float-stencil8"
pub val GPU_FEATURE_TEXTURE_COMPRESSION_BC: text = "texture-compression-bc"
pub val GPU_FEATURE_TEXTURE_COMPRESSION_ETC2: text = "texture-compression-etc2"
pub val GPU_FEATURE_TEXTURE_COMPRESSION_ASTC: text = "texture-compression-astc"
pub val GPU_FEATURE_INDIRECT_FIRST_INSTANCE: text = "indirect-first-instance"
pub val GPU_FEATURE_SHADER_F16: text = "shader-f16"
pub val GPU_FEATURE_FLOAT32_FILTERABLE: text = "float32-filterable"
pub val GPU_FEATURE_FLOAT32_BLENDABLE: text = "float32-blendable"
pub val GPU_FEATURE_CLIP_DISTANCES: text = "clip-distances"
pub val GPU_FEATURE_DUAL_SOURCE_BLENDING: text = "dual-source-blending"
pub val GPU_FEATURE_SUBGROUPS: text = "subgroups"

pub val GPU_POWER_LOW: i32 = 0
pub val GPU_POWER_HIGH: i32 = 1

pub val GPU_TEXTURE_FORMAT_BGRA8_UNORM: text = "bgra8unorm"
pub val GPU_TEXTURE_FORMAT_RGBA8_UNORM: text = "rgba8unorm"
pub val GPU_TEXTURE_FORMAT_RGBA16_FLOAT: text = "rgba16float"
pub val GPU_TEXTURE_FORMAT_DEPTH24_PLUS: text = "depth24plus"
pub val GPU_TEXTURE_USAGE_RENDER_ATTACHMENT: i32 = 16

pub class GPUAdapterInfo:
    vendor: text
    architecture: text
    device: text
    description: text

    static fn create(vendor: text, architecture: text, device: text, description: text) -> GPUAdapterInfo:
        GPUAdapterInfo(vendor: vendor, architecture: architecture, device: device, description: description)

    static fn software() -> GPUAdapterInfo:
        GPUAdapterInfo(
            vendor: "simple",
            architecture: "software",
            device: "simple-webgpu-fallback",
            description: "Simple WebGPU software fallback adapter"
        )

pub class GPUDeviceLimits:
    max_texture_dimension_1d: i32
    max_texture_dimension_2d: i32
    max_texture_dimension_3d: i32
    max_texture_array_layers: i32
    max_bind_groups: i32
    max_storage_buffers_per_shader_stage: i32
    max_compute_workgroup_size_x: i32
    max_compute_workgroup_size_y: i32
    max_compute_workgroup_size_z: i32
    max_compute_invocations_per_workgroup: i32
    max_buffer_size: i64
    max_vertex_buffers: i32
    max_vertex_attributes: i32

    static fn defaults() -> GPUDeviceLimits:
        GPUDeviceLimits(
            max_texture_dimension_1d: 8192,
            max_texture_dimension_2d: 8192,
            max_texture_dimension_3d: 2048,
            max_texture_array_layers: 256,
            max_bind_groups: 4,
            max_storage_buffers_per_shader_stage: 8,
            max_compute_workgroup_size_x: 256,
            max_compute_workgroup_size_y: 256,
            max_compute_workgroup_size_z: 64,
            max_compute_invocations_per_workgroup: 256,
            max_buffer_size: 268435456,
            max_vertex_buffers: 8,
            max_vertex_attributes: 16
        )

pub class GPURequestAdapterOptions:
    power_preference: i32
    force_fallback_adapter: bool

    static fn default_options() -> GPURequestAdapterOptions:
        GPURequestAdapterOptions(power_preference: GPU_POWER_HIGH, force_fallback_adapter: false)

    static fn fallback() -> GPURequestAdapterOptions:
        GPURequestAdapterOptions(power_preference: GPU_POWER_LOW, force_fallback_adapter: true)

pub class GPUDeviceDescriptor:
    required_features: [text]
    required_limits: GPUDeviceLimits
    label: text

    static fn create() -> GPUDeviceDescriptor:
        GPUDeviceDescriptor(required_features: [], required_limits: GPUDeviceLimits.defaults(), label: "")

    static fn with_features(features: [text]) -> GPUDeviceDescriptor:
        GPUDeviceDescriptor(required_features: features, required_limits: GPUDeviceLimits.defaults(), label: "")

pub class GPUCanvasConfiguration:
    device_id: i32
    format: text
    usage: i32
    alpha_mode: text
    width: i32
    height: i32

    static fn create(device_id: i32, format: text, usage: i32, width: i32, height: i32) -> GPUCanvasConfiguration:
        GPUCanvasConfiguration(
            device_id: device_id,
            format: format,
            usage: usage,
            alpha_mode: "opaque",
            width: width,
            height: height
        )

pub class GPUShaderModule:
    id: i32
    label: text
    source: text
    valid: bool
    stage: text
    error: text

pub class GPUPipelineHandle:
    id: i32
    kind: text
    valid: bool
    error: text
