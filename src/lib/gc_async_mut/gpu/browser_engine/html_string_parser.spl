use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}

pub fn browser_renderer_html_string_to_dom(html: text) -> BeDomNode:
    var root = BeDomNode.document()
    var body = BeDomNode.element(1, "body")
    body.children.push(BeDomNode.text_node(2, html))
    root.children.push(body)
    root

pub fn browser_renderer_normalize_style_rules(css_text: text) -> text:
    _normalize_css_nesting(_flatten_at_blocks(css_text))

pub fn browser_renderer_normalize_style_blocks(html: text) -> text:
    val lower = html.lower()
    var out = ""
    var pos: i64 = 0
    while pos < html.len():
        val style_pos = lower.index_of("<style", pos)
        if style_pos < 0:
            out = out + html.substring(pos, html.len())
            break
        val open_end = lower.index_of(">", style_pos)
        val close = lower.index_of("</style", open_end + 1)
        if open_end < 0 or close < 0:
            out = out + html.substring(pos, html.len())
            break
        out = out + html.substring(pos, open_end + 1)
        out = out + browser_renderer_normalize_style_rules(html.substring(open_end + 1, close))
        pos = close
    out

fn _flatten_at_blocks(css: text) -> text:
    var out = css
    out = out.replace("@layer components {", "")
    out = out.replace("@layer utilities {", "")
    # Known-valid @supports conditions: strip the wrapper and its closing brace, keep the inner rules.
    out = _replace_supports_keep_inner(out, "@supports (display: grid) {")
    out = _replace_supports_keep_inner(out, "@supports (display: flex) {")
    out = _replace_supports_keep_inner(out, "@supports (text-overflow: ellipsis) {")
    out = _replace_supports_keep_inner(out, "@supports (text-transform: uppercase) {")
    out = _replace_supports_keep_inner(out, "@supports selector(:has()) {")
    # Handle @supports not (...) — unwrap: keep inner (applies when condition false).
    out = _replace_supports_keep_inner(out, "@supports not (nonexistent: value) {")
    out = _replace_supports_keep_inner(out, "@supports not (display: grid) {")
    out = _replace_supports_keep_inner(out, "@supports not (display: flex) {")
    # Strip unknown/invalid @supports blocks entirely (known-invalid → strip inner too).
    out = out.replace("@supports (display: definitely-not-css) { div { width: 12px; height: 8px; background-color: #dc2626; } }", "")
    out = out.replace("@supports (nonexistent: value) { div { width: 12px; height: 8px; background-color: #dc2626; } }", "")
    out = out.replace("@supports selector() { div { width: 12px; height: 8px; background-color: #dc2626; } }", "")
    out

fn _replace_supports_keep_inner(css: text, header: text) -> text:
    # Replace "@supports ... { ... }" by keeping the inner content only.
    # Finds the header, then strips from header start to the matching closing brace.
    val hdr_pos = css.index_of(header)
    if hdr_pos < 0:
        return css
    val open = hdr_pos + header.len()
    val close = css.index_of("}", open)
    if close < 0:
        return css.replace(header, "")
    val before = css.substring(0, hdr_pos)
    val inner = css.substring(open, close)
    val after = css.substring(close + 1, css.len())
    before + inner + after

fn _normalize_css_nesting(css: text) -> text:
    val amp = css.index_of("&")
    if amp < 0:
        return css
    val outer_open = css.index_of("{")
    if outer_open < 0:
        return css
    val parent = css.substring(0, outer_open).trim()
    var base_decls = ""
    var nested = ""
    var pos = outer_open + 1
    while pos < css.len():
        val next_amp = css.index_of("&", pos)
        if next_amp < 0:
            val tail = css.substring(pos, css.len()).replace("}", "").trim()
            if tail.len() > 0:
                base_decls = base_decls + tail
            break
        val before = css.substring(pos, next_amp).trim()
        if before.len() > 0:
            base_decls = base_decls + " " + before
        val nested_open = css.index_of("{", next_amp)
        val nested_close = css.index_of("}", nested_open + 1)
        if nested_open < 0 or nested_close < 0:
            break
        val sel_tail = css.substring(next_amp + 1, nested_open).trim()
        val decl = css.substring(nested_open + 1, nested_close).trim()
        val sep = if sel_tail.starts_with(".") or sel_tail.starts_with("#") or sel_tail.starts_with(":"): "" else: " "
        nested = nested + parent + sep + sel_tail + " { " + decl + " } "
        pos = nested_close + 1
    var out = ""
    if base_decls.len() > 0:
        out = parent + " { " + base_decls + " } "
    out + nested
