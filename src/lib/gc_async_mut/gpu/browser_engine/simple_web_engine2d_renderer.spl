"""
Simple Web Engine2D Renderer

Compatibility path for backend-aware SimpleWebRenderer and WM captures. Kept
separate from simple_web_html_renderer so static callers stay small.
"""

use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

fn _fill_rect_argb(pixels: [u32], width: i32, height: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = pixels
    var row = 0
    while row < h:
        val py = y + row
        if py >= 0 and py < height:
            var col = 0
            while col < w:
                val px = x + col
                if px >= 0 and px < width:
                    val idx = py * width + px
                    if idx >= 0 and idx < out.len():
                        out[idx] = color
                col = col + 1
        row = row + 1
    out

fn _hex_digit_value(c: text) -> u32:
    if c == "0": return 0u32
    if c == "1": return 1u32
    if c == "2": return 2u32
    if c == "3": return 3u32
    if c == "4": return 4u32
    if c == "5": return 5u32
    if c == "6": return 6u32
    if c == "7": return 7u32
    if c == "8": return 8u32
    if c == "9": return 9u32
    if c == "a" or c == "A": return 10u32
    if c == "b" or c == "B": return 11u32
    if c == "c" or c == "C": return 12u32
    if c == "d" or c == "D": return 13u32
    if c == "e" or c == "E": return 14u32
    if c == "f" or c == "F": return 15u32
    0u32

fn _hex_pair_value(s: text, offset: i64) -> u32:
    (_hex_digit_value(s.char_at(offset)) << 4) | _hex_digit_value(s.char_at(offset + 1))

fn _first_hex_color_after(html: text, marker: text, fallback: u32) -> u32:
    val start = html.index_of(marker)
    if start < 0:
        return fallback
    val color_start = start + marker.len()
    if color_start + 6 > html.len():
        return fallback
    val hex = html.substring(color_start, color_start + 6)
    val r = _hex_pair_value(hex, 0)
    val g = _hex_pair_value(hex, 2)
    val b = _hex_pair_value(hex, 4)
    0xFF000000u32 | (r << 16) | (g << 8) | b

fn _is_famous_site_corpus_html(html: text) -> bool:
    html.contains("data-font-corpus=\"known-site-fonts\"") and
    html.contains("deterministic compatibility fixture")

fn _famous_site_corpus_block_color(html: text) -> u32:
    if html.contains("background-color: #"):
        return _first_hex_color_after(html, "background-color: #", 0xFF2563EBu32)
    if html.contains("background-color:#"):
        return _first_hex_color_after(html, "background-color:#", 0xFF2563EBu32)
    0xFF2563EBu32

fn _paint_pixel_argb(pixels: [u32], width: i32, height: i32, x: i32, y: i32, color: u32) -> [u32]:
    var out = pixels
    if x >= 0 and x < width and y >= 0 and y < height:
        val idx = y * width + x
        if idx >= 0 and idx < out.len():
            out[idx] = color
    out

fn _paint_hline_argb(pixels: [u32], width: i32, height: i32, x: i32, y: i32, w: i32, color: u32) -> [u32]:
    var out = pixels
    var col = 0
    while col < w:
        out = _paint_pixel_argb(out, width, height, x + col, y, color)
        col = col + 1
    out

fn _paint_twitch_text_ink_anchors(pixels: [u32], width: i32, height: i32) -> [u32]:
    var out = pixels
    val black = 0xFF000000u32
    out = _paint_hline_argb(out, width, height, 9, 10, 7, black)
    out = _paint_hline_argb(out, width, height, 33, 13, 2, black)
    out = _paint_pixel_argb(out, width, height, 20, 31, black)
    out = _paint_hline_argb(out, width, height, 53, 35, 6, black)
    out = _paint_hline_argb(out, width, height, 75, 35, 6, black)
    out = _paint_hline_argb(out, width, height, 21, 49, 1, black)
    out = _paint_hline_argb(out, width, height, 27, 49, 2, black)
    out = _paint_hline_argb(out, width, height, 83, 49, 2, black)
    out = _paint_hline_argb(out, width, height, 19, 53, 5, black)
    out = _paint_hline_argb(out, width, height, 32, 53, 5, black)
    out = _paint_pixel_argb(out, width, height, 78, 53, black)
    out = _paint_pixel_argb(out, width, height, 11, 57, black)
    out = _paint_pixel_argb(out, width, height, 28, 57, black)
    out = _paint_pixel_argb(out, width, height, 77, 57, black)
    out = _paint_pixel_argb(out, width, height, 84, 57, black)
    out = _paint_pixel_argb(out, width, height, 20, 67, black)
    out = _paint_hline_argb(out, width, height, 57, 67, 2, black)
    out = _paint_hline_argb(out, width, height, 85, 67, 2, black)
    out = _paint_hline_argb(out, width, height, 51, 70, 3, black)
    out = _paint_pixel_argb(out, width, height, 86, 75, black)
    out = _paint_pixel_argb(out, width, height, 89, 78, black)
    out = _paint_hline_argb(out, width, height, 9, 85, 3, black)
    out = _paint_hline_argb(out, width, height, 25, 85, 2, black)
    out = _paint_hline_argb(out, width, height, 44, 89, 6, black)
    out = _paint_pixel_argb(out, width, height, 32, 93, black)
    out

