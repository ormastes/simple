    elif name == "mediumslateblue": return _css_argb(255, 123, 104, 238)
    elif name == "mediumspringgreen": return _css_argb(255, 0, 250, 154)
    elif name == "mediumturquoise": return _css_argb(255, 72, 209, 204)
    elif name == "mediumvioletred": return _css_argb(255, 199, 21, 133)
    elif name == "midnightblue": return _css_argb(255, 25, 25, 112)
    elif name == "mintcream": return _css_argb(255, 245, 255, 250)
    elif name == "mistyrose": return _css_argb(255, 255, 228, 225)
    elif name == "moccasin": return _css_argb(255, 255, 228, 181)
    elif name == "navajowhite": return _css_argb(255, 255, 222, 173)
    elif name == "oldlace": return _css_argb(255, 253, 245, 230)
    elif name == "olivedrab": return _css_argb(255, 107, 142, 35)
    elif name == "orangered": return _css_argb(255, 255, 69, 0)
    elif name == "orchid": return _css_argb(255, 218, 112, 214)
    elif name == "palegoldenrod": return _css_argb(255, 238, 232, 170)
    elif name == "palegreen": return _css_argb(255, 152, 251, 152)
    elif name == "paleturquoise": return _css_argb(255, 175, 238, 238)
    elif name == "palevioletred": return _css_argb(255, 219, 112, 147)
    elif name == "papayawhip": return _css_argb(255, 255, 239, 213)
    elif name == "peachpuff": return _css_argb(255, 255, 218, 185)
    elif name == "peru": return _css_argb(255, 205, 133, 63)
    elif name == "pink": return _css_argb(255, 255, 192, 203)
    elif name == "plum": return _css_argb(255, 221, 160, 221)
    elif name == "powderblue": return _css_argb(255, 176, 224, 230)
    elif name == "rosybrown": return _css_argb(255, 188, 143, 143)
    elif name == "royalblue": return _css_argb(255, 65, 105, 225)
    elif name == "saddlebrown": return _css_argb(255, 139, 69, 19)
    elif name == "salmon": return _css_argb(255, 250, 128, 114)
    elif name == "sandybrown": return _css_argb(255, 244, 164, 96)
    elif name == "seagreen": return _css_argb(255, 46, 139, 87)
    elif name == "seashell": return _css_argb(255, 255, 245, 238)
    elif name == "sienna": return _css_argb(255, 160, 82, 45)
    elif name == "skyblue": return _css_argb(255, 135, 206, 235)
    elif name == "slateblue": return _css_argb(255, 106, 90, 205)
