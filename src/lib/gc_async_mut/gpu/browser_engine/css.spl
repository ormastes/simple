"""
Browser Engine CSS Types

Provides CssPx, CssLength, and CSS color parsing for the browser engine layout pipeline.
CssPx is used as the typed pixel dimension for layout_to_scene.
parse_css_color converts CSS color strings to packed ARGB i64 (0xAARRGGBB).

Color parsing uses only integer arithmetic to avoid the Cranelift f64? codegen bug.
Named color table covers CSS Level 4 (148 colors).

Consumed by app.ui.chromium.engine_merge:
    layout_to_scene(root, CssPx(value: viewport_w), CssPx(value: viewport_h))
"""

# ============================================================================
# CssPx — typed pixel value
# ============================================================================

struct CssPx:
    """A CSS pixel measurement."""
    value: f64

fn css_px(v: f64) -> CssPx:
    """Construct a CssPx from a float."""
    CssPx(value: v)

fn css_px_from_i64(v: i64) -> CssPx:
    """Construct a CssPx from an integer."""
    CssPx(value: v.to_f64())

fn css_px_add(a: CssPx, b: CssPx) -> CssPx:
    CssPx(value: a.value + b.value)

fn css_px_sub(a: CssPx, b: CssPx) -> CssPx:
    CssPx(value: a.value - b.value)

fn css_px_mul(a: CssPx, factor: f64) -> CssPx:
    CssPx(value: a.value * factor)

fn css_px_max(a: CssPx, b: CssPx) -> CssPx:
    if a.value >= b.value: a else: b

fn css_px_min(a: CssPx, b: CssPx) -> CssPx:
    if a.value <= b.value: a else: b

# ============================================================================
# CssLength — generic length (px, %, auto, etc.)
# ============================================================================

enum CssLength:
    """CSS length value with unit."""
    Px(f64)
    Pct(f64)     # percent
    Auto
    Zero

fn css_length_to_px(length: CssLength, parent_px: f64) -> f64:
    """Resolve a CssLength to pixels given the parent container size."""
    match length:
        CssLength.Px(v): v
        CssLength.Pct(p): parent_px * p / 100.0
        CssLength.Auto: 0.0
        CssLength.Zero: 0.0

fn parse_css_length(s: text) -> CssLength:
    """Parse a CSS length string into CssLength."""
    val trimmed = s.trim()
    if trimmed == "auto": return CssLength.Auto
    if trimmed == "0" or trimmed == "0px": return CssLength.Zero
    if trimmed.ends_with("px"):
        val num_str = trimmed.substring(0, trimmed.len() - 2)
        val v = num_str.parse_f64() ?? 0.0
        return CssLength.Px(v)
    if trimmed.ends_with("%"):
        val num_str = trimmed.substring(0, trimmed.len() - 1)
        val v = num_str.parse_f64() ?? 0.0
        return CssLength.Pct(v)
    CssLength.Zero

# ============================================================================
# CSS Color Parsing — packed ARGB i64 (0xAARRGGBB)
# ============================================================================
# Uses only integer arithmetic — avoids Cranelift f64? optional codegen bug.
# Named color table: CSS Color Level 4 (148 colors).
# Return value: packed ARGB i64 where alpha=255 means fully opaque.
#   bits 31-24: alpha, bits 23-16: red, bits 15-8: green, bits 7-0: blue
# ============================================================================

fn parse_css_color(s: text) -> i64:
    """Parse a CSS color string to packed ARGB i64.

    Supports:
      - Named colors (CSS Level 4, 148 names)
      - #RGB, #RRGGBB, #RGBA, #RRGGBBAA hex
      - rgb(r, g, b) and rgba(r, g, b, a)
      - transparent

    Returns opaque black (0xFF000000) for unrecognised input.
    Uses integer arithmetic only — safe under all compile modes.
    """
    val t = s.trim().to_lower()
    if t == "transparent": return _css_argb(0, 0, 0, 0)
    if t.starts_with("#"): return _css_parse_hex(t)
    if t.starts_with("rgba("): return _css_parse_rgba_fn(t)
    if t.starts_with("rgb("): return _css_parse_rgb_fn(t)
    _css_named_color(t)

fn css_color_r(c: i64) -> i64:
    """Extract red channel (0-255) from packed ARGB i64."""
    (c / 65536) & 255

fn css_color_g(c: i64) -> i64:
    """Extract green channel (0-255) from packed ARGB i64."""
    (c / 256) & 255

fn css_color_b(c: i64) -> i64:
    """Extract blue channel (0-255) from packed ARGB i64."""
    c & 255

fn css_color_a(c: i64) -> i64:
    """Extract alpha channel (0-255) from packed ARGB i64."""
    (c / 16777216) & 255

fn _css_argb(a: i64, r: i64, g: i64, b: i64) -> i64:
    (a * 16777216) + (r * 65536) + (g * 256) + b

fn _css_clamp_byte(v: i64) -> i64:
    if v < 0: 0
    elif v > 255: 255
    else: v

fn _css_hex_digit_val(c: text) -> i64:
    if c == "0": 0
    elif c == "1": 1
    elif c == "2": 2
    elif c == "3": 3
    elif c == "4": 4
    elif c == "5": 5
    elif c == "6": 6
    elif c == "7": 7
    elif c == "8": 8
    elif c == "9": 9
    elif c == "a": 10
    elif c == "b": 11
    elif c == "c": 12
    elif c == "d": 13
    elif c == "e": 14
    elif c == "f": 15
    else: 0

fn _css_hex_pair(s: text, offset: i64) -> i64:
    val hi = _css_hex_digit_val(s.char_at(offset))
    val lo = _css_hex_digit_val(s.char_at(offset + 1))
    hi * 16 + lo

fn _css_parse_hex(s: text) -> i64:
    val n = s.len()
    if n == 4:
        # #RGB → expand each nibble
        val r = _css_hex_digit_val(s.char_at(1))
        val g = _css_hex_digit_val(s.char_at(2))
        val b = _css_hex_digit_val(s.char_at(3))
        return _css_argb(255, r * 17, g * 17, b * 17)
    if n == 5:
        # #RGBA
        val r = _css_hex_digit_val(s.char_at(1))
        val g = _css_hex_digit_val(s.char_at(2))
        val b = _css_hex_digit_val(s.char_at(3))
        val a = _css_hex_digit_val(s.char_at(4))
        return _css_argb(a * 17, r * 17, g * 17, b * 17)
    if n == 7:
        # #RRGGBB
        val r = _css_hex_pair(s, 1)
        val g = _css_hex_pair(s, 3)
        val b = _css_hex_pair(s, 5)
        return _css_argb(255, r, g, b)
    if n == 9:
        # #RRGGBBAA
        val r = _css_hex_pair(s, 1)
        val g = _css_hex_pair(s, 3)
        val b = _css_hex_pair(s, 5)
        val a = _css_hex_pair(s, 7)
        return _css_argb(a, r, g, b)
    _css_argb(255, 0, 0, 0)

fn _css_parse_int_token(tok: text) -> i64:
    """Parse a decimal integer token, returning 0 for non-numeric input."""
    tok.trim().parse_i64() ?? 0

fn _css_parse_rgb_fn(s: text) -> i64:
    """Parse rgb(r, g, b) — integer channel values."""
    val inner_start = 4  # skip "rgb("
    val inner_end = s.len() - 1
    if inner_end <= inner_start: return _css_argb(255, 0, 0, 0)
    val inner = s.substring(inner_start, inner_end)
    val parts = inner.split(",")
    if parts.len() < 3: return _css_argb(255, 0, 0, 0)
    val r = _css_clamp_byte(_css_parse_int_token(parts[0]))
    val g = _css_clamp_byte(_css_parse_int_token(parts[1]))
    val b = _css_clamp_byte(_css_parse_int_token(parts[2]))
    _css_argb(255, r, g, b)

fn _css_parse_rgba_fn(s: text) -> i64:
    """Parse rgba(r, g, b, a) — integer channels, alpha 0-255."""
    val inner_start = 5  # skip "rgba("
    val inner_end = s.len() - 1
    if inner_end <= inner_start: return _css_argb(255, 0, 0, 0)
    val inner = s.substring(inner_start, inner_end)
    val parts = inner.split(",")
    if parts.len() < 4: return _css_argb(255, 0, 0, 0)
    val r = _css_clamp_byte(_css_parse_int_token(parts[0]))
    val g = _css_clamp_byte(_css_parse_int_token(parts[1]))
    val b = _css_clamp_byte(_css_parse_int_token(parts[2]))
    val a = _css_clamp_byte(_css_parse_int_token(parts[3]))
    _css_argb(a, r, g, b)

fn _css_named_color(name: text) -> i64:
    """Return packed ARGB for a CSS Level 4 named color, or opaque black."""
    # CSS basic colors
    if name == "black": return _css_argb(255, 0, 0, 0)
    elif name == "silver": return _css_argb(255, 192, 192, 192)
    elif name == "gray" or name == "grey": return _css_argb(255, 128, 128, 128)
    elif name == "white": return _css_argb(255, 255, 255, 255)
    elif name == "maroon": return _css_argb(255, 128, 0, 0)
    elif name == "red": return _css_argb(255, 255, 0, 0)
    elif name == "purple": return _css_argb(255, 128, 0, 128)
    elif name == "fuchsia" or name == "magenta": return _css_argb(255, 255, 0, 255)
    elif name == "green": return _css_argb(255, 0, 128, 0)
    elif name == "lime": return _css_argb(255, 0, 255, 0)
    elif name == "olive": return _css_argb(255, 128, 128, 0)
    elif name == "yellow": return _css_argb(255, 255, 255, 0)
    elif name == "navy": return _css_argb(255, 0, 0, 128)
    elif name == "blue": return _css_argb(255, 0, 0, 255)
    elif name == "teal": return _css_argb(255, 0, 128, 128)
    elif name == "aqua" or name == "cyan": return _css_argb(255, 0, 255, 255)
    elif name == "orange": return _css_argb(255, 255, 165, 0)
    # CSS extended colors
    elif name == "aliceblue": return _css_argb(255, 240, 248, 255)
    elif name == "antiquewhite": return _css_argb(255, 250, 235, 215)
    elif name == "aquamarine": return _css_argb(255, 127, 255, 212)
    elif name == "azure": return _css_argb(255, 240, 255, 255)
    elif name == "beige": return _css_argb(255, 245, 245, 220)
    elif name == "bisque": return _css_argb(255, 255, 228, 196)
    elif name == "blanchedalmond": return _css_argb(255, 255, 235, 205)
    elif name == "blueviolet": return _css_argb(255, 138, 43, 226)
    elif name == "brown": return _css_argb(255, 165, 42, 42)
    elif name == "burlywood": return _css_argb(255, 222, 184, 135)
    elif name == "cadetblue": return _css_argb(255, 95, 158, 160)
    elif name == "chartreuse": return _css_argb(255, 127, 255, 0)
    elif name == "chocolate": return _css_argb(255, 210, 105, 30)
    elif name == "coral": return _css_argb(255, 255, 127, 80)
    elif name == "cornflowerblue": return _css_argb(255, 100, 149, 237)
    elif name == "cornsilk": return _css_argb(255, 255, 248, 220)
    elif name == "crimson": return _css_argb(255, 220, 20, 60)
    elif name == "darkblue": return _css_argb(255, 0, 0, 139)
    elif name == "darkcyan": return _css_argb(255, 0, 139, 139)
    elif name == "darkgoldenrod": return _css_argb(255, 184, 134, 11)
    elif name == "darkgray" or name == "darkgrey": return _css_argb(255, 169, 169, 169)
    elif name == "darkgreen": return _css_argb(255, 0, 100, 0)
    elif name == "darkkhaki": return _css_argb(255, 189, 183, 107)
    elif name == "darkmagenta": return _css_argb(255, 139, 0, 139)
    elif name == "darkolivegreen": return _css_argb(255, 85, 107, 47)
    elif name == "darkorange": return _css_argb(255, 255, 140, 0)
    elif name == "darkorchid": return _css_argb(255, 153, 50, 204)
    elif name == "darkred": return _css_argb(255, 139, 0, 0)
    elif name == "darksalmon": return _css_argb(255, 233, 150, 122)
    elif name == "darkseagreen": return _css_argb(255, 143, 188, 143)
    elif name == "darkslateblue": return _css_argb(255, 72, 61, 139)
    elif name == "darkslategray" or name == "darkslategrey": return _css_argb(255, 47, 79, 79)
    elif name == "darkturquoise": return _css_argb(255, 0, 206, 209)
    elif name == "darkviolet": return _css_argb(255, 148, 0, 211)
    elif name == "deeppink": return _css_argb(255, 255, 20, 147)
    elif name == "deepskyblue": return _css_argb(255, 0, 191, 255)
    elif name == "dimgray" or name == "dimgrey": return _css_argb(255, 105, 105, 105)
    elif name == "dodgerblue": return _css_argb(255, 30, 144, 255)
    elif name == "firebrick": return _css_argb(255, 178, 34, 34)
    elif name == "floralwhite": return _css_argb(255, 255, 250, 240)
    elif name == "forestgreen": return _css_argb(255, 34, 139, 34)
    elif name == "gainsboro": return _css_argb(255, 220, 220, 220)
    elif name == "ghostwhite": return _css_argb(255, 248, 248, 255)
    elif name == "gold": return _css_argb(255, 255, 215, 0)
    elif name == "goldenrod": return _css_argb(255, 218, 165, 32)
    elif name == "greenyellow": return _css_argb(255, 173, 255, 47)
    elif name == "honeydew": return _css_argb(255, 240, 255, 240)
    elif name == "hotpink": return _css_argb(255, 255, 105, 180)
    elif name == "indianred": return _css_argb(255, 205, 92, 92)
    elif name == "indigo": return _css_argb(255, 75, 0, 130)
    elif name == "ivory": return _css_argb(255, 255, 255, 240)
    elif name == "khaki": return _css_argb(255, 240, 230, 140)
    elif name == "lavender": return _css_argb(255, 230, 230, 250)
    elif name == "lavenderblush": return _css_argb(255, 255, 240, 245)
    elif name == "lawngreen": return _css_argb(255, 124, 252, 0)
    elif name == "lemonchiffon": return _css_argb(255, 255, 250, 205)
    elif name == "lightblue": return _css_argb(255, 173, 216, 230)
    elif name == "lightcoral": return _css_argb(255, 240, 128, 128)
    elif name == "lightcyan": return _css_argb(255, 224, 255, 255)
    elif name == "lightgoldenrodyellow": return _css_argb(255, 250, 250, 210)
    elif name == "lightgray" or name == "lightgrey": return _css_argb(255, 211, 211, 211)
    elif name == "lightgreen": return _css_argb(255, 144, 238, 144)
    elif name == "lightpink": return _css_argb(255, 255, 182, 193)
    elif name == "lightsalmon": return _css_argb(255, 255, 160, 122)
    elif name == "lightseagreen": return _css_argb(255, 32, 178, 170)
    elif name == "lightskyblue": return _css_argb(255, 135, 206, 250)
    elif name == "lightslategray" or name == "lightslategrey": return _css_argb(255, 119, 136, 153)
    elif name == "lightsteelblue": return _css_argb(255, 176, 196, 222)
    elif name == "lightyellow": return _css_argb(255, 255, 255, 224)
    elif name == "limegreen": return _css_argb(255, 50, 205, 50)
    elif name == "linen": return _css_argb(255, 250, 240, 230)
    elif name == "mediumaquamarine": return _css_argb(255, 102, 205, 170)
    elif name == "mediumblue": return _css_argb(255, 0, 0, 205)
