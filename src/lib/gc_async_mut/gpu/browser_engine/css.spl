fn parse_css_value(s: text) -> CssValue:
    """Parse a CSS value string like '100px', '50%', or 'auto'."""
    val trimmed = s.trim()

    if trimmed == "auto" or trimmed == "":
        return CssValue.auto()

    if trimmed.ends_with("px"):
        val num_str = trimmed.slice(0, trimmed.len() - 2)
        val n = css_parse_num(num_str)
        return CssValue.px(n.to_f32())

    if trimmed.ends_with("%"):
        val num_str = trimmed.slice(0, trimmed.len() - 1)
        val n = css_parse_num(num_str)
        return CssValue.pct(n.to_f32())

    if trimmed.ends_with("em"):
        val num_str = trimmed.slice(0, trimmed.len() - 2)
        val n = css_parse_num(num_str)
        return CssValue.px(n.to_f32() * 16.0)

    if trimmed.ends_with("rem"):
        val num_str = trimmed.slice(0, trimmed.len() - 3)
        val n = css_parse_num(num_str)
        return CssValue.px(n.to_f32() * 16.0)

    # Try as plain number (treat as px)
    val n = css_parse_num(trimmed)
    if n != 0 or trimmed == "0":
        return CssValue.px(n.to_f32())

    return CssValue.auto()

fn css_parse_num(s: text) -> i64:
    """Manual number parser avoiding f64? optional (Cranelift bug)."""
    val t = s.trim()
    if t.len() == 0:
        return 0
    var neg = false
    var start = 0
    if t.slice(0, 1) == "-":
        neg = true
        start = 1
    elif t.slice(0, 1) == "+":
        start = 1
    var result = 0
    var idx = start
    val slen = t.len()
    while idx < slen:
        val ch = t.slice(idx, idx + 1)
        if ch == "." or ch == "e" or ch == "E":
            break
        val d = css_digit(ch)
        if d < 0:
            break
        result = result * 10 + d
        idx = idx + 1
    if neg:
        return 0 - result
    result

fn css_digit(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    return 0 - 1

# =========================================================================
# Style Resolution (Inheritance)
# =========================================================================

fn resolve_style(node: BeDomNode, parent_style: StyleProps) -> StyleProps:
    """Resolve the computed style for a node, inheriting from parent where appropriate.

    Inherited properties (per CSS spec): color, font_size, font_weight, text_align.
    Non-inherited properties use their own values or defaults.
    """
    var s = node.style

    # Inherit text-related properties from parent if not explicitly set
    if s.color == 0x000000FF and parent_style.color != 0x000000FF:
        s.color = parent_style.color

    if s.font_size == 16 and parent_style.font_size != 16:
        s.font_size = parent_style.font_size

    if s.font_weight == "normal" and parent_style.font_weight != "normal":
        s.font_weight = parent_style.font_weight

    if s.text_align == "left" and parent_style.text_align != "left":
        s.text_align = parent_style.text_align

    return s
