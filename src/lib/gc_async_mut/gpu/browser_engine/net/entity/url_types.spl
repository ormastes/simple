"""
# URL Types

Entity types for URL and Origin — pure value types with no externs.
"""

pub class Url:
    """A parsed URL with scheme, host, port, path, query, and fragment."""
    scheme: text
    host: text
    port: i64
    path: text
    query: text
    fragment: text

pub class Origin:
    """The security origin of a URL: scheme + host + port."""
    scheme: text
    host: text
    port: i64
