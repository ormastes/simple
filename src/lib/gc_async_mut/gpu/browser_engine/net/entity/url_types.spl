"""
# URL Types

Entity types for URL and Origin — pure value types with no externs.
"""

fn _default_port(scheme: text) -> i64:
    if scheme == "https" or scheme == "wss": 443 else: 80

pub class Url:
    """A parsed URL with scheme, host, port, path, query, and fragment."""
    scheme: text
    host: text
    port: i64
    path: text
    query: text
    fragment: text

    static fn parse(raw: text) -> Url:
        """Parse an absolute URL string. Defaults: scheme http, path /, port by scheme."""
        var scheme = "http"
        var remaining = raw
        val scheme_end = remaining.index_of("://")
        if scheme_end >= 0:
            scheme = remaining.substring(0, scheme_end)
            remaining = remaining.substring(scheme_end + 3, remaining.len())
        var fragment = ""
        val fragment_start = remaining.index_of("#")
        if fragment_start >= 0:
            fragment = remaining.substring(fragment_start + 1, remaining.len())
            remaining = remaining.substring(0, fragment_start)
        var query = ""
        val query_start = remaining.index_of("?")
        if query_start >= 0:
            query = remaining.substring(query_start + 1, remaining.len())
            remaining = remaining.substring(0, query_start)
        var path = "/"
        val path_start = remaining.index_of("/")
        if path_start >= 0:
            path = remaining.substring(path_start, remaining.len())
            remaining = remaining.substring(0, path_start)
        var host = remaining
        var port = _default_port(scheme)
        val port_start = remaining.index_of(":")
        if port_start >= 0:
            host = remaining.substring(0, port_start)
            port = remaining.substring(port_start + 1, remaining.len()).parse_int() ?? port
        Url(scheme: scheme, host: host, port: port, path: path, query: query, fragment: fragment)

    static fn create(scheme: text, host: text, port: i64, path: text) -> Url:
        """Build a URL from parts with empty query/fragment."""
        Url(scheme: scheme, host: host, port: port, path: path, query: "", fragment: "")

    me to_text() -> text:
        """Serialize back to URL text; default ports are omitted."""
        var out = self.scheme + "://" + self.host
        if self.port != _default_port(self.scheme):
            out = out + ":" + self.port.to_text()
        out = out + self.path
        if self.query.len() > 0:
            out = out + "?" + self.query
        if self.fragment.len() > 0:
            out = out + "#" + self.fragment
        out

pub class Origin:
    """The security origin of a URL: scheme + host + port."""
    scheme: text
    host: text
    port: i64

    static fn from_url(u: Url) -> Origin:
        Origin(scheme: u.scheme, host: u.host, port: u.port)

    me to_text() -> text:
        self.scheme + "://" + self.host + ":" + self.port.to_text()
