"""
# Cookie Types

Entity types for HTTP cookies — pure value types with no externs.
"""

pub enum SameSite:
    """RFC 6265 SameSite attribute values."""
    Strict
    Lax
    None

pub class Cookie:
    """An HTTP cookie with all RFC 6265 attributes."""
    name: text
    value: text
    domain: text
    path: text
    secure: bool
    http_only: bool
    same_site: SameSite
