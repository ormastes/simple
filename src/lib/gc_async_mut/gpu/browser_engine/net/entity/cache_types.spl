"""
# Cache Types

Entity types for HTTP caching: CacheControl, ETag, CachePolicy, CacheEntry.
"""

#![allow(REQC001)]

use std.js.types.pair.{Pair}

pub enum CacheControl:
    NoCache
    NoStore
    MaxAge(seconds: i64)
    Public
    Private
    MustRevalidate

pub class ETag:
    value: text
    weak: bool

    static fn strong(value: text) -> ETag:
        ETag(value: value, weak: false)

    static fn weak(value: text) -> ETag:
        ETag(value: value, weak: true)

pub class CachePolicy:
    controls: [CacheControl]
    etag: ETag
    last_modified: i64

    static fn create(controls: [CacheControl], etag: ETag, last_modified: i64) -> CachePolicy:
        CachePolicy(controls: controls, etag: etag, last_modified: last_modified)

pub class CacheEntry:
    url: text
    body: [u8]
    headers: text
    policy: CachePolicy
    stored_at: i64

    static fn create(url: text, body: [u8], policy: CachePolicy, stored_at: i64) -> CacheEntry:
        CacheEntry(url: url, body: body, headers: "", policy: policy, stored_at: stored_at)
