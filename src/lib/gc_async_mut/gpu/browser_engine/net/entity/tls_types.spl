"""
# TLS Types

Entity types for TLS configuration — pure value types with no externs.
"""

pub enum TlsVersion:
    """Minimum TLS protocol version."""
    Tls12
    Tls13

pub class CertChain:
    """A DER-encoded certificate chain."""
    certs: [text]
    ca_certs: [text]

pub class TlsConfig:
    """TLS connection configuration."""
    min_version: TlsVersion
    verify_peer: bool
    sni_hostname: text
