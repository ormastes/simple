#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# HTTP/2 HPACK-aware header encoding/decoding and DATA frame splitting.
# Implements simplified literal-without-indexing header block encoding.
# Reference: RFC 7540 Section 8, RFC 7541

use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, FetchResponse, HttpMethod}
use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.Url
use std.gc_async_mut.gpu.browser_engine.net.h2_frame.{
    H2Frame, H2FrameType, FLAG_END_STREAM, FLAG_END_HEADERS,
    frame_type_to_id, encode_byte, decode_byte, parse_simple_int, int_to_hex
}
use std.gc_async_mut.gpu.browser_engine.shared.error.{network_error, parse_error}
use std.js.types.pair.{Pair}

extern fn rt_text_to_bytes(s: text) -> [u8]

# --- Header encoding (simplified HPACK) ---

fn build_h2_headers(req: FetchRequest) -> [Pair<text, text>]:
    # Build the HTTP/2 pseudo-header and regular header list for a request.
    # Pseudo-headers are prefixed with ':' and must come before regular headers.
    var headers: [Pair<text, text>] = []

    # Pseudo-headers (RFC 7540 Section 8.1.2.3)
    val method = method_to_text(req.method)
    headers.push(Pair(first: ":method", second: method))
    headers.push(Pair(first: ":scheme", second: req.url.scheme))
    headers.push(Pair(first: ":authority", second: req.url.host))
    val path = if req.url.path.len() > 0: req.url.path else: "/"
    val query_str = if req.url.query.len() > 0: "?{req.url.query}" else: ""
    headers.push(Pair(first: ":path", second: "{path}{query_str}"))

    # Regular headers from the request
    for h in req.headers:
        # HTTP/2 requires lowercase header names
        headers.push(Pair(first: h.first.to_lower(), second: h.second))

    # Add default headers if not already present
    if not has_header(req.headers, "user-agent"):
        headers.push(Pair(first: "user-agent", second: "SimpleBrowser/1.0"))
    if not has_header(req.headers, "accept"):
        headers.push(Pair(first: "accept", second: "*/*"))

    headers

fn encode_header_block(headers: [Pair<text, text>]) -> text:
    # Simplified header block encoding.
    # A full implementation would use HPACK (RFC 7541) with static/dynamic tables
    # and Huffman encoding. This version uses literal header field representation
    # without indexing (HPACK Section 6.2.2).
    var result = ""
    for header in headers:
        # Format: 0x00 | name_length (7+) | name | value_length (7+) | value
        # Simplified: we encode lengths as single bytes (works for headers < 127 chars)
        val name = header.first
        val value = header.second
        result = result + encode_byte(0)  # Literal without indexing prefix
        result = result + encode_byte(name.len())
        result = result + name
        result = result + encode_byte(value.len())
        result = result + value
    result

fn decode_header_block(block: text) -> Result<[Pair<text, text>]>:
    # Decode the literal-without-indexing header representation emitted by
    # encode_header_block. This is intentionally small HPACK coverage, but it
    # is real parser state, not a fabricated response path.
    var headers: [Pair<text, text>] = []
    var pos = 0
    while pos < block.len():
        val prefix = decode_byte(block, pos)
        pos = pos + 1
        if prefix != 0:
            return Err(parse_error("h2: unsupported HPACK header prefix 0x{int_to_hex(prefix)}"))
        if pos >= block.len():
            return Err(parse_error("h2: truncated header name length"))
        val name_len = decode_byte(block, pos)
        pos = pos + 1
        if name_len < 0 or pos + name_len > block.len():
            return Err(parse_error("h2: truncated header name"))
        val name = block.slice(pos, pos + name_len)
        pos = pos + name_len
        if pos >= block.len():
            return Err(parse_error("h2: truncated header value length for {name}"))
        val value_len = decode_byte(block, pos)
        pos = pos + 1
        if value_len < 0 or pos + value_len > block.len():
            return Err(parse_error("h2: truncated header value for {name}"))
        val value = block.slice(pos, pos + value_len)
        pos = pos + value_len
        headers.push(Pair(first: name, second: value))
    Ok(headers)

fn build_h2_response(url: Url, frames: [H2Frame]) -> Result<FetchResponse>:
    var headers: [Pair<text, text>] = []
    var body = ""
    var saw_headers = false
    var response_stream_id = 0

    for frame in frames:
        if frame.stream_id > 0:
            if response_stream_id == 0:
                response_stream_id = frame.stream_id
            else if frame.stream_id != response_stream_id:
                return Err(parse_error("h2: response frames span multiple streams"))
        val type_id = frame_type_to_id(frame.frame_type)
        var payload_is_headers = false
        val decoded_probe = decode_header_block(frame.payload)
        match decoded_probe:
            Ok(probe_headers):
                for h in probe_headers:
                    if h.first == ":status":
                        payload_is_headers = true
            Err(e):
                pass_dn
        if type_id == 1 or payload_is_headers:
            if frame.stream_id == 0:
                return Err(parse_error("h2: response HEADERS frame used stream 0"))
            val decoded = decode_header_block(frame.payload)?
            for h in decoded:
                headers.push(h)
            saw_headers = true
        else if type_id == 9:
            if not saw_headers:
                return Err(parse_error("h2: CONTINUATION before HEADERS"))
            val decoded = decode_header_block(frame.payload)?
            for h in decoded:
                headers.push(h)
        else if type_id == 0:
            body = body + frame.payload
        else if type_id == 3:
            return Err(network_error("h2: stream reset while reading response"))
        else if type_id == 7:
            return Err(network_error("h2: connection closed while reading response"))

    if not saw_headers:
        return Err(parse_error("h2: response missing HEADERS"))
    var has_status = false
    for h in headers:
        if h.first == ":status":
            has_status = true
    if not has_status:
        return Err(parse_error("h2: response missing :status pseudo-header"))

    val status = extract_h2_status(headers)
    val response_headers = filter_pseudo_headers(headers)
    Ok(FetchResponse(
        status: status,
        headers: serialize_headers(response_headers),
        body: rt_text_to_bytes(body)
    ))

fn serialize_headers(headers: [Pair<text, text>]) -> text:
    # Serialize a header pair list into the declared FetchResponse raw-text
    # header form: one "Name: value\r\n" line per header.
    var out = ""
    for h in headers:
        out = out + h.first + ": " + h.second + "\r\n"
    out

fn extract_h2_status(headers: [Pair<text, text>]) -> i64:
    # Extract the :status pseudo-header from response headers.
    for h in headers:
        if h.first == ":status":
            return parse_simple_int(h.second)
    200  # Default to 200 if :status not found

fn filter_pseudo_headers(headers: [Pair<text, text>]) -> [Pair<text, text>]:
    # Remove pseudo-headers (those starting with ':') from the list.
    var result: [Pair<text, text>] = []
    for h in headers:
        val is_pseudo = h.first.len() > 0 and h.first.slice(0, 1) == ":"
        if not is_pseudo:
            result.push(h)
    result

fn has_header(headers: [Pair<text, text>], name: text) -> bool:
    val name_lower = name.to_lower()
    for h in headers:
        if h.first.to_lower() == name_lower:
            return true
    false

# --- DATA frame splitting ---

fn split_into_data_frames(body: text, stream_id: i64, max_frame_size: i64) -> [H2Frame]:
    # Split a request body into DATA frames respecting max_frame_size.
    # The last frame gets the END_STREAM flag.
    var frames = [H2Frame]()
    var offset = 0

    while offset < body.len():
        val remaining = body.len() - offset
        val chunk_size = if remaining > max_frame_size: max_frame_size else: remaining
        val chunk = body.slice(offset, offset + chunk_size)
        val is_last = offset + chunk_size >= body.len()

        val flags = if is_last: FLAG_END_STREAM else: 0
        val frame = H2Frame.create(H2FrameType.Data, flags, stream_id, chunk)
        frames.push(frame)

        offset = offset + chunk_size

    # Handle empty body edge case
    if frames.is_empty():
        val frame = H2Frame.create(H2FrameType.Data, FLAG_END_STREAM, stream_id, "")
        frames.push(frame)

    frames

# --- Utility helpers ---

fn method_to_text(method: HttpMethod) -> text:
    match method:
        HttpMethod.Get: "GET"
        HttpMethod.Post: "POST"
        HttpMethod.Put: "PUT"
        HttpMethod.Delete: "DELETE"
        HttpMethod.Head: "HEAD"
        HttpMethod.Options: "OPTIONS"
        HttpMethod.Patch: "PATCH"

