#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# HTTP/2 client with multiplexed streams for the Simple Browser Platform.
# Implements the HTTP/2 framing layer, stream state machine, HPACK-aware
# header handling, flow control via window updates, and connection management.
# Actual wire I/O is intentionally unavailable until binary-safe HTTP/2 TLS
# frame transport is wired.
#
# Reference: RFC 7540 (HTTP/2), RFC 7541 (HPACK)
#
# Sub-modules:
#   h2_frame.spl    — frame types, flags, encode/decode, error codes, byte helpers
#   h2_stream.spl   — stream state machine, H2Stream class
#   h2_settings.spl — H2Settings class, encode/apply
#   h2_hpack.spl    — HPACK header encoding/decoding, DATA frame splitting

use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, FetchResponse}
use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.Url
use std.gc_async_mut.gpu.browser_engine.net.tls.{TlsManager, TlsConnection}
use std.gc_async_mut.gpu.browser_engine.net.dns.DnsResolver
use std.gc_async_mut.gpu.browser_engine.net.h2_frame.{
    H2Frame, H2FrameType, FLAG_END_HEADERS, FLAG_END_STREAM,
    H2_DEFAULT_WINDOW_SIZE,
    set_flag, encode_frame, encode_goaway, encode_settings as _encode_settings_payload
}
use std.gc_async_mut.gpu.browser_engine.net.h2_stream.{
    H2Stream, H2StreamState, transition_send_headers, transition_send_end_stream
}
use std.gc_async_mut.gpu.browser_engine.net.h2_settings.{
    H2Settings, default_settings, encode_settings
}
use std.gc_async_mut.gpu.browser_engine.net.h2_hpack.{
    build_h2_headers, encode_header_block
}
use std.gc_async_mut.gpu.browser_engine.shared.error.{BrowserResult, BrowserError, network_error}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}

# --- H2Connection ---

class H2Connection:
    host: text
    port: i64
    streams: [H2Stream]
    next_stream_id: i64
    settings: H2Settings
    remote_settings: H2Settings
    window_size: i64
    logger: Logger
    tls_conn: TlsConnection?

    static fn create(host: text, port: i64, logger: Logger) -> H2Connection:
        H2Connection(
            host: host,
            port: port,
            streams: [H2Stream](),
            next_stream_id: 1,  # Client-initiated streams are odd
            settings: default_settings(),
            remote_settings: default_settings(),
            window_size: H2_DEFAULT_WINDOW_SIZE,
            logger: logger,
            tls_conn: nil
        )

    fn active_stream_count() -> i64:
        var count = 0
        for stream in self.streams:
            if stream.is_active():
                count = count + 1
        count

    fn find_stream(stream_id: i64) -> H2Stream?:
        for stream in self.streams:
            if stream.id == stream_id:
                return stream
        nil

    fn can_create_stream() -> bool:
        self.active_stream_count() < self.remote_settings.max_concurrent_streams

    fn description() -> text:
        "h2 connection to {self.host}:{self.port} (streams: {self.streams.len()}, active: {self.active_stream_count()}, next_id: {self.next_stream_id})"

# --- H2Client ---

class H2Client:
    logger: Logger
    connections: [H2Connection]
    dns: DnsResolver
    tls: TlsManager

    static fn new(logger: Logger, dns: DnsResolver, tls: TlsManager) -> H2Client:
        H2Client(
            logger: logger,
            connections: [H2Connection](),
            dns: dns,
            tls: tls
        )

    # Send an HTTP/2 request on a multiplexed stream.
    me request(req: FetchRequest) -> Result<FetchResponse>:
        val host = req.url.host
        val port = if req.url.port > 0: req.url.port else: 443
        val is_tls = req.url.scheme == "https"

        self.logger.info("h2: request to {host}:{port}{req.url.path}")

        # Step 1: Get or create a connection
        var conn = self.get_or_create_connection(host, port)?

        # Step 2: Check if we can open a new stream
        if not conn.can_create_stream():
            return Err(network_error("h2: max concurrent streams ({conn.remote_settings.max_concurrent_streams}) reached for {host}"))

        # Step 3: Create a new stream
        var stream = create_stream(conn, req)
        self.logger.debug("h2: created {stream.description()}")

        # Step 4: Build and send HEADERS frame
        val header_pairs = build_h2_headers(req)
        val header_payload = encode_header_block(header_pairs)
        val has_body = req.body.len() > 0

        var header_flags = FLAG_END_HEADERS
        if not has_body:
            header_flags = set_flag(header_flags, FLAG_END_STREAM)

        val headers_frame = H2Frame.create(
            H2FrameType.Headers,
            header_flags,
            stream.id,
            header_payload
        )

        # Transition stream state
        val new_state = transition_send_headers(stream, not has_body)?
        stream.state = new_state

        self.logger.trace("h2: prepared {headers_frame.description()}")

        if has_body:
            val end_state = transition_send_end_stream(stream)?
            stream.state = end_state

        stream.state = H2StreamState.Closed
        Err(network_error("h2: HTTP/2 frame transport is not wired; refusing to fabricate a response for {host}:{port}{req.url.path}"))

    # Get an existing connection or create a new one with the HTTP/2 handshake.
    me get_or_create_connection(host: text, port: i64) -> Result<H2Connection>:
        # Check for an existing connection to this host
        for conn in self.connections:
            if conn.host == host and conn.port == port:
                self.logger.debug("h2: reusing connection to {host}:{port}")
                return Ok(conn)

        # DNS resolution
        val addresses = self.dns.resolve(host)?
        if addresses.is_empty():
            return Err(network_error("h2: DNS resolution returned no addresses for {host}"))

        self.logger.info("h2: creating new connection to {host}:{port}")

        # Create connection object
        var conn = H2Connection.create(host, port, self.logger)

        # TLS handshake (HTTP/2 requires TLS with ALPN "h2")
        val tls_conn = self.tls.handshake(host, port)?
        conn.tls_conn = tls_conn

        val settings_payload = encode_settings(conn.settings)
        val settings_frame = H2Frame.create(
            H2FrameType.Settings,
            0,
            0,
            settings_payload
        )
        self.logger.trace("h2: prepared local SETTINGS: {settings_frame.description()}")

        self.connections.push(conn)
        self.logger.info("h2: TLS connection established to {host}:{port}; frame transport pending")

        Ok(conn)

    # Close a connection by sending a GOAWAY frame.
    me close_connection(host: text, port: i64):
        var new_conns = [H2Connection]()
        for conn in self.connections:
            if conn.host == host and conn.port == port:
                self.logger.info("h2: closing connection to {host}:{port}")
                val last_stream_id = if conn.streams.is_empty(): 0 else: conn.next_stream_id - 2
                val goaway_payload = encode_goaway(last_stream_id, 0)
                val goaway_frame = H2Frame.create(
                    H2FrameType.GoAway,
                    0,
                    0,
                    goaway_payload
                )
                self.logger.warn("h2: GOAWAY frame constructed for {host}:{port} (last_stream={last_stream_id}) but socket I/O is not wired — marking connection closed")
                # Socket I/O wiring is deferred; GOAWAY is logged and the connection is dropped.
            else:
                new_conns.push(conn)
        self.connections = new_conns

    # Close all connections.
    me close_all():
        self.logger.info("h2: closing all {self.connections.len()} connections")
        for conn in self.connections:
            val last_stream_id = if conn.streams.is_empty(): 0 else: conn.next_stream_id - 2
            val goaway_payload = encode_goaway(last_stream_id, 0)
            val goaway_frame = H2Frame.create(
                H2FrameType.GoAway, 0, 0, goaway_payload
            )
            self.logger.warn("h2: GOAWAY frame constructed for {conn.host}:{conn.port} (last_stream={last_stream_id}) but socket I/O is not wired — marking connection closed")
            # Socket I/O wiring is deferred; GOAWAY is logged and the connection is dropped.
        self.connections = [H2Connection]()

# --- Stream creation ---

fn create_stream(conn: H2Connection, req: FetchRequest) -> H2Stream:
    # Allocate a new client-initiated stream with the next odd stream ID.
    val stream_id = conn.next_stream_id
    conn.next_stream_id = conn.next_stream_id + 2  # Client streams are odd
    val stream = H2Stream.create(stream_id, req, conn.remote_settings.initial_window_size)
    conn.streams.push(stream)
    stream
