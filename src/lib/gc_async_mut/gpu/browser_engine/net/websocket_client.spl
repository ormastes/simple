#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# WebSocket client for the Simple Browser Platform.
# Implements RFC 6455 WebSocket protocol including the opening handshake,
# frame encoding/decoding with masking, extended payload lengths (16-bit
# and 64-bit), control frames (ping/pong/close), and connection state machine.
# Plain ws:// socket I/O delegates to hosted TCP primitives.

use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.Url
use std.gc_async_mut.gpu.browser_engine.net.tls.{TlsManager, TlsConnection}
use std.gc_async_mut.gpu.browser_engine.net.dns.DnsResolver
use std.gc_async_mut.gpu.browser_engine.shared.error.{BrowserResult, BrowserError, network_error, parse_error}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}
use std.gc_async_mut.gpu.browser_engine.net.ws_utils.{get_ws_port}
use std.gc_async_mut.gpu.browser_engine.net.ws_frame_codec.{
    WsOpcode, WsFrame, opcode_to_id, id_to_opcode, opcode_name, is_control_opcode,
    encode_frame, decode_frame, apply_mask, apply_client_mask, xor_bytes,
    encode_close_payload, decode_close_payload
}
use std.gc_async_mut.gpu.browser_engine.net.ws_crypto.{
    generate_ws_key, compute_accept_key, generate_mask_key
}
use std.gc_async_mut.gpu.browser_engine.net.ws_handshake.{
    HandshakeResult, build_upgrade_request, ws_request_path,
    read_ws_response_text, validate_handshake_response,
    ws_write_transport_fd, ws_read_transport_fd
}

extern fn rt_io_tcp_connect_timeout(addr: text, ms: i64) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_flush(fd: i64) -> bool
extern fn rt_io_tcp_close(fd: i64) -> bool
extern fn rt_io_tcp_set_nodelay(fd: i64, enabled: bool) -> bool
extern fn rt_io_tcp_set_read_timeout(fd: i64, ms: i64?) -> bool
extern fn rt_io_tcp_set_write_timeout(fd: i64, ms: i64?) -> bool
extern fn rt_bytes_to_text(data: [u8]) -> text

# --- Close status codes (RFC 6455 Section 7.4.1) ---

val WS_CLOSE_NORMAL = 1000
val WS_CLOSE_GOING_AWAY = 1001
val WS_CLOSE_PROTOCOL_ERROR = 1002
val WS_CLOSE_UNSUPPORTED_DATA = 1003
val WS_CLOSE_NO_STATUS = 1005
val WS_CLOSE_ABNORMAL = 1006
val WS_CLOSE_INVALID_PAYLOAD = 1007
val WS_CLOSE_POLICY_VIOLATION = 1008
val WS_CLOSE_MESSAGE_TOO_BIG = 1009
val WS_CLOSE_MANDATORY_EXTENSION = 1010
val WS_CLOSE_INTERNAL_ERROR = 1011

fn close_code_name(code: i64) -> text:
    if code == WS_CLOSE_NORMAL: return "Normal Closure"
    if code == WS_CLOSE_GOING_AWAY: return "Going Away"
    if code == WS_CLOSE_PROTOCOL_ERROR: return "Protocol Error"
    if code == WS_CLOSE_UNSUPPORTED_DATA: return "Unsupported Data"
    if code == WS_CLOSE_NO_STATUS: return "No Status Received"
    if code == WS_CLOSE_ABNORMAL: return "Abnormal Closure"
    if code == WS_CLOSE_INVALID_PAYLOAD: return "Invalid Payload Data"
    if code == WS_CLOSE_POLICY_VIOLATION: return "Policy Violation"
    if code == WS_CLOSE_MESSAGE_TOO_BIG: return "Message Too Big"
    if code == WS_CLOSE_MANDATORY_EXTENSION: return "Mandatory Extension"
    if code == WS_CLOSE_INTERNAL_ERROR: return "Internal Error"
    "Unknown ({code})"

# --- Connection state machine ---

enum WsState:
    Connecting  # Handshake in progress
    Open        # Connection established, data transfer
    Closing     # Close handshake initiated
    Closed      # Connection terminated

fn ws_state_name(state: WsState) -> text:
    match state:
        WsState.Connecting: "CONNECTING"
        WsState.Open: "OPEN"
        WsState.Closing: "CLOSING"
        WsState.Closed: "CLOSED"

# --- WsConnection ---

class WsConnection:
    url: Url
    state: WsState
    logger: Logger
    protocol: text
    extensions: [text]
    tls_conn: TlsConnection?
    tcp_fd: i64
    fragment_buffer: text

    static fn create(url: Url, logger: Logger) -> WsConnection:
        WsConnection(
            url: url,
            state: WsState.Connecting,
            logger: logger,
            protocol: "",
            extensions: [text](),
            tls_conn: nil,
            tcp_fd: -1,
            fragment_buffer: ""
        )

    fn is_open() -> bool:
        match self.state:
            WsState.Open: true
            _: false

    fn is_closed() -> bool:
        match self.state:
            WsState.Closed: true
            _: false

    fn description() -> text:
        val proto_str = if self.protocol.len() > 0: " proto={self.protocol}" else: ""
        "ws:{self.url.host}:{self.url.port} [{ws_state_name(self.state)}]{proto_str}"

# --- Transport helpers (thin wrappers over ws_handshake transport fns) ---

fn ws_write_transport(conn: WsConnection, data: text) -> i64:
    ws_write_transport_fd(conn.tls_conn, conn.tcp_fd, data)

fn ws_read_transport(conn: WsConnection, max_bytes: i64) -> text:
    ws_read_transport_fd(conn.tls_conn, conn.tcp_fd, max_bytes)

fn ws_close_transport(conn: WsConnection):
    if val tls_conn = conn.tls_conn:
        tls_conn.close()
        conn.tls_conn = nil
    if conn.tcp_fd >= 0:
        rt_io_tcp_close(conn.tcp_fd)
        conn.tcp_fd = -1

# --- WebSocketClient ---

class WebSocketClient:
    logger: Logger
    dns: DnsResolver
    tls: TlsManager

    static fn new(logger: Logger, dns: DnsResolver, tls: TlsManager) -> WebSocketClient:
        WebSocketClient(
            logger: logger,
            dns: dns,
            tls: tls
        )

    # Perform the WebSocket opening handshake and return an open connection.
    me connect(url: Url, protocols: [text]) -> Result<WsConnection>:
        val is_secure = url.scheme == "wss"
        val port = get_ws_port(url.scheme, url.port)
        val host = url.host

        self.logger.info("ws: connecting to {host}:{port}")

        # DNS resolution
        val addresses = self.dns.resolve(host)?
        if addresses.is_empty():
            return Err(network_error("ws: DNS resolution returned no addresses for {host}"))

        # Create connection
        var conn = WsConnection.create(url, self.logger)

        # TLS handshake if wss://
        if is_secure:
            val tls_conn = self.tls.handshake(host, port)?
            conn.tls_conn = tls_conn
            self.logger.debug("ws: TLS established for {host}:{port}")
        else:
            val addr = "{addresses.get(0)}:{port}"
            val fd = rt_io_tcp_connect_timeout(addr, 5000)
            if fd < 0:
                return Err(network_error("ws: TCP connect failed to {addr}"))
            rt_io_tcp_set_nodelay(fd, true)
            rt_io_tcp_set_read_timeout(fd, 5000)
            rt_io_tcp_set_write_timeout(fd, 5000)
            conn.tcp_fd = fd

        # Generate WebSocket key
        val ws_key = generate_ws_key()

        # Build the HTTP upgrade request
        val upgrade_request = build_upgrade_request(host, port, ws_request_path(url), ws_key, protocols)
        self.logger.trace("ws: prepared upgrade request:\n{upgrade_request}")

        val written = ws_write_transport(conn, upgrade_request)
        if written < upgrade_request.len():
            ws_close_transport(conn)
            return Err(network_error("ws: short write during opening handshake to {host}:{port}"))

        val raw_response = read_ws_response_text(conn.tls_conn, conn.tcp_fd)
        val handshake = validate_handshake_response(raw_response, ws_key, protocols)?

        # Update connection state
        conn.state = WsState.Open
        conn.protocol = handshake.protocol
        conn.extensions = handshake.extensions

        self.logger.info("ws: connected to {host}:{port} (protocol: {conn.protocol})")
        Ok(conn)

    # Send a text message as a single text frame.
    me send(conn: WsConnection, data: text) -> Result<()>:
        if not conn.is_open():
            return Err(network_error("ws: cannot send on {ws_state_name(conn.state)} connection"))

        self.logger.debug("ws: sending text frame ({data.len()} bytes)")

        val frame = WsFrame.text_frame(data)
        val mask = generate_mask_key()
        val masked_frame = apply_client_mask(frame, mask)
        val encoded = encode_frame(masked_frame)

        val written = ws_write_transport(conn, encoded)
        if written < encoded.len():
            return Err(network_error("ws: short write sending text frame"))
        Ok(())

    # Send binary data as a single binary frame.
    me send_binary(conn: WsConnection, data: text) -> Result<()>:
        if not conn.is_open():
            return Err(network_error("ws: cannot send on {ws_state_name(conn.state)} connection"))

        self.logger.debug("ws: sending binary frame ({data.len()} bytes)")

        val frame = WsFrame.binary_frame(data)
        val mask = generate_mask_key()
        val masked_frame = apply_client_mask(frame, mask)
        val encoded = encode_frame(masked_frame)

        val written = ws_write_transport(conn, encoded)
        if written < encoded.len():
            return Err(network_error("ws: short write sending binary frame"))
        Ok(())

    # Receive the next frame from the connection.
    me recv(conn: WsConnection) -> Result<WsFrame>:
        if not conn.is_open() and conn.state != WsState.Closing:
            return Err(network_error("ws: cannot receive on {ws_state_name(conn.state)} connection"))
        val raw = ws_read_transport(conn, 8192)
        if raw.len() == 0:
            return Err(network_error("ws: no frame data available"))
        val frame = decode_frame(raw)?

        self.logger.debug("ws: received {frame.description()}")

        # If the frame is masked (server-to-client should NOT be masked per RFC,
        # but we handle it gracefully), unmask it
        if frame.masked and frame.mask_key.len() == 4:
            val unmasked = apply_mask(frame.payload, frame.mask_key)
            return Ok(WsFrame(
                fin: frame.fin,
                opcode: frame.opcode,
                masked: false,
                mask_key: [],
                payload: unmasked,
                length: frame.length
            ))

        # Handle control frames transparently
        match frame.opcode:
            WsOpcode.Ping:
                # Automatically respond with PONG.
                self.logger.trace("ws: auto-responding to PING")
                val pong = WsFrame.pong_frame(frame.payload)
                val mask = generate_mask_key()
                val masked_pong = apply_client_mask(pong, mask)
                val encoded = encode_frame(masked_pong)
                ws_write_transport(conn, encoded)
            WsOpcode.Close:
                conn.state = WsState.Closing
                self.logger.info("ws: received close frame, transitioning to CLOSING")
            WsOpcode.Pong:
                self.logger.trace("ws: received PONG (keepalive response)")
            WsOpcode.Continuation:
                conn.fragment_buffer = conn.fragment_buffer + frame.payload
                self.logger.trace("ws: accumulated CONTINUATION fragment ({frame.length} bytes, total={conn.fragment_buffer.len()})")
                if frame.fin:
                    val full_payload = conn.fragment_buffer
                    conn.fragment_buffer = ""
                    self.logger.debug("ws: CONTINUATION sequence complete, total payload={full_payload.len()} bytes")
                    return Ok(WsFrame.create(true, WsOpcode.Text, full_payload))
            _:
                pass_dn

        Ok(frame)

    # Initiate the close handshake.
    me close(conn: WsConnection, code: i64, reason: text) -> Result<()>:
        if conn.is_closed():
            return Ok(())

        self.logger.info("ws: closing with code {code}: {reason}")

        val frame = WsFrame.close_frame(code, reason)
        val mask = generate_mask_key()
        val masked_frame = apply_client_mask(frame, mask)
        val encoded = encode_frame(masked_frame)

        ws_write_transport(conn, encoded)
        ws_close_transport(conn)
        conn.state = WsState.Closing

        conn.state = WsState.Closed
        self.logger.info("ws: connection closed (code: {code}, reason: {reason})")

        Ok(())

    # Send a ping frame to test connectivity.
    me ping(conn: WsConnection) -> Result<()>:
        if not conn.is_open():
            return Err(network_error("ws: cannot ping on {ws_state_name(conn.state)} connection"))

        self.logger.debug("ws: sending ping")

        val frame = WsFrame.ping_frame()
        val mask = generate_mask_key()
        val masked_frame = apply_client_mask(frame, mask)
        val encoded = encode_frame(masked_frame)

        val written = ws_write_transport(conn, encoded)
        if written < encoded.len():
            return Err(network_error("ws: short write sending ping"))
        Ok(())
