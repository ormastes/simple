#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# HTTP/2 settings management: H2Settings class, defaults, encode/apply.
# Reference: RFC 7540 Section 6.5

use std.gc_async_mut.gpu.browser_engine.net.h2_frame.{
    H2_DEFAULT_WINDOW_SIZE, H2_DEFAULT_MAX_FRAME_SIZE, H2_DEFAULT_HEADER_TABLE_SIZE,
    encode_byte, decode_uint16, decode_uint32
}

# --- H2Settings (RFC 7540 Section 6.5.1) ---

class H2Settings:
    max_concurrent_streams: i64
    initial_window_size: i64
    max_frame_size: i64
    header_table_size: i64
    enable_push: bool

fn default_settings() -> H2Settings:
    H2Settings(
        max_concurrent_streams: 100,
        initial_window_size: H2_DEFAULT_WINDOW_SIZE,
        max_frame_size: H2_DEFAULT_MAX_FRAME_SIZE,
        header_table_size: H2_DEFAULT_HEADER_TABLE_SIZE,
        enable_push: false
    )

# Settings parameter identifiers (RFC 7540 Section 6.5.1)
val SETTINGS_HEADER_TABLE_SIZE = 0x1
val SETTINGS_ENABLE_PUSH = 0x2
val SETTINGS_MAX_CONCURRENT_STREAMS = 0x3
val SETTINGS_INITIAL_WINDOW_SIZE = 0x4
val SETTINGS_MAX_FRAME_SIZE = 0x5
val SETTINGS_MAX_HEADER_LIST_SIZE = 0x6

fn encode_settings(settings: H2Settings) -> text:
    # Encode settings as SETTINGS frame payload.
    # Each setting is a 16-bit identifier + 32-bit value (6 bytes per setting).
    var payload = ""

    # Header table size
    payload = payload + encode_setting_param(SETTINGS_HEADER_TABLE_SIZE, settings.header_table_size)

    # Enable push
    val push_val = if settings.enable_push: 1 else: 0
    payload = payload + encode_setting_param(SETTINGS_ENABLE_PUSH, push_val)

    # Max concurrent streams
    payload = payload + encode_setting_param(SETTINGS_MAX_CONCURRENT_STREAMS, settings.max_concurrent_streams)

    # Initial window size
    payload = payload + encode_setting_param(SETTINGS_INITIAL_WINDOW_SIZE, settings.initial_window_size)

    # Max frame size
    payload = payload + encode_setting_param(SETTINGS_MAX_FRAME_SIZE, settings.max_frame_size)

    payload

fn encode_setting_param(id: i64, value: i64) -> text:
    # Encode a single settings parameter (2-byte id + 4-byte value).
    # Returns a 6-character text representation of the binary encoding.
    val id_hi = (id / 256) % 256
    val id_lo = id % 256
    val v_b3 = (value / 16777216) % 256
    val v_b2 = (value / 65536) % 256
    val v_b1 = (value / 256) % 256
    val v_b0 = value % 256
    encode_byte(id_hi) + encode_byte(id_lo) + encode_byte(v_b3) + encode_byte(v_b2) + encode_byte(v_b1) + encode_byte(v_b0)

fn apply_remote_settings(local: H2Settings, remote_payload: text) -> H2Settings:
    # Apply settings received from the remote peer.
    # Parse 6-byte settings entries from the payload.
    var settings = H2Settings(
        max_concurrent_streams: local.max_concurrent_streams,
        initial_window_size: local.initial_window_size,
        max_frame_size: local.max_frame_size,
        header_table_size: local.header_table_size,
        enable_push: local.enable_push
    )

    var pos = 0
    while pos + 6 <= remote_payload.len():
        val param_id = decode_uint16(remote_payload, pos)
        val param_val = decode_uint32(remote_payload, pos + 2)

        if param_id == SETTINGS_HEADER_TABLE_SIZE:
            settings.header_table_size = param_val
        if param_id == SETTINGS_ENABLE_PUSH:
            settings.enable_push = param_val != 0
        if param_id == SETTINGS_MAX_CONCURRENT_STREAMS:
            settings.max_concurrent_streams = param_val
        if param_id == SETTINGS_INITIAL_WINDOW_SIZE:
            settings.initial_window_size = param_val
        if param_id == SETTINGS_MAX_FRAME_SIZE:
            settings.max_frame_size = param_val

        pos = pos + 6

    settings
