"""Canvas-facing browser script wrappers for browser integration specs."""

use std.common.render_scene.scene.{RenderScene, SceneCommand}
use std.common.render_scene.scene_to_canvas2d_json.{render_scene_to_canvas2d_ops}
use std.gc_async_mut.gpu.browser_engine.webgpu_context.{
    WebGPUContext, GPUShaderModule, GPUPipelineHandle, webgpu_create_context
}

pub class Simple2DCommandSummary:
    command_count: i32
    last_kind: text
    canvas2d_json: text

pub class Simple2DContext:
    width: i32
    height: i32
    scene: RenderScene

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.fill_rect(x, y, w, h, color))
        self

    me stroke_rect(x: i32, y: i32, w: i32, h: i32, color: i32, stroke_width: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.stroke_rect(x, y, w, h, color, stroke_width))
        self

    me text(x: i32, y: i32, value: text, font_size: i32, color: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.text(x, y, value, font_size, color))
        self

    me clear() -> Simple2DContext:
        self.scene = RenderScene.new(self.width, self.height)
        self

    fn command_count() -> i32:
        self.scene.commands.len().to_i32()

    fn last_kind() -> text:
        if self.scene.commands.len() == 0:
            return ""
        self.scene.commands[self.scene.commands.len() - 1].kind

    fn to_canvas2d_json() -> text:
        render_scene_to_canvas2d_ops(self.scene)

    fn summary() -> Simple2DCommandSummary:
        Simple2DCommandSummary(command_count: self.command_count(), last_kind: self.last_kind(), canvas2d_json: self.to_canvas2d_json())

pub class CanvasWebGPUContext:
    width: i32
    height: i32
    gpu: WebGPUContext

    me is_available() -> bool:
        self.gpu.is_available()

    me request_device() -> bool:
        self.gpu.request_device()

    me configure() -> bool:
        self.gpu.configure()

    me present() -> bool:
        self.gpu.present()

    me create_shader_module(label: text, source: text) -> GPUShaderModule:
        self.gpu.create_shader_module(label, source)

    me create_render_pipeline(vertex: GPUShaderModule, fragment: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_render_pipeline(vertex, fragment)

    me create_compute_pipeline(shader: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_compute_pipeline(shader)

pub fn canvas_get_context_webgpu(width: i32, height: i32, secure_context: bool) -> CanvasWebGPUContext:
    CanvasWebGPUContext(width: width, height: height, gpu: webgpu_create_context(secure_context))

pub fn canvas_get_context_simple2d(width: i32, height: i32) -> Simple2DContext:
    Simple2DContext(width: width, height: height, scene: RenderScene.new(width, height))
