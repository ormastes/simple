pub val CANVAS_WEBGL_DEPTH_BUFFER_BIT: i32 = WEBGL_DEPTH_BUFFER_BIT
pub val CANVAS_WEBGL_STENCIL_BUFFER_BIT: i32 = WEBGL_STENCIL_BUFFER_BIT
pub val CANVAS_WEBGL_ARRAY_BUFFER: i32 = WEBGL_ARRAY_BUFFER
pub val CANVAS_WEBGL_ELEMENT_ARRAY_BUFFER: i32 = WEBGL_ELEMENT_ARRAY_BUFFER
pub val CANVAS_WEBGL_STATIC_DRAW: i32 = WEBGL_STATIC_DRAW
pub val CANVAS_WEBGL_DYNAMIC_DRAW: i32 = WEBGL_DYNAMIC_DRAW
pub val CANVAS_WEBGL_STREAM_DRAW: i32 = WEBGL_STREAM_DRAW
pub val CANVAS_WEBGL_TRIANGLES: i32 = WEBGL_TRIANGLES
pub val CANVAS_WEBGL_POINTS: i32 = WEBGL_POINTS
pub val CANVAS_WEBGL_FLOAT: i32 = WEBGL_FLOAT
pub val CANVAS_WEBGL_BLEND: i32 = WEBGL_BLEND
pub val CANVAS_WEBGL_CULL_FACE: i32 = WEBGL_CULL_FACE
pub val CANVAS_WEBGL_DEPTH_TEST: i32 = WEBGL_DEPTH_TEST
pub val CANVAS_WEBGL_SCISSOR_TEST: i32 = WEBGL_SCISSOR_TEST
pub val CANVAS_WEBGL_VERTEX_SHADER: i32 = WEBGL_VERTEX_SHADER
pub val CANVAS_WEBGL_FRAGMENT_SHADER: i32 = WEBGL_FRAGMENT_SHADER
pub val CANVAS_WEBGL_COMPILE_STATUS: i32 = WEBGL_COMPILE_STATUS
pub val CANVAS_WEBGL_LINK_STATUS: i32 = WEBGL_LINK_STATUS
pub val CANVAS_WEBGL_TEXTURE_2D: i32 = WEBGL_TEXTURE_2D
pub val CANVAS_WEBGL_TEXTURE0: i32 = WEBGL_TEXTURE0
pub val CANVAS_WEBGL_TEXTURE_MIN_FILTER: i32 = WEBGL_TEXTURE_MIN_FILTER
pub val CANVAS_WEBGL_TEXTURE_MAG_FILTER: i32 = WEBGL_TEXTURE_MAG_FILTER
pub val CANVAS_WEBGL_TEXTURE_WRAP_S: i32 = WEBGL_TEXTURE_WRAP_S
pub val CANVAS_WEBGL_TEXTURE_WRAP_T: i32 = WEBGL_TEXTURE_WRAP_T
pub val CANVAS_WEBGL_NEAREST: i32 = WEBGL_NEAREST
