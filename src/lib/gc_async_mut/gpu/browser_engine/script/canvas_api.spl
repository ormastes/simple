"""
# Canvas 2D API

Simple-script Canvas 2D drawing API for the browser engine.
Accumulates draw commands in a command buffer for later rendering.

JS Equivalent → Simple Function:
    ctx.fillRect()             → canvas_fill_rect()
    ctx.strokeRect()           → canvas_stroke_rect()
    ctx.clearRect()            → canvas_clear_rect()
    ctx.fillText()             → canvas_fill_text()
    ctx.strokeText()           → canvas_stroke_text()
    ctx.beginPath()            → canvas_begin_path()
    ctx.moveTo()               → canvas_move_to()
    ctx.lineTo()               → canvas_line_to()
    ctx.arc()                  → canvas_arc()
    ctx.bezierCurveTo()        → canvas_bezier_curve_to()
    ctx.quadraticCurveTo()     → canvas_quadratic_curve_to()
    ctx.closePath()            → canvas_close_path()
    ctx.fill()                 → canvas_fill()
    ctx.stroke()               → canvas_stroke()
    ctx.fillStyle =            → canvas_set_fill_style()
    ctx.strokeStyle =          → canvas_set_stroke_style()
    ctx.lineWidth =            → canvas_set_line_width()
    ctx.font =                 → canvas_set_font()
    ctx.save()                 → canvas_save()
    ctx.restore()              → canvas_restore()
    ctx.translate()            → canvas_translate()
    ctx.rotate()               → canvas_rotate()
    ctx.scale()                → canvas_scale()
    ctx.drawImage()            → canvas_draw_image()
    ctx.getImageData()         → canvas_get_image_data()
    ctx.putImageData()         → canvas_put_image_data()
    ctx.measureText()          → canvas_measure_text()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.webgpu_context.{
    WebGPUContext, webgpu_create_context, webgpu_preferred_canvas_format
}
use std.gc_async_mut.gpu.browser_engine.webgl_context.{
    WebGLContext, WebGLActiveInfo, WebGLBufferHandle, WebGLExtensionHandle,
    WebGLParameterValue, WebGLProgramHandle, WebGLShaderHandle,
    WebGLTextureHandle,
    webgl_create_context, webgl_context_version_for_name,
    WEBGL_ARRAY_BUFFER, WEBGL_BLEND, WEBGL_CLAMP_TO_EDGE,
    WEBGL_COLOR_BUFFER_BIT, WEBGL_COMPILE_STATUS, WEBGL_CULL_FACE,
    WEBGL_DEPTH_BUFFER_BIT, WEBGL_DEPTH_TEST, WEBGL_DYNAMIC_DRAW,
    WEBGL_ELEMENT_ARRAY_BUFFER, WEBGL_FLOAT, WEBGL_FRAGMENT_SHADER,
    WEBGL_LINEAR, WEBGL_LINK_STATUS, WEBGL_NEAREST, WEBGL_POINTS,
    WEBGL_REPEAT, WEBGL_RGBA, WEBGL_SCISSOR_TEST, WEBGL_STATIC_DRAW,
    WEBGL_STENCIL_BUFFER_BIT, WEBGL_STREAM_DRAW, WEBGL_TEXTURE0,
    WEBGL_TEXTURE_2D, WEBGL_TEXTURE_MAG_FILTER, WEBGL_TEXTURE_MIN_FILTER,
    WEBGL_TEXTURE_WRAP_S, WEBGL_TEXTURE_WRAP_T, WEBGL_TRIANGLES,
    WEBGL_UNSIGNED_BYTE, WEBGL_VERTEX_SHADER
}
use std.gc_async_mut.gpu.browser_engine.webgpu_types.{
    GPUDeviceDescriptor, GPURequestAdapterOptions, GPUShaderModule,
    GPUPipelineHandle
}
use std.gc_async_mut.gpu.browser_engine.webgpu_commands.{
    WebGPUCommandEncoder, GPUCommandBufferHandle
}
use std.gc_async_mut.gpu.browser_engine.webgpu_resources.{
    GPUBufferHandle, GPUTextureHandle, GPUSamplerHandle
}

# =========================================================================
# CanvasContext2D — command-buffer rendering context
# =========================================================================

pub class CanvasImageData:
    """Deterministic RGBA pixel buffer returned by getImageData."""
    width: i32
    height: i32
    data: [u8]

pub class CanvasContext2D:
    """2D canvas rendering context with command buffer.

    All draw operations append text commands to the _commands list.
    The renderer drains this buffer to produce pixels.

    Fields:
        width        - canvas width in pixels
        height       - canvas height in pixels
        fill_color   - current fill style color string
        stroke_color - current stroke style color string
        line_width   - current line width
        font         - current font descriptor string
        text_align   - current text alignment
        _pixel_xs    - sparse RGBA backing store x coordinates
        _pixel_ys    - sparse RGBA backing store y coordinates
        _pixel_data  - sparse RGBA backing store values
        _commands    - accumulated draw command buffer
        _save_stack  - saved state entries (flat: fill, stroke, line_width, font, text_align)
    """
    width: i32
    height: i32
    fill_color: text
    stroke_color: text
    line_width: f64
    font: text
    text_align: text
    _pixel_xs: [i32]
    _pixel_ys: [i32]
    _pixel_data: [u8]
    _commands: [text]
    _save_stack: [text]

    me fill_rect(x: f64, y: f64, w: f64, h: f64):
        self._commands.push("fillRect {x} {y} {w} {h} {self.fill_color}")

    me stroke_rect(x: f64, y: f64, w: f64, h: f64):
        self._commands.push("strokeRect {x} {y} {w} {h} {self.stroke_color} {self.line_width}")

    me clear_rect(x: f64, y: f64, w: f64, h: f64):
        self._commands.push("clearRect {x} {y} {w} {h}")

    me fill_text(txt: text, x: f64, y: f64):
        self._commands.push("fillText {x} {y} {self.fill_color} {self.font} {txt}")

    me stroke_text(txt: text, x: f64, y: f64):
        self._commands.push("strokeText {x} {y} {self.stroke_color} {self.font} {txt}")

    me begin_path():
        self._commands.push("beginPath")

    me move_to(x: f64, y: f64):
        self._commands.push("moveTo {x} {y}")

    me line_to(x: f64, y: f64):
        self._commands.push("lineTo {x} {y}")

    me arc(x: f64, y: f64, r: f64, start: f64, end: f64):
        self._commands.push("arc {x} {y} {r} {start} {end}")

    me bezier_curve_to(cp1x: f64, cp1y: f64, cp2x: f64, cp2y: f64, x: f64, y: f64):
        self._commands.push("bezierCurveTo {cp1x} {cp1y} {cp2x} {cp2y} {x} {y}")

    me quadratic_curve_to(cpx: f64, cpy: f64, x: f64, y: f64):
        self._commands.push("quadraticCurveTo {cpx} {cpy} {x} {y}")

    me close_path():
        self._commands.push("closePath")

    me fill():
        self._commands.push("fill {self.fill_color}")

    me stroke():
        self._commands.push("stroke {self.stroke_color} {self.line_width}")

    me set_fill_style(color: text):
        self.fill_color = color

    me set_stroke_style(color: text):
        self.stroke_color = color

    me set_line_width(width: f64):
        self.line_width = width

    me set_font(font_desc: text):
        self.font = font_desc

    me save():
        self._save_stack.push(self.fill_color)
        self._save_stack.push(self.stroke_color)
        self._save_stack.push("{self.line_width}")
        self._save_stack.push(self.font)
        self._save_stack.push(self.text_align)

    me restore():
        val n = self._save_stack.len()
        if n < 5:
            return
        self.text_align = self._save_stack[n - 1]
        self.font = self._save_stack[n - 2]
        self.stroke_color = self._save_stack[n - 4]
        self.fill_color = self._save_stack[n - 5]
        var new_stack: [text] = []
        var i = 0
        while i < n - 5:
            new_stack.push(self._save_stack[i])
            i = i + 1
        self._save_stack = new_stack

    me translate(x: f64, y: f64):
        self._commands.push("translate {x} {y}")

    me rotate(angle: f64):
        self._commands.push("rotate {angle}")

    me scale(x: f64, y: f64):
        self._commands.push("scale {x} {y}")

    me draw_image(src: text, x: f64, y: f64, w: f64, h: f64):
        self._commands.push("drawImage {src} {x} {y} {w} {h}")

    me get_image_data(sx: i32, sy: i32, sw: i32, sh: i32) -> CanvasImageData:
        var out: [u8] = []
        var y = 0
        while y < sh:
            var x = 0
            while x < sw:
                val src_x = sx + x
                val src_y = sy + y
                if src_x >= 0 and src_x < self.width and src_y >= 0 and src_y < self.height:
                    val stored_idx = self.find_pixel(src_x, src_y)
                    if stored_idx >= 0:
                        val data_idx = stored_idx * 4
                        out.push(self._pixel_data[data_idx])
                        out.push(self._pixel_data[data_idx + 1])
                        out.push(self._pixel_data[data_idx + 2])
                        out.push(self._pixel_data[data_idx + 3])
                    else:
                        out.push(0)
                        out.push(0)
                        out.push(0)
                        out.push(0)
                else:
                    out.push(0)
                    out.push(0)
                    out.push(0)
                    out.push(0)
                x = x + 1
            y = y + 1
        self._commands.push("getImageData {sx} {sy} {sw} {sh}")
        CanvasImageData(width: sw, height: sh, data: out)

    me put_image_data(image: CanvasImageData, dx: i32, dy: i32):
        var y = 0
        while y < image.height:
            var x = 0
            while x < image.width:
                val dest_x = dx + x
                val dest_y = dy + y
                if dest_x >= 0 and dest_x < self.width and dest_y >= 0 and dest_y < self.height:
                    val src_idx = ((y * image.width) + x) * 4
                    if src_idx + 3 < image.data.len():
                        self.set_pixel(dest_x, dest_y, image.data[src_idx], image.data[src_idx + 1], image.data[src_idx + 2], image.data[src_idx + 3])
                x = x + 1
            y = y + 1
        self._commands.push("putImageData {dx} {dy} {image.width} {image.height}")

    me find_pixel(x: i32, y: i32) -> i32:
        var i = 0
        while i < self._pixel_xs.len():
            if self._pixel_xs[i] == x and self._pixel_ys[i] == y:
                return i
            i = i + 1
        -1

    me set_pixel(x: i32, y: i32, r: u8, g: u8, b: u8, a: u8):
        val pixel_idx = self.find_pixel(x, y)
        if pixel_idx >= 0:
            val data_idx = pixel_idx * 4
            self._pixel_data[data_idx] = r
            self._pixel_data[data_idx + 1] = g
            self._pixel_data[data_idx + 2] = b
            self._pixel_data[data_idx + 3] = a
            return
        self._pixel_xs.push(x)
        self._pixel_ys.push(y)
        self._pixel_data.push(r)
        self._pixel_data.push(g)
        self._pixel_data.push(b)
        self._pixel_data.push(a)

pub class CanvasWebGPUContext:
    """Browser canvas WebGPU context wrapper.

    This mirrors the browser `canvas.getContext("webgpu")` boundary: creation
    is gated by secure context, then adapter/device/canvas configuration must
    succeed before shader and pipeline creation are usable.
    """
    width: i32
    height: i32
    secure_context: bool
    gpu: WebGPUContext
    context_type: text

    fn is_available() -> bool:
        self.gpu.secure_context and not self.gpu.device_lost

    me request_device() -> bool:
        if not self.gpu.request_adapter(GPURequestAdapterOptions.default_options()):
            return false
        self.gpu.request_device(GPUDeviceDescriptor.create())

    me configure() -> bool:
        if not self.gpu.device_ready:
            return false
        self.gpu.configure_canvas(webgpu_preferred_canvas_format(), self.width, self.height)

    me configure_with_alpha(alpha_mode: text) -> bool:
        if not self.gpu.device_ready:
            return false
        self.gpu.configure_canvas_with_alpha(webgpu_preferred_canvas_format(), self.width, self.height, alpha_mode)

    me present() -> bool:
        self.gpu.present()

    me destroy() -> bool:
        val lost = self.gpu.destroy()
        lost.lost

    me create_shader_module(label: text, source: text) -> GPUShaderModule:
        self.gpu.create_shader_module(label, source)

    me create_render_pipeline(vertex: GPUShaderModule, fragment: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_render_pipeline(vertex, fragment)

    me create_compute_pipeline(compute: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_compute_pipeline(compute)

    me create_command_encoder(label: text) -> WebGPUCommandEncoder:
        self.gpu.create_command_encoder(label)

    me create_buffer(label: text, size: i64, usage: i32) -> GPUBufferHandle:
        self.gpu.create_buffer(label, size, usage)

    me create_texture(label: text, width: i32, height: i32, depth_or_layers: i32, format: text, usage: i32) -> GPUTextureHandle:
        self.gpu.create_texture(label, width, height, depth_or_layers, format, usage)

    me create_sampler(label: text, address_mode_u: text, address_mode_v: text, mag_filter: text, min_filter: text) -> GPUSamplerHandle:
        self.gpu.create_sampler(label, address_mode_u, address_mode_v, mag_filter, min_filter)

    me queue_submit(buffers: [GPUCommandBufferHandle]) -> bool:
        self.gpu.queue_submit(buffers)

    me queue_write_buffer(buffer_id: i32, offset: i32, data_size: i32) -> bool:
        self.gpu.queue_write_buffer(buffer_id, offset, data_size)

    me queue_write_texture(texture_id: i32, width: i32, height: i32, depth_or_layers: i32, data_size: i32) -> bool:
        self.gpu.queue_write_texture(texture_id, width, height, depth_or_layers, data_size)

pub class CanvasWebGLContext:
    """Browser canvas WebGL/WebGL2 context wrapper."""
    width: i32
    height: i32
    context_type: text
    gl: WebGLContext

    fn is_available() -> bool:
        self.gl.is_available()

