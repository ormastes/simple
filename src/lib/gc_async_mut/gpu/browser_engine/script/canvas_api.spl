pub val CANVAS_WEBGL_UNSIGNED_BYTE: i32 = WEBGL_UNSIGNED_BYTE

pub fn canvas_create(w: i32, h: i32) -> CanvasContext2D:
    """Create a new 2D canvas context with the given dimensions."""
    CanvasContext2D(
        width: w,
        height: h,
        fill_color: "#000000",
        stroke_color: "#000000",
        line_width: 1.0,
        font: "10px sans-serif",
        text_align: "start",
        _pixel_xs: [],
        _pixel_ys: [],
        _pixel_data: [],
        _commands: [],
        _save_stack: []
    )

pub fn canvas_get_context_kind(kind: text) -> text:
    val lower = kind.lower()
    if lower == "2d":
        return "2d"
    if lower == "webgpu":
        return "webgpu"
    if lower == "webgl" or lower == "experimental-webgl":
        return "webgl"
    if lower == "webgl2":
        return "webgl2"
    "unsupported"

pub fn canvas_webgpu_create(w: i32, h: i32, secure_context: bool) -> CanvasWebGPUContext:
    CanvasWebGPUContext(
        width: w,
        height: h,
        secure_context: secure_context,
        gpu: webgpu_create_context(secure_context),
        context_type: "webgpu"
    )

pub fn canvas_get_context_webgpu(w: i32, h: i32, secure_context: bool) -> CanvasWebGPUContext:
    canvas_webgpu_create(w, h, secure_context)

pub fn canvas_webgl_create(w: i32, h: i32, kind: text) -> CanvasWebGLContext:
    val version = webgl_context_version_for_name(kind)
    val actual_version = if version == 2: 2 else: 1
    CanvasWebGLContext(
        width: w,
        height: h,
        context_type: if actual_version == 2: "webgl2" else: "webgl",
        gl: webgl_create_context(actual_version, w, h)
    )

pub fn canvas_get_context_webgl(w: i32, h: i32) -> CanvasWebGLContext:
    canvas_webgl_create(w, h, "webgl")

pub fn canvas_get_context_webgl2(w: i32, h: i32) -> CanvasWebGLContext:
    canvas_webgl_create(w, h, "webgl2")

pub fn canvas_webgl_viewport(ctx: CanvasWebGLContext, x: i32, y: i32, w: i32, h: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.viewport(x, y, w, h)
    next.gl = gl
    next

pub fn canvas_webgl_clear_color(ctx: CanvasWebGLContext, red: f64, green: f64, blue: f64, alpha: f64) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.clear_color(red, green, blue, alpha)
    next.gl = gl
    next

pub fn canvas_webgl_clear(ctx: CanvasWebGLContext, mask: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.clear(mask)
    next.gl = gl
    next

pub fn canvas_webgl_get_extension(ctx: CanvasWebGLContext, name: text) -> WebGLExtensionHandle:
    ctx.gl.get_extension(name)

pub fn canvas_webgl_enable(ctx: CanvasWebGLContext, cap: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.enable(cap)
    next.gl = gl
    next

pub fn canvas_webgl_create_buffer(ctx: CanvasWebGLContext) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _handle = gl.create_buffer()
    next.gl = gl
    next

pub fn canvas_webgl_last_buffer(ctx: CanvasWebGLContext) -> WebGLBufferHandle:
    val n = ctx.gl.buffers.len()
    if n == 0:
        return WebGLBufferHandle(id: -1, valid: false, error: "buffer not found", target: 0, byte_length: 0, usage: 0, initialized: false)
    ctx.gl.buffers[n - 1]

pub fn canvas_webgl_bind_buffer(ctx: CanvasWebGLContext, target: i32, buffer: WebGLBufferHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.bind_buffer(target, buffer.id)
    next.gl = gl
    next

pub fn canvas_webgl_buffer_data_size(ctx: CanvasWebGLContext, target: i32, byte_length: i32, usage: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.buffer_data_size(target, byte_length, usage)
    next.gl = gl
    next

pub fn canvas_webgl_enable_vertex_attrib_array(ctx: CanvasWebGLContext, index: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.enable_vertex_attrib_array(index)
    next.gl = gl
    next

pub fn canvas_webgl_vertex_attrib_pointer(ctx: CanvasWebGLContext, index: i32, size: i32, data_type: i32, normalized: bool, stride: i32, offset: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.vertex_attrib_pointer(index, size, data_type, normalized, stride, offset)
    next.gl = gl
    next

pub fn canvas_webgl_draw_arrays(ctx: CanvasWebGLContext, mode: i32, first: i32, count: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.draw_arrays(mode, first, count)
    next.gl = gl
    next

pub fn canvas_webgl_create_shader(ctx: CanvasWebGLContext, shader_type: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _handle = gl.create_shader(shader_type)
    next.gl = gl
    next

pub fn canvas_webgl_last_shader(ctx: CanvasWebGLContext) -> WebGLShaderHandle:
    val n = ctx.gl.shaders.len()
    if n == 0:
        return WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "shader not found")
    ctx.gl.shaders[n - 1]

pub fn canvas_webgl_shader_source(ctx: CanvasWebGLContext, shader: WebGLShaderHandle, source: text) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.shader_source(shader.id, source)
    next.gl = gl
    next

pub fn canvas_webgl_compile_shader(ctx: CanvasWebGLContext, shader: WebGLShaderHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _compiled = gl.compile_shader(shader.id)
    next.gl = gl
    next

pub fn canvas_webgl_create_program(ctx: CanvasWebGLContext) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _handle = gl.create_program()
    next.gl = gl
    next

pub fn canvas_webgl_last_program(ctx: CanvasWebGLContext) -> WebGLProgramHandle:
    val n = ctx.gl.programs.len()
    if n == 0:
        return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "program not found", active_attribs: [], active_uniforms: [], validate_status: false)
    ctx.gl.programs[n - 1]

pub fn canvas_webgl_attach_shader(ctx: CanvasWebGLContext, program: WebGLProgramHandle, shader: WebGLShaderHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.attach_shader(program.id, shader.id)
    next.gl = gl
    next

pub fn canvas_webgl_link_program(ctx: CanvasWebGLContext, program: WebGLProgramHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _linked = gl.link_program(program.id)
    next.gl = gl
    next

pub fn canvas_webgl_use_program(ctx: CanvasWebGLContext, program: WebGLProgramHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.use_program(program.id)
    next.gl = gl
    next

pub fn canvas_webgl_get_shader_parameter(ctx: CanvasWebGLContext, shader: WebGLShaderHandle, pname: i32) -> WebGLParameterValue:
    ctx.gl.get_shader_parameter(shader.id, pname)

pub fn canvas_webgl_get_program_parameter(ctx: CanvasWebGLContext, program: WebGLProgramHandle, pname: i32) -> WebGLParameterValue:
    ctx.gl.get_program_parameter(program.id, pname)

pub fn canvas_webgl_get_attrib_location(ctx: CanvasWebGLContext, program: WebGLProgramHandle, name: text) -> i32:
    ctx.gl.get_attrib_location(program.id, name)

pub fn canvas_webgl_get_active_uniform(ctx: CanvasWebGLContext, program: WebGLProgramHandle, index: i32) -> WebGLActiveInfo:
    ctx.gl.get_active_uniform(program.id, index)

pub fn canvas_webgl_get_uniform_location(ctx: CanvasWebGLContext, program: WebGLProgramHandle, name: text) -> i32:
    ctx.gl.get_uniform_location(program.id, name)

pub fn canvas_webgl_uniform_1i(ctx: CanvasWebGLContext, location: i32, value: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.uniform_1i(location, value)
    next.gl = gl
    next

pub fn canvas_webgl_uniform_1f(ctx: CanvasWebGLContext, location: i32, value: f64) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.uniform_1f(location, value)
    next.gl = gl
    next

pub fn canvas_webgl_uniform_4f(ctx: CanvasWebGLContext, location: i32, x: f64, y: f64, z: f64, w: f64) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.uniform_4f(location, x, y, z, w)
    next.gl = gl
    next

pub fn canvas_webgl_uniform_matrix4fv(ctx: CanvasWebGLContext, location: i32, transpose: bool, values: [f64]) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.uniform_matrix4fv(location, transpose, values)
    next.gl = gl
    next

pub fn canvas_webgl_create_texture(ctx: CanvasWebGLContext) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _handle = gl.create_texture()
    next.gl = gl
    next

pub fn canvas_webgl_last_texture(ctx: CanvasWebGLContext) -> WebGLTextureHandle:
    val n = ctx.gl.textures.len()
    if n == 0:
        return WebGLTextureHandle(id: -1, valid: false, error: "texture not found", target: 0, width: 0, height: 0, level: 0, internal_format: 0, format: 0, pixel_type: 0, initialized: false, min_filter: 0, mag_filter: 0, wrap_s: 0, wrap_t: 0, mipmap_generated: false, pixels: [])
    ctx.gl.textures[n - 1]

pub fn canvas_webgl_active_texture(ctx: CanvasWebGLContext, texture: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.active_texture(texture)
    next.gl = gl
    next

pub fn canvas_webgl_bind_texture(ctx: CanvasWebGLContext, target: i32, texture: WebGLTextureHandle) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.bind_texture(target, texture.id)
    next.gl = gl
    next

pub fn canvas_webgl_tex_parameter_i(ctx: CanvasWebGLContext, target: i32, pname: i32, param: i32) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.tex_parameter_i(target, pname, param)
    next.gl = gl
    next

pub fn canvas_webgl_tex_image_2d(ctx: CanvasWebGLContext, target: i32, level: i32, internal_format: i32, width: i32, height: i32, border: i32, format: i32, pixel_type: i32, pixels: [u8]) -> CanvasWebGLContext:
    var next = ctx
    var gl = next.gl
    val _ok = gl.tex_image_2d(target, level, internal_format, width, height, border, format, pixel_type, pixels)
    next.gl = gl
    next

# =========================================================================
# Shape Drawing
# =========================================================================

pub fn canvas_fill_rect(ctx: CanvasContext2D, x: f64, y: f64, w: f64, h: f64):
    """Draw a filled rectangle."""
    ctx.fill_rect(x, y, w, h)

pub fn canvas_stroke_rect(ctx: CanvasContext2D, x: f64, y: f64, w: f64, h: f64):
    """Draw a stroked rectangle."""
    ctx.stroke_rect(x, y, w, h)

pub fn canvas_clear_rect(ctx: CanvasContext2D, x: f64, y: f64, w: f64, h: f64):
    """Clear a rectangular area."""
    ctx.clear_rect(x, y, w, h)

# =========================================================================
# Text Drawing
# =========================================================================

pub fn canvas_fill_text(ctx: CanvasContext2D, txt: text, x: f64, y: f64):
    """Draw filled text."""
    ctx.fill_text(txt, x, y)

pub fn canvas_stroke_text(ctx: CanvasContext2D, txt: text, x: f64, y: f64):
    """Draw stroked text."""
    ctx.stroke_text(txt, x, y)

# =========================================================================
# Path Operations
# =========================================================================

pub fn canvas_begin_path(ctx: CanvasContext2D):
    """Begin a new path."""
    ctx.begin_path()

pub fn canvas_move_to(ctx: CanvasContext2D, x: f64, y: f64):
    """Move the pen to (x, y)."""
    ctx.move_to(x, y)

pub fn canvas_line_to(ctx: CanvasContext2D, x: f64, y: f64):
    """Draw a line from the current position to (x, y)."""
    ctx.line_to(x, y)

pub fn canvas_arc(ctx: CanvasContext2D, x: f64, y: f64, r: f64, start: f64, end: f64):
    """Draw an arc."""
    ctx.arc(x, y, r, start, end)

pub fn canvas_bezier_curve_to(ctx: CanvasContext2D, cp1x: f64, cp1y: f64, cp2x: f64, cp2y: f64, x: f64, y: f64):
    """Draw a cubic bezier curve."""
    ctx.bezier_curve_to(cp1x, cp1y, cp2x, cp2y, x, y)

pub fn canvas_quadratic_curve_to(ctx: CanvasContext2D, cpx: f64, cpy: f64, x: f64, y: f64):
    """Draw a quadratic bezier curve."""
    ctx.quadratic_curve_to(cpx, cpy, x, y)

pub fn canvas_close_path(ctx: CanvasContext2D):
    """Close the current path."""
    ctx.close_path()

pub fn canvas_fill(ctx: CanvasContext2D):
    """Fill the current path."""
    ctx.fill()

pub fn canvas_stroke(ctx: CanvasContext2D):
    """Stroke the current path."""
    ctx.stroke()

# =========================================================================
# Style Setters
# =========================================================================

pub fn canvas_set_fill_style(ctx: CanvasContext2D, color: text):
    """Set the fill color."""
    ctx.set_fill_style(color)

pub fn canvas_set_stroke_style(ctx: CanvasContext2D, color: text):
    """Set the stroke color."""
    ctx.set_stroke_style(color)

pub fn canvas_set_line_width(ctx: CanvasContext2D, width: f64):
    """Set the line width."""
    ctx.set_line_width(width)

pub fn canvas_set_font(ctx: CanvasContext2D, font_desc: text):
    """Set the font descriptor."""
    ctx.set_font(font_desc)

# =========================================================================
# State Save / Restore
# =========================================================================

pub fn canvas_save(ctx: CanvasContext2D):
    """Save the current drawing state onto the stack."""
    ctx.save()

pub fn canvas_restore(ctx: CanvasContext2D):
    """Restore the most recently saved drawing state."""
    ctx.restore()

# =========================================================================
# Transforms
# =========================================================================

pub fn canvas_translate(ctx: CanvasContext2D, x: f64, y: f64):
    """Apply a translation transform."""
    ctx.translate(x, y)

pub fn canvas_rotate(ctx: CanvasContext2D, angle: f64):
    """Apply a rotation transform."""
    ctx.rotate(angle)

pub fn canvas_scale(ctx: CanvasContext2D, x: f64, y: f64):
    """Apply a scale transform."""
    ctx.scale(x, y)

# =========================================================================
# Image Drawing
# =========================================================================

pub fn canvas_draw_image(ctx: CanvasContext2D, src: text, x: f64, y: f64, w: f64, h: f64):
    """Draw an image from the given source path."""
    ctx.draw_image(src, x, y, w, h)

# =========================================================================
# Image Data
# =========================================================================

pub fn canvas_get_image_data(ctx: CanvasContext2D, sx: i32, sy: i32, sw: i32, sh: i32) -> CanvasImageData:
    """Return a deterministic RGBA copy for the requested rectangle."""
    ctx.get_image_data(sx, sy, sw, sh)

pub fn canvas_put_image_data(ctx: CanvasContext2D, image: CanvasImageData, dx: i32, dy: i32) -> CanvasContext2D:
    """Copy RGBA image data into the canvas backing store."""
    ctx.put_image_data(image, dx, dy)
    ctx

# =========================================================================
# Text Measurement
# =========================================================================

pub fn canvas_measure_text(ctx: CanvasContext2D, txt: text) -> f64:
    """Estimate the width of the text in the current font.

    NOTE: Returns a rough estimate (character count * 8.0) since real
    font metrics require the rendering backend.
    """
    val char_count = txt.len()
    (char_count as f64) * 8.0

# =========================================================================
# Command Buffer Access
# =========================================================================

pub fn canvas_get_commands(ctx: CanvasContext2D) -> [text]:
    """Return the accumulated draw commands for the renderer."""
    ctx._commands
