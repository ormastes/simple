"""Canvas-facing browser script wrappers for browser integration specs."""

use std.common.render_scene.scene.{RenderScene, SceneCommand}
use std.common.render_scene.scene_to_canvas2d_json.{render_scene_to_canvas2d_ops}
use std.gc_async_mut.gpu.browser_engine.webgpu_context.{
    WebGPUContext, GPUShaderModule, GPUPipelineHandle, webgpu_create_context
}
use std.gc_async_mut.gpu.browser_engine.webgpu_software_executor.{webgpu_software_execute_queue}

val SIMPLE2D_WEBGPU_BUFFER_USAGE_COPY_DST: i64 = 8

pub class Simple2DCommandSummary:
    command_count: i32
    last_kind: text
    canvas2d_json: text

pub class Simple2DWebGPUDrawEvidence:
    available: bool
    submitted: bool
    status: text
    command_count: i32
    queue_write_count: i32
    render_pass_count: i32
    draw_call_count: i32
    present_count: i32
    pipeline_valid: bool
    canvas2d_json: text

    fn summary() -> text:
        "status={self.status};commands={self.command_count};writes={self.queue_write_count};render_passes={self.render_pass_count};draws={self.draw_call_count};presents={self.present_count}"

pub class Simple3DCommandSummary:
    command_count: i32
    triangle_count: i32
    last_kind: text
    scene3d_json: text

pub class Simple3DWebGPUDrawEvidence:
    available: bool
    submitted: bool
    status: text
    command_count: i32
    triangle_count: i32
    queue_write_count: i32
    render_pass_count: i32
    draw_call_count: i32
    present_count: i32
    pipeline_valid: bool
    scene_payload_bytes: i64
    scene_payload_checksum: i64
    scene3d_json: text

    fn summary() -> text:
        "status={self.status};commands={self.command_count};triangles={self.triangle_count};scene_bytes={self.scene_payload_bytes};scene_checksum={self.scene_payload_checksum};writes={self.queue_write_count};render_passes={self.render_pass_count};draws={self.draw_call_count};presents={self.present_count}"

    fn to_json() -> text:
        val available_text = if self.available: "true" else: "false"
        val submitted_text = if self.submitted: "true" else: "false"
        val pipeline_text = if self.pipeline_valid: "true" else: "false"
        "{\"status\":\"{self.status}\",\"available\":{available_text},\"submitted\":{submitted_text},\"commands\":{self.command_count},\"triangles\":{self.triangle_count},\"scenePayloadBytes\":{self.scene_payload_bytes},\"scenePayloadChecksum\":{self.scene_payload_checksum},\"writes\":{self.queue_write_count},\"renderPasses\":{self.render_pass_count},\"drawCalls\":{self.draw_call_count},\"presents\":{self.present_count},\"pipelineValid\":{pipeline_text},\"scene\":{self.scene3d_json}}"

fn _simple3d_scene_checksum(scene_json: text) -> i64:
    var hash: i64 = 5381
    for ch in scene_json:
        hash = ((hash << 5) + hash) + ch.ord()
    if hash < 0:
        return 0 - hash
    hash

pub class Simple3DContext:
    width: i32
    height: i32
    commands: [text]
    triangle_count_value: i32

    me clear_color(color: i32) -> Simple3DContext:
        self.commands.push("{\"op\":\"clearColor\",\"color\":{color}}")
        self

    me camera_perspective(fov_degrees: i32, near_plane: i32, far_plane: i32) -> Simple3DContext:
        self.commands.push("{\"op\":\"cameraPerspective\",\"fov\":{fov_degrees},\"near\":{near_plane},\"far\":{far_plane}}")
        self

    me triangle(x1: i32, y1: i32, z1: i32, x2: i32, y2: i32, z2: i32, x3: i32, y3: i32, z3: i32, color: i32) -> Simple3DContext:
        self.commands.push("{\"op\":\"triangle\",\"vertices\":[[{x1},{y1},{z1}],[{x2},{y2},{z2}],[{x3},{y3},{z3}]],\"color\":{color}}")
        self.triangle_count_value = self.triangle_count_value + 1
        self

    me clear() -> Simple3DContext:
        self.commands = []
        self.triangle_count_value = 0
        self

    fn command_count() -> i32:
        self.commands.len().to_i32()

    fn triangle_count() -> i32:
        self.triangle_count_value

    fn last_kind() -> text:
        if self.commands.len() == 0:
            return ""
        val command = self.commands[self.commands.len() - 1]
        if command.contains("\"op\":\"triangle\""):
            return "triangle"
        if command.contains("\"op\":\"cameraPerspective\""):
            return "cameraPerspective"
        if command.contains("\"op\":\"clearColor\""):
            return "clearColor"
        "unknown"

    fn to_scene3d_json() -> text:
        "{\"type\":\"simple3d\",\"width\":{self.width},\"height\":{self.height},\"commands\":[" + self.commands.join(",") + "]}"

    fn summary() -> Simple3DCommandSummary:
        Simple3DCommandSummary(command_count: self.command_count(), triangle_count: self.triangle_count(), last_kind: self.last_kind(), scene3d_json: self.to_scene3d_json())

    fn submit_to_webgpu(secure_context: bool) -> Simple3DWebGPUDrawEvidence:
        var ctx = canvas_get_context_webgpu(self.width, self.height, secure_context)
        val json = self.to_scene3d_json()
        val commands = self.command_count()
        val triangles = self.triangle_count()
        val scene_bytes = json.len().to_i64()
        val scene_checksum = _simple3d_scene_checksum(json)
        if not ctx.is_available():
            return Simple3DWebGPUDrawEvidence(available: false, submitted: false, status: "webgpu-unavailable", command_count: commands, triangle_count: triangles, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, scene_payload_bytes: scene_bytes, scene_payload_checksum: scene_checksum, scene3d_json: json)
        if not ctx.request_device():
            return Simple3DWebGPUDrawEvidence(available: false, submitted: false, status: ctx.gpu.last_error, command_count: commands, triangle_count: triangles, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, scene_payload_bytes: scene_bytes, scene_payload_checksum: scene_checksum, scene3d_json: json)
        if not ctx.configure():
            return Simple3DWebGPUDrawEvidence(available: true, submitted: false, status: ctx.gpu.last_error, command_count: commands, triangle_count: triangles, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, scene_payload_bytes: scene_bytes, scene_payload_checksum: scene_checksum, scene3d_json: json)
        val vertex = ctx.create_shader_module("simple3d-vertex", "@vertex fn main(@builtin(vertex_index) vertex_index: u32) -> @builtin(position) vec4f { var pos = array<vec3f, 3>(vec3f(0.0, 0.6, 0.0), vec3f(-0.6, -0.6, 0.0), vec3f(0.6, -0.6, 0.0)); return vec4f(pos[vertex_index], 1.0); }")
        val fragment = ctx.create_shader_module("simple3d-fragment", "@fragment fn main() -> @location(0) vec4f { return vec4f(0.2, 0.8, 1.0, 1.0); }")
        val pipeline = ctx.create_render_pipeline(vertex, fragment)
        if not pipeline.valid:
            return Simple3DWebGPUDrawEvidence(available: true, submitted: false, status: "render-pipeline-invalid", command_count: commands, triangle_count: triangles, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, scene_payload_bytes: scene_bytes, scene_payload_checksum: scene_checksum, scene3d_json: json)
        var gpu_ctx: WebGPUContext = ctx.gpu
        var resources = gpu_ctx.resources
        val upload_size = if scene_bytes <= 0: 4 else: scene_bytes
        val buffer = resources.create_buffer("simple3d-scene-command-buffer", upload_size, SIMPLE2D_WEBGPU_BUFFER_USAGE_COPY_DST)
        gpu_ctx.resources = resources
        val wrote = gpu_ctx.queue_write_buffer(buffer.id, 0, upload_size)
        var encoder = gpu_ctx.create_command_encoder("simple3d-scene-upload")
        val began = encoder.begin_render_pass()
        val set_pipeline = encoder.set_render_pipeline(pipeline.id)
        val vertex_count = if triangles <= 0: 3 else: triangles.to_i64() * 3
        val drawn = encoder.draw(vertex_count, 1)
        val ended = encoder.end_render_pass()
        val command_buffer = encoder.finish("simple3d-scene-upload-commands")
        val submitted = wrote and began and set_pipeline and drawn and ended and gpu_ctx.queue_submit([command_buffer])
        ctx.gpu = gpu_ctx
        val replay = webgpu_software_execute_queue(ctx.gpu.queue)
        val presented = if submitted: ctx.present() else: false
        val status = if submitted and replay.valid and presented: "submitted-webgpu-3d-scene-upload" else: "webgpu-3d-scene-submit-failed"
        Simple3DWebGPUDrawEvidence(available: true, submitted: submitted and replay.valid and presented, status: status, command_count: commands, triangle_count: triangles, queue_write_count: replay.queue_write_count, render_pass_count: replay.render_pass_count, draw_call_count: replay.draw_call_count, present_count: ctx.gpu.present_count, pipeline_valid: pipeline.valid, scene_payload_bytes: scene_bytes, scene_payload_checksum: scene_checksum, scene3d_json: json)

pub class Simple2DContext:
    width: i32
    height: i32
    scene: RenderScene

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.fill_rect(x, y, w, h, color))
        self

    me stroke_rect(x: i32, y: i32, w: i32, h: i32, color: i32, stroke_width: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.stroke_rect(x, y, w, h, color, stroke_width))
        self

    me text(x: i32, y: i32, value: text, font_size: i32, color: i32) -> Simple2DContext:
        self.scene = self.scene.push(SceneCommand.text(x, y, value, font_size, color))
        self

    me clear() -> Simple2DContext:
        self.scene = RenderScene.new(self.width, self.height)
        self

    fn command_count() -> i32:
        self.scene.commands.len().to_i32()

    fn last_kind() -> text:
        if self.scene.commands.len() == 0:
            return ""
        self.scene.commands[self.scene.commands.len() - 1].kind

    fn to_canvas2d_json() -> text:
        render_scene_to_canvas2d_ops(self.scene)

    fn summary() -> Simple2DCommandSummary:
        Simple2DCommandSummary(command_count: self.command_count(), last_kind: self.last_kind(), canvas2d_json: self.to_canvas2d_json())

    fn submit_to_webgpu(secure_context: bool) -> Simple2DWebGPUDrawEvidence:
        var ctx = canvas_get_context_webgpu(self.width, self.height, secure_context)
        val json = self.to_canvas2d_json()
        val commands = self.command_count()
        if not ctx.is_available():
            return Simple2DWebGPUDrawEvidence(available: false, submitted: false, status: "webgpu-unavailable", command_count: commands, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, canvas2d_json: json)
        if not ctx.request_device():
            return Simple2DWebGPUDrawEvidence(available: false, submitted: false, status: ctx.gpu.last_error, command_count: commands, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, canvas2d_json: json)
        if not ctx.configure():
            return Simple2DWebGPUDrawEvidence(available: true, submitted: false, status: ctx.gpu.last_error, command_count: commands, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, canvas2d_json: json)
        val vertex = ctx.create_shader_module("simple2d-vertex", "@vertex fn main() -> @builtin(position) vec4f { return vec4f(0.0, 0.0, 0.0, 1.0); }")
        val fragment = ctx.create_shader_module("simple2d-fragment", "@fragment fn main() -> @location(0) vec4f { return vec4f(0.0, 1.0, 0.0, 1.0); }")
        val pipeline = ctx.create_render_pipeline(vertex, fragment)
        if not pipeline.valid:
            return Simple2DWebGPUDrawEvidence(available: true, submitted: false, status: "render-pipeline-invalid", command_count: commands, queue_write_count: 0, render_pass_count: 0, draw_call_count: 0, present_count: 0, pipeline_valid: false, canvas2d_json: json)
        var gpu_ctx: WebGPUContext = ctx.gpu
        var resources = gpu_ctx.resources
        val upload_size = if commands <= 0: 4 else: commands.to_i64() * 32
        val buffer = resources.create_buffer("simple2d-command-buffer", upload_size, SIMPLE2D_WEBGPU_BUFFER_USAGE_COPY_DST)
        gpu_ctx.resources = resources
        val wrote = gpu_ctx.queue_write_buffer(buffer.id, 0, upload_size)
        var encoder = gpu_ctx.create_command_encoder("simple2d-render")
        val began = encoder.begin_render_pass()
        val set_pipeline = encoder.set_render_pipeline(pipeline.id)
        val drawn = encoder.draw(if commands <= 0: 3 else: commands.to_i64() * 6, 1)
        val ended = encoder.end_render_pass()
        val command_buffer = encoder.finish("simple2d-render-commands")
        val submitted = wrote and began and set_pipeline and drawn and ended and gpu_ctx.queue_submit([command_buffer])
        ctx.gpu = gpu_ctx
        val replay = webgpu_software_execute_queue(ctx.gpu.queue)
        val presented = if submitted: ctx.present() else: false
        val status = if submitted and replay.valid and presented: "submitted-webgpu-render" else: "webgpu-render-submit-failed"
        Simple2DWebGPUDrawEvidence(available: true, submitted: submitted and replay.valid and presented, status: status, command_count: commands, queue_write_count: replay.queue_write_count, render_pass_count: replay.render_pass_count, draw_call_count: replay.draw_call_count, present_count: ctx.gpu.present_count, pipeline_valid: pipeline.valid, canvas2d_json: json)

pub class CanvasWebGPUContext:
    width: i32
    height: i32
    gpu: WebGPUContext

    me is_available() -> bool:
        self.gpu.is_available()

    me request_device() -> bool:
        self.gpu.request_device()

    me configure() -> bool:
        self.gpu.configure()

    me present() -> bool:
        self.gpu.present()

    me create_shader_module(label: text, source: text) -> GPUShaderModule:
        self.gpu.create_shader_module(label, source)

    me create_render_pipeline(vertex: GPUShaderModule, fragment: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_render_pipeline(vertex, fragment)

    me create_compute_pipeline(shader: GPUShaderModule) -> GPUPipelineHandle:
        self.gpu.create_compute_pipeline(shader)

pub fn canvas_get_context_webgpu(width: i32, height: i32, secure_context: bool) -> CanvasWebGPUContext:
    CanvasWebGPUContext(width: width, height: height, gpu: webgpu_create_context(secure_context))

pub fn canvas_get_context_simple2d(width: i32, height: i32) -> Simple2DContext:
    Simple2DContext(width: width, height: height, scene: RenderScene.new(width, height))

pub fn canvas_get_context_simple3d(width: i32, height: i32) -> Simple3DContext:
    Simple3DContext(width: width, height: height, commands: [], triangle_count_value: 0)
