"""
# Storage API

In-memory key-value store — Simple equivalent of localStorage/sessionStorage.

JS Equivalent → Simple Function:
    localStorage.getItem()     → storage_get_item()
    localStorage.setItem()     → storage_set_item()
    localStorage.removeItem()  → storage_remove_item()
    localStorage.clear()       → storage_clear()
    localStorage.length        → storage_length()
    localStorage.key()         → storage_key()
"""

#![allow(REQC001)]

# =========================================================================
# BrowserStorage — flat key/value pair array
# =========================================================================

pub class BrowserStorage:
    """In-memory key-value store mimicking Web Storage API.

    Internal representation: _items is a flat array of [key, value, key, value, ...].
    """
    _items: [text]

    static fn new() -> BrowserStorage:
        """Create an empty storage instance."""
        BrowserStorage(_items: [])

# =========================================================================
# Storage Operations
# =========================================================================

pub fn storage_get_item(store: BrowserStorage, key: text) -> text?:
    """Get the value for a key, or nil if not present."""
    var i = 0
    while i + 1 < store._items.len():
        if store._items[i] == key:
            return Some(store._items[i + 1])
        i = i + 2
    nil

pub fn storage_set_item(store: BrowserStorage, key: text, value: text):
    """Set a key-value pair. Updates existing key or adds new one."""
    var i = 0
    while i + 1 < store._items.len():
        if store._items[i] == key:
            store._items[i + 1] = value
            return
        i = i + 2
    store._items.push(key)
    store._items.push(value)

pub fn storage_remove_item(store: BrowserStorage, key: text):
    """Remove a key-value pair by key."""
    var new_items: [text] = []
    var i = 0
    while i + 1 < store._items.len():
        if store._items[i] != key:
            new_items.push(store._items[i])
            new_items.push(store._items[i + 1])
        i = i + 2
    store._items = new_items

pub fn storage_clear(store: BrowserStorage):
    """Remove all entries from the store."""
    store._items = []

pub fn storage_length(store: BrowserStorage) -> i32:
    """Return the number of stored key-value pairs."""
    store._items.len() / 2

pub fn storage_key(store: BrowserStorage, idx: i32) -> text?:
    """Return the key at the given index, or nil if out of bounds."""
    val key_idx = idx * 2
    if key_idx >= 0 and key_idx + 1 < store._items.len():
        return Some(store._items[key_idx])
    nil
