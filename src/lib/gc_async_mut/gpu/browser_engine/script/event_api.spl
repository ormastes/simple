"""
# Event API

Simple-script event handling API for the browser engine.
Provides event listener registration, dispatch with capture/bubble phases,
and event creation/control.

JS Equivalent → Simple Function:
    node.addEventListener()     → node_add_event_listener()
    node.removeEventListener()  → node_remove_event_listener()
    event = new Event()         → event_create()
    node.dispatchEvent()        → event_dispatch()
    event.preventDefault()      → event_prevent_default()
    event.stopPropagation()     → event_stop_propagation()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{
    BeDomNode, BeDomEvent, BeDomEventDispatch,
    normalize_dom_event_type,
    be_dom_dispatch_event_actions
}

# =========================================================================
# Event Listener Registration
# =========================================================================

pub fn node_add_event_listener(node: BeDomNode, event_type: text, action: text, capture: bool):
    """Register an event listener on a node.

    Args:
        node       - target DOM node
        event_type - event name (e.g. "click", "keydown")
        action     - action identifier string
        capture    - true for capture phase, false for bubble/target
    """
    node.add_event_listener_with_capture(event_type, action, capture)

pub fn node_remove_event_listener(node: BeDomNode, event_type: text, action: text):
    """Remove an event listener matching the event type and action.

    Scans the listener arrays and removes the first match.
    """
    val normalized = normalize_dom_event_type(event_type)
    var new_types: [text] = []
    var new_actions: [text] = []
    var new_captures: [bool] = []
    var removed = false
    var i = 0
    while i < node.event_listener_types.len():
        if (not removed and
            node.event_listener_types[i] == normalized and
            node.event_listener_actions[i] == action):
            removed = true
        else:
            new_types.push(node.event_listener_types[i])
            new_actions.push(node.event_listener_actions[i])
            new_captures.push(node.event_listener_capture[i])
        i = i + 1
    node.event_listener_types = new_types
    node.event_listener_actions = new_actions
    node.event_listener_capture = new_captures

# =========================================================================
# Event Dispatch
# =========================================================================

pub fn event_dispatch(node: BeDomNode, event: BeDomEvent) -> [text]:
    """Dispatch an event on a node and return the list of triggered actions.

    Uses the existing be_dom_dispatch_event_actions helper for target-phase
    dispatch. Full capture/bubble path dispatch requires a tree-walk from
    root which is handled by the ScriptRunner at a higher level.
    """
    be_dom_dispatch_event_actions(node, event.event_type)

# =========================================================================
# Event Creation
# =========================================================================

pub fn event_create(event_type: text, target_id: text) -> BeDomEvent:
    """Create a new DOM event with sensible defaults.

    The event bubbles and is cancelable by default.
    """
    BeDomEvent.create(event_type, "", target_id, "", target_id, true, true)

# =========================================================================
# Event Control
# =========================================================================

pub fn event_prevent_default(event: BeDomEvent):
    """Prevent the default action for this event."""
    event.prevent_default()

pub fn event_stop_propagation(event: BeDomEvent):
    """Stop the event from propagating further."""
    event.stop_propagation()
