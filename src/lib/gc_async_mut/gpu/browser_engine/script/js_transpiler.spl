"""
# JS Transpiler

Lightweight JavaScript-to-Simple transpiler for the browser engine.
Converts common JS patterns to Simple equivalents so that standard HTML
pages with `<script>` tags can run in the Simple browser.

This is NOT a full JS engine. It handles common patterns via line-by-line
string processing with brace-depth tracking for block conversion.

Supported Conversions:
    var/let/const       -> var / val
    function f() {}     -> fn f():
    =>                  -> fn():
    ===                 -> ==
    !==                 -> !=
    null / undefined    -> nil
    this.               -> me.
    new X(...)          -> X(...)
    // comment          -> # comment
    /* comment */       -> (removed)
    `${x}`              -> "{x}"
    for (x of arr)      -> for x in arr:
    document.querySelector()      -> document_query_selector(root, ...)
    canvas.getContext("webgl")    -> canvas_get_context_webgl(300, 150)
    canvas.getContext("webgpu")   -> canvas_get_context_webgpu(300, 150, true)
    navigator.gpu.requestAdapter() -> navigator_gpu_request_adapter(nav)
    gl.clearColor()               -> canvas_webgl_clear_color(gl, ...)
    gl.createShader()             -> canvas_webgl_create_shader(gl, ...)
    gl.bufferData()               -> canvas_webgl_buffer_data_size(gl, ...)
    element.addEventListener()    -> node_add_event_listener(...)
    console.log()                 -> console_log(buf, ...)
    setTimeout()                  -> set_timeout(loop_ref, ...)
    new Worker()                  -> worker_create(...)
    worker.postMessage()          -> worker_post_message(worker, ...)
    worker.terminate()            -> worker_terminate(worker)
    self.postMessage()            -> worker_global_post_message(scope, ...)
    element.style.X = Y          -> node_set_style_property(node, "X", "Y")
    element.innerHTML = X         -> node_set_inner_html(node, X)
    element.textContent = X       -> node_set_text_content(node, X)
    element.classList.add(X)      -> node_class_list_add(node, X)
"""

#![allow(REQC001)]

# =========================================================================
# Public API
# =========================================================================

pub fn js_transpile(source: text) -> text:
    """Transpile JavaScript source to Simple source.

    Processes the source through multiple passes:
    1. Remove block comments
    2. Convert line-by-line (operators, keywords, literals)
    3. Convert braces to indentation-based blocks
    """
    var code = _remove_block_comments(source)
    code = _convert_template_literals(code)
    val lines = code.split("\n")
    var result_lines: [text] = []
    var i = 0
    while i < lines.len():
        val line = _convert_line(lines[i])
        result_lines.push(line)
        i = i + 1
    var joined = _join_lines(result_lines)
    joined = _convert_braces_to_indent(joined)
    joined

pub fn js_is_javascript(script_type: text) -> bool:
    """Check if a script type attribute indicates JavaScript.

    Returns true for:
    - empty string (no type attribute = default JS)
    - "text/javascript"
    - "application/javascript"
    - "module"
    """
    if script_type == "":
        return true
    val lower = script_type.lower()
    if lower == "text/javascript":
        return true
    if lower == "application/javascript":
        return true
    if lower == "module":
        return true
    false

pub fn js_is_simple(script_type: text) -> bool:
    """Check if a script type attribute indicates Simple."""
    val lower = script_type.lower()
    lower == "text/simple"

# =========================================================================
# Pass 1: Remove block comments /* ... */
# =========================================================================

fn _remove_block_comments(source: text) -> text:
    """Remove all /* ... */ block comments from source.

    Respects string boundaries — does not remove comment markers
    inside single or double quotes.
    """
    var result = ""
    var i = 0
    var in_block_comment = false
    var in_single_quote = false
    var in_double_quote = false
    while i < source.len():
        val ch = source.char_at(i)
        if in_block_comment:
            if ch == "*" and i + 1 < source.len():
                val next = source.char_at(i + 1)
                if next == "/":
                    in_block_comment = false
                    i = i + 2
                    continue
            i = i + 1
            continue
        # Track string boundaries
        if ch == "'" and not in_double_quote:
            in_single_quote = not in_single_quote
            result = result + ch
            i = i + 1
            continue
        if ch == "\"" and not in_single_quote:
            in_double_quote = not in_double_quote
            result = result + ch
            i = i + 1
            continue
        # Check for block comment start
        if (not in_single_quote and not in_double_quote and
                ch == "/" and i + 1 < source.len()):
            val next = source.char_at(i + 1)
            if next == "*":
                in_block_comment = true
                i = i + 2
                continue
        result = result + ch
        i = i + 1
    result

# =========================================================================
# Pass 2: Convert template literals `${x}` -> "{x}"
# =========================================================================

fn _convert_template_literals(source: text) -> text:
    """Convert JS template literals to Simple string interpolation.

    `hello ${name}!` -> "hello {name}!"
    """
    var result = ""
    var i = 0
    var in_template = false
    while i < source.len():
        val ch = source.char_at(i)
        if ch == "`":
            in_template = not in_template
            result = result + "\""
            i = i + 1
            continue
        if in_template and ch == "$" and i + 1 < source.len():
            val next = source.char_at(i + 1)
            if next == "{":
                result = result + "{"
                i = i + 2
                continue
        result = result + ch
        i = i + 1
    result

# =========================================================================
# Pass 3: Line-by-line conversions
# =========================================================================

fn _convert_line(line: text) -> text:
    """Apply all single-line conversions to a JS line."""
    var result = line

    # Convert line comments: // -> #
    result = _convert_line_comment(result)

    # Convert operators (string-aware)
    result = _safe_replace(result, "!==", "!=")
    result = _safe_replace(result, "===", "==")

    # Convert keywords
    result = _convert_declarations(result)
    result = _convert_function_keyword(result)
    result = _convert_null_undefined(result)
    result = _convert_this(result)
    result = _convert_new(result)
    result = _convert_for_of(result)
    result = _convert_return(result)

    # Convert DOM API calls
    result = _convert_dom_calls(result)
    result = _convert_webgl_calls(result)
    result = _convert_console_calls(result)
    result = _convert_timer_calls(result)
    result = _convert_worker_calls(result)
    result = _convert_style_get_property(result)
    result = _convert_style_assignment(result)
    result = _convert_inner_html(result)
    result = _convert_text_content(result)
    result = _convert_classlist(result)
    result = _convert_event_listener(result)

    result

# =========================================================================
# Line comment conversion
# =========================================================================

fn _convert_line_comment(line: text) -> text:
    """Convert // comments to # comments, respecting strings."""
    var i = 0
    var in_single = false
    var in_double = false
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "'" and not in_double:
            in_single = not in_single
        if ch == "\"" and not in_single:
            in_double = not in_double
        if (not in_single and not in_double and
                ch == "/" and i + 1 < line.len()):
            val next = line.char_at(i + 1)
            if next == "/":
                val before = line.slice(0, i)
                val comment = line.slice(i + 2, line.len())
                return before + "#" + comment
        i = i + 1
    line

# =========================================================================
# String-aware replacement
# =========================================================================

fn _safe_replace(line: text, old: text, replacement: text) -> text:
    """Replace occurrences of old with replacement, skipping string contents."""
    var result = ""
    var i = 0
    var in_single = false
    var in_double = false
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "'" and not in_double:
            in_single = not in_single
            result = result + ch
            i = i + 1
            continue
        if ch == "\"" and not in_single:
            in_double = not in_double
            result = result + ch
            i = i + 1
            continue
        if not in_single and not in_double and i + old.len() <= line.len():
            val candidate = line.slice(i, i + old.len())
            if candidate == old:
                result = result + replacement
                i = i + old.len()
                continue
        result = result + ch
        i = i + 1
    result

# =========================================================================
# Declaration conversions
# =========================================================================

fn _convert_declarations(line: text) -> text:
    """Convert var/let/const declarations.

    const x = ... -> val x = ...
    let x = ...   -> var x = ...
    var x = ...   -> var x = ...  (unchanged)
    """
    val trimmed = line.trim()
    if trimmed.starts_with("const "):
        return line.replace("const ", "val ")
    if trimmed.starts_with("let "):
        return line.replace("let ", "var ")
    line

fn _convert_function_keyword(line: text) -> text:
    """Convert function declarations.

    function f(a, b) { -> fn f(a, b) {
    The opening brace is left in place for _convert_braces_to_indent to handle.
    """
    val trimmed = line.trim()
    if trimmed.starts_with("function "):
        return line.replace("function ", "fn ")
    line

fn _convert_null_undefined(line: text) -> text:
    """Convert null and undefined to nil."""
    var result = _safe_replace(line, "undefined", "nil")
    result = _safe_replace(result, "null", "nil")
    result

fn _convert_this(line: text) -> text:
    """Convert this. to me. references."""
    _safe_replace(line, "this.", "me.")

fn _convert_new(line: text) -> text:
    """Convert new ClassName(...) to ClassName(...).

    Removes the 'new ' keyword before constructor calls.
    """
    _safe_replace(line, "new ", "")

fn _convert_for_of(line: text) -> text:
    """Convert for (let/var/const x of arr) to for x in arr {.

    Handles: for (let x of arr) { -> for x in arr {
    The opening brace is left in place for _convert_braces_to_indent to handle.
    """
    val trimmed = line.trim()
    if not trimmed.starts_with("for "):
        return line
    if not trimmed.contains(" of "):
        return line
    # Extract: for (let/var/const VARNAME of EXPR) {
    val paren_start = trimmed.index_of("(")
    val paren_end = trimmed.index_of(")")
    if paren_start < 0 or paren_end < 0:
        return line
    val inner = trimmed.slice(paren_start + 1, paren_end).trim()
    val of_pos = inner.index_of(" of ")
    if of_pos < 0:
        return line
    var var_part = inner.slice(0, of_pos).trim()
    val arr_part = inner.slice(of_pos + 4, inner.len()).trim()
    # Strip let/var/const from var_part
    if var_part.starts_with("let "):
        var_part = var_part.slice(4, var_part.len())
    if var_part.starts_with("var "):
        var_part = var_part.slice(4, var_part.len())
    if var_part.starts_with("const "):
        var_part = var_part.slice(6, var_part.len())
    val leading = _get_leading_whitespace(line)
    # Check if there's a trailing { — keep it for brace-to-indent pass
    val after_paren = trimmed.slice(paren_end + 1, trimmed.len()).trim()
    if after_paren == "{":
        return leading + "for " + var_part + " in " + arr_part + " {"
    if after_paren == "{}":
        return leading + "for " + var_part + " in " + arr_part + " {"
    leading + "for " + var_part + " in " + arr_part

fn _convert_return(line: text) -> text:
    """Convert return statements — strip trailing semicolons."""
    val trimmed = line.trim()
    if trimmed.starts_with("return ") and trimmed.ends_with(";"):
        val leading = _get_leading_whitespace(line)
        val body = trimmed.slice(0, trimmed.len() - 1)
        return leading + body
    if trimmed == "return;":
        val leading = _get_leading_whitespace(line)
        return leading + "return"
    line

# =========================================================================
# DOM API call conversions
# =========================================================================

fn _convert_dom_calls(line: text) -> text:
    """Convert document.querySelector etc. to Simple function calls."""
    var result = line
    result = result.replace("document.querySelector(", "document_query_selector(root, ")
    result = result.replace("document.querySelectorAll(", "document_query_selector_all(root, ")
    result = result.replace("document.getElementById(", "document_get_element_by_id(root, ")
    result = result.replace("document.createElement(", "document_create_element(")
    result = result.replace("document.createTextNode(", "document_create_text_node(")
    result

fn _convert_webgl_calls(line: text) -> text:
    """Convert a minimal browser WebGL JS surface to canvas_api helpers."""
    var result = line
    result = _safe_replace(result, ".getContext(\"experimental-webgl\")", "_getContext_experimental_webgl")
    result = _safe_replace(result, ".getContext('experimental-webgl')", "_getContext_experimental_webgl")
    result = _safe_replace(result, ".getContext(\"webgpu\")", "_getContext_webgpu")
    result = _safe_replace(result, ".getContext('webgpu')", "_getContext_webgpu")
    result = _safe_replace(result, ".getContext(\"webgl2\")", "_getContext_webgl2")
    result = _safe_replace(result, ".getContext('webgl2')", "_getContext_webgl2")
    result = _safe_replace(result, ".getContext(\"webgl\")", "_getContext_webgl")
    result = _safe_replace(result, ".getContext('webgl')", "_getContext_webgl")
    result = result.replace("canvas_getContext_experimental_webgl", "canvas_get_context_webgl(300, 150)")
    result = result.replace("canvas_getContext_webgpu", "canvas_get_context_webgpu(300, 150, true)")
    result = result.replace("canvas_getContext_webgl2", "canvas_get_context_webgl2(300, 150)")
    result = result.replace("canvas_getContext_webgl", "canvas_get_context_webgl(300, 150)")
    result = _convert_webgl_constants(result)
    result = result.replace("gl.drawingBufferWidth", "canvas_webgl_drawing_buffer_width(gl)")
    result = result.replace("gl.drawingBufferHeight", "canvas_webgl_drawing_buffer_height(gl)")
    if result.index_of(".clearColor(") >= 0:
        return _convert_webgl_method(result, ".clearColor(", "canvas_webgl_clear_color")
    if result.index_of(".viewport(") >= 0:
        return _convert_webgl_method(result, ".viewport(", "canvas_webgl_viewport")
    if result.index_of(".clear(") >= 0:
        return _convert_webgl_method(result, ".clear(", "canvas_webgl_clear")
    if result.index_of(".flush(") >= 0:
        return _convert_webgl_method_for_gl(result, ".flush(", "canvas_webgl_flush")
    if result.index_of(".finish(") >= 0:
        return _convert_webgl_method_for_gl(result, ".finish(", "canvas_webgl_finish")
    if result.index_of(".clearDepth(") >= 0:
        return _convert_webgl_method_for_gl(result, ".clearDepth(", "canvas_webgl_clear_depth")
    if result.index_of(".depthRange(") >= 0:
        return _convert_webgl_method_for_gl(result, ".depthRange(", "canvas_webgl_depth_range")
    if result.index_of(".clearStencil(") >= 0:
        return _convert_webgl_method_for_gl(result, ".clearStencil(", "canvas_webgl_clear_stencil")
    if result.index_of(".getExtension(") >= 0:
        return _convert_webgl_method(result, ".getExtension(", "canvas_webgl_get_extension")
    if result.index_of(".getSupportedExtensions(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getSupportedExtensions(", "canvas_webgl_get_supported_extensions")
    if result.index_of(".isContextLost(") >= 0:
        return _convert_webgl_method_for_gl(result, ".isContextLost(", "canvas_webgl_is_context_lost")
    if result.index_of(".loseContext(") >= 0:
        return _convert_webgl_method_for_gl(result, ".loseContext(", "canvas_webgl_lose_context")
    if result.index_of(".restoreContext(") >= 0:
        return _convert_webgl_method_for_gl(result, ".restoreContext(", "canvas_webgl_restore_context")
    if result.index_of(".getError(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getError(", "canvas_webgl_get_error")
    if result.index_of(".enable(") >= 0:
        return _convert_webgl_method_for_gl(result, ".enable(", "canvas_webgl_enable")
    if result.index_of(".disable(") >= 0:
        return _convert_webgl_method_for_gl(result, ".disable(", "canvas_webgl_disable")
    if result.index_of(".getContextAttributes(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getContextAttributes(", "canvas_webgl_get_context_attributes")
    if result.index_of(".getParameter(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getParameter(", "canvas_webgl_get_parameter")
    if result.index_of(".isEnabled(") >= 0:
        return _convert_webgl_method_for_gl(result, ".isEnabled(", "canvas_webgl_is_enabled")
    if result.index_of(".lineWidth(") >= 0:
        return _convert_webgl_method_for_gl(result, ".lineWidth(", "canvas_webgl_line_width")
    if result.index_of(".hint(") >= 0:
        return _convert_webgl_method_for_gl(result, ".hint(", "canvas_webgl_hint")
    if result.index_of(".frontFace(") >= 0:
        return _convert_webgl_method_for_gl(result, ".frontFace(", "canvas_webgl_front_face")
    if result.index_of(".cullFace(") >= 0:
        return _convert_webgl_method_for_gl(result, ".cullFace(", "canvas_webgl_cull_face")
    if result.index_of(".polygonOffset(") >= 0:
        return _convert_webgl_method_for_gl(result, ".polygonOffset(", "canvas_webgl_polygon_offset")
    if result.index_of(".sampleCoverage(") >= 0:
        return _convert_webgl_method_for_gl(result, ".sampleCoverage(", "canvas_webgl_sample_coverage")
    if result.index_of(".blendColor(") >= 0:
        return _convert_webgl_method_for_gl(result, ".blendColor(", "canvas_webgl_blend_color")
    if result.index_of(".depthFunc(") >= 0:
        return _convert_webgl_method_for_gl(result, ".depthFunc(", "canvas_webgl_depth_func")
    if result.index_of(".depthMask(") >= 0:
        return _convert_webgl_method_for_gl(result, ".depthMask(", "canvas_webgl_depth_mask")
    if result.index_of(".colorMask(") >= 0:
        return _convert_webgl_method_for_gl(result, ".colorMask(", "canvas_webgl_color_mask")
    if result.index_of(".scissor(") >= 0:
        return _convert_webgl_method_for_gl(result, ".scissor(", "canvas_webgl_scissor")
    if result.index_of(".stencilFuncSeparate(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilFuncSeparate(", "canvas_webgl_stencil_func_separate")
    if result.index_of(".stencilFunc(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilFunc(", "canvas_webgl_stencil_func")
    if result.index_of(".stencilOpSeparate(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilOpSeparate(", "canvas_webgl_stencil_op_separate")
    if result.index_of(".stencilOp(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilOp(", "canvas_webgl_stencil_op")
    if result.index_of(".stencilMaskSeparate(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilMaskSeparate(", "canvas_webgl_stencil_mask_separate")
    if result.index_of(".stencilMask(") >= 0:
        return _convert_webgl_method_for_gl(result, ".stencilMask(", "canvas_webgl_stencil_mask")
    if result.index_of(".blendFuncSeparate(") >= 0:
        return _convert_webgl_method_for_gl(result, ".blendFuncSeparate(", "canvas_webgl_blend_func_separate")
    if result.index_of(".blendFunc(") >= 0:
        return _convert_webgl_method_for_gl(result, ".blendFunc(", "canvas_webgl_blend_func")
    if result.index_of(".blendEquationSeparate(") >= 0:
        return _convert_webgl_method_for_gl(result, ".blendEquationSeparate(", "canvas_webgl_blend_equation_separate")
    if result.index_of(".blendEquation(") >= 0:
        return _convert_webgl_method_for_gl(result, ".blendEquation(", "canvas_webgl_blend_equation")
    if result.index_of(".pixelStorei(") >= 0:
        return _convert_webgl_method_for_gl(result, ".pixelStorei(", "canvas_webgl_pixel_store_i")
    if result.index_of(".readPixels(") >= 0:
        return _convert_webgl_method_for_gl(result, ".readPixels(", "canvas_webgl_read_pixels")
    if result.index_of(".createBuffer(") >= 0:
        return _convert_webgl_method_for_gl(result, ".createBuffer(", "canvas_webgl_create_buffer")
    if result.index_of(".createVertexArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".createVertexArray(", "canvas_webgl_create_vertex_array")
    if result.index_of(".isVertexArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".isVertexArray(", "canvas_webgl_is_vertex_array")
    if result.index_of(".deleteVertexArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".deleteVertexArray(", "canvas_webgl_delete_vertex_array")
    if result.index_of(".bindVertexArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".bindVertexArray(", "canvas_webgl_bind_vertex_array")
    if result.index_of(".isBuffer(") >= 0:
        return _convert_webgl_method_for_gl(result, ".isBuffer(", "canvas_webgl_is_buffer")
    if result.index_of(".deleteBuffer(") >= 0:
        return _convert_webgl_method_for_gl(result, ".deleteBuffer(", "canvas_webgl_delete_buffer")
    if result.index_of(".bindBuffer(") >= 0:
        return _convert_webgl_method_for_gl(result, ".bindBuffer(", "canvas_webgl_bind_buffer")
    if result.index_of(".bufferData(") >= 0:
        return _convert_webgl_method_for_gl(result, ".bufferData(", "canvas_webgl_buffer_data_size")
    if result.index_of(".getBufferParameter(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getBufferParameter(", "canvas_webgl_get_buffer_parameter")
    if result.index_of(".enableVertexAttribArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".enableVertexAttribArray(", "canvas_webgl_enable_vertex_attrib_array")
    if result.index_of(".disableVertexAttribArray(") >= 0:
        return _convert_webgl_method_for_gl(result, ".disableVertexAttribArray(", "canvas_webgl_disable_vertex_attrib_array")
    if result.index_of(".vertexAttribPointer(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttribPointer(", "canvas_webgl_vertex_attrib_pointer")
    if result.index_of(".vertexAttribDivisor(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttribDivisor(", "canvas_webgl_vertex_attrib_divisor")
    if result.index_of(".vertexAttrib1fv(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib1fv(", "canvas_webgl_vertex_attrib_1fv")
    if result.index_of(".vertexAttrib2fv(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib2fv(", "canvas_webgl_vertex_attrib_2fv")
    if result.index_of(".vertexAttrib3fv(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib3fv(", "canvas_webgl_vertex_attrib_3fv")
    if result.index_of(".vertexAttrib4fv(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib4fv(", "canvas_webgl_vertex_attrib_4fv")
    if result.index_of(".vertexAttrib1f(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib1f(", "canvas_webgl_vertex_attrib_1f")
    if result.index_of(".vertexAttrib2f(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib2f(", "canvas_webgl_vertex_attrib_2f")
    if result.index_of(".vertexAttrib3f(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib3f(", "canvas_webgl_vertex_attrib_3f")
    if result.index_of(".vertexAttrib4f(") >= 0:
        return _convert_webgl_method_for_gl(result, ".vertexAttrib4f(", "canvas_webgl_vertex_attrib_4f")
    if result.index_of(".getVertexAttribOffset(") >= 0:
        return _convert_webgl_method_for_gl(result, ".getVertexAttribOffset(", "canvas_webgl_get_vertex_attrib_offset")
    if result.index_of(".getVertexAttrib(") >= 0:
