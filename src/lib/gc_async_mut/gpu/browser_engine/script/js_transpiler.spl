fn _convert_webgpu_calls(line: text) -> text:
    """Convert browser WebGPU camelCase methods to Simple WebGPU wrapper names."""
    var result = line
    result = result.replace("navigator.gpu.requestAdapter()", "navigator_gpu_request_adapter(nav)")
    result = result.replace("navigator.gpu.requestAdapter(", "navigator_gpu_request_adapter_with_options(nav, ")
    result = result.replace("navigator.gpu.secureContext", "navigator_gpu_secure_context(nav)")
    result = result.replace("navigator.gpu.adapterAvailable", "navigator_gpu_adapter_available(nav)")
    result = result.replace("navigator.gpu.requestAdapterStatus", "navigator_gpu_request_adapter_status(nav)")
    result = result.replace("navigator.gpu.preferredCanvasFormat", "navigator_gpu_preferred_canvas_format(nav)")
    result = result.replace(".requestDevice(", ".request_device(")
    result = result.replace(".createShaderModule(", ".create_shader_module(")
    result = _convert_webgpu_auto_render_pipeline_descriptor(result)
    result = result.replace(".createRenderPipelineAutoLayout(", ".create_render_pipeline_auto_layout(")
    result = result.replace(".createRenderPipeline(", ".create_render_pipeline(")
    result = result.replace(".createComputePipeline(", ".create_compute_pipeline(")
    result = result.replace(".createCommandEncoder(", ".create_command_encoder(")
    result = _convert_webgpu_buffer_descriptor(result)
    result = result.replace(".createBuffer(", ".create_buffer(")
    result = _convert_webgpu_texture_descriptor(result)
    result = _convert_webgpu_texture_view_descriptor(result)
    result = _convert_webgpu_texture_create_view_descriptor(result)
    result = _convert_webgpu_bind_group_layout_descriptor(result)
    result = _convert_webgpu_bind_group_descriptor(result)
    result = result.replace(".createTextureWithDescriptor(", ".create_texture_with_descriptor(")
    result = result.replace(".createTextureWithMipLevels(", ".create_texture_with_mip_levels(")
    result = result.replace(".createTextureWithDimension(", ".create_texture_with_dimension(")
    result = result.replace(".createTextureView(", ".create_texture_view(")
    result = result.replace(".createTexture(", ".create_texture(")
    result = _convert_webgpu_sampler_descriptor(result)
    result = result.replace(".createSampler(", ".create_sampler(")
    result = result.replace(".createBindGroupLayout(", ".create_bind_group_layout(")
    result = result.replace(".createBindGroup(", ".create_bind_group(")
    result = result.replace(".queueSubmit(", ".queue_submit(")
    result = result.replace(".queueWriteBuffer(", ".queue_write_buffer(")
    result = _convert_webgpu_queue_write_texture_descriptor(result)
    result = result.replace(".queueWriteTexture(", ".queue_write_texture(")
    result = _convert_webgpu_render_pass_descriptor(result)
    result = result.replace(".beginRenderPass(", ".begin_render_pass(")
    result = result.replace(".endRenderPass(", ".end_render_pass(")
    result = result.replace(".beginComputePass(", ".begin_compute_pass(")
    result = result.replace(".endComputePass(", ".end_compute_pass(")
    result = result.replace(".setPipeline(", ".set_pipeline(")
    result = result.replace(".setBindGroupWithDynamicOffsets(", ".set_bind_group_with_dynamic_offsets(")
    result = result.replace(".setBindGroup(", ".set_bind_group(")
    result = result.replace(".setVertexBuffer(", ".set_vertex_buffer(")
    result = result.replace(".setIndexBuffer(", ".set_index_buffer(")
    result = result.replace(".setScissorRect(", ".set_scissor_rect(")
    result = result.replace(".setViewport(", ".set_viewport(")
    result = result.replace(".drawIndexed(", ".draw_indexed(")
    result = result.replace(".drawIndirect(", ".draw_indirect(")
    result = result.replace(".drawIndexedIndirect(", ".draw_indexed_indirect(")
    result = result.replace(".dispatchWorkgroups(", ".dispatch_workgroups(")
    result = result.replace(".copyBufferToBuffer(", ".copy_buffer_to_buffer(")
    result = _convert_webgpu_copy_texture_to_texture_descriptor(result)
    result = result.replace(".copyTextureToTexture(", ".copy_texture_to_texture(")
    result

fn _convert_webgpu_buffer_descriptor(line: text) -> text:
    val marker = ".createBuffer({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val size = _webgpu_descriptor_value(descriptor, "size")
    val usage = _webgpu_descriptor_value(descriptor, "usage")
    if size == "" or usage == "":
        return line
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_buffer(" + label + ", " + size + ", " + usage + ")" + suffix

fn _convert_webgpu_sampler_descriptor(line: text) -> text:
    val marker = ".createSampler({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    val address_mode_u = _webgpu_descriptor_value_or_default(descriptor, "addressModeU", "\"clamp-to-edge\"")
    val address_mode_v = _webgpu_descriptor_value_or_default(descriptor, "addressModeV", "\"clamp-to-edge\"")
    val address_mode_w = _webgpu_descriptor_value_or_default(descriptor, "addressModeW", "\"clamp-to-edge\"")
    val mag_filter = _webgpu_descriptor_value_or_default(descriptor, "magFilter", "\"nearest\"")
    val min_filter = _webgpu_descriptor_value_or_default(descriptor, "minFilter", "\"nearest\"")
    val mipmap_filter = _webgpu_descriptor_value_or_default(descriptor, "mipmapFilter", "\"nearest\"")
    val lod_min_clamp = _webgpu_descriptor_value_or_default(descriptor, "lodMinClamp", "0.0")
    val lod_max_clamp = _webgpu_descriptor_value_or_default(descriptor, "lodMaxClamp", "32.0")
    val compare = _webgpu_descriptor_value_or_default(descriptor, "compare", "\"\"")
    val max_anisotropy = _webgpu_descriptor_value_or_default(descriptor, "maxAnisotropy", "1")
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_sampler_with_descriptor(" + label + ", " + address_mode_u + ", " + address_mode_v + ", " + address_mode_w + ", " + mag_filter + ", " + min_filter + ", " + mipmap_filter + ", " + lod_min_clamp + ", " + lod_max_clamp + ", " + compare + ", " + max_anisotropy + ")" + suffix

fn _convert_webgpu_texture_descriptor(line: text) -> text:
    val marker = ".createTexture({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    var width = _webgpu_descriptor_value_or_default(descriptor, "width", "")
    var height = _webgpu_descriptor_value_or_default(descriptor, "height", "")
    var depth_or_layers = _webgpu_descriptor_value_or_default(descriptor, "depthOrArrayLayers", "")
    val size_value = _webgpu_descriptor_value(descriptor, "size")
    if size_value.starts_with("[") and size_value.ends_with("]"):
        val size_inner = size_value.slice(1, size_value.len() - 1)
        val size_parts = size_inner.split(",")
        if size_parts.len() >= 2:
            width = size_parts[0].trim()
            height = size_parts[1].trim()
        if depth_or_layers == "" and size_parts.len() >= 3:
            depth_or_layers = size_parts[2].trim()
    val format = _webgpu_descriptor_value_or_default(descriptor, "format", "")
    val usage = _webgpu_descriptor_value_or_default(descriptor, "usage", "")
    if width == "" or height == "" or format == "" or usage == "":
        return line
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    if depth_or_layers == "":
        depth_or_layers = "1"
    val dimension = _webgpu_descriptor_value_or_default(descriptor, "dimension", "\"2d\"")
    val mip_level_count = _webgpu_descriptor_value_or_default(descriptor, "mipLevelCount", "1")
    val sample_count = _webgpu_descriptor_value_or_default(descriptor, "sampleCount", "1")
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_texture_with_descriptor(" + label + ", " + width + ", " + height + ", " + depth_or_layers + ", " + format + ", " + usage + ", " + dimension + ", " + mip_level_count + ", " + sample_count + ")" + suffix

fn _convert_webgpu_texture_view_descriptor(line: text) -> text:
    val marker = ".createTextureView({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    var texture_id = _webgpu_descriptor_value(descriptor, "textureId")
    if texture_id == "":
        val texture = _webgpu_descriptor_value(descriptor, "texture")
        if texture == "":
            return line
        texture_id = _webgpu_texture_object_id(texture)
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_texture_view(" + _webgpu_texture_view_args(descriptor, texture_id) + ")" + suffix

fn _convert_webgpu_texture_create_view_descriptor(line: text) -> text:
    val marker = ".createView({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val target_expr = line.slice(0, marker_idx)
    val eq_pos = target_expr.index_of("=")
    if eq_pos < 0:
        return line
    val prefix = target_expr.slice(0, eq_pos + 1)
    val texture = target_expr.slice(eq_pos + 1, target_expr.len()).trim()
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + " gpu.create_texture_view(" + _webgpu_texture_view_args(descriptor, _webgpu_texture_object_id(texture)) + ")" + suffix

fn _webgpu_texture_object_id(texture: text) -> text:
    if texture.ends_with(".id"):
        return texture
    texture + ".id"

fn _webgpu_texture_view_args(descriptor: text, texture_id: text) -> text:
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    val format = _webgpu_descriptor_value_or_default(descriptor, "format", "\"\"")
    val dimension = _webgpu_descriptor_value_or_default(descriptor, "dimension", "\"\"")
    val base_mip_level = _webgpu_descriptor_value_or_default(descriptor, "baseMipLevel", "0")
    val mip_level_count = _webgpu_descriptor_value_or_default(descriptor, "mipLevelCount", "1")
    val base_array_layer = _webgpu_descriptor_value_or_default(descriptor, "baseArrayLayer", "0")
    val array_layer_count = _webgpu_descriptor_value_or_default(descriptor, "arrayLayerCount", "1")
    label + ", " + texture_id + ", " + format + ", " + dimension + ", " + base_mip_level + ", " + mip_level_count + ", " + base_array_layer + ", " + array_layer_count

fn _convert_webgpu_bind_group_layout_descriptor(line: text) -> text:
    val marker = ".createBindGroupLayout({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val entries = _webgpu_descriptor_value(descriptor, "entries")
    if entries == "":
        return line
    val lowered_entries = _webgpu_bind_group_layout_entries(entries)
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_bind_group_layout(" + label + ", " + lowered_entries + ")" + suffix

fn _webgpu_bind_group_layout_entries(entries: text) -> text:
    val trimmed = entries.trim()
    if not trimmed.starts_with("[") or not trimmed.ends_with("]"):
        return entries
    val inner = trimmed.slice(1, trimmed.len() - 1)
    var result = "["
    var pos = 0
    var first = true
    while pos < inner.len():
        while pos < inner.len() and (inner.slice(pos, pos + 1) == " " or inner.slice(pos, pos + 1) == ","):
            pos = pos + 1
        if pos >= inner.len():
            break
        if inner.slice(pos, pos + 1) != "{":
            return entries
        val end = _webgpu_matching_brace(inner, pos)
        if end < 0:
            return entries
        val descriptor = inner.slice(pos + 1, end)
        val lowered = _webgpu_bind_group_layout_entry(descriptor)
        if lowered == "":
            return entries
        if not first:
            result = result + ", "
        result = result + lowered
        first = false
        pos = end + 1
    result + "]"

fn _webgpu_matching_brace(source: text, open_idx: i32) -> i32:
    var depth = 0
    var i = open_idx
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if ch == "{":
            depth = depth + 1
        else: if ch == "}":
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    -1

fn _webgpu_bind_group_layout_entry(descriptor: text) -> text:
    val binding = _webgpu_descriptor_value(descriptor, "binding")
    val visibility = _webgpu_descriptor_value(descriptor, "visibility")
    if binding == "" or visibility == "":
        return ""
    val sampler = _webgpu_descriptor_value(descriptor, "sampler")
    if sampler != "":
        val sampler_type = _webgpu_descriptor_value_or_default(sampler, "type", "\"filtering\"")
        if sampler_type.contains("comparison"):
            return "GPUBindGroupLayoutEntry.comparison_sampler(" + binding + ", " + visibility + ")"
        if sampler_type.contains("non-filtering"):
            return "GPUBindGroupLayoutEntry.non_filtering_sampler(" + binding + ", " + visibility + ")"
        return "GPUBindGroupLayoutEntry.sampler(" + binding + ", " + visibility + ")"
    val buffer = _webgpu_descriptor_value(descriptor, "buffer")
    if buffer != "":
        val buffer_type = _webgpu_descriptor_value_or_default(buffer, "type", "\"uniform\"")
        val has_dynamic_offset = _webgpu_descriptor_value_or_default(buffer, "hasDynamicOffset", "false")
        if buffer_type.contains("storage"):
            if has_dynamic_offset == "true":
                return "GPUBindGroupLayoutEntry.dynamic_storage_buffer(" + binding + ", " + visibility + ")"
            if buffer_type.contains("read-only-storage"):
                return "GPUBindGroupLayoutEntry.readonly_storage_buffer(" + binding + ", " + visibility + ")"
            return "GPUBindGroupLayoutEntry.storage_buffer(" + binding + ", " + visibility + ")"
        if has_dynamic_offset == "true":
            return "GPUBindGroupLayoutEntry.dynamic_buffer(" + binding + ", " + visibility + ")"
        return "GPUBindGroupLayoutEntry.buffer(" + binding + ", " + visibility + ")"
    if _webgpu_descriptor_value(descriptor, "storageTexture") != "":
        return "GPUBindGroupLayoutEntry.storage_texture(" + binding + ", " + visibility + ")"
    if _webgpu_descriptor_value(descriptor, "texture") != "":
        return "GPUBindGroupLayoutEntry.texture(" + binding + ", " + visibility + ")"
    ""

fn _convert_webgpu_bind_group_descriptor(line: text) -> text:
    val marker = ".createBindGroup({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val layout = _webgpu_descriptor_value(descriptor, "layout")
    val entries = _webgpu_descriptor_value(descriptor, "entries")
    if layout == "" or entries == "":
        return line
    val label = _webgpu_descriptor_value_or_default(descriptor, "label", "\"\"")
    val lowered_entries = _webgpu_bind_group_entries(entries)
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_bind_group(" + label + ", " + _webgpu_layout_object_id(layout) + ", " + lowered_entries + ")" + suffix

fn _webgpu_bind_group_entries(entries: text) -> text:
    val trimmed = entries.trim()
    if not trimmed.starts_with("[") or not trimmed.ends_with("]"):
        return entries
    val inner = trimmed.slice(1, trimmed.len() - 1)
    var result = "["
    var pos = 0
    var first = true
    while pos < inner.len():
        while pos < inner.len() and (inner.slice(pos, pos + 1) == " " or inner.slice(pos, pos + 1) == ","):
            pos = pos + 1
        if pos >= inner.len():
            break
        if inner.slice(pos, pos + 1) != "{":
            return entries
        val end = _webgpu_matching_brace(inner, pos)
        if end < 0:
            return entries
        val descriptor = inner.slice(pos + 1, end)
        val lowered = _webgpu_bind_group_entry(descriptor)
        if lowered == "":
            return entries
        if not first:
            result = result + ", "
        result = result + lowered
        first = false
        pos = end + 1
    result + "]"

fn _webgpu_bind_group_entry(descriptor: text) -> text:
    val binding = _webgpu_descriptor_value(descriptor, "binding")
    val resource = _webgpu_descriptor_value(descriptor, "resource")
    if binding == "" or resource == "":
        return ""
    val buffer = _webgpu_descriptor_value(resource, "buffer")
    if buffer != "":
        val offset = _webgpu_descriptor_value_or_default(resource, "offset", "0")
        val size = _webgpu_descriptor_value_or_default(resource, "size", "-1")
        if offset != "0" or size != "-1":
            return "GPUBindGroupEntry.buffer_range(" + binding + ", " + _webgpu_resource_id(buffer) + ", " + offset + ", " + size + ")"
        return "GPUBindGroupEntry.buffer(" + binding + ", " + _webgpu_resource_id(buffer) + ")"
    val texture = _webgpu_descriptor_value(resource, "texture")
    if texture != "":
        return "GPUBindGroupEntry.texture(" + binding + ", " + _webgpu_resource_id(texture) + ")"
    val texture_view = _webgpu_descriptor_value(resource, "textureView")
    if texture_view != "":
        return "GPUBindGroupEntry.texture_view(" + binding + ", " + _webgpu_resource_id(texture_view) + ")"
    val sampler = _webgpu_descriptor_value(resource, "sampler")
    if sampler != "":
        return "GPUBindGroupEntry.sampler(" + binding + ", " + _webgpu_resource_id(sampler) + ")"
    ""

fn _webgpu_resource_id(resource: text) -> text:
    val trimmed = resource.trim()
    if trimmed.ends_with(".id"):
        return trimmed
    trimmed + ".id"

fn _webgpu_layout_object_id(layout: text) -> text:
    if layout.ends_with(".id"):
        return layout
    layout + ".id"

fn _convert_webgpu_render_pass_descriptor(line: text) -> text:
    val marker = ".beginRenderPass({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val color_attachments = _webgpu_descriptor_value(descriptor, "colorAttachments")
    if color_attachments == "":
        return line
    val depth_stencil = _webgpu_descriptor_value_or_default(descriptor, "depthStencilAttachment", "GPURenderPassDepthStencilAttachment.none()")
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".begin_render_pass_with_descriptor(gpu.resources, " + color_attachments + ", " + depth_stencil + ")" + suffix

fn _convert_webgpu_queue_write_texture_descriptor(line: text) -> text:
    val marker = ".queueWriteTexture({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("},")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val texture = _webgpu_descriptor_value(descriptor, "texture")
    if texture == "":
        return line
    val rest_start = descriptor_end + 2
    val rest = line.slice(rest_start, line.len())
    val first_comma = rest.index_of(",")
    if first_comma < 0:
        return line
    val data_expr = rest.slice(0, first_comma).trim()
    val size_start = rest.index_of("[")
    val size_end = rest.index_of("]")
    if size_start < 0 or size_end < size_start:
        return line
    val size_inner = rest.slice(size_start + 1, size_end)
    val size_parts = size_inner.split(",")
    if size_parts.len() < 2:
        return line
    val width = size_parts[0].trim()
    val height = size_parts[1].trim()
    var depth_or_layers = "1"
    if size_parts.len() >= 3:
        depth_or_layers = size_parts[2].trim()
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(rest_start + size_end + 2, line.len())
    prefix + ".queue_write_texture(" + _webgpu_texture_object_id(texture) + ", " + width + ", " + height + ", " + depth_or_layers + ", " + data_expr + ".len())" + suffix

fn _convert_webgpu_copy_texture_to_texture_descriptor(line: text) -> text:
    val marker = ".copyTextureToTexture({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    val source_start = marker_idx + marker.len()
    val after_source_start = line.slice(source_start, line.len())
    val source_end_rel = after_source_start.index_of("},")
    if source_end_rel < 0:
        return line
    val source_end = source_start + source_end_rel
    val source_descriptor = line.slice(source_start, source_end)
    val source_texture = _webgpu_descriptor_value(source_descriptor, "texture")
    if source_texture == "":
        return line
    val destination_search_start = source_end + 2
    val destination_search = line.slice(destination_search_start, line.len())
    val destination_open_rel = destination_search.index_of("{")
    if destination_open_rel < 0:
        return line
    val destination_start = destination_search_start + destination_open_rel + 1
    val after_destination_start = line.slice(destination_start, line.len())
    val destination_end_rel = after_destination_start.index_of("},")
    if destination_end_rel < 0:
        return line
    val destination_end = destination_start + destination_end_rel
    val destination_descriptor = line.slice(destination_start, destination_end)
    val destination_texture = _webgpu_descriptor_value(destination_descriptor, "texture")
    if destination_texture == "":
        return line
    val size_search_start = destination_end + 2
    val size_search = line.slice(size_search_start, line.len())
    val size_start = size_search.index_of("[")
    val size_end = size_search.index_of("]")
    if size_start < 0 or size_end < size_start:
        return line
    val size_inner = size_search.slice(size_start + 1, size_end)
    val size_parts = size_inner.split(",")
    if size_parts.len() < 2:
        return line
    val width = size_parts[0].trim()
    val height = size_parts[1].trim()
    var depth_or_layers = "1"
    if size_parts.len() >= 3:
        depth_or_layers = size_parts[2].trim()
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(size_search_start + size_end + 2, line.len())
    prefix + ".copy_texture_to_texture(" + _webgpu_texture_object_id(source_texture) + ", " + _webgpu_texture_object_id(destination_texture) + ", " + width + ", " + height + ", " + depth_or_layers + ")" + suffix

fn _convert_webgpu_auto_render_pipeline_descriptor(line: text) -> text:
    val marker = ".createRenderPipeline({"
    val marker_idx = line.index_of(marker)
    if marker_idx < 0:
        return line
    if not (line.contains("layout: \"auto\"") or line.contains("layout:'auto'") or line.contains("layout: 'auto'")):
        return line
    val descriptor_start = marker_idx + marker.len()
    val after_descriptor_start = line.slice(descriptor_start, line.len())
    val descriptor_end_rel = after_descriptor_start.index_of("})")
    if descriptor_end_rel < 0:
        return line
    val descriptor_end = descriptor_start + descriptor_end_rel
    val descriptor = line.slice(descriptor_start, descriptor_end)
    val vertex = _webgpu_descriptor_module_value(descriptor, "vertex")
    val fragment = _webgpu_descriptor_module_value(descriptor, "fragment")
    if vertex == "" or fragment == "":
        return line
    val prefix = line.slice(0, marker_idx)
    val suffix = line.slice(descriptor_end + 2, line.len())
    prefix + ".create_render_pipeline_auto_layout(" + vertex + ", " + fragment + ")" + suffix

fn _webgpu_descriptor_value_or_default(descriptor: text, property: text, default_value: text) -> text:
    val value = _webgpu_descriptor_value(descriptor, property)
    if value == "":
        return default_value
    value

fn _webgpu_descriptor_value(descriptor: text, property: text) -> text:
    val property_marker = property + ":"
    val property_idx = descriptor.index_of(property_marker)
    if property_idx < 0:
        return ""
    var value_start = property_idx + property_marker.len()
    while value_start < descriptor.len() and descriptor.slice(value_start, value_start + 1) == " ":
        value_start = value_start + 1
    var value_end = value_start
    var brace_depth = 0
    var bracket_depth = 0
    while value_end < descriptor.len():
        val ch = descriptor.slice(value_end, value_end + 1)
        if ch == "{":
            brace_depth = brace_depth + 1
        else: if ch == "[":
            bracket_depth = bracket_depth + 1
        else: if ch == "]":
            if bracket_depth == 0:
                return descriptor.slice(value_start, value_end).trim()
            bracket_depth = bracket_depth - 1
        else: if ch == "}":
            if brace_depth == 0:
                return descriptor.slice(value_start, value_end).trim()
            brace_depth = brace_depth - 1
        else: if ch == "," and brace_depth == 0 and bracket_depth == 0:
            return descriptor.slice(value_start, value_end).trim()
        value_end = value_end + 1
    descriptor.slice(value_start, value_end).trim()

fn _webgpu_descriptor_module_value(descriptor: text, property: text) -> text:
    val property_marker = property + ":"
    val property_idx = descriptor.index_of(property_marker)
    if property_idx < 0:
        return ""
    var value_start = property_idx + property_marker.len()
    while value_start < descriptor.len() and descriptor.slice(value_start, value_start + 1) == " ":
        value_start = value_start + 1
    val remaining = descriptor.slice(value_start, descriptor.len())
    if remaining.starts_with("{"):
        val module_idx = remaining.index_of("module:")
        if module_idx < 0:
            return ""
        value_start = value_start + module_idx + "module:".len()
        while value_start < descriptor.len() and descriptor.slice(value_start, value_start + 1) == " ":
            value_start = value_start + 1
    var value_end = value_start
    while value_end < descriptor.len() and descriptor.slice(value_end, value_end + 1) != "," and descriptor.slice(value_end, value_end + 1) != "}":
        value_end = value_end + 1
    descriptor.slice(value_start, value_end).trim()

fn _convert_webgl_method(line: text, pattern: text, fn_name: text) -> text:
    """Convert gl.method(args) to canvas_webgl_method(gl, args)."""
    val trimmed = line.trim()
    val dot_pos = trimmed.index_of(pattern)
    if dot_pos < 0:
        return line
    val target_expr = trimmed.slice(0, dot_pos)
    val args_start = dot_pos + pattern.len()
    val rest = trimmed.slice(args_start, trimmed.len())
    val leading = _get_leading_whitespace(line)
    val eq_pos = target_expr.index_of("=")
    val separator = if rest.trim().starts_with(")"): "" else: ", "
    if eq_pos >= 0:
        val prefix = target_expr.slice(0, eq_pos + 1).trim()
        val receiver = target_expr.slice(eq_pos + 1, target_expr.len()).trim()
        val last_fn = _webgl_create_last_function(fn_name)
        if last_fn != "":
            return leading + receiver + " = " + fn_name + "(" + receiver + separator + rest + "\n" + leading + prefix + " " + last_fn + "(" + receiver + ")"
        return leading + prefix + " " + fn_name + "(" + receiver + separator + rest
    if _webgl_method_returns_context(fn_name):
        return leading + target_expr + " = " + fn_name + "(" + target_expr + separator + rest
    leading + fn_name + "(" + target_expr + separator + rest

fn _convert_webgl_method_for_gl(line: text, pattern: text, fn_name: text) -> text:
    """Convert only calls on the conventional `gl` WebGL context variable."""
    val trimmed = line.trim()
    val dot_pos = trimmed.index_of(pattern)
    if dot_pos < 0:
        return line
    val target_expr = trimmed.slice(0, dot_pos)
    val eq_pos = target_expr.index_of("=")
    if eq_pos >= 0:
        val receiver = target_expr.slice(eq_pos + 1, target_expr.len()).trim()
        if receiver != "gl":
            return _convert_webgpu_calls(line)
    else:
        if target_expr != "gl":
            return _convert_webgpu_calls(line)
    _convert_webgl_method(line, pattern, fn_name)

fn _webgl_method_returns_context(fn_name: text) -> bool:
    if fn_name == "canvas_webgl_clear_color" or fn_name == "canvas_webgl_viewport" or fn_name == "canvas_webgl_clear":
        return true
    if fn_name == "canvas_webgl_flush" or fn_name == "canvas_webgl_finish":
        return true
    if fn_name == "canvas_webgl_lose_context" or fn_name == "canvas_webgl_restore_context":
        return true
    if fn_name == "canvas_webgl_clear_depth" or fn_name == "canvas_webgl_depth_range" or fn_name == "canvas_webgl_clear_stencil":
        return true
    if fn_name == "canvas_webgl_create_buffer" or fn_name == "canvas_webgl_create_shader":
        return true
    if fn_name == "canvas_webgl_create_vertex_array" or fn_name == "canvas_webgl_bind_vertex_array":
        return true
    if fn_name == "canvas_webgl_delete_vertex_array":
        return true
    if fn_name == "canvas_webgl_create_sampler" or fn_name == "canvas_webgl_delete_sampler":
        return true
    if fn_name == "canvas_webgl_delete_buffer" or fn_name == "canvas_webgl_delete_texture":
        return true
    if fn_name == "canvas_webgl_create_program" or fn_name == "canvas_webgl_create_texture":
        return true
    if fn_name == "canvas_webgl_enable" or fn_name == "canvas_webgl_bind_buffer" or fn_name == "canvas_webgl_buffer_data_size":
        return true
    if fn_name == "canvas_webgl_enable_vertex_attrib_array" or fn_name == "canvas_webgl_disable_vertex_attrib_array":
        return true
    if fn_name == "canvas_webgl_vertex_attrib_pointer" or fn_name == "canvas_webgl_vertex_attrib_1f" or fn_name == "canvas_webgl_vertex_attrib_2f":
        return true
    if fn_name == "canvas_webgl_vertex_attrib_3f" or fn_name == "canvas_webgl_vertex_attrib_4f":
        return true
    if fn_name == "canvas_webgl_vertex_attrib_1fv" or fn_name == "canvas_webgl_vertex_attrib_2fv":
        return true
    if fn_name == "canvas_webgl_vertex_attrib_3fv" or fn_name == "canvas_webgl_vertex_attrib_4fv":
        return true
    if fn_name == "canvas_webgl_vertex_attrib_divisor":
        return true
    if fn_name == "canvas_webgl_bind_sampler" or fn_name == "canvas_webgl_sampler_parameter_i":
        return true
    if fn_name == "canvas_webgl_draw_arrays":
        return true
    if fn_name == "canvas_webgl_draw_elements":
        return true
    if fn_name == "canvas_webgl_draw_arrays_instanced" or fn_name == "canvas_webgl_draw_elements_instanced":
        return true
    if fn_name == "canvas_webgl_shader_source" or fn_name == "canvas_webgl_compile_shader" or fn_name == "canvas_webgl_attach_shader":
        return true
    if fn_name == "canvas_webgl_link_program" or fn_name == "canvas_webgl_use_program":
        return true
    if fn_name == "canvas_webgl_delete_shader" or fn_name == "canvas_webgl_delete_program":
        return true
    if fn_name == "canvas_webgl_detach_shader" or fn_name == "canvas_webgl_validate_program":
        return true
    if fn_name == "canvas_webgl_uniform_1i" or fn_name == "canvas_webgl_uniform_1f" or fn_name == "canvas_webgl_uniform_2f":
        return true
    if fn_name == "canvas_webgl_uniform_2i" or fn_name == "canvas_webgl_uniform_3i" or fn_name == "canvas_webgl_uniform_4i":
        return true
    if fn_name == "canvas_webgl_uniform_1iv" or fn_name == "canvas_webgl_uniform_2iv":
        return true
    if fn_name == "canvas_webgl_uniform_3iv" or fn_name == "canvas_webgl_uniform_4iv":
        return true
    if fn_name == "canvas_webgl_uniform_3f" or fn_name == "canvas_webgl_uniform_4f":
        return true
    if fn_name == "canvas_webgl_uniform_1fv":
        return true
    if fn_name == "canvas_webgl_uniform_2fv" or fn_name == "canvas_webgl_uniform_3fv" or fn_name == "canvas_webgl_uniform_4fv":
        return true
    if fn_name == "canvas_webgl_uniform_matrix2fv" or fn_name == "canvas_webgl_uniform_matrix3fv" or fn_name == "canvas_webgl_uniform_matrix4fv":
        return true
    if fn_name == "canvas_webgl_active_texture" or fn_name == "canvas_webgl_bind_texture":
        return true
    if fn_name == "canvas_webgl_tex_parameter_i" or fn_name == "canvas_webgl_tex_image_2d":
        return true
    if fn_name == "canvas_webgl_tex_sub_image_2d" or fn_name == "canvas_webgl_generate_mipmap":
        return true
    if fn_name == "canvas_webgl_compressed_tex_image_2d" or fn_name == "canvas_webgl_compressed_tex_sub_image_2d":
        return true
    if fn_name == "canvas_webgl_copy_tex_image_2d" or fn_name == "canvas_webgl_copy_tex_sub_image_2d":
        return true
    if fn_name == "canvas_webgl_create_framebuffer" or fn_name == "canvas_webgl_bind_framebuffer":
        return true
    if fn_name == "canvas_webgl_create_renderbuffer" or fn_name == "canvas_webgl_bind_renderbuffer":
        return true
    if fn_name == "canvas_webgl_delete_framebuffer" or fn_name == "canvas_webgl_delete_renderbuffer":
        return true
    if fn_name == "canvas_webgl_renderbuffer_storage" or fn_name == "canvas_webgl_framebuffer_texture_2d" or fn_name == "canvas_webgl_framebuffer_renderbuffer":
        return true
    if fn_name == "canvas_webgl_draw_buffers":
        return true
    if fn_name == "canvas_webgl_read_buffer":
        return true
    if fn_name == "canvas_webgl_disable" or fn_name == "canvas_webgl_line_width" or fn_name == "canvas_webgl_front_face" or fn_name == "canvas_webgl_cull_face":
        return true
    if fn_name == "canvas_webgl_hint":
        return true
    if fn_name == "canvas_webgl_polygon_offset" or fn_name == "canvas_webgl_sample_coverage" or fn_name == "canvas_webgl_blend_color":
        return true
    if fn_name == "canvas_webgl_depth_func" or fn_name == "canvas_webgl_depth_mask" or fn_name == "canvas_webgl_color_mask":
        return true
    if fn_name == "canvas_webgl_scissor" or fn_name == "canvas_webgl_stencil_func" or fn_name == "canvas_webgl_stencil_op":
        return true
    if fn_name == "canvas_webgl_stencil_func_separate" or fn_name == "canvas_webgl_stencil_op_separate":
        return true
    if fn_name == "canvas_webgl_stencil_mask" or fn_name == "canvas_webgl_stencil_mask_separate":
        return true
    if fn_name == "canvas_webgl_blend_func" or fn_name == "canvas_webgl_blend_func_separate":
        return true
    if fn_name == "canvas_webgl_blend_equation" or fn_name == "canvas_webgl_blend_equation_separate":
        return true
    if fn_name == "canvas_webgl_pixel_store_i":
        return true
    false

fn _webgl_create_last_function(fn_name: text) -> text:
    if fn_name == "canvas_webgl_create_buffer":
        return "canvas_webgl_last_buffer"
    if fn_name == "canvas_webgl_create_vertex_array":
        return "canvas_webgl_last_vertex_array"
    if fn_name == "canvas_webgl_create_shader":
        return "canvas_webgl_last_shader"
    if fn_name == "canvas_webgl_create_program":
        return "canvas_webgl_last_program"
    if fn_name == "canvas_webgl_create_texture":
        return "canvas_webgl_last_texture"
    if fn_name == "canvas_webgl_create_sampler":
        return "canvas_webgl_last_sampler"
    if fn_name == "canvas_webgl_create_framebuffer":
        return "canvas_webgl_last_framebuffer"
    if fn_name == "canvas_webgl_create_renderbuffer":
        return "canvas_webgl_last_renderbuffer"
    ""

fn _convert_console_calls(line: text) -> text:
    """Convert console.log etc. to Simple function calls."""
    var result = line
    result = result.replace("console.clear()", "buf = console_clear(buf)")
    result = result.replace("console.log(", "buf = console_log(buf, ")
    result = result.replace("console.warn(", "buf = console_warn(buf, ")
    result = result.replace("console.error(", "buf = console_error(buf, ")
    result = result.replace("console.info(", "buf = console_info(buf, ")
    result = result.replace("console.debug(", "buf = console_debug(buf, ")
    result

fn _convert_timer_calls(line: text) -> text:
    """Convert setTimeout/setInterval to Simple function calls."""
    var result = line
    result = result.replace("setTimeout(", "set_timeout(loop_ref, ")
    result = result.replace("setInterval(", "set_interval(loop_ref, ")
    result = result.replace("clearTimeout(", "clear_timeout(loop_ref, ")
    result = result.replace("clearInterval(", "clear_interval(loop_ref, ")
    result

fn _convert_worker_calls(line: text) -> text:
    """Convert common Worker API construction and method calls."""
    var result = line
    result = result.replace("Worker(", "worker_create(")
    if result.index_of(".postMessage(") >= 0:
        return _convert_worker_method(result, ".postMessage(", "worker_post_message")
    if result.index_of(".terminate(") >= 0:
        return _convert_worker_method(result, ".terminate(", "worker_terminate")
    result

fn _convert_worker_method(line: text, pattern: text, fn_name: text) -> text:
    """Convert worker.method(args) to worker_method(worker, args)."""
    val trimmed = line.trim()
    val dot_pos = trimmed.index_of(pattern)
    if dot_pos < 0:
        return line
    val target_expr = trimmed.slice(0, dot_pos)
    val args_start = dot_pos + pattern.len()
    val rest = trimmed.slice(args_start, trimmed.len())
    val leading = _get_leading_whitespace(line)
    if fn_name == "worker_terminate":
        return leading + fn_name + "(" + target_expr + ")"
    if target_expr == "self":
        return leading + "worker_global_post_message(scope, " + rest
    leading + fn_name + "(" + target_expr + ", " + rest

fn _convert_event_listener(line: text) -> text:
    """Convert .addEventListener(...) to node_add_event_listener(node, ...).

    Pattern: EXPR.addEventListener(ARGS) -> node_add_event_listener(EXPR, ARGS)
    """
    val idx = line.index_of(".addEventListener(")
    if idx < 0:
        return line
    val leading = _get_leading_whitespace(line)
    val trimmed = line.trim()
    val dot_pos = trimmed.index_of(".addEventListener(")
    val node_expr = trimmed.slice(0, dot_pos)
    val args_start = dot_pos + 18
    val rest = trimmed.slice(args_start, trimmed.len())
    leading + "node_add_event_listener(" + node_expr + ", " + rest

fn _convert_style_assignment(line: text) -> text:
    """Convert element.style.X = Y to node_set_style_property(element, "X", Y).

    Pattern: EXPR.style.PROP = VALUE;
    """
    val idx = line.index_of(".style.")
    if idx < 0:
        return line
    val trimmed = line.trim()
    val style_pos = trimmed.index_of(".style.")
    if style_pos < 0:
        return line
    val eq_pos = trimmed.index_of("=", style_pos)
    if eq_pos < 0:
        return line
    val node_expr = trimmed.slice(0, style_pos)
    val prop_name = trimmed.slice(style_pos + 7, eq_pos).trim()
    var value = trimmed.slice(eq_pos + 1, trimmed.len()).trim()
    if value.ends_with(";"):
        value = value.slice(0, value.len() - 1).trim()
    val leading = _get_leading_whitespace(line)
    leading + node_expr + " = node_set_style_property(" + node_expr + ", \"" + prop_name + "\", " + value + ")"

fn _convert_style_get_property(line: text) -> text:
    """Convert element.style.getPropertyValue(name) to node_get_style_property(element, name)."""
    val idx = line.index_of(".style.getPropertyValue(")
    if idx < 0:
        return line
    val trimmed = line.trim()
    val style_pos = trimmed.index_of(".style.getPropertyValue(")
    if style_pos < 0:
        return line
    val leading = _get_leading_whitespace(line)
    val target_expr = trimmed.slice(0, style_pos)
    val args_start = style_pos + 24
    val rest = trimmed.slice(args_start, trimmed.len())
    val eq_pos = target_expr.index_of("=")
    if eq_pos >= 0:
        val prefix = target_expr.slice(0, eq_pos + 1).trim()
        val receiver = target_expr.slice(eq_pos + 1, target_expr.len()).trim()
        return leading + prefix + " node_get_style_property(" + receiver + ", " + rest
    leading + "node_get_style_property(" + target_expr + ", " + rest

fn _convert_inner_html(line: text) -> text:
    """Convert .innerHTML = X to node_set_inner_html(node, X)."""
    val idx = line.index_of(".innerHTML")
    if idx < 0:
        return line
    val trimmed = line.trim()
    val html_pos = trimmed.index_of(".innerHTML")
    val eq_pos = trimmed.index_of("=", html_pos)
    if eq_pos < 0:
        return line
    val node_expr = trimmed.slice(0, html_pos)
    var value = trimmed.slice(eq_pos + 1, trimmed.len()).trim()
    if value.ends_with(";"):
        value = value.slice(0, value.len() - 1).trim()
    val leading = _get_leading_whitespace(line)
    leading + node_expr + " = node_set_inner_html(" + node_expr + ", " + value + ")"

fn _convert_text_content(line: text) -> text:
    """Convert .textContent = X to node_set_text_content(node, X)."""
    val idx = line.index_of(".textContent")
    if idx < 0:
        return line
    val trimmed = line.trim()
    val tc_pos = trimmed.index_of(".textContent")
    val eq_pos = trimmed.index_of("=", tc_pos)
    if eq_pos < 0:
        return line
    val node_expr = trimmed.slice(0, tc_pos)
    var value = trimmed.slice(eq_pos + 1, trimmed.len()).trim()
    if value.ends_with(";"):
        value = value.slice(0, value.len() - 1).trim()
    val leading = _get_leading_whitespace(line)
    leading + node_expr + " = node_set_text_content(" + node_expr + ", " + value + ")"

fn _convert_classlist(line: text) -> text:
    """Convert .classList.add/remove/toggle/contains to Simple calls."""
    var result = line
    val add_idx = result.index_of(".classList.add(")
    if add_idx >= 0:
        return _convert_classlist_method(result, ".classList.add(", "node_class_list_add")
    val rem_idx = result.index_of(".classList.remove(")
    if rem_idx >= 0:
        return _convert_classlist_method(result, ".classList.remove(", "node_class_list_remove")
    val tog_idx = result.index_of(".classList.toggle(")
    if tog_idx >= 0:
        return _convert_classlist_method(result, ".classList.toggle(", "node_class_list_toggle")
    val con_idx = result.index_of(".classList.contains(")
    if con_idx >= 0:
        return _convert_classlist_method(result, ".classList.contains(", "node_class_list_contains")
    result

fn _convert_classlist_method(line: text, pattern: text, fn_name: text) -> text:
    """Convert a classList method call to a Simple function call."""
    val trimmed = line.trim()
    val dot_pos = trimmed.index_of(pattern)
    val node_expr = trimmed.slice(0, dot_pos)
    val args_start = dot_pos + pattern.len()
    val rest = trimmed.slice(args_start, trimmed.len())
    val leading = _get_leading_whitespace(line)
    if fn_name == "node_class_list_add" or fn_name == "node_class_list_remove":
        return leading + node_expr + " = " + fn_name + "(" + node_expr + ", " + rest
    leading + fn_name + "(" + node_expr + ", " + rest

# =========================================================================
# Pass 4: Brace-to-indent block conversion
# =========================================================================

fn _convert_braces_to_indent(source: text) -> text:
    """Convert JS brace-delimited blocks to Simple indent-based blocks.

    Tracks brace depth and converts:
    - Opening { -> : (with colon on the preceding statement)
    - Closing } -> (removed, indent decreases)
    - else { -> else:
    - } else { -> else:

    Also strips trailing semicolons.
    """
    val lines = source.split("\n")
    var result_lines: [text] = []
    var depth = 0
    var i = 0
    while i < lines.len():
        var line = lines[i]
        val trimmed = line.trim()

        # Skip empty lines
        if trimmed.len() == 0:
            result_lines.push("")
            i = i + 1
            continue

        # Handle closing brace lines
        if trimmed == "}":
            if depth > 0:
                depth = depth - 1
            i = i + 1
            continue

        # Handle } else {
        if trimmed == "} else {":
            if depth > 0:
                depth = depth - 1
            val indent = _make_indent(depth)
            result_lines.push(indent + "else:")
            depth = depth + 1
            i = i + 1
            continue

        # Handle } else if (...) {
        if trimmed.starts_with("} else if"):
            if depth > 0:
                depth = depth - 1
            val cond_start = trimmed.index_of("(")
            val cond_end = _find_matching_paren(trimmed, cond_start)
            if cond_start >= 0 and cond_end >= 0:
                val cond = trimmed.slice(cond_start + 1, cond_end)
                val indent = _make_indent(depth)
                result_lines.push(indent + "else if " + cond + ":")
                depth = depth + 1
            i = i + 1
            continue

        # Strip trailing semicolons
        if trimmed.ends_with(";"):
            line = _get_leading_whitespace(line) + trimmed.slice(0, trimmed.len() - 1)

        # Check if line ends with {
        val retrimmed = line.trim()
        if retrimmed.ends_with("{"):
            val without_brace = retrimmed.slice(0, retrimmed.len() - 1).trim()
            # Handle if (...) {
            if without_brace.starts_with("if ") or without_brace.starts_with("if("):
                val converted = _convert_if_header(without_brace)
                val indent = _make_indent(depth)
                result_lines.push(indent + converted + ":")
                depth = depth + 1
                i = i + 1
                continue
            # Handle while (...) {
            if without_brace.starts_with("while ") or without_brace.starts_with("while("):
                val converted = _convert_while_header(without_brace)
                val indent = _make_indent(depth)
                result_lines.push(indent + converted + ":")
                depth = depth + 1
                i = i + 1
                continue
            # Handle for ... in ...: (already converted from for-of)
            if without_brace.starts_with("for ") and without_brace.contains(" in "):
                val indent = _make_indent(depth)
                result_lines.push(indent + without_brace + ":")
                depth = depth + 1
                i = i + 1
                continue
            # Other block openers (fn, else, etc.)
            val indent = _make_indent(depth)
            if without_brace.ends_with(":"):
                result_lines.push(indent + without_brace)
            else:
                result_lines.push(indent + without_brace + ":")
            depth = depth + 1
            i = i + 1
            continue

        # Normal line — re-indent
        val indent = _make_indent(depth)
        result_lines.push(indent + retrimmed)
        i = i + 1
    _join_lines(result_lines)

fn _convert_if_header(header: text) -> text:
    """Convert if (...) to if ...: stripping parens."""
    var body = header
    if body.starts_with("if("):
        body = "if (" + body.slice(3, body.len())
    if body.starts_with("if ("):
        val paren_start = body.index_of("(")
        val paren_end = _find_matching_paren(body, paren_start)
        if paren_end >= 0:
            val cond = body.slice(paren_start + 1, paren_end)
            return "if " + cond
    body

fn _convert_while_header(header: text) -> text:
    """Convert while (...) to while ...: stripping parens."""
    var body = header
    if body.starts_with("while("):
        body = "while (" + body.slice(6, body.len())
    if body.starts_with("while ("):
        val paren_start = body.index_of("(")
        val paren_end = _find_matching_paren(body, paren_start)
        if paren_end >= 0:
            val cond = body.slice(paren_start + 1, paren_end)
            return "while " + cond
    body

# =========================================================================
# Utility Helpers
# =========================================================================

fn _get_leading_whitespace(line: text) -> text:
    """Extract leading whitespace from a line."""
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch != " " and ch != "\t":
            return line.slice(0, i)
        i = i + 1
    line

fn _make_indent(depth: i32) -> text:
    """Create indentation string for a given depth (4 spaces per level)."""
    var result = ""
    var i = 0
    while i < depth:
        result = result + "    "
        i = i + 1
    result

fn _find_matching_paren(s: text, open_pos: i32) -> i32:
    """Find the matching closing parenthesis for an opening one."""
    if open_pos < 0:
        return -1
    var depth = 0
    var i = open_pos
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "(":
            depth = depth + 1
        if ch == ")":
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    -1

fn _join_lines(lines: [text]) -> text:
    """Join lines with newline separator."""
    var result = ""
    var i = 0
    while i < lines.len():
        if i > 0:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result
