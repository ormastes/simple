fn _convert_webgl_constants(line: text) -> text:
    """Convert common WebGL constants exposed as gl.CONSTANT."""
    var result = line
    result = result.replace("gl.COLOR_BUFFER_BIT", "CANVAS_WEBGL_COLOR_BUFFER_BIT")
    result = result.replace("gl.DEPTH_BUFFER_BIT", "CANVAS_WEBGL_DEPTH_BUFFER_BIT")
    result = result.replace("gl.STENCIL_BUFFER_BIT", "CANVAS_WEBGL_STENCIL_BUFFER_BIT")
    result = result.replace("gl.ARRAY_BUFFER", "CANVAS_WEBGL_ARRAY_BUFFER")
    result = result.replace("gl.ELEMENT_ARRAY_BUFFER", "CANVAS_WEBGL_ELEMENT_ARRAY_BUFFER")
    result = result.replace("gl.BUFFER_SIZE", "CANVAS_WEBGL_BUFFER_SIZE")
    result = result.replace("gl.BUFFER_USAGE", "CANVAS_WEBGL_BUFFER_USAGE")
    result = result.replace("gl.STATIC_DRAW", "CANVAS_WEBGL_STATIC_DRAW")
    result = result.replace("gl.DYNAMIC_DRAW", "CANVAS_WEBGL_DYNAMIC_DRAW")
    result = result.replace("gl.STREAM_DRAW", "CANVAS_WEBGL_STREAM_DRAW")
    result = result.replace("gl.TRIANGLES", "CANVAS_WEBGL_TRIANGLES")
    result = result.replace("gl.TRIANGLE_STRIP", "CANVAS_WEBGL_TRIANGLE_STRIP")
