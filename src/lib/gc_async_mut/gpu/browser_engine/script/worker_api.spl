"""
# Worker API

Message-passing concurrency model for the Simple browser engine.
Mirrors the Web Worker API with an in-memory message queue.

JS Equivalent → Simple Function:
    new Worker()               → worker_create()
    worker.postMessage()       → worker_post_message()
    (message event)            → worker_receive_message()
    worker.terminate()         → worker_terminate()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.script.navigator_api.{BrowserNavigator, navigator_create, navigator_gpu_available}

# =========================================================================
# SimpleWorker
# =========================================================================

var _next_worker_id: i64 = 1

pub class SimpleWorker:
    """An in-memory worker with message queues.

    Fields:
        id          - unique worker identifier
        source_path - path to the worker script
        inbox       - messages received from the main thread
        outbox      - messages sent by the worker to the main thread
        secure_context - true when the owner context allows secure-only APIs
        navigator   - worker navigator surface inherited from the owner context
        terminated  - true if the worker has been terminated
    """
    id: i64
    source_path: text
    inbox: [text]
    outbox: [text]
    secure_context: bool
    navigator: BrowserNavigator
    terminated: bool

# =========================================================================
# Worker Operations
# =========================================================================

pub fn worker_create(source: text) -> SimpleWorker:
    """Create a new worker. The source is a path to a .spl script.

    NOTE: Actual background execution requires thread/process support.
    This creates the worker model for message passing.
    """
    worker_create_with_secure_context(source, true)

pub fn worker_create_with_secure_context(source: text, secure_context: bool) -> SimpleWorker:
    """Create a worker model with an owner-derived secure-context flag."""
    val wid = _next_worker_id
    _next_worker_id = _next_worker_id + 1
    SimpleWorker(
        id: wid,
        source_path: source,
        inbox: [],
        outbox: [],
        secure_context: secure_context,
        navigator: navigator_create(secure_context),
        terminated: false
    )

pub fn worker_is_secure_context(worker: SimpleWorker) -> bool:
    worker.secure_context

pub fn worker_navigator(worker: SimpleWorker) -> BrowserNavigator:
    worker.navigator

pub fn worker_gpu_available(worker: SimpleWorker) -> bool:
    navigator_gpu_available(worker.navigator)

pub fn worker_post_message(worker: SimpleWorker, msg: text):
    """Send a message to the worker's inbox."""
    if worker.terminated:
        return
    worker.inbox.push(msg)

pub fn worker_receive_message(worker: SimpleWorker) -> text?:
    """Receive the next message from the worker's outbox, or nil if empty."""
    if worker.outbox.len() == 0:
        return nil
    val msg = worker.outbox[0]
    var new_outbox: [text] = []
    var i = 1
    while i < worker.outbox.len():
        new_outbox.push(worker.outbox[i])
        i = i + 1
    worker.outbox = new_outbox
    Some(msg)

pub fn worker_terminate(worker: SimpleWorker):
    """Terminate the worker, preventing further message delivery."""
    worker.terminated = true
