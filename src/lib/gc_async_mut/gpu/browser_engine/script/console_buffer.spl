"""
# ConsoleBuffer

Bounded 512-entry ring buffer for browser DevTools console output (M15 / REQ-5 / AC-4).
"""

#![allow(REQC001)]

val CONSOLE_BUFFER_MAX = 512

pub class ConsoleEntry:
    """A single console log entry."""
    level: text
    message: text
    timestamp_micros: i64

pub class ConsoleBuffer:
    """Bounded ring buffer for console.log output.

    Holds at most 512 entries. When full, the oldest entry is overwritten.
    """
    _entries: [ConsoleEntry]
    _head: i32
    _count: i32

    static fn new() -> ConsoleBuffer:
        """Create an empty ConsoleBuffer."""
        ConsoleBuffer(_entries: [], _head: 0, _count: 0)

    me append(level: text, message: text, now_micros: i64):
        """Add a log entry, overwriting the oldest when at capacity."""
        val entry = ConsoleEntry(level: level, message: message, timestamp_micros: now_micros)
        if self._count < CONSOLE_BUFFER_MAX:
            self._entries.push(entry)
            self._count = self._count + 1
        else:
            self._entries[self._head] = entry
            self._head = (self._head + 1) % CONSOLE_BUFFER_MAX

    me entries() -> [ConsoleEntry]:
        """Return all stored entries in insertion order."""
        if self._count < CONSOLE_BUFFER_MAX:
            return self._entries
        var result: [ConsoleEntry] = []
        var i = 0
        while i < CONSOLE_BUFFER_MAX:
            val idx = (self._head + i) % CONSOLE_BUFFER_MAX
            result.push(self._entries[idx])
            i = i + 1
        result

    me clear():
        """Remove all entries."""
        self._entries = []
        self._head = 0
        self._count = 0
