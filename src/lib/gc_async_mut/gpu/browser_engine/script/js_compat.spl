"""
# JS Compatibility Layer

Pure-Simple implementations of common JavaScript standard library functions.
Used by the JS transpiler to provide JS-like APIs in transpiled scripts.

JS Function         -> Simple Function:
    parseInt()      -> js_parse_int()
    parseFloat()    -> js_parse_float()
    String()        -> js_to_string()
    isNaN()         -> js_is_nan()
    isFinite()      -> js_is_finite()
    Math.floor()    -> js_math_floor()
    Math.ceil()     -> js_math_ceil()
    Math.round()    -> js_math_round()
    Math.random()   -> js_math_random()
    Math.abs()      -> js_math_abs()
    Math.min()      -> js_math_min()
    Math.max()      -> js_math_max()
    Math.sqrt()     -> js_math_sqrt()
    Math.pow()      -> js_math_pow()
    Math.PI         -> js_math_pi()
    String.split()  -> js_string_split()
    Array.join()    -> js_string_join()
    String.trim()   -> js_string_trim()
    String.startsWith() -> js_string_starts_with()
    String.endsWith()   -> js_string_ends_with()
    String.includes()   -> js_string_includes()
    String.replace()    -> js_string_replace()
    String.toLowerCase() -> js_string_to_lower()
    String.toUpperCase() -> js_string_to_upper()
    Array.push()    -> js_array_push()
    Array.pop()     -> js_array_pop()
    Array.length    -> js_array_length()
    Array.indexOf() -> js_array_index_of()
    Array.slice()   -> js_array_slice()
    JSON.parse()    -> js_json_parse()
    JSON.stringify() -> js_json_stringify()
    encodeURIComponent() -> js_encode_uri_component()
    decodeURIComponent() -> js_decode_uri_component()
    Date.now()      -> js_date_now()
"""

#![allow(REQC001)]

extern fn rt_math_floor(x: f64) -> f64
extern fn rt_math_ceil(x: f64) -> f64
extern fn rt_random_random() -> f64
extern fn rt_time_now_unix_millis() -> i64

# =========================================================================
# Number Parsing
# =========================================================================

pub fn js_parse_int(s: text) -> i64:
    """Parse a string to an integer, like JS parseInt().

    Returns 0 if the string cannot be parsed.
    """
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return 0
    trimmed.to_int_or(0)

pub fn js_parse_float(s: text) -> f64:
    """Parse a string to a float, like JS parseFloat().

    Returns 0.0 if the string cannot be parsed.
    """
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return 0.0
    trimmed.to_float_or(0.0)

pub fn js_to_string(v: text) -> text:
    """Convert a value to string. Identity for text type."""
    v

# =========================================================================
# Number Checks
# =========================================================================

pub fn js_is_nan(v: f64) -> bool:
    """Check if a value is NaN. NaN != NaN in IEEE 754."""
    v != v

pub fn js_is_finite(v: f64) -> bool:
    """Check if a value is finite (not NaN and not infinity)."""
    if v != v:
        return false
    if v > 1.7976931348623157e308:
        return false
    if v < -1.7976931348623157e308:
        return false
    true

# =========================================================================
# Math Functions
# =========================================================================

pub fn js_math_floor(x: f64) -> i64:
    """Floor a float to the nearest integer below."""
    val floored = rt_math_floor(x)
    floored.to_i64()

pub fn js_math_ceil(x: f64) -> i64:
    """Ceil a float to the nearest integer above."""
    val ceiled = rt_math_ceil(x)
    ceiled.to_i64()

pub fn js_math_round(x: f64) -> i64:
    """Round a float to the nearest integer."""
    val floored = rt_math_floor(x)
    if x - floored >= 0.5:
        return (floored + 1.0).to_i64()
    floored.to_i64()

pub fn js_math_random() -> f64:
    """Return a random float in [0, 1)."""
    rt_random_random()

pub fn js_math_abs(x: f64) -> f64:
    """Absolute value."""
    if x < 0.0:
        return 0.0 - x
    x

pub fn js_math_min(a: f64, b: f64) -> f64:
    """Return the smaller of two values."""
    if a <= b:
        return a
    b

pub fn js_math_max(a: f64, b: f64) -> f64:
    """Return the larger of two values."""
    if a >= b:
        return a
    b

pub fn js_math_sqrt(x: f64) -> f64:
    """Square root via Newton's method."""
    if x < 0.0:
        return 0.0
    if x == 0.0:
        return 0.0
    var guess = x / 2.0
    var i = 0
    while i < 50:
        val next = (guess + x / guess) / 2.0
        val diff = next - guess
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        if abs_diff < 1.0e-15:
            return next
        guess = next
        i = i + 1
    guess

pub fn js_math_pow(base: f64, exp: f64) -> f64:
    """Integer-exponent power function.

    Handles non-negative integer exponents. For fractional exponents
    or negative bases with fractional exp, returns 0.0 (limitation).
    """
    val int_exp = rt_math_floor(exp)
    val frac = exp - int_exp
    val abs_frac = if frac < 0.0: 0.0 - frac else: frac
    if abs_frac > 1.0e-10:
        # Fractional exponent — not supported in pure Simple
        return 0.0
    var n = int_exp.to_i64()
    if n == 0:
        return 1.0
    var result = 1.0
    var b = base
    var neg = false
    if n < 0:
        neg = true
        n = 0 - n
    while n > 0:
        if n % 2 == 1:
            result = result * b
        b = b * b
        n = n / 2
    if neg:
        return 1.0 / result
    result

pub fn js_math_pi() -> f64:
    """Return the value of pi."""
    3.141592653589793

# =========================================================================
# String Functions
# =========================================================================

pub fn js_string_split(s: text, sep: text) -> [text]:
    """Split a string by separator."""
    s.split(sep)

pub fn js_string_join(arr: [text], sep: text) -> text:
    """Join an array of strings with a separator."""
    var result = ""
    var i = 0
    while i < arr.len():
        if i > 0:
            result = result + sep
        result = result + arr[i]
        i = i + 1
    result

pub fn js_string_trim(s: text) -> text:
    """Trim whitespace from both ends."""
    s.trim()

pub fn js_string_starts_with(s: text, prefix: text) -> bool:
    """Check if a string starts with a prefix."""
    s.starts_with(prefix)

pub fn js_string_ends_with(s: text, suffix: text) -> bool:
    """Check if a string ends with a suffix."""
    s.ends_with(suffix)

pub fn js_string_includes(s: text, sub: text) -> bool:
    """Check if a string contains a substring."""
    s.contains(sub)

pub fn js_string_replace(s: text, old: text, replacement: text) -> text:
    """Replace first occurrence of old with replacement."""
    s.replace(old, replacement)

pub fn js_string_to_lower(s: text) -> text:
    """Convert a string to lowercase."""
    s.lower()

pub fn js_string_to_upper(s: text) -> text:
    """Convert a string to uppercase."""
    s.upper()

# =========================================================================
# Array Functions
# =========================================================================

pub fn js_array_push(arr: [text], item: text):
    """Push an item to the end of an array."""
    arr.push(item)

pub fn js_array_pop(arr: [text]) -> text:
    """Pop and return the last item, or empty string if empty."""
    if arr.len() == 0:
        return ""
    val last = arr[arr.len() - 1]
    arr.pop()
    last

pub fn js_array_length(arr: [text]) -> i32:
    """Return the length of an array."""
    arr.len()

pub fn js_array_index_of(arr: [text], item: text) -> i32:
    """Return the index of the first occurrence of item, or -1."""
    var i = 0
    while i < arr.len():
        if arr[i] == item:
            return i
        i = i + 1
    -1

pub fn js_array_slice(arr: [text], start: i32, end_idx: i32) -> [text]:
    """Return a slice of the array from start to end (exclusive)."""
    var result: [text] = []
    var i = start
    while i < end_idx and i < arr.len():
        result.push(arr[i])
        i = i + 1
    result

# =========================================================================
# JSON
# =========================================================================

class JsJsonCompatParseResult:
    value: text
    pos: i64
    ok: bool
    is_string: bool

    static fn create(value: text, pos: i64, ok: bool, is_string: bool) -> JsJsonCompatParseResult:
        JsJsonCompatParseResult(value: value, pos: pos, ok: ok, is_string: is_string)

pub fn js_json_parse(s: text) -> text:
    """Parse JSON text into a deterministic Simple-compatible text value."""
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return ""
    val parsed = _js_json_parse_value(trimmed, 0)
    val end_pos = _js_json_skip_ws(trimmed, parsed.pos)
    if not parsed.ok or end_pos != trimmed.len():
        return ""
    if parsed.is_string:
        return parsed.value
    parsed.value

pub fn js_json_stringify(v: text) -> text:
    """Stringify a text value as a JSON string."""
    _js_json_quote(v)

fn _js_json_parse_value(data: text, pos: i64) -> JsJsonCompatParseResult:
    val p = _js_json_skip_ws(data, pos)
    if p >= data.len():
        return JsJsonCompatParseResult.create("", p, false, false)
    val ch = data.char_at(p)
    if ch == "\"":
        return _js_json_parse_string(data, p)
    if ch == "{":
        return _js_json_parse_object(data, p)
    if ch == "[":
        return _js_json_parse_array(data, p)
    if data.slice(p, p + 4) == "true":
        return JsJsonCompatParseResult.create("true", p + 4, true, false)
    if data.slice(p, p + 5) == "false":
        return JsJsonCompatParseResult.create("false", p + 5, true, false)
    if data.slice(p, p + 4) == "null":
        return JsJsonCompatParseResult.create("null", p + 4, true, false)
    _js_json_parse_number(data, p)

fn _js_json_parse_string(data: text, pos: i64) -> JsJsonCompatParseResult:
    var i = pos + 1
    var result = ""
    while i < data.len():
        val ch = data.char_at(i)
        if ch == "\"":
            return JsJsonCompatParseResult.create(result, i + 1, true, true)
        if ch == "\\":
            if i + 1 >= data.len():
                return JsJsonCompatParseResult.create("", i, false, true)
            val esc = data.char_at(i + 1)
            if esc == "\"" or esc == "\\" or esc == "/":
                result = result + esc
                i = i + 2
            else:
                if esc == "n":
                    result = result + "\n"
                    i = i + 2
                else:
                    if esc == "t":
                        result = result + "\t"
                        i = i + 2
                    else:
                        if esc == "r":
                            result = result + "\r"
                            i = i + 2
                        else:
                            if esc == "b":
                                result = result + "\b"
                                i = i + 2
                            else:
                                if esc == "f":
                                    result = result + "\f"
                                    i = i + 2
                                else:
                                    if esc == "u" and i + 5 < data.len():
                                        result = result + "\\u" + data.slice(i + 2, i + 6)
                                        i = i + 6
                                    else:
                                        return JsJsonCompatParseResult.create("", i, false, true)
        else:
            result = result + ch
            i = i + 1
    JsJsonCompatParseResult.create("", i, false, true)

fn _js_json_parse_number(data: text, pos: i64) -> JsJsonCompatParseResult:
    var i = pos
    if i < data.len() and data.char_at(i) == "-":
        i = i + 1
    val digit_start = i
    while i < data.len() and _js_json_is_digit(data.char_at(i)):
        i = i + 1
    if i == digit_start:
        return JsJsonCompatParseResult.create("", pos, false, false)
    if i < data.len() and data.char_at(i) == ".":
        i = i + 1
        val frac_start = i
        while i < data.len() and _js_json_is_digit(data.char_at(i)):
            i = i + 1
        if i == frac_start:
            return JsJsonCompatParseResult.create("", pos, false, false)
    if i < data.len() and (data.char_at(i) == "e" or data.char_at(i) == "E"):
        i = i + 1
        if i < data.len() and (data.char_at(i) == "+" or data.char_at(i) == "-"):
            i = i + 1
        val exp_start = i
        while i < data.len() and _js_json_is_digit(data.char_at(i)):
            i = i + 1
        if i == exp_start:
            return JsJsonCompatParseResult.create("", pos, false, false)
    JsJsonCompatParseResult.create(data.slice(pos, i), i, true, false)

fn _js_json_parse_object(data: text, pos: i64) -> JsJsonCompatParseResult:
    var i = _js_json_skip_ws(data, pos + 1)
    var result = "{"
    var first = true
    if i < data.len() and data.char_at(i) == "}":
        return JsJsonCompatParseResult.create("{}", i + 1, true, false)
    while i < data.len():
        val key = _js_json_parse_string(data, i)
        if not key.ok:
            return JsJsonCompatParseResult.create("", i, false, false)
        i = _js_json_skip_ws(data, key.pos)
        if i >= data.len() or data.char_at(i) != ":":
            return JsJsonCompatParseResult.create("", i, false, false)
        val value = _js_json_parse_value(data, i + 1)
        if not value.ok:
            return JsJsonCompatParseResult.create("", i, false, false)
        if not first:
            result = result + ","
        result = result + _js_json_quote(key.value) + ":" + _js_json_emit(value)
        first = false
        i = _js_json_skip_ws(data, value.pos)
        if i < data.len() and data.char_at(i) == "}":
            return JsJsonCompatParseResult.create(result + "}", i + 1, true, false)
        if i >= data.len() or data.char_at(i) != ",":
            return JsJsonCompatParseResult.create("", i, false, false)
        i = _js_json_skip_ws(data, i + 1)
    JsJsonCompatParseResult.create("", i, false, false)

fn _js_json_parse_array(data: text, pos: i64) -> JsJsonCompatParseResult:
    var i = _js_json_skip_ws(data, pos + 1)
    var result = "["
    var first = true
    if i < data.len() and data.char_at(i) == "]":
        return JsJsonCompatParseResult.create("[]", i + 1, true, false)
    while i < data.len():
        val value = _js_json_parse_value(data, i)
        if not value.ok:
            return JsJsonCompatParseResult.create("", i, false, false)
        if not first:
            result = result + ","
        result = result + _js_json_emit(value)
        first = false
        i = _js_json_skip_ws(data, value.pos)
        if i < data.len() and data.char_at(i) == "]":
            return JsJsonCompatParseResult.create(result + "]", i + 1, true, false)
        if i >= data.len() or data.char_at(i) != ",":
            return JsJsonCompatParseResult.create("", i, false, false)
        i = _js_json_skip_ws(data, i + 1)
    JsJsonCompatParseResult.create("", i, false, false)

fn _js_json_emit(value: JsJsonCompatParseResult) -> text:
    if value.is_string:
        return _js_json_quote(value.value)
    value.value

fn _js_json_quote(value: text) -> text:
    "\"" + _js_json_escape(value) + "\""

fn _js_json_escape(value: text) -> text:
    var result = ""
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        else:
            if ch == "\\":
                result = result + "\\\\"
            else:
                if ch == "\n":
                    result = result + "\\n"
                else:
                    if ch == "\t":
                        result = result + "\\t"
                    else:
                        if ch == "\r":
                            result = result + "\\r"
                        else:
                            result = result + ch
        i = i + 1
    result

fn _js_json_skip_ws(data: text, pos: i64) -> i64:
    var i = pos
    while i < data.len():
        val ch = data.char_at(i)
        if ch == " " or ch == "\n" or ch == "\t" or ch == "\r":
            i = i + 1
        else:
            return i
    i

fn _js_json_is_digit(ch: text) -> bool:
    ch >= "0" and ch <= "9"

# =========================================================================
# URI Encoding
# =========================================================================

pub fn js_encode_uri_component(s: text) -> text:
    """Percent-encode a URI component.

    Encodes all characters except A-Z a-z 0-9 - _ . ~
    Uses a lookup table for common special characters.
    """
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if _is_uri_unreserved(ch):
            result = result + ch
        else:
            result = result + _percent_encode(ch)
        i = i + 1
    result

pub fn js_decode_uri_component(s: text) -> text:
    """Decode a percent-encoded URI component.

    Converts %XX sequences back to characters.
    """
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "%" and i + 2 < s.len():
            val hex = s.slice(i + 1, i + 3)
            val decoded = _hex_to_char(hex)
            result = result + decoded
            i = i + 3
        else:
            result = result + ch
            i = i + 1
    result

# =========================================================================
# Date
# =========================================================================

pub fn js_date_now() -> i64:
    """Return current time in milliseconds since epoch."""
    rt_time_now_unix_millis()

# =========================================================================
# Internal Helpers
# =========================================================================

fn _is_uri_unreserved(ch: text) -> bool:
    """Check if a character is unreserved in URI encoding."""
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    if ch == "-" or ch == "_" or ch == "." or ch == "~":
        return true
    false

fn _percent_encode(ch: text) -> text:
    """Percent-encode a single character."""
    # Common characters lookup
    if ch == " ":
        return "%20"
    if ch == "!":
        return "%21"
    if ch == "#":
        return "%23"
    if ch == "$":
        return "%24"
    if ch == "&":
        return "%26"
    if ch == "'":
        return "%27"
    if ch == "(":
        return "%28"
    if ch == ")":
        return "%29"
    if ch == "*":
        return "%2A"
    if ch == "+":
        return "%2B"
    if ch == ",":
        return "%2C"
    if ch == "/":
        return "%2F"
    if ch == ":":
        return "%3A"
    if ch == ";":
        return "%3B"
    if ch == "=":
        return "%3D"
    if ch == "?":
        return "%3F"
    if ch == "@":
        return "%40"
    if ch == "[":
        return "%5B"
    if ch == "]":
        return "%5D"
    # Fallback: return as-is (unhandled characters)
    ch

fn _hex_to_char(hex: text) -> text:
    """Convert a 2-char hex string to the corresponding character."""
    # Common hex lookups
    val lower = hex.lower()
    if lower == "20":
        return " "
    if lower == "21":
        return "!"
    if lower == "23":
        return "#"
    if lower == "24":
        return "$"
    if lower == "26":
        return "&"
    if lower == "27":
        return "'"
    if lower == "28":
        return "("
    if lower == "29":
        return ")"
    if lower == "2a":
        return "*"
    if lower == "2b":
        return "+"
    if lower == "2c":
        return ","
    if lower == "2f":
        return "/"
    if lower == "3a":
        return ":"
    if lower == "3b":
        return ";"
    if lower == "3d":
        return "="
    if lower == "3f":
        return "?"
    if lower == "40":
        return "@"
    if lower == "5b":
        return "["
    if lower == "5d":
        return "]"
    # Fallback: return the hex as-is prefixed with %
    "%{hex}"
