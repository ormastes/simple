"""
# Form API

Simple-script form manipulation API for the browser engine.
Reads and writes form element state through BeDomNode attributes.

JS Equivalent → Simple Function:
    input.value (get)          → form_get_value()
    input.value (set)          → form_set_value()
    input.checked (get)        → form_get_checked()
    input.checked (set)        → form_set_checked()
    select.selectedIndex (get) → form_get_selected_index()
    select.selectedIndex (set) → form_set_selected_index()
    form.submit()              → form_submit()
    form.reset()               → form_reset()
    form.checkValidity()       → form_validate()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_get_attr, be_dom_get_tag}

# =========================================================================
# Value Access
# =========================================================================

pub fn form_get_value(node: BeDomNode) -> text:
    """Get the value of an input, textarea, or select element.

    Reads the 'value' attribute. For textarea, falls back to text_content.
    """
    val v = be_dom_get_attr(node, "value")
    if v != "":
        return v
    val tag = be_dom_get_tag(node)
    if tag == "textarea":
        return node.text_content
    ""

pub fn form_set_value(node: BeDomNode, value: text):
    """Set the value of an input, textarea, or select element."""
    node.set_attr("value", value)

# =========================================================================
# Checkbox / Radio
# =========================================================================

pub fn form_get_checked(node: BeDomNode) -> bool:
    """Return true if the input element is checked."""
    val v = be_dom_get_attr(node, "checked")
    v == "true" or v == "checked" or v == ""  and node.has_attr("checked")

pub fn form_set_checked(node: BeDomNode, checked: bool):
    """Set the checked state of an input element."""
    if checked:
        node.set_attr("checked", "true")
    else:
        node.remove_attr("checked")

# =========================================================================
# Select Element
# =========================================================================

pub fn form_get_selected_index(node: BeDomNode) -> i32:
    """Return the selected index for a select element.

    Searches children (option elements) for the 'selected' attribute.
    """
    var i = 0
    while i < node.children.len():
        val child = node.children[i]
        if child.has_attr("selected"):
            return i
        i = i + 1
    -1

pub fn form_set_selected_index(node: BeDomNode, idx: i32):
    """Set the selected index for a select element.

    Clears 'selected' from all options and sets it on the target index.
    """
    var i = 0
    while i < node.children.len():
        var child = node.children[i]
        if i == idx:
            child.set_attr("selected", "true")
        else:
            child.remove_attr("selected")
        node.children[i] = child
        i = i + 1

# =========================================================================
# Form Actions
# =========================================================================

pub fn form_submit(node: BeDomNode):
    """Trigger a submit event on the form.

    NOTE: Actual event dispatch requires wiring through the EventLoop.
    This is a structural placeholder.
    """
    pass_todo

pub fn form_reset(node: BeDomNode):
    """Reset form fields to their default values.

    Clears the 'value' attribute on all input children.
    """
    var i = 0
    while i < node.children.len():
        var child = node.children[i]
        val tag = be_dom_get_tag(child)
        if tag == "input" or tag == "textarea" or tag == "select":
            child.remove_attr("value")
            child.remove_attr("checked")
        node.children[i] = child
        i = i + 1

pub fn form_validate(node: BeDomNode) -> bool:
    """Check form validity.

    Returns true if all required fields have non-empty values.
    """
    var i = 0
    while i < node.children.len():
        val child = node.children[i]
        if child.has_attr("required"):
            val v = be_dom_get_attr(child, "value")
            if v == "":
                return false
        i = i + 1
    true
