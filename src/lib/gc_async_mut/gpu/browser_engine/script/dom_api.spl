"""
# DOM API

Simple-script DOM manipulation API for the browser engine.
Thin forwarding layer over BeDomNode methods and be_dom_* helpers.

JS Equivalent → Simple Function:
    document.querySelector()     → document_query_selector()
    document.querySelectorAll()  → document_query_selector_all()
    document.getElementById()    → document_get_element_by_id()
    document.createElement()     → document_create_element()
    document.createTextNode()    → document_create_text_node()
    node.appendChild()           → node_append_child()
    node.removeChild()           → node_remove_child()
    node.insertBefore()          → node_insert_before()
    node.setAttribute()          → node_set_attribute()
    node.getAttribute()          → node_get_attribute()
    node.removeAttribute()       → node_remove_attribute()
    node.textContent (set)       → node_set_text_content()
    node.textContent (get)       → node_get_text_content()
    node.innerHTML (set)         → node_set_inner_html()
    node.classList.add()         → node_class_list_add()
    node.classList.remove()      → node_class_list_remove()
    node.classList.toggle()      → node_class_list_toggle()
    node.classList.contains()    → node_class_list_contains()
    node.style.setProperty()     → node_set_style_property()
    node.style.getPropertyValue()→ node_get_style_property()
    node.parentNode              → node_parent()
    node.children                → node_children()
    node.tagName                 → node_tag_name()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{
    be_dom_get_tag, be_dom_get_text_content, be_dom_get_children,
    be_dom_get_attr, be_dom_get_id, be_dom_get_classes
}

# =========================================================================
# Query Functions
# =========================================================================

pub fn document_query_selector(root: BeDomNode, sel: text) -> BeDomNode?:
    """Return the first node matching a simple selector (tag, #id, .class)."""
    if _node_matches_selector(root, sel):
        return Some(root)
    var i = 0
    while i < root.children.len():
        val found = document_query_selector(root.children[i], sel)
        if found.?:
            return found
        i = i + 1
    nil

pub fn document_query_selector_all(root: BeDomNode, sel: text) -> [BeDomNode]:
    """Return all nodes matching a simple selector (tag, #id, .class).

    Uses return-based recursion (each call builds and returns its own list)
    rather than a shared out-parameter accumulator: pushing into an array
    passed as a function argument does not reliably persist to the caller
    across a module boundary under the interpreter (documented landmine)."""
    var results: [BeDomNode] = []
    if _node_matches_selector(root, sel):
        results.push(root)
    var i = 0
    while i < root.children.len():
        val child_matches = document_query_selector_all(root.children[i], sel)
        var j = 0
        while j < child_matches.len():
            results.push(child_matches[j])
            j = j + 1
        i = i + 1
    results

fn _node_matches_selector(node: BeDomNode, sel: text) -> bool:
    """Check if a node matches a simple selector."""
    if sel.starts_with("#"):
        val id = sel.slice(1, sel.len())
        return be_dom_get_id(node) == id
    if sel.starts_with("."):
        val cls = sel.slice(1, sel.len())
        val classes = be_dom_get_classes(node)
        var j = 0
        while j < classes.len():
            if classes[j] == cls:
                return true
            j = j + 1
        return false
    node.tag_name == sel

pub fn document_get_element_by_id(root: BeDomNode, id: text) -> BeDomNode?:
    """Return the first node with the given id, or nil."""
    document_query_selector(root, "#" + id)

# =========================================================================
# Node Creation
# =========================================================================

pub fn document_create_element(tag: text) -> BeDomNode:
    """Create a new element node with the given tag name."""
    BeDomNode.element(tag)

pub fn document_create_text_node(content: text) -> BeDomNode:
    """Create a new text node with the given content."""
    BeDomNode.text(content)

# =========================================================================
# Tree Manipulation
# =========================================================================

pub fn node_append_child(parent: BeDomNode, child: BeDomNode) -> BeDomNode:
    """Append a child node to the parent. Returns the mutated parent — callers
    must use the returned value, because in-place mutation of a class-arg does
    not reliably persist across a module boundary under the interpreter."""
    var next = parent
    var c = child
    c.parent_id = next.node_id
    next.children.push(c)
    next

pub fn node_remove_child(parent: BeDomNode, idx: i32) -> BeDomNode:
    """Remove child at the given index from the parent. Returns the parent."""
    var next = parent
    var new_children: [BeDomNode] = []
    var i = 0
    while i < next.children.len():
        if i != idx:
            new_children.push(next.children[i])
        i = i + 1
    next.children = new_children
    next

pub fn node_insert_before(parent: BeDomNode, child: BeDomNode, ref_idx: i32) -> BeDomNode:
    """Insert a child before the node at ref_idx. Returns the parent."""
    var next = parent
    var new_children: [BeDomNode] = []
    var i = 0
    var inserted = false
    while i < next.children.len():
        if i == ref_idx and not inserted:
            new_children.push(child)
            inserted = true
        new_children.push(next.children[i])
        i = i + 1
    if not inserted:
        new_children.push(child)
    next.children = new_children
    next

# =========================================================================
# Attribute Manipulation
# =========================================================================

pub fn node_set_attribute(node: BeDomNode, name: text, value: text) -> BeDomNode:
    """Set an attribute on the node. Returns the mutated node."""
    var next = node
    next.set_attr(name, value)
    next

pub fn node_get_attribute(node: BeDomNode, name: text) -> text?:
    """Get an attribute value. Returns nil if not present."""
    val v = be_dom_get_attr(node, name)
    if v == "":
        return nil
    Some(v)

pub fn node_remove_attribute(node: BeDomNode, name: text) -> BeDomNode:
    """Remove an attribute from the node. Returns the mutated node."""
    var next = node
    next.remove_attr(name)
    next

# =========================================================================
# Text Content
# =========================================================================

pub fn node_set_text_content(node: BeDomNode, content: text) -> BeDomNode:
    """Set the text content of a node, replacing all children with a text node.
    Returns the mutated node."""
    var next = node
    val text_node = BeDomNode.text(content)
    next.children = [text_node]
    next

pub fn node_get_text_content(node: BeDomNode) -> text:
    """Get the concatenated text content of a node and its descendants."""
    be_dom_get_text_content(node)

pub fn node_set_inner_html(node: BeDomNode, html: text) -> BeDomNode:
    """Set inner HTML. Returns the mutated node.

    NOTE: Full HTML parsing would require importing the tree builder,
    creating a circular dependency. For now, this handles simple text content.
    For full re-parse, use the tree builder externally and set children.
    """
    var next = node
    # Simple case: treat as text content
    val text_node = BeDomNode.text(html)
    next.children = [text_node]
    next

# =========================================================================
# Class List
# =========================================================================

fn _write_classes(node: BeDomNode, classes: [text]) -> BeDomNode:
    """Serialize a class list back into the node's `class` attribute.
    Returns the mutated node."""
    var next = node
    if classes.len() == 0:
        next.set_attr("class", "")
        return next
    next.set_attr("class", classes.join(" "))
    next

pub fn node_class_list_add(node: BeDomNode, cls: text) -> BeDomNode:
    """Add a CSS class to the node if not already present. Returns the node."""
    val classes = be_dom_get_classes(node)
    var j = 0
    while j < classes.len():
        if classes[j] == cls:
            return node
        j = j + 1
    var updated = classes
    updated.push(cls)
    _write_classes(node, updated)

pub fn node_class_list_remove(node: BeDomNode, cls: text) -> BeDomNode:
    """Remove a CSS class from the node. Returns the node."""
    val classes = be_dom_get_classes(node)
    var new_classes: [text] = []
    var j = 0
    while j < classes.len():
        if classes[j] != cls:
            new_classes.push(classes[j])
        j = j + 1
    _write_classes(node, new_classes)

pub fn node_class_list_toggle(node: BeDomNode, cls: text) -> bool:
    """Return true if the class would be added, false if it would be removed.

    NOTE: This returns the toggle *result* (whether the class was absent) but
    cannot return the mutated node, so it does not persist the class change.
    Callers that need the mutated node should use node_class_list_add /
    node_class_list_remove (which return the node) based on this result."""
    not node_class_list_contains(node, cls)

pub fn node_class_list_contains(node: BeDomNode, cls: text) -> bool:
    """Check if the node has a CSS class."""
    val classes = be_dom_get_classes(node)
    var j = 0
    while j < classes.len():
        if classes[j] == cls:
            return true
        j = j + 1
    false

# =========================================================================
# Style Properties
# =========================================================================

pub fn node_set_style_property(node: BeDomNode, prop: text, value: text) -> BeDomNode:
    """Set an inline style property on the node. Returns the mutated node."""
    var next = node
    next.set_style(prop, value)
    next

pub fn node_get_style_property(node: BeDomNode, prop: text) -> text:
    """Get an inline style property value. Returns empty string if not set.

    NOTE: Currently returns the display property only; extend as needed.
    """
    val s = node.style
    if prop == "display":
        return s.display
    ""

# =========================================================================
# Tree Traversal
# =========================================================================

pub fn node_parent(node: BeDomNode) -> BeDomNode?:
    """Return the parent node. Not tracked in BeDomNode; returns nil.

    Parent tracking requires a back-reference or tree-walk from root.
    Use node_parent_in(root, node) to resolve a parent by walking a subtree.
    """
    nil

fn _same_node(a: BeDomNode, b: BeDomNode) -> bool:
    """Best-effort structural identity for value-copied DOM nodes: matches on
    node_id, tag, id-attribute and child count."""
    (a.node_id == b.node_id and a.tag_name == b.tag_name and
        be_dom_get_id(a) == be_dom_get_id(b) and
        a.children.len() == b.children.len())

pub fn node_parent_in(root: BeDomNode, target: BeDomNode) -> BeDomNode?:
    """Find the parent of `target` by walking down from `root`.

    BeDomNode has no live parent back-reference, so this searches the subtree
    for the node whose direct children include one matching `target`, and
    returns that node (or nil if `target` is not found under `root`)."""
    var i = 0
    while i < root.children.len():
        if _same_node(root.children[i], target):
            return Some(root)
        i = i + 1
    var k = 0
    while k < root.children.len():
        val found = node_parent_in(root.children[k], target)
        if found.?:
            return found
        k = k + 1
    nil

pub fn node_children(node: BeDomNode) -> [BeDomNode]:
    """Return the children of the node."""
    be_dom_get_children(node)

pub fn node_tag_name(node: BeDomNode) -> text:
    """Return the tag name of the node."""
    be_dom_get_tag(node)
