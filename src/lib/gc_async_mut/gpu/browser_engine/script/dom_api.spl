"""
# DOM API

Simple-script DOM manipulation API for the browser engine.
Thin forwarding layer over BeDomNode methods and be_dom_* helpers.

JS Equivalent → Simple Function:
    document.querySelector()     → document_query_selector()
    document.querySelectorAll()  → document_query_selector_all()
    document.getElementById()    → document_get_element_by_id()
    document.createElement()     → document_create_element()
    document.createTextNode()    → document_create_text_node()
    node.appendChild()           → node_append_child()
    node.removeChild()           → node_remove_child()
    node.insertBefore()          → node_insert_before()
    node.setAttribute()          → node_set_attribute()
    node.getAttribute()          → node_get_attribute()
    node.removeAttribute()       → node_remove_attribute()
    node.textContent (set)       → node_set_text_content()
    node.textContent (get)       → node_get_text_content()
    node.innerHTML (set)         → node_set_inner_html()
    node.classList.add()         → node_class_list_add()
    node.classList.remove()      → node_class_list_remove()
    node.classList.toggle()      → node_class_list_toggle()
    node.classList.contains()    → node_class_list_contains()
    node.style.setProperty()     → node_set_style_property()
    node.style.getPropertyValue()→ node_get_style_property()
    node.parentNode              → node_parent_in()
    node.children                → node_children()
    node.tagName                 → node_tag_name()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{
    be_dom_query_selector, be_dom_find_by_id,
    be_dom_get_tag, be_dom_get_text_content, be_dom_get_children,
    be_dom_get_attr, be_dom_get_classes
}

# =========================================================================
# Query Functions
# =========================================================================

pub fn document_query_selector(root: BeDomNode, sel: text) -> BeDomNode?:
    """Return the first node matching a simple selector (tag, #id, .class)."""
    be_dom_query_selector(root, sel)

pub fn document_query_selector_all(root: BeDomNode, sel: text) -> [BeDomNode]:
    """Return all nodes matching a simple selector (tag, #id, .class)."""
    _collect_matching(root, sel)

fn _collect_matching(node: BeDomNode, sel: text) -> [BeDomNode]:
    """Recursively collect all nodes matching the selector."""
    var results: [BeDomNode] = []
    if _node_matches_selector(node, sel):
        results.push(node)
    var i = 0
    while i < node.children.len():
        val child_results = _collect_matching(node.children[i], sel)
        var child_idx = 0
        while child_idx < child_results.len():
            results.push(child_results[child_idx])
            child_idx = child_idx + 1
        i = i + 1
    results

fn _node_matches_selector(node: BeDomNode, sel: text) -> bool:
    """Check if a node matches a simple selector."""
    if sel.starts_with("#"):
        val id = sel.slice(1, sel.len())
        return node.id == id
    if sel.starts_with("."):
        val cls = sel.slice(1, sel.len())
        var j = 0
        while j < node.classes.len():
            if node.classes[j] == cls:
                return true
            j = j + 1
        return false
    node.tag == sel

pub fn document_get_element_by_id(root: BeDomNode, id: text) -> BeDomNode?:
    """Return the first node with the given id, or nil."""
    be_dom_find_by_id(root, id)

# =========================================================================
# Node Creation
# =========================================================================

pub fn document_create_element(tag: text) -> BeDomNode:
    """Create a new element node with the given tag name."""
    BeDomNode.element(tag)

pub fn document_create_text_node(content: text) -> BeDomNode:
    """Create a new text node with the given content."""
    BeDomNode.text(content)

# =========================================================================
# Tree Manipulation
# =========================================================================

pub fn node_append_child(parent: BeDomNode, child: BeDomNode) -> BeDomNode:
    """Append a child node to the parent."""
    parent.add_child(child)
    parent

pub fn node_remove_child(parent: BeDomNode, idx: i32) -> BeDomNode:
    """Remove child at the given index from the parent."""
    var new_children: [BeDomNode] = []
    var i = 0
    while i < parent.children.len():
        if i != idx:
            new_children.push(parent.children[i])
        i = i + 1
    parent.children = new_children
    parent

pub fn node_insert_before(parent: BeDomNode, child: BeDomNode, ref_idx: i32) -> BeDomNode:
    """Insert a child before the node at ref_idx."""
    var new_children: [BeDomNode] = []
    var i = 0
    var inserted = false
    while i < parent.children.len():
        if i == ref_idx and not inserted:
            new_children.push(child)
            inserted = true
        new_children.push(parent.children[i])
        i = i + 1
    if not inserted:
        new_children.push(child)
    parent.children = new_children
    parent

# =========================================================================
# Attribute Manipulation
# =========================================================================

pub fn node_set_attribute(node: BeDomNode, name: text, value: text) -> BeDomNode:
    """Set an attribute on the node."""
    node.set_attr(name, value)
    node

pub fn node_get_attribute(node: BeDomNode, name: text) -> text?:
    """Get an attribute value. Returns nil if not present."""
    val v = be_dom_get_attr(node, name)
    if v == "":
        return nil
    Some(v)

pub fn node_remove_attribute(node: BeDomNode, name: text) -> BeDomNode:
    """Remove an attribute from the node."""
    node.remove_attr(name)
    node

# =========================================================================
# Text Content
# =========================================================================

pub fn node_set_text_content(node: BeDomNode, content: text) -> BeDomNode:
    """Set the text content of a node, replacing all children with a text node."""
    val text_node = BeDomNode.text(content)
    node.children = [text_node]
    node

pub fn node_get_text_content(node: BeDomNode) -> text:
    """Get the concatenated text content of a node and its descendants."""
    be_dom_get_text_content(node)

pub fn node_set_inner_html(node: BeDomNode, html: text) -> BeDomNode:
    """Set inner HTML for text and flat element fragments.

    This intentionally keeps the script API dependency-light: unsupported or
    nested markup remains text content instead of pulling in the full tree
    builder and creating a circular browser-engine dependency.
    """
    val parsed = _parse_inner_html_fragment(html)
    node.children = parsed
    node

fn _parse_inner_html_fragment(html: text) -> [BeDomNode]:
    val trimmed = html.trim()
    if trimmed.len() == 0:
        return []
    if not trimmed.contains("<"):
        return [BeDomNode.text(html)]

    var nodes: [BeDomNode] = []
    var pos: i64 = 0
    while pos < html.len():
        val open = _dom_find(html, "<", pos)
        if open >= 999999999:
            val tail = html.slice(pos, html.len())
            if tail.len() > 0:
                nodes.push(BeDomNode.text(tail))
            return nodes
        if open > pos:
            val before = html.slice(pos, open)
            if before.len() > 0:
                nodes.push(BeDomNode.text(before))

        val tag_end = _dom_find(html, ">", open + 1)
        if tag_end >= 999999999:
            return [BeDomNode.text(html)]
        val tag_content = html.slice(open + 1, tag_end).trim()
        val tag = _dom_first_token(tag_content).lower()
        if tag.len() == 0 or tag.starts_with("/") or tag.contains("<"):
            return [BeDomNode.text(html)]

        val close_needle = "</" + tag + ">"
        val close = _dom_find(html.lower(), close_needle, tag_end + 1)
        if close >= 999999999:
            return [BeDomNode.text(html)]

        val inner = html.slice(tag_end + 1, close)
        if inner.contains("<"):
            return [BeDomNode.text(html)]

        var child = BeDomNode.element(tag)
        child = _apply_inner_html_attrs(child, tag_content)
        if inner.len() > 0:
            child.add_child(BeDomNode.text(inner))
        nodes.push(child)
        pos = close + close_needle.len()

    nodes

fn _apply_inner_html_attrs(node: BeDomNode, tag_content: text) -> BeDomNode:
    var idx = _dom_first_token(tag_content).len()
    while idx < tag_content.len():
        while idx < tag_content.len() and tag_content.slice(idx, idx + 1) == " ":
            idx = idx + 1
        val key_start = idx
        while idx < tag_content.len() and tag_content.slice(idx, idx + 1) != " " and tag_content.slice(idx, idx + 1) != "=":
            idx = idx + 1
        val key = tag_content.slice(key_start, idx).trim().lower()
        while idx < tag_content.len() and tag_content.slice(idx, idx + 1) == " ":
            idx = idx + 1
        var value = ""
        if idx < tag_content.len() and tag_content.slice(idx, idx + 1) == "=":
            idx = idx + 1
            while idx < tag_content.len() and tag_content.slice(idx, idx + 1) == " ":
                idx = idx + 1
            if idx < tag_content.len() and (tag_content.slice(idx, idx + 1) == "\"" or tag_content.slice(idx, idx + 1) == "'"):
                val quote = tag_content.slice(idx, idx + 1)
                idx = idx + 1
                val value_start = idx
                while idx < tag_content.len() and tag_content.slice(idx, idx + 1) != quote:
                    idx = idx + 1
                value = tag_content.slice(value_start, idx)
                if idx < tag_content.len():
                    idx = idx + 1
            else:
                val value_start = idx
                while idx < tag_content.len() and tag_content.slice(idx, idx + 1) != " ":
                    idx = idx + 1
                value = tag_content.slice(value_start, idx)
        if key.len() > 0:
            if key == "class":
                node.set_attr(key, value)
                node.classes = _dom_split_words(value)
            elif key == "style":
                node.set_attr(key, value)
                node = _apply_inner_html_style(node, value)
            else:
                node.set_attr(key, value)
        idx = idx + 1
    node

fn _apply_inner_html_style(node: BeDomNode, style: text) -> BeDomNode:
    val declarations = style.split(";")
    var idx = 0
    while idx < declarations.len():
        val decl = declarations[idx].trim()
        val colon = decl.index_of(":")
        if colon > 0:
            val prop = decl.slice(0, colon).trim().lower()
            val value = decl.slice(colon + 1, decl.len()).trim()
            if prop.len() > 0:
                node.set_style(prop, value)
        idx = idx + 1
    node

fn _dom_split_words(value: text) -> [text]:
    val parts = value.split(" ")
    var out: [text] = []
    var idx = 0
    while idx < parts.len():
        val part = parts[idx].trim()
        if part.len() > 0:
            out.push(part)
        idx = idx + 1
    out

fn _dom_first_token(value: text) -> text:
    val trimmed = value.trim()
    val space = trimmed.index_of(" ")
    if space < 0:
        return trimmed
    trimmed.slice(0, space)

fn _dom_unquote(value: text) -> text:
    if value.len() >= 2:
        if (value.starts_with("\"") and value.ends_with("\"")) or (value.starts_with("'") and value.ends_with("'")):
            return value.slice(1, value.len() - 1)
    value

fn _dom_find(haystack: text, needle: text, start: i64) -> i64:
    if needle.len() == 0:
        return start
    var idx = start
    while idx + needle.len() <= haystack.len():
        if haystack.slice(idx, idx + needle.len()) == needle:
            return idx
        idx = idx + 1
    999999999

# =========================================================================
# Class List
# =========================================================================

pub fn node_class_list_add(node: BeDomNode, cls: text) -> BeDomNode:
    """Add a CSS class to the node if not already present."""
    var j = 0
    while j < node.classes.len():
        if node.classes[j] == cls:
            return node
        j = j + 1
    node.classes.push(cls)
    node

pub fn node_class_list_remove(node: BeDomNode, cls: text) -> BeDomNode:
    """Remove a CSS class from the node."""
    var new_classes: [text] = []
    var j = 0
    while j < node.classes.len():
        if node.classes[j] != cls:
            new_classes.push(node.classes[j])
        j = j + 1
    node.classes = new_classes
    node

pub fn node_class_list_toggle(node: BeDomNode, cls: text) -> bool:
    """Toggle a CSS class. Returns true if added, false if removed."""
    var found = false
    var j = 0
    while j < node.classes.len():
        if node.classes[j] == cls:
            found = true
        j = j + 1
    if found:
        node_class_list_remove(node, cls)
        return false
    node.classes.push(cls)
    true

pub fn node_class_list_contains(node: BeDomNode, cls: text) -> bool:
    """Check if the node has a CSS class."""
    var j = 0
    while j < node.classes.len():
        if node.classes[j] == cls:
            return true
        j = j + 1
    false

# =========================================================================
# Style Properties
# =========================================================================

pub fn node_set_style_property(node: BeDomNode, prop: text, value: text) -> BeDomNode:
    """Set an inline style property on the node."""
    node.set_style(prop, value)
    node

pub fn node_get_style_property(node: BeDomNode, prop: text) -> text:
    """Get an inline style property value. Returns empty string if not set.

    NOTE: Currently returns the display property only; extend as needed.
    """
    val s = node.style
    if prop == "display":
        return s.display
    ""

# =========================================================================
# Tree Traversal
# =========================================================================

pub fn node_parent(node: BeDomNode) -> BeDomNode?:
    """Return the parent node. Not tracked in BeDomNode; returns nil.

    Parent tracking requires a back-reference or tree-walk from root.
    """
    nil

pub fn node_parent_in(root: BeDomNode, node: BeDomNode) -> BeDomNode?:
    """Return the parent by walking from a known root context."""
    _node_parent_walk(root, node)

fn _node_parent_walk(parent: BeDomNode, target: BeDomNode) -> BeDomNode?:
    var i = 0
    while i < parent.children.len():
        val child = parent.children[i]
        if _same_dom_node(child, target):
            return Some(parent)
        val nested = _node_parent_walk(child, target)
        if nested != nil:
            return nested
        i = i + 1
    nil

fn _same_dom_node(left: BeDomNode, right: BeDomNode) -> bool:
    if left.id.len() > 0 or right.id.len() > 0:
        return left.id.len() > 0 and left.id == right.id
    left.tag == right.tag and left.text_content == right.text_content and left.attributes == right.attributes

pub fn node_children(node: BeDomNode) -> [BeDomNode]:
    """Return the children of the node."""
    be_dom_get_children(node)

pub fn node_tag_name(node: BeDomNode) -> text:
    """Return the tag name of the node."""
    be_dom_get_tag(node)
