"""Navigator API for browser scripts.

Provides the browser-facing `navigator` data surface and a secure-context
entrypoint for `navigator.gpu`.
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.webgpu_context.{WebGPUContext, webgpu_create_context}
use std.gc_async_mut.gpu.browser_engine.webgpu_context.{webgpu_preferred_canvas_format}
use std.gc_async_mut.gpu.browser_engine.webgpu_types.{
    GPUAdapterInfo, GPUDeviceDescriptor, GPURequestAdapterOptions
}

pub class BrowserNavigatorGPU:
    secure_context: bool
    adapter_available: bool
    request_adapter_status: text
    preferred_canvas_format: text

    static fn create(secure_context: bool) -> BrowserNavigatorGPU:
        BrowserNavigatorGPU(
            secure_context: secure_context,
            adapter_available: secure_context,
            request_adapter_status: if secure_context: "available" else: "unavailable: secure context required",
            preferred_canvas_format: webgpu_preferred_canvas_format()
        )

    fn request_adapter() -> BrowserGPUAdapter:
        self.request_adapter_with_options(GPURequestAdapterOptions.default_options())

    fn request_adapter_with_options(options: GPURequestAdapterOptions) -> BrowserGPUAdapter:
        var ctx = webgpu_create_context(self.secure_context)
        val available = ctx.request_adapter(options)
        BrowserGPUAdapter.from_context(ctx, available)

pub class BrowserGPUAdapter:
    available: bool
    name: text
    request_adapter_status: text
    is_fallback_adapter: bool
    info: GPUAdapterInfo
    gpu: WebGPUContext

    static fn from_context(ctx: WebGPUContext, available: bool) -> BrowserGPUAdapter:
        val fallback = ctx.adapter.architecture == "software"
        BrowserGPUAdapter(
            available: available,
            name: if available: "Simple WebGPU Software Adapter" else: "",
            request_adapter_status: ctx.adapter_status,
            is_fallback_adapter: fallback,
            info: ctx.adapter,
            gpu: ctx
        )

    fn request_device() -> WebGPUContext:
        self.request_device_with_descriptor(GPUDeviceDescriptor.create())

    fn request_device_with_descriptor(descriptor: GPUDeviceDescriptor) -> WebGPUContext:
        var ctx = self.gpu
        val _ok = ctx.request_device(descriptor)
        ctx

pub class BrowserNavigator:
    user_agent: text
    language: text
    online: bool
    secure_context: bool
    platform: text

    static fn create(secure_context: bool) -> BrowserNavigator:
        BrowserNavigator(
            user_agent: "SimpleBrowser/0.1",
            language: "en-US",
            online: true,
            secure_context: secure_context,
            platform: "simple"
        )

    fn gpu_available() -> bool:
        self.secure_context

    fn request_gpu() -> WebGPUContext:
        webgpu_create_context(self.secure_context)

    fn gpu() -> BrowserNavigatorGPU:
        BrowserNavigatorGPU.create(self.secure_context)

pub fn navigator_create(secure_context: bool) -> BrowserNavigator:
    BrowserNavigator.create(secure_context)

pub fn navigator_user_agent(nav: BrowserNavigator) -> text:
    nav.user_agent

pub fn navigator_language(nav: BrowserNavigator) -> text:
    nav.language

pub fn navigator_on_line(nav: BrowserNavigator) -> bool:
    nav.online

pub fn navigator_platform(nav: BrowserNavigator) -> text:
    nav.platform

pub fn navigator_gpu_available(nav: BrowserNavigator) -> bool:
    nav.gpu_available()

pub fn navigator_gpu(nav: BrowserNavigator) -> WebGPUContext:
    nav.request_gpu()

pub fn navigator_gpu_bridge(nav: BrowserNavigator) -> BrowserNavigatorGPU:
    nav.gpu()

pub fn navigator_gpu_secure_context(nav: BrowserNavigator) -> bool:
    nav.secure_context

pub fn navigator_gpu_adapter_available(nav: BrowserNavigator) -> bool:
    nav.secure_context

pub fn navigator_gpu_request_adapter_status(nav: BrowserNavigator) -> text:
    if nav.secure_context:
        return "available"
    "unavailable: secure context required"

pub fn navigator_gpu_preferred_canvas_format(nav: BrowserNavigator) -> text:
    webgpu_preferred_canvas_format()

pub fn navigator_gpu_request_adapter(nav: BrowserNavigator) -> BrowserGPUAdapter:
    nav.gpu().request_adapter()

pub fn navigator_gpu_request_adapter_with_options(nav: BrowserNavigator, options: GPURequestAdapterOptions) -> BrowserGPUAdapter:
    nav.gpu().request_adapter_with_options(options)

pub fn navigator_gpu_adapter_request_device(adapter: BrowserGPUAdapter) -> WebGPUContext:
    adapter.request_device()
