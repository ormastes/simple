"""
# Network API

Simple-script network API for the browser engine.
Provides fetch() and WebSocket abstractions.

JS Equivalent → Simple Function:
    fetch()                    → fetch_send()
    new Request()              → fetch_create_request()
    request.headers.set()      → fetch_set_header()
    new WebSocket()            → websocket_connect()
    new WebSocket(url, protos) → websocket_connect_with_protocols()
    ws.send()                  → websocket_send()
    ws.close()                 → websocket_close()
    ws.close(code, reason)     → websocket_close_with_code()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, FetchResponse, RequestMode}
use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
use std.gc_async_mut.gpu.browser_engine.net.fetch_dispatch.{FetchDispatch}

extern fn rt_text_to_bytes(s: text) -> [u8]

# =========================================================================
# Fetch API — Simplified request/response types for script use
# =========================================================================

pub class ScriptFetchRequest:
    """A simplified fetch request for script-level use.

    Fields:
        url     - target URL string
        method  - HTTP method (GET, POST, etc.)
        headers - flat [name, value, name, value, ...] pairs
        body    - request body text
    """
    url: text
    method: text
    headers: [text]
    body: text

pub class ScriptFetchResponse:
    """A simplified fetch response for script-level use.

    Fields:
        status  - HTTP status code
        headers - flat [name, value, name, value, ...] pairs
        body    - response body as text
        ok      - true if status is 200-299
    """
    status: i64
    headers: [text]
    body: text
    ok: bool

pub fn fetch_create_request(url: text, method: text) -> ScriptFetchRequest:
    """Create a new fetch request."""
    ScriptFetchRequest(url: url, method: method, headers: [], body: "")

pub fn fetch_set_header(req: ScriptFetchRequest, name: text, value: text) -> ScriptFetchRequest:
    """Add a header to the fetch request."""
    var next = req
    next.headers.push(name)
    next.headers.push(value)
    next

pub fn fetch_send(req: ScriptFetchRequest) -> ScriptFetchResponse:
    """Send a fetch request and return the response.

    Without an injected FetchDispatch this returns the browser-compatible
    opaque network error shape: status 0, empty headers/body, ok=false. Host
    browsers wire fetch_send_with_dispatch() through ScriptHost/SimpleScript.
    """
    ScriptFetchResponse(status: 0, headers: [], body: "", ok: false)

pub fn fetch_send_with_dispatch(req: ScriptFetchRequest, dispatch: FetchDispatch) -> ScriptFetchResponse:
    """Send a script fetch request through the host FetchDispatch seam."""
    val response = dispatch.dispatch(script_fetch_to_net_request(req))
    ScriptFetchResponse(
        status: response.status,
        headers: script_fetch_response_headers(response.headers),
        body: response.body_text(),
        ok: response.status >= 200 and response.status < 300
    )

pub fn fetch_send_with_optional_dispatch(req: ScriptFetchRequest, dispatch: FetchDispatch?) -> ScriptFetchResponse:
    """Send through dispatch when one is installed, otherwise use the safe fallback."""
    if dispatch.is_some():
        return fetch_send_with_dispatch(req, dispatch.unwrap())
    fetch_send(req)

pub fn script_fetch_to_net_request(req: ScriptFetchRequest) -> FetchRequest:
    FetchRequest(
        method: req.method,
        url: script_fetch_parse_url(req.url),
        headers: script_fetch_flat_headers_to_text(req.headers),
        body: rt_text_to_bytes(req.body),
        mode: RequestMode.Cors,
        credentials: "same-origin"
    )

pub fn script_fetch_parse_url(raw: text) -> Url:
    var scheme = "https"
    var rest = raw
    if raw.starts_with("https://"):
        scheme = "https"
        rest = raw.substring(8, raw.len())
    else if raw.starts_with("http://"):
        scheme = "http"
        rest = raw.substring(7, raw.len())
    val slash_parts = rest.split("/")
    val host_port = slash_parts[0]
    var host = host_port
    var port = if scheme == "http": 80 else: 443
    val colon = host_port.index_of(":")
    if colon > 0:
        host = host_port.substring(0, colon)
        val parsed_port = host_port.substring(colon + 1, host_port.len()).parse_i64()
        if parsed_port != nil:
            port = (parsed_port ?? port.to_i64()).to_i32()
    var path = "/"
    if slash_parts.len() > 1:
        path = "/" + rest.substring(host_port.len() + 1, rest.len())
    var fragment = ""
    val hash = path.index_of("#")
    if hash >= 0:
        fragment = path.substring(hash + 1, path.len())
        path = path.substring(0, hash)
    var query = ""
    if path.contains("?"):
        val query_parts = path.split("?")
        path = query_parts[0]
        query = query_parts[1]
    Url(scheme: scheme, host: host, port: port, path: path, query: query, fragment: fragment)

pub fn script_fetch_flat_headers_to_text(headers: [text]) -> text:
    var lines: [text] = []
    var i = 0
    while i + 1 < headers.len():
        lines.push(headers[i] + ": " + headers[i + 1])
        i = i + 2
    lines.join("\n")

pub fn script_fetch_response_headers(headers: text) -> [text]:
    if headers == "":
        return []
    var flat: [text] = []
    var start: i64 = 0
    var i: i64 = 0
    while i <= headers.len():
        if i == headers.len() or headers.slice(i, i + 1) == "\n":
            flat = script_fetch_push_header_line(flat, headers.slice(start, i))
            start = i + 1
        i = i + 1
    flat

fn script_fetch_push_header_line(flat: [text], line_raw: text) -> [text]:
    var next = flat
    val line = line_raw.trim()
    val colon = line.index_of(":")
    if colon > 0:
        next.push(line.slice(0, colon).trim())
        next.push(line.slice(colon + 1, line.len()).trim())
    next

pub class ScriptStaticFetchDispatch:
    status: i64
    headers: text
    body: text

    static fn create(status: i64, headers: text, body: text) -> ScriptStaticFetchDispatch:
        ScriptStaticFetchDispatch(status: status, headers: headers, body: body)

    me fn dispatch(request: FetchRequest) -> FetchResponse:
        FetchResponse(status: self.status, headers: self.headers, body: rt_text_to_bytes(self.body))

# =========================================================================
# WebSocket API
# =========================================================================

pub val WEBSOCKET_CONNECTING: i64 = 0
pub val WEBSOCKET_OPEN: i64 = 1
pub val WEBSOCKET_CLOSING: i64 = 2
pub val WEBSOCKET_CLOSED: i64 = 3
pub val WEBSOCKET_CLOSE_NORMAL: i64 = 1000
pub val WEBSOCKET_CLOSE_NO_STATUS: i64 = 1005

pub class WebSocketConnection:
    """An in-memory WebSocket connection model.

    Fields:
        url             - connection URL
        state           - connection state: "connecting", "open", "closing", "closed"
        ready_state     - browser-compatible numeric readyState
        buffered_amount - bytes queued by script sends
        protocol        - selected subprotocol, empty when none was negotiated
        extensions      - selected extensions, empty when none were negotiated
        messages        - sent message buffer for deterministic tests
        received_messages - queued incoming message buffer
        close_code      - browser-compatible close code model
        close_reason    - browser-compatible close reason model
        close_was_clean - true when close metadata represents a clean close
    """
    url: text
    state: text
    ready_state: i64
    buffered_amount: i64
    protocol: text
    extensions: text
    messages: [text]
    received_messages: [text]
    close_code: i64
    close_reason: text
    close_was_clean: bool

pub class WebSocketReceiveResult:
    connection: WebSocketConnection
    message: text
    has_message: bool

pub fn websocket_connect(url: text) -> WebSocketConnection:
    """Create a deterministic script-level WebSocket connection.

    Valid ws:// and wss:// URLs enter "open" state for script-level tests.
    Invalid schemes and fragment-bearing URLs are represented as "closed" so
    sends cannot be queued.
    """
    websocket_connect_with_protocols(url, [])

pub fn websocket_connect_with_protocols(url: text, protocols: [text]) -> WebSocketConnection:
    """Create a deterministic script-level WebSocket with subprotocol input.

    The no-I/O model selects the first browser-token-like protocol from the
    caller-provided list. Invalid closed connections keep an empty protocol.
    """
    if not (url.starts_with("ws://") or url.starts_with("wss://")) or url.contains("#"):
        return websocket_new_connection(url, "closed", WEBSOCKET_CLOSED, "", WEBSOCKET_CLOSE_NO_STATUS, "", false)
    websocket_new_connection(url, "open", WEBSOCKET_OPEN, websocket_select_protocol(protocols), WEBSOCKET_CLOSE_NO_STATUS, "", false)

pub fn websocket_send(ws: WebSocketConnection, msg: text) -> WebSocketConnection:
    """Send a message through the WebSocket.

    Appends to the in-memory message buffer for deterministic script tests.
    Closed connections ignore sends, matching browser-safe no-delivery behavior
    without raising host-side errors.
    """
    if ws.ready_state != WEBSOCKET_OPEN:
        return ws
    var next = ws
    next.messages.push(msg)
    next.buffered_amount = next.buffered_amount + msg.len()
    next

pub fn websocket_close(ws: WebSocketConnection) -> WebSocketConnection:
    """Close the WebSocket connection."""
    websocket_close_with_code(ws, WEBSOCKET_CLOSE_NORMAL, "")

pub fn websocket_close_with_code(ws: WebSocketConnection, code: i64, reason: text) -> WebSocketConnection:
    """Close the WebSocket connection with browser-compatible metadata."""
    if ws.ready_state == WEBSOCKET_CLOSED:
        return ws
    if websocket_close_code_is_valid(code):
        var clean = ws
        clean.state = "closed"
        clean.ready_state = WEBSOCKET_CLOSED
        clean.close_code = code
        clean.close_reason = reason
        clean.close_was_clean = true
        return clean
    var unsafe = ws
    unsafe.state = "closed"
    unsafe.ready_state = WEBSOCKET_CLOSED
    unsafe.close_code = WEBSOCKET_CLOSE_NO_STATUS
    unsafe.close_reason = ""
    unsafe.close_was_clean = false
    unsafe

pub fn websocket_queue_received(ws: WebSocketConnection, msg: text) -> WebSocketConnection:
    """Queue an incoming message without performing live network I/O."""
    if ws.ready_state != WEBSOCKET_OPEN:
        return ws
    var next = ws
    next.received_messages.push(msg)
    next

pub fn websocket_receive_next(ws: WebSocketConnection) -> WebSocketReceiveResult:
    """Remove and return the oldest queued incoming message, if any."""
    if ws.received_messages.len() == 0:
        return WebSocketReceiveResult(connection: ws, message: "", has_message: false)
    var next = ws
    val msg = next.received_messages[0]
    var remaining: [text] = []
    var i = 1
    while i < next.received_messages.len():
        remaining.push(next.received_messages[i])
        i = i + 1
    next.received_messages = remaining
    WebSocketReceiveResult(connection: next, message: msg, has_message: true)

pub fn websocket_receive_count(ws: WebSocketConnection) -> i64:
    """Return the number of queued incoming messages."""
    ws.received_messages.len()

fn websocket_new_connection(url: text, state: text, ready_state: i64, protocol: text, close_code: i64, close_reason: text, close_was_clean: bool) -> WebSocketConnection:
    WebSocketConnection(
        url: url,
        state: state,
        ready_state: ready_state,
        buffered_amount: 0,
        protocol: protocol,
        extensions: "",
        messages: [],
        received_messages: [],
        close_code: close_code,
        close_reason: close_reason,
        close_was_clean: close_was_clean
    )

fn websocket_select_protocol(protocols: [text]) -> text:
    var i = 0
    while i < protocols.len():
        val protocol = protocols[i]
        if websocket_protocol_token_is_valid(protocol):
            return protocol
        i = i + 1
    ""

fn websocket_protocol_token_is_valid(protocol: text) -> bool:
    protocol != "" and protocol.trim() == protocol and not protocol.contains(" ") and not protocol.contains(",")

fn websocket_close_code_is_valid(code: i64) -> bool:
    code == WEBSOCKET_CLOSE_NORMAL or (code >= 3000 and code <= 4999)
