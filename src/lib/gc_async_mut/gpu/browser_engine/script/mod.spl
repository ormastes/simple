"""
# Browser Script Module

Simple-script execution layer for the browser engine.
Runs Simple language code from <script> tags, replacing the JS engine approach.

## Components
- ScriptHost: Top-level execution host managing script execution, event loop, and console
- ScriptRunner: Wraps Simple source, writes temp .spl, calls interpret_file
- EventLoop: Macrotask queue and rAF scheduling for async operations
- ConsoleBuffer: Ring buffer for console output (512 entries)
- DOM API: document_query_selector, document_create_element, node_append_child, etc.
- Event API: node_add_event_listener, event_dispatch, event_create, etc.
- Console API: console_log, console_warn, console_error, etc.
- Timer API: set_timeout, set_interval, request_animation_frame, etc.
- Network API: fetch_create_request, fetch_send, websocket_connect, etc.
- Storage API: storage_get_item, storage_set_item, storage_clear, etc.
- Canvas API: canvas_fill_rect, canvas_stroke, canvas_begin_path, etc.
- Form API: form_get_value, form_set_value, form_validate, etc.
- Clipboard API: clipboard_write_text, clipboard_read_text
- Worker API: worker_create, worker_post_message, worker_terminate
- Location API: location_from_url, history_push_state, history_back, etc.

References:
- M15: Browser engine integration milestone
"""

#![allow(REQC001)]

pub use std.gc_async_mut.gpu.browser_engine.script.script_host.{ScriptHost}
pub use std.gc_async_mut.gpu.browser_engine.script.script_runner.{ScriptRunner}
pub use std.gc_async_mut.gpu.browser_engine.script.event_loop.{EventLoop}
pub use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer, ConsoleEntry}
pub use std.gc_async_mut.gpu.browser_engine.script.simple_script.{SimpleScriptExecutor}
