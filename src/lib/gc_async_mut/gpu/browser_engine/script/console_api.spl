"""
# Console API

Simple-script console logging API for the browser engine.
All functions write to a ConsoleBuffer instance.

JS Equivalent → Simple Function:
    console.log()      → console_log()
    console.warn()     → console_warn()
    console.error()    → console_error()
    console.info()     → console_info()
    console.debug()    → console_debug()
    console.clear()    → console_clear()
    console.time()     → console_time()
    console.timeEnd()  → console_time_end()
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer}

# =========================================================================
# Timer State — module-level label→timestamp map (flat key/value array)
# =========================================================================

var _timer_labels: [text] = []
var _timer_stamps: [i64] = []

# =========================================================================
# Logging Functions
# =========================================================================

pub fn console_log(buf: ConsoleBuffer, msg: text):
    """Write a log-level entry to the console buffer."""
    buf.append("log", msg, 0)

pub fn console_warn(buf: ConsoleBuffer, msg: text):
    """Write a warn-level entry to the console buffer."""
    buf.append("warn", msg, 0)

pub fn console_error(buf: ConsoleBuffer, msg: text):
    """Write an error-level entry to the console buffer."""
    buf.append("error", msg, 0)

pub fn console_info(buf: ConsoleBuffer, msg: text):
    """Write an info-level entry to the console buffer."""
    buf.append("info", msg, 0)

pub fn console_debug(buf: ConsoleBuffer, msg: text):
    """Write a debug-level entry to the console buffer."""
    buf.append("debug", msg, 0)

pub fn console_clear(buf: ConsoleBuffer):
    """Clear all entries from the console buffer."""
    buf.clear()

# =========================================================================
# Timer Functions
# =========================================================================

pub fn console_time(buf: ConsoleBuffer, label: text):
    """Start a named timer. Records the label for later time_end lookup."""
    # Check for duplicate label
    var i = 0
    while i < _timer_labels.len():
        if _timer_labels[i] == label:
            buf.append("warn", "Timer '{label}' already exists", 0)
            return
        i = i + 1
    _timer_labels.push(label)
    _timer_stamps.push(0)

pub fn console_time_end(buf: ConsoleBuffer, label: text):
    """End a named timer and log the elapsed time.

    NOTE: Actual timing requires runtime clock access. Currently logs a
    placeholder message indicating the timer was stopped.
    """
    var new_labels: [text] = []
    var new_stamps: [i64] = []
    var found = false
    var i = 0
    while i < _timer_labels.len():
        if _timer_labels[i] == label:
            found = true
        else:
            new_labels.push(_timer_labels[i])
            new_stamps.push(_timer_stamps[i])
        i = i + 1
    _timer_labels = new_labels
    _timer_stamps = new_stamps
    if found:
        buf.append("log", "{label}: timer ended", 0)
    else:
        buf.append("warn", "Timer '{label}' does not exist", 0)
