"""
# Script Runner

Engine that executes scripts from <script> tags in the browser engine.
Supports both Simple scripts (type="text/simple") and JavaScript
(type="text/javascript" or no type attribute, which defaults to JS).

JavaScript sources are transpiled to Simple via js_transpiler before
execution. The transpiler handles common JS patterns (var/let/const,
arrow functions, DOM API calls, template literals, etc.).

Architecture:
    1. ScriptRunner receives script source and type from a <script> tag
    2. If JavaScript, it runs js_transpile() to convert to Simple
    3. It wraps the source with necessary imports (DOM API, console, etc.)
    4. Writes to a temp .spl file
    5. Calls interpret_file(path) to execute
    6. Collects results and marks DOM dirty if mutations occurred
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer}
use std.gc_async_mut.gpu.browser_engine.script.event_loop.{EventLoop}
use std.gc_async_mut.gpu.browser_engine.script.storage_api.{BrowserStorage}
use std.gc_async_mut.gpu.browser_engine.script.clipboard_api.{BrowserClipboard}
use std.gc_async_mut.gpu.browser_engine.script.location_api.{BrowserLocation, BrowserHistory}
use std.gc_async_mut.gpu.browser_engine.script.js_transpiler.{js_transpile, js_is_javascript, js_is_simple}

extern fn rt_file_write_text(path: text, content: text)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# =========================================================================
# Module-level shared state — the bridge between host and script
# =========================================================================

var _current_dom_root: BeDomNode? = nil
var _current_console: ConsoleBuffer? = nil
var _current_event_loop: EventLoop? = nil
var _script_counter: i64 = 0

# =========================================================================
# ScriptRunner
# =========================================================================

pub class ScriptRunner:
    """Executes Simple scripts in the context of a DOM tree.

    Fields:
        dom_root       - reference to the DOM root node
        console_buffer - console output buffer
        event_loop     - timer/rAF event loop
        storage        - localStorage equivalent
        clipboard      - clipboard buffer
        location       - current page location
        history        - navigation history
        _dom_dirty     - true if scripts have mutated the DOM
    """
    dom_root: BeDomNode
    console_buffer: ConsoleBuffer
    event_loop: EventLoop
    storage: BrowserStorage
    clipboard: BrowserClipboard
    location: BrowserLocation
    history: BrowserHistory
    _dom_dirty: bool

    static fn new() -> ScriptRunner:
        """Create a ScriptRunner with default state."""
        ScriptRunner(
            dom_root: BeDomNode.element("div"),
            console_buffer: ConsoleBuffer.new(),
            event_loop: EventLoop.new(),
            storage: BrowserStorage.new(),
            clipboard: BrowserClipboard.new(),
            location: BrowserLocation(
                href: "about:blank",
                protocol: "",
                host: "",
                pathname: "/",
                search: "",
                hash: ""
            ),
            history: BrowserHistory.new("about:blank"),
            _dom_dirty: false
        )

pub fn run_script_with_type(runner: ScriptRunner, source: text, script_type: text) -> text:
    """Execute a script with type detection and optional JS transpilation.

    If script_type indicates JavaScript (empty, "text/javascript", etc.),
    the source is first transpiled from JS to Simple via js_transpile().
    If script_type is "text/simple", runs directly as Simple code.

    Args:
        runner      - the ScriptRunner context
        source      - raw script source (JS or Simple)
        script_type - the type attribute from the <script> tag
    """
    if source.trim().len() == 0:
        return ""
    var effective_source = source
    if js_is_javascript(script_type):
        effective_source = js_transpile(source)
    run_script(runner, effective_source)

pub fn run_script(runner: ScriptRunner, source: text) -> text:
    """Execute a Simple script against the runner's DOM tree.

    Wraps the source with browser API imports and executes it via
    subprocess rt_process_run. Returns captured stdout. DOM mutations
    from scripts do not cross process boundary.
    """
    if source.trim().len() == 0:
        return ""

    # Set up shared state for the script to access
    _current_dom_root = Some(runner.dom_root)
    _current_console = Some(runner.console_buffer)
    _current_event_loop = Some(runner.event_loop)

    # Generate a unique temp file path
    _script_counter = _script_counter + 1
    val tmp_path = "/tmp/_simple_script_{_script_counter}.spl"

    # Build wrapped source with imports
    val wrapped = _wrap_script_source(source)

    # Write and execute via subprocess (DOM mutations don't cross process boundary)
    rt_file_write_text(tmp_path, wrapped)

    val result = rt_process_run("bin/simple", ["run", tmp_path])
    val stdout = result.0

    runner._dom_dirty = true
    stdout.trim()

pub fn run_script_file(runner: ScriptRunner, path: text) -> text:
    """Execute a Simple script file (for <script src="...">).

    Reads and executes the script at the given path. Returns stdout.
    """
    if not rt_file_exists(path):
        return ""
    val source = rt_file_read_text(path)
    run_script(runner, source)

pub fn run_script_file_with_type(runner: ScriptRunner, path: text, script_type: text) -> text:
    """Execute a script file with type-aware Simple/JS handling."""
    if not rt_file_exists(path):
        return ""
    val source = rt_file_read_text(path)
    run_script_with_type(runner, source, script_type)

pub fn script_runner_dom_dirty(runner: ScriptRunner) -> bool:
    """Check if scripts have mutated the DOM."""
    runner._dom_dirty

pub fn script_runner_clear_dirty(runner: ScriptRunner):
    """Clear the DOM dirty flag."""
    runner._dom_dirty = false

# =========================================================================
# Shared State Accessors — called by scripts via module-level functions
# =========================================================================

pub fn get_script_dom_root() -> BeDomNode?:
    """Return the current DOM root set by the runner, or nil."""
    _current_dom_root

pub fn get_script_console() -> ConsoleBuffer?:
    """Return the current console buffer, or nil."""
    _current_console

pub fn get_script_event_loop() -> EventLoop?:
    """Return the current event loop, or nil."""
    _current_event_loop

# =========================================================================
# Internal: Wrap script source with imports
# =========================================================================

fn _wrap_script_source(source: text) -> text:
    var lines: [text] = []
    lines.push("# Auto-generated script wrapper")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.dom_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.console_buffer.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.console_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.timer_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.event_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.storage_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.canvas_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.form_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.clipboard_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.network_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.worker_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.location_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.navigator_api.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.js_compat.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.script.script_runner.*")
    lines.push("use std.gc_async_mut.gpu.browser_engine.dom.*")
    lines.push("")
    lines.push("var buf = ConsoleBuffer.new()")
    lines.push(source)
    lines.push("val __console_entries = buf.entries()")
    lines.push("var __console_i = 0")
    lines.push("while __console_i < __console_entries.len():")
    lines.push("    print(\"__simple_console__|\" + __console_entries[__console_i].level + \"|\" + __console_entries[__console_i].message)")
    lines.push("    __console_i = __console_i + 1")
    lines.join("\n")
