# HTML Tree Builder — WHATWG insertion-mode tree construction
#
# Builds a BeDomNode tree from tokenized HTML.
# Key constraint: BeDomNode values are COPIED when pushed to arrays in interpreter mode.
# Pattern: use stack[n-1] = node after mutation; children added to parent when CLOSED.

use std.gc_async_mut.gpu.browser_engine.html_tokenizer.{
    HtmlTokenizer, HtmlToken, HtmlTokenKind, HtmlAttr,
    html_tokenizer_new, html_tokenizer_tokenize
}
use std.gc_async_mut.gpu.browser_engine.dom.{
    BeDomNode, be_dom_get_tag, be_dom_get_children, be_dom_get_attr,
    be_dom_add_child, be_dom_set_attr, be_dom_get_is_text,
    be_dom_set_children
}
use std.gc_async_mut.gpu.browser_engine.css.{be_default_style}

# Append child to node at top of stack, write it back
fn _stk_append(stack: [BeDomNode], child: BeDomNode) -> [BeDomNode]:
    """Append child to top of stack; return modified stack."""
    val n = stack.len()
    if n == 0: return stack
    var parent = stack[n - 1]
    var kids = parent.children
    kids.push(child)
    parent.children = kids
    stack[n - 1] = parent
    stack

# Pop top from stack, return it (caller writes back result stack)
fn _stk_pop_and_append(stack: [BeDomNode]) -> [BeDomNode]:
    """Pop top node, append it as child of new top. Return new stack."""
    val n = stack.len()
    if n <= 1: return stack
    val completed = stack[n - 1]
    var rest: [BeDomNode] = []
    var i = 0
    while i < n - 1:
        rest.push(stack[i])
        i = i + 1
    # Append completed to rest's top
    val rn = rest.len()
    var parent = rest[rn - 1]
    var kids = parent.children
    kids.push(completed)
    parent.children = kids
    rest[rn - 1] = parent
    rest

# Find top index of tag in stack (-1 if not found)
fn _stk_find_tag(stack: [BeDomNode], tag: text) -> i32:
    var i = stack.len() - 1
    while i >= 0:
        if be_dom_get_tag(stack[i]) == tag:
            return i
        i = i - 1
    -1

# Pop until and including tag
fn _stk_pop_until_incl(stack: [BeDomNode], tag: text) -> [BeDomNode]:
    var s = stack
    var limit = 200
    while limit > 0 and s.len() > 1:
        limit = limit - 1
        val top_tag = be_dom_get_tag(s[s.len() - 1])
        s = _stk_pop_and_append(s)
        if top_tag == tag:
            limit = 0  # done
    s

fn _is_void(tag: text) -> bool:
    if tag == "area": return true
    if tag == "base": return true
    if tag == "br": return true
    if tag == "col": return true
    if tag == "embed": return true
    if tag == "hr": return true
    if tag == "img": return true
    if tag == "input": return true
    if tag == "link": return true
    if tag == "meta": return true
    if tag == "param": return true
    if tag == "source": return true
    if tag == "track": return true
    if tag == "wbr": return true
    false

fn _is_table_context(tag: text) -> bool:
    """True if this tag is a table structural element."""
    tag == "table" or tag == "tbody" or tag == "thead" or tag == "tfoot" or tag == "tr"

fn _is_table_content(tag: text) -> bool:
    """True if this tag is valid inside a table."""
    if _is_table_context(tag): return true
    if tag == "td": return true
    if tag == "th": return true
    if tag == "col": return true
    if tag == "colgroup": return true
    if tag == "caption": return true
    false

fn _stk_in_table(stack: [BeDomNode]) -> bool:
    """True if current insertion context is inside a table structural element."""
    val top = be_dom_get_tag(stack[stack.len() - 1])
    _is_table_context(top)

fn _stk_find_table_ancestor(stack: [BeDomNode]) -> i32:
    """Find index of nearest table ancestor in stack, or -1."""
    var i = stack.len() - 1
    while i >= 0:
        if be_dom_get_tag(stack[i]) == "table":
            return i
        i = i - 1
    -1

fn _stk_foster_append(stack: [BeDomNode], child: BeDomNode) -> [BeDomNode]:
    """Append child before the table — to the table's parent. Returns modified stack."""
    val table_idx = _stk_find_table_ancestor(stack)
    if table_idx <= 0:
        # No table or table is root — append to bottom
        return _stk_append(stack, child)
    else:
        # Append to the table's parent (table_idx - 1)
        var s = stack
        var parent = s[table_idx - 1]
        var kids = parent.children
        kids.push(child)
        parent.children = kids
        s[table_idx - 1] = parent
        return s

fn _closes_p_elem(tag: text) -> bool:
    if tag == "address": return true
    if tag == "article": return true
    if tag == "aside": return true
    if tag == "blockquote": return true
    if tag == "div": return true
    if tag == "dl": return true
    if tag == "fieldset": return true
    if tag == "footer": return true
    if tag == "h1": return true
    if tag == "h2": return true
    if tag == "h3": return true
    if tag == "h4": return true
    if tag == "h5": return true
    if tag == "h6": return true
    if tag == "header": return true
    if tag == "hr": return true
    if tag == "main": return true
    if tag == "menu": return true
    if tag == "nav": return true
    if tag == "ol": return true
    if tag == "p": return true
    if tag == "pre": return true
    if tag == "section": return true
    if tag == "table": return true
    if tag == "ul": return true
    false

fn _apply_attrs(node: BeDomNode, attrs: [HtmlAttr]) -> BeDomNode:
    """Apply attributes to node and return the modified node."""
    var n = node
    var ai = 0
    while ai < attrs.len():
        val attr = attrs[ai]
        ai = ai + 1
        n.set_attr(attr.name, attr.value)
    n

pub class TreeBuilderResult:
    """Result from html_tree_builder_build_with_scripts.

    Fields:
        doc       - the built DOM tree (#document node)
        scripts   - collected <script> bodies in document order
        src_paths - collected <script src="..."> paths in document order
    """
    doc: BeDomNode
    scripts: [text]
    src_paths: [text]

pub fn html_tree_builder_build(html_text: text) -> BeDomNode:
    """Build a BeDomNode tree. Returns a #document node with an html child."""
    val result = html_tree_builder_build_with_scripts(html_text)
    result.doc

pub fn html_tree_builder_build_with_scripts(html_text: text) -> TreeBuilderResult:
    """Build a BeDomNode tree and collect <script> content.

    Returns a TreeBuilderResult with the DOM tree and any inline script
    bodies or external script src paths found during parsing.
    """
    val tokenizer = html_tokenizer_new(html_text)
    val tokens = html_tokenizer_tokenize(tokenizer)

    # Collected script content
    var script_bodies: [text] = []
    var script_src_paths: [text] = []

    # Stack: [#document, html, head] initially
    # We'll switch from head-mode to body-mode on first body content
    val doc_node = BeDomNode.element("#document")
    val html_el = BeDomNode.element("html")
    val head_el = BeDomNode.element("head")
    val body_el = BeDomNode.element("body")

    var stack: [BeDomNode] = []
    stack.push(doc_node)
    stack.push(html_el)
    stack.push(head_el)

    var in_body = false
    var in_script = false
    var script_content = ""
    var script_src = ""

    val ntok = tokens.len()
    var ti = 0
    while ti < ntok:
        val tok = tokens[ti]
        ti = ti + 1

        if tok.token_kind == HtmlTokenKind.Eof:
            ti = ntok

        elif tok.token_kind == HtmlTokenKind.Doctype:
            pass_dn

        elif tok.token_kind == HtmlTokenKind.Comment:
            pass_dn

        elif tok.token_kind == HtmlTokenKind.StartTag:
            val t = tok.tag_name

            if t == "html" or t == "head":
                pass_dn  # already implicit

            elif t == "body":
                if not in_body:
                    # Pop head, push body
                    stack = _stk_pop_and_append(stack)
                    stack.push(body_el)
                    in_body = true

            elif t == "title" or t == "meta" or t == "link" or t == "base":
                # head elements — add to top of stack as void children
                val he_raw = BeDomNode.element(t)
                val he = _apply_attrs(he_raw, tok.attrs)
                stack = _stk_append(stack, he)

            elif t == "script":
                # M15: Collect script content for execution
                if not in_body:
                    stack = _stk_pop_and_append(stack)
                    stack.push(body_el)
                    in_body = true
                in_script = true
                script_content = ""
                # Check for src attribute
                script_src = ""
                var sa = 0
                while sa < tok.attrs.len():
                    val attr = tok.attrs[sa]
                    if attr.name == "src":
                        script_src = attr.value
                    sa = sa + 1
                # Push script element onto stack
                val script_el = BeDomNode.element("script")
                val script_node = _apply_attrs(script_el, tok.attrs)
                stack.push(script_node)

            elif t == "style" or t == "noscript":
                pass_dn  # skip raw text elements

            else:
                # Switch to body if not yet
                if not in_body:
                    stack = _stk_pop_and_append(stack)  # close head
                    stack.push(body_el)
                    in_body = true

                # Implicit close of <p> before block elements
                if _closes_p_elem(t) and _stk_find_tag(stack, "p") >= 0:
                    stack = _stk_pop_until_incl(stack, "p")

                # Implicit close of <li> before new <li>
                if t == "li" and _stk_find_tag(stack, "li") >= 0:
                    stack = _stk_pop_until_incl(stack, "li")

                # Implicit close of <dt>/<dd>
                if t == "dt" and _stk_find_tag(stack, "dt") >= 0:
                    stack = _stk_pop_until_incl(stack, "dt")
                if t == "dd" and _stk_find_tag(stack, "dd") >= 0:
                    stack = _stk_pop_until_incl(stack, "dd")

                # Check if we're in a table context with non-table content
                val top_tag = be_dom_get_tag(stack[stack.len() - 1])
                val in_table_ctx = _is_table_context(top_tag)
                val is_table_content = _is_table_content(t)

                if _is_void(t):
                    val vn_raw = BeDomNode.element(t)
                    val vnode = _apply_attrs(vn_raw, tok.attrs)
                    if in_table_ctx and not is_table_content:
                        stack = _stk_foster_append(stack, vnode)
                    else:
                        stack = _stk_append(stack, vnode)
                elif in_table_ctx and not is_table_content:
                    # Foster-parent non-table elements that appear inside table context
                    val fp_raw = BeDomNode.element(t)
                    val fp_el = _apply_attrs(fp_raw, tok.attrs)
                    # Insert before table: find table ancestor, insert in its parent
                    val tbl_idx = _stk_find_table_ancestor(stack)
                    if tbl_idx > 0:
                        var tbl_parent = stack[tbl_idx - 1]
                        var fp_kids = tbl_parent.children
                        fp_kids.push(fp_el)
                        tbl_parent.children = fp_kids
                        stack[tbl_idx - 1] = tbl_parent
                    else:
                        stack = _stk_append(stack, fp_el)
                else:
                    val el_raw = BeDomNode.element(t)
                    val new_el = _apply_attrs(el_raw, tok.attrs)
                    stack.push(new_el)

        elif tok.token_kind == HtmlTokenKind.EndTag:
            val et = tok.tag_name
            if et == "script" and in_script:
                # M15: Close script tag — collect content
                in_script = false
                if script_src != "":
                    script_src_paths.push(script_src)
                elif script_content.trim().len() > 0:
                    script_bodies.push(script_content)
                # Store content in the script node's text_content
                var top = stack[stack.len() - 1]
                top.text_content = script_content
                stack[stack.len() - 1] = top
                # Pop script node and append to parent
                if _stk_find_tag(stack, "script") >= 0:
                    stack = _stk_pop_and_append(stack)
                script_content = ""
                script_src = ""
            elif et == "html" or et == "body" or et == "head":
                pass_dn  # handled in drain
            elif _stk_find_tag(stack, et) >= 0:
                stack = _stk_pop_until_incl(stack, et)

        elif tok.token_kind == HtmlTokenKind.Character:
            val data = tok.data
            # M15: Accumulate text inside <script> tags
            if in_script:
                script_content = "{script_content}{data}"
            elif not in_body:
                if data.trim().len() > 0:
                    # Non-whitespace before body — switch to body
                    stack = _stk_pop_and_append(stack)  # close head
                    stack.push(body_el)
                    in_body = true
                    val tn = BeDomNode.text(data)
                    stack = _stk_append(stack, tn)
            else:
                val tn2 = BeDomNode.text(data)
                stack = _stk_append(stack, tn2)

    # Drain remaining open elements
    while stack.len() > 1:
        stack = _stk_pop_and_append(stack)

    # stack[0] is now doc_node with html as only child (after drain)
    # But since we modified stack[0] in place, we need to return it
    val final_doc = if stack.len() > 0: stack[0] else: doc_node
    TreeBuilderResult(doc: final_doc, scripts: script_bodies, src_paths: script_src_paths)
