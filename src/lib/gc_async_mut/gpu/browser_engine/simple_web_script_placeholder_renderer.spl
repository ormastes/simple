"""
Simple Web Script Placeholder Renderer

Small script-mode URL placeholder for about: and not-yet-loaded URLs. The
file:// script execution path stays in simple_web_script_renderer so unloaded
script-capable surfaces do not retain BrowserRenderer or process/file stubs.
"""

use std.gc_async_mut.gpu.browser_engine.simple_web_url_placeholder_renderer.{simple_web_render_placeholder_url_to_pixels}

pub fn simple_web_render_script_placeholder_url_to_pixels(url: text, width: i64, height: i64) -> [u8]:
    simple_web_render_placeholder_url_to_pixels(url, width, height)
