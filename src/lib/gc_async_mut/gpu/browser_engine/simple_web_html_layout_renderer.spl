    font_size: i32
    font_family: text
    resolved_font_identity: text
    resolved_font_advances: [i32]
    resolved_font_width: i32
    resolved_font_line_height: i32
    line_height_px: i32
    width_px: i32
    height_px: i32
    border_box: bool
    min_width_px: i32
    max_width_px: i32
    min_height_px: i32
    max_height_px: i32
    min_height_vh: bool
    flex_fill: bool
    flex_grow: i32
    flex_shrink: i32
    flex_basis_px: i32
    order: i32
    flex_wrap: text
    justify_content: text
    align_items: text
    align_self: text
    align_content: text
    pad_l: i32
    pad_t: i32
    pad_r: i32
    pad_b: i32
    border_w: i32
    border_color: u32
    border_l: i32
    border_t: i32
    border_r: i32
    border_b: i32
    border_color_l: u32
    border_color_t: u32
    border_color_r: u32
    border_color_b: u32
    outline_w: i32
    outline_color: u32
    outline_offset_px: i32
    box_shadow_x_px: i32
    box_shadow_y_px: i32
    box_shadow_color: u32
    box_shadow_blur_px: i32
    box_shadow_alpha: i32
    box_shadow_raw: text
    bg_layers_raw: text
    border_radius_px: i32
    border_radius_tl_px: i32
    border_radius_tr_px: i32
    border_radius_br_px: i32
    border_radius_bl_px: i32
    gap_px: i32
    row_gap_px: i32
    column_gap_px: i32
    margin_l: i32
    margin_t: i32
    margin_r: i32
    margin_b: i32
    margin_l_auto: bool
    margin_r_auto: bool
    margin_t_auto: bool
    margin_b_auto: bool
    display: text       # block / inline / contents / none
    overflow_hidden: bool
    overflow_auto_y: bool
    scrollbar_thumb_color: u32
    scrollbar_track_color: u32
    text_overflow_ellipsis: bool
    visibility_hidden: bool
    content_visibility_hidden: bool
    will_change: text
    color_adjust: text
    forced_color_adjust: text
    print_color_adjust: text
    orphans: i32
    widows: i32
    position_relative: bool
    position_absolute: bool
    left_px: i32
    top_px: i32
    right_px: i32
    bottom_px: i32
    z_index: i32
    opacity_pct: i32
    flex_direction: text
    text_align: text
    text_align_last: text
    text_justify: text
    text_transform: text
    text_indent_px: i32
    letter_spacing_px: i32
    word_spacing_px: i32
    font_size_adjust: text
    font_palette: text
    font_feature_settings: text
    font_language_override: text
    font_variation_settings: text
    font_variant: text
    font_variant_alternates: text
    font_variant_caps: text
    font_variant_east_asian: text
    font_variant_emoji: text
    font_variant_ligatures: text
    font_variant_numeric: text
    font_variant_position: text
    font_style_italic: bool
    font_kerning: text
    font_optical_sizing: text
    font_stretch: text
    font_width: text
    font_synthesis: text
    font_synthesis_small_caps: text
    font_synthesis_position: text
    font_synthesis_style: text
    font_synthesis_weight: text
    direction_rtl: bool
    writing_mode: text
    text_orientation: text
    text_combine_upright: text
    text_shadow_x_px: i32
    text_shadow_y_px: i32
    text_shadow_color: u32
