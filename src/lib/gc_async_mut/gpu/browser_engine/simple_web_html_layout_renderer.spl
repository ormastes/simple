fn styles_with_height(styles: [Style], index: i32, height_px: i32) -> [Style]:
    val style_count = styles.len()
    if style_count == 0:
        return []
    var result: [Style] = [styles[0]; style_count]
    var si = 0
    while si < style_count:
        if si == index:
            result[si] = style_with_height(styles[si], height_px)
        else:
            result[si] = styles[si]
        si = si + 1
    result
fn intrinsic_text_width(nodes: [HNode], styles: [Style], child_index: HtmlChildIndex, i: i32, widths: [i32]) -> IntrinsicWidthResult:
    if widths[i] >= 0:
        return IntrinsicWidthResult(width: widths[i], widths: widths)
    var out_widths = widths
    var width = 0
    var c = child_index.first_child[i]
    while c >= 0:
        if nodes[c].tag == "#text":
            val txt: text = nodes[c].text_trimmed
            if txt.len() > 0:
                val resolved = styles[c].resolved_font_width
                if resolved > 0:
                    width = width + resolved
                else:
                    val glyph_w = style_char_w(styles[c])
                    val ink_w = if glyph_w > 1: glyph_w - 1 else: glyph_w
                    width = width + txt.len() * ink_w
        elif styles[c].display == "inline":
            val child = intrinsic_text_width(nodes, styles, child_index, c, out_widths)
            out_widths = child.widths
            width = width + child.width
        c = child_index.next_sibling[c]
    if nodes[i].tag != "#text":
        width = width + styles[i].pad_l + styles[i].pad_r + styles[i].border_l + styles[i].border_r
    out_widths[i] = width
    IntrinsicWidthResult(width: width, widths: out_widths)

fn inline_text_advance_width(node: HNode, st: Style) -> i32:
    if node.tag != "#text":
        return 0
    val raw = node.text_data
    if st.resolved_font_width > 0 and st.resolved_font_advances.len() == raw.len():
        return st.resolved_font_width
    if raw == " " and node.text_trimmed == "":
        var whitespace_advance = style_space_advance(st) / 3
        if whitespace_advance < 1:
            whitespace_advance = 1
        return whitespace_advance
    var width = 0
    var i = 0
    val n = raw.len()
    val advance = style_text_advance(st)
    val space_advance = style_space_advance(st)
    while i < n:
        val ch = raw.char_code_at(i)
        if ch == 32:
            width = width + space_advance
        elif ch == 9 or ch == 10 or ch == 13:
            if node.text_trimmed != "":
                width = width + space_advance
        else:
            width = width + advance
        i = i + 1
    width

fn text_ink_y_offset(fs: i32) -> i32:
    val scale = glyph_scale(fs)
    if scale > 1:
        return scale + 1
    1

fn text_ink_x_offset(fs: i32) -> i32:
    1

fn wrap_line_end(txt: text, off: i32, cpl: i32) -> i32:
    val n = txt.len()
    var limit = off + cpl
    if limit >= n:
        return n
    var last_space = -1
    var i = off
    while i < limit:
        if txt.char_code_at(i) == 32:
            last_space = i
        i = i + 1
    if last_space > off:
        return last_space
    limit

fn skip_wrap_spaces(txt: text, off: i32) -> i32:
    var out = off
    val n = txt.len()
    while out < n and txt.char_code_at(out) == 32:
        out = out + 1
    out

fn text_line_advance_width(txt: text, start: i32, endv: i32, advance: i32, space_advance: i32) -> i32:
    var width = 0
    var i = start
    while i < endv:
        width = width + if txt.char_code_at(i) == 32: space_advance else: advance
        i = i + 1
    width

fn style_text_line_advance_width(txt: text, start: i32, endv: i32, st: Style, advance: i32, space_advance: i32) -> i32:
    val resolved = resolved_text_range_width(st, start, endv)
    if resolved >= 0:
        return resolved
    text_line_advance_width(txt, start, endv, advance, space_advance)

fn text_line_aligned_x(base_x: i32, line_box_w: i32, line_w: i32, st: Style, line_i: i32, line_count: i32) -> i32:
    var align = st.text_align
    if line_i == line_count - 1 and st.text_align_last != "auto":
        align = st.text_align_last
    if align == "start":
        align = if st.direction_rtl: "right" else: "left"
    elif align == "end":
        align = if st.direction_rtl: "left" else: "right"
    if align == "center":
        return base_x + (line_box_w - line_w) / 2
    if align == "right":
        return base_x + line_box_w - line_w
    base_x

fn text_line_needs_paint_width(st: Style, line_i: i32, line_count: i32) -> bool:
    if st.text_decoration_underline:
        return true
    var align = st.text_align
    if line_i == line_count - 1 and st.text_align_last != "auto":
        align = st.text_align_last
    if align == "center" or align == "right":
        return true
    if align == "start":
        return st.direction_rtl
    if align == "end":
        return not st.direction_rtl
    false

fn ellipsize_text_for_width(txt: text, start: i32, endv: i32, max_width: i32, st: Style, advance: i32, space_advance: i32) -> text:
    if max_width <= 0:
        return ""
    val full_width = style_text_line_advance_width(txt, start, endv, st, advance, space_advance)
    if full_width <= max_width:
        return txt.substring(start, endv)
    val ellipsis = "..."
    val ellipsis_w = text_line_advance_width(ellipsis, 0, ellipsis.len(), advance, space_advance)
    if max_width <= ellipsis_w:
        return ellipsis
    val content_limit = max_width - ellipsis_w
    var out = ""
    var used = 0
    var i = start
    while i < endv:
        val resolved_char_w = resolved_text_range_width(st, i, i + 1)
        val char_w = if resolved_char_w >= 0: resolved_char_w elif txt.char_code_at(i) == 32: space_advance else: advance
        if used + char_w > content_limit:
            break
        out = out + txt.char_at(i)
        used = used + char_w
        i = i + 1
    out + ellipsis

fn compute_wrap_ranges(txt: text, cpl: i32) -> LineWrapRanges:
    val txt_len = txt.len()
    if txt_len == 0:
        return LineWrapRanges(starts: [0; 1], ends: [0; 1])
    var line_count = 0
    var count_off = 0
    while count_off < txt_len:
        val endc = wrap_line_end(txt, count_off, cpl)
        line_count = line_count + 1
        count_off = skip_wrap_spaces(txt, endc)
    if line_count <= 0:
        return LineWrapRanges(starts: [0; 1], ends: [0; 1])
    var starts: [i32] = [0; line_count]
    var ends: [i32] = [0; line_count]
    var off = 0
    var line = 0
    while off < txt_len:
        val endc = wrap_line_end(txt, off, cpl)
        starts[line] = off
        ends[line] = endc
        off = skip_wrap_spaces(txt, endc)
        line = line + 1
    LineWrapRanges(starts: starts, ends: ends)

fn compute_style_wrap_ranges(txt: text, max_width: i32, st: Style, fallback_cpl: i32) -> LineWrapRanges:
    if st.resolved_font_identity == "" or st.resolved_font_advances.len() != txt.len() or max_width <= 0:
        return compute_wrap_ranges(txt, fallback_cpl)
    var starts: [i32] = []
    var ends: [i32] = []
    var start = 0
    val n = txt.len()
    while start < n:
        var endv = start
        var used = 0
        var last_space = -1
        while endv < n and used + st.resolved_font_advances[endv] <= max_width:
            used = used + st.resolved_font_advances[endv]
            if txt.char_code_at(endv) == 32:
                last_space = endv
            endv = endv + 1
        if endv == start:
            endv = start + 1
        elif endv < n and last_space > start:
            endv = last_space
        starts.push(start)
        ends.push(endv)
        start = skip_wrap_spaces(txt, endv)
    LineWrapRanges(starts: starts, ends: ends)

fn zero_i32_list(count: i32) -> [i32]:
    [0; count]

fn neg_one_i32_list(count: i32) -> [i32]:
    [-1; count]

fn shifted_i32_list(values: [i32], delta: i32) -> [i32]:
    val count = values.len()
    var shifted: [i32] = [0; count]
    var i = 0
    while i < count:
        shifted[i] = values[i] + delta
        i = i + 1
    shifted

fn empty_i32_lists(count: i32) -> [[i32]]:
    [[]; count]

fn css_outer_width(node: HNode, st: Style, css_width: i32) -> i32:
    val legacy_widget_box = node.has_widget_class or node.has_icon_image_class
    if legacy_widget_box or st.border_box:
        return css_width
    css_width + st.pad_l + st.pad_r + st.border_l + st.border_r

fn css_outer_height(node: HNode, st: Style, css_height: i32) -> i32:
    val legacy_widget_box = node.has_widget_class or node.has_icon_image_class
    if legacy_widget_box or st.border_box:
        return css_height
    css_height + st.pad_t + st.pad_b + st.border_t + st.border_b

fn definite_content_height_limit(node: HNode, st: Style) -> i32:
    val legacy_widget_box = node.has_widget_class or node.has_icon_image_class
    val border_y = st.border_t + st.border_b
    if st.height_px > 0:
        if legacy_widget_box or st.border_box:
            return st.height_px - st.pad_t - st.pad_b - border_y
        return st.height_px
    if st.min_height_px > 0:
        return st.min_height_px
    0

fn constrained_outer_width(node: HNode, st: Style, candidate_width: i32) -> i32:
    var out = candidate_width
    if st.min_width_px > 0:
        val min_outer = css_outer_width(node, st, st.min_width_px)
        if out < min_outer:
            out = min_outer
    if st.max_width_px > 0:
        val max_outer = css_outer_width(node, st, st.max_width_px)
        if out > max_outer:
            out = max_outer
    if out < 1:
        out = 1
    out

fn constrained_outer_height(node: HNode, st: Style, candidate_height: i32) -> i32:
    var out = candidate_height
    if st.min_height_px > 0:
        val min_outer = css_outer_height(node, st, st.min_height_px)
        if out < min_outer:
            out = min_outer
    if st.max_height_px > 0:
        val max_outer = css_outer_height(node, st, st.max_height_px)
        if out > max_outer:
            out = max_outer
    if out < 1:
        out = 1
    out

fn absolute_outer_width(parent: Style, node: HNode, st: Style, containing_w: i32) -> i32:
    if st.width_px == 0 and st.left_px > 0 and st.right_px >= 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        var stretched = padding_box_w - st.left_px - st.right_px
        if stretched < 1:
            stretched = 1
        return constrained_outer_width(node, st, stretched)
    if st.width_px < 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        val percent_content_w = padding_box_w * (0 - st.width_px) / 100
        return constrained_outer_width(node, st, css_outer_width(node, st, percent_content_w))
    val explicit_node_w = css_outer_width(node, st, st.width_px)
    if st.width_px > 0:
        return constrained_outer_width(node, st, explicit_node_w)
    constrained_outer_width(node, st, containing_w)

fn absolute_outer_height(node: HNode, st: Style, containing_h: i32) -> i32:
    val border_y = st.border_t + st.border_b
    val resolved_h = resolve_percent_height_px(st.height_px, containing_h)
    if resolved_h > 0:
        if st.border_box:
            return constrained_outer_height(node, st, resolved_h)
        return constrained_outer_height(node, st, resolved_h + st.pad_t + st.pad_b + border_y)
    constrained_outer_height(node, st, style_line_h(st))

fn resolve_horizontal_margin_px(margin_px: i32, containing_w: i32) -> i32:
    if margin_px < 0:
        return containing_w * (0 - margin_px) / 100
    margin_px

fn resolve_percent_height_px(height_px: i32, containing_h: i32) -> i32:
    if height_px < 0 and containing_h > 0:
        return containing_h * (0 - height_px) / 100
    height_px

fn resolve_vertical_margin_px(margin_px: i32, viewport_h: i32) -> i32:
    if margin_px <= -1000:
        return viewport_h * ((0 - margin_px) - 1000) / 100
    if margin_px < 0:
        return 0
    margin_px

fn absolute_child_x(parent_x: i32, parent: Style, child_node: HNode, child: Style, containing_w: i32) -> i32:
    if child.right_px >= 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        return parent_x + parent.border_l + padding_box_w - absolute_outer_width(parent, child_node, child, containing_w) - child.right_px
    parent_x + parent.border_l + child.left_px

fn absolute_child_y(parent_y: i32, parent: Style, child_node: HNode, child: Style, containing_h: i32) -> i32:
    if child.bottom_px >= 0:
        return parent_y + parent.border_t + containing_h - absolute_outer_height(child_node, child, containing_h) - child.bottom_px
    parent_y + parent.border_t + child.top_px

fn absolute_child_styles(styles: [Style], child_index: i32, parent: Style, child: Style, containing_w: i32, containing_h: i32) -> [Style]:
    var resolved_child = child
    if child.width_px < 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        val child_width_px = padding_box_w * (0 - child.width_px) / 100
        resolved_child = style_with_width(resolved_child, child_width_px)
    val child_height_px = resolve_percent_height_px(child.height_px, containing_h)
    if child_height_px > 0 and child_height_px != resolved_child.height_px:
        resolved_child = style_with_height(resolved_child, child_height_px)
    if resolved_child.width_px != child.width_px or resolved_child.height_px != child.height_px:
        val style_count = styles.len()
        if style_count == 0:
            return []
        var result: [Style] = [styles[0]; style_count]
        var si = 0
        while si < style_count:
            if si == child_index:
                result[si] = resolved_child
            else:
                result[si] = styles[si]
            si = si + 1
        return result
    styles

fn layout(nodes: [HNode], styles: [Style], child_index: HtmlChildIndex, i: i32, x: i32, y: i32, w: i32, viewport_h: i32, bx: [i32], by: [i32], bw: [i32], bh: [i32], wrap_starts: [[i32]], wrap_ends: [[i32]], intrinsic_widths: [i32]) -> LayoutResult:
    var out_bx = bx
    var out_by = by
    var out_bw = bw
    var out_bh = bh
    var out_wrap_starts = wrap_starts
    var out_wrap_ends = wrap_ends
    var out_intrinsic_widths = intrinsic_widths
    out_bx[i] = x
    out_by[i] = y
    val st = styles[i]
    val node = nodes[i]
    # Budget guard: short-circuit layout of not-yet-processed subtrees on expiry.
    # Emit a zero-size box for this node and return a valid LayoutResult so the
    # recursion unwinds cleanly while already-computed boxes stay intact.
    if _web_budget_expired():
        out_bw[i] = 0
        out_bh[i] = 0
        return relative_layout_result(child_index, i, st, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths, 0)
    val legacy_widget_box = node.has_widget_class or node.has_icon_image_class
    if st.display == "none":
        out_bw[i] = 0
        out_bh[i] = 0
        return relative_layout_result(child_index, i, st, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths, 0)
    if st.display == "contents":
        out_bw[i] = w
        var cy_contents = y
        var c_contents = child_index.first_child[i]
        var child_count_contents = 0
        var prev_margin_b_contents = 0
        while c_contents >= 0:
            val cst = styles[c_contents]
            val cml = resolve_horizontal_margin_px(cst.margin_l, w)
            val cmr = resolve_horizontal_margin_px(cst.margin_r, w)
            if child_count_contents > 0:
                cy_contents = cy_contents + st.gap_px
            val cst_margin_t_contents = resolve_vertical_margin_px(cst.margin_t, viewport_h)
            val collapsed_margin_contents = if prev_margin_b_contents > cst_margin_t_contents: prev_margin_b_contents else: cst_margin_t_contents
            cy_contents = cy_contents + collapsed_margin_contents
            var child_w_contents = w - cml - cmr
            if child_w_contents < 1:
                child_w_contents = 1
            val child = layout(nodes, styles, child_index, c_contents, x + cml, cy_contents, child_w_contents, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
            out_bx = child.bx
