class TextWrapCache:
    starts: [[i32]]
    ends: [[i32]]

class IntrinsicWidthResult:
    width: i32
    widths: [i32]

class LineWrapRanges:
    starts: [i32]
    ends: [i32]

fn char_w(fs: i32) -> i32:
    if fs <= 8:
        return 4
    6 * glyph_scale(fs)

fn text_advance(fs: i32) -> i32:
    if fs <= 8:
        return 4
    5 * glyph_scale(fs)

fn line_h(fs: i32) -> i32:
