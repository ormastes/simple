    if font_variant_alternates_decl.len() > 0:
        val font_variant_alternates_norm = font_variant_alternates_decl.trim().lower()
        if font_variant_alternates_norm == "normal" or font_variant_alternates_norm == "historical-forms" or font_variant_alternates_norm.contains("("):
