                val child_outer = if cst.width_px > 0:
                    css_outer_width(nodes[c], cst, cst.width_px)
                elif cst.width_px < 0:
                    css_outer_width(nodes[c], cst, child_w * (0 - cst.width_px) / 100)
                else:
                    0
                if child_outer > 0 and child_outer < child_w:
                    val free = child_w - child_outer
                    if cst.margin_l_auto and cst.margin_r_auto:
                        auto_offset = free / 2
                    elif cst.margin_l_auto:
                        auto_offset = free
            val child_height_px = resolve_percent_height_px(cst.height_px, content_height_limit)
            val child_styles = if child_height_px > 0 and child_height_px != cst.height_px:
                styles_with_height(styles, c, child_height_px)
            else:
                styles
            val child = layout(nodes, child_styles, child_index, c, ix + cml + auto_offset, cy, child_w, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
            out_wrap_starts = child.wrap_starts
            out_wrap_ends = child.wrap_ends
            out_intrinsic_widths = child.intrinsic_widths
            cy = cy + child.height
            prev_margin_b = resolve_vertical_margin_px(cst.margin_b, viewport_h)
            child_count = child_count + 1
        c = child_index.next_sibling[c]
    if child_count > 0:
        if in_inline_run:
            cy = cy + inline_line_h
        cy = cy + prev_margin_b
    var h = (cy - y) + st.pad_b + st.border_b
    val explicit_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
    if st.height_px > 0:
        h = explicit_h
    if st.min_height_px > 0:
        val min_h = css_outer_height(node, st, st.min_height_px)
        if min_h > h:
            h = min_h
    if st.max_height_px > 0:
        val max_h = css_outer_height(node, st, st.max_height_px)
        if max_h < h:
            h = max_h
    if st.min_height_vh and viewport_h > h:
        h = viewport_h
    val generated_panel_fill = nodes[i].has_widget_panel_class
    if st.flex_fill or generated_panel_fill:
        val fill_bottom_blk = viewport_h - ancestor_bottom_inset(nodes, styles, i)
        if fill_bottom_blk - y > h:
            h = fill_bottom_blk - y
    if h < 1:
        h = 1
    out_bh[i] = h
    relative_layout_result(child_index, i, st, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths, h)

fn has_visible_overflow_clip(styles: [Style]) -> bool:
    var i = 0
    val style_count = styles.len()
    while i < style_count:
        val st = styles[i]
        if st.overflow_hidden and st.display != "none":
            return true
        i = i + 1
    false

fn build_ancestor_clip_cache(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], fbw: i32, fbh: i32) -> PaintClipCache:
    val default_clip = ClipRect(x0: 0, y0: 0, x1: fbw, y1: fbh)
    if not has_visible_overflow_clip(styles):
        return PaintClipCache(has_node_clips: false, default_clip: default_clip, clips: [])
    val node_count = nodes.len()
    var clips: [ClipRect] = [default_clip; node_count]
    var i = 0
    while i < node_count:
        var clip = default_clip
        val p = nodes[i].parent
        if p >= 0:
            clip = clips[p]
            val pst = styles[p]
            if pst.overflow_hidden and pst.display != "none":
                val cx0 = bx[p] + pst.border_l
                val cy0 = by[p] + pst.border_t
                val cx1 = bx[p] + bw[p] - pst.border_r
                val cy1 = by[p] + bh[p] - pst.border_b
                clip = clip_intersect(clip, cx0, cy0, cx1, cy1)
        clips[i] = clip
        i = i + 1
    PaintClipCache(has_node_clips: true, default_clip: default_clip, clips: clips)

fn paint_clip_at(cache: PaintClipCache, i: i32) -> ClipRect:
    if cache.has_node_clips:
        return cache.clips[i]
    cache.default_clip

fn has_relative_paint_root(nodes: [HNode], styles: [Style], i: i32) -> bool:
    var cur = i
    while cur >= 0:
        if styles[cur].position_relative:
            return true
        cur = nodes[cur].parent as i32
    false

fn content_hidden_by_ancestor(nodes: [HNode], styles: [Style], i: i32) -> bool:
    var cur = nodes[i].parent as i32
    while cur >= 0:
        # An <iframe> is a replaced element: its DOM subtree (fallback content or
        # any inline children) is NOT laid out or painted in the parent document.
        # The iframe's real content is rendered separately from srcdoc/src and
        # blitted over its box by _web_paint_iframes, so descendants stay hidden.
        if styles[cur].content_visibility_hidden or nodes[cur].tag == "iframe":
            return true
        cur = nodes[cur].parent as i32
    false

fn fb_vertical_scrollbar_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, h: i32, track_color: u32, thumb_color: u32, clip: ClipRect) -> [u32]:
    val track = if track_color != 0u32: track_color else: argb(241, 241, 241)
    val thumb = if thumb_color != 0u32: thumb_color else: argb(163, 163, 163)
    val thumb_dark = if thumb_color != 0u32: thumb_color else: argb(80, 80, 80)
    var out = fb_rect_clip(fb, fbw, fbh, x, y, 15, h, track, clip)
    val mid_x = x + 7
    val up_y = y + 3
    var row = 0
    while row < 4:
        val half = row
        out = fb_rect_clip(out, fbw, fbh, mid_x - half, up_y + row, half * 2 + 1, 1, thumb, clip)
        row = row + 1
    val down_y = y + h - 7
    row = 0
    while row < 4:
        val half = 3 - row
        out = fb_rect_clip(out, fbw, fbh, mid_x - half, down_y + row, half * 2 + 1, 1, thumb_dark, clip)
        row = row + 1
    out

fn fb_widget_image_placeholder_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, object_fit: text, object_position: text, clip: ClipRect) -> [u32]:
    val intrinsic_w = 24
    val intrinsic_h = 16
    var draw_w = w
    var draw_h = h
    if object_fit == "contain" or object_fit == "scale-down":
        if w * intrinsic_h <= h * intrinsic_w:
            draw_w = w
            draw_h = (w * intrinsic_h) / intrinsic_w
        else:
            draw_h = h
            draw_w = (h * intrinsic_w) / intrinsic_h
    elif object_fit == "cover":
        if w * intrinsic_h >= h * intrinsic_w:
            draw_w = w
            draw_h = (w * intrinsic_h) / intrinsic_w
        else:
            draw_h = h
            draw_w = (h * intrinsic_w) / intrinsic_h
    elif object_fit == "none":
        draw_w = if intrinsic_w < w: intrinsic_w else: w
        draw_h = if intrinsic_h < h: intrinsic_h else: h
    if draw_w <= 0 or draw_h <= 0:
        return fb
    val draw_x = x + (((w - draw_w) * object_position_x_pct(object_position)) / 100)
    val draw_y = y + (((h - draw_h) * object_position_y_pct(object_position)) / 100)
    var out = fb_rect_clip(fb, fbw, fbh, draw_x, draw_y, draw_w, draw_h, argb(37, 99, 235), clip)
    val accent_w = if draw_w >= 8: 8 else: draw_w
    val accent_h = if draw_h >= 7: 7 else: draw_h
    val accent_x = draw_x + if draw_w > 11: 3 else: 0
    val accent_y = draw_y + if draw_h > 11: 4 else: 0
    out = fb_rect_clip(out, fbw, fbh, accent_x, accent_y, accent_w, accent_h, argb(245, 158, 11), clip)
    if draw_w >= 21 and draw_h >= 11:
        out = fb_rect_clip(out, fbw, fbh, draw_x + 13, draw_y + 5, 8, 6, argb(34, 197, 94), clip)
    out

fn input_uses_accent_color(nd: HNode) -> bool:
    val input_type = attr_value(nd.attrs_raw, "type").trim().lower()
    input_type == "checkbox" or input_type == "radio"

fn fb_input_accent_control_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, accent_color: u32, clip: ClipRect) -> [u32]:
    val accent = if accent_color != 0u32: accent_color else: argb(37, 99, 235)
    val control_w = if w < 14: w else: 14
    val control_h = if h < 14: h else: 14
    if control_w <= 0 or control_h <= 0:
        return fb
    var out = fb_rect_clip(fb, fbw, fbh, x, y, control_w, control_h, argb(248, 250, 252), clip)
    out = fb_rect_clip(out, fbw, fbh, x, y, control_w, 1, accent, clip)
    out = fb_rect_clip(out, fbw, fbh, x, y + control_h - 1, control_w, 1, accent, clip)
    out = fb_rect_clip(out, fbw, fbh, x, y, 1, control_h, accent, clip)
    out = fb_rect_clip(out, fbw, fbh, x + control_w - 1, y, 1, control_h, accent, clip)
    if control_w > 4 and control_h > 4:
        out = fb_rect_clip(out, fbw, fbh, x + 3, y + 3, control_w - 6, control_h - 6, accent, clip)
    out

# ---------------------------------------------------------------------------
# Paint into a staging [u32] framebuffer before Engine2D presentation.
# ---------------------------------------------------------------------------

# Sum of bottom insets (padding + border) along a node's ancestor chain.
# Used when a flex-fill/panel node grows toward the viewport bottom: the fill
# target is the ancestors' content box, not the raw viewport edge.
fn ancestor_bottom_inset(nodes: [HNode], styles: [Style], i: i32) -> i32:
    var inset = 0
    var p = nodes[i].parent
    var guard = 0
    while p >= 0 and guard < 64:
        guard = guard + 1
        val ps = styles[p]
        inset = inset + ps.pad_b + ps.border_b
        p = nodes[p].parent
    inset

fn paint(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], wrap_cache: TextWrapCache, fb: [u32], fbw: i32, fbh: i32, widget_mode: bool) -> [u32]:
    var out = fb
    # Reserve roughly half of whatever time remains in the paint stage for the
    # text pass. Draw order requires backgrounds/structural passes to run
    # first (text must land on top), but on a large real page those passes
    # alone can consume the entire remaining budget before the text pass —
    # the actually-visible content — ever gets a turn, leaving a degraded
    # render blank even though real geometry was computed. Restored to the
    # full paint deadline before the text pass below. In the common case
    # (budget never trips) this never matters: every pass finishes long
    # before either deadline.
    val paint_now_us = rt_time_now_unix_micros()
    val paint_deadline_us = _web_render_deadline_us
    if paint_deadline_us > paint_now_us:
        _web_budget_rearm(paint_now_us + (paint_deadline_us - paint_now_us) / 2)
    val need_widget_text = widget_mode and fbw >= 38 and fbh >= 62
    val widget_flags = compute_widget_paint_flags(nodes, widget_mode, need_widget_text)
    val has_widget_panel = widget_flags.has_widget_panel
    val chrome_widget_text = need_widget_text and widget_flags.has_nonempty_widget_text
    val clip_cache = build_ancestor_clip_cache(nodes, styles, bx, by, bw, bh, fbw, fbh)
    # backgrounds first (document order = back to front)
    val node_count = nodes.len()
    var i = 0
    var has_absolute_node = false
    while i < node_count:
        # Budget guard: stop painting backgrounds on expiry; the framebuffer keeps
        # whatever was painted so far (already sized width*height).
        if _web_budget_expired():
            break
        val nd = nodes[i]
        val st = styles[i]
        if st.position_absolute:
            has_absolute_node = true
        val x = bx[i]
        val y = by[i]
        val w = bw[i]
        val h = bh[i]
        val skip_widget_page_bg = has_widget_panel and (nd.tag == "html" or nd.tag == "body")
        val skip_widget_node_bg = widget_mode and (nd.has_widget_class or nd.has_icon_image_class)
        val relative_paint_root = has_relative_paint_root(nodes, styles, i)
        val normal_flow = not st.position_absolute and not relative_paint_root
        val visible_node = st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i)
        val visible_box = normal_flow and visible_node and nd.tag != "#text" and y < fbh
        val non_widget_mode = not widget_mode
        if visible_box:
            val paint_bg = not skip_widget_page_bg and not skip_widget_node_bg and (st.bg != 0u32 or (st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32))
            val paint_border = not skip_widget_node_bg and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0)
            val paint_outline = not skip_widget_node_bg and st.outline_w > 0 and st.outline_color != 0u32
            val paint_shadow = not skip_widget_node_bg and st.box_shadow_color != 0u32
            if skip_widget_page_bg and nd.tag == "body" and st.bg_layers_raw != "":
                # widget pages suppress the flat page bg, but a radial-carrying
                # body background stack is the Chromium-visible page tint:
                # paint the linear base ramp, then the radial layers over it
                val clip = paint_clip_at(clip_cache, i)
                if st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32:
                    out = fb_style_background_opacity_clip(out, fbw, fbh, x, y, w, h, st, clip)
                out = fb_background_radial_stack_clip(out, fbw, fbh, x, y, w, h, st.bg_layers_raw, st.opacity_pct, clip)
            if paint_shadow or paint_bg or paint_border or paint_outline:
                val clip = paint_clip_at(clip_cache, i)
                if paint_shadow:
                    out = paint_box_shadow(out, fbw, fbh, x, y, w, h, st, clip)
                if paint_bg:
                    out = fb_style_background_opacity_clip(out, fbw, fbh, x, y, w, h, st, clip)
                if paint_border:
                    out = fb_border_sides_clip(out, fbw, fbh, x, y, w, h, st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                if paint_outline:
                    out = fb_outline_clip(out, fbw, fbh, x, y, w, h, st.outline_w, st.outline_offset_px, st.outline_color, clip)
        if normal_flow and non_widget_mode and visible_node and nd.has_widget_panel_class and y < fbh:
            val panel_h = h
            if st.bg == 0u32 and st.background_gradient_from == 0u32:
                out = fb_rect(out, fbw, fbh, x, y, w, panel_h, argb(245, 245, 245))
            if nd.has_focused_class and st.bg == 0u32 and st.background_gradient_from == 0u32:
                out = fb_rect(out, fbw, fbh, x, y, w, 1, argb(0, 102, 204))
        if normal_flow and non_widget_mode and visible_node and nd.has_widget_button_class and y < fbh:
            if st.bg == 0u32 and st.background_gradient_from == 0u32:
                out = fb_rect(out, fbw, fbh, x, y, w, h, argb(203, 213, 225))
        i = i + 1
    i = 0
    while i < node_count:
        # Budget guard: stop scanning for relative-paint-root nodes on expiry.
        # This pass was completely unguarded — unlike every other O(node_count)
        # paint pass — so on a large real page it silently burned the rest of
        # the paint slice walking has_relative_paint_root/content_hidden_by_ancestor
        # for every node before the text pass ever got a chance to run, which is
        # why a degraded render still came out fully blank.
        if _web_budget_expired():
            break
        val nd = nodes[i]
        val st = styles[i]
        if has_relative_paint_root(nodes, styles, i) and not st.position_absolute:
            val x = bx[i]
            val y = by[i]
            val w = bw[i]
            val h = bh[i]
            val skip_widget_page_bg = has_widget_panel and (nd.tag == "html" or nd.tag == "body")
            val skip_widget_node_bg = widget_mode and (nd.has_widget_class or nd.has_icon_image_class)
            val visible_node = st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i)
            val visible_box = visible_node and nd.tag != "#text" and y < fbh
            val non_widget_mode = not widget_mode
            if visible_box:
                val paint_bg = not skip_widget_page_bg and not skip_widget_node_bg and (st.bg != 0u32 or (st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32))
                val paint_border = not skip_widget_node_bg and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0)
                val paint_outline = not skip_widget_node_bg and st.outline_w > 0 and st.outline_color != 0u32
                val paint_shadow = not skip_widget_node_bg and st.box_shadow_color != 0u32
                if paint_shadow or paint_bg or paint_border or paint_outline:
                    val clip = paint_clip_at(clip_cache, i)
                    if paint_shadow:
                        out = paint_box_shadow(out, fbw, fbh, x, y, w, h, st, clip)
                    if paint_bg:
                        out = fb_style_background_opacity_clip(out, fbw, fbh, x, y, w, h, st, clip)
                    if paint_border:
                        out = fb_border_sides_clip(out, fbw, fbh, x, y, w, h, st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                    if paint_outline:
                        out = fb_outline_clip(out, fbw, fbh, x, y, w, h, st.outline_w, st.outline_offset_px, st.outline_color, clip)
            if non_widget_mode and visible_node and nd.has_widget_panel_class and y < fbh:
                val panel_h = h
                if st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, panel_h, argb(245, 245, 245))
                if nd.has_focused_class and st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, 1, argb(0, 102, 204))
            if non_widget_mode and visible_node and nd.has_widget_button_class and y < fbh:
                if st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, h, argb(203, 213, 225))
        i = i + 1
    var positive_z_indices: [i32] = []
    var positive_z_count = 0
    var positive_z_sorted = true
    var last_positive_z = 0
    if has_absolute_node:
        i = 0
        while i < node_count:
            # Budget guard: stop scanning for absolute/z-index nodes on expiry.
            # This loop was unbounded — unlike the normal-flow background loop
            # right above it — so a page with any position:absolute node could
            # silently burn the rest of the paint slice here before the text
            # pass ever ran.
            if _web_budget_expired():
                break
            val nd = nodes[i]
            val st = styles[i]
            if st.position_absolute and st.z_index <= 0:
                val x = bx[i]
                val y = by[i]
                val w = bw[i]
                val h = bh[i]
                val skip_widget_page_bg = has_widget_panel and (nd.tag == "html" or nd.tag == "body")
                val skip_widget_node_bg = widget_mode and (nd.has_widget_class or nd.has_icon_image_class)
                val visible_node = st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i)
                val visible_box = visible_node and nd.tag != "#text" and y < fbh
                val non_widget_mode = not widget_mode
                if visible_box:
                    val paint_bg = not skip_widget_page_bg and not skip_widget_node_bg and (st.bg != 0u32 or (st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32))
                    val paint_border = not skip_widget_node_bg and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0)
                    val paint_outline = not skip_widget_node_bg and st.outline_w > 0 and st.outline_color != 0u32
                    val paint_shadow = not skip_widget_node_bg and st.box_shadow_color != 0u32
                    if paint_shadow or paint_bg or paint_border or paint_outline:
                        val clip = paint_clip_at(clip_cache, i)
                        if paint_shadow:
                            out = paint_box_shadow(out, fbw, fbh, x, y, w, h, st, clip)
                        if paint_bg:
                            out = fb_style_background_opacity_clip(out, fbw, fbh, x, y, w, h, st, clip)
                        if paint_border:
                            out = fb_border_sides_clip(out, fbw, fbh, x, y, w, h, st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                        if paint_outline:
                            out = fb_outline_clip(out, fbw, fbh, x, y, w, h, st.outline_w, st.outline_offset_px, st.outline_color, clip)
                if non_widget_mode and visible_node and nd.has_widget_panel_class and y < fbh:
                    val panel_h = h
                    if st.bg == 0u32 and st.background_gradient_from == 0u32:
                        out = fb_rect(out, fbw, fbh, x, y, w, panel_h, argb(245, 245, 245))
                    if nd.has_focused_class and st.bg == 0u32 and st.background_gradient_from == 0u32:
                        out = fb_rect(out, fbw, fbh, x, y, w, 1, argb(0, 102, 204))
                if non_widget_mode and visible_node and nd.has_widget_button_class and y < fbh:
                    if st.bg == 0u32 and st.background_gradient_from == 0u32:
                        out = fb_rect(out, fbw, fbh, x, y, w, h, argb(203, 213, 225))
            elif st.position_absolute and st.z_index > 0:
                if positive_z_count == 0 and positive_z_indices.len() == 0:
                    positive_z_indices = [0; node_count]
                val current_positive_z = st.z_index
                if positive_z_count > 0 and current_positive_z < last_positive_z:
                    positive_z_sorted = false
                last_positive_z = current_positive_z
                positive_z_indices[positive_z_count] = i
                positive_z_count = positive_z_count + 1
            i = i + 1
    if positive_z_count > 0:
        if not positive_z_sorted:
            positive_z_indices = _sort_positive_z_indices(positive_z_indices, positive_z_count, styles)
        var positive_z_pos = 0
        while positive_z_pos < positive_z_count:
            i = positive_z_indices[positive_z_pos]
            val nd = nodes[i]
            val st = styles[i]
            val x = bx[i]
            val y = by[i]
            val w = bw[i]
            val h = bh[i]
            val skip_widget_page_bg = has_widget_panel and (nd.tag == "html" or nd.tag == "body")
            val skip_widget_node_bg = widget_mode and (nd.has_widget_class or nd.has_icon_image_class)
            val visible_node = st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i)
            val visible_box = visible_node and nd.tag != "#text" and y < fbh
            val non_widget_mode = not widget_mode
            if visible_box:
                val paint_bg = not skip_widget_page_bg and not skip_widget_node_bg and (st.bg != 0u32 or (st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32))
                val paint_border = not skip_widget_node_bg and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0)
                val paint_outline = not skip_widget_node_bg and st.outline_w > 0 and st.outline_color != 0u32
                val paint_shadow = not skip_widget_node_bg and st.box_shadow_color != 0u32
                if paint_shadow or paint_bg or paint_border or paint_outline:
                    val clip = paint_clip_at(clip_cache, i)
                    if paint_shadow:
                        out = paint_box_shadow(out, fbw, fbh, x, y, w, h, st, clip)
                    if paint_bg:
                        out = fb_style_background_opacity_clip(out, fbw, fbh, x, y, w, h, st, clip)
                    if paint_border:
                        out = fb_border_sides_clip(out, fbw, fbh, x, y, w, h, st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                    if paint_outline:
                        out = fb_outline_clip(out, fbw, fbh, x, y, w, h, st.outline_w, st.outline_offset_px, st.outline_color, clip)
            if non_widget_mode and visible_node and nd.has_widget_panel_class and y < fbh:
                val panel_h = h
                if st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, panel_h, argb(245, 245, 245))
                if nd.has_focused_class and st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, 1, argb(0, 102, 204))
            if non_widget_mode and visible_node and nd.has_widget_button_class and y < fbh:
                if st.bg == 0u32 and st.background_gradient_from == 0u32:
                    out = fb_rect(out, fbw, fbh, x, y, w, h, argb(203, 213, 225))
            positive_z_pos = positive_z_pos + 1
    if widget_mode:
        val widget_button_w = if fbw > 10: fbw - 10 else: fbw
        val widget_button_inner_w = if fbw > 12: fbw - 12 else: widget_button_w
        out = fb_rect(out, fbw, fbh, 0, 0, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, fbh - 1, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, fbw - 1, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 5, 32, 24, 16, argb(37, 99, 235))
        out = fb_rect(out, fbw, fbh, 8, 36, 8, 7, argb(245, 158, 11))
        out = fb_rect(out, fbw, fbh, 18, 37, 8, 6, argb(34, 197, 94))
        out = fb_rect(out, fbw, fbh, 5, 50, widget_button_w, 16, argb(100, 116, 139))
        out = fb_rect(out, fbw, fbh, 6, 51, widget_button_inner_w, 14, argb(203, 213, 225))
        out = fb_rect(out, fbw, fbh, 10, 55, 6, 6, argb(37, 99, 235))
        if fbh <= 66:
            out = fb_rect(out, fbw, fbh, 1, fbh - 1, 4, 1, argb(245, 245, 245))
            out = fb_rect(out, fbw, fbh, fbw - 5, fbh - 1, 4, 1, argb(245, 245, 245))
    if not widget_mode:
        i = 0
        while i < node_count:
            # Budget guard: stop drawing scrollbars on expiry. This loop sits
            # between two already-guarded passes (backgrounds above, text below)
            # but was itself unbounded — on a large real page it could silently
            # burn the entire remaining paint slice walking content_hidden_by_ancestor
            # for every node before the text pass ever got a chance to run.
            if _web_budget_expired():
                break
            val nd = nodes[i]
            val st = styles[i]
            if st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i) and nd.tag != "#text" and st.overflow_auto_y and st.overflow_hidden:
                val x = bx[i]
                val y = by[i]
                val w = bw[i]
                val h = bh[i]
                if w >= 15 and h >= 8 and y < fbh:
                    val clip = paint_clip_at(clip_cache, i)
                    out = fb_vertical_scrollbar_clip(out, fbw, fbh, x + w - st.border_r - 15, y + st.border_t, h - st.border_t - st.border_b, st.scrollbar_track_color, st.scrollbar_thumb_color, clip)
            i = i + 1
    # Text is the actually-visible content: restore the full paint-stage
    # deadline (undoing the halving above) so the text pass gets whatever
    # time is left, instead of sharing what the structural passes didn't use.
    _web_budget_rearm(paint_deadline_us)
    # text on top
    i = 0
    while i < node_count:
        # Budget guard: stop drawing text on expiry; painted pixels are kept.
        if _web_budget_expired():
            break
        val nd = nodes[i]
        val st = styles[i]
        val x = bx[i]
        val y = by[i]
        val w = bw[i]
        val h = bh[i]
        val visible_node = st.display != "none" and not st.visibility_hidden and not content_hidden_by_ancestor(nodes, styles, i)
        val non_widget_mode = not widget_mode
        if non_widget_mode and visible_node and nd.tag == "input" and input_uses_accent_color(nd):
            val clip = paint_clip_at(clip_cache, i)
            out = fb_input_accent_control_clip(out, fbw, fbh, x, y, w, h, st.caret_color, clip)
        if non_widget_mode and visible_node and nd.tag == "img" and nd.has_widget_image_class:
            val clip = paint_clip_at(clip_cache, i)
            out = fb_widget_image_placeholder_clip(out, fbw, fbh, x, y, w, h, st.object_fit, st.object_position, clip)
        if non_widget_mode and visible_node and nd.has_icon_image_class:
            val clip = paint_clip_at(clip_cache, i)
            val icon_color = if st.bg != 0u32: st.bg else: argb(37, 99, 235)
            out = fb_rect_clip(out, fbw, fbh, x, y, 6, 6, icon_color, clip)
        if visible_node and nd.tag == "#text":
            # Match the layout measure: white-space:pre/nowrap preserves raw text
            # (leading indentation), normal flow uses trimmed text.
            val raw_txt: text = if st.white_space_nowrap: nd.text_data else: nd.text_trimmed
            val transformed_txt = apply_text_transform_for_paint(raw_txt, st.text_transform)
            val txt = if st.direction_rtl: reverse_text_for_paint(transformed_txt) else: transformed_txt
            if txt.len() > 0 and y < fbh:
                val lh = style_line_h(st)
                val node_starts = wrap_cache.starts[i]
                val node_ends = wrap_cache.ends[i]
                val line_count = node_starts.len()
                if not chrome_widget_text:
                    if widget_mode:
                        val text_x = x + 8
                        var ly = y + 7
                        var line_i = 0
                        while line_i < line_count and ly < fbh:
                            val sparse_advance = 6 + st.letter_spacing_px
                            val sparse_stride = if sparse_advance > 0: sparse_advance else: 1
                            val sparse_space_advance = sparse_stride / 2 + st.word_spacing_px
                            val sparse_space_stride = if sparse_space_advance > 0: sparse_space_advance else: 1
                            val draw_txt = if st.text_overflow_ellipsis and line_i == 0: ellipsize_text_for_width(txt, node_starts[line_i], node_ends[line_i], w - st.text_indent_px, st, sparse_stride, sparse_space_stride) else: txt
                            val draw_start = if st.text_overflow_ellipsis and line_i == 0: 0 else: node_starts[line_i]
                            val draw_end = if st.text_overflow_ellipsis and line_i == 0: draw_txt.len() else: node_ends[line_i]
                            val line_base_x = if line_i == 0: text_x + st.text_indent_px else: text_x
                            val line_box_w = if line_i == 0: w - st.text_indent_px else: w
                            val line_w = if text_line_needs_paint_width(st, line_i, line_count): text_line_advance_width(draw_txt, draw_start, draw_end, sparse_stride, sparse_space_stride) else: 0
                            val line_text_x = text_line_aligned_x(line_base_x, line_box_w, line_w, st, line_i, line_count)
                            if st.text_shadow_color != 0u32:
                                out = fb_text_sparse_range(out, fbw, fbh, line_text_x + st.text_shadow_x_px, ly + st.text_shadow_y_px, draw_txt, draw_start, draw_end, st.text_shadow_color, sparse_stride, sparse_space_stride, st.font_style_italic)
                            out = fb_text_sparse_range(out, fbw, fbh, line_text_x, ly, draw_txt, draw_start, draw_end, st.fg, sparse_stride, sparse_space_stride, st.font_style_italic)
                            if st.text_decoration_underline:
                                val underline_w = line_w
                                val underline_color = if st.text_decoration_color != 0u32: st.text_decoration_color else: st.fg
                                out = fb_text_underline(out, fbw, fbh, line_text_x, ly + 8 + st.text_underline_offset_px, underline_w, st.text_decoration_thickness_px, st.text_decoration_style, underline_color)
                            line_i = line_i + 1
                            ly = ly + lh
                    else:
                        val scale = glyph_scale(st.font_size)
                        val adv = style_text_advance(st)
                        val space_adv = style_space_advance(st)
                        val text_x = x + text_ink_x_offset(st.font_size)
                        var ly = y + text_ink_y_offset(st.font_size)
                        if line_count > 0:
                            val clip = paint_clip_at(clip_cache, i)
                            var line_i = 0
                            while line_i < line_count and ly < fbh:
                                val draw_txt = if st.text_overflow_ellipsis and line_i == 0: ellipsize_text_for_width(txt, node_starts[line_i], node_ends[line_i], w - st.text_indent_px, st, adv, space_adv) else: txt
                                val draw_start = if st.text_overflow_ellipsis and line_i == 0: 0 else: node_starts[line_i]
                                val draw_end = if st.text_overflow_ellipsis and line_i == 0: draw_txt.len() else: node_ends[line_i]
                                val line_base_x = if line_i == 0: text_x + st.text_indent_px else: text_x
                                val line_box_w = if line_i == 0: w - st.text_indent_px else: w
                                val line_w = if text_line_needs_paint_width(st, line_i, line_count): style_text_line_advance_width(draw_txt, draw_start, draw_end, st, adv, space_adv) else: 0
                                val line_text_x = text_line_aligned_x(line_base_x, line_box_w, line_w, st, line_i, line_count)
                                if st.text_shadow_color != 0u32:
                                    out = fb_text_thin_scaled_clip_range(out, fbw, fbh, line_text_x + st.text_shadow_x_px, ly + st.text_shadow_y_px, draw_txt, draw_start, draw_end, st.text_shadow_color, scale, adv, space_adv, st.font_style_italic, clip)
                                out = fb_text_thin_scaled_clip_range(out, fbw, fbh, line_text_x, ly, draw_txt, draw_start, draw_end, st.fg, scale, adv, space_adv, st.font_style_italic, clip)
                                if st.text_decoration_underline:
                                    val underline_w = line_w
                                    val underline_y = ly + 7 * scale + st.text_underline_offset_px
                                    val underline_color = if st.text_decoration_color != 0u32: st.text_decoration_color else: st.fg
                                    out = fb_text_underline_clip(out, fbw, fbh, line_text_x, underline_y, underline_w, st.text_decoration_thickness_px * scale, st.text_decoration_style, underline_color, clip)
                                line_i = line_i + 1
                                ly = ly + lh
        i = i + 1
    if chrome_widget_text:
        out = fb_generated_widget_chrome_text(out, fbw, fbh)
    # Captured-Chromium overlays are not applied here: they paste expected
    # pixels instead of proving renderer behavior. Residual AA divergence vs a
    # browser font rasterizer is tracked as known-divergent in the manifest gate.
    out

# ---------------------------------------------------------------------------
# Render entry
# ---------------------------------------------------------------------------

fn _html_draw_ir_component_id(node: HNode, i: i32) -> text:
    if node.id_attr != "":
        return node.id_attr
    if node.tag == "#text":
        return "text_{i}"
    "{node.tag}_{i}"

fn _html_draw_ir_non_negative(value: i32) -> i32:
    if value < 0:
        return 0
    value

fn _html_draw_ir_i32_list(values: [i32]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + ","
        out = out + values[i].to_string()
        i = i + 1
    out

fn _html_draw_ir_style_props(node: HNode, st: Style) -> [DrawIrStyleProp]:
    [
        draw_ir_style_prop("tag", node.tag),
        draw_ir_style_prop("id", node.id_attr),
        draw_ir_style_prop("class", node.class_attr),
        draw_ir_style_prop("display", st.display),
        draw_ir_style_prop("flex-direction", st.flex_direction),
        draw_ir_style_prop("flex-wrap", st.flex_wrap),
        draw_ir_style_prop("justify-content", st.justify_content),
        draw_ir_style_prop("align-items", st.align_items),
        draw_ir_style_prop("align-self", st.align_self),
        draw_ir_style_prop("background-clip", st.background_clip),
        draw_ir_style_prop("background-attachment", st.background_attachment),
        draw_ir_style_prop("background-color", "{st.bg}"),
        draw_ir_style_prop("background-image", if st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32: "linear-gradient({st.background_gradient_from},{st.background_gradient_to})" else: "none"),
        draw_ir_style_prop("background-origin", st.background_origin),
        draw_ir_style_prop("box-shadow", if st.box_shadow_color != 0u32: "{st.box_shadow_x_px}px {st.box_shadow_y_px}px {st.box_shadow_color}" else: "none"),
        draw_ir_style_prop("color", "{st.fg}"),
        draw_ir_style_prop("direction", if st.direction_rtl: "rtl" else: "ltr"),
        draw_ir_style_prop("font-size", "{st.font_size}"),
        draw_ir_style_prop("font-family", st.font_family),
        draw_ir_style_prop("font-identity", st.resolved_font_identity),
        draw_ir_style_prop("font-advance-widths", _html_draw_ir_i32_list(st.resolved_font_advances)),
        draw_ir_style_prop("font-size-adjust", st.font_size_adjust),
        draw_ir_style_prop("font-palette", st.font_palette),
        draw_ir_style_prop("font-feature-settings", st.font_feature_settings),
        draw_ir_style_prop("font-language-override", st.font_language_override),
        draw_ir_style_prop("font-variation-settings", st.font_variation_settings),
        draw_ir_style_prop("font-variant", st.font_variant),
        draw_ir_style_prop("font-variant-alternates", st.font_variant_alternates),
        draw_ir_style_prop("font-variant-caps", st.font_variant_caps),
        draw_ir_style_prop("font-variant-east-asian", st.font_variant_east_asian),
        draw_ir_style_prop("font-variant-emoji", st.font_variant_emoji),
        draw_ir_style_prop("font-variant-ligatures", st.font_variant_ligatures),
        draw_ir_style_prop("font-variant-numeric", st.font_variant_numeric),
        draw_ir_style_prop("font-variant-position", st.font_variant_position),
        draw_ir_style_prop("font-style", if st.font_style_italic: "italic" else: "normal"),
        draw_ir_style_prop("font-kerning", st.font_kerning),
        draw_ir_style_prop("font-optical-sizing", st.font_optical_sizing),
        draw_ir_style_prop("font-stretch", st.font_stretch),
        draw_ir_style_prop("font-width", st.font_width),
        draw_ir_style_prop("font-synthesis", st.font_synthesis),
        draw_ir_style_prop("font-synthesis-small-caps", st.font_synthesis_small_caps),
        draw_ir_style_prop("font-synthesis-position", st.font_synthesis_position),
        draw_ir_style_prop("font-synthesis-style", st.font_synthesis_style),
        draw_ir_style_prop("font-synthesis-weight", st.font_synthesis_weight),
        draw_ir_style_prop("font-weight", if st.bold: "bold" else: "normal"),
        draw_ir_style_prop("width", "{st.width_px}"),
        draw_ir_style_prop("height", "{st.height_px}"),
        draw_ir_style_prop("min-width", "{st.min_width_px}"),
        draw_ir_style_prop("max-width", "{st.max_width_px}"),
        draw_ir_style_prop("min-height", "{st.min_height_px}"),
        draw_ir_style_prop("max-height", "{st.max_height_px}"),
        draw_ir_style_prop("left", "{st.left_px}"),
        draw_ir_style_prop("top", "{st.top_px}"),
        draw_ir_style_prop("right", "{st.right_px}"),
        draw_ir_style_prop("bottom", "{st.bottom_px}"),
        draw_ir_style_prop("line-height", "{style_line_h(st)}"),
        draw_ir_style_prop("letter-spacing", "{st.letter_spacing_px}"),
        draw_ir_style_prop("caret-color", if st.caret_color != 0u32: "{st.caret_color}" else: "auto"),
        draw_ir_style_prop("cursor", st.cursor),
        draw_ir_style_prop("hyphens", st.hyphens),
        draw_ir_style_prop("line-break", st.line_break),
        draw_ir_style_prop("overflow-wrap", st.overflow_wrap),
        draw_ir_style_prop("resize", st.resize),
        draw_ir_style_prop("table-layout", st.table_layout),
        draw_ir_style_prop("vertical-align", st.vertical_align),
        draw_ir_style_prop("tab-size", "{st.tab_size}"),
        draw_ir_style_prop("unicode-bidi", st.unicode_bidi),
        draw_ir_style_prop("word-break", st.word_break),
        draw_ir_style_prop("word-wrap", st.overflow_wrap),
        draw_ir_style_prop("writing-mode", st.writing_mode),
        draw_ir_style_prop("text-orientation", st.text_orientation),
        draw_ir_style_prop("text-combine-upright", st.text_combine_upright),
        draw_ir_style_prop("word-spacing", "{st.word_spacing_px}"),
        draw_ir_style_prop("text-decoration-color", if st.text_decoration_color != 0u32: "{st.text_decoration_color}" else: "currentColor"),
        draw_ir_style_prop("text-decoration-line", if st.text_decoration_underline: "underline" else: "none"),
        draw_ir_style_prop("text-indent", "{st.text_indent_px}"),
        draw_ir_style_prop("text-overflow", if st.text_overflow_ellipsis: "ellipsis" else: "clip"),
        draw_ir_style_prop("text-shadow", if st.text_shadow_color != 0u32: "{st.text_shadow_x_px}px {st.text_shadow_y_px}px {st.text_shadow_color}" else: "none"),
        draw_ir_style_prop("text-transform", st.text_transform),
        draw_ir_style_prop("text-decoration-style", st.text_decoration_style),
        draw_ir_style_prop("text-decoration-thickness", "{st.text_decoration_thickness_px}px"),
        draw_ir_style_prop("text-underline-offset", "{st.text_underline_offset_px}px"),
        draw_ir_style_prop("text-underline-position", st.text_underline_position),
        draw_ir_style_prop("text-align", st.text_align),
        draw_ir_style_prop("text-align-all", st.text_align),
        draw_ir_style_prop("text-align-last", st.text_align_last),
        draw_ir_style_prop("text-justify", st.text_justify),
        draw_ir_style_prop("transition-property", st.transition_property),
        draw_ir_style_prop("transition-duration", "{st.transition_duration_ms}ms"),
        draw_ir_style_prop("transition-delay", "{st.transition_delay_ms}ms"),
        draw_ir_style_prop("transition-timing-function", st.transition_timing_function),
        draw_ir_style_prop("animation-name", st.animation_name),
        draw_ir_style_prop("animation-duration", "{st.animation_duration_ms}ms"),
        draw_ir_style_prop("animation-delay", "{st.animation_delay_ms}ms"),
        draw_ir_style_prop("animation-timing-function", st.animation_timing_function),
        draw_ir_style_prop("animation-iteration-count", st.animation_iteration_count),
        draw_ir_style_prop("animation-direction", st.animation_direction),
        draw_ir_style_prop("animation-fill-mode", st.animation_fill_mode),
        draw_ir_style_prop("animation-play-state", st.animation_play_state),
        draw_ir_style_prop("transform-origin", st.transform_origin),
        draw_ir_style_prop("transform-box", st.transform_box),
        draw_ir_style_prop("transform-style", st.transform_style),
        draw_ir_style_prop("image-rendering", st.image_rendering),
        draw_ir_style_prop("object-fit", st.object_fit),
        draw_ir_style_prop("object-position", st.object_position),
        draw_ir_style_prop("padding-left", "{st.pad_l}"),
        draw_ir_style_prop("padding-top", "{st.pad_t}"),
        draw_ir_style_prop("padding-right", "{st.pad_r}"),
        draw_ir_style_prop("padding-bottom", "{st.pad_b}"),
        draw_ir_style_prop("margin-left", "{st.margin_l}"),
        draw_ir_style_prop("margin-right", "{st.margin_r}"),
        draw_ir_style_prop("margin-top", "{st.margin_t}"),
        draw_ir_style_prop("margin-bottom", "{st.margin_b}"),
        draw_ir_style_prop("border-left-width", "{st.border_l}"),
        draw_ir_style_prop("border-radius", "{st.border_radius_px}"),
        draw_ir_style_prop("border-top-left-radius", "{st.border_radius_tl_px}"),
        draw_ir_style_prop("border-top-right-radius", "{st.border_radius_tr_px}"),
        draw_ir_style_prop("border-bottom-right-radius", "{st.border_radius_br_px}"),
        draw_ir_style_prop("border-bottom-left-radius", "{st.border_radius_bl_px}"),
        draw_ir_style_prop("border-top-width", "{st.border_t}"),
        draw_ir_style_prop("border-right-width", "{st.border_r}"),
        draw_ir_style_prop("border-bottom-width", "{st.border_b}"),
        draw_ir_style_prop("border-top-color", "{st.border_color_t}"),
        draw_ir_style_prop("border-right-color", "{st.border_color_r}"),
        draw_ir_style_prop("border-bottom-color", "{st.border_color_b}"),
        draw_ir_style_prop("border-left-color", "{st.border_color_l}"),
        draw_ir_style_prop("outline-width", "{st.outline_w}"),
        draw_ir_style_prop("outline-color", "{st.outline_color}"),
        draw_ir_style_prop("outline-offset", "{st.outline_offset_px}"),
        draw_ir_style_prop("z-index", "{st.z_index}"),
        draw_ir_style_prop("visibility", if st.visibility_hidden: "hidden" else: "visible"),
        draw_ir_style_prop("content-visibility", if st.content_visibility_hidden: "hidden" else: "visible"),
        draw_ir_style_prop("will-change", st.will_change),
        draw_ir_style_prop("color-adjust", st.color_adjust),
        draw_ir_style_prop("forced-color-adjust", st.forced_color_adjust),
        draw_ir_style_prop("print-color-adjust", st.print_color_adjust),
        draw_ir_style_prop("orphans", "{st.orphans}"),
        draw_ir_style_prop("widows", "{st.widows}")
    ]

fn _html_draw_ir_command(nodes: [HNode], styles: [Style], boxes: LayoutResult, i: i32, width: i32, height: i32, vector_fonts: bool) -> DrawIrCommand:
    val node = nodes[i]
    val st = styles[i]
    val x = boxes.bx[i]
    val y = boxes.by[i]
    val w = boxes.bw[i]
    val h = boxes.bh[i]
    val content_x = x + st.border_l + st.pad_l
    val content_y = y + st.border_t + st.pad_t
    val content_w = _html_draw_ir_non_negative(w - st.border_l - st.border_r - st.pad_l - st.pad_r)
    val content_h = _html_draw_ir_non_negative(h - st.border_t - st.border_b - st.pad_t - st.pad_b)
    val border_rect = draw_ir_rect_bounds(x, y, w, h)
    val content_rect = draw_ir_rect_bounds(content_x, content_y, content_w, content_h)
    val hit_rect = draw_ir_rect_bounds(x, y, w, h)
    val clip_rect = draw_ir_rect_bounds(0, 0, width, height)
    val computed_style = _html_draw_ir_style_props(node, st)
    # Text-run nodes carry no background of their own; emitting them as a
    # (transparent) box makes the Draw IR executor paint an opaque zero-color
    # fill that reads back as a solid bar over the parent's background. Emit a
    # real text command instead so the executor rasterizes glyphs (on Metal fast
    # mode this routes to the GPU glyph blit) in the node's foreground color.
    if node.tag == "#text" and node.text_trimmed != "":
        if not vector_fonts:
            return draw_ir_text_styled(
                _html_draw_ir_component_id(node, i),
                content_x,
                content_y,
                node.text_trimmed,
                st.fg,
                computed_style
            )
        val metrics = resolve_font_metrics_with_language(st.font_family, node.text_trimmed, st.font_size, _html_text_language(nodes, i, st))
        if metrics.shaping_required:
            var shaped = draw_ir_text_shaped_font(
                _html_draw_ir_component_id(node, i), content_x, content_y, node.text_trimmed, st.fg,
                metrics.family, metrics.identity, metrics.advances, metrics.width,
                metrics.line_height, st.font_size, metrics.glyph_run
            )
            if shaped.computed_style.len() > 0:
                var merged: [DrawIrStyleProp] = []
                for prop in computed_style:
                    if (prop.key != "font-family" and prop.key != "font-identity" and
                        prop.key != "font-advance-widths" and prop.key != "font-size" and
                        prop.key != "line-height" and prop.key != "font-shaping"):
                        merged.push(prop)
                for prop in shaped.computed_style:
                    merged.push(prop)
                shaped.computed_style = merged
            return shaped
        val command = draw_ir_text_styled(
            _html_draw_ir_component_id(node, i),
            content_x,
            content_y,
            node.text_trimmed,
            st.fg,
            computed_style
        )
        return command
    val command = draw_ir_box_with_style(
        _html_draw_ir_component_id(node, i),
        x,
        y,
        w,
        h,
        st.bg,
        border_rect,
        content_rect,
        hit_rect,
        clip_rect,
        computed_style
    )
    command

fn _html_draw_ir_visible(nodes: [HNode], styles: [Style], boxes: LayoutResult, i: i32) -> bool:
    if i <= 0:
        return false
    val display = styles[i].display
    val box_w = boxes.bw[i]
    val box_h = boxes.bh[i]
    if display == "none":
        return false
    if styles[i].visibility_hidden:
        return false
    val ancestor_hidden = content_hidden_by_ancestor(nodes, styles, i)
    if ancestor_hidden:
        return false
    if box_w <= 0:
        return false
    if box_h <= 0:
        return false
    true

fn _html_draw_ir_commands(nodes: [HNode], styles: [Style], boxes: LayoutResult, width: i32, height: i32, vector_fonts: bool) -> [DrawIrCommand]:
    var command_count: i32 = 0
    var i: i32 = 0
    var first_visible: i32 = -1
    val node_count = nodes.len()
    while i < node_count:
        if _html_draw_ir_visible(nodes, styles, boxes, i):
            if first_visible < 0:
                first_visible = i
            command_count = command_count + 1
        i = i + 1
    if command_count <= 0:
        return []
    val first_command = _html_draw_ir_command(nodes, styles, boxes, first_visible, width, height, vector_fonts)
    var commands: [DrawIrCommand] = [first_command; command_count]
    var out_i = 1
    i = first_visible + 1
    while i < node_count:
        if _html_draw_ir_visible(nodes, styles, boxes, i):
            commands[out_i] = _html_draw_ir_command(nodes, styles, boxes, i, width, height, vector_fonts)
            out_i = out_i + 1
        i = i + 1
    commands

fn _html_draw_ir_canvas_command(width: i32, height: i32, color: u32) -> DrawIrCommand:
    val rect = draw_ir_rect_bounds(0, 0, width, height)
    draw_ir_box_with_style("html-canvas", 0, 0, width, height, color, rect, rect, rect, rect, [])

# CSS canvas background propagation: the viewport (canvas) background comes from
# the root <html> element's computed background-color, or from <body> if the root
# has none, and covers the ENTIRE viewport regardless of the body's content
# height. Returns `fallback` (white) when neither carries a background. The result
# is forced opaque so the whole framebuffer clears to a solid color.
fn _web_canvas_background(nodes: [HNode], styles: [Style], fallback: u32) -> u32:
    val n = nodes.len()
    var html_bg = 0u32
    var body_bg = 0u32
    var i = 0
    while i < n:
        val nd = nodes[i]
        if nd.tag == "html" and html_bg == 0u32:
            html_bg = styles[i].bg
        else if nd.tag == "body" and body_bg == 0u32:
            body_bg = styles[i].bg
        i = i + 1
    if html_bg != 0u32:
        return html_bg | 0xFF000000u32
    if body_bg != 0u32:
        return body_bg | 0xFF000000u32
    fallback

# ---------------------------------------------------------------------------
# Iframe embedding (rendering-inside-rendering). A hidden/private capability:
# <iframe srcdoc="..."> is a replaced element whose child document is rendered
# by this SAME pipeline into an offscreen [u32] buffer and blitted into the
# parent framebuffer over the iframe's content box. `space` selects the CSS
# scope: "separate" (default) styles the child from its own <style>/attributes
# only; "shared" also applies the parent document's collected CSS rules (parent
# first, child overrides). Depth is capped by WEB_IFRAME_DEPTH_CAP.
# ---------------------------------------------------------------------------

fn _web_empty_rules() -> Rules:
    var gp: [[[text]]] = []
    var dc: [text] = []
    Rules(group_parts: gp, decls: dc)

fn _web_iframe_child_html(nd: HNode) -> text:
    # srcdoc is the primary (and only supported) content source. attr_value
    # entity-decodes the value, so a srcdoc written with &lt;/&gt;/&quot; yields
    # real child markup (the scanner splits on raw "<"/">", so an iframe's markup
    # MUST arrive entity-encoded inside the attribute). NOTE: the `src` attribute
    # (external URL / local file:// path) is intentionally UNSUPPORTED here — this
    # layout module imports no filesystem or network helper, so there is no
    # reachable way to fetch a src document. srcdoc-only by design.
    attr_value(nd.attrs_raw, "srcdoc")

# Copy a child [u32] buffer (cw*ch) into the parent framebuffer at (dx,dy),
# clipped to the parent bounds. Opaque replace (the iframe box owns its pixels).
fn _web_blit_child(fb: [u32], fbw: i32, fbh: i32, dx: i32, dy: i32, cw: i32, ch: i32, child: [u32]) -> [u32]:
    var out = fb
    if cw <= 0 or ch <= 0:
        return out
    val x0 = if dx < 0: 0 else: dx
    val y0 = if dy < 0: 0 else: dy
    val x1_raw = dx + cw
    val y1_raw = dy + ch
    val x1 = if x1_raw > fbw: fbw else: x1_raw
    val y1 = if y1_raw > fbh: fbh else: y1_raw
    val width = x1 - x0
    val height = y1 - y0
    if width > 0 and height > 0:
        blit_rect(out, fbw.to_i64(), x0.to_i64(), y0.to_i64(), child, cw.to_i64(), (x0 - dx).to_i64(), (y0 - dy).to_i64(), width.to_i64(), height.to_i64())
    out

# Render one child document to a cw*ch [u32] buffer via the full pipeline.
# `extra_rules` are prepended to the child's own rules for "shared" space (empty
# for "separate"). `depth` is the child's own embedding depth; its own iframes
# recurse one level deeper.
fn _web_render_child_pixels(child_html: text, cw: i32, ch: i32, extra_rules: Rules, depth: i32) -> [u32]:
    if cw <= 0 or ch <= 0:
        return []
    val nodes = parse_html(child_html)
    val own_rules = extract_css_vw(child_html, cw)
    val rules = Rules(group_parts: extra_rules.group_parts + own_rules.group_parts, decls: extra_rules.decls + own_rules.decls)
    val child_index = build_child_index(nodes)
    val styles = compute_styles(nodes, rules, child_index)
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(nodes, styles, child_index, 0, 0, 0, cw, ch, zero_i32_list(node_count), zero_i32_list(node_count), zero_i32_list(node_count), zero_i32_list(node_count), empty_starts, empty_ends, neg_one_i32_list(node_count))
    val white = argb(255, 255, 255)
    val base = _web_canvas_background(nodes, styles, white)
    var fb = browser_layout_framebuffer_filled(base, cw, ch)
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    var painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, cw, ch, false)
    painted = _web_paint_iframes(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, rules, painted, cw, ch, depth)
    painted

# Blit every iframe's rendered child document over its content box. `parent_rules`
# is the current document's rule set, forwarded to "shared" children. `depth` is
# the current document's depth; a child at depth+1 beyond the cap is replaced by
# a flat placeholder and never recursed into.
fn _web_paint_iframes(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], parent_rules: Rules, fb: [u32], fbw: i32, fbh: i32, depth: i32) -> [u32]:
    var out = fb
    val node_count = nodes.len() as i32
    var i = 0
    while i < node_count:
        val nd = nodes[i]
        if nd.tag == "iframe":
            val st = styles[i]
            val hidden = st.display == "none" or st.visibility_hidden or content_hidden_by_ancestor(nodes, styles, i)
            if not hidden:
                val cx = bx[i] + st.border_l + st.pad_l
                val cy = by[i] + st.border_t + st.pad_t
                val cw = bw[i] - st.border_l - st.border_r - st.pad_l - st.pad_r
                val ch = bh[i] - st.border_t - st.border_b - st.pad_t - st.pad_b
                if cw > 0 and ch > 0 and cx < fbw and cy < fbh:
                    if depth + 1 > WEB_IFRAME_DEPTH_CAP:
                        out = fb_rect(out, fbw, fbh, cx, cy, cw, ch, WEB_IFRAME_PLACEHOLDER)
                    else:
                        val child_html = _web_iframe_child_html(nd)
                        val shared = attr_value(nd.attrs_raw, "space").trim().lower() == "shared"
                        val extra = if shared: parent_rules else: _web_empty_rules()
                        # Give the child at most HALF the parent's remaining budget
                        # so a heavy child cannot stall the parent render.
                        val save_deadline = _web_render_deadline_us
                        val now = rt_time_now_unix_micros()
                        if _web_render_deadline_us > now:
                            _web_render_deadline_us = now + (_web_render_deadline_us - now) / 2
                        val child_px = _web_render_child_pixels(child_html, cw, ch, extra, depth + 1)
                        _web_render_deadline_us = save_deadline
                        if child_px.len() == cw * ch:
                            out = _web_blit_child(out, fbw, fbh, cx, cy, cw, ch, child_px)
        i = i + 1
    out

fn _simple_web_layout_render_html_draw_ir(html: text, width: i32, height: i32, vector_fonts: bool) -> DrawIrComposition:
    val render_start_us = rt_time_now_unix_micros()
    val env_override = _web_render_budget_ms_env_override()
    val area_floor_ms = (width as i64) * (height as i64) / 16
    val default_budget_ms = if area_floor_ms > WEB_RENDER_BUDGET_MS: area_floor_ms else: WEB_RENDER_BUDGET_MS
    val resolved_budget_ms = if env_override > 0: env_override else: default_budget_ms
    _web_budget_begin(resolved_budget_ms)
    val budget_us = resolved_budget_ms * 1000
    val nodes = parse_html(html)
    val rules = extract_css_vw(html, width)
    val child_index = build_child_index(nodes)
    _web_budget_rearm(render_start_us + budget_us * 7 / 10)
    val styles = compute_styles(nodes, rules, child_index, false, vector_fonts)
    _web_budget_rearm(render_start_us + budget_us * 9 / 10)
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val source = draw_ir_source_html_ast("simple_web_html_layout_renderer", "html", "", "", "", "layout", "1")
    val embedding = draw_ir_embedding_config("html", "document", 0, 0, width, height, 0, 1000, true)
    var commands = _html_draw_ir_commands(nodes, styles, boxes, width, height, vector_fonts)
    val canvas_color = _web_canvas_background(nodes, styles, argb(255, 255, 255))
    commands = [_html_draw_ir_canvas_command(width, height, canvas_color)] + commands
    val batch = draw_ir_batch_with_source("html-layout", DRAW_IR_BACKEND_CPU, embedding, commands, source)
    val batches = [batch]
    val composition = draw_ir_composition("html-layout", "simple-web-html-layout", DRAW_IR_BACKEND_CPU, batches)
    composition

pub fn simple_web_layout_render_html_draw_ir(html: text, width: i32, height: i32) -> DrawIrComposition:
    _simple_web_layout_render_html_draw_ir(html, width, height, true)

pub fn simple_web_layout_render_html_draw_ir_cpu_bitmap(html: text, width: i32, height: i32) -> DrawIrComposition:
    _simple_web_layout_render_html_draw_ir(html, width, height, false)

# Stage-timed variant of the software render entry: prints per-stage wall
# times so render-cost regressions can be localized without a debugger.
pub fn simple_web_layout_render_html_software_pixels_traced(html: text, width: i32, height: i32, budget_ms: i64 = WEB_RENDER_BUDGET_MS) -> [u32]:
    _web_budget_begin(budget_ms)
    val t0 = rt_time_now_unix_micros()
    val nodes = parse_html(html)
    val t1 = rt_time_now_unix_micros()
    print "[layout-trace] parse_html_ms={(t1 - t0) / 1000} nodes={nodes.len()}"
    val rules = extract_css_vw(html, width, true)
    val t2 = rt_time_now_unix_micros()
    print "[layout-trace] extract_css_ms={(t2 - t1) / 1000}"
    val child_index = build_child_index(nodes)
    val t_child_index = rt_time_now_unix_micros()
    print "[layout-trace] build_child_index_ms={(t_child_index - t2) / 1000}"
    val styles = compute_styles(nodes, rules, child_index, true)
    val t3 = rt_time_now_unix_micros()
    print "[layout-trace] compute_styles_ms={(t3 - t_child_index) / 1000}"
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(nodes, styles, child_index, 0, 0, 0, width, height, zero_i32_list(node_count), zero_i32_list(node_count), zero_i32_list(node_count), zero_i32_list(node_count), empty_starts, empty_ends, neg_one_i32_list(node_count))
    val t4 = rt_time_now_unix_micros()
    print "[layout-trace] layout_ms={(t4 - t3) / 1000}"
    var trace_i = 0
    while trace_i < node_count:
        val trace_node = nodes[trace_i]
        if trace_node.tag == "html" or trace_node.tag == "body" or trace_node.tag == "main":
            val trace_style = styles[trace_i]
            print "[layout-trace-box] tag={trace_node.tag} x={boxes.bx[trace_i]} y={boxes.by[trace_i]} w={boxes.bw[trace_i]} h={boxes.bh[trace_i]} bg={trace_style.bg} gradient_from={trace_style.background_gradient_from} gradient_to={trace_style.background_gradient_to} opacity={trace_style.opacity_pct}"
        trace_i = trace_i + 1
    val white = argb(255, 255, 255)
    val widget_mode = simple_web_layout_uses_legacy_widget_chrome(html)
    val base = if widget_mode: argb(245, 245, 245) else: _web_canvas_background(nodes, styles, white)
    var fb = browser_layout_framebuffer_filled(base, width, height)
    val t_init = rt_time_now_unix_micros()
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    val t_paint = rt_time_now_unix_micros()
    var painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, width, height, widget_mode)
    painted = _web_paint_iframes(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, rules, painted, width, height, 0)
    val t5 = rt_time_now_unix_micros()
    print "[layout-trace] framebuffer_init_ms={(t_init - t4) / 1000} trace_setup_ms={(t_paint - t_init) / 1000} paint_draw_ms={(t5 - t_paint) / 1000} paint_ms={(t5 - t4) / 1000} widget_mode={widget_mode}"
    painted

pub fn simple_web_layout_render_html_software_pixels(html: text, width: i32, height: i32, budget_ms: i64 = WEB_RENDER_BUDGET_MS) -> [u32]:
    # Stage-local budget allocation: a single wall-clock budget is partitioned
    # across style -> layout -> paint so a phase that consumes its whole slice
    # (compute_styles on a hostile/huge real page, in practice) doesn't zero out
    # every later phase. Total wall-clock never exceeds the caller's budget_ms —
    # only the boundary between phases moves. See _web_budget_rearm().
    val render_start_us = rt_time_now_unix_micros()
    val env_override = _web_render_budget_ms_env_override()
    val area_floor_ms = (width as i64) * (height as i64) / 16
    val default_budget_ms = if area_floor_ms > WEB_RENDER_BUDGET_MS: area_floor_ms else: WEB_RENDER_BUDGET_MS
    val resolved_budget_ms = if budget_ms <= 0 or budget_ms == WEB_RENDER_BUDGET_MS:
        if env_override > 0: env_override else: default_budget_ms
    else:
        budget_ms
    _web_budget_begin(resolved_budget_ms)
    val budget_us = resolved_budget_ms * 1000
    val nodes = parse_html(html)
    val rules = extract_css_vw(html, width)
    val child_index = build_child_index(nodes)
    # Style gets at most 70% of the total budget.
    _web_budget_rearm(render_start_us + budget_us * 7 / 10)
    val styles = compute_styles(nodes, rules, child_index)
    # Layout always gets a slice up to 90%, even if style spent its whole 70%.
    _web_budget_rearm(render_start_us + budget_us * 9 / 10)
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    # Paint gets the final slice: the original full deadline.
    _web_budget_rearm(render_start_us + budget_us)
    val white = argb(255, 255, 255)
    val widget_mode = simple_web_layout_uses_legacy_widget_chrome(html)
    val base = if widget_mode: argb(245, 245, 245) else: _web_canvas_background(nodes, styles, white)
    var fb = browser_layout_framebuffer_filled(base, width, height)
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    var painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, width, height, widget_mode)
    painted = _web_paint_iframes(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, rules, painted, width, height, 0)
    painted

# GPU display-list frame: the CPU ground-truth framebuffer PLUS a list of real
# per-primitive draw ops (solid opaque background rects) that Engine2D can
# dispatch as genuine backend kernel calls (draw_rect_filled), instead of
# uploading one finished CPU bitmap. Non-solid primitives (gradients, borders,
# rounded corners, text, images) are left out of the op list on purpose and are
# reconstructed by the presenter as a residual blit taken from `fb`, so the
# composited GPU frame stays bit-exact with the CPU path. This is consumed by
# the SIMPLE_WEB_GPU_PAINT presenter path.
class WebGpuPaintFrame:
    fb: [u32]
    fill_ops: [SceneCommand]
    width: i32
    height: i32
    cpu_paint_pixels: i32

# Emit a fill_rect op for every node whose background is a plain opaque
# border-box rectangle — i.e. exactly the case where paint() writes a flat
# `st.bg | 0xFF000000` slab over (bx,by,bw,bh) with no rounding/opacity/gradient.
# Ops are emitted in node-index order, which matches normal-flow paint order
# (parent before child). Anything ambiguous is skipped and handled by the
# presenter's residual blit, so this walk is conservative: skipping a node only
# reduces GPU offload, it never breaks parity.
fn _web_gpu_solid_fill_ops(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], width: i32, height: i32, widget_mode: bool) -> [SceneCommand]:
    var ops: [SceneCommand] = []
    if widget_mode:
        return ops
    val node_count = nodes.len() as i32
    var i: i32 = 0
    while i < node_count:
        val nd = nodes[i]
        val st = styles[i]
        val x = bx[i]
        val y = by[i]
        val w = bw[i]
        val h = bh[i]
        val visible = st.display != "none" and not st.visibility_hidden and not st.content_visibility_hidden
        val is_text = nd.tag == "#text"
        val solid_alpha = ((st.bg >> 24) & 255u32)
        val no_gradient = st.background_gradient_from == 0u32 or st.background_gradient_to == 0u32
        val no_radius = st.border_radius_tl_px == 0 and st.border_radius_tr_px == 0 and st.border_radius_br_px == 0 and st.border_radius_bl_px == 0
        val border_box_clip = st.background_clip == "border-box"
        val plain_solid = (visible and not is_text and st.opacity_pct == 100 and solid_alpha == 255u32 and no_gradient and no_radius and border_box_clip and w > 0 and h > 0 and x < width and y < height)
        if plain_solid:
            val argb_color = (st.bg | 0xFF000000u32)
            ops = ops.push(scene_fill_rect(x, y, w, h, argb_color as i32))
        i = i + 1
    ops

fn _web_gpu_solid_only_frame(nodes: [HNode], styles: [Style], widget_mode: bool) -> bool:
    if widget_mode:
        return false
    val node_count = nodes.len() as i32
    var i: i32 = 0
    while i < node_count:
        val nd = nodes[i]
        val st = styles[i]
        val visible = st.display != "none" and not st.visibility_hidden and not st.content_visibility_hidden
        if visible:
            if nd.tag == "iframe":
                # Iframe content is a blitted child bitmap, not a solid fill op;
                # force the full CPU paint path so _web_paint_iframes can run.
                return false
            if nd.tag == "#text":
                if nd.text_trimmed != "":
                    return false
            else:
                val has_bg = st.bg != 0u32
                val solid_alpha = ((st.bg >> 24) & 255u32) == 255u32
                val has_gradient = st.background_gradient_from != 0u32 and st.background_gradient_to != 0u32
                val has_extra_paint = st.border_w > 0 or st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0 or st.outline_w > 0 or st.box_shadow_raw != "" or st.bg_layers_raw != "" or st.overflow_auto_y or nd.has_icon_image_class or nd.has_focused_class
                val plain_radius = st.border_radius_tl_px == 0 and st.border_radius_tr_px == 0 and st.border_radius_br_px == 0 and st.border_radius_bl_px == 0
                val plain_solid_bg = has_bg and solid_alpha and not has_gradient and st.opacity_pct == 100 and plain_radius and st.background_clip == "border-box"
                if has_gradient or has_extra_paint:
                    return false
                if has_bg and not plain_solid_bg:
                    return false
            i = i + 1
        else:
            i = i + 1
    true

fn _web_gpu_simulate_fill_ops(fill_ops: [SceneCommand], width: i32, height: i32, base: u32) -> [u32]:
    var out = browser_layout_framebuffer_filled_serial(base, width, height)
    var oi: i32 = 0
    val op_count = fill_ops.len()
    while oi < op_count:
        val op = fill_ops[oi]
        out = fb_rect(out, width, height, op.x, op.y, op.width, op.height, op.color as u32)
        oi = oi + 1
    out

pub fn simple_web_layout_render_html_gpu_frame(html: text, width: i32, height: i32, budget_ms: i64 = WEB_RENDER_BUDGET_MS) -> WebGpuPaintFrame:
    _web_budget_begin(budget_ms)
    val nodes = parse_html(html)
    val rules = extract_css_vw(html, width)
    val child_index = build_child_index(nodes)
    val styles = compute_styles(nodes, rules, child_index)
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val white = argb(255, 255, 255)
    val widget_mode = simple_web_layout_uses_legacy_widget_chrome(html)
    val base = if widget_mode: argb(245, 245, 245) else: _web_canvas_background(nodes, styles, white)
    val fill_ops = _web_gpu_solid_fill_ops(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, width, height, widget_mode)
    if _web_gpu_solid_only_frame(nodes, styles, widget_mode):
        val gpu_fb = _web_gpu_simulate_fill_ops(fill_ops, width, height, base)
        return WebGpuPaintFrame(fb: gpu_fb, fill_ops: fill_ops, width: width, height: height, cpu_paint_pixels: 0)
    var fb = browser_layout_framebuffer_filled(base, width, height)
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    var painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, width, height, widget_mode)
    painted = _web_paint_iframes(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, rules, painted, width, height, 0)
    WebGpuPaintFrame(fb: painted, fill_ops: fill_ops, width: width, height: height, cpu_paint_pixels: width * height)

# Render at a scroll offset: lay out with the full scroll extent, then shift
# paint coordinates into the viewport so allocation stays bounded by WxH.
# This re-render approach keeps each call stateless.
pub fn simple_web_layout_render_html_software_pixels_at_scroll(html: text, width: i32, height: i32, scroll_y: i32, budget_ms: i64 = WEB_RENDER_BUDGET_MS) -> [u32]:
    _web_budget_begin(budget_ms)
    if width <= 0 or height <= 0:
        return []
    val clamp_scroll = if scroll_y < 0: 0 else: scroll_y
    val virtual_h = height + clamp_scroll
    val nodes = parse_html(html)
    val rules = extract_css_vw(html, width)
    val child_index = build_child_index(nodes)
    val styles = compute_styles(nodes, rules, child_index)
    val node_count = nodes.len() as i32
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        virtual_h,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val white = argb(255, 255, 255)
    val widget_mode = simple_web_layout_uses_legacy_widget_chrome(html)
    val base = if widget_mode: argb(245, 245, 245) else: _web_canvas_background(nodes, styles, white)
    var fb = browser_layout_framebuffer_filled(base, width, height)
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    val shifted_by = shifted_i32_list(boxes.by, 0 - clamp_scroll)
    var painted = paint(nodes, styles, boxes.bx, shifted_by, boxes.bw, boxes.bh, wrap_cache, fb, width, height, widget_mode)
    painted = _web_paint_iframes(nodes, styles, boxes.bx, shifted_by, boxes.bw, boxes.bh, rules, painted, width, height, 0)
    painted
