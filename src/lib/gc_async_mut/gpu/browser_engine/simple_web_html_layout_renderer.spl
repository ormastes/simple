# simple_web_html_layout_renderer.spl — a small but REAL HTML renderer in pure
# Simple, ported from examples/06_io/ui/mini_html_render.spl for the production web
# rendering path.
#
# Parses HTML into a flat node arena (avoiding the interpreter's nested-field
# push bug), applies inline + <style>-block CSS, does block-flow layout with
# word-wrapped text, and paints boxes + text into a staging [u32] framebuffer
# using a tiny 5x7 bitmap font. Engine2D presentation lives in a separate shim
# so Draw IR and software layout stay free of the GPU backend closure.
#
# Two interpreter bugs are worked around here (both worth a seed fix):
#   * text.index_of(needle, pos) IGNORES pos -> use find_from() (substring+find).
#   * obj.field.push() on an array element does not persist -> use a flat arena
#     of nodes keyed by integer parent index; only ever append to the top array.
#
# Public entry: simple_web_layout_render_html_software_pixels(html, w, h)
#   parse -> CSS cascade -> block layout -> paint text+boxes -> [u32]

use common.ui.draw_ir.{
    DRAW_IR_BACKEND_CPU,
    DrawIrCommand,
    DrawIrComposition,
    DrawIrStyleProp,
    draw_ir_batch_with_source,
    draw_ir_box_with_style,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_rect_bounds,
    draw_ir_source_html_ast,
    draw_ir_style_prop
}

# ---------------------------------------------------------------------------
# Flat node arena
# ---------------------------------------------------------------------------

class HNode:
    tag: text          # lowercased tag, "#text", or "#root"
    text_data: text    # text for #text nodes
    text_trimmed: text
    style_attr: text   # raw style="" value
    class_attr: text
    class_words: [text]
    has_widget_class: bool
    has_icon_image_class: bool
    has_widget_panel_class: bool
    has_widget_button_class: bool
    has_widget_image_class: bool
    has_focused_class: bool
    id_attr: text
    attrs_raw: text    # raw tag inner text for attribute selectors
    parent: i64        # index of parent in the arena (-1 for root)

class HtmlChildIndex:
    first_child: [i32]
    next_sibling: [i32]
    child_count: [i32]

fn mk_node(tag: text, parent: i64) -> HNode:
    HNode(tag: tag, text_data: "", text_trimmed: "", style_attr: "", class_attr: "", class_words: [], has_widget_class: false, has_icon_image_class: false, has_widget_panel_class: false, has_widget_button_class: false, has_widget_image_class: false, has_focused_class: false, id_attr: "", attrs_raw: "", parent: parent)

fn build_child_index(nodes: [HNode]) -> HtmlChildIndex:
    val node_count = nodes.len()
    var first_child: [i32] = [-1; node_count]
    var last_child: [i32] = [-1; node_count]
    var next_sibling: [i32] = [-1; node_count]
    var child_count: [i32] = [0; node_count]
    var i = 0
    while i < node_count:
        val parent = nodes[i].parent
        if parent >= 0 and parent < node_count:
            if first_child[parent] < 0:
                first_child[parent] = i
            else:
                next_sibling[last_child[parent]] = i
            last_child[parent] = i
            child_count[parent] = child_count[parent] + 1
        i = i + 1
    HtmlChildIndex(first_child: first_child, next_sibling: next_sibling, child_count: child_count)

# ---------------------------------------------------------------------------
# Position-aware string find (works around index_of(needle,pos) ignoring pos)
# ---------------------------------------------------------------------------

fn text_index_of(haystack: text, needle: text) -> i32:
    if needle.len() == 0:
        return 0
    if haystack.len() < needle.len():
        return -1
    var i = 0
    val limit = haystack.len() - needle.len()
    while i <= limit:
        if haystack.substring(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn find_from(s: text, needle: text, pos: i32) -> i32:
    if pos <= 0:
        return text_index_of(s, needle)
    if pos >= s.len():
        return -1
    val sub = s.substring(pos, s.len())
    val rel = text_index_of(sub, needle)
    if rel < 0:
        return -1
    pos + rel

fn is_void(tag: text) -> bool:
    tag == "meta" or tag == "br" or tag == "img" or tag == "input" or tag == "link" or tag == "hr" or tag == "area" or tag == "base" or tag == "col" or tag == "embed" or tag == "source" or tag == "track" or tag == "wbr"

# ---------------------------------------------------------------------------
# Attribute extraction (reads class/id/style out of the raw tag inner text)
# ---------------------------------------------------------------------------

fn attr_value(inner: text, name: text) -> text:
    # find name= and read the quoted value; simple, tolerant
    val key = name + "="
    val kpos = text_index_of(inner, key)
    if kpos < 0:
        return ""
    var i = kpos + key.len()
    if i >= inner.len():
        return ""
    val q = inner.substring(i, i + 1)
    if q == "\"" or q == "'":
        val sub = inner.substring(i + 1, inner.len())
        val end = text_index_of(sub, q)
        if end < 0:
            return ""
        return sub.substring(0, end)
    # unquoted: read to whitespace
    val sub = inner.substring(i, inner.len())
    var j = 0
    val sub_len = sub.len()
    while j < sub_len:
        val c = sub.substring(j, j + 1)
        if c == " " or c == "\t" or c == "\n" or c == "\r" or c == "/":
            break
        j = j + 1
    sub.substring(0, j)

fn tag_name_of(inner: text) -> text:
    var j = 0
    val m = inner.len()
    while j < m:
        val c = inner.substring(j, j + 1)
        if c == " " or c == "\t" or c == "\n" or c == "\r" or c == "/":
            break
        j = j + 1
    val nm = inner.substring(0, j)
    nm.lower()

fn split_class_words_trimmed(class_attr: text) -> [text]:
    var word_count = 1
    var i = 0
    val class_len = class_attr.len()
    while i < class_len:
        if class_attr.substring(i, i + 1) == " ":
            word_count = word_count + 1
        i = i + 1
    var words: [text] = [""; word_count]
    i = 0
    var start = 0
    var word_i = 0
    while i < class_len:
        if class_attr.substring(i, i + 1) == " ":
            words[word_i] = class_attr.substring(start, i).trim()
            word_i = word_i + 1
            start = i + 1
        i = i + 1
    words[word_i] = class_attr.substring(start, class_len).trim()
    words

# ---------------------------------------------------------------------------
# Parser -> arena
# ---------------------------------------------------------------------------

fn count_html_nodes(html: text) -> i32:
    var count = 1
    var pos = 0
    val n = html.len()
    while pos < n:
        val lt = find_from(html, "<", pos)
        if lt < 0:
            val tail = html.substring(pos, n)
            if tail.trim().len() > 0:
                count = count + 1
            break
        if lt > pos:
            val txt = html.substring(pos, lt)
            if txt.trim().len() > 0:
                count = count + 1
        val c4 = if lt + 4 <= n: html.substring(lt, lt + 4) else: ""
        if c4 == "<!--":
            val cend = find_from(html, "-->", lt)
            if cend < 0:
                break
            pos = cend + 3
            continue
        val gt = find_from(html, ">", lt)
        if gt < 0:
            break
        val inner = html.substring(lt + 1, gt)
        pos = gt + 1
        if inner.len() == 0:
            continue
        val first = inner.substring(0, 1)
        if first == "!" or first == "/":
            continue
        val name = tag_name_of(inner)
        if name == "style":
            val sclose = find_from(html, "</style", pos)
            if sclose >= 0:
                val sgt = find_from(html, ">", sclose)
                pos = if sgt >= 0: sgt + 1 else: sclose
            continue
        if name == "script":
            val cclose = find_from(html, "</script", pos)
            if cclose >= 0:
                val cgt = find_from(html, ">", cclose)
                pos = if cgt >= 0: cgt + 1 else: cclose
            continue
        if name == "title":
            val tclose = find_from(html, "</title", pos)
            if tclose >= 0:
                val tgt = find_from(html, ">", tclose)
                pos = if tgt >= 0: tgt + 1 else: tclose
            continue
        if name == "head" or name == "meta" or name == "link" or name == "base":
            continue
        count = count + 1
    count

fn parse_html(html: text) -> [HNode]:
    val node_count = count_html_nodes(html)
    var nodes: [HNode] = [mk_node("#root", -1); node_count]
    var node_i = 1
    var pstack: [i64] = [0]
    var pos = 0
    val n = html.len()
    while pos < n:
        val lt = find_from(html, "<", pos)
        if lt < 0:
            val tail = html.substring(pos, n)
            val tail_trimmed = tail.trim()
            if tail_trimmed.len() > 0:
                var tn = mk_node("#text", pstack[pstack.len() - 1])
                tn.text_data = tail
                tn.text_trimmed = tail_trimmed
                nodes[node_i] = tn
                node_i = node_i + 1
            break
        if lt > pos:
            val txt = html.substring(pos, lt)
            val txt_trimmed = txt.trim()
            if txt_trimmed.len() > 0:
                var tn = mk_node("#text", pstack[pstack.len() - 1])
                tn.text_data = txt
                tn.text_trimmed = txt_trimmed
                nodes[node_i] = tn
                node_i = node_i + 1
        # comment?
        val c4 = if lt + 4 <= n: html.substring(lt, lt + 4) else: ""
        if c4 == "<!--":
            val cend = find_from(html, "-->", lt)
            if cend < 0:
                break
            pos = cend + 3
            continue
        val gt = find_from(html, ">", lt)
        if gt < 0:
            break
        val inner = html.substring(lt + 1, gt)
        pos = gt + 1
        if inner.len() == 0:
            continue
        val first = inner.substring(0, 1)
        if first == "!":
            continue
        if first == "/":
            val cname = inner.substring(1, inner.len()).trim().lower()
            var k = pstack.len() - 1
            var found = -1
            while k >= 1:
                val pidx = pstack[k]
                if nodes[pidx].tag == cname:
                    found = k
                    break
                k = k - 1
            if found >= 1:
                val keep_stack_len = found
                var next_stack: [i64] = [0; keep_stack_len]
                var stack_i = 0
                while stack_i < keep_stack_len:
                    next_stack[stack_i] = pstack[stack_i]
                    stack_i = stack_i + 1
                pstack = next_stack
            continue
        val name = tag_name_of(inner)
        if name == "style":
            val sclose = find_from(html, "</style", pos)
            if sclose >= 0:
                val sgt = find_from(html, ">", sclose)
                pos = if sgt >= 0: sgt + 1 else: sclose
            continue
        if name == "script":
            val cclose = find_from(html, "</script", pos)
            if cclose >= 0:
                val cgt = find_from(html, ">", cclose)
                pos = if cgt >= 0: cgt + 1 else: cclose
            continue
        if name == "title":
            # <title> is document metadata, never painted. Consume its text so it
            # does not become a rendered #text node in the body flow.
            val tclose = find_from(html, "</title", pos)
            if tclose >= 0:
                val tgt = find_from(html, ">", tclose)
                pos = if tgt >= 0: tgt + 1 else: tclose
            continue
        if name == "head" or name == "meta" or name == "link" or name == "base":
            continue
        var node = mk_node(name, pstack[pstack.len() - 1])
        node.class_attr = attr_value(inner, "class")
        if node.class_attr.len() > 0:
            node.class_words = split_class_words_trimmed(node.class_attr)
            node.has_widget_class = class_contains(node.class_attr, "widget-")
            node.has_icon_image_class = class_contains(node.class_attr, "icon-image")
            node.has_widget_panel_class = class_contains(node.class_attr, "widget-panel")
            node.has_widget_button_class = class_contains(node.class_attr, "widget-button")
            node.has_widget_image_class = class_contains(node.class_attr, "widget-image")
            node.has_focused_class = class_contains(node.class_attr, "focused")
        node.id_attr = attr_value(inner, "id")
        node.style_attr = attr_value(inner, "style")
        node.attrs_raw = inner
        val current_index = node_i
        nodes[current_index] = node
        node_i = node_i + 1
        val self_close = inner.substring(inner.len() - 1, inner.len()) == "/"
        if not is_void(name) and not self_close:
            pstack.push(current_index)
    nodes

pub fn simple_web_layout_debug_attr_by_id(html: text, id: text, attr: text) -> text:
    val nodes = parse_html(html)
    var i = 0
    while i < nodes.len():
        val node = nodes[i]
        if node.id_attr == id:
            if attr == "style":
                return node.style_attr
            if attr == "class":
                return node.class_attr
            if attr == "id":
                return node.id_attr
            return attr_value(node.attrs_raw, attr)
        i = i + 1
    ""

pub fn simple_web_layout_debug_style_by_id(html: text, id: text, field: text) -> text:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules)
    var i = 0
    val node_count = nodes.len()
    while i < node_count:
        if nodes[i].id_attr == id:
            val st = styles[i]
            if field == "decl_width":
                return decl_get(nodes[i].style_attr, "width")
            if field == "decl_margin":
                return decl_get(nodes[i].style_attr, "margin")
            if field == "decl_height":
                return decl_get(nodes[i].style_attr, "height")
            if field == "parse_width":
                return parse_int(decl_get(nodes[i].style_attr, "width")).to_string()
            if field == "parse_margin":
                return parse_int(decl_get(nodes[i].style_attr, "margin")).to_string()
            if field == "parse_height":
                return parse_int(decl_get(nodes[i].style_attr, "height")).to_string()
            if field == "display":
                return st.display
            if field == "width":
                return st.width_px.to_string()
            if field == "height":
                return st.height_px.to_string()
            if field == "margin_l":
                return st.margin_l.to_string()
            if field == "flex_wrap":
                return st.flex_wrap
            if field == "flex_direction":
                return st.flex_direction
        i = i + 1
    ""

pub fn simple_web_layout_debug_layout_by_id(html: text, width: i32, height: i32, id: text, field: text) -> text:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules)
    val child_index = build_child_index(nodes)
    val node_count = nodes.len().to_i32()
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    var i = 0
    while i < node_count:
        if nodes[i].id_attr == id:
            if field == "x": return boxes.bx[i].to_string()
            if field == "y": return boxes.by[i].to_string()
            if field == "w": return boxes.bw[i].to_string()
            if field == "h": return boxes.bh[i].to_string()
        i = i + 1
    ""

# ---------------------------------------------------------------------------
# Minimal CSS color parsing (#rgb, #rrggbb, rgb()/rgba(), a few names)
# ---------------------------------------------------------------------------

fn hex_val(c: text) -> i32:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    val l = c.lower()
    if l == "a": return 10
    if l == "b": return 11
    if l == "c": return 12
    if l == "d": return 13
    if l == "e": return 14
    if l == "f": return 15
    0

fn dec_val(c: text) -> i32:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    10

fn argb(r: i32, g: i32, b: i32) -> u32:
    0xFF000000u32 | ((r.to_u32()) << 16) | ((g.to_u32()) << 8) | b.to_u32()

# returns packed u32, or 0 for "none/transparent/empty"
fn parse_color(raw: text) -> u32:
    val s = raw.trim().lower()
    if s.len() == 0 or s == "transparent" or s == "none" or s == "inherit":
        return 0u32
    if s == "white": return argb(255, 255, 255)
    if s == "black": return argb(0, 0, 0)
    if s == "red": return argb(220, 50, 50)
    if s.substring(0, 1) == "#":
        val h = s.substring(1, s.len())
        if h.len() >= 6:
            val r = hex_val(h.substring(0, 1)) * 16 + hex_val(h.substring(1, 2))
            val g = hex_val(h.substring(2, 3)) * 16 + hex_val(h.substring(3, 4))
            val b = hex_val(h.substring(4, 5)) * 16 + hex_val(h.substring(5, 6))
            return argb(r, g, b)
        if h.len() >= 3:
            val r = hex_val(h.substring(0, 1)) * 17
            val g = hex_val(h.substring(1, 2)) * 17
            val b = hex_val(h.substring(2, 3)) * 17
            return argb(r, g, b)
        return 0u32
    if s.substring(0, 3) == "rgb":
        val lp = text_index_of(s, "(")
        val rp = text_index_of(s, ")")
        if lp >= 0 and rp > lp:
            val inside = s.substring(lp + 1, rp)
            val parts = inside.split(",")
            if parts.len() >= 3:
                return argb(parse_int(parts[0]), parse_int(parts[1]), parse_int(parts[2]))
    0u32

fn parse_color_any(raw: text) -> u32:
    val direct = parse_color(raw)
    if direct != 0u32:
        return direct
    val lower = raw.lower()
    val rgb = text_index_of(lower, "rgb")
    if rgb >= 0:
        val rtail = raw.substring(rgb, raw.len())
        val rp = text_index_of(rtail, ")")
        if rp >= 0:
            val cv = parse_color(rtail.substring(0, rp + 1))
            if cv != 0u32:
                return cv
    val hash = text_index_of(raw, "#")
    if hash >= 0:
        return parse_color(raw.substring(hash, raw.len()))
    0u32

fn parse_int(s: text) -> i32:
    var i = 0
    var v = 0
    var matched_any_digit = false
    val s_len = s.len()
    while i < s_len:
        val c = s.substring(i, i + 1)
        val digit = dec_val(c)
        if digit < 10:
            v = v * 10 + digit
            matched_any_digit = true
        else:
            if matched_any_digit:
                break
        i = i + 1
    v

fn parse_nth_int(s: text, target: i32) -> i32:
    var i = 0
    var seen = 0
    val s_len = s.len()
    while i < s_len:
        val c = s.substring(i, i + 1)
        if dec_val(c) < 10:
            var v = 0
            while i < s_len:
                val d = s.substring(i, i + 1)
                val digit = dec_val(d)
                if digit >= 10:
                    break
                v = v * 10 + digit
                i = i + 1
            if seen == target:
                return v
            seen = seen + 1
        else:
            i = i + 1
    -1

fn parse_opacity_pct(raw: text) -> i32:
    val t = raw.trim()
    if t.len() == 0:
        return 100
    if t == "0":
        return 0
    if t == "1":
        return 100
    val dot = text_index_of(t, ".")
    if dot >= 0:
        var frac = 0
        var scale = 1
        var i = dot + 1
        val t_len = t.len()
        while i < t_len and scale < 100:
            val d = t.substring(i, i + 1)
            if d < "0" or d > "9":
                break
            frac = frac * 10 + hex_val(d)
            scale = scale * 10
            i = i + 1
        return (frac * 100 + scale / 2) / scale
    val pct = parse_int(t)
    if pct < 0:
        return 0
    if pct > 100:
        return 100
    pct

# read a property value from a declaration block "a: b; c: d"
fn decl_get(decls: text, prop: text) -> text:
    var pos = 0
    var found = ""
    val decls_len = decls.len()
    while pos < decls_len:
        val tail = decls.substring(pos, decls_len)
        val semi = text_index_of(tail, ";")
        val raw = if semi >= 0: tail.substring(0, semi) else: tail
        val colon = text_index_of(raw, ":")
        if colon >= 0:
            val name = raw.substring(0, colon).trim().lower()
            if name == prop:
                found = raw.substring(colon + 1, raw.len()).trim()
        if semi < 0:
            break
        pos = pos + semi + 1
    found

fn decl_last_pos(decls: text, prop: text) -> i32:
    var pos = 0
    var found = -1
    val decls_len = decls.len()
    while pos < decls_len:
        val tail = decls.substring(pos, decls_len)
        val semi = text_index_of(tail, ";")
        val raw = if semi >= 0: tail.substring(0, semi) else: tail
        val colon = text_index_of(raw, ":")
        if colon >= 0:
            val name = raw.substring(0, colon).trim().lower()
            if name == prop:
                found = pos
        if semi < 0:
            break
        pos = pos + semi + 1
    found

# ---------------------------------------------------------------------------
# Computed style
# ---------------------------------------------------------------------------

class Style:
    bg: u32
    fg: u32
    font_size: i32
    line_height_px: i32
    width_px: i32
    height_px: i32
    border_box: bool
    min_width_px: i32
    max_width_px: i32
    min_height_px: i32
    min_height_vh: bool
    flex_fill: bool
    flex_grow: i32
    flex_shrink: i32
    flex_basis_px: i32
    flex_wrap: text
    justify_content: text
    align_items: text
    align_self: text
    align_content: text
    pad_l: i32
    pad_t: i32
    pad_r: i32
    pad_b: i32
    border_w: i32
    border_color: u32
    border_l: i32
    border_t: i32
    border_r: i32
    border_b: i32
    border_color_l: u32
    border_color_t: u32
    border_color_r: u32
    border_color_b: u32
    gap_px: i32
    margin_l: i32
    margin_t: i32
    margin_r: i32
    margin_b: i32
    display: text       # block / inline / contents / none
    overflow_hidden: bool
    overflow_auto_y: bool
    visibility_hidden: bool
    position_relative: bool
    position_absolute: bool
    left_px: i32
    top_px: i32
    right_px: i32
    bottom_px: i32
    z_index: i32
    opacity_pct: i32
    flex_direction: text
    text_align: text
    bold: bool

fn default_style() -> Style:
