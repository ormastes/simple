    var object_fit_v = st.object_fit
    var object_position_v = st.object_position
    var bold_v = st.bold
    val font_decl = decl_get(decls, "font")
    val font_pos = decl_last_pos(decls, "font")
    if font_decl.len() > 0:
        val font_raw = font_decl.trim()
        val font_norm = font_raw.lower()
        font_style_italic_v = false
        bold_v = false
        if font_norm.contains("italic") or font_norm.contains("oblique"):
            font_style_italic_v = true
        if font_norm.contains("bold") or font_norm.contains("700") or font_norm.contains("600") or font_norm.contains("800"):
            bold_v = true
        # The size component of a `font:` shorthand is the number attached to
        # "px" — a bare leading number is the WEIGHT ("font: 600 11px system-ui"
        # must not become font-size 600px, which rendered screen-filling glyphs).
        val parsed_font_size = parse_font_shorthand_size_px(font_norm)
        if parsed_font_size > 0:
            font_size_v = parsed_font_size
        val shorthand_family = parse_font_shorthand_family(font_raw)
        if shorthand_family != "":
            font_family_v = shorthand_family
        val slash = find_from(font_norm, "/", 0)
        if slash >= 0 and slash + 1 < font_norm.len():
            val after_slash = font_norm.substring(slash + 1, font_norm.len()).trim()
            val slash_space = find_from(after_slash, " ", 0)
            val line_part = if slash_space >= 0: after_slash.substring(0, slash_space) else: after_slash
            val parsed_line_height = parse_line_height_value(line_part)
            if parsed_line_height != 0:
                line_height_v = parsed_line_height
    val font_family_decl = decl_get(decls, "font-family").trim()
    if font_family_decl != "" and decl_last_pos(decls, "font-family") > font_pos:
        font_family_v = font_family_decl
    val bg = decl_get(decls, "background-color")
    val bgs = decl_get(decls, "background")
    val bg_image = decl_get(decls, "background-image")
    val bg_repeat = decl_get(decls, "background-repeat")
    val bg_size = decl_get(decls, "background-size")
    val bg_position = decl_get(decls, "background-position")
    val bg_attachment = decl_get(decls, "background-attachment")
    val bg_pos = decl_last_pos(decls, "background-color")
    val bgs_pos = decl_last_pos(decls, "background")
    if bg_pos >= 0 or bgs_pos >= 0:
        if bgs_pos > bg_pos:
            # keep the raw multi-layer value when it carries radial layers the
            # scalar Style fields cannot represent (painted by the stack path)
            bg_layers_raw_v = if bgs.lower().contains("radial-gradient("): bgs else: ""
            val gradient_from = parse_linear_gradient_color(bgs, 0)
            val gradient_to = parse_linear_gradient_color(bgs, 1)
            if gradient_from != 0u32 and gradient_to != 0u32:
                background_gradient_from_v = gradient_from
                background_gradient_to_v = gradient_to
            elif bgs.contains("gradient("):
                # multi-layer / nested-rgba shorthand the simple splitter can't
                # handle (e.g. "linear-gradient(180deg, rgba(...), rgba(...)), #f5f5f5")
                val bg_layers = parse_background_layers(bgs)
                if bg_layers.base_color != 0u32:
                    bg_v = bg_layers.base_color
                if bg_layers.gradient_from != 0u32 and bg_layers.gradient_to != 0u32:
                    background_gradient_from_v = bg_layers.gradient_from
                    background_gradient_to_v = bg_layers.gradient_to
                else:
                    background_gradient_from_v = 0u32
                    background_gradient_to_v = 0u32
                    if bg_layers.base_color == 0u32:
                        bg_v = parse_color_alpha(bgs)
            else:
                bg_v = parse_color_alpha(bgs)
                background_gradient_from_v = 0u32
                background_gradient_to_v = 0u32
        else:
            bg_v = parse_color_alpha(bg)
            background_gradient_from_v = 0u32
            background_gradient_to_v = 0u32
    if bg_image.len() > 0:
        val image_lower = bg_image.trim().lower()
        if image_lower == "none":
            background_gradient_from_v = 0u32
            background_gradient_to_v = 0u32
        else:
            val gradient_from = parse_linear_gradient_color(bg_image, 0)
            val gradient_to = parse_linear_gradient_color(bg_image, 1)
            if gradient_from != 0u32 and gradient_to != 0u32:
                background_gradient_from_v = gradient_from
                background_gradient_to_v = gradient_to
    if bg_repeat.len() > 0:
        val repeat_lower = bg_repeat.trim().lower()
        if repeat_lower == "no-repeat" or repeat_lower == "repeat":
            background_repeat_v = repeat_lower
    if bg_size.len() > 0:
        val size_trimmed = bg_size.trim()
        val first_space = find_from(size_trimmed, " ", 0)
        val first_size = if first_space >= 0: size_trimmed.substring(0, first_space) else: size_trimmed
        if first_size.len() > 0:
            val sw = parse_int(first_size)
            if sw > 0:
                background_size_w_px_v = sw
        if first_space >= 0:
            val second_size = size_trimmed.substring(first_space + 1, size_trimmed.len()).trim()
            val sh = parse_int(second_size)
            if sh > 0:
                background_size_h_px_v = sh
        elif background_size_w_px_v > 0:
            background_size_h_px_v = background_size_w_px_v
    if bg_position.len() > 0:
        val pos_trimmed = bg_position.trim()
        val first_space = find_from(pos_trimmed, " ", 0)
        val first_pos = if first_space >= 0: pos_trimmed.substring(0, first_space) else: pos_trimmed
        if first_pos.len() > 0:
            background_position_x_px_v = parse_int(first_pos)
        if first_space >= 0:
            val second_pos = pos_trimmed.substring(first_space + 1, pos_trimmed.len()).trim()
            background_position_y_px_v = parse_int(second_pos)
    val bg_clip = decl_get(decls, "background-clip")
    if bg_clip.len() > 0:
        val bg_clip_norm = bg_clip.trim().lower()
        if bg_clip_norm == "border-box" or bg_clip_norm == "padding-box" or bg_clip_norm == "content-box":
            background_clip_v = bg_clip_norm
    val bg_origin = decl_get(decls, "background-origin")
    if bg_origin.len() > 0:
        val bg_origin_norm = bg_origin.trim().lower()
        if bg_origin_norm == "border-box" or bg_origin_norm == "padding-box" or bg_origin_norm == "content-box":
            background_origin_v = bg_origin_norm
    if bg_attachment.len() > 0:
        val bg_attachment_norm = bg_attachment.trim().lower()
        if bg_attachment_norm == "scroll" or bg_attachment_norm == "fixed" or bg_attachment_norm == "local":
            background_attachment_v = bg_attachment_norm
    val col = decl_get(decls, "color")
    if col.len() > 0:
        val cv = parse_color(col)
        if cv != 0u32:
            fg_v = cv
    val fs = decl_get(decls, "font-size")
    val fs_pos = decl_last_pos(decls, "font-size")
    if fs.len() > 0 and (font_pos < 0 or fs_pos > font_pos):
        val fsl = fs.trim().lower()
        if fsl.ends_with("rem"):
            # rem is relative to the root font-size (16px default).
            val computed = (16 * parse_decimal_x10(fsl)) / 10
            if computed > 0:
                font_size_v = computed
        elif fsl.ends_with("em"):
            # em is relative to the inherited (parent) font-size.
            val computed = (em_base * parse_decimal_x10(fsl)) / 10
            if computed > 0:
                font_size_v = computed
        elif fsl.ends_with("%"):
            # percent font-size is relative to the inherited font-size.
            val computed = (em_base * parse_int(fsl)) / 100
            if computed > 0:
                font_size_v = computed
        else:
            val v = parse_int(fs)
            if v > 0:
                font_size_v = v
    val font_size_adjust_decl = decl_get(decls, "font-size-adjust")
    if font_size_adjust_decl.len() > 0:
        val font_size_adjust_norm = font_size_adjust_decl.trim().lower()
        if font_size_adjust_norm == "none" or font_size_adjust_norm == "from-font" or parse_int(font_size_adjust_norm) >= 0:
            font_size_adjust_v = font_size_adjust_norm
    val font_palette_decl = decl_get(decls, "font-palette")
    if font_palette_decl.len() > 0:
        val font_palette_norm = font_palette_decl.trim().lower()
        if font_palette_norm == "normal" or font_palette_norm == "light" or font_palette_norm == "dark":
            font_palette_v = font_palette_norm
    val font_feature_settings_decl = decl_get(decls, "font-feature-settings")
    if font_feature_settings_decl.len() > 0:
        val font_feature_settings_norm = font_feature_settings_decl.trim().lower()
        if font_feature_settings_norm.len() > 0:
            font_feature_settings_v = font_feature_settings_norm
    val line_height = decl_get(decls, "line-height")
    val line_height_pos = decl_last_pos(decls, "line-height")
    if line_height.len() > 0 and (font_pos < 0 or line_height_pos > font_pos):
        val parsed_line_height = parse_line_height_value(line_height)
        if parsed_line_height != 0:
            line_height_v = parsed_line_height
    val width = decl_get(decls, "width")
    val width_pos = decl_last_pos(decls, "width")
    if width.len() > 0:
        if width.ends_with("%"):
            # Percentage width: store as a negative sentinel (resolved against the
            # parent's available width at layout time, where it is known).
            val wp = parse_int(width)
            width_v = if wp > 0: 0 - wp else: 0
        elif width.ends_with("vw"):
            # Viewport width unit: exact for viewport-level elements (parent ==
            # viewport). Reuse the percent sentinel so it resolves against the
            # parent's available width at layout time.
            val wv = parse_int(width)
            width_v = if wv > 0: 0 - wv else: 0
        else:
            width_v = parse_int(width)
    val height = decl_get(decls, "height")
    val height_pos = decl_last_pos(decls, "height")
    if height.len() > 0:
        if height.ends_with("%"):
            val hp = parse_int(height)
            height_v = if hp > 0: 0 - hp else: 0
        else:
            height_v = parse_int(height)
    val inline_size = decl_get(decls, "inline-size")
    val inline_size_pos = decl_last_pos(decls, "inline-size")
    if inline_size.len() > 0 and inline_size_pos > width_pos:
        if inline_size.ends_with("%"):
            val isp = parse_int(inline_size)
            width_v = if isp > 0: 0 - isp else: 0
        else:
            width_v = parse_int(inline_size)
    val block_size = decl_get(decls, "block-size")
    val block_size_pos = decl_last_pos(decls, "block-size")
    if block_size.len() > 0 and block_size_pos > height_pos:
        if block_size.ends_with("%"):
            val bsp = parse_int(block_size)
            height_v = if bsp > 0: 0 - bsp else: 0
        else:
            height_v = parse_int(block_size)
    val aspect_ratio = decl_get(decls, "aspect-ratio")
    if aspect_ratio.len() > 0:
        val ar_num = parse_aspect_ratio_numerator(aspect_ratio)
        val ar_den = parse_aspect_ratio_denominator(aspect_ratio)
        if ar_num > 0 and ar_den > 0:
            if width_v > 0 and height_v == 0:
                height_v = (width_v * ar_den) / ar_num
            elif height_v > 0 and width_v == 0:
                width_v = (height_v * ar_num) / ar_den
    val box_sizing = decl_get(decls, "box-sizing")
    if box_sizing.len() > 0:
        border_box_v = box_sizing == "border-box"
    val border_radius = decl_get(decls, "border-radius")
    if border_radius.len() > 0:
        val radius_v = parse_int(border_radius)
        border_radius_px_v = if radius_v > 0: radius_v else: 0
        border_radius_tl_px_v = border_radius_px_v
        border_radius_tr_px_v = border_radius_px_v
        border_radius_br_px_v = border_radius_px_v
        border_radius_bl_px_v = border_radius_px_v
    val border_top_left_radius = decl_get(decls, "border-top-left-radius")
    if border_top_left_radius.len() > 0:
        val r_tl = parse_int(border_top_left_radius)
        border_radius_tl_px_v = if r_tl > 0: r_tl else: 0
    val border_top_right_radius = decl_get(decls, "border-top-right-radius")
    if border_top_right_radius.len() > 0:
        val r_tr = parse_int(border_top_right_radius)
        border_radius_tr_px_v = if r_tr > 0: r_tr else: 0
    val border_bottom_right_radius = decl_get(decls, "border-bottom-right-radius")
    if border_bottom_right_radius.len() > 0:
        val r_br = parse_int(border_bottom_right_radius)
        border_radius_br_px_v = if r_br > 0: r_br else: 0
    val border_bottom_left_radius = decl_get(decls, "border-bottom-left-radius")
    if border_bottom_left_radius.len() > 0:
        val r_bl = parse_int(border_bottom_left_radius)
        border_radius_bl_px_v = if r_bl > 0: r_bl else: 0
    val border_start_start_radius = decl_get(decls, "border-start-start-radius")
    if border_start_start_radius.len() > 0:
        val r_ss = parse_int(border_start_start_radius)
        border_radius_tl_px_v = if r_ss > 0: r_ss else: 0
    val border_start_end_radius = decl_get(decls, "border-start-end-radius")
    if border_start_end_radius.len() > 0:
        val r_se = parse_int(border_start_end_radius)
        border_radius_tr_px_v = if r_se > 0: r_se else: 0
    val border_end_start_radius = decl_get(decls, "border-end-start-radius")
    if border_end_start_radius.len() > 0:
        val r_es = parse_int(border_end_start_radius)
        border_radius_bl_px_v = if r_es > 0: r_es else: 0
    val border_end_end_radius = decl_get(decls, "border-end-end-radius")
    if border_end_end_radius.len() > 0:
        val r_ee = parse_int(border_end_end_radius)
        border_radius_br_px_v = if r_ee > 0: r_ee else: 0
    val min_width = decl_get(decls, "min-width")
    val min_width_pos = decl_last_pos(decls, "min-width")
    if min_width.len() > 0:
        min_width_v = parse_int(min_width)
    val max_width = decl_get(decls, "max-width")
    val max_width_pos = decl_last_pos(decls, "max-width")
    if max_width.len() > 0:
        max_width_v = parse_int(max_width)
    val min_height = decl_get(decls, "min-height")
    val min_height_pos = decl_last_pos(decls, "min-height")
    if min_height.len() > 0:
        if min_height.contains("vh"):
            min_height_vh_v = true
        else:
            min_height_v = parse_int(min_height)
    val max_height = decl_get(decls, "max-height")
    val max_height_pos = decl_last_pos(decls, "max-height")
    if max_height.len() > 0:
        max_height_v = parse_int(max_height)
    val min_inline_size = decl_get(decls, "min-inline-size")
    if min_inline_size.len() > 0 and decl_last_pos(decls, "min-inline-size") > min_width_pos:
        min_width_v = parse_int(min_inline_size)
    val max_inline_size = decl_get(decls, "max-inline-size")
    if max_inline_size.len() > 0 and decl_last_pos(decls, "max-inline-size") > max_width_pos:
        max_width_v = parse_int(max_inline_size)
    val min_block_size = decl_get(decls, "min-block-size")
    if min_block_size.len() > 0 and decl_last_pos(decls, "min-block-size") > min_height_pos:
        if min_block_size.contains("vh"):
            min_height_vh_v = true
        else:
            min_height_v = parse_int(min_block_size)
    val max_block_size = decl_get(decls, "max-block-size")
    if max_block_size.len() > 0 and decl_last_pos(decls, "max-block-size") > max_height_pos:
        max_height_v = parse_int(max_block_size)
    val flex = decl_get(decls, "flex")
    if flex.len() > 0:
        val flex_grow_raw = parse_nth_int(flex, 0)
        if flex_grow_raw >= 0:
            flex_grow_v = flex_grow_raw
        val flex_shrink_raw = parse_nth_int(flex, 1)
        if flex_shrink_raw >= 0:
            flex_shrink_v = flex_shrink_raw
        val flex_basis_raw = parse_nth_int(flex, 2)
        if flex_basis_raw > 0:
            flex_basis_px_v = flex_basis_raw
    val flex_grow_decl = decl_get(decls, "flex-grow")
    if flex_grow_decl.len() > 0:
        val grow_v = parse_int(flex_grow_decl)
        if grow_v > 0:
            flex_grow_v = grow_v
    val flex_shrink_decl = decl_get(decls, "flex-shrink")
    if flex_shrink_decl.len() > 0:
        val shrink_v = parse_int(flex_shrink_decl)
        if shrink_v >= 0:
            flex_shrink_v = shrink_v
    val flex_basis_decl = decl_get(decls, "flex-basis")
    if flex_basis_decl.len() > 0:
        val basis_v = parse_int(flex_basis_decl)
        if basis_v > 0:
            flex_basis_px_v = basis_v
    val order_decl = decl_get(decls, "order")
    if order_decl.len() > 0:
        order_v = parse_int(order_decl)
    val display_decl = decl_get(decls, "display")
    if display_decl.len() > 0:
        if display_decl == "none":
            display_v = "none"
        elif display_decl == "inline":
            display_v = "inline"
        elif display_decl == "flex":
            display_v = "flex"
        elif display_decl == "contents":
            display_v = "contents"
        else:
            display_v = "block"
    val overflow_decl = decl_get(decls, "overflow")
    if overflow_decl.len() > 0:
        overflow_hidden_v = overflow_decl == "hidden"
        if overflow_decl == "auto" or overflow_decl == "scroll":
            overflow_auto_y_v = true
    val overflow_x_decl = decl_get(decls, "overflow-x")
    if overflow_x_decl.len() > 0:
        if overflow_x_decl == "hidden":
            overflow_hidden_v = true
    val overflow_y_decl = decl_get(decls, "overflow-y")
    if overflow_y_decl.len() > 0:
        if overflow_y_decl == "hidden":
            overflow_hidden_v = true
        if overflow_y_decl == "auto" or overflow_y_decl == "scroll":
            overflow_auto_y_v = true
    if overflow_x_decl == "hidden" and overflow_y_decl == "visible":
        overflow_auto_y_v = true
    val contain_decl = decl_get(decls, "contain")
    if contain_decl.len() > 0:
        val contain_norm = contain_decl.trim().lower()
        if contain_norm.contains("paint") or contain_norm == "content" or contain_norm == "strict":
            overflow_hidden_v = true
    val color_scheme_decl = decl_get(decls, "color-scheme")
    if color_scheme_decl.len() > 0:
        val color_scheme_norm = color_scheme_decl.trim().lower()
        if color_scheme_norm.contains("dark"):
            if bg_v == 0u32:
                bg_v = argb(17, 24, 39)
            if fg_v == argb(0, 0, 0):
                fg_v = argb(248, 250, 252)
    val scrollbar_width_decl = decl_get(decls, "scrollbar-width")
    if scrollbar_width_decl.len() > 0:
        val scrollbar_width_norm = scrollbar_width_decl.trim().lower()
        if scrollbar_width_norm == "none":
            overflow_auto_y_v = false
    val scrollbar_color_decl = decl_get(decls, "scrollbar-color")
    if scrollbar_color_decl.len() > 0:
        val scrollbar_color_norm = scrollbar_color_decl.trim().lower()
        if scrollbar_color_norm != "auto":
            val scrollbar_color_parts = scrollbar_color_norm.split(" ")
            if scrollbar_color_parts.len() >= 2:
                val thumb_color = parse_color_any(scrollbar_color_parts[0])
                val track_color = parse_color_any(scrollbar_color_parts[1])
                if thumb_color != 0u32 and track_color != 0u32:
                    scrollbar_thumb_color_v = thumb_color
                    scrollbar_track_color_v = track_color
    val text_overflow_decl = decl_get(decls, "text-overflow")
    if text_overflow_decl.len() > 0:
        val text_overflow_norm = text_overflow_decl.trim().lower()
        text_overflow_ellipsis_v = text_overflow_norm == "ellipsis"
    val visibility_decl = decl_get(decls, "visibility")
    if visibility_decl.len() > 0:
        if visibility_decl == "hidden":
            visibility_hidden_v = true
        elif visibility_decl == "visible":
            visibility_hidden_v = false
    val content_visibility_decl = decl_get(decls, "content-visibility")
    if content_visibility_decl.len() > 0:
        val content_visibility_norm = content_visibility_decl.trim().lower()
        if content_visibility_norm == "hidden":
            content_visibility_hidden_v = true
        elif content_visibility_norm == "visible" or content_visibility_norm == "auto":
            content_visibility_hidden_v = false
    val color_adjust_decl = decl_get(decls, "color-adjust")
    if color_adjust_decl.len() > 0:
        val color_adjust_norm = color_adjust_decl.trim().lower()
        if color_adjust_norm == "economy" or color_adjust_norm == "exact":
            color_adjust_v = color_adjust_norm
    val forced_color_adjust_decl = decl_get(decls, "forced-color-adjust")
    if forced_color_adjust_decl.len() > 0:
        val forced_color_adjust_norm = forced_color_adjust_decl.trim().lower()
        if forced_color_adjust_norm == "auto" or forced_color_adjust_norm == "none" or forced_color_adjust_norm == "preserve-parent-color":
            forced_color_adjust_v = forced_color_adjust_norm
    val print_color_adjust_decl = decl_get(decls, "print-color-adjust")
    if print_color_adjust_decl.len() > 0:
        val print_color_adjust_norm = print_color_adjust_decl.trim().lower()
        if print_color_adjust_norm == "economy" or print_color_adjust_norm == "exact":
            print_color_adjust_v = print_color_adjust_norm
    val orphans_decl = decl_get(decls, "orphans")
    if orphans_decl.len() > 0:
        val orphans_parsed = parse_int(orphans_decl)
        if orphans_parsed > 0:
            orphans_v = orphans_parsed
    val widows_decl = decl_get(decls, "widows")
    if widows_decl.len() > 0:
        val widows_parsed = parse_int(widows_decl)
        if widows_parsed > 0:
            widows_v = widows_parsed
    val will_change_decl = decl_get(decls, "will-change")
    if will_change_decl.len() > 0:
        val will_change_norm = will_change_decl.trim().lower()
        if will_change_norm == "auto" or will_change_norm == "scroll-position" or will_change_norm == "contents" or will_change_norm.contains("transform") or will_change_norm.contains("opacity") or will_change_norm.contains("left") or will_change_norm.contains("top"):
            will_change_v = will_change_norm
    val position_decl = decl_get(decls, "position")
    if position_decl.len() > 0:
        if position_decl == "relative":
            position_relative_v = true
            position_absolute_v = false
        elif position_decl == "absolute":
            position_relative_v = false
            position_absolute_v = true
        else:
            position_relative_v = false
            position_absolute_v = false
    val left_decl = decl_get(decls, "left")
    val left_pos = decl_last_pos(decls, "left")
    if left_decl.len() > 0:
        left_px_v = parse_int(left_decl)
    val top_decl = decl_get(decls, "top")
    val top_pos = decl_last_pos(decls, "top")
    if top_decl.len() > 0:
        top_px_v = parse_int(top_decl)
    val right_decl = decl_get(decls, "right")
    val right_pos = decl_last_pos(decls, "right")
    if right_decl.len() > 0:
        right_px_v = parse_int(right_decl)
    val bottom_decl = decl_get(decls, "bottom")
    val bottom_pos = decl_last_pos(decls, "bottom")
    if bottom_decl.len() > 0:
        bottom_px_v = parse_int(bottom_decl)
    val inset_decl = decl_get(decls, "inset")
    val inset_pos = decl_last_pos(decls, "inset")
    if inset_decl.len() > 0:
        val inset_top = parse_nth_box_int(inset_decl, 0)
        val inset_right = parse_nth_box_int(inset_decl, 1)
        val inset_bottom = parse_nth_box_int(inset_decl, 2)
        val inset_left = parse_nth_box_int(inset_decl, 3)
        if inset_pos > top_pos:
            top_px_v = inset_top
        if inset_pos > right_pos:
            right_px_v = inset_right
        if inset_pos > bottom_pos:
            bottom_px_v = inset_bottom
        if inset_pos > left_pos:
            left_px_v = inset_left
    val inset_block = decl_get(decls, "inset-block")
    val inset_block_pos = decl_last_pos(decls, "inset-block")
    if inset_block.len() > 0:
        val ib0 = parse_nth_box_int(inset_block, 0)
        val ib1 = parse_nth_box_int(inset_block, 1)
        if inset_block_pos > top_pos:
            top_px_v = ib0
        if inset_block_pos > bottom_pos:
            bottom_px_v = ib1
    val inset_inline = decl_get(decls, "inset-inline")
    val inset_inline_pos = decl_last_pos(decls, "inset-inline")
    if inset_inline.len() > 0:
        val ii0 = parse_nth_box_int(inset_inline, 0)
        val ii1 = parse_nth_box_int(inset_inline, 1)
        if inset_inline_pos > left_pos:
            left_px_v = ii0
        if inset_inline_pos > right_pos:
            right_px_v = ii1
    val inset_block_start = decl_get(decls, "inset-block-start")
    if inset_block_start.len() > 0 and decl_last_pos(decls, "inset-block-start") > top_pos:
        top_px_v = parse_int(inset_block_start)
    val inset_block_end = decl_get(decls, "inset-block-end")
    if inset_block_end.len() > 0 and decl_last_pos(decls, "inset-block-end") > bottom_pos:
        bottom_px_v = parse_int(inset_block_end)
    val inset_inline_start = decl_get(decls, "inset-inline-start")
    if inset_inline_start.len() > 0 and decl_last_pos(decls, "inset-inline-start") > left_pos:
        left_px_v = parse_int(inset_inline_start)
    val inset_inline_end = decl_get(decls, "inset-inline-end")
    if inset_inline_end.len() > 0 and decl_last_pos(decls, "inset-inline-end") > right_pos:
        right_px_v = parse_int(inset_inline_end)
    val z_index_decl = decl_get(decls, "z-index")
    if z_index_decl.len() > 0:
        z_index_v = parse_int(z_index_decl)
    val opacity_decl = decl_get(decls, "opacity")
    if opacity_decl.len() > 0:
        opacity_pct_v = parse_opacity_pct(opacity_decl)
    val filter_decl = decl_get(decls, "filter")
    if filter_decl.len() > 0:
        val filter_opacity_pct = parse_filter_opacity_pct(filter_decl)
        if filter_opacity_pct >= 0:
            opacity_pct_v = (opacity_pct_v * filter_opacity_pct) / 100
    val clip_decl = decl_get(decls, "clip")
    if clip_decl.len() > 0:
        val clip_right = parse_clip_rect_value(clip_decl, 1)
        val clip_bottom = parse_clip_rect_value(clip_decl, 2)
        val clip_left = parse_clip_rect_value(clip_decl, 3)
        val clipped_w = clip_right - clip_left
        if clipped_w > 0 and width_v > 0 and clipped_w < width_v:
            width_v = clipped_w
        if clip_bottom > 0 and height_v > 0 and clip_bottom < height_v:
            height_v = clip_bottom
    val transform_decl = decl_get(decls, "transform")
    if transform_decl.len() > 0:
        val translate_x = parse_transform_translate_x(transform_decl)
        val translate_y = parse_transform_translate_y(transform_decl)
        if translate_x != 0 or translate_y != 0:
            left_px_v = left_px_v + translate_x
            top_px_v = top_px_v + translate_y
            position_relative_v = true
        val transform_scale_pct = parse_transform_scale_pct(transform_decl)
        if transform_scale_pct != 100:
            if width_v > 0:
                width_v = (width_v * transform_scale_pct) / 100
            if height_v > 0:
                height_v = (height_v * transform_scale_pct) / 100
        if parse_transform_rotate_quarter_turn(transform_decl) and width_v > 0 and height_v > 0:
            val old_width = width_v
            width_v = height_v
            height_v = old_width
    val translate_decl = decl_get(decls, "translate")
    if translate_decl.len() > 0:
        val individual_translate_x = parse_individual_translate_x(translate_decl)
        val individual_translate_y = parse_individual_translate_y(translate_decl)
        if individual_translate_x != 0 or individual_translate_y != 0:
            left_px_v = left_px_v + individual_translate_x
            top_px_v = top_px_v + individual_translate_y
            position_relative_v = true
    val scale_decl = decl_get(decls, "scale")
    if scale_decl.len() > 0:
        val scale_pct = parse_scale_pct(scale_decl)
        if scale_pct != 100:
            if width_v > 0:
                width_v = (width_v * scale_pct) / 100
            if height_v > 0:
                height_v = (height_v * scale_pct) / 100
    val rotate_decl = decl_get(decls, "rotate")
    if rotate_decl.len() > 0:
        if parse_rotate_quarter_turn(rotate_decl) and width_v > 0 and height_v > 0:
            val old_width = width_v
            width_v = height_v
            height_v = old_width
    val transform_origin_decl = decl_get(decls, "transform-origin")
    if transform_origin_decl.len() > 0:
        transform_origin_v = transform_origin_decl.trim().lower()
    val transform_box_decl = decl_get(decls, "transform-box")
    if transform_box_decl.len() > 0:
        val transform_box_norm = transform_box_decl.trim().lower()
        if transform_box_norm == "content-box" or transform_box_norm == "border-box" or transform_box_norm == "fill-box" or transform_box_norm == "stroke-box" or transform_box_norm == "view-box":
            transform_box_v = transform_box_norm
    val transform_style_decl = decl_get(decls, "transform-style")
    if transform_style_decl.len() > 0:
        val transform_style_norm = transform_style_decl.trim().lower()
        if transform_style_norm == "flat" or transform_style_norm == "preserve-3d":
            transform_style_v = transform_style_norm
    val object_fit_decl = decl_get(decls, "object-fit")
    if object_fit_decl.len() > 0:
        val object_fit_norm = object_fit_decl.trim().lower()
        if object_fit_norm == "fill" or object_fit_norm == "contain" or object_fit_norm == "cover" or object_fit_norm == "none" or object_fit_norm == "scale-down":
            object_fit_v = object_fit_norm
    val image_rendering_decl = decl_get(decls, "image-rendering")
    if image_rendering_decl.len() > 0:
        val image_rendering_norm = image_rendering_decl.trim().lower()
        if image_rendering_norm == "auto" or image_rendering_norm == "smooth" or image_rendering_norm == "crisp-edges" or image_rendering_norm == "pixelated":
            image_rendering_v = image_rendering_norm
    val object_position_decl = decl_get(decls, "object-position")
    if object_position_decl.len() > 0:
        object_position_v = object_position_decl.trim().lower()
    val flex_direction_decl = decl_get(decls, "flex-direction")
    if flex_direction_decl.len() > 0:
        if flex_direction_decl == "column":
            flex_direction_v = "column"
        else:
            flex_direction_v = "row"
    val flex_wrap_decl = decl_get(decls, "flex-wrap")
    if flex_wrap_decl.len() > 0:
        if flex_wrap_decl == "wrap" or flex_wrap_decl == "wrap-reverse" or flex_wrap_decl == "nowrap":
            flex_wrap_v = flex_wrap_decl
    val flex_flow_decl = decl_get(decls, "flex-flow")
    if flex_flow_decl.len() > 0:
        if css_word_contains(flex_flow_decl, "column"):
            flex_direction_v = "column"
        elif css_word_contains(flex_flow_decl, "row"):
            flex_direction_v = "row"
        if css_word_contains(flex_flow_decl, "wrap-reverse"):
            flex_wrap_v = "wrap-reverse"
        elif css_word_contains(flex_flow_decl, "wrap"):
            flex_wrap_v = "wrap"
        elif css_word_contains(flex_flow_decl, "nowrap"):
            flex_wrap_v = "nowrap"
    val justify_content_decl = decl_get(decls, "justify-content")
    if justify_content_decl.len() > 0:
        val normalized_justify_content = normalize_overflow_box_alignment(justify_content_decl)
        if supports_content_distribution_alignment(normalized_justify_content):
            justify_content_v = normalized_justify_content
    val place_content_decl = decl_get(decls, "place-content")
    if place_content_decl.len() > 0:
        val normalized_place_content = normalize_overflow_box_alignment(place_content_decl)
        if supports_content_distribution_alignment(normalized_place_content):
            align_content_v = normalized_place_content
            justify_content_v = normalized_place_content
        else:
            val place_content_parts = normalized_place_content.split(" ")
            if place_content_parts.len() == 2:
                val place_align = normalize_overflow_box_alignment(place_content_parts[0])
                val place_justify = normalize_overflow_box_alignment(place_content_parts[1])
                if supports_align_content_alignment(place_align):
                    align_content_v = place_align
                if supports_content_distribution_alignment(place_justify):
                    justify_content_v = place_justify
    val ta = decl_get(decls, "text-align")
    if ta.len() > 0:
        text_align_v = ta
    val text_align_all_decl = decl_get(decls, "text-align-all")
    if text_align_all_decl.len() > 0:
        val text_align_all_norm = text_align_all_decl.trim().lower()
        if text_align_all_norm == "left" or text_align_all_norm == "right" or text_align_all_norm == "center" or text_align_all_norm == "start" or text_align_all_norm == "end" or text_align_all_norm == "justify":
            text_align_v = text_align_all_norm
    val text_align_last_decl = decl_get(decls, "text-align-last")
    if text_align_last_decl.len() > 0:
        val text_align_last_norm = text_align_last_decl.trim().lower()
        if text_align_last_norm == "auto" or text_align_last_norm == "left" or text_align_last_norm == "right" or text_align_last_norm == "center" or text_align_last_norm == "start" or text_align_last_norm == "end":
            text_align_last_v = text_align_last_norm
    val text_justify_decl = decl_get(decls, "text-justify")
    if text_justify_decl.len() > 0:
        val text_justify_norm = text_justify_decl.trim().lower()
        if text_justify_norm == "auto" or text_justify_norm == "none" or text_justify_norm == "inter-word" or text_justify_norm == "inter-character" or text_justify_norm == "distribute":
            text_justify_v = text_justify_norm
    val text_transform_decl = decl_get(decls, "text-transform")
    if text_transform_decl.len() > 0:
        val text_transform_norm = text_transform_decl.trim().lower()
        if text_transform_norm == "uppercase" or text_transform_norm == "lowercase" or text_transform_norm == "capitalize" or text_transform_norm == "none":
            text_transform_v = text_transform_norm
    val text_indent_decl = decl_get(decls, "text-indent")
    if text_indent_decl.len() > 0:
        text_indent_px_v = parse_int(text_indent_decl)
    val letter_spacing_decl = decl_get(decls, "letter-spacing")
    if letter_spacing_decl.len() > 0:
        letter_spacing_px_v = parse_int(letter_spacing_decl)
    val word_spacing_decl = decl_get(decls, "word-spacing")
    if word_spacing_decl.len() > 0:
        word_spacing_px_v = parse_int(word_spacing_decl)
    val font_style_decl = decl_get(decls, "font-style")
    val font_style_pos = decl_last_pos(decls, "font-style")
    if font_style_decl.len() > 0 and (font_pos < 0 or font_style_pos > font_pos):
        val font_style_norm = font_style_decl.trim().lower()
        font_style_italic_v = font_style_norm == "italic" or font_style_norm == "oblique"
    val font_kerning_decl = decl_get(decls, "font-kerning")
    if font_kerning_decl.len() > 0:
        val font_kerning_norm = font_kerning_decl.trim().lower()
        if font_kerning_norm == "auto" or font_kerning_norm == "normal" or font_kerning_norm == "none":
            font_kerning_v = font_kerning_norm
    val font_optical_sizing_decl = decl_get(decls, "font-optical-sizing")
    if font_optical_sizing_decl.len() > 0:
        val font_optical_sizing_norm = font_optical_sizing_decl.trim().lower()
        if font_optical_sizing_norm == "auto" or font_optical_sizing_norm == "none":
            font_optical_sizing_v = font_optical_sizing_norm
    val font_language_override_decl = decl_get(decls, "font-language-override")
    if font_language_override_decl.len() > 0:
        val font_language_override_norm = font_language_override_decl.trim()
        val font_language_override_lower = font_language_override_norm.lower()
        if font_language_override_lower == "normal" or font_language_override_norm.starts_with("\"") or font_language_override_norm.starts_with("'"):
            font_language_override_v = font_language_override_norm
    val font_variation_settings_decl = decl_get(decls, "font-variation-settings")
    if font_variation_settings_decl.len() > 0:
        val font_variation_settings_norm = font_variation_settings_decl.trim()
        val font_variation_settings_lower = font_variation_settings_norm.lower()
        if font_variation_settings_lower == "normal" or font_variation_settings_norm.starts_with("\"") or font_variation_settings_norm.starts_with("'"):
            font_variation_settings_v = font_variation_settings_norm
    val font_variant_decl = decl_get(decls, "font-variant")
    if font_variant_decl.len() > 0:
        val font_variant_norm = font_variant_decl.trim().lower()
        if font_variant_norm.len() > 0:
