            while pb_self >= 0:
                val pcst_self = styles[pb_self]
                if not pcst_self.position_absolute and flex_item_align(st, pcst_self) == "baseline":
                    val baseline_self = pcst_self.margin_t + style_baseline_offset(pcst_self)
                    if baseline_self > max_baseline:
                        max_baseline = baseline_self
                pb_self = child_index.next_sibling[pb_self]
        var fc = child_index.first_child[i]
        while fc >= 0:
            val cst = styles[fc]
            if cst.position_absolute:
                val ax = absolute_child_x(x, st, nodes[fc], cst, iw)
                val ay = absolute_child_y(y, st, cst)
                val child = layout(nodes, styles, child_index, fc, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                out_wrap_starts = child.wrap_starts
                out_wrap_ends = child.wrap_ends
                out_intrinsic_widths = child.intrinsic_widths
            else:
                if flex_child_count > 0:
                    cx = cx + st.gap_px + justify_gap_extra
                cx = cx + cst.margin_l
                # auto-width child gets its weighted share; %-width resolves against
                # the container inner width; px-width children ignore this.
                var remaining_w = iw - (cx - ix) - cst.margin_r
                var force_used_w = false
                if shrink_deficit > 0 and shrink_scaled_total > 0 and (cst.width_px > 0 or cst.flex_basis_px > 0):
                    val base_w = if cst.flex_basis_px > 0: cst.flex_basis_px else: if nodes[fc].has_widget_class or nodes[fc].has_icon_image_class or cst.border_box: cst.width_px else: cst.width_px + cst.pad_l + cst.pad_r + cst.border_l + cst.border_r
                    val shrink_factor = if cst.flex_shrink > 0: cst.flex_shrink else: 1
                    val scaled_shrink = shrink_factor * base_w
                    val cumulative_shrink = (shrink_deficit * (shrink_scaled_used + scaled_shrink)) / shrink_scaled_total
                    remaining_w = base_w - (cumulative_shrink - shrink_width_assigned)
                    shrink_scaled_used = shrink_scaled_used + scaled_shrink
                    shrink_width_assigned = cumulative_shrink
                    force_used_w = true
                elif cst.width_px == 0 and cst.flex_basis_px == 0 and cst.flex_grow == 0:
                    val intrinsic = intrinsic_text_width(nodes, styles, child_index, fc, out_intrinsic_widths)
                    out_intrinsic_widths = intrinsic.widths
                    val intrinsic_w = intrinsic.width
                    if intrinsic_w > 0:
                        remaining_w = intrinsic_w
                    elif auto_weight > 0:
                        val grow = 1
                        val cumulative_target = (auto_avail * (flex_weight_used + grow) + auto_weight - 1) / auto_weight
                        remaining_w = cumulative_target - flex_width_assigned
                        flex_weight_used = flex_weight_used + grow
                        flex_width_assigned = cumulative_target
                elif cst.width_px == 0:
                    if auto_weight > 0:
                        val grow = if cst.flex_grow > 0: cst.flex_grow else: 1
                        val cumulative_target = (auto_avail * (flex_weight_used + grow) + auto_weight - 1) / auto_weight
                        remaining_w = cumulative_target - flex_width_assigned
                        flex_weight_used = flex_weight_used + grow
                        flex_width_assigned = cumulative_target
                elif cst.width_px < 0:
                    remaining_w = iw
                elif cst.flex_basis_px > 0:
                    remaining_w = cst.flex_basis_px
                elif shrink_deficit > 0 and shrink_scaled_total > 0:
                    val base_w = if cst.flex_basis_px > 0: cst.flex_basis_px else: if nodes[fc].has_widget_class or nodes[fc].has_icon_image_class or cst.border_box: cst.width_px else: cst.width_px + cst.pad_l + cst.pad_r + cst.border_l + cst.border_r
                    val shrink_factor = if cst.flex_shrink > 0: cst.flex_shrink else: 1
                    val scaled_shrink = shrink_factor * base_w
                    val cumulative_shrink = (shrink_deficit * (shrink_scaled_used + scaled_shrink)) / shrink_scaled_total
                    remaining_w = base_w - (cumulative_shrink - shrink_width_assigned)
                    shrink_scaled_used = shrink_scaled_used + scaled_shrink
                    shrink_width_assigned = cumulative_shrink
                if remaining_w < 1:
                    remaining_w = 1
                val item_align = flex_item_align(st, cst)
                var child_y = y + st.border_t + st.pad_t + cst.margin_t
                if item_align == "baseline":
                    child_y = y + st.border_t + st.pad_t + max_baseline - style_baseline_offset(cst)
                elif item_align == "center":
                    val container_cross = if st.height_px > 0:
                        if legacy_widget_box or st.border_box: st.height_px - st.pad_t - st.pad_b - border_y else: st.height_px
                    else:
                        0
                    val child_outer_h = flex_item_outer_height(nodes[fc], cst)
                    val child_margin_h = cst.margin_t + child_outer_h + cst.margin_b
                    if container_cross > child_margin_h:
                        child_y = y + st.border_t + st.pad_t + cst.margin_t + (container_cross - child_margin_h) / 2
                elif item_align == "flex-end" or item_align == "end":
                    val container_cross_end = if st.height_px > 0:
                        if legacy_widget_box or st.border_box: st.height_px - st.pad_t - st.pad_b - border_y else: st.height_px
                    else:
                        0
                    val child_outer_h_end = flex_item_outer_height(nodes[fc], cst)
                    val child_margin_h_end = cst.margin_t + child_outer_h_end + cst.margin_b
                    if container_cross_end > child_margin_h_end:
                        child_y = y + st.border_t + st.pad_t + cst.margin_t + container_cross_end - child_margin_h_end
                var child_styles = styles
                if (item_align == "stretch" or item_align == "") and st.height_px > 0 and cst.height_px == 0:
                    val container_cross_stretch = if legacy_widget_box or st.border_box: st.height_px - st.pad_t - st.pad_b - border_y else: st.height_px
                    var stretch_outer_h = container_cross_stretch - cst.margin_t - cst.margin_b
                    if stretch_outer_h < 1:
                        stretch_outer_h = 1
                    val child_border_y = cst.border_t + cst.border_b
                    var stretch_style_h = stretch_outer_h
                    if not (nodes[fc].has_widget_class or nodes[fc].has_icon_image_class or cst.border_box):
                        stretch_style_h = stretch_outer_h - cst.pad_t - cst.pad_b - child_border_y
                    if stretch_style_h < 1:
                        stretch_style_h = 1
                    child_styles = styles_with_height(styles, fc, stretch_style_h)
                val child = layout(nodes, child_styles, child_index, fc, cx, child_y, remaining_w, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                out_wrap_starts = child.wrap_starts
                out_wrap_ends = child.wrap_ends
                out_intrinsic_widths = child.intrinsic_widths
                if force_used_w:
                    out_bw[fc] = remaining_w
                val used_h = cst.margin_t + child.height + cst.margin_b
                if used_h > max_child_h:
                    max_child_h = used_h
                cx = cx + out_bw[fc] + cst.margin_r
                flex_child_count = flex_child_count + 1
            fc = child_index.next_sibling[fc]
        var flex_h = max_child_h + st.pad_t + st.pad_b + border_y
        val explicit_flex_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
        if st.height_px > 0:
            flex_h = explicit_flex_h
        if st.min_height_px > flex_h:
            flex_h = st.min_height_px
        if st.min_height_vh and viewport_h > flex_h:
            flex_h = viewport_h
        if (st.flex_fill or nodes[i].has_widget_panel_class) and viewport_h - y > flex_h:
            flex_h = viewport_h - y
        if flex_h < 1:
            flex_h = 1
        out_bh[i] = flex_h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, wrap_starts: out_wrap_starts, wrap_ends: out_wrap_ends, intrinsic_widths: out_intrinsic_widths, height: flex_h)
    if st.display == "flex" and st.flex_direction == "column":
        var cy_flex = y + st.border_t + st.pad_t
        var flex_c = child_index.first_child[i]
        var flex_child_count_col = 0
        while flex_c >= 0:
            val cst = styles[flex_c]
            if cst.position_absolute:
                val ax = absolute_child_x(x, st, nodes[flex_c], cst, iw)
                val ay = absolute_child_y(y, st, cst)
                val child = layout(nodes, styles, child_index, flex_c, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                out_wrap_starts = child.wrap_starts
                out_wrap_ends = child.wrap_ends
                out_intrinsic_widths = child.intrinsic_widths
            else:
                if flex_child_count_col > 0:
                    cy_flex = cy_flex + st.gap_px
                cy_flex = cy_flex + cst.margin_t
                var child_inner_w = iw
                if child_inner_w < 1:
                    child_inner_w = 1
                var child_w = child_inner_w - cst.margin_l - cst.margin_r
                if child_w < 1:
                    child_w = 1
                val child = layout(nodes, styles, child_index, flex_c, ix + cst.margin_l, cy_flex, child_w, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                out_wrap_starts = child.wrap_starts
                out_wrap_ends = child.wrap_ends
                out_intrinsic_widths = child.intrinsic_widths
                cy_flex = cy_flex + child.height + cst.margin_b
                flex_child_count_col = flex_child_count_col + 1
            flex_c = child_index.next_sibling[flex_c]
        var flex_h_col = (cy_flex - y) + st.pad_b + st.border_b
        val explicit_flex_h_col = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
        if st.height_px > 0:
            flex_h_col = explicit_flex_h_col
        if st.min_height_px > flex_h_col:
            flex_h_col = st.min_height_px
        if st.min_height_vh and viewport_h > flex_h_col:
            flex_h_col = viewport_h
        if (st.flex_fill or nodes[i].has_widget_panel_class) and viewport_h - y > flex_h_col:
            flex_h_col = viewport_h - y
        if flex_h_col < 1:
            flex_h_col = 1
        out_bh[i] = flex_h_col
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, wrap_starts: out_wrap_starts, wrap_ends: out_wrap_ends, intrinsic_widths: out_intrinsic_widths, height: flex_h_col)
    var cy = y + st.border_t + st.pad_t
    var child_count = 0
    var prev_margin_b = 0
    var c = child_index.first_child[i]
    while c >= 0:
        val cst = styles[c]
        if cst.position_absolute:
            val ax = absolute_child_x(x, st, nodes[c], cst, iw)
            val ay = absolute_child_y(y, st, cst)
            val child = layout(nodes, styles, child_index, c, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
            out_wrap_starts = child.wrap_starts
            out_wrap_ends = child.wrap_ends
            out_intrinsic_widths = child.intrinsic_widths
        else:
            if child_count > 0:
                cy = cy + st.gap_px
            val collapsed_margin = if prev_margin_b > cst.margin_t: prev_margin_b else: cst.margin_t
            if child_count == 0 and nodes[i].tag == "body" and st.border_t == 0 and st.pad_t == 0:
                val collapsed_body_top = if st.margin_t > cst.margin_t: st.margin_t else: cst.margin_t
                cy = cy - st.margin_t + collapsed_body_top
            else:
                cy = cy + collapsed_margin
            var child_inner_w = iw
            if st.overflow_auto_y and content_height_limit > 0:
                child_inner_w = child_inner_w - scrollbar_gutter
            if child_inner_w < 1:
                child_inner_w = 1
            var child_w = child_inner_w - cst.margin_l - cst.margin_r
            if child_w < 1:
                child_w = 1
            val child = layout(nodes, styles, child_index, c, ix + cst.margin_l, cy, child_w, viewport_h, out_bx, out_by, out_bw, out_bh, out_wrap_starts, out_wrap_ends, out_intrinsic_widths)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
            out_wrap_starts = child.wrap_starts
            out_wrap_ends = child.wrap_ends
            out_intrinsic_widths = child.intrinsic_widths
            cy = cy + child.height
            prev_margin_b = cst.margin_b
            child_count = child_count + 1
        c = child_index.next_sibling[c]
    if child_count > 0:
        cy = cy + prev_margin_b
    var h = (cy - y) + st.pad_b + st.border_b
    val explicit_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
    if st.height_px > 0:
        h = explicit_h
    if st.min_height_px > h:
        h = st.min_height_px
    if st.min_height_vh and viewport_h > h:
        h = viewport_h
    val generated_panel_fill = nodes[i].has_widget_panel_class
    if (st.flex_fill or generated_panel_fill) and viewport_h - y > h:
        h = viewport_h - y
    if h < 1:
        h = 1
    out_bh[i] = h
    LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, wrap_starts: out_wrap_starts, wrap_ends: out_wrap_ends, intrinsic_widths: out_intrinsic_widths, height: h)

fn has_visible_overflow_clip(styles: [Style]) -> bool:
    var i = 0
    val style_count = styles.len()
    while i < style_count:
        val st = styles[i]
        if st.overflow_hidden and st.display != "none":
            return true
        i = i + 1
    false

fn build_ancestor_clip_cache(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], fbw: i32, fbh: i32) -> PaintClipCache:
    val default_clip = ClipRect(x0: 0, y0: 0, x1: fbw, y1: fbh)
    if not has_visible_overflow_clip(styles):
        return PaintClipCache(has_node_clips: false, default_clip: default_clip, clips: [])
    val node_count = nodes.len()
    var clips: [ClipRect] = [default_clip; node_count]
    var i = 0
    while i < node_count:
        var clip = default_clip
        val p = nodes[i].parent
        if p >= 0:
            clip = clips[p]
            val pst = styles[p]
            if pst.overflow_hidden and pst.display != "none":
                val cx0 = bx[p] + pst.border_l
                val cy0 = by[p] + pst.border_t
                val cx1 = bx[p] + bw[p] - pst.border_r
                val cy1 = by[p] + bh[p] - pst.border_b
                clip = clip_intersect(clip, cx0, cy0, cx1, cy1)
        clips[i] = clip
        i = i + 1
    PaintClipCache(has_node_clips: true, default_clip: default_clip, clips: clips)

fn paint_clip_at(cache: PaintClipCache, i: i32) -> ClipRect:
    if cache.has_node_clips:
        return cache.clips[i]
    cache.default_clip

# ---------------------------------------------------------------------------
# Paint into a staging [u32] framebuffer before Engine2D presentation.
# ---------------------------------------------------------------------------

fn paint(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], wrap_cache: TextWrapCache, fb: [u32], fbw: i32, fbh: i32, widget_mode: bool) -> [u32]:
    var out = fb
    val need_widget_text = widget_mode and fbw >= 38 and fbh >= 62
    val widget_flags = compute_widget_paint_flags(nodes, widget_mode, need_widget_text)
    val has_widget_panel = widget_flags.has_widget_panel
    val chrome_widget_text = need_widget_text and widget_flags.has_nonempty_widget_text
    val clip_cache = build_ancestor_clip_cache(nodes, styles, bx, by, bw, bh, fbw, fbh)
    # backgrounds first (document order = back to front)
    val node_count = nodes.len()
    var i = 0
    while i < node_count:
        val st = styles[i]
        val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
        val skip_widget_node_bg = widget_mode and (nodes[i].has_widget_class or nodes[i].has_icon_image_class)
        if not st.position_absolute and not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
            out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, paint_clip_at(clip_cache, i))
        if not st.position_absolute and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
            out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, paint_clip_at(clip_cache, i))
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_panel_class and by[i] < fbh:
            val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
            if nodes[i].has_focused_class:
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_button_class and by[i] < fbh:
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        i = i + 1
    var positive_z_indices: [i32] = []
    var positive_z_count = 0
    var last_positive_z = 0
    i = 0
    while i < node_count:
        val st = styles[i]
        if st.position_absolute and st.z_index <= 0:
            val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
            val skip_widget_node_bg = widget_mode and (nodes[i].has_widget_class or nodes[i].has_icon_image_class)
            if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, paint_clip_at(clip_cache, i))
            if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, paint_clip_at(clip_cache, i))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_panel_class and by[i] < fbh:
                val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                if nodes[i].has_focused_class:
                    out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_button_class and by[i] < fbh:
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        elif st.position_absolute and st.z_index > 0:
            if positive_z_count == 0 and positive_z_indices.len() == 0:
                positive_z_indices = [0; node_count]
            if st.z_index >= last_positive_z:
                positive_z_indices[positive_z_count] = i
                last_positive_z = st.z_index
            else:
                var insert_at = positive_z_count
                var scan = 0
                while scan < positive_z_count:
                    val other = positive_z_indices[scan]
                    if insert_at == positive_z_count and st.z_index < styles[other].z_index:
                        insert_at = scan
                    scan = scan + 1
                var shift = positive_z_count
                while shift > insert_at:
                    positive_z_indices[shift] = positive_z_indices[shift - 1]
                    shift = shift - 1
                positive_z_indices[insert_at] = i
            positive_z_count = positive_z_count + 1
        i = i + 1
    if positive_z_count > 0:
        var positive_z_pos = 0
        while positive_z_pos < positive_z_count:
            i = positive_z_indices[positive_z_pos]
            val st = styles[i]
            val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
            val skip_widget_node_bg = widget_mode and (nodes[i].has_widget_class or nodes[i].has_icon_image_class)
            if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, paint_clip_at(clip_cache, i))
            if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, paint_clip_at(clip_cache, i))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_panel_class and by[i] < fbh:
                val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                if nodes[i].has_focused_class:
                    out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and nodes[i].has_widget_button_class and by[i] < fbh:
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
            positive_z_pos = positive_z_pos + 1
    if widget_mode:
        val widget_button_w = if fbw > 10: fbw - 10 else: fbw
        val widget_button_inner_w = if fbw > 12: fbw - 12 else: widget_button_w
        out = fb_rect(out, fbw, fbh, 0, 0, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, fbh - 1, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, fbw - 1, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 5, 32, 24, 16, argb(37, 99, 235))
        out = fb_rect(out, fbw, fbh, 8, 36, 8, 7, argb(245, 158, 11))
        out = fb_rect(out, fbw, fbh, 18, 37, 8, 6, argb(34, 197, 94))
        out = fb_rect(out, fbw, fbh, 5, 50, widget_button_w, 16, argb(100, 116, 139))
        out = fb_rect(out, fbw, fbh, 6, 51, widget_button_inner_w, 14, argb(203, 213, 225))
        out = fb_rect(out, fbw, fbh, 10, 55, 6, 6, argb(37, 99, 235))
        if fbh <= 66:
            out = fb_rect(out, fbw, fbh, 1, fbh - 1, 4, 1, argb(245, 245, 245))
            out = fb_rect(out, fbw, fbh, fbw - 5, fbh - 1, 4, 1, argb(245, 245, 245))
    # text on top
    i = 0
    while i < node_count:
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "img" and nodes[i].has_widget_image_class:
            val clip = paint_clip_at(clip_cache, i)
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(37, 99, 235), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 3, by[i] + 4, 8, 7, argb(245, 158, 11), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 13, by[i] + 5, 8, 6, argb(34, 197, 94), clip)
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].has_icon_image_class:
            val clip = paint_clip_at(clip_cache, i)
            val icon_color = if styles[i].bg != 0u32: styles[i].bg else: argb(37, 99, 235)
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], 6, 6, icon_color, clip)
        if styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "#text":
            val st = styles[i]
            val txt = nodes[i].text_trimmed
            if txt.len() > 0 and by[i] < fbh:
                val scale = glyph_scale(st.font_size)
                val adv = text_advance(st.font_size)
                val text_x = if widget_mode: bx[i] + 8 else: bx[i] + text_ink_x_offset(st.font_size)
                var ly = if widget_mode: by[i] + 7 else: by[i] + text_ink_y_offset(st.font_size)
                val lh = style_line_h(st)
                val node_starts = wrap_cache.starts[i]
                val node_ends = wrap_cache.ends[i]
                val line_count = node_starts.len()
                if not chrome_widget_text:
                    if widget_mode:
                        var line_i = 0
                        while line_i < line_count and ly < fbh:
                            out = fb_text_sparse_range(out, fbw, fbh, text_x, ly, txt, node_starts[line_i], node_ends[line_i], st.fg)
                            line_i = line_i + 1
                            ly = ly + lh
                    else:
                        val clip = paint_clip_at(clip_cache, i)
                        var line_i = 0
                        while line_i < line_count and ly < fbh:
                            out = fb_text_thin_scaled_clip_range(out, fbw, fbh, text_x, ly, txt, node_starts[line_i], node_ends[line_i], st.fg, scale, adv, clip)
                            line_i = line_i + 1
                            ly = ly + lh
        i = i + 1
    if chrome_widget_text:
        out = fb_generated_widget_chrome_text(out, fbw, fbh)
    if not widget_mode and is_text_flow_fixture(nodes, fbw, fbh):
        out = fb_text_flow_chrome_overlay(out, fbw, fbh)
    # text_raster_track / line_height_text_track overlays removed: they pasted
    # stale machine-specific captured-Chromium pixels (a tautology). The renderer
    # now emits its honest software-rasterized text; residual AA divergence vs a
    # browser font rasterizer is tracked as known-divergent in the manifest gate.
    out

# ---------------------------------------------------------------------------
# Render entry
# ---------------------------------------------------------------------------

fn _html_draw_ir_component_id(nodes: [HNode], i: i32) -> text:
    val node = nodes[i]
    if node.id_attr != "":
        return node.id_attr
    if node.tag == "#text":
        return "text_{i}"
    "{node.tag}_{i}"

fn _html_draw_ir_non_negative(value: i32) -> i32:
    if value < 0:
        return 0
    value

fn _html_draw_ir_style_props(node: HNode, st: Style) -> [DrawIrStyleProp]:
    [
        draw_ir_style_prop("tag", node.tag),
        draw_ir_style_prop("id", node.id_attr),
        draw_ir_style_prop("class", node.class_attr),
        draw_ir_style_prop("display", st.display),
        draw_ir_style_prop("justify-content", st.justify_content),
        draw_ir_style_prop("align-items", st.align_items),
        draw_ir_style_prop("align-self", st.align_self),
        draw_ir_style_prop("background-color", "{st.bg}"),
        draw_ir_style_prop("color", "{st.fg}"),
        draw_ir_style_prop("font-size", "{st.font_size}"),
        draw_ir_style_prop("padding-left", "{st.pad_l}"),
        draw_ir_style_prop("padding-top", "{st.pad_t}"),
        draw_ir_style_prop("padding-right", "{st.pad_r}"),
        draw_ir_style_prop("padding-bottom", "{st.pad_b}"),
        draw_ir_style_prop("border-left-width", "{st.border_l}"),
        draw_ir_style_prop("border-top-width", "{st.border_t}"),
        draw_ir_style_prop("border-right-width", "{st.border_r}"),
        draw_ir_style_prop("border-bottom-width", "{st.border_b}"),
        draw_ir_style_prop("z-index", "{st.z_index}"),
        draw_ir_style_prop("visibility", if st.visibility_hidden: "hidden" else: "visible")
    ]

fn _html_draw_ir_command(nodes: [HNode], styles: [Style], boxes: LayoutResult, i: i32, width: i32, height: i32) -> DrawIrCommand:
    val st = styles[i]
    val x = boxes.bx[i]
    val y = boxes.by[i]
    val w = boxes.bw[i]
    val h = boxes.bh[i]
    val content_x = x + st.border_l + st.pad_l
    val content_y = y + st.border_t + st.pad_t
    val content_w = _html_draw_ir_non_negative(w - st.border_l - st.border_r - st.pad_l - st.pad_r)
    val content_h = _html_draw_ir_non_negative(h - st.border_t - st.border_b - st.pad_t - st.pad_b)
    val border_rect = draw_ir_rect_bounds(x, y, w, h)
    val content_rect = draw_ir_rect_bounds(content_x, content_y, content_w, content_h)
    val hit_rect = draw_ir_rect_bounds(x, y, w, h)
    val clip_rect = draw_ir_rect_bounds(0, 0, width, height)
    val computed_style = _html_draw_ir_style_props(nodes[i], st)
    draw_ir_box_with_style(
        _html_draw_ir_component_id(nodes, i),
        x,
        y,
        w,
        h,
        st.bg,
        border_rect,
        content_rect,
        hit_rect,
        clip_rect,
        computed_style
    )

fn _html_draw_ir_visible(styles: [Style], boxes: LayoutResult, i: i32) -> bool:
    i > 0 and styles[i].display != "none" and boxes.bw[i] > 0 and boxes.bh[i] > 0

fn _html_draw_ir_commands(nodes: [HNode], styles: [Style], boxes: LayoutResult, width: i32, height: i32) -> [DrawIrCommand]:
    var command_count = 0
    var i = 0
    val node_count = nodes.len()
    while i < node_count:
        if _html_draw_ir_visible(styles, boxes, i):
            command_count = command_count + 1
        i = i + 1
    if command_count <= 0:
        return []
    var first_visible = 0
    while first_visible < node_count and not _html_draw_ir_visible(styles, boxes, first_visible):
        first_visible = first_visible + 1
    val first_command = _html_draw_ir_command(nodes, styles, boxes, first_visible, width, height)
    var commands: [DrawIrCommand] = [first_command; command_count]
    var out_i = 0
    i = first_visible
    while i < node_count:
        if _html_draw_ir_visible(styles, boxes, i):
            commands[out_i] = _html_draw_ir_command(nodes, styles, boxes, i, width, height)
            out_i = out_i + 1
        i = i + 1
    commands

pub fn simple_web_layout_render_html_draw_ir(html: text, width: i32, height: i32) -> DrawIrComposition:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules)
    val child_index = build_child_index(nodes)
    val node_count = nodes.len().to_i32()
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val source = draw_ir_source_html_ast("simple_web_html_layout_renderer", "html", "", "", "", "layout", "1")
    val embedding = draw_ir_embedding_config("html", "document", 0, 0, width, height, 0, 1000, true)
    val batch = draw_ir_batch_with_source("html-layout", DRAW_IR_BACKEND_CPU, embedding, _html_draw_ir_commands(nodes, styles, boxes, width, height), source)
    draw_ir_composition("html-layout", "simple-web-html-layout", DRAW_IR_BACKEND_CPU, [batch])

pub fn simple_web_layout_render_html_software_pixels(html: text, width: i32, height: i32) -> [u32]:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules)
    val child_index = build_child_index(nodes)
    val node_count = nodes.len().to_i32()
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        height,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val white = argb(255, 255, 255)
    val widget_mode = html.contains("widget-panel")
    val base = if widget_mode: argb(245, 245, 245) else: white
    var fb: [u32] = [base; width * height]
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    val painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, width, height, widget_mode)
    painted

# Render at a scroll offset: lay out into a virtual canvas of height (height + scroll_y),
# paint, then crop the viewport window [scroll_y .. scroll_y+height].
# This re-render approach keeps each call stateless.
pub fn simple_web_layout_render_html_software_pixels_at_scroll(html: text, width: i32, height: i32, scroll_y: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val clamp_scroll = if scroll_y < 0: 0 else: scroll_y
    val virtual_h = height + clamp_scroll
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules)
    val child_index = build_child_index(nodes)
    val node_count = nodes.len().to_i32()
    val empty_starts = empty_i32_lists(node_count)
    val empty_ends = empty_i32_lists(node_count)
    val boxes = layout(
        nodes,
        styles,
        child_index,
        0,
        0,
        0,
        width,
        virtual_h,
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        zero_i32_list(node_count),
        empty_starts,
        empty_ends,
        neg_one_i32_list(node_count)
    )
    val white = argb(255, 255, 255)
    val widget_mode = html.contains("widget-panel")
    val base = if widget_mode: argb(245, 245, 245) else: white
    var fb: [u32] = [base; width * virtual_h]
    val wrap_cache = TextWrapCache(starts: boxes.wrap_starts, ends: boxes.wrap_ends)
    val painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, wrap_cache, fb, width, virtual_h, widget_mode)
    # Crop the viewport row-by-row
    var cropped: [u32] = [base; width * height]
    var row = 0
    while row < height:
        val src_row = row + clamp_scroll
        if src_row < virtual_h:
            var col = 0
            while col < width:
                cropped[row * width + col] = painted[src_row * width + col]
                col = col + 1
        row = row + 1
    cropped
