    var margin_r_v = st.margin_r
    var margin_b_v = st.margin_b
    var border_box_v = st.border_box
    var bold_v = st.bold
    if is_non_rendered_tag(tag):
        return Style(bg: st.bg, fg: st.fg, font_size: font_size_v, line_height_px: st.line_height_px, width_px: st.width_px, height_px: st.height_px, border_box: st.border_box, min_width_px: st.min_width_px, max_width_px: st.max_width_px, min_height_px: st.min_height_px, min_height_vh: st.min_height_vh, flex_fill: st.flex_fill, flex_grow: st.flex_grow, flex_shrink: st.flex_shrink, flex_basis_px: st.flex_basis_px, flex_wrap: st.flex_wrap, justify_content: st.justify_content, align_items: st.align_items, align_self: st.align_self, align_content: st.align_content, pad_l: st.pad_l, pad_t: st.pad_t, pad_r: st.pad_r, pad_b: st.pad_b, border_w: st.border_w, border_color: st.border_color, border_l: st.border_l, border_t: st.border_t, border_r: st.border_r, border_b: st.border_b, border_color_l: st.border_color_l, border_color_t: st.border_color_t, border_color_r: st.border_color_r, border_color_b: st.border_color_b, gap_px: st.gap_px, margin_l: st.margin_l, margin_t: margin_t_v, margin_r: st.margin_r, margin_b: margin_b_v, display: "none", overflow_hidden: st.overflow_hidden, overflow_auto_y: st.overflow_auto_y, visibility_hidden: st.visibility_hidden, position_relative: st.position_relative, position_absolute: st.position_absolute, left_px: st.left_px, top_px: st.top_px, right_px: st.right_px, bottom_px: st.bottom_px, z_index: st.z_index, opacity_pct: st.opacity_pct, flex_direction: st.flex_direction, text_align: st.text_align, bold: bold_v)
    if is_inline_tag(tag):
        display_v = "inline"
    if tag == "h1":
        font_size_v = 34
        bold_v = true
        margin_t_v = 10
        margin_b_v = 10
    elif tag == "h2":
        font_size_v = 26
        bold_v = true
        margin_t_v = 8
        margin_b_v = 8
    elif tag == "h3":
        font_size_v = 20
        bold_v = true
        margin_t_v = 6
        margin_b_v = 6
    elif tag == "p":
        margin_t_v = 16
        margin_b_v = 16
    elif tag == "body":
        display_v = "block"
        margin_l_v = 8
        margin_t_v = 8
        margin_r_v = 8
        margin_b_v = 8
    elif tag == "input":
        display_v = "inline"
        pad_l_v = 2
        pad_r_v = 2
        pad_t_v = 1
        pad_b_v = 1
    elif tag == "button":
        display_v = "inline"
        border_box_v = true
        pad_l_v = 6
        pad_r_v = 6
        pad_t_v = 1
        pad_b_v = 1
        margin_b_v = 3
    elif tag == "header" or tag == "footer" or tag == "nav" or tag == "section" or tag == "table" or tag == "tr" or tag == "div" or tag == "ul" or tag == "li":
        display_v = "block"
    Style(bg: st.bg, fg: st.fg, font_size: font_size_v, line_height_px: st.line_height_px, width_px: st.width_px, height_px: st.height_px, border_box: border_box_v, min_width_px: st.min_width_px, max_width_px: st.max_width_px, min_height_px: st.min_height_px, min_height_vh: st.min_height_vh, flex_fill: st.flex_fill, flex_grow: st.flex_grow, flex_shrink: st.flex_shrink, flex_basis_px: st.flex_basis_px, flex_wrap: st.flex_wrap, justify_content: st.justify_content, align_items: st.align_items, align_self: st.align_self, align_content: st.align_content, pad_l: pad_l_v, pad_t: pad_t_v, pad_r: pad_r_v, pad_b: pad_b_v, border_w: st.border_w, border_color: st.border_color, border_l: st.border_l, border_t: st.border_t, border_r: st.border_r, border_b: st.border_b, border_color_l: st.border_color_l, border_color_t: st.border_color_t, border_color_r: st.border_color_r, border_color_b: st.border_color_b, gap_px: st.gap_px, margin_l: margin_l_v, margin_t: margin_t_v, margin_r: margin_r_v, margin_b: margin_b_v, display: display_v, overflow_hidden: st.overflow_hidden, overflow_auto_y: st.overflow_auto_y, visibility_hidden: st.visibility_hidden, position_relative: st.position_relative, position_absolute: st.position_absolute, left_px: st.left_px, top_px: st.top_px, right_px: st.right_px, bottom_px: st.bottom_px, z_index: st.z_index, opacity_pct: st.opacity_pct, flex_direction: st.flex_direction, text_align: st.text_align, bold: bold_v)

# ---------------------------------------------------------------------------
# CSS rules from <style> blocks
# ---------------------------------------------------------------------------

class Rules:
    group_parts: [[[text]]]
    decls: [text]

class RuleBuckets:
    id_keys: [text]
    id_rules: [[i32]]
    class_keys: [text]
    class_rules: [[i32]]
    tag_keys: [text]
    tag_rules: [[i32]]
    fallback_rules: [i32]

fn count_css_rules(html: text) -> i32:
    var count = 0
    var pos = 0
    var guard = 0
    while guard < 1000:
        guard = guard + 1
        val sp = find_from(html, "<style", pos)
        if sp < 0:
            break
        val open = find_from(html, ">", sp)
        if open < 0:
            break
        val close = find_from(html, "</style", open)
        if close < 0:
            break
        val css = html.substring(open + 1, close)
        var cp = 0
        val css_len = css.len()
        while cp < css_len:
            val brace = find_from(css, "{", cp)
            if brace < 0:
                break
            val endb = find_from(css, "}", brace)
            if endb < 0:
                break
            val sel_raw = css.substring(cp, brace)
            val sel = sel_raw.trim()
            if sel.len() > 0:
                count = count + 1
            cp = endb + 1
        pos = close + 1
    count

fn extract_css(html: text) -> Rules:
    val rule_count = count_css_rules(html)
    var group_parts: [[[text]]] = [[[]]; rule_count]
    var decls: [text] = [""; rule_count]
    var rule_i = 0
    var pos = 0
    var guard = 0
    while guard < 1000:
        guard = guard + 1
        val sp = find_from(html, "<style", pos)
        if sp < 0:
            break
        val open = find_from(html, ">", sp)
        if open < 0:
            break
        val close = find_from(html, "</style", open)
        if close < 0:
            break
        val css = html.substring(open + 1, close)
        # split into "selector { decls }" chunks
        var cp = 0
        val css_len = css.len()
        while cp < css_len:
            val brace = find_from(css, "{", cp)
            if brace < 0:
                break
            val endb = find_from(css, "}", brace)
            if endb < 0:
                break
            val sel_raw = css.substring(cp, brace)
            val sel = sel_raw.trim()
            val decl_raw = css.substring(brace + 1, endb)
            val decl = decl_raw.trim()
            if sel.len() > 0:
                val rule_groups = split_selector_groups(sel)
                group_parts[rule_i] = split_selector_group_parts(rule_groups)
                decls[rule_i] = decl
                rule_i = rule_i + 1
            cp = endb + 1
        pos = close + 1
    Rules(group_parts: group_parts, decls: decls)

fn unquote_css_attr_value(raw: text) -> text:
    val v = raw.trim()
    if v.len() >= 2:
        val first = v.substring(0, 1)
        val last = v.substring(v.len() - 1, v.len())
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return v.substring(1, v.len() - 1)
    v

fn attr_selector_matches(attrs: text, expr: text) -> bool:
    val raw = expr.trim()
    if raw.len() == 0:
        return false
    val prefix_op = text_index_of(raw, "^=")
    if prefix_op >= 0:
        val name = raw.substring(0, prefix_op).trim()
        val want = unquote_css_attr_value(raw.substring(prefix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.starts_with(want)
    val suffix_op = text_index_of(raw, "$=")
    if suffix_op >= 0:
        val name = raw.substring(0, suffix_op).trim()
        val want = unquote_css_attr_value(raw.substring(suffix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.ends_with(want)
    val exact_op = text_index_of(raw, "=")
    if exact_op >= 0:
        val name = raw.substring(0, exact_op).trim()
        val want = unquote_css_attr_value(raw.substring(exact_op + 1, raw.len()))
        return attr_value(attrs, name) == want
    attr_value(attrs, raw).len() > 0

fn class_words_has(words: [text], want: text) -> bool:
    var i = 0
    val word_count = words.len()
    while i < word_count:
        if words[i] == want:
            return true
        i = i + 1
    false

fn base_selector_matches(base: text, tag: text, cls: text, class_words: [text], id: text) -> bool:
    if base.len() == 0:
        return true
    if base.substring(0, 1) == ".":
        val want = base.substring(1, base.len())
        return class_has_all(class_words, want)
    if base.substring(0, 1) == "#":
        return id == base.substring(1, base.len())
    val dot = text_index_of(base, ".")
    if dot >= 0:
        val t = base.substring(0, dot)
        val want = base.substring(dot + 1, base.len())
        return t == tag and class_has_all(class_words, want)
    base == tag

# does a single simple selector match this node? (rightmost token only)
fn simple_match(sel: text, tag: text, cls: text, class_words: [text], id: text, attrs: text) -> bool:
    if sel.len() == 0:
        return false
    # strip pseudo (:hover, :nth-child(..))
    var base = sel
    val colon = text_index_of(base, ":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_start = text_index_of(base, "[")
    if attr_start >= 0:
        val attr_end = text_index_of(base, "]")
        if attr_end < attr_start:
            return false
        val node_base = base.substring(0, attr_start).trim()
        val expr = base.substring(attr_start + 1, attr_end)
        return base_selector_matches(node_base, tag, cls, class_words, id) and attr_selector_matches(attrs, expr)
    base_selector_matches(base, tag, cls, class_words, id)

fn class_has_all(words: [text], wants: text) -> bool:
    val parts = wants.split(".")
    var i = 0
    val part_count = parts.len()
    while i < part_count:
        val want = parts[i]
        if want.len() > 0 and not class_words_has(words, want):
            return false
        i = i + 1
    true

fn class_contains(cls: text, want: text) -> bool:
    cls.contains(want)

fn split_selector_groups(sel: text) -> [text]:
    var current = ""
    var depth = 0
    var i = 0
    val sel_len = sel.len()
    var group_count = 0
    while i < sel_len:
        val ch = sel.substring(i, i + 1)
        if ch == "(":
            depth = depth + 1
            current = current + ch
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
            current = current + ch
        elif ch == "," and depth == 0:
            group_count = group_count + 1
            current = ""
        else:
            current = current + ch
        i = i + 1
    if current.trim().len() > 0:
        group_count = group_count + 1
    var groups: [text] = [""; group_count]
    current = ""
    depth = 0
    i = 0
    var group_i = 0
    while i < sel_len:
        val ch = sel.substring(i, i + 1)
        if ch == "(":
            depth = depth + 1
            current = current + ch
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
            current = current + ch
        elif ch == "," and depth == 0:
            groups[group_i] = current.trim()
            group_i = group_i + 1
            current = ""
        else:
            current = current + ch
        i = i + 1
    if current.trim().len() > 0:
        groups[group_i] = current.trim()
    groups

fn normalize_child_combinators(group: text) -> text:
    var out = ""
    var i = 0
    val group_len = group.len()
    while i < group_len:
        val ch = group.substring(i, i + 1)
        if ch == ">":
            out = out + " > "
        else:
            out = out + ch
        i = i + 1
    out.trim()

fn selector_group_parts(group: text) -> [text]:
    val raw_parts = normalize_child_combinators(group).split(" ")
    val part_count = raw_parts.len()
    var parts: [text] = [""; part_count]
    var i = 0
    while i < part_count:
        parts[i] = raw_parts[i].trim()
        i = i + 1
    parts

fn split_selector_group_parts(groups: [text]) -> [[text]]:
    val group_count = groups.len()
    var parts: [[text]] = [[]; group_count]
    var i = 0
    while i < group_count:
        parts[i] = selector_group_parts(groups[i])
        i = i + 1
    parts

fn selector_rightmost_part(parts: [text]) -> text:
    var right = parts.len() - 1
    while right >= 0:
        val part = parts[right]
        if part.len() > 0 and part != ">":
            return part
        right = right - 1
    ""

fn selector_bucket_base(part: text) -> text:
    var base = part
    val colon = text_index_of(base, ":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_start = text_index_of(base, "[")
    if attr_start >= 0:
        base = base.substring(0, attr_start).trim()
    base

fn selector_bucket_kind(part: text) -> text:
    val base = selector_bucket_base(part)
    selector_bucket_kind_from_base(base)

fn selector_bucket_kind_from_base(base: text) -> text:
    if base.len() == 0 or base == "*":
        return "fallback"
    if base.substring(0, 1) == "#":
        return "id"
    if base.substring(0, 1) == ".":
        return "class"
    if text_index_of(base, ".") >= 0:
        return "class"
    "tag"

fn selector_bucket_value(part: text) -> text:
    val base = selector_bucket_base(part)
    selector_bucket_value_from_base(base)

fn selector_bucket_value_from_base(base: text) -> text:
    if base.len() == 0:
        return ""
    if base.substring(0, 1) == "#" or base.substring(0, 1) == ".":
        val raw = base.substring(1, base.len())
        val dot = text_index_of(raw, ".")
        if dot >= 0:
            return raw.substring(0, dot)
        return raw
    val dot = text_index_of(base, ".")
    if dot >= 0:
        val raw = base.substring(dot + 1, base.len())
        val next_dot = text_index_of(raw, ".")
        if next_dot >= 0:
            return raw.substring(0, next_dot)
        return raw
    base

fn text_key_index(keys: [text], key: text) -> i32:
    var i = 0
    val key_count = keys.len()
    while i < key_count:
        if keys[i] == key:
            return i
        i = i + 1
    -1

fn text_key_index_count(keys: [text], key: text, key_count: i32) -> i32:
    var i = 0
    while i < key_count:
        if keys[i] == key:
            return i
        i = i + 1
    -1

fn text_list_prefix(values: [text], count: i32) -> [text]:
    var out: [text] = [""; count]
    var i = 0
    while i < count:
        out[i] = values[i]
        i = i + 1
    out

fn i32_list_prefix(values: [i32], count: i32) -> [i32]:
    var out: [i32] = [0; count]
    var i = 0
    while i < count:
        out[i] = values[i]
        i = i + 1
    out

fn text_seen_before(values: [text], end_index: i32, value: text) -> bool:
    var i = 0
    while i < end_index:
        if values[i] == value:
            return true
        i = i + 1
    false

fn merge_sorted_rule_lists_unique_count(lists: [[i32]], list_count: i32) -> [i32]:
    if list_count == 0:
        return []
    if list_count == 1:
        return lists[0]
    var positions: [i32] = [0; list_count]
    var out_count = 0
    var last = -1
    var has_last = false
    var done = false
    while not done:
        var min_rule = 2147483647
        var found = false
        var list_i = 0
        while list_i < list_count:
            val rules = lists[list_i]
            val rule_count = rules.len()
            var pos = positions[list_i]
            while pos < rule_count and has_last and rules[pos] == last:
                pos = pos + 1
            positions[list_i] = pos
            if pos < rule_count and rules[pos] < min_rule:
                min_rule = rules[pos]
                found = true
            list_i = list_i + 1
        if found:
            out_count = out_count + 1
            last = min_rule
            has_last = true
        else:
            done = true
    positions = [0; list_count]
    var out: [i32] = [0; out_count]
    var out_i = 0
    last = -1
    has_last = false
    done = false
    while not done:
        var min_rule = 2147483647
        var found = false
        var list_i = 0
        while list_i < list_count:
            val rules = lists[list_i]
            val rule_count = rules.len()
            var pos = positions[list_i]
            while pos < rule_count and has_last and rules[pos] == last:
                pos = pos + 1
            positions[list_i] = pos
            if pos < rule_count and rules[pos] < min_rule:
                min_rule = rules[pos]
                found = true
            list_i = list_i + 1
        if found:
            out[out_i] = min_rule
            out_i = out_i + 1
            last = min_rule
            has_last = true
        else:
            done = true
    out

fn rule_lists_from_counts(counts: [i32]) -> [[i32]]:
    val count_len = counts.len()
    var lists: [[i32]] = [[]; count_len]
    var i = 0
    while i < count_len:
        lists[i] = [0; counts[i]]
        i = i + 1
    lists

fn build_rule_buckets(rules: Rules) -> RuleBuckets:
    var bucket_capacity = 0
    var cr = 0
    val rule_count = rules.group_parts.len()
    while cr < rule_count:
        bucket_capacity = bucket_capacity + rules.group_parts[cr].len()
        cr = cr + 1
    var id_keys_raw: [text] = [""; bucket_capacity]
    var id_counts_raw: [i32] = [0; bucket_capacity]
    var id_key_count = 0
    var class_keys_raw: [text] = [""; bucket_capacity]
    var class_counts_raw: [i32] = [0; bucket_capacity]
    var class_key_count = 0
    var tag_keys_raw: [text] = [""; bucket_capacity]
    var tag_counts_raw: [i32] = [0; bucket_capacity]
    var tag_key_count = 0
    var fallback_count = 0
    var r = 0
    while r < rule_count:
        val groups = rules.group_parts[r]
        var g = 0
        val group_count = groups.len()
        while g < group_count:
            val right = selector_rightmost_part(groups[g])
            val base = selector_bucket_base(right)
            val kind = selector_bucket_kind_from_base(base)
            val key = selector_bucket_value_from_base(base)
            if kind == "id" and key.len() > 0:
                var idx = text_key_index_count(id_keys_raw, key, id_key_count)
                if idx < 0:
                    idx = id_key_count
                    id_keys_raw[idx] = key
                    id_key_count = id_key_count + 1
                id_counts_raw[idx] = id_counts_raw[idx] + 1
            elif kind == "class" and key.len() > 0:
                var idx = text_key_index_count(class_keys_raw, key, class_key_count)
                if idx < 0:
                    idx = class_key_count
                    class_keys_raw[idx] = key
                    class_key_count = class_key_count + 1
                class_counts_raw[idx] = class_counts_raw[idx] + 1
            elif kind == "tag" and key.len() > 0:
                var idx = text_key_index_count(tag_keys_raw, key, tag_key_count)
                if idx < 0:
                    idx = tag_key_count
                    tag_keys_raw[idx] = key
                    tag_key_count = tag_key_count + 1
                tag_counts_raw[idx] = tag_counts_raw[idx] + 1
            else:
                fallback_count = fallback_count + 1
            g = g + 1
        r = r + 1
    val id_keys = text_list_prefix(id_keys_raw, id_key_count)
    val id_counts = i32_list_prefix(id_counts_raw, id_key_count)
    val class_keys = text_list_prefix(class_keys_raw, class_key_count)
    val class_counts = i32_list_prefix(class_counts_raw, class_key_count)
    val tag_keys = text_list_prefix(tag_keys_raw, tag_key_count)
    val tag_counts = i32_list_prefix(tag_counts_raw, tag_key_count)
    var id_rules = rule_lists_from_counts(id_counts)
    var id_positions: [i32] = [0; id_counts.len()]
    var class_rules = rule_lists_from_counts(class_counts)
    var class_positions: [i32] = [0; class_counts.len()]
    var tag_rules = rule_lists_from_counts(tag_counts)
    var tag_positions: [i32] = [0; tag_counts.len()]
    var fallback_rules: [i32] = [0; fallback_count]
    var fallback_pos = 0
    r = 0
    while r < rule_count:
        val groups = rules.group_parts[r]
        var g = 0
        val group_count = groups.len()
        while g < group_count:
            val right = selector_rightmost_part(groups[g])
            val base = selector_bucket_base(right)
            val kind = selector_bucket_kind_from_base(base)
            val key = selector_bucket_value_from_base(base)
            if kind == "id" and key.len() > 0:
                val idx = text_key_index(id_keys, key)
                if idx >= 0:
                    var bucket = id_rules[idx]
                    bucket[id_positions[idx]] = r
                    id_rules[idx] = bucket
                    id_positions[idx] = id_positions[idx] + 1
            elif kind == "class" and key.len() > 0:
                val idx = text_key_index(class_keys, key)
                if idx >= 0:
                    var bucket = class_rules[idx]
                    bucket[class_positions[idx]] = r
                    class_rules[idx] = bucket
                    class_positions[idx] = class_positions[idx] + 1
            elif kind == "tag" and key.len() > 0:
                val idx = text_key_index(tag_keys, key)
                if idx >= 0:
                    var bucket = tag_rules[idx]
                    bucket[tag_positions[idx]] = r
                    tag_rules[idx] = bucket
                    tag_positions[idx] = tag_positions[idx] + 1
            else:
                fallback_rules[fallback_pos] = r
                fallback_pos = fallback_pos + 1
            g = g + 1
        r = r + 1
    RuleBuckets(id_keys: id_keys, id_rules: id_rules, class_keys: class_keys, class_rules: class_rules, tag_keys: tag_keys, tag_rules: tag_rules, fallback_rules: fallback_rules)

fn style_rule_candidates(node: HNode, buckets: RuleBuckets) -> [i32]:
    val class_count = node.class_words.len()
    var lists: [[i32]] = [[]; class_count + 3]
    var list_count = 0
    lists[list_count] = buckets.fallback_rules
    list_count = list_count + 1
    if node.id_attr.len() > 0:
        val id_idx = text_key_index(buckets.id_keys, node.id_attr)
        if id_idx >= 0:
            lists[list_count] = buckets.id_rules[id_idx]
            list_count = list_count + 1
    val tag_idx = text_key_index(buckets.tag_keys, node.tag)
    if tag_idx >= 0:
        lists[list_count] = buckets.tag_rules[tag_idx]
        list_count = list_count + 1
    var i = 0
    while i < class_count:
        val cls = node.class_words[i]
        if cls.len() > 0:
            if class_count <= 1 or not text_seen_before(node.class_words, i, cls):
                val class_idx = text_key_index(buckets.class_keys, cls)
                if class_idx >= 0:
                    lists[list_count] = buckets.class_rules[class_idx]
                    list_count = list_count + 1
        i = i + 1
    merge_sorted_rule_lists_unique_count(lists, list_count)

fn selector_group_matches_node_parts(nodes: [HNode], idx: i32, parts: [text]) -> bool:
    var right = parts.len() - 1
    while right >= 0 and parts[right] == "":
        right = right - 1
    if right < 0:
        return false
    val nd = nodes[idx]
    if not simple_match(parts[right], nd.tag, nd.class_attr, nd.class_words, nd.id_attr, nd.attrs_raw):
        return false
    var ancestor = nd.parent
    var want = right - 1
    var require_direct = false
    while want >= 0:
        val part = parts[want]
        if part.len() == 0:
            want = want - 1
        elif part == ">":
            require_direct = true
            want = want - 1
        else:
            if require_direct:
                if ancestor < 0:
                    return false
                val anc = nodes[ancestor]
                if simple_match(part, anc.tag, anc.class_attr, anc.class_words, anc.id_attr, anc.attrs_raw):
                    ancestor = anc.parent
                    require_direct = false
                else:
                    return false
            else:
                var found = false
                while ancestor >= 0 and not found:
                    val anc = nodes[ancestor]
                    if simple_match(part, anc.tag, anc.class_attr, anc.class_words, anc.id_attr, anc.attrs_raw):
                        found = true
                    else:
                        ancestor = anc.parent
                if not found:
                    return false
                ancestor = nodes[ancestor].parent
            want = want - 1
    not require_direct

fn selector_matches_node_group_parts(nodes: [HNode], idx: i32, group_parts: [[text]]) -> bool:
    var g = 0
    val group_count = group_parts.len()
    while g < group_count:
        if selector_group_matches_node_parts(nodes, idx, group_parts[g]):
            return true
        g = g + 1
    false

# ---------------------------------------------------------------------------
# Compute styles (cascade: inherit -> tag defaults -> matched rules -> inline)
# ---------------------------------------------------------------------------

fn compute_styles(nodes: [HNode], rules: Rules) -> [Style]:
    val rule_buckets = build_rule_buckets(rules)
    val node_count = nodes.len()
    var styles: [Style] = [default_style(); node_count]
    var i = 0
    while i < node_count:
        val nd = nodes[i]
        var st = if nd.parent >= 0: inherit_style(styles[nd.parent]) else: default_style()
        st = tag_defaults(st, nd.tag)
        val candidates = style_rule_candidates(nd, rule_buckets)
        var candidate_i = 0
        val candidate_count = candidates.len()
        while candidate_i < candidate_count:
            val r = candidates[candidate_i]
            if selector_matches_node_group_parts(nodes, i, rules.group_parts[r]):
                st = apply_decls(st, rules.decls[r])
            candidate_i = candidate_i + 1
        if nd.style_attr.len() > 0:
            st = apply_decls(st, nd.style_attr)
        styles[i] = st
        i = i + 1
    styles

# ---------------------------------------------------------------------------
# Tiny 5x7 bitmap font + plain [u32] framebuffer rasterizer
# ---------------------------------------------------------------------------
# Each glyph is 7 rows; each row's low 5 bits are pixels (bit 4 = leftmost).
# Basic lowercase glyphs are included for browser text parity. Layout geometry
# is derived from glyph_scale() so wrapping matches exactly what fb_text draws.

val FONT_CHARSET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 .,:;!?-_()[]/\\'\"+=#%&@*<>abcdefghijklmnopqrstuvwxyz"

val FONT_ROWS_PACKED: [i64] = [
    18842895918i64, 32801094206i64, 15620129326i64, 32801080894i64, 33840200223i64, 17734072863i64, 15621407278i64, 18842451505i64,
    15170932878i64, 13507823687i64, 18879369809i64, 33840185872i64, 18842572657i64, 18842507057i64, 15621211694i64, 17734518334i64,
    14585218606i64, 18879563326i64, 32247333391i64, 4433514655i64, 15621211697i64, 4648912433i64, 19182306865i64, 18593485137i64,
    4433514833i64, 33831389247i64, 15629733422i64, 15170933124i64, 33831454254i64, 15604060255i64, 2247698626i64, 15603923487i64,
    15621636358i64, 8866891839i64, 15621113390i64, 12953568814i64, 0i64, 4294967296i64, 8724152320i64, 134217856i64,
    8724152448i64, 4295102596i64, 4299295278i64, 1015808i64, 33285996544i64, 2290360450i64, 8726317192i64, 15309480206i64,
    15101659214i64, 17456826433i64, 1143087376i64, 8324i64, 10570i64, 139432064i64, 32537600i64, 368389098i64,
    120853337i64, 455782988i64, 487282222i64, 5014436516i64, 2290622594i64, 8726284424i64, 521635264i64, 1025047056i64,
    487080384i64, 521714721i64, 487572928i64, 277117190i64, 471320032i64, 588839440i64, 474099716i64, 421599234i64,
    625758800i64, 474091660i64, 588961600i64, 588826560i64, 488162752i64, 554649536i64, 35112416i64, 554197696i64,
    1008157152i64, 211035080i64, 456705568i64, 145278496i64, 358270496i64, 581052960i64, 471320096i64, 1048710112i64
]

val FONT_UNKNOWN_PACKED: i64 = 33874822719i64

fn glyph_row_bits(gi: i32, row: i32) -> i32:
    if row < 0 or row >= 7:
        return 0
    val packed = if gi >= 0 and gi < FONT_ROWS_PACKED.len(): FONT_ROWS_PACKED[gi] else: FONT_UNKNOWN_PACKED
    ((packed >> (row * 5)) & 31i64) as i32

# returns the 7 row bitmasks for a glyph index into FONT_CHARSET
fn glyph_rows(gi: i32) -> [i32]:
    if gi == 0:  return [0b01110, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]  # A
    if gi == 1:  return [0b11110, 0b10001, 0b11110, 0b10001, 0b10001, 0b10001, 0b11110]  # B
    if gi == 2:  return [0b01110, 0b10001, 0b10000, 0b10000, 0b10000, 0b10001, 0b01110]  # C
    if gi == 3:  return [0b11110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b11110]  # D
    if gi == 4:  return [0b11111, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000, 0b11111]  # E
    if gi == 5:  return [0b11111, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000, 0b10000]  # F
    if gi == 6:  return [0b01110, 0b10001, 0b10000, 0b10111, 0b10001, 0b10001, 0b01110]  # G
    if gi == 7:  return [0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001, 0b10001]  # H
    if gi == 8:  return [0b01110, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]  # I
    if gi == 9:  return [0b00111, 0b00010, 0b00010, 0b00010, 0b10010, 0b10010, 0b01100]  # J
    if gi == 10: return [0b10001, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b10001]  # K
    if gi == 11: return [0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b11111]  # L
    if gi == 12: return [0b10001, 0b11011, 0b10101, 0b10101, 0b10001, 0b10001, 0b10001]  # M
    if gi == 13: return [0b10001, 0b11001, 0b10101, 0b10011, 0b10001, 0b10001, 0b10001]  # N
    if gi == 14: return [0b01110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]  # O
    if gi == 15: return [0b11110, 0b10001, 0b10001, 0b11110, 0b10000, 0b10000, 0b10000]  # P
    if gi == 16: return [0b01110, 0b10001, 0b10001, 0b10001, 0b10101, 0b10010, 0b01101]  # Q
    if gi == 17: return [0b11110, 0b10001, 0b10001, 0b11110, 0b10100, 0b10010, 0b10001]  # R
    if gi == 18: return [0b01111, 0b10000, 0b10000, 0b01110, 0b00001, 0b00001, 0b11110]  # S
    if gi == 19: return [0b11111, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]  # T
    if gi == 20: return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]  # U
    if gi == 21: return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01010, 0b00100]  # V
    if gi == 22: return [0b10001, 0b10001, 0b10001, 0b10101, 0b10101, 0b11011, 0b10001]  # W
    if gi == 23: return [0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b01010, 0b10001]  # X
    if gi == 24: return [0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]  # Y
    if gi == 25: return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b10000, 0b11111]  # Z
    if gi == 26: return [0b01110, 0b10001, 0b10011, 0b10101, 0b11001, 0b10001, 0b01110]  # 0
    if gi == 27: return [0b00100, 0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]  # 1
    if gi == 28: return [0b01110, 0b10001, 0b00001, 0b00110, 0b01000, 0b10000, 0b11111]  # 2
    if gi == 29: return [0b11111, 0b00010, 0b00100, 0b00110, 0b00001, 0b10001, 0b01110]  # 3
    if gi == 30: return [0b00010, 0b00110, 0b01010, 0b10010, 0b11111, 0b00010, 0b00010]  # 4
    if gi == 31: return [0b11111, 0b10000, 0b11110, 0b00001, 0b00001, 0b10001, 0b01110]  # 5
    if gi == 32: return [0b00110, 0b01000, 0b10000, 0b11110, 0b10001, 0b10001, 0b01110]  # 6
    if gi == 33: return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b01000, 0b01000]  # 7
    if gi == 34: return [0b01110, 0b10001, 0b10001, 0b01110, 0b10001, 0b10001, 0b01110]  # 8
    if gi == 35: return [0b01110, 0b10001, 0b10001, 0b01111, 0b00001, 0b00010, 0b01100]  # 9
    if gi == 36: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000]  # space
    if gi == 37: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100]  # .
    if gi == 38: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]  # ,
    if gi == 39: return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b00000]  # :
    if gi == 40: return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]  # ;
    if gi == 41: return [0b00100, 0b00100, 0b00100, 0b00100, 0b00000, 0b00000, 0b00100]  # !
    if gi == 42: return [0b01110, 0b10001, 0b00010, 0b00100, 0b00100, 0b00000, 0b00100]  # ?
    if gi == 43: return [0b00000, 0b00000, 0b00000, 0b11111, 0b00000, 0b00000, 0b00000]  # -
    if gi == 44: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b11111]  # _
    if gi == 45: return [0b00010, 0b00100, 0b01000, 0b01000, 0b01000, 0b00100, 0b00010]  # (
    if gi == 46: return [0b01000, 0b00100, 0b00010, 0b00010, 0b00010, 0b00100, 0b01000]  # )
    if gi == 47: return [0b01110, 0b01000, 0b01000, 0b01000, 0b01000, 0b01000, 0b01110]  # [
    if gi == 48: return [0b01110, 0b00010, 0b00010, 0b00010, 0b00010, 0b00010, 0b01110]  # ]
    if gi == 49: return [0b00001, 0b00010, 0b00010, 0b00100, 0b01000, 0b01000, 0b10000]  # /
    if gi == 50: return [0b10000, 0b01000, 0b01000, 0b00100, 0b00010, 0b00010, 0b00001]  # \
    if gi == 51: return [0b00100, 0b00100, 0b01000, 0b00000, 0b00000, 0b00000, 0b00000]  # '
    if gi == 52: return [0b01010, 0b01010, 0b01010, 0b00000, 0b00000, 0b00000, 0b00000]  # "
    if gi == 53: return [0b00000, 0b00100, 0b00100, 0b11111, 0b00100, 0b00100, 0b00000]  # +
    if gi == 54: return [0b00000, 0b00000, 0b11111, 0b00000, 0b11111, 0b00000, 0b00000]  # =
    if gi == 55: return [0b01010, 0b11111, 0b01010, 0b01010, 0b11111, 0b01010, 0b00000]  # #
    if gi == 56: return [0b11001, 0b11010, 0b00100, 0b01000, 0b10011, 0b00011, 0b00000]  # %
    if gi == 57: return [0b01100, 0b10010, 0b01100, 0b10101, 0b10010, 0b01101, 0b00000]  # &
    if gi == 58: return [0b01110, 0b10001, 0b10101, 0b10110, 0b10000, 0b01110, 0b00000]  # @
    if gi == 59: return [0b00100, 0b10101, 0b01110, 0b00100, 0b01110, 0b10101, 0b00100]  # *
    if gi == 60: return [0b00010, 0b00100, 0b01000, 0b10000, 0b01000, 0b00100, 0b00010]  # <
    if gi == 61: return [0b01000, 0b00100, 0b00010, 0b00001, 0b00010, 0b00100, 0b01000]  # >
    if gi == 62: return [0b00000, 0b01110, 0b00001, 0b01111, 0b10001, 0b01111, 0b00000]  # a
    if gi == 63: return [0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b11110, 0b00000]  # b
    if gi == 64: return [0b00000, 0b01110, 0b10000, 0b10000, 0b10000, 0b01110, 0b00000]  # c
    if gi == 65: return [0b00001, 0b00001, 0b01111, 0b10001, 0b10001, 0b01111, 0b00000]  # d
    if gi == 66: return [0b00000, 0b01110, 0b10001, 0b11111, 0b10000, 0b01110, 0b00000]  # e
    if gi == 67: return [0b00110, 0b01000, 0b11110, 0b01000, 0b01000, 0b01000, 0b00000]  # f
    if gi == 68: return [0b00000, 0b01111, 0b10001, 0b01111, 0b00001, 0b01110, 0b00000]  # g
    if gi == 69: return [0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b10001, 0b00000]  # h
    if gi == 70: return [0b00100, 0b00000, 0b01100, 0b00100, 0b00100, 0b01110, 0b00000]  # i
    if gi == 71: return [0b00010, 0b00000, 0b00110, 0b00010, 0b10010, 0b01100, 0b00000]  # j
    if gi == 72: return [0b10000, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b00000]  # k
    if gi == 73: return [0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110, 0b00000]  # l
    if gi == 74: return [0b00000, 0b11010, 0b10101, 0b10101, 0b10001, 0b10001, 0b00000]  # m
    if gi == 75: return [0b00000, 0b11110, 0b10001, 0b10001, 0b10001, 0b10001, 0b00000]  # n
    if gi == 76: return [0b00000, 0b01110, 0b10001, 0b10001, 0b10001, 0b01110, 0b00000]  # o
    if gi == 77: return [0b00000, 0b11110, 0b10001, 0b11110, 0b10000, 0b10000, 0b00000]  # p
    if gi == 78: return [0b00000, 0b01111, 0b10001, 0b01111, 0b00001, 0b00001, 0b00000]  # q
    if gi == 79: return [0b00000, 0b10110, 0b11000, 0b10000, 0b10000, 0b10000, 0b00000]  # r
    if gi == 80: return [0b00000, 0b01111, 0b10000, 0b01110, 0b00001, 0b11110, 0b00000]  # s
    if gi == 81: return [0b01000, 0b11110, 0b01000, 0b01000, 0b01001, 0b00110, 0b00000]  # t
    if gi == 82: return [0b00000, 0b10001, 0b10001, 0b10001, 0b10011, 0b01101, 0b00000]  # u
    if gi == 83: return [0b00000, 0b10001, 0b10001, 0b10001, 0b01010, 0b00100, 0b00000]  # v
    if gi == 84: return [0b00000, 0b10001, 0b10001, 0b10101, 0b10101, 0b01010, 0b00000]  # w
    if gi == 85: return [0b00000, 0b10001, 0b01010, 0b00100, 0b01010, 0b10001, 0b00000]  # x
    if gi == 86: return [0b00000, 0b10001, 0b10001, 0b01111, 0b00001, 0b01110, 0b00000]  # y
    if gi == 87: return [0b00000, 0b11111, 0b00010, 0b00100, 0b01000, 0b11111, 0b00000]  # z
    [0b11111, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b11111]  # unknown -> box

fn glyph_index_for_char_code(code: i32) -> i32:
    if code >= 65 and code <= 90:
        return code - 65
    if code >= 48 and code <= 57:
        return 26 + (code - 48)
    if code == 32: return 36
    if code == 46: return 37
    if code == 44: return 38
    if code == 58: return 39
    if code == 59: return 40
    if code == 33: return 41
    if code == 63: return 42
    if code == 45: return 43
    if code == 95: return 44
    if code == 40: return 45
    if code == 41: return 46
    if code == 91: return 47
    if code == 93: return 48
    if code == 47: return 49
    if code == 92: return 50
    if code == 39: return 51
    if code == 34: return 52
    if code == 43: return 53
    if code == 61: return 54
    if code == 35: return 55
    if code == 37: return 56
    if code == 38: return 57
    if code == 64: return 58
    if code == 42: return 59
    if code == 60: return 60
    if code == 62: return 61
    if code >= 97 and code <= 122:
        return 62 + (code - 97)
    -1

fn _glyph_charset_index_of(ch: text) -> i32:
    if ch.len() != 1:
        return -1
    val needle = ch.char_code_at(0)
    var i = 0
    val charset_len = FONT_CHARSET.len()
    while i < charset_len:
        if FONT_CHARSET.char_code_at(i) == needle:
            return i
        i = i + 1
    -1

fn glyph_index_for_char(ch: text) -> i32:
    if ch.len() == 1:
        val direct_code = glyph_index_for_char_code(ch.char_code_at(0))
        if direct_code >= 0:
            return direct_code
    val direct = _glyph_charset_index_of(ch)
    if direct >= 0:
        return direct
    _glyph_charset_index_of(ch.upper())

# integer nearest scale based on font size; 16->2, 34->4
fn glyph_scale(fs: i32) -> i32:
    var s = fs / 8
    if s < 1:
        s = 1
    s

# write `color` to a single framebuffer pixel (clipped)
fn fb_put(mut fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= fbw or y >= fbh:
        return
    fb[y * fbw + x] = color

fn fb_clear(mut fb: [u32], color: u32):
    var i = 0
    val n = fb.len()
    while i < n:
        fb[i] = color
        i = i + 1

# clipped filled rectangle
fn fb_rect(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

class ClipRect:
    x0: i32
    y0: i32
    x1: i32
    y1: i32

class PaintClipCache:
    has_node_clips: bool
    default_clip: ClipRect
    clips: [ClipRect]

fn clip_intersect(c: ClipRect, x0: i32, y0: i32, x1: i32, y1: i32) -> ClipRect:
    var nx0 = c.x0
    var ny0 = c.y0
    var nx1 = c.x1
    var ny1 = c.y1
    if x0 > nx0:
        nx0 = x0
    if y0 > ny0:
        ny0 = y0
    if x1 < nx1:
        nx1 = x1
    if y1 < ny1:
        ny1 = y1
    ClipRect(x0: nx0, y0: ny0, x1: nx1, y1: ny1)

fn fb_rect_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, clip: ClipRect) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

fn blend_opacity(src: u32, dst: u32, opacity_pct: i32) -> u32:
    if opacity_pct >= 100:
        return src
    if opacity_pct <= 0:
        return dst
    val sr = (((src >> 16) & 255u32) as i32)
    val sg = (((src >> 8) & 255u32) as i32)
    val sb = ((src & 255u32) as i32)
    val dr = (((dst >> 16) & 255u32) as i32)
    val dg = (((dst >> 8) & 255u32) as i32)
    val db = ((dst & 255u32) as i32)
    val inv = 100 - opacity_pct
    val r = (sr * opacity_pct + dr * inv + 50) / 100
    val g = (sg * opacity_pct + dg * inv + 50) / 100
    val b = (sb * opacity_pct + db * inv + 50) / 100
    argb(r, g, b)

fn fb_rect_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    if opacity_pct >= 100:
        return fb_rect_clip(fb, fbw, fbh, x, y, w, h, color, clip)
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            val idx = row + px
            out[idx] = blend_opacity(color, out[idx], opacity_pct)
            px = px + 1
        py = py + 1
    out

fn fb_border(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, border_w: i32, color: u32) -> [u32]:
    var out = fb
    if border_w <= 0 or color == 0u32:
        return out
    out = fb_rect(out, fbw, fbh, x, y, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y + h - border_w, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y, border_w, h, color)
    out = fb_rect(out, fbw, fbh, x + w - border_w, y, border_w, h, color)
    out

fn fb_border_sides(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, w, bt, ct)
    if bb > 0 and cb != 0u32:
        out = fb_rect(out, fbw, fbh, x, y + h - bb, w, bb, cb)
    if bl > 0 and cl != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, bl, h, cl)
    if br > 0 and cr != 0u32:
        out = fb_rect(out, fbw, fbh, x + w - br, y, br, h, cr)
    out

fn fb_border_sides_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32, clip: ClipRect) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, w, bt, ct, clip)
    if bb > 0 and cb != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y + h - bb, w, bb, cb, clip)
    if bl > 0 and cl != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, bl, h, cl, clip)
    if br > 0 and cr != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x + w - br, y, br, h, cr, clip)
    out

fn fb_glyph_thin_scaled_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, scale: i32, clip: ClipRect) -> [u32]:
    var out = fb
    var ry = 0
    while ry < 7:
        val bits = glyph_row_bits(gi, ry)
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0:
                val bx0 = x + rx * scale
                val by0 = y + ry * scale
                var dy = 0
                while dy < scale:
                    val yy = by0 + dy
                    if yy >= 0 and yy < fbh and yy >= clip.y0 and yy < clip.y1:
                        val row = yy * fbw
                        var dx = 0
                        while dx < scale:
                            val xx = bx0 + dx
                            if xx >= 0 and xx < fbw and xx >= clip.x0 and xx < clip.x1:
                                out[row + xx] = color
                            dx = dx + 1
                    dy = dy + 1
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_thin_scaled_clip_range(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, start: i32, endv: i32, color: u32, scale: i32, advance: i32, clip: ClipRect) -> [u32]:
    var out = fb
    val glyph_h = 7 * scale
    if y >= fbh or y >= clip.y1 or y + glyph_h <= 0 or y + glyph_h <= clip.y0:
        return out
    var i = start
    var cx = x
    while i < endv:
        if cx >= fbw or cx >= clip.x1:
            return out
        if cx < fbw and cx < clip.x1:
            var gi = glyph_index_for_char_code(s.char_code_at(i))
            if gi < 0:
                gi = glyph_index_for_char(s.substring(i, i + 1))
            if gi >= 0 and gi != 36:
                out = fb_glyph_thin_scaled_clip(out, fbw, fbh, cx, y, gi, color, scale, clip)
        cx = cx + advance
        i = i + 1
    out

fn fb_glyph_sparse(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32) -> [u32]:
    var out = fb
    var ry = 0
    while ry < 7:
        val bits = glyph_row_bits(gi, ry)
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0 and ((rx + ry) % 2) == 0:
                val xx = x + rx
                val yy = y + ry
                if xx >= 0 and xx < fbw and yy >= 0 and yy < fbh:
                    out[yy * fbw + xx] = color
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_sparse_range(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, start: i32, endv: i32, color: u32) -> [u32]:
    var out = fb
    if y >= fbh or y + 7 <= 0:
        return out
    var i = start
    var cx = x
    while i < endv:
        if cx >= fbw:
            return out
        if cx < fbw:
            var gi = glyph_index_for_char_code(s.char_code_at(i))
            if gi < 0:
                gi = glyph_index_for_char(s.substring(i, i + 1))
            if gi >= 0 and gi != 36:
                out = fb_glyph_sparse(out, fbw, fbh, cx, y, gi, color)
        cx = cx + 6
        i = i + 1
    out

fn fb_px(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32) -> [u32]:
    var out = fb
    if x >= 0 and x < fbw and y >= 0 and y < fbh:
        out[y * fbw + x] = color
    out

