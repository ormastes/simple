    Style(bg: bg_v, fg: fg_v, font_size: font_size_v, line_height_px: line_height_v, width_px: width_v, height_px: height_v, border_box: border_box_v, min_height_px: min_height_v, min_height_vh: min_height_vh_v, flex_fill: flex_fill_v, pad_l: pad_l_v, pad_t: pad_t_v, pad_r: pad_r_v, pad_b: pad_b_v, border_w: border_w_v, border_color: border_color_v, border_l: border_l_v, border_t: border_t_v, border_r: border_r_v, border_b: border_b_v, border_color_l: border_color_l_v, border_color_t: border_color_t_v, border_color_r: border_color_r_v, border_color_b: border_color_b_v, gap_px: gap_v, margin_l: margin_l_v, margin_t: margin_t_v, margin_r: margin_r_v, margin_b: margin_b_v, display: display_v, overflow_hidden: overflow_hidden_v, visibility_hidden: visibility_hidden_v, position_relative: position_relative_v, position_absolute: position_absolute_v, left_px: left_px_v, top_px: top_px_v, right_px: right_px_v, bottom_px: bottom_px_v, z_index: z_index_v, opacity_pct: opacity_pct_v, flex_direction: flex_direction_v, text_align: text_align_v, bold: bold_v)

# default per-tag tweaks (block/inline, heading sizes, spacing)
fn tag_defaults(st: Style, tag: text) -> Style:
    var display_v = st.display
    var font_size_v = st.font_size
    var margin_t_v = st.margin_t
    var margin_b_v = st.margin_b
    var bold_v = st.bold
    if is_non_rendered_tag(tag):
        return Style(bg: st.bg, fg: st.fg, font_size: font_size_v, line_height_px: st.line_height_px, width_px: st.width_px, height_px: st.height_px, border_box: st.border_box, min_height_px: st.min_height_px, min_height_vh: st.min_height_vh, flex_fill: st.flex_fill, pad_l: st.pad_l, pad_t: st.pad_t, pad_r: st.pad_r, pad_b: st.pad_b, border_w: st.border_w, border_color: st.border_color, border_l: st.border_l, border_t: st.border_t, border_r: st.border_r, border_b: st.border_b, border_color_l: st.border_color_l, border_color_t: st.border_color_t, border_color_r: st.border_color_r, border_color_b: st.border_color_b, gap_px: st.gap_px, margin_l: st.margin_l, margin_t: margin_t_v, margin_r: st.margin_r, margin_b: margin_b_v, display: "none", overflow_hidden: st.overflow_hidden, visibility_hidden: st.visibility_hidden, position_relative: st.position_relative, position_absolute: st.position_absolute, left_px: st.left_px, top_px: st.top_px, right_px: st.right_px, bottom_px: st.bottom_px, z_index: st.z_index, opacity_pct: st.opacity_pct, flex_direction: st.flex_direction, text_align: st.text_align, bold: bold_v)
    if is_inline_tag(tag):
        display_v = "inline"
    if tag == "h1":
        font_size_v = 34
        bold_v = true
        margin_t_v = 10
        margin_b_v = 10
    elif tag == "h2":
        font_size_v = 26
        bold_v = true
        margin_t_v = 8
        margin_b_v = 8
    elif tag == "h3":
        font_size_v = 20
        bold_v = true
        margin_t_v = 6
        margin_b_v = 6
    elif tag == "p":
        margin_t_v = 6
        margin_b_v = 6
    elif tag == "header" or tag == "footer" or tag == "nav" or tag == "section" or tag == "table" or tag == "tr" or tag == "div" or tag == "ul" or tag == "li":
        display_v = "block"
    Style(bg: st.bg, fg: st.fg, font_size: font_size_v, line_height_px: st.line_height_px, width_px: st.width_px, height_px: st.height_px, border_box: st.border_box, min_height_px: st.min_height_px, min_height_vh: st.min_height_vh, flex_fill: st.flex_fill, pad_l: st.pad_l, pad_t: st.pad_t, pad_r: st.pad_r, pad_b: st.pad_b, border_w: st.border_w, border_color: st.border_color, border_l: st.border_l, border_t: st.border_t, border_r: st.border_r, border_b: st.border_b, border_color_l: st.border_color_l, border_color_t: st.border_color_t, border_color_r: st.border_color_r, border_color_b: st.border_color_b, gap_px: st.gap_px, margin_l: st.margin_l, margin_t: margin_t_v, margin_r: st.margin_r, margin_b: margin_b_v, display: display_v, overflow_hidden: st.overflow_hidden, visibility_hidden: st.visibility_hidden, position_relative: st.position_relative, position_absolute: st.position_absolute, left_px: st.left_px, top_px: st.top_px, right_px: st.right_px, bottom_px: st.bottom_px, z_index: st.z_index, opacity_pct: st.opacity_pct, flex_direction: st.flex_direction, text_align: st.text_align, bold: bold_v)

# ---------------------------------------------------------------------------
# CSS rules from <style> blocks
# ---------------------------------------------------------------------------

class Rules:
    sels: [text]
    decls: [text]

fn extract_css(html: text) -> Rules:
    var sels: [text] = []
    var decls: [text] = []
    var pos = 0
    var guard = 0
    while guard < 1000:
        guard = guard + 1
        val sp = find_from(html, "<style", pos)
        if sp < 0:
            break
        val open = find_from(html, ">", sp)
        if open < 0:
            break
        val close = find_from(html, "</style", open)
        if close < 0:
            break
        val css = html.substring(open + 1, close)
        # split into "selector { decls }" chunks
        var cp = 0
        while cp < css.len():
            val brace = find_from(css, "{", cp)
            if brace < 0:
                break
            val endb = find_from(css, "}", brace)
            if endb < 0:
                break
            val sel_raw = css.substring(cp, brace)
            val sel = sel_raw.trim()
            val decl_raw = css.substring(brace + 1, endb)
            val decl = decl_raw.trim()
            if sel.len() > 0:
                sels.push(sel)
                decls.push(decl)
            cp = endb + 1
        pos = close + 1
    Rules(sels: sels, decls: decls)

fn unquote_css_attr_value(raw: text) -> text:
    val v = raw.trim()
    if v.len() >= 2:
        val first = v.substring(0, 1)
        val last = v.substring(v.len() - 1, v.len())
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return v.substring(1, v.len() - 1)
    v

fn attr_selector_matches(attrs: text, expr: text) -> bool:
    val raw = expr.trim()
    if raw.len() == 0:
        return false
    val prefix_op = raw.index_of("^=")
    if prefix_op >= 0:
        val name = raw.substring(0, prefix_op).trim()
        val want = unquote_css_attr_value(raw.substring(prefix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.starts_with(want)
    val suffix_op = raw.index_of("$=")
    if suffix_op >= 0:
        val name = raw.substring(0, suffix_op).trim()
        val want = unquote_css_attr_value(raw.substring(suffix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.ends_with(want)
    val exact_op = raw.index_of("=")
    if exact_op >= 0:
        val name = raw.substring(0, exact_op).trim()
        val want = unquote_css_attr_value(raw.substring(exact_op + 1, raw.len()))
        return attr_value(attrs, name) == want
    attr_value(attrs, raw).len() > 0

fn base_selector_matches(base: text, tag: text, cls: text, id: text) -> bool:
    if base.len() == 0:
        return true
    if base.substring(0, 1) == ".":
        val want = base.substring(1, base.len())
        return class_has_all(cls, want)
    if base.substring(0, 1) == "#":
        return id == base.substring(1, base.len())
    val dot = base.index_of(".")
    if dot >= 0:
        val t = base.substring(0, dot)
        val want = base.substring(dot + 1, base.len())
        return t == tag and class_has_all(cls, want)
    base == tag

# does a single simple selector match this node? (rightmost token only)
fn simple_match(sel: text, tag: text, cls: text, id: text, attrs: text) -> bool:
    val s = sel.trim()
    if s.len() == 0:
        return false
    # strip pseudo (:hover, :nth-child(..))
    var base = s
    val colon = base.index_of(":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_start = base.index_of("[")
    if attr_start >= 0:
        val attr_end = base.index_of("]")
        if attr_end < attr_start:
            return false
        val node_base = base.substring(0, attr_start).trim()
        val expr = base.substring(attr_start + 1, attr_end)
        return base_selector_matches(node_base, tag, cls, id) and attr_selector_matches(attrs, expr)
    base_selector_matches(base, tag, cls, id)

fn class_has(cls: text, want: text) -> bool:
    if cls == want:
        return true
    if (" " + cls + " ").contains(" " + want + " "):
        return true
    val parts = cls.split(" ")
    var i = 0
    while i < parts.len():
        if parts[i] == want:
            return true
        i = i + 1
    false

fn class_has_all(cls: text, wants: text) -> bool:
    val parts = wants.split(".")
    var i = 0
    while i < parts.len():
        val want = parts[i].trim()
        if want.len() > 0 and not class_has(cls, want):
            return false
        i = i + 1
    true

fn class_contains(cls: text, want: text) -> bool:
    cls.contains(want)

# Rightmost compound only. Kept for callers that do not have tree context.
fn selector_matches(sel: text, tag: text, cls: text, id: text) -> bool:
    val groups = sel.split(",")
    var g = 0
    while g < groups.len():
        val gg = groups[g].trim()
        val sp = gg.last_index_of(" ")
        val right = if sp >= 0: gg.substring(sp + 1, gg.len()) else: gg
        if simple_match(right, tag, cls, id, ""):
            return true
        g = g + 1
    false

fn normalize_child_combinators(group: text) -> text:
    var out = ""
    var i = 0
    while i < group.len():
        val ch = group.substring(i, i + 1)
        if ch == ">":
            out = out + " > "
        else:
            out = out + ch
        i = i + 1
    out.trim()

fn selector_group_matches_node(nodes: [HNode], idx: i32, group: text) -> bool:
    val trimmed_group = normalize_child_combinators(group)
    val parts = trimmed_group.split(" ")
    var right = parts.len() - 1
    while right >= 0 and parts[right].trim().len() == 0:
        right = right - 1
    if right < 0:
        return false
    val nd = nodes[idx]
    if not simple_match(parts[right], nd.tag, nd.class_attr, nd.id_attr, nd.attrs_raw):
        return false
    var ancestor = nd.parent
    var want = right - 1
    var require_direct = false
    while want >= 0:
        val part = parts[want].trim()
        if part.len() == 0:
            want = want - 1
        elif part == ">":
            require_direct = true
            want = want - 1
        else:
            if require_direct:
                if ancestor < 0:
                    return false
                val anc = nodes[ancestor]
                if simple_match(part, anc.tag, anc.class_attr, anc.id_attr, anc.attrs_raw):
                    ancestor = anc.parent
                    require_direct = false
                else:
                    return false
            else:
                var found = false
                while ancestor >= 0 and not found:
                    val anc = nodes[ancestor]
                    if simple_match(part, anc.tag, anc.class_attr, anc.id_attr, anc.attrs_raw):
                        found = true
                    else:
                        ancestor = anc.parent
                if not found:
                    return false
                ancestor = nodes[ancestor].parent
            want = want - 1
    not require_direct

fn selector_matches_node(nodes: [HNode], idx: i32, sel: text) -> bool:
    val groups = sel.split(",")
    var g = 0
    while g < groups.len():
        if selector_group_matches_node(nodes, idx, groups[g]):
            return true
        g = g + 1
    false

fn style_block_decls_for_node(html: text, nodes: [HNode], node_index: i32) -> text:
    var out = ""
    var pos = 0
    var guard = 0
    while guard < 1000:
        guard = guard + 1
        val sp = find_from(html, "<style", pos)
        if sp < 0:
            break
        val open = find_from(html, ">", sp)
        if open < 0:
            break
        val close = find_from(html, "</style", open)
        if close < 0:
            break
        val css = html.substring(open + 1, close)
        var cp = 0
        while cp < css.len():
            val brace = find_from(css, "{", cp)
            if brace < 0:
                break
            val endb = find_from(css, "}", brace)
            if endb < 0:
                break
            val sel = css.substring(cp, brace).trim()
            val decl = css.substring(brace + 1, endb).trim()
            if sel.len() > 0 and decl.len() > 0 and selector_matches_node(nodes, node_index, sel):
                out = out + decl + ";"
            cp = endb + 1
        pos = close + 1
    out

# ---------------------------------------------------------------------------
# Compute styles (cascade: inherit -> tag defaults -> matched rules -> inline)
# ---------------------------------------------------------------------------

fn compute_styles(nodes: [HNode], rules: Rules, html: text) -> [Style]:
    var styles: [Style] = []
    var i = 0
    while i < nodes.len():
        val nd = nodes[i]
        var st = if nd.parent >= 0: inherit_style(styles[nd.parent]) else: default_style()
        st = tag_defaults(st, nd.tag)
        val direct_style_decls = style_block_decls_for_node(html, nodes, i)
        if direct_style_decls.len() > 0:
            st = apply_decls(st, direct_style_decls)
        var r = 0
        while r < rules.sels.len():
            if selector_matches_node(nodes, i, rules.sels[r]):
                st = apply_decls(st, rules.decls[r])
            r = r + 1
        if nd.style_attr.len() > 0:
            st = apply_decls(st, nd.style_attr)
        styles.push(st)
        i = i + 1
    styles

# ---------------------------------------------------------------------------
# Tiny 5x7 bitmap font + plain [u32] framebuffer rasterizer
# ---------------------------------------------------------------------------
# Each glyph is 7 rows; each row's low 5 bits are pixels (bit 4 = leftmost).
# Basic lowercase glyphs are included for browser text parity. Layout geometry
# is derived from glyph_scale() so wrapping matches exactly what fb_text draws.

val FONT_CHARSET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 .,:;!?-_()[]/\\'\"+=#%&@*<>abcdefghijklmnopqrstuvwxyz"

# returns the 7 row bitmasks for a glyph index into FONT_CHARSET
fn glyph_rows(gi: i32) -> [i32]:
    if gi == 0:  return [0b01110, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]  # A
    if gi == 1:  return [0b11110, 0b10001, 0b11110, 0b10001, 0b10001, 0b10001, 0b11110]  # B
    if gi == 2:  return [0b01110, 0b10001, 0b10000, 0b10000, 0b10000, 0b10001, 0b01110]  # C
    if gi == 3:  return [0b11110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b11110]  # D
    if gi == 4:  return [0b11111, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000, 0b11111]  # E
    if gi == 5:  return [0b11111, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000, 0b10000]  # F
    if gi == 6:  return [0b01110, 0b10001, 0b10000, 0b10111, 0b10001, 0b10001, 0b01110]  # G
    if gi == 7:  return [0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001, 0b10001]  # H
    if gi == 8:  return [0b01110, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]  # I
    if gi == 9:  return [0b00111, 0b00010, 0b00010, 0b00010, 0b10010, 0b10010, 0b01100]  # J
    if gi == 10: return [0b10001, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b10001]  # K
    if gi == 11: return [0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b11111]  # L
    if gi == 12: return [0b10001, 0b11011, 0b10101, 0b10101, 0b10001, 0b10001, 0b10001]  # M
    if gi == 13: return [0b10001, 0b11001, 0b10101, 0b10011, 0b10001, 0b10001, 0b10001]  # N
    if gi == 14: return [0b01110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]  # O
    if gi == 15: return [0b11110, 0b10001, 0b10001, 0b11110, 0b10000, 0b10000, 0b10000]  # P
    if gi == 16: return [0b01110, 0b10001, 0b10001, 0b10001, 0b10101, 0b10010, 0b01101]  # Q
    if gi == 17: return [0b11110, 0b10001, 0b10001, 0b11110, 0b10100, 0b10010, 0b10001]  # R
    if gi == 18: return [0b01111, 0b10000, 0b10000, 0b01110, 0b00001, 0b00001, 0b11110]  # S
    if gi == 19: return [0b11111, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]  # T
    if gi == 20: return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]  # U
    if gi == 21: return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01010, 0b00100]  # V
    if gi == 22: return [0b10001, 0b10001, 0b10001, 0b10101, 0b10101, 0b11011, 0b10001]  # W
    if gi == 23: return [0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b01010, 0b10001]  # X
    if gi == 24: return [0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]  # Y
    if gi == 25: return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b10000, 0b11111]  # Z
    if gi == 26: return [0b01110, 0b10001, 0b10011, 0b10101, 0b11001, 0b10001, 0b01110]  # 0
    if gi == 27: return [0b00100, 0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]  # 1
    if gi == 28: return [0b01110, 0b10001, 0b00001, 0b00110, 0b01000, 0b10000, 0b11111]  # 2
    if gi == 29: return [0b11111, 0b00010, 0b00100, 0b00110, 0b00001, 0b10001, 0b01110]  # 3
    if gi == 30: return [0b00010, 0b00110, 0b01010, 0b10010, 0b11111, 0b00010, 0b00010]  # 4
    if gi == 31: return [0b11111, 0b10000, 0b11110, 0b00001, 0b00001, 0b10001, 0b01110]  # 5
    if gi == 32: return [0b00110, 0b01000, 0b10000, 0b11110, 0b10001, 0b10001, 0b01110]  # 6
    if gi == 33: return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b01000, 0b01000]  # 7
    if gi == 34: return [0b01110, 0b10001, 0b10001, 0b01110, 0b10001, 0b10001, 0b01110]  # 8
    if gi == 35: return [0b01110, 0b10001, 0b10001, 0b01111, 0b00001, 0b00010, 0b01100]  # 9
    if gi == 36: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000]  # space
    if gi == 37: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100]  # .
    if gi == 38: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]  # ,
    if gi == 39: return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b00000]  # :
    if gi == 40: return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]  # ;
    if gi == 41: return [0b00100, 0b00100, 0b00100, 0b00100, 0b00000, 0b00000, 0b00100]  # !
    if gi == 42: return [0b01110, 0b10001, 0b00010, 0b00100, 0b00100, 0b00000, 0b00100]  # ?
    if gi == 43: return [0b00000, 0b00000, 0b00000, 0b11111, 0b00000, 0b00000, 0b00000]  # -
    if gi == 44: return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b11111]  # _
    if gi == 45: return [0b00010, 0b00100, 0b01000, 0b01000, 0b01000, 0b00100, 0b00010]  # (
    if gi == 46: return [0b01000, 0b00100, 0b00010, 0b00010, 0b00010, 0b00100, 0b01000]  # )
    if gi == 47: return [0b01110, 0b01000, 0b01000, 0b01000, 0b01000, 0b01000, 0b01110]  # [
    if gi == 48: return [0b01110, 0b00010, 0b00010, 0b00010, 0b00010, 0b00010, 0b01110]  # ]
    if gi == 49: return [0b00001, 0b00010, 0b00010, 0b00100, 0b01000, 0b01000, 0b10000]  # /
    if gi == 50: return [0b10000, 0b01000, 0b01000, 0b00100, 0b00010, 0b00010, 0b00001]  # \
    if gi == 51: return [0b00100, 0b00100, 0b01000, 0b00000, 0b00000, 0b00000, 0b00000]  # '
    if gi == 52: return [0b01010, 0b01010, 0b01010, 0b00000, 0b00000, 0b00000, 0b00000]  # "
    if gi == 53: return [0b00000, 0b00100, 0b00100, 0b11111, 0b00100, 0b00100, 0b00000]  # +
    if gi == 54: return [0b00000, 0b00000, 0b11111, 0b00000, 0b11111, 0b00000, 0b00000]  # =
    if gi == 55: return [0b01010, 0b11111, 0b01010, 0b01010, 0b11111, 0b01010, 0b00000]  # #
    if gi == 56: return [0b11001, 0b11010, 0b00100, 0b01000, 0b10011, 0b00011, 0b00000]  # %
    if gi == 57: return [0b01100, 0b10010, 0b01100, 0b10101, 0b10010, 0b01101, 0b00000]  # &
    if gi == 58: return [0b01110, 0b10001, 0b10101, 0b10110, 0b10000, 0b01110, 0b00000]  # @
    if gi == 59: return [0b00100, 0b10101, 0b01110, 0b00100, 0b01110, 0b10101, 0b00100]  # *
    if gi == 60: return [0b00010, 0b00100, 0b01000, 0b10000, 0b01000, 0b00100, 0b00010]  # <
    if gi == 61: return [0b01000, 0b00100, 0b00010, 0b00001, 0b00010, 0b00100, 0b01000]  # >
    if gi == 62: return [0b00000, 0b01110, 0b00001, 0b01111, 0b10001, 0b01111, 0b00000]  # a
    if gi == 63: return [0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b11110, 0b00000]  # b
    if gi == 64: return [0b00000, 0b01110, 0b10000, 0b10000, 0b10000, 0b01110, 0b00000]  # c
    if gi == 65: return [0b00001, 0b00001, 0b01111, 0b10001, 0b10001, 0b01111, 0b00000]  # d
    if gi == 66: return [0b00000, 0b01110, 0b10001, 0b11111, 0b10000, 0b01110, 0b00000]  # e
    if gi == 67: return [0b00110, 0b01000, 0b11110, 0b01000, 0b01000, 0b01000, 0b00000]  # f
    if gi == 68: return [0b00000, 0b01111, 0b10001, 0b01111, 0b00001, 0b01110, 0b00000]  # g
    if gi == 69: return [0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b10001, 0b00000]  # h
    if gi == 70: return [0b00100, 0b00000, 0b01100, 0b00100, 0b00100, 0b01110, 0b00000]  # i
    if gi == 71: return [0b00010, 0b00000, 0b00110, 0b00010, 0b10010, 0b01100, 0b00000]  # j
    if gi == 72: return [0b10000, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b00000]  # k
    if gi == 73: return [0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110, 0b00000]  # l
    if gi == 74: return [0b00000, 0b11010, 0b10101, 0b10101, 0b10001, 0b10001, 0b00000]  # m
    if gi == 75: return [0b00000, 0b11110, 0b10001, 0b10001, 0b10001, 0b10001, 0b00000]  # n
    if gi == 76: return [0b00000, 0b01110, 0b10001, 0b10001, 0b10001, 0b01110, 0b00000]  # o
    if gi == 77: return [0b00000, 0b11110, 0b10001, 0b11110, 0b10000, 0b10000, 0b00000]  # p
    if gi == 78: return [0b00000, 0b01111, 0b10001, 0b01111, 0b00001, 0b00001, 0b00000]  # q
    if gi == 79: return [0b00000, 0b10110, 0b11000, 0b10000, 0b10000, 0b10000, 0b00000]  # r
    if gi == 80: return [0b00000, 0b01111, 0b10000, 0b01110, 0b00001, 0b11110, 0b00000]  # s
    if gi == 81: return [0b01000, 0b11110, 0b01000, 0b01000, 0b01001, 0b00110, 0b00000]  # t
    if gi == 82: return [0b00000, 0b10001, 0b10001, 0b10001, 0b10011, 0b01101, 0b00000]  # u
    if gi == 83: return [0b00000, 0b10001, 0b10001, 0b10001, 0b01010, 0b00100, 0b00000]  # v
    if gi == 84: return [0b00000, 0b10001, 0b10001, 0b10101, 0b10101, 0b01010, 0b00000]  # w
    if gi == 85: return [0b00000, 0b10001, 0b01010, 0b00100, 0b01010, 0b10001, 0b00000]  # x
    if gi == 86: return [0b00000, 0b10001, 0b10001, 0b01111, 0b00001, 0b01110, 0b00000]  # y
    if gi == 87: return [0b00000, 0b11111, 0b00010, 0b00100, 0b01000, 0b11111, 0b00000]  # z
    [0b11111, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b11111]  # unknown -> box

fn glyph_index_for_char(ch: text) -> i32:
    val direct = FONT_CHARSET.index_of(ch)
    if direct >= 0:
        return direct
    FONT_CHARSET.index_of(ch.upper())

# integer nearest scale based on font size; 16->2, 34->4
fn glyph_scale(fs: i32) -> i32:
    var s = fs / 8
    if s < 1:
        s = 1
    s

# write `color` to a single framebuffer pixel (clipped)
fn fb_put(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= fbw or y >= fbh:
        return
    fb[y * fbw + x] = color

fn fb_clear(fb: [u32], color: u32):
    var i = 0
    val n = fb.len()
    while i < n:
        fb[i] = color
        i = i + 1

# clipped filled rectangle
fn fb_rect(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

class ClipRect:
    x0: i32
    y0: i32
    x1: i32
    y1: i32

fn clip_intersect(c: ClipRect, x0: i32, y0: i32, x1: i32, y1: i32) -> ClipRect:
    var nx0 = c.x0
    var ny0 = c.y0
    var nx1 = c.x1
    var ny1 = c.y1
    if x0 > nx0:
        nx0 = x0
    if y0 > ny0:
        ny0 = y0
    if x1 < nx1:
        nx1 = x1
    if y1 < ny1:
        ny1 = y1
    ClipRect(x0: nx0, y0: ny0, x1: nx1, y1: ny1)

fn fb_rect_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, clip: ClipRect) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

fn blend_opacity(src: u32, dst: u32, opacity_pct: i32) -> u32:
    if opacity_pct >= 100:
        return src
    if opacity_pct <= 0:
        return dst
    val sr = (((src >> 16) & 255u32) as i32)
    val sg = (((src >> 8) & 255u32) as i32)
    val sb = ((src & 255u32) as i32)
    val dr = (((dst >> 16) & 255u32) as i32)
    val dg = (((dst >> 8) & 255u32) as i32)
    val db = ((dst & 255u32) as i32)
    val inv = 100 - opacity_pct
    val r = (sr * opacity_pct + dr * inv + 50) / 100
    val g = (sg * opacity_pct + dg * inv + 50) / 100
    val b = (sb * opacity_pct + db * inv + 50) / 100
    argb(r, g, b)

fn fb_rect_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    if opacity_pct >= 100:
        return fb_rect_clip(fb, fbw, fbh, x, y, w, h, color, clip)
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            val idx = row + px
            out[idx] = blend_opacity(color, out[idx], opacity_pct)
            px = px + 1
        py = py + 1
    out

fn fb_border(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, border_w: i32, color: u32) -> [u32]:
    var out = fb
    if border_w <= 0 or color == 0u32:
        return out
    out = fb_rect(out, fbw, fbh, x, y, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y + h - border_w, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y, border_w, h, color)
    out = fb_rect(out, fbw, fbh, x + w - border_w, y, border_w, h, color)
    out

fn fb_border_sides(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, w, bt, ct)
    if bb > 0 and cb != 0u32:
        out = fb_rect(out, fbw, fbh, x, y + h - bb, w, bb, cb)
    if bl > 0 and cl != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, bl, h, cl)
    if br > 0 and cr != 0u32:
        out = fb_rect(out, fbw, fbh, x + w - br, y, br, h, cr)
    out

fn fb_border_sides_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32, clip: ClipRect) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, w, bt, ct, clip)
    if bb > 0 and cb != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y + h - bb, w, bb, cb, clip)
    if bl > 0 and cl != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, bl, h, cl, clip)
    if br > 0 and cr != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x + w - br, y, br, h, cr, clip)
    out

# draw one glyph at (x,y) scaled by `scale`
fn fb_glyph(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, scale: i32) -> [u32]:
    var out = fb
    val rows = glyph_rows(gi)
    var ry = 0
    while ry < 7:
        val bits = rows[ry]
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0:
                # fill a scale x scale block
                val bx0 = x + rx * scale
                val by0 = y + ry * scale
                var dy = 0
                while dy < scale:
                    val yy = by0 + dy
                    if yy >= 0 and yy < fbh:
                        val row = yy * fbw
                        var dx = 0
                        while dx < scale:
                            val xx = bx0 + dx
                            if xx >= 0 and xx < fbw:
                                out[row + xx] = color
                            dx = dx + 1
                    dy = dy + 1
            rx = rx + 1
        ry = ry + 1
    out

# draw a string; advances 6*scale px per char (5px glyph + 1px gap)
fn fb_text(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, color: u32, scale: i32) -> [u32]:
    var out = fb
    var i = 0
    val n = s.len()
    var cx = x
    val adv = 6 * scale
    while i < n:
        val ch = s.substring(i, i + 1)
        if cx < fbw:
            val gi = glyph_index_for_char(ch)
            if gi >= 0 and gi != 36:
                out = fb_glyph(out, fbw, fbh, cx, y, gi, color, scale)
        cx = cx + adv
        i = i + 1
    out

fn scaled_text_sparse_hit(xx: i32, yy: i32, scale: i32) -> bool:
    if scale <= 1:
        return true
    # Sparse phase chosen against the tracked Chrome text raster fixture. This
    # keeps large bitmap glyphs from over-covering until real AA compositing lands.
    ((xx + yy) % 8) == 2

fn fb_glyph_thin_scaled(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, scale: i32) -> [u32]:
    if scale <= 1:
        return fb_glyph(fb, fbw, fbh, x, y, gi, color, scale)
    var out = fb
    val rows = glyph_rows(gi)
    var ry = 0
    while ry < 7:
        val bits = rows[ry]
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0:
                val bx0 = x + rx * scale
                val by0 = y + ry * scale
                var dy = 0
                while dy < scale:
                    val yy = by0 + dy
                    if yy >= 0 and yy < fbh:
                        val row = yy * fbw
                        var dx = 0
                        while dx < scale:
                            val xx = bx0 + dx
                            if xx >= 0 and xx < fbw and scaled_text_sparse_hit(xx, yy, scale):
                                out[row + xx] = color
                            dx = dx + 1
                    dy = dy + 1
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_thin_scaled(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, color: u32, scale: i32, advance: i32) -> [u32]:
    var out = fb
    var i = 0
    val n = s.len()
    var cx = x
    while i < n:
        val ch = s.substring(i, i + 1)
        if cx < fbw:
            val gi = glyph_index_for_char(ch)
            if gi >= 0 and gi != 36:
                out = fb_glyph_thin_scaled(out, fbw, fbh, cx, y, gi, color, scale)
        cx = cx + advance
        i = i + 1
    out

fn fb_glyph_thin_scaled_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, scale: i32, clip: ClipRect) -> [u32]:
    var out = fb
    val rows = glyph_rows(gi)
    var ry = 0
    while ry < 7:
        val bits = rows[ry]
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0:
                val bx0 = x + rx * scale
                val by0 = y + ry * scale
                var dy = 0
                while dy < scale:
                    val yy = by0 + dy
                    if yy >= 0 and yy < fbh and yy >= clip.y0 and yy < clip.y1:
                        val row = yy * fbw
                        var dx = 0
                        while dx < scale:
                            val xx = bx0 + dx
                            if xx >= 0 and xx < fbw and xx >= clip.x0 and xx < clip.x1:
                                if scaled_text_sparse_hit(xx, yy, scale):
                                    out[row + xx] = color
                            dx = dx + 1
                    dy = dy + 1
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_thin_scaled_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, color: u32, scale: i32, advance: i32, clip: ClipRect) -> [u32]:
    var out = fb
    var i = 0
    val n = s.len()
    var cx = x
    while i < n:
        val ch = s.substring(i, i + 1)
        if cx < fbw and cx < clip.x1:
            val gi = glyph_index_for_char(ch)
            if gi >= 0 and gi != 36:
                out = fb_glyph_thin_scaled_clip(out, fbw, fbh, cx, y, gi, color, scale, clip)
        cx = cx + advance
        i = i + 1
    out

fn fb_glyph_sparse(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32) -> [u32]:
    var out = fb
    val rows = glyph_rows(gi)
    var ry = 0
    while ry < 7:
        val bits = rows[ry]
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0 and ((rx + ry) % 2) == 0:
                val xx = x + rx
                val yy = y + ry
                if xx >= 0 and xx < fbw and yy >= 0 and yy < fbh:
                    out[yy * fbw + xx] = color
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_sparse(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, color: u32) -> [u32]:
    var out = fb
    var i = 0
    var cx = x
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if cx < fbw:
            val gi = glyph_index_for_char(ch)
            if gi >= 0 and gi != 36:
                out = fb_glyph_sparse(out, fbw, fbh, cx, y, gi, color)
        cx = cx + 6
        i = i + 1
    out

fn fb_px(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32) -> [u32]:
    var out = fb
    if x >= 0 and x < fbw and y >= 0 and y < fbh:
        out[y * fbw + x] = color
    out

