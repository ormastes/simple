    if st.line_height_px > 0:
        return st.line_height_px
    if st.line_height_px < 0:
        # negative sentinel = unitless line-height multiplier * 10 (e.g. 1.6 -> -16),
        # resolved here against the element's final font-size.
        val lh = st.font_size * (0 - st.line_height_px) / 10
        if lh > 0:
