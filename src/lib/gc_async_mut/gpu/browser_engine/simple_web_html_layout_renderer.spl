# simple_web_html_layout_renderer.spl — a small but REAL HTML renderer in pure
# Simple, ported from examples/06_io/ui/mini_html_render.spl for the production web
# rendering path.
#
# Parses HTML into a flat node arena (avoiding the interpreter's nested-field
# push bug), applies inline + <style>-block CSS, does block-flow layout with
# word-wrapped text, and paints boxes + text into a staging [u32] framebuffer
# using a tiny 5x7 bitmap font. The final frame is presented through Engine2D
# so generic Simple Web rendering shares the same backend interface as GUI/WM
# surfaces while preserving this renderer's pixel-exact text and CSS fixtures.
#
# Two interpreter bugs are worked around here (both worth a seed fix):
#   * text.index_of(needle, pos) IGNORES pos -> use find_from() (substring+find).
#   * obj.field.push() on an array element does not persist -> use a flat arena
#     of nodes keyed by integer parent index; only ever append to the top array.
#
# Public entry: simple_web_layout_render_html_pixels(html, w, h, backend_name)
#   parse -> CSS cascade -> block layout -> paint text+boxes -> Engine2D -> [u32]

use std.gpu.engine2d.engine.{Engine2D}

# ---------------------------------------------------------------------------
# Flat node arena
# ---------------------------------------------------------------------------

class HNode:
    tag: text          # lowercased tag, "#text", or "#root"
    text_data: text    # text for #text nodes
    style_attr: text   # raw style="" value
    class_attr: text
    id_attr: text
    attrs_raw: text    # raw tag inner text for attribute selectors
    parent: i64        # index of parent in the arena (-1 for root)

fn mk_node(tag: text, parent: i64) -> HNode:
    HNode(tag: tag, text_data: "", style_attr: "", class_attr: "", id_attr: "", attrs_raw: "", parent: parent)

# ---------------------------------------------------------------------------
# Position-aware string find (works around index_of(needle,pos) ignoring pos)
# ---------------------------------------------------------------------------

fn find_from(s: text, needle: text, pos: i32) -> i32:
    if pos <= 0:
        return s.index_of(needle)
    if pos >= s.len():
        return -1
    val sub = s.substring(pos, s.len())
    val rel = sub.index_of(needle)
    if rel < 0:
        return -1
    pos + rel

fn is_void(tag: text) -> bool:
    tag == "meta" or tag == "br" or tag == "img" or tag == "input" or tag == "link" or tag == "hr" or tag == "area" or tag == "base" or tag == "col" or tag == "embed" or tag == "source" or tag == "track" or tag == "wbr"

# ---------------------------------------------------------------------------
# Attribute extraction (reads class/id/style out of the raw tag inner text)
# ---------------------------------------------------------------------------

fn attr_value(inner: text, name: text) -> text:
    # find name= and read the quoted value; simple, tolerant
    val key = name + "="
    val kpos = inner.index_of(key)
    if kpos < 0:
        return ""
    var i = kpos + key.len()
    if i >= inner.len():
        return ""
    val q = inner.substring(i, i + 1)
    if q == "\"" or q == "'":
        val sub = inner.substring(i + 1, inner.len())
        val end = sub.index_of(q)
        if end < 0:
            return ""
        return sub.substring(0, end)
    # unquoted: read to whitespace
    val sub = inner.substring(i, inner.len())
    var j = 0
    while j < sub.len():
        val c = sub.substring(j, j + 1)
        if c == " " or c == "\t" or c == "\n" or c == "\r" or c == "/":
            break
        j = j + 1
    sub.substring(0, j)

fn tag_name_of(inner: text) -> text:
    var j = 0
    val m = inner.len()
    while j < m:
        val c = inner.substring(j, j + 1)
        if c == " " or c == "\t" or c == "\n" or c == "\r" or c == "/":
            break
        j = j + 1
    val nm = inner.substring(0, j)
    nm.lower()

# ---------------------------------------------------------------------------
# Parser -> arena
# ---------------------------------------------------------------------------

fn parse_html(html: text) -> [HNode]:
    var nodes: [HNode] = []
    nodes.push(mk_node("#root", -1))
    var pstack: [i64] = [0]
    var pos = 0
    val n = html.len()
    while pos < n:
        val lt = find_from(html, "<", pos)
        if lt < 0:
            val tail = html.substring(pos, n)
            if tail.trim().len() > 0:
                var tn = mk_node("#text", pstack[pstack.len() - 1])
                tn.text_data = tail
                nodes.push(tn)
            break
        if lt > pos:
            val txt = html.substring(pos, lt)
            if txt.trim().len() > 0:
                var tn = mk_node("#text", pstack[pstack.len() - 1])
                tn.text_data = txt
                nodes.push(tn)
        # comment?
        val c4 = if lt + 4 <= n: html.substring(lt, lt + 4) else: ""
        if c4 == "<!--":
            val cend = find_from(html, "-->", lt)
            if cend < 0:
                break
            pos = cend + 3
            continue
        val gt = find_from(html, ">", lt)
        if gt < 0:
            break
        val inner = html.substring(lt + 1, gt)
        pos = gt + 1
        if inner.len() == 0:
            continue
        val first = inner.substring(0, 1)
        if first == "!":
            continue
        if first == "/":
            val cname = inner.substring(1, inner.len()).trim().lower()
            var k = pstack.len() - 1
            var found = -1
            while k >= 1:
                val pidx = pstack[k]
                if nodes[pidx].tag == cname:
                    found = k
                    break
                k = k - 1
            if found >= 1:
                while pstack.len() > found:
                    pstack.pop()
            continue
        val name = tag_name_of(inner)
        var node = mk_node(name, pstack[pstack.len() - 1])
        node.class_attr = attr_value(inner, "class")
        node.id_attr = attr_value(inner, "id")
        node.style_attr = attr_value(inner, "style")
        node.attrs_raw = inner
        nodes.push(node)
        val self_close = inner.substring(inner.len() - 1, inner.len()) == "/"
        if name == "style":
            val sclose = find_from(html, "</style", pos)
            if sclose >= 0:
                val sgt = find_from(html, ">", sclose)
                pos = if sgt >= 0: sgt + 1 else: sclose
            continue
        if name == "script":
            val cclose = find_from(html, "</script", pos)
            if cclose >= 0:
                val cgt = find_from(html, ">", cclose)
                pos = if cgt >= 0: cgt + 1 else: cclose
            continue
        if not is_void(name) and not self_close:
            pstack.push(nodes.len() - 1)
    nodes

# ---------------------------------------------------------------------------
# Minimal CSS color parsing (#rgb, #rrggbb, rgb()/rgba(), a few names)
# ---------------------------------------------------------------------------

fn hex_val(c: text) -> i32:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    val l = c.lower()
    if l == "a": return 10
    if l == "b": return 11
    if l == "c": return 12
    if l == "d": return 13
    if l == "e": return 14
    if l == "f": return 15
    0

fn argb(r: i32, g: i32, b: i32) -> u32:
    0xFF000000u32 | ((r.to_u32()) << 16) | ((g.to_u32()) << 8) | b.to_u32()

# returns packed u32, or 0 for "none/transparent/empty"
fn parse_color(raw: text) -> u32:
    val s = raw.trim().lower()
    if s.len() == 0 or s == "transparent" or s == "none" or s == "inherit":
        return 0u32
    if s == "white": return argb(255, 255, 255)
    if s == "black": return argb(0, 0, 0)
    if s == "red": return argb(220, 50, 50)
    if s.substring(0, 1) == "#":
        val h = s.substring(1, s.len())
        if h.len() >= 6:
            val r = hex_val(h.substring(0, 1)) * 16 + hex_val(h.substring(1, 2))
            val g = hex_val(h.substring(2, 3)) * 16 + hex_val(h.substring(3, 4))
            val b = hex_val(h.substring(4, 5)) * 16 + hex_val(h.substring(5, 6))
            return argb(r, g, b)
        if h.len() >= 3:
            val r = hex_val(h.substring(0, 1)) * 17
            val g = hex_val(h.substring(1, 2)) * 17
            val b = hex_val(h.substring(2, 3)) * 17
            return argb(r, g, b)
        return 0u32
    if s.substring(0, 3) == "rgb":
        val lp = s.index_of("(")
        val rp = s.index_of(")")
        if lp >= 0 and rp > lp:
            val inside = s.substring(lp + 1, rp)
            val parts = inside.split(",")
            if parts.len() >= 3:
                return argb(parse_int(parts[0]), parse_int(parts[1]), parse_int(parts[2]))
    0u32

fn parse_color_any(raw: text) -> u32:
    val direct = parse_color(raw)
    if direct != 0u32:
        return direct
    val lower = raw.lower()
    val rgb = lower.index_of("rgb")
    if rgb >= 0:
        val rtail = raw.substring(rgb, raw.len())
        val rp = rtail.index_of(")")
        if rp >= 0:
            val cv = parse_color(rtail.substring(0, rp + 1))
            if cv != 0u32:
                return cv
    val hash = raw.index_of("#")
    if hash >= 0:
        return parse_color(raw.substring(hash, raw.len()))
    0u32

fn parse_int(s: text) -> i32:
    val t = s.trim()
    var i = 0
    var v = 0
    var any = false
    while i < t.len():
        val c = t.substring(i, i + 1)
        if c >= "0" and c <= "9":
            v = v * 10 + hex_val(c)
            any = true
        else:
            if any:
                break
        i = i + 1
    v

fn parse_nth_int(s: text, target: i32) -> i32:
    var i = 0
    var seen = 0
    while i < s.len():
        val c = s.substring(i, i + 1)
        if c >= "0" and c <= "9":
            var v = 0
            while i < s.len():
                val d = s.substring(i, i + 1)
                if d < "0" or d > "9":
                    break
                v = v * 10 + hex_val(d)
                i = i + 1
            if seen == target:
                return v
            seen = seen + 1
        else:
            i = i + 1
    -1

fn parse_opacity_pct(raw: text) -> i32:
    val t = raw.trim()
    if t.len() == 0:
        return 100
    if t == "0":
        return 0
    if t == "1":
        return 100
    val dot = t.index_of(".")
    if dot >= 0:
        var frac = 0
        var scale = 1
        var i = dot + 1
        while i < t.len() and scale < 100:
            val d = t.substring(i, i + 1)
            if d < "0" or d > "9":
                break
            frac = frac * 10 + hex_val(d)
            scale = scale * 10
            i = i + 1
        return (frac * 100 + scale / 2) / scale
    val pct = parse_int(t)
    if pct < 0:
        return 0
    if pct > 100:
        return 100
    pct

# read a property value from a declaration block "a: b; c: d"
fn decl_get(decls: text, prop: text) -> text:
    var pos = 0
    var found = ""
    while pos < decls.len():
        val tail = decls.substring(pos, decls.len())
        val semi = tail.index_of(";")
        val raw = if semi >= 0: tail.substring(0, semi) else: tail
        val colon = raw.index_of(":")
        if colon >= 0:
            val name = raw.substring(0, colon).trim().lower()
            if name == prop:
                found = raw.substring(colon + 1, raw.len()).trim()
        if semi < 0:
            break
        pos = pos + semi + 1
    found

fn decl_last_pos(decls: text, prop: text) -> i32:
    var pos = 0
    var found = -1
    while pos < decls.len():
        val tail = decls.substring(pos, decls.len())
        val semi = tail.index_of(";")
        val raw = if semi >= 0: tail.substring(0, semi) else: tail
        val colon = raw.index_of(":")
        if colon >= 0:
            val name = raw.substring(0, colon).trim().lower()
            if name == prop:
                found = pos
        if semi < 0:
            break
        pos = pos + semi + 1
    found

# ---------------------------------------------------------------------------
# Computed style
# ---------------------------------------------------------------------------

class Style:
    bg: u32
    fg: u32
    font_size: i32
    line_height_px: i32
    width_px: i32
    height_px: i32
    border_box: bool
    min_height_px: i32
    min_height_vh: bool
    flex_fill: bool
    pad_l: i32
    pad_t: i32
    pad_r: i32
    pad_b: i32
    border_w: i32
    border_color: u32
    border_l: i32
    border_t: i32
    border_r: i32
    border_b: i32
    border_color_l: u32
    border_color_t: u32
    border_color_r: u32
    border_color_b: u32
    gap_px: i32
    margin_l: i32
    margin_t: i32
    margin_r: i32
    margin_b: i32
    display: text       # block / inline / contents / none
    overflow_hidden: bool
    visibility_hidden: bool
    position_relative: bool
    position_absolute: bool
    left_px: i32
    top_px: i32
    right_px: i32
    bottom_px: i32
    z_index: i32
    opacity_pct: i32
    flex_direction: text
    text_align: text
    bold: bool

fn default_style() -> Style:
    Style(bg: 0u32, fg: argb(20, 20, 24), font_size: 16, line_height_px: 0, width_px: 0, height_px: 0, border_box: false, min_height_px: 0, min_height_vh: false, flex_fill: false, pad_l: 0, pad_t: 0, pad_r: 0, pad_b: 0, border_w: 0, border_color: 0u32, border_l: 0, border_t: 0, border_r: 0, border_b: 0, border_color_l: 0u32, border_color_t: 0u32, border_color_r: 0u32, border_color_b: 0u32, gap_px: 0, margin_l: 0, margin_t: 0, margin_r: 0, margin_b: 0, display: "block", overflow_hidden: false, visibility_hidden: false, position_relative: false, position_absolute: false, left_px: 0, top_px: 0, right_px: -1, bottom_px: -1, z_index: 0, opacity_pct: 100, flex_direction: "row", text_align: "left", bold: false)

fn inherit_style(p: Style) -> Style:
    val display = if p.display == "none": "none" else: "block"
    Style(bg: 0u32, fg: p.fg, font_size: p.font_size, line_height_px: p.line_height_px, width_px: 0, height_px: 0, border_box: false, min_height_px: 0, min_height_vh: false, flex_fill: false, pad_l: 0, pad_t: 0, pad_r: 0, pad_b: 0, border_w: 0, border_color: 0u32, border_l: 0, border_t: 0, border_r: 0, border_b: 0, border_color_l: 0u32, border_color_t: 0u32, border_color_r: 0u32, border_color_b: 0u32, gap_px: 0, margin_l: 0, margin_t: 0, margin_r: 0, margin_b: 0, display: display, overflow_hidden: false, visibility_hidden: p.visibility_hidden, position_relative: false, position_absolute: false, left_px: 0, top_px: 0, right_px: -1, bottom_px: -1, z_index: 0, opacity_pct: 100, flex_direction: "row", text_align: p.text_align, bold: p.bold)

fn is_inline_tag(tag: text) -> bool:
    tag == "a" or tag == "span" or tag == "b" or tag == "strong" or tag == "em" or tag == "i" or tag == "small" or tag == "code" or tag == "#text"

fn is_heading(tag: text) -> bool:
    tag == "h1" or tag == "h2" or tag == "h3" or tag == "h4" or tag == "h5" or tag == "h6"

fn is_non_rendered_tag(tag: text) -> bool:
    tag == "head" or tag == "title" or tag == "meta" or tag == "style" or tag == "script" or tag == "link"

# apply a declaration block onto a style
fn apply_decls(st: Style, decls: text) -> Style:
    if decls.len() == 0:
        return st
    var bg_v = st.bg
    var fg_v = st.fg
    var font_size_v = st.font_size
    var line_height_v = st.line_height_px
    var width_v = st.width_px
    var height_v = st.height_px
    var border_box_v = st.border_box
    var min_height_v = st.min_height_px
    var min_height_vh_v = st.min_height_vh
    var flex_fill_v = st.flex_fill
    var pad_l_v = st.pad_l
    var pad_t_v = st.pad_t
    var pad_r_v = st.pad_r
    var pad_b_v = st.pad_b
    var border_w_v = st.border_w
    var border_color_v = st.border_color
    var border_l_v = st.border_l
    var border_t_v = st.border_t
    var border_r_v = st.border_r
    var border_b_v = st.border_b
    var border_color_l_v = st.border_color_l
    var border_color_t_v = st.border_color_t
    var border_color_r_v = st.border_color_r
    var border_color_b_v = st.border_color_b
    var gap_v = st.gap_px
    var margin_l_v = st.margin_l
    var margin_t_v = st.margin_t
    var margin_r_v = st.margin_r
    var margin_b_v = st.margin_b
    var display_v = st.display
    var overflow_hidden_v = st.overflow_hidden
    var visibility_hidden_v = st.visibility_hidden
    var position_relative_v = st.position_relative
    var position_absolute_v = st.position_absolute
    var left_px_v = st.left_px
    var top_px_v = st.top_px
    var right_px_v = st.right_px
    var bottom_px_v = st.bottom_px
    var z_index_v = st.z_index
    var opacity_pct_v = st.opacity_pct
    var flex_direction_v = st.flex_direction
    var text_align_v = st.text_align
    var bold_v = st.bold
    val bg = decl_get(decls, "background-color")
    val bgs = decl_get(decls, "background")
    val bg_pos = decl_last_pos(decls, "background-color")
    val bgs_pos = decl_last_pos(decls, "background")
    if bg_pos >= 0 or bgs_pos >= 0:
        if bgs_pos > bg_pos:
            bg_v = parse_color_any(bgs)
        else:
            bg_v = parse_color(bg)
    val col = decl_get(decls, "color")
    if col.len() > 0:
        val cv = parse_color(col)
        if cv != 0u32:
            fg_v = cv
    val fs = decl_get(decls, "font-size")
    if fs.len() > 0:
        val v = parse_int(fs)
        if v > 0:
            font_size_v = v
    val line_height = decl_get(decls, "line-height")
    if line_height.len() > 0:
        val lh = parse_int(line_height)
        if lh > 0:
            line_height_v = lh
    val width = decl_get(decls, "width")
    if width.len() > 0:
        width_v = parse_int(width)
    val height = decl_get(decls, "height")
    if height.len() > 0:
        height_v = parse_int(height)
    val box_sizing = decl_get(decls, "box-sizing")
    if box_sizing.len() > 0:
        border_box_v = box_sizing == "border-box"
    val min_height = decl_get(decls, "min-height")
    if min_height.len() > 0:
        if min_height.contains("vh"):
            min_height_vh_v = true
        else:
            min_height_v = parse_int(min_height)
    val flex = decl_get(decls, "flex")
    if flex.len() > 0 and parse_int(flex) > 0:
        flex_fill_v = true
    val display_decl = decl_get(decls, "display")
    if display_decl.len() > 0:
        if display_decl == "none":
            display_v = "none"
        elif display_decl == "inline":
            display_v = "inline"
        elif display_decl == "flex":
            display_v = "flex"
        elif display_decl == "contents":
            display_v = "contents"
        else:
            display_v = "block"
    val overflow_decl = decl_get(decls, "overflow")
    if overflow_decl.len() > 0:
        overflow_hidden_v = overflow_decl == "hidden"
    val overflow_x_decl = decl_get(decls, "overflow-x")
    if overflow_x_decl.len() > 0:
        if overflow_x_decl == "hidden":
            overflow_hidden_v = true
    val overflow_y_decl = decl_get(decls, "overflow-y")
    if overflow_y_decl.len() > 0:
        if overflow_y_decl == "hidden":
            overflow_hidden_v = true
    val visibility_decl = decl_get(decls, "visibility")
    if visibility_decl.len() > 0:
        if visibility_decl == "hidden":
            visibility_hidden_v = true
        elif visibility_decl == "visible":
            visibility_hidden_v = false
    val position_decl = decl_get(decls, "position")
    if position_decl.len() > 0:
        if position_decl == "relative":
            position_relative_v = true
            position_absolute_v = false
        elif position_decl == "absolute":
            position_relative_v = false
            position_absolute_v = true
        else:
            position_relative_v = false
            position_absolute_v = false
    val left_decl = decl_get(decls, "left")
    if left_decl.len() > 0:
        left_px_v = parse_int(left_decl)
    val top_decl = decl_get(decls, "top")
    if top_decl.len() > 0:
        top_px_v = parse_int(top_decl)
    val right_decl = decl_get(decls, "right")
    if right_decl.len() > 0:
        right_px_v = parse_int(right_decl)
    val bottom_decl = decl_get(decls, "bottom")
    if bottom_decl.len() > 0:
        bottom_px_v = parse_int(bottom_decl)
    val z_index_decl = decl_get(decls, "z-index")
    if z_index_decl.len() > 0:
        z_index_v = parse_int(z_index_decl)
    val opacity_decl = decl_get(decls, "opacity")
    if opacity_decl.len() > 0:
        opacity_pct_v = parse_opacity_pct(opacity_decl)
    val flex_direction_decl = decl_get(decls, "flex-direction")
    if flex_direction_decl.len() > 0:
        if flex_direction_decl == "column":
            flex_direction_v = "column"
        else:
            flex_direction_v = "row"
    val ta = decl_get(decls, "text-align")
    if ta.len() > 0:
        text_align_v = ta
    val fw = decl_get(decls, "font-weight")
    if fw.len() > 0:
        if fw == "bold" or fw == "700" or fw == "600" or fw == "800":
            bold_v = true
    val pad = decl_get(decls, "padding")
    if pad.len() > 0:
        val p0 = parse_nth_int(pad, 0)
        val p1 = parse_nth_int(pad, 1)
        val p2 = parse_nth_int(pad, 2)
        val p3 = parse_nth_int(pad, 3)
        if p0 >= 0:
            pad_t_v = p0
            pad_r_v = p0
            pad_b_v = p0
            pad_l_v = p0
            if p1 >= 0:
                pad_r_v = p1
                pad_l_v = p1
            if p2 >= 0:
                pad_b_v = p2
            if p3 >= 0:
                pad_l_v = p3
    val pl = decl_get(decls, "padding-left")
    if pl.len() > 0:
        pad_l_v = parse_int(pl)
    val pt = decl_get(decls, "padding-top")
    if pt.len() > 0:
        pad_t_v = parse_int(pt)
    val pr = decl_get(decls, "padding-right")
    if pr.len() > 0:
        pad_r_v = parse_int(pr)
    val pb = decl_get(decls, "padding-bottom")
    if pb.len() > 0:
        pad_b_v = parse_int(pb)
    val gap = decl_get(decls, "gap")
    if gap.len() > 0:
        val gv = parse_int(gap)
        if gv > 0:
            gap_v = gv
    val border = decl_get(decls, "border")
    if border.len() > 0:
        val bw = parse_int(border)
        if bw > 0:
            border_w_v = bw
            border_l_v = bw
            border_t_v = bw
            border_r_v = bw
            border_b_v = bw
        val bc = parse_color_any(border)
        if bc != 0u32:
            border_color_v = bc
            border_color_l_v = bc
            border_color_t_v = bc
            border_color_r_v = bc
            border_color_b_v = bc
    val border_width = decl_get(decls, "border-width")
    if border_width.len() > 0:
        val bw0 = parse_nth_int(border_width, 0)
        val bw1 = parse_nth_int(border_width, 1)
        val bw2 = parse_nth_int(border_width, 2)
        val bw3 = parse_nth_int(border_width, 3)
        if bw0 >= 0:
            border_w_v = bw0
            border_t_v = bw0
            border_r_v = bw0
            border_b_v = bw0
            border_l_v = bw0
            if bw1 >= 0:
                border_r_v = bw1
                border_l_v = bw1
            if bw2 >= 0:
                border_b_v = bw2
            if bw3 >= 0:
                border_l_v = bw3
    val border_color = decl_get(decls, "border-color")
    if border_color.len() > 0:
        val bcv = parse_color_any(border_color)
        if bcv != 0u32:
            border_color_v = bcv
            border_color_l_v = bcv
            border_color_t_v = bcv
            border_color_r_v = bcv
            border_color_b_v = bcv
    val border_left = decl_get(decls, "border-left")
    if border_left.len() > 0:
        val blw = parse_int(border_left)
        if blw >= 0:
            border_l_v = blw
        val blc = parse_color_any(border_left)
        if blc != 0u32:
            border_color_l_v = blc
    val border_top = decl_get(decls, "border-top")
    if border_top.len() > 0:
        val btw = parse_int(border_top)
        if btw >= 0:
            border_t_v = btw
        val btc = parse_color_any(border_top)
        if btc != 0u32:
            border_color_t_v = btc
    val border_right = decl_get(decls, "border-right")
    if border_right.len() > 0:
        val brw = parse_int(border_right)
        if brw >= 0:
            border_r_v = brw
        val brc = parse_color_any(border_right)
        if brc != 0u32:
            border_color_r_v = brc
    val border_bottom = decl_get(decls, "border-bottom")
    if border_bottom.len() > 0:
        val bbw = parse_int(border_bottom)
        if bbw >= 0:
            border_b_v = bbw
        val bbc = parse_color_any(border_bottom)
        if bbc != 0u32:
            border_color_b_v = bbc
    val border_left_width = decl_get(decls, "border-left-width")
    if border_left_width.len() > 0:
        border_l_v = parse_int(border_left_width)
    val border_top_width = decl_get(decls, "border-top-width")
    if border_top_width.len() > 0:
        border_t_v = parse_int(border_top_width)
    val border_right_width = decl_get(decls, "border-right-width")
    if border_right_width.len() > 0:
        border_r_v = parse_int(border_right_width)
    val border_bottom_width = decl_get(decls, "border-bottom-width")
    if border_bottom_width.len() > 0:
        border_b_v = parse_int(border_bottom_width)
    val border_left_color = decl_get(decls, "border-left-color")
    if border_left_color.len() > 0:
        val blcv = parse_color_any(border_left_color)
        if blcv != 0u32:
            border_color_l_v = blcv
    val border_top_color = decl_get(decls, "border-top-color")
    if border_top_color.len() > 0:
        val btcv = parse_color_any(border_top_color)
        if btcv != 0u32:
            border_color_t_v = btcv
    val border_right_color = decl_get(decls, "border-right-color")
    if border_right_color.len() > 0:
        val brcv = parse_color_any(border_right_color)
        if brcv != 0u32:
            border_color_r_v = brcv
    val border_bottom_color = decl_get(decls, "border-bottom-color")
    if border_bottom_color.len() > 0:
        val bbcv = parse_color_any(border_bottom_color)
        if bbcv != 0u32:
            border_color_b_v = bbcv
    val margin = decl_get(decls, "margin")
    if margin.len() > 0:
        val m0 = parse_nth_int(margin, 0)
        val m1 = parse_nth_int(margin, 1)
        val m2 = parse_nth_int(margin, 2)
        val m3 = parse_nth_int(margin, 3)
        if m0 >= 0:
            margin_t_v = m0
            margin_r_v = m0
            margin_b_v = m0
            margin_l_v = m0
            if m1 >= 0:
                margin_r_v = m1
                margin_l_v = m1
            if m2 >= 0:
                margin_b_v = m2
            if m3 >= 0:
