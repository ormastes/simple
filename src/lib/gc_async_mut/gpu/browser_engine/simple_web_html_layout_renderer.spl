    if display_v == "contents":
        bg_v = 0u32
        width_v = 0
        height_v = 0
        pad_l_v = 0
        pad_t_v = 0
        pad_r_v = 0
        pad_b_v = 0
        border_w_v = 0
        border_l_v = 0
        border_t_v = 0
        border_r_v = 0
        border_b_v = 0
        border_color_v = 0u32
        border_color_l_v = 0u32
        border_color_t_v = 0u32
        border_color_r_v = 0u32
        border_color_b_v = 0u32
