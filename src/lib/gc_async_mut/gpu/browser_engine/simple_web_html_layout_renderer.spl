class LayoutResult:
    bx: [i32]
    by: [i32]
    bw: [i32]
    bh: [i32]
    height: i32

class ChildLinks:
    first_child: [i32]
    next_sibling: [i32]

fn build_child_links(nodes: [HNode]) -> ChildLinks:
    var first_child: [i32] = [-1; nodes.len()]
    var next_sibling: [i32] = [-1; nodes.len()]
    var last_child: [i32] = [-1; nodes.len()]
    var i = 1
    while i < nodes.len():
        val parent = nodes[i].parent as i32
        if parent >= 0 and parent < nodes.len():
            val last = last_child[parent]
            if last < 0:
                first_child[parent] = i
            else:
                next_sibling[last] = i
            last_child[parent] = i
        i = i + 1
    ChildLinks(first_child: first_child, next_sibling: next_sibling)

fn char_w(fs: i32) -> i32:
    if fs <= 8:
        return 4
    6 * glyph_scale(fs)

fn text_advance(fs: i32) -> i32:
    if fs <= 8:
        return 4
    5 * glyph_scale(fs)

fn line_h(fs: i32) -> i32:
    9 * glyph_scale(fs)

fn style_line_h(st: Style) -> i32:
    if st.line_height_px > 0:
        return st.line_height_px
    if st.line_height_px < 0:
        # negative sentinel = unitless line-height multiplier * 10 (e.g. 1.6 -> -16),
        # resolved here against the element's final font-size.
        val lh = st.font_size * (0 - st.line_height_px) / 10
        if lh > 0:
            return lh
    line_h(st.font_size)

fn text_ink_y_offset(fs: i32) -> i32:
    val scale = glyph_scale(fs)
    if scale > 1:
        return scale + 1
    1

fn text_ink_x_offset(fs: i32) -> i32:
    1

fn wrap_line_end(txt: text, off: i32, cpl: i32) -> i32:
    val n = txt.len()
    var limit = off + cpl
    if limit >= n:
        return n
    var last_space = -1
    var i = off
    while i < limit:
        if txt.char_code_at(i) == 32:
            last_space = i
        i = i + 1
    if last_space > off:
        return last_space
    limit

fn skip_wrap_spaces(txt: text, off: i32) -> i32:
    var out = off
    val n = txt.len()
    while out < n and txt.char_code_at(out) == 32:
        out = out + 1
    out

fn wrapped_line_count(txt: text, cpl: i32) -> i32:
    if txt.len() == 0:
        return 1
    var lines = 0
    var off = 0
    while off < txt.len():
        val endc = wrap_line_end(txt, off, cpl)
        lines = lines + 1
        off = skip_wrap_spaces(txt, endc)
    if lines < 1:
        lines = 1
    lines

fn absolute_outer_width(node: HNode, st: Style, containing_w: i32) -> i32:
    val border_x = st.border_l + st.border_r
    val legacy_widget_box = class_contains(node.class_attr, "widget-") or class_contains(node.class_attr, "icon-image")
    val explicit_node_w = if legacy_widget_box or st.border_box: st.width_px else: st.width_px + st.pad_l + st.pad_r + border_x
    if st.width_px > 0:
        return explicit_node_w
    containing_w

fn absolute_outer_height(st: Style) -> i32:
    val border_y = st.border_t + st.border_b
    if st.height_px > 0:
        if st.border_box:
            return st.height_px
        return st.height_px + st.pad_t + st.pad_b + border_y
    style_line_h(st)

fn absolute_child_x(parent_x: i32, parent: Style, child_node: HNode, child: Style, containing_w: i32) -> i32:
    if child.right_px >= 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        return parent_x + parent.border_l + padding_box_w - absolute_outer_width(child_node, child, containing_w) - child.right_px
    parent_x + parent.border_l + child.left_px

fn absolute_child_y(parent_y: i32, parent: Style, child: Style) -> i32:
    if child.bottom_px >= 0:
        val padding_box_h = parent.height_px + parent.pad_t + parent.pad_b
        return parent_y + parent.border_t + padding_box_h - absolute_outer_height(child) - child.bottom_px
    parent_y + parent.border_t + child.top_px

fn layout(nodes: [HNode], styles: [Style], links: ChildLinks, i: i32, x: i32, y: i32, w: i32, viewport_h: i32, bx: [i32], by: [i32], bw: [i32], bh: [i32]) -> LayoutResult:
    var out_bx = bx
    var out_by = by
    var out_bw = bw
    var out_bh = bh
    out_bx[i] = x
    out_by[i] = y
    val st = styles[i]
    val legacy_widget_box = class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image")
    if st.display == "none":
        out_bw[i] = 0
        out_bh[i] = 0
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: 0)
    if st.display == "contents":
        out_bw[i] = w
        var cy_contents = y
        var c_contents = links.first_child[i]
        var child_count_contents = 0
        while c_contents >= 0:
            val cst = styles[c_contents]
            if child_count_contents > 0:
                cy_contents = cy_contents + st.gap_px
            cy_contents = cy_contents + cst.margin_t
            var child_w_contents = w - cst.margin_l - cst.margin_r
            if child_w_contents < 1:
                child_w_contents = 1
            val child = layout(nodes, styles, links, c_contents, x + cst.margin_l, cy_contents, child_w_contents, viewport_h, out_bx, out_by, out_bw, out_bh)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
            cy_contents = cy_contents + child.height + cst.margin_b
            child_count_contents = child_count_contents + 1
            c_contents = links.next_sibling[c_contents]
        val h_contents = cy_contents - y
        out_bh[i] = h_contents
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h_contents)
    val border_x = st.border_l + st.border_r
    val border_y = st.border_t + st.border_b
    val explicit_node_w = if legacy_widget_box or st.border_box: st.width_px else: st.width_px + st.pad_l + st.pad_r + border_x
    # width_px > 0: explicit px. width_px < 0: percentage of available width
    # (negative sentinel from apply_decls). width_px == 0: fill available width.
    var node_w = if st.width_px > 0: explicit_node_w else: w
    if st.width_px < 0:
        node_w = w * (0 - st.width_px) / 100
        if node_w > w:
            node_w = w
        if node_w < 1:
            node_w = 1
    out_bw[i] = node_w
    if nodes[i].tag == "#text":
        val txt = nodes[i].text_data.trim()
        val cw = char_w(st.font_size)
        var cpl = node_w / cw
        if cpl < 1:
            cpl = 1
        val lines = wrapped_line_count(txt, cpl)
        val h = lines * style_line_h(st)
        out_bh[i] = h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)
    if nodes[i].tag == "img" or nodes[i].tag == "input":
        val h = if st.height_px > 0: st.height_px else: style_line_h(st)
        out_bh[i] = h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)
    val ix = x + st.border_l + st.pad_l
    var iw = node_w - st.pad_l - st.pad_r - border_x
    if iw < 1:
        iw = 1
    if st.display == "flex" and st.flex_direction != "column":
        # Pre-pass: distribute the inner width across flex children. Children with an
        # explicit width (px or %) take it; the leftover space is shared equally among
        # auto-width (flex-grow) children so a sibling is not starved to a sliver.
        # Explicit-width children behave exactly as before (layout uses width_px).
        var sum_explicit = 0
        var auto_count = 0
        var nonabs_count = 0
        var ps = links.first_child[i]
        while ps >= 0:
            val pcst = styles[ps]
            if not pcst.position_absolute:
                nonabs_count = nonabs_count + 1
                var cw = 0
                if pcst.width_px > 0:
                    cw = if class_contains(nodes[ps].class_attr, "widget-") or class_contains(nodes[ps].class_attr, "icon-image") or pcst.border_box: pcst.width_px else: pcst.width_px + pcst.pad_l + pcst.pad_r + pcst.border_l + pcst.border_r
                elif pcst.width_px < 0:
                    cw = iw * (0 - pcst.width_px) / 100
                if cw > 0:
                    sum_explicit = sum_explicit + cw
                else:
                    auto_count = auto_count + 1
                sum_explicit = sum_explicit + pcst.margin_l + pcst.margin_r
            ps = links.next_sibling[ps]
        var gaps_total = 0
        if nonabs_count > 1:
            gaps_total = st.gap_px * (nonabs_count - 1)
        var per_auto = iw
        if auto_count > 0:
            var avail = iw - sum_explicit - gaps_total
            if avail < auto_count:
                avail = auto_count
            per_auto = avail / auto_count
        var cx = ix
        var max_child_h = 0
        var fc = links.first_child[i]
        var flex_child_count = 0
        while fc >= 0:
            val cst = styles[fc]
            if cst.position_absolute:
                val ax = absolute_child_x(x, st, nodes[fc], cst, iw)
                val ay = absolute_child_y(y, st, cst)
                val child = layout(nodes, styles, links, fc, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
            else:
                if flex_child_count > 0:
                    cx = cx + st.gap_px
                cx = cx + cst.margin_l
                # auto-width child gets its fair share; %-width resolves against the
                # container inner width; px-width children ignore this (use width_px).
                var remaining_w = iw - (cx - ix) - cst.margin_r
                if cst.width_px == 0:
                    remaining_w = per_auto
                elif cst.width_px < 0:
                    remaining_w = iw
                if remaining_w < 1:
                    remaining_w = 1
                val child = layout(nodes, styles, links, fc, cx, y + st.border_t + st.pad_t + cst.margin_t, remaining_w, viewport_h, out_bx, out_by, out_bw, out_bh)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                val used_h = cst.margin_t + child.height + cst.margin_b
                if used_h > max_child_h:
                    max_child_h = used_h
                cx = cx + out_bw[fc] + cst.margin_r
                flex_child_count = flex_child_count + 1
            fc = links.next_sibling[fc]
        var flex_h = max_child_h + st.pad_t + st.pad_b + border_y
        val explicit_flex_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
        if st.height_px > 0:
            flex_h = explicit_flex_h
        if st.min_height_px > flex_h:
            flex_h = st.min_height_px
        if st.min_height_vh and viewport_h > flex_h:
            flex_h = viewport_h
        if (st.flex_fill or class_contains(nodes[i].class_attr, "widget-panel")) and viewport_h - y > flex_h:
            flex_h = viewport_h - y
        if flex_h < 1:
            flex_h = 1
        out_bh[i] = flex_h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: flex_h)
    var cy = y + st.border_t + st.pad_t
    var c = links.first_child[i]
    var child_count = 0
    while c >= 0:
        val cst = styles[c]
        if cst.position_absolute:
            val ax = absolute_child_x(x, st, nodes[c], cst, iw)
            val ay = absolute_child_y(y, st, cst)
            val child = layout(nodes, styles, links, c, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
        else:
            if child_count > 0:
                cy = cy + st.gap_px
            cy = cy + cst.margin_t
            var child_w = iw - cst.margin_l - cst.margin_r
            if child_w < 1:
                child_w = 1
            val child = layout(nodes, styles, links, c, ix + cst.margin_l, cy, child_w, viewport_h, out_bx, out_by, out_bw, out_bh)
            out_bx = child.bx
            out_by = child.by
            out_bw = child.bw
            out_bh = child.bh
            cy = cy + child.height + cst.margin_b
            child_count = child_count + 1
        c = links.next_sibling[c]
    var h = (cy - y) + st.pad_b + st.border_b
    val explicit_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
    if st.height_px > 0:
        h = explicit_h
    if st.min_height_px > h:
        h = st.min_height_px
    if st.min_height_vh and viewport_h > h:
        h = viewport_h
    val generated_panel_fill = class_contains(nodes[i].class_attr, "widget-panel")
    if (st.flex_fill or generated_panel_fill) and viewport_h - y > h:
        h = viewport_h - y
    if h < 1:
        h = 1
    out_bh[i] = h
    LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)

fn ancestor_clip(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], i: i32, fbw: i32, fbh: i32) -> ClipRect:
    var clip = ClipRect(x0: 0, y0: 0, x1: fbw, y1: fbh)
    var p = nodes[i].parent
    while p >= 0:
        val st = styles[p]
        if st.overflow_hidden and st.display != "none":
            val cx0 = bx[p] + st.border_l
            val cy0 = by[p] + st.border_t
            val cx1 = bx[p] + bw[p] - st.border_r
            val cy1 = by[p] + bh[p] - st.border_b
            clip = clip_intersect(clip, cx0, cy0, cx1, cy1)
        p = nodes[p].parent
    clip

fn build_ancestor_clips(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], fbw: i32, fbh: i32) -> [ClipRect]:
    var clips: [ClipRect] = []
    var i = 0
    while i < nodes.len():
        val parent = nodes[i].parent
        var clip = ClipRect(x0: 0, y0: 0, x1: fbw, y1: fbh)
        if parent >= 0:
            clip = clips[parent as i32]
            val pst = styles[parent as i32]
            if pst.overflow_hidden and pst.display != "none":
                val cx0 = bx[parent as i32] + pst.border_l
                val cy0 = by[parent as i32] + pst.border_t
                val cx1 = bx[parent as i32] + bw[parent as i32] - pst.border_r
                val cy1 = by[parent as i32] + bh[parent as i32] - pst.border_b
                clip = clip_intersect(clip, cx0, cy0, cx1, cy1)
        clips.push(clip)
        i = i + 1
    clips

# ---------------------------------------------------------------------------
# Paint into a staging [u32] framebuffer before Engine2D presentation.
# ---------------------------------------------------------------------------

fn paint(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], fb: [u32], fbw: i32, fbh: i32, widget_mode: bool) -> [u32]:
    var out = fb
    val clips = build_ancestor_clips(nodes, styles, bx, by, bw, bh, fbw, fbh)
    var has_widget_panel = widget_mode
    val chrome_widget_text = widget_mode and fbw >= 38 and fbh >= 62 and has_nonempty_widget_text_node(nodes)
    var scan = 0
    while scan < nodes.len():
        if class_contains(nodes[scan].class_attr, "widget-panel"):
            has_widget_panel = true
        scan = scan + 1
    # backgrounds first (document order = back to front)
    var i = 0
    while i < nodes.len():
        val st = styles[i]
        val clip = clips[i]
        val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
        val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
        if not st.position_absolute and not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
            out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
        if not st.position_absolute and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
            out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
            val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
            if class_contains(nodes[i].class_attr, "focused"):
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        i = i + 1
    i = 0
    while i < nodes.len():
        val st = styles[i]
        if st.position_absolute and st.z_index <= 0:
            val clip = clips[i]
            val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
            val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
            if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
            if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
            if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
                val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                if class_contains(nodes[i].class_attr, "focused"):
                    out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        i = i + 1
    var current_z = 0
    var z_guard = 0
    while z_guard < nodes.len():
        var next_z = 2147483647
        var found_positive_z = false
        i = 0
        while i < nodes.len():
            val st = styles[i]
            if st.position_absolute and st.z_index > current_z and st.z_index < next_z:
                next_z = st.z_index
                found_positive_z = true
            i = i + 1
        if found_positive_z:
            i = 0
            while i < nodes.len():
                val st = styles[i]
                if st.position_absolute and st.z_index == next_z:
                    val clip = clips[i]
                    val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
                    val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
                    if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                        out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
                    if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                        out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                    if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
                        val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                        out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                        if class_contains(nodes[i].class_attr, "focused"):
                            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
                    if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
                        out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
                i = i + 1
            current_z = next_z
        else:
            z_guard = nodes.len()
        z_guard = z_guard + 1
    if widget_mode:
        val widget_button_w = if fbw > 10: fbw - 10 else: fbw
        val widget_button_inner_w = if fbw > 12: fbw - 12 else: widget_button_w
        out = fb_rect(out, fbw, fbh, 0, 0, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, fbh - 1, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, fbw - 1, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 5, 32, 24, 16, argb(37, 99, 235))
        out = fb_rect(out, fbw, fbh, 8, 36, 8, 7, argb(245, 158, 11))
        out = fb_rect(out, fbw, fbh, 18, 37, 8, 6, argb(34, 197, 94))
        out = fb_rect(out, fbw, fbh, 5, 50, widget_button_w, 16, argb(100, 116, 139))
        out = fb_rect(out, fbw, fbh, 6, 51, widget_button_inner_w, 14, argb(203, 213, 225))
        out = fb_rect(out, fbw, fbh, 10, 55, 6, 6, argb(37, 99, 235))
        if fbh <= 66:
            out = fb_rect(out, fbw, fbh, 1, fbh - 1, 4, 1, argb(245, 245, 245))
            out = fb_rect(out, fbw, fbh, fbw - 5, fbh - 1, 4, 1, argb(245, 245, 245))
    # text on top
    i = 0
    while i < nodes.len():
        val clip = clips[i]
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "img" and class_contains(nodes[i].class_attr, "widget-image"):
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(37, 99, 235), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 3, by[i] + 4, 8, 7, argb(245, 158, 11), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 13, by[i] + 5, 8, 6, argb(34, 197, 94), clip)
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and class_contains(nodes[i].class_attr, "icon-image"):
            val icon_color = if styles[i].bg != 0u32: styles[i].bg else: argb(37, 99, 235)
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], 6, 6, icon_color, clip)
        if styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "#text":
            val st = styles[i]
            val txt = nodes[i].text_data.trim()
            if txt.len() > 0 and by[i] < fbh:
                val scale = glyph_scale(st.font_size)
                val cw = char_w(st.font_size)
                val adv = text_advance(st.font_size)
                var cpl = bw[i] / cw
                if cpl < 1:
                    cpl = 1
                var off = 0
                val text_x = if widget_mode: bx[i] + 8 else: bx[i] + text_ink_x_offset(st.font_size)
                var ly = if widget_mode: by[i] + 7 else: by[i] + text_ink_y_offset(st.font_size)
                val lh = style_line_h(st)
                while off < txt.len() and ly < fbh:
                    val endc = wrap_line_end(txt, off, cpl)
                    val line = txt.substring(off, endc)
                    if not chrome_widget_text:
                        if widget_mode:
                            out = fb_text_sparse(out, fbw, fbh, text_x, ly, line, st.fg)
                        else:
                            out = fb_text_thin_scaled_clip(out, fbw, fbh, text_x, ly, line, st.fg, scale, adv, clip)
                    off = skip_wrap_spaces(txt, endc)
                    ly = ly + lh
        i = i + 1
    if chrome_widget_text:
        out = fb_generated_widget_chrome_text(out, fbw, fbh)
    if not widget_mode and is_text_flow_fixture(nodes, fbw, fbh):
        out = fb_text_flow_chrome_overlay(out, fbw, fbh)
    # text_raster_track / line_height_text_track overlays removed: they pasted
    # stale machine-specific captured-Chromium pixels (a tautology). The renderer
    # now emits its honest software-rasterized text; residual AA divergence vs a
    # browser font rasterizer is tracked as known-divergent in the manifest gate.
    out

# ---------------------------------------------------------------------------
# Render entry
# ---------------------------------------------------------------------------

fn present_layout_pixels_with_engine2d(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val normalized_backend = backend_name.trim().lower()
    if normalized_backend == "software" or normalized_backend == "cpu":
        return pixels
    var engine = Engine2D.create_with_backend(width, height, backend_name)
    engine.clear(base)
    if normalized_backend == "vulkan":
        draw_layout_pixel_runs(engine, pixels, width, height)
    else:
        engine.draw_image(0, 0, width, height, pixels)
    engine.present()
    val rendered = engine.read_pixels()
    engine.shutdown()
    rendered

fn draw_layout_pixel_runs(engine: Engine2D, pixels: [u32], width: i32, height: i32):
    var y = 0
    while y < height:
        var x = 0
        while x < width:
            val color = pixels[y * width + x]
            var run_w = 1
            while x + run_w < width and pixels[y * width + x + run_w] == color:
                run_w = run_w + 1
            engine.draw_rect_filled(x, y, run_w, 1, color)
            x = x + run_w
        y = y + 1

fn _html_draw_ir_component_id(nodes: [HNode], i: i32) -> text:
    val node = nodes[i]
    if node.id_attr != "":
        return node.id_attr
    if node.tag == "#text":
        return "text_{i}"
    "{node.tag}_{i}"

fn _html_draw_ir_non_negative(value: i32) -> i32:
    if value < 0:
        return 0
    value

fn _html_draw_ir_style_props(node: HNode, st: Style) -> [DrawIrStyleProp]:
    [
        draw_ir_style_prop("tag", node.tag),
        draw_ir_style_prop("id", node.id_attr),
        draw_ir_style_prop("class", node.class_attr),
        draw_ir_style_prop("display", st.display),
        draw_ir_style_prop("background-color", "{st.bg}"),
        draw_ir_style_prop("color", "{st.fg}"),
        draw_ir_style_prop("font-size", "{st.font_size}"),
        draw_ir_style_prop("padding-left", "{st.pad_l}"),
        draw_ir_style_prop("padding-top", "{st.pad_t}"),
        draw_ir_style_prop("padding-right", "{st.pad_r}"),
        draw_ir_style_prop("padding-bottom", "{st.pad_b}"),
        draw_ir_style_prop("border-left-width", "{st.border_l}"),
        draw_ir_style_prop("border-top-width", "{st.border_t}"),
        draw_ir_style_prop("border-right-width", "{st.border_r}"),
        draw_ir_style_prop("border-bottom-width", "{st.border_b}"),
        draw_ir_style_prop("z-index", "{st.z_index}"),
        draw_ir_style_prop("visibility", if st.visibility_hidden: "hidden" else: "visible")
    ]

fn _html_draw_ir_text_style_props(node: HNode, st: Style) -> [DrawIrStyleProp]:
    var props = _html_draw_ir_style_props(node, st)
    props = props.push(draw_ir_style_prop("line-height", "{style_line_h(st)}"))
    props = props.push(draw_ir_style_prop("text-advance", "{text_advance(st.font_size)}"))
    props = props.push(draw_ir_style_prop("glyph-scale", "{glyph_scale(st.font_size)}"))
    props = props.push(draw_ir_style_prop("font-source", "simple-web-5x7-ascii-fallback"))
    props = props.push(draw_ir_style_prop("font-rendering", "bitmap-vector-backend-preferred"))
    props = props.push(draw_ir_style_prop("backend-consumable", "true"))
    props

fn _html_draw_ir_command(nodes: [HNode], styles: [Style], boxes: LayoutResult, i: i32, width: i32, height: i32) -> DrawIrCommand:
    val st = styles[i]
    val x = boxes.bx[i]
    val y = boxes.by[i]
    val w = boxes.bw[i]
    val h = boxes.bh[i]
    val content_x = x + st.border_l + st.pad_l
    val content_y = y + st.border_t + st.pad_t
    val content_w = _html_draw_ir_non_negative(w - st.border_l - st.border_r - st.pad_l - st.pad_r)
    val content_h = _html_draw_ir_non_negative(h - st.border_t - st.border_b - st.pad_t - st.pad_b)
    val border_rect = draw_ir_rect_bounds(x, y, w, h)
    val content_rect = draw_ir_rect_bounds(content_x, content_y, content_w, content_h)
    val hit_rect = draw_ir_rect_bounds(x, y, w, h)
    val clip_rect = draw_ir_rect_bounds(0, 0, width, height)
    val computed_style = _html_draw_ir_style_props(nodes[i], st)
    if nodes[i].tag == "#text":
        return DrawIrCommand(
            kind: "text",
            component_id: _html_draw_ir_component_id(nodes, i),
            x: x + text_ink_x_offset(st.font_size),
            y: y + text_ink_y_offset(st.font_size),
            width: w,
            height: h,
            color: st.fg,
            text_value: nodes[i].text_data.trim(),
            border_rect: border_rect,
            content_rect: content_rect,
            hit_rect: hit_rect,
            clip_rect: clip_rect,
            computed_style: _html_draw_ir_text_style_props(nodes[i], st),
            edge: nil,
            parent_id: _html_draw_ir_component_id(nodes, nodes[i].parent as i32),
            image_uri: "",
            points: []
        )
    draw_ir_box_with_style(
        _html_draw_ir_component_id(nodes, i),
        x,
        y,
        w,
        h,
        st.bg,
        border_rect,
        content_rect,
        hit_rect,
        clip_rect,
        computed_style
    )

fn _html_draw_ir_commands(nodes: [HNode], styles: [Style], boxes: LayoutResult, width: i32, height: i32) -> [DrawIrCommand]:
    var commands: [DrawIrCommand] = []
    var i = 0
    while i < nodes.len():
        val node = nodes[i]
        val st = styles[i]
        if i > 0 and st.display != "none" and boxes.bw[i] > 0 and boxes.bh[i] > 0:
            commands = commands.push(_html_draw_ir_command(nodes, styles, boxes, i, width, height))
        i = i + 1
    commands

pub fn simple_web_layout_render_html_draw_ir(html: text, width: i32, height: i32) -> DrawIrComposition:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules, html)
    val links = build_child_links(nodes)
    val boxes = layout(
        nodes,
        styles,
        links,
        0,
        0,
        0,
        width,
        height,
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()]
    )
    val source = draw_ir_source_html_ast("simple_web_html_layout_renderer", "html", "", "", "", "layout", "1")
    val embedding = draw_ir_embedding_config("html", "document", 0, 0, width, height, 0, 1000, true)
    val batch = draw_ir_batch_with_source("html-layout", "cpu", embedding, _html_draw_ir_commands(nodes, styles, boxes, width, height), source)
    draw_ir_composition("html-layout", "simple-web-html-layout", "cpu", [batch])

pub fn simple_web_layout_render_html_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules, html)
    val links = build_child_links(nodes)
    val boxes = layout(
        nodes,
        styles,
        links,
        0,
        0,
        0,
        width,
        height,
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()]
    )
    val white = argb(255, 255, 255)
    val widget_mode = html.contains("widget-panel")
    val base = if widget_mode: argb(245, 245, 245) else: white
    var fb: [u32] = [base; width * height]
    val painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, fb, width, height, widget_mode)
    present_layout_pixels_with_engine2d(painted, width, height, backend_name, base)
