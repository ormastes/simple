            font_variant_caps_v = font_variant_caps_norm
    val font_variant_east_asian_decl = decl_get(decls, "font-variant-east-asian")
    if font_variant_east_asian_decl.len() > 0:
        val font_variant_east_asian_norm = font_variant_east_asian_decl.trim().lower()
        if font_variant_east_asian_norm == "normal" or font_variant_east_asian_norm == "ruby" or font_variant_east_asian_norm.starts_with("jis") or font_variant_east_asian_norm.contains("width") or font_variant_east_asian_norm.contains("simplified") or font_variant_east_asian_norm.contains("traditional"):
            font_variant_east_asian_v = font_variant_east_asian_norm
    val font_variant_emoji_decl = decl_get(decls, "font-variant-emoji")
