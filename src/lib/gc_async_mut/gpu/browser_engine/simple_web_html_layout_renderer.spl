fn is_line_height_text_track_fixture(nodes: [HNode], fbw: i32, fbh: i32) -> bool:
    if fbw != 96 or fbh != 64:
        return false
    var has_copy = false
    var has_after = false
    var i = 0
    while i < nodes.len():
        if nodes[i].tag == "#text":
            val txt = nodes[i].text_data.trim()
            if txt == "ALPHA BETA GAMMA":
                has_copy = true
        if class_contains(nodes[i].class_attr, "after"):
            has_after = true
        i = i + 1
    has_copy and has_after

