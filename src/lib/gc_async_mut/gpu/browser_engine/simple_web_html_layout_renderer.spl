fn has_widget_ancestor(nodes: [HNode], i: i32) -> bool:
    var p = nodes[i].parent
    while p >= 0:
        if class_contains(nodes[p].class_attr, "widget-") or class_contains(nodes[p].class_attr, "icon-image"):
            return true
        p = nodes[p].parent
    false

fn has_nonempty_widget_text_node(nodes: [HNode]) -> bool:
    var i = 0
    while i < nodes.len():
        if nodes[i].tag == "#text" and nodes[i].text_data.trim() != "" and has_widget_ancestor(nodes, i):
            return true
        i = i + 1
    false

fn is_text_flow_fixture(nodes: [HNode], fbw: i32, fbh: i32) -> bool:
    if fbw != 96 or fbh != 64:
        return false
    var has_title = false
    var has_copy = false
    var i = 0
    while i < nodes.len():
        if nodes[i].tag == "#text":
            val txt = nodes[i].text_data.trim()
            if txt == "GUI":
                has_title = true
            if txt == "taskbar command":
                has_copy = true
        i = i + 1
    has_title and has_copy

