class LayoutResult:
    bx: [i32]
    by: [i32]
    bw: [i32]
    bh: [i32]
    wrap_starts: [[i32]]
    wrap_ends: [[i32]]
    intrinsic_widths: [i32]
    height: i32

class PositionOffsetResult:
    bx: [i32]
    by: [i32]

fn offset_layout_subtree(child_index: HtmlChildIndex, node_index: i32, dx: i32, dy: i32, bx: [i32], by: [i32]) -> PositionOffsetResult:
    var out_bx = bx
    var out_by = by
    out_bx[node_index] = out_bx[node_index] + dx
    out_by[node_index] = out_by[node_index] + dy
    var child = child_index.first_child[node_index]
    while child >= 0:
        val shifted = offset_layout_subtree(child_index, child, dx, dy, out_bx, out_by)
        out_bx = shifted.bx
        out_by = shifted.by
        child = child_index.next_sibling[child]
    PositionOffsetResult(bx: out_bx, by: out_by)

fn relative_layout_result(child_index: HtmlChildIndex, node_index: i32, st: Style, bx: [i32], by: [i32], bw: [i32], bh: [i32], wrap_starts: [[i32]], wrap_ends: [[i32]], intrinsic_widths: [i32], height: i32) -> LayoutResult:
    if st.position_relative and (st.left_px != 0 or st.top_px != 0):
        val shifted = offset_layout_subtree(child_index, node_index, st.left_px, st.top_px, bx, by)
        return LayoutResult(bx: shifted.bx, by: shifted.by, bw: bw, bh: bh, wrap_starts: wrap_starts, wrap_ends: wrap_ends, intrinsic_widths: intrinsic_widths, height: height)
    LayoutResult(bx: bx, by: by, bw: bw, bh: bh, wrap_starts: wrap_starts, wrap_ends: wrap_ends, intrinsic_widths: intrinsic_widths, height: height)

class TextWrapCache:
    starts: [[i32]]
    ends: [[i32]]

class IntrinsicWidthResult:
    width: i32
    widths: [i32]

class LineWrapRanges:
    starts: [i32]
    ends: [i32]

fn char_w(fs: i32) -> i32:
    if fs <= 8:
        return 4
    6 * glyph_scale(fs)

fn text_advance(fs: i32) -> i32:
    if fs <= 8:
        return 4
    5 * glyph_scale(fs)

fn style_char_w(st: Style) -> i32:
    var out = char_w(st.font_size) + st.letter_spacing_px
    if out < 1:
        out = 1
    out

fn style_text_advance(st: Style) -> i32:
    var out = text_advance(st.font_size) + st.letter_spacing_px
    if out < 1:
        out = 1
    out

fn style_space_advance(st: Style) -> i32:
    var out = style_text_advance(st) / 2 + st.word_spacing_px
    if out < 1:
        out = 1
    out

fn line_h(fs: i32) -> i32:
    9 * glyph_scale(fs)

fn style_line_h(st: Style) -> i32:
    if st.line_height_px > 0:
        return st.line_height_px
    if st.line_height_px < 0:
        # negative sentinel = unitless line-height multiplier * 10 (e.g. 1.6 -> -16),
        # resolved here against the element's final font-size.
        val lh = st.font_size * (0 - st.line_height_px) / 10
        if lh > 0:
            return lh
    if st.resolved_font_line_height > 0:
        return st.resolved_font_line_height
    line_h(st.font_size)

fn resolved_text_range_width(st: Style, start: i32, endv: i32) -> i32:
    if st.resolved_font_identity == "" or start < 0 or endv > st.resolved_font_advances.len():
        return -1
    var width = 0
    var i = start
    while i < endv:
        width = width + st.resolved_font_advances[i]
        i = i + 1
    width

fn style_baseline_offset(st: Style) -> i32:
    var baseline = st.font_size * 7 / 8
    if baseline < 1:
        baseline = 1
    baseline

fn flex_item_align(parent: Style, child: Style) -> text:
    if child.align_self.len() > 0 and child.align_self != "auto":
        return child.align_self
    parent.align_items

fn flex_ordered_children(styles: [Style], child_index: HtmlChildIndex, parent_i: i32) -> [i32]:
    val child_count = child_index.child_count[parent_i]
    if child_count <= 0:
        return []
    var out: [i32] = [0; child_count]
    var c = child_index.first_child[parent_i]
    var out_len = 0
    var sorted = true
    var last_order = 0
    while c >= 0:
        val current_order = styles[c].order
        if out_len > 0 and current_order < last_order:
            sorted = false
        last_order = current_order
        out[out_len] = c
        out_len = out_len + 1
        c = child_index.next_sibling[c]
    if sorted:
        return out
    _sort_style_order_indices(out, out_len, styles)

fn flex_item_outer_height(node: HNode, st: Style) -> i32:
    val legacy_widget_box = node.has_widget_class or node.has_icon_image_class
    val border_y = st.border_t + st.border_b
    if st.height_px > 0:
        if legacy_widget_box or st.border_box:
            return constrained_outer_height(node, st, st.height_px)
        return constrained_outer_height(node, st, st.height_px + st.pad_t + st.pad_b + border_y)
    constrained_outer_height(node, st, style_line_h(st))

