fn inherit_style(p: Style) -> Style:
    var st = renderer_default_style()
    st.inherit_from(p)
    st

fn is_inline_tag(tag: text) -> bool:
    tag == "a" or tag == "span" or tag == "b" or tag == "strong" or tag == "em" or tag == "i" or tag == "small" or tag == "code" or tag == "#text"

fn is_heading(tag: text) -> bool:
    tag == "h1" or tag == "h2" or tag == "h3" or tag == "h4" or tag == "h5" or tag == "h6"

fn is_non_rendered_tag(tag: text) -> bool:
    tag == "head" or tag == "title" or tag == "meta" or tag == "style" or tag == "script" or tag == "link"

# apply a declaration block onto a style
# Size component of a `font:` shorthand: the first number immediately followed
# by "px". Bare numbers (numeric weights like 600) are skipped; keyword weights
# never contain digits so `font: bold 12px ...` still yields 12.
fn parse_font_shorthand_number(s: text, start: i32, n: i32) -> (i32, i32):
    var value = 0
    var j = start
    while j < n and dec_val(s.char_at(j)) < 10:
        value = value * 10 + dec_val(s.char_at(j))
        j = j + 1
    if j < n and s.char_at(j) == ".":
        j = j + 1
        while j < n and dec_val(s.char_at(j)) < 10:
            j = j + 1
    (value, j)

fn parse_font_shorthand_size_px(s: text) -> i32:
    val n = s.len()
    var i = 0
    while i < n:
        if dec_val(s.char_at(i)) < 10:
            val (v, j) = parse_font_shorthand_number(s, i, n)
            if j + 1 < n and s.char_at(j) == "p" and s.char_at(j + 1) == "x":
                return v
            i = j
        else:
            i = i + 1
    0

# Family tail after the required size[/line-height] component of `font:`.
fn parse_font_shorthand_family(s: text) -> text:
    val n = s.len()
    var i = 0
    while i + 1 < n:
        if dec_val(s.char_at(i)) < 10:
            val (_, number_end) = parse_font_shorthand_number(s, i, n)
            var j = number_end
            if j + 1 < n and s.char_at(j) == "p" and s.char_at(j + 1) == "x":
                j = j + 2
                j = skip_wrap_spaces(s, j)
                if j < n and s.char_at(j) == "/":
                    j = skip_wrap_spaces(s, j + 1)
                    val family_sep = find_from(s, " ", j)
                    if family_sep < 0:
                        return ""
                    j = skip_wrap_spaces(s, family_sep)
                return s.substring(j, n).trim()
            i = j
        else:
            i = i + 1
    ""

class BoxShadowAgg:
    found: bool
    x: i32
    y: i32
    blur: i32
    alpha: i32
    color: u32

fn split_top_level_commas(s: text) -> [text]:
    var parts: [text] = [""; 24]
    var count = 0
    var depth = 0
    var start = 0
    val n = s.len()
    var i = 0
    while i < n:
        val c = s.char_at(i)
        if c == "(":
            depth = depth + 1
        elif c == ")":
            if depth > 0:
                depth = depth - 1
        elif c == "," and depth == 0:
            if count < parts.len():
                parts[count] = s.substring(start, i)
                count = count + 1
            start = i + 1
        i = i + 1
    if count < parts.len():
        parts[count] = s.substring(start, n)
        count = count + 1
    text_list_prefix(parts, count)

# parse a CSS <alpha-value> "0.4" / ".08" / "1" into 0..255
fn parse_float_to_255(s: text) -> i32:
    val t = s.trim()
    val dot = text_index_of(t, ".")
    if dot < 0:
        val iv = parse_int(t)
        return if iv >= 1: 255 else: 0
    val ipart = parse_int(t.substring(0, dot))
    if ipart >= 1:
        return 255
    var frac = 0
    var digits = 0
    var i = dot + 1
    val n = t.len()
    while i < n and digits < 3:
        val d = dec_val(t.char_at(i))
        if d >= 10:
            break
        frac = frac * 10 + d
        digits = digits + 1
        i = i + 1
    while digits < 3:
        frac = frac * 10
        digits = digits + 1
    (frac * 255) / 1000

# alpha (0..255) of an rgba()/rgb() layer; 255 when no explicit alpha
fn shadow_layer_alpha(layer: text) -> i32:
    val rp = text_index_of(layer, "rgba(")
    if rp < 0:
        return 255
    val lp = rp + 5
    val close = find_from(layer, ")", lp)
    if close < 0:
        return 255
    val inner = layer.substring(lp, close)
    var commas = 0
    var i = 0
    val n = inner.len()
    while i < n:
        if inner.char_at(i) == ",":
            commas = commas + 1
            if commas == 3:
                return parse_float_to_255(inner.substring(i + 1, n))
        i = i + 1
    255

# the length tokens of a shadow layer live before the color token
fn shadow_length_prefix(layer: text) -> text:
    var cut = layer.len()
    val r = text_index_of(layer, "rgb")
    if r >= 0 and r < cut:
        cut = r
    val h = text_index_of(layer, "#")
    if h >= 0 and h < cut:
        cut = h
    layer.substring(0, cut)

# find the matching ")" for the "(" at open_idx (handles nested parens)
fn paren_matching_close(s: text, open_idx: i32) -> i32:
    var depth = 0
    var i = open_idx
    val n = s.len()
    while i < n:
        val c = s.char_at(i)
        if c == "(":
            depth = depth + 1
        elif c == ")":
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    -1

# src-over composite an rgba color (alpha 0..255) onto an opaque base color
fn composite_over_base(col: u32, alpha: i32, base: u32) -> u32:
    if alpha >= 255 or base == 0u32:
        return col
    val sr = (((col >> 16) & 255u32) as i32)
    val sg = (((col >> 8) & 255u32) as i32)
    val sb = ((col & 255u32) as i32)
    val dr = (((base >> 16) & 255u32) as i32)
    val dg = (((base >> 8) & 255u32) as i32)
    val db = ((base & 255u32) as i32)
    val inv = 255 - alpha
    argb((sr * alpha + dr * inv + 127) / 255, (sg * alpha + dg * inv + 127) / 255, (sb * alpha + db * inv + 127) / 255)

class BgLayers:
    base_color: u32
    gradient_from: u32
    gradient_to: u32

fn _gradient_stop_color(stop_raw: text, base: u32) -> u32:
    # strip a trailing position ("... 0%" / "... 34%")
    var stop = stop_raw.trim()
    val pct = text_index_of(stop, "%")
    if pct >= 0:
        # cut the trailing "<num>%" token
        var cut = stop.len()
        var k = stop.len() - 1
        var seen_pct = false
        while k >= 0:
            val c = stop.char_at(k)
            if c == "%":
                seen_pct = true
            elif seen_pct and c == " ":
                cut = k
                break
            k = k - 1
        if seen_pct and cut < stop.len():
            stop = stop.substring(0, cut).trim()
    val col = parse_color_any(stop)
    if col == 0u32:
        return 0u32
    val alpha = shadow_layer_alpha(stop)
    composite_over_base(col, alpha, base)

fn _bg_layer_is_direction(part: text) -> bool:
    val p = part.trim().lower()
    if p.starts_with("to ") or p == "top" or p == "bottom" or p == "left" or p == "right":
        return true
    if p.ends_with("deg"):
        return true
    if p.starts_with("circle") or p.starts_with("ellipse") or p.starts_with("at "):
        return true
    false

# Parse a (possibly multi-layer) CSS `background` shorthand value:
#   background: linear-gradient(...), radial-gradient(...), #f5f5f5
# Returns the opaque base color layer (if any) plus the last linear-gradient
# layer's first/last stops composited over that base (so translucent
# rgba() gradient fills match Chromium's src-over result). Radial layers are
# not paintable by this engine and are skipped.
fn parse_background_layers(value: text) -> BgLayers:
    val layers = split_top_level_commas(value)
    val lc = layers.len()
    # base color: last layer that is not a gradient/url and parses as a color
    var base: u32 = 0u32
    var li = lc - 1
    while li >= 0:
        val lay = layers[li].trim()
        if not lay.contains("gradient(") and not lay.contains("url("):
            val col = parse_color_any(lay)
            if col != 0u32:
                base = col
                break
        li = li - 1
    # last linear-gradient layer wins (painted closest to the base)
    var g_from: u32 = 0u32
    var g_to: u32 = 0u32
    li = lc - 1
    while li >= 0:
        val lay = layers[li]
        val gpos = text_index_of(lay.lower(), "linear-gradient(")
        if gpos >= 0:
            val lp = find_from(lay, "(", gpos)
            val rp = paren_matching_close(lay, lp)
            if lp >= 0 and rp > lp:
                val inner = lay.substring(lp + 1, rp)
                val parts = split_top_level_commas(inner)
                val pc = parts.len()
                var first_stop = ""
                var last_stop = ""
                var pi = 0
                while pi < pc:
                    val part = parts[pi]
                    pi = pi + 1
                    if _bg_layer_is_direction(part):
                        continue
                    if first_stop == "":
                        first_stop = part
                    last_stop = part
                if first_stop != "" and last_stop != "":
                    val cf = _gradient_stop_color(first_stop, base)
                    val ct = _gradient_stop_color(last_stop, base)
                    if cf != 0u32 and ct != 0u32:
                        g_from = cf
                        g_to = ct
                        break
        li = li - 1
    BgLayers(base_color: base, gradient_from: g_from, gradient_to: g_to)

# Aggregate the visible SOFT/dark shadow layers of a (possibly multi-layer)
# box-shadow value into a single representative blurred layer. Near-white and
# near-transparent layers are ignored; alpha of the dark layers is summed
# (capped) to approximate Chromium's stacked compositing, and the largest blur
# (with its offset) is used as the halo geometry. blur==0 preserves the legacy
# hard-offset behavior byte-for-byte via the caller.
fn parse_box_shadow_agg(value: text) -> BoxShadowAgg:
    val layers = split_top_level_commas(value)
    # Represent the stacked dark layers as ONE equivalent blurred layer:
    #  - geometry (blur, offset, color) = alpha-weighted average of the layers,
    #  - opacity = the src-over combined alpha 255*(1 - prod((255-a_i)/255)),
    # which reproduces Chromium's layered compositing far better than a naive
    # sum (a single wide-blur layer at summed alpha over-darkens the far field).
    var wsum = 0
    var blur_w = 0
    var mass_sum = 0
    var ox_w = 0
    var oy_w = 0
    var cr_w = 0
    var cg_w = 0
    var cb_w = 0
    var inv = 255
    var kept = false
    var li = 0
    val lc = layers.len()
    while li < lc:
        val layer = layers[li]
        li = li + 1
        if layer.contains("inset"):
            continue
        val col = parse_color_any(layer)
        val cr = (((col >> 16) & 255u32) as i32)
        val cg = (((col >> 8) & 255u32) as i32)
        val cb = ((col & 255u32) as i32)
        val alpha = shadow_layer_alpha(layer)
        # skip near-white (glossy highlight) and near-transparent layers
        if cr + cg + cb > 360 or alpha < 30:
            continue
        val prefix = shadow_length_prefix(layer)
        val ox = parse_signed_nth_int(prefix, 0)
        val oy = parse_signed_nth_int(prefix, 1)
        if ox == -1000000 or oy == -1000000:
            continue
        var blur = parse_signed_nth_int(prefix, 2)
        if blur == -1000000 or blur < 0:
            blur = 0
        # blur/color track alpha weight; offset tracks shadow "mass"
        # (alpha*(blur+1)) so the wide soft layer dominates the visible halo
        # position rather than the tight near-edge layers.
        val mass = alpha * (blur + 1)
        wsum = wsum + alpha
        blur_w = blur_w + alpha * blur
        cr_w = cr_w + alpha * cr
        cg_w = cg_w + alpha * cg
        cb_w = cb_w + alpha * cb
        mass_sum = mass_sum + mass
        ox_w = ox_w + mass * ox
        oy_w = oy_w + mass * oy
        inv = (inv * (255 - alpha)) / 255
        kept = true
    if not kept or wsum <= 0 or mass_sum <= 0:
        return BoxShadowAgg(found: false, x: 0, y: 0, blur: 0, alpha: 255, color: 0u32)
    val avg_blur = blur_w / wsum
    val avg_ox = ox_w / mass_sum
    val avg_oy = oy_w / mass_sum
    val avg_color = argb(cr_w / wsum, cg_w / wsum, cb_w / wsum)
    val combined = 255 - inv
    BoxShadowAgg(found: true, x: avg_ox, y: avg_oy, blur: if avg_blur < 0: 0 else: avg_blur, alpha: if combined > 255: 255 else: combined, color: avg_color)

# True if a declaration block carries more than WEB_RULE_DECL_QUOTA declarations.
# Early-exits once the cap is crossed, so ordinary small rules pay only a short
# semicolon scan. (A `;` inside a data: URI value slightly overcounts — harmless
# for a coarse abuse threshold.)
fn _decl_over_quota(decls: text) -> bool:
    var count = 1
    var pos = 0
    val n = decls.len()
    while pos < n:
        val semi = find_from(decls, ";", pos)
        if semi < 0:
            break
        count = count + 1
        if count > WEB_RULE_DECL_QUOTA:
            return true
        pos = semi + 1
    false

fn apply_decls(st: Style, decls: text, em_base: i32) -> Style:
    if decls.len() == 0:
        return st
    # Per-rule declaration quota: a rule carrying more than the cap is dropped
    # wholesale (graceful — the cascade continues with the remaining rules).
    if _decl_over_quota(decls):
        return st
    var bg_v = st.bg
    var background_gradient_from_v = st.background_gradient_from
    var background_gradient_to_v = st.background_gradient_to
    var background_repeat_v = st.background_repeat
    var background_size_w_px_v = st.background_size_w_px
    var background_size_h_px_v = st.background_size_h_px
    var background_position_x_px_v = st.background_position_x_px
    var background_position_y_px_v = st.background_position_y_px
    var background_clip_v = st.background_clip
    var background_origin_v = st.background_origin
    var background_attachment_v = st.background_attachment
    var fg_v = st.fg
    var font_size_v = st.font_size
    var font_family_v = st.font_family
    var line_height_v = st.line_height_px
