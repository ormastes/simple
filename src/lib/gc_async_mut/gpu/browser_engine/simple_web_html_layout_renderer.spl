class WidgetPaintFlags:
    has_widget_panel: bool
    has_nonempty_widget_text: bool

fn compute_widget_paint_flags(nodes: [HNode], widget_mode: bool, need_text: bool) -> WidgetPaintFlags:
    if not need_text:
        var has_panel = widget_mode
        var scan = 0
        val node_count = nodes.len()
        while scan < node_count:
            val nd = nodes[scan]
            if nd.has_widget_panel_class:
                has_panel = true
            scan = scan + 1
        return WidgetPaintFlags(has_widget_panel: has_panel, has_nonempty_widget_text: false)
    val node_count = nodes.len()
    var widget_ancestor_flags: [i32] = [0; node_count]
    var has_widget_panel = widget_mode
    var i = 0
    while i < node_count:
        val nd = nodes[i]
        if nd.has_widget_panel_class:
            has_widget_panel = true
        var has_widget_parent = 0
        val p = nd.parent
        if p >= 0:
            val parent = nodes[p]
            if parent.has_widget_class or parent.has_icon_image_class:
                has_widget_parent = 1
            elif widget_ancestor_flags[p] == 1:
                has_widget_parent = 1
        widget_ancestor_flags[i] = has_widget_parent
        if need_text and nd.tag == "#text" and nd.text_trimmed != "" and has_widget_parent == 1:
            return WidgetPaintFlags(has_widget_panel: has_widget_panel, has_nonempty_widget_text: true)
        i = i + 1
    WidgetPaintFlags(has_widget_panel: has_widget_panel, has_nonempty_widget_text: false)

fn is_text_flow_fixture(nodes: [HNode], fbw: i32, fbh: i32) -> bool:
    if fbw != 96 or fbh != 64:
        return false
    var has_title = false
    var has_copy = false
    var i = 0
    val node_count = nodes.len()
    while i < node_count:
        if nodes[i].tag == "#text":
            val txt = nodes[i].text_trimmed
            if txt == "GUI":
                has_title = true
            if txt == "taskbar command":
                has_copy = true
        i = i + 1
    has_title and has_copy

