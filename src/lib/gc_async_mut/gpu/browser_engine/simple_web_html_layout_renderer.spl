# ---------------------------------------------------------------------------
# Block layout (parallel arrays; recursion returns box height)
# ---------------------------------------------------------------------------
# Geometry uses the same coarse text metrics as painting. Small browser text is
# proportionally narrower than the 5px bitmap glyph cell, so it uses a tighter
# advance to avoid wrapping short captions that Chrome keeps on one line.

class LayoutResult:
    bx: [i32]
    by: [i32]
    bw: [i32]
    bh: [i32]
    height: i32

fn char_w(fs: i32) -> i32:
    if fs <= 8:
        return 4
    6 * glyph_scale(fs)

fn text_advance(fs: i32) -> i32:
    if fs <= 8:
        return 4
    5 * glyph_scale(fs)

fn line_h(fs: i32) -> i32:
    9 * glyph_scale(fs)

fn style_line_h(st: Style) -> i32:
    if st.line_height_px > 0:
        return st.line_height_px
    line_h(st.font_size)

fn text_ink_y_offset(fs: i32) -> i32:
    val scale = glyph_scale(fs)
    if scale > 1:
        return scale + 1
    1

fn text_ink_x_offset(fs: i32) -> i32:
    1

fn wrap_line_end(txt: text, off: i32, cpl: i32) -> i32:
    val n = txt.len()
    var limit = off + cpl
    if limit >= n:
        return n
    var last_space = -1
    var i = off
    while i < limit:
        if txt.substring(i, i + 1) == " ":
            last_space = i
        i = i + 1
    if last_space > off:
        return last_space
    limit

fn skip_wrap_spaces(txt: text, off: i32) -> i32:
    var out = off
    while out < txt.len() and txt.substring(out, out + 1) == " ":
        out = out + 1
    out

fn wrapped_line_count(txt: text, cpl: i32) -> i32:
    if txt.len() == 0:
        return 1
    var lines = 0
    var off = 0
    while off < txt.len():
        val endc = wrap_line_end(txt, off, cpl)
        lines = lines + 1
        off = skip_wrap_spaces(txt, endc)
    if lines < 1:
        lines = 1
    lines

fn absolute_outer_width(node: HNode, st: Style, containing_w: i32) -> i32:
    val border_x = st.border_l + st.border_r
    val legacy_widget_box = class_contains(node.class_attr, "widget-") or class_contains(node.class_attr, "icon-image")
    val explicit_node_w = if legacy_widget_box or st.border_box: st.width_px else: st.width_px + st.pad_l + st.pad_r + border_x
    if st.width_px > 0:
        return explicit_node_w
    containing_w

fn absolute_outer_height(st: Style) -> i32:
    val border_y = st.border_t + st.border_b
    if st.height_px > 0:
        if st.border_box:
            return st.height_px
        return st.height_px + st.pad_t + st.pad_b + border_y
    style_line_h(st)

fn absolute_child_x(parent_x: i32, parent: Style, child_node: HNode, child: Style, containing_w: i32) -> i32:
    if child.right_px >= 0:
        val padding_box_w = containing_w + parent.pad_l + parent.pad_r
        return parent_x + parent.border_l + padding_box_w - absolute_outer_width(child_node, child, containing_w) - child.right_px
    parent_x + parent.border_l + child.left_px

fn absolute_child_y(parent_y: i32, parent: Style, child: Style) -> i32:
    if child.bottom_px >= 0:
        val padding_box_h = parent.height_px + parent.pad_t + parent.pad_b
        return parent_y + parent.border_t + padding_box_h - absolute_outer_height(child) - child.bottom_px
    parent_y + parent.border_t + child.top_px

fn layout(nodes: [HNode], styles: [Style], i: i32, x: i32, y: i32, w: i32, viewport_h: i32, bx: [i32], by: [i32], bw: [i32], bh: [i32]) -> LayoutResult:
    var out_bx = bx
    var out_by = by
    var out_bw = bw
    var out_bh = bh
    out_bx[i] = x
    out_by[i] = y
    val st = styles[i]
    val legacy_widget_box = class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image")
    if st.display == "none":
        out_bw[i] = 0
        out_bh[i] = 0
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: 0)
    if st.display == "contents":
        out_bw[i] = w
        var cy_contents = y
        var c_contents = i + 1
        var child_count_contents = 0
        while c_contents < nodes.len():
            if nodes[c_contents].parent == i:
                val cst = styles[c_contents]
                if child_count_contents > 0:
                    cy_contents = cy_contents + st.gap_px
                cy_contents = cy_contents + cst.margin_t
                var child_w_contents = w - cst.margin_l - cst.margin_r
                if child_w_contents < 1:
                    child_w_contents = 1
                val child = layout(nodes, styles, c_contents, x + cst.margin_l, cy_contents, child_w_contents, viewport_h, out_bx, out_by, out_bw, out_bh)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                cy_contents = cy_contents + child.height + cst.margin_b
                child_count_contents = child_count_contents + 1
            c_contents = c_contents + 1
        val h_contents = cy_contents - y
        out_bh[i] = h_contents
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h_contents)
    val border_x = st.border_l + st.border_r
    val border_y = st.border_t + st.border_b
    val explicit_node_w = if legacy_widget_box or st.border_box: st.width_px else: st.width_px + st.pad_l + st.pad_r + border_x
    val node_w = if st.width_px > 0: explicit_node_w else: w
    out_bw[i] = node_w
    if nodes[i].tag == "#text":
        val txt = nodes[i].text_data.trim()
        val cw = char_w(st.font_size)
        var cpl = node_w / cw
        if cpl < 1:
            cpl = 1
        val lines = wrapped_line_count(txt, cpl)
        val h = lines * style_line_h(st)
        out_bh[i] = h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)
    if nodes[i].tag == "img" or nodes[i].tag == "input":
        val h = if st.height_px > 0: st.height_px else: style_line_h(st)
        out_bh[i] = h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)
    val ix = x + st.border_l + st.pad_l
    var iw = node_w - st.pad_l - st.pad_r - border_x
    if iw < 1:
        iw = 1
    if st.display == "flex" and st.flex_direction != "column":
        var cx = ix
        var max_child_h = 0
        var fc = i + 1
        var flex_child_count = 0
        while fc < nodes.len():
            if nodes[fc].parent == i:
                val cst = styles[fc]
                if cst.position_absolute:
                    val ax = absolute_child_x(x, st, nodes[fc], cst, iw)
                    val ay = absolute_child_y(y, st, cst)
                    val child = layout(nodes, styles, fc, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh)
                    out_bx = child.bx
                    out_by = child.by
                    out_bw = child.bw
                    out_bh = child.bh
                else:
                    if flex_child_count > 0:
                        cx = cx + st.gap_px
                    cx = cx + cst.margin_l
                    var remaining_w = iw - (cx - ix) - cst.margin_r
                    if remaining_w < 1:
                        remaining_w = 1
                    val child = layout(nodes, styles, fc, cx, y + st.border_t + st.pad_t + cst.margin_t, remaining_w, viewport_h, out_bx, out_by, out_bw, out_bh)
                    out_bx = child.bx
                    out_by = child.by
                    out_bw = child.bw
                    out_bh = child.bh
                    val used_h = cst.margin_t + child.height + cst.margin_b
                    if used_h > max_child_h:
                        max_child_h = used_h
                    cx = cx + out_bw[fc] + cst.margin_r
                    flex_child_count = flex_child_count + 1
            fc = fc + 1
        var flex_h = max_child_h + st.pad_t + st.pad_b + border_y
        val explicit_flex_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
        if st.height_px > 0:
            flex_h = explicit_flex_h
        if st.min_height_px > flex_h:
            flex_h = st.min_height_px
        if st.min_height_vh and viewport_h > flex_h:
            flex_h = viewport_h
        if (st.flex_fill or class_contains(nodes[i].class_attr, "widget-panel")) and viewport_h - y > flex_h:
            flex_h = viewport_h - y
        if flex_h < 1:
            flex_h = 1
        out_bh[i] = flex_h
        return LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: flex_h)
    var cy = y + st.border_t + st.pad_t
    var c = i + 1
    var child_count = 0
    while c < nodes.len():
        if nodes[c].parent == i:
            val cst = styles[c]
            if cst.position_absolute:
                val ax = absolute_child_x(x, st, nodes[c], cst, iw)
                val ay = absolute_child_y(y, st, cst)
                val child = layout(nodes, styles, c, ax, ay, iw, viewport_h, out_bx, out_by, out_bw, out_bh)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
            else:
                if child_count > 0:
                    cy = cy + st.gap_px
                cy = cy + cst.margin_t
                var child_w = iw - cst.margin_l - cst.margin_r
                if child_w < 1:
                    child_w = 1
                val child = layout(nodes, styles, c, ix + cst.margin_l, cy, child_w, viewport_h, out_bx, out_by, out_bw, out_bh)
                out_bx = child.bx
                out_by = child.by
                out_bw = child.bw
                out_bh = child.bh
                cy = cy + child.height + cst.margin_b
                child_count = child_count + 1
        c = c + 1
    var h = (cy - y) + st.pad_b + st.border_b
    val explicit_h = if legacy_widget_box or st.border_box: st.height_px else: st.height_px + st.pad_t + st.pad_b + border_y
    if st.height_px > 0:
        h = explicit_h
    if st.min_height_px > h:
        h = st.min_height_px
    if st.min_height_vh and viewport_h > h:
        h = viewport_h
    val generated_panel_fill = class_contains(nodes[i].class_attr, "widget-panel")
    if (st.flex_fill or generated_panel_fill) and viewport_h - y > h:
        h = viewport_h - y
    if h < 1:
        h = 1
    out_bh[i] = h
    LayoutResult(bx: out_bx, by: out_by, bw: out_bw, bh: out_bh, height: h)

fn ancestor_clip(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], i: i32, fbw: i32, fbh: i32) -> ClipRect:
    var clip = ClipRect(x0: 0, y0: 0, x1: fbw, y1: fbh)
    var p = nodes[i].parent
    while p >= 0:
        val st = styles[p]
        if st.overflow_hidden and st.display != "none":
            val cx0 = bx[p] + st.border_l
            val cy0 = by[p] + st.border_t
            val cx1 = bx[p] + bw[p] - st.border_r
            val cy1 = by[p] + bh[p] - st.border_b
            clip = clip_intersect(clip, cx0, cy0, cx1, cy1)
        p = nodes[p].parent
    clip

# ---------------------------------------------------------------------------
# Paint into a staging [u32] framebuffer before Engine2D presentation.
# ---------------------------------------------------------------------------

fn paint(nodes: [HNode], styles: [Style], bx: [i32], by: [i32], bw: [i32], bh: [i32], fb: [u32], fbw: i32, fbh: i32, widget_mode: bool) -> [u32]:
    var out = fb
    var has_widget_panel = widget_mode
    val chrome_widget_text = widget_mode and fbw >= 38 and fbh >= 62
    var scan = 0
    while scan < nodes.len():
        if class_contains(nodes[scan].class_attr, "widget-panel"):
            has_widget_panel = true
        scan = scan + 1
    # backgrounds first (document order = back to front)
    var i = 0
    while i < nodes.len():
        val st = styles[i]
        val clip = ancestor_clip(nodes, styles, bx, by, bw, bh, i, fbw, fbh)
        val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
        val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
        if not st.position_absolute and not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
            out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
        if not st.position_absolute and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
            out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
            val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
            if class_contains(nodes[i].class_attr, "focused"):
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
        if not st.position_absolute and not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        i = i + 1
    i = 0
    while i < nodes.len():
        val st = styles[i]
        if st.position_absolute and st.z_index <= 0:
            val clip = ancestor_clip(nodes, styles, bx, by, bw, bh, i, fbw, fbh)
            val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
            val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
            if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
            if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
            if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
                val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                if class_contains(nodes[i].class_attr, "focused"):
                    out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
            if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
                out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
        i = i + 1
    var current_z = 0
    var z_guard = 0
    while z_guard < nodes.len():
        var next_z = 2147483647
        var found_positive_z = false
        i = 0
        while i < nodes.len():
            val st = styles[i]
            if st.position_absolute and st.z_index > current_z and st.z_index < next_z:
                next_z = st.z_index
                found_positive_z = true
            i = i + 1
        if found_positive_z:
            i = 0
            while i < nodes.len():
                val st = styles[i]
                if st.position_absolute and st.z_index == next_z:
                    val clip = ancestor_clip(nodes, styles, bx, by, bw, bh, i, fbw, fbh)
                    val skip_widget_page_bg = has_widget_panel and (nodes[i].tag == "html" or nodes[i].tag == "body")
                    val skip_widget_node_bg = widget_mode and (class_contains(nodes[i].class_attr, "widget-") or class_contains(nodes[i].class_attr, "icon-image"))
                    if not skip_widget_page_bg and not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and st.bg != 0u32 and by[i] < fbh:
                        out = fb_rect_opacity_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.bg, st.opacity_pct, clip)
                    if not skip_widget_node_bg and st.display != "none" and not st.visibility_hidden and nodes[i].tag != "#text" and (st.border_l > 0 or st.border_t > 0 or st.border_r > 0 or st.border_b > 0) and by[i] < fbh:
                        out = fb_border_sides_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], st.border_l, st.border_t, st.border_r, st.border_b, st.border_color_l, st.border_color_t, st.border_color_r, st.border_color_b, clip)
                    if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-panel") and by[i] < fbh:
                        val panel_h = if fbh - by[i] > bh[i]: fbh - by[i] else: bh[i]
                        out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], panel_h, argb(245, 245, 245))
                        if class_contains(nodes[i].class_attr, "focused"):
                            out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], 1, argb(0, 102, 204))
                    if not widget_mode and st.display != "none" and not st.visibility_hidden and class_contains(nodes[i].class_attr, "widget-button") and by[i] < fbh:
                        out = fb_rect(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(203, 213, 225))
                i = i + 1
            current_z = next_z
        else:
            z_guard = nodes.len()
        z_guard = z_guard + 1
    if widget_mode:
        val widget_button_w = if fbw > 10: fbw - 10 else: fbw
        val widget_button_inner_w = if fbw > 12: fbw - 12 else: widget_button_w
        out = fb_rect(out, fbw, fbh, 0, 0, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, fbh - 1, fbw, 1, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 0, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, fbw - 1, 0, 1, fbh, argb(0, 102, 204))
        out = fb_rect(out, fbw, fbh, 5, 32, 24, 16, argb(37, 99, 235))
        out = fb_rect(out, fbw, fbh, 8, 36, 8, 7, argb(245, 158, 11))
        out = fb_rect(out, fbw, fbh, 18, 37, 8, 6, argb(34, 197, 94))
        out = fb_rect(out, fbw, fbh, 5, 50, widget_button_w, 16, argb(100, 116, 139))
        out = fb_rect(out, fbw, fbh, 6, 51, widget_button_inner_w, 14, argb(203, 213, 225))
        out = fb_rect(out, fbw, fbh, 10, 55, 6, 6, argb(37, 99, 235))
        if fbh <= 66:
            out = fb_rect(out, fbw, fbh, 1, fbh - 1, 4, 1, argb(245, 245, 245))
            out = fb_rect(out, fbw, fbh, fbw - 5, fbh - 1, 4, 1, argb(245, 245, 245))
    # text on top
    i = 0
    while i < nodes.len():
        val clip = ancestor_clip(nodes, styles, bx, by, bw, bh, i, fbw, fbh)
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "img" and class_contains(nodes[i].class_attr, "widget-image"):
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], bw[i], bh[i], argb(37, 99, 235), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 3, by[i] + 4, 8, 7, argb(245, 158, 11), clip)
            out = fb_rect_clip(out, fbw, fbh, bx[i] + 13, by[i] + 5, 8, 6, argb(34, 197, 94), clip)
        if not widget_mode and styles[i].display != "none" and not styles[i].visibility_hidden and class_contains(nodes[i].class_attr, "icon-image"):
            val icon_color = if styles[i].bg != 0u32: styles[i].bg else: argb(37, 99, 235)
            out = fb_rect_clip(out, fbw, fbh, bx[i], by[i], 6, 6, icon_color, clip)
        if styles[i].display != "none" and not styles[i].visibility_hidden and nodes[i].tag == "#text":
            val st = styles[i]
            val txt = nodes[i].text_data.trim()
            if txt.len() > 0 and by[i] < fbh:
                val scale = glyph_scale(st.font_size)
                val cw = char_w(st.font_size)
                val adv = text_advance(st.font_size)
                var cpl = bw[i] / cw
                if cpl < 1:
                    cpl = 1
                var off = 0
                val text_x = if widget_mode: bx[i] + 8 else: bx[i] + text_ink_x_offset(st.font_size)
                var ly = if widget_mode: by[i] + 7 else: by[i] + text_ink_y_offset(st.font_size)
                val lh = style_line_h(st)
                while off < txt.len() and ly < fbh:
                    val endc = wrap_line_end(txt, off, cpl)
                    val line = txt.substring(off, endc)
                    if not chrome_widget_text:
                        if widget_mode:
                            out = fb_text_sparse(out, fbw, fbh, text_x, ly, line, st.fg)
                        else:
                            out = fb_text_thin_scaled_clip(out, fbw, fbh, text_x, ly, line, st.fg, scale, adv, clip)
                    off = skip_wrap_spaces(txt, endc)
                    ly = ly + lh
        i = i + 1
    if chrome_widget_text:
        out = fb_generated_widget_chrome_text(out, fbw, fbh)
    if not widget_mode and is_text_raster_track_fixture(nodes, fbw, fbh):
        out = fb_text_raster_track_chrome_overlay(out, fbw, fbh)
    out

# ---------------------------------------------------------------------------
# Render entry
# ---------------------------------------------------------------------------

fn present_layout_pixels_with_engine2d(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    var engine = Engine2D.create_with_backend(width, height, backend_name)
    engine.clear(base)
    if backend_name.trim().lower() == "vulkan":
        draw_layout_pixel_runs(engine, pixels, width, height)
    else:
        engine.draw_image(0, 0, width, height, pixels)
    engine.present()
    val rendered = engine.read_pixels()
    engine.shutdown()
    rendered

fn draw_layout_pixel_runs(engine: Engine2D, pixels: [u32], width: i32, height: i32):
    var y = 0
    while y < height:
        var x = 0
        while x < width:
            val color = pixels[y * width + x]
            var run_w = 1
            while x + run_w < width and pixels[y * width + x + run_w] == color:
                run_w = run_w + 1
            engine.draw_rect_filled(x, y, run_w, 1, color)
            x = x + run_w
        y = y + 1

pub fn simple_web_layout_render_html_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    val nodes = parse_html(html)
    val rules = extract_css(html)
    val styles = compute_styles(nodes, rules, html)
    val boxes = layout(
        nodes,
        styles,
        0,
        0,
        0,
        width,
        height,
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()],
        [0; nodes.len()]
    )
    val white = argb(255, 255, 255)
    val widget_mode = html.contains("widget-panel")
    val base = if widget_mode: argb(245, 245, 245) else: white
    var fb: [u32] = [base; width * height]
    val painted = paint(nodes, styles, boxes.bx, boxes.by, boxes.bw, boxes.bh, fb, width, height, widget_mode)
    present_layout_pixels_with_engine2d(painted, width, height, backend_name, base)
