        0xffd6d6d7u32, 0xff141418u32, 0xff848486u32, 0xff78787au32, 0xffb7b7b8u32, 0xffd6d6d7u32, 0xff48484bu32, 0xffc6c6c7u32, 0xff88888au32, 0xff808082u32, 0xffebebebu32, 0xff838385u32, 0xff868688u32, 0xff454549u32, 0xffe0e0e0u32, 0xffc2c2c3u32,
        0xff434346u32, 0xffc0c0c1u32, 0xff88888au32, 0xffaaaaabu32, 0xff404043u32, 0xfff2f2f2u32, 0xff7b7b7du32, 0xffc4c4c5u32, 0xffe6e6e6u32, 0xff636366u32, 0xffccccccu32, 0xff404043u32, 0xfff1f1f1u32, 0xffeeeeeeu32, 0xffb5b5b6u32, 0xff48484bu32,
        0xffcfcfd0u32, 0xff656568u32, 0xfff4f4f4u32, 0xff2d2d30u32, 0xffd7d7d8u32, 0xff5f5f62u32, 0xffbbbbbcu32, 0xff5a5a5cu32, 0xff3d3d40u32, 0xff707072u32, 0xff535356u32, 0xffd1d1d1u32, 0xfff2f2f2u32, 0xff434346u32, 0xff48484bu32, 0xfff1f1f1u32,
