    IntrinsicWidthResult(width: width, widths: out_widths)

fn text_ink_y_offset(fs: i32) -> i32:
    val scale = glyph_scale(fs)
    if scale > 1:
        return scale + 1
    1

fn text_ink_x_offset(fs: i32) -> i32:
    1

fn wrap_line_end(txt: text, off: i32, cpl: i32) -> i32:
    val n = txt.len()
    var limit = off + cpl
    if limit >= n:
        return n
    var last_space = -1
    var i = off
    while i < limit:
        if txt.char_code_at(i) == 32:
            last_space = i
        i = i + 1
    if last_space > off:
        return last_space
    limit

fn skip_wrap_spaces(txt: text, off: i32) -> i32:
    var out = off
    val n = txt.len()
    while out < n and txt.char_code_at(out) == 32:
        out = out + 1
    out

fn compute_wrap_ranges(txt: text, cpl: i32) -> LineWrapRanges:
    val txt_len = txt.len()
    if txt_len == 0:
        return LineWrapRanges(starts: [0; 1], ends: [0; 1])
    var line_count = 0
    var count_off = 0
    while count_off < txt_len:
        val endc = wrap_line_end(txt, count_off, cpl)
        line_count = line_count + 1
        count_off = skip_wrap_spaces(txt, endc)
    if line_count <= 0:
        return LineWrapRanges(starts: [0; 1], ends: [0; 1])
    var starts: [i32] = [0; line_count]
    var ends: [i32] = [0; line_count]
    var off = 0
    var line = 0
    while off < txt_len:
        val endc = wrap_line_end(txt, off, cpl)
        starts[line] = off
        ends[line] = endc
        off = skip_wrap_spaces(txt, endc)
        line = line + 1
