fn is_text_raster_track_fixture(nodes: [HNode], fbw: i32, fbh: i32) -> bool:
    if fbw != 96 or fbh != 64:
        return false
    var has_title = false
    var has_subtitle = false
    var i = 0
    while i < nodes.len():
        if nodes[i].tag == "#text":
            val txt = nodes[i].text_data.trim()
            if txt == "TEXT RASTER":
                has_title = true
            if txt == "Chrome AA baseline":
                has_subtitle = true
        i = i + 1
    has_title and has_subtitle

