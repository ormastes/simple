# ---------------------------------------------------------------------------
# CSS rules from <style> blocks
# ---------------------------------------------------------------------------

class Rules:
    group_parts: [[[text]]]
    decls: [text]

# Named transport for the three parallel rule-scan arrays. Returning these as
# an anonymous [[text]] loses the inner RuntimeArray identity in native code.
class CssRuleScan:
    selectors: [text]
    declarations: [text]
    wrappers: [text]

class RuleBuckets:
    id_keys: [text]
    id_rules: [[i32]]
    class_keys: [text]
    class_rules: [[i32]]
    tag_keys: [text]
    tag_rules: [[i32]]
    fallback_rules: [i32]
    # O(1) key->index lookups for style_rule_candidates. build_rule_buckets already
    # builds these dicts while bucketing rules; without carrying them forward,
    # style_rule_candidates fell back to text_key_index's O(distinct-keys) linear
    # scan per node lookup, reproducing the same quadratic shape build_rule_buckets
    # itself was fixed for (WEB-2) -- O(nodes x distinct-keys) overall.
    id_key_dict: Dict<text, i32>
    class_key_dict: Dict<text, i32>
    tag_key_dict: Dict<text, i32>

# Byte-array CSS structural scanners. The embedded stylesheet is ~290 KB, so
# char_at-based scanning was O(n^2) (each char_at is O(index) on UTF-8 text).
# The CSS is ASCII, so a one-time byte array gives O(1) indexed access and turns
# every structural scan (brace find, matching-close, selector probe) into O(n).
fn css_bytes_find(cb: [i64], n: i32, ch: i64, from: i32) -> i32:
    var i = if from < 0: 0 else: from
    while i < n:
        if cb[i] == ch:
            return i
        i = i + 1
    -1

fn css_bytes_match_close(cb: [i64], n: i32, open: i32) -> i32:
    var depth = 1
    var i = open + 1
    while i < n:
        val c = cb[i]
        if c == 123:
            depth = depth + 1
        elif c == 125:
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    -1

# True if cb[start, end) trimmed of ASCII whitespace equals `target`.
fn css_bytes_trimmed_eq(cb: [i64], start: i32, end: i32, target: text) -> bool:
    var a = start
    var b = end
    while a < b and (cb[a] == 32 or cb[a] == 9 or cb[a] == 10 or cb[a] == 13):
        a = a + 1
    while b > a and (cb[b - 1] == 32 or cb[b - 1] == 9 or cb[b - 1] == 10 or cb[b - 1] == 13):
        b = b - 1
    val tb = target.bytes()
    val tn = tb.len() as i32
    if b - a != tn:
        return false
    var i = 0
    while i < tn:
        if cb[a + i] != tb[i]:
            return false
        i = i + 1
    true

# count chars (non-continuation bytes) in cb[from..to)
fn _cb_chars_between(cb: [i64], from: i32, to: i32) -> i32:
    var n = 0
    var i = from
    while i < to:
        val c = cb[i]
        if c < 128 or c >= 192:
            n = n + 1
        i = i + 1
    n

fn _css_collect_custom_props(css: text) -> text:
    # Collect --name: value pairs from :root { } blocks.
    # Returns a compact string of "--name:value\n" entries.
    #
    # `:root` blocks are few (theme + a handful of variants), so locate each
    # one with the native substring search (`find_from`) instead of walking
    # the whole ~336KB stylesheet one byte at a time in interpreted Simple —
    # the byte-array walk cost ~6.6s per frame on a realistic theme sheet
    # (measured), because each interpreted `cb[i]` element read over 336K
    # entries is ~1us. Native search + a single small-body substring per
    # `:root` block is O(occurrences), microseconds in practice. Semantics are
    # preserved: a `:root` match counts only when the text between it and the
    # opening brace is whitespace (a standalone `:root` selector, exactly what
    # `css_bytes_trimmed_eq(..., ":root")` accepted before).
    var entries: [text] = [""; 400]
    var entry_i = 0
    var pos = 0
    var guard = 0
    while guard < 200:
        guard = guard + 1
        val rp = find_from(css, ":root", pos)
        if rp < 0:
            break
        val brace = find_from(css, "{", rp + 5)
        if brace < 0:
            break
        val between = css.substring(rp + 5, brace)
        if between.trim() != "":
            # `:root` was part of a larger selector (e.g. `:root.dark`); skip it.
            pos = rp + 5
        else:
            val close = find_from(css, "}", brace)
            if close < 0:
                break
            val body = css.substring(brace + 1, close)
            val body_len = body.len()
            var bp: i64 = 0
            var bg = 0
            while bp < body_len and bg < 400:
                bg = bg + 1
                val dd = find_from(body, "--", bp)
                if dd < 0:
                    break
                val colon = find_from(body, ":", dd)
                if colon < 0:
                    break
                val semi = find_from(body, ";", colon)
                val name = body.substring(dd, colon).trim()
                var val_end = semi
                if val_end < 0:
                    val_end = body_len
                val prop_val = body.substring(colon + 1, val_end).trim()
                if name.len() > 2 and entry_i < entries.len():
                    entries[entry_i] = name + ":" + prop_val + "\n"
                    entry_i = entry_i + 1
                bp = if semi >= 0: semi + 1 else: body_len
            pos = close + 1
    if entry_i == 0:
        return ""
    text_list_prefix(entries, entry_i).join("")

fn _css_resolve_vars(css: text, props: text) -> text:
    if props.len() == 0 or css.index_of("var(") < 0:
        return css
    var names: [text] = [""; 200]
    var values: [text] = [""; 200]
    var prop_count = 0
    val props_len = props.len()
    var pp: i64 = 0
    var pg = 0
    while pp < props_len and pg < 200:
        pg = pg + 1
        val nl = find_from(props, "\n", pp)
        var line_end = nl
        if line_end < 0:
            line_end = props_len
        val line = props.substring(pp, line_end).trim()
        val lc = line.index_of(":")
        if lc > 0 and prop_count < names.len():
            names[prop_count] = line.substring(0, lc).trim()
            values[prop_count] = line.substring(lc + 1, line.len()).trim()
            prop_count = prop_count + 1
        pp = if nl >= 0: nl + 1 else: props_len
    if prop_count == 0:
        return css
    var chunks: [text] = [""; 801]
    var chunk_count = 0
    val css_len = css.len()
    var scan = 0
    var vg = 0
    while scan < css_len and vg < 400:
        vg = vg + 1
        val open = find_from(css, "var(", scan)
        if open < 0:
            break
        # Match the closing paren by depth: var() args may nest more var()/
        # calc() parens, so the first ")" is not necessarily the close.
        var depth = 1
        var k = open + 4
        while k < css_len and depth > 0:
            if css[k] == "(":
                depth = depth + 1
            elif css[k] == ")":
                depth = depth - 1
            k = k + 1
        if depth != 0:
            break
        val close = k - 1
        if chunk_count + 2 >= chunks.len():
            break
        # Split "--name, fallback" at the first TOP-LEVEL comma; the fallback
        # itself may be another var() and is resolved recursively per spec.
        val inner = css.substring(open + 4, close)
        var cdepth = 0
        var comma = -1
        var m = 0
        val inner_len = inner.len()
        while m < inner_len:
            val ch = inner[m]
            if ch == "(":
                cdepth = cdepth + 1
            elif ch == ")":
                cdepth = cdepth - 1
            elif ch == "," and cdepth == 0:
                comma = m
                break
            m = m + 1
        val prop_name = (if comma >= 0: inner.substring(0, comma) else: inner).trim()
        val prop_idx = text_key_index_count(names, prop_name, prop_count)
        chunks[chunk_count] = css.substring(scan, open)
        chunk_count = chunk_count + 1
        if prop_idx >= 0:
            chunks[chunk_count] = values[prop_idx]
        elif comma >= 0:
            chunks[chunk_count] = _css_resolve_vars(inner.substring(comma + 1, inner_len).trim(), props)
        else:
            chunks[chunk_count] = css.substring(open, close + 1)
        chunk_count = chunk_count + 1
        scan = close + 1
    if scan < css_len and chunk_count < chunks.len():
        chunks[chunk_count] = css.substring(scan, css_len)
        chunk_count = chunk_count + 1
    text_list_prefix(chunks, chunk_count).join("")

# Evaluate one comma-group of a @media prelude: every parenthesized term must
# pass. Width terms compare against the viewport; any unknown feature term
# (prefers-*, forced-colors, resolution, ...) fails its group, matching a UA
# with no such preference set (Chrome headless defaults).
fn _media_group_applies(group: text, viewport_w: i32) -> bool:
    var ok = true
    var i = 0
    val n = group.len()
    while i < n and ok:
        val lp = find_from(group, "(", i)
        if lp < 0:
            break
        val rp = find_from(group, ")", lp)
        if rp < 0:
            ok = false
            break
        val term = group.substring(lp + 1, rp).trim().lower()
        val colon = text_index_of(term, ":")
        if colon < 0:
            ok = false
        else:
            val feat = term.substring(0, colon).trim()
            val px = parse_int(term.substring(colon + 1, term.len()))
            if feat == "max-width":
                ok = viewport_w <= px
            elif feat == "min-width":
                ok = viewport_w >= px
            else:
                ok = false
        i = rp + 1
    ok

# Evaluate a @media prelude ("@media (max-width: 599px), print") against the
# viewport width. Comma groups OR together. viewport_w < 0 = legacy mode:
# every media block applies (the pre-media-support behavior).
fn _media_prelude_applies(prelude: text, viewport_w: i32) -> bool:
    if viewport_w < 0:
        return true
    val cond = prelude.substring(6, prelude.len()).trim()
    if cond.len() == 0:
        return true
    val groups = split_top_level_commas(cond)
    val gc = groups.len()
    var gi = 0
    while gi < gc:
        if _media_group_applies(groups[gi], viewport_w):
            return true
        gi = gi + 1
    false

fn extract_css(html: text) -> Rules:
    # Legacy entry: media blocks all apply (no viewport context).
    extract_css_vw(html, -1)

# Pure-Simple rule-boundary scanner. Returns 3 parallel text arrays in
# document order: [sel_text, decl_text, wrapper_prelude] — trimmed selector /
# declaration text per candidate rule; wrapper_prelude is "" for
# unconditional rules or the "@media (...)" prelude for rules nested in a
# depth-0 @-wrapper.
#
# It must NOT slice the ~336KB stylesheet with `css.substring()` / `css[a:b]`
# per rule: under this interpreter both re-collect the ENTIRE receiver string
# on every call (measured: ~0.7ms per call on a 262KB string → O(rules *
# total_css_len), the multi-second/minute quadratic that hung the browser's
# first frame). Instead it splits the sheet ONCE on "{" (native, O(n)), then
# splits each small segment on "}" (native, O(segment)) and only ever slices
# those small pieces — genuine O(total_css_len). A brace-depth stack tracks
# @-wrappers so depth-1 rules carry their wrapper prelude, matching the
# depth-0-rule / depth-1-child-of-@-wrapper emission the layout cascade
# expects.
fn _css_scan_rules_simple(css: text) -> CssRuleScan:
    val cap = 6000
    var sels: [text] = [""; cap]
    var decls: [text] = [""; cap]
    var wraps: [text] = [""; cap]
    var out = 0
    # Brace-depth stack of opener (selector / @-prelude) strings.
    var stack: [text] = [""; 64]
    var depth = 0
    val parts = css.split("{")
    val np = parts.len()
    if np == 0:
        return CssRuleScan(selectors: [], declarations: [], wrappers: [])
    var sel_pending: text = parts[0]
    var k = 1
    while k < np:
        val opener = sel_pending.trim()
        # This "{" opens a block whose selector / prelude is `opener`.
        if depth < stack.len():
            stack[depth] = opener
        depth = depth + 1
        val seg: text = parts[k]
        val subs: [text] = seg.split("}")
        val nsubs = subs.len()
        # `subs[0]` is the just-opened block's body up to its first "}". If the
        # block is a leaf rule (opener not an @-wrapper) with a non-empty
        # selector, emit it. Its wrapper prelude is the nearest enclosing
        # @-ancestor, if any (depth-1 child of a depth-0 @-wrapper).
        val is_wrapper = opener.starts_with("@")
        if (not is_wrapper) and opener.len() > 0 and out < cap:
            var wrapper = ""
            if depth >= 2 and (depth - 2) < stack.len():
                val parent: text = stack[depth - 2]
                if parent.starts_with("@"):
                    wrapper = parent
            sels[out] = opener
            decls[out] = subs[0].trim()
            wraps[out] = wrapper
            out = out + 1
        # Each "}" in `seg` closes one open block; pop that many.
        var closes = nsubs - 1
        while closes > 0 and depth > 0:
            depth = depth - 1
            closes = closes - 1
        # The trailing piece after the last "}" is the next block's selector.
        sel_pending = if nsubs > 0: subs[nsubs - 1] else: ""
        k = k + 1
    CssRuleScan(
        selectors: text_list_prefix(sels, out),
        declarations: text_list_prefix(decls, out),
        wrappers: text_list_prefix(wraps, out)
    )

fn extract_css_vw(html: text, viewport_w: i32, trace_stages: bool = false) -> Rules:
    # First pass: collect CSS custom properties from all :root blocks
    var custom_prop_parts: [text] = [""; 100]
    var custom_prop_count = 0
    var pre_pos = 0
    var pre_guard = 0
    while pre_guard < 100:
        pre_guard = pre_guard + 1
        val pre_sp = find_from(html, "<style", pre_pos)
        if pre_sp < 0:
            break
        val pre_open = find_from(html, ">", pre_sp)
        if pre_open < 0:
            break
        val pre_close = find_from(html, "</style", pre_open)
        if pre_close < 0:
            break
        val pre_css = html.substring(pre_open + 1, pre_close)
        val collected_props = _css_collect_custom_props(pre_css)
        if collected_props.len() > 0 and custom_prop_count < custom_prop_parts.len():
            custom_prop_parts[custom_prop_count] = collected_props
            custom_prop_count = custom_prop_count + 1
        pre_pos = pre_close + 1
    val custom_props = if custom_prop_count == 0: "" else: custom_prop_parts.join("")
    var group_parts: [[[text]]] = []
    var decls: [text] = []
    var pos = 0
    var guard = 0
    while guard < 1000:
        guard = guard + 1
        val sp = find_from(html, "<style", pos)
        if sp < 0:
            break
        val open = find_from(html, ">", sp)
        if open < 0:
            break
        val close = find_from(html, "</style", open)
        if close < 0:
            break
        val css_raw = html.substring(open + 1, close)
        val css = _css_resolve_vars(css_raw, custom_props)
        # Rule-boundary scan: split the sheet ONCE on "{"/"}" natively rather
        # than walking it a character at a time in interpreted Simple (which
        # cost seconds-to-minutes on a realistic theme sheet). See
        # `_css_scan_rules_simple`. Selector-group splitting, @media condition
        # evaluation, and CSS-variable substitution stay in Simple below.
        val bounds: CssRuleScan = _css_scan_rules_simple(css)
        val b_sel_text: [text] = bounds.selectors
        val b_decl_text: [text] = bounds.declarations
        val b_wrapper: [text] = bounds.wrappers
        val candidate_count = b_sel_text.len()
        if trace_stages:
            print "[layout-trace] css_scan candidates={candidate_count} declarations={b_decl_text.len()} wrappers={b_wrapper.len()}"
            var trace_rule_i = 0
            while trace_rule_i < candidate_count:
                print "[layout-trace] css_scan rule={trace_rule_i} selector={b_sel_text[trace_rule_i]} decl_len={b_decl_text[trace_rule_i].len()}"
                trace_rule_i = trace_rule_i + 1
        var block_group_parts: [[[text]]] = [[[]]; candidate_count]
        var block_decls: [text] = [""; candidate_count]
        var out_i = 0
        var bi = 0
        while bi < candidate_count:
            val wrapper_prelude: text = b_wrapper[bi]
            var include = true
            if wrapper_prelude.len() > 0 and wrapper_prelude.lower().starts_with("@media"):
                # @media wrappers apply only when their condition holds for
                # the viewport; other @-wrappers (@layer, @supports) keep
                # emitting their children unconditionally (wrapper_prelude
                # not starting with "@media" falls through with include=true).
                include = _media_prelude_applies(wrapper_prelude, viewport_w)
            if include:
                val sel: text = b_sel_text[bi]
                val decl: text = b_decl_text[bi]
                val rule_groups = split_selector_groups(sel)
                block_group_parts[out_i] = split_selector_group_parts(rule_groups)
                block_decls[out_i] = decl
                out_i = out_i + 1
            bi = bi + 1
        group_parts = group_parts + group_parts_list_prefix(block_group_parts, out_i)
        decls = decls + text_list_prefix(block_decls, out_i)
        pos = close + 1
    val result = Rules(group_parts: group_parts, decls: decls)
    if trace_stages:
        print "[layout-trace] css_result rules={result.group_parts.len()} decls={result.decls.len()}"
    result

fn unquote_css_attr_value(raw: text) -> text:
    val v = raw.trim()
    if v.len() >= 2:
        val first = v.char_at(0)
        val last = v.char_at(v.len() - 1)
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return v.substring(1, v.len() - 1)
    v

fn attr_selector_matches(attrs: text, expr: text) -> bool:
    val raw = expr.trim()
    if raw.len() == 0:
        return false
    val prefix_op = text_index_of(raw, "^=")
    if prefix_op >= 0:
        val name = raw.substring(0, prefix_op).trim()
        val want = unquote_css_attr_value(raw.substring(prefix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.starts_with(want)
    val suffix_op = text_index_of(raw, "$=")
    if suffix_op >= 0:
        val name = raw.substring(0, suffix_op).trim()
        val want = unquote_css_attr_value(raw.substring(suffix_op + 2, raw.len()))
        val actual = attr_value(attrs, name)
        return actual.len() > 0 and actual.ends_with(want)
    val exact_op = text_index_of(raw, "=")
    if exact_op >= 0:
        val name = raw.substring(0, exact_op).trim()
        val want = unquote_css_attr_value(raw.substring(exact_op + 1, raw.len()))
        return attr_value(attrs, name) == want
    attr_value(attrs, raw).len() > 0

fn class_words_has(words: [text], want: text) -> bool:
    var i = 0
    val word_count = words.len()
    while i < word_count:
        if words[i] == want:
            return true
        i = i + 1
    false

fn base_selector_matches(base: text, tag: text, cls: text, class_words: [text], id: text) -> bool:
    if base.len() == 0:
        return true
    # universal selector (e.g. the `*, *::before, *::after` margin/padding reset)
    if base == "*":
        return true
    if base.char_at(0) == ".":
        val want = base.substring(1, base.len())
        return class_has_all(class_words, want)
    if base.char_at(0) == "#":
        return id == base.substring(1, base.len())
    val hash = text_index_of(base, "#")
    if hash > 0:
        # tag#id or tag#id.class
        val t = base.substring(0, hash)
        val dot2 = find_from(base, ".", hash + 1)
        if dot2 >= 0:
            val want_id = base.substring(hash + 1, dot2)
            val want_cls = base.substring(dot2 + 1, base.len())
            return t == tag and id == want_id and class_has_all(class_words, want_cls)
        return t == tag and id == base.substring(hash + 1, base.len())
    val dot = text_index_of(base, ".")
    if dot >= 0:
        val t = base.substring(0, dot)
        val want = base.substring(dot + 1, base.len())
        return t == tag and class_has_all(class_words, want)
    base == tag

# does a single simple selector match this node? (rightmost token only)
# Extract the pseudo-class name from a selector part (returns "" if none).
# e.g. "div:not(.x)" -> "not", ".card:first-child" -> "first-child"
fn _pseudo_name(sel: text) -> text:
    val colon = text_index_of(sel, ":")
    if colon < 0:
        return ""
    val after = sel.substring(colon + 1, sel.len())
    val paren = text_index_of(after, "(")
    if paren >= 0:
        return after.substring(0, paren)
    # strip trailing non-identifier chars (e.g. nothing after plain pseudo)
    after

# Extract the argument inside a functional pseudo (returns "" if not functional).
# e.g. "div:not(.x, #y)" -> ".x, #y"
fn _pseudo_arg(sel: text) -> text:
    val colon = text_index_of(sel, ":")
    if colon < 0:
        return ""
    val after = sel.substring(colon + 1, sel.len())
    val paren_open = text_index_of(after, "(")
    if paren_open < 0:
        return ""
    val paren_close = text_index_of(after, ")")
    if paren_close <= paren_open:
        return ""
    after.substring(paren_open + 1, paren_close).trim()

# Check :not(), :is(), :where() pseudo-class against this element's base properties.
# Returns true if the selector pseudo condition is satisfied.
fn _pseudo_list_matches(pseudo: text, arg: text, tag: text, cls: text, class_words: [text], id: text, attrs: text) -> bool:
    # Split arg on commas (not inside parens) to get individual options
    var options: [text] = [""; 16]
    var opt_count = 0
    var depth = 0
    var i = 0
    val arg_len = arg.len()
    var option_start = 0
    while i < arg_len:
        val ch = arg.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == "," and depth == 0:
            if opt_count < 16:
                options[opt_count] = arg.substring(option_start, i).trim()
                opt_count = opt_count + 1
            option_start = i + 1
        i = i + 1
    val tail = arg.substring(option_start, arg_len).trim()
    if tail.len() > 0 and opt_count < 16:
        options[opt_count] = tail
        opt_count = opt_count + 1
    if pseudo == "not":
        # :not(sel, ...) — match if NONE of the options match
        var j = 0
        while j < opt_count:
            val opt = options[j]
            if opt.len() > 0 and simple_match(opt, tag, cls, class_words, id, attrs):
                return false
            j = j + 1
        return true
    if pseudo == "is" or pseudo == "where":
        # :is(sel, ...) / :where(sel, ...) — match if ANY option matches
        var j = 0
        while j < opt_count:
            val opt = options[j]
            if opt.len() > 0 and simple_match(opt, tag, cls, class_words, id, attrs):
                return true
            j = j + 1
        return false
    # Unknown pseudo-class: treat as non-matching for reject tests, but allow pass-through
    # for unknown structural pseudos (handled in full context).
    false

fn simple_match(sel: text, tag: text, cls: text, class_words: [text], id: text, attrs: text) -> bool:
    if sel.len() == 0:
        return false
    # Pseudo-element selectors (::before, ::after, ::selection, ...) target
    # boxes this engine does not render; they must never match the host
    # element (previously "body::before" applied its decls to <body> itself).
    if text_index_of(sel, "::") >= 0:
        return false
    # :root matches only the root element; honor its attribute filter so
    # theme-variant blocks like :root[data-wm-transparency=off] apply only
    # when the <html> tag actually carries that attribute. Previously the
    # empty base before ":" matched EVERY element, so every variant applied
    # at once (dark transparency-off backgrounds leaked into light themes).
    if sel.starts_with(":root"):
        if tag != "html":
            return false
        val root_rest = sel.substring(5, sel.len())
        if root_rest.len() == 0:
            return true
        if root_rest.starts_with("["):
            val root_close = text_index_of(root_rest, "]")
            if root_close > 0:
                return attr_selector_matches(attrs, root_rest.substring(1, root_close))
            return false
        return true
    # Split off the base (before the first colon at depth 0)
    var base = sel
    val colon = text_index_of(base, ":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_start = text_index_of(base, "[")
    if attr_start >= 0:
        val attr_end = text_index_of(base, "]")
        if attr_end < attr_start:
            return false
        val node_base = base.substring(0, attr_start).trim()
        val expr = base.substring(attr_start + 1, attr_end)
        if not (base_selector_matches(node_base, tag, cls, class_words, id) and attr_selector_matches(attrs, expr)):
            return false
    else:
        if not base_selector_matches(base, tag, cls, class_words, id):
            return false
    # Now check pseudo-classes (at the current element level, no node-position context)
    if colon < 0:
        return true
    val pseudo = _pseudo_name(sel)
    val arg = _pseudo_arg(sel)
    if pseudo == "not" or pseudo == "is" or pseudo == "where":
        return _pseudo_list_matches(pseudo, arg, tag, cls, class_words, id, attrs)
    # Interaction/UA-state pseudo-classes can never be satisfied by a static
    # render: this engine has no pointer, focus, or form state. Previously they
    # fell through to the structural pass-through below and matched EVERY
    # element, so `.widget-button:disabled { opacity: 0.4 }` washed all accent
    # buttons toward white and `:hover` transforms/opacities applied at rest.
    if _is_interaction_state_pseudo(pseudo, attrs):
        return false
    # Position-based pseudos (first-child, last-child, only-child, nth-child, empty, has)
    # require full node context — return true here (base matched); the full context check
    # in simple_match_with_ctx will apply the real constraint.
    true

# Interaction/UA-state pseudo-classes a static renderer must treat as
# unsatisfied. `:disabled` honors an actual disabled attribute when present.
fn _is_interaction_state_pseudo(pseudo: text, attrs: text) -> bool:
    if pseudo == "hover":
        return true
    if pseudo == "active":
        return true
    if pseudo == "focus":
        return true
    if pseudo == "focus-visible":
        return true
    if pseudo == "focus-within":
        return true
    if pseudo == "visited":
        return true
    if pseudo == "target":
        return true
    if pseudo == "checked":
        return true
    if pseudo == "placeholder-shown":
        return true
    if pseudo == "autofill":
        return true
    if pseudo == "disabled":
        return not attrs.contains("disabled")
    false

fn class_has_all(words: [text], wants: text) -> bool:
    val wants_len = wants.len()
    var start = 0
    var i = 0
    while i <= wants_len:
        if i == wants_len or wants.char_at(i) == ".":
            if i > start:
                val want = wants.substring(start, i)
                if not class_words_has(words, want):
                    return false
            start = i + 1
        i = i + 1
    true

fn class_contains(cls: text, want: text) -> bool:
    cls.contains(want)

# Count element-type siblings of node[idx] up to and including idx (1-based child position).
fn _child_position(ctx: SelectorContext, idx: i32) -> i32:
    if idx < 0 or idx >= ctx.element_position.len():
        return 1
    ctx.element_position[idx]

# Count total element-type children of parent of node[idx].
fn _sibling_count(ctx: SelectorContext, idx: i32) -> i32:
    if idx < 0 or idx >= ctx.element_sibling_count.len():
        return 1
    ctx.element_sibling_count[idx]

# Evaluate :nth-child(expr) where expr is odd, even, or an+b / n+b / b.
fn _nth_child_matches(expr: text, pos: i32) -> bool:
    val e = expr.trim()
    if e == "odd":
        return (pos % 2) == 1
    if e == "even":
        return (pos % 2) == 0
    # Check for "an+b" or "n+b" or just "b"
    val n_idx = text_index_of(e, "n")
    if n_idx >= 0:
        val a_str = e.substring(0, n_idx).trim()
        val a = if a_str == "" or a_str == "+": 1 elif a_str == "-": -1 else: parse_int(a_str)
        val after_n = e.substring(n_idx + 1, e.len()).trim()
        val b = if after_n.len() == 0: 0 else: parse_int(after_n)
        if a == 0:
            return pos == b
        val rem = pos - b
        if rem < 0:
            return false
        return (rem % a) == 0
    # plain number
    parse_int(e) == pos

# Check whether any node that is a child of parent_idx matches simple selector sel_arg.
fn _has_direct_child_match(nodes: [HNode], ctx: SelectorContext, parent_idx: i32, sel_arg: text) -> bool:
    if parent_idx < 0 or parent_idx >= ctx.child_index.first_child.len():
        return false
    var c = ctx.child_index.first_child[parent_idx]
    while c >= 0:
        val nd = nodes[c]
        if nd.tag != "#text":
            if simple_match(sel_arg, nd.tag, nd.class_attr, nd.class_words, nd.id_attr, nd.attrs_raw):
                return true
        c = ctx.child_index.next_sibling[c]
    false

# Check whether any descendant of node[idx] matches simple selector sel_arg.
fn _has_descendant_match(nodes: [HNode], ctx: SelectorContext, idx: i32, sel_arg: text) -> bool:
    if idx < 0 or idx >= ctx.child_index.first_child.len():
        return false
    val node_count = nodes.len()
    var stack: [i32] = [0; node_count]
    var stack_len = 0
    var c = ctx.child_index.first_child[idx]
    while c >= 0:
        stack[stack_len] = c
        stack_len = stack_len + 1
        c = ctx.child_index.next_sibling[c]
    while stack_len > 0:
        stack_len = stack_len - 1
        val cur = stack[stack_len]
        val nd = nodes[cur]
        if nd.tag != "#text":
            if simple_match(sel_arg, nd.tag, nd.class_attr, nd.class_words, nd.id_attr, nd.attrs_raw):
                return true
        c = ctx.child_index.first_child[cur]
        while c >= 0:
            stack[stack_len] = c
            stack_len = stack_len + 1
            c = ctx.child_index.next_sibling[c]
    false

# Check any :has() option (space-separated = descendant, "> .x" = direct child).
fn _has_option_matches(nodes: [HNode], ctx: SelectorContext, idx: i32, opt: text) -> bool:
    val trimmed = opt.trim()
    if trimmed.starts_with("> "):
        val child_sel = trimmed.substring(2, trimmed.len()).trim()
        return _has_direct_child_match(nodes, ctx, idx, child_sel)
    if trimmed == ">":
        return false
    _has_descendant_match(nodes, ctx, idx, trimmed)

# Check whether a node has any child element (non-text) or non-whitespace text children.
fn _node_is_empty(ctx: SelectorContext, idx: i32) -> bool:
    if idx < 0 or idx >= ctx.has_content_child.len():
        return true
    not ctx.has_content_child[idx]

# Full-context pseudo-class check. Called after simple_match() passes the base check.
# Returns true if all pseudo-class conditions on sel are satisfied given node context.
fn _pseudo_ctx_matches(sel: text, nodes: [HNode], ctx: SelectorContext, idx: i32) -> bool:
    val colon = text_index_of(sel, ":")
    if colon < 0:
        return true
    val pseudo = _pseudo_name(sel)
    val arg = _pseudo_arg(sel)
    if pseudo == "not" or pseudo == "is" or pseudo == "where":
        # Already handled in simple_match; return true here.
        return true
    if pseudo == "empty":
        return _node_is_empty(ctx, idx)
    if pseudo == "first-child":
        return _child_position(ctx, idx) == 1
    if pseudo == "last-child":
        val pos = _child_position(ctx, idx)
        val total = _sibling_count(ctx, idx)
        return pos == total
    if pseudo == "only-child":
        return _sibling_count(ctx, idx) == 1
    if pseudo == "nth-child":
        val pos = _child_position(ctx, idx)
        return _nth_child_matches(arg, pos)
    if pseudo == "has":
        # split arg on commas (depth-aware) to get :has(opt1, opt2, ...)
        var opts: [text] = [""; 8]
        var opt_count = 0
        var depth = 0
        var i = 0
        val arg_len = arg.len()
        var option_start = 0
        while i < arg_len:
            val ch = arg.char_at(i)
            if ch == "(":
                depth = depth + 1
            elif ch == ")":
                if depth > 0:
                    depth = depth - 1
            elif ch == "," and depth == 0:
                if opt_count < 8:
                    opts[opt_count] = arg.substring(option_start, i).trim()
                    opt_count = opt_count + 1
                option_start = i + 1
            i = i + 1
        val tail = arg.substring(option_start, arg_len).trim()
        if tail.len() > 0 and opt_count < 8:
            opts[opt_count] = tail
            opt_count = opt_count + 1
        var j = 0
        while j < opt_count:
            if _has_option_matches(nodes, ctx, idx, opts[j]):
                return true
            j = j + 1
        return false
    # Unknown pseudo — pass through (non-positional, already base-matched)
    true

# Full-context simple match: base match + pseudo-class positional check.
fn simple_match_ctx(sel: text, tag: text, cls: text, class_words: [text], id: text, attrs: text, nodes: [HNode], ctx: SelectorContext, idx: i32) -> bool:
    if not simple_match(sel, tag, cls, class_words, id, attrs):
        return false
    _pseudo_ctx_matches(sel, nodes, ctx, idx)

fn split_selector_groups(sel: text) -> [text]:
    var depth = 0
    var i = 0
    val sel_len = sel.len()
    var group_count = 0
    var group_start = 0
    while i < sel_len:
        val ch = sel.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == "," and depth == 0:
            group_count = group_count + 1
            group_start = i + 1
        i = i + 1
    if sel.substring(group_start, sel_len).trim().len() > 0:
        group_count = group_count + 1
    var groups: [text] = [""; group_count]
    depth = 0
    i = 0
    var group_i = 0
    group_start = 0
    while i < sel_len:
        val ch = sel.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == "," and depth == 0:
            groups[group_i] = sel.substring(group_start, i).trim()
            group_i = group_i + 1
            group_start = i + 1
        i = i + 1
    val tail = sel.substring(group_start, sel_len).trim()
    if tail.len() > 0:
        groups[group_i] = tail
    groups

fn normalize_child_combinators(group: text) -> text:
    var i = 0
    val group_len = group.len()
    var depth = 0
    var combinator_count = 0
    while i < group_len:
        val ch = group.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == ">" and depth == 0:
            combinator_count = combinator_count + 1
        i = i + 1
    if combinator_count == 0:
        return group.trim()
    val chunk_count = combinator_count * 2 + 1
    var chunks: [text] = [""; chunk_count]
    var chunk_i = 0
    var start = 0
    i = 0
    depth = 0
    while i < group_len:
        val ch = group.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == ">" and depth == 0:
            chunks[chunk_i] = group.substring(start, i)
            chunk_i = chunk_i + 1
            chunks[chunk_i] = " > "
            chunk_i = chunk_i + 1
            start = i + 1
        i = i + 1
    chunks[chunk_i] = group.substring(start, group_len)
    chunks.join("").trim()

fn selector_group_parts(group: text) -> [text]:
    # Split on spaces at depth-0 only: depth counts ( ) and [ ] so that spaces
    # inside :has(> .x) args and [attr='val with spaces'] are preserved.
    val normalized = normalize_child_combinators(group)
    val norm_len = normalized.len()
    # First pass: count tokens
    var token_count = 0
    var depth = 0
    var in_token = false
    var pi = 0
    while pi < norm_len:
        val ch = normalized.char_at(pi)
        if ch == "(" or ch == "[":
            depth = depth + 1
            if not in_token:
                token_count = token_count + 1
                in_token = true
        elif ch == ")" or ch == "]":
            if depth > 0:
                depth = depth - 1
        elif ch == " " and depth == 0:
            in_token = false
        else:
            if not in_token:
                token_count = token_count + 1
                in_token = true
        pi = pi + 1
    if token_count == 0:
        return [""]
    var parts: [text] = [""; token_count]
    var part_i = 0
    depth = 0
    in_token = false
    var token_start = -1
    pi = 0
    while pi < norm_len:
        val ch = normalized.char_at(pi)
        if ch == "(" or ch == "[":
            if not in_token:
                token_start = pi
            depth = depth + 1
            in_token = true
        elif ch == ")" or ch == "]":
            if not in_token:
                token_start = pi
            if depth > 0:
                depth = depth - 1
            in_token = true
        elif ch == " " and depth == 0:
            if in_token:
                if part_i < token_count:
                    parts[part_i] = normalized.substring(token_start, pi).trim()
                    part_i = part_i + 1
                token_start = -1
                in_token = false
        else:
            if not in_token:
                token_start = pi
            in_token = true
        pi = pi + 1
    if token_start >= 0 and part_i < token_count:
        val tail = normalized.substring(token_start, norm_len).trim()
        if tail.len() > 0:
            parts[part_i] = tail
    parts

fn split_selector_group_parts(groups: [text]) -> [[text]]:
    val group_count = groups.len()
    var parts: [[text]] = [[]; group_count]
    var i = 0
    while i < group_count:
        parts[i] = selector_group_parts(groups[i])
        i = i + 1
    parts

fn selector_rightmost_part(parts: [text]) -> text:
    var right = parts.len() - 1
    while right >= 0:
        val part = parts[right]
        if part.len() > 0 and part != ">":
            return part
        right = right - 1
    ""

fn selector_bucket_base(part: text) -> text:
    var base = part
    val colon = text_index_of(base, ":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_start = text_index_of(base, "[")
    if attr_start >= 0:
        base = base.substring(0, attr_start).trim()
    base

fn selector_bucket_kind(part: text) -> text:
    val base = selector_bucket_base(part)
    selector_bucket_kind_from_base(base)

fn selector_bucket_kind_from_base(base: text) -> text:
    if base.len() == 0 or base == "*":
        return "fallback"
    if base.char_at(0) == "#":
        return "id"
    if base.char_at(0) == ".":
        return "class"
    # tag#id compound: bucket as "id" so rules fire when node has that id
    val hash = text_index_of(base, "#")
    if hash > 0:
        return "id"
    if text_index_of(base, ".") >= 0:
        return "class"
    "tag"

fn selector_bucket_value(part: text) -> text:
    val base = selector_bucket_base(part)
    selector_bucket_value_from_base(base)

fn selector_bucket_value_from_base(base: text) -> text:
    if base.len() == 0:
        return ""
    val first = base.char_at(0)
    if first == "#" or first == ".":
        val dot = find_from(base, ".", 1)
        if dot >= 0:
            return base.substring(1, dot)
        return base.substring(1, base.len())
    # tag#id compound: return the id part as the bucket key
    val hash = text_index_of(base, "#")
    if hash > 0:
        val dot2 = find_from(base, ".", hash + 1)
        if dot2 >= 0:
            return base.substring(hash + 1, dot2)
        return base.substring(hash + 1, base.len())
    val dot = text_index_of(base, ".")
    if dot >= 0:
        val next_dot = find_from(base, ".", dot + 1)
        if next_dot >= 0:
            return base.substring(dot + 1, next_dot)
        return base.substring(dot + 1, base.len())
    base

fn text_key_index_count(keys: [text], key: text, key_count: i32) -> i32:
    var i = 0
    while i < key_count:
        if keys[i] == key:
            return i
        i = i + 1
    -1

fn text_list_prefix(values: [text], count: i32) -> [text]:
    var out: [text] = [""; count]
    var i = 0
    while i < count:
        out[i] = values[i]
        i = i + 1
    out

fn group_parts_list_prefix(values: [[[text]]], count: i32) -> [[[text]]]:
    var out: [[[text]]] = [[[]]; count]
    var i = 0
    while i < count:
        out[i] = values[i]
        i = i + 1
    out

fn i32_list_prefix(values: [i32], count: i32) -> [i32]:
    var out: [i32] = [0; count]
    var i = 0
    while i < count:
        out[i] = values[i]
        i = i + 1
    out

fn text_seen_before(values: [text], end_index: i32, value: text) -> bool:
    var i = 0
    while i < end_index:
        if values[i] == value:
            return true
        i = i + 1
    false

fn merge_two_sorted_rule_lists_unique(left: [i32], right: [i32]) -> [i32]:
    val left_count = left.len()
    val right_count = right.len()
    if left_count == 0:
        return right
    if right_count == 0:
        return left
    var li = 0
    var ri = 0
    var out_count = 0
    var last = -1
    var has_last = false
    while li < left_count or ri < right_count:
        var next = 0
        if ri >= right_count or (li < left_count and left[li] <= right[ri]):
            next = left[li]
            li = li + 1
        else:
            next = right[ri]
            ri = ri + 1
        if not has_last or next != last:
            out_count = out_count + 1
            last = next
            has_last = true
    var out: [i32] = [0; out_count]
    li = 0
    ri = 0
    var oi = 0
    last = -1
    has_last = false
    while li < left_count or ri < right_count:
        var next = 0
        if ri >= right_count or (li < left_count and left[li] <= right[ri]):
            next = left[li]
            li = li + 1
        else:
            next = right[ri]
            ri = ri + 1
        if not has_last or next != last:
            out[oi] = next
            oi = oi + 1
            last = next
            has_last = true
    out

fn merge_sorted_rule_lists_unique_count(lists: [[i32]], list_count: i32) -> [i32]:
    if list_count == 0:
        return []
    if list_count == 1:
        return lists[0]
    if list_count == 2:
        return merge_two_sorted_rule_lists_unique(lists[0], lists[1])
    var positions: [i32] = [0; list_count]
    var out_count = 0
    var last = -1
    var has_last = false
    var done = false
    while not done:
        var min_rule = 2147483647
        var found = false
        var list_i = 0
        while list_i < list_count:
            val rules = lists[list_i]
            val rule_count = rules.len()
            var pos = positions[list_i]
            while pos < rule_count and has_last and rules[pos] == last:
                pos = pos + 1
            positions[list_i] = pos
            if pos < rule_count and rules[pos] < min_rule:
                min_rule = rules[pos]
                found = true
            list_i = list_i + 1
        if found:
            out_count = out_count + 1
            last = min_rule
            has_last = true
        else:
            done = true
    positions = [0; list_count]
    var out: [i32] = [0; out_count]
    var out_i = 0
    last = -1
    has_last = false
    done = false
    while not done:
        var min_rule = 2147483647
        var found = false
        var list_i = 0
        while list_i < list_count:
            val rules = lists[list_i]
            val rule_count = rules.len()
            var pos = positions[list_i]
            while pos < rule_count and has_last and rules[pos] == last:
                pos = pos + 1
            positions[list_i] = pos
            if pos < rule_count and rules[pos] < min_rule:
                min_rule = rules[pos]
                found = true
            list_i = list_i + 1
        if found:
            out[out_i] = min_rule
            out_i = out_i + 1
            last = min_rule
            has_last = true
        else:
            done = true
    out

fn rule_lists_from_counts(counts: [i32]) -> [[i32]]:
    val count_len = counts.len()
    var lists: [[i32]] = [[]; count_len]
    var i = 0
    while i < count_len:
        lists[i] = [0; counts[i]]
        i = i + 1
    lists

fn dict_key_index_count(d: Dict<text, i32>, keys: [text], key: text, count: i32) -> i32:
    if d.has(key):
        return d[key]
    # ponytail: linear fallback keeps Simple-core correct until its Dict ABI is available; hosted runtimes stay O(1).
    text_key_index_count(keys, key, count)

fn build_rule_buckets(rules: Rules, trace_stages: bool = false) -> RuleBuckets:
    var bucket_capacity = 0
    var cr = 0
    val rule_count = rules.group_parts.len()
    if trace_stages:
        print "[layout-trace] bucket_stage=count-start rules={rule_count}"
    while cr < rule_count:
        bucket_capacity = bucket_capacity + rules.group_parts[cr].len()
        cr = cr + 1
    if trace_stages:
        print "[layout-trace] bucket_stage=count-ready capacity={bucket_capacity}"
    var id_keys_raw: [text] = [""; bucket_capacity]
    var id_counts_raw: [i32] = [0; bucket_capacity]
    var id_key_count = 0
    var class_keys_raw: [text] = [""; bucket_capacity]
    var class_counts_raw: [i32] = [0; bucket_capacity]
    var class_key_count = 0
    var tag_keys_raw: [text] = [""; bucket_capacity]
    var tag_counts_raw: [i32] = [0; bucket_capacity]
    var tag_key_count = 0
    var entry_kinds: [i32] = [0; bucket_capacity]
    var entry_buckets: [i32] = [0; bucket_capacity]
    var entry_rules: [i32] = [0; bucket_capacity]
    var entry_count = 0
    var fallback_count = 0
    var id_key_dict: Dict<text, i32> = {}
    var class_key_dict: Dict<text, i32> = {}
    var tag_key_dict: Dict<text, i32> = {}
    if trace_stages:
        print "[layout-trace] bucket_stage=storage-ready"
    var r = 0
    while r < rule_count:
        val groups = rules.group_parts[r]
        var g = 0
        val group_count = groups.len()
        if trace_stages:
            print "[layout-trace] bucket_stage=rule-start rule={r} groups={group_count}"
        while g < group_count:
            val right = selector_rightmost_part(groups[g])
            val base = selector_bucket_base(right)
            val kind = selector_bucket_kind_from_base(base)
            val key = selector_bucket_value_from_base(base)
            if kind == "id" and key.len() > 0:
                var idx = dict_key_index_count(id_key_dict, id_keys_raw, key, id_key_count)
                if idx < 0:
                    idx = id_key_count
                    id_keys_raw[idx] = key
                    id_key_count = id_key_count + 1
                    id_key_dict[key] = idx
                id_counts_raw[idx] = id_counts_raw[idx] + 1
                entry_kinds[entry_count] = 1
                entry_buckets[entry_count] = idx
                entry_rules[entry_count] = r
                entry_count = entry_count + 1
            elif kind == "class" and key.len() > 0:
                var idx = dict_key_index_count(class_key_dict, class_keys_raw, key, class_key_count)
                if idx < 0:
                    idx = class_key_count
                    class_keys_raw[idx] = key
                    class_key_count = class_key_count + 1
                    class_key_dict[key] = idx
                class_counts_raw[idx] = class_counts_raw[idx] + 1
                entry_kinds[entry_count] = 2
                entry_buckets[entry_count] = idx
                entry_rules[entry_count] = r
                entry_count = entry_count + 1
            elif kind == "tag" and key.len() > 0:
                var idx = dict_key_index_count(tag_key_dict, tag_keys_raw, key, tag_key_count)
                if idx < 0:
                    idx = tag_key_count
                    tag_keys_raw[idx] = key
                    tag_key_count = tag_key_count + 1
                    tag_key_dict[key] = idx
                tag_counts_raw[idx] = tag_counts_raw[idx] + 1
                entry_kinds[entry_count] = 3
                entry_buckets[entry_count] = idx
                entry_rules[entry_count] = r
                entry_count = entry_count + 1
            else:
                entry_kinds[entry_count] = 4
                entry_buckets[entry_count] = fallback_count
                entry_rules[entry_count] = r
                entry_count = entry_count + 1
                fallback_count = fallback_count + 1
            g = g + 1
        r = r + 1
    val id_keys = text_list_prefix(id_keys_raw, id_key_count)
    val id_counts = i32_list_prefix(id_counts_raw, id_key_count)
    val class_keys = text_list_prefix(class_keys_raw, class_key_count)
    val class_counts = i32_list_prefix(class_counts_raw, class_key_count)
    val tag_keys = text_list_prefix(tag_keys_raw, tag_key_count)
    val tag_counts = i32_list_prefix(tag_counts_raw, tag_key_count)
    var id_rules = rule_lists_from_counts(id_counts)
    var id_positions: [i32] = [0; id_counts.len()]
    var class_rules = rule_lists_from_counts(class_counts)
    var class_positions: [i32] = [0; class_counts.len()]
    var tag_rules = rule_lists_from_counts(tag_counts)
    var tag_positions: [i32] = [0; tag_counts.len()]
    var fallback_rules: [i32] = [0; fallback_count]
    var entry_i = 0
    while entry_i < entry_count:
        val entry_kind = entry_kinds[entry_i]
        val bucket_idx = entry_buckets[entry_i]
        val rule_idx = entry_rules[entry_i]
        if entry_kind == 1:
            var bucket = id_rules[bucket_idx]
            bucket[id_positions[bucket_idx]] = rule_idx
            id_rules[bucket_idx] = bucket
            id_positions[bucket_idx] = id_positions[bucket_idx] + 1
        elif entry_kind == 2:
            var bucket = class_rules[bucket_idx]
            bucket[class_positions[bucket_idx]] = rule_idx
            class_rules[bucket_idx] = bucket
            class_positions[bucket_idx] = class_positions[bucket_idx] + 1
        elif entry_kind == 3:
            var bucket = tag_rules[bucket_idx]
            bucket[tag_positions[bucket_idx]] = rule_idx
            tag_rules[bucket_idx] = bucket
            tag_positions[bucket_idx] = tag_positions[bucket_idx] + 1
        else:
            fallback_rules[bucket_idx] = rule_idx
        entry_i = entry_i + 1
    RuleBuckets(id_keys: id_keys, id_rules: id_rules, class_keys: class_keys, class_rules: class_rules, tag_keys: tag_keys, tag_rules: tag_rules, fallback_rules: fallback_rules, id_key_dict: id_key_dict, class_key_dict: class_key_dict, tag_key_dict: tag_key_dict)

fn dict_key_index(d: Dict<text, i32>, keys: [text], key: text) -> i32:
    dict_key_index_count(d, keys, key, keys.len() as i32)

fn style_rule_candidates(node: HNode, buckets: RuleBuckets) -> [i32]:
    val class_count = node.class_words.len()
    if class_count == 0 and node.id_attr.len() == 0:
        val tag_idx = dict_key_index(buckets.tag_key_dict, buckets.tag_keys, node.tag)
        if tag_idx < 0:
            return buckets.fallback_rules
        return merge_two_sorted_rule_lists_unique(buckets.fallback_rules, buckets.tag_rules[tag_idx])
    var lists: [[i32]] = [[]; class_count + 3]
    var list_count = 0
    lists[list_count] = buckets.fallback_rules
    list_count = list_count + 1
    if node.id_attr.len() > 0:
        val id_idx = dict_key_index(buckets.id_key_dict, buckets.id_keys, node.id_attr)
        if id_idx >= 0:
            lists[list_count] = buckets.id_rules[id_idx]
            list_count = list_count + 1
    val tag_idx = dict_key_index(buckets.tag_key_dict, buckets.tag_keys, node.tag)
    if tag_idx >= 0:
        lists[list_count] = buckets.tag_rules[tag_idx]
        list_count = list_count + 1
    var i = 0
    while i < class_count:
        val cls = node.class_words[i]
        if cls.len() > 0:
            if class_count <= 1 or not text_seen_before(node.class_words, i, cls):
                val class_idx = dict_key_index(buckets.class_key_dict, buckets.class_keys, cls)
                if class_idx >= 0:
                    lists[list_count] = buckets.class_rules[class_idx]
                    list_count = list_count + 1
        i = i + 1
    merge_sorted_rule_lists_unique_count(lists, list_count)

fn selector_group_matches_node_parts(nodes: [HNode], ctx: SelectorContext, idx: i32, parts: [text]) -> bool:
    var right = parts.len() - 1
    while right >= 0 and parts[right] == "":
        right = right - 1
    if right < 0:
        return false
    val nd = nodes[idx]
    # Use full-context match for the rightmost part (the target element) so that
    # position-based pseudos (:first-child, :last-child, :nth-child, :empty, :has, etc.)
    # are evaluated against the real node tree.
    if not simple_match_ctx(parts[right], nd.tag, nd.class_attr, nd.class_words, nd.id_attr, nd.attrs_raw, nodes, ctx, idx):
        return false
    var ancestor = nd.parent
    var want = right - 1
    var require_direct = false
    while want >= 0:
        val part = parts[want]
        if part.len() == 0:
            want = want - 1
        elif part == ">":
            require_direct = true
            want = want - 1
        else:
            if require_direct:
                if ancestor < 0:
                    return false
                val anc = nodes[ancestor]
                if simple_match(part, anc.tag, anc.class_attr, anc.class_words, anc.id_attr, anc.attrs_raw):
                    ancestor = anc.parent
                    require_direct = false
                else:
                    return false
            else:
                var found = false
                while ancestor >= 0 and not found:
                    val anc = nodes[ancestor]
                    if simple_match(part, anc.tag, anc.class_attr, anc.class_words, anc.id_attr, anc.attrs_raw):
                        found = true
                    else:
                        ancestor = anc.parent
                if not found:
                    return false
                ancestor = nodes[ancestor].parent
            want = want - 1
    not require_direct

fn selector_matches_node_group_parts(nodes: [HNode], ctx: SelectorContext, idx: i32, group_parts: [[text]]) -> bool:
    var g = 0
    val group_count = group_parts.len()
    while g < group_count:
        if selector_group_matches_node_parts(nodes, ctx, idx, group_parts[g]):
            return true
        g = g + 1
    false

# ---------------------------------------------------------------------------
# CSS specificity helpers
# ---------------------------------------------------------------------------

fn _part_specificity(part: text) -> i32:
    var base = part
    val colon = text_index_of(base, ":")
    if colon >= 0:
        base = base.substring(0, colon)
    val attr_bracket = text_index_of(base, "[")
    if attr_bracket >= 0:
        base = base.substring(0, attr_bracket).trim()
    if base.len() == 0 or base == "*":
        return 0
    if base.char_at(0) == "#":
        val dot = find_from(base, ".", 1)
        if dot >= 0:
            return 110
        return 100
    if base.char_at(0) == ".":
        var class_count = 1
        var i = 1
        val base_len = base.len()
        while i < base_len:
            if base.char_at(i) == ".":
                class_count = class_count + 1
            i = i + 1
        return class_count * 10
    val hash = text_index_of(base, "#")
    if hash > 0:
        val dot = find_from(base, ".", hash + 1)
        if dot >= 0:
            return 111
        return 101
    val dot = text_index_of(base, ".")
    if dot >= 0:
        var class_count2 = 1
        var j = dot + 1
        val base_len2 = base.len()
        while j < base_len2:
            if base.char_at(j) == ".":
                class_count2 = class_count2 + 1
            j = j + 1
        return 1 + class_count2 * 10
    1

fn _group_specificity(parts: [text]) -> i32:
    var total = 0
    var i = 0
    val part_count = parts.len()
    while i < part_count:
        val p = parts[i]
        if p.len() > 0 and p != ">":
            total = total + _part_specificity(p)
        i = i + 1
    total

fn _rule_specificity(rules: Rules, r: i32) -> i32:
    val groups = rules.group_parts[r]
    var best = 0
    var g = 0
    val group_count = groups.len()
    while g < group_count:
        val s = _group_specificity(groups[g])
        if s > best:
            best = s
        g = g + 1
    best

fn build_rule_specificities(rules: Rules) -> [i32]:
    val rule_count = rules.group_parts.len()
    var specificities: [i32] = [0; rule_count]
    var r = 0
    while r < rule_count:
        specificities[r] = _rule_specificity(rules, r)
        r = r + 1
    specificities

fn _candidate_sort_before(left: i32, right: i32, rule_specificities: [i32]) -> bool:
    val left_spec = rule_specificities[left]
    val right_spec = rule_specificities[right]
    if left_spec < right_spec:
        return true
    if left_spec > right_spec:
        return false
    left <= right

fn _sort_candidates_by_specificity(candidates: [i32], rule_specificities: [i32]) -> [i32]:
    val n = candidates.len()
    if n <= 1:
        return candidates
    var src: [i32] = [0; n]
    var dest: [i32] = [0; n]
    var i = 0
    while i < n:
        src[i] = candidates[i]
        i = i + 1
    var width = 1
    while width < n:
        var start = 0
        while start < n:
            var mid = start + width
            if mid > n:
                mid = n
            var endv = start + width + width
            if endv > n:
                endv = n
            var left_i = start
            var right_i = mid
            var out_i = start
            while left_i < mid and right_i < endv:
                if _candidate_sort_before(src[left_i], src[right_i], rule_specificities):
                    dest[out_i] = src[left_i]
                    left_i = left_i + 1
                else:
                    dest[out_i] = src[right_i]
                    right_i = right_i + 1
                out_i = out_i + 1
            while left_i < mid:
                dest[out_i] = src[left_i]
                left_i = left_i + 1
                out_i = out_i + 1
            while right_i < endv:
                dest[out_i] = src[right_i]
                right_i = right_i + 1
                out_i = out_i + 1
            start = start + width + width
        i = 0
        while i < n:
            src[i] = dest[i]
            i = i + 1
        width = width + width
    src

fn _z_index_sort_before(left: i32, right: i32, styles: [Style]) -> bool:
    val left_z = styles[left].z_index
    val right_z = styles[right].z_index
    if left_z < right_z:
        return true
    if left_z > right_z:
        return false
    left <= right

fn _sort_positive_z_indices(indices: [i32], count: i32, styles: [Style]) -> [i32]:
    if count <= 0:
        return []
    var src: [i32] = [0; count]
    var dest: [i32] = [0; count]
    var i = 0
    while i < count:
        src[i] = indices[i]
        i = i + 1
    var width = 1
    while width < count:
        var start = 0
        while start < count:
            var mid = start + width
            if mid > count:
                mid = count
            var endv = start + width + width
            if endv > count:
                endv = count
            var left_i = start
            var right_i = mid
            var out_i = start
            while left_i < mid and right_i < endv:
                if _z_index_sort_before(src[left_i], src[right_i], styles):
                    dest[out_i] = src[left_i]
                    left_i = left_i + 1
                else:
                    dest[out_i] = src[right_i]
                    right_i = right_i + 1
                out_i = out_i + 1
            while left_i < mid:
                dest[out_i] = src[left_i]
                left_i = left_i + 1
                out_i = out_i + 1
            while right_i < endv:
                dest[out_i] = src[right_i]
                right_i = right_i + 1
                out_i = out_i + 1
            start = start + width + width
        i = 0
        while i < count:
            src[i] = dest[i]
            i = i + 1
        width = width + width
    src

fn _style_order_sort_before(left: i32, right: i32, styles: [Style]) -> bool:
    val left_order = styles[left].order
    val right_order = styles[right].order
    if left_order < right_order:
        return true
    if left_order > right_order:
        return false
    left <= right

fn _sort_style_order_indices(indices: [i32], count: i32, styles: [Style]) -> [i32]:
    if count <= 0:
        return []
    var src: [i32] = [0; count]
    var dest: [i32] = [0; count]
    var i = 0
    while i < count:
        src[i] = indices[i]
        i = i + 1
    var width = 1
    while width < count:
        var start = 0
        while start < count:
            var mid = start + width
            if mid > count:
                mid = count
            var endv = start + width + width
            if endv > count:
                endv = count
            var left_i = start
            var right_i = mid
            var out_i = start
            while left_i < mid and right_i < endv:
                if _style_order_sort_before(src[left_i], src[right_i], styles):
                    dest[out_i] = src[left_i]
                    left_i = left_i + 1
                else:
                    dest[out_i] = src[right_i]
                    right_i = right_i + 1
                out_i = out_i + 1
            while left_i < mid:
                dest[out_i] = src[left_i]
                left_i = left_i + 1
                out_i = out_i + 1
            while right_i < endv:
                dest[out_i] = src[right_i]
                right_i = right_i + 1
                out_i = out_i + 1
            start = start + width + width
        i = 0
        while i < count:
            src[i] = dest[i]
            i = i + 1
        width = width + width
    src

# ---------------------------------------------------------------------------
# Presentational attributes (bgcolor/width/height/align -> CSS declarations)
# ---------------------------------------------------------------------------
# Map legacy HTML presentational attributes (bgcolor/width/height/align) to CSS
# declarations. Applied with lowest priority: after tag defaults but before
# matched CSS rules and inline style.
fn presentational_attr_decls(node: HNode) -> text:
    if node.attrs_raw.len() == 0:
        return ""
    var out = ""
    var bg = attr_value_by_key(node.attrs_raw, "bgcolor=").trim()
    if bg.len() == 6 and not bg.starts_with("#"):
        bg = "#" + bg
    if bg.len() > 0:
        out = out + "background-color:" + bg + ";"
    val w = attr_value_by_key(node.attrs_raw, "width=").trim()
    if w.len() > 0:
        if w.ends_with("%"):
            out = out + "width:" + w + ";"
        elif parse_int(w) > 0:
            out = out + "width:" + parse_int(w).to_text() + "px;"
    val h = attr_value_by_key(node.attrs_raw, "height=").trim()
    if h.len() > 0:
        if h.ends_with("%"):
            out = out + "height:" + h + ";"
        elif parse_int(h) > 0:
            out = out + "height:" + parse_int(h).to_text() + "px;"
    val align = attr_value_by_key(node.attrs_raw, "align=").trim().lower()
    if align == "center" or align == "left" or align == "right":
        out = out + "text-align:" + align + ";"
    out

# ---------------------------------------------------------------------------
# Compute styles (cascade: inherit -> tag defaults -> matched rules -> inline)
# ---------------------------------------------------------------------------

fn compute_styles(nodes: [HNode], rules: Rules, child_index: HtmlChildIndex, trace_stages: bool = false, vector_fonts: bool = true) -> [Style]:
    val rule_buckets = build_rule_buckets(rules, trace_stages)
    if trace_stages:
        print "[layout-trace] style_stage=rule-buckets-ready"
    val selector_ctx = build_selector_context(nodes, child_index)
    if trace_stages:
        print "[layout-trace] style_stage=selector-context-ready"
    val rule_specificities = build_rule_specificities(rules)
    if trace_stages:
        print "[layout-trace] style_stage=rule-specificities-ready"
    val node_count = nodes.len()
    var styles: [Style] = [renderer_default_style(); node_count]
    if trace_stages:
        print "[layout-trace] style_stage=defaults-ready nodes={node_count}"
    var i = 0
    while i < node_count:
        # Budget guard (outer): stop resolving further nodes on expiry; nodes not
        # yet reached keep their renderer_default_style() so the array stays valid.
        if _web_budget_expired():
            break
        val nd = nodes[i]
        if trace_stages:
            print "[layout-trace] style_stage=node-start index={i} parent={nd.parent} tag={nd.tag}"
        var st = renderer_default_style()
        if nd.parent >= 0:
            val parent_style = styles[nd.parent]
            if trace_stages:
                print "[layout-trace] style_stage=parent-loaded index={i}"
                print "[layout-trace] style_stage=parent-display index={i} display={parent_style.display}"
                print "[layout-trace] style_stage=parent-font index={i} size={parent_style.font_size} family={parent_style.font_family}"
            st.inherit_from(parent_style)
            if trace_stages:
                print "[layout-trace] style_stage=inherit-returned index={i} display={st.display} font={st.font_family}"
        # em/% font-size resolve against the inherited (parent) font-size, not the
        # UA-default set by tag_defaults (so h1{font-size:1.5em} == 1.5 x parent).
        val em_base = if nd.parent >= 0: styles[nd.parent].font_size else: 16
        if trace_stages:
            print "[layout-trace] style_stage=em-base-ready index={i} em={em_base}"
        st = tag_defaults(st, nd.tag)
        if trace_stages:
            print "[layout-trace] style_stage=tag-defaults-ready index={i} display={st.display}"
            print "[layout-trace] style_stage=attrs-ready index={i} attrs_len={nd.attrs_raw.len()}"
        val pres_decls = presentational_attr_decls(nd)
        if trace_stages:
            print "[layout-trace] style_stage=presentational-ready index={i} decls_len={pres_decls.len()}"
        if pres_decls.len() > 0:
            st = apply_decls(st, pres_decls, em_base)
        var empty_cells_hide = false
        if trace_stages:
            print "[layout-trace] style_stage=selector-inputs index={i} class_attr={nd.class_attr} classes={nd.class_words.len()} id_len={nd.id_attr.len()}"
        val candidates_raw = style_rule_candidates(nd, rule_buckets)
        if trace_stages:
            print "[layout-trace] style_stage=candidates-ready index={i} count={candidates_raw.len()}"
        val candidates = _sort_candidates_by_specificity(candidates_raw, rule_specificities)
        if trace_stages:
            print "[layout-trace] style_stage=candidates-sorted index={i} count={candidates.len()}"
        var candidate_i = 0
        val candidate_count = candidates.len()
        while candidate_i < candidate_count:
            # Budget guard (inner): this is the apply_decls call site loop where a
            # single node can match thousands of rules (the hostile case). Sample
            # the clock so the legit large-theme path pays no per-rule clock cost.
            if (candidate_i & 255) == 0 and _web_budget_expired():
                break
            val r = candidates[candidate_i]
            # Rule quota: rules past the cap (CSS source order) are dropped so the
            # first, load-bearing rules keep winning without unbounded cascade work.
            if r >= WEB_STYLE_RULE_QUOTA:
                candidate_i = candidate_i + 1
                continue
            if selector_matches_node_group_parts(nodes, selector_ctx, i, rules.group_parts[r]):
                val empty_cells_decl = decl_get(rules.decls[r], "empty-cells")
                if empty_cells_decl.trim().lower() == "hide":
                    empty_cells_hide = true
                st = apply_decls(st, rules.decls[r], em_base)
            candidate_i = candidate_i + 1
        if trace_stages:
            print "[layout-trace] style_stage=inline-input index={i} len={nd.style_attr.len()}"
        if nd.style_attr.len() > 0:
            val inline_empty_cells_decl = decl_get(nd.style_attr, "empty-cells")
            if inline_empty_cells_decl.trim().lower() == "hide":
                empty_cells_hide = true
            st = apply_decls(st, nd.style_attr, em_base)
        if trace_stages:
            print "[layout-trace] style_stage=inline-ready index={i}"
        if empty_cells_hide and (nd.tag == "td" or nd.tag == "th") and not selector_ctx.has_content_child[i]:
            st = apply_decls(st, "background-color:transparent;background-image:none", em_base)
        if vector_fonts and nd.tag == "#text":
            val metric_text = if st.white_space_nowrap: nd.text_data else: nd.text_trimmed
            if trace_stages:
                print "[layout-trace] style_stage=metric-text-ready index={i} len={metric_text.len()}"
            val language = _html_text_language(nodes, i, st)
            if trace_stages:
                print "[layout-trace] style_stage=metric-language-ready index={i} language={language}"
            val metrics = resolve_font_metrics_with_language(st.font_family, metric_text, st.font_size, language)
            if trace_stages:
                print "[layout-trace] style_stage=metrics-ready index={i} valid={metrics.valid}"
            if metrics.valid:
                st.resolved_font_identity = metrics.identity
                st.resolved_font_advances = metrics.advances
                st.resolved_font_width = metrics.width
                st.resolved_font_line_height = metrics.line_height
        styles[i] = st
        if trace_stages:
            print "[layout-trace] style_stage=node-complete index={i}"
        i = i + 1
    styles

# ---------------------------------------------------------------------------
# Tiny 5x7 bitmap font + plain [u32] framebuffer rasterizer
# ---------------------------------------------------------------------------
# The 5x7 glyph table + index/row lookups now live in the shared module
# common.ui.glyph_bitmap_5x7 (glyph_row_bits / glyph_index_for_char_code,
# imported above) so the browser paint path and Engine2D rasterize
# byte-identically. Layout geometry is derived from glyph_scale() so wrapping
# matches exactly what fb_text draws.

# integer nearest scale based on font size; 16->2, 34->4
fn glyph_scale(fs: i32) -> i32:
    var s = fs / 8
    if s < 1:
        s = 1
    s

# write `color` to a single framebuffer pixel (clipped)
fn fb_put(mut fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32):
    if x < 0 or y < 0 or x >= fbw or y >= fbh:
        return
    fb[y * fbw + x] = color

fn fb_clear(mut fb: [u32], color: u32):
    var i = 0
    val n = fb.len()
    while i < n:
        fb[i] = color
        i = i + 1

fn browser_layout_framebuffer_filled(base: u32, width: i32, height: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val pixels = width.to_i64() * height.to_i64()
    val workers: i64 = if pixels >= 1048576: 8 else: 1
    engine2d_simd_fill_rows_u32(width.to_i64(), height.to_i64(), base, workers)

fn browser_layout_framebuffer_filled_serial(base: u32, width: i32, height: i32) -> [u32]:
    engine2d_simd_fill_rows_u32(width.to_i64(), height.to_i64(), base, 1)

# clipped filled rectangle
fn fb_rect(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

class ClipRect:
    x0: i32
    y0: i32
    x1: i32
    y1: i32

class PaintClipCache:
    has_node_clips: bool
    default_clip: ClipRect
    clips: [ClipRect]

fn clip_intersect(c: ClipRect, x0: i32, y0: i32, x1: i32, y1: i32) -> ClipRect:
    var nx0 = c.x0
    var ny0 = c.y0
    var nx1 = c.x1
    var ny1 = c.y1
    if x0 > nx0:
        nx0 = x0
    if y0 > ny0:
        ny0 = y0
    if x1 < nx1:
        nx1 = x1
    if y1 < ny1:
        ny1 = y1
    ClipRect(x0: nx0, y0: ny0, x1: nx1, y1: ny1)

fn fb_rect_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, clip: ClipRect) -> [u32]:
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            out[row + px] = color
            px = px + 1
        py = py + 1
    out

fn blend_opacity(src: u32, dst: u32, opacity_pct: i32) -> u32:
    if opacity_pct >= 100:
        return src
    if opacity_pct <= 0:
        return dst
    val sr = (((src >> 16) & 255u32) as i32)
    val sg = (((src >> 8) & 255u32) as i32)
    val sb = ((src & 255u32) as i32)
    val dr = (((dst >> 16) & 255u32) as i32)
    val dg = (((dst >> 8) & 255u32) as i32)
    val db = ((dst & 255u32) as i32)
    val inv = 100 - opacity_pct
    val r = (sr * opacity_pct + dr * inv + 50) / 100
    val g = (sg * opacity_pct + dg * inv + 50) / 100
    val b = (sb * opacity_pct + db * inv + 50) / 100
    argb(r, g, b)

fn fb_rect_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    if opacity_pct >= 100:
        return fb_rect_clip(fb, fbw, fbh, x, y, w, h, color, clip)
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            val idx = row + px
            out[idx] = blend_opacity(color, out[idx], opacity_pct)
            px = px + 1
        py = py + 1
    out

fn fb_rounded_rect_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    if radius <= 0:
        return fb_rect_opacity_clip(fb, fbw, fbh, x, y, w, h, color, opacity_pct, clip)
    var out = fb
    var r = radius
    val max_r = if w < h: w / 2 else: h / 2
    if r > max_r:
        r = max_r
    if r <= 0:
        return fb_rect_opacity_clip(fb, fbw, fbh, x, y, w, h, color, opacity_pct, clip)
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    val rr = r * r
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            var inside = true
            if px < x + r and py < y + r:
                val dx = (x + r - 1) - px
                val dy = (y + r - 1) - py
                inside = dx * dx + dy * dy <= rr
            elif px >= x + w - r and py < y + r:
                val dx = px - (x + w - r)
                val dy = (y + r - 1) - py
                inside = dx * dx + dy * dy <= rr
            elif px < x + r and py >= y + h - r:
                val dx = (x + r - 1) - px
                val dy = py - (y + h - r)
                inside = dx * dx + dy * dy <= rr
            elif px >= x + w - r and py >= y + h - r:
                val dx = px - (x + w - r)
                val dy = py - (y + h - r)
                inside = dx * dx + dy * dy <= rr
            if inside:
                if opacity_pct >= 100:
                    out[row + px] = color
                else:
                    out[row + px] = blend_opacity(color, out[row + px], opacity_pct)
            px = px + 1
        py = py + 1
    out

fn clamp_corner_radius(radius: i32, w: i32, h: i32) -> i32:
    if radius <= 0:
        return 0
    val max_r = if w < h: w / 2 else: h / 2
    if radius > max_r:
        return max_r
    radius

# Paint ONE row (py) of the rounded rect (x,y,w,h), span sx..sx+sw, honoring
# the per-corner radii of the FULL rect. The per-row gradient painter used to
# pass 1px-tall strips to the corners helper, which degenerated the corner
# tests and painted gradient backgrounds square (radius-16 buttons filled
# their corners with accent where Chromium shows the page beneath).
fn fb_rounded_rect_row_span_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, rtl: i32, rtr: i32, rbr: i32, rbl: i32, py: i32, sx: i32, sw: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    val tl = clamp_corner_radius(rtl, w, h)
    val tr = clamp_corner_radius(rtr, w, h)
    val br = clamp_corner_radius(rbr, w, h)
    val bl = clamp_corner_radius(rbl, w, h)
    if tl <= 0 and tr <= 0 and br <= 0 and bl <= 0:
        return fb_rect_opacity_clip(fb, fbw, fbh, sx, py, sw, 1, color, opacity_pct, clip)
    if py < 0 or py >= fbh or py < clip.y0 or py >= clip.y1:
        return fb
    var out = fb
    var x0 = sx
    var x1 = sx + sw
    if x0 < 0:
        x0 = 0
    if x1 > fbw:
        x1 = fbw
    if x0 < clip.x0:
        x0 = clip.x0
    if x1 > clip.x1:
        x1 = clip.x1
    val row = py * fbw
    var px = x0
    while px < x1:
        var inside = true
        if tl > 0 and px < x + tl and py < y + tl:
            val dx = (x + tl - 1) - px
            val dy = (y + tl - 1) - py
            inside = dx * dx + dy * dy <= tl * tl
        elif tr > 0 and px >= x + w - tr and py < y + tr:
            val dx = px - (x + w - tr)
            val dy = (y + tr - 1) - py
            inside = dx * dx + dy * dy <= tr * tr
        elif bl > 0 and px < x + bl and py >= y + h - bl:
            val dx = (x + bl - 1) - px
            val dy = py - (y + h - bl)
            inside = dx * dx + dy * dy <= bl * bl
        elif br > 0 and px >= x + w - br and py >= y + h - br:
            val dx = px - (x + w - br)
            val dy = py - (y + h - br)
            inside = dx * dx + dy * dy <= br * br
        if inside:
            val idx = row + px
            out[idx] = blend_opacity(color, out[idx], opacity_pct)
        px = px + 1
    out

fn fb_rounded_rect_corners_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, rtl: i32, rtr: i32, rbr: i32, rbl: i32, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    val tl = clamp_corner_radius(rtl, w, h)
    val tr = clamp_corner_radius(rtr, w, h)
    val br = clamp_corner_radius(rbr, w, h)
    val bl = clamp_corner_radius(rbl, w, h)
    if tl <= 0 and tr <= 0 and br <= 0 and bl <= 0:
        return fb_rect_opacity_clip(fb, fbw, fbh, x, y, w, h, color, opacity_pct, clip)
    var out = fb
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > fbw:
        x1 = fbw
    if y1 > fbh:
        y1 = fbh
    if x0 < clip.x0:
        x0 = clip.x0
    if y0 < clip.y0:
        y0 = clip.y0
    if x1 > clip.x1:
        x1 = clip.x1
    if y1 > clip.y1:
        y1 = clip.y1
    var py = y0
    while py < y1:
        val row = py * fbw
        var px = x0
        while px < x1:
            var inside = true
            if tl > 0 and px < x + tl and py < y + tl:
                val dx = (x + tl - 1) - px
                val dy = (y + tl - 1) - py
                inside = dx * dx + dy * dy <= tl * tl
            elif tr > 0 and px >= x + w - tr and py < y + tr:
                val dx = px - (x + w - tr)
                val dy = (y + tr - 1) - py
                inside = dx * dx + dy * dy <= tr * tr
            elif bl > 0 and px < x + bl and py >= y + h - bl:
                val dx = (x + bl - 1) - px
                val dy = py - (y + h - bl)
                inside = dx * dx + dy * dy <= bl * bl
            elif br > 0 and px >= x + w - br and py >= y + h - br:
                val dx = px - (x + w - br)
                val dy = py - (y + h - br)
                inside = dx * dx + dy * dy <= br * br
            if inside:
                if opacity_pct >= 100:
                    out[row + px] = color
                else:
                    out[row + px] = blend_opacity(color, out[row + px], opacity_pct)
            px = px + 1
        py = py + 1
    out

fn fb_style_rounded_rect_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, st: Style, color: u32, opacity_pct: i32, clip: ClipRect) -> [u32]:
    fb_rounded_rect_corners_opacity_clip(fb, fbw, fbh, x, y, w, h, st.border_radius_tl_px, st.border_radius_tr_px, st.border_radius_br_px, st.border_radius_bl_px, color, opacity_pct, clip)

# Soft (blurred) drop shadow. The blurred rounded-rect silhouette is
# approximated by a separable edge ramp (a fast, buffer-free stand-in for a
# 3-pass box blur of the silhouette): coverage falls linearly across a band of
# +/- `blur` px centered on each edge (=> ~0.5 at the edge, matching a gaussian
# with sigma ~ blur). `alpha` (0..255) scales the peak opacity; the shadow color
# is composited src-over onto the existing framebuffer (integer math).
# Piecewise-linear standard-normal CDF scaled to 0..256; z is in 1/256 units.
# Knots every z=0.5 from -3 to +3 (max interp error ~2/256, inside tol).
fn _phi256(z256: i32) -> i32:
    if z256 <= -768:
        return 0
    if z256 >= 768:
        return 256
    val t = z256 + 768
    val seg = t / 128
    val frac = t - seg * 128
    var a = 0
    var b = 0
    if seg == 0:
        a = 0
        b = 2
    elif seg == 1:
        a = 2
        b = 6
    elif seg == 2:
        a = 6
        b = 17
    elif seg == 3:
        a = 17
        b = 41
    elif seg == 4:
        a = 41
        b = 79
    elif seg == 5:
        a = 79
        b = 128
    elif seg == 6:
        a = 128
        b = 177
    elif seg == 7:
        a = 177
        b = 215
    elif seg == 8:
        a = 215
        b = 239
    elif seg == 9:
        a = 239
        b = 250
    elif seg == 10:
        a = 250
        b = 254
    else:
        a = 254
        b = 256
    a + ((b - a) * frac) / 128

fn fb_soft_box_shadow(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, color: u32, blur: i32, alpha: i32, clip: ClipRect) -> [u32]:
    if blur <= 0 or alpha <= 0 or w <= 0 or h <= 0:
        return fb
    var out = fb
    val x0 = x
    val y0 = y
    val x1 = x + w
    val y1 = y + h
    var rx0 = x0 - blur
    var ry0 = y0 - blur
    var rx1 = x1 + blur
    var ry1 = y1 + blur
    if rx0 < 0:
        rx0 = 0
    if ry0 < 0:
        ry0 = 0
    if rx1 > fbw:
        rx1 = fbw
    if ry1 > fbh:
        ry1 = fbh
    if rx0 < clip.x0:
        rx0 = clip.x0
    if ry0 < clip.y0:
        ry0 = clip.y0
    if rx1 > clip.x1:
        rx1 = clip.x1
    if ry1 > clip.y1:
        ry1 = clip.y1
    if rx1 <= rx0 or ry1 <= ry0:
        return out
    val sr = (((color >> 16) & 255u32) as i32)
    val sg = (((color >> 8) & 255u32) as i32)
    val sb = ((color & 255u32) as i32)
    # A CSS blur radius r means a Gaussian with sigma = r/2, and the blurred
    # silhouette of an axis-aligned rect separates exactly into the product of
    # two 1D blurred-edge profiles: cov(x,y) = covx(x) * covy(y) with each
    # covA = Phi(dist_to_near_edge/sigma) * Phi(dist_to_far_edge/sigma).
    # (The old linear edge ramp over-darkened the whole halo and made drop
    # shadows read as broad gray bands.) z*256 = dist*256/sigma = dist*512/blur.
    val span = rx1 - rx0
    var colcov: [i32] = [0; span]
    var k = 0
    while k < span:
        # distinct name from the row-loop `var px`: a `val` here would
        # const-poison the later `var` on interpreters without the
        # CONST_NAMES scoping fix (the deployed self-hosted binary).
        val col_px = rx0 + k
        val cxl = _phi256(((col_px - x0) * 512) / blur)
        val cxr = _phi256(((x1 - col_px) * 512) / blur)
        colcov[k] = (cxl * cxr) / 256
        k = k + 1
    var py = ry0
    while py < ry1:
        val cyl = _phi256(((py - y0) * 512) / blur)
        val cyr = _phi256(((y1 - py) * 512) / blur)
        val cov_y = (cyl * cyr) / 256
        if cov_y > 0:
            val row = py * fbw
            var px = rx0
            while px < rx1:
                val cov = (colcov[px - rx0] * cov_y) / 256
                if cov > 0:
                    var a = (cov * alpha) / 255
                    if a > 256:
                        a = 256
                    val idx = row + px
                    val d = out[idx]
                    val dr = (((d >> 16) & 255u32) as i32)
                    val dg = (((d >> 8) & 255u32) as i32)
                    val db = ((d & 255u32) as i32)
                    val nr = (sr * a + dr * (256 - a)) / 256
                    val ng = (sg * a + dg * (256 - a)) / 256
                    val nb = (sb * a + db * (256 - a)) / 256
                    out[idx] = argb(nr, ng, nb)
                px = px + 1
        py = py + 1
    out

# Dispatch a node's box-shadow: soft blurred halo when a blur radius was parsed,
# otherwise the exact legacy hard-offset rounded-rect (byte-identical).
# When the raw multi-layer declaration is available, each dark layer is painted
# separately back-to-front (Chromium-style stacking): the tight small-blur
# layers hug the box while the wide soft layer spreads, so spill above the box
# stays light while the drop below is deep.
fn paint_box_shadow(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, st: Style, clip: ClipRect) -> [u32]:
    if st.box_shadow_blur_px > 0:
        if st.box_shadow_raw != "":
            var out = fb
            val layers = split_top_level_commas(st.box_shadow_raw)
            var li = layers.len() - 1
            while li >= 0:
                val layer = layers[li]
                li = li - 1
                if layer.contains("inset"):
                    continue
                val col = parse_color_any(layer)
                val lr = (((col >> 16) & 255u32) as i32)
                val lg = (((col >> 8) & 255u32) as i32)
                val lb = ((col & 255u32) as i32)
                val alpha = shadow_layer_alpha(layer)
                if lr + lg + lb > 360 or alpha < 30:
                    continue
                val prefix = shadow_length_prefix(layer)
                val ox = parse_signed_nth_int(prefix, 0)
                val oy = parse_signed_nth_int(prefix, 1)
                if ox == -1000000 or oy == -1000000:
                    continue
                var blur = parse_signed_nth_int(prefix, 2)
                if blur == -1000000 or blur < 0:
                    blur = 0
                if blur <= 0:
                    blur = 1
                out = fb_soft_box_shadow(out, fbw, fbh, x + ox, y + oy, w, h, col, blur, alpha, clip)
            return out
        return fb_soft_box_shadow(fb, fbw, fbh, x + st.box_shadow_x_px, y + st.box_shadow_y_px, w, h, st.box_shadow_color, st.box_shadow_blur_px, st.box_shadow_alpha, clip)
    fb_style_rounded_rect_opacity_clip(fb, fbw, fbh, x + st.box_shadow_x_px, y + st.box_shadow_y_px, w, h, st, st.box_shadow_color, 100, clip)

fn gradient_dither_threshold(px: i32, py: i32) -> i32:
    val mx = px % 4
    val my = py % 4
    if my == 0:
        if mx == 0: return 7
        if mx == 1: return 10
        if mx == 2: return 4
        return 7
    if my == 1:
        if mx == 0: return 12
        if mx == 1: return 2
        if mx == 2: return 14
        return 2
    if my == 2:
        if mx == 0:
            if px % 8 == 4:
                return 3
            return 7
        if mx == 1: return 11
        if mx == 2: return 7
        return 9
    if mx == 0: return 15
    if mx == 1: return 2
    if mx == 2: return 12
    5

fn mix_channel_gradient_centered(a: i32, b: i32, pos: i32, span: i32, px: i32, py: i32) -> i32:
    if span <= 0:
        return a
    val denom = span * 2
    val b_weight = pos * 2 + 1
    val weighted = a * (denom - b_weight) + b * b_weight
    var base = weighted / denom
    val rem = weighted - base * denom
    if rem > 0 and rem * 16 > gradient_dither_threshold(px, py) * denom:
        base = base + 1
    base

fn mix_color_vertical_centered(a: u32, b: u32, pos: i32, span: i32, px: i32, py: i32) -> u32:
    if span <= 0:
        return a
    val ar = (((a >> 16) & 255u32) as i32)
    val ag = (((a >> 8) & 255u32) as i32)
    val ab = ((a & 255u32) as i32)
    val br = (((b >> 16) & 255u32) as i32)
    val bg = (((b >> 8) & 255u32) as i32)
    val bb = ((b & 255u32) as i32)
    argb(mix_channel_gradient_centered(ar, br, pos, span, px, py), mix_channel_gradient_centered(ag, bg, pos, span, px, py), mix_channel_gradient_centered(ab, bb, pos, span, px, py))

fn fb_style_background_opacity_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, st: Style, clip: ClipRect) -> [u32]:
    var bg_x = x
    var bg_y = y
    var bg_w = w
    var bg_h = h
    var image_origin_x = x + st.border_l
    var image_origin_y = y + st.border_t
    var image_origin_w = w - st.border_l - st.border_r
    var image_origin_h = h - st.border_t - st.border_b
    if st.background_origin == "border-box":
        image_origin_x = x
        image_origin_y = y
        image_origin_w = w
        image_origin_h = h
    elif st.background_origin == "content-box":
        image_origin_x = x + st.border_l + st.pad_l
        image_origin_y = y + st.border_t + st.pad_t
        image_origin_w = w - st.border_l - st.border_r - st.pad_l - st.pad_r
        image_origin_h = h - st.border_t - st.border_b - st.pad_t - st.pad_b
    if st.background_clip == "padding-box" or st.background_clip == "content-box":
        bg_x = bg_x + st.border_l
        bg_y = bg_y + st.border_t
        bg_w = bg_w - st.border_l - st.border_r
        bg_h = bg_h - st.border_t - st.border_b
    if st.background_clip == "content-box":
        bg_x = bg_x + st.pad_l
        bg_y = bg_y + st.pad_t
        bg_w = bg_w - st.pad_l - st.pad_r
        bg_h = bg_h - st.pad_t - st.pad_b
    if bg_w <= 0 or bg_h <= 0:
        return fb
    if image_origin_w <= 0 or image_origin_h <= 0:
        image_origin_x = bg_x
        image_origin_y = bg_y
        image_origin_w = bg_w
        image_origin_h = bg_h
    # Fold the solid background color's own alpha (rgba) into the paint
    # opacity: translucent panels must composite over what's beneath, not
    # paint as opaque slabs. For alpha=255 colors this is bit-identical to
    # the old path ((pct*255+127)/255 == pct).
    val solid_bg_alpha = (((st.bg >> 24) & 255u32) as i32)
    val solid_bg_opacity = (st.opacity_pct * solid_bg_alpha + 127) / 255
    if st.background_gradient_from == 0u32 or st.background_gradient_to == 0u32:
        if solid_bg_opacity <= 0:
            return fb
        return fb_style_rounded_rect_opacity_clip(fb, fbw, fbh, bg_x, bg_y, bg_w, bg_h, st, st.bg | 0xFF000000u32, solid_bg_opacity, clip)
    var out = fb
    if st.bg != 0u32 and solid_bg_opacity > 0:
        out = fb_style_rounded_rect_opacity_clip(out, fbw, fbh, bg_x, bg_y, bg_w, bg_h, st, st.bg | 0xFF000000u32, solid_bg_opacity, clip)
    val tile_w = if st.background_size_w_px > 0: st.background_size_w_px else: image_origin_w
    val tile_h = if st.background_size_h_px > 0: st.background_size_h_px else: image_origin_h
    val fixed_no_repeat = st.background_attachment == "fixed" and st.background_repeat == "no-repeat"
    val image_x = if st.background_repeat == "no-repeat": st.background_position_x_px else: 0
    val image_y = if st.background_repeat == "no-repeat": st.background_position_y_px else: 0
    val remaining_w = image_origin_w - image_x
    val remaining_h = image_origin_h - image_y
    val max_x = if fixed_no_repeat: tile_w else: (if st.background_repeat == "no-repeat": (if tile_w < remaining_w: tile_w else: remaining_w) else: image_origin_w)
    val max_y = if fixed_no_repeat: tile_h else: (if st.background_repeat == "no-repeat": (if tile_h < remaining_h: tile_h else: remaining_h) else: image_origin_h)
    val image_base_x = if fixed_no_repeat: image_x else: image_origin_x + image_x
    val image_base_y = if fixed_no_repeat: image_y else: image_origin_y + image_y
    val image_clip = if fixed_no_repeat: clip_intersect(clip, bg_x, bg_y, bg_x + bg_w, bg_y + bg_h) else: clip
    var py = 0
    val small_no_repeat_gradient_tile = st.background_repeat == "no-repeat" and tile_w <= 64 and tile_h <= 64
    while py < max_y:
        val tile_py = py % tile_h
        if small_no_repeat_gradient_tile:
            var px = 0
            while px < max_x:
                val color = mix_color_vertical_centered(st.background_gradient_from, st.background_gradient_to, tile_py, tile_h, px, tile_py)
                out = fb_rounded_rect_row_span_opacity_clip(out, fbw, fbh, bg_x, bg_y, bg_w, bg_h, st.border_radius_tl_px, st.border_radius_tr_px, st.border_radius_br_px, st.border_radius_bl_px, image_base_y + py, image_base_x + px, 1, color, st.opacity_pct, image_clip)
                px = px + 1
        else:
            val color = mix_color_vertical_centered(st.background_gradient_from, st.background_gradient_to, tile_py, tile_h, 0, tile_py)
            out = fb_rounded_rect_row_span_opacity_clip(out, fbw, fbh, bg_x, bg_y, bg_w, bg_h, st.border_radius_tl_px, st.border_radius_tr_px, st.border_radius_br_px, st.border_radius_bl_px, image_base_y + py, image_base_x, max_x, color, st.opacity_pct, image_clip)
        py = py + 1
    out

# integer sqrt (Newton, monotone-decreasing loop) for radial falloff distances
fn _isqrt_i64(v: i64) -> i64:
    if v <= 0:
        return 0
    var g: i64 = v
    var nx: i64 = (g + 1) / 2
    while nx < g:
        g = nx
        nx = (g + v / g) / 2
    g

# Parse the center of a radial-gradient position spec ("circle at top left",
# "at 78% 10%", "circle at bottom center") into [x_pct, y_pct] of the box.
# Keywords bind to their own axis; "center"/percentages consume x then y.
fn _radial_center_pct(spec: text) -> [i32]:
    var xp = 50
    var yp = 50
    val low = spec.lower()
    val at = text_index_of(low, "at ")
    if at < 0:
        return [xp, yp]
    val pos = low.substring(at + 3, low.len()).trim()
    val toks = pos.split(" ")
    var x_set = false
    var y_set = false
    var ti = 0
    val tc = toks.len()
    while ti < tc:
        val tok = toks[ti].trim()
        ti = ti + 1
        if tok == "":
            continue
        if tok == "left":
            xp = 0
            x_set = true
        elif tok == "right":
            xp = 100
            x_set = true
        elif tok == "top":
            yp = 0
            y_set = true
        elif tok == "bottom":
            yp = 100
            y_set = true
        elif tok == "center":
            if not x_set:
                x_set = true
            else:
                y_set = true
        elif tok.ends_with("%"):
            val v = parse_int(tok.substring(0, tok.len() - 1))
            if not x_set:
                xp = v
                x_set = true
            elif not y_set:
                yp = v
                y_set = true
    [xp, yp]

# Paint the radial-gradient layers of a multi-layer `background` stack over
# the already-painted base ramp. CSS paints the FIRST layer topmost, so layers
# composite back-to-front (iterate from the last layer up). Falloff is linear
# from the center stop's rgba alpha down to the "transparent N%" stop, where
# N% is a fraction of the farthest-corner radius (the CSS default gradient
# size). Non-radial layers are ignored (the scalar Style fields paint them).
fn fb_background_radial_stack_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, raw: text, opacity_pct: i32, clip: ClipRect) -> [u32]:
    var out = fb
    if w <= 0 or h <= 0 or opacity_pct <= 0:
        return out
    val layers = split_top_level_commas(raw)
    var li = layers.len() - 1
    while li >= 0:
        val lay = layers[li]
        li = li - 1
        val gpos = text_index_of(lay.lower(), "radial-gradient(")
        if gpos < 0:
            continue
        val lp = find_from(lay, "(", gpos)
        val rp = paren_matching_close(lay, lp)
        if lp < 0 or rp <= lp:
            continue
        val inner = lay.substring(lp + 1, rp)
        val parts = split_top_level_commas(inner)
        val pc = parts.len()
        if pc < 2:
            continue
        var pi = 0
        var cx_pct = 50
        var cy_pct = 50
        val head = parts[0].trim().lower()
        if head.starts_with("circle") or head.starts_with("ellipse") or head.starts_with("at "):
            val cp = _radial_center_pct(parts[0])
            cx_pct = cp[0]
            cy_pct = cp[1]
            pi = 1
        if pi >= pc:
            continue
        val col = parse_color_any(parts[pi])
        if col == 0u32:
            continue
        val a0 = shadow_layer_alpha(parts[pi])
        if a0 <= 0:
            continue
        var ext_pct = 100
        val tail = parts[pc - 1].trim().lower()
        val tpct = text_index_of(tail, "%")
        if tail.starts_with("transparent") and tpct > 0:
            var s = tpct - 1
            while s >= 0 and tail.char_at(s) != " ":
                s = s - 1
            val v = parse_int(tail.substring(s + 1, tpct))
            if v > 0:
                ext_pct = v
        val cx = x + (w * cx_pct) / 100
        val cy = y + (h * cy_pct) / 100
        var dxm = cx - x
        if x + w - cx > dxm:
            dxm = x + w - cx
        var dym = cy - y
        if y + h - cy > dym:
            dym = y + h - cy
        val rfull = _isqrt_i64((dxm as i64) * (dxm as i64) + (dym as i64) * (dym as i64))
        val rstop = (rfull * (ext_pct as i64)) / 100
        if rstop <= 0:
            continue
        val rstop2 = rstop * rstop
        val src = col | 0xFF000000u32
        # scan only the circle's bounding box, intersected with box+clip+fb
        var x0 = cx - (rstop as i32)
        var y0 = cy - (rstop as i32)
        var x1 = cx + (rstop as i32) + 1
        var y1 = cy + (rstop as i32) + 1
        if x0 < x:
            x0 = x
        if y0 < y:
            y0 = y
        if x1 > x + w:
            x1 = x + w
        if y1 > y + h:
            y1 = y + h
        if x0 < 0:
            x0 = 0
        if y0 < 0:
            y0 = 0
        if x1 > fbw:
            x1 = fbw
        if y1 > fbh:
            y1 = fbh
        if x0 < clip.x0:
            x0 = clip.x0
        if y0 < clip.y0:
            y0 = clip.y0
        if x1 > clip.x1:
            x1 = clip.x1
        if y1 > clip.y1:
            y1 = clip.y1
        var py = y0
        while py < y1:
            val row = py * fbw
            val dy = (py - cy) as i64
            val dy2 = dy * dy
            var px = x0
            while px < x1:
                val dx = (px - cx) as i64
                val d2 = dx * dx + dy2
                if d2 < rstop2:
                    val d = _isqrt_i64(d2)
                    var aeff = (((a0 as i64) * (rstop - d)) / rstop) as i32
                    if opacity_pct < 100:
                        aeff = (aeff * opacity_pct) / 100
                    if aeff > 0:
                        val idx = row + px
                        out[idx] = composite_over_base(src, aeff, out[idx])
                px = px + 1
            py = py + 1
    out

fn fb_border(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, border_w: i32, color: u32) -> [u32]:
    var out = fb
    if border_w <= 0 or color == 0u32:
        return out
    out = fb_rect(out, fbw, fbh, x, y, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y + h - border_w, w, border_w, color)
    out = fb_rect(out, fbw, fbh, x, y, border_w, h, color)
    out = fb_rect(out, fbw, fbh, x + w - border_w, y, border_w, h, color)
    out

fn fb_border_sides(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, w, bt, ct)
    if bb > 0 and cb != 0u32:
        out = fb_rect(out, fbw, fbh, x, y + h - bb, w, bb, cb)
    if bl > 0 and cl != 0u32:
        out = fb_rect(out, fbw, fbh, x, y, bl, h, cl)
    if br > 0 and cr != 0u32:
        out = fb_rect(out, fbw, fbh, x + w - br, y, br, h, cr)
    out

fn fb_border_sides_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, bl: i32, bt: i32, br: i32, bb: i32, cl: u32, ct: u32, cr: u32, cb: u32, clip: ClipRect) -> [u32]:
    var out = fb
    if bt > 0 and ct != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, w, bt, ct, clip)
    if bb > 0 and cb != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y + h - bb, w, bb, cb, clip)
    if bl > 0 and cl != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x, y, bl, h, cl, clip)
    if br > 0 and cr != 0u32:
        out = fb_rect_clip(out, fbw, fbh, x + w - br, y, br, h, cr, clip)
    out

fn fb_outline_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, h: i32, outline_w: i32, outline_offset: i32, color: u32, clip: ClipRect) -> [u32]:
    if outline_w <= 0 or color == 0u32:
        return fb
    val grow = outline_w + outline_offset
    val ox = x - grow
    val oy = y - grow
    val ow = w + grow * 2
    val oh = h + grow * 2
    fb_border_sides_clip(fb, fbw, fbh, ox, oy, ow, oh, outline_w, outline_w, outline_w, outline_w, color, color, color, color, clip)

fn fb_text_underline(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, thickness: i32, style: text, color: u32) -> [u32]:
    var out = fb
    if w <= 0 or color == 0u32:
        return out
    val line_h = if thickness > 0: thickness else: 1
    if style == "double":
        out = fb_rect(out, fbw, fbh, x, y, w, line_h, color)
        return fb_rect(out, fbw, fbh, x, y + line_h + 1, w, line_h, color)
    if style == "dashed" or style == "dotted":
        val dash_w = if style == "dotted": line_h else: line_h * 3
        val gap_w = if line_h > 0: line_h else: 1
        var px = 0
        while px < w:
            val seg_w = if px + dash_w > w: w - px else: dash_w
            out = fb_rect(out, fbw, fbh, x + px, y, seg_w, line_h, color)
            px = px + dash_w + gap_w
        return out
    fb_rect(out, fbw, fbh, x, y, w, line_h, color)

fn fb_text_underline_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, w: i32, thickness: i32, style: text, color: u32, clip: ClipRect) -> [u32]:
    var out = fb
    if w <= 0 or color == 0u32:
        return out
    val line_h = if thickness > 0: thickness else: 1
    if style == "double":
        out = fb_rect_clip(out, fbw, fbh, x, y, w, line_h, color, clip)
        return fb_rect_clip(out, fbw, fbh, x, y + line_h + 1, w, line_h, color, clip)
    if style == "dashed" or style == "dotted":
        val dash_w = if style == "dotted": line_h else: line_h * 3
        val gap_w = if line_h > 0: line_h else: 1
        var px = 0
        while px < w:
            val seg_w = if px + dash_w > w: w - px else: dash_w
            out = fb_rect_clip(out, fbw, fbh, x + px, y, seg_w, line_h, color, clip)
            px = px + dash_w + gap_w
        return out
    fb_rect_clip(out, fbw, fbh, x, y, w, line_h, color, clip)

fn fb_glyph_thin_scaled_clip(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, scale: i32, italic: bool, clip: ClipRect) -> [u32]:
    var out = fb
    var ry = 0
    while ry < 7:
        val bits = glyph_row_bits(gi, ry)
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0:
                val italic_shift = if italic: (6 - ry) * scale / 3 else: 0
                val bx0 = x + italic_shift + rx * scale
                val by0 = y + ry * scale
                var dy = 0
                while dy < scale:
                    val yy = by0 + dy
                    if yy >= 0 and yy < fbh and yy >= clip.y0 and yy < clip.y1:
                        val row = yy * fbw
                        var dx = 0
                        while dx < scale:
                            val xx = bx0 + dx
                            if xx >= 0 and xx < fbw and xx >= clip.x0 and xx < clip.x1:
                                out[row + xx] = color
                            dx = dx + 1
                    dy = dy + 1
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_thin_scaled_clip_range(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, start: i32, endv: i32, color: u32, scale: i32, advance: i32, space_advance: i32, italic: bool, clip: ClipRect) -> [u32]:
    var out = fb
    val glyph_h = 7 * scale
    if y >= fbh or y >= clip.y1 or y + glyph_h <= 0 or y + glyph_h <= clip.y0:
        return out
    var i = start
    var cx = x
    while i < endv:
        if cx >= fbw or cx >= clip.x1:
            return out
        val code = s.char_code_at(i)
        val gi = glyph_index_for_char_code(code)
        if gi >= 0 and gi != 36:
            out = fb_glyph_thin_scaled_clip(out, fbw, fbh, cx, y, gi, color, scale, italic, clip)
        cx = cx + if code == 32: space_advance else: advance
        i = i + 1
    out

fn apply_text_transform_for_paint(value: text, transform: text) -> text:
    if transform == "uppercase":
        return value.upper()
    if transform == "lowercase":
        return value.lower()
    if transform == "capitalize":
        var out = ""
        var new_word = true
        var i = 0
        while i < value.len():
            val ch = value.char_at(i)
            if ch == " " or ch == "\n" or ch == "\t":
                out = out + ch
                new_word = true
            else:
                out = out + if new_word: ch.upper() else: ch
                new_word = false
            i = i + 1
        return out
    value

fn reverse_text_for_paint(value: text) -> text:
    var out = ""
    var i = value.len()
    while i > 0:
        i = i - 1
        out = out + value.char_at(i)
    out

fn fb_glyph_sparse(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, gi: i32, color: u32, italic: bool) -> [u32]:
    var out = fb
    var ry = 0
    while ry < 7:
        val bits = glyph_row_bits(gi, ry)
        var rx = 0
        while rx < 5:
            val mask = 1 << (4 - rx)
            if (bits & mask) != 0 and ((rx + ry) % 2) == 0:
                val italic_shift = if italic: (6 - ry) / 3 else: 0
                val xx = x + italic_shift + rx
                val yy = y + ry
                if xx >= 0 and xx < fbw and yy >= 0 and yy < fbh:
                    out[yy * fbw + xx] = color
            rx = rx + 1
        ry = ry + 1
    out

fn fb_text_sparse_range(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, s: text, start: i32, endv: i32, color: u32, advance: i32, space_advance: i32, italic: bool) -> [u32]:
    var out = fb
    if y >= fbh or y + 7 <= 0:
        return out
    var i = start
    var cx = x
    while i < endv:
        if cx >= fbw:
            return out
        if cx < fbw:
            val gi = glyph_index_for_char_code(s.char_code_at(i))
            if gi >= 0 and gi != 36:
                out = fb_glyph_sparse(out, fbw, fbh, cx, y, gi, color, italic)
        cx = cx + if s.char_code_at(i) == 32: space_advance else: advance
        i = i + 1
    out

fn fb_px(fb: [u32], fbw: i32, fbh: i32, x: i32, y: i32, color: u32) -> [u32]:
    var out = fb
    if x >= 0 and x < fbw and y >= 0 and y < fbh:
        out[y * fbw + x] = color
    out

