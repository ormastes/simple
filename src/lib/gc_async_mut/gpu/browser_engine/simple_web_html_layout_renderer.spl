    object_fit: text
    object_position: text
    bold: bool

    me inherit_from(p: Style):
        self.display = if p.display == "none": "none" else: "block"
        self.fg = p.fg
        self.font_size = p.font_size
        self.font_family = p.font_family
        self.line_height_px = p.line_height_px
        self.scrollbar_thumb_color = p.scrollbar_thumb_color
        self.scrollbar_track_color = p.scrollbar_track_color
        self.text_overflow_ellipsis = p.text_overflow_ellipsis
        self.visibility_hidden = p.visibility_hidden
        self.text_align = p.text_align
        self.text_align_last = p.text_align_last
        self.text_justify = p.text_justify
        self.text_transform = p.text_transform
        self.text_indent_px = p.text_indent_px
        self.letter_spacing_px = p.letter_spacing_px
        self.word_spacing_px = p.word_spacing_px
        self.font_size_adjust = p.font_size_adjust
        self.font_palette = p.font_palette
        self.font_feature_settings = p.font_feature_settings
        self.font_language_override = p.font_language_override
        self.font_variation_settings = p.font_variation_settings
        self.font_variant = p.font_variant
        self.font_variant_alternates = p.font_variant_alternates
        self.font_variant_caps = p.font_variant_caps
        self.font_variant_east_asian = p.font_variant_east_asian
        self.font_variant_emoji = p.font_variant_emoji
        self.font_variant_ligatures = p.font_variant_ligatures
        self.font_variant_numeric = p.font_variant_numeric
        self.font_variant_position = p.font_variant_position
        self.font_style_italic = p.font_style_italic
        self.font_kerning = p.font_kerning
        self.font_optical_sizing = p.font_optical_sizing
        self.font_stretch = p.font_stretch
        self.font_width = p.font_width
        self.font_synthesis = p.font_synthesis
        self.font_synthesis_small_caps = p.font_synthesis_small_caps
        self.font_synthesis_position = p.font_synthesis_position
        self.font_synthesis_style = p.font_synthesis_style
        self.font_synthesis_weight = p.font_synthesis_weight
        self.direction_rtl = p.direction_rtl
        self.writing_mode = p.writing_mode
        self.text_orientation = p.text_orientation
        self.text_combine_upright = p.text_combine_upright
        self.text_shadow_x_px = p.text_shadow_x_px
        self.text_shadow_y_px = p.text_shadow_y_px
        self.text_shadow_color = p.text_shadow_color
        self.text_decoration_color = p.text_decoration_color
        self.text_decoration_underline = p.text_decoration_underline
        self.text_decoration_style = p.text_decoration_style
        self.text_decoration_thickness_px = p.text_decoration_thickness_px
        self.text_underline_offset_px = p.text_underline_offset_px
        self.text_underline_position = p.text_underline_position
        self.white_space_nowrap = p.white_space_nowrap
        self.overflow_wrap = p.overflow_wrap
        self.line_break = p.line_break
        self.hyphens = p.hyphens
        self.word_break = p.word_break
        self.cursor = p.cursor
        self.caret_color = p.caret_color
        self.tab_size = p.tab_size
        self.object_fit = p.object_fit
        self.object_position = p.object_position
        self.bold = p.bold

fn _html_text_language(nodes: [HNode], node_index: i32, st: Style) -> text:
    val override = st.font_language_override.trim()
    if override != "" and override.lower() != "normal":
        if override.len() >= 2 and ((override.starts_with("\"") and override.ends_with("\"")) or
                                   (override.starts_with("'") and override.ends_with("'"))):
            return override.slice(1, override.len() - 1)
        return override
    var current = node_index.to_i64()
    while current >= 0:
        val language = attr_value(nodes[current].attrs_raw, "lang").trim()
        if language != "":
            return language
        current = nodes[current].parent
    "und"

fn renderer_default_style() -> Style:
