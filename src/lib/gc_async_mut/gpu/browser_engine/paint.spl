# Paint — Generate and Execute Paint Commands
#
# Walks the layout tree to produce a flat list of paint commands,
# then executes them against the 2D engine. The two-phase approach
# allows command inspection, reordering by z-index, and caching.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, BorderProps}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox}

# =========================================================================
# Paint Command
# =========================================================================

class PaintCommand:
    """A single drawing operation to be executed by the 2D engine.

    Fields:
        kind          - "rect", "text", "border", "image", "gradient"
        x, y          - top-left position in pixels
        width, height - size in pixels
        color         - fill color as RGBA u32
        text_val      - text content (for "text" kind)
        font_size     - font size in pixels (for "text" kind)
        border_radius - corner radius in pixels
        border_width  - border stroke width
        border_color  - border stroke color
        opacity       - alpha multiplier (0.0-1.0)
    """
    kind: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: u32
    text_val: text
    font_size: i32
    border_radius: i32
    border_width: i32
    border_color: u32
    opacity: f32

    static fn rect(x: i32, y: i32, w: i32, h: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "rect", x: x, y: y, width: w, height: h,
            color: color, text_val: "", font_size: 16,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0
        )

    static fn text_cmd(x: i32, y: i32, content: text, font_size: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "text", x: x, y: y, width: 0, height: 0,
            color: color, text_val: content, font_size: font_size,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0
        )

    static fn border(x: i32, y: i32, w: i32, h: i32, bw: i32, bc: u32, radius: i32) -> PaintCommand:
        return PaintCommand(
            kind: "border", x: x, y: y, width: w, height: h,
            color: 0, text_val: "", font_size: 0,
            border_radius: radius, border_width: bw, border_color: bc,
            opacity: 1.0
        )

# =========================================================================
# Paint List Generation
# =========================================================================

fn generate_paint_list(layout: BeLayoutBox) -> [PaintCommand]:
    """Walk the layout tree and generate a flat list of paint commands.

    Commands are generated in tree order (pre-order traversal),
    which naturally produces correct back-to-front painting for
    non-positioned elements.
    """
    var commands: [PaintCommand] = []
    commands = paint_layout_box(layout, commands)
    return commands

fn paint_layout_box(box: BeLayoutBox, commands: [PaintCommand]) -> [PaintCommand]:
    """Generate paint commands for a single layout box and its children."""
    var cmds = commands
    val node = box.node
    val style = node.style

    # Skip invisible nodes
    if style.display == "none":
        return cmds

    if style.opacity < 0.01:
        return cmds

    # 1. Background
    if style.background_color != 0x00000000:
        var bg_cmd = PaintCommand.rect(
            box.content_x - style.padding.left,
            box.content_y - style.padding.top,
            box.content_width + style.padding.horizontal(),
            box.content_height + style.padding.vertical(),
            style.background_color
        )
        bg_cmd.border_radius = style.border_radius
        bg_cmd.opacity = style.opacity
        cmds = cmds + [bg_cmd]

    # 2. Border
    if style.border.width > 0 and style.border.style != "none":
        val b_cmd = PaintCommand.border(
            box.x, box.y, box.width, box.height,
            style.border.width, style.border.color,
            style.border_radius
        )
        cmds = cmds + [b_cmd]

    # 3. Text content
    if node.is_text_node() and node.text_content.len() > 0:
        val t_cmd = PaintCommand.text_cmd(
            box.content_x, box.content_y,
            node.text_content, style.font_size, style.color
        )
        cmds = cmds + [t_cmd]

    # 4. Children
    for child in box.children:
        cmds = paint_layout_box(child, cmds)

    return cmds

# =========================================================================
# Paint Execution (2D Engine Integration)
# =========================================================================

fn execute_paint(engine: Engine2D, commands: [PaintCommand]):
    """Execute a list of paint commands using the 2D engine.

    Each command maps to one or more 2D engine draw calls:
      - rect  -> engine.fill_rect()
      - text  -> engine.draw_text()
      - border -> engine.stroke_rect()
    """
    for cmd in commands:
        match cmd.kind:
            "rect" =>
                engine.fill_rect(cmd.x, cmd.y, cmd.width, cmd.height, cmd.color)
            "text" =>
                engine.draw_text(cmd.x, cmd.y, cmd.text_val, cmd.font_size, cmd.color)
            "border" =>
                engine.stroke_rect(
                    cmd.x, cmd.y, cmd.width, cmd.height,
                    cmd.border_width, cmd.border_color
                )
            _ =>
                pass_dn

fn paint_tree(engine: Engine2D, layout: BeLayoutBox):
    """Convenience: generate paint commands from layout tree and execute them."""
    val commands = generate_paint_list(layout)
    execute_paint(engine, commands)

# =========================================================================
# Engine2D Facade (forward-declared interface)
# =========================================================================
# The 2D engine will live at std.gc_async_mut.gpu.engine2d.engine
# and provide these methods. For now we declare the interface here
# so paint.spl compiles independently.

class Engine2D:
    """2D rendering engine facade.

    Provides basic drawing primitives used by the paint system.
    This is a placeholder that will be replaced by the real engine2d
    module import once it exists.
    """
    width: i32
    height: i32
    pixels: [u32]

    static fn create(w: i32, h: i32) -> Engine2D:
        var px: [u32] = []
        var i = 0
        val total = w * h
        while i < total:
            px = px + [0x00000000]
            i = i + 1
        return Engine2D(width: w, height: h, pixels: px)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Fill a rectangle with a solid color."""
        var row = y
        while row < y + h and row < self.height:
            if row >= 0:
                var col = x
                while col < x + w and col < self.width:
                    if col >= 0:
                        val idx = row * self.width + col
                        self.pixels[idx] = color
                    col = col + 1
            row = row + 1

    me draw_text(x: i32, y: i32, content: text, font_size: i32, color: u32):
        """Draw text at a position. In this placeholder, renders as a colored rect."""
        val char_w = font_size / 2
        val text_w = content.len() * char_w
        self.fill_rect(x, y, text_w, font_size, color)

    me stroke_rect(x: i32, y: i32, w: i32, h: i32, stroke_w: i32, color: u32):
        """Draw a rectangle outline (border)."""
        # Top edge
        self.fill_rect(x, y, w, stroke_w, color)
        # Bottom edge
        self.fill_rect(x, y + h - stroke_w, w, stroke_w, color)
        # Left edge
        self.fill_rect(x, y, stroke_w, h, color)
        # Right edge
        self.fill_rect(x + w - stroke_w, y, stroke_w, h, color)

    me clear(color: u32):
        """Fill the entire canvas with a color."""
        self.fill_rect(0, 0, self.width, self.height, color)

    fn get_pixels() -> [u32]:
        """Return the pixel buffer."""
        return self.pixels
