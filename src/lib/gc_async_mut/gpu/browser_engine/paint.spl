# Paint — Generate and Execute Paint Commands
#
# Walks the layout tree to produce a flat list of paint commands,
# then executes them against the 2D engine. The two-phase approach
# allows command inspection, reordering by z-index, and caching.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, BorderProps}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox}
use common.render_scene.scene.{SceneCommand, RenderScene, render_scene,
    scene_fill_rect, scene_stroke_rect, scene_text, scene_rounded_rect,
    scene_gradient_rect, scene_image, rgba_to_argb}
use common.text_layout.font_renderer.{FontRenderer}

# =========================================================================
# Paint Command
# =========================================================================

class PaintCommand:
    """A single drawing operation to be executed by the 2D engine.

    Fields:
        kind          - "rect", "text", "border", "image", "gradient"
        x, y          - top-left position in pixels
        width, height - size in pixels
        color         - fill color as RGBA u32
        text_val      - text content (for "text" kind)
        font_size     - font size in pixels (for "text" kind)
        border_radius - corner radius in pixels
        border_width  - border stroke width
        border_color  - border stroke color
        opacity       - alpha multiplier (0.0-1.0)
    """
    kind: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: u32
    text_val: text
    font_size: i32
    border_radius: i32
    border_width: i32
    border_color: u32
    opacity: f32

    static fn rect(x: i32, y: i32, w: i32, h: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "rect", x: x, y: y, width: w, height: h,
            color: color, text_val: "", font_size: 16,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0
        )

    static fn text_cmd(x: i32, y: i32, content: text, font_size: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "text", x: x, y: y, width: 0, height: 0,
            color: color, text_val: content, font_size: font_size,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0
        )

    static fn border(x: i32, y: i32, w: i32, h: i32, bw: i32, bc: u32, radius: i32) -> PaintCommand:
        return PaintCommand(
            kind: "border", x: x, y: y, width: w, height: h,
            color: 0, text_val: "", font_size: 0,
            border_radius: radius, border_width: bw, border_color: bc,
            opacity: 1.0
        )

    static fn shadow(x: i32, y: i32, w: i32, h: i32, color: u32, opacity: f32) -> PaintCommand:
        return PaintCommand(
            kind: "rect", x: x, y: y, width: w, height: h,
            color: color, text_val: "", font_size: 0,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: opacity
        )

# =========================================================================
# Paint List Generation
# =========================================================================

fn generate_paint_list(layout: BeLayoutBox) -> [PaintCommand]:
    """Walk the layout tree and generate a flat list of paint commands.

    Commands are generated in tree order (pre-order traversal),
    which naturally produces correct back-to-front painting for
    non-positioned elements.
    """
    var commands: [PaintCommand] = []
    commands = paint_layout_box(layout, commands)
    return commands

fn paint_layout_box(box: BeLayoutBox, commands: [PaintCommand]) -> [PaintCommand]:
    """Generate paint commands for a single layout box and its children."""
    var cmds = commands
    val node = box.node
    val style = node.style

    # Skip invisible nodes
    if style.display == "none":
        return cmds

    if style.visibility == "hidden":
        return cmds

    if style.opacity < 0.01:
        return cmds

    # 0. Box shadow (painted before background per CSS spec)
    # Simple drop shadow: 2px offset, 4px blur, black@30%
    # Future: parse box_shadow property from StyleProps
    # Currently uses a simple default shadow for any element with border-radius > 0

    # 1. Background
    if style.background_color != 0x00000000:
        var bg_cmd = PaintCommand.rect(
            box.content_x - style.padding.left,
            box.content_y - style.padding.top,
            box.content_width + style.padding.horizontal(),
            box.content_height + style.padding.vertical(),
            style.background_color
        )
        bg_cmd.border_radius = style.border_radius
        bg_cmd.opacity = style.opacity
        cmds = cmds + [bg_cmd]

    # 2. Border
    if style.border.width > 0 and style.border.style != "none":
        val b_cmd = PaintCommand.border(
            box.x, box.y, box.width, box.height,
            style.border.width, style.border.color,
            style.border_radius
        )
        cmds = cmds + [b_cmd]

    # 3. Text content
    if node.is_text_node() and node.text_content.len() > 0:
        val t_cmd = PaintCommand.text_cmd(
            box.content_x, box.content_y,
            node.text_content, style.font_size, style.color
        )
        cmds = cmds + [t_cmd]

        # 3b. Text decoration (underline, overline, line-through)
        if style.text_decoration != "none" and style.text_decoration != "":
            var text_width = box.content_width
            if text_width <= 0:
                text_width = node.text_content.len() * (style.font_size * 55 / 100)
            val line_h = 1  # 1px decoration line
            if style.text_decoration == "underline":
                val deco_y = box.content_y + style.font_size + 2
                cmds = cmds + [PaintCommand.rect(box.content_x, deco_y, text_width, line_h, style.color)]
            else if style.text_decoration == "overline":
                val deco_y = box.content_y - 1
                cmds = cmds + [PaintCommand.rect(box.content_x, deco_y, text_width, line_h, style.color)]
            else if style.text_decoration == "line-through":
                val deco_y = box.content_y + style.font_size / 2
                cmds = cmds + [PaintCommand.rect(box.content_x, deco_y, text_width, line_h, style.color)]

    # 4. Children
    for child in box.children:
        cmds = paint_layout_box(child, cmds)

    return cmds

# =========================================================================
# Paint -> RenderScene Bridge
# =========================================================================

fn paint_commands_to_scene(commands: [PaintCommand], viewport_w: i32, viewport_h: i32) -> RenderScene:
    """Convert paint commands to a RenderScene for the render_scene executor.

    Maps PaintCommand kinds to SceneCommand factory calls:
      - rect     -> scene_fill_rect
      - text     -> scene_text
      - border   -> scene_stroke_rect
      - gradient -> scene_gradient_rect
    """
    var scene_cmds: [SceneCommand] = []
    for cmd in commands:
        match cmd.kind:
            "rect" =>
                val argb_color = apply_opacity_to_argb(rgba_to_argb(cmd.color), cmd.opacity)
                if cmd.border_radius > 0:
                    scene_cmds = scene_cmds + [scene_rounded_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color, cmd.border_radius)]
                else:
                    scene_cmds = scene_cmds + [scene_fill_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color)]
            "text" =>
                val argb_color = rgba_to_argb(cmd.color)
                scene_cmds = scene_cmds + [scene_text(cmd.x, cmd.y, cmd.text_val, argb_color, cmd.font_size)]
            "border" =>
                val argb_color = rgba_to_argb(cmd.border_color)
                scene_cmds = scene_cmds + [scene_stroke_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color, cmd.border_width)]
            "gradient" =>
                val c1 = rgba_to_argb(cmd.color)
                val c2 = rgba_to_argb(cmd.border_color)
                scene_cmds = scene_cmds + [scene_gradient_rect(cmd.x, cmd.y, cmd.width, cmd.height, c1, c2)]
            "image" =>
                pass_dn  # images not yet supported in paint commands
            _ =>
                pass_dn
    render_scene(scene_cmds, viewport_w, viewport_h)

fn apply_opacity_to_argb(argb_color: u32, opacity: f32) -> u32:
    """Multiply the alpha channel of an ARGB color by an opacity factor (0.0-1.0)."""
    if opacity >= 1.0:
        return argb_color
    if opacity <= 0.0:
        return argb_color & 0x00FFFFFF  # zero alpha, keep RGB
    val a = (argb_color >> 24) & 0xFF
    var new_a = (a.to_f32() * opacity).to_u32()
    if new_a > 255:
        new_a = 255
    return (new_a << 24) | (argb_color & 0x00FFFFFF)

fn paint_tree_to_scene(layout: BeLayoutBox, viewport_w: i32, viewport_h: i32) -> RenderScene:
    """Convenience: generate paint commands from layout tree and convert to scene."""
    val commands = generate_paint_list(layout)
    paint_commands_to_scene(commands, viewport_w, viewport_h)
