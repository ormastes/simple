# Paint — Generate and Execute Paint Commands
#
# Walks the layout tree to produce a flat list of paint commands,
# then executes them against the 2D engine. The two-phase approach
# allows command inspection, reordering by z-index, and caching.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{be_dom_get_style,
    be_dom_get_display, be_dom_get_visibility, be_dom_get_opacity}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, BorderProps, CssOpacity}
use std.gc_async_mut.gpu.browser_engine.layout_box.{BeLayoutBox}
use common.render_scene.scene.{SceneCommand, RenderScene, render_scene,
    scene_fill_rect, scene_stroke_rect, scene_text, scene_rounded_rect,
    scene_gradient_rect, scene_image, rgba_to_argb}
use common.text_layout.text_layout.{text_line_height}
use std.gc_async_mut.gpu.browser_engine.style.transform.{parse_transform, transforms_to_matrix}
use examples.browser.shared.matrix4.Matrix4

# =========================================================================
# Paint Command
# =========================================================================

class PaintCommand:
    """A single drawing operation to be executed by the 2D engine.

    Fields:
        kind          - "rect", "text", "border", "image", "gradient"
        x, y          - top-left position in pixels
        width, height - size in pixels
        color         - fill color as RGBA u32
        text_val      - text content (for "text" kind)
        font_size     - font size in pixels (for "text" kind)
        border_radius - corner radius in pixels
        border_width  - border stroke width
        border_color  - border stroke color
        opacity       - alpha multiplier (0.0-1.0)
        pixels        - ARGB pixels for "image" kind
        pixel_width   - source image width
        pixel_height  - source image height
    """
    kind: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: u32
    text_val: text
    font_size: i32
    border_radius: i32
    border_width: i32
    border_color: u32
    opacity: f32
    pixels: [u32]
    pixel_width: i32
    pixel_height: i32

    static fn rect(x: i32, y: i32, w: i32, h: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "rect", x: x, y: y, width: w, height: h,
            color: color, text_val: "", font_size: 16,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0, pixels: [], pixel_width: 0, pixel_height: 0
        )

    static fn text_cmd(x: i32, y: i32, content: text, font_size: i32, color: u32) -> PaintCommand:
        return PaintCommand(
            kind: "text", x: x, y: y, width: 0, height: 0,
            color: color, text_val: content, font_size: font_size,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0, pixels: [], pixel_width: 0, pixel_height: 0
        )

    static fn border(x: i32, y: i32, w: i32, h: i32, bw: i32, bc: u32, radius: i32) -> PaintCommand:
        return PaintCommand(
            kind: "border", x: x, y: y, width: w, height: h,
            color: 0, text_val: "", font_size: 0,
            border_radius: radius, border_width: bw, border_color: bc,
            opacity: 1.0, pixels: [], pixel_width: 0, pixel_height: 0
        )

    static fn shadow(x: i32, y: i32, w: i32, h: i32, color: u32, opacity: f32) -> PaintCommand:
        return PaintCommand(
            kind: "rect", x: x, y: y, width: w, height: h,
            color: color, text_val: "", font_size: 0,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: opacity, pixels: [], pixel_width: 0, pixel_height: 0
        )

    static fn image(x: i32, y: i32, w: i32, h: i32, pixels: [u32], pixel_width: i32, pixel_height: i32) -> PaintCommand:
        return PaintCommand(
            kind: "image", x: x, y: y, width: w, height: h,
            color: 0, text_val: "", font_size: 0,
            border_radius: 0, border_width: 0, border_color: 0,
            opacity: 1.0, pixels: pixels, pixel_width: pixel_width, pixel_height: pixel_height
        )

fn _wrap_text_lines(content: text, font_size: i32, max_width: i32) -> [text]:
    if content.len() == 0:
        return [""]
    if max_width <= 0:
        return [content]

    var lines: [text] = []
    var line = ""
    var line_width: i32 = 0
    for ch in content:
        val cp = ch.char_code_at(0)
        if cp == 10:
            lines.push(line)
            line = ""
            line_width = 0
            continue
        val adv = if font_size <= 8: 5 else: 8
        if line.len() > 0 and line_width + adv > max_width:
            lines.push(line)
            line = ""
            line_width = 0
            if cp == 32:
                continue
        line = line + ch
        line_width = line_width + adv
    if line.len() > 0 or lines.len() == 0:
        lines.push(line)
    lines

# =========================================================================
# Paint List Generation
# =========================================================================

fn generate_paint_list(layout: BeLayoutBox) -> [PaintCommand]:
    """Walk the layout tree and generate a flat list of paint commands.

    Commands are generated in tree order (pre-order traversal),
    which naturally produces correct back-to-front painting for
    non-positioned elements.
    """
    var commands: [PaintCommand] = []
    commands = paint_layout_box(layout, commands)
    return commands

fn paint_layout_box(box: BeLayoutBox, commands: [PaintCommand]) -> [PaintCommand]:
    """Generate paint commands for a single layout box and its children."""
    var cmds = commands
    val node = box.node

    # Skip invisible nodes — use accessors to avoid cross-module FieldGet bug
    val paint_disp = be_dom_get_display(node)
    if paint_disp == "none":
        return cmds

    val paint_vis = be_dom_get_visibility(node)
    if paint_vis == "hidden":
        return cmds

    val paint_opacity = be_dom_get_opacity(node)
    if paint_opacity.value < 0.01:
        return cmds

    val style = be_dom_get_style(node)

    # 0. Box shadows (painted before background per CSS spec)
    var shadow_idx = 0
    while shadow_idx < style.box_shadows.len():
        val shadow = style.box_shadows[shadow_idx]
        shadow_idx = shadow_idx + 1
        if not shadow.inset:
            # Outer shadow: offset rect with spread expansion, semi-transparent
            val sx = box.x + shadow.offset_x - shadow.spread_radius
            val sy = box.y + shadow.offset_y - shadow.spread_radius
            val sw = box.width + shadow.spread_radius * 2
            val sh = box.height + shadow.spread_radius * 2

            if shadow.blur_radius > 0:
                # Approximate blur with concentric semi-transparent rects
                val steps = if shadow.blur_radius > 8: 4 else: 2
                var si: i32 = steps
                while si > 0:
                    val expand = shadow.blur_radius * si / steps
                    val alpha_factor = 1.0 / (si + 1).to_f32()
                    var s_cmd = PaintCommand.rect(
                        sx - expand, sy - expand,
                        sw + expand * 2, sh + expand * 2,
                        shadow.color
                    )
                    s_cmd.opacity = style.opacity * alpha_factor
                    s_cmd.border_radius = style.border_radius
                    cmds.push(s_cmd)
                    si = si - 1
            else:
                var s_cmd = PaintCommand.rect(sx, sy, sw, sh, shadow.color)
                s_cmd.opacity = style.opacity
                s_cmd.border_radius = style.border_radius
                cmds.push(s_cmd)

    # 0b. Backdrop blur (before background, blurs existing content behind element)
    if style.backdrop_filter_blur > 0:
        var blur_cmd = PaintCommand(
            kind: "backdrop_blur",
            x: box.x, y: box.y,
            width: box.width, height: box.height,
            color: 0, text_val: "",
            font_size: style.backdrop_filter_blur,
            border_radius: style.border_radius,
            border_width: 0, border_color: 0,
            opacity: 1.0, pixels: [], pixel_width: 0, pixel_height: 0
        )
        cmds.push(blur_cmd)

    # 1. Background (gradient or solid)
    if style.gradient_set:
        var grad_cmd = PaintCommand(
            kind: "gradient",
            x: box.content_x - style.padding.left,
            y: box.content_y - style.padding.top,
            width: box.content_width + style.padding.horizontal(),
            height: box.content_height + style.padding.vertical(),
            color: style.gradient_color1,
            text_val: "",
            font_size: style.gradient_angle,
            border_radius: style.border_radius,
            border_width: 0,
            border_color: style.gradient_color2,
            opacity: style.opacity, pixels: [], pixel_width: 0, pixel_height: 0
        )
        cmds.push(grad_cmd)

    if style.background_color != 0x00000000:
        var bg_cmd = PaintCommand.rect(
            box.content_x - style.padding.left,
            box.content_y - style.padding.top,
            box.content_width + style.padding.horizontal(),
            box.content_height + style.padding.vertical(),
            style.background_color
        )
        bg_cmd.border_radius = style.border_radius
        bg_cmd.opacity = style.opacity
        cmds.push(bg_cmd)

    # 2. Border — drawn around the padding box. box.height may include
    # margin.vertical() (layout stores total height with margin), so derive
    # the border box from the (correct) content + padding + border extents.
    if style.border.width > 0 and style.border.style != "none":
        val bbw = style.border.width
        val b_cmd = PaintCommand.border(
            box.content_x - style.padding.left - bbw,
            box.content_y - style.padding.top - bbw,
            box.content_width + style.padding.horizontal() + bbw * 2,
            box.content_height + style.padding.vertical() + bbw * 2,
            bbw, style.border.color,
            style.border_radius
        )
        cmds.push(b_cmd)

    # 3. Text content
    if node.is_text_node() and node.text_content.len() > 0:
        val line_h = if style.font_size <= 8:
            text_line_height(style.font_size)
        else:
            style.font_size + style.font_size / 5
        val wrapped_lines = _wrap_text_lines(node.text_content, style.font_size, box.content_width)
        var line_idx: i32 = 0
        while line_idx < wrapped_lines.len():
            val line = wrapped_lines[line_idx]
            val line_y = box.content_y + line_idx * line_h
            val t_cmd = PaintCommand.text_cmd(
                box.content_x, line_y,
                line, style.font_size, style.color
            )
            cmds.push(t_cmd)

            # 3b. Text decoration (underline, overline, line-through)
            if style.text_decoration != "none" and style.text_decoration != "":
                var text_width = line.len() * (if style.font_size <= 8: 5 else: 8)
                if text_width <= 0:
                    text_width = box.content_width
                val deco_h = 1
                if style.text_decoration == "underline":
                    val deco_y = line_y + style.font_size + 2
                    cmds.push(PaintCommand.rect(box.content_x, deco_y, text_width, deco_h, style.color))
                else if style.text_decoration == "overline":
                    val deco_y = line_y - 1
                    cmds.push(PaintCommand.rect(box.content_x, deco_y, text_width, deco_h, style.color))
                else if style.text_decoration == "line-through":
                    val deco_y = line_y + style.font_size / 2
                    cmds.push(PaintCommand.rect(box.content_x, deco_y, text_width, deco_h, style.color))
            line_idx = line_idx + 1

    # 4. Children
    var child_idx = 0
    while child_idx < box.children.len():
        val child = box.children[child_idx]
        child_idx = child_idx + 1
        cmds = paint_layout_box(child, cmds)

    return cmds

# =========================================================================
# Paint -> RenderScene Bridge
# =========================================================================

fn paint_commands_to_scene(commands: [PaintCommand], viewport_w: i32, viewport_h: i32) -> RenderScene:
    """Convert paint commands to a RenderScene for the render_scene executor.

    Maps PaintCommand kinds to SceneCommand factory calls:
      - rect     -> scene_fill_rect
      - text     -> scene_text
      - border   -> scene_stroke_rect
      - gradient -> scene_gradient_rect
    """
    var scene_cmds: [SceneCommand] = []
    var cmd_idx = 0
    while cmd_idx < commands.len():
        val cmd = commands[cmd_idx]
        cmd_idx = cmd_idx + 1
        match cmd.kind:
            "rect" =>
                val argb_color = apply_opacity_to_argb(rgba_to_argb(cmd.color), cmd.opacity)
                if cmd.border_radius > 0:
                    scene_cmds.push(scene_rounded_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color, cmd.border_radius))
                else:
                    scene_cmds.push(scene_fill_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color))
            "text" =>
                val argb_color = rgba_to_argb(cmd.color)
                scene_cmds.push(scene_text(cmd.x, cmd.y, cmd.text_val, argb_color, cmd.font_size))
            "border" =>
                val argb_color = rgba_to_argb(cmd.border_color)
                scene_cmds.push(scene_stroke_rect(cmd.x, cmd.y, cmd.width, cmd.height, argb_color, cmd.border_width))
            "gradient" =>
                val c1 = apply_opacity_to_argb(rgba_to_argb(cmd.color), cmd.opacity)
                val c2 = apply_opacity_to_argb(rgba_to_argb(cmd.border_color), cmd.opacity)
                val angle = cmd.font_size  # angle stored in font_size field
                if cmd.border_radius > 0:
                    # For rounded gradients, use rounded rect with first color as approximation
                    # then overlay gradient (imperfect but reasonable)
                    scene_cmds.push(scene_gradient_rect(cmd.x, cmd.y, cmd.width, cmd.height, c1, c2))
                else:
                    scene_cmds.push(scene_gradient_rect(cmd.x, cmd.y, cmd.width, cmd.height, c1, c2))
            "backdrop_blur" =>
                # Emit a blur_rect scene command — the executor reads the existing
                # pixel buffer, applies box blur, and writes back
                val blur_radius = cmd.font_size  # blur radius stored in font_size
                var blur_scene = SceneCommand(
                    kind: "blur_rect",
                    x: cmd.x, y: cmd.y,
                    width: cmd.width, height: cmd.height,
                    color: 0, text_val: "",
                    font_size: blur_radius,
                    border_radius: cmd.border_radius,
                    stroke_width: 0, stroke_color: 0,
                    color2: 0, opacity: 1.0,
                    pixels: [], pixel_width: 0, pixel_height: 0
                )
                scene_cmds.push(blur_scene)
            "image" =>
                if cmd.pixels.len() > 0 and cmd.pixel_width > 0 and cmd.pixel_height > 0 and cmd.width > 0 and cmd.height > 0:
                    scene_cmds.push(scene_image(cmd.x, cmd.y, cmd.width, cmd.height, cmd.pixels, cmd.pixel_width, cmd.pixel_height))
            _ =>
                pass_dn
    render_scene(scene_cmds, viewport_w, viewport_h)

fn apply_opacity_to_argb(argb_color: u32, opacity: f32) -> u32:
    """Multiply the alpha channel of an ARGB color by an opacity factor (0.0-1.0)."""
    if opacity >= 1.0:
        return argb_color
    if opacity <= 0.0:
        return argb_color & 0x00FFFFFF  # zero alpha, keep RGB
    val a = (argb_color >> 24) & 0xFF
    var new_a = (a.to_f32() * opacity).to_u32()
    if new_a > 255:
        new_a = 255
    return (new_a << 24) | (argb_color & 0x00FFFFFF)

fn paint_tree_to_scene(layout: BeLayoutBox, viewport_w: i32, viewport_h: i32) -> RenderScene:
    """Convenience: generate paint commands from layout tree and convert to scene."""
    val commands = generate_paint_list(layout)
    paint_commands_to_scene(commands, viewport_w, viewport_h)

# =========================================================================
# Object-Fit / Object-Position
# =========================================================================

class ObjectFitResult:
    """Destination rect for a replaced element after applying object-fit."""
    dest_x: f64
    dest_y: f64
    dest_width: f64
    dest_height: f64

pub fn compute_object_fit(obj_width: f64, obj_height: f64, box_width: f64, box_height: f64, fit: text, position: text) -> ObjectFitResult:
    """Compute the destination rect for a replaced element (e.g. img) given its
    natural size, the box size, and the object-fit / object-position values."""
    var dest_w = box_width
    var dest_h = box_height
    var dest_x = 0.0
    var dest_y = 0.0

    if fit == "fill" or fit == "":
        dest_w = box_width
        dest_h = box_height
    else if fit == "none":
        dest_w = obj_width
        dest_h = obj_height
    else if fit == "contain":
        if obj_width > 0.0 and obj_height > 0.0:
            val scale_x = box_width / obj_width
            val scale_y = box_height / obj_height
            val scale = if scale_x < scale_y: scale_x else: scale_y
            dest_w = obj_width * scale
            dest_h = obj_height * scale
    else if fit == "cover":
        if obj_width > 0.0 and obj_height > 0.0:
            val scale_x = box_width / obj_width
            val scale_y = box_height / obj_height
            val scale = if scale_x > scale_y: scale_x else: scale_y
            dest_w = obj_width * scale
            dest_h = obj_height * scale
    else if fit == "scale-down":
        if obj_width > 0.0 and obj_height > 0.0:
            val scale_x = box_width / obj_width
            val scale_y = box_height / obj_height
            val scale_contain = if scale_x < scale_y: scale_x else: scale_y
            val scale = if scale_contain < 1.0: scale_contain else: 1.0
            dest_w = obj_width * scale
            dest_h = obj_height * scale

    # Apply object-position (default "50% 50%")
    val pos = if position == "": "50% 50%" else: position
    val space_idx = pos.index_of(" ")
    var pos_x_str = "50%"
    var pos_y_str = "50%"
    if space_idx >= 0:
        pos_x_str = pos.slice(0, space_idx).trim()
        pos_y_str = pos.slice(space_idx + 1, pos.len()).trim()

    val offset_x = _resolve_position_axis(pos_x_str, box_width, dest_w)
    val offset_y = _resolve_position_axis(pos_y_str, box_height, dest_h)
    dest_x = offset_x
    dest_y = offset_y

    return ObjectFitResult(dest_x: dest_x, dest_y: dest_y, dest_width: dest_w, dest_height: dest_h)

fn _resolve_position_axis(value: text, box_dim: f64, dest_dim: f64) -> f64:
    val free = box_dim - dest_dim
    if value == "left" or value == "top" or value == "0%":
        return 0.0
    if value == "right" or value == "bottom" or value == "100%":
        return free
    if value == "center" or value == "50%":
        return free * 0.5
    if value.ends_with("%"):
        val pct_str = value.slice(0, value.len() - 1)
        val pct = pct_str.to_f64() / 100.0
        return free * pct
    if value.ends_with("px"):
        val px_str = value.slice(0, value.len() - 2)
        return px_str.to_f64()
    return free * 0.5

# =========================================================================
# Scrollbar Rendering
# =========================================================================

pub fn paint_scrollbar(x: f64, y: f64, width: f64, height: f64, content_height: f64, scroll_y: f64) -> [PaintCommand]:
    """Generate paint commands for a vertical scrollbar.
    Renders a track rect and a proportional thumb based on scroll position."""
    var cmds: [PaintCommand] = []
    val bar_w = 8
    val track_x = (x + width - bar_w.to_f64()).to_i32()
    val track_y = y.to_i32()
    val track_h = height.to_i32()
    val track_color: u32 = 0xFFEEEEEE

    var track_cmd = PaintCommand.rect(track_x, track_y, bar_w, track_h, track_color)
    cmds.push(track_cmd)

    if content_height > height and content_height > 0.0:
        val ratio = height / content_height
        val thumb_h_f = height * ratio
        val thumb_h = if thumb_h_f < 16.0: 16 else: thumb_h_f.to_i32()
        val max_scroll = content_height - height
        val scroll_ratio = if max_scroll > 0.0: scroll_y / max_scroll else: 0.0
        val max_thumb_offset = height - thumb_h.to_f64()
        val thumb_offset = (max_thumb_offset * scroll_ratio).to_i32()
        val thumb_y = track_y + thumb_offset
        val thumb_color: u32 = 0xFF888888
        var thumb_cmd = PaintCommand.rect(track_x, thumb_y, bar_w, thumb_h, thumb_color)
        cmds.push(thumb_cmd)

    return cmds

# =========================================================================
# Transform Painting
# =========================================================================

pub fn apply_transform_to_commands(cmds: [PaintCommand], transform: text, origin_x: f64, origin_y: f64) -> [PaintCommand]:
    """Apply a CSS transform to a list of paint commands by adjusting their positions.
    Transforms each command's top-left and bottom-right corners through the matrix."""
    if transform == "" or transform == "none":
        return cmds

    val fns = parse_transform(transform)
    if fns.len() == 0:
        return cmds

    val mat = transforms_to_matrix(fns)

    var result: [PaintCommand] = []
    var i = 0
    while i < cmds.len():
        val cmd = cmds[i]
        i = i + 1

        val local_x = cmd.x.to_f64() - origin_x
        val local_y = cmd.y.to_f64() - origin_y
        val tl = mat.transform_point(local_x, local_y)
        val new_x = (origin_x + tl[0]).to_i32()
        val new_y = (origin_y + tl[1]).to_i32()

        val local_br_x = local_x + cmd.width.to_f64()
        val local_br_y = local_y + cmd.height.to_f64()
        val br = mat.transform_point(local_br_x, local_br_y)
        val new_w = ((origin_x + br[0]) - new_x.to_f64()).to_i32()
        val new_h = ((origin_y + br[1]) - new_y.to_f64()).to_i32()

        var new_cmd = PaintCommand(
            kind: cmd.kind,
            x: new_x, y: new_y,
            width: new_w, height: new_h,
            color: cmd.color,
            text_val: cmd.text_val,
            font_size: cmd.font_size,
            border_radius: cmd.border_radius,
            border_width: cmd.border_width,
            border_color: cmd.border_color,
            opacity: cmd.opacity,
            pixels: cmd.pixels,
            pixel_width: cmd.pixel_width,
            pixel_height: cmd.pixel_height
        )
        result.push(new_cmd)

    return result
