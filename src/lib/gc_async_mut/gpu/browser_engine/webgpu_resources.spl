"""Browser WebGPU resource handles.

This module keeps browser-facing WebGPU resources as deterministic Simple-level
handles. It validates descriptors before allocating IDs so rejected resources do
not perturb later handle sequences.
"""

use std.gc_async_mut.gpu.browser_engine.webgpu_types.{
    GPU_TEXTURE_FORMAT_BGRA8_UNORM, GPU_TEXTURE_FORMAT_RGBA8_UNORM,
    GPU_TEXTURE_FORMAT_RGBA16_FLOAT, GPU_TEXTURE_FORMAT_DEPTH24_PLUS
}

pub val WEBGPU_BUFFER_USAGE_MAP_READ: i32 = 1
pub val WEBGPU_BUFFER_USAGE_MAP_WRITE: i32 = 2
pub val WEBGPU_BUFFER_USAGE_COPY_SRC: i32 = 4
pub val WEBGPU_BUFFER_USAGE_COPY_DST: i32 = 8
pub val WEBGPU_BUFFER_USAGE_INDEX: i32 = 16
pub val WEBGPU_BUFFER_USAGE_VERTEX: i32 = 32
pub val WEBGPU_BUFFER_USAGE_UNIFORM: i32 = 64
pub val WEBGPU_BUFFER_USAGE_STORAGE: i32 = 128
pub val WEBGPU_BUFFER_USAGE_INDIRECT: i32 = 256
pub val WEBGPU_BUFFER_USAGE_QUERY_RESOLVE: i32 = 512
pub val WEBGPU_BUFFER_USAGE_ALL: i32 = 1023

pub val WEBGPU_TEXTURE_USAGE_COPY_SRC: i32 = 1
pub val WEBGPU_TEXTURE_USAGE_COPY_DST: i32 = 2
pub val WEBGPU_TEXTURE_USAGE_TEXTURE_BINDING: i32 = 4
pub val WEBGPU_TEXTURE_USAGE_STORAGE_BINDING: i32 = 8
pub val WEBGPU_TEXTURE_USAGE_RENDER_ATTACHMENT: i32 = 16
pub val WEBGPU_TEXTURE_USAGE_ALL: i32 = 31

pub val WEBGPU_TEXTURE_DIMENSION_2D: text = "2d"
pub val WEBGPU_TEXTURE_DIMENSION_3D: text = "3d"
pub val WEBGPU_TEXTURE_VIEW_DIMENSION_CUBE: text = "cube"

pub val WEBGPU_SHADER_STAGE_VERTEX: i32 = 1
pub val WEBGPU_SHADER_STAGE_FRAGMENT: i32 = 2
pub val WEBGPU_SHADER_STAGE_COMPUTE: i32 = 4
pub val WEBGPU_SHADER_STAGE_ALL: i32 = 7

pub val WEBGPU_BINDING_TYPE_UNIFORM_BUFFER: i32 = 1
pub val WEBGPU_BINDING_TYPE_STORAGE_BUFFER: i32 = 2
pub val WEBGPU_BINDING_TYPE_READONLY_STORAGE_BUFFER: i32 = 3
pub val WEBGPU_BINDING_TYPE_TEXTURE: i32 = 4
pub val WEBGPU_BINDING_TYPE_STORAGE_TEXTURE: i32 = 5
pub val WEBGPU_BINDING_TYPE_SAMPLER: i32 = 6

pub class GPUBufferHandle:
    id: i32
    label: text
    size: i64
    usage: i32
    valid: bool
    error: text

pub class GPUTextureHandle:
    id: i32
    label: text
    width: i32
    height: i32
    depth_or_layers: i32
    format: text
    usage: i32
    valid: bool
    error: text

pub class GPUSamplerHandle:
    id: i32
    label: text
    address_mode_u: text
    address_mode_v: text
    mag_filter: text
    min_filter: text
    valid: bool
    error: text

pub class GPUBindGroupLayoutEntry:
    binding: i32
    visibility: i32
    binding_type: i32
    has_dynamic_offset: bool

    static fn buffer(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_UNIFORM_BUFFER, has_dynamic_offset: false)

    static fn dynamic_buffer(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_UNIFORM_BUFFER, has_dynamic_offset: true)

    static fn storage_buffer(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_STORAGE_BUFFER, has_dynamic_offset: false)

    static fn readonly_storage_buffer(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_READONLY_STORAGE_BUFFER, has_dynamic_offset: false)

    static fn dynamic_storage_buffer(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_STORAGE_BUFFER, has_dynamic_offset: true)

    static fn texture(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_TEXTURE, has_dynamic_offset: false)

    static fn storage_texture(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_STORAGE_TEXTURE, has_dynamic_offset: false)

    static fn sampler(binding: i32, visibility: i32) -> GPUBindGroupLayoutEntry:
        GPUBindGroupLayoutEntry(binding: binding, visibility: visibility, binding_type: WEBGPU_BINDING_TYPE_SAMPLER, has_dynamic_offset: false)

pub class GPUBindGroupEntry:
    binding: i32
    buffer_id: i32
    texture_id: i32
    sampler_id: i32

    static fn buffer(binding: i32, buffer_id: i32) -> GPUBindGroupEntry:
        GPUBindGroupEntry(binding: binding, buffer_id: buffer_id, texture_id: -1, sampler_id: -1)

    static fn texture(binding: i32, texture_id: i32) -> GPUBindGroupEntry:
        GPUBindGroupEntry(binding: binding, buffer_id: -1, texture_id: texture_id, sampler_id: -1)

    static fn sampler(binding: i32, sampler_id: i32) -> GPUBindGroupEntry:
        GPUBindGroupEntry(binding: binding, buffer_id: -1, texture_id: -1, sampler_id: sampler_id)

pub class GPUBindGroupLayoutHandle:
    id: i32
    label: text
    entries: [GPUBindGroupLayoutEntry]
    valid: bool
    error: text

    fn entry_count() -> i32:
        self.entries.len()

pub class GPUBindGroupHandle:
    id: i32
    label: text
    layout_id: i32
    entries: [GPUBindGroupEntry]
    valid: bool
    error: text

    fn entry_count() -> i32:
        self.entries.len()

pub class WebGPUResourceTable:
    next_resource_id: i32
    buffers: [GPUBufferHandle]
    textures: [GPUTextureHandle]
    samplers: [GPUSamplerHandle]
    bind_group_layouts: [GPUBindGroupLayoutHandle]
    bind_groups: [GPUBindGroupHandle]
    last_error: text

    static fn create() -> WebGPUResourceTable:
        WebGPUResourceTable(
            next_resource_id: 1,
            buffers: [],
            textures: [],
            samplers: [],
            bind_group_layouts: [],
            bind_groups: [],
            last_error: ""
        )

    me create_buffer(label: text, size: i64, usage: i32) -> GPUBufferHandle:
        val err = webgpu_validate_buffer_descriptor(size, usage)
        if err != "":
            self.last_error = err
            return GPUBufferHandle(id: -1, label: label, size: size, usage: usage, valid: false, error: err)
        val id = self.next_resource_id
        self.next_resource_id = self.next_resource_id + 1
        val handle = GPUBufferHandle(id: id, label: label, size: size, usage: usage, valid: true, error: "")
        self.buffers.push(handle)
        self.last_error = ""
        handle

    me create_texture(label: text, width: i32, height: i32, depth_or_layers: i32, format: text, usage: i32) -> GPUTextureHandle:
        val err = webgpu_validate_texture_descriptor(width, height, depth_or_layers, format, usage)
        if err != "":
            self.last_error = err
            return GPUTextureHandle(id: -1, label: label, width: width, height: height, depth_or_layers: depth_or_layers, format: format, usage: usage, valid: false, error: err)
        val id = self.next_resource_id
        self.next_resource_id = self.next_resource_id + 1
        val handle = GPUTextureHandle(id: id, label: label, width: width, height: height, depth_or_layers: depth_or_layers, format: format, usage: usage, valid: true, error: "")
        self.textures.push(handle)
        self.last_error = ""
        handle

    me create_sampler(label: text, address_mode_u: text, address_mode_v: text, mag_filter: text, min_filter: text) -> GPUSamplerHandle:
        val err = webgpu_validate_sampler_descriptor(address_mode_u, address_mode_v, mag_filter, min_filter)
        if err != "":
            self.last_error = err
            return GPUSamplerHandle(id: -1, label: label, address_mode_u: address_mode_u, address_mode_v: address_mode_v, mag_filter: mag_filter, min_filter: min_filter, valid: false, error: err)
        val id = self.next_resource_id
        self.next_resource_id = self.next_resource_id + 1
        val handle = GPUSamplerHandle(id: id, label: label, address_mode_u: address_mode_u, address_mode_v: address_mode_v, mag_filter: mag_filter, min_filter: min_filter, valid: true, error: "")
        self.samplers.push(handle)
        self.last_error = ""
        handle

    me create_bind_group_layout(label: text, entries: [GPUBindGroupLayoutEntry]) -> GPUBindGroupLayoutHandle:
        val err = webgpu_validate_bind_group_layout_descriptor(entries)
        if err != "":
            self.last_error = err
            return GPUBindGroupLayoutHandle(id: -1, label: label, entries: entries, valid: false, error: err)
        val id = self.next_resource_id
        self.next_resource_id = self.next_resource_id + 1
        val handle = GPUBindGroupLayoutHandle(id: id, label: label, entries: entries, valid: true, error: "")
        self.bind_group_layouts.push(handle)
        self.last_error = ""
        handle

    me create_bind_group(label: text, layout_id: i32, entries: [GPUBindGroupEntry]) -> GPUBindGroupHandle:
        val layout = self.find_bind_group_layout(layout_id)
        if not layout.valid:
            self.last_error = "GPUBindGroup layout does not exist"
            return GPUBindGroupHandle(id: -1, label: label, layout_id: layout_id, entries: entries, valid: false, error: self.last_error)
        val err = self.validate_bind_group_entries(layout, entries)
        if err != "":
            self.last_error = err
            return GPUBindGroupHandle(id: -1, label: label, layout_id: layout_id, entries: entries, valid: false, error: err)
        val id = self.next_resource_id
        self.next_resource_id = self.next_resource_id + 1
        val handle = GPUBindGroupHandle(id: id, label: label, layout_id: layout_id, entries: entries, valid: true, error: "")
        self.bind_groups.push(handle)
        self.last_error = ""
        handle

    fn resource_count() -> i32:
        self.buffers.len() + self.textures.len() + self.samplers.len() +
            self.bind_group_layouts.len() + self.bind_groups.len()

    me clear():
        self.next_resource_id = 1
        self.buffers.clear()
        self.textures.clear()
        self.samplers.clear()
        self.bind_group_layouts.clear()
        self.bind_groups.clear()
        self.last_error = ""

    fn find_bind_group_layout(layout_id: i32) -> GPUBindGroupLayoutHandle:
        var i = 0
        while i < self.bind_group_layouts.len():
            val layout = self.bind_group_layouts[i]
            if layout.id == layout_id and layout.valid:
                return layout
            i = i + 1
        GPUBindGroupLayoutHandle(id: -1, label: "", entries: [], valid: false, error: "GPUBindGroupLayout does not exist")

    fn has_buffer(buffer_id: i32) -> bool:
        var i = 0
        while i < self.buffers.len():
            val buffer = self.buffers[i]
            if buffer.id == buffer_id and buffer.valid:
                return true
            i = i + 1
        false

    fn has_texture(texture_id: i32) -> bool:
        var i = 0
        while i < self.textures.len():
            val texture = self.textures[i]
            if texture.id == texture_id and texture.valid:
                return true
            i = i + 1
        false

    fn has_sampler(sampler_id: i32) -> bool:
        var i = 0
        while i < self.samplers.len():
            val sampler = self.samplers[i]
            if sampler.id == sampler_id and sampler.valid:
                return true
            i = i + 1
        false

    fn validate_bind_group_entries(layout: GPUBindGroupLayoutHandle, entries: [GPUBindGroupEntry]) -> text:
        var j = 0
        while j < entries.len():
            val raw_entry = entries[j]
            if raw_entry.binding < 0:
                return "GPUBindGroup binding must be non-negative"
            if webgpu_bind_group_entry_seen(entries, raw_entry.binding, j):
                return "GPUBindGroup bindings must be unique"
            j = j + 1
        if entries.len() != layout.entries.len():
            return "GPUBindGroup entry count must match layout"
        var i = 0
        while i < layout.entries.len():
            val layout_entry = layout.entries[i]
            val entry = webgpu_find_bind_group_entry(entries, layout_entry.binding)
            if not webgpu_bind_group_entry_exists(entry):
                return "GPUBindGroup entry is missing layout binding"
            val match_err = self.validate_bind_group_entry_resource(layout_entry, entry)
            if match_err != "":
                return match_err
            i = i + 1
        ""

    fn validate_bind_group_entry_resource(layout_entry: GPUBindGroupLayoutEntry, entry: GPUBindGroupEntry) -> text:
        val is_buffer_binding = layout_entry.binding_type == WEBGPU_BINDING_TYPE_UNIFORM_BUFFER or layout_entry.binding_type == WEBGPU_BINDING_TYPE_STORAGE_BUFFER or layout_entry.binding_type == WEBGPU_BINDING_TYPE_READONLY_STORAGE_BUFFER
        val is_texture_binding = layout_entry.binding_type == WEBGPU_BINDING_TYPE_TEXTURE or layout_entry.binding_type == WEBGPU_BINDING_TYPE_STORAGE_TEXTURE
        if is_buffer_binding:
            if entry.buffer_id < 0 or entry.texture_id >= 0 or entry.sampler_id >= 0:
                return "GPUBindGroup buffer binding must reference a buffer"
            if not self.has_buffer(entry.buffer_id):
                return "GPUBindGroup buffer resource does not exist"
            return ""
        if is_texture_binding:
            if entry.texture_id < 0 or entry.buffer_id >= 0 or entry.sampler_id >= 0:
                return "GPUBindGroup texture binding must reference a texture"
            if not self.has_texture(entry.texture_id):
                return "GPUBindGroup texture resource does not exist"
            return ""
        if layout_entry.binding_type == WEBGPU_BINDING_TYPE_SAMPLER:
            if entry.sampler_id < 0 or entry.buffer_id >= 0 or entry.texture_id >= 0:
                return "GPUBindGroup sampler binding must reference a sampler"
            if not self.has_sampler(entry.sampler_id):
                return "GPUBindGroup sampler resource does not exist"
            return ""
        "GPUBindGroup layout binding type is not supported"

pub fn webgpu_validate_buffer_descriptor(size: i64, usage: i32) -> text:
    if size <= 0:
        return "GPUBuffer size must be positive"
    if not webgpu_is_supported_buffer_usage(usage):
        return "GPUBuffer usage is not supported"
    ""

pub fn webgpu_find_buffer(resources: WebGPUResourceTable, buffer_id: i32) -> GPUBufferHandle:
    var i = 0
    while i < resources.buffers.len():
        val buffer = resources.buffers[i]
        if buffer.id == buffer_id and buffer.valid:
            return buffer
        i = i + 1
    GPUBufferHandle(id: -1, label: "", size: 0, usage: 0, valid: false, error: "GPUBuffer does not exist")

pub fn webgpu_find_texture(resources: WebGPUResourceTable, texture_id: i32) -> GPUTextureHandle:
    var i = 0
    while i < resources.textures.len():
        val texture = resources.textures[i]
        if texture.id == texture_id and texture.valid:
            return texture
        i = i + 1
    GPUTextureHandle(id: -1, label: "", width: 0, height: 0, depth_or_layers: 0, format: "", usage: 0, valid: false, error: "GPUTexture does not exist")

pub fn webgpu_find_bind_group(resources: WebGPUResourceTable, bind_group_id: i32) -> GPUBindGroupHandle:
    var i = 0
    while i < resources.bind_groups.len():
        val bind_group = resources.bind_groups[i]
        if bind_group.id == bind_group_id and bind_group.valid:
            return bind_group
        i = i + 1
    GPUBindGroupHandle(id: -1, label: "", layout_id: -1, entries: [], valid: false, error: "GPUBindGroup does not exist")

pub fn webgpu_validate_texture_descriptor(width: i32, height: i32, depth_or_layers: i32, format: text, usage: i32) -> text:
    if width <= 0 or height <= 0 or depth_or_layers <= 0:
        return "GPUTexture size must be positive"
    if not webgpu_is_supported_texture_format(format):
        return "GPUTexture format is not supported"
    if not webgpu_is_supported_texture_usage(usage):
        return "GPUTexture usage is not supported"
    ""

pub fn webgpu_validate_extended_texture_descriptor(width: i32, height: i32, depth_or_layers: i32, format: text, usage: i32, dimension: text, mip_level_count: i32, sample_count: i32, view_dimension: text) -> text:
    val basic_err = webgpu_validate_texture_descriptor(width, height, depth_or_layers, format, usage)
    if basic_err != "":
        return basic_err
    if not webgpu_is_supported_texture_dimension(dimension):
        return "GPUTexture dimension is not supported"
    if mip_level_count <= 0:
        return "GPUTexture mipLevelCount must be positive"
    if not webgpu_is_supported_sample_count(sample_count):
        return "GPUTexture sampleCount is not supported"
    if sample_count > 1 and mip_level_count != 1:
        return "GPUTexture multisampled textures must have one mip level"
    if sample_count > 1 and dimension != WEBGPU_TEXTURE_DIMENSION_2D:
        return "GPUTexture multisampling requires 2d texture dimension"
    if sample_count > 1 and depth_or_layers != 1:
        return "GPUTexture multisampling requires one array layer"
    if mip_level_count > webgpu_max_mip_level_count(width, height, depth_or_layers, dimension):
        return "GPUTexture mipLevelCount exceeds texture size"
    if view_dimension == WEBGPU_TEXTURE_VIEW_DIMENSION_CUBE:
        if dimension != WEBGPU_TEXTURE_DIMENSION_2D:
            return "GPUTexture cube views require 2d texture dimension"
        if depth_or_layers != 6:
            return "GPUTexture cube views require exactly six array layers"
        if width != height:
            return "GPUTexture cube views require square faces"
    else: if view_dimension != "" and view_dimension != dimension:
        return "GPUTexture view dimension is not supported"
    ""

pub fn webgpu_max_mip_level_count(width: i32, height: i32, depth_or_layers: i32, dimension: text) -> i32:
    var largest = width
    if height > largest:
        largest = height
    if dimension == WEBGPU_TEXTURE_DIMENSION_3D and depth_or_layers > largest:
        largest = depth_or_layers
    var levels = 1
    var size = largest
    while size > 1:
        size = size / 2
        levels = levels + 1
    levels

pub fn webgpu_validate_sampler_descriptor(address_mode_u: text, address_mode_v: text, mag_filter: text, min_filter: text) -> text:
    if not webgpu_is_supported_address_mode(address_mode_u) or not webgpu_is_supported_address_mode(address_mode_v):
        return "GPUSampler address mode is not supported"
    if not webgpu_is_supported_filter_mode(mag_filter) or not webgpu_is_supported_filter_mode(min_filter):
        return "GPUSampler filter mode is not supported"
    ""

pub fn webgpu_validate_bind_group_layout_descriptor(entries: [GPUBindGroupLayoutEntry]) -> text:
    if entries.len() == 0:
        return "GPUBindGroupLayout must have at least one entry"
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry.binding < 0:
            return "GPUBindGroupLayout binding must be non-negative"
        if not webgpu_is_supported_shader_visibility(entry.visibility):
            return "GPUBindGroupLayout visibility is not supported"
        if not webgpu_is_supported_binding_type(entry.binding_type):
            return "GPUBindGroupLayout binding type is not supported"
        if entry.has_dynamic_offset and not webgpu_is_buffer_binding_type(entry.binding_type):
            return "GPUBindGroupLayout dynamic offsets require buffer bindings"
        if webgpu_layout_binding_seen(entries, entry.binding, i):
            return "GPUBindGroupLayout bindings must be unique"
        i = i + 1
    ""

pub fn webgpu_count_dynamic_bind_group_layout_entries(entries: [GPUBindGroupLayoutEntry]) -> i32:
    var count = 0
    var i = 0
    while i < entries.len():
        if entries[i].has_dynamic_offset:
            count = count + 1
        i = i + 1
    count

pub fn webgpu_is_supported_buffer_usage(usage: i32) -> bool:
    usage > 0 and (usage & WEBGPU_BUFFER_USAGE_ALL) == usage

pub fn webgpu_is_supported_texture_usage(usage: i32) -> bool:
    usage > 0 and (usage & WEBGPU_TEXTURE_USAGE_ALL) == usage

pub fn webgpu_is_supported_texture_format(format: text) -> bool:
    format == GPU_TEXTURE_FORMAT_BGRA8_UNORM or
        format == GPU_TEXTURE_FORMAT_RGBA8_UNORM or
        format == GPU_TEXTURE_FORMAT_RGBA16_FLOAT or
        format == GPU_TEXTURE_FORMAT_DEPTH24_PLUS

pub fn webgpu_is_supported_texture_dimension(dimension: text) -> bool:
    dimension == WEBGPU_TEXTURE_DIMENSION_2D or dimension == WEBGPU_TEXTURE_DIMENSION_3D

pub fn webgpu_is_supported_sample_count(sample_count: i32) -> bool:
    sample_count == 1 or sample_count == 4

pub fn webgpu_is_supported_address_mode(mode: text) -> bool:
    mode == "clamp-to-edge" or mode == "repeat" or mode == "mirror-repeat"

pub fn webgpu_is_supported_filter_mode(mode: text) -> bool:
    mode == "nearest" or mode == "linear"

pub fn webgpu_is_supported_shader_visibility(visibility: i32) -> bool:
    visibility > 0 and (visibility & WEBGPU_SHADER_STAGE_ALL) == visibility

pub fn webgpu_is_supported_binding_type(binding_type: i32) -> bool:
    binding_type == WEBGPU_BINDING_TYPE_UNIFORM_BUFFER or
        binding_type == WEBGPU_BINDING_TYPE_STORAGE_BUFFER or
        binding_type == WEBGPU_BINDING_TYPE_READONLY_STORAGE_BUFFER or
        binding_type == WEBGPU_BINDING_TYPE_TEXTURE or
        binding_type == WEBGPU_BINDING_TYPE_STORAGE_TEXTURE or
        binding_type == WEBGPU_BINDING_TYPE_SAMPLER

pub fn webgpu_is_buffer_binding_type(binding_type: i32) -> bool:
    binding_type == WEBGPU_BINDING_TYPE_UNIFORM_BUFFER or
        binding_type == WEBGPU_BINDING_TYPE_STORAGE_BUFFER or
        binding_type == WEBGPU_BINDING_TYPE_READONLY_STORAGE_BUFFER

pub fn webgpu_layout_binding_seen(entries: [GPUBindGroupLayoutEntry], binding: i32, before_index: i32) -> bool:
    var i = 0
    while i < before_index:
        if entries[i].binding == binding:
            return true
        i = i + 1
    false

pub fn webgpu_bind_group_entry_seen(entries: [GPUBindGroupEntry], binding: i32, before_index: i32) -> bool:
    var i = 0
    while i < before_index:
        if entries[i].binding == binding:
            return true
        i = i + 1
    false

pub fn webgpu_bind_group_entry_exists(entry: GPUBindGroupEntry) -> bool:
    entry.binding >= 0

pub fn webgpu_find_bind_group_entry(entries: [GPUBindGroupEntry], binding: i32) -> GPUBindGroupEntry:
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry.binding == binding:
            return entry
        i = i + 1
    GPUBindGroupEntry(binding: -1, buffer_id: -1, texture_id: -1, sampler_id: -1)
