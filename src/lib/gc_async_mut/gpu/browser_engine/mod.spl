# Browser Rendering Engine
#
# Sits between the UI library and the 2D engine in the rendering stack:
#   Apps -> UI Lib -> Browser Engine (this) -> 2D Engine -> Backend
#
# Takes a DOM/CSS tree (from UI widgets or HTML) and renders it using
# the 2D engine's drawing primitives.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BoxEdges, BorderProps,
    parse_css_value, resolve_style, default_style}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_tree, layout_block,
    layout_flex, layout_text, hit_test}
use std.gc_async_mut.gpu.browser_engine.paint.{PaintCommand, generate_paint_list,
    paint_commands_to_scene, paint_tree_to_scene}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{widget_to_dom, ui_tree_to_dom,
    html_string_to_dom}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer, BeRenderResult}
