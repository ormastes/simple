# Browser Rendering Engine
#
# Sits between the UI library and the 2D engine in the rendering stack:
#   Apps -> UI Lib -> Browser Engine (this) -> 2D Engine -> Backend
#
# Takes a DOM/CSS tree (from UI widgets or HTML) and renders it using
# the 2D engine's drawing primitives.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BoxEdges, BorderProps,
    BoxShadow, parse_css_value, resolve_style, be_default_style}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_tree, layout_block,
    layout_flex, layout_text, hit_test}
use std.gc_async_mut.gpu.browser_engine.paint.{PaintCommand, generate_paint_list,
    paint_commands_to_scene, paint_tree_to_scene}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{widget_to_dom, ui_tree_to_dom,
    html_string_to_dom, WidgetToDomApi}
use std.gc_async_mut.gpu.browser_engine.style_block.{process_style_blocks}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer, BeRenderResult}
use std.gc_async_mut.gpu.browser_engine.browser_engine2d_bridge.{
    create_gpu_browser_renderer, create_gpu_browser_renderer_with_backend,
    create_software_browser_renderer}
use std.gc_async_mut.gpu.browser_engine.glass_demo_registry.{GlassDemo, list_glass_demos,
    list_core_glass_demos, list_glass_demos_dark_only}
use std.gc_async_mut.gpu.browser_engine.glass_pipeline_compare.{PipelineOutput,
    render_both_pipelines, render_web_pipeline_only, render_engine_pipeline_only}
use std.gc_async_mut.gpu.browser_engine.glass_comparison_runner.{GlassComparisonResult,
    GlassComparisonReport, run_glass_comparison, run_core_glass_comparison,
    run_full_glass_comparison, print_glass_report, glass_report_to_markdown}
