# Glass Comparison Runner
#
# Runs pixel-level comparisons across all glass-themed demos,
# producing per-channel diff results and markdown reports.

use os.compositor.screenshot_compare.{ComparisonResult, ChannelDiffResult,
    compare_pixel_buffers, compare_per_channel, find_diff_regions,
    generate_diff_image, print_comparison_report, print_channel_report,
    format_percentage, DiffRegion}
use std.gc_async_mut.gpu.browser_engine.glass_demo_registry.{GlassDemo, list_glass_demos,
    list_core_glass_demos}
use std.gc_async_mut.gpu.browser_engine.glass_pipeline_compare.{PipelineOutput,
    render_both_pipelines}
use std.gc_async_mut.gpu.browser_engine.browser_renderer_utils.{browser_renderer_find_char,
    browser_renderer_split_spaces, br_find_str}
use std.gc_async_mut.gpu.browser_engine.dom_color_named.{split_top_level_commas}

# ============================================================================
# Types
# ============================================================================

struct GlassComparisonResult:
    """Result of comparing one demo across both pipelines."""
    demo_name: text
    theme: text
    overall: ComparisonResult
    channels: [ChannelDiffResult]    # R, G, B, A
    diff_regions: [DiffRegion]
    missing_features: [text]
    error: text

struct GlassComparisonReport:
    """Aggregate report across all demos."""
    results: [GlassComparisonResult]
    total_demos: i32
    identical_count: i32    # 100% match
    similar_count: i32      # >= 95%
    moderate_count: i32     # >= 80%
    divergent_count: i32    # < 80%

# ============================================================================
# Runner
# ============================================================================

val DEFAULT_WIDTH: i32 = 64
val DEFAULT_HEIGHT: i32 = 48
val DEFAULT_THRESHOLD: i32 = 4

fn run_glass_comparison(demos: [GlassDemo], width: i32, height: i32) -> GlassComparisonReport:
    """Run pixel comparison for all demos and produce an aggregate report."""
    var results: [GlassComparisonResult] = []
    var identical: i32 = 0
    var similar: i32 = 0
    var moderate: i32 = 0
    var divergent: i32 = 0

    for demo in demos:
        print "  Comparing: {demo.name} ({demo.theme})..."
        val output = render_both_pipelines(demo.sdn_path, demo.theme, width, height)

        if output.error != "":
            results.push(GlassComparisonResult(
                demo_name: demo.name, theme: demo.theme,
                overall: ComparisonResult(total_pixels: 0, matching_pixels: 0,
                    different_pixels: 0, match_percentage: 0,
                    max_channel_diff: 0, total_channel_diff: 0),
                channels: [], diff_regions: [],
                missing_features: [],
                error: output.error
            ))
            divergent = divergent + 1
            continue

        if output.web_pixels.len() == 0 or output.engine_pixels.len() == 0:
            results.push(GlassComparisonResult(
                demo_name: demo.name, theme: demo.theme,
                overall: ComparisonResult(total_pixels: 0, matching_pixels: 0,
                    different_pixels: 0, match_percentage: 0,
                    max_channel_diff: 0, total_channel_diff: 0),
                channels: [], diff_regions: [],
                missing_features: [],
                error: "Empty pixel buffer"
            ))
            divergent = divergent + 1
            continue

        # Overall comparison
        val overall = compare_pixel_buffers(
            output.web_pixels, output.engine_pixels,
            width, height, DEFAULT_THRESHOLD)

        # Per-channel comparison
        val channels = compare_per_channel(
            output.web_pixels, output.engine_pixels,
            width, height, DEFAULT_THRESHOLD)

        # Diff regions
        val regions = find_diff_regions(
            output.web_pixels, output.engine_pixels,
            width, height, DEFAULT_THRESHOLD)

        # Missing features
        val missing = identify_missing_features(output.web_html)

        results.push(GlassComparisonResult(
            demo_name: demo.name, theme: demo.theme,
            overall: overall, channels: channels,
            diff_regions: regions,
            missing_features: missing,
            error: ""
        ))

        val pct = overall.match_percentage / 100
        if overall.match_percentage == 10000:
            identical = identical + 1
        elif pct >= 95:
            similar = similar + 1
        elif pct >= 80:
            moderate = moderate + 1
        else:
            divergent = divergent + 1

    GlassComparisonReport(
        results: results,
        total_demos: demos.len().to_i32(),
        identical_count: identical,
        similar_count: similar,
        moderate_count: moderate,
        divergent_count: divergent
    )

fn run_core_glass_comparison() -> GlassComparisonReport:
    """Run comparison on the core subset (3 demos × 2 themes)."""
    val demos = list_core_glass_demos()
    run_glass_comparison(demos, DEFAULT_WIDTH, DEFAULT_HEIGHT)

fn run_full_glass_comparison() -> GlassComparisonReport:
    """Run comparison on all demos (27 × 2 themes)."""
    val demos = list_glass_demos()
    run_glass_comparison(demos, DEFAULT_WIDTH, DEFAULT_HEIGHT)

# ============================================================================
# Missing Feature Detection
# ============================================================================

pub fn identify_missing_features(html: text) -> [text]:
    """Scan generated HTML/CSS for CSS features not supported by browser engine."""
    var missing: [text] = []

    if html.contains("backdrop-filter"):
        missing.push("backdrop-filter: blur()")
    if html.contains("radial-gradient"):
        missing.push("radial-gradient()")
    if html.contains("text-shadow"):
        missing.push("text-shadow")
    if glass_has_unsupported_transform(html):
        missing.push("transform")
    if html.contains("filter:"):
        missing.push("filter")
    if html.contains("mix-blend-mode"):
        missing.push("mix-blend-mode")
    if html.contains("transition:"):
        missing.push("transition (static-only)")

    missing

fn glass_has_unsupported_transform(html: text) -> bool:
    val lower = html.lower()
    var pos: i64 = 0
    while pos < lower.len():
        val transform_pos = br_find_str(lower, "transform:", pos)
        if transform_pos >= 999999999:
            return false
        val value_start = transform_pos + 10
        var value_end = browser_renderer_find_char(lower, ";", value_start)
        val brace_end = browser_renderer_find_char(lower, "}", value_start)
        if value_end >= 999999999 or (brace_end < value_end and brace_end >= 0):
            value_end = brace_end
        if value_end >= 999999999:
            value_end = lower.len()
        val value = lower.slice(value_start, value_end).trim()
        if not glass_transform_value_is_simple_translate(value):
            return true
        pos = value_end + 1
    false

fn glass_transform_value_is_simple_translate(value: text) -> bool:
    if value.len() == 0 or value == "none":
        return true
    if value.contains("rotate(") or value.contains("scale(") or value.contains("skew(") or value.contains("matrix(") or value.contains("perspective("):
        return false
    if value.starts_with("translate(") or value.starts_with("translatex(") or value.starts_with("translatey("):
        val close = browser_renderer_find_char(value, ")", 0)
        if close >= 999999999:
            return false
        if value.slice(close + 1, value.len()).trim().len() != 0:
            return false
        return glass_translate_args_are_supported(value)
    false

fn glass_translate_args_are_supported(value: text) -> bool:
    val open = browser_renderer_find_char(value, "(", 0)
    val close = browser_renderer_find_char(value, ")", open + 1)
    if open >= 999999999 or close >= 999999999:
        return false
    val inner = value.slice(open + 1, close).trim()
    if inner.len() == 0:
        return false
    if inner.contains("calc(") or inner.contains("em") or inner.contains("rem") or inner.contains("vw") or inner.contains("vh"):
        return false
    var args: [text] = []
    if browser_renderer_find_char(inner, ",", 0) >= 999999999:
        args = browser_renderer_split_spaces(inner)
    else:
        args = split_top_level_commas(inner)
    if value.starts_with("translate("):
        if args.len() == 0 or args.len() > 2:
            return false
    elif args.len() != 1:
        return false
    for arg in args:
        if not glass_translate_arg_is_supported(arg):
            return false
    true

fn glass_translate_arg_is_supported(arg: text) -> bool:
    val trimmed = arg.trim().lower()
    if trimmed.len() == 0:
        return false
    if trimmed == "0":
        return true
    var core = trimmed
    if trimmed.ends_with("px"):
        core = trimmed.slice(0, trimmed.len() - 2).trim()
    elif trimmed.ends_with("%"):
        core = trimmed.slice(0, trimmed.len() - 1).trim()
    else:
        return false
    glass_is_integer_token(core)

fn glass_is_integer_token(value: text) -> bool:
    if value.len() == 0:
        return false
    var idx = 0
    if value.char_at(0) == "-":
        idx = 1
    if idx >= value.len():
        return false
    while idx < value.len():
        val ch = value.char_at(idx)
        if ch < "0" or ch > "9":
            return false
        idx = idx + 1
    true
# ============================================================================
# Report Output
# ============================================================================

fn print_glass_report(report: GlassComparisonReport):
    """Print a human-readable comparison report to stdout."""
    print "=========================================="
    print "  Glass Pipeline Comparison Report"
    print "=========================================="
    print ""
    print "  Total demos:   {report.total_demos}"
    print "  Identical:     {report.identical_count}"
    print "  Similar (95%+):{report.similar_count}"
    print "  Moderate (80%+):{report.moderate_count}"
    print "  Divergent:     {report.divergent_count}"
    print ""

    for r in report.results:
        if r.error != "":
            print "  [{r.demo_name}] ERROR: {r.error}"
            continue

        val pct = format_percentage(r.overall.match_percentage)
        val status = if r.overall.match_percentage == 10000: "IDENTICAL"
            elif r.overall.match_percentage / 100 >= 95: "SIMILAR"
            elif r.overall.match_percentage / 100 >= 80: "MODERATE"
            else: "DIVERGENT"

        print "  [{r.demo_name}] {pct} match — {status}"
        print "    Diff pixels: {r.overall.different_pixels}, max channel diff: {r.overall.max_channel_diff}"
        print_channel_report(r.channels)

        if r.missing_features.len() > 0:
            var features_str = ""
            for f in r.missing_features:
                if features_str.len() > 0:
                    features_str = "{features_str}, {f}"
                else:
                    features_str = f
            print "    Missing CSS: {features_str}"

        if r.diff_regions.len() > 0:
            print "    Diff regions: {r.diff_regions.len()}"

        print ""

    print "=========================================="

fn glass_report_to_markdown(report: GlassComparisonReport) -> text:
    """Generate a markdown report for the comparison results."""
    var md = "# Glass Pipeline Comparison Report\n\n"

    md = "{md}## Summary\n\n"
    md = "{md}| Metric | Count |\n"
    md = "{md}|--------|-------|\n"
    md = "{md}| Total demos | {report.total_demos} |\n"
    md = "{md}| Identical (100%) | {report.identical_count} |\n"
    md = "{md}| Similar (>=95%) | {report.similar_count} |\n"
    md = "{md}| Moderate (>=80%) | {report.moderate_count} |\n"
    md = "{md}| Divergent (<80%) | {report.divergent_count} |\n\n"

    # CSS feature gap analysis
    md = "{md}## CSS Feature Gap Analysis\n\n"
    md = "{md}| Feature | Demos Using It | Browser Engine Support |\n"
    md = "{md}|---------|---------------|------------------------|\n"

    # Count feature usage across demos
    var backdrop_count: i32 = 0
    var shadow_count: i32 = 0
    var lingrad_count: i32 = 0
    var radgrad_count: i32 = 0
    var pseudo_count: i32 = 0
    var transform_count: i32 = 0

    for r in report.results:
        for f in r.missing_features:
            if f == "backdrop-filter: blur()":
                backdrop_count = backdrop_count + 1
            elif f == "box-shadow (multi-layer)":
                shadow_count = shadow_count + 1
            elif f == "linear-gradient()":
                lingrad_count = lingrad_count + 1
            elif f == "radial-gradient()":
                radgrad_count = radgrad_count + 1
            elif f == "pseudo-elements (::before/::after)":
                pseudo_count = pseudo_count + 1
            elif f == "transform":
                transform_count = transform_count + 1

    md = "{md}| backdrop-filter: blur() | {backdrop_count} | NOT SUPPORTED |\n"
    md = "{md}| box-shadow (multi-layer) | {shadow_count} | NOT SUPPORTED |\n"
    md = "{md}| linear-gradient() | {lingrad_count} | PARTIAL |\n"
    md = "{md}| radial-gradient() | {radgrad_count} | NOT SUPPORTED |\n"
    md = "{md}| transform | {transform_count} | PARTIAL |\n"
    md = "{md}| pseudo-elements | {pseudo_count} | SUPPORTED |\n\n"

    # Per-demo results table
    md = "{md}## Per-Demo Results\n\n"
    md = "{md}| Demo | Theme | Match % | R diff | G diff | B diff | A diff | Status |\n"
    md = "{md}|------|-------|---------|--------|--------|--------|--------|--------|\n"

    for r in report.results:
        if r.error != "":
            md = "{md}| {r.demo_name} | {r.theme} | ERROR | - | - | - | - | {r.error} |\n"
            continue

        val pct = format_percentage(r.overall.match_percentage)
        val status = if r.overall.match_percentage == 10000: "IDENTICAL"
            elif r.overall.match_percentage / 100 >= 95: "SIMILAR"
            elif r.overall.match_percentage / 100 >= 80: "MODERATE"
            else: "DIVERGENT"

        var r_pct = "-"
        var g_pct = "-"
        var b_pct = "-"
        var a_pct = "-"
        if r.channels.len() >= 4:
            r_pct = format_percentage(r.channels[0].match_pct)
            g_pct = format_percentage(r.channels[1].match_pct)
            b_pct = format_percentage(r.channels[2].match_pct)
            a_pct = format_percentage(r.channels[3].match_pct)

        md = "{md}| {r.demo_name} | {r.theme} | {pct} | {r_pct} | {g_pct} | {b_pct} | {a_pct} | {status} |\n"

    md = "{md}\n"

    # Diff region summary
    md = "{md}## Diff Region Summary\n\n"
    var total_regions: i32 = 0
    for r in report.results:
        total_regions = total_regions + r.diff_regions.len().to_i32()
    md = "{md}Total diff regions across all demos: {total_regions}\n\n"

    md
