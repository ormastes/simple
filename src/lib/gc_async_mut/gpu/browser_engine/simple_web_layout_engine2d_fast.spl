# Unified web render entry: HTML -> layout -> Draw IR -> Engine2D fast mode.
#
# This is the native-accelerated counterpart to the software layout renderer
# (simple_web_layout_render_html_software_pixels) and the pinned heuristic
# renderer (simple_web_engine2d_render_html_pixels), which remain explicit
# compatibility oracles. This entry runs the real
# layout/paint Draw IR on an Engine2D created in no-mirror fast mode, so the
# per-op interpreted framebuffer mirror (the entire render cost at desktop
# resolution — see
# doc/08_tracking/bug/engine2d_interpreted_mirror_dominates_render_2026-07-03.md)
# is collapsed to a 1x1 clip and the framebuffer is read back from the GPU in a
# single FFI hop.

use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_draw_ir_result}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{Engine2dDrawIrAdvResult, engine2d_draw_ir_adv_composition}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback, engine2d_readback}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendStatus}
use common.ui.web_render_api.{WebRenderMaterialFallbackProvenance}

class SimpleWebLayoutEngine2DExecutionResult:
    render: Engine2dDrawIrAdvResult
    material_fallback: WebRenderMaterialFallbackProvenance

class SimpleWebLayoutEngine2DReadbackResult:
    readback: Engine2DReadback
    material_fallback: WebRenderMaterialFallbackProvenance

fn _simple_web_layout_render_html_engine2d_execution(html: text, width: i32, height: i32, backend_name: text) -> SimpleWebLayoutEngine2DExecutionResult:
    val layout_result = simple_web_layout_render_html_draw_ir_result(html, width, height)
    var engine = Engine2D.create_with_backend_fast(width, height, backend_name)
    engine.clear(0u32)
    val render = engine2d_draw_ir_adv_composition(engine, layout_result.composition, true)
    engine.shutdown()
    SimpleWebLayoutEngine2DExecutionResult(render: render, material_fallback: layout_result.material_fallback)

# Render `html` to a flat ARGB [u32] framebuffer through the layout Draw IR on an
# Engine2D in native-only fast mode. On Metal this is GPU-rendered with a
# one-shot readback; on other backends Engine2D.create_with_backend_fast() falls
# back to the normal (correct but interpreter-bound) path.
#
# The framebuffer is cleared to transparent black (0) first, matching the
# zero-initialized software surface the Draw IR executor otherwise paints onto,
# and — for Metal — arming gpu_frame_complete so read_pixels() takes the GPU
# download path rather than the shrunken mirror.
pub fn simple_web_layout_render_html_engine2d_result(html: text, width: i32, height: i32, backend_name: text) -> Engine2dDrawIrAdvResult:
    _simple_web_layout_render_html_engine2d_execution(html, width, height, backend_name).render

pub fn simple_web_layout_render_html_pixels_engine2d(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val execution = _simple_web_layout_render_html_engine2d_execution(html, width, height, backend_name)
    if execution.render.skipped_command_count != 0:
        return []
    execution.render.pixels

pub fn simple_web_layout_render_html_readback_engine2d_result(html: text, width: i32, height: i32, backend_name: text) -> SimpleWebLayoutEngine2DReadbackResult:
    if width <= 0 or height <= 0:
        return SimpleWebLayoutEngine2DReadbackResult(
            readback: engine2d_readback([], "unavailable"),
            material_fallback: WebRenderMaterialFallbackProvenance.none()
        )
    val execution = _simple_web_layout_render_html_engine2d_execution(html, width, height, backend_name)
    if execution.render.skipped_command_count != 0:
        return SimpleWebLayoutEngine2DReadbackResult(
            readback: engine2d_readback([], "unavailable"),
            material_fallback: execution.material_fallback
        )
    val pixel_count = execution.render.pixels.len().to_i64()
    val readback = Engine2DReadback(pixels: execution.render.pixels, source: execution.render.readback_source,
        backend_handle: execution.render.backend_handle, device_identity: execution.render.device_identity,
        pixel_count: pixel_count, checksum: execution.render.readback_checksum)
    SimpleWebLayoutEngine2DReadbackResult(readback: readback, material_fallback: execution.material_fallback)

pub fn simple_web_layout_render_html_readback_engine2d(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    simple_web_layout_render_html_readback_engine2d_result(html, width, height, backend_name).readback

# True when the Metal native fast path is genuinely available, so callers (e.g.
# the WM compositor at desktop resolution) can gate on it before routing a large
# scene through the fast entry instead of silently falling back to the
# interpreter-bound software mirror.
pub fn engine2d_fast_metal_available() -> bool:
    val probe = Engine2D.probe_backend(1, 1, "metal")
    probe.status == BackendStatus.Initialized

export simple_web_layout_render_html_pixels_engine2d
export simple_web_layout_render_html_readback_engine2d
export simple_web_layout_render_html_readback_engine2d_result
export simple_web_layout_render_html_engine2d_result
export SimpleWebLayoutEngine2DReadbackResult
export engine2d_fast_metal_available
