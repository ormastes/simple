# DOM Accessor and Dispatch Functions
#
# Free pub fn be_dom_* wrappers, BeDomFactory, and M15 tree-walk query helpers.
# Depends on dom.spl for BeDomNode, BeDomEvent, BeDomEventDispatch.

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, BeDomEvent, BeDomEventDispatch, BeDomFactory, normalize_dom_event_type, normalize_dom_key}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssPx, CssColor, CssOpacity, BoxShadow}

pub fn be_dom_get_style(node: BeDomNode) -> StyleProps:
    """Same-module accessor for node.style to avoid cross-module FieldGet issues."""
    node.style

pub fn be_dom_get_bg_color(node: BeDomNode) -> CssColor:
    CssColor(value: node.style.background_color)

pub fn be_dom_get_display(node: BeDomNode) -> text:
    css_get_display(node.style)

pub fn be_dom_get_visibility(node: BeDomNode) -> text:
    css_get_visibility(node.style)

pub fn be_dom_get_opacity(node: BeDomNode) -> CssOpacity:
    CssOpacity(value: node.style.opacity)

pub fn be_dom_get_color(node: BeDomNode) -> CssColor:
    CssColor(value: node.style.color)

pub fn be_dom_get_font_size(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.font_size)

pub fn be_dom_get_border_radius(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.border_radius)

pub fn be_dom_get_border_width(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.border.width)

pub fn be_dom_get_border_color(node: BeDomNode) -> CssColor:
    CssColor(value: node.style.border.color)

pub fn be_dom_get_border_style(node: BeDomNode) -> text:
    node.style.border.style

pub fn be_dom_get_padding_left(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.padding.left)

pub fn be_dom_get_padding_top(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.padding.top)

pub fn be_dom_get_padding_h(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.padding.horizontal())

pub fn be_dom_get_padding_v(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.padding.vertical())

pub fn be_dom_get_has_gradient(node: BeDomNode) -> bool:
    node.style.gradient_set

pub fn be_dom_get_gradient_c1(node: BeDomNode) -> CssColor:
    CssColor(value: node.style.gradient_color1)

pub fn be_dom_get_gradient_c2(node: BeDomNode) -> CssColor:
    CssColor(value: node.style.gradient_color2)

pub fn be_dom_get_text(node: BeDomNode) -> text:
    node.text_content

pub fn be_dom_get_children(node: BeDomNode) -> [BeDomNode]:
    node.children

pub fn be_dom_get_tag(node: BeDomNode) -> text:
    node.tag

pub fn be_dom_get_tag_name(node: BeDomNode) -> text:
    """Alias for be_dom_get_tag — WHATWG-style name used by M14 specs."""
    node.tag

pub fn be_dom_get_attribute(node: BeDomNode, key: text) -> text:
    """Alias for be_dom_get_attr — WHATWG-style name used by M14 specs."""
    be_dom_get_attr(node, key)

pub fn be_dom_get_text_content(node: BeDomNode) -> text:
    """Alias for be_dom_get_text — WHATWG-style name used by M14 specs."""
    node.text_content

pub fn be_dom_get_id(node: BeDomNode) -> text:
    node.id

pub fn be_dom_get_classes(node: BeDomNode) -> [text]:
    node.classes

pub fn be_dom_get_is_text(node: BeDomNode) -> bool:
    node.tag == "#text"

pub fn be_dom_get_attributes(node: BeDomNode) -> [text]:
    node.attributes

pub fn be_dom_get_attr(node: BeDomNode, key: text) -> text:
    node.get_attr(key)

pub fn be_dom_has_attr(node: BeDomNode, key: text) -> bool:
    node.has_attr(key)

pub fn be_dom_get_event_listener_count(node: BeDomNode, event_type: text) -> i32:
    node.event_listener_count(event_type)

pub fn be_dom_dispatch_event_actions(node: BeDomNode, event_type: text) -> [text]:
    node.dispatch_event_actions(event_type)

pub fn be_dom_create_event(node: BeDomNode, event_type: text, bubbles: bool, cancelable: bool) -> BeDomEvent:
    BeDomEvent.create(event_type, node.tag, node.id, node.tag, node.id, bubbles, cancelable)

pub fn be_dom_create_pointer_event(node: BeDomNode, event_type: text, bubbles: bool, cancelable: bool,
                                   client_x: i32, client_y: i32, button: i32, buttons: i32, detail: i32) -> BeDomEvent:
    BeDomEvent.pointer(event_type, node.tag, node.id, node.tag, node.id, bubbles, cancelable,
        client_x, client_y, button, buttons, detail)

pub fn be_dom_create_pointer_event_with_modifiers(node: BeDomNode, event_type: text, bubbles: bool, cancelable: bool,
                                                  client_x: i32, client_y: i32, button: i32, buttons: i32, detail: i32,
                                                  alt_key: bool, ctrl_key: bool, meta_key: bool, shift_key: bool) -> BeDomEvent:
    BeDomEvent.pointer_with_modifiers(event_type, node.tag, node.id, node.tag, node.id, bubbles, cancelable,
        client_x, client_y, button, buttons, detail, alt_key, ctrl_key, meta_key, shift_key)

pub fn be_dom_dispatch_event(node: BeDomNode, event_type: text, bubbles: bool, cancelable: bool) -> BeDomEventDispatch:
    node.dispatch_event(event_type, bubbles, cancelable)

pub fn be_dom_dispatch_event_apply_default(node: BeDomNode, event_type: text, bubbles: bool, cancelable: bool) -> BeDomNode:
    """Dispatch an event and return the node after any allowed default action."""
    val dispatch = node.dispatch_event(event_type, bubbles, cancelable)
    if dispatch.default_action_allowed:
        return be_dom_apply_default_action(node, dispatch.default_action)
    node

pub fn be_dom_keyboard_activation_event_for_target(target: BeDomNode, key: text) -> text:
    """Map a focused key press to the browser activation event it should synthesize."""
    if target.has_attr("disabled"):
        return ""
    val normalized_key = normalize_dom_key(key)
    if normalized_key == "enter":
        if target.tag == "a":
            return "click"
        if target.tag == "button":
            return "click"
        if target.tag == "input":
            val input_type = target.get_attr("type").lower()
            if input_type == "checkbox" or input_type == "radio" or input_type == "submit" or input_type == "button":
                return "click"
    elif normalized_key == "space":
        if target.tag == "button":
            return "click"
        if target.tag == "input":
            val input_type = target.get_attr("type").lower()
            if input_type == "checkbox" or input_type == "radio" or input_type == "button":
                return "click"
    ""

pub fn be_dom_dispatch_keyboard_activation_apply_default(node: BeDomNode, key: text) -> BeDomNode:
    """Apply the click default action synthesized by a focused keyboard activation."""
    val activation_event = be_dom_keyboard_activation_event_for_target(node, key)
    if activation_event == "":
        return node
    be_dom_dispatch_event_apply_default(node, activation_event, true, true)

pub fn be_dom_dispatch_event_path(path: [BeDomNode], event_type: text, bubbles: bool, cancelable: bool) -> BeDomEventDispatch:
    """Dispatch over an explicit root-to-target path with capture, target, and bubble phases."""
    if path.len() == 0:
        val empty_event = BeDomEvent.create(event_type, "", "", "", "", bubbles, cancelable)
        return BeDomEventDispatch.create(empty_event, [], [], [], "", false)
    val target = path[path.len() - 1]
    val event = BeDomEvent.create(event_type, target.tag, target.id, target.tag, target.id, bubbles, cancelable)
    be_dom_dispatch_event_path_with_event(path, event)

pub fn be_dom_dispatch_event_path_with_event(path: [BeDomNode], source_event: BeDomEvent) -> BeDomEventDispatch:
    """Dispatch a prebuilt event over an explicit root-to-target path."""
    if path.len() == 0:
        return BeDomEventDispatch.create(source_event, [], [], [], "", false)
    val target = path[path.len() - 1]
    var event = source_event
    var actions: [text] = []
    var phases: [text] = []
    var current_ids: [text] = []
    var propagation_stopped = false
    var immediate_stopped = false
    var capture_index = 0
    while capture_index + 1 < path.len() and not propagation_stopped:
        val capture_actions = path[capture_index].dispatch_event_actions_for_phase(event.event_type, "capture")
        var capture_action_index = 0
        while capture_action_index < capture_actions.len() and not immediate_stopped:
            actions.push(capture_actions[capture_action_index])
            phases.push("capture")
            current_ids.push(path[capture_index].id)
            if capture_actions[capture_action_index] == "prevent-default":
                event.prevent_default()
            elif capture_actions[capture_action_index] == "stop-propagation":
                propagation_stopped = true
            elif capture_actions[capture_action_index] == "stop-immediate-propagation":
                immediate_stopped = true
                propagation_stopped = true
            capture_action_index = capture_action_index + 1
        capture_index = capture_index + 1
    if not propagation_stopped:
        val target_actions = target.dispatch_event_actions_for_phase(event.event_type, "target")
        var target_action_index = 0
        while target_action_index < target_actions.len() and not immediate_stopped:
            actions.push(target_actions[target_action_index])
            phases.push("target")
            current_ids.push(target.id)
            if target_actions[target_action_index] == "prevent-default":
                event.prevent_default()
            elif target_actions[target_action_index] == "stop-propagation":
                propagation_stopped = true
            elif target_actions[target_action_index] == "stop-immediate-propagation":
                immediate_stopped = true
                propagation_stopped = true
            target_action_index = target_action_index + 1
    if event.bubbles and not propagation_stopped:
        var bubble_index = path.len() - 1
        while bubble_index > 0 and not propagation_stopped:
            bubble_index = bubble_index - 1
            val bubble_actions = path[bubble_index].dispatch_event_actions_for_phase(event.event_type, "bubble")
            var bubble_action_index = 0
            while bubble_action_index < bubble_actions.len() and not immediate_stopped:
                actions.push(bubble_actions[bubble_action_index])
                phases.push("bubble")
                current_ids.push(path[bubble_index].id)
                if bubble_actions[bubble_action_index] == "prevent-default":
                    event.prevent_default()
                elif bubble_actions[bubble_action_index] == "stop-propagation":
                    propagation_stopped = true
                elif bubble_actions[bubble_action_index] == "stop-immediate-propagation":
                    immediate_stopped = true
                    propagation_stopped = true
                bubble_action_index = bubble_action_index + 1
    event.propagation_stopped = propagation_stopped
    event.immediate_propagation_stopped = immediate_stopped
    val default_action = be_dom_default_action_for_target(target, event.event_type)
    BeDomEventDispatch.create(event, actions, phases, current_ids, default_action, default_action != "" and not event.default_prevented)

pub fn be_dom_find_path_to_id(root: BeDomNode, target_id: text) -> [BeDomNode]:
    """Return the first root-to-target path for an element id, or an empty path."""
    if target_id == "":
        return []
    if root.id == target_id:
        return [root]
    var child_index = 0
    while child_index < root.children.len():
        val child_path = be_dom_find_path_to_id(root.children[child_index], target_id)
        if child_path.len() > 0:
            var path: [BeDomNode] = [root]
            var i = 0
            while i < child_path.len():
                path.push(child_path[i])
                i = i + 1
            return path
        child_index = child_index + 1
    []

pub fn be_dom_dispatch_event_to_id(root: BeDomNode, target_id: text, event_type: text, bubbles: bool, cancelable: bool) -> BeDomEventDispatch:
    """Find a target by id and dispatch using the discovered root-to-target path."""
    be_dom_dispatch_event_path(be_dom_find_path_to_id(root, target_id), event_type, bubbles, cancelable)

pub fn be_dom_default_action_for_target(target: BeDomNode, event_type: text) -> text:
    """Return a deterministic token for focused browser default actions."""
    val normalized = normalize_dom_event_type(event_type)
    if normalized == "click":
        if target.tag == "a":
            val href = target.get_attr("href")
            if href != "":
                return "navigate:" + href
        if target.tag == "button":
            if target.has_attr("disabled"):
                return ""
            return "button-activate"
        if target.tag == "input":
            if target.has_attr("disabled"):
                return ""
            val input_type = target.get_attr("type").lower()
            if input_type == "checkbox":
                return "input-checkbox-toggle"
            if input_type == "radio":
                return "input-radio-select"
    if normalized == "submit" and target.tag == "form":
        return "form-submit"
    if normalized == "focus":
        if target.tag == "input" or target.tag == "button" or target.tag == "select" or target.tag == "textarea" or target.tag == "a":
            return "focus-element"
    ""

pub fn be_dom_apply_default_action(target: BeDomNode, default_action: text) -> BeDomNode:
    """Return a target node with the simplified browser default action applied."""
    var updated = target
    if default_action == "input-checkbox-toggle":
        if updated.has_attr("checked"):
            updated.remove_attr("checked")
        else:
            updated.set_attr("checked", "checked")
    elif default_action == "input-radio-select":
        updated.set_attr("checked", "checked")
    elif default_action == "focus-element":
        updated.set_attr("data-focused", "true")
    elif default_action == "button-activate":
        updated.set_attr("data-activated", "true")
    elif default_action == "form-submit":
        updated.set_attr("data-submitted", "true")
    elif default_action.starts_with("navigate:"):
        updated.set_attr("data-navigation", default_action.slice(9, default_action.len()))
    updated

pub fn be_dom_get_box_shadows(node: BeDomNode) -> [BoxShadow]:
    node.style.box_shadows

pub fn be_dom_get_backdrop_blur(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.backdrop_filter_blur)

pub fn be_dom_get_gradient_angle(node: BeDomNode) -> CssPx:
    CssPx(value: node.style.gradient_angle)

pub fn be_dom_get_text_decoration(node: BeDomNode) -> text:
    node.style.text_decoration

pub fn be_dom_set_style(node: BeDomNode, prop: text, value: text):
    """Standalone wrapper for node.set_style() across module boundaries."""
    node.set_style(prop, value)

pub fn be_dom_set_attr(node: BeDomNode, key: text, value: text):
    """Standalone wrapper for node.set_attr() across module boundaries."""
    node.set_attr(key, value)

pub fn be_dom_add_event_listener(node: BeDomNode, event_type: text, action: text):
    """Standalone wrapper for target/bubble DOM event listener registration."""
    node.add_event_listener(event_type, action)

pub fn be_dom_add_event_listener_with_capture(node: BeDomNode, event_type: text, action: text, capture: bool):
    """Standalone wrapper for capture or target/bubble DOM event listener registration."""
    node.add_event_listener_with_capture(event_type, action, capture)

pub fn be_dom_add_child(parent: BeDomNode, child: BeDomNode):
    """Standalone wrapper for parent.add_child() across module boundaries."""
    parent.add_child(child)

pub fn be_dom_set_children(node: BeDomNode, new_children: [BeDomNode]):
    """Replace this node's children array wholesale. Needed by tree-walk
    passes (style application, layout) because the interpreter copies class
    instances on array push/index, so a child fetched via `children[i]` is
    detached from the original; callers must rebuild the children array and
    write it back via this accessor to make mutations stick.
    """
    node.children = new_children

# Cross-module method resolution aliases — the import map indexes these
# with double-underscore convention matching ClassName__method lookups
pub fn BeDomNode__set_style(node: BeDomNode, prop: text, value: text):
    node.set_style(prop, value)

pub fn BeDomNode__add_child(parent: BeDomNode, child: BeDomNode):
    parent.add_child(child)

pub fn BeDomNode__add_event_listener(node: BeDomNode, event_type: text, action: text):
    node.add_event_listener(event_type, action)

pub fn BeDomNode__add_event_listener_with_capture(node: BeDomNode, event_type: text, action: text, capture: bool):
    node.add_event_listener_with_capture(event_type, action, capture)

# =========================================================================
# M15: DOM tree-walk query helpers
# =========================================================================

pub fn be_dom_find_by_id(root: BeDomNode, id: text) -> BeDomNode?:
    """Return the first node in the tree whose id field equals id, or nil."""
    if root.id == id:
        return root
    var i = 0
    while i < root.children.len():
        val found = be_dom_find_by_id(root.children[i], id)
        if found != nil:
            return found
        i = i + 1
    nil

pub fn be_dom_query_selector(root: BeDomNode, selector: text) -> BeDomNode?:
    """Return the first node matching a simple selector: tag, #id, or .class."""
    if selector.starts_with("#"):
        val id = selector.slice(1, selector.len())
        return be_dom_find_by_id(root, id)
    if selector.starts_with("."):
        val cls = selector.slice(1, selector.len())
        return _be_dom_find_by_class(root, cls)
    _be_dom_find_by_tag(root, selector)

fn _be_dom_find_by_tag(root: BeDomNode, tag: text) -> BeDomNode?:
    if root.tag == tag:
        return root
    var i = 0
    while i < root.children.len():
        val found = _be_dom_find_by_tag(root.children[i], tag)
        if found != nil:
            return found
        i = i + 1
    nil

fn _be_dom_find_by_class(root: BeDomNode, cls: text) -> BeDomNode?:
    var j = 0
    while j < root.classes.len():
        if root.classes[j] == cls:
            return root
        j = j + 1
    var i = 0
    while i < root.children.len():
        val found = _be_dom_find_by_class(root.children[i], cls)
        if found != nil:
            return found
        i = i + 1
    nil
