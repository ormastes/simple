
# Selector Matcher — CSS selector matching primitives
#
# Implements Blink-style selector matching: simple selectors, functional
# pseudo-classes (:is, :where, :has, :not, :empty, :first-child, :last-child,
# :only-child, :nth-child), attribute selectors, and multi-class compound
# selectors.
#
# Extracted from browser_renderer.spl to stay within the 800-line module limit.

use std.gc_async_mut.gpu.browser_engine.browser_renderer_utils.{
    browser_renderer_find_char, br_find_str,
    browser_renderer_split_spaces, browser_renderer_split_tag_parts,
    br_tag_attr_value, br_tag_has_attr, br_unquote_attr_value,
    br_merge_style_text}

# =========================================================================
# Selector-list scanning
# =========================================================================

fn br_selector_list_contains_simple(selector_list: text, wanted: text) -> bool:
    var segment_start: i64 = 0
    var idx: i64 = 0
    var paren_depth = 0
    while idx <= selector_list.len():
        if idx < selector_list.len():
            val ch = selector_list.char_at(idx)
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")" and paren_depth > 0:
                paren_depth = paren_depth - 1
        if idx == selector_list.len() or (selector_list.char_at(idx) == "," and paren_depth == 0):
            val part = selector_list.slice(segment_start, idx).trim().lower()
            if part == wanted or br_functional_selector_contains(part, wanted):
                return true
            segment_start = idx + 1
        idx = idx + 1
    false

fn br_functional_selector_contains(selector: text, wanted: text) -> bool:
    val is_pos = br_find_str(selector, ":is(", 0)
    val where_pos = br_find_str(selector, ":where(", 0)
    var fn_pos = is_pos
    if where_pos < fn_pos:
        fn_pos = where_pos
    if fn_pos >= 999999999:
        return false
    val prefix = selector.slice(0, fn_pos).trim()
    if prefix.len() > 0 and prefix != "*" and prefix != wanted and not wanted.starts_with(prefix):
        return false
    val open = browser_renderer_find_char(selector, "(", fn_pos)
    val close = browser_renderer_find_char(selector, ")", open + 1)
    if open >= 999999999 or close >= 999999999:
        return false
    var segment_start: i64 = open + 1
    var idx: i64 = open + 1
    while idx <= close:
        if idx == close or selector.char_at(idx) == ",":
            val option = selector.slice(segment_start, idx).trim()
            if option == wanted or (prefix.len() > 0 and prefix + option == wanted):
                return true
            segment_start = idx + 1
        idx = idx + 1
    false

fn br_selector_list_contains_has_descendant(selector_list: text, subject: text, subtree: text) -> bool:
    var segment_start: i64 = 0
    var idx: i64 = 0
    var paren_depth = 0
    while idx <= selector_list.len():
        if idx < selector_list.len():
            val ch = selector_list.char_at(idx)
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")" and paren_depth > 0:
                paren_depth = paren_depth - 1
        if idx == selector_list.len() or (selector_list.char_at(idx) == "," and paren_depth == 0):
            val part = selector_list.slice(segment_start, idx).trim().lower()
            if br_selector_matches_has_descendant(part, subject, subtree):
                return true
            segment_start = idx + 1
        idx = idx + 1
    false

