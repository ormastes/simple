# DOM Visual Effects Parsing
#
# Box shadow, backdrop filter, calc wiring.
# Depends on dom_color for parse_color_value and split_top_level_commas,
# and dom_color_named for find_char_in.

use std.gc_async_mut.gpu.browser_engine.css.{BoxShadow, CssValue, css_parse_length_or_calc}
use std.gc_async_mut.gpu.browser_engine.dom_color.{parse_color_value}
use std.gc_async_mut.gpu.browser_engine.dom_color_named.{split_top_level_commas, find_char_in}
use common.string_builder.{StringBuilder}

# =========================================================================
# Box Shadow Parser
# =========================================================================

pub fn parse_box_shadows(value: text) -> [BoxShadow]:
    """Parse CSS box-shadow value, supporting multiple comma-separated shadows.

    Format: [inset] offset-x offset-y [blur [spread]] color
    Multiple: shadow1, shadow2, ...
    """
    val shadow_strs = split_top_level_commas(value)
    var shadows: [BoxShadow] = []

    for shadow_str in shadow_strs:
        val shadow = parse_single_box_shadow(shadow_str.trim())
        if shadow.color != 0x00000000 or shadow.blur_radius > 0 or shadow.offset_x != 0 or shadow.offset_y != 0:
            shadows.push(shadow)

    shadows

pub fn parse_single_box_shadow(s: text) -> BoxShadow:
    """Parse a single box-shadow value.

    Examples:
      0 2px 4px rgba(0,0,0,0.2)
      0 0 0 1px rgba(255,255,255,0.05)
      0 1px 0 rgba(255,255,255,0.1) inset
      inset 0 1px 0 rgba(255,255,255,0.1)
    """
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return BoxShadow.none()

    var inset = false
    var work = trimmed

    # Check for 'inset' keyword
    if work.starts_with("inset ") or work.starts_with("inset\t"):
        inset = true
        val work_after_inset = work.slice(6, work.len())
        work = work_after_inset.trim()
    elif work.ends_with(" inset"):
        inset = true
        val work_before_inset = work.slice(0, work.len() - 6)
        work = work_before_inset.trim()

    # Split into tokens respecting parens
    val tokens = split_shadow_tokens(work)
    if tokens.len() < 3:
        return BoxShadow.none()

    # First 2-4 tokens are numeric values, last is color
    var offset_x: i32 = 0
    var offset_y: i32 = 0
    var blur: i32 = 0
    var spread: i32 = 0
    var color: u32 = 0x000000FF

    # Parse numeric values from the front
    var num_count: i32 = 0
    var nums: [i32] = []
    var color_start: i32 = 0

    for tok in tokens:
        val tv = tok.trim()
        if num_count < 4:
            # Try to parse as a number (px value)
            val stripped = if tv.ends_with("px"): tv.slice(0, tv.len() - 2) else: tv
            val parsed = stripped.parse_f64()
            if parsed != nil:
                val pval = parsed ?? 0.0
                nums.push(pval.to_i32())
                num_count = num_count + 1
                color_start = color_start + 1
                continue
        # Not a number — must be start of color
        break

    if nums.len() >= 2:
        offset_x = nums[0]
        offset_y = nums[1]
    if nums.len() >= 3:
        blur = nums[2]
    if nums.len() >= 4:
        spread = nums[3]

    # Remaining tokens form the color
    if color_start < tokens.len():
        var color_str = ""
        var ci = color_start
        while ci < tokens.len():
            val t = tokens[ci].trim()
            if t == "inset":
                inset = true
            else:
                if color_str.len() > 0:
                    color_str = "{color_str} {t}"
                else:
                    color_str = t
            ci = ci + 1
        if color_str.len() > 0:
            color = parse_color_value(color_str)

    BoxShadow(offset_x: offset_x, offset_y: offset_y,
        blur_radius: blur, spread_radius: spread,
        color: color, inset: inset)

pub fn split_shadow_tokens(s: text) -> [text]:
    """Split shadow value into tokens, keeping function calls like rgba(...) together."""
    var tokens: [text] = []
    val sb = StringBuilder.new()
    var depth: i32 = 0

    var idx_7 = 0
    while idx_7 < s.len():
        val ch = s.char_at(idx_7)
        if ch == "(":
            depth = depth + 1
            sb.push(ch)
        elif ch == ")":
            depth = depth - 1
            sb.push(ch)
        elif (ch == " " or ch == "\t") and depth == 0:
            val mid = sb.to_text().trim()
            if mid.len() > 0:
                tokens.push(mid)
            sb.clear()
        else:
            sb.push(ch)
        idx_7 = idx_7 + 1

    val tail2 = sb.to_text().trim()
    if tail2.len() > 0:
        tokens.push(tail2)

    tokens

# =========================================================================
# Backdrop Filter Parser
# =========================================================================

pub fn parse_blur_value(value: text) -> i32:
    """Parse backdrop-filter/filter value to extract blur radius.

    Handles: blur(20px), blur(20px) saturate(180%), etc.
    Returns blur radius in px, or 0 if not found.
    """
    val trimmed = value.trim()
    val blur_idx = find_substr(trimmed, "blur(")
    if blur_idx >= 999999999:
        return 0

    val start = blur_idx + 5  # length of "blur("
    val end = find_char_in(trimmed, ")", start)
    if end >= 999999999:
        return 0

    val inner_raw_blur = trimmed.slice(start, end)
    val inner = inner_raw_blur.trim()
    val num_str = if inner.ends_with("px"):
        inner.slice(0, inner.len() - 2)
    else:
        inner

    val parsed = num_str.parse_f64()
    if parsed != nil:
        val pval = parsed ?? 0.0
        return pval.to_i32()
    0

pub fn find_substr(haystack: text, needle: text) -> i32:
    """Find the first occurrence of needle in haystack. Returns 999999999 if not found."""
    val nlen = needle.len()
    if nlen == 0 or nlen > haystack.len():
        return 999999999
    var i: i32 = 0
    while i + nlen <= haystack.len():
        if haystack.slice(i, i + nlen) == needle:
            return i
        i = i + 1
    return 999999999

# =========================================================================
# calc() wiring — routes length-valued properties through css_ext::calc_resolve
# =========================================================================

pub fn parse_length_or_calc(value: text) -> CssValue:
    """Length/percentage parser with a `calc(...)` fast path.

    Detects the `calc(` prefix and delegates to `css_ext::calc_resolve`; on
    success yields a pixel-valued `CssValue`. Any parse failure — malformed
    expression, divide-by-zero, mixed units — falls back to the plain
    `parse_css_value` path so unrelated declarations keep working.
    """
    css_parse_length_or_calc(value)
