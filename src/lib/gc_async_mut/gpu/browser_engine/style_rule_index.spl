fn br_style_block_rule_for_nth_child_self(html: text, subject_selector: text, tag_content: text, nth: i32) -> text:
    val subject = subject_selector.trim().lower()
    if subject.len() == 0 or nth <= 0:
        return ""
    val lower_html = html.lower()
    var out = ""
    var search_pos: i64 = 0
    while search_pos < html.len():
        val style_pos = br_find_str(lower_html, "<style", search_pos)
        if style_pos >= 999999999:
            return out
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            return out
