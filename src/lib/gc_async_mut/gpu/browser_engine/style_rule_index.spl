        var rule_start: i64 = 0
        while rule_start < css.len():
            val open = browser_renderer_find_char(css, "{", rule_start)
            if open >= 999999999:
                break
            val close = browser_renderer_find_char(css, "}", open + 1)
            if close >= 999999999:
                break
            val selector_list = css.slice(rule_start, open)
            if br_selector_list_contains_nth_child_self(selector_list, subject, tag_content, nth):
                out = br_merge_style_text(out, css.slice(open + 1, close).trim())
            rule_start = close + 1
        search_pos = style_close + 1
    out

fn br_style_block_rule_for_attr_self(html: text, subject_selector: text, tag_content: text) -> text:
    _br_style_block_rule_by_mode(html, subject_selector, tag_content, "attr_self")

fn br_style_block_rule_for_multi_class(html: text, class_value: text) -> text:
    val classes = browser_renderer_split_spaces(class_value)
    if classes.len() < 2:
        return ""
    val lower = html.lower()
    var out = ""
    var search_pos: i64 = 0
    while search_pos < html.len():
        val style_pos = br_find_str(lower, "<style", search_pos)
        if style_pos >= 999999999:
            return out
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            return out
        val style_close = br_find_str(lower, "</style", style_open_end + 1)
        if style_close >= 999999999:
            return out
        val css = br_flatten_supports_blocks(br_flatten_layer_blocks(html.slice(style_open_end + 1, style_close)))
        var rule_start: i64 = 0
        while rule_start < css.len():
            val open = browser_renderer_find_char(css, "{", rule_start)
            if open >= 999999999:
                break
            val close = browser_renderer_find_char(css, "}", open + 1)
            if close >= 999999999:
                break
            val selector_list = css.slice(rule_start, open)
            if br_selector_list_contains_multi_class(selector_list, classes):
                out = br_merge_style_text(out, css.slice(open + 1, close).trim())
            rule_start = close + 1
        search_pos = style_close + 1
    out

# =========================================================================
# Core selector lookup
# =========================================================================

fn br_style_block_rule_for_selector(html: text, selector: text) -> text:
    val wanted = selector.trim().lower()
    if wanted.len() == 0:
        return ""
    val lower = html.lower()
    var out = ""
    var search_pos: i64 = 0
    while search_pos < html.len():
        val style_pos = br_find_str(lower, "<style", search_pos)
        if style_pos >= 999999999:
            return out
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            return out
        val style_close = br_find_str(lower, "</style", style_open_end + 1)
        if style_close >= 999999999:
            return out
        val css = br_flatten_supports_blocks(br_flatten_layer_blocks(html.slice(style_open_end + 1, style_close)))
        var rule_start: i64 = 0
        while rule_start < css.len():
            val open = browser_renderer_find_char(css, "{", rule_start)
            if open >= 999999999:
                break
            val close = browser_renderer_find_char(css, "}", open + 1)
            if close >= 999999999:
                break
            val selector_list = css.slice(rule_start, open)
            if br_selector_list_contains_simple(selector_list, wanted):
                out = br_merge_style_text(out, css.slice(open + 1, close).trim())
            rule_start = close + 1
        search_pos = style_close + 1
    out

# =========================================================================
# Content helpers used by empty_self
# =========================================================================

fn br_div_content_is_empty(html: text, content_start: i64) -> bool:
    val lower = html.lower()
    val close_pos = br_find_str(lower, "</div", content_start)
    if close_pos >= 999999999:
        return false
    html.slice(content_start, close_pos).trim().len() == 0
