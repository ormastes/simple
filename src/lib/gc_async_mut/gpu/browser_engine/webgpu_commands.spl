pub fn webgpu_validate_bind_group_dynamic_offsets(slot: i32, bind_group_id: i32, dynamic_offsets: [i32]) -> text:
    if slot < 0:
        return "GPUPassEncoder bind group slot must be non-negative"
    if bind_group_id <= 0:
        return "GPUPassEncoder bind group must be valid"
    var i = 0
    while i < dynamic_offsets.len():
        if dynamic_offsets[i] < 0:
            return "GPUPassEncoder dynamic offsets must be non-negative"
        if dynamic_offsets[i] % 256 != 0:
            return "GPUPassEncoder dynamic offsets must be 256-byte aligned"
        i = i + 1
    ""

pub fn webgpu_validate_render_pass_descriptor_with_resources(resources: WebGPUResourceTable, color_attachments: [GPURenderPassColorAttachment], depth_stencil_attachment: GPURenderPassDepthStencilAttachment) -> text:
    if color_attachments.len() == 0 and depth_stencil_attachment.texture_id < 0:
        return "GPURenderPassDescriptor requires at least one attachment"
    var expected_width = -1
    var expected_height = -1
    var expected_depth_or_layers = -1
    var i = 0
    while i < color_attachments.len():
        val attachment = color_attachments[i]
        if attachment.texture_id <= 0:
            return "GPURenderPassColorAttachment view must be valid"
        if webgpu_render_pass_color_attachment_seen(color_attachments, attachment.texture_id, i):
            return "GPURenderPassColorAttachment textures must be unique"
        val texture = webgpu_find_texture(resources, attachment.texture_id)
        if not texture.valid:
            return "GPURenderPassColorAttachment texture does not exist"
        if (texture.usage & WEBGPU_TEXTURE_USAGE_RENDER_ATTACHMENT) == 0:
            return "GPURenderPassColorAttachment texture missing RENDER_ATTACHMENT usage"
        if webgpu_is_depth_stencil_renderable_texture_format(texture.format):
            return "GPURenderPassColorAttachment format must be color-renderable"
        val dimensions_err = webgpu_validate_render_pass_attachment_dimensions(texture.width, texture.height, texture.depth_or_layers, expected_width, expected_height, expected_depth_or_layers)
        if dimensions_err != "":
            return dimensions_err
        if expected_width < 0:
            expected_width = texture.width
            expected_height = texture.height
            expected_depth_or_layers = texture.depth_or_layers
        i = i + 1
    if depth_stencil_attachment.texture_id == 0:
        return "GPURenderPassDepthStencilAttachment view must be valid"
    if depth_stencil_attachment.texture_id > 0:
        val depth_texture = webgpu_find_texture(resources, depth_stencil_attachment.texture_id)
        if not depth_texture.valid:
            return "GPURenderPassDepthStencilAttachment texture does not exist"
        if (depth_texture.usage & WEBGPU_TEXTURE_USAGE_RENDER_ATTACHMENT) == 0:
            return "GPURenderPassDepthStencilAttachment texture missing RENDER_ATTACHMENT usage"
        if not webgpu_is_depth_stencil_renderable_texture_format(depth_texture.format):
            return "GPURenderPassDepthStencilAttachment format must be depth-stencil-renderable"
        if not webgpu_is_stencil_capable_texture_format(depth_texture.format) and webgpu_depth_stencil_attachment_uses_stencil(depth_stencil_attachment):
            return "GPURenderPassDepthStencilAttachment stencil operations require a stencil-capable format"
        val depth_ops_err = webgpu_validate_render_pass_depth_stencil_ops(depth_stencil_attachment)
        if depth_ops_err != "":
            return depth_ops_err
        val depth_dimensions_err = webgpu_validate_render_pass_attachment_dimensions(depth_texture.width, depth_texture.height, depth_texture.depth_or_layers, expected_width, expected_height, expected_depth_or_layers)
        if depth_dimensions_err != "":
            return depth_dimensions_err
    ""

pub fn webgpu_render_pass_color_attachment_seen(color_attachments: [GPURenderPassColorAttachment], texture_id: i32, before_index: i32) -> bool:
    var i = 0
    while i < before_index:
        if color_attachments[i].texture_id == texture_id:
            return true
        i = i + 1
    false

pub fn webgpu_is_depth_stencil_renderable_texture_format(format: text) -> bool:
    format == GPU_TEXTURE_FORMAT_DEPTH24_PLUS or format == GPU_TEXTURE_FORMAT_DEPTH24_PLUS_STENCIL8

pub fn webgpu_is_stencil_capable_texture_format(format: text) -> bool:
    format == GPU_TEXTURE_FORMAT_DEPTH24_PLUS_STENCIL8

pub fn webgpu_depth_stencil_attachment_uses_stencil(attachment: GPURenderPassDepthStencilAttachment) -> bool:
    attachment.stencil_read_only or attachment.stencil_load_op != "" or attachment.stencil_store_op != ""

pub fn webgpu_validate_render_pass_depth_stencil_ops(attachment: GPURenderPassDepthStencilAttachment) -> text:
    if not attachment.depth_read_only or attachment.depth_load_op != "":
        val depth_load_err = webgpu_validate_render_pass_load_op(attachment.depth_load_op, "depthLoadOp")
        if depth_load_err != "":
            return depth_load_err
    if not attachment.depth_read_only or attachment.depth_store_op != "":
        val depth_store_err = webgpu_validate_render_pass_store_op(attachment.depth_store_op, "depthStoreOp")
        if depth_store_err != "":
            return depth_store_err
    if attachment.stencil_load_op != "":
        val stencil_load_err = webgpu_validate_render_pass_load_op(attachment.stencil_load_op, "stencilLoadOp")
        if stencil_load_err != "":
            return stencil_load_err
    if attachment.stencil_store_op != "":
        val stencil_store_err = webgpu_validate_render_pass_store_op(attachment.stencil_store_op, "stencilStoreOp")
        if stencil_store_err != "":
            return stencil_store_err
    ""

pub fn webgpu_validate_render_pass_load_op(value: text, field_name: text) -> text:
    if value == WEBGPU_LOAD_OP_CLEAR or value == WEBGPU_LOAD_OP_LOAD:
        return ""
    "GPURenderPassDepthStencilAttachment " + field_name + " must be 'clear' or 'load'"

pub fn webgpu_validate_render_pass_store_op(value: text, field_name: text) -> text:
    if value == WEBGPU_STORE_OP_STORE or value == WEBGPU_STORE_OP_DISCARD:
        return ""
    "GPURenderPassDepthStencilAttachment " + field_name + " must be 'store' or 'discard'"

pub fn webgpu_validate_render_pass_attachment_dimensions(width: i32, height: i32, depth_or_layers: i32, expected_width: i32, expected_height: i32, expected_depth_or_layers: i32) -> text:
    if expected_width < 0:
        return ""
    if width != expected_width or height != expected_height or depth_or_layers != expected_depth_or_layers:
        return "GPURenderPassDescriptor attachments must have matching dimensions"
    ""

pub fn webgpu_validate_buffer_copy(source_buffer_id: i32, source_offset: i32, destination_buffer_id: i32, destination_offset: i32, size: i32) -> text:
    if source_buffer_id <= 0 or destination_buffer_id <= 0:
        return "GPUCommandEncoder copyBufferToBuffer buffers must be valid"
    if source_buffer_id == destination_buffer_id:
        return "GPUCommandEncoder copyBufferToBuffer requires distinct buffers"
    if source_offset < 0 or destination_offset < 0:
        return "GPUCommandEncoder copyBufferToBuffer offsets must be non-negative"
    if size <= 0:
        return "GPUCommandEncoder copyBufferToBuffer size must be positive"
    ""

pub fn webgpu_validate_texture_copy(source_texture_id: i32, destination_texture_id: i32, width: i32, height: i32, depth_or_layers: i32) -> text:
    if source_texture_id <= 0 or destination_texture_id <= 0:
        return "GPUCommandEncoder copyTextureToTexture textures must be valid"
    if source_texture_id == destination_texture_id:
        return "GPUCommandEncoder copyTextureToTexture requires distinct textures"
    if width <= 0 or height <= 0 or depth_or_layers <= 0:
        return "GPUCommandEncoder copyTextureToTexture size must be positive"
    ""

pub fn webgpu_validate_indirect_draw_buffer(buffer_id: i32, offset: i32, command_size: i32) -> text:
    if buffer_id <= 0:
        return "GPURenderPassEncoder indirect draw buffer must be valid"
    if offset < 0:
        return "GPURenderPassEncoder indirect draw offset must be non-negative"
    if offset % 4 != 0:
        return "GPURenderPassEncoder indirect draw offset must be 4-byte aligned"
    if command_size != 16 and command_size != 20:
        return "GPURenderPassEncoder indirect draw command size is unsupported"
    ""

pub fn webgpu_validate_render_buffer_binding(slot: i32, buffer_id: i32, offset: i32, size: i32, label: text) -> text:
    if slot < 0:
        return "GPURenderPassEncoder " + label + " buffer slot must be non-negative"
    if buffer_id <= 0:
        return "GPURenderPassEncoder " + label + " buffer must be valid"
    if offset < 0:
        return "GPURenderPassEncoder " + label + " buffer offset must be non-negative"
    if size != -1 and size <= 0:
        return "GPURenderPassEncoder " + label + " buffer size must be positive"
    ""

pub fn webgpu_validate_index_buffer_binding(buffer_id: i32, index_format: text, offset: i32, size: i32) -> text:
    val basic_err = webgpu_validate_render_buffer_binding(0, buffer_id, offset, size, "index")
    if basic_err != "":
        return basic_err
    if webgpu_index_format_bits(index_format) == 0:
        return "GPURenderPassEncoder index buffer format must be uint16 or uint32"
    ""

pub fn webgpu_index_format_bits(index_format: text) -> i32:
    if index_format == "uint16":
        return 16
    if index_format == "uint32":
        return 32
    0

pub fn webgpu_validate_scissor_rect(x: i32, y: i32, width: i32, height: i32) -> text:
    if x < 0 or y < 0:
        return "GPURenderPassEncoder scissor rect origin must be non-negative"
    if width <= 0 or height <= 0:
        return "GPURenderPassEncoder scissor rect size must be positive"
    ""

pub fn webgpu_validate_viewport(x: i32, y: i32, width: i32, height: i32, min_depth: f64, max_depth: f64) -> text:
    if x < 0 or y < 0:
        return "GPURenderPassEncoder viewport origin must be non-negative"
    if width <= 0 or height <= 0:
        return "GPURenderPassEncoder viewport size must be positive"
    if min_depth < 0.0 or min_depth > 1.0 or max_depth < 0.0 or max_depth > 1.0:
        return "GPURenderPassEncoder viewport depth range must be between 0 and 1"
    if min_depth > max_depth:
        return "GPURenderPassEncoder viewport minDepth must not exceed maxDepth"
    ""

pub fn webgpu_validate_stencil_reference(reference: i32) -> text:
    if reference < 0:
        return "GPURenderPassEncoder stencil reference must be non-negative"
    ""

pub fn webgpu_validate_queue_write_buffer(buffer_id: i32, offset: i32, data_size: i32) -> text:
    if buffer_id <= 0:
        return "GPUQueue writeBuffer buffer must be valid"
    if offset < 0:
        return "GPUQueue writeBuffer offset must be non-negative"
    if data_size <= 0:
        return "GPUQueue writeBuffer data size must be positive"
    ""

pub fn webgpu_validate_queue_write_texture(texture_id: i32, width: i32, height: i32, depth_or_layers: i32, data_size: i32) -> text:
    if texture_id <= 0:
        return "GPUQueue writeTexture texture must be valid"
    if width <= 0 or height <= 0 or depth_or_layers <= 0:
        return "GPUQueue writeTexture size must be positive"
    if data_size <= 0:
        return "GPUQueue writeTexture data size must be positive"
    ""

pub fn webgpu_validate_bind_group_dynamic_offsets_with_resources(resources: WebGPUResourceTable, slot: i32, bind_group_id: i32, dynamic_offsets: [i32]) -> text:
    val basic_err = webgpu_validate_bind_group_dynamic_offsets(slot, bind_group_id, dynamic_offsets)
    if basic_err != "":
        return basic_err
    val bind_group = webgpu_find_bind_group(resources, bind_group_id)
    if not bind_group.valid:
        return "GPUPassEncoder bind group does not exist"
    val layout = resources.find_bind_group_layout(bind_group.layout_id)
    if not layout.valid:
        return "GPUPassEncoder bind group layout does not exist"
    if dynamic_offsets.len() != webgpu_count_dynamic_bind_group_layout_entries(layout.entries):
        return "GPUPassEncoder dynamic offset count must match bind group layout"
    var dynamic_index = 0
    var i = 0
    while i < layout.entries.len():
        val layout_entry = layout.entries[i]
        if layout_entry.has_dynamic_offset:
            val entry = webgpu_find_bind_group_entry(bind_group.entries, layout_entry.binding)
            val buffer = webgpu_find_buffer(resources, entry.buffer_id)
            if not buffer.valid:
                return "GPUPassEncoder dynamic offset buffer does not exist"
            val total_offset = entry.buffer_offset + (dynamic_offsets[dynamic_index] as i64)
            if webgpu_validate_bind_group_buffer_range(buffer, total_offset, entry.buffer_size) != "":
                return "GPUPassEncoder dynamic offset exceeds buffer size"
            dynamic_index = dynamic_index + 1
        i = i + 1
    ""

pub fn webgpu_validate_vertex_buffer_binding_with_resources(resources: WebGPUResourceTable, slot: i32, buffer_id: i32, offset: i32, size: i32) -> text:
    val basic_err = webgpu_validate_render_buffer_binding(slot, buffer_id, offset, size, "vertex")
    if basic_err != "":
        return basic_err
    val buffer = webgpu_find_buffer(resources, buffer_id)
    if not buffer.valid:
        return "GPURenderPassEncoder vertex buffer does not exist"
    if (buffer.usage & WEBGPU_BUFFER_USAGE_VERTEX) == 0:
        return "GPURenderPassEncoder vertex buffer missing VERTEX usage"
    if webgpu_validate_render_buffer_range(buffer.size, offset, size) != "":
        return "GPURenderPassEncoder vertex buffer binding range exceeds buffer size"
    ""

pub fn webgpu_validate_index_buffer_binding_with_resources(resources: WebGPUResourceTable, buffer_id: i32, index_format: text, offset: i32, size: i32) -> text:
    val basic_err = webgpu_validate_index_buffer_binding(buffer_id, index_format, offset, size)
    if basic_err != "":
        return basic_err
    val buffer = webgpu_find_buffer(resources, buffer_id)
    if not buffer.valid:
        return "GPURenderPassEncoder index buffer does not exist"
    if (buffer.usage & WEBGPU_BUFFER_USAGE_INDEX) == 0:
        return "GPURenderPassEncoder index buffer missing INDEX usage"
    if webgpu_validate_render_buffer_range(buffer.size, offset, size) != "":
        return "GPURenderPassEncoder index buffer binding range exceeds buffer size"
    ""

pub fn webgpu_validate_render_buffer_range(buffer_size: i64, offset: i32, size: i32) -> text:
    if (offset as i64) >= buffer_size:
        return "range exceeds buffer size"
    if size == -1:
        return ""
    if (offset as i64) + (size as i64) > buffer_size:
        return "range exceeds buffer size"
    ""

pub fn webgpu_validate_buffer_copy_with_resources(resources: WebGPUResourceTable, source_buffer_id: i32, source_offset: i32, destination_buffer_id: i32, destination_offset: i32, size: i32) -> text:
    val basic_err = webgpu_validate_buffer_copy(source_buffer_id, source_offset, destination_buffer_id, destination_offset, size)
    if basic_err != "":
        return basic_err
    val source = webgpu_find_buffer(resources, source_buffer_id)
    if not source.valid:
        return "GPUCommandEncoder copyBufferToBuffer source buffer does not exist"
    val destination = webgpu_find_buffer(resources, destination_buffer_id)
    if not destination.valid:
        return "GPUCommandEncoder copyBufferToBuffer destination buffer does not exist"
    if (source.usage & WEBGPU_BUFFER_USAGE_COPY_SRC) == 0:
        return "GPUCommandEncoder copyBufferToBuffer source buffer missing COPY_SRC usage"
    if (destination.usage & WEBGPU_BUFFER_USAGE_COPY_DST) == 0:
        return "GPUCommandEncoder copyBufferToBuffer destination buffer missing COPY_DST usage"
    if (source_offset as i64) + (size as i64) > source.size:
        return "GPUCommandEncoder copyBufferToBuffer source range exceeds buffer size"
    if (destination_offset as i64) + (size as i64) > destination.size:
        return "GPUCommandEncoder copyBufferToBuffer destination range exceeds buffer size"
    ""

pub fn webgpu_validate_texture_copy_with_resources(resources: WebGPUResourceTable, source_texture_id: i32, destination_texture_id: i32, width: i32, height: i32, depth_or_layers: i32) -> text:
    val basic_err = webgpu_validate_texture_copy(source_texture_id, destination_texture_id, width, height, depth_or_layers)
    if basic_err != "":
        return basic_err
    val source = webgpu_find_texture(resources, source_texture_id)
    if not source.valid:
        return "GPUCommandEncoder copyTextureToTexture source texture does not exist"
    val destination = webgpu_find_texture(resources, destination_texture_id)
    if not destination.valid:
        return "GPUCommandEncoder copyTextureToTexture destination texture does not exist"
    if source.format != destination.format:
        return "GPUCommandEncoder copyTextureToTexture formats must match"
    if (source.usage & WEBGPU_TEXTURE_USAGE_COPY_SRC) == 0:
        return "GPUCommandEncoder copyTextureToTexture source texture missing COPY_SRC usage"
    if (destination.usage & WEBGPU_TEXTURE_USAGE_COPY_DST) == 0:
        return "GPUCommandEncoder copyTextureToTexture destination texture missing COPY_DST usage"
    if width > source.width or height > source.height or depth_or_layers > source.depth_or_layers:
        return "GPUCommandEncoder copyTextureToTexture source range exceeds texture size"
    if width > destination.width or height > destination.height or depth_or_layers > destination.depth_or_layers:
        return "GPUCommandEncoder copyTextureToTexture destination range exceeds texture size"
    ""

pub fn webgpu_validate_indirect_draw_buffer_with_resources(resources: WebGPUResourceTable, buffer_id: i32, offset: i32, command_size: i32) -> text:
    val basic_err = webgpu_validate_indirect_draw_buffer(buffer_id, offset, command_size)
    if basic_err != "":
        return basic_err
    val buffer = webgpu_find_buffer(resources, buffer_id)
    if not buffer.valid:
        return "GPURenderPassEncoder indirect draw buffer does not exist"
    if (buffer.usage & WEBGPU_BUFFER_USAGE_INDIRECT) == 0:
        return "GPURenderPassEncoder indirect draw buffer missing INDIRECT usage"
    if (offset as i64) + (command_size as i64) > buffer.size:
        return "GPURenderPassEncoder indirect draw range exceeds buffer size"
    ""

pub fn webgpu_validate_queue_write_buffer_with_resources(resources: WebGPUResourceTable, buffer_id: i32, offset: i32, data_size: i32) -> text:
    val basic_err = webgpu_validate_queue_write_buffer(buffer_id, offset, data_size)
    if basic_err != "":
        return basic_err
    val buffer = webgpu_find_buffer(resources, buffer_id)
    if not buffer.valid:
        return "GPUQueue writeBuffer buffer does not exist"
    if (buffer.usage & WEBGPU_BUFFER_USAGE_COPY_DST) == 0:
        return "GPUQueue writeBuffer buffer missing COPY_DST usage"
    if (offset as i64) + (data_size as i64) > buffer.size:
        return "GPUQueue writeBuffer range exceeds buffer size"
    ""

pub fn webgpu_validate_queue_write_texture_with_resources(resources: WebGPUResourceTable, texture_id: i32, width: i32, height: i32, depth_or_layers: i32, data_size: i32) -> text:
    val basic_err = webgpu_validate_queue_write_texture(texture_id, width, height, depth_or_layers, data_size)
    if basic_err != "":
        return basic_err
    val texture = webgpu_find_texture(resources, texture_id)
    if not texture.valid:
        return "GPUQueue writeTexture texture does not exist"
    if (texture.usage & WEBGPU_TEXTURE_USAGE_COPY_DST) == 0:
        return "GPUQueue writeTexture texture missing COPY_DST usage"
    if width > texture.width or height > texture.height or depth_or_layers > texture.depth_or_layers:
        return "GPUQueue writeTexture range exceeds texture size"
    ""
