"""Browser WebGPU command encoder and queue handles.

This is the browser-facing command recording surface. It keeps commands as flat
records so tests can validate WebGPU sequencing before native submission exists.
"""

use std.gc_async_mut.gpu.browser_engine.webgpu_resources.{
    WebGPUResourceTable,
    WEBGPU_BUFFER_USAGE_COPY_SRC, WEBGPU_BUFFER_USAGE_COPY_DST,
    WEBGPU_BUFFER_USAGE_INDEX, WEBGPU_BUFFER_USAGE_VERTEX, WEBGPU_BUFFER_USAGE_INDIRECT,
    WEBGPU_TEXTURE_USAGE_COPY_SRC, WEBGPU_TEXTURE_USAGE_COPY_DST,
    WEBGPU_TEXTURE_USAGE_RENDER_ATTACHMENT,
    webgpu_find_buffer, webgpu_find_texture, webgpu_find_bind_group,
    webgpu_find_bind_group_entry, webgpu_count_dynamic_bind_group_layout_entries,
    webgpu_validate_bind_group_buffer_range
}
use std.gc_async_mut.gpu.browser_engine.webgpu_types.{
    GPU_TEXTURE_FORMAT_DEPTH24_PLUS, GPU_TEXTURE_FORMAT_DEPTH24_PLUS_STENCIL8
}
pub val WEBGPU_COMMAND_BEGIN_RENDER_PASS: text = "begin-render-pass"
pub val WEBGPU_COMMAND_END_RENDER_PASS: text = "end-render-pass"
pub val WEBGPU_COMMAND_BEGIN_COMPUTE_PASS: text = "begin-compute-pass"
pub val WEBGPU_COMMAND_END_COMPUTE_PASS: text = "end-compute-pass"
pub val WEBGPU_COMMAND_SET_PIPELINE: text = "set-pipeline"
pub val WEBGPU_COMMAND_SET_BIND_GROUP: text = "set-bind-group"
pub val WEBGPU_COMMAND_SET_VERTEX_BUFFER: text = "set-vertex-buffer"
pub val WEBGPU_COMMAND_SET_INDEX_BUFFER: text = "set-index-buffer"
pub val WEBGPU_COMMAND_SET_SCISSOR_RECT: text = "set-scissor-rect"
pub val WEBGPU_COMMAND_SET_VIEWPORT: text = "set-viewport"
pub val WEBGPU_COMMAND_SET_STENCIL_REFERENCE: text = "set-stencil-reference"
pub val WEBGPU_COMMAND_SET_BLEND_CONSTANT: text = "set-blend-constant"
pub val WEBGPU_COMMAND_DRAW: text = "draw"
pub val WEBGPU_COMMAND_DRAW_INDEXED: text = "draw-indexed"
pub val WEBGPU_COMMAND_DRAW_INDIRECT: text = "draw-indirect"
pub val WEBGPU_COMMAND_DRAW_INDEXED_INDIRECT: text = "draw-indexed-indirect"
pub val WEBGPU_COMMAND_DISPATCH_WORKGROUPS: text = "dispatch-workgroups"
pub val WEBGPU_COMMAND_COPY_BUFFER_TO_BUFFER: text = "copy-buffer-to-buffer"
pub val WEBGPU_COMMAND_COPY_TEXTURE_TO_TEXTURE: text = "copy-texture-to-texture"
pub val WEBGPU_COMMAND_WRITE_BUFFER: text = "write-buffer"
pub val WEBGPU_COMMAND_WRITE_TEXTURE: text = "write-texture"
pub val WEBGPU_LOAD_OP_CLEAR: text = "clear"
pub val WEBGPU_LOAD_OP_LOAD: text = "load"
pub val WEBGPU_STORE_OP_DISCARD: text = "discard"
pub val WEBGPU_STORE_OP_STORE: text = "store"

pub class WebGPURecordedCommand:
    kind: text
    pipeline_id: i32
    bind_group_id: i32
    slot: i32
    vertex_count: i32
    instance_count: i32
    workgroups_x: i32
    workgroups_y: i32
    workgroups_z: i32
    source_buffer_id: i32
    destination_buffer_id: i32
    source_texture_id: i32
    destination_texture_id: i32
    offset: i32
    destination_offset: i32
    size: i32
    dynamic_offset_count: i32
    width: i32
    height: i32
    depth_or_layers: i32
    data_size: i32
    viewport_min_depth: f64
    viewport_max_depth: f64
    blend_constant_red: f64
    blend_constant_green: f64
    blend_constant_blue: f64
    blend_constant_alpha: f64

pub class GPUCommandBufferHandle:
    id: i32
    label: text
    commands: [WebGPURecordedCommand]
    valid: bool
    error: text

    fn command_count() -> i32:
        self.commands.len()

pub class GPURenderPassColorAttachment:
    texture_id: i32

    static fn texture(texture_id: i32) -> GPURenderPassColorAttachment:
        GPURenderPassColorAttachment(texture_id: texture_id)

pub class GPURenderPassDepthStencilAttachment:
    texture_id: i32
    depth_read_only: bool
    stencil_read_only: bool
    depth_load_op: text
    depth_store_op: text
    stencil_load_op: text
    stencil_store_op: text

    static fn none() -> GPURenderPassDepthStencilAttachment:
        GPURenderPassDepthStencilAttachment(texture_id: -1, depth_read_only: false, stencil_read_only: false, depth_load_op: "", depth_store_op: "", stencil_load_op: "", stencil_store_op: "")

    static fn texture(texture_id: i32) -> GPURenderPassDepthStencilAttachment:
        GPURenderPassDepthStencilAttachment(texture_id: texture_id, depth_read_only: false, stencil_read_only: false, depth_load_op: WEBGPU_LOAD_OP_CLEAR, depth_store_op: WEBGPU_STORE_OP_STORE, stencil_load_op: "", stencil_store_op: "")

    static fn texture_with_depth_ops(texture_id: i32, depth_load_op: text, depth_store_op: text) -> GPURenderPassDepthStencilAttachment:
        GPURenderPassDepthStencilAttachment(texture_id: texture_id, depth_read_only: false, stencil_read_only: false, depth_load_op: depth_load_op, depth_store_op: depth_store_op, stencil_load_op: "", stencil_store_op: "")

    static fn texture_read_only(texture_id: i32, depth_read_only: bool, stencil_read_only: bool) -> GPURenderPassDepthStencilAttachment:
        GPURenderPassDepthStencilAttachment(texture_id: texture_id, depth_read_only: depth_read_only, stencil_read_only: stencil_read_only, depth_load_op: "", depth_store_op: "", stencil_load_op: "", stencil_store_op: "")

    static fn texture_with_depth_stencil_ops(texture_id: i32, depth_load_op: text, depth_store_op: text, stencil_load_op: text, stencil_store_op: text) -> GPURenderPassDepthStencilAttachment:
        GPURenderPassDepthStencilAttachment(texture_id: texture_id, depth_read_only: false, stencil_read_only: false, depth_load_op: depth_load_op, depth_store_op: depth_store_op, stencil_load_op: stencil_load_op, stencil_store_op: stencil_store_op)

pub class WebGPUCommandEncoder:
    label: text
    next_command_buffer_id: i32
    commands: [WebGPURecordedCommand]
    active_pass: text
    finished: bool
    last_error: text

    static fn create(label: text) -> WebGPUCommandEncoder:
        WebGPUCommandEncoder(
            label: label,
            next_command_buffer_id: 1,
            commands: [],
            active_pass: "",
            finished: false,
            last_error: ""
        )

    me begin_render_pass() -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder already has an active pass"
            return false
        self.commands.push(webgpu_command_begin_render_pass(0, -1, 0, 0, 0))
        self.active_pass = "render"
        self.last_error = ""
        true

    me begin_render_pass_with_descriptor(resources: WebGPUResourceTable, color_attachments: [GPURenderPassColorAttachment], depth_stencil_attachment: GPURenderPassDepthStencilAttachment) -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder already has an active pass"
            return false
        val err = webgpu_validate_render_pass_descriptor_with_resources(resources, color_attachments, depth_stencil_attachment)
        if err != "":
            self.last_error = err
            return false
        var width = 0
        var height = 0
        var depth_or_layers = 0
        if color_attachments.len() > 0:
            val color_texture = webgpu_find_texture(resources, color_attachments[0].texture_id)
            width = color_texture.width
            height = color_texture.height
            depth_or_layers = color_texture.depth_or_layers
        else: if depth_stencil_attachment.texture_id > 0:
            val depth_texture = webgpu_find_texture(resources, depth_stencil_attachment.texture_id)
            width = depth_texture.width
            height = depth_texture.height
            depth_or_layers = depth_texture.depth_or_layers
        self.commands.push(webgpu_command_begin_render_pass(color_attachments.len(), depth_stencil_attachment.texture_id, width, height, depth_or_layers))
        self.active_pass = "render"
        self.last_error = ""
        true

    me end_render_pass() -> bool:
        if self.active_pass != "render":
            self.last_error = "GPUCommandEncoder has no active render pass"
            return false
        self.commands.push(webgpu_command_empty(WEBGPU_COMMAND_END_RENDER_PASS))
        self.active_pass = ""
        self.last_error = ""
        true

    me begin_compute_pass() -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder already has an active pass"
            return false
        self.commands.push(webgpu_command_empty(WEBGPU_COMMAND_BEGIN_COMPUTE_PASS))
        self.active_pass = "compute"
        self.last_error = ""
        true

    me end_compute_pass() -> bool:
        if self.active_pass != "compute":
            self.last_error = "GPUCommandEncoder has no active compute pass"
            return false
        self.commands.push(webgpu_command_empty(WEBGPU_COMMAND_END_COMPUTE_PASS))
        self.active_pass = ""
        self.last_error = ""
        true

    me set_pipeline(pipeline_id: i32) -> bool:
        if not self.ensure_active_pass():
            return false
        if pipeline_id <= 0:
            self.last_error = "GPURenderPassEncoder pipeline must be valid"
            return false
        self.commands.push(webgpu_command_pipeline(pipeline_id))
        self.last_error = ""
        true

    me set_bind_group(slot: i32, bind_group_id: i32) -> bool:
        self.set_bind_group_with_dynamic_offsets(slot, bind_group_id, [])

    me set_bind_group_with_dynamic_offsets(slot: i32, bind_group_id: i32, dynamic_offsets: [i32]) -> bool:
        if not self.ensure_active_pass():
            return false
        val err = webgpu_validate_bind_group_dynamic_offsets(slot, bind_group_id, dynamic_offsets)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_bind_group_with_dynamic_offsets(slot, bind_group_id, dynamic_offsets.len()))
        self.last_error = ""
        true

    me set_bind_group_with_resources(resources: WebGPUResourceTable, slot: i32, bind_group_id: i32) -> bool:
        self.set_bind_group_with_dynamic_offsets_and_resources(resources, slot, bind_group_id, [])

    me set_bind_group_with_dynamic_offsets_and_resources(resources: WebGPUResourceTable, slot: i32, bind_group_id: i32, dynamic_offsets: [i32]) -> bool:
        if not self.ensure_active_pass():
            return false
        val err = webgpu_validate_bind_group_dynamic_offsets_with_resources(resources, slot, bind_group_id, dynamic_offsets)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_bind_group_with_dynamic_offsets(slot, bind_group_id, dynamic_offsets.len()))
        self.last_error = ""
        true

    me set_vertex_buffer(slot: i32, buffer_id: i32, offset: i32, size: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setVertexBuffer requires an active render pass"
            return false
        val err = webgpu_validate_render_buffer_binding(slot, buffer_id, offset, size, "vertex")
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_vertex_buffer(slot, buffer_id, offset, size))
        self.last_error = ""
        true

    me set_vertex_buffer_with_resources(resources: WebGPUResourceTable, slot: i32, buffer_id: i32, offset: i32, size: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setVertexBuffer requires an active render pass"
            return false
        val err = webgpu_validate_vertex_buffer_binding_with_resources(resources, slot, buffer_id, offset, size)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_vertex_buffer(slot, buffer_id, offset, size))
        self.last_error = ""
        true

    me set_index_buffer(buffer_id: i32, index_format: text, offset: i32, size: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setIndexBuffer requires an active render pass"
            return false
        val err = webgpu_validate_index_buffer_binding(buffer_id, index_format, offset, size)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_index_buffer(buffer_id, index_format, offset, size))
        self.last_error = ""
        true

    me set_index_buffer_with_resources(resources: WebGPUResourceTable, buffer_id: i32, index_format: text, offset: i32, size: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setIndexBuffer requires an active render pass"
            return false
        val err = webgpu_validate_index_buffer_binding_with_resources(resources, buffer_id, index_format, offset, size)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_index_buffer(buffer_id, index_format, offset, size))
        self.last_error = ""
        true

    me set_scissor_rect(x: i32, y: i32, width: i32, height: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setScissorRect requires an active render pass"
            return false
        val err = webgpu_validate_scissor_rect(x, y, width, height)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_scissor_rect(x, y, width, height))
        self.last_error = ""
        true

    me set_viewport(x: i32, y: i32, width: i32, height: i32, min_depth: f64, max_depth: f64) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setViewport requires an active render pass"
            return false
        val err = webgpu_validate_viewport(x, y, width, height, min_depth, max_depth)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_viewport(x, y, width, height, min_depth, max_depth))
        self.last_error = ""
        true

    me set_stencil_reference(reference: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setStencilReference requires an active render pass"
            return false
        val err = webgpu_validate_stencil_reference(reference)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_set_stencil_reference(reference))
        self.last_error = ""
        true

    me set_blend_constant(red: f64, green: f64, blue: f64, alpha: f64) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder setBlendConstant requires an active render pass"
            return false
        self.commands.push(webgpu_command_set_blend_constant(red, green, blue, alpha))
        self.last_error = ""
        true

    me draw(vertex_count: i32, instance_count: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder draw requires an active render pass"
            return false
        if vertex_count <= 0 or instance_count <= 0:
            self.last_error = "GPURenderPassEncoder draw counts must be positive"
            return false
        self.commands.push(webgpu_command_draw(vertex_count, instance_count))
        self.last_error = ""
        true

    me draw_indexed(index_count: i32, instance_count: i32, first_index: i32, base_vertex: i32, first_instance: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder drawIndexed requires an active render pass"
            return false
        if index_count <= 0 or instance_count <= 0:
            self.last_error = "GPURenderPassEncoder drawIndexed counts must be positive"
            return false
        if first_index < 0 or first_instance < 0:
            self.last_error = "GPURenderPassEncoder drawIndexed offsets must be non-negative"
            return false
        self.commands.push(webgpu_command_draw_indexed(index_count, instance_count, first_index, base_vertex, first_instance))
        self.last_error = ""
        true

    me draw_indirect(buffer_id: i32, offset: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder drawIndirect requires an active render pass"
            return false
        val err = webgpu_validate_indirect_draw_buffer(buffer_id, offset, 16)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_draw_indirect(buffer_id, offset))
        self.last_error = ""
        true

    me draw_indexed_indirect(buffer_id: i32, offset: i32) -> bool:
        if self.active_pass != "render":
            self.last_error = "GPURenderPassEncoder drawIndexedIndirect requires an active render pass"
            return false
        val err = webgpu_validate_indirect_draw_buffer(buffer_id, offset, 20)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_draw_indexed_indirect(buffer_id, offset))
        self.last_error = ""
        true

    me dispatch_workgroups(workgroups_x: i32, workgroups_y: i32, workgroups_z: i32) -> bool:
        if self.active_pass != "compute":
            self.last_error = "GPUComputePassEncoder dispatch requires an active compute pass"
            return false
        if workgroups_x <= 0 or workgroups_y <= 0 or workgroups_z <= 0:
            self.last_error = "GPUComputePassEncoder workgroup counts must be positive"
            return false
        self.commands.push(webgpu_command_dispatch(workgroups_x, workgroups_y, workgroups_z))
        self.last_error = ""
        true

    me copy_buffer_to_buffer(source_buffer_id: i32, source_offset: i32, destination_buffer_id: i32, destination_offset: i32, size: i32) -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder copyBufferToBuffer cannot run inside a pass"
            return false
        val err = webgpu_validate_buffer_copy(source_buffer_id, source_offset, destination_buffer_id, destination_offset, size)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_copy_buffer_to_buffer(source_buffer_id, source_offset, destination_buffer_id, destination_offset, size))
        self.last_error = ""
        true

    me copy_texture_to_texture(source_texture_id: i32, destination_texture_id: i32, width: i32, height: i32, depth_or_layers: i32) -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder copyTextureToTexture cannot run inside a pass"
            return false
        val err = webgpu_validate_texture_copy(source_texture_id, destination_texture_id, width, height, depth_or_layers)
        if err != "":
            self.last_error = err
            return false
        self.commands.push(webgpu_command_copy_texture_to_texture(source_texture_id, destination_texture_id, width, height, depth_or_layers))
        self.last_error = ""
        true

    me finish(label: text) -> GPUCommandBufferHandle:
        if self.finished:
            self.last_error = "GPUCommandEncoder is already finished"
            return GPUCommandBufferHandle(id: -1, label: label, commands: [], valid: false, error: self.last_error)
        if self.active_pass != "":
            self.last_error = "GPUCommandEncoder cannot finish while a pass is active"
            return GPUCommandBufferHandle(id: -1, label: label, commands: [], valid: false, error: self.last_error)
        val id = self.next_command_buffer_id
        self.next_command_buffer_id = self.next_command_buffer_id + 1
        self.finished = true
        self.last_error = ""
        GPUCommandBufferHandle(id: id, label: label, commands: self.commands, valid: true, error: "")

    fn command_count() -> i32:
        self.commands.len()

    me ensure_can_record() -> bool:
        if self.finished:
            self.last_error = "GPUCommandEncoder is already finished"
            return false
        true

    me ensure_active_pass() -> bool:
        if not self.ensure_can_record():
            return false
        if self.active_pass == "":
            self.last_error = "GPUPassEncoder command requires an active pass"
            return false
        true

pub class WebGPUQueue:
    submitted_buffers: [GPUCommandBufferHandle]
    write_commands: [WebGPURecordedCommand]
    last_error: text

    static fn create() -> WebGPUQueue:
        WebGPUQueue(submitted_buffers: [], write_commands: [], last_error: "")

    me write_buffer(buffer_id: i32, offset: i32, data_size: i32) -> bool:
        val err = webgpu_validate_queue_write_buffer(buffer_id, offset, data_size)
        if err != "":
            self.last_error = err
            return false
        self.write_commands.push(webgpu_command_write_buffer(buffer_id, offset, data_size))
        self.last_error = ""
        true

    me write_texture(texture_id: i32, width: i32, height: i32, depth_or_layers: i32, data_size: i32) -> bool:
        val err = webgpu_validate_queue_write_texture(texture_id, width, height, depth_or_layers, data_size)
        if err != "":
            self.last_error = err
            return false
        self.write_commands.push(webgpu_command_write_texture(texture_id, width, height, depth_or_layers, data_size))
        self.last_error = ""
        true

    me submit(buffers: [GPUCommandBufferHandle]) -> bool:
        if buffers.len() == 0:
            self.last_error = "GPUQueue submit requires at least one command buffer"
            return false
        var i = 0
        while i < buffers.len():
            val buffer = buffers[i]
            if not buffer.valid:
                self.last_error = "GPUQueue cannot submit an invalid command buffer"
                return false
            i = i + 1
        i = 0
        while i < buffers.len():
            self.submitted_buffers.push(buffers[i])
            i = i + 1
        self.last_error = ""
        true

    fn submitted_count() -> i32:
        self.submitted_buffers.len()

    fn submitted_command_count() -> i32:
        var total = 0
        var i = 0
        while i < self.submitted_buffers.len():
            total = total + self.submitted_buffers[i].command_count()
            i = i + 1
        total

    fn write_count() -> i32:
        self.write_commands.len()

pub fn webgpu_command_empty(kind: text) -> WebGPURecordedCommand:
    WebGPURecordedCommand(kind: kind, pipeline_id: -1, bind_group_id: -1, slot: -1, vertex_count: 0, instance_count: 0, workgroups_x: 0, workgroups_y: 0, workgroups_z: 0, source_buffer_id: -1, destination_buffer_id: -1, source_texture_id: -1, destination_texture_id: -1, offset: 0, destination_offset: 0, size: 0, dynamic_offset_count: 0, width: 0, height: 0, depth_or_layers: 0, data_size: 0, viewport_min_depth: 0.0, viewport_max_depth: 0.0, blend_constant_red: 0.0, blend_constant_green: 0.0, blend_constant_blue: 0.0, blend_constant_alpha: 0.0)

pub fn webgpu_command_begin_render_pass(color_attachment_count: i32, depth_stencil_texture_id: i32, width: i32, height: i32, depth_or_layers: i32) -> WebGPURecordedCommand:
    WebGPURecordedCommand(kind: WEBGPU_COMMAND_BEGIN_RENDER_PASS, pipeline_id: -1, bind_group_id: -1, slot: color_attachment_count, vertex_count: 0, instance_count: 0, workgroups_x: 0, workgroups_y: 0, workgroups_z: 0, source_buffer_id: -1, destination_buffer_id: -1, source_texture_id: -1, destination_texture_id: depth_stencil_texture_id, offset: 0, destination_offset: 0, size: 0, dynamic_offset_count: 0, width: width, height: height, depth_or_layers: depth_or_layers, data_size: 0, viewport_min_depth: 0.0, viewport_max_depth: 0.0, blend_constant_red: 0.0, blend_constant_green: 0.0, blend_constant_blue: 0.0, blend_constant_alpha: 0.0)

pub fn webgpu_command_pipeline(pipeline_id: i32) -> WebGPURecordedCommand:
