# Simplified DOM for UI Rendering
#
# A lightweight DOM tree that the browser engine uses internally.
# Unlike the full browser DOM (examples/browser/entity/dom/), this is
# optimized for UI widget rendering: fewer node types, inline style props,
# and a tree structure using direct child references rather than ID-based
# lookups.

use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BorderProps, BoxShadow, BoxEdges, be_default_style, parse_css_value, css_parse_length_or_calc, CssPx, CssColor, CssOpacity, FloatCode, ClearCode, css_value_as_i32}
use app.ui.chromium.css_ext.{parse_float_keyword, parse_clear_keyword, parse_outline_style}
use common.string_builder.{StringBuilder}
use std.gc_async_mut.gpu.browser_engine.dom_color.{parse_color_value, parse_float_value, parse_int_value}
use std.gc_async_mut.gpu.browser_engine.dom_color_named.{parse_linear_gradient, dom_background_shorthand_color_value, sb_dom_split_ws, named_color_to_u32}
use std.gc_async_mut.gpu.browser_engine.dom_visual_effects.{parse_box_shadows, parse_blur_value, parse_length_or_calc}

class BeDomEvent:
    """Simplified DOM Event object for browser-engine dispatch."""
    event_type: text
    target_tag: text
    target_id: text
    current_target_tag: text
    current_target_id: text
    bubbles: bool
    cancelable: bool
    default_prevented: bool
    propagation_stopped: bool
    immediate_propagation_stopped: bool
    client_x: i32
    client_y: i32
    screen_x: i32
    screen_y: i32
    button: i32
    buttons: i32
    detail: i32
    pointer_id: i32
    pointer_type: text
    is_primary: bool
    alt_key: bool
    ctrl_key: bool
    meta_key: bool
    shift_key: bool

    static fn create(event_type: text, target_tag: text, target_id: text,
                     current_target_tag: text, current_target_id: text,
                     bubbles: bool, cancelable: bool) -> BeDomEvent:
        BeDomEvent(
            event_type: normalize_dom_event_type(event_type),
            target_tag: target_tag,
            target_id: target_id,
            current_target_tag: current_target_tag,
            current_target_id: current_target_id,
            bubbles: bubbles,
            cancelable: cancelable,
            default_prevented: false,
            propagation_stopped: false,
            immediate_propagation_stopped: false,
            client_x: 0,
            client_y: 0,
            screen_x: 0,
            screen_y: 0,
            button: 0,
            buttons: 0,
            detail: 0,
            pointer_id: 0,
            pointer_type: "",
            is_primary: false,
            alt_key: false,
            ctrl_key: false,
            meta_key: false,
            shift_key: false
        )

    static fn pointer(event_type: text, target_tag: text, target_id: text,
                      current_target_tag: text, current_target_id: text,
                      bubbles: bool, cancelable: bool,
                      client_x: i32, client_y: i32, button: i32, buttons: i32, detail: i32) -> BeDomEvent:
        BeDomEvent(
            event_type: normalize_dom_event_type(event_type),
            target_tag: target_tag,
            target_id: target_id,
            current_target_tag: current_target_tag,
            current_target_id: current_target_id,
            bubbles: bubbles,
            cancelable: cancelable,
            default_prevented: false,
            propagation_stopped: false,
            immediate_propagation_stopped: false,
            client_x: client_x,
            client_y: client_y,
            screen_x: client_x,
            screen_y: client_y,
            button: button,
            buttons: buttons,
            detail: detail,
            pointer_id: 1,
            pointer_type: "mouse",
            is_primary: true,
            alt_key: false,
            ctrl_key: false,
            meta_key: false,
            shift_key: false
        )

    static fn pointer_with_modifiers(event_type: text, target_tag: text, target_id: text,
                                     current_target_tag: text, current_target_id: text,
                                     bubbles: bool, cancelable: bool,
                                     client_x: i32, client_y: i32, button: i32, buttons: i32, detail: i32,
                                     alt_key: bool, ctrl_key: bool, meta_key: bool, shift_key: bool) -> BeDomEvent:
        BeDomEvent(
            event_type: normalize_dom_event_type(event_type),
            target_tag: target_tag,
            target_id: target_id,
            current_target_tag: current_target_tag,
            current_target_id: current_target_id,
            bubbles: bubbles,
            cancelable: cancelable,
            default_prevented: false,
            propagation_stopped: false,
            immediate_propagation_stopped: false,
            client_x: client_x,
            client_y: client_y,
            screen_x: client_x,
            screen_y: client_y,
            button: button,
            buttons: buttons,
            detail: detail,
            pointer_id: 1,
            pointer_type: "mouse",
            is_primary: true,
            alt_key: alt_key,
            ctrl_key: ctrl_key,
            meta_key: meta_key,
            shift_key: shift_key
        )

    me prevent_default():
        if self.cancelable:
            self.default_prevented = true

    me stop_propagation():
        self.propagation_stopped = true

    me stop_immediate_propagation():
        self.immediate_propagation_stopped = true
        self.propagation_stopped = true

class BeDomEventDispatch:
    """Result of simplified DOM event dispatch."""
    event: BeDomEvent
    actions: [text]
    phases: [text]
    current_target_ids: [text]
    default_action: text
    default_action_allowed: bool

    static fn create(event: BeDomEvent, actions: [text], phases: [text],
                     current_target_ids: [text], default_action: text,
                     default_action_allowed: bool) -> BeDomEventDispatch:
        BeDomEventDispatch(
            event: event,
            actions: actions,
            phases: phases,
            current_target_ids: current_target_ids,
            default_action: default_action,
            default_action_allowed: default_action_allowed
        )

class BeDomNode:
    """A DOM node in the browser engine's simplified tree.

    Fields:
        tag          - element tag name ("div", "span", "button", "input", etc.)
        id           - unique identifier for this node
        classes      - CSS class names applied to this node
        style        - inline style properties
        children     - child nodes (direct references, not IDs)
        text_content - text content for text nodes
        attributes   - key-value attribute pairs stored as flat [key, value, key, value, ...]
        event_listener_types/actions - event listener records.
        event_listener_capture - true for capture-phase listener records.
    """
    tag: text
    id: text
    classes: [text]
    style: StyleProps
    children: [BeDomNode]
    text_content: text
    attributes: [text]
    event_listener_types: [text]
    event_listener_actions: [text]
    event_listener_capture: [bool]

    static fn element(tag: text) -> BeDomNode:
        """Create an element node with the given tag name."""
        return BeDomNode(
            tag: tag,
            id: "",
            classes: [],
            style: be_default_style(),
            children: [],
            text_content: "",
            attributes: [],
            event_listener_types: [],
            event_listener_actions: [],
            event_listener_capture: []
        )

    static fn text(content: text) -> BeDomNode:
        """Create a text node with the given content."""
        return BeDomNode(
            tag: "#text",
            id: "",
            classes: [],
            style: be_default_style(),
            children: [],
            text_content: content,
            attributes: [],
            event_listener_types: [],
            event_listener_actions: [],
            event_listener_capture: []
        )

    me add_child(child: BeDomNode):
        """Append a child node."""
        self.children.push(child)

    me set_style(prop: text, value: text):
        """Set a style property by name and string value."""
        var s = self.style
        match prop:
            "display" =>
                s.display = value
            "width" =>
                s.width = parse_length_or_calc(value)
            "height" =>
                s.height = parse_length_or_calc(value)
            "min-width" =>
                s.min_width = parse_css_value(value)
            "max-width" =>
                s.max_width = parse_css_value(value)
            "min-height" =>
                s.min_height = parse_css_value(value)
            "max-height" =>
                s.max_height = parse_css_value(value)
            "background-color" =>
                val bg_val = value.trim()
                s.background_color = if bg_val.lower() == "currentcolor": s.color else: parse_color_value(bg_val)
            "background_color" =>
                val bg_val = value.trim()
                s.background_color = if bg_val.lower() == "currentcolor": s.color else: parse_color_value(bg_val)
            "color" =>
                s.color = parse_color_value(value)
            "font-size" =>
                val cv = parse_css_value(value)
                s.font_size = css_value_as_i32(cv)
            "font_size" =>
                val cv = parse_css_value(value)
                s.font_size = css_value_as_i32(cv)
            "font-weight" =>
                s.font_weight = value
            "font_weight" =>
                s.font_weight = value
            "text-align" =>
                s.text_align = value
            "text_align" =>
                s.text_align = value
            "text-decoration" =>
                s.text_decoration = value
            "text-transform" =>
                s.text_transform = value
            "white-space" =>
                s.white_space = value
            "word-break" =>
                s.word_break = value
            "overflow-wrap" =>
                s.overflow_wrap = value
            "word-wrap" =>
                s.overflow_wrap = value
            "letter-spacing" =>
                val cv = parse_css_value(value)
                s.letter_spacing = css_value_as_i32(cv)
            "flex-direction" =>
                s.flex_direction = value
            "flex_direction" =>
                s.flex_direction = value
            "flex-wrap" =>
                s.flex_wrap = value
            "justify-content" =>
                s.justify_content = value
            "align-items" =>
                s.align_items = value
            "flex-grow" =>
                s.flex_grow = parse_float_value(value)
            "flex-shrink" =>
                s.flex_shrink = parse_float_value(value)
            "flex-basis" =>
                s.flex_basis = parse_css_value(value)
            "gap" =>
                val cv = parse_css_value(value)
                val v = css_value_as_i32(cv)
                s.gap = v
                s.row_gap = v
                s.column_gap = v
            "row-gap" =>
                val cv = parse_css_value(value)
                s.row_gap = css_value_as_i32(cv)
            "column-gap" =>
                val cv = parse_css_value(value)
                s.column_gap = css_value_as_i32(cv)
            "border" =>
                val bparts = sb_dom_split_ws(value)
                var bw = 1
                var bc = 0x000000FF
                for bp in bparts:
                    if bp.ends_with("px") or bp.ends_with("em") or bp == "thin" or bp == "medium" or bp == "thick":
                        val cv = parse_css_value(bp)
                        bw = css_value_as_i32(cv)
                    elif bp != "solid" and bp != "dashed" and bp != "dotted" and bp != "none" and bp != "double":
                        bc = parse_color_value(bp)
                s.border = BorderProps.solid(bw, bc)
            "border-width" =>
                val cv = parse_css_value(value)
                s.border = BorderProps(width: css_value_as_i32(cv), color: s.border.color, style: "solid")
            "border-style" =>
                s.border = BorderProps(width: s.border.width, color: s.border.color, style: value)
            "border-color" =>
                val bc_val = if value.lower() == "currentcolor": s.color else: parse_color_value(value)
                s.border = BorderProps(width: s.border.width, color: bc_val, style: s.border.style)
            "border-radius" =>
                val cv = parse_css_value(value)
                s.border_radius = css_value_as_i32(cv)
            "border_radius" =>
                val cv = parse_css_value(value)
                s.border_radius = css_value_as_i32(cv)
            "overflow" =>
                s.overflow = value
            "position" =>
                s.position = value
            "top" =>
                s.top = parse_length_or_calc(value)
            "right" =>
                s.right = parse_length_or_calc(value)
            "bottom" =>
                s.bottom = parse_length_or_calc(value)
            "left" =>
                s.left = parse_length_or_calc(value)
            "opacity" =>
                s.opacity = parse_float_value(value)
            "visibility" =>
                s.visibility = value
            "z-index" =>
                s.z_index = parse_int_value(value)
            "z_index" =>
                s.z_index = parse_int_value(value)
            "margin" =>
                val cv = parse_css_value(value)
                val v = css_value_as_i32(cv)
                s.margin = BoxEdges(top: v, right: v, bottom: v, left: v)
            "margin-top" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: css_value_as_i32(cv), right: s.margin.right, bottom: s.margin.bottom, left: s.margin.left)
            "margin-right" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: s.margin.top, right: css_value_as_i32(cv), bottom: s.margin.bottom, left: s.margin.left)
            "margin-bottom" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: s.margin.top, right: s.margin.right, bottom: css_value_as_i32(cv), left: s.margin.left)
            "margin-left" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: s.margin.top, right: s.margin.right, bottom: s.margin.bottom, left: css_value_as_i32(cv))
            "padding" =>
                val cv = parse_css_value(value)
                val v = css_value_as_i32(cv)
                s.padding = BoxEdges(top: v, right: v, bottom: v, left: v)
            "padding-top" =>
                val cv = parse_css_value(value)
                s.padding = BoxEdges(top: css_value_as_i32(cv), right: s.padding.right, bottom: s.padding.bottom, left: s.padding.left)
            "padding-right" =>
                val cv = parse_css_value(value)
                s.padding = BoxEdges(top: s.padding.top, right: css_value_as_i32(cv), bottom: s.padding.bottom, left: s.padding.left)
            "padding-bottom" =>
                val cv = parse_css_value(value)
                s.padding = BoxEdges(top: s.padding.top, right: s.padding.right, bottom: css_value_as_i32(cv), left: s.padding.left)
            "padding-left" =>
                val cv = parse_css_value(value)
                s.padding = BoxEdges(top: s.padding.top, right: s.padding.right, bottom: s.padding.bottom, left: css_value_as_i32(cv))
            "background" =>
                val bg_trimmed = value.trim()
                if bg_trimmed.starts_with("linear-gradient"):
                    val grad = parse_linear_gradient(bg_trimmed)
                    if grad.gradient_set:
                        s.gradient_set = true
                        s.gradient_color1 = grad.gradient_color1
                        s.gradient_color2 = grad.gradient_color2
                        s.gradient_angle = grad.gradient_angle
                elif not bg_trimmed.starts_with("radial-gradient"):
                    val bg_color = dom_background_shorthand_color_value(bg_trimmed)
                    if bg_color.len() > 0:
                        s.background_color = if bg_color.lower() == "currentcolor": s.color else: parse_color_value(bg_color)
            "line-height" =>
                pass_dn  # parsed but not stored yet
            "align-self" =>
                s.align_self = value
            "box-sizing" =>
                pass_dn  # would need box_sizing field in StyleProps
            "list-style" =>
                pass_dn  # accept silently
            "list-style-type" =>
                pass_dn
            "float" =>
                # Routed via css_ext::parse_float_keyword.
                val fc = parse_float_keyword(value.trim())
                if fc >= 0:
                    s.float_code = fc
            "clear" =>
                # Routed via css_ext::parse_clear_keyword.
                val cc = parse_clear_keyword(value.trim())
                if cc >= 0:
                    s.clear_code = cc
            "text-indent" =>
                pass_dn
            "vertical-align" =>
                pass_dn
            "inline-size" =>
                s.width = parse_css_value(value)
            "block-size" =>
                s.height = parse_css_value(value)
            "margin-inline-start" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: s.margin.top, right: s.margin.right, bottom: s.margin.bottom, left: css_value_as_i32(cv))
            "margin-inline-end" =>
                val cv = parse_css_value(value)
                s.margin = BoxEdges(top: s.margin.top, right: css_value_as_i32(cv), bottom: s.margin.bottom, left: s.margin.left)
            "writing-mode" =>
                pass_dn
            "direction" =>
                pass_dn
            "outline" =>
                # Shorthand: width style color (any order). Route style keyword
                # through css_ext::parse_outline_style and length/color through
                # the existing helpers.
                val oparts = sb_dom_split_ws(value)
                for op in oparts:
                    val os_code = parse_outline_style(op)
                    if os_code >= 0:
                        s.outline_style = op
                    elif op.ends_with("px") or op.ends_with("em"):
                        val ocv = parse_css_value(op)
                        s.outline_width = css_value_as_i32(ocv)
                    else:
                        s.outline_color = if op.lower() == "currentcolor": s.color else: parse_color_value(op)
            "outline-color" =>
                val oc_val = value.trim()
                s.outline_color = if oc_val.lower() == "currentcolor": s.color else: parse_color_value(oc_val)
            "outline-style" =>
                val os_code2 = parse_outline_style(value.trim())
                if os_code2 >= 0:
                    s.outline_style = value.trim()
            "outline-width" =>
                val ocv2 = parse_css_value(value)
                s.outline_width = css_value_as_i32(ocv2)
            "outline-offset" =>
                val ocv3 = parse_css_value(value)
                s.outline_offset = css_value_as_i32(ocv3)
            "border-spacing" =>
                pass_dn
            "box-shadow" =>
                # Local parse_box_shadows (below, ~line 1359) handles: inset keyword
                # (prefix and suffix), offset-x/y, blur-radius, spread-radius,
                # multi-shadow (comma-separated), and rgba()/color-function tokens.
                # Coverage is adequate for the browser engine renderer.
                #
                # css_ext.spl also defines BoxShadow but with different field names
                # (offset_x_px/blur_px/color_argb vs offset_x/blur_radius/color) and
                # packs color as 0xAARRGGBB ARGB for the chromium shell consumer.
                # Do NOT migrate to css_ext parser — the two types serve different
                # rendering stacks. Named-color support (e.g. "red", "blue") is
                # implemented in named_color_to_u32 and called from parse_color_value.
                # If css_ext gains new features (e.g. percentage lengths), mirror them here.
                s.box_shadows = parse_box_shadows(value)
            "text-shadow" =>
                pass_dn
            "cursor" =>
                pass_dn
            "word-spacing" =>
                pass_dn
            "transform" =>
                s.transform = value
            "transform-origin" =>
                s.transform_origin = value
            "transition" =>
                s.transition = value
            "animation" =>
                s.animation = value
            "object-fit" =>
                s.object_fit = value
            "object-position" =>
                s.object_position = value
            "backdrop-filter" =>
                s.backdrop_filter_blur = parse_blur_value(value)
            "-webkit-backdrop-filter" =>
                if s.backdrop_filter_blur == 0:
                    s.backdrop_filter_blur = parse_blur_value(value)
            "filter" =>
                pass_dn
            "content" =>
                pass_dn
            "background-clip" =>
                pass_dn
            "background-image" =>
                pass_dn
            "background-size" =>
                pass_dn
            "background-position" =>
                pass_dn
            "background-repeat" =>
                pass_dn
            _ =>
                pass_dn
        self.style = s

    me set_attr(key: text, value: text):
        """Set an attribute key-value pair."""
        if key == "id":
            self.id = value
        # Check if key already exists and update it
        var new_attrs: [text] = []
        var found = false
        var i = 0
        while i + 1 < self.attributes.len():
            if self.attributes[i] == key:
                new_attrs.push(key)
                new_attrs.push(value)
                found = true
            else:
                new_attrs.push(self.attributes[i])
                new_attrs.push(self.attributes[i + 1])
            i = i + 2
        if not found:
            new_attrs.push(key)
            new_attrs.push(value)
        self.attributes = new_attrs

    fn get_attr(key: text) -> text:
        """Get an attribute value by key. Returns empty string if not found."""
        var i = 0
        while i + 1 < self.attributes.len():
            if self.attributes[i] == key:
                return self.attributes[i + 1]
            i = i + 2
        return ""

    fn has_attr(key: text) -> bool:
        """Return true when an attribute key is present, even with an empty value."""
        var i = 0
        while i + 1 < self.attributes.len():
            if self.attributes[i] == key:
                return true
            i = i + 2
        false

    me remove_attr(key: text):
        """Remove every attribute pair with the given key."""
        var new_attrs: [text] = []
        var i = 0
        while i + 1 < self.attributes.len():
            if self.attributes[i] != key:
                new_attrs.push(self.attributes[i])
                new_attrs.push(self.attributes[i + 1])
            i = i + 2
        self.attributes = new_attrs
        if key == "id":
            self.id = ""

    me add_event_listener(event_type: text, action: text):
        """Record a target/bubble DOM event listener token for this node."""
        self.add_event_listener_with_capture(event_type, action, false)

    me add_event_listener_with_capture(event_type: text, action: text, capture: bool):
        """Record a DOM event listener token for target/bubble or capture dispatch."""
        val normalized = normalize_dom_event_type(event_type)
        if normalized == "" or action == "":
            return
        var types = self.event_listener_types
        var actions = self.event_listener_actions
        var captures = self.event_listener_capture
        types.push(normalized)
        actions.push(action)
        captures.push(capture)
        self.event_listener_types = types
        self.event_listener_actions = actions
        self.event_listener_capture = captures

    fn event_listener_count(event_type: text) -> i32:
        val normalized = normalize_dom_event_type(event_type)
        var count = 0
        var i = 0
        while i < self.event_listener_types.len():
            if self.event_listener_types[i] == normalized:
                count = count + 1
            i = i + 1
        count

    fn dispatch_event_actions(event_type: text) -> [text]:
        """Return target-phase inline and registered listener actions in dispatch order."""
        self.dispatch_event_actions_for_phase(event_type, "target")

    fn dispatch_event_actions_for_phase(event_type: text, phase: text) -> [text]:
        """Return listener actions for a simplified capture, target, or bubble phase."""
        val normalized = normalize_dom_event_type(event_type)
        var actions: [text] = []
        if normalized == "":
            return actions
        if phase == "target":
            val inline_action = self.get_attr("on" + normalized)
            if inline_action != "":
                actions.push(inline_action)
        var i = 0
        while i < self.event_listener_types.len() and i < self.event_listener_actions.len():
            var is_capture = false
            if i < self.event_listener_capture.len():
                is_capture = self.event_listener_capture[i]
            if self.event_listener_types[i] == normalized:
                if phase == "capture" and is_capture:
                    actions.push(self.event_listener_actions[i])
                elif phase == "target" and not is_capture:
                    actions.push(self.event_listener_actions[i])
                elif phase == "bubble" and not is_capture:
                    actions.push(self.event_listener_actions[i])
            i = i + 1
        actions

    fn dispatch_event(event_type: text, bubbles: bool, cancelable: bool) -> BeDomEventDispatch:
        """Return a simplified Event object with target-phase dispatch actions."""
        var event = BeDomEvent.create(event_type, self.tag, self.id, self.tag, self.id, bubbles, cancelable)
        val source_actions = self.dispatch_event_actions(event.event_type)
        var actions: [text] = []
        var phases: [text] = []
        var ids: [text] = []
        var propagation_stopped = false
        var immediate_stopped = false
        var i = 0
        while i < source_actions.len() and not immediate_stopped:
            actions.push(source_actions[i])
            phases.push("target")
            ids.push(self.id)
            if source_actions[i] == "prevent-default":
                event.prevent_default()
            elif source_actions[i] == "stop-propagation":
                propagation_stopped = true
            elif source_actions[i] == "stop-immediate-propagation":
                immediate_stopped = true
                propagation_stopped = true
            i = i + 1
        event.propagation_stopped = propagation_stopped
        event.immediate_propagation_stopped = immediate_stopped
        val default_action = be_dom_default_action_for_target(self, event.event_type)
        BeDomEventDispatch.create(event, actions, phases, ids, default_action, default_action != "" and not event.default_prevented)

    fn is_text_node() -> bool:
        """True if this is a text node (tag == '#text')."""
        return self.tag == "#text"

    fn is_element() -> bool:
        """True if this is an element node (not a text node)."""
        return self.tag != "#text"

    fn has_class(name: text) -> bool:
        """Check if this node has a given CSS class."""
        for cls in self.classes:
            if cls == name:
                return true
        return false

pub fn normalize_dom_event_type(event_type: text) -> text:
    val trimmed = event_type.trim().lower()
    if trimmed.starts_with("on") and trimmed.len() > 2:
        trimmed.slice(2, trimmed.len())
    else:
        trimmed

pub fn normalize_dom_key(key: text) -> text:
    if key == " ":
        return "space"
    val trimmed = key.trim().lower()
    if trimmed == "spacebar":
        return "space"
    if trimmed == "return":
        return "enter"
    trimmed

class BeDomFactory:
    static fn element(tag: text) -> BeDomNode:
        BeDomNode.element(tag)

    static fn text(content: text) -> BeDomNode:
        BeDomNode.text(content)

# Internal stub — be_dom_default_action_for_target is defined in dom_accessors.spl
# but BeDomNode.dispatch_event (above) calls it. Forward-declare via a local
# thin wrapper so the hub compiles without importing dom_accessors (which would
# create a cycle: dom_accessors imports dom, dom imports dom_accessors).
fn be_dom_default_action_for_target(target: BeDomNode, event_type: text) -> text:
    val normalized = normalize_dom_event_type(event_type)
    if normalized == "click":
        if target.tag == "a":
            val href = target.get_attr("href")
            if href != "":
                return "navigate:" + href
        if target.tag == "button":
            if target.has_attr("disabled"):
                return ""
            return "button-activate"
        if target.tag == "input":
            if target.has_attr("disabled"):
                return ""
            val input_type = target.get_attr("type").lower()
            if input_type == "checkbox":
                return "input-checkbox-toggle"
            if input_type == "radio":
                return "input-radio-select"
    if normalized == "submit" and target.tag == "form":
        return "form-submit"
    if normalized == "focus":
        if target.tag == "input" or target.tag == "button" or target.tag == "select" or target.tag == "textarea" or target.tag == "a":
            return "focus-element"
    ""
