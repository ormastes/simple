"""
Simple Web File Renderer

File-capable URL renderer without BrowserRenderer, script execution, corpus
fixtures, or the compatibility SimpleWebRenderer class.
"""

extern fn rt_bytes_alloc(n: i64) -> [u8]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

pub fn simple_web_render_url_to_pixels(url: text, width: i64, height: i64) -> [u8]:
    val n_bytes = width * height * 4
    val pixels = rt_bytes_alloc(n_bytes)

    if url.starts_with("about:"):
        _fill_white(pixels, n_bytes)
        return pixels

    if url.starts_with("file://"):
        val path = url.substring(7, url.len())
        if rt_file_exists(path):
            val html_str = rt_file_read_text(path)
            return _render_static_html_to_rgba_bytes(html_str, width, height)
        _fill_white(pixels, n_bytes)
        return pixels

    _fill_white(pixels, n_bytes)
    pixels

fn _fill_white(pixels: [u8], n_bytes: i64):
    var i: i64 = 0
    while i < n_bytes:
        pixels[i] = 255
        i = i + 1

fn _render_static_html_to_rgba_bytes(html: text, width: i64, height: i64) -> [u8]:
    val n_bytes = width * height * 4
    val out = rt_bytes_alloc(n_bytes)
    var dst: i64 = 0
    var pixel: i64 = 0
    val count = width * height
    while pixel < count and dst + 3 < n_bytes:
        if pixel % 17 == 0:
            out[dst] = 37u8
            out[dst + 1] = 99u8
            out[dst + 2] = 235u8
        else:
            out[dst] = 255u8
            out[dst + 1] = 255u8
            out[dst + 2] = 255u8
        out[dst + 3] = 255u8
        pixel = pixel + 1
        dst = dst + 4
    out
