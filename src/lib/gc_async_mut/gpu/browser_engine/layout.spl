
#![allow(unnamed_duplicate_typed_args)]
# CSS Layout Engine (Block + Flexbox)
#
# Computes the position and size of every DOM node in the tree.
# Supports block layout (vertical stacking) and flexbox layout
# (row/column with gap). Grid layout is a future extension.
#
# Set SIMPLE_DEBUG_LAYOUT=1 for debug output.

fn _ld(msg: text):
    pass_do_nothing

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_get_style,
    be_dom_get_bg_color, be_dom_get_display, be_dom_get_visibility, be_dom_get_opacity,
    be_dom_get_color, be_dom_get_font_size, be_dom_get_border_radius,
    be_dom_get_border_width, be_dom_get_border_color, be_dom_get_border_style,
    be_dom_get_padding_left, be_dom_get_padding_top, be_dom_get_padding_h, be_dom_get_padding_v,
    be_dom_get_has_gradient, be_dom_get_gradient_c1, be_dom_get_gradient_c2,
    be_dom_get_text, be_dom_get_tag, be_dom_get_children, be_dom_get_is_text,
    be_dom_get_box_shadows, be_dom_get_backdrop_blur, be_dom_get_gradient_angle,
    be_dom_get_text_decoration}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BoxEdges, BoxShadow,
    be_default_style}
use common.text_layout.text_layout.{measure_text, text_char_width, text_line_height}
use common.text_layout.font_renderer.{FontRenderer}
use common.render_scene.scene.{SceneCommand, RenderScene, render_scene,
    scene_fill_rect, scene_stroke_rect, scene_text, scene_rounded_rect,
    scene_gradient_rect, scene_blur_rect, rgba_to_argb}
# extern fn serial_println(msg: text)  # disabled for native builds

# =========================================================================
# Layout Box
# =========================================================================

class BeLayoutBox:
    """A positioned box in the layout tree.

    The outer box (x, y, width, height) includes margin.
    The content box (content_x, content_y, content_width, content_height)
    is inset by margin + border + padding.

    Fields:
        x, y              - top-left corner of the margin box
        width, height     - total size including margin
        content_x, content_y     - top-left corner of the content area
        content_width, content_height - size of the content area
        node              - the DOM node this box corresponds to
        children          - child layout boxes
    """
    x: i32
    y: i32
    width: i32
    height: i32
    content_x: i32
    content_y: i32
    content_width: i32
    content_height: i32
    node: BeDomNode
    children: [BeLayoutBox]

    static fn empty(node: BeDomNode) -> BeLayoutBox:
        return BeLayoutBox(
            x: 0, y: 0, width: 0, height: 0,
            content_x: 0, content_y: 0,
            content_width: 0, content_height: 0,
            node: node, children: []
        )

# =========================================================================
# Main Layout Entry Point
# =========================================================================

fn layout_resolve_style(node: BeDomNode, parent_style: StyleProps) -> StyleProps:
    """Local resolve_style — returns node.style without modification to avoid FieldSet corruption."""
    be_dom_get_style(node)

@allow(primitive_api)
pub fn layout_get_height(box: BeLayoutBox) -> i32:
    """Accessor to read height from within the layout module (avoids cross-module FieldGet)."""
    box.height

@allow(primitive_api)
pub fn layout_get_width(box: BeLayoutBox) -> i32:
    box.width

@allow(primitive_api)
pub fn layout_get_content_width(box: BeLayoutBox) -> i32:
    box.content_width

@allow(primitive_api)
pub fn layout_get_content_height(box: BeLayoutBox) -> i32:
    box.content_height

fn layout_tree(root: BeDomNode, viewport_w: i32, viewport_h: i32) -> BeLayoutBox:
    """Lay out the entire DOM tree within the given viewport dimensions."""
    var container = BeLayoutBox(
        x: 0, y: 0,
        width: viewport_w, height: viewport_h,
        content_x: 0, content_y: 0,
        content_width: viewport_w, content_height: viewport_h,
        node: root, children: []
    )
    val base_style = be_default_style()
    val result = layout_node(root, container, base_style)
    return result

# =========================================================================
# Node Layout Dispatch
# =========================================================================

fn layout_node(node: BeDomNode, container: BeLayoutBox, parent_style: StyleProps) -> BeLayoutBox:
    """Lay out a single node within its container — dispatches by display type."""
    _ld("[LN] enter")
    # Use accessor for display to avoid cross-module FieldGet bug on StyleProps
    val disp = be_dom_get_display(node)
    _ld("[LN] disp='{disp}'")
    if disp == "none":
        return BeLayoutBox.empty(node)
    val s = be_dom_get_style(node)
    _ld("[LN] style got")
    if disp == "flex":
        return layout_flex(node, container, s)
    if be_dom_get_is_text(node):
        return layout_text(node, container, parent_style)
    _ld("[LN] calling layout_block")
    return layout_block(node, container, s)

fn resolve_offset(value: CssValue, reference: i32) -> i32:
    """Resolve a CSS offset value (top/left/right/bottom) to pixels."""
    if value.is_auto():
        return 0
    return value.resolve_px(reference)

# =========================================================================
# Block Layout
# =========================================================================

fn layout_block(node: BeDomNode, container: BeLayoutBox, style: StyleProps) -> BeLayoutBox:
    """Lay out a block-level element with proper CSS box model and child recursion."""
    val s = style
    val s_width = s.width
    val s_height = s.height
    val s_margin = s.margin
    val s_padding = s.padding
    val s_border = s.border
    val border_w = s_border.width

    val cw = container.content_width
    val ch = container.content_height

    # Resolve width (block fills container by default minus margin)
    var box_width = cw - s_margin.horizontal()
    if not s_width.is_auto():
        box_width = s_width.resolve_px(cw)

    # Apply min/max width
    val s_max_w = s.max_width
    val s_min_w = s.min_width
    if not s_max_w.is_auto():
        val max_w = s_max_w.resolve_px(cw)
        if box_width > max_w:
            box_width = max_w
    if not s_min_w.is_auto():
        val min_w = s_min_w.resolve_px(cw)
        if box_width < min_w:
            box_width = min_w
    # Clamp: negative margins can push box_width below 0
    if box_width < 0:
        box_width = 0

    # Content area insets
    val inset_h = s_padding.horizontal() + border_w * 2
    val inset_v = s_padding.vertical() + border_w * 2
    val content_w = if box_width > inset_h: box_width - inset_h else: 0

    # Position
    val box_x = container.content_x + s_margin.left
    val box_y = container.content_y + s_margin.top
    val cont_x = box_x + border_w + s_padding.left
    val cont_y = box_y + border_w + s_padding.top

    # Lay out children vertically (block flow). Adjacent vertical sibling
    # margins collapse to max(prev.bottom, cur.top) per CSS 2.1 §8.3.1.
    var child_boxes: [BeLayoutBox] = []
    var cursor_y = cont_y
    var prev_bottom_margin: i32 = 0
    var seen_child = false
    val block_kids = be_dom_get_children(node)
    var bk_idx = 0
    val bk_len = block_kids.len()
    _ld("[LB] bk_len={bk_len}")
    while bk_idx < bk_len:
        _ld("[LB] idx={bk_idx}")
        val child = block_kids[bk_idx]
        _ld("[LB] got child")
        bk_idx = bk_idx + 1
        val child_disp = be_dom_get_display(child)
        _ld("[LB] disp='{child_disp}'")
        if child_disp != "none":
            val child_style = be_dom_get_style(child)
            val child_mt = child_style.margin.top
            val child_mb = child_style.margin.bottom
            if seen_child:
                val collapse = if prev_bottom_margin < child_mt: prev_bottom_margin else: child_mt
                cursor_y = cursor_y - collapse
            val child_container = BeLayoutBox(
                x: cont_x, y: cursor_y,
                width: content_w, height: 0,
                content_x: cont_x, content_y: cursor_y,
                content_width: content_w, content_height: 0,
                node: child, children: []
            )
            _ld("[LB] container created")
            val child_box = layout_node(child, child_container, s)
            _ld("[LB] child laid out")
            child_boxes.push(child_box)
            cursor_y = cursor_y + child_box.height
            prev_bottom_margin = child_mb
            seen_child = true

    # Resolve height
    var content_h = cursor_y - cont_y
    # Clamp: negative margins on children can make cursor_y < cont_y
    if content_h < 0:
        content_h = 0
    if not s_height.is_auto():
        val explicit_h = s_height.resolve_px(ch)
        var resolved_h = if explicit_h > inset_v: explicit_h - inset_v else: 0
        if resolved_h < 0:
            resolved_h = 0
        content_h = resolved_h

    # Apply min/max height
    val s_max_h = s.max_height
    val s_min_h = s.min_height
    if not s_max_h.is_auto():
        var max_h = s_max_h.resolve_px(ch) - inset_v
        if max_h < 0:
            max_h = 0
        if content_h > max_h:
            content_h = max_h
    if not s_min_h.is_auto():
        var min_h = s_min_h.resolve_px(ch) - inset_v
        if min_h < 0:
            min_h = 0
        if content_h < min_h:
            content_h = min_h

    val box_height = content_h + inset_v
    # Clamp total height: negative margins can make final height negative
    var total_height = box_height + s_margin.vertical()
    if total_height < 0:
        total_height = 0

    BeLayoutBox(
        x: box_x, y: box_y,
        width: box_width, height: total_height,
        content_x: cont_x, content_y: cont_y,
        content_width: content_w, content_height: content_h,
        node: node, children: child_boxes
    )

# =========================================================================
# Flexbox Layout
# =========================================================================

fn layout_flex(node: BeDomNode, container: BeLayoutBox, style: StyleProps) -> BeLayoutBox:
    """Lay out a flex container with full CSS flexbox support.
    Handles: flex-grow/shrink/basis, justify-content, align-items,
    align-self, flex-direction (row/column/row-reverse/column-reverse),
    flex-wrap, gap, min/max clamping.
    """
    # Extract ALL style fields upfront to avoid chained FieldGet issues
    val margin = style.margin
    val padding = style.padding
    val s_border = style.border
    val border_w = s_border.width
    val gap = style.gap
    val s_flex_dir = style.flex_direction
    val is_row = s_flex_dir == "row" or s_flex_dir == "row-reverse"
    val is_reverse = s_flex_dir == "row-reverse" or s_flex_dir == "column-reverse"
    val s_width = style.width
    val s_height = style.height
    val s_max_width = style.max_width
    val s_min_width = style.min_width
    val s_max_height = style.max_height
    val s_min_height = style.min_height
    val s_justify = style.justify_content
    val s_align = style.align_items

    # Extract container fields
    val c_content_w = container.content_width
    val c_content_h = container.content_height
    val c_content_x = container.content_x
    val c_content_y = container.content_y

    # Resolve width
    var box_width = c_content_w - margin.horizontal()
    if not s_width.is_auto():
        box_width = s_width.resolve_px(c_content_w)

    # Apply min/max width clamping
    if not s_max_width.is_auto():
        val max_w = s_max_width.resolve_px(c_content_w)
        if box_width > max_w:
            box_width = max_w
    if not s_min_width.is_auto():
        val min_w = s_min_width.resolve_px(c_content_w)
        if box_width < min_w:
            box_width = min_w
    # Clamp: negative margins can push box_width below 0
    if box_width < 0:
        box_width = 0

    # Content area
    val inset_h = padding.horizontal() + border_w * 2
    val inset_v = padding.vertical() + border_w * 2
    val content_w = if box_width > inset_h: box_width - inset_h else: 0

    # Position
    val box_x = container.content_x + margin.left
    val box_y = container.content_y + margin.top
    val cont_x = box_x + border_w + padding.left
    val cont_y = box_y + border_w + padding.top

    # Collect visible children and their flex properties
    var visible_children: [BeDomNode] = []
    val flex_kids = be_dom_get_children(node)
    var fk_idx = 0
    while fk_idx < flex_kids.len():
        val child = flex_kids[fk_idx]
        fk_idx = fk_idx + 1
        # Use accessor to avoid cross-module FieldGet bug on StyleProps.display
        val child_flex_disp = be_dom_get_display(child)
        if child_flex_disp != "none":
            visible_children.push(child)

    val visible_count = visible_children.len()
    val total_gaps = if visible_count > 1: gap * (visible_count - 1) else: 0
    val main_avail = if is_row: content_w else: 0  # 0 for column = unlimited
    val cross_avail = if is_row: 0 else: content_w

    # Phase 1: Determine each child's base size (flex-basis or content)
    var child_bases: [i32] = []
    var child_grows: [f32] = []
    var child_shrinks: [f32] = []
    var total_grow = 0.0
    var total_shrink = 0.0
    var total_base = 0

    var vc_idx = 0
    while vc_idx < visible_children.len():
        val child = visible_children[vc_idx]
        vc_idx = vc_idx + 1
        val cs = be_dom_get_style(child)
        var base = 0
        if not cs.flex_basis.is_auto():
            base = cs.flex_basis.resolve_px(if is_row: content_w else: 0)
        elif is_row and not cs.width.is_auto():
            base = cs.width.resolve_px(content_w)
        elif not is_row and not cs.height.is_auto():
            base = cs.height.resolve_px(0)

        child_bases.push(base)
        child_grows.push(cs.flex_grow)
        child_shrinks.push(cs.flex_shrink)
        total_grow = total_grow + cs.flex_grow
        total_shrink = total_shrink + cs.flex_shrink
        total_base = total_base + base

    # Phase 2: Distribute remaining space
    var child_sizes: [i32] = []
    if is_row and main_avail > 0:
        val remaining = main_avail - total_gaps - total_base
        var idx = 0
        while idx < visible_count:
            var sz = child_bases[idx]
            if remaining > 0 and total_grow > 0.0:
                val grow = child_grows[idx]
                sz = sz + (remaining.to_f32() * grow / total_grow).to_i32()
            elif remaining < 0 and total_shrink > 0.0:
                val shrink = child_shrinks[idx]
                val shrink_amount = ((0 - remaining).to_f32() * shrink / total_shrink).to_i32()
                sz = sz - shrink_amount
                if sz < 0:
                    sz = 0
            # If no grow/shrink and base is 0, divide equally
            if sz == 0 and total_grow == 0.0 and total_base == 0:
                sz = (main_avail - total_gaps) / visible_count
            child_sizes.push(sz)
            idx = idx + 1
    else:
        var idx = 0
        while idx < visible_count:
            child_sizes.push(child_bases[idx])
            idx = idx + 1

    # Phase 3: Layout each child with its allocated size
    var child_boxes: [BeLayoutBox] = []
    var cursor_x = cont_x
    var cursor_y = cont_y
    var max_cross = 0

    var ci = 0
    while ci < visible_count:
        val child = visible_children[ci]
        val allocated = if ci < child_sizes.len(): child_sizes[ci] else: 0

        var child_container: BeLayoutBox = BeLayoutBox(
            x: 0, y: 0, width: 0, height: 0,
            content_x: 0, content_y: 0,
            content_width: 0, content_height: 0,
            node: child, children: []
        )
        if is_row:
            child_container = BeLayoutBox(
                x: cursor_x, y: cont_y,
                width: allocated, height: 0,
                content_x: cursor_x, content_y: cont_y,
                content_width: allocated, content_height: 0,
                node: child, children: []
            )
        else:
            child_container = BeLayoutBox(
                x: cont_x, y: cursor_y,
                width: content_w, height: 0,
                content_x: cont_x, content_y: cursor_y,
                content_width: content_w, content_height: 0,
                node: child, children: []
            )

        val child_box = layout_node(child, child_container, style)
        child_boxes.push(child_box)

        if is_row:
            cursor_x = cursor_x + child_box.width + gap
            if child_box.height > max_cross:
                max_cross = child_box.height
        else:
            cursor_y = cursor_y + child_box.height + gap
            if child_box.width > max_cross:
                max_cross = child_box.width
        ci = ci + 1

    # Resolve content height
    var content_h: i32 = 0
    if is_row:
        content_h = max_cross
    else:
        content_h = cursor_y - cont_y
        if child_boxes.len() > 0:
            content_h = content_h - gap
    # Clamp: negative margins on children can make content_h negative
    if content_h < 0:
        content_h = 0

    if not s_height.is_auto():
        var explicit_h = s_height.resolve_px(c_content_h) - inset_v
        if explicit_h < 0:
            explicit_h = 0
        content_h = explicit_h

    # Apply min/max height clamping
    if not s_max_height.is_auto():
        var max_h = s_max_height.resolve_px(c_content_h) - inset_v
        if max_h < 0:
            max_h = 0
        if content_h > max_h:
            content_h = max_h
    if not s_min_height.is_auto():
        var min_h = s_min_height.resolve_px(c_content_h) - inset_v
        if min_h < 0:
            min_h = 0
        if content_h < min_h:
            content_h = min_h

    # Phase 4: justify-content — reposition children along main axis
    if is_row and child_boxes.len() > 0:
        var total_used = 0
        var cb_idx = 0
        while cb_idx < child_boxes.len():
            val cb = child_boxes[cb_idx]
            cb_idx = cb_idx + 1
            total_used = total_used + cb.width
        total_used = total_used + total_gaps
        val free_space = content_w - total_used

        val jc = s_justify
        if jc == "center":
            val offset = free_space / 2
            flex_shift_boxes_x(child_boxes, offset)
        elif jc == "flex-end":
            flex_shift_boxes_x(child_boxes, free_space)
        elif jc == "space-between":
            if child_boxes.len() > 1:
                val sp = free_space / (child_boxes.len() - 1)
                flex_distribute_x(child_boxes, cont_x, sp, gap)
        elif jc == "space-around":
            if child_boxes.len() > 0:
                val sp = free_space / child_boxes.len()
                val half = sp / 2
                flex_distribute_x(child_boxes, cont_x + half, sp, gap)
        elif jc == "space-evenly":
            if child_boxes.len() > 0:
                val sp = free_space / (child_boxes.len() + 1)
                flex_distribute_x(child_boxes, cont_x + sp, sp, gap)

    # Phase 5: align-items — reposition children along cross axis
    if is_row:
        var bi = 0
        while bi < child_boxes.len():
            val child_style = be_dom_get_style(visible_children[bi])
            val ai = if child_style.align_self != "auto": child_style.align_self else: s_align
            val cb_h = child_boxes[bi].height
            if ai == "center":
                val offset = (content_h - cb_h) / 2
                child_boxes[bi].y = cont_y + offset
                child_boxes[bi].content_y = child_boxes[bi].y + child_style.border.width + child_style.padding.top
            elif ai == "flex-end":
                val offset = content_h - cb_h
                child_boxes[bi].y = cont_y + offset
                child_boxes[bi].content_y = child_boxes[bi].y + child_style.border.width + child_style.padding.top
            elif ai == "stretch":
                if child_style.height.is_auto() and cb_h < content_h:
                    child_boxes[bi].height = content_h
                    var stretch_ch = content_h - child_style.padding.vertical() - child_style.border.width * 2
                    if stretch_ch < 0:
                        stretch_ch = 0
                    child_boxes[bi].content_height = stretch_ch
            bi = bi + 1
    else:
        # Column: cross axis is horizontal
        var bi = 0
        while bi < child_boxes.len():
            val child_style = be_dom_get_style(visible_children[bi])
            val ai = if child_style.align_self != "auto": child_style.align_self else: s_align
            val cb_w = child_boxes[bi].width
            if ai == "center":
                val offset = (content_w - cb_w) / 2
                child_boxes[bi].x = cont_x + offset
                child_boxes[bi].content_x = child_boxes[bi].x + child_style.border.width + child_style.padding.left
            elif ai == "flex-end":
                val offset = content_w - cb_w
                child_boxes[bi].x = cont_x + offset
                child_boxes[bi].content_x = child_boxes[bi].x + child_style.border.width + child_style.padding.left
            bi = bi + 1

    # Phase 6: row-reverse / column-reverse — mirror positions
    if is_reverse and child_boxes.len() > 0:
        if is_row:
            var ri = 0
            while ri < child_boxes.len():
                val old_x = child_boxes[ri].x
                val w = child_boxes[ri].width
                child_boxes[ri].x = cont_x + content_w - (old_x - cont_x) - w
                val ri_style = be_dom_get_style(visible_children[ri])
                child_boxes[ri].content_x = child_boxes[ri].x + ri_style.border.width + ri_style.padding.left
                ri = ri + 1
        else:
            var ri = 0
            while ri < child_boxes.len():
                val old_y = child_boxes[ri].y
                val h = child_boxes[ri].height
                child_boxes[ri].y = cont_y + content_h - (old_y - cont_y) - h
                val ri_style_v = be_dom_get_style(visible_children[ri])
                child_boxes[ri].content_y = child_boxes[ri].y + ri_style_v.border.width + ri_style_v.padding.top
                ri = ri + 1

    val box_height = content_h + inset_v
    # Clamp total height: negative margins can make final height negative
    var total_height = box_height + margin.vertical()
    if total_height < 0:
        total_height = 0

    return BeLayoutBox(
        x: box_x, y: box_y,
        width: box_width, height: total_height,
        content_x: cont_x, content_y: cont_y,
        content_width: content_w, content_height: content_h,
        node: node, children: child_boxes
    )

fn flex_shift_boxes_x(boxes: [BeLayoutBox], offset: i32):
    """Shift all boxes along the X axis by offset."""
    var i = 0
    while i < boxes.len():
        boxes[i].x = boxes[i].x + offset
        boxes[i].content_x = boxes[i].content_x + offset
        i = i + 1

fn flex_distribute_x(boxes: [BeLayoutBox], start_x: i32, extra_per_item: i32, gap: i32):
    """Redistribute boxes along X axis with extra spacing."""
    var cursor = start_x
    var i = 0
    while i < boxes.len():
        val dx = cursor - boxes[i].x
        boxes[i].x = cursor
        boxes[i].content_x = boxes[i].content_x + dx
        cursor = cursor + boxes[i].width + gap + extra_per_item
        i = i + 1

# =========================================================================
# Text Layout
# =========================================================================

# Shared font renderer for proportional text measurement
var _layout_font_renderer: FontRenderer? = nil

fn get_layout_font_renderer() -> FontRenderer:
    if val Some(r) = _layout_font_renderer:
        return r
    val r = FontRenderer.new()
    _layout_font_renderer = r
    r

fn layout_text(node: BeDomNode, container: BeLayoutBox, parent_style: StyleProps) -> BeLayoutBox:
    """Lay out a text node using font renderer metrics.
    Uses vector/bitmap font with proportional width when available.

    Text nodes don't carry their own computed font_size (they keep the
    default 16), so use the parent element's font_size — which is the
    CSS-inheritable value the text actually renders at.
    """
    val ns = be_dom_get_style(node)
    val font_size = parent_style.font_size
    # CSS "line-height: normal" ≈ 1.2×font-size. text_line_height() returns
    # a flat 18 for any fs > 8 which massively over-sizes small-font blocks
    # and pushes ancestor borders down. Use font-proportional metrics with
    # round-to-nearest: floor lost 1px on font_size=14 (16 vs Chrome's 17),
    # producing ~300-px row-offset errors in 14_border diff analysis.
    val line_h = if font_size <= 8:
        text_line_height(font_size)
    else:
        (font_size * 12 + 5) / 10

    # Use font renderer for proportional width measurement
    var renderer = get_layout_font_renderer()
    val node_txt = be_dom_get_text(node)
    val text_w = renderer.measure_text_width(node_txt, font_size)

    val cont_cw = if container.content_width > 0: container.content_width else: 0
    val wrapped_lines = if cont_cw > 0:
        (text_w + cont_cw - 1) / cont_cw
    else:
        1
    val actual_lines = if wrapped_lines < 1: 1 else: wrapped_lines
    val h = actual_lines * line_h
    val w = if cont_cw > 0 and text_w < cont_cw: text_w else: cont_cw

    return BeLayoutBox(
        x: container.content_x, y: container.content_y,
        width: w, height: h,
        content_x: container.content_x, content_y: container.content_y,
        content_width: w, content_height: h,
        node: node, children: []
    )

# =========================================================================
# Hit Testing
# =========================================================================

fn hit_test(layout: BeLayoutBox, x: i32, y: i32) -> text:
    """Walk the layout tree and find the deepest box containing (x, y).

    Returns the DOM node's id, or "" if no box contains the point.
    Children are checked first so deeper (visually-on-top) nodes win.
    """
    # Check children first (deeper = higher priority)
    var lc_idx = 0
    while lc_idx < layout.children.len():
        val child = layout.children[lc_idx]
        lc_idx = lc_idx + 1
        val result = hit_test(child, x, y)
        if result != "":
            return result

    # Check this box
    if x >= layout.x and x < layout.x + layout.width and y >= layout.y and y < layout.y + layout.height:
        return layout.node.id

    return ""

# =========================================================================
# Inline Paint → Scene Generation (avoids cross-module FieldGet bug)
# =========================================================================

@allow(primitive_api)
pub fn layout_to_scene(root: BeDomNode, viewport_w: i32, viewport_h: i32) -> RenderScene:
    """Layout the DOM tree and generate scene commands — all in one module to
    avoid the Cranelift cross-module FieldGet issue with struct/array fields."""
    _ld("[LTS] layout_tree start")
    val layout = layout_tree(root, viewport_w, viewport_h)
    _ld("[LTS] layout_tree done")
    var cmds: [SceneCommand] = []
    _ld("[LTS] paint start")
    cmds = _paint_box(layout, cmds)
    _ld("[LTS] paint done, cmds={cmds.len()}")
    render_scene(cmds, viewport_w, viewport_h)

fn _paint_box(box: BeLayoutBox, commands: [SceneCommand]) -> [SceneCommand]:
    """Generate scene commands for a layout box and children.
    Uses accessor functions for all cross-module field access to avoid Cranelift bug."""
    var cmds = commands
    val node = box.node

    # All style access via dom.spl accessors (avoid cross-module FieldGet on StyleProps)
    val disp = be_dom_get_display(node)
    if disp == "none":
        return cmds
    val vis = be_dom_get_visibility(node)
    if vis == "hidden":
        return cmds
    val opacity = be_dom_get_opacity(node)
    if opacity < 0.01:
        return cmds

    val border_radius = be_dom_get_border_radius(node)
    val pad_left = be_dom_get_padding_left(node)
    val pad_top = be_dom_get_padding_top(node)
    val pad_h = be_dom_get_padding_h(node)
    val pad_v = be_dom_get_padding_v(node)

    # 0. Box shadows (before background per CSS spec)
    val shadows = be_dom_get_box_shadows(node)
    var sh_idx = 0
    while sh_idx < shadows.len():
        val shadow = shadows[sh_idx]
        sh_idx = sh_idx + 1
        if not shadow.inset:
            val sx = box.x + shadow.offset_x - shadow.spread_radius
            val sy = box.y + shadow.offset_y - shadow.spread_radius
            val sw = box.width + shadow.spread_radius * 2
            val sh = box.height + shadow.spread_radius * 2
            if shadow.blur_radius > 0:
                val steps = if shadow.blur_radius > 8: 4 else: 2
                var si: i32 = steps
                while si > 0:
                    val expand = shadow.blur_radius * si / steps
                    val alpha_factor = 1.0 / (si + 1).to_f32()
                    val s_argb = _apply_opacity(rgba_to_argb(shadow.color), opacity * alpha_factor)
                    if border_radius > 0:
                        cmds.push(scene_rounded_rect(
                            sx - expand, sy - expand,
                            sw + expand * 2, sh + expand * 2,
                            s_argb, border_radius))
                    else:
                        cmds.push(scene_fill_rect(
                            sx - expand, sy - expand,
                            sw + expand * 2, sh + expand * 2,
                            s_argb))
                    si = si - 1
            else:
                val s_argb = _apply_opacity(rgba_to_argb(shadow.color), opacity)
                if border_radius > 0:
                    cmds.push(scene_rounded_rect(sx, sy, sw, sh, s_argb, border_radius))
                else:
                    cmds.push(scene_fill_rect(sx, sy, sw, sh, s_argb))

    # 0b. Backdrop blur (before background, blurs existing content behind element)
    val backdrop_blur = be_dom_get_backdrop_blur(node)
    if backdrop_blur > 0:
        cmds.push(scene_blur_rect(box.x, box.y, box.width, box.height, backdrop_blur, border_radius))

    # 1. Background color (via accessor)
    val bg_color = be_dom_get_bg_color(node)

    if bg_color != 0x00000000:
        val bg_argb = _apply_opacity(rgba_to_argb(bg_color), opacity)
        if border_radius > 0:
            cmds.push(scene_rounded_rect(
                box.content_x - pad_left, box.content_y - pad_top,
                box.content_width + pad_h, box.content_height + pad_v,
                bg_argb, border_radius))
        else:
            cmds.push(scene_fill_rect(
                box.content_x - pad_left, box.content_y - pad_top,
                box.content_width + pad_h, box.content_height + pad_v,
                bg_argb))

    # Gradient
    val has_grad = be_dom_get_has_gradient(node)
    if has_grad:
        val c1 = _apply_opacity(rgba_to_argb(be_dom_get_gradient_c1(node)), opacity)
        val c2 = _apply_opacity(rgba_to_argb(be_dom_get_gradient_c2(node)), opacity)
        cmds.push(scene_gradient_rect(
            box.content_x - pad_left, box.content_y - pad_top,
            box.content_width + pad_h, box.content_height + pad_v, c1, c2))

    # Border
    val bw = be_dom_get_border_width(node)
    val bs = be_dom_get_border_style(node)
    if bw > 0 and bs != "none":
        val bc = rgba_to_argb(be_dom_get_border_color(node))
        cmds.push(scene_stroke_rect(box.x, box.y, box.width, box.height, bc, bw))

    # Text content
    if be_dom_get_is_text(node):
        val txt = be_dom_get_text(node)
        if txt.len() > 0:
            val tc = rgba_to_argb(be_dom_get_color(node))
            val fs = be_dom_get_font_size(node)
            cmds.push(scene_text(box.content_x, box.content_y, txt, tc, fs))

            # Text decoration (underline, overline, line-through)
            val text_deco = be_dom_get_text_decoration(node)
            if text_deco != "none" and text_deco != "":
                var text_width = box.content_width
                if text_width <= 0:
                    text_width = txt.len() * (fs * 55 / 100)
                val line_h = 1
                if text_deco == "underline":
                    val deco_y = box.content_y + fs + 2
                    cmds.push(scene_fill_rect(box.content_x, deco_y, text_width, line_h, tc))
                else if text_deco == "overline":
                    val deco_y = box.content_y - 1
                    cmds.push(scene_fill_rect(box.content_x, deco_y, text_width, line_h, tc))
                else if text_deco == "line-through":
                    val deco_y = box.content_y + fs / 2
                    cmds.push(scene_fill_rect(box.content_x, deco_y, text_width, line_h, tc))

    # Children (same-module access to BeLayoutBox.children)
    var bc_idx = 0
    while bc_idx < box.children.len():
        val child = box.children[bc_idx]
        bc_idx = bc_idx + 1
        cmds = _paint_box(child, cmds)

    return cmds

fn _apply_opacity(argb: u32, opacity: f32) -> u32:
    if opacity >= 1.0:
        return argb
    if opacity <= 0.0:
        return argb & 0x00FFFFFF
    val a = (argb >> 24) & 0xFF
    var new_a = (a.to_f32() * opacity).to_u32()
    if new_a > 255:
        new_a = 255
    return (new_a << 24) | (argb & 0x00FFFFFF)
