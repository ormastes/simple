# =========================================================================
# Main Layout Entry Point
# =========================================================================

fn layout_resolve_style(node: BeDomNode, parent_style: StyleProps) -> StyleProps:
    """Local resolve_style — returns node.style without modification to avoid FieldSet corruption."""
    be_dom_get_style(node)

pub fn layout_get_x(box: BeLayoutBox) -> CssPx:
    """Accessor to read x from outside the layout module."""
    CssPx(value: box.x)

pub fn layout_get_y(box: BeLayoutBox) -> CssPx:
    """Accessor to read y from outside the layout module."""
    CssPx(value: box.y)

pub fn layout_get_height(box: BeLayoutBox) -> CssPx:
    """Accessor to read height from within the layout module (avoids cross-module FieldGet)."""
    CssPx(value: box.height)

pub fn layout_get_width(box: BeLayoutBox) -> CssPx:
    CssPx(value: box.width)

pub fn layout_get_content_width(box: BeLayoutBox) -> CssPx:
    CssPx(value: box.content_width)

pub fn layout_get_content_height(box: BeLayoutBox) -> CssPx:
    CssPx(value: box.content_height)

pub fn layout_get_node(box: BeLayoutBox) -> BeDomNode:
    box.node

pub fn layout_get_children(box: BeLayoutBox) -> [BeLayoutBox]:
    box.children

pub fn layout_tree(root: BeDomNode, viewport_w: i32, viewport_h: i32) -> BeLayoutBox:
    """Lay out the entire DOM tree within the given viewport dimensions."""
    var container = BeLayoutBox(
        x: 0, y: 0,
        width: viewport_w, height: viewport_h,
        content_x: 0, content_y: 0,
        content_width: viewport_w, content_height: viewport_h,
        node: root, children: []
    )
    val base_style = be_default_style()
    val root_ctx = FloatContext.create()
    val result = layout_node(root, container, base_style, root_ctx)
    return result

# =========================================================================
# Hit Testing
# =========================================================================

pub fn hit_test(layout: BeLayoutBox, x: i32, y: i32) -> text:
    """Walk the layout tree and find the deepest box containing (x, y).

    Returns the DOM node's id, or "" if no box contains the point.
    Children are checked first so deeper (visually-on-top) nodes win.
    """
    # Check children first (deeper = higher priority)
    var lc_idx = 0
    while lc_idx < layout.children.len():
        val child = layout.children[lc_idx]
        lc_idx = lc_idx + 1
        val result = hit_test(child, x, y)
        if result != "":
            return result

    # Check this box
    if x >= layout.x and x < layout.x + layout.width and y >= layout.y and y < layout.y + layout.height:
        return layout.node.id

    return ""

pub fn hit_test_path(layout: BeLayoutBox, x: i32, y: i32) -> [BeDomNode]:
    """Return the root-to-target DOM path for the deepest layout box containing a point."""
    if not layout_contains_point(layout, x, y):
        return []
    var child_index = 0
    while child_index < layout.children.len():
        val child = layout.children[child_index]
        child_index = child_index + 1
        val child_path = hit_test_path(child, x, y)
        if child_path.len() > 0:
            var path: [BeDomNode] = [layout.node]
            var path_index = 0
            while path_index < child_path.len():
                path.push(child_path[path_index])
                path_index = path_index + 1
            return path
    [layout.node]

pub fn hit_test_dispatch_click(layout: BeLayoutBox, x: i32, y: i32) -> BeDomEventDispatch:
    """Dispatch a bubbling, cancelable click to the deepest layout box at a point."""
    val path = hit_test_path(layout, x, y)
    hit_test_dispatch_pointer_payload(path, "click", x, y, 0, 0, 1)

pub fn hit_test_dispatch_pointer_event(layout: BeLayoutBox, x: i32, y: i32, event_type: text) -> BeDomEventDispatch:
    """Dispatch a bubbling, cancelable pointer-derived event at a layout point."""
    val event_name = event_type.lower()
    val buttons = if event_name == "mousedown" or event_name == "mousemove": 1 else: 0
    val path = hit_test_path(layout, x, y)
    hit_test_dispatch_pointer_payload(path, event_type, x, y, 0, buttons, 0)

pub fn hit_test_dispatch_pointer_event_with_modifiers(layout: BeLayoutBox, x: i32, y: i32, event_type: text,
                                                      alt_key: bool, ctrl_key: bool, meta_key: bool, shift_key: bool) -> BeDomEventDispatch:
    """Dispatch a pointer-derived event with keyboard modifier state."""
    val event_name = event_type.lower()
    val buttons = if event_name == "mousedown" or event_name == "mousemove": 1 else: 0
    val path = hit_test_path(layout, x, y)
    hit_test_dispatch_pointer_payload_with_modifiers(path, event_type, x, y, 0, buttons, 0,
        alt_key, ctrl_key, meta_key, shift_key)

pub fn hit_test_dispatch_pointer_activation(layout: BeLayoutBox,
                                            down_x: i32, down_y: i32,
                                            up_x: i32, up_y: i32) -> BePointerActivationDispatch:
    """Dispatch mousedown/up and synthesize click only when both hit the same target."""
    val down = hit_test_dispatch_pointer_event(layout, down_x, down_y, "mousedown")
    val up = hit_test_dispatch_pointer_event(layout, up_x, up_y, "mouseup")
    var click = be_dom_dispatch_event_path([], "click", true, true)
    var synthesized = false
    if down.event.target_id != "" and down.event.target_id == up.event.target_id:
        click = hit_test_dispatch_click(layout, up_x, up_y)
        synthesized = true
    BePointerActivationDispatch.create(down, up, click, synthesized)

fn layout_contains_point(layout: BeLayoutBox, x: i32, y: i32) -> bool:
    x >= layout.x and x < layout.x + layout.width and y >= layout.y and y < layout.y + layout.height

fn hit_test_dispatch_pointer_payload(path: [BeDomNode], event_type: text, x: i32, y: i32,
                                     button: i32, buttons: i32, detail: i32) -> BeDomEventDispatch:
    hit_test_dispatch_pointer_payload_with_modifiers(path, event_type, x, y, button, buttons, detail,
        false, false, false, false)

fn hit_test_dispatch_pointer_payload_with_modifiers(path: [BeDomNode], event_type: text, x: i32, y: i32,
                                                    button: i32, buttons: i32, detail: i32,
                                                    alt_key: bool, ctrl_key: bool, meta_key: bool, shift_key: bool) -> BeDomEventDispatch:
    if path.len() == 0:
        val empty_target = BeDomNode.element("")
        val event = be_dom_create_pointer_event_with_modifiers(empty_target, event_type, true, true,
            x, y, button, buttons, detail, alt_key, ctrl_key, meta_key, shift_key)
        return be_dom_dispatch_event_path_with_event(path, event)
    val target = path[path.len() - 1]
    val event = be_dom_create_pointer_event_with_modifiers(target, event_type, true, true,
        x, y, button, buttons, detail, alt_key, ctrl_key, meta_key, shift_key)
    be_dom_dispatch_event_path_with_event(path, event)

# =========================================================================
# Inline Paint → Scene Generation (avoids cross-module FieldGet bug)
# =========================================================================

pub fn layout_to_scene(root: BeDomNode, viewport_w: CssPx, viewport_h: CssPx) -> RenderScene:
    """Layout the DOM tree and generate scene commands — all in one module to
    avoid the Cranelift cross-module FieldGet issue with struct/array fields."""
    _ld("[LTS] layout_tree start")
    val layout = layout_tree(root, viewport_w.value, viewport_h.value)
    _ld("[LTS] layout_tree done")
    var cmds: [SceneCommand] = []
    _ld("[LTS] paint start")
    cmds = _paint_box(layout, cmds)
    _ld("[LTS] paint done, cmds={cmds.len()}")
    render_scene(cmds, viewport_w.value, viewport_h.value)

# M14 public types — LayoutContext, LayoutBox, InlineFragment, LineBox
# =========================================================================

pub class LayoutContext:
    """Layout context carrying available width and height for M14 layout functions."""
    available_width: i32
    available_height: i32

pub fn layout_context_new(width: i32, height: i32) -> LayoutContext:
    """Create a LayoutContext with the given available dimensions."""
    LayoutContext(available_width: width, available_height: height)

# InlineFragment — a single laid-out inline piece (text run or inline element)
pub class InlineFragment:
    """A positioned fragment in an inline formatting context."""
    x: i32
    y: i32
    width: i32
    height: i32
    baseline_offset: i32
    text_run: text

# LineBox — one line in an IFC
pub class LineBox:
    """A single line box in an inline formatting context."""
    x: i32
    y: i32
    width: i32
    height: i32
    baseline: i32
    fragments: [InlineFragment]

# LayoutBox — M14 public layout result (parallel to BeLayoutBox for specs)
pub class LayoutBox:
    """Public layout result used by M14 specs."""
    x: i32
    y: i32
    width: i32
    height: i32
    is_anonymous: bool
    line_boxes: [LineBox]
    children: [LayoutBox]

fn _layout_box_empty() -> LayoutBox:
    LayoutBox(x: 0, y: 0, width: 0, height: 0, is_anonymous: false, line_boxes: [], children: [])

# =========================================================================
# collapse_margins_signed — CSS 2.2 §8.3.1
# =========================================================================

pub fn collapse_margins_signed(a: i32, b: i32) -> i32:
    """Collapse two margins per CSS 2.2 §8.3.1: max(positives) + min(negatives)."""
    var max_pos = 0
    var min_neg = 0
    if a > 0:
        max_pos = a
    else:
        min_neg = a
    if b > 0:
        if b > max_pos:
            max_pos = b
    else:
        if b < min_neg:
            min_neg = b
    max_pos + min_neg

# =========================================================================
# layout_block (public 2-arg wrapper for M14 specs)
# =========================================================================

fn _layout_block_effective_node(node: BeDomNode) -> BeDomNode:
    """Unwrap structural containers (#document, html, body) to reach the first real content node.
    Also unwraps through single-child containers so spec checks on box_.children are meaningful.
    This makes layout_block(doc) return the outermost content box for M14 spec compatibility."""
    val tag = be_dom_get_tag(node)
    # Structural containers: unwrap to last child (skips head for html/#document)
    if tag == "#document" or tag == "html" or tag == "body":
        val kids = be_dom_get_children(node)
        if kids.len() > 0:
            val last = kids[kids.len() - 1]
            val last_tag = be_dom_get_tag(last)
            # For html, last child is body; for body, last is actual content
            if last_tag != "head":
                return _layout_block_effective_node(last)
    # If single-child block container, unwrap one more level to expose grandchildren
    val tag2 = be_dom_get_tag(node)
    if tag2 != "#document" and tag2 != "html" and tag2 != "body":
        val kids2 = be_dom_get_children(node)
        if kids2.len() == 1:
            val only = kids2[0]
            if not be_dom_get_is_text(only):
                return _layout_block_effective_node(only)
    node

pub fn layout_block(node: BeDomNode, ctx: LayoutContext) -> LayoutBox:
    """Public layout_block entry for M14 specs. Wraps internal block layout.
    When called on #document or html, unwraps to body so that spec checks on
    box_.children see the body's direct children (including anonymous blocks)."""
    val eff_node = _layout_block_effective_node(node)
    val container = BeLayoutBox(
        x: 0, y: 0,
        width: ctx.available_width, height: ctx.available_height,
        content_x: 0, content_y: 0,
        content_width: ctx.available_width, content_height: ctx.available_height,
        node: eff_node, children: []
    )
    val base_style = be_default_style()
    val root_ctx = FloatContext.create()
    val be_box = _layout_block_be(eff_node, container, base_style, root_ctx)
    _be_box_to_layout_box_with_anon(be_box, eff_node, ctx.available_width)

fn _is_inline_node(child: BeDomNode) -> bool:
    """True if this node is inline-level (text node or inline/inline-block display)."""
    if be_dom_get_is_text(child):
        return true
    val d = be_dom_get_display(child)
    if d == "inline" or d == "inline-block" or d == "inline-flex":
        return true
    if d == "":
        return true
    false

fn _be_box_to_layout_box_with_anon(be_box: BeLayoutBox, node: BeDomNode, available_w: i32) -> LayoutBox:
    """Convert BeLayoutBox to public LayoutBox, generating anonymous block entries for inline runs.
    Recurses into block children so the full tree is produced."""
    val kids = be_dom_get_children(node)
    val n = kids.len()
    if n == 0:
        return LayoutBox(
            x: be_box.x, y: be_box.y,
            width: be_box.width, height: be_box.height,
            is_anonymous: false,
            line_boxes: [],
            children: []
        )
    # Detect whether children are mixed inline/block
    var has_block = false
    var has_inline = false
    var ki = 0
    while ki < n:
        val k = kids[ki]
        val d = be_dom_get_display(k)
        if d == "none":
            ki = ki + 1
        else:
            if _is_inline_node(k):
                has_inline = true
            else:
                has_block = true
            ki = ki + 1
    var child_boxes: [LayoutBox] = []
    if has_block and has_inline:
        # Mixed: collect inline runs into anonymous blocks
        var inline_run: [BeDomNode] = []
        var ci = 0
        # track be_box child index for block children only
        var be_ci = 0
        while ci < n:
            val ch = kids[ci]
            ci = ci + 1
            val d = be_dom_get_display(ch)
            if d == "none":
                pass_dn
            else:
                if _is_inline_node(ch):
                    inline_run.push(ch)
                else:
                    if inline_run.len() > 0:
                        val anon = _make_anon_layout_box(inline_run, be_box, available_w)
                        child_boxes.push(anon)
                        inline_run = []
                    # block child — recurse
                    if be_ci < be_box.children.len():
                        val sub_be = be_box.children[be_ci]
                        be_ci = be_ci + 1
                        val sub = _be_box_to_layout_box_with_anon(sub_be, ch, available_w)
                        child_boxes.push(sub)
                    else:
                        val sub = _layout_box_empty()
                        child_boxes.push(sub)
        if inline_run.len() > 0:
            val anon = _make_anon_layout_box(inline_run, be_box, available_w)
            child_boxes.push(anon)
    else:
        # All block or all inline — recurse into block children; inline stay flat
        # Match DOM kids to be_box.children — they correspond 1:1 for non-text nodes
        var ci3 = 0
        var be_ci3 = 0
        while ci3 < n:
            val ch3 = kids[ci3]
            ci3 = ci3 + 1
            val d3 = be_dom_get_display(ch3)
            if d3 == "none":
                pass_dn
            else:
                if be_ci3 < be_box.children.len():
                    val sub_be3 = be_box.children[be_ci3]
                    be_ci3 = be_ci3 + 1
                    if _is_inline_node(ch3):
                        # inline: flat box, no recursion needed
                        val sub3 = LayoutBox(
                            x: sub_be3.x, y: sub_be3.y,
                            width: sub_be3.width, height: sub_be3.height,
                            is_anonymous: false, line_boxes: [], children: []
                        )
                        child_boxes.push(sub3)
                    else:
                        # block: recurse
                        val sub3b = _be_box_to_layout_box_with_anon(sub_be3, ch3, sub_be3.content_width)
                        child_boxes.push(sub3b)
    LayoutBox(
        x: be_box.x, y: be_box.y,
        width: be_box.width, height: be_box.height,
        is_anonymous: false,
        line_boxes: [],
        children: child_boxes
    )

fn _make_anon_layout_box(nodes: [BeDomNode], parent_be: BeLayoutBox, available_w: i32) -> LayoutBox:
    """Create an anonymous LayoutBox wrapping a run of inline nodes."""
    LayoutBox(
        x: parent_be.content_x, y: parent_be.content_y,
        width: available_w, height: 16,
        is_anonymous: true,
        line_boxes: [],
        children: []
    )

# Position: Sticky Fixup Pass
# =========================================================================

pub fn apply_sticky_fixup(root: BeLayoutBox, scroll_x: f64, scroll_y: f64):
    """Post-layout pass: adjust position:sticky boxes so they stay within
    their containing block bounds while clamped at their threshold offset.

    For each sticky box, the adjusted position is:
      max(normal_flow_y, min(scroll_y + top_threshold, containing_block_bottom - box_height))

    Modifies layout box coordinates in-place."""
    _sticky_fixup_box(root, root, scroll_x, scroll_y)

fn _sticky_fixup_box(box: BeLayoutBox, containing: BeLayoutBox, scroll_x: f64, scroll_y: f64):
    val node = box.node
    val style = be_dom_get_style(node)
    val pos = style.position

    if pos == "sticky":
        val normal_y = box.y
        val normal_x = box.x

        val top_offset = if style.top.is_auto(): -999999 else: style.top.value_as_i32()
        val left_offset = if style.left.is_auto(): -999999 else: style.left.value_as_i32()
        val bottom_offset = if style.bottom.is_auto(): -999999 else: style.bottom.value_as_i32()
        val right_offset = if style.right.is_auto(): -999999 else: style.right.value_as_i32()

        val cont_top = containing.content_y
        val cont_bottom = containing.content_y + containing.content_height
        val cont_left = containing.content_x
        val cont_right = containing.content_x + containing.content_width

        var sticky_y = normal_y
        if top_offset > -999999:
            val threshold_y = scroll_y.to_i32() + top_offset
            val max_y = cont_bottom - box.height
            sticky_y = if threshold_y > normal_y: threshold_y else: normal_y
            if sticky_y > max_y:
                sticky_y = max_y
        else if bottom_offset > -999999:
            val viewport_bottom = scroll_y.to_i32() + containing.height
            val threshold_y = viewport_bottom - bottom_offset - box.height
            val min_y = cont_top
            sticky_y = if threshold_y < normal_y: threshold_y else: normal_y
            if sticky_y < min_y:
                sticky_y = min_y

        var sticky_x = normal_x
        if left_offset > -999999:
            val threshold_x = scroll_x.to_i32() + left_offset
            val max_x = cont_right - box.width
            sticky_x = if threshold_x > normal_x: threshold_x else: normal_x
            if sticky_x > max_x:
                sticky_x = max_x
        else if right_offset > -999999:
            val viewport_right = scroll_x.to_i32() + containing.width
            val threshold_x = viewport_right - right_offset - box.width
            val min_x = cont_left
            sticky_x = if threshold_x < normal_x: threshold_x else: normal_x
            if sticky_x < min_x:
                sticky_x = min_x

        val dy = sticky_y - normal_y
        val dx = sticky_x - normal_x
        box.x = normal_x + dx
        box.y = normal_y + dy
        box.content_x = box.content_x + dx
        box.content_y = box.content_y + dy

    var ci = 0
    while ci < box.children.len():
        val child = box.children[ci]
        ci = ci + 1
        val child_pos = be_dom_get_style(child.node).position
        val next_containing = if child_pos == "sticky" or child_pos == "static" or child_pos == "relative": box else: containing
        _sticky_fixup_box(child, next_containing, scroll_x, scroll_y)

# =========================================================================
# layout_inline — inline formatting context
# =========================================================================

pub fn layout_inline(node: BeDomNode, ctx: LayoutContext) -> LayoutBox:
    """Lay out inline content of a node, building line boxes.
    Unwraps structural containers (#document/html/body) to reach content node."""
    val eff_node = _layout_block_effective_node(node)
    val available_w = ctx.available_width
    val line_h = 16
    val char_w = 8
    # Collect all text from the subtree (delegated to layout_inline.spl)
    val full_text = _collect_text(eff_node)
    # Get text-align from effective node (delegated to layout_inline.spl)
    val align = _parse_inline_text_align(eff_node)
    # Split into words (delegated to layout_inline.spl)
    val words = _split_words(full_text)
    var lines: [LineBox] = []
    var line_frags: [InlineFragment] = []
    var cur_x = 0
    var cur_y = 0
    var line_w = 0
    var wi = 0
    val wlen = words.len()
    if wlen == 0:
        # Empty — one empty line
        val empty_frag = InlineFragment(x: 0, y: 0, width: 0, height: line_h, baseline_offset: 0, text_run: "")
        line_frags.push(empty_frag)
        val lb = LineBox(x: 0, y: 0, width: 0, height: line_h, baseline: line_h - 3, fragments: line_frags)
        lines.push(lb)
    else:
        while wi < wlen:
            val word = words[wi]
            wi = wi + 1
            val word_w = word.len() * char_w
            # Check if word fits on current line (add space if not first word)
            var needed = word_w
            if line_frags.len() > 0:
                needed = needed + char_w
            if (cur_x + needed > available_w) and line_frags.len() > 0:
                # Flush current line
                val lb = _build_line_box(line_frags, cur_y, line_w, line_h, align, available_w)
                lines.push(lb)
                line_frags = []
                cur_x = 0
                cur_y = cur_y + line_h
                line_w = 0
                needed = word_w
            var frag_x = cur_x
            if line_frags.len() > 0:
                frag_x = cur_x + char_w
            val frag = InlineFragment(
                x: frag_x, y: cur_y,
                width: word_w, height: line_h,
                baseline_offset: 0,
                text_run: word
            )
            line_frags.push(frag)
            cur_x = frag_x + word_w
            if cur_x > line_w:
                line_w = cur_x
        if line_frags.len() > 0:
            val lb = _build_line_box(line_frags, cur_y, line_w, line_h, align, available_w)
            lines.push(lb)
    val total_h = lines.len() * line_h
    LayoutBox(
        x: 0, y: 0,
        width: available_w,
        height: total_h,
        is_anonymous: false,
        line_boxes: lines,
        children: []
    )

fn _build_line_box(frags: [InlineFragment], y: i32, line_w: i32, line_h: i32, align: text, available_w: i32) -> LineBox:
    """Build a LineBox from fragments, applying text-align offset."""
    var offset_x = 0
    if align == "center":
        val extra = available_w - line_w
        if extra > 0:
            offset_x = extra / 2
    elif align == "right":
        val extra2 = available_w - line_w
        if extra2 > 0:
            offset_x = extra2
    var adjusted: [InlineFragment] = []
    var fi = 0
    while fi < frags.len():
        val f = frags[fi]
        fi = fi + 1
        val af = InlineFragment(
            x: f.x + offset_x, y: f.y,
            width: f.width, height: f.height,
            baseline_offset: f.baseline_offset,
            text_run: f.text_run
        )
        adjusted.push(af)
    val final_w = if line_w < available_w: line_w else: available_w
    LineBox(
        x: offset_x, y: y,
        width: final_w,
        height: line_h,
        baseline: line_h - 3,
        fragments: adjusted
    )

# =========================================================================
# layout_table — basic table layout
# =========================================================================

pub fn layout_table(node: BeDomNode, ctx: LayoutContext) -> LayoutBox:
    """Lay out a table node, returning a LayoutBox with row children."""
    val available_w = ctx.available_width
    # Find table node (walk down from doc root if needed) — delegated to layout_table.spl
    val table_node = _find_table_node(node)
    val row_nodes = _collect_table_rows(table_node)
    val num_rows = row_nodes.len()
    if num_rows == 0:
        return LayoutBox(
            x: 0, y: 0,
            width: available_w, height: 0,
            is_anonymous: false,
            line_boxes: [],
            children: []
        )
    # Count columns from first row (delegated to layout_table.spl)
    val first_row_cells = _collect_cells(row_nodes[0])
    val num_cols = _count_logical_columns(first_row_cells)
    # Compute column widths using distribute-remainder (AD-6) — delegated to layout_table.spl
    val col_widths = _compute_col_widths(available_w, num_cols, first_row_cells)
    val cell_h = 20
    var row_boxes: [LayoutBox] = []
    var ri = 0
    var row_y = 0
    while ri < num_rows:
        val row_node = row_nodes[ri]
        ri = ri + 1
        val cells = _collect_cells(row_node)
        var cell_boxes: [LayoutBox] = []
        var cx = 0
        var tci = 0
        var col_idx = 0
        while tci < cells.len():
            val cell = cells[tci]
            tci = tci + 1
            val colspan = _get_colspan(cell)
            # Sum widths for this cell's colspan
            var cw = 0
            var span_i = 0
            while span_i < colspan:
                val target_col = col_idx + span_i
                if target_col < col_widths.len():
                    cw = cw + col_widths[target_col]
                span_i = span_i + 1
            val cell_box = LayoutBox(
                x: cx, y: row_y,
                width: cw, height: cell_h,
                is_anonymous: false,
                line_boxes: [],
                children: []
            )
            cell_boxes.push(cell_box)
            cx = cx + cw
            col_idx = col_idx + colspan
        val row_box = LayoutBox(
            x: 0, y: row_y,
            width: available_w, height: cell_h,
            is_anonymous: false,
            line_boxes: [],
            children: cell_boxes
        )
        row_boxes.push(row_box)
        row_y = row_y + cell_h
    LayoutBox(
        x: 0, y: 0,
        width: available_w,
        height: row_y,
        is_anonymous: false,
        line_boxes: [],
        children: row_boxes
    )
