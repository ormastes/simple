    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 150, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 14, 44, 292, 74, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 14, 14, 128, 28, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 52, 88, 28, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 82, 88, 28, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 14, 120, 124, 24, 0xFF60A5FAu32)
