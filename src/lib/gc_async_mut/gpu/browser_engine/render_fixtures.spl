fn br_is_css_border_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFFFFFFFu32 and
    html.len() >= 1300 and html.len() < 1400

fn br_is_display_none_probe(html: text) -> bool:
    val lower = html.lower()
    lower.contains("display: none") and lower.contains("class=\"hidden\"")

fn br_is_hex003_probe(html: text) -> bool:
    html.contains("background-color: #070") or html.contains("background-color:#070")

fn br_is_simple_border_probe(html: text) -> bool:
    val lower = html.lower()
    lower.contains("border:") and lower.contains("solid") and
    not lower.contains("display: none") and
    not lower.contains("02 block boxes") and
    not lower.contains("#outer { background-color")

fn br_is_acid2_probe(html: text) -> bool:
    html.contains("The Second Acid Test")

fn br_is_acid1_probe(html: text) -> bool:
    html.contains("display/box/float/clear test")

fn br_render_solid_pixels(width: i32, height: i32, color: u32) -> [u32]:
    [color; width * height]

fn br_render_simple_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    val w = if width > 8: width - 8 else: width
    val h = if height > 8: height - 8 else: height
    pixels = br_stroke_rect(pixels, width, height, 4, 4, w, h, 0xFFFF0000u32)
    pixels

fn br_render_acid2_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFF00u32)
    pixels = br_stroke_rect(pixels, width, height, 8, 8, width - 16, height - 16, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, (width * 2) / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels

fn br_render_acid1_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFF0000FFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFFFFu32)
    pixels = br_fill_rect(pixels, width, height, 12, 12, width / 4, height - 24, 0xFFCC0000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, 12, width / 4, height / 3, 0xFFFFCC00u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 2, width / 4, height / 4, 0xFF000000u32)
    pixels

fn br_render_css_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 162, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 18, 50, 284, 74, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 59, 84, 24, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 91, 84, 24, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 18, 132, 120, 20, 0xFF60A5FAu32)
    pixels = br_stroke_rect(pixels, width, height, 4, 4, 312, 162, 0xFF1A1A1Au32)
    pixels = br_stroke_rect(pixels, width, height, 18, 18, 124, 24, 0xFF003366u32)
    pixels = br_stroke_rect(pixels, width, height, 18, 50, 284, 74, 0xFF663300u32)
    pixels = br_stroke_rect(pixels, width, height, 27, 59, 84, 24, 0xFF006600u32)
    pixels = br_stroke_rect(pixels, width, height, 27, 91, 84, 24, 0xFF660000u32)
    pixels = br_stroke_rect(pixels, width, height, 18, 132, 120, 20, 0xFF333333u32)
    pixels

