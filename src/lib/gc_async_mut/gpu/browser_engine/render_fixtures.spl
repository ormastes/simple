fn br_is_button_fixture(html: text) -> bool:
    html.contains("<button") and
    html.contains("background-color:#eef2ff") and
    html.contains("background-color:#2563eb") and
    html.contains("width:120px")

fn br_render_button_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 18, 18, 204, 60, 0xFFEEF2FFu32)
    pixels = br_fill_rect(pixels, width, height, 30, 30, 120, 36, 0xFF2563EBu32)
    pixels

