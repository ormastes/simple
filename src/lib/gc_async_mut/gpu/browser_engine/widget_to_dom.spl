# Widget-to-DOM Conversion
#
# Converts UI widget trees (WidgetNode/UITree/UIState) into
# browser engine DOM nodes for rendering. Also provides a basic
# HTML string parser for simple markup.

use common.ui.widget.{WidgetNode, UITree, UIState}
use common.ui.glass_theme.{is_glass_theme}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BoxEdges,
    BorderProps, be_default_style}

# =========================================================================
# Widget -> DOM Conversion
# =========================================================================

pub fn widget_to_dom(node: WidgetNode, state: UIState) -> BeDomNode:
    """Convert a single WidgetNode to a BeDomNode.

    Maps widget kinds to appropriate HTML-like tags and transfers
    properties as style/attributes.
    """
    val kind = node.kind_name()
    val tag = widget_kind_to_tag(kind)

    var dom = BeDomNode.element(tag)
    dom.id = node.id

    # Transfer widget properties to DOM
    apply_widget_props(dom, node, kind)

    # Apply glass theme styles if applicable
    val theme = state.tree.theme_name()
    if is_glass_theme(theme):
        apply_glass_theme_styles(dom, kind, theme)

    # Apply focus styling
    val is_focused = node.id == state.focused_id
    if is_focused:
        dom.classes = dom.classes + ["focused"]
        var s = dom.style
        s.border = BorderProps.solid(2, 0x58A6FFFF)  # blue focus ring
        dom.style = s

    # Recursively convert children
    for child in node.children():
        val child_dom = widget_to_dom(child, state)
        dom.add_child(child_dom)

    return dom

pub fn ui_tree_to_dom(tree: UITree, state: UIState) -> BeDomNode:
    """Convert an entire UITree to a DOM tree.

    Creates a root 'div' container and converts the tree's root widget.
    """
    val root_widget = tree.root_node()
    var root_dom = BeDomNode.element("div")
    root_dom.id = "ui-root"
    root_dom.classes = ["ui-container"]

    # Set root styles
    var s = root_dom.style
    s.display = "flex"
    s.flex_direction = "column"
    s.width = CssValue.pct(100.0)
    s.height = CssValue.pct(100.0)
    root_dom.style = s

    val content = widget_to_dom(root_widget, state)
    root_dom.add_child(content)

    return root_dom

# =========================================================================
# HTML String -> DOM Parsing
# =========================================================================

pub fn html_string_to_dom(html: text) -> BeDomNode:
    """Parse a simple HTML string into a DOM tree.

    Supports basic tags: <div>, <span>, <p>, <h1>-<h6>, <button>,
    <input>, <ul>, <li>, <a>, <img>, <br>.
    Attributes are parsed for id, class, and style.

    This is a minimal parser for UI templates, not a full HTML5 parser.
    """
    var root = BeDomNode.element("div")
    root.id = "html-root"

    var stack: [BeDomNode] = [root]
    var pos = 0
    val len = html.len()

    while pos < len:
        val ch = html.slice(pos, pos + 1)

        if ch == "<":
            # Find the end of the tag
            val tag_end = find_char(html, ">", pos)
            if tag_end < 0:
                # Malformed, treat rest as text
                val remaining = html.slice(pos, len)
                val txt = BeDomNode.text(remaining)
                if stack.len() > 0:
                    var parent = stack[stack.len() - 1]
                    parent.add_child(txt)
                    stack[stack.len() - 1] = parent
                break

            val tag_content = html.slice(pos + 1, tag_end)

            if tag_content.starts_with("/"):
                # Closing tag: pop from stack
                if stack.len() > 1:
                    val completed = stack[stack.len() - 1]
                    var new_stack: [BeDomNode] = []
                    var si = 0
                    while si < stack.len() - 1:
                        new_stack = new_stack + [stack[si]]
                        si = si + 1
                    stack = new_stack
                    if stack.len() > 0:
                        var new_parent = stack[stack.len() - 1]
                        new_parent.add_child(completed)
                        stack[stack.len() - 1] = new_parent
            else:
                # Opening tag
                val is_self_closing = tag_content.ends_with("/")
                val clean_content = if is_self_closing:
                    tag_content.slice(0, tag_content.len() - 1).trim()
                else:
                    tag_content.trim()

                val parsed = parse_tag(clean_content)
                var new_node = parsed

                if is_self_closing or is_void_element(new_node.tag):
                    # Self-closing: add directly to parent
                    if stack.len() > 0:
                        var parent = stack[stack.len() - 1]
                        parent.add_child(new_node)
                        stack[stack.len() - 1] = parent
                else:
                    # Opening: push onto stack
                    stack = stack + [new_node]

            pos = tag_end + 1
        else:
            # Text content
            val text_end = find_char(html, "<", pos)
            val end_pos = if text_end < 0: len else: text_end
            val text_content = html.slice(pos, end_pos).trim()

            if text_content.len() > 0:
                val txt = BeDomNode.text(text_content)
                if stack.len() > 0:
                    var parent = stack[stack.len() - 1]
                    parent.add_child(txt)
                    stack[stack.len() - 1] = parent

            pos = end_pos

    # Unwind remaining stack
    while stack.len() > 1:
        val completed = stack[stack.len() - 1]
        var new_stack: [BeDomNode] = []
        var si = 0
        while si < stack.len() - 1:
            new_stack = new_stack + [stack[si]]
            si = si + 1
        stack = new_stack
        if stack.len() > 0:
            var parent = stack[stack.len() - 1]
            parent.add_child(completed)
            stack[stack.len() - 1] = parent

    if stack.len() > 0:
        return stack[0]
    return root

# =========================================================================
# Tag Parsing Helpers
# =========================================================================

fn parse_tag(content: text) -> BeDomNode:
    """Parse tag content like 'div id=\"main\" class=\"container\"' into a BeDomNode."""
    val parts = split_tag_parts(content)
    if parts.len() == 0:
        return BeDomNode.element("div")

    val tag_name = parts[0]
    var node = BeDomNode.element(tag_name)

    # Parse attributes
    var i = 1
    while i < parts.len():
        val part = parts[i]
        val eq_pos = find_char(part, "=", 0)
        if eq_pos > 0:
            val key = part.slice(0, eq_pos)
            var value = part.slice(eq_pos + 1, part.len())
            # Strip quotes
            if value.starts_with("\"") and value.ends_with("\""):
                value = value.slice(1, value.len() - 1)
            elif value.starts_with("'") and value.ends_with("'"):
                value = value.slice(1, value.len() - 1)

            if key == "id":
                node.id = value
            elif key == "class":
                node.classes = split_spaces(value)
            elif key == "style":
                apply_inline_style(node, value)
            else:
                node.set_attr(key, value)
        i = i + 1

    return node

fn split_tag_parts(s: text) -> [text]:
    """Split a tag string by spaces, respecting quoted values."""
    var parts: [text] = []
    var current = ""
    var in_quote = false
    var quote_char = ""

    for ch in s:
        if in_quote:
            current = "{current}{ch}"
            if ch == quote_char:
                in_quote = false
        elif ch == "\"" or ch == "'":
            in_quote = true
            quote_char = ch
            current = "{current}{ch}"
        elif ch == " ":
            if current.len() > 0:
                parts = parts + [current]
                current = ""
        else:
            current = "{current}{ch}"

    if current.len() > 0:
        parts = parts + [current]

    return parts

fn split_spaces(s: text) -> [text]:
    """Split a string by whitespace."""
    var parts: [text] = []
    var current = ""
    for ch in s:
        if ch == " " or ch == "\t":
            if current.len() > 0:
                parts = parts + [current]
                current = ""
        else:
            current = "{current}{ch}"
    if current.len() > 0:
        parts = parts + [current]
    return parts

fn apply_inline_style(node: BeDomNode, style_str: text):
    """Parse and apply inline CSS style string like 'color: red; font-size: 14px'."""
    var declarations = split_semicolons(style_str)
    for decl in declarations:
        val colon_pos = find_char(decl, ":", 0)
        if colon_pos > 0:
            val prop = decl.slice(0, colon_pos).trim()
            val value = decl.slice(colon_pos + 1, decl.len()).trim()
            node.set_style(prop, value)

fn split_semicolons(s: text) -> [text]:
    """Split a string by semicolons."""
    var parts: [text] = []
    var current = ""
    for ch in s:
        if ch == ";":
            if current.trim().len() > 0:
                parts = parts + [current.trim()]
            current = ""
        else:
            current = "{current}{ch}"
    if current.trim().len() > 0:
        parts = parts + [current.trim()]
    return parts

fn find_char(s: text, target: text, start: i32) -> i32:
    """Find the first occurrence of target character in s starting from start.
    Returns -1 if not found."""
    var i = start
    while i < s.len():
        if s.slice(i, i + 1) == target:
            return i
        i = i + 1
    return -1

fn is_void_element(tag: text) -> bool:
    """Check if a tag is a void (self-closing) HTML element."""
    match tag:
        "br" => true
        "hr" => true
        "img" => true
        "input" => true
        "meta" => true
        "link" => true
        _ => false

# =========================================================================
# Widget Kind -> Tag Mapping
# =========================================================================

fn widget_kind_to_tag(kind: text) -> text:
    """Map a UI widget kind to an appropriate HTML tag."""
    match kind:
        "panel" => "div"
        "text" => "span"
        "label" => "span"
        "heading" => "h2"
        "button" => "button"
        "input" => "input"
        "textfield" => "input"
        "textarea" => "textarea"
        "checkbox" => "input"
        "dropdown" => "select"
        "list" => "ul"
        "table" => "table"
        "tabs" => "nav"
        "menubar" => "nav"
        "statusbar" => "footer"
        "progress" => "div"
        "image" => "img"
        "divider" => "hr"
        "dialog" => "dialog"
        "tooltip" => "div"
        "tree" => "ul"
        "treenode" => "li"
        "scroll" => "div"
        "card" => "div"
        "switch" => "input"
        "navigation_bar" => "nav"
        "tab_bar" => "nav"
        _ => "div"

# =========================================================================
# Widget Property Transfer
# =========================================================================

fn apply_widget_props(dom: BeDomNode, node: WidgetNode, kind: text):
    """Transfer widget properties to DOM node attributes and styles."""
    # Add the widget kind as a CSS class
    dom.classes = dom.classes + [kind]

    # Transfer common properties
    val title = node.get_prop("title")
    if title.len() > 0:
        dom.set_attr("title", title)

    val text_content = node.get_prop("text")
    if text_content.len() > 0:
        val txt = BeDomNode.text(text_content)
        dom.add_child(txt)

    val value = node.get_prop("value")
    if value.len() > 0:
        dom.set_attr("value", value)

    val placeholder = node.get_prop("placeholder")
    if placeholder.len() > 0:
        dom.set_attr("placeholder", placeholder)

    # Apply layout
    val layout = node.layout_name()
    if layout == "hbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "row"
        dom.style = s
    elif layout == "vbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "column"
        dom.style = s
    elif layout == "grid":
        var s = dom.style
        s.display = "grid"
        dom.style = s

    # Transfer dimension / layout properties
    val width_val = node.get_prop("width")
    if width_val.len() > 0:
        dom.set_style("width", width_val)

    val height_val = node.get_prop("height")
    if height_val.len() > 0:
        dom.set_style("height", height_val)

    val flex_val = node.get_prop("flex")
    if flex_val.len() > 0:
        var s = dom.style
        s.display = "flex"
        s.flex_direction = flex_val
        dom.style = s

    val gap_val = node.get_prop("gap")
    if gap_val.len() > 0:
        dom.set_style("gap", gap_val)

    val bg_val = node.get_prop("background")
    if bg_val.len() > 0:
        dom.set_style("background-color", bg_val)
    else:
        val bg2_val = node.get_prop("bg")
        if bg2_val.len() > 0:
            dom.set_style("background-color", bg2_val)

    # Visibility
    if not node.is_visible():
        var s = dom.style
        s.display = "none"
        dom.style = s

# =========================================================================
# Glass Theme Style Application
# =========================================================================

fn apply_glass_theme_styles(dom: BeDomNode, kind: text, theme: text):
    """Apply glassmorphism-specific styles to a DOM node based on widget kind.

    Ports the key visual properties from the Electron/web CSS generator
    (src/app/ui.web/html.spl) into the browser engine DOM node, so the
    browser engine rendering matches the Electron output more closely.

    Values match those in generate_css() for glass_dark and glass_light themes.
    """
    val is_dark = theme == "glass_dark"

    # Theme-specific color values (matching html.spl lines 62-109)
    val bg = if is_dark: "#0A0A0F" else: "#F0F0F5"
    val fg = if is_dark: "#F5F5F7" else: "#1D1D1F"
    val border_color = if is_dark: "rgba(255,255,255,0.08)" else: "rgba(0,0,0,0.08)"
    val accent = if is_dark: "#0A84FF" else: "#007AFF"
    val panel_bg = if is_dark: "rgba(30,30,35,0.72)" else: "rgba(255,255,255,0.72)"
    val hover_bg = if is_dark: "rgba(255,255,255,0.06)" else: "rgba(0,0,0,0.04)"
    val dim_fg = if is_dark: "rgba(235,235,245,0.3)" else: "rgba(60,60,67,0.3)"
    val surface_bg = if is_dark: "rgba(40,40,48,0.52)" else: "rgba(255,255,255,0.52)"

    match kind:
        "panel" =>
            dom.set_style("background-color", panel_bg)
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "20px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-panel"]

        "card" =>
            dom.set_style("background-color", surface_bg)
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "16px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-card"]

        "button" =>
            dom.set_style("background-color", accent)
            dom.set_style("border-radius", "16px")
            dom.set_style("color", bg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-button"]

        "input" =>
            dom.set_style("background-color", "rgba(255,255,255,0.05)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "12px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-input"]

        "textfield" =>
            dom.set_style("background-color", "rgba(255,255,255,0.05)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "12px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-textfield"]

        "textarea" =>
            dom.set_style("background-color", "rgba(255,255,255,0.05)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "12px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-textarea"]

        "statusbar" =>
            dom.set_style("background-color", "rgba(255,255,255,0.06)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "16px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-statusbar"]

        "menubar" =>
            dom.set_style("background-color", "rgba(255,255,255,0.06)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "18px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.set_style("padding", "10px")
            dom.classes = dom.classes + ["widget-menubar"]

        "navigation_bar" =>
            dom.set_style("background-color", "rgba(255,255,255,0.06)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "18px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-navigation-bar"]

        "dialog" =>
            dom.set_style("background-color", panel_bg)
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "22px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-dialog"]

        "tabs" =>
            dom.set_style("background-color", "rgba(255,255,255,0.03)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "18px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-tabs"]

        "dropdown" =>
            dom.set_style("background-color", "rgba(255,255,255,0.06)")
            dom.set_style("border-color", border_color)
            dom.set_style("border-radius", "12px")
            dom.set_style("border-width", "1px")
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-dropdown"]

        "checkbox" =>
            dom.set_style("border-radius", "12px")
            dom.set_style("color", fg)
            dom.set_style("padding", "8px")
            dom.classes = dom.classes + ["widget-checkbox"]

        "list" =>
            dom.set_style("color", fg)
            dom.set_style("padding", "4px")
            dom.classes = dom.classes + ["widget-list"]

        "text" =>
            dom.set_style("color", fg)
            dom.set_style("padding", "4px")
            dom.classes = dom.classes + ["widget-text"]

        "label" =>
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-text"]

        "heading" =>
            dom.set_style("color", fg)
            dom.set_style("padding", "8px")
            dom.set_style("border-color", border_color)
            dom.classes = dom.classes + ["widget-heading"]

        "progress" =>
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-progress"]

        "divider" =>
            dom.set_style("border-color", border_color)
            dom.classes = dom.classes + ["widget-divider"]

        "table" =>
            dom.set_style("color", fg)
            dom.set_style("border-color", border_color)
            dom.classes = dom.classes + ["widget-table"]

        "tree" =>
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-tree"]

        "tooltip" =>
            dom.set_style("color", fg)
            dom.classes = dom.classes + ["widget-tooltip"]

        "scroll" =>
            dom.classes = dom.classes + ["widget-scroll"]

        "image" =>
            dom.classes = dom.classes + ["widget-image"]

        _ =>
            # Default: just set text color
            dom.set_style("color", fg)

class WidgetToDomApi:
    static fn widget_to_dom(node: WidgetNode, state: UIState) -> BeDomNode:
        widget_to_dom(node, state)

    static fn ui_tree_to_dom(tree: UITree, state: UIState) -> BeDomNode:
        ui_tree_to_dom(tree, state)

    static fn html_string_to_dom(html: text) -> BeDomNode:
        html_string_to_dom(html)

# =========================================================================
# Exports
export widget_to_dom, ui_tree_to_dom, html_string_to_dom
