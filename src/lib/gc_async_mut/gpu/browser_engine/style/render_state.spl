#![allow(REQC001)]
#![allow(REQC004)]

class RenderState:
    current_time: f64
    delta_time: f64
    viewport_width: f64
    viewport_height: f64
    scroll_x: f64
    scroll_y: f64
    frame_count: i64

    static fn new() -> RenderState:
        return RenderState(
            current_time: 0.0,
            delta_time: 0.0,
            viewport_width: 0.0,
            viewport_height: 0.0,
            scroll_x: 0.0,
            scroll_y: 0.0,
            frame_count: 0
        )

    static fn create(current_time: f64, viewport_width: f64, viewport_height: f64) -> RenderState:
        return RenderState(
            current_time: current_time,
            delta_time: 0.0,
            viewport_width: viewport_width,
            viewport_height: viewport_height,
            scroll_x: 0.0,
            scroll_y: 0.0,
            frame_count: 0
        )

    me advance(new_time: f64):
        self.delta_time = new_time - self.current_time
        self.current_time = new_time
        self.frame_count = self.frame_count + 1

    me set_scroll(x: f64, y: f64):
        self.scroll_x = x
        self.scroll_y = y

    me set_viewport(width: f64, height: f64):
        self.viewport_width = width
        self.viewport_height = height
