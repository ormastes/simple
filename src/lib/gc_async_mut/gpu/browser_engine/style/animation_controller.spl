use std.gc_async_mut.gpu.browser_engine.style.animation.{CSSValue, AnimationEngine, StyleUpdate, AnimationState, interpolate}
use std.common.animation.timing.{TimingFunction, evaluate_timing, parse_timing_function}
use examples.browser.feature.style.computed.{ComputedStyle, extract_px, get_property_from_style}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}

class ActiveTransition:
    node_id: i64
    property: text
    from_value: CSSValue
    to_value: CSSValue
    duration_ms: f64
    elapsed_ms: f64
    timing: text

    static fn create(node_id: i64, property: text, from_value: CSSValue, to_value: CSSValue, duration_ms: f64, timing: text) -> ActiveTransition:
        ActiveTransition(
            node_id: node_id,
            property: property,
            from_value: from_value,
            to_value: to_value,
            duration_ms: duration_ms,
            elapsed_ms: 0.0,
            timing: timing
        )

class AnimationController:
    engine: AnimationEngine
    logger: Logger
    active_transitions: [ActiveTransition]

    static fn new(engine: AnimationEngine, logger: Logger) -> AnimationController:
        AnimationController(
            engine: engine,
            logger: logger,
            active_transitions: [ActiveTransition]()
        )

    me detect_transitions(node_id: i64, old_style: ComputedStyle, new_style: ComputedStyle, transition_props: [text], duration_ms: f64, timing: text):
        for prop in transition_props:
            if not is_transitionable(prop):
                continue

            val old_val = get_property_from_style(old_style, prop)
            val new_val = get_property_from_style(new_style, prop)

            if not css_values_equal(old_val, new_val):
                self.remove_transition(node_id, prop)

                val trans = ActiveTransition.create(
                    node_id, prop, old_val, new_val, duration_ms, timing
                )
                self.active_transitions.push(trans)
                self.logger.debug("transition detected: node={node_id} property='{prop}' duration={duration_ms}ms timing={timing}")

    me tick(delta_ms: f64) -> [StyleUpdate]:
        var updates = [StyleUpdate]()
        var finished_indices = [i64]()

        var idx = 0
        while idx < self.active_transitions.len():
            var trans = self.active_transitions.get(idx)
            trans.elapsed_ms = trans.elapsed_ms + delta_ms

            if trans.elapsed_ms >= trans.duration_ms:
                updates.push(StyleUpdate.create(trans.node_id, trans.property, trans.to_value))
                finished_indices.push(idx)
            else:
                val raw_progress = trans.elapsed_ms / trans.duration_ms
                val eased = apply_timing(raw_progress, trans.timing)
                val interp_value = interpolate(trans.from_value, trans.to_value, eased)
                updates.push(StyleUpdate.create(trans.node_id, trans.property, interp_value))

            self.active_transitions.set(idx, trans)
            idx = idx + 1

        var remove_idx = finished_indices.len() - 1
        while remove_idx >= 0:
            val fi = finished_indices.get(remove_idx)
            self.active_transitions.remove(fi)
            remove_idx = remove_idx - 1

        if updates.len() > 0:
            self.logger.trace("tick delta={delta_ms}ms produced {updates.len()} updates, {self.active_transitions.len()} active transitions remaining")

        updates

    fn has_active_transitions() -> bool:
        self.active_transitions.len() > 0

    me cancel_transitions(node_id: i64):
        var idx = self.active_transitions.len() - 1
        while idx >= 0:
            val trans = self.active_transitions.get(idx)
            if trans.node_id == node_id:
                self.active_transitions.remove(idx)
            idx = idx - 1
        self.logger.debug("cancelled all transitions for node {node_id}")

    me remove_transition(node_id: i64, property: text):
        var idx = self.active_transitions.len() - 1
        while idx >= 0:
            val trans = self.active_transitions.get(idx)
            if trans.node_id == node_id and trans.property == property:
                self.active_transitions.remove(idx)
            idx = idx - 1

fn is_transitionable(property: text) -> bool:
    val transitionable = [
        "width", "height", "min-width", "max-width", "min-height", "max-height",
        "top", "right", "bottom", "left",
        "margin-top", "margin-right", "margin-bottom", "margin-left",
        "padding-top", "padding-right", "padding-bottom", "padding-left",
        "border-top-width", "border-right-width", "border-bottom-width", "border-left-width",
        "border-top-left-radius", "border-top-right-radius",
        "border-bottom-right-radius", "border-bottom-left-radius",
        "color", "background-color",
        "border-top-color", "border-right-color", "border-bottom-color", "border-left-color",
        "font-size", "font-weight", "line-height",
        "letter-spacing", "word-spacing", "text-indent",
        "opacity",
        "flex-grow", "flex-shrink", "flex-basis",
        "row-gap", "column-gap",
        "z-index"
    ]
    for p in transitionable:
        if p == property:
            return true
    false

fn apply_timing(progress: f64, timing: text) -> f64:
    evaluate_timing(parse_timing_function(timing), progress)

fn css_values_equal(a: CSSValue, b: CSSValue) -> bool:
    match a:
        CSSValue.Keyword(av):
            match b:
                CSSValue.Keyword(bv): av == bv
                _: false
        CSSValue.Length(av, au):
            match b:
                CSSValue.Length(bv, bu):
                    au == bu and float_eq(av, bv)
                _: false
        CSSValue.Percentage(av):
            match b:
                CSSValue.Percentage(bv): float_eq(av, bv)
                _: false
        CSSValue.Number(av):
            match b:
                CSSValue.Number(bv): float_eq(av, bv)
                _: false
        CSSValue.Color(ac):
            match b:
                CSSValue.Color(bc):
                    ac.r == bc.r and ac.g == bc.g and ac.b == bc.b and ac.a == bc.a
                _: false
        CSSValue.Url(av):
            match b:
                CSSValue.Url(bv): av == bv
                _: false
        CSSValue.Inherit:
            match b:
                CSSValue.Inherit: true
                _: false
        CSSValue.Initial:
            match b:
                CSSValue.Initial: true
                _: false
        CSSValue.Unset:
            match b:
                CSSValue.Unset: true
                _: false
        _: false

fn float_eq(a: f64, b: f64) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0.0: 0.0 - diff else: diff
    abs_diff < 0.0001
