#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

pub fn known_properties() -> [text]:
    val props: [text] = [
        "display",
        "color",
        "background-color",
        "background",
        "opacity",
        "position",
        "top",
        "left",
        "right",
        "bottom",
        "width",
        "height",
        "min-width",
        "min-height",
        "max-width",
        "max-height",
        "margin",
        "margin-top",
        "margin-left",
        "margin-right",
        "margin-bottom",
        "padding",
        "padding-top",
        "padding-left",
        "padding-right",
        "padding-bottom",
        "border",
        "border-width",
        "border-color",
        "border-style",
        "border-radius",
        "font-size",
        "font-family",
        "font-weight",
        "font-style",
        "line-height",
        "text-align",
        "text-decoration",
        "text-indent",
        "text-overflow",
        "text-transform",
        "overflow",
        "overflow-x",
        "overflow-y",
        "transform",
        "transition",
        "animation",
        "object-fit",
        "object-position",
        "visibility",
        "z-index",
        "cursor",
        "pointer-events",
        "box-sizing",
        "flex",
        "flex-direction",
        "flex-wrap",
        "flex-grow",
        "flex-shrink",
        "flex-basis",
        "align-items",
        "align-self",
        "justify-content",
        "gap",
        "outline",
        "box-shadow",
        "text-shadow",
        "white-space",
        "word-break",
        "word-spacing",
        "overflow-wrap",
        "letter-spacing",
        "vertical-align",
        "float",
        "clear",
        "content",
        "list-style",
        "list-style-type",
        "counter-reset",
        "counter-increment"
    ]
    props

pub fn eval_supports_query(query: text) -> bool:
    val trimmed = query.trim()
    if trimmed.len() == 0:
        return false
    if trimmed.starts_with("not "):
        val rest = trimmed.slice(4, trimmed.len()).trim()
        return not eval_supports_query(rest)

    val and_pos = _find_combinator(trimmed, " and ")
    if and_pos >= 0:
        val left = trimmed.slice(0, and_pos).trim()
        val right = trimmed.slice(and_pos + 5, trimmed.len()).trim()
        return eval_supports_query(left) and eval_supports_query(right)

    val or_pos = _find_combinator(trimmed, " or ")
    if or_pos >= 0:
        val left = trimmed.slice(0, or_pos).trim()
        val right = trimmed.slice(or_pos + 4, trimmed.len()).trim()
        return eval_supports_query(left) or eval_supports_query(right)

    if trimmed.starts_with("selector(") and trimmed.ends_with(")"):
        return _eval_selector_support(trimmed)

    if trimmed.starts_with("(") and trimmed.ends_with(")"):
        val inner = trimmed.slice(1, trimmed.len() - 1).trim()
        return _eval_single(inner)

    false

fn _eval_single(condition: text) -> bool:
    if condition.starts_with("selector(") and condition.ends_with(")"):
        return _eval_selector_support(condition)

    if condition.starts_with("--"):
        return true

    val colon_pos = condition.index_of(":")
    if colon_pos < 0:
        return false

    val prop = condition.slice(0, colon_pos).trim()
    val value = condition.slice(colon_pos + 1, condition.len()).trim()
    if value.len() == 0:
        return false
    val props = known_properties()
    for p in props:
        if p == prop:
            return _property_value_supported(prop, value)
    false

fn _property_value_supported(prop: text, value: text) -> bool:
    val v = value.lower().trim()
    if _css_wide_keyword(v):
        return true
    if prop == "display":
        return _text_in(v, [
            "block", "inline", "inline-block", "flex", "inline-flex", "grid",
            "inline-grid", "flow-root", "none", "contents", "list-item",
            "table", "inline-table", "table-row", "table-cell"
        ])
    if prop == "position":
        return _text_in(v, ["static", "relative", "absolute", "fixed", "sticky"])
    if prop == "overflow" or prop == "overflow-x" or prop == "overflow-y":
        return _text_in(v, ["visible", "hidden", "clip", "scroll", "auto"])
    if prop == "text-overflow":
        return _text_in(v, ["clip", "ellipsis"]) or _is_quoted_text(v)
    if prop == "text-transform":
        return _text_in(v, ["none", "capitalize", "uppercase", "lowercase", "full-width", "full-size-kana"])
    if prop == "object-fit":
        return _text_in(v, ["fill", "contain", "cover", "none", "scale-down"])
    if prop == "visibility":
        return _text_in(v, ["visible", "hidden", "collapse"])
    if prop == "box-sizing":
        return _text_in(v, ["content-box", "border-box"])
    if prop == "pointer-events":
        return _text_in(v, ["auto", "none"])
    if prop == "float":
        return _text_in(v, ["left", "right", "none", "inline-start", "inline-end"])
    if prop == "clear":
        return _text_in(v, ["none", "left", "right", "both", "inline-start", "inline-end"])
    if prop == "white-space":
        return _text_in(v, ["normal", "nowrap", "pre", "pre-wrap", "pre-line", "break-spaces"])
    if prop == "word-break":
        return _text_in(v, ["normal", "break-all", "keep-all", "break-word"])
    if prop == "overflow-wrap":
        return _text_in(v, ["normal", "break-word", "anywhere"])
    if prop == "font-style":
        return _text_in(v, ["normal", "italic", "oblique"]) or v.starts_with("oblique ")
    if prop == "font-weight":
        return _text_in(v, ["normal", "bold", "bolder", "lighter", "100", "200", "300", "400", "500", "600", "700", "800", "900"])
    true

fn _css_wide_keyword(value: text) -> bool:
    _text_in(value, ["inherit", "initial", "unset", "revert", "revert-layer"])

fn _is_quoted_text(value: text) -> bool:
    if value.len() < 2:
        return false
    val first = value.slice(0, 1)
    val last = value.slice(value.len() - 1, value.len())
    (first == "\"" and last == "\"") or (first == "'" and last == "'")

fn _text_in(value: text, values: [text]) -> bool:
    for candidate in values:
        if value == candidate:
            return true
    false

fn _eval_selector_support(condition: text) -> bool:
    val selector = condition.slice(9, condition.len() - 1).trim()
    if selector.len() == 0:
        return false
    _selector_pseudos_supported(selector)

fn _selector_pseudos_supported(selector: text) -> bool:
    var i = 0
    while i < selector.len():
        val ch = selector.slice(i, i + 1)
        if ch == ":":
            if i + 1 < selector.len() and selector.slice(i + 1, i + 2) == ":":
                return false
            val rest = selector.slice(i, selector.len())
            if rest.starts_with(":is(") or rest.starts_with(":where(") or rest.starts_with(":not(") or rest.starts_with(":has("):
                var open = i + 3
                if rest.starts_with(":where("):
                    open = i + 6
                else if rest.starts_with(":not(") or rest.starts_with(":has("):
                    open = i + 4
                val close = _find_matching_paren(selector, open)
                if close < 0:
                    return false
                val inner = selector.slice(open + 1, close).trim()
                if inner.len() == 0:
                    return false
                if not _selector_pseudos_supported(inner):
                    return false
                i = close + 1
            else if rest.starts_with(":nth-child("):
                val open = i + 10
                val close = _find_matching_paren(selector, open)
                if close < 0:
                    return false
                i = close + 1
            else if rest.starts_with(":empty"):
                i = i + 6
            else if rest.starts_with(":first-child"):
                i = i + 12
            else if rest.starts_with(":last-child"):
                i = i + 11
            else if rest.starts_with(":only-child"):
                i = i + 11
            else:
                return false
        else:
            i = i + 1
    true

fn _find_matching_paren(s: text, open_pos: i64) -> i64:
    var depth = 0
    var i = open_pos
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if ch == "(":
            depth = depth + 1
        else if ch == ")":
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    -1

fn _find_combinator(s: text, combinator: text) -> i64:
    var depth = 0
    var i = 0
    val slen = s.len()
    val clen = combinator.len()
    while i < slen:
        val ch = s.slice(i, i + 1)
        if ch == "(":
            depth = depth + 1
        else if ch == ")":
            depth = depth - 1
        else if depth == 0:
            if i + clen <= slen:
                val candidate = s.slice(i, i + clen)
                if candidate == combinator:
                    return i
        i = i + 1
    -1
