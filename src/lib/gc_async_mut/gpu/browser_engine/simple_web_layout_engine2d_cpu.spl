# CPU-only web Draw IR execution for native benchmark and bootstrap paths.

use common.ui.draw_ir.{DRAW_IR_COMMAND_RECT, DRAW_IR_COMMAND_TEXT, DrawIrCommand, DrawIrComposition, DrawIrStyleProp}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_draw_ir_cpu_bitmap}
use std.gc_async_mut.gpu.engine2d.backend_cpu.{CpuBackend}

fn _cpu_draw_ir_style_value(style: [DrawIrStyleProp], key: text) -> text:
    for prop in style:
        if prop.key == key:
            return prop.value
    ""

fn _cpu_draw_ir_nth_int(value: text, n: i32, fallback: i64) -> i64:
    var count = 0
    var idx: i64 = 0
    while idx < value.len():
        val first = value.char_code_at(idx).to_i32()
        val digit = first >= 48 and first <= 57
        var signed = false
        if (first == 45 or first == 43) and idx + 1 < value.len():
            val next = value.char_code_at(idx + 1).to_i32()
            signed = next >= 48 and next <= 57
        if digit or signed:
            val negative = first == 45
            if first == 45 or first == 43:
                idx = idx + 1
            var parsed: i64 = 0
            while idx < value.len():
                val ch = value.char_code_at(idx).to_i32()
                if ch < 48 or ch > 57:
                    break
                parsed = parsed * 10 + ((ch - 48) as i64)
                idx = idx + 1
            if negative:
                parsed = 0 - parsed
            if count == n:
                return parsed
            count = count + 1
        else:
            idx = idx + 1
    fallback

fn _cpu_draw_ir_visible(color: u32) -> bool:
    ((color >> 24) & 0xFFu32) != 0u32

fn _cpu_draw_ir_font_size(style: [DrawIrStyleProp]) -> i32:
    val size = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "font-size"), 0, 12)
    if size > 0 and size <= 2147483647:
        return size as i32
    12

fn _cpu_draw_ir_borders(backend: CpuBackend, command: DrawIrCommand, x: i32, y: i32) -> CpuBackend:
    var out = backend
    val style = command.computed_style
    val top_w = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-top-width"), 0, 0) as i32
    val right_w = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-right-width"), 0, 0) as i32
    val bottom_w = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-bottom-width"), 0, 0) as i32
    val left_w = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-left-width"), 0, 0) as i32
    val top_c = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-top-color"), 0, 0) as u32
    val right_c = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-right-color"), 0, 0) as u32
    val bottom_c = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-bottom-color"), 0, 0) as u32
    val left_c = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-left-color"), 0, 0) as u32
    val radius = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-radius"), 0, 0) as i32
    val uniform = top_w == right_w and right_w == bottom_w and bottom_w == left_w and top_w > 0 and top_c == right_c and right_c == bottom_c and bottom_c == left_c
    if radius > 0 and uniform and _cpu_draw_ir_visible(top_c):
        out.draw_rounded_rect_outline(x, y, command.width, command.height, radius, top_c, top_w)
        return out
    if top_w > 0 and _cpu_draw_ir_visible(top_c):
        out.draw_rect_filled(x, y, command.width, top_w, top_c)
    if bottom_w > 0 and _cpu_draw_ir_visible(bottom_c):
        out.draw_rect_filled(x, y + command.height - bottom_w, command.width, bottom_w, bottom_c)
    if left_w > 0 and _cpu_draw_ir_visible(left_c):
        out.draw_rect_filled(x, y, left_w, command.height, left_c)
    if right_w > 0 and _cpu_draw_ir_visible(right_c):
        out.draw_rect_filled(x + command.width - right_w, y, right_w, command.height, right_c)
    out

fn _cpu_draw_ir_rect(backend: CpuBackend, command: DrawIrCommand, x: i32, y: i32) -> CpuBackend:
    var out = backend
    val style = command.computed_style
    val shadow = _cpu_draw_ir_style_value(style, "box-shadow")
    if shadow != "" and shadow != "none":
        val shadow_color = _cpu_draw_ir_nth_int(shadow, 2, 0) as u32
        if _cpu_draw_ir_visible(shadow_color):
            out.draw_shadow_rect(x, y, command.width, command.height,
                _cpu_draw_ir_nth_int(shadow, 0, 0) as i32,
                _cpu_draw_ir_nth_int(shadow, 1, 0) as i32, 0, shadow_color)
    val radius = _cpu_draw_ir_nth_int(_cpu_draw_ir_style_value(style, "border-radius"), 0, 0) as i32
    val background = _cpu_draw_ir_style_value(style, "background-image")
    if background.starts_with("linear-gradient("):
        out.draw_gradient_rect(x, y, command.width, command.height,
            _cpu_draw_ir_nth_int(background, 0, 0) as u32,
            _cpu_draw_ir_nth_int(background, 1, 0) as u32)
    elif _cpu_draw_ir_visible(command.color):
        if radius > 0:
            out.draw_rounded_rect(x, y, command.width, command.height, radius, command.color)
        else:
            out.draw_rect_filled(x, y, command.width, command.height, command.color)
    _cpu_draw_ir_borders(out, command, x, y)

fn _cpu_draw_ir_execute(backend: CpuBackend, composition: DrawIrComposition) -> CpuBackend:
    var out = backend
    for batch in composition.batches:
        for command in batch.commands:
            val x = batch.embedding.x + command.x
            val y = batch.embedding.y + command.y
            if command.kind == DRAW_IR_COMMAND_RECT:
                out = _cpu_draw_ir_rect(out, command, x, y)
            elif command.kind == DRAW_IR_COMMAND_TEXT:
                out.draw_text(x, y, command.text_value, command.color, _cpu_draw_ir_font_size(command.computed_style))
    out

pub fn simple_web_render_html_to_pixels_with_cpu_draw_ir_backend(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val composition = simple_web_layout_render_html_draw_ir_cpu_bitmap(html, width, height)
    var backend = if backend_name == "cpu_simd": CpuBackend.create_simd() else: CpuBackend.create()
    if not backend.init(width, height):
        return []
    backend.clear(0u32)
    backend = _cpu_draw_ir_execute(backend, composition)
    val pixels = backend.read_pixels()
    backend.shutdown()
    pixels
