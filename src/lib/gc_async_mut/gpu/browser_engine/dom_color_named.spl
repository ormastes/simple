# DOM Gradient and Background Shorthand Parsing
#
# Linear-gradient parsing, background shorthand color extraction,
# and top-level comma/character utilities.
# Named color table lives in dom_color.spl (leaf, no deps).

use std.gc_async_mut.gpu.browser_engine.dom_color.{parse_color_value, dom_find_str, dom_split_ws, split_comma, strip_css_comments, named_color_to_u32}
use common.string_builder.{StringBuilder}

pub fn sb_dom_split_ws(s: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx_5 = 0
    while idx_5 < s.len():
        val ch = s.char_at(idx_5)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if not sb.is_empty():
                parts.push(sb.to_text())
                sb.clear()
        else:
            sb.push(ch)
        idx_5 = idx_5 + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

# =========================================================================
# Linear Gradient Parser
# =========================================================================

pub struct GradientParseResult:
    gradient_set: bool
    gradient_color1: u32
    gradient_color2: u32
    gradient_angle: i32

pub fn parse_linear_gradient(value: text) -> GradientParseResult:
    """Parse linear-gradient(angle, color1, color2).

    Handles common patterns from glass CSS:
      linear-gradient(180deg, rgba(255,255,255,0.09), rgba(255,255,255,0.02))
      linear-gradient(90deg, #007AFF, #30D158)

    Multi-layer gradients (with commas separating gradient() calls) use
    only the first gradient.
    """
    val empty = GradientParseResult(gradient_set: false, gradient_color1: 0, gradient_color2: 0, gradient_angle: 180)

    # Find opening paren
    val open = find_char_in(value, "(", 0)
    if open >= 999999999:
        return empty

    # Find matching closing paren (handle nested parens for rgba)
    var depth: i32 = 0
    var close: i32 = 999999999
    var i: i32 = open
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                close = i
                break
        i = i + 1

    if close >= 999999999:
        return empty

    val inner_raw_grad = value.slice(open + 1, close)
    val inner = inner_raw_grad.trim()

    # Split by top-level commas (not inside parens)
    val parts = split_top_level_commas(inner)
    if parts.len() < 2:
        return empty

    # First part: angle or color
    var angle: i32 = 180
    var color_start_idx: i32 = 0

    val first = parts[0].trim()
    if first.ends_with("deg"):
        val deg_str_raw = first.slice(0, first.len() - 3)
        val deg_str = deg_str_raw.trim()
        val parsed = deg_str.parse_f64()
        if parsed != nil:
            val pval = parsed ?? 0.0
            angle = pval.to_i32()
        color_start_idx = 1
    elif first == "to bottom":
        angle = 180
        color_start_idx = 1
    elif first == "to top":
        angle = 0
        color_start_idx = 1
    elif first == "to right":
        angle = 90
        color_start_idx = 1
    elif first == "to left":
        angle = 270
        color_start_idx = 1

    if color_start_idx + 1 >= parts.len():
        return empty

    val c1_str = parts[color_start_idx].trim()
    val c2_str = parts[color_start_idx + 1].trim()

    # Strip optional stop positions (e.g., "rgba(0,0,0,0.2) 50%")
    val c1 = parse_color_value(strip_stop_position(c1_str))
    val c2 = parse_color_value(strip_stop_position(c2_str))

    GradientParseResult(gradient_set: true, gradient_color1: c1, gradient_color2: c2, gradient_angle: angle)

pub fn strip_stop_position(s: text) -> text:
    """Strip trailing percentage or length from a gradient color stop."""
    val trimmed = s.trim()
    # If it ends with % or px after a space, strip the position
    val last_space = find_last_space(trimmed)
    if last_space > 0 and last_space < 999999999:
        val after_raw = trimmed.slice(last_space + 1, trimmed.len())
        val after = after_raw.trim()
        if after.ends_with("%") or after.ends_with("px"):
            val before_stop = trimmed.slice(0, last_space)
            return before_stop.trim()
    trimmed

pub fn find_last_space(s: text) -> i32:
    var last: i32 = 999999999
    var depth: i32 = 0
    var i: i32 = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "(": depth = depth + 1
        elif ch == ")": depth = depth - 1
        elif ch == " " and depth == 0: last = i
        i = i + 1
    last

pub fn split_top_level_commas(s: text) -> [text]:
    """Split a string by commas, but not inside parentheses."""
    var parts: [text] = []
    val sb = StringBuilder.new()
    var depth: i32 = 0

    var idx_6 = 0
    while idx_6 < s.len():
        val ch = s.char_at(idx_6)
        if ch == "(":
            depth = depth + 1
            sb.push(ch)
        elif ch == ")":
            depth = depth - 1
            sb.push(ch)
        elif ch == "," and depth == 0:
            parts.push(sb.to_text().trim())
            sb.clear()
        else:
            sb.push(ch)
        idx_6 = idx_6 + 1

    val tail = sb.to_text().trim()
    if tail.len() > 0:
        parts.push(tail)

    parts

pub fn find_char_in(s: text, target: text, start: i64) -> i64:
    """Find the first occurrence of target character in s starting at position start."""
    var i = start
    val slen = s.len()
    while i < slen:
        if s.char_at(i) == target:
            return i
        i = i + 1
    return 999999999

pub fn dom_background_shorthand_color_value(value: text) -> text:
    """Extract the color token from a background shorthand value."""
    val trimmed = value.trim()
    if trimmed.len() == 0:
        return ""
    val lower = trimmed.lower()
    if lower.starts_with("linear-gradient") or lower.starts_with("radial-gradient"):
        return ""
    var pos: i64 = 0
    while pos < trimmed.len():
        while pos < trimmed.len() and trimmed.char_at(pos) == " ":
            pos = pos + 1
        if pos >= trimmed.len():
            break
        val token = dom_background_token_from(trimmed, pos)
        if token.len() == 0:
            break
        val token_lower = token.lower()
        if token_lower.starts_with("url(") or token_lower.starts_with("linear-gradient") or token_lower.starts_with("radial-gradient"):
            pos = pos + token.len()
            continue
        if token.starts_with("#") or token_lower.starts_with("rgb(") or token_lower.starts_with("rgba(") or token_lower.starts_with("hsl(") or token_lower.starts_with("hsla(") or token_lower == "transparent" or token_lower == "currentcolor":
            return token
        val parsed = parse_color_value(token)
        if parsed != 0x000000FF or token_lower == "black":
            return token
        pos = pos + token.len()
    ""

pub fn dom_background_token_from(value: text, start: i64) -> text:
    var end = start
    var depth: i32 = 0
    while end < value.len():
        val ch = value.char_at(end)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == " " and depth == 0:
            break
        end = end + 1
    val raw = value.slice(start, end)
    raw.trim()
