use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels,
    simple_web_layout_render_html_software_pixels_at_scroll,
    simple_web_layout_uses_legacy_widget_chrome,
    simple_web_layout_render_html_gpu_frame,
    WebGpuPaintFrame
}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback, engine2d_readback}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.io.mod_stub.{env_get}

# ---------------------------------------------------------------------------
# GPU paint flag
# ---------------------------------------------------------------------------
# SIMPLE_WEB_GPU_PAINT=1 forces per-primitive GPU paint. The default path stays
# upload-bound; callers can use the economics API below before opting into GPU
# paint so command/readback overhead does not silently make small pages slower.
pub fn web_gpu_paint_enabled() -> bool:
    val v = env_get("SIMPLE_WEB_GPU_PAINT")
    v == "1" or v == "true" or v == "on"

fn _backend_is_cpu(normalized_backend: text) -> bool:
    (normalized_backend == "software" or normalized_backend == "cpu"
        or normalized_backend == "cpu_simd" or normalized_backend == "simd_cpu"
        or normalized_backend == "cpu-simd")

fn _backend_is_gpu_paint_candidate(normalized_backend: text) -> bool:
    normalized_backend == "metal" or normalized_backend == "cuda" or normalized_backend == "rocm" or
        normalized_backend == "hip" or normalized_backend == "amd-hip" or normalized_backend == "amd_hip" or
        normalized_backend == "vulkan" or normalized_backend == "opencl" or normalized_backend == "webgpu" or
        normalized_backend == "qualcomm" or normalized_backend == "directx" or normalized_backend == "opengl" or
        normalized_backend == "intel"

pub fn web_gpu_paint_backend_verdict(backend_name: text) -> text:
    val normalized_backend = backend_name.trim().lower()
    if _backend_is_cpu(normalized_backend):
        return "cpu-backend-not-gpu-offload"
    if _backend_is_gpu_paint_candidate(normalized_backend):
        return "gpu-paint-candidate"
    "unknown-backend-not-gpu-offload"

# ---------------------------------------------------------------------------
# Residual (dirty) region between the CPU ground truth and the GPU fill result
# ---------------------------------------------------------------------------
class _DirtyRect:
    valid: bool
    x: i32
    y: i32
    w: i32
    h: i32

pub class WebGpuPaintEconomics:
    frame_pixels: i32
    cpu_paint_pixels: i32
    fill_op_count: i32
    fill_pixels: i32
    residual_pixels: i32
    upload_bound_transfer_pixels: i32
    gpu_paint_transfer_pixels: i32
    upload_bound_total_pixels: i32
    gpu_paint_total_pixels: i32
    should_offload: bool
    reason: text
    cpu_job_verdict: text
    speed_verdict: text

# Bounding box of every pixel where the GPU-composited fills differ from the CPU
# ground-truth framebuffer. If the GPU readback length is wrong (backend cannot
# read back), the whole frame is treated as dirty so the residual blit still
# yields a bit-exact frame.
fn _dirty_bounds(truth: [u32], gpu: [u32], width: i32, height: i32) -> _DirtyRect:
    if gpu.len() != width * height or truth.len() != width * height:
        return _DirtyRect(valid: true, x: 0, y: 0, w: width, h: height)
    var min_x: i32 = width
    var min_y: i32 = height
    var max_x: i32 = -1
    var max_y: i32 = -1
    var y: i32 = 0
    while y < height:
        val row = y * width
        var x: i32 = 0
        while x < width:
            val k = row + x
            if truth[k] != gpu[k]:
                if x < min_x:
                    min_x = x
                if x > max_x:
                    max_x = x
                if y < min_y:
                    min_y = y
                if y > max_y:
                    max_y = y
            x = x + 1
        y = y + 1
    if max_x < 0:
        return _DirtyRect(valid: false, x: 0, y: 0, w: 0, h: 0)
    _DirtyRect(valid: true, x: min_x, y: min_y, w: max_x - min_x + 1, h: max_y - min_y + 1)

fn _extract_subimage(src: [u32], src_width: i32, rect: _DirtyRect) -> [u32]:
    val zero = 0 as u32
    var out: [u32] = [zero; rect.w * rect.h]
    var ry: i32 = 0
    while ry < rect.h:
        val src_row = (rect.y + ry) * src_width + rect.x
        val dst_row = ry * rect.w
        var rx: i32 = 0
        while rx < rect.w:
            out[dst_row + rx] = src[src_row + rx]
            rx = rx + 1
        ry = ry + 1
    out

fn _clip_start(v: i32) -> i32:
    if v < 0: 0 else: v

fn _clip_end(v: i32, max_value: i32) -> i32:
    if v > max_value: max_value else: v

fn _fill_op_clipped_pixels(op_x: i32, op_y: i32, op_w: i32, op_h: i32, width: i32, height: i32) -> i32:
    val x0 = _clip_start(op_x)
    val y0 = _clip_start(op_y)
    val x1 = _clip_end(op_x + op_w, width)
    val y1 = _clip_end(op_y + op_h, height)
    if x1 <= x0 or y1 <= y0:
        return 0
    (x1 - x0) * (y1 - y0)

fn _fill_op_pixels(frame: WebGpuPaintFrame) -> i32:
    var total: i32 = 0
    var i: i32 = 0
    val op_count = frame.fill_ops.len()
    while i < op_count:
        val op = frame.fill_ops[i]
        total = total + _fill_op_clipped_pixels(op.x, op.y, op.width, op.height, frame.width, frame.height)
        i = i + 1
    total

fn _simulate_fill_ops(frame: WebGpuPaintFrame, base: u32) -> [u32]:
    val width = frame.width
    val height = frame.height
    var out: [u32] = [base; width * height]
    var oi: i32 = 0
    val op_count = frame.fill_ops.len()
    while oi < op_count:
        val op = frame.fill_ops[oi]
        val x0 = _clip_start(op.x)
        val y0 = _clip_start(op.y)
        val x1 = _clip_end(op.x + op.width, width)
        val y1 = _clip_end(op.y + op.height, height)
        var y = y0
        while y < y1:
            val row = y * width
            var x = x0
            while x < x1:
                out[row + x] = op.color as u32
                x = x + 1
            y = y + 1
        oi = oi + 1
    out

pub fn web_gpu_paint_economics(frame: WebGpuPaintFrame, base: u32) -> WebGpuPaintEconomics:
    val frame_pixels = frame.width * frame.height
    val op_count = frame.fill_ops.len()
    val fill_pixels = _fill_op_pixels(frame)
    val simulated = _simulate_fill_ops(frame, base)
    val dirty = _dirty_bounds(frame.fb, simulated, frame.width, frame.height)
    val residual_pixels = if dirty.valid: dirty.w * dirty.h else: 0
    val upload_transfer = frame_pixels * 2
    val gpu_transfer = frame_pixels + residual_pixels + op_count * 64
    val upload_total = frame_pixels + upload_transfer
    val gpu_total = frame.cpu_paint_pixels + gpu_transfer
    val saves_cpu_paint = frame.cpu_paint_pixels < frame_pixels
    val should = saves_cpu_paint and op_count > 0 and fill_pixels > 0 and gpu_total < upload_total
    val reason = if should:
        if gpu_transfer < upload_transfer:
            "gpu-paint-transfer-win"
        else:
            "gpu-paint-total-win"
    else:
        if not saves_cpu_paint:
            "cpu-ground-truth-required"
        else:
            if op_count == 0:
                "no-gpu-fill-ops"
            else:
                if fill_pixels == 0:
                    "no-clipped-fill-pixels"
                else:
                    "communication-overhead"
    val cpu_job_verdict = if saves_cpu_paint and op_count > 0 and fill_pixels > 0:
        "cpu-paint-offloaded"
    else:
        "cpu-paint-required"
    val speed_verdict = if should:
        "measured-gpu-faster"
    elif reason == "communication-overhead":
        "measured-gpu-slower-overhead"
    else:
        "not-offloaded"
    WebGpuPaintEconomics(frame_pixels: frame_pixels, cpu_paint_pixels: frame.cpu_paint_pixels, fill_op_count: op_count, fill_pixels: fill_pixels, residual_pixels: residual_pixels, upload_bound_transfer_pixels: upload_transfer, gpu_paint_transfer_pixels: gpu_transfer, upload_bound_total_pixels: upload_total, gpu_paint_total_pixels: gpu_total, should_offload: should, reason: reason, cpu_job_verdict: cpu_job_verdict, speed_verdict: speed_verdict)

fn _should_use_gpu_paint(frame: WebGpuPaintFrame, backend_name: text, base: u32, gpu_paint: bool) -> bool:
    if not gpu_paint:
        return false
    if web_gpu_paint_backend_verdict(backend_name) != "gpu-paint-candidate":
        return false
    web_gpu_paint_economics(frame, base).should_offload

pub fn simple_web_layout_render_html_should_gpu_paint(html: text, width: i32, height: i32, backend_name: text, gpu_paint: bool) -> bool:
    val normalized_backend = backend_name.trim().lower()
    if not gpu_paint:
        return false
    if web_gpu_paint_backend_verdict(normalized_backend) != "gpu-paint-candidate":
        return false
    val base = _base_for(html)
    val frame = simple_web_layout_render_html_gpu_frame(html, width, height)
    _should_use_gpu_paint(frame, normalized_backend, base, true)

pub fn simple_web_layout_render_html_gpu_paint_route_verdict(html: text, width: i32, height: i32, backend_name: text, gpu_paint: bool) -> text:
    val normalized_backend = backend_name.trim().lower()
    if not gpu_paint:
        return "gpu-paint-disabled"
    val backend_verdict = web_gpu_paint_backend_verdict(normalized_backend)
    if backend_verdict != "gpu-paint-candidate":
        return backend_verdict
    val base = _base_for(html)
    val frame = simple_web_layout_render_html_gpu_frame(html, width, height)
    val economics = web_gpu_paint_economics(frame, base)
    if economics.should_offload:
        return "gpu-paint:" + economics.reason + ":" + economics.cpu_job_verdict + ":" + economics.speed_verdict
    "gpu-upload:" + economics.reason + ":" + economics.cpu_job_verdict + ":" + economics.speed_verdict

# ---------------------------------------------------------------------------
# GPU-paint present: real per-primitive Engine2D dispatch
# ---------------------------------------------------------------------------
# clear(base) + one draw_rect_filled per solid box (REAL backend kernel calls) +
# a residual blit of whatever the fills did not reproduce (gradients, borders,
# text, images), taken from the CPU ground truth so the composited GPU frame is
# bit-exact with the CPU path. The residual is measured against the ACTUAL GPU
# readback, so parity holds by construction regardless of per-kernel rounding;
# the residual-blit count is therefore also a divergence meter (0 == the GPU
# fills reproduced every solid box bit-exactly).
fn present_gpu_paint_readback(frame: WebGpuPaintFrame, backend_name: text, base: u32) -> Engine2DReadback:
    val width = frame.width
    val height = frame.height
    if width <= 0 or height <= 0:
        return engine2d_readback([], "not_requested")
    val engine_result = Engine2D.create_requested_backend(width, height, backend_name)
    val readback = match engine_result:
        Ok(engine):
            engine.clear(base)
            var rect_count: i32 = 0
            var oi: i32 = 0
            val op_count = frame.fill_ops.len()
            while oi < op_count:
                val op = frame.fill_ops[oi]
                engine.draw_rect_filled(op.x, op.y, op.width, op.height, op.color as u32)
                rect_count = rect_count + 1
                oi = oi + 1
            # Predict the residual locally so GPU paint does not pay an extra
            # full-frame GPU->CPU readback before the final API readback.
            val after_fills = _simulate_fill_ops(frame, base)
            val dirty = _dirty_bounds(frame.fb, after_fills, width, height)
            var blit_count: i32 = 0
            var blit_pixels: i32 = 0
            if dirty.valid:
                val sub = _extract_subimage(frame.fb, width, dirty)
                engine.draw_image(dirty.x, dirty.y, dirty.w, dirty.h, sub)
                blit_count = 1
                blit_pixels = dirty.w * dirty.h
            val out = engine.read_pixels_with_source()
            val gpu_backend_used = not _backend_is_cpu(out.source.trim().lower())
            print "[web-gpu-paint] backend={backend_name} dispatch rect={rect_count} gradient=0 blit={blit_count} blit_pixels={blit_pixels} readback_source={out.source} gpu_backend_used={gpu_backend_used} pixels={out.pixels.len()}"
            out
        Err(_):
            engine2d_readback(frame.fb, "cpu_fallback")
    readback

# ---------------------------------------------------------------------------
# Default (upload-bound) present path — unchanged
# ---------------------------------------------------------------------------
fn present_layout_pixels_with_engine2d_readback(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> Engine2DReadback:
    if width <= 0 or height <= 0:
        return engine2d_readback([], "not_requested")
    val normalized_backend = backend_name.trim().lower()
    if _backend_is_cpu(normalized_backend):
        return engine2d_readback(pixels, "cpu_mirror")

    # Route non-CPU backends to Engine2D for GPU rendering (Vulkan, CUDA, Metal, etc.)
    # Create the GPU backend, fill with base color, then blit layout pixels on top.
    # If the GPU backend fails to initialize, fall back to software pixels.
    val engine_result = Engine2D.create_requested_backend(width, height, normalized_backend)
    val readback = match engine_result:
        Ok(engine):
            engine.clear(base)
            if pixels.len() == width * height:
                engine.draw_image(0, 0, width, height, pixels)
            val gpu_pixels = engine.read_pixels_with_source()
            gpu_pixels
        Err(_):
            # GPU backend unavailable; return software pixels as fallback
            engine2d_readback(pixels, "cpu_fallback")
    readback

fn present_layout_pixels_with_engine2d(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> [u32]:
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base).pixels

fn _base_for(html: text) -> u32:
    if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32

# ---------------------------------------------------------------------------
# Readback entry with explicit GPU-paint selection (used by parity specs to run
# both lanes in one process).
# ---------------------------------------------------------------------------
pub fn simple_web_layout_render_html_readback_paint(html: text, width: i32, height: i32, backend_name: text, gpu_paint: bool) -> Engine2DReadback:
    val base = _base_for(html)
    val normalized_backend = backend_name.trim().lower()
    if normalized_backend == "cpu_simd" or normalized_backend == "simd_cpu" or normalized_backend == "cpu-simd":
        val frame = simple_web_layout_render_html_gpu_frame(html, width, height)
        if frame.cpu_paint_pixels == 0:
            return present_gpu_paint_readback(frame, "cpu_simd", base)
        return present_layout_pixels_with_engine2d_readback(frame.fb, width, height, backend_name, base)
    if gpu_paint and web_gpu_paint_backend_verdict(normalized_backend) == "gpu-paint-candidate":
        val frame = simple_web_layout_render_html_gpu_frame(html, width, height)
        if _should_use_gpu_paint(frame, normalized_backend, base, true):
            return present_gpu_paint_readback(frame, normalized_backend, base)
        return present_layout_pixels_with_engine2d_readback(frame.fb, width, height, backend_name, base)
    val pixels = simple_web_layout_render_html_software_pixels(html, width, height)
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    simple_web_layout_render_html_readback_paint(html, width, height, backend_name, web_gpu_paint_enabled()).pixels

pub fn simple_web_layout_render_html_pixels_at_scroll(html: text, width: i32, height: i32, backend_name: text, scroll_y: i32) -> [u32]:
    val pixels = simple_web_layout_render_html_software_pixels_at_scroll(html, width, height, scroll_y)
    val base = _base_for(html)
    present_layout_pixels_with_engine2d(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_readback(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    simple_web_layout_render_html_readback_paint(html, width, height, backend_name, web_gpu_paint_enabled())
