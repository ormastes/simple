use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels,
    simple_web_layout_render_html_software_pixels_at_scroll,
    simple_web_layout_uses_legacy_widget_chrome,
    simple_web_layout_render_html_gpu_frame,
    WebGpuPaintFrame
}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback, engine2d_readback}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

extern fn rt_env_get(key: text) -> text

# ---------------------------------------------------------------------------
# GPU paint flag
# ---------------------------------------------------------------------------
# When SIMPLE_WEB_GPU_PAINT=1 the non-CPU presenter path composes the frame from
# a display list of REAL per-primitive Engine2D backend calls (one
# draw_rect_filled per solid box) plus a residual blit, instead of uploading one
# finished CPU bitmap and blitting it once. Default OFF: the safe upload path
# stays in force until per-primitive parity is proven on the target machine.
pub fn web_gpu_paint_enabled() -> bool:
    val v = rt_env_get("SIMPLE_WEB_GPU_PAINT")
    v == "1" or v == "true" or v == "on"

fn _backend_is_cpu(normalized_backend: text) -> bool:
    (normalized_backend == "software" or normalized_backend == "cpu"
        or normalized_backend == "cpu_simd" or normalized_backend == "simd_cpu"
        or normalized_backend == "cpu-simd")

# ---------------------------------------------------------------------------
# Residual (dirty) region between the CPU ground truth and the GPU fill result
# ---------------------------------------------------------------------------
class _DirtyRect:
    valid: bool
    x: i32
    y: i32
    w: i32
    h: i32

# Bounding box of every pixel where the GPU-composited fills differ from the CPU
# ground-truth framebuffer. If the GPU readback length is wrong (backend cannot
# read back), the whole frame is treated as dirty so the residual blit still
# yields a bit-exact frame.
fn _dirty_bounds(truth: [u32], gpu: [u32], width: i32, height: i32) -> _DirtyRect:
    if gpu.len() != width * height or truth.len() != width * height:
        return _DirtyRect(valid: true, x: 0, y: 0, w: width, h: height)
    var min_x: i32 = width
    var min_y: i32 = height
    var max_x: i32 = -1
    var max_y: i32 = -1
    var y: i32 = 0
    while y < height:
        val row = y * width
        var x: i32 = 0
        while x < width:
            val k = row + x
            if truth[k] != gpu[k]:
                if x < min_x:
                    min_x = x
                if x > max_x:
                    max_x = x
                if y < min_y:
                    min_y = y
                if y > max_y:
                    max_y = y
            x = x + 1
        y = y + 1
    if max_x < 0:
        return _DirtyRect(valid: false, x: 0, y: 0, w: 0, h: 0)
    _DirtyRect(valid: true, x: min_x, y: min_y, w: max_x - min_x + 1, h: max_y - min_y + 1)

fn _extract_subimage(src: [u32], src_width: i32, rect: _DirtyRect) -> [u32]:
    var out: [u32] = [0u32; rect.w * rect.h]
    var ry: i32 = 0
    while ry < rect.h:
        val src_row = (rect.y + ry) * src_width + rect.x
        val dst_row = ry * rect.w
        var rx: i32 = 0
        while rx < rect.w:
            out[dst_row + rx] = src[src_row + rx]
            rx = rx + 1
        ry = ry + 1
    out

# ---------------------------------------------------------------------------
# GPU-paint present: real per-primitive Engine2D dispatch
# ---------------------------------------------------------------------------
# clear(base) + one draw_rect_filled per solid box (REAL backend kernel calls) +
# a residual blit of whatever the fills did not reproduce (gradients, borders,
# text, images), taken from the CPU ground truth so the composited GPU frame is
# bit-exact with the CPU path. The residual is measured against the ACTUAL GPU
# readback, so parity holds by construction regardless of per-kernel rounding;
# the residual-blit count is therefore also a divergence meter (0 == the GPU
# fills reproduced every solid box bit-exactly).
fn present_gpu_paint_readback(frame: WebGpuPaintFrame, backend_name: text, base: u32) -> Engine2DReadback:
    val width = frame.width
    val height = frame.height
    if width <= 0 or height <= 0:
        return engine2d_readback([], "not_requested")
    val engine_result = Engine2D.create_requested_backend(width, height, backend_name)
    val readback = match engine_result:
        Ok(engine):
            engine.clear(base)
            var rect_count: i32 = 0
            var oi: i32 = 0
            while oi < frame.fill_ops.len():
                val op = frame.fill_ops[oi]
                engine.draw_rect_filled(op.x, op.y, op.width, op.height, op.color as u32)
                rect_count = rect_count + 1
                oi = oi + 1
            # Measure the residual against the real GPU output after the fills.
            val after_fills = engine.read_pixels()
            val dirty = _dirty_bounds(frame.fb, after_fills, width, height)
            var blit_count: i32 = 0
            var blit_pixels: i32 = 0
            if dirty.valid:
                val sub = _extract_subimage(frame.fb, width, dirty)
                engine.draw_image(dirty.x, dirty.y, dirty.w, dirty.h, sub)
                blit_count = 1
                blit_pixels = dirty.w * dirty.h
            val out = engine.read_pixels_with_source()
            val gpu_backend_used = not _backend_is_cpu(out.source.trim().lower())
            print "[web-gpu-paint] backend={backend_name} dispatch rect={rect_count} gradient=0 blit={blit_count} blit_pixels={blit_pixels} readback_source={out.source} gpu_backend_used={gpu_backend_used} pixels={out.pixels.len()}"
            out
        Err(_):
            engine2d_readback(frame.fb, "cpu_fallback")
    readback

# ---------------------------------------------------------------------------
# Default (upload-bound) present path — unchanged
# ---------------------------------------------------------------------------
fn present_layout_pixels_with_engine2d_readback(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> Engine2DReadback:
    if width <= 0 or height <= 0:
        return engine2d_readback([], "not_requested")
    val normalized_backend = backend_name.trim().lower()
    if _backend_is_cpu(normalized_backend):
        return engine2d_readback(pixels, "cpu_mirror")

    # Route non-CPU backends to Engine2D for GPU rendering (Vulkan, CUDA, Metal, etc.)
    # Create the GPU backend, fill with base color, then blit layout pixels on top.
    # If the GPU backend fails to initialize, fall back to software pixels.
    val engine_result = Engine2D.create_requested_backend(width, height, normalized_backend)
    val readback = match engine_result:
        Ok(engine):
            engine.clear(base)
            if pixels.len() == width * height:
                engine.draw_image(0, 0, width, height, pixels)
            val gpu_pixels = engine.read_pixels_with_source()
            gpu_pixels
        Err(_):
            # GPU backend unavailable; return software pixels as fallback
            engine2d_readback(pixels, "cpu_fallback")
    readback

fn present_layout_pixels_with_engine2d(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> [u32]:
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base).pixels

fn _base_for(html: text) -> u32:
    if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32

# ---------------------------------------------------------------------------
# Readback entry with explicit GPU-paint selection (used by parity specs to run
# both lanes in one process).
# ---------------------------------------------------------------------------
pub fn simple_web_layout_render_html_readback_paint(html: text, width: i32, height: i32, backend_name: text, gpu_paint: bool) -> Engine2DReadback:
    val base = _base_for(html)
    val normalized_backend = backend_name.trim().lower()
    if gpu_paint and not _backend_is_cpu(normalized_backend):
        val frame = simple_web_layout_render_html_gpu_frame(html, width, height)
        return present_gpu_paint_readback(frame, normalized_backend, base)
    val pixels = simple_web_layout_render_html_software_pixels(html, width, height)
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    simple_web_layout_render_html_readback_paint(html, width, height, backend_name, web_gpu_paint_enabled()).pixels

pub fn simple_web_layout_render_html_pixels_at_scroll(html: text, width: i32, height: i32, backend_name: text, scroll_y: i32) -> [u32]:
    val pixels = simple_web_layout_render_html_software_pixels_at_scroll(html, width, height, scroll_y)
    val base = _base_for(html)
    present_layout_pixels_with_engine2d(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_readback(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    simple_web_layout_render_html_readback_paint(html, width, height, backend_name, web_gpu_paint_enabled())
