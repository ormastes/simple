use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels,
    simple_web_layout_render_html_software_pixels_at_scroll,
    simple_web_layout_uses_legacy_widget_chrome
}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback, engine2d_readback}

fn present_layout_pixels_with_engine2d_readback(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> Engine2DReadback:
    if width <= 0 or height <= 0:
        return engine2d_readback([], "not_requested")
    val normalized_backend = backend_name.trim().lower()
    if normalized_backend == "software" or normalized_backend == "cpu" or normalized_backend == "cpu_simd" or normalized_backend == "simd_cpu" or normalized_backend == "cpu-simd":
        return engine2d_readback(pixels, "cpu_mirror")
    # The browser corpus renderer is a software HTML/CSS oracle. Keep GPU
    # backend captures in the dedicated wm_compare backend/parity tools so this
    # path does not compile optional CUDA/ROCm/driver externs on CPU-only hosts.
    engine2d_readback(pixels, "cpu_mirror")

fn present_layout_pixels_with_engine2d(pixels: [u32], width: i32, height: i32, backend_name: text, base: u32) -> [u32]:
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base).pixels


pub fn simple_web_layout_render_html_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    val pixels = simple_web_layout_render_html_software_pixels(html, width, height)
    val base = if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32
    present_layout_pixels_with_engine2d(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_pixels_at_scroll(html: text, width: i32, height: i32, backend_name: text, scroll_y: i32) -> [u32]:
    val pixels = simple_web_layout_render_html_software_pixels_at_scroll(html, width, height, scroll_y)
    val base = if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32
    present_layout_pixels_with_engine2d(pixels, width, height, backend_name, base)

pub fn simple_web_layout_render_html_readback(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    val pixels = simple_web_layout_render_html_software_pixels(html, width, height)
    val base = if simple_web_layout_uses_legacy_widget_chrome(html): 0xFFF5F5F5u32 else: 0xFFFFFFFFu32
    present_layout_pixels_with_engine2d_readback(pixels, width, height, backend_name, base)
