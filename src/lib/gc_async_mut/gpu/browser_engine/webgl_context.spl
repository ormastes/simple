        self.blend_color_green = webgl_clamp_f64(green, 0.0, 1.0)
        self.blend_color_blue = webgl_clamp_f64(blue, 0.0, 1.0)
        self.blend_color_alpha = webgl_clamp_f64(alpha, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_blend_color(self.blend_color_red, self.blend_color_green, self.blend_color_blue, self.blend_color_alpha))
        true

    me blend_func(src_factor: i32, dst_factor: i32) -> bool:
        self.blend_func_separate(src_factor, dst_factor, src_factor, dst_factor)

    me blend_func_separate(src_rgb: i32, dst_rgb: i32, src_alpha: i32, dst_alpha: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_blend_factor(src_rgb) or not webgl_valid_blend_factor(dst_rgb) or not webgl_valid_blend_factor(src_alpha) or not webgl_valid_blend_factor(dst_alpha):
