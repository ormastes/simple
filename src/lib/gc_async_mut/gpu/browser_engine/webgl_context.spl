    me depth_func(func: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_depth_func(func):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.depth_func_value = func
        self.render_commands.push(webgl_render_command_depth_func(func))
        true

    me stencil_func(func: i32, ref_value: i32, mask: i32) -> bool:
        if not self.ensure_context_available():
