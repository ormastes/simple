"""Browser WebGL/WebGL2 compatibility context.

This models the browser-facing WebGL state machine boundary in pure Simple:
context creation, error state, context loss, resources, shader compile, and
program link/use. Rendering backend translation is layered after this API.
"""

pub val WEBGL_NO_ERROR: i32 = 0
pub val WEBGL_INVALID_ENUM: i32 = 1280
pub val WEBGL_INVALID_VALUE: i32 = 1281
pub val WEBGL_INVALID_OPERATION: i32 = 1282
pub val WEBGL_CONTEXT_LOST_WEBGL: i32 = 37442

pub val WEBGL_VERTEX_SHADER: i32 = 35633
pub val WEBGL_FRAGMENT_SHADER: i32 = 35632
pub val WEBGL_DELETE_STATUS: i32 = 35712
pub val WEBGL_COMPILE_STATUS: i32 = 35713
pub val WEBGL_LINK_STATUS: i32 = 35714
pub val WEBGL_VALIDATE_STATUS: i32 = 35715
pub val WEBGL_INFO_LOG_LENGTH: i32 = 35716
pub val WEBGL_ATTACHED_SHADERS: i32 = 35717
pub val WEBGL_ACTIVE_UNIFORMS: i32 = 35718
pub val WEBGL_ACTIVE_ATTRIBUTES: i32 = 35721
pub val WEBGL_SHADER_TYPE: i32 = 35663
pub val WEBGL_FLOAT: i32 = 5126
pub val WEBGL_FLOAT_VEC2: i32 = 35664
pub val WEBGL_FLOAT_VEC3: i32 = 35665
pub val WEBGL_FLOAT_VEC4: i32 = 35666
pub val WEBGL_FLOAT_MAT4: i32 = 35676
pub val WEBGL_SAMPLER_2D: i32 = 35678
pub val WEBGL_TEXTURE_2D: i32 = 3553
pub val WEBGL_TEXTURE_BINDING_2D: i32 = 32873
pub val WEBGL_UNPACK_ALIGNMENT: i32 = 3317
pub val WEBGL_RGB: i32 = 6407
pub val WEBGL_RGBA: i32 = 6408
pub val WEBGL_UNSIGNED_BYTE: i32 = 5121
pub val WEBGL_UNPACK_FLIP_Y_WEBGL: i32 = 37440
pub val WEBGL_UNPACK_PREMULTIPLY_ALPHA_WEBGL: i32 = 37441
pub val WEBGL_UNPACK_COLORSPACE_CONVERSION_WEBGL: i32 = 37443
pub val WEBGL_BROWSER_DEFAULT_WEBGL: i32 = 37444

pub class WebGLBufferHandle:
    id: i32
    valid: bool
    error: text

pub class WebGLTextureHandle:
    id: i32
    valid: bool
    error: text
    target: i32
    width: i32
    height: i32
    level: i32
    internal_format: i32
    format: i32
    pixel_type: i32
    initialized: bool
    pixels: [u8]

pub class WebGLShaderHandle:
    id: i32
    shader_type: i32
    source: text
    compiled: bool
    valid: bool
    info_log: text

pub class WebGLActiveInfo:
    name: text
    size: i32
    data_type: i32
    location: i32

pub class WebGLParameterValue:
    value_kind: text
    bool_value: bool
    int_value: i32
    text_value: text

pub class WebGLExtensionInfo:
    name: text
    minimum_version: i32

pub class WebGLExtensionHandle:
    name: text
    valid: bool
    enabled: bool
    error: text

pub class WebGLProgramHandle:
    id: i32
    vertex_shader_id: i32
    fragment_shader_id: i32
    linked: bool
    valid: bool
    info_log: text
    active_attribs: [WebGLActiveInfo]
    active_uniforms: [WebGLActiveInfo]
    validate_status: bool

pub class WebGLContext:
    version: i32
    context_name: text
    context_lost: bool
    last_error: i32
    width: i32
    height: i32
    next_buffer_id: i32
    next_texture_id: i32
    next_shader_id: i32
    next_program_id: i32
    buffers: [WebGLBufferHandle]
    textures: [WebGLTextureHandle]
    shaders: [WebGLShaderHandle]
    programs: [WebGLProgramHandle]
    current_program_id: i32
    supported_extensions: [text]
    enabled_extensions: [text]
    bound_texture_2d: i32
    unpack_alignment: i32
    unpack_flip_y: bool
    unpack_premultiply_alpha: bool
    unpack_colorspace_conversion: i32

    fn is_available() -> bool:
        not self.context_lost

    me get_error() -> i32:
        val err = self.last_error
        if self.context_lost:
            self.last_error = WEBGL_NO_ERROR
            return WEBGL_CONTEXT_LOST_WEBGL
        self.last_error = WEBGL_NO_ERROR
        err

    me lose_context():
        self.context_lost = true
        self.last_error = WEBGL_CONTEXT_LOST_WEBGL
        self.current_program_id = -1

    me restore_context():
        self.context_lost = false
        self.last_error = WEBGL_NO_ERROR

    me create_buffer() -> WebGLBufferHandle:
        if not self.ensure_context_available():
            return WebGLBufferHandle(id: -1, valid: false, error: "context lost")
        val handle = WebGLBufferHandle(id: self.next_buffer_id, valid: true, error: "")
        self.next_buffer_id = self.next_buffer_id + 1
        self.buffers.push(handle)
        handle

    me create_texture() -> WebGLTextureHandle:
        if not self.ensure_context_available():
            return WebGLTextureHandle(id: -1, valid: false, error: "context lost", target: 0, width: 0, height: 0, level: 0, internal_format: 0, format: 0, pixel_type: 0, initialized: false, pixels: [])
        val handle = WebGLTextureHandle(id: self.next_texture_id, valid: true, error: "", target: 0, width: 0, height: 0, level: 0, internal_format: 0, format: 0, pixel_type: 0, initialized: false, pixels: [])
        self.next_texture_id = self.next_texture_id + 1
        self.textures.push(handle)
        handle

    me create_shader(shader_type: i32) -> WebGLShaderHandle:
        if not self.ensure_context_available():
            return WebGLShaderHandle(id: -1, shader_type: shader_type, source: "", compiled: false, valid: false, info_log: "context lost")
        if shader_type != WEBGL_VERTEX_SHADER and shader_type != WEBGL_FRAGMENT_SHADER:
            self.last_error = WEBGL_INVALID_ENUM
            return WebGLShaderHandle(id: -1, shader_type: shader_type, source: "", compiled: false, valid: false, info_log: "invalid shader type")
        val handle = WebGLShaderHandle(id: self.next_shader_id, shader_type: shader_type, source: "", compiled: false, valid: true, info_log: "")
        self.next_shader_id = self.next_shader_id + 1
        self.shaders.push(handle)
        handle

    me shader_source(shader_id: i32, source: text) -> bool:
        if not self.ensure_context_available():
            return false
        var i = 0
        while i < self.shaders.len():
            if self.shaders[i].id == shader_id:
                var shader = self.shaders[i]
                shader.source = source
                shader.compiled = false
                shader.info_log = ""
                self.shaders[i] = shader
                return true
            i = i + 1
        self.last_error = WEBGL_INVALID_VALUE
        false

    me compile_shader(shader_id: i32) -> WebGLShaderHandle:
        if not self.ensure_context_available():
            return WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "context lost")
        var i = 0
        while i < self.shaders.len():
            if self.shaders[i].id == shader_id:
                var shader = self.shaders[i]
                val err = webgl_validate_shader_source(shader.shader_type, shader.source)
                shader.compiled = err == ""
                shader.info_log = err
                self.shaders[i] = shader
                if err != "":
                    self.last_error = WEBGL_INVALID_OPERATION
                return shader
            i = i + 1
        self.last_error = WEBGL_INVALID_VALUE
        WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "shader not found")

    me create_program() -> WebGLProgramHandle:
        if not self.ensure_context_available():
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "context lost", active_attribs: [], active_uniforms: [], validate_status: false)
        val handle = WebGLProgramHandle(id: self.next_program_id, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: true, info_log: "", active_attribs: [], active_uniforms: [], validate_status: false)
        self.next_program_id = self.next_program_id + 1
        self.programs.push(handle)
        handle

    me attach_shader(program_id: i32, shader_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val shader_index = self.find_shader_index(shader_id)
        val program_index = self.find_program_index(program_id)
        if shader_index < 0 or program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var program = self.programs[program_index]
        val shader = self.shaders[shader_index]
        if shader.shader_type == WEBGL_VERTEX_SHADER:
            program.vertex_shader_id = shader_id
        if shader.shader_type == WEBGL_FRAGMENT_SHADER:
            program.fragment_shader_id = shader_id
        self.programs[program_index] = program
        true

    me link_program(program_id: i32) -> WebGLProgramHandle:
        if not self.ensure_context_available():
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "context lost", active_attribs: [], active_uniforms: [], validate_status: false)
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "program not found", active_attribs: [], active_uniforms: [], validate_status: false)
        var program = self.programs[program_index]
        val vertex_ok = self.shader_compiled(program.vertex_shader_id, WEBGL_VERTEX_SHADER)
        val fragment_ok = self.shader_compiled(program.fragment_shader_id, WEBGL_FRAGMENT_SHADER)
        if not vertex_ok or not fragment_ok:
            program.linked = false
            program.info_log = "compiled vertex and fragment shaders required"
            program.active_attribs = []
            program.active_uniforms = []
            program.validate_status = false
            self.last_error = WEBGL_INVALID_OPERATION
        else:
            program.linked = true
            program.info_log = ""
            program.active_attribs = webgl_collect_active_attribs(self.shader_source_text(program.vertex_shader_id))
            program.active_uniforms = webgl_collect_active_uniforms(self.shader_source_text(program.vertex_shader_id), self.shader_source_text(program.fragment_shader_id))
            program.validate_status = true
        self.programs[program_index] = program
        program

    me get_shader_parameter(shader_id: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_bool(false)
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_bool(false)
        val shader = self.shaders[shader_index]
        if pname == WEBGL_COMPILE_STATUS:
            return webgl_parameter_bool(shader.compiled)
        if pname == WEBGL_DELETE_STATUS:
            return webgl_parameter_bool(not shader.valid)
        if pname == WEBGL_SHADER_TYPE:
            return webgl_parameter_int(shader.shader_type)
        if pname == WEBGL_INFO_LOG_LENGTH:
            return webgl_parameter_int(shader.info_log.len())
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_bool(false)

    me get_shader_info_log(shader_id: i32) -> text:
        if not self.ensure_context_available():
            return ""
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return ""
        self.shaders[shader_index].info_log

    me get_program_parameter(program_id: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_bool(false)
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_bool(false)
        val program = self.programs[program_index]
        if pname == WEBGL_LINK_STATUS:
            return webgl_parameter_bool(program.linked)
        if pname == WEBGL_VALIDATE_STATUS:
            return webgl_parameter_bool(program.validate_status)
        if pname == WEBGL_DELETE_STATUS:
            return webgl_parameter_bool(not program.valid)
        if pname == WEBGL_INFO_LOG_LENGTH:
            return webgl_parameter_int(program.info_log.len())
        if pname == WEBGL_ATTACHED_SHADERS:
            return webgl_parameter_int(webgl_attached_shader_count(program))
        if pname == WEBGL_ACTIVE_UNIFORMS:
            return webgl_parameter_int(program.active_uniforms.len())
        if pname == WEBGL_ACTIVE_ATTRIBUTES:
            return webgl_parameter_int(program.active_attribs.len())
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_bool(false)

    me get_program_info_log(program_id: i32) -> text:
        if not self.ensure_context_available():
            return ""
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return ""
        self.programs[program_index].info_log

    me get_attrib_location(program_id: i32, name: text) -> i32:
        if not self.ensure_context_available():
            return -1
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        var i = 0
        while i < program.active_attribs.len():
            if program.active_attribs[i].name == name:
                return program.active_attribs[i].location
            i = i + 1
        -1

    me get_active_attrib(program_id: i32, index: i32) -> WebGLActiveInfo:
        if not self.ensure_context_available():
            return webgl_empty_active_info()
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if index < 0 or index >= program.active_attribs.len():
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        program.active_attribs[index]

    me get_uniform_location(program_id: i32, name: text) -> i32:
        if not self.ensure_context_available():
            return -1
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        var i = 0
        while i < program.active_uniforms.len():
            if program.active_uniforms[i].name == name:
                return program.active_uniforms[i].location
            i = i + 1
        -1

    me get_active_uniform(program_id: i32, index: i32) -> WebGLActiveInfo:
        if not self.ensure_context_available():
            return webgl_empty_active_info()
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if index < 0 or index >= program.active_uniforms.len():
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        program.active_uniforms[index]

    me use_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val program_index = self.find_program_index(program_id)
        if program_index < 0 or not self.programs[program_index].linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.current_program_id = program_id
        true

    me supports_extension(name: text) -> bool:
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "":
            return false
        var i = 0
        while i < self.supported_extensions.len():
            if self.supported_extensions[i] == canonical:
                return true
            i = i + 1
        false

    me is_extension_enabled(name: text) -> bool:
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "":
            return false
        webgl_text_list_contains(self.enabled_extensions, canonical)

    me get_extension(name: text) -> WebGLExtensionHandle:
        if not self.ensure_context_available():
            return WebGLExtensionHandle(name: webgl_canonical_extension_name(name), valid: false, enabled: false, error: "context lost")
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "" or not self.supports_extension(canonical):
            return WebGLExtensionHandle(name: canonical, valid: false, enabled: false, error: "extension not supported")
        if not webgl_text_list_contains(self.enabled_extensions, canonical):
            self.enabled_extensions.push(canonical)
        WebGLExtensionHandle(name: canonical, valid: true, enabled: true, error: "")

    me bind_texture(target: i32, texture_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if texture_id == -1:
            self.bound_texture_2d = -1
            return true
        val texture_index = self.find_texture_index(texture_id)
        if texture_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var texture = self.textures[texture_index]
        texture.target = target
        self.textures[texture_index] = texture
        self.bound_texture_2d = texture_id
        true

    me pixel_store_i(pname: i32, param: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if pname == WEBGL_UNPACK_ALIGNMENT:
            if param != 1 and param != 2 and param != 4 and param != 8:
                self.last_error = WEBGL_INVALID_VALUE
                return false
            self.unpack_alignment = param
            return true
        if pname == WEBGL_UNPACK_FLIP_Y_WEBGL:
            self.unpack_flip_y = param != 0
            return true
        if pname == WEBGL_UNPACK_PREMULTIPLY_ALPHA_WEBGL:
            self.unpack_premultiply_alpha = param != 0
            return true
        if pname == WEBGL_UNPACK_COLORSPACE_CONVERSION_WEBGL:
            if param != WEBGL_BROWSER_DEFAULT_WEBGL and param != WEBGL_NO_ERROR:
                self.last_error = WEBGL_INVALID_VALUE
                return false
            self.unpack_colorspace_conversion = param
            return true
        self.last_error = WEBGL_INVALID_ENUM
        false

    me tex_image_2d(target: i32, level: i32, internal_format: i32, width: i32, height: i32, border: i32, format: i32, pixel_type: i32, pixels: [u8]) -> bool:
        if not self.ensure_context_available():
            return false
        val texture_index = self.bound_texture_index_for_upload(target)
        if texture_index < 0:
            return false
        if not self.validate_texture_image_args(level, internal_format, width, height, border, format, pixel_type):
            return false
        val required = webgl_required_texture_bytes(width, height, webgl_texture_format_bytes(format), self.unpack_alignment)
        if pixels.len() > 0 and pixels.len() < required:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        var texture = self.textures[texture_index]
        texture.target = target
        texture.width = width
        texture.height = height
        texture.level = level
        texture.internal_format = internal_format
        texture.format = format
        texture.pixel_type = pixel_type
        texture.initialized = true
        if pixels.len() == 0:
            texture.pixels = webgl_zero_bytes(required)
        else:
            texture.pixels = webgl_copy_bytes(pixels, required)
        self.textures[texture_index] = texture
        true

    me tex_sub_image_2d(target: i32, level: i32, xoffset: i32, yoffset: i32, width: i32, height: i32, format: i32, pixel_type: i32, pixels: [u8]) -> bool:
        if not self.ensure_context_available():
            return false
        val texture_index = self.bound_texture_index_for_upload(target)
        if texture_index < 0:
            return false
        var texture = self.textures[texture_index]
        if not texture.initialized:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        if level != texture.level:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if format != texture.format or pixel_type != texture.pixel_type:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        if xoffset < 0 or yoffset < 0 or width < 0 or height < 0 or xoffset + width > texture.width or yoffset + height > texture.height:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        val bpp = webgl_texture_format_bytes(format)
        if bpp == 0:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        val required = webgl_required_texture_bytes(width, height, bpp, self.unpack_alignment)
        if pixels.len() < required:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        texture.pixels = webgl_replace_texture_region(texture.pixels, texture.width, bpp, xoffset, yoffset, width, height, self.unpack_alignment, pixels)
        self.textures[texture_index] = texture
        true

    me ensure_context_available() -> bool:
        if self.context_lost:
            self.last_error = WEBGL_CONTEXT_LOST_WEBGL
            return false
        true

    fn find_shader_index(shader_id: i32) -> i32:
        var i = 0
        while i < self.shaders.len():
            if self.shaders[i].id == shader_id:
                return i
            i = i + 1
        -1

    fn find_texture_index(texture_id: i32) -> i32:
        var i = 0
        while i < self.textures.len():
            if self.textures[i].id == texture_id:
                return i
            i = i + 1
        -1

    me bound_texture_index_for_upload(target: i32) -> i32:
        if target != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_ENUM
            return -1
        if self.bound_texture_2d < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        val texture_index = self.find_texture_index(self.bound_texture_2d)
        if texture_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        texture_index

    me validate_texture_image_args(level: i32, internal_format: i32, width: i32, height: i32, border: i32, format: i32, pixel_type: i32) -> bool:
        if level != 0 or width < 0 or height < 0 or border != 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if internal_format != format or webgl_texture_format_bytes(format) == 0 or pixel_type != WEBGL_UNSIGNED_BYTE:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        true

    fn find_program_index(program_id: i32) -> i32:
        var i = 0
        while i < self.programs.len():
            if self.programs[i].id == program_id:
                return i
            i = i + 1
        -1

    fn shader_compiled(shader_id: i32, shader_type: i32) -> bool:
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            return false
        self.shaders[shader_index].shader_type == shader_type and self.shaders[shader_index].compiled

    fn shader_source_text(shader_id: i32) -> text:
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            return ""
        self.shaders[shader_index].source

pub fn webgl_create_context(version: i32, width: i32, height: i32) -> WebGLContext:
    val actual_version = if version == 2: 2 else: 1
    WebGLContext(
        version: actual_version,
        context_name: if actual_version == 2: "webgl2" else: "webgl",
        context_lost: false,
        last_error: WEBGL_NO_ERROR,
        width: width,
        height: height,
        next_buffer_id: 1,
        next_texture_id: 1,
        next_shader_id: 1,
        next_program_id: 1,
        buffers: [],
        textures: [],
        shaders: [],
        programs: [],
        current_program_id: -1,
        supported_extensions: webgl_default_extensions(actual_version),
        enabled_extensions: [],
        bound_texture_2d: -1,
        unpack_alignment: 4,
        unpack_flip_y: false,
        unpack_premultiply_alpha: false,
        unpack_colorspace_conversion: WEBGL_BROWSER_DEFAULT_WEBGL
    )

pub fn webgl_is_supported_context_name(name: text) -> bool:
    val lower = name.lower()
    lower == "webgl" or lower == "experimental-webgl" or lower == "webgl2"

pub fn webgl_context_version_for_name(name: text) -> i32:
    val lower = name.lower()
    if lower == "webgl2":
        return 2
    if lower == "webgl" or lower == "experimental-webgl":
        return 1
    0

pub fn webgl_validate_shader_source(shader_type: i32, source: text) -> text:
    val trimmed = source.trim()
    if trimmed == "":
        return "shader source is empty"
    if not trimmed.contains("void main"):
        return "shader must define void main"
    if shader_type == WEBGL_VERTEX_SHADER and not trimmed.contains("gl_Position"):
        return "vertex shader must write gl_Position"
    if shader_type == WEBGL_FRAGMENT_SHADER and not (trimmed.contains("gl_FragColor") or trimmed.contains("out ")):
        return "fragment shader must write a color output"
    ""

pub fn webgl_parameter_bool(value: bool) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "bool", bool_value: value, int_value: 0, text_value: "")

pub fn webgl_parameter_int(value: i32) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "int", bool_value: false, int_value: value, text_value: "")

pub fn webgl_empty_active_info() -> WebGLActiveInfo:
    WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)

pub fn webgl_attached_shader_count(program: WebGLProgramHandle) -> i32:
    var count = 0
    if program.vertex_shader_id >= 0:
        count = count + 1
    if program.fragment_shader_id >= 0:
        count = count + 1
    count

pub fn webgl_collect_active_attribs(vertex_source: text) -> [WebGLActiveInfo]:
    var active: [WebGLActiveInfo] = []
    val normalized_source = vertex_source.replace("\n", " ")
    val statements = normalized_source.split(";")
    var i = 0
    while i < statements.len():
        val declaration = statements[i].trim()
        if declaration.starts_with("attribute "):
            val info = webgl_active_info_from_declaration(declaration, "attribute", active.len())
            if info.name != "":
                active.push(info)
        i = i + 1
    active

pub fn webgl_collect_active_uniforms(vertex_source: text, fragment_source: text) -> [WebGLActiveInfo]:
    var active: [WebGLActiveInfo] = []
    active = webgl_collect_uniforms_from_source(vertex_source, active)
    webgl_collect_uniforms_from_source(fragment_source, active)

pub fn webgl_collect_uniforms_from_source(source: text, active: [WebGLActiveInfo]) -> [WebGLActiveInfo]:
    var result = active
    val normalized_source = source.replace("\n", " ")
    val statements = normalized_source.split(";")
    var i = 0
    while i < statements.len():
        val declaration = statements[i].trim()
        if declaration.starts_with("uniform "):
            val info = webgl_active_info_from_declaration(declaration, "uniform", result.len())
            if info.name != "" and not webgl_has_active_info(result, info.name):
                result.push(info)
        i = i + 1
    result

pub fn webgl_has_active_info(active: [WebGLActiveInfo], name: text) -> bool:
    var i = 0
    while i < active.len():
        if active[i].name == name:
            return true
        i = i + 1
    false

pub fn webgl_active_info_from_declaration(declaration: text, qualifier: text, location: i32) -> WebGLActiveInfo:
    val normalized = declaration.replace("\t", " ").trim()
    val parts = normalized.split(" ")
    var filtered: [text] = []
    var i = 0
    while i < parts.len():
        val token = parts[i].trim()
        if token != "":
            filtered.push(token)
        i = i + 1
    if filtered.len() < 3:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    if filtered[0] != qualifier:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    val data_type = webgl_glsl_type_enum(filtered[1])
    if data_type == 0:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    WebGLActiveInfo(name: webgl_clean_glsl_name(filtered[2]), size: 1, data_type: data_type, location: location)

pub fn webgl_glsl_type_enum(type_name: text) -> i32:
    if type_name == "float":
        return WEBGL_FLOAT
    if type_name == "vec2":
        return WEBGL_FLOAT_VEC2
    if type_name == "vec3":
        return WEBGL_FLOAT_VEC3
    if type_name == "vec4":
        return WEBGL_FLOAT_VEC4
    if type_name == "mat4":
        return WEBGL_FLOAT_MAT4
    if type_name == "sampler2D":
        return WEBGL_SAMPLER_2D
    0

pub fn webgl_clean_glsl_name(name: text) -> text:
    val parts = name.split("[")
    val without_array = parts[0]
    without_array.trim()

pub fn webgl_default_extensions(version: i32) -> [text]:
    val catalog = webgl_extension_catalog()
    var supported: [text] = []
    var i = 0
    while i < catalog.len():
        if version >= catalog[i].minimum_version:
            supported.push(catalog[i].name)
        i = i + 1
    supported

pub fn webgl_extension_catalog() -> [WebGLExtensionInfo]:
    [
        WebGLExtensionInfo(name: "OES_texture_float", minimum_version: 1),
        WebGLExtensionInfo(name: "OES_element_index_uint", minimum_version: 1),
        WebGLExtensionInfo(name: "WEBGL_lose_context", minimum_version: 1),
        WebGLExtensionInfo(name: "EXT_color_buffer_float", minimum_version: 2)
    ]

pub fn webgl_canonical_extension_name(name: text) -> text:
    val catalog = webgl_extension_catalog()
    var i = 0
    while i < catalog.len():
        if catalog[i].name == name:
            return catalog[i].name
        i = i + 1
    ""

pub fn webgl_text_list_contains(values: [text], needle: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

pub fn webgl_texture_format_bytes(format: i32) -> i32:
    if format == WEBGL_RGB:
        return 3
    if format == WEBGL_RGBA:
        return 4
    0

pub fn webgl_aligned_row_stride(width: i32, bytes_per_pixel: i32, alignment: i32) -> i32:
    val row_bytes = width * bytes_per_pixel
    val remainder = row_bytes % alignment
    if remainder == 0:
        return row_bytes
    row_bytes + alignment - remainder

pub fn webgl_required_texture_bytes(width: i32, height: i32, bytes_per_pixel: i32, alignment: i32) -> i32:
    if width == 0 or height == 0:
        return 0
    webgl_aligned_row_stride(width, bytes_per_pixel, alignment) * height

pub fn webgl_zero_bytes(count: i32) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < count:
        bytes.push(0)
        i = i + 1
    bytes

pub fn webgl_copy_bytes(source: [u8], count: i32) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < count:
        bytes.push(source[i])
        i = i + 1
    bytes

pub fn webgl_replace_texture_region(existing: [u8], texture_width: i32, bytes_per_pixel: i32, xoffset: i32, yoffset: i32, width: i32, height: i32, unpack_alignment: i32, pixels: [u8]) -> [u8]:
    var result = existing
    val destination_stride = texture_width * bytes_per_pixel
    val source_stride = webgl_aligned_row_stride(width, bytes_per_pixel, unpack_alignment)
    var row = 0
    while row < height:
        var col_byte = 0
        while col_byte < width * bytes_per_pixel:
            val destination_index = (yoffset + row) * destination_stride + xoffset * bytes_per_pixel + col_byte
            val source_index = row * source_stride + col_byte
            result[destination_index] = pixels[source_index]
            col_byte = col_byte + 1
        row = row + 1
    result
