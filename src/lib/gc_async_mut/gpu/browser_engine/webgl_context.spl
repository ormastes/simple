        val renderbuffer_index = self.find_renderbuffer_index(renderbuffer_id)
        if renderbuffer_index < 0 or not self.renderbuffers[renderbuffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var renderbuffer = self.renderbuffers[renderbuffer_index]
        renderbuffer.valid = false
        renderbuffer.initialized = false
        self.renderbuffers[renderbuffer_index] = renderbuffer
        if self.bound_renderbuffer == renderbuffer_id:
            self.bound_renderbuffer = -1
        self.clear_framebuffer_renderbuffer_references(renderbuffer_id)
        true

    me create_shader(shader_type: i32) -> WebGLShaderHandle:
        if not self.ensure_context_available():
            return WebGLShaderHandle(id: -1, shader_type: shader_type, source: "", compiled: false, valid: false, info_log: "context lost")
        if shader_type != WEBGL_VERTEX_SHADER and shader_type != WEBGL_FRAGMENT_SHADER:
            self.last_error = WEBGL_INVALID_ENUM
            return WebGLShaderHandle(id: -1, shader_type: shader_type, source: "", compiled: false, valid: false, info_log: "invalid shader type")
        val handle = WebGLShaderHandle(id: self.next_shader_id, shader_type: shader_type, source: "", compiled: false, valid: true, info_log: "")
        self.next_shader_id = self.next_shader_id + 1
        self.shaders.push(handle)
        handle

    me delete_shader(shader_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if shader_id == -1:
            return true
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0 or not self.shaders[shader_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var shader = self.shaders[shader_index]
        shader.valid = false
        shader.compiled = false
        self.shaders[shader_index] = shader
        true

    me shader_source(shader_id: i32, source: text) -> bool:
        if not self.ensure_context_available():
            return false
        var i = 0
        while i < self.shaders.len():
            if self.shaders[i].id == shader_id:
                if not self.shaders[i].valid:
                    self.last_error = WEBGL_INVALID_VALUE
                    return false
                var shader = self.shaders[i]
                shader.source = source
                shader.compiled = false
                shader.info_log = ""
                self.shaders[i] = shader
                return true
            i = i + 1
        self.last_error = WEBGL_INVALID_VALUE
        false

    me get_shader_source(shader_id: i32) -> text:
        if not self.ensure_context_available():
            return ""
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0 or not self.shaders[shader_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return ""
        self.shaders[shader_index].source

    me compile_shader(shader_id: i32) -> WebGLShaderHandle:
        if not self.ensure_context_available():
            return WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "context lost")
        var i = 0
        while i < self.shaders.len():
            if self.shaders[i].id == shader_id:
                if not self.shaders[i].valid:
                    self.last_error = WEBGL_INVALID_VALUE
                    return WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "shader deleted")
                var shader = self.shaders[i]
                val err = webgl_validate_shader_source_for_version(shader.shader_type, shader.source, self.version)
                shader.compiled = err == ""
                shader.info_log = err
                self.shaders[i] = shader
                if err != "":
                    self.last_error = WEBGL_INVALID_OPERATION
                return shader
            i = i + 1
        self.last_error = WEBGL_INVALID_VALUE
        WebGLShaderHandle(id: -1, shader_type: 0, source: "", compiled: false, valid: false, info_log: "shader not found")

    me is_shader(shader_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val shader_index = self.find_shader_index(shader_id)
        shader_index >= 0 and self.shaders[shader_index].valid

    me create_program() -> WebGLProgramHandle:
        if not self.ensure_context_available():
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "context lost", active_attribs: [], active_uniforms: [], validate_status: false)
        val handle = WebGLProgramHandle(id: self.next_program_id, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: true, info_log: "", active_attribs: [], active_uniforms: [], validate_status: false)
        self.next_program_id = self.next_program_id + 1
        self.programs.push(handle)
        handle

    me delete_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if program_id == -1:
            return true
        val program_index = self.find_program_index(program_id)
        if program_index < 0 or not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var program = self.programs[program_index]
        program.valid = false
        program.linked = false
        program.validate_status = false
        self.programs[program_index] = program
        if self.current_program_id == program_id:
            self.current_program_id = -1
        self.remove_uniform_values_for_program(program_id)
        true

    me is_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val program_index = self.find_program_index(program_id)
        program_index >= 0 and self.programs[program_index].valid

    me attach_shader(program_id: i32, shader_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val shader_index = self.find_shader_index(shader_id)
        val program_index = self.find_program_index(program_id)
        if shader_index < 0 or program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if not self.shaders[shader_index].valid or not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var program = self.programs[program_index]
        val shader = self.shaders[shader_index]
        if shader.shader_type == WEBGL_VERTEX_SHADER:
            program.vertex_shader_id = shader_id
        if shader.shader_type == WEBGL_FRAGMENT_SHADER:
            program.fragment_shader_id = shader_id
        self.programs[program_index] = program
        true

    me detach_shader(program_id: i32, shader_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val shader_index = self.find_shader_index(shader_id)
        val program_index = self.find_program_index(program_id)
        if shader_index < 0 or program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var program = self.programs[program_index]
        val shader = self.shaders[shader_index]
        if shader.shader_type == WEBGL_VERTEX_SHADER and program.vertex_shader_id == shader_id:
            program.vertex_shader_id = -1
            self.programs[program_index] = program
            return true
        if shader.shader_type == WEBGL_FRAGMENT_SHADER and program.fragment_shader_id == shader_id:
            program.fragment_shader_id = -1
            self.programs[program_index] = program
            return true
        self.last_error = WEBGL_INVALID_OPERATION
        false

    me link_program(program_id: i32) -> WebGLProgramHandle:
        if not self.ensure_context_available():
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "context lost", active_attribs: [], active_uniforms: [], validate_status: false)
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "program not found", active_attribs: [], active_uniforms: [], validate_status: false)
        var program = self.programs[program_index]
        if not program.valid:
            self.last_error = WEBGL_INVALID_VALUE
            return WebGLProgramHandle(id: -1, vertex_shader_id: -1, fragment_shader_id: -1, linked: false, valid: false, info_log: "program deleted", active_attribs: [], active_uniforms: [], validate_status: false)
        val vertex_ok = self.shader_compiled(program.vertex_shader_id, WEBGL_VERTEX_SHADER)
        val fragment_ok = self.shader_compiled(program.fragment_shader_id, WEBGL_FRAGMENT_SHADER)
        if not vertex_ok or not fragment_ok:
            program.linked = false
            program.info_log = "compiled vertex and fragment shaders required"
            program.active_attribs = []
            program.active_uniforms = []
            program.validate_status = false
            self.last_error = WEBGL_INVALID_OPERATION
        else:
            program.linked = true
            program.info_log = ""
            program.active_attribs = webgl_collect_active_attribs(self.shader_source_text(program.vertex_shader_id))
            program.active_uniforms = webgl_collect_active_uniforms(self.shader_source_text(program.vertex_shader_id), self.shader_source_text(program.fragment_shader_id))
            program.validate_status = true
        self.programs[program_index] = program
        program

    me validate_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val program_index = self.find_program_index(program_id)
        if program_index < 0 or not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var program = self.programs[program_index]
        if not program.linked:
            program.validate_status = false
            program.info_log = "linked program required"
            self.programs[program_index] = program
            return false
        val vertex_ok = self.shader_compiled(program.vertex_shader_id, WEBGL_VERTEX_SHADER)
        val fragment_ok = self.shader_compiled(program.fragment_shader_id, WEBGL_FRAGMENT_SHADER)
        program.validate_status = vertex_ok and fragment_ok
        if program.validate_status:
            program.info_log = ""
        else:
            program.info_log = "compiled vertex and fragment shaders required"
        self.programs[program_index] = program
        program.validate_status

    me get_shader_parameter(shader_id: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_bool(false)
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_bool(false)
        val shader = self.shaders[shader_index]
        if pname == WEBGL_COMPILE_STATUS:
            return webgl_parameter_bool(shader.compiled)
        if pname == WEBGL_DELETE_STATUS:
            return webgl_parameter_bool(not shader.valid)
        if pname == WEBGL_SHADER_TYPE:
            return webgl_parameter_int(shader.shader_type)
        if pname == WEBGL_INFO_LOG_LENGTH:
            return webgl_parameter_int(shader.info_log.len())
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_bool(false)

    me get_shader_info_log(shader_id: i32) -> text:
        if not self.ensure_context_available():
            return ""
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return ""
        self.shaders[shader_index].info_log

    me get_shader_precision_format(shader_type: i32, precision_type: i32) -> WebGLShaderPrecisionFormat:
        if not self.ensure_context_available():
            return webgl_shader_precision_format_invalid("context lost")
        if shader_type != WEBGL_VERTEX_SHADER and shader_type != WEBGL_FRAGMENT_SHADER:
            self.last_error = WEBGL_INVALID_ENUM
            return webgl_shader_precision_format_invalid("invalid shader type")
        if not webgl_valid_shader_precision_type(precision_type):
            self.last_error = WEBGL_INVALID_ENUM
            return webgl_shader_precision_format_invalid("invalid precision type")
        webgl_shader_precision_format_for(precision_type)

    me get_program_parameter(program_id: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_bool(false)
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_bool(false)
        val program = self.programs[program_index]
        if pname == WEBGL_LINK_STATUS:
            return webgl_parameter_bool(program.linked)
        if pname == WEBGL_VALIDATE_STATUS:
            return webgl_parameter_bool(program.validate_status)
        if pname == WEBGL_DELETE_STATUS:
            return webgl_parameter_bool(not program.valid)
        if pname == WEBGL_INFO_LOG_LENGTH:
            return webgl_parameter_int(program.info_log.len())
        if pname == WEBGL_ATTACHED_SHADERS:
            return webgl_parameter_int(webgl_attached_shader_count(program))
        if pname == WEBGL_ACTIVE_UNIFORMS:
            return webgl_parameter_int(program.active_uniforms.len())
        if pname == WEBGL_ACTIVE_ATTRIBUTES:
            return webgl_parameter_int(program.active_attribs.len())
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_bool(false)

    me get_program_info_log(program_id: i32) -> text:
        if not self.ensure_context_available():
            return ""
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return ""
        self.programs[program_index].info_log

    me get_attached_shaders(program_id: i32) -> [WebGLShaderHandle]:
        if not self.ensure_context_available():
            return []
        val program_index = self.find_program_index(program_id)
        if program_index < 0 or not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return []
        var attached: [WebGLShaderHandle] = []
        val program = self.programs[program_index]
        val vertex_index = self.find_shader_index(program.vertex_shader_id)
        if vertex_index >= 0:
            attached.push(self.shaders[vertex_index])
        val fragment_index = self.find_shader_index(program.fragment_shader_id)
        if fragment_index >= 0:
            attached.push(self.shaders[fragment_index])
        attached

    me get_attrib_location(program_id: i32, name: text) -> i32:
        if not self.ensure_context_available():
            return -1
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        var i = 0
        while i < program.active_attribs.len():
            if program.active_attribs[i].name == name:
                return program.active_attribs[i].location
            i = i + 1
        -1

    me get_active_attrib(program_id: i32, index: i32) -> WebGLActiveInfo:
        if not self.ensure_context_available():
            return webgl_empty_active_info()
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if index < 0 or index >= program.active_attribs.len():
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        program.active_attribs[index]

    me get_uniform_location(program_id: i32, name: text) -> i32:
        if not self.ensure_context_available():
            return -1
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        var i = 0
        while i < program.active_uniforms.len():
            if program.active_uniforms[i].name == name:
                return program.active_uniforms[i].location
            i = i + 1
        -1

    me get_active_uniform(program_id: i32, index: i32) -> WebGLActiveInfo:
        if not self.ensure_context_available():
            return webgl_empty_active_info()
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if index < 0 or index >= program.active_uniforms.len():
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        program.active_uniforms[index]

    me use_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        if not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if not self.programs[program_index].linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.current_program_id = program_id
        self.render_commands.push(webgl_render_command_use_program(program_id))
        true

    me uniform_1i(location: i32, value: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val info = self.current_program_uniform(location)
        if location < 0:
            return true
        if info.location < 0:
            return false
        if info.data_type != WEBGL_SAMPLER_2D:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.set_uniform_value(WebGLUniformValue(program_id: self.current_program_id, location: location, data_type: info.data_type, int_value: value, float_values: []))
        true

    me uniform_1f(location: i32, value: f64) -> bool:
        if not self.ensure_context_available():
            return false
        val info = self.current_program_uniform(location)
        if location < 0:
            return true
        if info.location < 0:
            return false
        if info.data_type != WEBGL_FLOAT:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.set_uniform_value(WebGLUniformValue(program_id: self.current_program_id, location: location, data_type: info.data_type, int_value: 0, float_values: [value]))
        true

    me uniform_4f(location: i32, x: f64, y: f64, z: f64, w: f64) -> bool:
        if not self.ensure_context_available():
            return false
        val info = self.current_program_uniform(location)
        if location < 0:
            return true
        if info.location < 0:
            return false
        if info.data_type != WEBGL_FLOAT_VEC4:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.set_uniform_value(WebGLUniformValue(program_id: self.current_program_id, location: location, data_type: info.data_type, int_value: 0, float_values: [x, y, z, w]))
        true

    me uniform_matrix4fv(location: i32, transpose: bool, values: [f64]) -> bool:
        if not self.ensure_context_available():
            return false
        if transpose:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        val info = self.current_program_uniform(location)
        if location < 0:
            return true
        if info.location < 0:
            return false
        if info.data_type != WEBGL_FLOAT_MAT4:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        if values.len() != 16:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.set_uniform_value(WebGLUniformValue(program_id: self.current_program_id, location: location, data_type: info.data_type, int_value: 0, float_values: webgl_copy_f64(values)))
        true

    me supports_extension(name: text) -> bool:
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "":
            return false
        var i = 0
        while i < self.supported_extensions.len():
            if self.supported_extensions[i] == canonical:
                return true
            i = i + 1
        false

    me is_extension_enabled(name: text) -> bool:
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "":
            return false
        webgl_text_list_contains(self.enabled_extensions, canonical)

    me get_extension(name: text) -> WebGLExtensionHandle:
        if not self.ensure_context_available():
            return WebGLExtensionHandle(name: webgl_canonical_extension_name(name), valid: false, enabled: false, error: "context lost")
        val canonical = webgl_canonical_extension_name(name)
        if canonical == "" or not self.supports_extension(canonical):
            return WebGLExtensionHandle(name: canonical, valid: false, enabled: false, error: "extension not supported")
        if not webgl_text_list_contains(self.enabled_extensions, canonical):
            self.enabled_extensions.push(canonical)
        WebGLExtensionHandle(name: canonical, valid: true, enabled: true, error: "")

    me active_texture(texture: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val unit_index = texture - WEBGL_TEXTURE0
        if unit_index < 0 or unit_index >= WEBGL_MAX_COMBINED_TEXTURE_IMAGE_UNITS:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.active_texture_unit = unit_index
        self.bound_texture_2d = self.texture_units[unit_index].texture_2d_id
        self.render_commands.push(webgl_render_command_active_texture(texture))
        true

    me bind_texture(target: i32, texture_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if texture_id == -1:
            self.bound_texture_2d = -1
            var texture_unit = self.texture_units[self.active_texture_unit]
            texture_unit.texture_2d_id = -1
            self.texture_units[self.active_texture_unit] = texture_unit
            return true
        val texture_index = self.find_texture_index(texture_id)
        if texture_index < 0 or not self.textures[texture_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var texture = self.textures[texture_index]
        texture.target = target
        self.textures[texture_index] = texture
        self.bound_texture_2d = texture_id
        var texture_unit = self.texture_units[self.active_texture_unit]
        texture_unit.texture_2d_id = texture_id
        self.texture_units[self.active_texture_unit] = texture_unit
        self.render_commands.push(webgl_render_command_bind_texture(target, texture_id))
        true

    me bind_framebuffer(target: i32, framebuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_FRAMEBUFFER:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if framebuffer_id == -1:
            self.bound_framebuffer = -1
            return true
        val framebuffer_index = self.find_framebuffer_index(framebuffer_id)
        if framebuffer_index < 0 or not self.framebuffers[framebuffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.bound_framebuffer = framebuffer_id
        true

    me bind_renderbuffer(target: i32, renderbuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_RENDERBUFFER:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if renderbuffer_id == -1:
            self.bound_renderbuffer = -1
            return true
        val renderbuffer_index = self.find_renderbuffer_index(renderbuffer_id)
        if renderbuffer_index < 0 or not self.renderbuffers[renderbuffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.bound_renderbuffer = renderbuffer_id
        true

    me renderbuffer_storage(target: i32, internal_format: i32, width: i32, height: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_RENDERBUFFER:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if width < 0 or height < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if not webgl_valid_renderbuffer_format(internal_format):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        val renderbuffer_index = self.bound_renderbuffer_index_for_target(target)
        if renderbuffer_index < 0:
            return false
        var renderbuffer = self.renderbuffers[renderbuffer_index]
        renderbuffer.internal_format = internal_format
        renderbuffer.width = width
        renderbuffer.height = height
        renderbuffer.initialized = true
        self.renderbuffers[renderbuffer_index] = renderbuffer
        true

    me get_renderbuffer_parameter(target: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_int(0)
        val renderbuffer_index = self.bound_renderbuffer_index_for_target(target)
        if renderbuffer_index < 0:
            return webgl_parameter_int(0)
        val renderbuffer = self.renderbuffers[renderbuffer_index]
        if pname == WEBGL_RENDERBUFFER_WIDTH:
            return webgl_parameter_int(renderbuffer.width)
        if pname == WEBGL_RENDERBUFFER_HEIGHT:
            return webgl_parameter_int(renderbuffer.height)
        if pname == WEBGL_RENDERBUFFER_INTERNAL_FORMAT:
            return webgl_parameter_int(renderbuffer.internal_format)
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_int(0)

    me framebuffer_texture_2d(target: i32, attachment: i32, textarget: i32, texture_id: i32, level: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val framebuffer_index = self.bound_framebuffer_index_for_target(target)
        if framebuffer_index < 0:
            return false
        if attachment != WEBGL_COLOR_ATTACHMENT0 or textarget != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if level != 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var framebuffer = self.framebuffers[framebuffer_index]
        if texture_id == -1:
            framebuffer.color_texture_id = -1
            self.framebuffers[framebuffer_index] = framebuffer
            return true
        val texture_index = self.find_texture_index(texture_id)
        if texture_index < 0 or not self.textures[texture_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if self.textures[texture_index].target != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        framebuffer.color_texture_id = texture_id
        framebuffer.color_renderbuffer_id = -1
        self.framebuffers[framebuffer_index] = framebuffer
        true

    me framebuffer_renderbuffer(target: i32, attachment: i32, renderbuffertarget: i32, renderbuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val framebuffer_index = self.bound_framebuffer_index_for_target(target)
        if framebuffer_index < 0:
            return false
        if renderbuffertarget != WEBGL_RENDERBUFFER or not webgl_valid_renderbuffer_attachment(attachment):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        var framebuffer = self.framebuffers[framebuffer_index]
        if renderbuffer_id == -1:
            framebuffer = webgl_clear_renderbuffer_attachment(framebuffer, attachment)
            self.framebuffers[framebuffer_index] = framebuffer
            return true
        val renderbuffer_index = self.find_renderbuffer_index(renderbuffer_id)
        if renderbuffer_index < 0 or not self.renderbuffers[renderbuffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        framebuffer = webgl_set_renderbuffer_attachment(framebuffer, attachment, renderbuffer_id)
        self.framebuffers[framebuffer_index] = framebuffer
        true

    me get_framebuffer_attachment_parameter(target: i32, attachment: i32, pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_int(0)
        val framebuffer_index = self.bound_framebuffer_index_for_target(target)
        if framebuffer_index < 0:
            return webgl_parameter_int(0)
        if not webgl_valid_renderbuffer_attachment(attachment):
            self.last_error = WEBGL_INVALID_ENUM
            return webgl_parameter_int(0)
        val framebuffer = self.framebuffers[framebuffer_index]
        val object_type = webgl_framebuffer_attachment_object_type(framebuffer, attachment)
