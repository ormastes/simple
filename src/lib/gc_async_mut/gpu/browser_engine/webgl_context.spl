    me stencil_mask_separate(face: i32, mask: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if face != WEBGL_FRONT and face != WEBGL_BACK and face != WEBGL_FRONT_AND_BACK:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if face == WEBGL_FRONT or face == WEBGL_FRONT_AND_BACK:
            self.stencil_write_mask_value = mask
        if face == WEBGL_BACK or face == WEBGL_FRONT_AND_BACK:
            self.stencil_back_write_mask_value = mask
        self.render_commands.push(webgl_render_command_stencil_mask_separate(face, mask))
        true

    me create_buffer() -> WebGLBufferHandle:
        if not self.ensure_context_available():
            return WebGLBufferHandle(id: -1, valid: false, error: "context lost", target: 0, byte_length: 0, usage: 0, initialized: false)
        val handle = WebGLBufferHandle(id: self.next_buffer_id, valid: true, error: "", target: 0, byte_length: 0, usage: 0, initialized: false)
        self.next_buffer_id = self.next_buffer_id + 1
        self.buffers.push(handle)
        handle

    me create_texture() -> WebGLTextureHandle:
        if not self.ensure_context_available():
            return webgl_invalid_texture_handle("context lost")
        val handle = webgl_default_texture_handle(self.next_texture_id, true, "")
        self.next_texture_id = self.next_texture_id + 1
        self.textures.push(handle)
        handle

    me create_framebuffer() -> WebGLFramebufferHandle:
        if not self.ensure_context_available():
            return webgl_default_framebuffer_handle(-1, false, "context lost")
        val handle = webgl_default_framebuffer_handle(self.next_framebuffer_id, true, "")
        self.next_framebuffer_id = self.next_framebuffer_id + 1
        self.framebuffers.push(handle)
        handle

    me create_renderbuffer() -> WebGLRenderbufferHandle:
        if not self.ensure_context_available():
            return WebGLRenderbufferHandle(id: -1, valid: false, error: "context lost", internal_format: 0, width: 0, height: 0, initialized: false)
        val handle = WebGLRenderbufferHandle(id: self.next_renderbuffer_id, valid: true, error: "", internal_format: 0, width: 0, height: 0, initialized: false)
        self.next_renderbuffer_id = self.next_renderbuffer_id + 1
        self.renderbuffers.push(handle)
        handle

    me is_buffer(buffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val buffer_index = self.find_buffer_index(buffer_id)
        buffer_index >= 0 and self.buffers[buffer_index].valid

    me is_texture(texture_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val texture_index = self.find_texture_index(texture_id)
        texture_index >= 0 and self.textures[texture_index].valid

    me is_framebuffer(framebuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val framebuffer_index = self.find_framebuffer_index(framebuffer_id)
        framebuffer_index >= 0 and self.framebuffers[framebuffer_index].valid

    me is_renderbuffer(renderbuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val renderbuffer_index = self.find_renderbuffer_index(renderbuffer_id)
        renderbuffer_index >= 0 and self.renderbuffers[renderbuffer_index].valid

    me delete_buffer(buffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if buffer_id == -1:
            return true
        val buffer_index = self.find_buffer_index(buffer_id)
        if buffer_index < 0 or not self.buffers[buffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var buffer = self.buffers[buffer_index]
        buffer.valid = false
        buffer.initialized = false
        self.buffers[buffer_index] = buffer
        if self.bound_array_buffer == buffer_id:
            self.bound_array_buffer = -1
        if self.bound_element_array_buffer == buffer_id:
            self.bound_element_array_buffer = -1
        self.clear_vertex_attrib_buffer_references(buffer_id)
        true

    me delete_texture(texture_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if texture_id == -1:
            return true
        val texture_index = self.find_texture_index(texture_id)
        if texture_index < 0 or not self.textures[texture_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var texture = self.textures[texture_index]
        texture.valid = false
        texture.initialized = false
        self.textures[texture_index] = texture
        if self.bound_texture_2d == texture_id:
            self.bound_texture_2d = -1
        self.clear_texture_unit_references(texture_id)
        self.clear_framebuffer_texture_references(texture_id)
        true

    me delete_framebuffer(framebuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if framebuffer_id == -1:
            return true
        val framebuffer_index = self.find_framebuffer_index(framebuffer_id)
        if framebuffer_index < 0 or not self.framebuffers[framebuffer_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        var framebuffer = self.framebuffers[framebuffer_index]
        framebuffer.valid = false
        self.framebuffers[framebuffer_index] = framebuffer
        if self.bound_framebuffer == framebuffer_id:
            self.bound_framebuffer = -1
        true

    me delete_renderbuffer(renderbuffer_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if renderbuffer_id == -1:
