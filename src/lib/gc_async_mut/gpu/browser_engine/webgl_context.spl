    me current_program_uniform(location: i32) -> WebGLActiveInfo:
        if self.current_program_id < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if location < 0:
            return webgl_empty_active_info()
        val program_index = self.find_program_index(self.current_program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        if not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_empty_active_info()
        if not self.programs[program_index].linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_empty_active_info()
        val program = self.programs[program_index]
        var i = 0
        while i < program.active_uniforms.len():
            if program.active_uniforms[i].location == location:
                return program.active_uniforms[i]
            i = i + 1
        self.last_error = WEBGL_INVALID_OPERATION
        webgl_empty_active_info()

    me set_uniform_value(value: WebGLUniformValue):
        var i = 0
        while i < self.uniform_values.len():
            if self.uniform_values[i].program_id == value.program_id and self.uniform_values[i].location == value.location:
                self.uniform_values[i] = value
                return
            i = i + 1
        self.uniform_values.push(value)

    me remove_uniform_values_for_program(program_id: i32):
        var kept: [WebGLUniformValue] = []
        var i = 0
        while i < self.uniform_values.len():
            if self.uniform_values[i].program_id != program_id:
                kept.push(self.uniform_values[i])
            i = i + 1
        self.uniform_values = kept

    me bound_texture_index_for_upload(target: i32) -> i32:
        if target != WEBGL_TEXTURE_2D:
            self.last_error = WEBGL_INVALID_ENUM
            return -1
        if self.bound_texture_2d < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        val texture_index = self.find_texture_index(self.bound_texture_2d)
        if texture_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        texture_index

    me validate_texture_image_args(level: i32, internal_format: i32, width: i32, height: i32, border: i32, format: i32, pixel_type: i32) -> bool:
        if level != 0 or width < 0 or height < 0 or border != 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if internal_format != format or webgl_texture_format_bytes(format) == 0 or pixel_type != WEBGL_UNSIGNED_BYTE:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        true

    fn find_program_index(program_id: i32) -> i32:
        var i = 0
        while i < self.programs.len():
            if self.programs[i].id == program_id:
                return i
            i = i + 1
        -1

    fn shader_compiled(shader_id: i32, shader_type: i32) -> bool:
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            return false
        self.shaders[shader_index].valid and self.shaders[shader_index].shader_type == shader_type and self.shaders[shader_index].compiled

    fn shader_source_text(shader_id: i32) -> text:
        val shader_index = self.find_shader_index(shader_id)
        if shader_index < 0:
            return ""
        if not self.shaders[shader_index].valid:
            return ""
        self.shaders[shader_index].source

    me clear_vertex_attrib_buffer_references(buffer_id: i32):
        var i = 0
        while i < self.vertex_attribs.len():
            if self.vertex_attribs[i].buffer_id == buffer_id:
                var attrib = self.vertex_attribs[i]
                attrib.buffer_id = -1
                self.vertex_attribs[i] = attrib
            i = i + 1

    me clear_texture_unit_references(texture_id: i32):
        var i = 0
        while i < self.texture_units.len():
            if self.texture_units[i].texture_2d_id == texture_id:
                var texture_unit = self.texture_units[i]
                texture_unit.texture_2d_id = -1
                self.texture_units[i] = texture_unit
            i = i + 1

    me clear_framebuffer_texture_references(texture_id: i32):
        var i = 0
        while i < self.framebuffers.len():
            if self.framebuffers[i].color_texture_id == texture_id:
                var framebuffer = self.framebuffers[i]
                framebuffer.color_texture_id = -1
                self.framebuffers[i] = framebuffer
            i = i + 1

    me clear_framebuffer_renderbuffer_references(renderbuffer_id: i32):
        var i = 0
        while i < self.framebuffers.len():
            var framebuffer = self.framebuffers[i]
            if framebuffer.color_renderbuffer_id == renderbuffer_id:
                framebuffer.color_renderbuffer_id = -1
            if framebuffer.depth_renderbuffer_id == renderbuffer_id:
                framebuffer.depth_renderbuffer_id = -1
            if framebuffer.stencil_renderbuffer_id == renderbuffer_id:
                framebuffer.stencil_renderbuffer_id = -1
            if framebuffer.depth_stencil_renderbuffer_id == renderbuffer_id:
                framebuffer.depth_stencil_renderbuffer_id = -1
            self.framebuffers[i] = framebuffer
            i = i + 1

pub fn webgl_default_context_attributes() -> WebGLContextAttributes:
    WebGLContextAttributes(
        alpha: true,
        depth: true,
        stencil: false,
        antialias: true,
        premultiplied_alpha: true,
        preserve_drawing_buffer: false,
        power_preference: "default",
        fail_if_major_performance_caveat: false,
        valid: true,
        error: ""
    )

pub fn webgl_invalid_context_attributes(error: text) -> WebGLContextAttributes:
    WebGLContextAttributes(
        alpha: false,
        depth: false,
        stencil: false,
        antialias: false,
        premultiplied_alpha: false,
        preserve_drawing_buffer: false,
        power_preference: "",
        fail_if_major_performance_caveat: false,
        valid: false,
        error: error
    )

pub fn webgl_create_context(version: i32, width: i32, height: i32) -> WebGLContext:
    val actual_version = if version == 2: 2 else: 1
    WebGLContext(
        version: actual_version,
        context_name: if actual_version == 2: "webgl2" else: "webgl",
        context_lost: false,
        last_error: WEBGL_NO_ERROR,
        width: width,
        height: height,
        next_buffer_id: 1,
        next_texture_id: 1,
        next_framebuffer_id: 1,
        next_renderbuffer_id: 1,
        next_shader_id: 1,
        next_program_id: 1,
        buffers: [],
        textures: [],
        framebuffers: [],
        renderbuffers: [],
        shaders: [],
        programs: [],
        current_program_id: -1,
        supported_extensions: webgl_default_extensions(actual_version),
        enabled_extensions: [],
        uniform_values: [],
        bound_array_buffer: -1,
        bound_element_array_buffer: -1,
        vertex_attribs: webgl_default_vertex_attribs(),
        bound_framebuffer: -1,
        bound_renderbuffer: -1,
        active_texture_unit: 0,
        texture_units: webgl_default_texture_units(),
        bound_texture_2d: -1,
        pack_alignment: 4,
        unpack_alignment: 4,
        unpack_flip_y: false,
        unpack_premultiply_alpha: false,
        unpack_colorspace_conversion: WEBGL_BROWSER_DEFAULT_WEBGL,
        viewport_x: 0,
        viewport_y: 0,
        viewport_width: width,
        viewport_height: height,
        clear_red: 0.0,
        clear_green: 0.0,
        clear_blue: 0.0,
        clear_alpha: 0.0,
        line_width_value: 1.0,
        clear_depth_value: 1.0,
        depth_range_near: 0.0,
        depth_range_far: 1.0,
        clear_stencil_value: 0,
        blend_enabled: false,
        depth_test_enabled: false,
        dither_enabled: true,
        polygon_offset_fill_enabled: false,
        sample_alpha_to_coverage_enabled: false,
        sample_coverage_enabled: false,
        cull_face_enabled: false,
        scissor_test_enabled: false,
        stencil_test_enabled: false,
        depth_func_value: WEBGL_LESS,
        stencil_func_value: WEBGL_ALWAYS,
        stencil_ref_value: 0,
        stencil_value_mask: -1,
        stencil_fail_op: WEBGL_KEEP,
        stencil_zfail_op: WEBGL_KEEP,
        stencil_zpass_op: WEBGL_KEEP,
        cull_face_mode: WEBGL_BACK,
        front_face_mode: WEBGL_CCW,
        polygon_offset_factor: 0.0,
        polygon_offset_units: 0.0,
        sample_coverage_value: 1.0,
        sample_coverage_invert: false,
        blend_color_red: 0.0,
        blend_color_green: 0.0,
        blend_color_blue: 0.0,
        blend_color_alpha: 0.0,
        blend_src_factor: WEBGL_ONE,
        blend_dst_factor: WEBGL_ZERO,
        blend_src_alpha_factor: WEBGL_ONE,
        blend_dst_alpha_factor: WEBGL_ZERO,
        blend_equation_rgb: WEBGL_FUNC_ADD,
        blend_equation_alpha: WEBGL_FUNC_ADD,
        scissor_x: 0,
        scissor_y: 0,
        scissor_width: width,
        scissor_height: height,
        color_mask_red: true,
        color_mask_green: true,
        color_mask_blue: true,
        color_mask_alpha: true,
        depth_mask_enabled: true,
        stencil_write_mask_value: -1,
        stencil_back_write_mask_value: -1,
        draw_call_count: 0,
        indexed_draw_call_count: 0,
        last_draw_mode: 0,
        last_draw_count: 0,
        render_commands: []
    )

pub fn webgl_is_supported_context_name(name: text) -> bool:
    val lower = name.lower()
    lower == "webgl" or lower == "experimental-webgl" or lower == "webgl2"

pub fn webgl_context_version_for_name(name: text) -> i32:
    val lower = name.lower()
    if lower == "webgl2":
        return 2
    if lower == "webgl" or lower == "experimental-webgl":
        return 1
    0

pub fn webgl_validate_shader_source(shader_type: i32, source: text) -> text:
    webgl_validate_shader_source_for_version(shader_type, source, 2)

pub fn webgl_validate_shader_source_for_version(shader_type: i32, source: text, version: i32) -> text:
    val trimmed = source.trim()
    if trimmed == "":
        return "shader source is empty"
    if version < 2 and trimmed.starts_with("#version 300 es"):
        return "GLSL ES 3.00 shaders require WebGL2"
    if not trimmed.contains("void main"):
        return "shader must define void main"
    if shader_type == WEBGL_VERTEX_SHADER and not trimmed.contains("gl_Position"):
        return "vertex shader must write gl_Position"
    if shader_type == WEBGL_FRAGMENT_SHADER and not (trimmed.contains("gl_FragColor") or trimmed.contains("out ")):
        return "fragment shader must write a color output"
    ""

pub fn webgl_parameter_bool(value: bool) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "bool", bool_value: value, bool_values: [], int_value: 0, int_values: [], float_value: 0.0, float_values: [], text_value: "")

pub fn webgl_parameter_bool_list(values: [bool]) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "bool-list", bool_value: false, bool_values: values, int_value: 0, int_values: [], float_value: 0.0, float_values: [], text_value: "")

pub fn webgl_parameter_int(value: i32) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "int", bool_value: false, bool_values: [], int_value: value, int_values: [], float_value: 0.0, float_values: [], text_value: "")

pub fn webgl_parameter_int_list(values: [i32]) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "int-list", bool_value: false, bool_values: [], int_value: 0, int_values: values, float_value: 0.0, float_values: [], text_value: "")

pub fn webgl_parameter_float(value: f64) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "float", bool_value: false, bool_values: [], int_value: 0, int_values: [], float_value: value, float_values: [], text_value: "")

pub fn webgl_parameter_float_list(values: [f64]) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "float-list", bool_value: false, bool_values: [], int_value: 0, int_values: [], float_value: 0.0, float_values: values, text_value: "")

pub fn webgl_parameter_text(value: text) -> WebGLParameterValue:
    WebGLParameterValue(value_kind: "text", bool_value: false, bool_values: [], int_value: 0, int_values: [], float_value: 0.0, float_values: [], text_value: value)

pub fn webgl_empty_active_info() -> WebGLActiveInfo:
    WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)

pub fn webgl_invalid_texture_handle(error: text) -> WebGLTextureHandle:
    webgl_default_texture_handle(-1, false, error)

pub fn webgl_default_texture_handle(id: i32, valid: bool, error: text) -> WebGLTextureHandle:
    WebGLTextureHandle(id: id, valid: valid, error: error, target: 0, width: 0, height: 0, level: 0, internal_format: 0, format: 0, pixel_type: 0, initialized: false, min_filter: WEBGL_LINEAR_MIPMAP_LINEAR, mag_filter: WEBGL_LINEAR, wrap_s: WEBGL_REPEAT, wrap_t: WEBGL_REPEAT, mipmap_generated: false, pixels: [])

pub fn webgl_default_framebuffer_handle(id: i32, valid: bool, error: text) -> WebGLFramebufferHandle:
    WebGLFramebufferHandle(id: id, valid: valid, error: error, color_texture_id: -1, color_renderbuffer_id: -1, depth_renderbuffer_id: -1, stencil_renderbuffer_id: -1, depth_stencil_renderbuffer_id: -1)

pub fn webgl_attached_shader_count(program: WebGLProgramHandle) -> i32:
    var count = 0
    if program.vertex_shader_id >= 0:
        count = count + 1
    if program.fragment_shader_id >= 0:
        count = count + 1
    count

pub fn webgl_collect_active_attribs(vertex_source: text) -> [WebGLActiveInfo]:
    var active: [WebGLActiveInfo] = []
    val normalized_source = vertex_source.replace("\n", " ")
    val statements = normalized_source.split(";")
    var i = 0
    while i < statements.len():
        val declaration = statements[i].trim()
        if declaration.starts_with("attribute "):
            val info = webgl_active_info_from_declaration(declaration, "attribute", active.len())
            if info.name != "":
                active.push(info)
        i = i + 1
    active

pub fn webgl_collect_active_uniforms(vertex_source: text, fragment_source: text) -> [WebGLActiveInfo]:
    var active: [WebGLActiveInfo] = []
    active = webgl_collect_uniforms_from_source(vertex_source, active)
    webgl_collect_uniforms_from_source(fragment_source, active)

pub fn webgl_collect_uniforms_from_source(source: text, active: [WebGLActiveInfo]) -> [WebGLActiveInfo]:
    var result = active
    val normalized_source = source.replace("\n", " ")
    val statements = normalized_source.split(";")
    var i = 0
    while i < statements.len():
        val declaration = statements[i].trim()
        if declaration.starts_with("uniform "):
            val info = webgl_active_info_from_declaration(declaration, "uniform", result.len())
            if info.name != "" and not webgl_has_active_info(result, info.name):
                result.push(info)
        i = i + 1
    result

pub fn webgl_has_active_info(active: [WebGLActiveInfo], name: text) -> bool:
    var i = 0
    while i < active.len():
        if active[i].name == name:
            return true
        i = i + 1
    false

pub fn webgl_active_info_from_declaration(declaration: text, qualifier: text, location: i32) -> WebGLActiveInfo:
    val normalized = declaration.replace("\t", " ").trim()
    val parts = normalized.split(" ")
    var filtered: [text] = []
    var i = 0
    while i < parts.len():
        val token = parts[i].trim()
        if token != "":
            filtered.push(token)
        i = i + 1
    if filtered.len() < 3:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    if filtered[0] != qualifier:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    val data_type = webgl_glsl_type_enum(filtered[1])
    if data_type == 0:
        return WebGLActiveInfo(name: "", size: 0, data_type: 0, location: -1)
    WebGLActiveInfo(name: webgl_clean_glsl_name(filtered[2]), size: 1, data_type: data_type, location: location)

pub fn webgl_glsl_type_enum(type_name: text) -> i32:
    if type_name == "float":
        return WEBGL_FLOAT
    if type_name == "vec2":
        return WEBGL_FLOAT_VEC2
    if type_name == "vec3":
        return WEBGL_FLOAT_VEC3
    if type_name == "vec4":
        return WEBGL_FLOAT_VEC4
    if type_name == "mat4":
        return WEBGL_FLOAT_MAT4
    if type_name == "sampler2D":
        return WEBGL_SAMPLER_2D
    0

pub fn webgl_clean_glsl_name(name: text) -> text:
    val parts = name.split("[")
    val without_array = parts[0]
    without_array.trim()

pub fn webgl_default_extensions(version: i32) -> [text]:
    val catalog = webgl_extension_catalog()
    var supported: [text] = []
    var i = 0
    while i < catalog.len():
        if version >= catalog[i].minimum_version:
            supported.push(catalog[i].name)
        i = i + 1
    supported

pub fn webgl_extension_catalog() -> [WebGLExtensionInfo]:
    [
        WebGLExtensionInfo(name: "OES_texture_float", minimum_version: 1),
        WebGLExtensionInfo(name: "OES_element_index_uint", minimum_version: 1),
        WebGLExtensionInfo(name: "WEBGL_lose_context", minimum_version: 1),
        WebGLExtensionInfo(name: "EXT_color_buffer_float", minimum_version: 2)
    ]

pub fn webgl_canonical_extension_name(name: text) -> text:
    val catalog = webgl_extension_catalog()
    var i = 0
    while i < catalog.len():
        if catalog[i].name == name:
            return catalog[i].name
        i = i + 1
    ""

pub fn webgl_text_list_contains(values: [text], needle: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

pub fn webgl_default_vertex_attribs() -> [WebGLVertexAttribState]:
    var attribs: [WebGLVertexAttribState] = []
    var i = 0
    while i < WEBGL_MAX_VERTEX_ATTRIBS:
        attribs.push(WebGLVertexAttribState(index: i, enabled: false, size: 4, data_type: WEBGL_FLOAT, normalized: false, stride: 0, offset: 0, buffer_id: -1))
        i = i + 1
    attribs

pub fn webgl_default_texture_units() -> [WebGLTextureUnitState]:
    var units: [WebGLTextureUnitState] = []
    var i = 0
    while i < WEBGL_MAX_COMBINED_TEXTURE_IMAGE_UNITS:
        units.push(WebGLTextureUnitState(unit: i, texture_2d_id: -1))
        i = i + 1
    units

pub fn webgl_valid_attrib_index(index: i32) -> bool:
    index >= 0 and index < WEBGL_MAX_VERTEX_ATTRIBS

pub fn webgl_valid_buffer_usage(usage: i32) -> bool:
    usage == WEBGL_STATIC_DRAW or usage == WEBGL_DYNAMIC_DRAW or usage == WEBGL_STREAM_DRAW

pub fn webgl_valid_draw_mode(mode: i32) -> bool:
    mode == WEBGL_TRIANGLES or mode == WEBGL_LINES or mode == WEBGL_POINTS

pub fn webgl_valid_clear_mask(mask: i32) -> bool:
    val allowed = WEBGL_COLOR_BUFFER_BIT + WEBGL_DEPTH_BUFFER_BIT + WEBGL_STENCIL_BUFFER_BIT
    mask != 0 and (mask & allowed) == mask

pub fn webgl_valid_depth_func(func: i32) -> bool:
    webgl_valid_stencil_func(func)

pub fn webgl_valid_stencil_func(func: i32) -> bool:
    func == WEBGL_NEVER or func == WEBGL_LESS or func == WEBGL_EQUAL or func == WEBGL_LEQUAL or func == WEBGL_GREATER or func == WEBGL_NOTEQUAL or func == WEBGL_GEQUAL or func == WEBGL_ALWAYS

pub fn webgl_valid_stencil_op(op: i32) -> bool:
    op == WEBGL_KEEP or op == WEBGL_ZERO or op == WEBGL_REPLACE or op == WEBGL_INCR or op == WEBGL_INCR_WRAP or op == WEBGL_DECR or op == WEBGL_DECR_WRAP or op == WEBGL_INVERT

pub fn webgl_valid_blend_factor(factor: i32) -> bool:
    factor == WEBGL_ZERO or factor == WEBGL_ONE or factor == WEBGL_SRC_ALPHA or factor == WEBGL_ONE_MINUS_SRC_ALPHA or factor == WEBGL_CONSTANT_COLOR or factor == WEBGL_ONE_MINUS_CONSTANT_COLOR or factor == WEBGL_CONSTANT_ALPHA or factor == WEBGL_ONE_MINUS_CONSTANT_ALPHA

pub fn webgl_valid_blend_equation(mode: i32) -> bool:
    mode == WEBGL_FUNC_ADD or mode == WEBGL_FUNC_SUBTRACT or mode == WEBGL_FUNC_REVERSE_SUBTRACT or mode == WEBGL_MIN or mode == WEBGL_MAX

pub fn webgl_valid_shader_precision_type(precision_type: i32) -> bool:
    precision_type == WEBGL_LOW_FLOAT or precision_type == WEBGL_MEDIUM_FLOAT or precision_type == WEBGL_HIGH_FLOAT or precision_type == WEBGL_LOW_INT or precision_type == WEBGL_MEDIUM_INT or precision_type == WEBGL_HIGH_INT

pub fn webgl_shader_precision_format_invalid(error: text) -> WebGLShaderPrecisionFormat:
    WebGLShaderPrecisionFormat(range_min: 0, range_max: 0, precision: 0, valid: false, error: error)

pub fn webgl_shader_precision_format_for(precision_type: i32) -> WebGLShaderPrecisionFormat:
    if precision_type == WEBGL_LOW_FLOAT:
        return WebGLShaderPrecisionFormat(range_min: 8, range_max: 8, precision: 8, valid: true, error: "")
    if precision_type == WEBGL_MEDIUM_FLOAT:
        return WebGLShaderPrecisionFormat(range_min: 14, range_max: 14, precision: 10, valid: true, error: "")
    if precision_type == WEBGL_HIGH_FLOAT:
        return WebGLShaderPrecisionFormat(range_min: 127, range_max: 127, precision: 23, valid: true, error: "")
    if precision_type == WEBGL_LOW_INT:
        return WebGLShaderPrecisionFormat(range_min: 8, range_max: 8, precision: 0, valid: true, error: "")
    if precision_type == WEBGL_MEDIUM_INT:
        return WebGLShaderPrecisionFormat(range_min: 16, range_max: 16, precision: 0, valid: true, error: "")
    if precision_type == WEBGL_HIGH_INT:
        return WebGLShaderPrecisionFormat(range_min: 31, range_max: 31, precision: 0, valid: true, error: "")
    webgl_shader_precision_format_invalid("invalid precision type")

pub fn webgl_valid_texture_min_filter(param: i32) -> bool:
    param == WEBGL_NEAREST or param == WEBGL_LINEAR or param == WEBGL_NEAREST_MIPMAP_NEAREST or param == WEBGL_LINEAR_MIPMAP_NEAREST or param == WEBGL_NEAREST_MIPMAP_LINEAR or param == WEBGL_LINEAR_MIPMAP_LINEAR

pub fn webgl_valid_texture_wrap(param: i32) -> bool:
    param == WEBGL_CLAMP_TO_EDGE or param == WEBGL_REPEAT or param == WEBGL_MIRRORED_REPEAT

pub fn webgl_valid_renderbuffer_format(format: i32) -> bool:
    format == WEBGL_RGBA4 or format == WEBGL_RGB565 or format == WEBGL_DEPTH_COMPONENT16 or format == WEBGL_STENCIL_INDEX8 or format == WEBGL_DEPTH_STENCIL

pub fn webgl_valid_renderbuffer_attachment(attachment: i32) -> bool:
    attachment == WEBGL_COLOR_ATTACHMENT0 or attachment == WEBGL_DEPTH_ATTACHMENT or attachment == WEBGL_STENCIL_ATTACHMENT or attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT

pub fn webgl_renderbuffer_format_matches_attachment(format: i32, attachment: i32) -> bool:
    if attachment == WEBGL_COLOR_ATTACHMENT0:
        return format == WEBGL_RGBA4 or format == WEBGL_RGB565
    if attachment == WEBGL_DEPTH_ATTACHMENT:
        return format == WEBGL_DEPTH_COMPONENT16
    if attachment == WEBGL_STENCIL_ATTACHMENT:
        return format == WEBGL_STENCIL_INDEX8
    if attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT:
        return format == WEBGL_DEPTH_STENCIL
    false

pub fn webgl_framebuffer_has_attachment(framebuffer: WebGLFramebufferHandle) -> bool:
    framebuffer.color_texture_id >= 0 or framebuffer.color_renderbuffer_id >= 0 or framebuffer.depth_renderbuffer_id >= 0 or framebuffer.stencil_renderbuffer_id >= 0 or framebuffer.depth_stencil_renderbuffer_id >= 0

pub fn webgl_framebuffer_attachment_object_type(framebuffer: WebGLFramebufferHandle, attachment: i32) -> i32:
    if attachment == WEBGL_COLOR_ATTACHMENT0:
        if framebuffer.color_texture_id >= 0:
            return WEBGL_TEXTURE
        if framebuffer.color_renderbuffer_id >= 0:
            return WEBGL_RENDERBUFFER
        return WEBGL_NO_ERROR
    if attachment == WEBGL_DEPTH_ATTACHMENT:
        if framebuffer.depth_renderbuffer_id >= 0:
            return WEBGL_RENDERBUFFER
        return WEBGL_NO_ERROR
    if attachment == WEBGL_STENCIL_ATTACHMENT:
        if framebuffer.stencil_renderbuffer_id >= 0:
            return WEBGL_RENDERBUFFER
        return WEBGL_NO_ERROR
    if attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT:
        if framebuffer.depth_stencil_renderbuffer_id >= 0:
            return WEBGL_RENDERBUFFER
        return WEBGL_NO_ERROR
    WEBGL_NO_ERROR

pub fn webgl_framebuffer_attachment_object_name(framebuffer: WebGLFramebufferHandle, attachment: i32) -> i32:
    if attachment == WEBGL_COLOR_ATTACHMENT0:
        if framebuffer.color_texture_id >= 0:
            return framebuffer.color_texture_id
        return framebuffer.color_renderbuffer_id
    if attachment == WEBGL_DEPTH_ATTACHMENT:
        return framebuffer.depth_renderbuffer_id
    if attachment == WEBGL_STENCIL_ATTACHMENT:
        return framebuffer.stencil_renderbuffer_id
    if attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT:
        return framebuffer.depth_stencil_renderbuffer_id
    -1

pub fn webgl_set_renderbuffer_attachment(framebuffer: WebGLFramebufferHandle, attachment: i32, renderbuffer_id: i32) -> WebGLFramebufferHandle:
    var result = framebuffer
    if attachment == WEBGL_COLOR_ATTACHMENT0:
        result.color_texture_id = -1
        result.color_renderbuffer_id = renderbuffer_id
    if attachment == WEBGL_DEPTH_ATTACHMENT:
        result.depth_renderbuffer_id = renderbuffer_id
        result.depth_stencil_renderbuffer_id = -1
    if attachment == WEBGL_STENCIL_ATTACHMENT:
        result.stencil_renderbuffer_id = renderbuffer_id
        result.depth_stencil_renderbuffer_id = -1
    if attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT:
        result.depth_renderbuffer_id = -1
        result.stencil_renderbuffer_id = -1
        result.depth_stencil_renderbuffer_id = renderbuffer_id
    result

pub fn webgl_clear_renderbuffer_attachment(framebuffer: WebGLFramebufferHandle, attachment: i32) -> WebGLFramebufferHandle:
    var result = framebuffer
    if attachment == WEBGL_COLOR_ATTACHMENT0:
        result.color_renderbuffer_id = -1
    if attachment == WEBGL_DEPTH_ATTACHMENT:
        result.depth_renderbuffer_id = -1
    if attachment == WEBGL_STENCIL_ATTACHMENT:
        result.stencil_renderbuffer_id = -1
    if attachment == WEBGL_DEPTH_STENCIL_ATTACHMENT:
        result.depth_stencil_renderbuffer_id = -1
    result

pub fn webgl_power_of_two(value: i32) -> bool:
    if value <= 0:
        return false
    var candidate = 1
    while candidate < value:
        candidate = candidate * 2
    candidate == value

pub fn webgl_clamp_f64(value: f64, low: f64, high: f64) -> f64:
    if value < low:
        return low
    if value > high:
        return high
    value

pub fn webgl_texture_format_bytes(format: i32) -> i32:
    if format == WEBGL_RGB:
        return 3
    if format == WEBGL_RGBA:
        return 4
    0

pub fn webgl_aligned_row_stride(width: i32, bytes_per_pixel: i32, alignment: i32) -> i32:
    val row_bytes = width * bytes_per_pixel
    val remainder = row_bytes % alignment
    if remainder == 0:
        return row_bytes
    row_bytes + alignment - remainder

pub fn webgl_required_texture_bytes(width: i32, height: i32, bytes_per_pixel: i32, alignment: i32) -> i32:
    webgl_required_texture_bytes_safe(width, height, bytes_per_pixel, alignment)

pub fn webgl_required_texture_bytes_safe(width: i32, height: i32, bytes_per_pixel: i32, alignment: i32) -> i32:
    if width == 0 or height == 0:
        return 0
    if width < 0 or height < 0 or bytes_per_pixel <= 0 or alignment <= 0:
        return -1
    if width > WEBGL_MAX_TEXTURE_UPLOAD_BYTES / bytes_per_pixel:
        return -1
    val row_bytes = width * bytes_per_pixel
    val remainder = row_bytes % alignment
    var row_stride = row_bytes
    if remainder != 0:
        val padding = alignment - remainder
        if row_bytes > WEBGL_MAX_TEXTURE_UPLOAD_BYTES - padding:
            return -1
        row_stride = row_bytes + padding
    if row_stride <= 0:
        return -1
    if height > WEBGL_MAX_TEXTURE_UPLOAD_BYTES / row_stride:
        return -1
    row_stride * height

pub fn webgl_zero_bytes(count: i32) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < count:
        bytes.push(0)
        i = i + 1
    bytes

pub fn webgl_copy_bytes(source: [u8], count: i32) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < count:
        bytes.push(source[i])
        i = i + 1
    bytes

pub fn webgl_copy_f64(source: [f64]) -> [f64]:
    var values: [f64] = []
    var i = 0
    while i < source.len():
        values.push(source[i])
        i = i + 1
    values

pub fn webgl_replace_texture_region(existing: [u8], texture_width: i32, bytes_per_pixel: i32, xoffset: i32, yoffset: i32, width: i32, height: i32, unpack_alignment: i32, pixels: [u8]) -> [u8]:
    var result = existing
    val destination_stride = texture_width * bytes_per_pixel
    val source_stride = webgl_aligned_row_stride(width, bytes_per_pixel, unpack_alignment)
    var row = 0
    while row < height:
        var col_byte = 0
        while col_byte < width * bytes_per_pixel:
            val destination_index = (yoffset + row) * destination_stride + xoffset * bytes_per_pixel + col_byte
            val source_index = row * source_stride + col_byte
            result[destination_index] = pixels[source_index]
            col_byte = col_byte + 1
        row = row + 1
    result
