"""Browser WebGL/WebGL2 compatibility context.

This models the browser-facing WebGL state machine boundary in pure Simple:
context creation, error state, context loss, resources, shader compile, and
program link/use. Rendering backend translation is layered after this API.
"""

use std.gc_async_mut.gpu.browser_engine.webgl_render_commands.{
    WebGLRenderCommand,
    webgl_render_command_viewport, webgl_render_command_scissor,
    webgl_render_command_clear_color, webgl_render_command_clear_depth,
    webgl_render_command_depth_range, webgl_render_command_clear_stencil,
    webgl_render_command_clear, webgl_render_command_flush,
    webgl_render_command_finish, webgl_render_command_capability,
    webgl_render_command_line_width, webgl_render_command_hint,
    webgl_render_command_depth_func, webgl_render_command_cull_face,
    webgl_render_command_front_face, webgl_render_command_blend_color,
    webgl_render_command_blend_func_separate,
    webgl_render_command_blend_equation_separate,
    webgl_render_command_polygon_offset,
    webgl_render_command_sample_coverage,
    webgl_render_command_color_mask, webgl_render_command_depth_mask,
    webgl_render_command_stencil_func, webgl_render_command_stencil_func_separate,
    webgl_render_command_stencil_op, webgl_render_command_stencil_op_separate,
    webgl_render_command_stencil_mask,
    webgl_render_command_stencil_mask_separate,
    webgl_render_command_use_program,
    webgl_render_command_uniform_1i,
    webgl_render_command_uniform_2i,
    webgl_render_command_uniform_3i,
    webgl_render_command_uniform_4i,
    webgl_render_command_uniform_1iv,
    webgl_render_command_uniform_2iv,
    webgl_render_command_uniform_3iv,
    webgl_render_command_uniform_4iv,
    webgl_render_command_uniform_1f,
    webgl_render_command_uniform_2f,
    webgl_render_command_uniform_3f,
    webgl_render_command_uniform_4f,
    webgl_render_command_uniform_1fv,
    webgl_render_command_uniform_2fv,
    webgl_render_command_uniform_3fv,
    webgl_render_command_uniform_4fv,
    webgl_render_command_uniform_matrix2fv,
    webgl_render_command_uniform_matrix3fv,
    webgl_render_command_uniform_matrix4fv,
    webgl_render_command_bind_buffer, webgl_render_command_active_texture,
    webgl_render_command_bind_texture,
    webgl_render_command_tex_parameter,
    webgl_render_command_bind_sampler,
    webgl_render_command_sampler_parameter,
    webgl_render_command_tex_image_2d,
    webgl_render_command_tex_sub_image_2d,
    webgl_render_command_copy_tex_image_2d,
    webgl_render_command_copy_tex_sub_image_2d,
    webgl_render_command_generate_mipmap,
    webgl_render_command_pixel_store,
    webgl_render_command_read_pixels,
    webgl_render_command_bind_framebuffer,
    webgl_render_command_bind_renderbuffer,
    webgl_render_command_renderbuffer_storage,
    webgl_render_command_framebuffer_texture_2d,
    webgl_render_command_framebuffer_renderbuffer,
    webgl_render_command_draw_buffers,
    webgl_render_command_read_buffer,
    webgl_render_command_buffer_data,
    webgl_render_command_vertex_attrib_enable,
    webgl_render_command_vertex_attrib_pointer,
    webgl_render_command_vertex_attrib_divisor,
    webgl_render_command_vertex_attrib_4f,
    webgl_render_command_bind_vertex_array,
    webgl_render_command_draw_arrays, webgl_render_command_draw_elements,
    webgl_render_command_draw_arrays_instanced,
    webgl_render_command_draw_elements_instanced
}

