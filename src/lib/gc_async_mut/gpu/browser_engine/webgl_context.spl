    me get_uniform(program_id: i32, location: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_int(0)
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_int(0)
        val program = self.programs[program_index]
        if not program.linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return webgl_parameter_int(0)
        if location < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return webgl_parameter_int(0)
        var uniform_index = 0
        while uniform_index < program.active_uniforms.len():
            val info = program.active_uniforms[uniform_index]
            if info.location == location:
                var value_index = 0
                while value_index < self.uniform_values.len():
                    val value = self.uniform_values[value_index]
                    if value.program_id == program_id and value.location == location:
                        return webgl_uniform_parameter_value(value)
                    value_index = value_index + 1
                return webgl_default_uniform_parameter_value(info.data_type)
            uniform_index = uniform_index + 1
        self.last_error = WEBGL_INVALID_OPERATION
        webgl_parameter_int(0)

    me use_program(program_id: i32) -> bool:
        if not self.ensure_context_available():
            return false
        val program_index = self.find_program_index(program_id)
        if program_index < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        if not self.programs[program_index].valid:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if not self.programs[program_index].linked:
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.current_program_id = program_id
        self.render_commands.push(webgl_render_command_use_program(program_id))
        true

