        val buffer_id = if target == WEBGL_ARRAY_BUFFER: self.bound_array_buffer else: self.bound_element_array_buffer
        if buffer_id < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        val buffer_index = self.find_buffer_index(buffer_id)
        if buffer_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        buffer_index

    me bound_framebuffer_index_for_target(target: i32) -> i32:
        if target != WEBGL_FRAMEBUFFER:
