            self.last_error = WEBGL_INVALID_ENUM
            return false
        if ref_value < 0 or mask < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.stencil_func_value = func
        self.stencil_ref_value = ref_value
        self.stencil_value_mask = mask
        true

