pub class WebGLBufferHandle:
    id: i32
    valid: bool
    error: text
    target: i32
    byte_length: i32
    usage: i32
    initialized: bool

pub class WebGLVertexAttribState:
    index: i32
    enabled: bool
    size: i32
    data_type: i32
    normalized: bool
    stride: i32
    offset: i32
    buffer_id: i32
    divisor: i32
    current_x: f64
    current_y: f64
    current_z: f64
    current_w: f64

pub class WebGLVertexArrayHandle:
    id: i32
    valid: bool
    error: text
    element_array_buffer_id: i32
    vertex_attribs: [WebGLVertexAttribState]

pub class WebGLTextureHandle:
    id: i32
    valid: bool
    error: text
    target: i32
    width: i32
    height: i32
    level: i32
    internal_format: i32
    format: i32
    pixel_type: i32
    initialized: bool
    min_filter: i32
    mag_filter: i32
    wrap_s: i32
    wrap_t: i32
    mipmap_generated: bool
    pixels: [u8]

pub class WebGLTextureUnitState:
    unit: i32
    texture_2d_id: i32
    texture_cube_map_id: i32
    sampler_id: i32

pub class WebGLSamplerHandle:
    id: i32
    valid: bool
    error: text
    min_filter: i32
    mag_filter: i32
    wrap_s: i32
    wrap_t: i32

pub class WebGLFramebufferHandle:
    id: i32
    valid: bool
    error: text
    color_texture_id: i32
    color_texture_face: i32
    color_renderbuffer_id: i32
    depth_renderbuffer_id: i32
    stencil_renderbuffer_id: i32
    depth_stencil_renderbuffer_id: i32

pub class WebGLRenderbufferHandle:
    id: i32
    valid: bool
    error: text
    internal_format: i32
    width: i32
    height: i32
    initialized: bool

pub class WebGLShaderHandle:
    id: i32
    shader_type: i32
    source: text
    compiled: bool
    valid: bool
    info_log: text

pub class WebGLShaderPrecisionFormat:
    range_min: i32
    range_max: i32
    precision: i32
    valid: bool
    error: text

pub class WebGLActiveInfo:
    name: text
    size: i32
    data_type: i32
    location: i32

pub class WebGLParameterValue:
    value_kind: text
    bool_value: bool
    bool_values: [bool]
    int_value: i32
    int_values: [i32]
    float_value: f64
    float_values: [f64]
    text_value: text

pub class WebGLUniformValue:
    program_id: i32
    location: i32
    data_type: i32
    int_value: i32
    int_values: [i32]
    float_values: [f64]

pub class WebGLExtensionInfo:
    name: text
    minimum_version: i32

pub class WebGLExtensionHandle:
    name: text
    valid: bool
    enabled: bool
    error: text

pub class WebGLContextAttributes:
    alpha: bool
    depth: bool
    stencil: bool
    antialias: bool
    premultiplied_alpha: bool
    preserve_drawing_buffer: bool
    power_preference: text
    fail_if_major_performance_caveat: bool
    valid: bool
    error: text

pub class WebGLProgramHandle:
    id: i32
    vertex_shader_id: i32
    fragment_shader_id: i32
    linked: bool
    valid: bool
    info_log: text
    active_attribs: [WebGLActiveInfo]
    active_uniforms: [WebGLActiveInfo]
    validate_status: bool

pub class WebGLContext:
    version: i32
    context_name: text
    context_lost: bool
    last_error: i32
    width: i32
    height: i32
    next_buffer_id: i32
    next_texture_id: i32
    next_framebuffer_id: i32
    next_renderbuffer_id: i32
    next_vertex_array_id: i32
    next_sampler_id: i32
    next_shader_id: i32
    next_program_id: i32
    buffers: [WebGLBufferHandle]
    textures: [WebGLTextureHandle]
    framebuffers: [WebGLFramebufferHandle]
    renderbuffers: [WebGLRenderbufferHandle]
    vertex_arrays: [WebGLVertexArrayHandle]
    samplers: [WebGLSamplerHandle]
    shaders: [WebGLShaderHandle]
    programs: [WebGLProgramHandle]
    current_program_id: i32
    supported_extensions: [text]
    enabled_extensions: [text]
    uniform_values: [WebGLUniformValue]
    bound_array_buffer: i32
    bound_element_array_buffer: i32
    bound_vertex_array: i32
    vertex_attribs: [WebGLVertexAttribState]
    bound_framebuffer: i32
    bound_renderbuffer: i32
    draw_buffers: [i32]
    read_buffer: i32
    active_texture_unit: i32
    texture_units: [WebGLTextureUnitState]
    bound_texture_2d: i32
    bound_texture_cube_map: i32
    pack_alignment: i32
    unpack_alignment: i32
    unpack_flip_y: bool
    unpack_premultiply_alpha: bool
    unpack_colorspace_conversion: i32
    viewport_x: i32
    viewport_y: i32
    viewport_width: i32
    viewport_height: i32
    clear_red: f64
    clear_green: f64
    clear_blue: f64
    clear_alpha: f64
    line_width_value: f64
    clear_depth_value: f64
    depth_range_near: f64
    depth_range_far: f64
    clear_stencil_value: i32
    blend_enabled: bool
    depth_test_enabled: bool
    dither_enabled: bool
    polygon_offset_fill_enabled: bool
    sample_alpha_to_coverage_enabled: bool
    sample_coverage_enabled: bool
    cull_face_enabled: bool
    scissor_test_enabled: bool
    stencil_test_enabled: bool
    depth_func_value: i32
    stencil_func_value: i32
    stencil_ref_value: i32
    stencil_value_mask: i32
    stencil_back_func_value: i32
    stencil_back_ref_value: i32
    stencil_back_value_mask: i32
    stencil_fail_op: i32
    stencil_zfail_op: i32
    stencil_zpass_op: i32
    stencil_back_fail_op: i32
    stencil_back_zfail_op: i32
    stencil_back_zpass_op: i32
    cull_face_mode: i32
    front_face_mode: i32
    polygon_offset_factor: f64
    polygon_offset_units: f64
    sample_coverage_value: f64
    sample_coverage_invert: bool
    blend_color_red: f64
    blend_color_green: f64
    blend_color_blue: f64
    blend_color_alpha: f64
    blend_src_factor: i32
    blend_dst_factor: i32
    blend_src_alpha_factor: i32
    blend_dst_alpha_factor: i32
    blend_equation_rgb: i32
    blend_equation_alpha: i32
    generate_mipmap_hint: i32
    scissor_x: i32
    scissor_y: i32
    scissor_width: i32
    scissor_height: i32
    color_mask_red: bool
    color_mask_green: bool
    color_mask_blue: bool
    color_mask_alpha: bool
    depth_mask_enabled: bool
    stencil_write_mask_value: i32
    stencil_back_write_mask_value: i32
    draw_call_count: i32
    indexed_draw_call_count: i32
    last_draw_mode: i32
    last_draw_count: i32
    render_commands: [WebGLRenderCommand]

    fn is_available() -> bool:
        not self.context_lost

    me get_error() -> i32:
        val err = self.last_error
        if self.context_lost:
            self.last_error = WEBGL_NO_ERROR
            return WEBGL_CONTEXT_LOST_WEBGL
        self.last_error = WEBGL_NO_ERROR
        err

    me lose_context():
        self.context_lost = true
        self.last_error = WEBGL_CONTEXT_LOST_WEBGL
        self.current_program_id = -1

    me restore_context():
        self.context_lost = false
        self.last_error = WEBGL_NO_ERROR

    fn drawing_buffer_width() -> i32:
        self.width

    fn drawing_buffer_height() -> i32:
        self.height

    me get_context_attributes() -> WebGLContextAttributes:
        if not self.ensure_context_available():
            return webgl_invalid_context_attributes("context lost")
        webgl_default_context_attributes()

    me viewport(x: i32, y: i32, width: i32, height: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if width < 0 or height < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.viewport_x = x
        self.viewport_y = y
        self.viewport_width = width
        self.viewport_height = height
        self.render_commands.push(webgl_render_command_viewport(x, y, width, height))
        true

    me clear_color(red: f64, green: f64, blue: f64, alpha: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_red = webgl_clamp_f64(red, 0.0, 1.0)
        self.clear_green = webgl_clamp_f64(green, 0.0, 1.0)
        self.clear_blue = webgl_clamp_f64(blue, 0.0, 1.0)
        self.clear_alpha = webgl_clamp_f64(alpha, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_clear_color(self.clear_red, self.clear_green, self.clear_blue, self.clear_alpha))
        true

    me clear(mask: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_clear_mask(mask):
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.render_commands.push(webgl_render_command_clear(mask))
        true

    me flush() -> bool:
        if not self.ensure_context_available():
            return false
        self.render_commands.push(webgl_render_command_flush())
        true

    me finish() -> bool:
        if not self.ensure_context_available():
            return false
        self.render_commands.push(webgl_render_command_finish())
        true

    me line_width(width: f64) -> bool:
        if not self.ensure_context_available():
            return false
        if width <= 0.0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.line_width_value = width
        self.render_commands.push(webgl_render_command_line_width(width))
        true

    me hint(target: i32, mode: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if target != WEBGL_GENERATE_MIPMAP_HINT:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if mode != WEBGL_DONT_CARE and mode != WEBGL_FASTEST and mode != WEBGL_NICEST:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.generate_mipmap_hint = mode
        self.render_commands.push(webgl_render_command_hint(target, mode))
        true

    me clear_depth(depth: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_depth_value = webgl_clamp_f64(depth, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_clear_depth(self.clear_depth_value))
        true

    me depth_range(z_near: f64, z_far: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.depth_range_near = webgl_clamp_f64(z_near, 0.0, 1.0)
        self.depth_range_far = webgl_clamp_f64(z_far, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_depth_range(self.depth_range_near, self.depth_range_far))
        true

    me clear_stencil(stencil: i32) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_stencil_value = stencil
        self.render_commands.push(webgl_render_command_clear_stencil(stencil))
        true

    me enable(cap: i32) -> bool:
        self.set_capability(cap, true)

    me disable(cap: i32) -> bool:
        self.set_capability(cap, false)

    me is_enabled(cap: i32) -> bool:
        if cap == WEBGL_BLEND:
            return self.blend_enabled
        if cap == WEBGL_DEPTH_TEST:
            return self.depth_test_enabled
        if cap == WEBGL_DITHER:
            return self.dither_enabled
        if cap == WEBGL_POLYGON_OFFSET_FILL:
            return self.polygon_offset_fill_enabled
        if cap == WEBGL_SAMPLE_ALPHA_TO_COVERAGE:
            return self.sample_alpha_to_coverage_enabled
        if cap == WEBGL_SAMPLE_COVERAGE:
            return self.sample_coverage_enabled
        if cap == WEBGL_CULL_FACE:
            return self.cull_face_enabled
        if cap == WEBGL_SCISSOR_TEST:
            return self.scissor_test_enabled
        if cap == WEBGL_STENCIL_TEST:
            return self.stencil_test_enabled
        false

    me get_parameter(pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_int(0)
        if pname == WEBGL_CURRENT_PROGRAM:
            return webgl_parameter_int(self.current_program_id)
        if pname == WEBGL_ACTIVE_TEXTURE:
            return webgl_parameter_int(WEBGL_TEXTURE0 + self.active_texture_unit)
        if pname == WEBGL_MAX_COMBINED_TEXTURE_IMAGE_UNITS:
            return webgl_parameter_int(WEBGL_MAX_COMBINED_TEXTURE_IMAGE_UNITS)
        if pname == WEBGL_MAX_TEXTURE_IMAGE_UNITS:
            return webgl_parameter_int(8)
        if pname == WEBGL_MAX_VERTEX_TEXTURE_IMAGE_UNITS:
            return webgl_parameter_int(8)
        if pname == WEBGL_MAX_VERTEX_UNIFORM_VECTORS:
            return webgl_parameter_int(128)
        if pname == WEBGL_MAX_FRAGMENT_UNIFORM_VECTORS:
            return webgl_parameter_int(64)
        if pname == WEBGL_MAX_VARYING_VECTORS:
            return webgl_parameter_int(8)
        if pname == WEBGL_COMPRESSED_TEXTURE_FORMATS:
            return webgl_parameter_int_list(webgl_supported_compressed_texture_formats())
        if pname == WEBGL_NUM_COMPRESSED_TEXTURE_FORMATS:
            return webgl_parameter_int(webgl_supported_compressed_texture_formats().len())
        if pname == WEBGL_VENDOR:
            return webgl_parameter_text("Simple Browser")
        if pname == WEBGL_RENDERER:
            return webgl_parameter_text("Simple Browser WebGL")
        if pname == WEBGL_VERSION:
            return webgl_parameter_text(if self.version == 2: "WebGL 2.0 Simple Browser" else: "WebGL 1.0 Simple Browser")
        if pname == WEBGL_SHADING_LANGUAGE_VERSION:
            return webgl_parameter_text(if self.version == 2: "WebGL GLSL ES 3.00 Simple Browser" else: "WebGL GLSL ES 1.00 Simple Browser")
        if pname == WEBGL_MAX_VERTEX_ATTRIBS:
            return webgl_parameter_int(WEBGL_MAX_VERTEX_ATTRIBS)
        if pname == WEBGL_MAX_TEXTURE_SIZE:
            return webgl_parameter_int(4096)
        if pname == WEBGL_MAX_CUBE_MAP_TEXTURE_SIZE:
            return webgl_parameter_int(4096)
        if pname == WEBGL_MAX_RENDERBUFFER_SIZE:
            return webgl_parameter_int(4096)
        if pname == WEBGL_MAX_VIEWPORT_DIMS:
            return webgl_parameter_int_list([4096, 4096])
        if pname == WEBGL_SUBPIXEL_BITS:
            return webgl_parameter_int(4)
        if pname == WEBGL_RED_BITS or pname == WEBGL_GREEN_BITS or pname == WEBGL_BLUE_BITS or pname == WEBGL_ALPHA_BITS:
            return webgl_parameter_int(8)
        if pname == WEBGL_DEPTH_BITS:
            return webgl_parameter_int(24)
        if pname == WEBGL_STENCIL_BITS:
            return webgl_parameter_int(8)
        if pname == WEBGL_PACK_ALIGNMENT:
            return webgl_parameter_int(self.pack_alignment)
        if pname == WEBGL_UNPACK_ALIGNMENT:
            return webgl_parameter_int(self.unpack_alignment)
        if pname == WEBGL_TEXTURE_BINDING_2D:
            return webgl_parameter_int(self.bound_texture_2d)
        if pname == WEBGL_TEXTURE_BINDING_CUBE_MAP:
            return webgl_parameter_int(self.bound_texture_cube_map)
        if pname == WEBGL_SAMPLER_BINDING:
            return webgl_parameter_int(self.texture_units[self.active_texture_unit].sampler_id)
        if pname == WEBGL_FRAMEBUFFER_BINDING:
            return webgl_parameter_int(self.bound_framebuffer)
        if pname == WEBGL_RENDERBUFFER_BINDING:
            return webgl_parameter_int(self.bound_renderbuffer)
        if pname == WEBGL_MAX_DRAW_BUFFERS:
            return webgl_parameter_int(1)
        if pname == WEBGL_DRAW_BUFFER0:
            return webgl_parameter_int(self.draw_buffers[0])
        if pname == WEBGL_READ_BUFFER:
            return webgl_parameter_int(self.read_buffer)
        if pname == WEBGL_VIEWPORT:
            return webgl_parameter_int_list([self.viewport_x, self.viewport_y, self.viewport_width, self.viewport_height])
        if pname == WEBGL_SCISSOR_BOX:
            return webgl_parameter_int_list([self.scissor_x, self.scissor_y, self.scissor_width, self.scissor_height])
        if pname == WEBGL_COLOR_CLEAR_VALUE:
            return webgl_parameter_float_list([self.clear_red, self.clear_green, self.clear_blue, self.clear_alpha])
        if pname == WEBGL_LINE_WIDTH:
            return webgl_parameter_float(self.line_width_value)
        if pname == WEBGL_ALIASED_LINE_WIDTH_RANGE:
            return webgl_parameter_float_list([1.0, 1.0])
        if pname == WEBGL_DEPTH_CLEAR_VALUE:
            return webgl_parameter_float(self.clear_depth_value)
        if pname == WEBGL_DEPTH_RANGE:
            return webgl_parameter_float_list([self.depth_range_near, self.depth_range_far])
        if pname == WEBGL_STENCIL_CLEAR_VALUE:
            return webgl_parameter_int(self.clear_stencil_value)
        if pname == WEBGL_COLOR_WRITEMASK:
            return webgl_parameter_bool_list([self.color_mask_red, self.color_mask_green, self.color_mask_blue, self.color_mask_alpha])
        if pname == WEBGL_DEPTH_WRITEMASK:
            return webgl_parameter_bool(self.depth_mask_enabled)
        if pname == WEBGL_STENCIL_WRITEMASK:
            return webgl_parameter_int(self.stencil_write_mask_value)
        if pname == WEBGL_STENCIL_BACK_WRITEMASK:
            return webgl_parameter_int(self.stencil_back_write_mask_value)
        if pname == WEBGL_STENCIL_FUNC:
            return webgl_parameter_int(self.stencil_func_value)
        if pname == WEBGL_STENCIL_REF:
            return webgl_parameter_int(self.stencil_ref_value)
        if pname == WEBGL_STENCIL_VALUE_MASK:
            return webgl_parameter_int(self.stencil_value_mask)
        if pname == WEBGL_STENCIL_FAIL:
            return webgl_parameter_int(self.stencil_fail_op)
        if pname == WEBGL_STENCIL_PASS_DEPTH_FAIL:
            return webgl_parameter_int(self.stencil_zfail_op)
        if pname == WEBGL_STENCIL_PASS_DEPTH_PASS:
            return webgl_parameter_int(self.stencil_zpass_op)
        if pname == WEBGL_STENCIL_BACK_FUNC:
            return webgl_parameter_int(self.stencil_back_func_value)
        if pname == WEBGL_STENCIL_BACK_REF:
            return webgl_parameter_int(self.stencil_back_ref_value)
        if pname == WEBGL_STENCIL_BACK_VALUE_MASK:
            return webgl_parameter_int(self.stencil_back_value_mask)
        if pname == WEBGL_STENCIL_BACK_FAIL:
            return webgl_parameter_int(self.stencil_back_fail_op)
        if pname == WEBGL_STENCIL_BACK_PASS_DEPTH_FAIL:
            return webgl_parameter_int(self.stencil_back_zfail_op)
        if pname == WEBGL_STENCIL_BACK_PASS_DEPTH_PASS:
            return webgl_parameter_int(self.stencil_back_zpass_op)
        if pname == WEBGL_BLEND:
            return webgl_parameter_bool(self.blend_enabled)
        if pname == WEBGL_DEPTH_TEST:
            return webgl_parameter_bool(self.depth_test_enabled)
        if pname == WEBGL_DITHER:
            return webgl_parameter_bool(self.dither_enabled)
        if pname == WEBGL_POLYGON_OFFSET_FILL:
            return webgl_parameter_bool(self.polygon_offset_fill_enabled)
        if pname == WEBGL_SAMPLE_ALPHA_TO_COVERAGE:
            return webgl_parameter_bool(self.sample_alpha_to_coverage_enabled)
        if pname == WEBGL_SAMPLE_COVERAGE:
            return webgl_parameter_bool(self.sample_coverage_enabled)
        if pname == WEBGL_CULL_FACE:
            return webgl_parameter_bool(self.cull_face_enabled)
        if pname == WEBGL_SCISSOR_TEST:
            return webgl_parameter_bool(self.scissor_test_enabled)
        if pname == WEBGL_STENCIL_TEST:
            return webgl_parameter_bool(self.stencil_test_enabled)
        if pname == WEBGL_DEPTH_FUNC:
            return webgl_parameter_int(self.depth_func_value)
        if pname == WEBGL_CULL_FACE_MODE:
            return webgl_parameter_int(self.cull_face_mode)
        if pname == WEBGL_FRONT_FACE:
            return webgl_parameter_int(self.front_face_mode)
        if pname == WEBGL_POLYGON_OFFSET_FACTOR:
            return webgl_parameter_float(self.polygon_offset_factor)
        if pname == WEBGL_POLYGON_OFFSET_UNITS:
            return webgl_parameter_float(self.polygon_offset_units)
        if pname == WEBGL_SAMPLE_COVERAGE_VALUE:
            return webgl_parameter_float(self.sample_coverage_value)
        if pname == WEBGL_SAMPLE_COVERAGE_INVERT:
            return webgl_parameter_bool(self.sample_coverage_invert)
        if pname == WEBGL_BLEND_COLOR:
            return webgl_parameter_float_list([self.blend_color_red, self.blend_color_green, self.blend_color_blue, self.blend_color_alpha])
        if pname == WEBGL_BLEND_SRC_RGB:
            return webgl_parameter_int(self.blend_src_factor)
        if pname == WEBGL_BLEND_DST_RGB:
            return webgl_parameter_int(self.blend_dst_factor)
        if pname == WEBGL_BLEND_SRC_ALPHA:
            return webgl_parameter_int(self.blend_src_alpha_factor)
        if pname == WEBGL_BLEND_DST_ALPHA:
            return webgl_parameter_int(self.blend_dst_alpha_factor)
        if pname == WEBGL_BLEND_EQUATION or pname == WEBGL_BLEND_EQUATION_RGB:
            return webgl_parameter_int(self.blend_equation_rgb)
        if pname == WEBGL_BLEND_EQUATION_ALPHA:
            return webgl_parameter_int(self.blend_equation_alpha)
        if pname == WEBGL_GENERATE_MIPMAP_HINT:
            return webgl_parameter_int(self.generate_mipmap_hint)
        self.last_error = WEBGL_INVALID_ENUM
        webgl_parameter_int(0)

    me depth_func(func: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_depth_func(func):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.depth_func_value = func
        self.render_commands.push(webgl_render_command_depth_func(func))
        true

    me stencil_func(func: i32, ref_value: i32, mask: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_stencil_func(func):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if ref_value < 0 or mask < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.stencil_func_value = func
        self.stencil_ref_value = ref_value
        self.stencil_value_mask = mask
        self.stencil_back_func_value = func
        self.stencil_back_ref_value = ref_value
        self.stencil_back_value_mask = mask
        self.render_commands.push(webgl_render_command_stencil_func(func, ref_value, mask))
        true

    me stencil_func_separate(face: i32, func: i32, ref_value: i32, mask: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if face != WEBGL_FRONT and face != WEBGL_BACK and face != WEBGL_FRONT_AND_BACK:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if not webgl_valid_stencil_func(func):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if ref_value < 0 or mask < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        if face == WEBGL_FRONT or face == WEBGL_FRONT_AND_BACK:
            self.stencil_func_value = func
            self.stencil_ref_value = ref_value
            self.stencil_value_mask = mask
        if face == WEBGL_BACK or face == WEBGL_FRONT_AND_BACK:
            self.stencil_back_func_value = func
            self.stencil_back_ref_value = ref_value
            self.stencil_back_value_mask = mask
        self.render_commands.push(webgl_render_command_stencil_func_separate(face, func, ref_value, mask))
        true

    me stencil_op(fail: i32, zfail: i32, zpass: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_stencil_op(fail) or not webgl_valid_stencil_op(zfail) or not webgl_valid_stencil_op(zpass):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.stencil_fail_op = fail
        self.stencil_zfail_op = zfail
        self.stencil_zpass_op = zpass
        self.stencil_back_fail_op = fail
        self.stencil_back_zfail_op = zfail
        self.stencil_back_zpass_op = zpass
        self.render_commands.push(webgl_render_command_stencil_op(fail, zfail, zpass))
        true

    me stencil_op_separate(face: i32, fail: i32, zfail: i32, zpass: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if face != WEBGL_FRONT and face != WEBGL_BACK and face != WEBGL_FRONT_AND_BACK:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if not webgl_valid_stencil_op(fail) or not webgl_valid_stencil_op(zfail) or not webgl_valid_stencil_op(zpass):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if face == WEBGL_FRONT or face == WEBGL_FRONT_AND_BACK:
            self.stencil_fail_op = fail
            self.stencil_zfail_op = zfail
            self.stencil_zpass_op = zpass
        if face == WEBGL_BACK or face == WEBGL_FRONT_AND_BACK:
            self.stencil_back_fail_op = fail
            self.stencil_back_zfail_op = zfail
            self.stencil_back_zpass_op = zpass
        self.render_commands.push(webgl_render_command_stencil_op_separate(face, fail, zfail, zpass))
        true

    me cull_face(mode: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if mode != WEBGL_BACK and mode != WEBGL_FRONT and mode != WEBGL_FRONT_AND_BACK:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.cull_face_mode = mode
        self.render_commands.push(webgl_render_command_cull_face(mode))
        true

    me front_face(mode: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if mode != WEBGL_CW and mode != WEBGL_CCW:
            self.last_error = WEBGL_INVALID_ENUM
            return false
        self.front_face_mode = mode
        self.render_commands.push(webgl_render_command_front_face(mode))
        true

    me polygon_offset(factor: f64, units: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.polygon_offset_factor = factor
        self.polygon_offset_units = units
        self.render_commands.push(webgl_render_command_polygon_offset(factor, units))
        true

    me sample_coverage(value: f64, invert: bool) -> bool:
        if not self.ensure_context_available():
            return false
        self.sample_coverage_value = webgl_clamp_f64(value, 0.0, 1.0)
        self.sample_coverage_invert = invert
        self.render_commands.push(webgl_render_command_sample_coverage(self.sample_coverage_value, invert))
        true

    me blend_color(red: f64, green: f64, blue: f64, alpha: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.blend_color_red = webgl_clamp_f64(red, 0.0, 1.0)
        self.blend_color_green = webgl_clamp_f64(green, 0.0, 1.0)
        self.blend_color_blue = webgl_clamp_f64(blue, 0.0, 1.0)
        self.blend_color_alpha = webgl_clamp_f64(alpha, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_blend_color(self.blend_color_red, self.blend_color_green, self.blend_color_blue, self.blend_color_alpha))
        true

    me blend_func(src_factor: i32, dst_factor: i32) -> bool:
        self.blend_func_separate(src_factor, dst_factor, src_factor, dst_factor)

    me blend_func_separate(src_rgb: i32, dst_rgb: i32, src_alpha: i32, dst_alpha: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_blend_factor(src_rgb) or not webgl_valid_blend_factor(dst_rgb) or not webgl_valid_blend_factor(src_alpha) or not webgl_valid_blend_factor(dst_alpha):
            self.last_error = WEBGL_INVALID_ENUM
            return false
        if webgl_blend_factor_mixes_constant_color_and_alpha(src_rgb, dst_rgb, src_alpha, dst_alpha):
            self.last_error = WEBGL_INVALID_OPERATION
            return false
        self.blend_src_factor = src_rgb
        self.blend_dst_factor = dst_rgb
        self.blend_src_alpha_factor = src_alpha
        self.blend_dst_alpha_factor = dst_alpha
        self.render_commands.push(webgl_render_command_blend_func_separate(src_rgb, dst_rgb, src_alpha, dst_alpha))
        true

    me blend_equation(mode: i32) -> bool:
        self.blend_equation_separate(mode, mode)

    me blend_equation_separate(mode_rgb: i32, mode_alpha: i32) -> bool:
