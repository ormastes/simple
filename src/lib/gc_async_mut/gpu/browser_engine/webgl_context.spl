pub class WebGLBufferHandle:
    id: i32
    valid: bool
    error: text
    target: i32
    byte_length: i32
    usage: i32
    initialized: bool

pub class WebGLVertexAttribState:
    index: i32
    enabled: bool
    size: i32
    data_type: i32
    normalized: bool
    stride: i32
    offset: i32
    buffer_id: i32

pub class WebGLTextureHandle:
    id: i32
    valid: bool
    error: text
    target: i32
    width: i32
    height: i32
    level: i32
    internal_format: i32
    format: i32
    pixel_type: i32
    initialized: bool
    min_filter: i32
    mag_filter: i32
    wrap_s: i32
    wrap_t: i32
    mipmap_generated: bool
    pixels: [u8]

pub class WebGLTextureUnitState:
    unit: i32
    texture_2d_id: i32

pub class WebGLFramebufferHandle:
    id: i32
    valid: bool
    error: text
    color_texture_id: i32
    color_renderbuffer_id: i32
    depth_renderbuffer_id: i32
    stencil_renderbuffer_id: i32
    depth_stencil_renderbuffer_id: i32

pub class WebGLRenderbufferHandle:
    id: i32
    valid: bool
    error: text
    internal_format: i32
    width: i32
    height: i32
    initialized: bool

pub class WebGLShaderHandle:
    id: i32
    shader_type: i32
    source: text
    compiled: bool
    valid: bool
    info_log: text

pub class WebGLShaderPrecisionFormat:
    range_min: i32
    range_max: i32
    precision: i32
    valid: bool
    error: text

pub class WebGLActiveInfo:
    name: text
    size: i32
    data_type: i32
    location: i32

pub class WebGLParameterValue:
    value_kind: text
    bool_value: bool
    bool_values: [bool]
    int_value: i32
    int_values: [i32]
    float_value: f64
    float_values: [f64]
    text_value: text

pub class WebGLUniformValue:
    program_id: i32
    location: i32
    data_type: i32
    int_value: i32
    float_values: [f64]

pub class WebGLExtensionInfo:
    name: text
    minimum_version: i32

pub class WebGLExtensionHandle:
    name: text
    valid: bool
    enabled: bool
    error: text

pub class WebGLContextAttributes:
    alpha: bool
    depth: bool
    stencil: bool
    antialias: bool
    premultiplied_alpha: bool
    preserve_drawing_buffer: bool
    power_preference: text
    fail_if_major_performance_caveat: bool
    valid: bool
    error: text

pub class WebGLProgramHandle:
    id: i32
    vertex_shader_id: i32
    fragment_shader_id: i32
    linked: bool
    valid: bool
    info_log: text
    active_attribs: [WebGLActiveInfo]
    active_uniforms: [WebGLActiveInfo]
    validate_status: bool

pub class WebGLContext:
    version: i32
    context_name: text
    context_lost: bool
    last_error: i32
    width: i32
    height: i32
    next_buffer_id: i32
    next_texture_id: i32
    next_framebuffer_id: i32
    next_renderbuffer_id: i32
    next_shader_id: i32
    next_program_id: i32
    buffers: [WebGLBufferHandle]
    textures: [WebGLTextureHandle]
    framebuffers: [WebGLFramebufferHandle]
    renderbuffers: [WebGLRenderbufferHandle]
    shaders: [WebGLShaderHandle]
    programs: [WebGLProgramHandle]
    current_program_id: i32
    supported_extensions: [text]
    enabled_extensions: [text]
    uniform_values: [WebGLUniformValue]
    bound_array_buffer: i32
    bound_element_array_buffer: i32
    vertex_attribs: [WebGLVertexAttribState]
    bound_framebuffer: i32
    bound_renderbuffer: i32
    active_texture_unit: i32
    texture_units: [WebGLTextureUnitState]
    bound_texture_2d: i32
    pack_alignment: i32
    unpack_alignment: i32
    unpack_flip_y: bool
    unpack_premultiply_alpha: bool
    unpack_colorspace_conversion: i32
    viewport_x: i32
    viewport_y: i32
    viewport_width: i32
    viewport_height: i32
    clear_red: f64
    clear_green: f64
    clear_blue: f64
    clear_alpha: f64
    line_width_value: f64
    clear_depth_value: f64
    depth_range_near: f64
    depth_range_far: f64
    clear_stencil_value: i32
    blend_enabled: bool
    depth_test_enabled: bool
    dither_enabled: bool
    polygon_offset_fill_enabled: bool
    sample_alpha_to_coverage_enabled: bool
    sample_coverage_enabled: bool
    cull_face_enabled: bool
    scissor_test_enabled: bool
    stencil_test_enabled: bool
    depth_func_value: i32
    stencil_func_value: i32
    stencil_ref_value: i32
    stencil_value_mask: i32
    stencil_fail_op: i32
    stencil_zfail_op: i32
    stencil_zpass_op: i32
    cull_face_mode: i32
    front_face_mode: i32
    polygon_offset_factor: f64
    polygon_offset_units: f64
    sample_coverage_value: f64
    sample_coverage_invert: bool
    blend_color_red: f64
    blend_color_green: f64
    blend_color_blue: f64
    blend_color_alpha: f64
    blend_src_factor: i32
    blend_dst_factor: i32
    blend_src_alpha_factor: i32
    blend_dst_alpha_factor: i32
    blend_equation_rgb: i32
    blend_equation_alpha: i32
    scissor_x: i32
    scissor_y: i32
    scissor_width: i32
    scissor_height: i32
    color_mask_red: bool
    color_mask_green: bool
    color_mask_blue: bool
    color_mask_alpha: bool
    depth_mask_enabled: bool
    stencil_write_mask_value: i32
    stencil_back_write_mask_value: i32
    draw_call_count: i32
    indexed_draw_call_count: i32
    last_draw_mode: i32
    last_draw_count: i32
    render_commands: [WebGLRenderCommand]

    fn is_available() -> bool:
        not self.context_lost

    me get_error() -> i32:
        val err = self.last_error
        if self.context_lost:
            self.last_error = WEBGL_NO_ERROR
            return WEBGL_CONTEXT_LOST_WEBGL
        self.last_error = WEBGL_NO_ERROR
        err

    me lose_context():
        self.context_lost = true
        self.last_error = WEBGL_CONTEXT_LOST_WEBGL
        self.current_program_id = -1

    me restore_context():
        self.context_lost = false
        self.last_error = WEBGL_NO_ERROR

    fn drawing_buffer_width() -> i32:
        self.width

    fn drawing_buffer_height() -> i32:
        self.height

    me get_context_attributes() -> WebGLContextAttributes:
        if not self.ensure_context_available():
            return webgl_invalid_context_attributes("context lost")
        webgl_default_context_attributes()

    me viewport(x: i32, y: i32, width: i32, height: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if width < 0 or height < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.viewport_x = x
        self.viewport_y = y
        self.viewport_width = width
        self.viewport_height = height
        self.render_commands.push(webgl_render_command_viewport(x, y, width, height))
        true

    me clear_color(red: f64, green: f64, blue: f64, alpha: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_red = webgl_clamp_f64(red, 0.0, 1.0)
        self.clear_green = webgl_clamp_f64(green, 0.0, 1.0)
        self.clear_blue = webgl_clamp_f64(blue, 0.0, 1.0)
        self.clear_alpha = webgl_clamp_f64(alpha, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_clear_color(self.clear_red, self.clear_green, self.clear_blue, self.clear_alpha))
        true

    me clear(mask: i32) -> bool:
        if not self.ensure_context_available():
            return false
        if not webgl_valid_clear_mask(mask):
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.render_commands.push(webgl_render_command_clear(mask))
        true

    me line_width(width: f64) -> bool:
        if not self.ensure_context_available():
            return false
        if width <= 0.0:
            self.last_error = WEBGL_INVALID_VALUE
            return false
        self.line_width_value = width
        self.render_commands.push(webgl_render_command_line_width(width))
        true

    me clear_depth(depth: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_depth_value = webgl_clamp_f64(depth, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_clear_depth(self.clear_depth_value))
        true

    me depth_range(z_near: f64, z_far: f64) -> bool:
        if not self.ensure_context_available():
            return false
        self.depth_range_near = webgl_clamp_f64(z_near, 0.0, 1.0)
        self.depth_range_far = webgl_clamp_f64(z_far, 0.0, 1.0)
        self.render_commands.push(webgl_render_command_depth_range(self.depth_range_near, self.depth_range_far))
        true

    me clear_stencil(stencil: i32) -> bool:
        if not self.ensure_context_available():
            return false
        self.clear_stencil_value = stencil
        self.render_commands.push(webgl_render_command_clear_stencil(stencil))
        true

    me enable(cap: i32) -> bool:
        self.set_capability(cap, true)

    me disable(cap: i32) -> bool:
        self.set_capability(cap, false)

    me is_enabled(cap: i32) -> bool:
        if cap == WEBGL_BLEND:
            return self.blend_enabled
        if cap == WEBGL_DEPTH_TEST:
            return self.depth_test_enabled
        if cap == WEBGL_DITHER:
            return self.dither_enabled
        if cap == WEBGL_POLYGON_OFFSET_FILL:
            return self.polygon_offset_fill_enabled
        if cap == WEBGL_SAMPLE_ALPHA_TO_COVERAGE:
            return self.sample_alpha_to_coverage_enabled
        if cap == WEBGL_SAMPLE_COVERAGE:
            return self.sample_coverage_enabled
        if cap == WEBGL_CULL_FACE:
            return self.cull_face_enabled
        if cap == WEBGL_SCISSOR_TEST:
            return self.scissor_test_enabled
        if cap == WEBGL_STENCIL_TEST:
            return self.stencil_test_enabled
        false

    me get_parameter(pname: i32) -> WebGLParameterValue:
        if not self.ensure_context_available():
            return webgl_parameter_int(0)
        if pname == WEBGL_CURRENT_PROGRAM:
            return webgl_parameter_int(self.current_program_id)
        if pname == WEBGL_ACTIVE_TEXTURE:
            return webgl_parameter_int(WEBGL_TEXTURE0 + self.active_texture_unit)
