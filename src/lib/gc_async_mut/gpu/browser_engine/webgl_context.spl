    me save_bound_vertex_array_state():
        if self.bound_vertex_array < 0:
            return
        val vertex_array_index = self.find_vertex_array_index(self.bound_vertex_array)
        if vertex_array_index < 0:
            return
        var vertex_array = self.vertex_arrays[vertex_array_index]
        if not vertex_array.valid:
            return
        vertex_array.element_array_buffer_id = self.bound_element_array_buffer
        vertex_array.vertex_attribs = webgl_copy_vertex_attribs(self.vertex_attribs)
        self.vertex_arrays[vertex_array_index] = vertex_array

    me bound_buffer_index_for_target(target: i32) -> i32:
        if target != WEBGL_ARRAY_BUFFER and target != WEBGL_ELEMENT_ARRAY_BUFFER:
            self.last_error = WEBGL_INVALID_ENUM
            return -1
        val buffer_id = if target == WEBGL_ARRAY_BUFFER: self.bound_array_buffer else: self.bound_element_array_buffer
        if buffer_id < 0:
            self.last_error = WEBGL_INVALID_OPERATION
            return -1
        val buffer_index = self.find_buffer_index(buffer_id)
        if buffer_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        buffer_index

