        val renderbuffer_index = self.find_renderbuffer_index(self.bound_renderbuffer)
        if renderbuffer_index < 0:
            self.last_error = WEBGL_INVALID_VALUE
            return -1
        renderbuffer_index

    fn bound_framebuffer_is_complete() -> bool:
        self.check_framebuffer_status(WEBGL_FRAMEBUFFER) == WEBGL_FRAMEBUFFER_COMPLETE

    fn framebuffer_attachments_are_complete(framebuffer: WebGLFramebufferHandle) -> bool:
        if framebuffer.color_texture_id >= 0:
            val texture_index = self.find_texture_index(framebuffer.color_texture_id)
            if texture_index < 0 or not self.textures[texture_index].initialized:
                return false
        if framebuffer.color_renderbuffer_id >= 0 and not self.renderbuffer_attachment_complete(framebuffer.color_renderbuffer_id, WEBGL_COLOR_ATTACHMENT0):
            return false
        if framebuffer.depth_renderbuffer_id >= 0 and not self.renderbuffer_attachment_complete(framebuffer.depth_renderbuffer_id, WEBGL_DEPTH_ATTACHMENT):
            return false
        if framebuffer.stencil_renderbuffer_id >= 0 and not self.renderbuffer_attachment_complete(framebuffer.stencil_renderbuffer_id, WEBGL_STENCIL_ATTACHMENT):
            return false
        if framebuffer.depth_stencil_renderbuffer_id >= 0 and not self.renderbuffer_attachment_complete(framebuffer.depth_stencil_renderbuffer_id, WEBGL_DEPTH_STENCIL_ATTACHMENT):
            return false
        true

    fn renderbuffer_attachment_complete(renderbuffer_id: i32, attachment: i32) -> bool:
        val renderbuffer_index = self.find_renderbuffer_index(renderbuffer_id)
        if renderbuffer_index < 0:
            return false
        val renderbuffer = self.renderbuffers[renderbuffer_index]
        renderbuffer.initialized and webgl_renderbuffer_format_matches_attachment(renderbuffer.internal_format, attachment)

    fn webgl_has_enabled_vertex_source() -> bool:
        var i = 0
        while i < self.vertex_attribs.len():
            val attrib = self.vertex_attribs[i]
            if attrib.enabled and attrib.buffer_id >= 0:
                val buffer_index = self.find_buffer_index(attrib.buffer_id)
                if buffer_index >= 0 and self.buffers[buffer_index].initialized:
                    return true
            i = i + 1
        false

    fn webgl_valid_index_type(element_type: i32) -> bool:
        if element_type == WEBGL_UNSIGNED_SHORT:
            return true
        if element_type == WEBGL_UNSIGNED_INT:
            return self.version >= 2 or self.is_extension_enabled("OES_element_index_uint")
