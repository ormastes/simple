# Browser Engine — Engine2D Bridge
#
# Convenience factories for creating BrowserRenderers backed by Engine2D
# GPU backends. Provides easy one-call setup for GPU-accelerated browser
# rendering.
#
# Usage:
#   use std.gc_async_mut.gpu.browser_engine.browser_engine2d_bridge.{
#       create_gpu_browser_renderer, create_software_browser_renderer}
#
#   # Auto-detect best GPU backend (CUDA > ROCm > Metal > Vulkan > OpenGL > Intel > Software)
#   var renderer = create_gpu_browser_renderer(800, 600)
#
#   # Or use deterministic Engine2D software rendering
#   var renderer = create_software_browser_renderer(800, 600)

use os.drivers.framebuffer.fb_driver.{FramebufferDriver}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_baremetal.{BaremetalBackend}
use std.gc_async_mut.gpu.engine2d.backend_virtio_gpu.{VirtioGpuBackend}

# ============================================================================
# Factory functions
# ============================================================================

fn create_gpu_browser_renderer(w: i32, h: i32) -> BrowserRenderer:
    """Create a BrowserRenderer backed by the best available GPU backend.

    Auto-detects the best available Engine2D backend in priority order:
    CUDA > ROCm > Metal > Vulkan > OpenGL > Intel > Software.

    The resulting renderer uses Engine2D for all pixel rendering, enabling
    GPU acceleration when available.

    Args:
        w: Viewport width in pixels
        h: Viewport height in pixels

    Returns:
        BrowserRenderer with Engine2D backend
    """
    val engine = Engine2D.create(w, h)
    BrowserRenderer.create_with_engine(w, h, engine)

fn create_gpu_browser_renderer_with_backend(w: i32, h: i32, backend_name: text) -> BrowserRenderer:
    """Create a BrowserRenderer backed by a specific Engine2D backend.

    Args:
        w: Viewport width in pixels
        h: Viewport height in pixels
        backend_name: One of "cuda", "rocm", "metal", "vulkan", "opengl",
                      "intel", "software", "cpu"

    Returns:
        BrowserRenderer with the specified Engine2D backend
    """
    val engine = Engine2D.create_with_backend(w, h, backend_name)
    BrowserRenderer.create_with_engine(w, h, engine)

fn create_software_browser_renderer(w: i32, h: i32) -> BrowserRenderer:
    """Create a BrowserRenderer backed by Engine2D's software backend.

    This is the deterministic default path for browser pixel rendering.

    Args:
        w: Viewport width in pixels
        h: Viewport height in pixels

    Returns:
        BrowserRenderer using Engine2D software
    """
    BrowserRenderer.create_with_backend(w, h, "software")

fn create_baremetal_browser_renderer(fb: FramebufferDriver) -> BrowserRenderer:
    """Create a BrowserRenderer backed by a baremetal framebuffer.

    Wraps the FramebufferDriver in a BaremetalBackend, then in an Engine2D,
    producing a BrowserRenderer suitable for OS-level rendering without
    any hosted GPU stack.

    Args:
        fb: Initialized FramebufferDriver (from Limine/multiboot)

    Returns:
        BrowserRenderer rendering to the framebuffer
    """
    val backend = BaremetalBackend.create(fb)
    val engine = Engine2D.create_with_baremetal_backend_dims(fb.width.to_i32(), fb.height.to_i32(), backend)
    BrowserRenderer.create_with_engine(engine.width(), engine.height(), engine)

fn create_virtio_gpu_browser_renderer(gpu: VirtioGpuDriver) -> BrowserRenderer:
    """Create a BrowserRenderer backed by a VirtIO-GPU driver.

    Wraps the VirtioGpuDriver in a VirtioGpuBackend, then in an Engine2D,
    producing a BrowserRenderer for QEMU/KVM virtual GPU rendering.

    Args:
        gpu: Initialized VirtioGpuDriver (init_from_grant() already called)

    Returns:
        BrowserRenderer rendering through VirtIO-GPU
    """
    val w = gpu.width.to_i32()
    val h = gpu.height.to_i32()
    var backend = VirtioGpuBackend.create(gpu)
    backend.init(w, h)
    val engine = Engine2D.create_with_virtio_gpu_backend(backend)
    BrowserRenderer.create_with_engine(w, h, engine)
