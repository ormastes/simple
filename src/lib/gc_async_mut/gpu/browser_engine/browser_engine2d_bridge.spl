use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

pub fn create_gpu_browser_renderer(w: i32, h: i32) -> BrowserRenderer:
    BrowserRenderer.create_with_backend(w, h, "software")

pub fn create_gpu_browser_renderer_with_backend(w: i32, h: i32, backend_name: text) -> BrowserRenderer:
    BrowserRenderer.create_with_backend(w, h, backend_name)

pub fn create_software_browser_renderer(w: i32, h: i32) -> BrowserRenderer:
    BrowserRenderer.create_with_backend(w, h, "software")
