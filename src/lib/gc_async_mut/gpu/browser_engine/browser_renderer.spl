    pixels = br_fill_rect(pixels, width, height, 8, 28, 304, 40, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
