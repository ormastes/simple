    while idx <= selector_list.len():
        if idx < selector_list.len():
            val ch = selector_list.char_at(idx)
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")" and paren_depth > 0:
                paren_depth = paren_depth - 1
            elif ch == "[":
                bracket_depth = bracket_depth + 1
            elif ch == "]" and bracket_depth > 0:
                bracket_depth = bracket_depth - 1
        if idx == selector_list.len() or (selector_list.char_at(idx) == "," and paren_depth == 0 and bracket_depth == 0):
            val part = selector_list.slice(segment_start, idx).trim().lower()
            if br_selector_matches_empty_self(part, subject, tag_content):
                return true
