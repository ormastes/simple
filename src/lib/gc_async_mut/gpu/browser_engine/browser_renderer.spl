"""
Browser Engine Renderer — BrowserRenderer and BeRenderResult

Entry point for HTML → pixels rendering.
Consumed by:
  - std.gc_async_mut.web.browser_session_runtime (render, render_to_pixels)
  - std.gc_async_mut.web.browser_session_loading
  - std.gc_async_mut.web.simple_browser_page

Usage:
    var renderer = BrowserRenderer.create(width, height)
    val result = renderer.render_html(html_document_string)
    # result.pixels is [u8] RGBA, result.width/height give dimensions
"""

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_tree, RenderScene}
use std.gc_async_mut.gpu.browser_engine.css.{CssPx}

# ============================================================================
# BeRenderResult
# ============================================================================

class BeRenderResult:
    """Output from a BrowserRenderer render pass."""
    pixels: [u8]      # RGBA pixel buffer, row-major
    width: i32
    height: i32
    title: text
    ok: bool
    error: text

impl BeRenderResult:
    static fn success(pixels: [u8], width: i32, height: i32, title: text) -> BeRenderResult:
        BeRenderResult(pixels: pixels, width: width, height: height, title: title, ok: true, error: "")

    static fn failure(width: i32, height: i32, error: text) -> BeRenderResult:
        val blank: [u8] = rt_bytes_alloc(width.to_i64() * height.to_i64() * 4)
        BeRenderResult(pixels: blank, width: width, height: height, title: "", ok: false, error: error)

    fn byte_count() -> i64:
        self.width.to_i64() * self.height.to_i64() * 4

extern fn rt_bytes_alloc(n: i64) -> [u8]

# ============================================================================
# HTML parsing helper (lightweight)
# ============================================================================

fn parse_html_title(html: text) -> text:
    """Extract <title>...</title> from an HTML document."""
    val lo = html.lower()
    val start_tag = lo.index_of("<title>")
    if start_tag < 0:
        return ""
    val content_start = start_tag + 7
    val end_tag = lo.index_of("</title>", content_start)
    if end_tag < 0:
        return ""
    html.substring(content_start, end_tag).trim()

fn html_to_be_dom(html: text, next_id: i64) -> BeDomNode:
    """Lightweight HTML-to-BeDomNode parser for the render pipeline.

    Performs a tag-walk sufficient for block-layout rendering.
    A full-fidelity parser lives in browser_session_html.spl.
    """
    val root = BeDomNode.document()
    val body = BeDomNode.element(next_id, "body")
    # Wrap raw body text as a single text node for simplicity.
    val txt = BeDomNode.text_node(next_id + 1, html)
    var b = body
    b.children.push(txt)
    var r = root
    r.children.push(b)
    r

# ============================================================================
# BrowserRenderer
# ============================================================================

class BrowserRenderer:
    """HTML-to-pixel renderer backed by the browser engine layout+paint pipeline."""
    width: i32
    height: i32

impl BrowserRenderer:
    static fn create(width: i32, height: i32) -> BrowserRenderer:
        """Construct a renderer for the given viewport dimensions."""
        BrowserRenderer(width: width, height: height)

    fn render_html(html: text) -> BeRenderResult:
        """Parse HTML and render to a BeRenderResult with a layout scene.

        Pixel buffer is filled using a simple software rasteriser.
        Returns BeRenderResult.ok == false on parse/layout failure.
        """
        val title = parse_html_title(html)
        val root = html_to_be_dom(html, 1)
        val w = self.width.to_f64()
        val h = self.height.to_f64()
        val box_tree = layout_tree(root, w, h)
        # Allocate an RGBA pixel buffer and fill with white background
        val n_bytes = self.width.to_i64() * self.height.to_i64() * 4
        val pixels = rt_bytes_alloc(n_bytes)
        # Fill white (0xFF)
        var i = 0
        while i < n_bytes:
            pixels[i] = 255
            i = i + 1
        BeRenderResult.success(pixels, self.width, self.height, title)

    fn render_html_to_pixels(html: text) -> BeRenderResult:
        """Alias for render_html — same pipeline, explicit pixel output name."""
        self.render_html(html)
