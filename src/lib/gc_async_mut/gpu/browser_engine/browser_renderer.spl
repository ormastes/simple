fn br_load_p6_ppm_pixels(path: text, width: i32, height: i32) -> [u32]:
    val data: [u8] = rt_file_read_bytes(path) ?? []
    val header_len = 15
    val expected_len = header_len + width * height * 3
    if data.len() < expected_len:
        return []
    if data[0] != 80u8 or data[1] != 54u8 or data[2] != 10u8:
        return []
    var pixels: [u32] = []
    var idx = header_len
    while idx + 2 < expected_len:
        val r = data[idx].to_u32()
        val g = data[idx + 1].to_u32()
        val b = data[idx + 2].to_u32()
        pixels.push(0xFF000000u32 | (r << 16) | (g << 8) | b)
        idx = idx + 3
    pixels

fn br_draw_font_renderer_layout_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, max_width: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    var out = pixels
    val glyphs = renderer.layout_text(text_val, font_size, max_width)
    if glyphs.len() == 0:
        return br_draw_font_renderer_text_wrapped(pixels, width, height, x, y, text_val, color, font_size, max_width, 19)
    for layout_glyph in glyphs:
        val glyph = renderer.get_glyph(layout_glyph.codepoint.to_i32(), font_size)
        if glyph.width > 0 and glyph.height > 0:
            out = br_blend_cached_glyph_chrome_text(out, width, height, x + layout_glyph.x.to_i32(), y + layout_glyph.y.to_i32(), 0, glyph, color)
    out

fn br_draw_font_renderer_layout_text_for_bg(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, max_width: i32, bg: u32) -> [u32]:
    if bg == 0xFF2563EBu32:
        return br_draw_font_renderer_layout_text(pixels, width, height, x, y, text_val, color, font_size, max_width)
    var renderer = br_chrome_default_font_renderer()
    var out = pixels
    val glyphs = renderer.layout_text(text_val, font_size, max_width)
    if glyphs.len() == 0:
        return br_draw_font_renderer_text_wrapped(pixels, width, height, x, y, text_val, color, font_size, max_width, 19)
    for layout_glyph in glyphs:
        val subpixel = renderer.rasterize_subpixel(layout_glyph.codepoint.to_i32(), font_size)
        if subpixel != nil:
            out = br_blend_subpixel_glyph_chrome_text(out, width, height, x + layout_glyph.x.to_i32(), y + layout_glyph.y.to_i32(), 0, subpixel, color)
        else:
            val glyph = renderer.get_glyph(layout_glyph.codepoint.to_i32(), font_size)
            if glyph.width > 0 and glyph.height > 0:
                out = br_blend_cached_glyph_chrome_text(out, width, height, x + layout_glyph.x.to_i32(), y + layout_glyph.y.to_i32(), 0, glyph, color)
    out

fn br_famous_site_corpus_layout_lines_sdn(html: text, font_size: i32, max_width: i32) -> text:
    val lines = br_famous_site_corpus_layout_lines(html, font_size, max_width)
    var out = "(layout_lines"
    var idx = 0
    for line in lines:
        out = out + " (line index: " + idx.to_string() + " text: \"" + line + "\")"
        idx = idx + 1
    out + " count: " + lines.len().to_string() + ")"

fn br_famous_site_corpus_layout_line_widths_sdn(html: text, font_size: i32, max_width: i32) -> text:
    val lines = br_famous_site_corpus_layout_lines(html, font_size, max_width)
    var renderer = br_chrome_default_font_renderer()
    var out = "(layout_line_widths"
    var idx = 0
    for line in lines:
        out = out + " (line index: " + idx.to_string() + " width: " + renderer.measure_text_width(line, font_size).to_string() + " text: \"" + line + "\")"
        idx = idx + 1
    out + " count: " + lines.len().to_string() + ")"

fn br_famous_site_corpus_layout_lines(html: text, font_size: i32, max_width: i32) -> [text]:
    val label = br_famous_site_corpus_label(html)
    if label.len() == 0:
        return []
    var renderer = br_chrome_default_font_renderer()
    val glyphs = renderer.layout_text(label, font_size, max_width)
    if glyphs.len() == 0:
        return []

    var lines: [text] = []
    var previous_x = glyphs[0].x
    var line_start = glyphs[0].byte_offset.to_i32()
    var line_end = line_start
    for layout_glyph in glyphs:
        if layout_glyph.x < previous_x:
            lines.push(label.slice(line_start, line_end + 1).trim())
            line_start = layout_glyph.byte_offset.to_i32()
            line_end = line_start
        elif layout_glyph.byte_offset.to_i32() > line_end:
            line_end = layout_glyph.byte_offset.to_i32()
        previous_x = layout_glyph.x
    lines.push(label.slice(line_start, line_end + 1).trim())
    lines

fn br_blend_cached_glyph_chrome_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, min_y: i32, glyph: CachedGlyph, color: u32) -> [u32]:
    var out = pixels
    val fg_r = (color >> 16) & 0xFF
    val fg_g = (color >> 8) & 0xFF
    val fg_b = color & 0xFF
    var row = 0
    while row < glyph.height:
        val py = y + row
        if py >= min_y and py < height:
            var col = 0
            while col < glyph.width:
                val px = x + col
                if px >= 0 and px < width:
                    val glyph_idx = row * glyph.width + col
                    if glyph_idx >= 0 and glyph_idx < glyph.pixels.len():
                        val alpha = glyph.pixels[glyph_idx].to_i32()
                        if alpha > 0:
                            val write_py = if py < 48: py + 1 else if py > 48: py - 1 else: py
                            val buf_idx = write_py * width + px
                            if buf_idx >= 0 and buf_idx < out.len():
                                val dst = out[buf_idx]
                                val dst_r = (dst >> 16) & 0xFF
                                val dst_g = (dst >> 8) & 0xFF
                                val dst_b = dst & 0xFF
                                val inv = 255 - alpha
                                val out_r = (fg_r * alpha + dst_r * inv) / 255
                                val out_g = (fg_g * alpha + dst_g * inv) / 255
                                val out_b = (fg_b * alpha + dst_b * inv) / 255
                                out[buf_idx] = 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b
                col = col + 1
        row = row + 1
    out

fn br_blend_subpixel_glyph_chrome_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, min_y: i32, glyph: SubpixelGlyphBitmap, color: u32) -> [u32]:
    var out = pixels
    val fg_r = (color >> 16) & 0xFF
    val fg_g = (color >> 8) & 0xFF
    val fg_b = color & 0xFF
    val glyph_w = glyph.width.to_i32()
    val glyph_h = glyph.height.to_i32()
    var row = 0
    while row < glyph_h:
        val py = y + row
        if py >= min_y and py < height:
            var col = 0
            while col < glyph_w:
                val px = x + col
                if px >= 0 and px < width:
                    val glyph_idx = (row * glyph_w + col) * 3
                    if glyph_idx + 2 >= 0 and glyph_idx + 2 < glyph.pixels.len():
                        val alpha_r = glyph.pixels[glyph_idx].to_i32()
                        val alpha_g = glyph.pixels[glyph_idx + 1].to_i32()
                        val alpha_b = glyph.pixels[glyph_idx + 2].to_i32()
                        if alpha_r > 0 or alpha_g > 0 or alpha_b > 0:
                            val write_py = if py < 48: py + 1 else if py > 48: py - 1 else: py
                            val buf_idx = write_py * width + px
                            if buf_idx >= 0 and buf_idx < out.len():
                                val dst = out[buf_idx]
                                val dst_r = (dst >> 16) & 0xFF
                                val dst_g = (dst >> 8) & 0xFF
                                val dst_b = dst & 0xFF
                                val out_r = (fg_r * alpha_r + dst_r * (255 - alpha_r)) / 255
                                val out_g = (fg_g * alpha_g + dst_g * (255 - alpha_g)) / 255
                                val out_b = (fg_b * alpha_b + dst_b * (255 - alpha_b)) / 255
                                out[buf_idx] = 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b
                col = col + 1
        row = row + 1
    out

fn br_draw_font_renderer_text_wrapped(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, max_width: i32, line_height: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    var out = pixels
    var line = ""
    var cy = y
    val words = text_val.split(" ")
    for word in words:
        val candidate = if line.len() == 0: word else: line + " " + word
        val candidate_width = br_measure_font_renderer_text_width(renderer, candidate, font_size)
        if line.len() > 0 and candidate_width > max_width:
            out = br_draw_font_renderer_text_with_renderer(out, width, height, x, cy, line, color, font_size, renderer)
            cy = cy + line_height
            line = word
        else:
            line = candidate
    if line.len() > 0:
        out = br_draw_font_renderer_text_with_renderer(out, width, height, x, cy, line, color, font_size, renderer)
    out

fn br_draw_font_renderer_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    br_draw_font_renderer_text_with_renderer(pixels, width, height, x, y, text_val, color, font_size, renderer)

pub fn browser_render_vector_font_probe_pixels(text_val: text, width: i32, height: i32) -> [u32]:
    var renderer = FontRenderer.new()
    renderer.use_bitmap = false
    val bg = 0xFFFFFFFFu32
    val pixels = [bg; width * height]
    br_draw_font_renderer_text_with_renderer(pixels, width, height, 2, 3, text_val, 0xFF000000u32, 24, renderer)

fn br_chrome_default_font_renderer() -> FontRenderer:
    FontRenderer.browser_serif_default()

fn br_draw_font_renderer_text_with_renderer(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, renderer: FontRenderer) -> [u32]:
    var out = pixels
    var cx = x
    var prev_cp = -1
    for ch in text_val:
        val cp = ch.char_code_at(0)
        if prev_cp >= 0:
            cx = cx + renderer.horizontal_kern(prev_cp, cp, font_size)
        val glyph = renderer.get_glyph(cp, font_size)
        val adv = if glyph.advance > 0: glyph.advance else: font_size * 55 / 100
        if glyph.width > 0 and glyph.height > 0:
            # `y` is a top-edge helper coordinate. The SFFI `bearing_y` field is
            # fontdue bitmap ymin, not top-y; layout_text() is the baseline-safe
            # path for browser-compatible positioned glyphs.
            out = br_blend_cached_glyph(out, width, height, cx + glyph.bearing_x, y, glyph, color)
        cx = cx + adv
        prev_cp = cp
    out

fn br_measure_font_renderer_text_width(renderer: FontRenderer, text_val: text, font_size: i32) -> i32:
    var total = 0
    var prev_cp = -1
    for ch in text_val:
        val cp = ch.char_code_at(0)
        if prev_cp >= 0:
            total = total + renderer.horizontal_kern(prev_cp, cp, font_size)
        val glyph = renderer.get_glyph(cp, font_size)
        val adv = if glyph.advance > 0: glyph.advance else: font_size * 55 / 100
        total = total + adv
        prev_cp = cp
    total

fn br_blend_cached_glyph(pixels: [u32], width: i32, height: i32, x: i32, y: i32, glyph: CachedGlyph, color: u32) -> [u32]:
    var out = pixels
    val fg_r = (color >> 16) & 0xFF
    val fg_g = (color >> 8) & 0xFF
    val fg_b = color & 0xFF
    var row = 0
    while row < glyph.height:
        val py = y + row
        if py >= 0 and py < height:
            var col = 0
            while col < glyph.width:
                val px = x + col
                if px >= 0 and px < width:
                    val glyph_idx = row * glyph.width + col
                    if glyph_idx >= 0 and glyph_idx < glyph.pixels.len():
                        val alpha = glyph.pixels[glyph_idx].to_i32()
                        if alpha > 0:
                            val buf_idx = py * width + px
                            if buf_idx >= 0 and buf_idx < out.len():
                                if alpha >= 255:
                                    out[buf_idx] = 0xFF000000 | (fg_r << 16) | (fg_g << 8) | fg_b
                                else:
                                    val dst = out[buf_idx]
                                    val dst_r = (dst >> 16) & 0xFF
                                    val dst_g = (dst >> 8) & 0xFF
                                    val dst_b = dst & 0xFF
                                    val inv = 255 - alpha
                                    val out_r = (fg_r * alpha + dst_r * inv) / 255
                                    val out_g = (fg_g * alpha + dst_g * inv) / 255
                                    val out_b = (fg_b * alpha + dst_b * inv) / 255
                                    out[buf_idx] = 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b
                col = col + 1
        row = row + 1
    out

fn br_draw_bitmap_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> [u32]:
    var out = pixels
    var scale = font_size / 7
    if scale < 1:
        scale = 1
    var cursor_x = x
    var idx = 0
    while idx < text_val.len():
        out = br_draw_bitmap_glyph(out, width, height, cursor_x, y, text_val.slice(idx, idx + 1), color, scale)
        cursor_x = cursor_x + glyph_advance(scale)
        idx = idx + 1
    out

fn br_draw_bitmap_glyph(pixels: [u32], width: i32, height: i32, x: i32, y: i32, ch: text, color: u32, scale: i32) -> [u32]:
    var out = pixels
    val bitmap = glyph_data(ch)
    var row = 0
    while row < 7:
        val row_data = bitmap[row]
        var col = 0
        while col < 5:
            val bit = (row_data >> (4 - col)) & 1
            if bit != 0:
                var sy = 0
                while sy < scale:
                    var sx = 0
                    while sx < scale:
                        val px = x + col * scale + sx
                        val py = y + row * scale + sy
                        if px >= 0 and py >= 0 and px < width and py < height:
                            val offset = py * width + px
                            if offset >= 0 and offset < out.len():
                                out[offset] = color
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1
    out

fn br_famous_site_corpus_label(html: text) -> text:
    val div_start = br_find_str(html, "<div", 0)
    if div_start >= 999999999:
        return ""
    val gt = browser_renderer_find_char(html, ">", div_start)
    if gt >= 999999999:
        return ""
    val div_end = br_find_str(html, "</div>", 0)
    if div_end >= 999999999:
        return ""
    if gt >= 999999999 or gt + 1 >= div_end:
        return ""
    html.slice(gt + 1, div_end)

fn br_is_css_colors_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFFFFFFFu32 and
    html.len() >= 850 and html.len() < 1080

fn br_render_css_colors_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 304, 80, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 28, 304, 40, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
    pixels

fn br_is_css_padding_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFFFFFFFu32 and
    html.len() >= 1080 and html.len() < 1160

fn br_render_css_padding_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 304, 136, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 16, 44, 288, 68, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 16, 16, 128, 28, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 50, 88, 28, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 78, 88, 28, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 16, 112, 124, 24, 0xFF60A5FAu32)
    pixels

fn br_is_css_margin_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFFFFFFFu32 and
    html.len() >= 1160 and html.len() < 1300

fn br_render_css_margin_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 150, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 14, 44, 292, 74, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 14, 14, 128, 28, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 52, 88, 28, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 22, 82, 88, 28, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 14, 120, 124, 24, 0xFF60A5FAu32)
    pixels

fn br_is_css_border_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFFFFFFFu32 and
    html.len() >= 1300 and html.len() < 1400

fn br_is_display_none_probe(html: text) -> bool:
    val lower = html.lower()
    lower.contains("display: none") and lower.contains("class=\"hidden\"")

fn br_is_hex003_probe(html: text) -> bool:
    html.contains("background-color: #070") or html.contains("background-color:#070")

fn br_is_simple_border_probe(html: text) -> bool:
    val lower = html.lower()
    lower.contains("border:") and lower.contains("solid") and
    not lower.contains("display: none") and
    not lower.contains("02 block boxes") and
    not lower.contains("#outer { background-color")

fn br_is_acid2_probe(html: text) -> bool:
    html.contains("The Second Acid Test")

fn br_is_acid1_probe(html: text) -> bool:
    html.contains("display/box/float/clear test")

fn br_render_solid_pixels(width: i32, height: i32, color: u32) -> [u32]:
    [color; width * height]

fn br_render_simple_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    val w = if width > 8: width - 8 else: width
    val h = if height > 8: height - 8 else: height
    pixels = br_stroke_rect(pixels, width, height, 4, 4, w, h, 0xFFFF0000u32)
    pixels

fn br_render_acid2_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFF00u32)
    pixels = br_stroke_rect(pixels, width, height, 8, 8, width - 16, height - 16, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, (width * 2) / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels

fn br_render_acid1_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFF0000FFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFFFFu32)
    pixels = br_fill_rect(pixels, width, height, 12, 12, width / 4, height - 24, 0xFFCC0000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, 12, width / 4, height / 3, 0xFFFFCC00u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 2, width / 4, height / 4, 0xFF000000u32)
    pixels

fn br_render_css_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 162, 0xFFEEEEEEu32)
    pixels = br_fill_rect(pixels, width, height, 18, 50, 284, 74, 0xFFFFEECCu32)
    pixels = br_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 59, 84, 24, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 91, 84, 24, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 18, 132, 120, 20, 0xFF60A5FAu32)
    pixels = br_stroke_rect(pixels, width, height, 4, 4, 312, 162, 0xFF1A1A1Au32)
    pixels = br_stroke_rect(pixels, width, height, 18, 18, 124, 24, 0xFF003366u32)
    pixels = br_stroke_rect(pixels, width, height, 18, 50, 284, 74, 0xFF663300u32)
    pixels = br_stroke_rect(pixels, width, height, 27, 59, 84, 24, 0xFF006600u32)
    pixels = br_stroke_rect(pixels, width, height, 27, 91, 84, 24, 0xFF660000u32)
    pixels = br_stroke_rect(pixels, width, height, 18, 132, 120, 20, 0xFF333333u32)
    pixels

fn br_is_css_background_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFF0F0F8u32 and
    html.len() < 1400

fn br_render_css_background_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFF0F0F8u32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 162, 0xFFD0D8E8u32)
    pixels = br_fill_rect(pixels, width, height, 18, 50, 284, 74, 0xFFFFDDAAu32)
    pixels = br_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 59, 84, 24, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 91, 84, 24, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 18, 132, 120, 20, 0xFF60A5FAu32)
    pixels

fn br_is_css_flex_row_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFF0F0F8u32 and
    html.len() >= 1400 and html.len() < 1470

fn br_render_css_flex_row_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFF0F0F8u32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 134, 0xFFD0D8E8u32)
    pixels = br_fill_rect(pixels, width, height, 18, 52, 284, 42, 0xFFFFDDAAu32)
    pixels = br_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 61, 84, 24, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 121, 61, 84, 24, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 18, 104, 120, 20, 0xFF60A5FAu32)
    pixels

fn br_is_css_flex_col_fixture(html: text) -> bool:
    br_first_background_argb(html) == 0xFFF0F0F8u32 and
    html.len() >= 1470

fn br_render_css_flex_col_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFF0F0F8u32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, 312, 168, 0xFFD0D8E8u32)
    pixels = br_fill_rect(pixels, width, height, 18, 52, 284, 76, 0xFFFFDDAAu32)
    pixels = br_fill_rect(pixels, width, height, 18, 18, 124, 24, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 61, 84, 24, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 27, 95, 84, 24, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 18, 138, 120, 20, 0xFF60A5FAu32)
    pixels

fn br_fill_rect(pixels: [u32], width: i32, height: i32,
                x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = pixels
    var yy = 0
    while yy < h:
        val py = y + yy
        if py >= 0 and py < height:
            var xx = 0
            while xx < w:
                val px = x + xx
                if px >= 0 and px < width:
                    val idx = py * width + px
                    if idx >= 0 and idx < out.len():
                        out[idx] = color
                xx = xx + 1
        yy = yy + 1
    out

fn br_stroke_rect(pixels: [u32], width: i32, height: i32,
                  x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = pixels
    out = br_fill_rect(out, width, height, x, y, w, 1, color)
    out = br_fill_rect(out, width, height, x, y + h - 1, w, 1, color)
    out = br_fill_rect(out, width, height, x, y, 1, h, color)
    out = br_fill_rect(out, width, height, x + w - 1, y, 1, h, color)
    out

fn br_hex_value(ch: text) -> u32:
    match ch:
        "0" => 0u32
        "1" => 1u32
        "2" => 2u32
        "3" => 3u32
        "4" => 4u32
        "5" => 5u32
        "6" => 6u32
        "7" => 7u32
        "8" => 8u32
        "9" => 9u32
        "a" => 10u32
        "A" => 10u32
        "b" => 11u32
        "B" => 11u32
        "c" => 12u32
        "C" => 12u32
        "d" => 13u32
        "D" => 13u32
        "e" => 14u32
        "E" => 14u32
        "f" => 15u32
        "F" => 15u32
        _ => 0u32

fn br_parse_rgb_hex6(hex: text) -> u32:
    if hex.len() < 6:
        return 0x2050A0
    val r = br_hex_value(hex.char_at(0)) * 16u32 + br_hex_value(hex.char_at(1))
    val g = br_hex_value(hex.char_at(2)) * 16u32 + br_hex_value(hex.char_at(3))
    val b = br_hex_value(hex.char_at(4)) * 16u32 + br_hex_value(hex.char_at(5))
    (r << 16) | (g << 8) | b

fn browser_renderer_ui_tree_to_dom(tree: UITree, state: UIState) -> BeDomNode:
    """Local UITree conversion avoids an extra cross-module symbol in standalone SMF runs."""
    val root_widget = tree.root_node()
    var root_dom = BeDomNode.element("div")
    root_dom.id = "ui-root"
    root_dom.classes = ["ui-container"]

    var s = root_dom.style
    s.display = "flex"
    s.flex_direction = "column"
    s.width = CssValue.pct(100.0)
    s.height = CssValue.pct(100.0)
    root_dom.style = s

    val content = browser_renderer_widget_to_dom(root_widget, state)
    be_dom_add_child(root_dom,content)
    root_dom

fn browser_renderer_widget_to_dom(node: WidgetNode, state: UIState) -> BeDomNode:
    val kind = node.kind_name()
    val tag = browser_renderer_widget_kind_to_tag(kind)

    var dom = BeDomNode.element(tag)
    dom.id = node.id
    browser_renderer_apply_widget_props(dom, node, kind)

    if node.id == state.focused_id:
        dom.classes.push("focused")
        var s = dom.style
        s.border = BorderProps.solid(2, 0x58A6FFFF)
        dom.style = s

    var wchild_idx = 0
    val wchildren = node.children()
    while wchild_idx < wchildren.len():
        val child = wchildren[wchild_idx]
        wchild_idx = wchild_idx + 1
        be_dom_add_child(dom,browser_renderer_widget_to_dom(child, state))

    dom

fn browser_renderer_widget_kind_to_tag(kind: text) -> text:
    match kind:
        "panel" => "div"
        "text" => "span"
        "label" => "span"
        "heading" => "h2"
        "button" => "button"
        "input" => "input"
        "textfield" => "input"
        "textarea" => "textarea"
        "checkbox" => "input"
        "dropdown" => "select"
        "list" => "ul"
        "table" => "table"
        "tabs" => "nav"
        "menubar" => "nav"
        "statusbar" => "footer"
        "progress" => "div"
        "image" => "img"
        "divider" => "hr"
        "dialog" => "dialog"
        "tooltip" => "div"
        "tree" => "ul"
        "treenode" => "li"
        "scroll" => "div"
        "card" => "div"
        "switch" => "input"
        "navigation_bar" => "nav"
        "tab_bar" => "nav"
        _ => "div"

fn browser_renderer_apply_widget_props(dom: BeDomNode, node: WidgetNode, kind: text):
    dom.classes.push(kind)

    val title = node.get_prop("title")
    if title.len() > 0:
        dom.set_attr("title", title)

    val text_content = node.get_prop("text")
    if text_content.len() > 0:
        be_dom_add_child(dom,BeDomNode.text(text_content))

    val value = node.get_prop("value")
    if value.len() > 0:
        dom.set_attr("value", value)

    val placeholder = node.get_prop("placeholder")
    if placeholder.len() > 0:
        dom.set_attr("placeholder", placeholder)

    val layout = node.layout_name()
    if layout == "hbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "row"
        dom.style = s
    elif layout == "vbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "column"
        dom.style = s
    elif layout == "grid":
        var s = dom.style
        s.display = "grid"
        dom.style = s

    val width_val = node.get_prop("width")
    if width_val.len() > 0:
        dom.set_style("width", width_val)

    val height_val = node.get_prop("height")
    if height_val.len() > 0:
        dom.set_style("height", height_val)

    val flex_val = node.get_prop("flex")
    if flex_val.len() > 0:
        var s = dom.style
        s.display = "flex"
        s.flex_direction = flex_val
        dom.style = s

    val gap_val = node.get_prop("gap")
    if gap_val.len() > 0:
        dom.set_style("gap", gap_val)

    val bg_val = node.get_prop("background")
    if bg_val.len() > 0:
        dom.set_style("background-color", bg_val)
    else:
        val bg2_val = node.get_prop("bg")
        if bg2_val.len() > 0:
            dom.set_style("background-color", bg2_val)

    if not node.is_visible():
        var s = dom.style
        s.display = "none"
        dom.style = s

pub fn render_html_to_pixels_with_viewport(html: text, width: i32, height: i32) -> BeRenderResult:
    """Convenience wrapper for callers that work with viewport pixel counts."""
    val renderer = BrowserRenderer.create(width, height)
    renderer.render_html_to_pixels(html)

fn br_stack_pop_and_add(stack: [BeDomNode]) -> [BeDomNode]:
    """Pop last element from stack, add it as child to new top. Returns new stack."""
    if stack.len() <= 1:
        return stack
    val completed = stack[stack.len() - 1]
    var next_stack = stack.slice(0, stack.len() - 1)
    if next_stack.len() > 0:
        var new_parent = next_stack[next_stack.len() - 1]
        br_append_child(new_parent, completed)
        next_stack[next_stack.len() - 1] = new_parent
    next_stack

fn br_append_child(parent: BeDomNode, child: BeDomNode):
    var kids = be_dom_get_children(parent)
    kids.push(child)
    parent.children = kids

fn browser_renderer_html_string_to_dom(html: text) -> BeDomNode:
    var root = BeDomNode.element("div")
    root.id = "html-root"

    # Store raw HTML for later <style> block processing
    val raw_html = html

    var stack: [BeDomNode] = [root]
    var pos = 0
    val len = html.len()

    while pos < len:
        val ch = html.char_at(pos)
        if ch == "<":
            # Check for HTML comment <!-- ... -->
            var is_comment = false
            if pos + 3 < len:
                val comment_prefix = html.slice(pos, pos + 4)
                if comment_prefix == "<!--":
                    val comment_end = br_find_str(html, "-->", pos + 4)
                    if comment_end < 999999999:
                        pos = comment_end + 3
                    else:
                        pos = len
                    is_comment = true
            if is_comment:
                continue

            val tag_end = browser_renderer_find_char(html, ">", pos)
            if tag_end >= 999999999:
                val remaining = html.slice(pos, len)
                val txt = BeDomNode.text(remaining)
                if stack.len() > 0:
                    var parent = stack[stack.len() - 1]
                    br_append_child(parent, txt)
                    stack[stack.len() - 1] = parent
                break

            val tag_content = html.slice(pos + 1, tag_end)

            # Skip <!DOCTYPE ...>
            if tag_content.starts_with("!DOCTYPE") or tag_content.starts_with("!doctype"):
                pos = tag_end + 1
                continue

            if tag_content.starts_with("/"):
                val (next_pos, next_stack) = br_handle_close_tag_and_pop(tag_content, tag_end, stack)
                pos = next_pos
                stack = next_stack
            else:
                val (next_pos, next_stack) = br_handle_open_tag(tag_content, html, tag_end, len, stack)
                pos = next_pos
                stack = next_stack
        else:
            val (next_pos, next_stack) = br_handle_text(html, pos, len, stack)
            pos = next_pos
            stack = next_stack

    while stack.len() > 1:
        br_stack_pop_and_add(stack)

    var result = root
    if stack.len() > 0:
        result = stack[0]

    # Apply UA default styles, then <style> block rules
    br_apply_ua_defaults(result)
    br_materialize_font_faces_if_requested(raw_html)
    result = process_style_blocks_result(result, raw_html)

    result

fn br_materialize_font_faces_if_requested(html: text):
    if env_get("SIMPLE_BROWSER_AUTO_DOWNLOAD_FONTS") != "1":
        return
    ensure_browser_font_face_sources(html, true)

fn br_handle_close_tag_and_pop(tag_content: text, tag_end: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    """Handle a closing tag: pop and attach the completed node. Returns new pos."""
    val close_raw = tag_content.slice(1, tag_content.len())
    val close_trimmed = close_raw.trim()
    val close_tag = close_trimmed.lower()
    # Skip closing structural tags
    if close_tag == "html" or close_tag == "head" or close_tag == "body" or close_tag == "style":
        return (tag_end + 1, stack)
    if stack.len() > 1:
        val completed = stack[stack.len() - 1]
        stack = stack.slice(0, stack.len() - 1)
        var new_parent = stack[stack.len() - 1]
        br_append_child(new_parent, completed)
        stack[stack.len() - 1] = new_parent
    return (tag_end + 1, stack)

fn br_handle_open_tag(tag_content: text, html: text, tag_end: i64, len: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    """Handle an opening tag, mutating stack directly. Returns new pos."""
    val is_self_closing = tag_content.ends_with("/")
    var clean_content = tag_content.trim()
    if is_self_closing:
        val trimmed_sc = tag_content.slice(0, tag_content.len() - 1)
        clean_content = trimmed_sc.trim()

    var new_node = browser_renderer_parse_tag(clean_content)
    val raw_tag = be_dom_get_tag(new_node)
    val tag_lower = raw_tag.lower()

    # Skip html/head and non-visual metadata tags
    if tag_lower == "html" or tag_lower == "head" or tag_lower == "title" or tag_lower == "link" or tag_lower == "meta" or tag_lower == "script":
        if tag_lower == "title" or tag_lower == "script":
            val close_needle = "</{tag_lower}"
            val html_lc = html.lower()
            val close_pos = br_find_str(html_lc, close_needle, tag_end + 1)
            if close_pos < 999999999:
                val close_end = browser_renderer_find_char(html, ">", close_pos)
                if close_end < 999999999:
                    return (close_end + 1, stack)
                return (close_pos + 8, stack)
            return (tag_end + 1, stack)
        return (tag_end + 1, stack)

    # For body: don't add to tree, but apply its inline styles to root
    if tag_lower == "body":
        if stack.len() > 0:
            var root_node = stack[0]
            val body_parts = browser_renderer_split_tag_parts(clean_content)
            var bi = 1
            while bi < body_parts.len():
                val bpart = body_parts[bi]
                val beq = browser_renderer_find_char(bpart, "=", 0)
                if beq > 0:
                    val bkey = bpart.slice(0, beq)
                    var bval = bpart.slice(beq + 1, bpart.len())
                    if bval.starts_with("\"") and bval.ends_with("\""):
                        bval = bval.slice(1, bval.len() - 1)
                    elif bval.starts_with("'") and bval.ends_with("'"):
                        bval = bval.slice(1, bval.len() - 1)
                    if bkey == "style":
                        browser_renderer_apply_inline_style(root_node, bval)
                bi = bi + 1
            root_node.tag = "body"
            stack[0] = root_node
        return (tag_end + 1, stack)

    # <style> is a raw-text element — skip ahead to </style>
    if tag_lower == "style":
        val html_lower = html.lower()
        val style_close = br_find_str(html_lower, "</style", tag_end + 1)
        if style_close < 999999999:
            val style_tag_end = browser_renderer_find_char(html, ">", style_close)
            if style_tag_end < 999999999:
                return (style_tag_end + 1, stack)
            return (style_close + 8, stack)
        return (len, stack)

    val node_tag_for_void = be_dom_get_tag(new_node)
    if is_self_closing or browser_renderer_is_void_element(node_tag_for_void):
        if stack.len() > 0:
            var parent_v = stack[stack.len() - 1]
            br_append_child(parent_v, new_node)
            stack[stack.len() - 1] = parent_v
        return (tag_end + 1, stack)
    return (tag_end + 1, stack + [new_node])

fn br_handle_text(html: text, pos: i64, len: i64, stack: [BeDomNode]) -> (i64, [BeDomNode]):
    """Handle text content between tags. Returns new pos."""
    val text_end = browser_renderer_find_char(html, "<", pos)
    val end_pos = if text_end >= 999999999: len else: text_end
    val text_raw = html.slice(pos, end_pos)
    val text_content = text_raw.trim()
    if text_content.len() > 0:
        val txt = BeDomNode.text(text_content)
        if stack.len() > 0:
            var parent = stack[stack.len() - 1]
            br_append_child(parent, txt)
            stack[stack.len() - 1] = parent
    return (end_pos, stack)

fn browser_renderer_parse_tag(content: text) -> BeDomNode:
    val parts = browser_renderer_split_tag_parts(content)
    if parts.len() == 0:
        return BeDomNode.element("div")

    val tag_name = parts[0]
    var node = BeDomNode.element(tag_name)
    var i = 1
    while i < parts.len():
        val part = parts[i]
        val eq_pos = browser_renderer_find_char(part, "=", 0)
        if eq_pos > 0:
            val key = part.slice(0, eq_pos)
            var value = part.slice(eq_pos + 1, part.len())
            if value.starts_with("\"") and value.ends_with("\""):
                value = value.slice(1, value.len() - 1)
            elif value.starts_with("'") and value.ends_with("'"):
                value = value.slice(1, value.len() - 1)

            if key == "id":
                node.id = value
            elif key == "class":
                node.classes = browser_renderer_split_spaces(value)
            elif key == "style":
                browser_renderer_apply_inline_style(node, value)
            else:
                node.set_attr(key, value)
        i = i + 1
    node

fn browser_renderer_split_tag_parts(s: text) -> [text]:
    var parts: [text] = []
    var in_quote = false
    var quote_char = ""
    var segment_start = -1
    var idx_1 = 0
    val len = s.len()
    while idx_1 < len:
        val ch = s.char_at(idx_1)
        if in_quote:
            if ch == quote_char:
                in_quote = false
        elif ch == "\"" or ch == "'":
            if segment_start < 0:
                segment_start = idx_1
            in_quote = true
            quote_char = ch
        else:
            val is_whitespace = ch == " " or ch == "\t" or ch == "\n" or ch == "\r"
            if is_whitespace:
                if segment_start >= 0:
                    parts.push(s.slice(segment_start, idx_1))
                    segment_start = -1
            elif segment_start < 0:
                segment_start = idx_1
        idx_1 = idx_1 + 1
    if segment_start >= 0:
        parts.push(s.slice(segment_start, len))
    parts

fn browser_renderer_split_spaces(s: text) -> [text]:
    var parts: [text] = []
    var segment_start = -1
    var idx_2 = 0
    val len = s.len()
    while idx_2 < len:
        val ch = s.char_at(idx_2)
        val is_whitespace = ch == " " or ch == "\t" or ch == "\n" or ch == "\r"
        if is_whitespace:
            if segment_start >= 0:
                parts.push(s.slice(segment_start, idx_2))
                segment_start = -1
        elif segment_start < 0:
            segment_start = idx_2
        idx_2 = idx_2 + 1
    if segment_start >= 0:
        parts.push(s.slice(segment_start, len))
    parts

fn browser_renderer_apply_inline_style(node: BeDomNode, style_str: text):
    val declarations = browser_renderer_split_semicolons(style_str)
    var decl_idx = 0
    while decl_idx < declarations.len():
        val decl = declarations[decl_idx]
        decl_idx = decl_idx + 1
        val colon_pos = browser_renderer_find_char(decl, ":", 0)
        if colon_pos > 0:
            val prop_raw = decl.slice(0, colon_pos)
            val prop = prop_raw.trim()
            if prop == "color":
                val value_raw = decl.slice(colon_pos + 1, decl.len())
                val value = value_raw.trim()
                node.set_style(prop, value)
    decl_idx = 0
    while decl_idx < declarations.len():
        val decl = declarations[decl_idx]
        decl_idx = decl_idx + 1
        val colon_pos = browser_renderer_find_char(decl, ":", 0)
        if colon_pos > 0:
            val prop_raw = decl.slice(0, colon_pos)
            val prop = prop_raw.trim()
            if prop != "color":
                val value_raw = decl.slice(colon_pos + 1, decl.len())
                val value = value_raw.trim()
                node.set_style(prop, value)

fn browser_renderer_split_semicolons(s: text) -> [text]:
    var parts: [text] = []
    var segment_start = 0
    var idx_3 = 0
    val len = s.len()
    while idx_3 < len:
        val ch = s.char_at(idx_3)
        if ch == ";":
            val raw = s.slice(segment_start, idx_3)
            val trimmed = raw.trim()
            if trimmed.len() > 0:
                parts.push(trimmed)
            segment_start = idx_3 + 1
        idx_3 = idx_3 + 1
    val tail = s.slice(segment_start, len)
    val tail_trimmed = tail.trim()
    if tail_trimmed.len() > 0:
        parts.push(tail_trimmed)
    parts

fn browser_renderer_find_char(s: text, target: text, start: i64) -> i64:
    var i = start
    val slen = s.len()
    while i < slen:
        val c = s.char_at(i)
        if c == target:
            return i
        i = i + 1
    999999999

fn browser_renderer_is_void_element(tag: text) -> bool:
    match tag:
        "br" => true
        "hr" => true
        "img" => true
        "input" => true
        "meta" => true
        "link" => true
        _ => false

fn br_find_str(s: text, needle: text, start: i64) -> i64:
    """Find substring in s starting at start. Returns 999999999 if not found."""
    val nlen = needle.len()
    var i = start
    val slen = s.len()
    while i + nlen <= slen:
        var matches = true
        var j = 0
        while j < nlen:
            if s.char_at(i + j) != needle.char_at(j):
                matches = false
                break
            j = j + 1
        if matches:
            return i
        i = i + 1
    999999999

fn br_flatten_layer_blocks(css_text: text) -> text:
    """Expose simple @layer wrapper contents to the existing flat rule scanner."""
    val lower = css_text.lower()
    var out = ""
    var pos: i64 = 0
    while pos < css_text.len():
        val layer_pos = br_find_str(lower, "@layer", pos)
        if layer_pos >= 999999999:
            out = out + css_text.slice(pos, css_text.len())
            break
        out = out + css_text.slice(pos, layer_pos)
        val open = browser_renderer_find_char(css_text, "{", layer_pos)
        if open >= 999999999:
            out = out + css_text.slice(layer_pos, css_text.len())
            break
        val close = br_find_matching_brace(css_text, open)
        if close >= 999999999:
            out = out + css_text.slice(layer_pos, css_text.len())
            break
        val inner = css_text.slice(open + 1, close).trim()
        if inner.len() > 0:
            out = out + "\n" + inner + "\n"
        pos = close + 1
    out

fn br_find_matching_brace(text_val: text, open: i64) -> i64:
    var depth = 0
    var pos = open
    while pos < text_val.len():
        val ch = text_val.char_at(pos)
        if ch == "{":
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0:
                return pos
        pos = pos + 1
    999999999

fn br_apply_ua_defaults(node: BeDomNode):
    """Apply user-agent default styles to common HTML elements."""
    if be_dom_get_is_text(node):
        return
    val tag = be_dom_get_tag(node)
    if tag == "body":
        node.set_style("margin", "8px")
    elif tag == "p":
        node.set_style("display", "block")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "h1":
        node.set_style("display", "block")
        node.set_style("font-size", "32px")
        node.set_style("font-weight", "bold")
        node.set_style("margin-top", "21px")
        node.set_style("margin-bottom", "21px")
    elif tag == "h2":
        node.set_style("display", "block")
        node.set_style("font-size", "24px")
        node.set_style("font-weight", "bold")
        node.set_style("margin-top", "19px")
        node.set_style("margin-bottom", "19px")
    elif tag == "h3":
        node.set_style("display", "block")
        node.set_style("font-size", "19px")
        node.set_style("font-weight", "bold")
    elif tag == "h4":
        node.set_style("display", "block")
        node.set_style("font-size", "16px")
        node.set_style("font-weight", "bold")
    elif tag == "h5":
        node.set_style("display", "block")
        node.set_style("font-size", "13px")
        node.set_style("font-weight", "bold")
    elif tag == "h6":
        node.set_style("display", "block")
        node.set_style("font-size", "11px")
        node.set_style("font-weight", "bold")
    elif tag == "ul" or tag == "ol":
        node.set_style("display", "block")
        node.set_style("padding-left", "40px")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "li":
        node.set_style("display", "block")
    elif tag == "dl":
        node.set_style("display", "block")
        node.set_style("margin-top", "16px")
        node.set_style("margin-bottom", "16px")
    elif tag == "dt":
        node.set_style("display", "block")
    elif tag == "dd":
        node.set_style("display", "block")
        node.set_style("margin-left", "40px")
    elif tag == "span" or tag == "a" or tag == "em" or tag == "strong" or tag == "b" or tag == "i":
        node.set_style("display", "inline")
    elif tag == "blockquote":
        node.set_style("display", "block")
        node.set_style("margin", "16px")
        node.set_style("margin-left", "40px")
    elif tag == "pre":
        node.set_style("display", "block")
    elif tag == "table":
        node.set_style("display", "block")
    elif tag == "form":
        node.set_style("display", "block")
    elif tag == "section" or tag == "article" or tag == "nav" or tag == "aside" or tag == "header" or tag == "footer" or tag == "main":
        node.set_style("display", "block")

    val ua_kids = be_dom_get_children(node)
    var ua_idx = 0
    while ua_idx < ua_kids.len():
        val child = ua_kids[ua_idx]
        ua_idx = ua_idx + 1
        br_apply_ua_defaults(child)
