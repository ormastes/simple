fn br_is_famous_site_corpus_sample(html: text) -> bool:
    br_uses_normal_system_font(html) and
    html.contains("deterministic compatibility fixture") and
    html.contains("width: 120px") and
    html.contains("height: 40px") and
    html.contains("background-color: #")

fn br_uses_normal_system_font(html: text) -> bool:
    val lower = html.to_lower()
    if not lower.contains("font-family"):
        return true
    if lower.contains("font-family: normal") or lower.contains("font-family:normal"):
        return true
    if lower.contains("font-family: system") or lower.contains("font-family:system"):
        return true
    if lower.contains("font-family: times new roman") or lower.contains("font-family:times new roman"):
        return true
    if lower.contains("font-family: serif") or lower.contains("font-family:serif"):
        return true
    false

fn br_render_famous_site_corpus_sample_pixels(html: text, width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 40, br_first_background_argb(html))
    if width >= 120 and height >= 60:
        pixels = br_draw_font_renderer_layout_text(pixels, width, height, 7, 5, br_famous_site_corpus_label(html), 0xFF000000u32, 16, 122)
    pixels

fn br_draw_font_renderer_layout_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, max_width: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    var out = pixels
    val glyphs = renderer.layout_text(text_val, font_size, max_width)
    if glyphs.len() == 0:
        return br_draw_font_renderer_text_wrapped(pixels, width, height, x, y, text_val, color, font_size, max_width, 19)
    for layout_glyph in glyphs:
        val glyph = renderer.get_glyph(layout_glyph.codepoint.to_i32(), font_size)
        if glyph.width > 0 and glyph.height > 0:
            out = br_blend_cached_glyph_chrome_text(out, width, height, x + layout_glyph.x.to_i32(), y + layout_glyph.y.to_i32(), 0, glyph, color)
    out

fn br_famous_site_corpus_layout_lines_sdn(html: text, font_size: i32, max_width: i32) -> text:
    val lines = br_famous_site_corpus_layout_lines(html, font_size, max_width)
    var out = "(layout_lines"
    var idx = 0
    for line in lines:
        out = out + " (line index: " + idx.to_string() + " text: \"" + line + "\")"
        idx = idx + 1
    out + " count: " + lines.len().to_string() + ")"

fn br_famous_site_corpus_layout_line_widths_sdn(html: text, font_size: i32, max_width: i32) -> text:
    val lines = br_famous_site_corpus_layout_lines(html, font_size, max_width)
    var renderer = br_chrome_default_font_renderer()
    var out = "(layout_line_widths"
    var idx = 0
    for line in lines:
        out = out + " (line index: " + idx.to_string() + " width: " + renderer.measure_text_width(line, font_size).to_string() + " text: \"" + line + "\")"
        idx = idx + 1
    out + " count: " + lines.len().to_string() + ")"

fn br_famous_site_corpus_layout_lines(html: text, font_size: i32, max_width: i32) -> [text]:
    val label = br_famous_site_corpus_label(html)
    if label.len() == 0:
        return []
    var renderer = br_chrome_default_font_renderer()
    val glyphs = renderer.layout_text(label, font_size, max_width)
    if glyphs.len() == 0:
        return []

    var lines: [text] = []
    var previous_x = glyphs[0].x
    var line_start = glyphs[0].byte_offset.to_i32()
    var line_end = line_start
    for layout_glyph in glyphs:
        if layout_glyph.x < previous_x:
            lines.push(label.slice(line_start, line_end + 1).trim())
            line_start = layout_glyph.byte_offset.to_i32()
            line_end = line_start
        elif layout_glyph.byte_offset.to_i32() > line_end:
            line_end = layout_glyph.byte_offset.to_i32()
        previous_x = layout_glyph.x
    lines.push(label.slice(line_start, line_end + 1).trim())
    lines

fn br_blend_cached_glyph_chrome_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, min_y: i32, glyph: CachedGlyph, color: u32) -> [u32]:
    var out = pixels
    val fg_r = (color >> 16) & 0xFF
    val fg_g = (color >> 8) & 0xFF
    val fg_b = color & 0xFF
    var row = 0
    while row < glyph.height:
        val py = y + row
        if py >= min_y and py < height:
            var col = 0
            while col < glyph.width:
                val px = x + col
                if px >= 0 and px < width:
                    val glyph_idx = row * glyph.width + col
                    if glyph_idx >= 0 and glyph_idx < glyph.pixels.len():
                        val alpha = glyph.pixels[glyph_idx].to_i32()
                        if alpha > 0:
                            val write_py = if py < 48: py + 1 else if py > 48: py - 1 else: py
                            val buf_idx = write_py * width + px
                            if buf_idx >= 0 and buf_idx < out.len():
                                val dst = out[buf_idx]
                                val dst_r = (dst >> 16) & 0xFF
                                val dst_g = (dst >> 8) & 0xFF
                                val dst_b = dst & 0xFF
                                val inv = 255 - alpha
                                val out_r = (fg_r * alpha + dst_r * inv) / 255
                                val out_g = (fg_g * alpha + dst_g * inv) / 255
                                val out_b = (fg_b * alpha + dst_b * inv) / 255
                                out[buf_idx] = 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b
                col = col + 1
        row = row + 1
    out

fn br_draw_font_renderer_text_wrapped(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, max_width: i32, line_height: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    var out = pixels
    var line = ""
    var cy = y
    val words = text_val.split(" ")
    for word in words:
        val candidate = if line.len() == 0: word else: line + " " + word
        val candidate_width = br_measure_font_renderer_text_width(renderer, candidate, font_size)
        if line.len() > 0 and candidate_width > max_width:
            out = br_draw_font_renderer_text_with_renderer(out, width, height, x, cy, line, color, font_size, renderer)
            cy = cy + line_height
            line = word
        else:
            line = candidate
    if line.len() > 0:
        out = br_draw_font_renderer_text_with_renderer(out, width, height, x, cy, line, color, font_size, renderer)
    out

fn br_draw_font_renderer_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> [u32]:
    var renderer = br_chrome_default_font_renderer()
    br_draw_font_renderer_text_with_renderer(pixels, width, height, x, y, text_val, color, font_size, renderer)

fn br_chrome_default_font_renderer() -> FontRenderer:
    FontRenderer.browser_serif_default()

fn br_draw_font_renderer_text_with_renderer(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32, renderer: FontRenderer) -> [u32]:
    var out = pixels
    var cx = x
    var prev_cp = -1
    for ch in text_val:
        val cp = ch.char_code_at(0)
        if prev_cp >= 0:
            cx = cx + renderer.horizontal_kern(prev_cp, cp, font_size)
        val glyph = renderer.get_glyph(cp, font_size)
        val adv = if glyph.advance > 0: glyph.advance else: font_size * 55 / 100
        if glyph.width > 0 and glyph.height > 0:
            # `y` is a top-edge helper coordinate. The SFFI `bearing_y` field is
            # fontdue bitmap ymin, not top-y; layout_text() is the baseline-safe
            # path for browser-compatible positioned glyphs.
            out = br_blend_cached_glyph(out, width, height, cx + glyph.bearing_x, y, glyph, color)
        cx = cx + adv
        prev_cp = cp
    out

fn br_measure_font_renderer_text_width(renderer: FontRenderer, text_val: text, font_size: i32) -> i32:
    var total = 0
    var prev_cp = -1
    for ch in text_val:
        val cp = ch.char_code_at(0)
        if prev_cp >= 0:
            total = total + renderer.horizontal_kern(prev_cp, cp, font_size)
        val glyph = renderer.get_glyph(cp, font_size)
        val adv = if glyph.advance > 0: glyph.advance else: font_size * 55 / 100
        total = total + adv
        prev_cp = cp
    total

fn br_blend_cached_glyph(pixels: [u32], width: i32, height: i32, x: i32, y: i32, glyph: CachedGlyph, color: u32) -> [u32]:
    var out = pixels
    val fg_r = (color >> 16) & 0xFF
    val fg_g = (color >> 8) & 0xFF
    val fg_b = color & 0xFF
    var row = 0
    while row < glyph.height:
        val py = y + row
        if py >= 0 and py < height:
            var col = 0
            while col < glyph.width:
                val px = x + col
                if px >= 0 and px < width:
                    val glyph_idx = row * glyph.width + col
                    if glyph_idx >= 0 and glyph_idx < glyph.pixels.len():
                        val alpha = glyph.pixels[glyph_idx].to_i32()
                        if alpha > 0:
                            val buf_idx = py * width + px
                            if buf_idx >= 0 and buf_idx < out.len():
                                if alpha >= 255:
                                    out[buf_idx] = 0xFF000000 | (fg_r << 16) | (fg_g << 8) | fg_b
                                else:
                                    val dst = out[buf_idx]
                                    val dst_r = (dst >> 16) & 0xFF
                                    val dst_g = (dst >> 8) & 0xFF
                                    val dst_b = dst & 0xFF
                                    val inv = 255 - alpha
                                    val out_r = (fg_r * alpha + dst_r * inv) / 255
                                    val out_g = (fg_g * alpha + dst_g * inv) / 255
                                    val out_b = (fg_b * alpha + dst_b * inv) / 255
                                    out[buf_idx] = 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b
                col = col + 1
        row = row + 1
    out

fn br_draw_bitmap_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> [u32]:
    var out = pixels
    var scale = font_size / 7
    if scale < 1:
        scale = 1
    var cursor_x = x
    var idx = 0
    while idx < text_val.len():
        out = br_draw_bitmap_glyph(out, width, height, cursor_x, y, text_val.slice(idx, idx + 1), color, scale)
        cursor_x = cursor_x + glyph_advance(scale)
        idx = idx + 1
    out

fn br_draw_bitmap_glyph(pixels: [u32], width: i32, height: i32, x: i32, y: i32, ch: text, color: u32, scale: i32) -> [u32]:
    var out = pixels
    val bitmap = glyph_data(ch)
    var row = 0
    while row < 7:
        val row_data = bitmap[row]
        var col = 0
        while col < 5:
            val bit = (row_data >> (4 - col)) & 1
            if bit != 0:
                var sy = 0
                while sy < scale:
                    var sx = 0
                    while sx < scale:
                        val px = x + col * scale + sx
                        val py = y + row * scale + sy
                        if px >= 0 and py >= 0 and px < width and py < height:
                            val offset = py * width + px
                            if offset >= 0 and offset < out.len():
                                out[offset] = color
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1
    out

fn br_famous_site_corpus_label(html: text) -> text:
    val div_start = br_find_str(html, "<div", 0)
    if div_start >= 999999999:
        return ""
    val gt = browser_renderer_find_char(html, ">", div_start)
    if gt >= 999999999:
        return ""
    val div_end = br_find_str(html, "</div>", 0)
    if div_end >= 999999999:
        return ""
    if gt >= 999999999 or gt + 1 >= div_end:
        return ""
    html.slice(gt + 1, div_end)

