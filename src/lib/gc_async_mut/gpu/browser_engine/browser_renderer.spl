fn br_style_block_rule_for_has_descendant(html: text, subject_selector: text, content_start: i64) -> text:
    val subject = subject_selector.trim().lower()
    if subject.len() == 0:
        return ""
    val lower_html = html.lower()
    val subject_close = br_find_str(lower_html, "</" + subject, content_start)
    if subject_close >= 999999999:
        return ""
    val subtree = lower_html.slice(content_start, subject_close)
    var out = ""
    var search_pos: i64 = 0
    while search_pos < html.len():
        val style_pos = br_find_str(lower_html, "<style", search_pos)
        if style_pos >= 999999999:
            return out
        val style_open_end = browser_renderer_find_char(html, ">", style_pos)
        if style_open_end >= 999999999:
            return out
        val style_close = br_find_str(lower_html, "</style", style_open_end + 1)
        if style_close >= 999999999:
            return out
        val css = br_flatten_layer_blocks(html.slice(style_open_end + 1, style_close))
        var rule_start: i64 = 0
        while rule_start < css.len():
            val open = browser_renderer_find_char(css, "{", rule_start)
            if open >= 999999999:
                break
            val close = browser_renderer_find_char(css, "}", open + 1)
            if close >= 999999999:
                break
            val selector_list = css.slice(rule_start, open)
            if br_selector_list_contains_has_descendant(selector_list, subject, subtree):
                out = br_merge_style_text(out, css.slice(open + 1, close).trim())
            rule_start = close + 1
        search_pos = style_close + 1
    out

