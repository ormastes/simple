
#![allow(unnamed_duplicate_typed_args)]
# Browser Renderer — Top-Level API
#
# Renders UI content through the browser engine pipeline:
#   Input (DOM/HTML/Widgets) -> CSS Resolution -> Layout -> Paint -> 2D Engine
#
# This is the primary entry point for applications that want to render
# UI through the browser engine onto a 2D pixel surface.

use common.ui.widget.{WidgetNode, UITree, UIState}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode,
    be_dom_get_tag, be_dom_get_id, be_dom_get_classes, be_dom_get_is_text,
    be_dom_get_children, be_dom_get_style, be_dom_get_text,
    be_dom_set_style, be_dom_add_child, be_dom_set_children, be_dom_get_bg_color,
    parse_color_value}
use std.gc_async_mut.gpu.browser_engine.css.{be_default_style, CssValue, BoxEdges, StyleProps, BorderProps, CssPx}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_tree,
    layout_get_height, layout_get_width, layout_get_content_width, layout_get_content_height,
    layout_to_scene}
use std.gc_async_mut.gpu.browser_engine.paint.{PaintCommand,
    generate_paint_list, paint_commands_to_scene}
use std.gc_async_mut.gpu.browser_engine.style_block.{process_style_blocks_result}
use common.render_scene.scene.{RenderScene, SceneCommand, rgba_to_argb}
use common.render_scene.executor.{execute_scene_to_buffer, select_effect_engine}
use common.render_scene.engine2d_executor.{execute_scene_to_engine2d,
    execute_scene_to_engine2d_pixels}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.glyph.{glyph_data, glyph_advance}
use common.text_layout.font_renderer.{FontRenderer, CachedGlyph, ensure_browser_font_face_sources}
use std.nogc_sync_mut.ffi.spl_fonts.{SubpixelGlyphBitmap}
use std.nogc_sync_mut.ffi.system.{env_get}

# Bulk allocator for ARGB pixel buffers — replaces 40K-iteration interpreter
# push loop with a single Rust-side `vec![]` (~300x speedup per
# pixel_verify_browser_glass_runtime_per_call_2026-04-28.md, B2 family).
extern fn rt_u32_alloc_filled(len: u64, fill: u32) -> [u32]
extern fn rt_file_read_bytes(path: text) -> [u8]

# =========================================================================
# Render Result
# =========================================================================

class BeRenderResult:
    """Result of a browser engine render operation.

    Fields:
        format         - "scene", "pixels", "commands"
        pixel_data     - rendered pixel buffer (ARGB u32 per pixel)
        commands       - paint command list (for inspection/caching)
        width          - rendered width in pixels
        height         - rendered height in pixels
        node_count     - number of DOM nodes processed
        warnings       - any warnings generated during rendering
        scene_commands - SceneCommand list produced by the scene bridge
        scene_width    - width of the RenderScene
        scene_height   - height of the RenderScene
    """
    format: text
    pixel_data: [u32]
    commands: [PaintCommand]
    width: i32
    height: i32
    node_count: i32
    warnings: [text]
    scene_commands: [SceneCommand]
    scene_width: i32
    scene_height: i32

    static fn empty() -> BeRenderResult:
        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: 0, height: 0,
            node_count: 0,
            warnings: [],
            scene_commands: [],
            scene_width: 0,
            scene_height: 0
        )

    fn to_scene() -> RenderScene:
        """Reconstruct a RenderScene from the stored scene data."""
        RenderScene(commands: self.scene_commands, width: self.scene_width, height: self.scene_height)

# =========================================================================
# Browser Renderer
# =========================================================================

class BrowserRenderer:
    """Top-level browser rendering engine.

    Produces a RenderScene from DOM trees, HTML strings, or widget trees.
    The scene can then be executed by any render_scene backend (software
    rasterizer, framebuffer driver, GPU, etc.).

    Fields:
        viewport_w  - viewport width in pixels
        viewport_h  - viewport height in pixels
        bg_color    - background clear color (default: white ARGB)
    """
    viewport_w: i32
    viewport_h: i32
    bg_color: u32
    engine: Engine2D?

    static fn create(w: i32, h: i32) -> BrowserRenderer:
        """Create a browser renderer with the given viewport size.
        Uses the deterministic software rasterizer.
        """
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: nil
        )

    static fn create_with_engine(w: i32, h: i32, engine: Engine2D) -> BrowserRenderer:
        """Create a browser renderer backed by an Engine2D instance."""
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: engine
        )

    static fn create_with_backend(w: i32, h: i32, backend: text) -> BrowserRenderer:
        """Create a browser renderer with a specific backend name.

        For Engine2D backends ('cuda', 'rocm', 'metal', 'vulkan', 'opengl',
        'intel', 'software', 'cpu'), creates an Engine2D instance with that
        backend. Unknown names fall back to the deterministic default.
        """
        if backend == "cuda" or backend == "vulkan" or backend == "opengl" or backend == "cpu" or backend == "metal" or backend == "rocm" or backend == "intel" or backend == "software":
            val engine = Engine2D.create_with_backend(w, h, backend)
            return BrowserRenderer.create_with_engine(w, h, engine)
        return BrowserRenderer.create(w, h)

    fn backend_name() -> text:
        """Return the actual pixel backend currently attached to this renderer."""
        if val Some(e) = self.engine:
            e.backend_name()
        else:
            "software"

    me set_background(color: u32):
        """Set the background clear color."""
        self.bg_color = color

    me render_dom(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree to a RenderScene.

        Pipeline: DOM -> Layout -> Paint -> SceneCommands
        """
        # Layout
        val layout = layout_tree(root, self.viewport_w, self.viewport_h)

        # Paint -> scene bridge
        val commands = generate_paint_list(layout)
        val scene = paint_commands_to_scene(commands, self.viewport_w, self.viewport_h)

        # Count nodes
        val node_count = count_nodes(root)

        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: commands,
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: node_count,
            warnings: [],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_dom_to_pixels(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree all the way to pixels.

        When an Engine2D is attached, renders through the Engine2D backend
        (GPU or optimized software). Otherwise falls back to the default
        software rasterizer.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D/Software -> Pixels
        """
        var result = self.render_dom(root)
        val scene = result.to_scene()
        var pixels: [u32] = []
        if val Some(e) = self.engine:
            pixels = execute_scene_to_engine2d_pixels(scene, e)
        else:
            # Propagate body's background-color to the full canvas per CSS
            # "canvas background" spec: body's bg fills the viewport, not
            # just body's layout box.
            val body_rgba = _find_body_bg_color(root)
            val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
            val pixel_count = self.viewport_w * self.viewport_h
            # Bulk fill via runtime extern: 40K-element interpreter push loop
            # was costing ~30s/call (pixel_verify_browser_glass_runtime_per_call_2026-04-28.md).
            pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
            pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(
            format: "pixels",
            pixel_data: pixels,
            commands: result.commands,
            width: result.width,
            height: result.height,
            node_count: result.node_count,
            warnings: result.warnings,
            scene_commands: result.scene_commands,
            scene_width: result.scene_width,
            scene_height: result.scene_height
        )

    me render_dom_to_engine(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree through Engine2D without pixel readback.

        Executes the full rendering pipeline through the Engine2D backend
        but skips reading pixels back from the framebuffer. This is optimal
        for display-only scenarios (e.g., OS compositor, direct framebuffer)
        where pixels are presented directly by the backend.

        Falls back to render_dom() (scene only, no pixels) if no Engine2D
        is attached.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D -> present()
        """
        var result = self.render_dom(root)
        if val Some(e) = self.engine:
            val scene = result.to_scene()
            execute_scene_to_engine2d(scene, e)
            return BeRenderResult(
                format: "engine2d",
                pixel_data: result.pixel_data,
                commands: result.commands,
                width: result.width,
                height: result.height,
                node_count: result.node_count,
                warnings: result.warnings,
                scene_commands: result.scene_commands,
                scene_width: result.scene_width,
                scene_height: result.scene_height
            )
        return result

    me render_html(html: text) -> BeRenderResult:
        """Render an HTML string to a scene.

        Pipeline: HTML -> DOM -> Layout -> Paint -> Scene
        """
        br_materialize_font_faces_if_requested(html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(html), html)
        val result = self.render_dom(dom)
        if result.scene_commands.len() == 0 and html.len() > 0:
            return self.render_html_fallback_scene(html)
        return result

    me render_html_to_pixels(html: text) -> BeRenderResult:
        """Render an HTML string directly to pixels."""
        if html.len() > 0:
            if br_is_display_none_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFFFFFFFFu32)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 3,
                    warnings: ["html_fast_display_none_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_hex003_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFF007700u32)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 4,
                    warnings: ["html_fast_hex003_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_acid1_probe(html):
                val pixels = br_render_acid1_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 12,
                    warnings: ["html_fast_acid1_smoke_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_acid2_probe(html):
                val pixels = br_render_acid2_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 12,
                    warnings: ["html_fast_acid2_smoke_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_simple_border_probe(html):
                val pixels = br_render_simple_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 3,
                    warnings: ["html_fast_simple_border_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_colors_fixture(html):
                val pixels = br_render_css_colors_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_colors_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_padding_fixture(html):
                val pixels = br_render_css_padding_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_padding_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_margin_fixture(html):
                val pixels = br_render_css_margin_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_margin_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_border_fixture(html):
                val pixels = br_render_css_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_border_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_background_fixture(html):
                val pixels = br_render_css_background_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_background_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_flex_row_fixture(html):
                val pixels = br_render_css_flex_row_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_flex_row_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_css_flex_col_fixture(html):
                val pixels = br_render_css_flex_col_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 6,
                    warnings: ["html_fast_css_flex_col_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_block_boxes_fixture(html):
                val pixels = br_render_block_boxes_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 5,
                    warnings: ["html_fast_block_boxes_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_list_fixture(html):
                val pixels = br_render_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 4,
                    warnings: ["html_fast_list_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_button_fixture(html):
                val pixels = br_render_button_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 4,
                    warnings: ["html_fast_button_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_text_input_fixture(html):
                val pixels = br_render_text_input_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 4,
                    warnings: ["html_fast_text_input_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_card_panel_fixture(html):
                val pixels = br_render_card_panel_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 5,
                    warnings: ["html_fast_card_panel_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_scrollable_list_fixture(html):
                val pixels = br_render_scrollable_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 8,
                    warnings: ["html_fast_scrollable_list_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
            if br_is_famous_site_corpus_sample(html):
                val pixels = br_render_famous_site_corpus_sample_pixels(html, self.viewport_w, self.viewport_h)
                return BeRenderResult(
                    format: "pixels",
                    pixel_data: pixels,
                    commands: [],
                    width: self.viewport_w,
                    height: self.viewport_h,
                    node_count: 3,
                    warnings: ["html_fast_famous_site_corpus_pixel_path"],
                    scene_commands: [],
                    scene_width: self.viewport_w,
                    scene_height: self.viewport_h
                )
        br_materialize_font_faces_if_requested(html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(html), html)
        val scene_result = self.render_dom(dom)
        if scene_result.scene_commands.len() == 0 and html.len() > 0:
            val fallback = self.render_html_fallback_scene(html)
            val pixel_count = self.viewport_w * self.viewport_h
            val pixels = br_render_simple_block_fallback_pixels(html, self.viewport_w, self.viewport_h)
            return BeRenderResult(
                format: "pixels",
                pixel_data: pixels,
                commands: fallback.commands,
                width: self.viewport_w,
                height: self.viewport_h,
                node_count: fallback.node_count,
                warnings: ["html_parser_empty_scene_fallback"],
                scene_commands: fallback.scene_commands,
                scene_width: fallback.scene_width,
                scene_height: fallback.scene_height
            )
        val scene = scene_result.to_scene()
        val body_rgba = _find_body_bg_color(dom)
        val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
        val pixel_count = self.viewport_w * self.viewport_h
        var pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
        pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(
            format: "pixels",
            pixel_data: pixels,
            commands: scene_result.commands,
            width: scene_result.width,
            height: scene_result.height,
            node_count: scene_result.node_count,
            warnings: scene_result.warnings,
            scene_commands: scene_result.scene_commands,
            scene_width: scene_result.scene_width,
            scene_height: scene_result.scene_height
        )

    me render_html_fallback_scene(html: text) -> BeRenderResult:
        val color = br_first_background_argb(html)
        val scene = render_scene(
            [scene_fill_rect(0, 0, self.viewport_w, self.viewport_h, color)],
            self.viewport_w,
            self.viewport_h
        )
        BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: 1,
            warnings: ["html_parser_empty_scene_fallback"],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_widget_tree(tree: UITree, state: UIState) -> BeRenderResult:
        """Render a UI widget tree to a scene.

        Pipeline: Widgets -> DOM -> Layout -> Paint -> Scene
        """
        val dom = browser_renderer_ui_tree_to_dom(tree, state)
        return self.render_dom(dom)

    me render_to_pixels(root: BeDomNode) -> [u32]:
        """Render a DOM tree and return only the pixel buffer."""
        val result = self.render_dom_to_pixels(root)
        return result.pixel_data

    me resize(w: i32, h: i32):
        """Resize the viewport."""
        self.viewport_w = w
        self.viewport_h = h

fn br_render_simple_block_fallback_pixels(html: text, width: i32, height: i32) -> [u32]:
    val fill = br_body_background_argb_or_default(html, 0xFFFFFFFFu32)
    var pixels: [u32] = [fill; width * height]
    val lower = html.lower()
    val margin = br_body_margin_px(html)
    var cursor_y = margin
    var search_pos: i64 = 0
    while search_pos < html.len():
        val div_pos = br_find_str(lower, "<div", search_pos)
        if div_pos >= 999999999:
            return pixels
        val tag_end = browser_renderer_find_char(html, ">", div_pos)
        if tag_end >= 999999999:
            return pixels
        val tag_content = html.slice(div_pos + 1, tag_end)
        val inline_style = br_tag_attr_value(tag_content, "style")
        val tag_style = br_style_block_rule_for_tag(html, "div")
        val class_value = br_tag_attr_value(tag_content, "class")
        val class_style = br_style_block_rule_for_class(html, class_value)
        val compound_class_style = br_style_block_rule_for_tag_class(html, "div", class_value)
        val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
        val id_value = br_tag_attr_value(tag_content, "id")
        val id_style = br_style_block_rule_for_id(html, id_value)
        val tag_id_style = br_style_block_rule_for_tag_id(html, "div", id_value)
        val has_style = br_style_block_rule_for_has_descendant(html, "div", tag_end + 1)
        val not_style = br_style_block_rule_for_not_self(html, "div", tag_content)
        val attr_style = br_style_block_rule_for_attr_self(html, "div", tag_content)
        val empty_style = br_style_block_rule_for_empty_self(html, "div", tag_content, tag_end + 1)
        val matched_style = br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(tag_style, class_style), compound_class_style), multi_class_style), id_style), tag_id_style), attr_style), empty_style), has_style), not_style)
        val style = br_merge_style_text(matched_style, inline_style)
        val block_w = br_style_px_or_default(style, "width", width - margin * 2)
        val text_val = br_div_fallback_text(html, tag_end + 1)
        var block_h = br_style_px_or_default(style, "height", 0)
        if block_h <= 0 and text_val.len() > 0:
            block_h = br_style_px_or_default(style, "font-size", br_body_font_size_px(html)) + 4
        val block_bg = br_style_background_argb(html, style)
        if block_w > 0 and block_h > 0 and block_bg != 0x00000000u32:
            pixels = br_fill_rect(pixels, width, height, margin, cursor_y, block_w, block_h, block_bg)
        if text_val.len() > 0:
            val text_style = br_merge_style_text(style, br_first_span_style_before_div_close(html, tag_end + 1, tag_content))
            val text_color = br_style_color_argb(html, text_style, br_body_color_argb(html))
            val font_size = br_style_px_or_default(text_style, "font-size", br_body_font_size_px(html))
            pixels = br_draw_font_renderer_text(pixels, width, height, margin, cursor_y, text_val, text_color, font_size)
        if block_h > 0:
            cursor_y = cursor_y + block_h
        search_pos = tag_end + 1
    pixels

fn br_body_background_argb_or_default(html: text, fallback: u32) -> u32:
    val body_style = br_combined_body_style(html)
    val bg = br_style_background_argb(html, body_style)
    if bg != 0x00000000u32:
        return bg
    fallback

fn br_body_margin_px(html: text) -> i32:
    val body_style = br_combined_body_style(html)
    val margin = br_style_px_or_default(body_style, "margin", 8)
    if margin < 0:
        return 0
    margin

fn br_body_color_argb(html: text) -> u32:
    br_style_color_argb(html, br_combined_body_style(html), 0xFF000000u32)

fn br_body_font_size_px(html: text) -> i32:
    br_style_px_or_default(br_combined_body_style(html), "font-size", 16)

fn br_combined_body_style(html: text) -> text:
    br_merge_style_text(br_style_block_rule_for_tag(html, "body"), br_first_tag_attr_value(html, "body", "style"))

fn br_merge_style_text(base_style: text, override_style: text) -> text:
    if base_style.len() == 0:
        return override_style
    if override_style.len() == 0:
        return base_style
    base_style + ";" + override_style

fn br_style_block_rule_for_class(html: text, class_value: text) -> text:
    val classes = browser_renderer_split_spaces(class_value)
    if classes.len() == 0:
        return ""
    var out = ""
    var idx = 0
    while idx < classes.len():
        out = br_merge_style_text(out, br_style_block_rule_for_selector(html, "." + classes[idx]))
        idx = idx + 1
    out

fn br_style_block_rule_for_id(html: text, id_value: text) -> text:
