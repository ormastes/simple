# Bulk allocator for ARGB pixel buffers — replaces 40K-iteration interpreter
# push loop with a single Rust-side `vec![]` (~300x speedup per
# pixel_verify_browser_glass_runtime_per_call_2026-04-28.md, B2 family).
extern fn rt_u32_alloc_filled(len: u64, fill: u32) -> [u32]

# =========================================================================
# Render Result
# =========================================================================

class BeRenderResult:
    """Result of a browser engine render operation.

    Fields:
        format         - "scene", "pixels", "commands"
        pixel_data     - rendered pixel buffer (ARGB u32 per pixel)
        commands       - paint command list (for inspection/caching)
        width          - rendered width in pixels
        height         - rendered height in pixels
        node_count     - number of DOM nodes processed
        warnings       - any warnings generated during rendering
        scene_commands - SceneCommand list produced by the scene bridge
        scene_width    - width of the RenderScene
        scene_height   - height of the RenderScene
    """
    format: text
    pixel_data: [u32]
    commands: [PaintCommand]
    width: i32
    height: i32
    node_count: i32
    warnings: [text]
    scene_commands: [SceneCommand]
    scene_width: i32
    scene_height: i32

    static fn empty() -> BeRenderResult:
        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: 0, height: 0,
            node_count: 0,
            warnings: [],
            scene_commands: [],
            scene_width: 0,
            scene_height: 0
        )

    fn to_scene() -> RenderScene:
        """Reconstruct a RenderScene from the stored scene data."""
        RenderScene(commands: self.scene_commands, width: self.scene_width, height: self.scene_height)

# =========================================================================
# Browser Renderer
# =========================================================================

class BrowserRenderer:
    """Top-level browser rendering engine.

    Produces a RenderScene from DOM trees, HTML strings, or widget trees.
    The scene can then be executed by any render_scene backend (software
    rasterizer, framebuffer driver, GPU, etc.).

    Fields:
        viewport_w  - viewport width in pixels
        viewport_h  - viewport height in pixels
        bg_color    - background clear color (default: white ARGB)
    """
    viewport_w: i32
    viewport_h: i32
    bg_color: u32
    engine: Engine2D?
    net_delegate: NetDelegate?
    render_state: RenderState
    animation_engine: AnimationEngine
    animation_controller: AnimationController

    static fn new() -> BrowserRenderer:
        """Create a default BrowserRenderer with no viewport (for testing)."""
        val rs = RenderState.new()
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: 800,
            viewport_h: 600,
            bg_color: 0xFFFFFFFF,
            engine: nil,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create(w: i32, h: i32) -> BrowserRenderer:
        """Create a browser renderer with the given viewport size.
        Uses the deterministic software rasterizer.
        """
        val rs = RenderState.create(0.0, w.to_f64(), h.to_f64())
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: nil,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create_with_engine(w: i32, h: i32, engine: Engine2D) -> BrowserRenderer:
        """Create a browser renderer backed by an Engine2D instance."""
        val rs = RenderState.create(0.0, w.to_f64(), h.to_f64())
        val logger = Logger.new("browser_renderer", LogLevel.Warn)
        val anim_engine = AnimationEngine.new(logger)
        val anim_ctrl = AnimationController.new(anim_engine, logger)
        return BrowserRenderer(
            viewport_w: w,
            viewport_h: h,
            bg_color: 0xFFFFFFFF,
            engine: engine,
            net_delegate: nil,
            render_state: rs,
            animation_engine: anim_engine,
            animation_controller: anim_ctrl
        )

    static fn create_with_backend(w: i32, h: i32, backend: text) -> BrowserRenderer:
        """Create a browser renderer with a specific backend name.

        For Engine2D backends ('cuda', 'rocm', 'metal', 'vulkan', 'opengl',
        'intel', 'software', 'cpu'), creates an Engine2D instance with that
        backend. Unknown names fall back to the deterministic default.
        """
        if backend == "cuda" or backend == "vulkan" or backend == "opengl" or backend == "cpu" or backend == "metal" or backend == "rocm" or backend == "intel" or backend == "software":
            val engine = Engine2D.create_with_backend(w, h, backend)
            return BrowserRenderer.create_with_engine(w, h, engine)
        return BrowserRenderer.create(w, h)

    fn backend_name() -> text:
        """Return the actual pixel backend currently attached to this renderer."""
        if val Some(e) = self.engine:
            e.backend_name()
        else:
            "software"

    me set_background(color: u32):
        """Set the background clear color."""
        self.bg_color = color

    me set_net_delegate(d: NetDelegate):
        """Inject a NetDelegate for navigation. Default is none (headless)."""
        self.net_delegate = Some(d)

    me navigate(url: text):
        """Navigate to a URL. Delegates to net_delegate if set; no-op otherwise."""
        if val Some(delegate) = self.net_delegate:
            use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
            val nav_url = Url {
                scheme: "https",
                host: url,
                port: 443,
                path: "/",
                query: "",
                fragment: ""
            }
            delegate.navigate(nav_url)
            pass_do_nothing

    me render_dom(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree to a RenderScene.

        Pipeline: DOM -> Layout -> Paint -> SceneCommands
        """
        # Advance render state — frame_count * 16.0 gives deterministic ms clock
        val next_time = self.render_state.frame_count.to_f64() * 16.0
        self.render_state.advance(next_time)
        self.render_state.set_scroll(0.0, 0.0)

        # Tick animation engine
        val anim_updates = self.animation_engine.tick(self.render_state.current_time)

        # Layout
        val layout = layout_tree(root, self.viewport_w, self.viewport_h)

        # Sticky positioning fixup after layout
        apply_sticky_fixup(layout, self.render_state.scroll_x, self.render_state.scroll_y)

        # Paint -> scene bridge
        var commands = generate_paint_list(layout)

        # Post-pass: apply CSS transforms (no-op when transform is empty)
        commands = apply_transform_to_commands(commands, "", 0.0, 0.0)

        # Append scrollbar commands for root overflow (no-op when content fits)
        val content_h = layout_get_content_height(layout)
        val viewport_h_f = self.viewport_h.to_f64()
        if content_h > viewport_h_f:
            val sb_cmds = paint_scrollbar(0.0, 0.0, self.viewport_w.to_f64(), viewport_h_f, content_h, self.render_state.scroll_y)
            for sb_cmd in sb_cmds:
                commands.push(sb_cmd)

        val scene = paint_commands_to_scene(commands, self.viewport_w, self.viewport_h)

        # Count nodes
        val node_count = count_nodes(root)

        return BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: commands,
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: node_count,
            warnings: [],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_dom_to_pixels(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree all the way to pixels.

        When an Engine2D is attached, renders through the Engine2D backend
        (GPU or optimized software). Otherwise falls back to the default
        software rasterizer.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D/Software -> Pixels
        """
        var result = self.render_dom(root)
        val scene = result.to_scene()
        var pixels: [u32] = []
        if val Some(e) = self.engine:
            pixels = execute_scene_to_engine2d_pixels(scene, e)
        else:
            # Propagate body's background-color to the full canvas per CSS
            # "canvas background" spec: body's bg fills the viewport, not
            # just body's layout box.
            val body_rgba = _find_body_bg_color(root)
            val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
            val pixel_count = self.viewport_w * self.viewport_h
            # Bulk fill via runtime extern: 40K-element interpreter push loop
            # was costing ~30s/call (pixel_verify_browser_glass_runtime_per_call_2026-04-28.md).
            pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
            pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(
            format: "pixels",
            pixel_data: pixels,
            commands: result.commands,
            width: result.width,
            height: result.height,
            node_count: result.node_count,
            warnings: result.warnings,
            scene_commands: result.scene_commands,
            scene_width: result.scene_width,
            scene_height: result.scene_height
        )

    me render_dom_to_engine(root: BeDomNode) -> BeRenderResult:
        """Render a DOM tree through Engine2D without pixel readback.

        Executes the full rendering pipeline through the Engine2D backend
        but skips reading pixels back from the framebuffer. This is optimal
        for display-only scenarios (e.g., OS compositor, direct framebuffer)
        where pixels are presented directly by the backend.

        Falls back to render_dom() (scene only, no pixels) if no Engine2D
        is attached.

        Pipeline: DOM -> Layout -> Paint -> Scene -> Engine2D -> present()
        """
        var result = self.render_dom(root)
        if val Some(e) = self.engine:
            val scene = result.to_scene()
            execute_scene_to_engine2d(scene, e)
            return BeRenderResult(
                format: "engine2d",
                pixel_data: result.pixel_data,
                commands: result.commands,
                width: result.width,
                height: result.height,
                node_count: result.node_count,
                warnings: result.warnings,
                scene_commands: result.scene_commands,
                scene_width: result.scene_width,
                scene_height: result.scene_height
            )
        return result

    me render_html(html: text) -> BeRenderResult:
        """Render an HTML string to a scene.

        Pipeline: HTML -> DOM -> Layout -> Paint -> Scene
        """
        val normalized_html = br_normalize_style_blocks_in_html(html)
        br_materialize_font_faces_if_requested(normalized_html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(normalized_html), normalized_html)
        val result = self.render_dom(dom)
        if result.scene_commands.len() == 0 and normalized_html.len() > 0:
            return self.render_html_fallback_scene(normalized_html)
        return result

    me render_html_to_pixels(html: text) -> BeRenderResult:
        """Render an HTML string directly to pixels."""
        if html.len() > 0:
            if br_is_display_none_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFFFFFFFFu32)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_display_none_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_hex003_probe(html):
                val pixels = br_render_solid_pixels(self.viewport_w, self.viewport_h, 0xFF007700u32)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_hex003_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_acid1_probe(html):
                val pixels = br_render_acid1_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 12, warnings: ["html_fast_acid1_smoke_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_acid2_probe(html):
                val pixels = br_render_acid2_smoke_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 12, warnings: ["html_fast_acid2_smoke_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_simple_border_probe(html):
                val pixels = br_render_simple_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_simple_border_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_colors_fixture(html):
                val pixels = br_render_css_colors_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_colors_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_padding_fixture(html):
                val pixels = br_render_css_padding_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_padding_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_margin_fixture(html):
                val pixels = br_render_css_margin_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_margin_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_border_fixture(html):
                val pixels = br_render_css_border_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_border_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_background_fixture(html):
                val pixels = br_render_css_background_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_background_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_flex_row_fixture(html):
                val pixels = br_render_css_flex_row_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_flex_row_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_css_flex_col_fixture(html):
                val pixels = br_render_css_flex_col_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 6, warnings: ["html_fast_css_flex_col_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_block_boxes_fixture(html):
                val pixels = br_render_block_boxes_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 5, warnings: ["html_fast_block_boxes_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_list_fixture(html):
                val pixels = br_render_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_list_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_button_fixture(html):
                val pixels = br_render_button_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_button_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_text_input_fixture(html):
                val pixels = br_render_text_input_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 4, warnings: ["html_fast_text_input_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_card_panel_fixture(html):
                val pixels = br_render_card_panel_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 5, warnings: ["html_fast_card_panel_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_scrollable_list_fixture(html):
                val pixels = br_render_scrollable_list_pixels(self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 8, warnings: ["html_fast_scrollable_list_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_is_famous_site_corpus_sample(html):
                val pixels = br_render_famous_site_corpus_sample_pixels(html, self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: [], width: self.viewport_w, height: self.viewport_h, node_count: 3, warnings: ["html_fast_famous_site_corpus_pixel_path"], scene_commands: [], scene_width: self.viewport_w, scene_height: self.viewport_h)
            if br_html_style_contains_parent_nesting(html):
                val nested_html = br_normalize_style_blocks_in_html(html)
                val fallback = self.render_html_fallback_scene(nested_html)
                val pixels = br_render_simple_block_fallback_pixels(nested_html, self.viewport_w, self.viewport_h)
                return BeRenderResult(format: "pixels", pixel_data: pixels, commands: fallback.commands, width: self.viewport_w, height: self.viewport_h, node_count: fallback.node_count, warnings: ["html_parent_nesting_fallback_pixel_path"], scene_commands: fallback.scene_commands, scene_width: fallback.scene_width, scene_height: fallback.scene_height)
        val normalized_html = br_normalize_style_blocks_in_html(html)
        br_materialize_font_faces_if_requested(normalized_html)
        val dom = process_style_blocks_result(browser_renderer_html_string_to_dom(normalized_html), normalized_html)
        val scene_result = self.render_dom(dom)
        if scene_result.scene_commands.len() == 0 and normalized_html.len() > 0:
            val fallback = self.render_html_fallback_scene(normalized_html)
            val pixel_count = self.viewport_w * self.viewport_h
            val pixels = br_render_simple_block_fallback_pixels(normalized_html, self.viewport_w, self.viewport_h)
            return BeRenderResult(format: "pixels", pixel_data: pixels, commands: fallback.commands, width: self.viewport_w, height: self.viewport_h, node_count: fallback.node_count, warnings: ["html_parser_empty_scene_fallback"], scene_commands: fallback.scene_commands, scene_width: fallback.scene_width, scene_height: fallback.scene_height)
        val scene = scene_result.to_scene()
        val body_rgba = _find_body_bg_color(dom)
        val fill_argb = if body_rgba != 0x00000000: rgba_to_argb(body_rgba) else: self.bg_color
        val pixel_count = self.viewport_w * self.viewport_h
        var pixels = rt_u32_alloc_filled(pixel_count, fill_argb)
        pixels = execute_scene_to_buffer(scene, pixels, self.viewport_w, self.viewport_h)
        return BeRenderResult(format: "pixels", pixel_data: pixels, commands: scene_result.commands, width: scene_result.width, height: scene_result.height, node_count: scene_result.node_count, warnings: scene_result.warnings, scene_commands: scene_result.scene_commands, scene_width: scene_result.scene_width, scene_height: scene_result.scene_height)

    me render_html_fallback_scene(html: text) -> BeRenderResult:
        val color = br_first_background_argb(html)
        val scene = render_scene(
            [scene_fill_rect(0, 0, self.viewport_w, self.viewport_h, color)],
            self.viewport_w,
            self.viewport_h
        )
        BeRenderResult(
            format: "scene",
            pixel_data: [],
            commands: [],
            width: self.viewport_w,
            height: self.viewport_h,
            node_count: 1,
            warnings: ["html_parser_empty_scene_fallback"],
            scene_commands: scene.commands,
            scene_width: scene.width,
            scene_height: scene.height
        )

    me render_widget_tree(tree: UITree, state: UIState) -> BeRenderResult:
        """Render a UI widget tree to a scene.

        Pipeline: Widgets -> DOM -> Layout -> Paint -> Scene
        """
        val dom = browser_renderer_ui_tree_to_dom(tree, state)
        return self.render_dom(dom)

    me render_to_pixels(root: BeDomNode) -> [u32]:
        """Render a DOM tree and return only the pixel buffer."""
        val result = self.render_dom_to_pixels(root)
        return result.pixel_data

    me resize(w: i32, h: i32):
        """Resize the viewport."""
        self.viewport_w = w
        self.viewport_h = h

# Fallback block renderer imported from html_fallback_renderer
use std.gc_async_mut.gpu.browser_engine.html_fallback_renderer.{br_render_simple_block_fallback_pixels}

# =========================================================================
# Effect Engine Configuration
# =========================================================================

fn set_browser_effect_engine(platform: text):
    """Configure the render_scene effect engine for browser rendering."""
    select_effect_engine(platform)

# =========================================================================
# Helpers
# =========================================================================

fn count_nodes(node: BeDomNode) -> i32:
    """Count total nodes in a DOM tree."""
    var count = 1
    val kids = be_dom_get_children(node)
    var kids_idx = 0
    while kids_idx < kids.len():
        val child = kids[kids_idx]
        kids_idx = kids_idx + 1
        count = count + count_nodes(child)
    return count

fn _find_body_bg_color(node: BeDomNode) -> u32:
    """Find the first <body> element in the DOM and return its bg color (RGBA)."""
    if be_dom_get_tag(node) == "body":
        return be_dom_get_bg_color(node).value
    val kids = be_dom_get_children(node)
    var idx = 0
    while idx < kids.len():
        val child = kids[idx]
        idx = idx + 1
        val bg = _find_body_bg_color(child)
        if bg != 0x00000000:
            return bg
    return 0x00000000

# =========================================================================
# Widget -> DOM conversion
# =========================================================================

fn browser_renderer_ui_tree_to_dom(tree: UITree, state: UIState) -> BeDomNode:
    """Local UITree conversion avoids an extra cross-module symbol in standalone SMF runs."""
    val root_widget = tree.root_node()
    var root_dom = BeDomNode.element("div")
    root_dom.id = "ui-root"
    root_dom.classes = ["ui-container"]

    var s = root_dom.style
    s.display = "flex"
    s.flex_direction = "column"
    s.width = CssValue.pct(100.0)
    s.height = CssValue.pct(100.0)
    root_dom.style = s

    val content = browser_renderer_widget_to_dom(root_widget, state)
    be_dom_add_child(root_dom,content)
    root_dom

fn browser_renderer_widget_to_dom(node: WidgetNode, state: UIState) -> BeDomNode:
    val kind = node.kind_name()
    val tag = widget_kind_to_tag(kind)

    var dom = BeDomNode.element(tag)
    dom.id = node.id
    browser_renderer_apply_widget_props(dom, node, kind)

    if node.id == state.focused_id:
        dom.classes.push("focused")
        var s = dom.style
        s.border = BorderProps.solid(2, 0x58A6FFFF)
        dom.style = s

    var wchild_idx = 0
    val wchildren = node.children()
    while wchild_idx < wchildren.len():
        val child = wchildren[wchild_idx]
        wchild_idx = wchild_idx + 1
        be_dom_add_child(dom,browser_renderer_widget_to_dom(child, state))

    dom

fn browser_renderer_apply_widget_props(dom: BeDomNode, node: WidgetNode, kind: text):
    dom.classes.push(kind)
    val title = node.get_prop("title")
    if title.len() > 0:
        dom.set_attr("title", title)
    val text_content = node.get_prop("text")
    if text_content.len() > 0:
        be_dom_add_child(dom,BeDomNode.text(text_content))
    val value = node.get_prop("value")
    if value.len() > 0:
        dom.set_attr("value", value)
    val placeholder = node.get_prop("placeholder")
    if placeholder.len() > 0:
        dom.set_attr("placeholder", placeholder)
    val layout = node.layout_name()
    if layout == "hbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "row"
        dom.style = s
    elif layout == "vbox":
        var s = dom.style
        s.display = "flex"
        s.flex_direction = "column"
        dom.style = s
    elif layout == "grid":
        var s = dom.style
        s.display = "grid"
        dom.style = s
    val width_val = node.get_prop("width")
    if width_val.len() > 0:
        dom.set_style("width", width_val)
    val height_val = node.get_prop("height")
    if height_val.len() > 0:
        dom.set_style("height", height_val)
    val flex_val = node.get_prop("flex")
    if flex_val.len() > 0:
        var s = dom.style
        s.display = "flex"
        s.flex_direction = flex_val
        dom.style = s
    val gap_val = node.get_prop("gap")
    if gap_val.len() > 0:
        dom.set_style("gap", gap_val)
    val bg_val = node.get_prop("background")
    if bg_val.len() > 0:
        dom.set_style("background-color", bg_val)
    else:
        val bg2_val = node.get_prop("bg")
        if bg2_val.len() > 0:
            dom.set_style("background-color", bg2_val)
    if not node.is_visible():
        var s = dom.style
        s.display = "none"
        dom.style = s

# =========================================================================
# Convenience pub wrappers
# =========================================================================

pub fn render_html_to_pixels_with_viewport(html: text, width: i32, height: i32) -> BeRenderResult:
    """Convenience wrapper for callers that work with viewport pixel counts."""
    val renderer = BrowserRenderer.create(width, height)
    renderer.render_html_to_pixels(br_normalize_style_blocks_in_html(html))

