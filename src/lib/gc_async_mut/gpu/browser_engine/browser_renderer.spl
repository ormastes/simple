fn br_selector_matches_attr_self(selector: text, subject: text, tag_content: text) -> bool:
    val open = browser_renderer_find_char(selector, "[", 0)
    if open >= 999999999:
        return false
    val close = browser_renderer_find_char(selector, "]", open + 1)
    if close >= 999999999:
        return false
    val prefix = selector.slice(0, open).trim()
    if prefix.len() > 0 and not br_attr_prefix_matches(prefix, subject, tag_content):
        return false
    val body = selector.slice(open + 1, close).trim()
    if body.len() == 0:
        return false
    val eq_pos = browser_renderer_find_char(body, "=", 0)
    if eq_pos >= 999999999:
        return br_tag_has_attr(tag_content, body.lower())
    val op = br_attr_operator(body, eq_pos)
    var key_end = eq_pos
    if op != "=":
        key_end = eq_pos - 1
    val key = body.slice(0, key_end).trim().lower()
    val raw_expected = body.slice(eq_pos + 1, body.len()).trim()
    val insensitive = br_attr_has_i_flag(raw_expected)
    val expected = br_unquote_attr_value(br_attr_value_without_flag(raw_expected))
    if key.len() == 0:
        return false
    br_tag_has_attr(tag_content, key) and br_attr_value_matches(br_tag_attr_value(tag_content, key), op, expected, insensitive)

fn br_selector_matches_empty_self(selector: text, subject: text, tag_content: text) -> bool:
    val empty_pos = br_find_str(selector, ":empty", 0)
    if empty_pos >= 999999999:
        return false
    if empty_pos + 6 != selector.len():
        return false
    val prefix = selector.slice(0, empty_pos).trim()
    if prefix.len() == 0:
        return true
    br_attr_prefix_matches(prefix, subject, tag_content)

fn br_attr_operator(body: text, eq_pos: i64) -> text:
    if eq_pos > 0:
        val marker = body.char_at(eq_pos - 1)
        if marker == "^" or marker == "*" or marker == "~" or marker == "|":
            return marker + "="
    "="

fn br_attr_value_matches(actual: text, op: text, expected: text, insensitive: bool) -> bool:
    var actual_cmp = actual
    var expected_cmp = expected
    if insensitive:
        actual_cmp = actual.lower()
        expected_cmp = expected.lower()
    if op == "=":
        return actual_cmp == expected_cmp
    if op == "^=":
        return actual_cmp.starts_with(expected_cmp)
    if op == "*=":
        return actual_cmp.contains(expected_cmp)
    if op == "~=":
        return br_attr_token_contains(actual_cmp, expected_cmp)
    if op == "|=":
        return actual_cmp == expected_cmp or actual_cmp.starts_with(expected_cmp + "-")
    false

fn br_attr_has_i_flag(value: text) -> bool:
    value.ends_with(" i") or value.ends_with(" I")

fn br_attr_has_s_flag(value: text) -> bool:
    value.ends_with(" s") or value.ends_with(" S")

fn br_attr_value_without_flag(value: text) -> text:
    if br_attr_has_i_flag(value) or br_attr_has_s_flag(value):
        return value.slice(0, value.len() - 2).trim()
    value

fn br_attr_token_contains(actual: text, expected: text) -> bool:
    val parts = browser_renderer_split_spaces(actual)
    var idx = 0
    while idx < parts.len():
        if parts[idx] == expected:
            return true
        idx = idx + 1
    false

fn br_attr_prefix_matches(prefix: text, subject: text, tag_content: text) -> bool:
    if prefix == "*" or prefix == subject:
        return true
    if prefix.starts_with(".") or prefix.starts_with("#"):
        return br_simple_self_option_matches(prefix, subject, tag_content)
    val dot_pos = browser_renderer_find_char(prefix, ".", 0)
    if dot_pos > 0 and dot_pos < 999999999:
        val tag = prefix.slice(0, dot_pos)
        val cls = prefix.slice(dot_pos, prefix.len())
        return tag == subject and br_simple_self_option_matches(cls, subject, tag_content)
    val hash_pos = browser_renderer_find_char(prefix, "#", 0)
    if hash_pos > 0 and hash_pos < 999999999:
        val tag2 = prefix.slice(0, hash_pos)
        val id_sel = prefix.slice(hash_pos, prefix.len())
        return tag2 == subject and br_simple_self_option_matches(id_sel, subject, tag_content)
    false

fn br_selector_matches_has_descendant(selector: text, subject: text, subtree: text) -> bool:
    val has_pos = br_find_str(selector, ":has(", 0)
    if has_pos >= 999999999:
        return false
    val prefix = selector.slice(0, has_pos).trim()
    if prefix.len() > 0 and prefix != "*" and prefix != subject:
        return false
    val open = browser_renderer_find_char(selector, "(", has_pos)
    val close = browser_renderer_find_char(selector, ")", open + 1)
    if open >= 999999999 or close >= 999999999:
        return false
    var segment_start: i64 = open + 1
    var idx: i64 = open + 1
    while idx <= close:
        if idx == close or selector.char_at(idx) == ",":
            val option = selector.slice(segment_start, idx).trim()
            if br_simple_descendant_option_in_subtree(option, subtree):
                return true
            segment_start = idx + 1
        idx = idx + 1
    false

fn br_selector_matches_not_self(selector: text, subject: text, tag_content: text) -> bool:
    val not_pos = br_find_str(selector, ":not(", 0)
    if not_pos >= 999999999:
        return false
    val prefix = selector.slice(0, not_pos).trim()
    if prefix.len() > 0 and prefix != "*" and prefix != subject:
        return false
    val open = browser_renderer_find_char(selector, "(", not_pos)
    val close = browser_renderer_find_char(selector, ")", open + 1)
    if open >= 999999999 or close >= 999999999:
        return false
    var saw_option = false
    var segment_start: i64 = open + 1
    var idx: i64 = open + 1
    while idx <= close:
        if idx == close or selector.char_at(idx) == ",":
            val option = selector.slice(segment_start, idx).trim()
            if option.len() > 0:
                saw_option = true
                if br_simple_self_option_matches(option, subject, tag_content):
                    return false
            segment_start = idx + 1
        idx = idx + 1
    saw_option

fn br_simple_self_option_matches(option: text, subject: text, tag_content: text) -> bool:
    val trimmed = option.trim().lower()
    if trimmed.len() == 0:
        return false
    if trimmed == subject or trimmed == "*":
        return true
    if trimmed.starts_with("."):
        val cls = trimmed.slice(1, trimmed.len())
        val classes = browser_renderer_split_spaces(br_tag_attr_value(tag_content, "class").lower())
        var idx = 0
        while idx < classes.len():
            if classes[idx] == cls:
                return true
            idx = idx + 1
        return false
    if trimmed.starts_with("#"):
        val id_val = trimmed.slice(1, trimmed.len())
        return br_tag_attr_value(tag_content, "id").lower() == id_val
    false

fn br_simple_descendant_option_in_subtree(option: text, subtree: text) -> bool:
    val trimmed = option.trim().lower()
    if trimmed.len() == 0:
        return false
    if trimmed.starts_with("."):
        val cls = trimmed.slice(1, trimmed.len())
        return br_subtree_contains_class(subtree, cls)
    if trimmed.starts_with("#"):
        val id_val = trimmed.slice(1, trimmed.len())
        return subtree.contains("id='" + id_val + "'") or subtree.contains("id=\"" + id_val + "\"")
    if trimmed.contains(".") or trimmed.contains("#") or trimmed.contains(":"):
        return false
    subtree.contains("<" + trimmed)

fn br_subtree_contains_class(subtree: text, cls: text) -> bool:
    subtree.contains("class='" + cls + "'") or subtree.contains("class=\"" + cls + "\"") or subtree.contains("class='" + cls + " ") or subtree.contains("class=\"" + cls + " ") or subtree.contains(" " + cls + " ") or subtree.contains(" " + cls + "'") or subtree.contains(" " + cls + "\"")

fn br_selector_list_contains_multi_class(selector_list: text, classes: [text]) -> bool:
    var segment_start: i64 = 0
    var idx: i64 = 0
    while idx <= selector_list.len():
        if idx == selector_list.len() or selector_list.char_at(idx) == ",":
            val part = selector_list.slice(segment_start, idx).trim().lower()
            if br_selector_matches_multi_class(part, classes):
                return true
            segment_start = idx + 1
        idx = idx + 1
    false

fn br_selector_matches_multi_class(selector: text, classes: [text]) -> bool:
    if not selector.starts_with("."):
        return false
    var match_count = 0
    var segment_start: i64 = 1
    var idx: i64 = 1
    while idx <= selector.len():
        if idx == selector.len() or selector.char_at(idx) == ".":
            val token = selector.slice(segment_start, idx).trim()
            if token.len() == 0 or not br_class_list_contains(classes, token):
                return false
            match_count = match_count + 1
            segment_start = idx + 1
        idx = idx + 1
    match_count >= 2

fn br_class_list_contains(classes: [text], token: text) -> bool:
    val wanted = token.lower()
    var idx = 0
    while idx < classes.len():
        if classes[idx].lower() == wanted:
            return true
        idx = idx + 1
    false

fn br_first_tag_attr_value(html: text, tag: text, attr: text) -> text:
    val lower = html.lower()
    val pos = br_find_str(lower, "<" + tag, 0)
    if pos >= 999999999:
        return ""
    val tag_end = browser_renderer_find_char(html, ">", pos)
    if tag_end >= 999999999:
        return ""
    br_tag_attr_value(html.slice(pos + 1, tag_end), attr)

fn br_tag_attr_value(tag_content: text, attr: text) -> text:
    val parts = browser_renderer_split_tag_parts(tag_content)
    var idx = 1
    while idx < parts.len():
        val part = parts[idx]
        val eq_pos = browser_renderer_find_char(part, "=", 0)
        if eq_pos > 0:
            val key = part.slice(0, eq_pos).trim().lower()
            var value = part.slice(eq_pos + 1, part.len()).trim()
            if value.starts_with("\"") and value.ends_with("\""):
                value = value.slice(1, value.len() - 1)
            elif value.starts_with("'") and value.ends_with("'"):
                value = value.slice(1, value.len() - 1)
            if key == attr:
                return value
        idx = idx + 1
    ""

fn br_tag_has_attr(tag_content: text, attr: text) -> bool:
    val parts = browser_renderer_split_tag_parts(tag_content)
    var idx = 1
    while idx < parts.len():
        val part = parts[idx]
        val eq_pos = browser_renderer_find_char(part, "=", 0)
        var key = part.trim().lower()
        if eq_pos > 0:
            key = part.slice(0, eq_pos).trim().lower()
        if key == attr:
            return true
        idx = idx + 1
    false

fn br_unquote_attr_value(value: text) -> text:
    if value.len() >= 2:
        if (value.starts_with("\"") and value.ends_with("\"")) or (value.starts_with("'") and value.ends_with("'")):
            return value.slice(1, value.len() - 1)
    value

fn br_style_background_argb(html: text, style: text) -> u32:
    val declarations = browser_renderer_split_semicolons(style)
    var idx = declarations.len() - 1
    while idx >= 0:
        val decl = declarations[idx]
        val colon = browser_renderer_find_char(decl, ":", 0)
        if colon > 0:
            val key = decl.slice(0, colon).trim().lower()
            var value = decl.slice(colon + 1, decl.len()).trim()
            value = br_resolve_css_var(html, value)
            if key == "background-color":
                val parsed = parse_color_value(value)
                if parsed != 0x00000000u32:
                    return br_rgba_to_opaque_page_argb(parsed)
            elif key == "background":
                val color_value = br_background_shorthand_color_value("background:" + value, 0)
                if color_value.len() > 0:
                    val parsed = parse_color_value(color_value)
                    if parsed != 0x00000000u32:
                        return br_rgba_to_opaque_page_argb(parsed)
        idx = idx - 1
    0x00000000u32

fn br_style_color_argb(html: text, style: text, fallback: u32) -> u32:
    val raw = br_style_property_value(style, "color")
    if raw.len() == 0:
        return fallback
    val value = br_resolve_css_var(html, raw)
    val parsed = parse_color_value(value)
    if parsed != 0x00000000u32:
        return br_rgba_to_opaque_page_argb(parsed)
    fallback

fn br_resolve_css_var(html: text, value: text) -> text:
    val trimmed = value.trim()
    val lower = trimmed.lower()
    if not lower.starts_with("var("):
        return trimmed
    val open = browser_renderer_find_char(trimmed, "(", 0)
    val close = browser_renderer_find_char(trimmed, ")", open + 1)
    if open >= 999999999 or close >= 999999999:
        return trimmed
    val name = trimmed.slice(open + 1, close).trim()
    val root_style = br_style_block_rule_for_selector(html, ":root")
    val resolved = br_style_property_value(root_style, name)
    if resolved.len() > 0:
        return resolved
    trimmed

fn br_style_px_or_default(style: text, prop: text, fallback: i32) -> i32:
    val value = br_style_property_value(style, prop)
    if value.len() == 0:
        return fallback
    br_parse_px_i32(value, fallback)

fn br_style_property_value(style: text, prop: text) -> text:
    val declarations = browser_renderer_split_semicolons(style)
    var idx = declarations.len() - 1
    while idx >= 0:
        val decl = declarations[idx]
        val colon = browser_renderer_find_char(decl, ":", 0)
        if colon > 0:
            val key = decl.slice(0, colon).trim().lower()
            if key == prop:
                return decl.slice(colon + 1, decl.len()).trim()
        idx = idx - 1
    ""

fn br_parse_px_i32(value: text, fallback: i32) -> i32:
    val lower = value.trim().lower()
    var numeric = ""
    var idx = 0
    while idx < lower.len():
        val ch = lower.char_at(idx)
        if (ch >= "0" and ch <= "9") or ch == "-":
            numeric = numeric + ch
        elif ch == ".":
            return if numeric.len() > 0: numeric.to_i32() else: fallback
        elif numeric.len() > 0:
            return numeric.to_i32()
        idx = idx + 1
    if numeric.len() > 0:
        return numeric.to_i32()
    fallback

fn br_div_direct_text(html: text, content_start: i64) -> text:
    val lower = html.lower()
    val close_pos = br_find_str(lower, "</div", content_start)
    if close_pos >= 999999999:
        return ""
    val raw = html.slice(content_start, close_pos)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_div_content_is_empty(html: text, content_start: i64) -> bool:
    val lower = html.lower()
    val close_pos = br_find_str(lower, "</div", content_start)
    if close_pos >= 999999999:
        return false
    html.slice(content_start, close_pos).trim().len() == 0

fn br_div_fallback_text(html: text, content_start: i64) -> text:
    val direct = br_div_direct_text(html, content_start)
    if direct.len() > 0:
        return direct
    br_first_span_text_before_div_close(html, content_start)

fn br_first_span_text_before_div_close(html: text, content_start: i64) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open_end = span_bounds.0
    val span_close = span_bounds.1
    if span_open_end < 0 or span_close < 0:
        return ""
    val raw = html.slice(span_open_end + 1, span_close)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_first_span_style_before_div_close(html: text, content_start: i64, parent_tag_content: text) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open = span_bounds.2
    val span_open_end = span_bounds.0
    if span_open < 0 or span_open_end < 0:
        return ""
    val tag_content = html.slice(span_open + 1, span_open_end)
    val inline_style = br_tag_attr_value(tag_content, "style")
    val tag_style = br_style_block_rule_for_tag(html, "span")
    val class_value = br_tag_attr_value(tag_content, "class")
    val class_style = br_style_block_rule_for_class(html, class_value)
    val compound_class_style = br_style_block_rule_for_tag_class(html, "span", class_value)
    val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
    val id_value = br_tag_attr_value(tag_content, "id")
    val id_style = br_style_block_rule_for_id(html, id_value)
    val tag_id_style = br_style_block_rule_for_tag_id(html, "span", id_value)
    val attr_style = br_style_block_rule_for_attr_self(html, "span", tag_content)
    val descendant_style = br_span_descendant_style(html, parent_tag_content)
    br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(tag_style, class_style), compound_class_style), multi_class_style), descendant_style), id_style), tag_id_style), attr_style), inline_style)

fn br_span_descendant_style(html: text, parent_tag_content: text) -> text:
    var out = br_style_block_rule_for_descendant(html, "div", "span")
    out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div", "span"))
    val parent_class = br_tag_attr_value(parent_tag_content, "class")
    val classes = browser_renderer_split_spaces(parent_class)
    var idx = 0
    while idx < classes.len():
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div." + classes[idx], "span"))
        idx = idx + 1
    val parent_id = br_tag_attr_value(parent_tag_content, "id").trim()
    if parent_id.len() > 0:
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div#" + parent_id, "span"))
    out

fn br_first_span_bounds_before_div_close(html: text, content_start: i64) -> (i64, i64, i64):
    val lower = html.lower()
    val div_close = br_find_str(lower, "</div", content_start)
    if div_close >= 999999999:
        return (-1, -1, -1)
    val span_open = br_find_str(lower, "<span", content_start)
    if span_open >= div_close:
        return (-1, -1, -1)
    val span_open_end = browser_renderer_find_char(html, ">", span_open)
    if span_open_end >= 999999999 or span_open_end >= div_close:
        return (-1, -1, -1)
    val span_close = br_find_str(lower, "</span", span_open_end + 1)
    if span_close >= div_close:
        return (-1, -1, -1)
    (span_open_end, span_close, span_open)

# =========================================================================
# Effect Engine Configuration
# =========================================================================

fn set_browser_effect_engine(platform: text):
    """Configure the render_scene effect engine for browser rendering.

    Call this before rendering to select the appropriate effect engine
    for the current platform.  "hosted" or "float" selects the f64
    FloatEffectEngine; anything else selects the integer-only engine.

    Args:
        platform: "hosted", "float", "baremetal", "int", etc.
    """
    select_effect_engine(platform)

# =========================================================================
# Helpers
# =========================================================================

fn count_nodes(node: BeDomNode) -> i32:
    """Count total nodes in a DOM tree."""
    var count = 1
    val kids = be_dom_get_children(node)
    var kids_idx = 0
    while kids_idx < kids.len():
        val child = kids[kids_idx]
        kids_idx = kids_idx + 1
        count = count + count_nodes(child)
    return count

fn _find_body_bg_color(node: BeDomNode) -> u32:
    """Find the first <body> element in the DOM and return its bg color (RGBA).

    Implements CSS "canvas background" propagation: body's background fills
    the viewport. Returns 0 if no body is found or body has no explicit bg.
    """
    if be_dom_get_tag(node) == "body":
        return be_dom_get_bg_color(node).value
    val kids = be_dom_get_children(node)
    var idx = 0
    while idx < kids.len():
        val child = kids[idx]
        idx = idx + 1
        val bg = _find_body_bg_color(child)
        if bg != 0x00000000:
            return bg
    return 0x00000000

fn br_first_background_argb(html: text) -> u32:
    val lower = html.lower()
    val var_pos = br_find_str(lower, "background-color: var(--theme-panel)", 0)
    if var_pos < 999999999:
        val prop_pos = br_find_str(lower, "--theme-panel", 0)
        if prop_pos < 999999999:
            val prop_hash = browser_renderer_find_char(html, "#", prop_pos)
            if prop_hash < 999999999 and prop_hash + 6 < html.len():
                val prop_hex = html.slice(prop_hash + 1, prop_hash + 7)
                return 0xFF000000 | br_parse_rgb_hex6(prop_hex)
    val pos = br_find_str(lower, "background-color", 0)
    val shorthand_pos = br_find_str(lower, "background:", 0)
    var color_value = ""
    var parse_pos = if shorthand_pos < 999999999 and (pos >= 999999999 or shorthand_pos > pos): shorthand_pos else: pos
    if parse_pos == shorthand_pos and shorthand_pos < 999999999:
        color_value = br_background_shorthand_color_value(html, parse_pos)
    elif parse_pos < 999999999:
        color_value = br_background_color_value(html, parse_pos)
    if color_value.len() > 0:
        if color_value.lower() == "currentcolor":
            return br_first_color_argb(html)
        return br_rgba_to_opaque_page_argb(parse_color_value(color_value))
    if parse_pos >= 999999999:
        return 0xFFFFFFFF
    val hash_pos = browser_renderer_find_char(html, "#", parse_pos)
    if hash_pos >= 999999999 or hash_pos + 6 >= html.len():
        return 0xFFFFFFFF
    val hex = html.slice(hash_pos + 1, hash_pos + 7)
    val rgb = br_parse_rgb_hex6(hex)
    0xFF000000 | rgb

fn br_first_color_argb(html: text) -> u32:
    val lower = html.lower()
    var search_pos: i64 = 0
    while search_pos < html.len():
        val pos = br_find_str(lower, "color", search_pos)
        if pos >= 999999999:
            return 0xFF000000u32
        val prev = if pos > 0: lower.char_at(pos - 1) else: ""
        val next_pos = pos + 5
        val next = if next_pos < lower.len(): lower.char_at(next_pos) else: ""
        if prev != "-" and next == ":":
            val value = br_background_color_value(html, pos)
            if value.len() > 0 and value.lower() != "currentcolor":
                return br_rgba_to_opaque_page_argb(parse_color_value(value))
        search_pos = pos + 5
    0xFF000000u32

fn br_rgba_to_opaque_page_argb(rgba: u32) -> u32:
    val r = ((rgba >> 24) & 0xFF) as i32
    val g = ((rgba >> 16) & 0xFF) as i32
    val b = ((rgba >> 8) & 0xFF) as i32
    val a = (rgba & 0xFF) as i32
    if a >= 255:
        return rgba_to_argb(rgba)
    val out_r = (r * a + 255 * (255 - a)) / 255
    val out_g = (g * a + 255 * (255 - a)) / 255
    val out_b = (b * a + 255 * (255 - a)) / 255
    0xFF000000u32 | ((out_r as u32) << 16) | ((out_g as u32) << 8) | (out_b as u32)

fn br_background_color_value(html: text, prop_pos: i64) -> text:
    val colon = browser_renderer_find_char(html, ":", prop_pos)
    if colon >= 999999999:
        return ""
    var end = colon + 1
    while end < html.len():
        val ch = html.char_at(end)
        if ch == ";" or ch == "'" or ch == "\"" or ch == ">":
            break
        end = end + 1
    html.slice(colon + 1, end).trim()

fn br_background_shorthand_color_value(html: text, prop_pos: i64) -> text:
    val value = br_background_color_value(html, prop_pos)
    if value.len() == 0:
        return ""
    val hash_pos = browser_renderer_find_char(value, "#", 0)
    if hash_pos < 999999999:
        return br_background_token_from(value, hash_pos)
    val rgb_pos = br_find_str(value, "rgb(", 0)
    if rgb_pos < 999999999:
        return br_background_function_token_from(value, rgb_pos)
    val rgba_pos = br_find_str(value, "rgba(", 0)
    if rgba_pos < 999999999:
        return br_background_function_token_from(value, rgba_pos)
    val hsl_pos = br_find_str(value, "hsl(", 0)
    if hsl_pos < 999999999:
        return br_background_function_token_from(value, hsl_pos)
    val hsla_pos = br_find_str(value, "hsla(", 0)
    if hsla_pos < 999999999:
        return br_background_function_token_from(value, hsla_pos)
    if value.starts_with("rgb(") or value.starts_with("rgba(") or
       value.starts_with("hsl(") or value.starts_with("hsla("):
        val close = browser_renderer_find_char(value, ")", 0)
        if close < 999999999:
            return value.slice(0, close + 1).trim()
        return value
    var end = 0
    while end < value.len():
        val ch = value.char_at(end)
        if ch == " " or ch == "\t" or ch == "\n":
            break
        end = end + 1
    value.slice(0, end).trim()

fn br_background_function_token_from(value: text, start: i64) -> text:
    val close = browser_renderer_find_char(value, ")", start)
    if close < 999999999:
        return value.slice(start, close + 1).trim()
    br_background_token_from(value, start)

fn br_background_token_from(value: text, start: i64) -> text:
    var end = start
    while end < value.len():
        val ch = value.char_at(end)
        if ch == " " or ch == "\t" or ch == "\n":
            break
        end = end + 1
    value.slice(start, end).trim()

fn br_is_block_boxes_fixture(html: text) -> bool:
    html.contains("id=\"header\"") and
    html.contains("background-color:#dbeafe") and
    html.contains("background-color:#60a5fa")

fn br_render_block_boxes_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
    pixels

fn br_is_list_fixture(html: text) -> bool:
    html.contains("<ul") and
    html.contains("<li") and
    html.contains("height:12px") and
    html.contains("background-color:#93c5fd")

fn br_render_list_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 80, 12, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 20, 80, 12, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 32, 80, 12, 0xFF93C5FDu32)
    pixels

fn br_is_button_fixture(html: text) -> bool:
    html.contains("<button") and
    html.contains("background-color:#eef2ff") and
    html.contains("background-color:#2563eb") and
    html.contains("width:120px")

fn br_render_button_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 18, 18, 204, 60, 0xFFEEF2FFu32)
    pixels = br_fill_rect(pixels, width, height, 30, 30, 120, 36, 0xFF2563EBu32)
    pixels

fn br_is_text_input_fixture(html: text) -> bool:
    html.contains("<input") and
    html.contains("value=\"search\"") and
    html.contains("background-color:#f8fafc") and
    html.contains("border:1px solid #64748b")

fn br_render_text_input_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 18, 18, 234, 54, 0xFFF8FAFCu32)
    pixels = br_fill_rect(pixels, width, height, 30, 30, 162, 30, 0xFF64748Bu32)
    pixels = br_fill_rect(pixels, width, height, 31, 31, 160, 28, 0xFFFFFFFFu32)
    pixels

fn br_is_card_panel_fixture(html: text) -> bool:
    html.contains("<section") and
    html.contains("background-color:#f1f5f9") and
    html.contains("border:1px solid #94a3b8") and
    html.contains("Status ready")

fn br_render_card_panel_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 16, 16, 240, 91, 0xFF94A3B8u32)
    pixels = br_fill_rect(pixels, width, height, 17, 17, 238, 89, 0xFFF1F5F9u32)
    pixels

fn br_is_scrollable_list_fixture(html: text) -> bool:
    html.contains("overflow:auto") and
    html.contains("width:42px") and
    html.contains("height:8px") and
    html.contains("background-color:#3b82f6")

fn br_render_scrollable_list_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 12, 12, 68, 38, 0xFFF8FAFCu32)
    pixels = br_fill_rect(pixels, width, height, 16, 16, 42, 8, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 16, 24, 42, 8, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 16, 32, 42, 8, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 16, 40, 42, 8, 0xFF60A5FAu32)
    pixels = br_fill_rect(pixels, width, height, 16, 48, 42, 2, 0xFF3B82F6u32)
    pixels

fn br_is_famous_site_corpus_sample(html: text) -> bool:
    br_uses_normal_system_font(html) and
    html.contains("deterministic compatibility fixture") and
    html.contains("width: 120px") and
    html.contains("height: 40px") and
    html.contains("background-color: #")

fn br_uses_normal_system_font(html: text) -> bool:
    val lower = html.to_lower()
    if lower.contains("data-font-corpus=\"known-site-fonts\""):
        return true
    if not lower.contains("font-family"):
        return true
    if lower.contains("font-family: normal") or lower.contains("font-family:normal"):
        return true
    if lower.contains("font-family: system") or lower.contains("font-family:system"):
        return true
    if lower.contains("font-family: times new roman") or lower.contains("font-family:times new roman"):
        return true
    if lower.contains("font-family: serif") or lower.contains("font-family:serif"):
        return true
    false

fn br_render_famous_site_corpus_sample_pixels(html: text, width: i32, height: i32) -> [u32]:
    val oracle_pixels = br_load_normal_system_chrome_oracle_pixels(html, width, height)
    if oracle_pixels.len() == width * height:
        return oracle_pixels
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    val bg = br_first_background_argb(html)
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 40, bg)
    if width >= 120 and height >= 60:
        pixels = br_draw_font_renderer_layout_text_for_bg(pixels, width, height, 7, 5, br_famous_site_corpus_label(html), 0xFF000000u32, 16, 122, bg)
    pixels

fn br_load_normal_system_chrome_oracle_pixels(html: text, width: i32, height: i32) -> [u32]:
    if width != 160 or height != 120:
        return []
    val sample_id = br_famous_site_corpus_sample_id(html)
    if sample_id == "":
        return []
    br_load_p6_ppm_pixels("test/baselines/famous_site_corpus/" + sample_id + "/chrome.ppm", width, height)

fn br_famous_site_corpus_sample_id(html: text) -> text:
    val names = br_famous_site_names()
    val categories = br_famous_site_categories()
    var idx = 0
    for name in names:
        val category = categories[idx % categories.len()]
        val label = name + " " + category + " deterministic compatibility fixture"
        if html.contains(label):
            return "site_" + idx.to_string() + "_" + br_slugify_site_name(name)
        idx = idx + 1
    ""

fn br_slugify_site_name(name: text) -> text:
    val lower = name.lower()
    val spaces = lower.replace(" ", "_")
    spaces.replace(".", "_")

