"""
Browser Script Render — Script collection and execution wired into the render pipeline.

Provides:
  - TreeBuilderResult  — inline scripts + external src paths collected from HTML
  - browser_renderer_parse_html_with_scripts(html) -> TreeBuilderResult
  - BeScriptRenderResult — render output augmented with script execution metadata
  - render_html_to_pixels_with_scripts(html, width, height) -> BeScriptRenderResult

Scripts tagged `type="text/simple"` (and default/untyped tags) are executed via
`bin/simple` subprocess. Console stdout is captured into `console_output`.

DOM mutations across the subprocess boundary are not supported in this iteration.
"""

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

# ============================================================================
# Externs
# ============================================================================

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_bytes_alloc(n: i64) -> [u8]

# ============================================================================
# TreeBuilderResult — collected scripts from an HTML document
# ============================================================================

class TreeBuilderResult:
    """Scripts and src references extracted from an HTML document."""
    scripts: [text]       # inline script bodies (text content of <script> tags)
    script_types: [text]  # type attribute for each inline script (empty = default)
    src_paths: [text]     # src attribute for external <script src="..."> tags
    src_types: [text]     # type attribute for each external script tag

impl TreeBuilderResult:
    static fn empty() -> TreeBuilderResult:
        var s: [text] = []
        var st: [text] = []
        var sp: [text] = []
        var spt: [text] = []
        TreeBuilderResult(scripts: s, script_types: st, src_paths: sp, src_types: spt)

# ============================================================================
# HTML script collection
# ============================================================================

fn _extract_attr(tag_text: text, attr: text) -> text:
    """Extract a quoted attribute value from a tag string."""
    val key_dq = attr + "=\""
    val key_sq = attr + "='"
    val lo = tag_text.lower()
    val idx_dq = lo.index_of(key_dq)
    val idx_sq = lo.index_of(key_sq)
    if idx_dq >= 0:
        val start = idx_dq + key_dq.len()
        val end = tag_text.index_of("\"", start)
        if end > start:
            return tag_text.substring(start, end)
    if idx_sq >= 0:
        val start = idx_sq + key_sq.len()
        val end = tag_text.index_of("'", start)
        if end > start:
            return tag_text.substring(start, end)
    ""

fn browser_renderer_parse_html_with_scripts(html: text) -> TreeBuilderResult:
    """Walk HTML collecting <script> tag bodies and src references.

    Finds every <script ...>...</script> block.  Inline bodies go into
    `scripts` / `script_types`.  Tags with a src attribute go into
    `src_paths` / `src_types`.
    """
    var result = TreeBuilderResult.empty()
    val lo = html.lower()
    var search_pos: i64 = 0
    while search_pos < html.len():
        val tag_open = lo.index_of("<script", search_pos)
        if tag_open < 0:
            return result
        # Find the end of the opening tag
        val tag_close = html.index_of(">", tag_open)
        if tag_close < 0:
            return result
        val open_tag = html.substring(tag_open, tag_close + 1)
        val script_type = _extract_attr(open_tag, "type")
        val src_attr = _extract_attr(open_tag, "src")
        val body_start = tag_close + 1
        # Find closing tag
        val close_idx = lo.index_of("</script>", body_start)
        if close_idx < 0:
            return result
        if src_attr != "":
            # External script reference
            result.src_paths.push(src_attr)
            result.src_types.push(script_type)
        else:
            # Inline script body
            val body = html.substring(body_start, close_idx)
            result.scripts.push(body)
            result.script_types.push(script_type)
        search_pos = close_idx + 9  # advance past </script>
    result

# ============================================================================
# BeScriptRenderResult
# ============================================================================

class BeScriptRenderResult:
    """Render result augmented with script execution metadata."""
    pixels: [u8]
    width: i32
    height: i32
    title: text
    ok: bool
    error: text
    scripts_collected: i64   # total inline scripts found
    scripts_executed: i64    # scripts that were executed (subprocess exit 0)
    console_output: [text]   # captured stdout lines from executed scripts

impl BeScriptRenderResult:
    static fn empty(width: i32, height: i32) -> BeScriptRenderResult:
        val n = width.to_i64() * height.to_i64() * 4
        val px = rt_bytes_alloc(n)
        var co: [text] = []
        BeScriptRenderResult(
            pixels: px,
            width: width,
            height: height,
            title: "",
            ok: true,
            error: "",
            scripts_collected: 0,
            scripts_executed: 0,
            console_output: co
        )

# ============================================================================
# Script execution helpers
# ============================================================================

fn _run_script_source(source: text) -> (bool, text):
    """Write source to a temp file and run it via bin/simple.

    Returns (success, stdout) where stdout is the captured console output.
    """
    val tmp = "/tmp/browser_script_exec_tmp.spl"
    rt_file_write_text(tmp, source)
    var out = ""
    var err = ""
    var rc: i64 = 0
    (out, err, rc) = rt_process_run("bin/simple", [tmp])
    rt_file_delete(tmp)
    val ok = rc == 0
    (ok, out)

fn _split_lines(s: text) -> [text]:
    """Split a string on newline into a list of non-empty lines."""
    var lines: [text] = []
    var remaining = s
    while remaining.len() > 0:
        val nl = remaining.index_of("\n")
        if nl < 0:
            val trimmed = remaining.trim()
            if trimmed.len() > 0:
                lines.push(trimmed)
            return lines
        val line = remaining.substring(0, nl).trim()
        if line.len() > 0:
            lines.push(line)
        remaining = remaining.substring(nl + 1, remaining.len())
    lines

# ============================================================================
# render_html_to_pixels_with_scripts
# ============================================================================

fn render_html_to_pixels_with_scripts(html: text, width: i32, height: i32) -> BeScriptRenderResult:
    """Render HTML to pixels and execute collected scripts.

    1. Render via BrowserRenderer (produces pixel buffer).
    2. Collect scripts via browser_renderer_parse_html_with_scripts.
    3. Execute each inline script via bin/simple subprocess.
    4. Capture stdout into console_output.
    """
    var renderer = BrowserRenderer.create(width, height)
    val render = renderer.render_html(html)

    val parsed = browser_renderer_parse_html_with_scripts(html)
    val n_collected = parsed.scripts.len()

    var co: [text] = []
    var executed: i64 = 0

    var idx: i64 = 0
    while idx < parsed.scripts.len():
        val body = parsed.scripts[idx]
        var run_ok = false
        var run_stdout = ""
        (run_ok, run_stdout) = _run_script_source(body)
        if run_ok:
            executed = executed + 1
        val output_lines = _split_lines(run_stdout)
        var li: i64 = 0
        while li < output_lines.len():
            co.push(output_lines[li])
            li = li + 1
        idx = idx + 1

    BeScriptRenderResult(
        pixels: render.pixels,
        width: render.width,
        height: render.height,
        title: render.title,
        ok: render.ok,
        error: render.error,
        scripts_collected: n_collected,
        scripts_executed: executed,
        console_output: co
    )
