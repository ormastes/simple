"""
# Browser Error Types

Unified error type for browser engine subsystems.
"""

#![allow(REQC001)]

pub enum BrowserErrorKind:
    Config
    Ipc
    Network
    Parse
    Dom
    Layout
    Paint
    Script
    Sandbox
    Io

pub class BrowserError:
    kind: BrowserErrorKind
    message: text
    source: text

    static fn create(kind: BrowserErrorKind, message: text, source: text) -> BrowserError:
        BrowserError(kind: kind, message: message, source: source)

pub fn config_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Config, message: msg, source: "config")

pub fn ipc_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Ipc, message: msg, source: "ipc")

pub fn network_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Network, message: msg, source: "network")

pub fn parse_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Parse, message: msg, source: "parse")

pub fn dom_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Dom, message: msg, source: "dom")

pub fn layout_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Layout, message: msg, source: "layout")

pub fn paint_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Paint, message: msg, source: "paint")

pub fn script_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Script, message: msg, source: "script")

pub fn sandbox_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Sandbox, message: msg, source: "sandbox")

pub fn io_error(msg: text) -> BrowserError:
    BrowserError(kind: BrowserErrorKind.Io, message: msg, source: "io")
