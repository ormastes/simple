class SimpleWebHtmlPixelCache:
    width: i32
    height: i32
    last_html: text
    last_pixels: [u32]
    hits: i32
    stores: i32

impl SimpleWebHtmlPixelCache:
    static fn create(width: i32, height: i32) -> SimpleWebHtmlPixelCache:
        SimpleWebHtmlPixelCache(
            width: width,
            height: height,
            last_html: "",
            last_pixels: [],
            hits: 0,
            stores: 0
        )

    fn pixels_for_html(html: text) -> [u32]:
        if html == self.last_html and self.last_pixels.len() == self.width * self.height:
            self.hits = self.hits + 1
            return self.last_pixels
        val pixels = simple_web_render_html_to_pixels(html, self.width, self.height)
        self.last_html = html
        self.last_pixels = pixels
        self.stores = self.stores + 1
        pixels

pub fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val _ = html
    [0xFFFFFFFFu32; width * height]
