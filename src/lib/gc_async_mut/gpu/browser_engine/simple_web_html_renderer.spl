"""
Simple Web HTML Renderer

Tiny HTML-only box rasterizer for small static callers. Renders a page
background plus absolutely-positioned colored boxes parsed from inline
`style="..."` attributes. Rich Engine2D/background compatibility lives in
simple_web_engine2d_renderer; this is a focused, dependency-free renderer.

Output: [u32] ARGB (0xAARRGGBB), row-major, length width*height.
"""

pub fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val cw = width.to_i64()
    val ch = height.to_i64()
    val count = (cw * ch).to_i32()

    val bg = _body_background_color(html)
    var px: [u32] = [bg; count]

    # Scan every inline style="..." and paint boxes that declare bg+width+height.
    var pos: i64 = 0
    val key = "style=\""
    val klen = key.len()
    while true:
        val rel = html[pos:].index_of(key)
        if rel < 0:
            break
        val start = pos + rel + klen
        val erel = html[start:].index_of("\"")
        if erel < 0:
            break
        val style = html[start:start + erel]
        pos = start + erel + 1

        val has_bg = style.contains("background")
        val has_w = style.contains("width")
        val has_h = style.contains("height")
        if not (has_bg and has_w and has_h):
            continue

        val x = _style_px(style, "left")
        val y = _style_px(style, "top")
        val w = _style_px(style, "width")
        val h = _style_px(style, "height")
        if w <= 0 or h <= 0:
            continue
        val color = _parse_color(_style_val(style, "background"))
        px = _fill_rect(px, cw, ch, x, y, w, h, color)
    px

# ----------------------------------------------------------------------------
# Background extraction
# ----------------------------------------------------------------------------

fn _body_background_color(html: text) -> u32:
    val brel = html.index_of("<body")
    if brel < 0:
        return 0xFFFFFFFFu32
    val tail = html[brel:]
    val close = tail.index_of(">")
    val tag = if close < 0: tail else: tail[0:close]
    val krel = tag.index_of("style=\"")
    if krel < 0:
        return 0xFFFFFFFFu32
    val sstart = krel + "style=\"".len()
    val srest = tag[sstart:]
    val send = srest.index_of("\"")
    val style = if send < 0: srest else: srest[0:send]
    val raw = _style_val(style, "background")
    if raw == "":
        return 0xFFFFFFFFu32
    _parse_color(raw)

# ----------------------------------------------------------------------------
# Style value helpers
# ----------------------------------------------------------------------------

fn _style_val(style: text, key: text) -> text:
    # Returns the value of `key:` up to the next `;` (or end). Empty if absent.
    val needle = "{key}:"
    val rel = style.index_of(needle)
    if rel < 0:
        return ""
    val vstart = rel + needle.len()
    val rest = style[vstart:]
    val semi = rest.index_of(";")
    val value = if semi < 0: rest else: rest[0:semi]
    value.trim()

fn _style_px(style: text, key: text) -> i64:
    val raw = _style_val(style, key)
    if raw == "":
        return 0
    var v = raw.replace("px", "")
    v = v.trim()
    v.to_i64() ?? 0

# ----------------------------------------------------------------------------
# Color parsing
# ----------------------------------------------------------------------------

fn _parse_color(value: text) -> u32:
    val v = value.trim()
    if v.starts_with("#"):
        return _parse_hex_color(v)
    if v.starts_with("rgba(") or v.starts_with("rgb("):
        return _parse_rgba(v)
    0xFFFFFFFFu32

fn _parse_hex_color(value: text) -> u32:
    # Supports #rrggbb and #rrggbbaa.
    val v = value.trim()
    if not v.starts_with("#") or v.len() < 7:
        return 0xFFFFFFFFu32
    # NOTE: `s[i].to_i64()` parses the char *content* as a number (so "f" -> 0),
    # it does NOT yield a char code. Use char_code_at for the actual code point.
    val r = _hex_digit(v.char_code_at(1)) * 16 + _hex_digit(v.char_code_at(2))
    val g = _hex_digit(v.char_code_at(3)) * 16 + _hex_digit(v.char_code_at(4))
    val b = _hex_digit(v.char_code_at(5)) * 16 + _hex_digit(v.char_code_at(6))
    var a: i64 = 255
    if v.len() >= 9:
        a = _hex_digit(v.char_code_at(7)) * 16 + _hex_digit(v.char_code_at(8))
    _pack_argb(a, r, g, b)

fn _parse_rgba(value: text) -> u32:
    val open = value.index_of("(")
    val close = value.index_of(")")
    if open < 0 or close < 0 or close <= open:
        return 0xFFFFFFFFu32
    val inner = value[open + 1:close]
    val parts = inner.split(",")
    if parts.len() < 3:
        return 0xFFFFFFFFu32
    val r = _clamp_byte(parts[0].trim().to_i64() ?? 0)
    val g = _clamp_byte(parts[1].trim().to_i64() ?? 0)
    val b = _clamp_byte(parts[2].trim().to_i64() ?? 0)
    var a: i64 = 255
    if parts.len() >= 4:
        a = _parse_alpha(parts[3].trim())
    _pack_argb(a, r, g, b)

fn _parse_alpha(tok: text) -> i64:
    # Alpha may be a 0-1 float (e.g. "0.5") or a 0-255 int.
    if tok == "":
        return 255
    if tok.contains("."):
        val dot = tok.index_of(".")
        val whole = tok[0:dot].trim().to_i64() ?? 0
        if whole >= 1:
            return 255
        val frac_str = tok[dot + 1:]
        val frac = frac_str.to_i64() ?? 0
        var denom: i64 = 1
        var i: i64 = 0
        while i < frac_str.len():
            denom = denom * 10
            i = i + 1
        if denom <= 0:
            return 255
        # frac/denom in [0,1) -> scale to 0-255
        _clamp_byte((frac * 255) / denom)
    else:
        _clamp_byte(tok.to_i64() ?? 255)

fn _hex_digit(ch: i64) -> i64:
    if ch >= 48 and ch <= 57:
        return ch - 48
    if ch >= 97 and ch <= 102:
        return ch - 87
    if ch >= 65 and ch <= 70:
        return ch - 55
    0

fn _clamp_byte(v: i64) -> i64:
    if v < 0:
        return 0
    if v > 255:
        return 255
    v

fn _pack_argb(a: i64, r: i64, g: i64, b: i64) -> u32:
    val aa = _clamp_byte(a)
    val rr = _clamp_byte(r)
    val gg = _clamp_byte(g)
    val bb = _clamp_byte(b)
    (aa.to_u32() << 24) | (rr.to_u32() << 16) | (gg.to_u32() << 8) | bb.to_u32()

# ----------------------------------------------------------------------------
# Blitting
# ----------------------------------------------------------------------------

fn _blend(dst: u32, src: u32) -> u32:
    val a = (src >> 24).to_i64() & 0xFF
    if a >= 255:
        # Opaque: keep full alpha in output framebuffer.
        return 0xFF000000u32 | (src & 0x00FFFFFFu32)
    if a <= 0:
        return dst
    val sr = (src >> 16).to_i64() & 0xFF
    val sg = (src >> 8).to_i64() & 0xFF
    val sb = src.to_i64() & 0xFF
    val dr = (dst >> 16).to_i64() & 0xFF
    val dg = (dst >> 8).to_i64() & 0xFF
    val db = dst.to_i64() & 0xFF
    val inv = 255 - a
    val rr = (sr * a + dr * inv) / 255
    val gg = (sg * a + dg * inv) / 255
    val bb = (sb * a + db * inv) / 255
    _pack_argb(255, rr, gg, bb)

fn _fill_rect(src_px: [u32], cw: i64, ch: i64, x: i64, y: i64, w: i64, h: i64, color: u32) -> [u32]:
    var px = src_px
    var y0 = y
    if y0 < 0:
        y0 = 0
    var x0 = x
    if x0 < 0:
        x0 = 0
    var y1 = y + h
    if y1 > ch:
        y1 = ch
    var x1 = x + w
    if x1 > cw:
        x1 = cw
    var py = y0
    while py < y1:
        val row = py * cw
        var pxx = x0
        while pxx < x1:
            val idx = (row + pxx).to_i32()
            px[idx] = _blend(px[idx], color)
            pxx = pxx + 1
        py = py + 1
    px
