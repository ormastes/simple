"""
Simple Web HTML Renderer

Tiny HTML-only renderer for small static callers. Rich Engine2D/background
compatibility lives in simple_web_engine2d_renderer.
"""

pub fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    [0xFFFFFFFFu32; width * height]
