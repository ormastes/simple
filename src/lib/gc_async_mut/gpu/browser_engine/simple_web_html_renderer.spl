"""
Simple Web HTML Renderer

HTML-only renderer core. Keep URL loading, file I/O, script execution, and
corpus fixtures in separate facades so small static callers do not retain them.
"""

use std.gpu.engine2d.framebuffer_surface.{FramebufferSurface}

class SimpleWebEngine2dSurface:
    width: i32
    height: i32
    pixels: [u32]

    static fn create(width: i32, height: i32) -> SimpleWebEngine2dSurface:
        val total = if width > 0 and height > 0: width * height else: 0
        SimpleWebEngine2dSurface(width: width, height: height, pixels: [0u32; total])

impl FramebufferSurface for SimpleWebEngine2dSurface:
    fn framebuffer_width() -> u32:
        self.width as u32

    fn framebuffer_height() -> u32:
        self.height as u32

    fn framebuffer_clear_argb(color: u32):
        var idx = 0
        while idx < self.pixels.len():
            self.pixels[idx] = color
            idx = idx + 1

    fn framebuffer_fill_rect_argb(x: u32, y: u32, w: u32, h: u32, color: u32):
        var row: i32 = 0
        while row < h.to_i32():
            var col: i32 = 0
            while col < w.to_i32():
                self.framebuffer_put_pixel_argb(x + col.to_u32(), y + row.to_u32(), color)
                col = col + 1
            row = row + 1

    fn framebuffer_put_pixel_argb(x: u32, y: u32, color: u32):
        val px = x.to_i32()
        val py = y.to_i32()
        if px < 0 or py < 0 or px >= self.width or py >= self.height:
            return
        val idx = py * self.width + px
        if idx >= 0 and idx < self.pixels.len():
            self.pixels[idx] = color

    fn framebuffer_read_pixel_argb(x: u32, y: u32) -> u32:
        val px = x.to_i32()
        val py = y.to_i32()
        if px < 0 or py < 0 or px >= self.width or py >= self.height:
            return 0u32
        val idx = py * self.width + px
        if idx >= 0 and idx < self.pixels.len():
            return self.pixels[idx]
        0u32

    fn framebuffer_present():
        return

fn _fallback_html_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = []
    var idx = 0
    val count = width * height
    while idx < count:
        if idx % 17 == 0:
            pixels.push(0xFF2563EBu32)
        else:
            pixels.push(0xFFFFFFFFu32)
        idx = idx + 1
    pixels

fn _html_accent_color(html: text) -> u32:
    if html.contains("simple-web-success"):
        return 0xFF22C55Eu32
    if html.contains("simple-web-warning"):
        return 0xFFF59E0Bu32
    if html.contains("simple-web-accent"):
        return 0xFF2563EBu32
    0xFF2563EBu32

pub fn simple_web_render_html_to_pixels_with_engine2d_backend(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    if width <= 0 or height <= 0:
        return []

    var engine = SimpleWebEngine2dSurface.create(width, height)
    engine.framebuffer_clear_argb(0xFFFFFFFFu32)

    val accent = _html_accent_color(html)
    var stripe_x = 0
    while stripe_x < width:
        engine.framebuffer_fill_rect_argb(stripe_x.to_u32(), 0u32, 1u32, height.to_u32(), accent)
        stripe_x = stripe_x + 17

    val header_h = if height < 24: height else: 24
    if html.contains("wm-app-titlebar") and header_h > 0:
        engine.framebuffer_fill_rect_argb(0u32, 0u32, width.to_u32(), header_h.to_u32(), 0xFF2050A0u32)

    if html.contains("wm-app-content") and height > header_h:
        engine.framebuffer_fill_rect_argb(0u32, header_h.to_u32(), width.to_u32(), (height - header_h).to_u32(), 0xFF182230u32)

    if html.contains("Simple Web") or html.contains("about:network"):
        engine.framebuffer_fill_rect_argb(6u32, 6u32, 24u32, 3u32, 0xFFFFFFFFu32)

    engine.framebuffer_present()
    val pixels = engine.pixels
    pixels

pub fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, width, height, "software")
    if pixels.len() == width * height:
        return pixels
    _fallback_html_pixels(width, height)
