use std.gc_async_mut.gpu.browser_engine.simple_web_file_renderer.{simple_web_file_render_url_to_pixels}
use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{
    simple_web_engine2d_resolved_backend_name,
    simple_web_html_background_color}
use std.gc_async_mut.gpu.browser_engine.simple_web_layout_engine2d_fast.{simple_web_layout_render_html_pixels_engine2d, simple_web_layout_render_html_readback_engine2d}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback}
use std.gc_async_mut.gpu.engine2d.helpers_availability.{backend_canonical_name}

class SimpleWebRenderer:
    width: i32
    height: i32
    backend_name: text

class SimpleWebSceneCommand:
    kind: text
    color: u32

class SimpleWebRenderScene:
    width: i32
    height: i32
    commands: [SimpleWebSceneCommand]

class SimpleWebRenderResult:
    scene: SimpleWebRenderScene
    ok: bool

fn _normalize_backend_name(backend_name: text) -> text:
    val canonical = backend_canonical_name(backend_name)
    if canonical == "auto":
        return "auto"
    if canonical == "software" or canonical == "cpu" or canonical == "cpu_simd" or canonical == "metal" or canonical == "cuda" or canonical == "rocm" or canonical == "opencl" or canonical == "opengl" or canonical == "vulkan" or canonical == "intel" or canonical == "webgpu" or canonical == "qualcomm" or canonical == "directx":
        return canonical
    "software"

fn _accent_for_html(html: text) -> u32:
    if html.contains("simple-web-success"):
        return 0xFF22C55Eu32
    if html.contains("simple-web-warning"):
        return 0xFFF59E0Bu32
    0xFF2563EBu32

fn _css_background_color_for_html(html: text) -> u32:
    simple_web_html_background_color(html)

fn _render_engine2d_surface_pixels(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    simple_web_layout_render_html_pixels_engine2d(html, width, height, backend_name)

fn _render_engine2d_surface_readback(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    simple_web_layout_render_html_readback_engine2d(html, width, height, backend_name)

fn _resolved_backend_name(width: i32, height: i32, backend_name: text) -> text:
    simple_web_engine2d_resolved_backend_name(width, height, _normalize_backend_name(backend_name))

pub fn simple_web_render_html_to_scene(html: text, width: i32, height: i32) -> SimpleWebRenderScene:
    val color = _css_background_color_for_html(html)
    SimpleWebRenderScene(
        width: width,
        height: height,
        commands: [SimpleWebSceneCommand(kind: "fill_rect", color: color)]
    )

pub fn simple_web_renderer_create(width: i32, height: i32) -> SimpleWebRenderer:
    SimpleWebRenderer.create(width, height)

export SimpleWebRenderResult
export simple_web_renderer_create
export simple_web_render_html_to_scene

impl SimpleWebRenderer:
    static fn create(width: i32, height: i32) -> SimpleWebRenderer:
        SimpleWebRenderer(width: width, height: height, backend_name: _resolved_backend_name(width, height, "auto"))

    static fn create_with_backend(width: i32, height: i32, backend_name: text) -> SimpleWebRenderer:
        SimpleWebRenderer(width: width, height: height, backend_name: _resolved_backend_name(width, height, backend_name))

    fn render_html_to_pixels(html: text) -> [u32]:
        _render_engine2d_surface_pixels(html, self.width, self.height, self.backend_name)

    fn render_url_to_pixels(url: text) -> [u32]:
        _render_engine2d_surface_pixels(simple_web_default_page_html(url), self.width, self.height, self.backend_name)

pub fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    _render_engine2d_surface_pixels(html, width, height, _resolved_backend_name(width, height, "auto"))

pub fn simple_web_render_html_to_pixels_with_engine2d_backend(html: text, width: i32, height: i32, backend_name: text) -> [u32]:
    _render_engine2d_surface_pixels(html, width, height, _resolved_backend_name(width, height, backend_name))

pub fn simple_web_render_html_to_readback_with_engine2d_backend(html: text, width: i32, height: i32, backend_name: text) -> Engine2DReadback:
    _render_engine2d_surface_readback(html, width, height, _resolved_backend_name(width, height, backend_name))

pub fn simple_web_resolved_engine2d_backend_name(width: i32, height: i32, backend_name: text) -> text:
    _resolved_backend_name(width, height, backend_name)

pub fn simple_web_default_page_html(url: text) -> text:
    "<html><head><title>Simple Web</title></head><body><main class='simple-web-default'><h1>Simple Web</h1><p>" + url + "</p></main></body></html>"

pub fn simple_web_render_url_to_pixels(url: text, width: i64, height: i64) -> [u8]:
    """Fetch the resource at url and render it to an RGBA pixel buffer.

    For local (file://) and about: URLs, generates a placeholder page.
    For http(s) URLs, the actual fetch must be wired by the caller via
    the network stack — this function produces a stub white framebuffer
    until the network layer is connected.

    Returns: RGBA bytes, row-major, width * height * 4 bytes.
    """
    simple_web_file_render_url_to_pixels(url, width, height)
