extern fn rt_bytes_alloc(n: i64) -> [u8]

pub fn simple_web_render_placeholder_url_to_pixels(url: text, width: i64, height: i64) -> [u8]:
    val n_bytes = width * height * 4
    val pixels = rt_bytes_alloc(n_bytes)
    var i = 0
    while i < n_bytes:
        pixels[i] = 255
        i = i + 1
    pixels
