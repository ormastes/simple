#![allow(unnamed_duplicate_typed_args)]
# Style Block Processor — <style> tag CSS rule extraction and application
#
# Extracts CSS rules from <style> blocks in HTML, parses simple selectors
# (tag, .class, #id, compound), and applies matched styles to DOM nodes.
#
# Supports:
#   - Tag selectors: div, span, p, h1-h6, etc.
#   - Class selectors: .container, .active
#   - ID selectors: #main, #header
#   - Compound: div.active, span.highlight
#   - Comma-separated: div, span { ... }
#   - Descendant: div span { ... } (limited — matches if ANY ancestor matches)
#   - Pseudo-classes: :nth-child(N) (basic numeric only), :is(), :where(), :not(), :has()
#   - Shorthand properties: flex, border, background, margin multi-value

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode,
    be_dom_get_tag, be_dom_get_id, be_dom_get_classes, be_dom_get_children,
    be_dom_get_is_text, be_dom_set_children, be_dom_get_bg_color,
    parse_color_value}
use std.gc_async_mut.gpu.browser_engine.css.{parse_css_value, BoxEdges,
    BorderProps, CssValue}
use common.string_builder.{StringBuilder}

# =========================================================================
# CSS Rule types
# =========================================================================

pub class CssRule:
    selector: text
    declarations: [CssDecl]

pub class CssDecl:
    property: text
    value: text

pub fn css_decl_property(decl: CssDecl) -> text:
    decl.property

pub fn css_decl_value(decl: CssDecl) -> text:
    decl.value

pub fn css_decls_contain(decls: [CssDecl], property: text, value: text) -> bool:
    var i = 0
    while i < decls.len():
        val decl = decls[i]
        i = i + 1
        if decl.property == property and decl.value == value:
            return true
    false

# =========================================================================
# Extract <style> blocks from HTML
# =========================================================================

fn extract_style_blocks(html: text) -> [text]:
    var blocks: [text] = []
    var pos = 0
    val lower = html.lower()
    while pos < lower.len():
        val style_open = sb_find(lower, "<style", pos)
        if style_open >= 999999999:
            break
        val gt = sb_find(html, ">", style_open)
        if gt >= 999999999:
            break
        val content_start = gt + 1
        val style_close = sb_find(lower, "</style", content_start)
        if style_close >= 999999999:
            break
        val block = html.slice(content_start, style_close)
        blocks.push(block)
        pos = style_close + 8
    blocks

# =========================================================================
# Parse CSS text into rules
# =========================================================================

fn parse_css_rules(css_text: text) -> [CssRule]:
    var rules: [CssRule] = []
    var pos = 0
    val normalized_css = flatten_layer_blocks(css_text)
    val len = normalized_css.len()

    while pos < len:
        pos = sb_skip_ws_comments(normalized_css, pos)
        if pos >= len:
            break
        val brace_open = sb_find(normalized_css, "{", pos)
        if brace_open >= 999999999:
            break
        val selector_raw = normalized_css.slice(pos, brace_open)
        val selector_text = selector_raw.trim()
        if selector_text.len() == 0:
            pos = brace_open + 1
            continue
        val brace_close = sb_find(normalized_css, "}", brace_open + 1)
        if brace_close >= 999999999:
            break
        val decl_raw = normalized_css.slice(brace_open + 1, brace_close)
        val decl_text = decl_raw.trim()
        val declarations = parse_declarations(decl_text)
        val selectors = sb_split_selector_list(selector_text)
        var sel_idx = 0
        while sel_idx < selectors.len():
            val sel = selectors[sel_idx]
            sel_idx = sel_idx + 1
            val trimmed = sel.trim()
            if trimmed.len() > 0:
                rules.push(CssRule(selector: trimmed, declarations: declarations))
        pos = brace_close + 1

    rules

fn flatten_layer_blocks(css_text: text) -> text:
    """Expose simple @layer wrapper contents to the existing flat rule parser."""
    val lower = css_text.lower()
    var out = ""
    var pos = 0
    while pos < css_text.len():
        val layer_pos = sb_find(lower, "@layer", pos)
        if layer_pos >= 999999999:
            out = out + css_text.slice(pos, css_text.len())
            break
        out = out + css_text.slice(pos, layer_pos)
        val open = sb_find(css_text, "{", layer_pos)
        if open >= 999999999:
            out = out + css_text.slice(layer_pos, css_text.len())
            break
        val close = find_matching_brace(css_text, open)
        if close >= 999999999:
            out = out + css_text.slice(layer_pos, css_text.len())
            break
        val inner = css_text.slice(open + 1, close).trim()
        if inner.len() > 0:
            out = out + "\n" + inner + "\n"
        pos = close + 1
    out

fn find_matching_brace(text_val: text, open: i32) -> i32:
    var depth = 0
    var pos = open
    while pos < text_val.len():
        val ch = text_val.char_at(pos)
        if ch == "{":
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0:
                return pos
        pos = pos + 1
    999999999

fn parse_declarations(text_val: text) -> [CssDecl]:
    var decls: [CssDecl] = []
    val parts = sb_split_char(text_val, ";")
    var pt_idx = 0
    while pt_idx < parts.len():
        val part = parts[pt_idx]
        pt_idx = pt_idx + 1
        val trimmed = part.trim()
        if trimmed.len() == 0:
            continue
        val colon = sb_find(trimmed, ":", 0)
        if colon <= 0 or colon >= 999999999:
            continue
        val prop_raw = trimmed.slice(0, colon)
        val prop = prop_raw.trim()
        val value_raw = trimmed.slice(colon + 1, trimmed.len())
        val value = value_raw.trim()
        if prop.len() > 0 and value.len() > 0:
            val expanded = expand_shorthand(prop, value)
            var ex_idx = 0
            while ex_idx < expanded.len():
                val e = expanded[ex_idx]
                ex_idx = ex_idx + 1
                decls.push(e)
    decls

fn collect_css_vars(rules: [CssRule]) -> [CssDecl]:
    var vars: [CssDecl] = []
    var ri = 0
    while ri < rules.len():
        val rule = rules[ri]
        ri = ri + 1
        if rule.selector == ":root" or rule.selector == "html":
            var di = 0
            while di < rule.declarations.len():
                val decl = rule.declarations[di]
                di = di + 1
                if decl.property.starts_with("--"):
                    vars.push(decl)
    vars

fn resolve_css_vars_in_value(value: text, vars: [CssDecl]) -> text:
    var resolved = value
    var vi = 0
    while vi < vars.len():
        val v = vars[vi]
        vi = vi + 1
        resolved = resolved.replace("var(" + v.property + ")", v.value)
        resolved = resolved.replace("var(" + v.property + " )", v.value)
    resolved

fn resolve_css_vars_in_rules(rules: [CssRule], vars: [CssDecl]) -> [CssRule]:
    if vars.len() == 0:
        return rules
    var out: [CssRule] = []
    var ri = 0
    while ri < rules.len():
        val rule = rules[ri]
        ri = ri + 1
        var decls: [CssDecl] = []
        var di = 0
        while di < rule.declarations.len():
            val decl = rule.declarations[di]
            di = di + 1
            decls.push(CssDecl(
                property: decl.property,
                value: resolve_css_vars_in_value(decl.value, vars)
            ))
        out.push(CssRule(selector: rule.selector, declarations: decls))
    out

# =========================================================================
# Shorthand expansion
# =========================================================================

fn expand_shorthand(prop: text, value: text) -> [CssDecl]:
    if prop == "flex":
        return expand_flex(value)
    if prop == "flex-flow":
        return expand_flex_flow(value)
    if prop == "border":
        return expand_border(value)
    if prop == "background":
        return expand_background(value)
    if prop == "margin" or prop == "padding":
        return expand_box_shorthand(prop, value)
    if prop == "font":
        return expand_font(value)
    [CssDecl(property: prop, value: value)]

pub fn expand_flex_flow(value: text) -> [CssDecl]:
    val parts = sb_split_ws(value)
    var direction = "row"
    var wrap = "nowrap"
    var fp_idx = 0
    while fp_idx < parts.len():
        val part = parts[fp_idx]
        fp_idx = fp_idx + 1
        if part == "row" or part == "column" or part == "row-reverse" or part == "column-reverse":
            direction = part
        elif part == "wrap" or part == "nowrap" or part == "wrap-reverse":
            wrap = part
    [CssDecl(property: "flex-direction", value: direction),
     CssDecl(property: "flex-wrap", value: wrap)]

fn expand_font(value: text) -> [CssDecl]:
    """Extract font-size from font shorthand (simplified)."""
    val parts = sb_split_ws(value)
    var decls: [CssDecl] = []
    var fp2_idx = 0
    while fp2_idx < parts.len():
        val part = parts[fp2_idx]
        fp2_idx = fp2_idx + 1
        if part.ends_with("px") or part.ends_with("em") or part.ends_with("rem") or part.ends_with("pt"):
            decls.push(CssDecl(property: "font-size", value: part))
        elif part.ends_with("%"):
            decls.push(CssDecl(property: "font-size", value: part))
        elif part == "bold" or part == "bolder":
            decls.push(CssDecl(property: "font-weight", value: part))
        elif part == "italic":
            pass_dn
    if decls.len() == 0:
        decls = [CssDecl(property: "font", value: value)]
    decls

fn expand_flex(value: text) -> [CssDecl]:
    if value == "none":
        return [
            CssDecl(property: "flex-grow", value: "0"),
            CssDecl(property: "flex-shrink", value: "0"),
            CssDecl(property: "flex-basis", value: "auto")
        ]
    val parts = sb_split_ws(value)
    if parts.len() == 1:
        # flex: N means flex-grow: N, flex-shrink: 1, flex-basis: 0%
        return [
            CssDecl(property: "flex-grow", value: parts[0]),
            CssDecl(property: "flex-shrink", value: "1"),
            CssDecl(property: "flex-basis", value: "0%")
        ]
    if parts.len() == 2:
        return [
            CssDecl(property: "flex-grow", value: parts[0]),
            CssDecl(property: "flex-shrink", value: parts[1]),
            CssDecl(property: "flex-basis", value: "0%")
        ]
    if parts.len() >= 3:
        return [
            CssDecl(property: "flex-grow", value: parts[0]),
            CssDecl(property: "flex-shrink", value: parts[1]),
            CssDecl(property: "flex-basis", value: parts[2])
        ]
    [CssDecl(property: "flex-grow", value: value)]

fn expand_border(value: text) -> [CssDecl]:
    val parts = sb_split_ws(value)
    var width = "1px"
    var style = "solid"
    var color = "black"
    var bp_idx = 0
    while bp_idx < parts.len():
        val part = parts[bp_idx]
        bp_idx = bp_idx + 1
        if part.ends_with("px") or part.ends_with("em") or part == "thin" or part == "medium" or part == "thick":
            width = part
            if part == "thin":
                width = "1px"
            if part == "medium":
                width = "3px"
            if part == "thick":
                width = "5px"
        elif part == "solid" or part == "dashed" or part == "dotted" or part == "none" or part == "double":
            style = part
        else:
            color = part
    [
        CssDecl(property: "border-width", value: width),
        CssDecl(property: "border-style", value: style),
        CssDecl(property: "border-color", value: color)
    ]

fn expand_background(value: text) -> [CssDecl]:
    val trimmed = value.trim()
    if not trimmed.starts_with("linear-gradient") and not trimmed.starts_with("radial-gradient"):
        val color = sb_background_shorthand_color_value(trimmed)
        if color.len() > 0:
            return [CssDecl(property: "background-color", value: color)]
    [CssDecl(property: "background", value: value)]

fn sb_background_shorthand_color_value(value: text) -> text:
    val trimmed = value.trim()
    if trimmed.len() == 0:
        return ""
    var pos = 0
    while pos < trimmed.len():
        while pos < trimmed.len() and trimmed.char_at(pos) == " ":
            pos = pos + 1
        if pos >= trimmed.len():
            break
        val token = sb_background_token_from(trimmed, pos)
        if token.len() == 0:
            break
        val lower = token.lower()
        if lower.starts_with("url(") or lower.starts_with("linear-gradient") or lower.starts_with("radial-gradient"):
            pos = pos + token.len()
            continue
        if token.starts_with("#") or lower.starts_with("rgb(") or lower.starts_with("rgba(") or lower.starts_with("hsl(") or lower.starts_with("hsla(") or lower == "transparent" or lower == "currentcolor":
            return token
        val parsed = parse_color_value(token)
        if parsed != 0x000000FF or lower == "black":
            return token
        pos = pos + token.len()
    ""

fn sb_background_token_from(value: text, start: i32) -> text:
    var end = start
    var depth: i32 = 0
    while end < value.len():
        val ch = value.char_at(end)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
        elif ch == " " and depth == 0:
            break
        end = end + 1
    val raw = value.slice(start, end)
    raw.trim()

fn expand_box_shorthand(prop: text, value: text) -> [CssDecl]:
    val parts = sb_split_ws(value)
    if parts.len() == 1:
        return [CssDecl(property: prop, value: parts[0])]
    if parts.len() == 2:
        return [
            CssDecl(property: "{prop}-top", value: parts[0]),
            CssDecl(property: "{prop}-right", value: parts[1]),
            CssDecl(property: "{prop}-bottom", value: parts[0]),
            CssDecl(property: "{prop}-left", value: parts[1])
        ]
    if parts.len() == 3:
        return [
            CssDecl(property: "{prop}-top", value: parts[0]),
            CssDecl(property: "{prop}-right", value: parts[1]),
            CssDecl(property: "{prop}-bottom", value: parts[2]),
            CssDecl(property: "{prop}-left", value: parts[1])
        ]
    if parts.len() >= 4:
        return [
            CssDecl(property: "{prop}-top", value: parts[0]),
            CssDecl(property: "{prop}-right", value: parts[1]),
            CssDecl(property: "{prop}-bottom", value: parts[2]),
            CssDecl(property: "{prop}-left", value: parts[3])
        ]
    [CssDecl(property: prop, value: value)]

# =========================================================================
# Selector matching
# =========================================================================

fn selector_matches(selector: text, node: BeDomNode, parent: BeDomNode?, nth: i32) -> bool:
    val trimmed = selector.trim()
    if trimmed.len() == 0:
        return false

    # Descendant combinator: "div span" — check if any ancestor matches first part
    val space_parts = sb_split_ws(trimmed)
    if space_parts.len() > 1:
        # Last part must match the node itself
        val last = space_parts[space_parts.len() - 1]
        if not simple_selector_matches(last, node, nth):
            return false
        # For descendant, we just check if node matches the last selector
        # Full descendant matching would require walking ancestors, but the
        # caller walks the tree so parents are available
        return true

    simple_selector_matches(trimmed, node, nth)

fn simple_selector_matches(selector: text, node: BeDomNode, nth: i32) -> bool:
    val sel = selector.trim()
    if sel.len() == 0:
        return false
    if sel == "*":
        return node.is_element()

    # Modern forgiving selector-list pseudos. Specificity differences do not
    # matter in this order-only style applicator, so :is() and :where() share
    # matching behavior here.
    if sel.starts_with(":is(") or sel.starts_with(":where("):
        return functional_selector_list_matches(sel, node, nth)
    if sel.starts_with(":not("):
        return not_selector_list_matches(sel, node, nth)
    if sel.starts_with(":has("):
        return has_descendant_selector_list_match(sel, node)

    # Handle :nth-child pseudo
    val nth_pos = sb_find(sel, ":nth-child(", 0)
    if nth_pos < 999999999:
        val base_sel = sel.slice(0, nth_pos)
        val paren_end = sb_find(sel, ")", nth_pos)
        if paren_end > 0 and paren_end < 999999999:
            val n_raw = sel.slice(nth_pos + 11, paren_end)
            val n_str = n_raw.trim()
            val target_n = sb_parse_int(n_str)
            if nth != target_n:
                return false
            if base_sel.len() == 0:
                return node.is_element()
            return simple_selector_matches(base_sel, node, nth)

    # ID selector: #foo
    if sel.starts_with("#"):
        val id = sel.slice(1, sel.len())
        return be_dom_get_id(node) == id

    # Class selector: .foo
    if sel.starts_with("."):
        val cls = sel.slice(1, sel.len())
        return sb_has_class(node, cls)

    # Compound: tag.class or tag#id
    val pseudo_is_pos = sb_find(sel, ":is(", 0)
    if pseudo_is_pos > 0 and pseudo_is_pos < 999999999:
        val base = sel.slice(0, pseudo_is_pos)
        val pseudo = sel.slice(pseudo_is_pos, sel.len())
        return simple_selector_matches(base, node, nth) and functional_selector_list_matches(pseudo, node, nth)
    val pseudo_where_pos = sb_find(sel, ":where(", 0)
    if pseudo_where_pos > 0 and pseudo_where_pos < 999999999:
        val base = sel.slice(0, pseudo_where_pos)
        val pseudo = sel.slice(pseudo_where_pos, sel.len())
        return simple_selector_matches(base, node, nth) and functional_selector_list_matches(pseudo, node, nth)
    val pseudo_not_pos = sb_find(sel, ":not(", 0)
    if pseudo_not_pos > 0 and pseudo_not_pos < 999999999:
        val base = sel.slice(0, pseudo_not_pos)
        val pseudo = sel.slice(pseudo_not_pos, sel.len())
        return simple_selector_matches(base, node, nth) and not_selector_list_matches(pseudo, node, nth)
    val pseudo_has_pos = sb_find(sel, ":has(", 0)
    if pseudo_has_pos > 0 and pseudo_has_pos < 999999999:
        val base = sel.slice(0, pseudo_has_pos)
        val pseudo = sel.slice(pseudo_has_pos, sel.len())
        return simple_selector_matches(base, node, nth) and has_descendant_selector_list_match(pseudo, node)

    val dot_pos = sb_find(sel, ".", 0)
    if dot_pos > 0 and dot_pos < 999999999:
        val tag = sel.slice(0, dot_pos)
        val cls = sel.slice(dot_pos + 1, sel.len())
        val ntag = be_dom_get_tag(node)
        return ntag == tag and sb_has_class(node, cls)

    val hash_pos = sb_find(sel, "#", 0)
    if hash_pos > 0 and hash_pos < 999999999:
        val tag = sel.slice(0, hash_pos)
        val id = sel.slice(hash_pos + 1, sel.len())
        val ntag2 = be_dom_get_tag(node)
        val nid = be_dom_get_id(node)
        return ntag2 == tag and nid == id

    # Plain tag selector
    val ntag3 = be_dom_get_tag(node)
    ntag3 == sel

fn functional_selector_list_matches(selector: text, node: BeDomNode, nth: i32) -> bool:
    val open = sb_find(selector, "(", 0)
    if open >= 999999999:
        return false
    val close = sb_find(selector, ")", open + 1)
    if close >= 999999999:
        return false
    val inner = selector.slice(open + 1, close)
    val options = sb_split_selector_list(inner)
    var idx = 0
    while idx < options.len():
        val option = options[idx].trim()
        if option.len() > 0 and simple_selector_matches(option, node, nth):
            return true
        idx = idx + 1
    false

fn not_selector_list_matches(selector: text, node: BeDomNode, nth: i32) -> bool:
    val open = sb_find(selector, "(", 0)
    if open >= 999999999:
        return false
    val close = sb_find(selector, ")", open + 1)
    if close >= 999999999:
        return false
    val inner = selector.slice(open + 1, close)
    val options = sb_split_selector_list(inner)
    var idx = 0
    var saw_option = false
    while idx < options.len():
        val option = options[idx].trim()
        if option.len() > 0:
            saw_option = true
            if simple_selector_matches(option, node, nth):
                return false
        idx = idx + 1
    saw_option

fn has_descendant_selector_list_match(selector: text, node: BeDomNode) -> bool:
    val open = sb_find(selector, "(", 0)
    if open >= 999999999:
        return false
    val close = sb_find(selector, ")", open + 1)
    if close >= 999999999:
        return false
    val inner = selector.slice(open + 1, close)
    val options = sb_split_selector_list(inner)
    var idx = 0
    while idx < options.len():
        val option = options[idx].trim()
        if option.len() > 0 and node_has_descendant_matching(node, option):
            return true
        idx = idx + 1
    false

fn node_has_descendant_matching(node: BeDomNode, selector: text) -> bool:
    val children = be_dom_get_children(node)
    var idx = 0
    var nth = 1
    while idx < children.len():
        val child = children[idx]
        if not be_dom_get_is_text(child):
            if simple_selector_matches(selector, child, nth):
                return true
            if node_has_descendant_matching(child, selector):
                return true
            nth = nth + 1
        idx = idx + 1
    false

fn sb_has_class(node: BeDomNode, name: text) -> bool:
    """Cross-module class membership check using be_dom_get_classes accessor."""
    val classes = be_dom_get_classes(node)
    for cls in classes:
        if cls == name:
            return true
    false

# =========================================================================
# Apply rules to DOM tree
# =========================================================================

fn apply_css_rules_to_tree(root: BeDomNode, rules: [CssRule]):
    apply_rules_to_node(root, rules, nil, 1)

fn apply_rules_to_node(node: BeDomNode, rules: [CssRule], parent: BeDomNode?, nth: i32):
    if be_dom_get_is_text(node):
        return

    # Skip style/link/meta/title/head/html/!doctype elements
    val tag = be_dom_get_tag(node)
    if tag == "style" or tag == "link" or tag == "meta" or tag == "title" or tag == "head":
        return

    var color_ru_idx = 0
    while color_ru_idx < rules.len():
        val rule = rules[color_ru_idx]
        color_ru_idx = color_ru_idx + 1
        if selector_matches(rule.selector, node, parent, nth):
            var dc_idx = 0
            while dc_idx < rule.declarations.len():
                val decl = rule.declarations[dc_idx]
                dc_idx = dc_idx + 1
                if decl.property == "color":
                    node.set_style(decl.property, decl.value)
    var ru_idx = 0
    while ru_idx < rules.len():
        val rule = rules[ru_idx]
        ru_idx = ru_idx + 1
        if selector_matches(rule.selector, node, parent, nth):
            var dc_idx = 0
            while dc_idx < rule.declarations.len():
                val decl = rule.declarations[dc_idx]
                dc_idx = dc_idx + 1
                if decl.property != "color":
                    node.set_style(decl.property, decl.value)

    # Recurse to children with nth tracking, rebuilding the children array.
    # The interpreter copies class instances on array index/push, so the
    # `child` we fetch from children[i] is a detached copy. We style it,
    # recurse (which rebuilds its grandchildren in turn), then push the
    # styled copy into a new array and write the new array back via
    # be_dom_set_children so the parent sees the changes.
    var child_nth = 1
    val sb_kids = be_dom_get_children(node)
    var new_kids: [BeDomNode] = []
    var sc_idx = 0
    while sc_idx < sb_kids.len():
        var child = sb_kids[sc_idx]
        sc_idx = sc_idx + 1
        apply_rules_to_node(child, rules, node, child_nth)
        new_kids.push(child)
        if not be_dom_get_is_text(child):
            child_nth = child_nth + 1
    be_dom_set_children(node, new_kids)

# =========================================================================
# Public API: process HTML with <style> blocks
# =========================================================================

pub fn process_style_blocks(root: BeDomNode, html: text):
    val blocks = extract_style_blocks(html)
    var all_rules: [CssRule] = []
    var all_vars: [CssDecl] = []
    var bl_idx = 0
    while bl_idx < blocks.len():
        val block = blocks[bl_idx]
        bl_idx = bl_idx + 1
        val rules = parse_css_rules(block)
        val vars = collect_css_vars(rules)
        var vi = 0
        while vi < vars.len():
            all_vars.push(vars[vi])
            vi = vi + 1
        var ri_idx = 0
        while ri_idx < rules.len():
            val r = rules[ri_idx]
            ri_idx = ri_idx + 1
            all_rules.push(r)
    if all_rules.len() > 0:
        val resolved_rules = resolve_css_vars_in_rules(all_rules, all_vars)
        apply_css_rules_to_tree(root, resolved_rules)

pub fn process_style_blocks_result(root: BeDomNode, html: text) -> BeDomNode:
    process_style_blocks(root, html)
    root

# =========================================================================
# Helpers
# =========================================================================

fn sb_find(s: text, target: text, start: i64) -> i64:
    var i = start
    val tlen = target.len()
    val slen = s.len()
    while i + tlen <= slen:
        if s.slice(i, i + tlen) == target:
            return i
        i = i + 1
    999999999

fn sb_split_char(s: text, delimiter: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == delimiter:
            parts.push(sb.to_text())
            sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

fn sb_split_selector_list(s: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    var paren_depth = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == "(":
            paren_depth = paren_depth + 1
            sb.push(ch)
        elif ch == ")" and paren_depth > 0:
            paren_depth = paren_depth - 1
            sb.push(ch)
        elif ch == "," and paren_depth == 0:
            parts.push(sb.to_text())
            sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

fn sb_split_ws(s: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if not sb.is_empty():
                parts.push(sb.to_text())
                sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

fn sb_skip_ws_comments(s: text, start: i64) -> i64:
    var pos = start
    val slen = s.len()
    while pos < slen:
        val ch = s.char_at(pos)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            pos = pos + 1
            continue
        # CSS comment: /* ... */
        if pos + 1 < slen and s.slice(pos, pos + 2) == "/*":
            val end = sb_find(s, "*/", pos + 2)
            if end < 999999999:
                pos = end + 2
                continue
            break
        break
    pos

fn sb_parse_int(s: text) -> i32:
    """Manual integer parser avoiding optional type bugs in Cranelift."""
    val t = s.trim()
    if t.len() == 0:
        return 0
    var neg = false
    var start = 0
    if t.slice(0, 1) == "-":
        neg = true
        start = 1
    elif t.slice(0, 1) == "+":
        start = 1
    var result = 0
    var idx = start
    val slen = t.len()
    while idx < slen:
        val ch = t.char_at(idx)
        var digit = -1
        if ch == "0": digit = 0
        elif ch == "1": digit = 1
        elif ch == "2": digit = 2
        elif ch == "3": digit = 3
        elif ch == "4": digit = 4
        elif ch == "5": digit = 5
        elif ch == "6": digit = 6
        elif ch == "7": digit = 7
        elif ch == "8": digit = 8
        elif ch == "9": digit = 9
        if digit < 0:
            break
        result = result * 10 + digit
        idx = idx + 1
    if neg:
        return 0 - result
    result
