"""session_api — Module-level functions for backend session lifecycle.

Implements backend_session_create, backend_session_retain, backend_session_release,
and backend_session_probe. All return new values (interpreter-safe, no mutating self).
"""

use std.io
use std.gpu.session.session_types.{BackendSessionHandle, BackendSessionPolicy, BackendSessionError}

# ---------------------------------------------------------------------------
# BackendProbeResult — read-only device/API information
# ---------------------------------------------------------------------------

class BackendProbeResult:
    """Result from probing a session's backend state."""

    session_id: i64
    kind: text
    mode: text
    device_available: bool
    api_available: bool
    driver_version: text
    error: BackendSessionError

    static fn create(h: BackendSessionHandle) -> BackendProbeResult:
        val avail = BackendSessionHandle.is_valid(h)
        return BackendProbeResult(
            session_id: h.id,
            kind: h.kind,
            mode: h.mode,
            device_available: avail,
            api_available: avail,
            driver_version: "1.0.0",
            error: BackendSessionError.none()
        )

    static fn unavailable(kind: text) -> BackendProbeResult:
        val err = BackendSessionError.backend_unavailable(kind)
        return BackendProbeResult(
            session_id: -1,
            kind: kind,
            mode: "",
            device_available: false,
            api_available: false,
            driver_version: "",
            error: err
        )

    static fn is_ready(pr: BackendProbeResult) -> bool:
        return pr.device_available and pr.api_available

# ---------------------------------------------------------------------------
# Session counter (module-level, not mutable self)
# ---------------------------------------------------------------------------

val SESSION_ID_SEED: i64 = 100

fn next_session_id(base: i64, ordinal: i64) -> i64:
    return base + ordinal

# ---------------------------------------------------------------------------
# backend_session_create — allocate a new session handle for kind + policy
# ---------------------------------------------------------------------------

fn backend_session_create(kind: text, policy: BackendSessionPolicy, ordinal: i64) -> BackendSessionHandle:
    """Create a new session handle for the given backend kind and policy.
    Returns invalid handle if the kind is empty or policy mode is unknown.
    ordinal is caller-managed ID seed (pass 1 for first session).
    """
    if kind == "":
        return BackendSessionHandle.invalid()
    val allowed = policy.mode == "managed_shared" or policy.mode == "perf_exclusive" or policy.mode == "legacy_no_session"
    if allowed == false:
        return BackendSessionHandle.invalid()
    val sid = next_session_id(SESSION_ID_SEED, ordinal)
    val h = BackendSessionHandle.create(sid, kind, policy.mode)
    return h

# ---------------------------------------------------------------------------
# backend_session_retain — increment generation (returns new handle)
# ---------------------------------------------------------------------------

fn backend_session_retain(h: BackendSessionHandle) -> BackendSessionHandle:
    """Retain a session by returning a handle with an incremented generation.
    Perf-exclusive sessions cannot be retained while active — returns invalid if mode is perf_exclusive.
    """
    if BackendSessionHandle.is_valid(h) == false:
        return BackendSessionHandle.invalid()
    if h.mode == "perf_exclusive":
        return BackendSessionHandle.invalid()
    return BackendSessionHandle.increment_generation(h)

# ---------------------------------------------------------------------------
# backend_session_release — return invalidated handle
# ---------------------------------------------------------------------------

fn backend_session_release(h: BackendSessionHandle) -> BackendSessionHandle:
    """Release a session. Returns an invalid handle to signal ownership transfer."""
    return BackendSessionHandle.invalid()

# ---------------------------------------------------------------------------
# backend_session_probe — inspect current session state
# ---------------------------------------------------------------------------

fn backend_session_probe(h: BackendSessionHandle) -> BackendProbeResult:
    """Probe a session handle to get device and API availability info."""
    if BackendSessionHandle.is_valid(h) == false:
        return BackendProbeResult.unavailable(h.kind)
    return BackendProbeResult.create(h)
