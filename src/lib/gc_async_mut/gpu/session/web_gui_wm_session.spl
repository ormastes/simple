# web_gui_wm_session.spl — Session types for web renderer, GUI apps, and WM compositor.
#
# None of these classes store raw GPU device handles (i64 handles).
# They store only session_id + mode. The actual GPU backend handle lives in
# the GraphicsSession that they reference by session_id.
#
# Modes: "legacy_no_session", "managed_shared", "perf_exclusive"

use std.io

val WEB_SESSION_ID_BASE: i64 = 4000
val GUI_SESSION_ID_BASE: i64 = 5000
val WM_SESSION_ID_BASE:  i64 = 6000

val WEB_SESSION_COUNTER: i64 = 0
val GUI_SESSION_COUNTER: i64 = 0
val WM_SESSION_COUNTER:  i64 = 0

# ---------------------------------------------------------------------------
# WebRendererSession — web content renderer bound to a surface
# ---------------------------------------------------------------------------

class WebRendererSession:
    """Session for web content rendering (HTML/CSS/canvas/WebGPU fragments).
    References the GPU backend by session_id only — no raw handles stored."""

    session_id: i64
    mode: text
    surface_id: i64
    canvas_width: i64
    canvas_height: i64
    paint_count: i64
    webgpu_enabled: bool
    active: bool

    static fn create(surface_id: i64, mode: text) -> WebRendererSession:
        val sid = WEB_SESSION_ID_BASE + surface_id
        val use_webgpu = mode == "managed_shared" or mode == "perf_exclusive"
        return WebRendererSession(
            session_id: sid,
            mode: mode,
            surface_id: surface_id,
            canvas_width: 1280,
            canvas_height: 720,
            paint_count: 0,
            webgpu_enabled: use_webgpu,
            active: true
        )

    static fn create_managed(surface_id: i64) -> WebRendererSession:
        return WebRendererSession.create(surface_id, "managed_shared")

    me paint_fragment(fragment_type: text, x: i64, y: i64, w: i64, h: i64) -> text:
        self.paint_count = self.paint_count + 1
        return "paint fragment_type={fragment_type} x={x} y={y} w={w} h={h} count={self.paint_count}"

    me needs_gpu() -> bool:
        return self.webgpu_enabled

    me present() -> text:
        return "web_present surface={self.surface_id} paints={self.paint_count}"

    me stats() -> text:
        return "web_session id={self.session_id} mode={self.mode} surface={self.surface_id} paints={self.paint_count} webgpu={self.webgpu_enabled}"

    me cleanup() -> text:
        self.active = false
        return "web_session cleaned up id={self.session_id}"

# ---------------------------------------------------------------------------
# GuiAppSession — GUI application session (windows, widgets, paint cycles)
# ---------------------------------------------------------------------------

class GuiAppSession:
    """Session for a GUI application. Tracks windows and widget paint state.
    References the GPU backend by session_id only — no raw handles stored."""

    session_id: i64
    mode: text
    window_count: i64
    widget_count: i64
    paint_dirty: bool
    active: bool

    static fn create(mode: text) -> GuiAppSession:
        return GuiAppSession(
            session_id: GUI_SESSION_ID_BASE,
            mode: mode,
            window_count: 0,
            widget_count: 0,
            paint_dirty: false,
            active: true
        )

    static fn create_managed() -> GuiAppSession:
        return GuiAppSession.create("managed_shared")

    me add_window(title: text, w: i64, h: i64) -> i64:
        self.window_count = self.window_count + 1
        return self.window_count

    me mark_dirty():
        self.paint_dirty = true

    me paint_widgets() -> text:
        self.paint_dirty = false
        return "paint_widgets windows={self.window_count} widgets={self.widget_count}"

    me present() -> text:
        return "gui_present id={self.session_id} windows={self.window_count}"

    me stats() -> text:
        return "gui_session id={self.session_id} mode={self.mode} windows={self.window_count} widgets={self.widget_count} dirty={self.paint_dirty}"

    me cleanup() -> text:
        self.active = false
        return "gui_session cleaned up id={self.session_id}"

# ---------------------------------------------------------------------------
# WmCompositorSession — WM compositor session (surfaces, damage, frames)
# ---------------------------------------------------------------------------

class WmCompositorSession:
    """Session for a window-manager compositor. Tracks client surfaces and damage.
    References the GPU backend by session_id only — no raw handles stored."""

    session_id: i64
    mode: text
    surface_count: i64
    damage_region_count: i64
    frame_count: i64
    active: bool

    static fn create(mode: text) -> WmCompositorSession:
        return WmCompositorSession(
            session_id: WM_SESSION_ID_BASE,
            mode: mode,
            surface_count: 0,
            damage_region_count: 0,
            frame_count: 0,
            active: true
        )

    static fn create_managed() -> WmCompositorSession:
        return WmCompositorSession.create("managed_shared")

    me add_surface(owner_id: i64, w: i64, h: i64) -> i64:
        self.surface_count = self.surface_count + 1
        return self.surface_count

    me mark_damage(surface_id: i64, x: i64, y: i64, w: i64, h: i64) -> text:
        self.damage_region_count = self.damage_region_count + 1
        return "damage surface={surface_id} x={x} y={y} w={w} h={h} regions={self.damage_region_count}"

    me compose_frame() -> text:
        self.frame_count = self.frame_count + 1
        val result = "compose_frame frame={self.frame_count} surfaces={self.surface_count} damage={self.damage_region_count}"
        self.damage_region_count = 0
        return result

    me present() -> text:
        return "wm_present id={self.session_id} frame={self.frame_count}"

    me stats() -> text:
        return "wm_session id={self.session_id} mode={self.mode} surfaces={self.surface_count} frames={self.frame_count}"

    me cleanup() -> text:
        self.active = false
        return "wm_session cleaned up id={self.session_id}"
