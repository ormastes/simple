# CUDA compute/interop backend adapter.
# Compute-only: no graphics rasterization, no direct present.

use std.io
use std.gc_async_mut.gpu.session.backend_runtime_ops.{
    backend_cuda_device_init, backend_cuda_submit, backend_cuda_cleanup
}

class BackendCudaAdapter:
    handle: i64
    device_name: text
    initialized: bool
    session_mode: text

    static fn create(mode: text) -> BackendCudaAdapter:
        BackendCudaAdapter(
            handle: 0,
            device_name: "cuda",
            initialized: false,
            session_mode: mode,
        )

    me init_device() -> text:
        val h = backend_cuda_device_init(0)
        if h <= 0:
            return "cuda: device init failed"
        self.handle = h
        self.initialized = true
        ""

    me submit_commands(cmd_count: i64) -> text:
        if self.initialized == false:
            return "cuda: device not initialized"
        if cmd_count < 0:
            return "cuda: invalid cmd_count"
        backend_cuda_submit(self.handle, cmd_count)

    me present() -> text:
        "cuda: present not supported"

    me readback(x: i64, y: i64, w: i64, h: i64) -> text:
        if self.initialized == false:
            return "cuda: device not initialized"
        if w <= 0 or h <= 0:
            return "cuda: invalid readback dimensions"
        ""

    me supports_compute() -> bool:
        true

    me supports_graphics() -> bool:
        false

    me supports_present() -> bool:
        false

    me device_info() -> text:
        "cuda handle=" + self.handle.to_text() + " mode=" + self.session_mode + " initialized=" + self.initialized.to_text()

    me cleanup() -> text:
        if self.initialized:
            backend_cuda_cleanup(self.handle)
        self.initialized = false
        self.handle = 0
        ""
