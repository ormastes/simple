# GraphicsCapabilities — Capability probing for the graphics session API
#
# Detects backend support, SIMD width, texture/buffer limits, and API availability.

use std.io

class GraphicsCapabilities:
    """Describes the hardware and API capabilities available to a session."""

    backend_kind: text
    arch_family: text
    bits: i64
    simd_kind: text
    vector_bits: i64
    has_compute: bool
    has_graphics: bool
    has_present: bool
    has_readback: bool
    max_texture_size: i64
    max_buffer_size: i64
    supports_vulkan: bool
    supports_metal: bool
    supports_webgpu: bool
    supports_cuda: bool

    # -------------------------------------------------------------------------
    # Constructors
    # -------------------------------------------------------------------------

    static fn probe(backend: text, arch: text, bits: i64) -> GraphicsCapabilities:
        var has_vulkan = false
        var has_metal = false
        var has_webgpu = false
        var has_cuda = false
        var has_compute = false
        var has_graphics = false

        if backend == "vulkan":
            has_vulkan = true
            has_compute = true
            has_graphics = true
        if backend == "metal":
            has_metal = true
            has_compute = true
            has_graphics = true
        if backend == "webgpu":
            has_webgpu = true
            has_compute = true
            has_graphics = true
        if backend == "cuda":
            has_cuda = true
            has_compute = true

        return GraphicsCapabilities(
            backend_kind: backend,
            arch_family: arch,
            bits: bits,
            simd_kind: "avx2",
            vector_bits: 256,
            has_compute: has_compute,
            has_graphics: has_graphics,
            has_present: has_graphics,
            has_readback: has_compute,
            max_texture_size: 16384,
            max_buffer_size: 2147483648,
            supports_vulkan: has_vulkan,
            supports_metal: has_metal,
            supports_webgpu: has_webgpu,
            supports_cuda: has_cuda
        )

    static fn cpu_only() -> GraphicsCapabilities:
        return GraphicsCapabilities(
            backend_kind: "cpu",
            arch_family: "x86_64",
            bits: 64,
            simd_kind: "sse2",
            vector_bits: 128,
            has_compute: true,
            has_graphics: false,
            has_present: false,
            has_readback: true,
            max_texture_size: 0,
            max_buffer_size: 1073741824,
            supports_vulkan: false,
            supports_metal: false,
            supports_webgpu: false,
            supports_cuda: false
        )

    # -------------------------------------------------------------------------
    # Queries
    # -------------------------------------------------------------------------

    me supports_backend(kind: text) -> bool:
        if kind == "vulkan":
            return self.supports_vulkan
        if kind == "metal":
            return self.supports_metal
        if kind == "webgpu":
            return self.supports_webgpu
        if kind == "cuda":
            return self.supports_cuda
        if kind == "cpu":
            return true
        return false

    me summary() -> text:
        var s = "backend=" + self.backend_kind
        s = s + " arch=" + self.arch_family
        s = s + " bits=" + self.bits.to_text()
        s = s + " simd=" + self.simd_kind
        if self.has_compute:
            s = s + " compute"
        if self.has_graphics:
            s = s + " graphics"
        if self.has_present:
            s = s + " present"
        return s
