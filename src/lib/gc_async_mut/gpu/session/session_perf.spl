"""session_perf — RenderBackendPerf read-only performance counter interface.

Read-only perf interface. Must not alter scheduling or caching (rule from plan).
All state is returned as new values (interpreter-safe, no mutating self methods).
"""

use std.io
use std.gpu.session.session_types.{BackendSessionHandle}

# ---------------------------------------------------------------------------
# PerfSample — a single named timing measurement
# ---------------------------------------------------------------------------

class PerfSample:
    """Named timing sample captured between begin_sample and end_sample."""

    label: text
    start_tick: i64
    end_tick: i64
    elapsed_ms: i64
    closed: bool

    static fn begin(label: text, tick: i64) -> PerfSample:
        return PerfSample(label: label, start_tick: tick, end_tick: 0, elapsed_ms: 0, closed: false)

    static fn end_sample(s: PerfSample, tick: i64) -> PerfSample:
        val elapsed = tick - s.start_tick
        return PerfSample(label: s.label, start_tick: s.start_tick, end_tick: tick, elapsed_ms: elapsed, closed: true)

    static fn is_closed(s: PerfSample) -> bool:
        return s.closed

# ---------------------------------------------------------------------------
# PerfCounterSet — accumulated counter values
# ---------------------------------------------------------------------------

class PerfCounterSet:
    """Accumulated performance counters for one session."""

    total_frames: i64
    total_draw_calls: i64
    total_gpu_ms: i64
    peak_gpu_ms: i64
    sample_count: i64
    cache_warmth: text

    static fn zero() -> PerfCounterSet:
        return PerfCounterSet(
            total_frames: 0,
            total_draw_calls: 0,
            total_gpu_ms: 0,
            peak_gpu_ms: 0,
            sample_count: 0,
            cache_warmth: "cold"
        )

    static fn add_frame(c: PerfCounterSet, gpu_ms: i64, draws: i64) -> PerfCounterSet:
        var peak = c.peak_gpu_ms
        if gpu_ms > peak:
            peak = gpu_ms
        var warmth = c.cache_warmth
        if c.total_frames > 0:
            warmth = "warm-managed"
        return PerfCounterSet(
            total_frames: c.total_frames + 1,
            total_draw_calls: c.total_draw_calls + draws,
            total_gpu_ms: c.total_gpu_ms + gpu_ms,
            peak_gpu_ms: peak,
            sample_count: c.sample_count,
            cache_warmth: warmth
        )

    static fn add_sample(c: PerfCounterSet) -> PerfCounterSet:
        return PerfCounterSet(
            total_frames: c.total_frames,
            total_draw_calls: c.total_draw_calls,
            total_gpu_ms: c.total_gpu_ms,
            peak_gpu_ms: c.peak_gpu_ms,
            sample_count: c.sample_count + 1,
            cache_warmth: c.cache_warmth
        )

# ---------------------------------------------------------------------------
# RenderBackendPerf — read-only perf interface bound to a session
# ---------------------------------------------------------------------------

class RenderBackendPerf:
    """Read-only performance counter interface for a graphics backend session.
    Must not alter scheduling or caching. All mutation returns new instances."""

    session_id: i64
    backend_mode_text: text
    counters: PerfCounterSet
    last_sample: PerfSample

    static fn create(h: BackendSessionHandle) -> RenderBackendPerf:
        val empty_sample = PerfSample(label: "", start_tick: 0, end_tick: 0, elapsed_ms: 0, closed: true)
        return RenderBackendPerf(
            session_id: h.id,
            backend_mode_text: h.mode,
            counters: PerfCounterSet.zero(),
            last_sample: empty_sample
        )

    static fn create_for_mode(session_id: i64, mode: text) -> RenderBackendPerf:
        val empty_sample = PerfSample(label: "", start_tick: 0, end_tick: 0, elapsed_ms: 0, closed: true)
        return RenderBackendPerf(
            session_id: session_id,
            backend_mode_text: mode,
            counters: PerfCounterSet.zero(),
            last_sample: empty_sample
        )

    # Read-only accessors (no mutation)

    static fn get_counters(p: RenderBackendPerf) -> PerfCounterSet:
        return p.counters

    static fn backend_mode(p: RenderBackendPerf) -> text:
        return p.backend_mode_text

    static fn get_session_id(p: RenderBackendPerf) -> i64:
        return p.session_id

    # Returns new RenderBackendPerf with updated counters (does not mutate)

    static fn begin_sample(p: RenderBackendPerf, label: text, tick: i64) -> RenderBackendPerf:
        val s = PerfSample.begin(label, tick)
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: PerfCounterSet.add_sample(p.counters),
            last_sample: s
        )

    static fn end_sample(p: RenderBackendPerf, tick: i64) -> RenderBackendPerf:
        val s = PerfSample.end_sample(p.last_sample, tick)
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: p.counters,
            last_sample: s
        )

    static fn record_frame(p: RenderBackendPerf, gpu_ms: i64, draws: i64) -> RenderBackendPerf:
        val updated = PerfCounterSet.add_frame(p.counters, gpu_ms, draws)
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: updated,
            last_sample: p.last_sample
        )

    static fn reset_counters(p: RenderBackendPerf) -> RenderBackendPerf:
        val empty_sample = PerfSample(label: "", start_tick: 0, end_tick: 0, elapsed_ms: 0, closed: true)
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: PerfCounterSet.zero(),
            last_sample: empty_sample
        )
