# @gc — module uses GC runtime
#
# svllm readiness/metrics surface — the missing observability primitive for the
# svllm serving engine.
#
# Bidirectional cross-reference:
#   - THIS module (`std.gc_async_mut.svllm.svllm_status`) defines the
#     SvllmStatus value type and its readiness/metrics surface.
#   - CONSUMER: `app.ide.agent_dashboard` imports this surface and adds an
#     "svllm-inference" lane and gate so the IDE can show whether the local
#     svllm engine is ready to serve before handing inference work to it.
#
# Neither side may change this contract without coordinating with the other:
#   - SvllmStatus struct fields and readiness semantics are load-bearing for
#     the dashboard rendering logic.
#   - The dashboard module path is embedded in `svllm_status_consumer_module()`
#     and must stay in sync with the actual dashboard location.
#
# Readiness invariant (enforced by this module):
#   readiness == "ready"   ⟺   all 5 component flags are true
#                          ⟺   reasons list is empty
#                          ⟺   svllm_status_is_servable(status) == true
#
# Design: doc/05_design/ml/svllm/svllm_master_plan.md (Phase A1 surface).

# Readiness snapshot for the svllm engine. Pure value type; safe to build from
# any tier and pass across module boundaries.
struct SvllmStatus:
    engine_id: text          # stable engine identity, "svllm"
    phase: text              # current implemented phase, e.g. "A1"
    served_model: text       # model name if one is loaded, "" otherwise
    pack_available: bool     # a tensor_pack is present and indexable
    loader_ready: bool       # model loader can stream weights
    nvfs_ready: bool         # nvfs client contract is wired
    kv_cache_ready: bool     # paged kv cache is allocated
    model_loaded: bool       # weights resident and servable
    readiness: text          # "ready" | "degraded" | "offline"
    reasons: [text]          # human-readable degradation/offline reasons
    consumer_module: text    # cross-ref: who consumes this surface

# Module the dashboard lives in; kept as a named constant so the cross-reference
# is greppable from both sides.
fn svllm_status_consumer_module() -> text:
    "app.ide.agent_dashboard"

# Derive readiness + reasons from the component flags.
fn svllm_status_reasons(pack_available: bool, loader_ready: bool, nvfs_ready: bool, kv_cache_ready: bool, model_loaded: bool) -> [text]:
    var reasons: [text] = []
    if not pack_available:
        reasons.push("tensor-pack-unavailable")
    if not loader_ready:
        reasons.push("model-loader-not-ready")
    if not nvfs_ready:
        reasons.push("nvfs-client-not-wired")
    if not kv_cache_ready:
        reasons.push("kv-cache-not-allocated")
    if not model_loaded:
        reasons.push("model-not-loaded")
    reasons

fn svllm_status_readiness(pack_available: bool, loader_ready: bool, nvfs_ready: bool, kv_cache_ready: bool, model_loaded: bool) -> text:
    if (pack_available and loader_ready and nvfs_ready and kv_cache_ready and model_loaded):
        return "ready"
    if (pack_available or loader_ready or nvfs_ready or kv_cache_ready or model_loaded):
        return "degraded"
    "offline"

fn svllm_status_from(pack_available: bool, loader_ready: bool, nvfs_ready: bool, kv_cache_ready: bool, model_loaded: bool, served_model: text) -> SvllmStatus:
    val readiness = svllm_status_readiness(pack_available, loader_ready, nvfs_ready, kv_cache_ready, model_loaded)
    val reasons = svllm_status_reasons(pack_available, loader_ready, nvfs_ready, kv_cache_ready, model_loaded)
    SvllmStatus(
        engine_id: "svllm",
        phase: "A1",
        served_model: served_model,
        pack_available: pack_available,
        loader_ready: loader_ready,
        nvfs_ready: nvfs_ready,
        kv_cache_ready: kv_cache_ready,
        model_loaded: model_loaded,
        readiness: readiness,
        reasons: reasons,
        consumer_module: svllm_status_consumer_module()
    )

# Default A1 status: contract wired but nothing loaded yet (offline).
fn svllm_status_default() -> SvllmStatus:
    svllm_status_from(false, false, false, false, false, "")

fn svllm_status_summary(status: SvllmStatus) -> text:
    "svllm: phase={status.phase} model={status.served_model} pack={status.pack_available} loader={status.loader_ready} nvfs={status.nvfs_ready} kv={status.kv_cache_ready} loaded={status.model_loaded} readiness={status.readiness}"

# True iff this status snapshot indicates the engine is fully ready to serve
# inference requests (all 5 component flags true, readiness=="ready", no
# degradation reasons). This is equivalent to `status.readiness == "ready"`.
fn svllm_status_is_servable(status: SvllmStatus) -> bool:
    status.readiness == "ready"
