# @gc — module uses GC runtime
#
# svllm — vLLM-like LLM serving engine for Simple.
#
# Design: doc/05_design/svllm/svllm_master_plan.md
# Filesystem contract: doc/05_design/nvfs/svllm_requirements.md
#
# Module layout mirrors vLLM's package hierarchy (engine, executor, worker,
# core, model_executor, attention, sequence, lora, entrypoints) unless doing
# so breaks MDSOC+.
#
# Phase A1 surface (first slice): model_executor/model_loader + nvfs_client
# contract. Later phases add the rest.

# A1 re-exports (model loader)
export TensorPack, TensorInfo, ChunkInfo, Dtype
export TensorPackManifest, ManifestError
export SafetensorsHeader, SafetensorsError
export LoaderError, LoadResult

# nvfs client contract (shim against the parallel nvfs design)
export NvfsClient, ObjHandle, BufHandle, ObjClass, OpenMode, NvfsError
