# @gc — module uses GC runtime
#
# Tensor-pack manifest — parses the SDN-formatted manifest.sdn at the
# pack root and produces a TensorPack in-memory descriptor.
#
# The manifest schema (v0):
#   model_id: text
#   revision: text
#   preferred_chunk_bytes: i64
#   chunks: [ { id: i32, relative_path: text, byte_len: i64, digest_hex: text } ]
#   tensors: [ { name: text, shape: [i64], dtype: text,
#                chunk_id: i32, offset_in_chunk: i64, byte_len: i64 } ]
#
# SDN is the project's canonical data format (see .claude/rules/language.md).

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack, TensorInfo, ChunkInfo}
use std.gc_async_mut.svllm.model_executor.model_loader.weight_utils.{Dtype}

enum ManifestError:
    NotFound
    Malformed
    UnsupportedVersion
    ChecksumMismatch
    TensorChunkMismatch

# Parsed manifest representation. parse_manifest(sdn_text) produces one
# of these or returns a ManifestError. Includes the full tensor and chunk
# lists after Phase A3 parsing.
struct TensorPackManifest:
    schema_version: i32
    model_id: text
    revision: text
    preferred_chunk_bytes: i64
    tensor_count: i64
    chunk_count: i64
    tensors: [TensorInfo]
    chunks: [ChunkInfo]

    static fn empty() -> TensorPackManifest:
        TensorPackManifest(
            schema_version: 0,
            model_id: "",
            revision: "",
            preferred_chunk_bytes: 0,
            tensor_count: 0,
            chunk_count: 0,
            tensors: [],
            chunks: []
        )

    fn is_empty(self) -> bool:
        self.model_id == "" and self.chunk_count == 0

# Returns true if needle appears in t starting at position pos.
# Uses char_at exclusively — no substring/index_of semantics to guess.
fn _match_at(t: text, needle: text, pos: i64) -> bool:
    val tlen = t.len()
    val nlen = needle.len()
    if pos + nlen > tlen:
        return false
    var k = 0
    while k < nlen:
        if t.char_at(pos + k) != needle.char_at(k):
            return false
        k = k + 1
    true

# Returns the position of the first occurrence of needle in t at or after
# from_pos, or -1 if not found.
fn _find_in(t: text, needle: text, from_pos: i64) -> i64:
    val tlen = t.len()
    val nlen = needle.len()
    var i = from_pos
    while i + nlen <= tlen:
        if _match_at(t, needle, i):
            return i
        i = i + 1
    -1

# Counts non-overlapping occurrences of needle in t.
fn _count_occurrences(t: text, needle: text) -> i64:
    val nlen = needle.len()
    if nlen == 0:
        return 0
    var count: i64 = 0
    var pos: i64 = 0
    var found = _find_in(t, needle, pos)
    while found >= 0:
        count = count + 1
        pos = found + nlen
        found = _find_in(t, needle, pos)
    count

# Returns the integer value that follows key in t, or -1 if key is absent
# or no digit immediately follows the key. Parses until a non-digit is seen.
fn _find_int_after(t: text, key: text) -> i64:
    val kpos = _find_in(t, key, 0)
    if kpos < 0:
        return -1
    var i = kpos + key.len()
    val tlen = t.len()
    # skip any optional whitespace after the key (up to 4 chars for safety)
    var spaces = 0
    while i < tlen and spaces < 4:
        val ch = t.char_at(i)
        if ch == " " or ch == "\t":
            i = i + 1
            spaces = spaces + 1
        else:
            spaces = 99
    # must have a digit next
    if i >= tlen:
        return -1
    val first = t.char_at(i)
    val digits = "0123456789"
    var dpos = _find_in(digits, first, 0)
    if dpos < 0:
        return -1
    var result: i64 = dpos
    i = i + 1
    var running = true
    while running and i < tlen:
        val ch2 = t.char_at(i)
        var dp2 = _find_in(digits, ch2, 0)
        if dp2 >= 0:
            result = result * 10 + dp2
            i = i + 1
        else:
            running = false
    result

# Like _find_int_after but starts searching from from_pos instead of 0.
# Returns the integer value that follows key in t at or after from_pos,
# or -1 if key is absent or no digit immediately follows.
fn _find_int_from(t: text, key: text, from_pos: i64) -> i64:
    val kpos = _find_in(t, key, from_pos)
    if kpos < 0:
        return -1
    var i = kpos + key.len()
    val tlen = t.len()
    var spaces = 0
    while i < tlen and spaces < 4:
        val ch = t.char_at(i)
        if ch == " " or ch == "\t":
            i = i + 1
            spaces = spaces + 1
        else:
            spaces = 99
    if i >= tlen:
        return -1
    val first = t.char_at(i)
    val digits = "0123456789"
    var dpos = _find_in(digits, first, 0)
    if dpos < 0:
        return -1
    var result: i64 = dpos
    i = i + 1
    var running = true
    while running and i < tlen:
        val ch2 = t.char_at(i)
        var dp2 = _find_in(digits, ch2, 0)
        if dp2 >= 0:
            result = result * 10 + dp2
            i = i + 1
        else:
            running = false
    result

# Returns the quoted-string value that follows key (which must end with `":"`
# or similar so that the next char is `"`). Returns "" if key not found or
# no opening quote is found immediately after key.
fn _find_str_after(t: text, key: text) -> text:
    val kpos = _find_in(t, key, 0)
    if kpos < 0:
        return ""
    # key already includes the opening quote; collect until closing quote
    var i = kpos + key.len()
    val tlen = t.len()
    var out = ""
    var running = true
    while running and i < tlen:
        val ch = t.char_at(i)
        if ch == "\"":
            running = false
        else:
            if ch == "\\":
                # minimal unescape: skip the backslash, take next char
                i = i + 1
                if i < tlen:
                    out = out + t.char_at(i)
            else:
                out = out + ch
        i = i + 1
    out

# Like _find_str_after but starts searching from from_pos.
# The key must end with the opening quote of the value.
fn _find_str_from(t: text, key: text, from_pos: i64) -> text:
    val kpos = _find_in(t, key, from_pos)
    if kpos < 0:
        return ""
    var i = kpos + key.len()
    val tlen = t.len()
    var out = ""
    var running = true
    while running and i < tlen:
        val ch = t.char_at(i)
        if ch == "\"":
            running = false
        else:
            if ch == "\\":
                i = i + 1
                if i < tlen:
                    out = out + t.char_at(i)
            else:
                out = out + ch
        i = i + 1
    out

# Parse the position just past the end of the quoted string starting at from_pos.
# The key must end with the opening quote. Returns the position after the
# closing quote, or from_pos if the key is not found.
fn _end_pos_after_str(t: text, key: text, from_pos: i64) -> i64:
    val kpos = _find_in(t, key, from_pos)
    if kpos < 0:
        return from_pos
    var i = kpos + key.len()
    val tlen = t.len()
    var running = true
    while running and i < tlen:
        val ch = t.char_at(i)
        if ch == "\"":
            running = false
        else:
            if ch == "\\":
                i = i + 1
        i = i + 1
    i

# Parse a shape array `[a,b,c,...]` starting search from from_pos.
# Finds `"shape":[` then reads comma-separated integers until `]`.
# Returns a 2-element struct carrying the shape list and the position
# after the closing `]`. Returns empty list if not found.
struct _ShapeResult:
    shape: [i64]
    next_pos: i64

fn _parse_shape_from(t: text, from_pos: i64) -> _ShapeResult:
    val key = "\"shape\":["
    val kpos = _find_in(t, key, from_pos)
    if kpos < 0:
        return _ShapeResult(shape: [], next_pos: from_pos)
    var i = kpos + key.len()
    val tlen = t.len()
    var shape: [i64] = []
    val digits = "0123456789"
    # read integers until we hit `]`
    var done = false
    while not done and i < tlen:
        val ch = t.char_at(i)
        if ch == "]":
            i = i + 1
            done = true
        else:
            # skip commas and whitespace
            val dpos = _find_in(digits, ch, 0)
            if dpos >= 0:
                # parse the integer
                var num: i64 = dpos
                i = i + 1
                var reading = true
                while reading and i < tlen:
                    val c2 = t.char_at(i)
                    val dp2 = _find_in(digits, c2, 0)
                    if dp2 >= 0:
                        num = num * 10 + dp2
                        i = i + 1
                    else:
                        reading = false
                shape.push(num)
            else:
                i = i + 1
    _ShapeResult(shape: shape, next_pos: i)

# Map a dtype label text to Dtype enum. Unknown labels default to F32.
fn _dtype_from_label(s: text) -> Dtype:
    if s == "F32":
        return Dtype.F32
    if s == "F16":
        return Dtype.F16
    if s == "BF16":
        return Dtype.Bf16
    if s == "F64":
        return Dtype.F64
    if s == "I8":
        return Dtype.I8
    if s == "I16":
        return Dtype.I16
    if s == "I32":
        return Dtype.I32
    if s == "I64":
        return Dtype.I64
    if s == "U8":
        return Dtype.U8
    if s == "BOOL":
        return Dtype.Bool
    Dtype.F32

# Real parser: extracts scalar fields from the JSON-ish v0 manifest text.
# Uses key-search helpers (char_at/len only) so it is robust to ASCII-clean
# v0 content. Returns Err(Malformed) for missing/garbage input,
# Err(UnsupportedVersion) when schema_version != 0, Ok otherwise.
fn parse_manifest(sdn_text: text) -> Result<TensorPackManifest, ManifestError>:
    # Empty / whitespace input
    if sdn_text.len() == 0:
        return Err(ManifestError.Malformed)
    # Error ordering: missing required keys → Malformed takes precedence over
    # UnsupportedVersion. schema_version and model_id are checked first so
    # that a totally garbage input returns Malformed, not UnsupportedVersion.
    # Note: negative schema_version → Malformed because _find_int_after returns
    # -1 when no digit is found (no sign handling), triggering the sv < 0 guard.
    #
    # schema_version key must be present
    val sv_key_pos = _find_in(sdn_text, "\"schema_version\":", 0)
    if sv_key_pos < 0:
        return Err(ManifestError.Malformed)
    # model_id key must be present
    val mid_key_pos = _find_in(sdn_text, "\"model_id\":\"", 0)
    if mid_key_pos < 0:
        return Err(ManifestError.Malformed)
    # Parse schema_version integer
    val sv = _find_int_after(sdn_text, "\"schema_version\":")
    if sv < 0:
        return Err(ManifestError.Malformed)
    if sv != 0:
        return Err(ManifestError.UnsupportedVersion)
    # Structural integrity: after confirming version, require the essential
    # array markers and enclosing braces. This rejects truncated or
    # garbage-tail manifests that would otherwise slip through key-scan only.
    val trimmed = sdn_text.trim()
    if trimmed.len() == 0:
        return Err(ManifestError.Malformed)
    if trimmed.char_at(0) != "{":
        return Err(ManifestError.Malformed)
    if trimmed.char_at(trimmed.len() - 1) != "}":
        return Err(ManifestError.Malformed)
    if _find_in(sdn_text, "\"chunks\":[", 0) < 0:
        return Err(ManifestError.Malformed)
    if _find_in(sdn_text, "\"tensors\":[", 0) < 0:
        return Err(ManifestError.Malformed)
    if _find_in(sdn_text, "\"preferred_chunk_bytes\":", 0) < 0:
        return Err(ManifestError.Malformed)
    # Parse remaining scalar fields
    val mid = _find_str_after(sdn_text, "\"model_id\":\"")
    val rev = _find_str_after(sdn_text, "\"revision\":\"")
    val pcb = _find_int_after(sdn_text, "\"preferred_chunk_bytes\":")
    val preferred: i64
    if pcb < 0:
        preferred = 0
    else:
        preferred = pcb
    # Count arrays by unique-per-type keys
    val tc = _count_occurrences(sdn_text, "\"offset_in_chunk\":")
    val cc = _count_occurrences(sdn_text, "\"digest_hex\":")

    # --- Parse chunks array ---
    # Chunk objects contain no shape arrays (no nested `[`), so the FIRST `]`
    # after the `"chunks":[` position closes the chunks array.
    # ASSUMPTION: `relative_path` is a generator-controlled filename (e.g. `data-NNN.bin`)
    # that never contains `[` or `]`. The `_esc` serializer escapes only `"` and `\`,
    # NOT brackets, so an externally-authored manifest with a bracket-bearing
    # relative_path would misplace the array-end marker. Callers supplying hand-built
    # manifests must ensure relative_path values are bracket-free.
    var chunks: [ChunkInfo] = []
    val chunks_start_pos = _find_in(sdn_text, "\"chunks\":[", 0)
    val chunks_arr_pos = chunks_start_pos + 9  # position of `[`
    # Find the end of chunks array: first `]` at or after chunks_arr_pos
    val chunks_end_pos = _find_in(sdn_text, "]", chunks_arr_pos)
    if cc > 0 and chunks_end_pos >= 0:
        # Parse each chunk object by searching for successive "id": anchors
        # Use "\"id\":" as the chunk-start anchor (does not appear in tensors as bare "id":)
        var chunk_cursor = chunks_arr_pos
        var chunk_idx: i64 = 0
        while chunk_idx < cc:
            val id_pos = _find_in(sdn_text, "\"id\":", chunk_cursor)
            if id_pos < 0 or id_pos > chunks_end_pos:
                return Err(ManifestError.Malformed)
            val cid = _find_int_from(sdn_text, "\"id\":", chunk_cursor)
            val cpath = _find_str_from(sdn_text, "\"relative_path\":\"", chunk_cursor)
            val cbl = _find_int_from(sdn_text, "\"byte_len\":", chunk_cursor)
            val cdh = _find_str_from(sdn_text, "\"digest_hex\":\"", chunk_cursor)
            if cbl < 0:
                return Err(ManifestError.Malformed)
            chunks.push(ChunkInfo(
                id: cid as i32,
                relative_path: cpath,
                byte_len: cbl,
                digest_hex: cdh
            ))
            # Advance cursor past the digest_hex field of this object
            chunk_cursor = _end_pos_after_str(sdn_text, "\"digest_hex\":\"", chunk_cursor)
            chunk_idx = chunk_idx + 1

    # --- Parse tensors array ---
    # Tensor objects contain "shape":[...] so we cannot find array end by first `]`.
    # Instead parse exactly tc objects walking a cursor.
    var tensors: [TensorInfo] = []
    val tensors_start_pos = _find_in(sdn_text, "\"tensors\":[", 0)
    val tensors_arr_pos = tensors_start_pos + 10  # position of `[`
    if tc > 0:
        var tensor_cursor = tensors_arr_pos
        var tensor_idx: i64 = 0
        while tensor_idx < tc:
            # Anchor: find the next tensor's "name":"
            val name_key_pos = _find_in(sdn_text, "\"name\":\"", tensor_cursor)
            if name_key_pos < 0:
                return Err(ManifestError.Malformed)
            val tname = _find_str_from(sdn_text, "\"name\":\"", tensor_cursor)
            val tdtype_str = _find_str_from(sdn_text, "\"dtype\":\"", name_key_pos)
            val tdtype = _dtype_from_label(tdtype_str)
            val shape_result = _parse_shape_from(sdn_text, name_key_pos)
            val tchunk_id = _find_int_from(sdn_text, "\"chunk_id\":", name_key_pos)
            val toffset = _find_int_from(sdn_text, "\"offset_in_chunk\":", name_key_pos)
            val tbl = _find_int_from(sdn_text, "\"byte_len\":", name_key_pos)
            if toffset < 0 or tbl < 0 or tchunk_id < 0:
                return Err(ManifestError.Malformed)
            tensors.push(TensorInfo(
                name: tname,
                shape: shape_result.shape,
                dtype: tdtype,
                chunk_id: tchunk_id as i32,
                offset_in_chunk: toffset,
                byte_len: tbl
            ))
            # Advance cursor past this tensor's "byte_len": field so the next
            # iteration anchors on the NEXT tensor's "name":"
            val bl_key_pos = _find_in(sdn_text, "\"byte_len\":", name_key_pos)
            if bl_key_pos < 0:
                return Err(ManifestError.Malformed)
            # skip past the digits of byte_len value
            var cur = bl_key_pos + 11  # len("\"byte_len\":") == 11
            val tlen_s = sdn_text.len()
            val digits = "0123456789"
            var skipping = true
            while skipping and cur < tlen_s:
                val dc = _find_in(digits, sdn_text.char_at(cur), 0)
                if dc >= 0:
                    cur = cur + 1
                else:
                    skipping = false
            tensor_cursor = cur
            tensor_idx = tensor_idx + 1
        if tensors.len() < tc:
            return Err(ManifestError.Malformed)

    Ok(TensorPackManifest(
        schema_version: 0,
        model_id: mid,
        revision: rev,
        preferred_chunk_bytes: preferred,
        tensor_count: tensors.len(),
        chunk_count: chunks.len(),
        tensors: tensors,
        chunks: chunks
    ))

# Materializer: given a parsed manifest, build the full TensorPack descriptor.
# Validates that every tensor references a valid chunk and that its byte range
# fits within that chunk. Returns Err(TensorChunkMismatch) on any violation.
fn build_tensor_pack(pack_root: text, m: TensorPackManifest) -> Result<TensorPack, ManifestError>:
    # Empty manifest → Ok empty pack
    if m.tensors.len() == 0 and m.chunks.len() == 0:
        var pack = TensorPack.empty(pack_root)
        pack.model_id = m.model_id
        pack.revision = m.revision
        pack.preferred_chunk_bytes = m.preferred_chunk_bytes
        return Ok(pack)
    # Tensors with no chunks to hold them
    if m.chunks.len() == 0 and m.tensors.len() > 0:
        return Err(ManifestError.TensorChunkMismatch)
    # Validate each tensor
    var ti: i64 = 0
    while ti < m.tensors.len():
        val t = m.tensors[ti]
        val cid = t.chunk_id as i64
        # Reject obviously-invalid chunk ids; the id-value lookup below handles "not found".
        if cid < 0:
            return Err(ManifestError.TensorChunkMismatch)
        # Find the chunk with matching id (by VALUE, not index — supports non-contiguous ids).
        var found_chunk = false
        var chunk_byte_len: i64 = 0
        var ci: i64 = 0
        while ci < m.chunks.len():
            val c = m.chunks[ci]
            if (c.id as i64) == cid:
                found_chunk = true
                chunk_byte_len = c.byte_len
            ci = ci + 1
        if not found_chunk:
            return Err(ManifestError.TensorChunkMismatch)
        # Guard negative chunk byte_len (corrupt manifest).
        if chunk_byte_len < 0:
            return Err(ManifestError.TensorChunkMismatch)
        if t.offset_in_chunk < 0:
            return Err(ManifestError.TensorChunkMismatch)
        # Guard negative tensor byte_len — a negative value passes the range
        # check (offset + negative <= chunk_byte_len) without this guard.
        if t.byte_len < 0:
            return Err(ManifestError.TensorChunkMismatch)
        if (t.offset_in_chunk + t.byte_len) > chunk_byte_len:
            return Err(ManifestError.TensorChunkMismatch)
        ti = ti + 1
    var pack = TensorPack.empty(pack_root)
    pack.model_id = m.model_id
    pack.revision = m.revision
    pack.preferred_chunk_bytes = m.preferred_chunk_bytes
    pack.tensors = m.tensors
    pack.chunks = m.chunks
    Ok(pack)

# Map a Dtype enum back to its safetensors-style text label.
fn _dtype_label(dt: Dtype) -> text:
    match dt:
        Dtype.F32 => "F32"
        Dtype.F16 => "F16"
        Dtype.Bf16 => "BF16"
        Dtype.F64 => "F64"
        Dtype.I8 => "I8"
        Dtype.I16 => "I16"
        Dtype.I32 => "I32"
        Dtype.I64 => "I64"
        Dtype.U8 => "U8"
        Dtype.Bool => "BOOL"

# Minimal JSON-string escape: `"` and `\` only. Manifest values do not
# contain control chars for v0. Uses char_at (Rust-seed compatible) rather
# than byte_at; input is restricted to ASCII-clean identifiers + hex digests.
fn _esc(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            out = out + "\\\""
        else:
            if ch == "\\":
                out = out + "\\\\"
            else:
                out = out + ch
        i = i + 1
    out

# Serialize an [i64] shape array as `[a,b,c]`.
fn _shape_json(shape: [i64]) -> text:
    var out = "["
    var i = 0
    while i < shape.len():
        if i > 0:
            out = out + ","
        out = out + shape[i].to_text()
        i = i + 1
    out + "]"

# Serialize a TensorPack into the canonical v0 manifest format. Output is a
# deterministic JSON-ish single-line text (schema per arch.md §4). Keys are
# emitted in a fixed order; integers decimal; no whitespace padding.
fn serialize_manifest(pack: TensorPack) -> text:
    var out = "{"
    out = out + "\"schema_version\":0"
    out = out + ",\"model_id\":\"" + _esc(pack.model_id) + "\""
    out = out + ",\"revision\":\"" + _esc(pack.revision) + "\""
    out = out + ",\"preferred_chunk_bytes\":" + pack.preferred_chunk_bytes.to_text()
    out = out + ",\"digest_algo\":\"sha256\""
    out = out + ",\"chunks\":["
    var i = 0
    while i < pack.chunks.len():
        val c = pack.chunks[i]
        if i > 0:
            out = out + ","
        out = out + "{\"id\":" + (c.id as i64).to_text()
        out = out + ",\"relative_path\":\"" + _esc(c.relative_path) + "\""
        out = out + ",\"byte_len\":" + c.byte_len.to_text()
        out = out + ",\"digest_hex\":\"" + _esc(c.digest_hex) + "\"}"
        i = i + 1
    out = out + "]"
    out = out + ",\"tensors\":["
    var j = 0
    while j < pack.tensors.len():
        val t = pack.tensors[j]
        if j > 0:
            out = out + ","
        out = out + "{\"name\":\"" + _esc(t.name) + "\""
        out = out + ",\"dtype\":\"" + _dtype_label(t.dtype) + "\""
        out = out + ",\"shape\":" + _shape_json(t.shape)
        out = out + ",\"chunk_id\":" + (t.chunk_id as i64).to_text()
        out = out + ",\"offset_in_chunk\":" + t.offset_in_chunk.to_text()
        out = out + ",\"byte_len\":" + t.byte_len.to_text() + "}"
        j = j + 1
    out = out + "]"
    out + "}"
