# @gc — module uses GC runtime
#
# Tensor-pack manifest — parses the SDN-formatted manifest.sdn at the
# pack root and produces a TensorPack in-memory descriptor.
#
# The manifest schema (v0):
#   model_id: text
#   revision: text
#   preferred_chunk_bytes: i64
#   chunks: [ { id: i32, relative_path: text, byte_len: i64, digest_hex: text } ]
#   tensors: [ { name: text, shape: [i64], dtype: text,
#                chunk_id: i32, offset_in_chunk: i64, byte_len: i64 } ]
#
# SDN is the project's canonical data format (see .claude/rules/language.md).

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack, TensorInfo, ChunkInfo}
use std.gc_async_mut.svllm.model_executor.model_loader.weight_utils.{Dtype}

enum ManifestError:
    NotFound
    Malformed
    UnsupportedVersion
    ChecksumMismatch
    TensorChunkMismatch

# Parsed manifest representation. parse_manifest(sdn_text) produces one
# of these or returns a ManifestError. This first parser accepts the canonical
# v0 single-line manifest emitted by serialize_manifest.
struct TensorPackManifest:
    schema_version: i32
    model_id: text
    revision: text
    preferred_chunk_bytes: i64
    tensor_count: i64
    chunk_count: i64
    tensors: [TensorInfo]
    chunks: [ChunkInfo]

    static fn empty() -> TensorPackManifest:
        TensorPackManifest(
            schema_version: 0,
            model_id: "",
            revision: "",
            preferred_chunk_bytes: 0,
            tensor_count: 0,
            chunk_count: 0,
            tensors: [],
            chunks: []
        )

    fn is_empty(self) -> bool:
        self.model_id == "" and self.chunk_count == 0

fn _field_text(source: text, key: text) -> text:
    val marker = "\"" + key + "\":\""
    val start = source.find(marker)
    if start < 0:
        return ""
    val value_start = start + marker.len()
    val rest = source.slice(value_start, source.len())
    val end = rest.find("\"")
    if end < 0:
        return ""
    rest.slice(0, end)

fn _field_i64(source: text, key: text, missing: i64) -> i64:
    val marker = "\"" + key + "\":"
    val start = source.find(marker)
    if start < 0:
        return missing
    var i = start + marker.len()
    var out: i64 = 0
    var seen = false
    while i < source.len():
        val ch = source.char_at(i)
        if ch >= "0" and ch <= "9":
            out = (out * 10) + (ch.ord() - "0".ord())
            seen = true
        else:
            if seen:
                return out
            if ch != " ":
                return missing
        i = i + 1
    if seen:
        return out
    missing

fn _array_item_count(source: text, key: text) -> i64:
    val marker = "\"" + key + "\":["
    val start = source.find(marker)
    if start < 0:
        return -1
    var i = start + marker.len()
    var count: i64 = 0
    var depth: i64 = 0
    while i < source.len():
        val ch = source.char_at(i)
        if ch == "{":
            if depth == 0:
                count = count + 1
            depth = depth + 1
        else:
            if ch == "}":
                if depth > 0:
                    depth = depth - 1
            else:
                if ch == "]" and depth == 0:
                    return count
        i = i + 1
    -1

fn _array_body(source: text, key: text) -> text:
    val marker = "\"" + key + "\":["
    val start = source.find(marker)
    if start < 0:
        return ""
    val body_start = start + marker.len()
    var i = body_start
    var nested_arrays: i64 = 0
    while i < source.len():
        val ch = source.char_at(i)
        if ch == "[":
            nested_arrays = nested_arrays + 1
        else:
            if ch == "]":
                if nested_arrays == 0:
                    return source.slice(body_start, i)
                nested_arrays = nested_arrays - 1
        i = i + 1
    ""

fn _object_blocks(body: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < body.len():
        if body.char_at(i) == "{":
            val start = i
            var depth: i64 = 1
            i = i + 1
            while i < body.len() and depth > 0:
                val ch = body.char_at(i)
                if ch == "{":
                    depth = depth + 1
                else:
                    if ch == "}":
                        depth = depth - 1
                i = i + 1
            if depth == 0:
                out.push(body.slice(start, i))
        else:
            i = i + 1
    out

fn _parse_dtype_label(label: text) -> Result<Dtype, ManifestError>:
    if label == "F32":
        return Ok(Dtype.F32)
    if label == "F16":
        return Ok(Dtype.F16)
    if label == "BF16":
        return Ok(Dtype.Bf16)
    if label == "F64":
        return Ok(Dtype.F64)
    if label == "I8":
        return Ok(Dtype.I8)
    if label == "I16":
        return Ok(Dtype.I16)
    if label == "I32":
        return Ok(Dtype.I32)
    if label == "I64":
        return Ok(Dtype.I64)
    if label == "U8":
        return Ok(Dtype.U8)
    if label == "BOOL":
        return Ok(Dtype.Bool)
    Err(ManifestError.Malformed)

fn _is_lower_hex_char(ch: text) -> bool:
    (ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "f")

fn _valid_digest_hex(digest: text, byte_len: i64) -> bool:
    if byte_len == 0 and digest == "":
        return true
    if digest.len() != 64:
        return false
    var i = 0
    while i < digest.len():
        if not _is_lower_hex_char(digest.char_at(i)):
            return false
        i = i + 1
    true

fn _shape_field(source: text) -> [i64]:
    val marker = "\"shape\":["
    val start = source.find(marker)
    if start < 0:
        return []
    var i = start + marker.len()
    var out: [i64] = []
    var value: i64 = 0
    var seen = false
    while i < source.len():
        val ch = source.char_at(i)
        if ch >= "0" and ch <= "9":
            value = (value * 10) + (ch.ord() - "0".ord())
            seen = true
        else:
            if seen:
                out.push(value)
                value = 0
                seen = false
            if ch == "]":
                return out
        i = i + 1
    out

fn _parse_chunks(source: text, expected_count: i64) -> Result<[ChunkInfo], ManifestError>:
    val blocks = _object_blocks(_array_body(source, "chunks"))
    if blocks.len() != expected_count:
        return Err(ManifestError.Malformed)
    var out: [ChunkInfo] = []
    var i = 0
    while i < blocks.len():
        val block = blocks[i]
        val id = _field_i64(block, "id", -1)
        val relative_path = _field_text(block, "relative_path")
        val byte_len = _field_i64(block, "byte_len", -1)
        val digest_hex = _field_text(block, "digest_hex")
        if id < 0 or relative_path == "" or byte_len < 0:
            return Err(ManifestError.Malformed)
        if not _valid_digest_hex(digest_hex, byte_len):
            return Err(ManifestError.ChecksumMismatch)
        out.push(ChunkInfo(
            id: id as i32,
            relative_path: relative_path,
            byte_len: byte_len,
            digest_hex: digest_hex
        ))
        i = i + 1
    Ok(out)

fn _parse_tensors(source: text, expected_count: i64) -> Result<[TensorInfo], ManifestError>:
    val blocks = _object_blocks(_array_body(source, "tensors"))
    if blocks.len() != expected_count:
        return Err(ManifestError.Malformed)
    var out: [TensorInfo] = []
    var i = 0
    while i < blocks.len():
        val block = blocks[i]
        val name = _field_text(block, "name")
        val dtype_label = _field_text(block, "dtype")
        val dtype = _parse_dtype_label(dtype_label)?
        val shape = _shape_field(block)
        val chunk_id = _field_i64(block, "chunk_id", -1)
        val offset = _field_i64(block, "offset_in_chunk", -1)
        val byte_len = _field_i64(block, "byte_len", -1)
        if name == "" or chunk_id < 0 or offset < 0 or byte_len < 0:
            return Err(ManifestError.Malformed)
        out.push(TensorInfo(
            name: name,
            shape: shape,
            dtype: dtype,
            chunk_id: chunk_id as i32,
            offset_in_chunk: offset,
            byte_len: byte_len
        ))
        i = i + 1
    Ok(out)

fn _chunk_exists(chunks: [ChunkInfo], id: i32) -> bool:
    var i = 0
    while i < chunks.len():
        if chunks[i].id == id:
            return true
        i = i + 1
    false

fn _validate_tensor_chunks(tensors: [TensorInfo], chunks: [ChunkInfo]) -> bool:
    var i = 0
    while i < tensors.len():
        if not _chunk_exists(chunks, tensors[i].chunk_id):
            return false
        i = i + 1
    true

fn parse_manifest(sdn_text: text) -> Result<TensorPackManifest, ManifestError>:
    val trimmed = sdn_text.trim()
    if not trimmed.starts_with("{"):
        return Err(ManifestError.Malformed)
    val version = _field_i64(trimmed, "schema_version", -1)
    if version < 0:
        return Err(ManifestError.Malformed)
    if version != 0:
        return Err(ManifestError.UnsupportedVersion)
    val model_id = _field_text(trimmed, "model_id")
    val revision = _field_text(trimmed, "revision")
    val preferred = _field_i64(trimmed, "preferred_chunk_bytes", -1)
    val chunk_count = _array_item_count(trimmed, "chunks")
    val tensor_count = _array_item_count(trimmed, "tensors")
    if model_id == "" or preferred < 0 or chunk_count < 0 or tensor_count < 0:
        return Err(ManifestError.Malformed)
    val chunks = _parse_chunks(trimmed, chunk_count)?
    val tensors = _parse_tensors(trimmed, tensor_count)?
    if not _validate_tensor_chunks(tensors, chunks):
        return Err(ManifestError.TensorChunkMismatch)
    Ok(TensorPackManifest(
        schema_version: version as i32,
        model_id: model_id,
        revision: revision,
        preferred_chunk_bytes: preferred,
        tensor_count: tensor_count,
        chunk_count: chunk_count,
        tensors: tensors,
        chunks: chunks
    ))

# Materializer for parsed canonical v0 manifest details.
fn build_tensor_pack(pack_root: text, m: TensorPackManifest) -> Result<TensorPack, ManifestError>:
    if m.tensor_count != m.tensors.len() or m.chunk_count != m.chunks.len():
        return Err(ManifestError.Malformed)
    if not _validate_tensor_chunks(m.tensors, m.chunks):
        return Err(ManifestError.TensorChunkMismatch)
    Ok(TensorPack(
        pack_root: pack_root,
        model_id: m.model_id,
        revision: m.revision,
        tensors: m.tensors,
        chunks: m.chunks,
        preferred_chunk_bytes: m.preferred_chunk_bytes
    ))

# Map a Dtype enum back to its safetensors-style text label.
fn _dtype_label(dt: Dtype) -> text:
    match dt:
        Dtype.F32 => "F32"
        Dtype.F16 => "F16"
        Dtype.Bf16 => "BF16"
        Dtype.F64 => "F64"
        Dtype.I8 => "I8"
        Dtype.I16 => "I16"
        Dtype.I32 => "I32"
        Dtype.I64 => "I64"
        Dtype.U8 => "U8"
        Dtype.Bool => "BOOL"

# Minimal JSON-string escape: `"` and `\` only. Manifest values do not
# contain control chars for v0. Uses char_at (Rust-seed compatible) rather
# than byte_at; input is restricted to ASCII-clean identifiers + hex digests.
fn _esc(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            out = out + "\\\""
        else:
            if ch == "\\":
                out = out + "\\\\"
            else:
                out = out + ch
        i = i + 1
    out

# Serialize an [i64] shape array as `[a,b,c]`.
fn _shape_json(shape: [i64]) -> text:
    var out = "["
    var i = 0
    while i < shape.len():
        if i > 0:
            out = out + ","
        out = out + shape[i].to_text()
        i = i + 1
    out + "]"

# Serialize a TensorPack into the canonical v0 manifest format. Output is a
# deterministic JSON-ish single-line text (schema per arch.md §4). Keys are
# emitted in a fixed order; integers decimal; no whitespace padding.
fn serialize_manifest(pack: TensorPack) -> text:
    var out = "{"
    out = out + "\"schema_version\":0"
    out = out + ",\"model_id\":\"" + _esc(pack.model_id) + "\""
    out = out + ",\"revision\":\"" + _esc(pack.revision) + "\""
    out = out + ",\"preferred_chunk_bytes\":" + pack.preferred_chunk_bytes.to_text()
    out = out + ",\"digest_algo\":\"sha256\""
    out = out + ",\"chunks\":["
    var i = 0
    while i < pack.chunks.len():
        val c = pack.chunks[i]
        if i > 0:
            out = out + ","
        out = out + "{\"id\":" + (c.id as i64).to_text()
        out = out + ",\"relative_path\":\"" + _esc(c.relative_path) + "\""
        out = out + ",\"byte_len\":" + c.byte_len.to_text()
        out = out + ",\"digest_hex\":\"" + _esc(c.digest_hex) + "\"}"
        i = i + 1
    out = out + "]"
    out = out + ",\"tensors\":["
    var j = 0
    while j < pack.tensors.len():
        val t = pack.tensors[j]
        if j > 0:
            out = out + ","
        out = out + "{\"name\":\"" + _esc(t.name) + "\""
        out = out + ",\"dtype\":\"" + _dtype_label(t.dtype) + "\""
        out = out + ",\"shape\":" + _shape_json(t.shape)
        out = out + ",\"chunk_id\":" + (t.chunk_id as i64).to_text()
        out = out + ",\"offset_in_chunk\":" + t.offset_in_chunk.to_text()
        out = out + ",\"byte_len\":" + t.byte_len.to_text() + "}"
        j = j + 1
    out = out + "]"
    out + "}"
