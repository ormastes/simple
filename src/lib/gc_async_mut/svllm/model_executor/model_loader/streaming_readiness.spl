use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoaderError, load_tensor_bytes_from_pack, load_tensor_stream_plan_from_pack, load_tensor_stream_plan_from_manifest_text}

class SvllmStreamingReadiness:
    status: text
    reason: text
    plan_status: text
    execution_status: text
    read_range_status: text
    pinned_buffer_status: text
    device_staging_status: text
    local_read_bytes_status: text
    segment_count: i64
    total_byte_len: i64
    evidence_jsonl: text

fn _json_pair(key: text, value: text) -> text:
    "\"" + key + "\":\"" + _json_safe(value) + "\""

fn _json_num_pair(key: text, value: i64) -> text:
    "\"" + key + "\":" + str(value)

fn _json_safe(value: text) -> text:
    var cleaned = value.replace("\\", "_")
    cleaned = cleaned.replace("\"", "_")
    cleaned = cleaned.replace("\n", "_")
    cleaned = cleaned.replace("\r", "_")
    if cleaned.trim() == "":
        return "none"
    cleaned

fn _capability_status(status: text) -> text:
    val value = status.trim().to_lower()
    if value == "ready":
        return "ready"
    if value == "unsupported":
        return "unsupported"
    if value == "unavailable":
        return "unavailable"
    if value == "unchecked":
        return "unchecked"
    "unavailable"

fn _local_read_status(status: text) -> text:
    val value = status.trim().to_lower()
    if value == "ready":
        return "ready"
    if value == "error":
        return "error"
    if value == "unchecked":
        return "unchecked"
    "unchecked"

fn _loader_error_reason(error: LoaderError) -> text:
    match error:
        LoaderError.PackRootNotFound => "pack_root_not_found"
        LoaderError.ManifestInvalid => "manifest_invalid"
        LoaderError.ChunkOpenFailed => "chunk_open_failed"
        LoaderError.TensorNotFound => "tensor_not_found"
        LoaderError.TensorRangeInvalid => "tensor_range_invalid"
        LoaderError.NvfsUnavailable => "nvfs_unavailable"
        LoaderError.Unimplemented => "unimplemented"

fn _streaming_reason(read_range_status: text, pinned_buffer_status: text, device_staging_status: text) -> text:
    if read_range_status != "ready":
        return "native_read_range_unavailable"
    if pinned_buffer_status != "ready":
        return "pinned_buffer_registration_unavailable"
    if device_staging_status != "ready":
        return "device_staging_unavailable"
    "ready"

fn svllm_streaming_readiness_from_statuses(pack_root: text, tensor_name: text, read_range_status: text, pinned_buffer_status: text, device_staging_status: text) -> SvllmStreamingReadiness:
    val normalized_read_range = _capability_status(read_range_status)
    val normalized_pinned_buffer = _capability_status(pinned_buffer_status)
    val normalized_device_staging = _capability_status(device_staging_status)
    match load_tensor_stream_plan_from_pack(pack_root, tensor_name, true, true):
        Err(error) =>
            _readiness("blocked", _loader_error_reason(error), "error", "not_scheduled", normalized_read_range, normalized_pinned_buffer, normalized_device_staging, "unchecked", 0, 0)
        Ok(plan) =>
            val reason = _streaming_reason(normalized_read_range, normalized_pinned_buffer, normalized_device_staging)
            val status = if reason == "ready": "ready" else: "blocked"
            val execution_status = if status == "ready": "ready_to_schedule" else: plan.execution_status
            _readiness(status, reason, "ok", execution_status, normalized_read_range, normalized_pinned_buffer, normalized_device_staging, "unchecked", plan.segment_count, plan.total_byte_len)

fn svllm_streaming_readiness_from_pack(pack_root: text, tensor_name: text) -> SvllmStreamingReadiness:
    svllm_streaming_readiness_from_statuses(pack_root, tensor_name, "unsupported", "unsupported", "unsupported")

fn svllm_streaming_readiness_from_local_pack(pack_root: text, tensor_name: text) -> SvllmStreamingReadiness:
    val normalized_read_range = "unsupported"
    val normalized_pinned_buffer = "unsupported"
    val normalized_device_staging = "unsupported"
    match load_tensor_stream_plan_from_pack(pack_root, tensor_name, true, true):
        Err(error) =>
            _readiness("blocked", _loader_error_reason(error), "error", "not_scheduled", normalized_read_range, normalized_pinned_buffer, normalized_device_staging, "error", 0, 0)
        Ok(plan) =>
            var local_status = "error"
            match load_tensor_bytes_from_pack(pack_root, tensor_name):
                Ok(bytes) =>
                    if bytes.len() == plan.total_byte_len:
                        local_status = "ready"
                Err(_) =>
                    local_status = "error"
            val reason = _streaming_reason(normalized_read_range, normalized_pinned_buffer, normalized_device_staging)
            _readiness("blocked", reason, "ok", "local_read_bytes_ready", normalized_read_range, normalized_pinned_buffer, normalized_device_staging, local_status, plan.segment_count, plan.total_byte_len)

fn svllm_streaming_readiness_from_manifest_text(pack_root: text, manifest_text: text, tensor_name: text, read_range_status: text, pinned_buffer_status: text, device_staging_status: text) -> SvllmStreamingReadiness:
    val normalized_read_range = _capability_status(read_range_status)
    val normalized_pinned_buffer = _capability_status(pinned_buffer_status)
    val normalized_device_staging = _capability_status(device_staging_status)
    match load_tensor_stream_plan_from_manifest_text(pack_root, manifest_text, tensor_name, true, true):
        Err(error) =>
            _readiness("blocked", _loader_error_reason(error), "error", "not_scheduled", normalized_read_range, normalized_pinned_buffer, normalized_device_staging, "unchecked", 0, 0)
        Ok(plan) =>
            val reason = _streaming_reason(normalized_read_range, normalized_pinned_buffer, normalized_device_staging)
            val status = if reason == "ready": "ready" else: "blocked"
            val execution_status = if status == "ready": "ready_to_schedule" else: plan.execution_status
            _readiness(status, reason, "ok", execution_status, normalized_read_range, normalized_pinned_buffer, normalized_device_staging, "unchecked", plan.segment_count, plan.total_byte_len)

fn _readiness(status: text, reason: text, plan_status: text, execution_status: text, read_range_status: text, pinned_buffer_status: text, device_staging_status: text, local_read_bytes_status: text, segment_count: i64, total_byte_len: i64) -> SvllmStreamingReadiness:
    val result = SvllmStreamingReadiness(
        status: status,
        reason: reason,
        plan_status: plan_status,
        execution_status: execution_status,
        read_range_status: read_range_status,
        pinned_buffer_status: pinned_buffer_status,
        device_staging_status: device_staging_status,
        local_read_bytes_status: _local_read_status(local_read_bytes_status),
        segment_count: segment_count,
        total_byte_len: total_byte_len,
        evidence_jsonl: ""
    )
    result.evidence_jsonl = svllm_streaming_readiness_jsonl_event(result)
    result

fn svllm_streaming_readiness_jsonl_event(readiness: SvllmStreamingReadiness) -> text:
    "{" +
    _json_pair("event", "svllm_streaming_readiness") +
    "," + _json_pair("status", readiness.status) +
    "," + _json_pair("reason", readiness.reason) +
    "," + _json_pair("plan_status", readiness.plan_status) +
    "," + _json_pair("execution_status", readiness.execution_status) +
    "," + _json_pair("read_range", readiness.read_range_status) +
    "," + _json_pair("pinned_buffer", readiness.pinned_buffer_status) +
    "," + _json_pair("device_staging", readiness.device_staging_status) +
    "," + _json_pair("local_read_bytes", readiness.local_read_bytes_status) +
    "," + _json_num_pair("segment_count", readiness.segment_count) +
    "," + _json_num_pair("total_byte_len", readiness.total_byte_len) +
    "}\n"

export SvllmStreamingReadiness, svllm_streaming_readiness_from_pack, svllm_streaming_readiness_from_local_pack, svllm_streaming_readiness_from_statuses, svllm_streaming_readiness_from_manifest_text, svllm_streaming_readiness_jsonl_event
