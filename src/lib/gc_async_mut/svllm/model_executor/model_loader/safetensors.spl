# @gc — module uses GC runtime
#
# Minimal safetensors reader. Used only by the packer CLI (svllm_pack)
# at model install time to convert upstream checkpoints into the local
# tensor_pack format. svllm's serving hot path does not touch this.
#
# Safetensors layout:
#   8 bytes little-endian header length N
#   N bytes of JSON header: { "<tensor_name>": { "dtype": ..., "shape": [...], "data_offsets": [start, end] }, "__metadata__": {...} }
#   remaining: concatenated tensor bytes referenced by data_offsets
#
# Phase A1 defines the types + a stub parser; the full reader is built
# in the A2 slice.

enum SafetensorsError:
    NotFound
    TruncatedHeader
    MalformedJson
    UnknownDtype
    OffsetOutOfRange

struct SafetensorsTensorEntry:
    name: text
    dtype: text
    shape: [i64]
    data_start: i64
    data_end: i64

struct SafetensorsHeader:
    header_byte_len: i64
    tensors: [SafetensorsTensorEntry]

    static fn empty() -> SafetensorsHeader:
        SafetensorsHeader(header_byte_len: 0, tensors: [])

# Stub: parses only the 8-byte length prefix; rest is TODO for A2.
fn parse_safetensors_header(bytes: [u8]) -> Result<SafetensorsHeader, SafetensorsError>:
    if bytes.len() < 8:
        return Err(SafetensorsError.TruncatedHeader)
    Err(SafetensorsError.MalformedJson)
