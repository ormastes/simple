# @gc — module uses GC runtime
#
# Top-level loader. Orchestrates:
#   1. open the pack root on the NvfsClient
#   2. read + parse manifest.sdn
#   3. build a TensorPack descriptor
#   4. return it for the streamer (A3) to consume
#
# Phase A1 only fixes the surface; the implementation is stubbed so
# tests that exercise the full flow fail loudly. Tests that only
# exercise data types pass.

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack}
use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{ManifestError}

enum LoaderError:
    PackRootNotFound
    ManifestInvalid
    ChunkOpenFailed
    NvfsUnavailable
    Unimplemented

# Result of a successful load. For A1 this is just the pack; A3 adds the
# streamer handle and staging-pool references.
struct LoadResult:
    pack: TensorPack

# Main entry point. A1 stub returns Unimplemented; A3 wires this to the
# NvfsClient and the streamer.
fn load_model_from_pack(pack_root: text) -> Result<LoadResult, LoaderError>:
    Err(LoaderError.Unimplemented)
