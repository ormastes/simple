# @gc — module uses GC runtime
#
# Top-level loader. Orchestrates:
#   1. open the pack root on the NvfsClient
#   2. read + parse manifest.sdn
#   3. build a TensorPack descriptor
#   4. stream-stage the pack (A3)
#
# The A3 streaming path is fully implemented in load_model_from_pack_streamed.
# The bare load_model_from_pack entry awaits a concrete NvfsClient adapter
# to supply manifest_text and chunk bytes (tracked, parallel nvfs design).

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack}
use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{ManifestError, parse_manifest, build_tensor_pack}
use std.gc_async_mut.svllm.model_executor.model_loader.streamer.{plan_stream, stream_pack, StreamError}

enum LoaderError:
    ManifestInvalid
    ChunkOpenFailed
    ChunkDataInvalid
    NvfsUnavailable

# Result of a successful load. Carries the pack descriptor plus streaming
# outcome: total bytes moved, number of tensors staged, and the op count
# from the stream plan.
struct LoadResult:
    pack: TensorPack
    bytes_streamed: i64
    staged_tensor_count: i64
    op_count: i64

# Full A3 streaming path. The caller supplies:
#   manifest_text — contents of manifest.sdn (fetched by the NvfsClient adapter)
#   granule       — preferred read granule in bytes (0 = one read per chunk)
#   chunk_data    — raw bytes of each chunk in pack order (fetched by the adapter)
# Steps: parse manifest -> build TensorPack -> plan stream -> stage tensors.
# Each Result is unwrapped with an explicit match; errors are mapped to
# LoaderError (cannot use ? across different error types).
fn load_model_from_pack_streamed(pack_root: text, manifest_text: text, granule: i64, chunk_data: [[u8]]) -> Result<LoadResult, LoaderError>:
    val m_result = parse_manifest(manifest_text)
    if m_result.is_err():
        return Err(LoaderError.ManifestInvalid)
    val m = m_result.unwrap()

    val pack_result = build_tensor_pack(pack_root, m)
    if pack_result.is_err():
        return Err(LoaderError.ManifestInvalid)
    val pack = pack_result.unwrap()

    val plan = plan_stream(pack, granule)
    val op_count = plan.op_count

    val stream_result = stream_pack(pack, chunk_data)
    match stream_result:
        Ok(sr) =>
            Ok(LoadResult(
                pack: pack,
                bytes_streamed: sr.bytes_streamed,
                staged_tensor_count: sr.stages.len(),
                op_count: op_count
            ))
        Err(StreamError.ChunkDataMissing) => Err(LoaderError.ChunkOpenFailed)
        Err(StreamError.ChunkTooShort) => Err(LoaderError.ChunkOpenFailed)
        Err(StreamError.TensorOutOfBounds) => Err(LoaderError.ChunkDataInvalid)
        Err(StreamError.ChunkNotFound) => Err(LoaderError.ChunkDataInvalid)

# Bare entry point. The implemented A3 streaming path is
# load_model_from_pack_streamed, which takes the manifest text and chunk bytes
# a client has already fetched. This entry returns NvfsUnavailable until a
# concrete NvfsClient adapter is wired to supply those inputs (tracked,
# parallel nvfs design).
fn load_model_from_pack(pack_root: text) -> Result<LoadResult, LoaderError>:
    Err(LoaderError.NvfsUnavailable)
