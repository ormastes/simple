    """Download i64 array from device to host."""
    var result = [for i in 0..count: 0]
    val byte_size = count * 8
    val dl_result = gpu_download(gpu_ptr, result.data_ptr(), byte_size)
    match dl_result:
        case Ok(_):
            Ok(result)
        case Err(e):
            Err(e)

fn gpu_download_f64(gpu_ptr: GpuPtr, count: i64) -> Result<[f64], GpuError>:
