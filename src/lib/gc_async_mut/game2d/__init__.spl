# game2d — Retained-Mode 2D Game Rendering
#
# @tag:stdlib
# @tag:api
# @tag:game2d
#
# High-level 2D game scene graph built on top of std.gpu.engine2d.Engine2D.
#
# Public API
# ----------
#
# Core facade:
#   use std.game2d.{Game2DEngine}
#
# Scene graph:
#   use std.game2d.scene.{Scene, SceneNode}
#
# Sprites:
#   use std.game2d.sprite.{Sprite, AnimatedSprite, FrameRef}
#
# Sprite batching:
#   use std.game2d.batch.{SpriteBatch}
#
# Camera:
#   use std.game2d.camera.{Camera2D, Rect}
#
# Transforms:
#   use std.game2d.transform.{Transform2D}
#
# Tile maps:
#   use std.game2d.tilemap.{TileMap}
#
# Submodules
# ----------
#
# - transform:  Transform2D (position, rotation, scale, parent, world matrix)
# - sprite:     Sprite, AnimatedSprite, FrameRef
# - batch:      SpriteBatch (z-sorted, flushed via Engine2D.draw_image)
# - camera:     Camera2D (world↔screen, viewport clip)
# - tilemap:    TileMap (tile grid, per-tile draw_image)
# - scene:      Scene (retained scene graph: add/update/render)
#
# Quick example
# -------------
#
#   use std.game2d.{Game2DEngine}
#   use std.gpu.engine2d.engine.{Engine2D}
#   use std.gpu.engine2d.color.{rgb}
#
#   var eng = Engine2D.create(800, 600)
#   var game = Game2DEngine.create(eng, 800, 600)
#   game.scene.add_sprite(Sprite.create(1, 100.0, 200.0, 32, 32))
#   game.render()
#   val pixels = eng.read_pixels()

use std.game2d.transform.{Transform2D}
use std.game2d.sprite.{Sprite, AnimatedSprite, FrameRef}
use std.game2d.batch.{SpriteBatch}
use std.game2d.camera.{Camera2D, Rect}
use std.game2d.tilemap.{TileMap}
use std.game2d.scene.{Scene, SceneNode}
use std.gpu.engine2d.engine.{Engine2D}
use std.gpu.engine2d.color.{color_black}

# ============================================================================
# Game2DEngine — top-level facade
# ============================================================================

class Game2DEngine:
    """Top-level facade that owns a Scene and Camera2D.

    Wraps Engine2D (composition only).  Call render() each frame.
    """

    engine: Engine2D
    scene: Scene
    camera: Camera2D
    width: i32
    height: i32

    static fn create(eng: Engine2D, w: i32, h: i32) -> Game2DEngine:
        """Create a Game2DEngine wrapping an existing Engine2D.

        A default camera covering the full viewport and an empty root Scene
        are created automatically.
        """
        val cam = Camera2D.create(0.0, 0.0, _i32_to_f64(w), _i32_to_f64(h))
        Game2DEngine(
            engine: eng,
            scene: Scene.create(),
            camera: cam,
            width: w,
            height: h
        )

    me update(dt_ms: f64):
        """Advance all animated nodes by dt_ms milliseconds."""
        self.scene.update(dt_ms)

    me render():
        """Clear the framebuffer and draw the entire scene."""
        self.engine.clear(color_black())
        self.scene.render(self.engine, self.camera)
        self.engine.present()

    fn read_pixels() -> [u32]:
        """Read back the framebuffer after render()."""
        self.engine.read_pixels()

# Re-export public symbols
export Game2DEngine
export Scene, SceneNode
export Sprite, AnimatedSprite, FrameRef
export SpriteBatch
export Camera2D, Rect
export Transform2D
export TileMap

@extern fn _i32_to_f64(x: i32) -> f64
