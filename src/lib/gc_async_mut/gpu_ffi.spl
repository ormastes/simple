"""
# GC Async GPU FFI Facade

CUDA runtime calls are synchronous backend operations. The GC async family
routes through the no-GC async CUDA surface, which reuses the no-GC sync
backend owner instead of declaring duplicate hooks.
"""

export use std.nogc_async_mut.cuda.mod.{
    cuda_init,
    cuda_device_get,
    cuda_device_count,
    cuda_device_name,
    cuda_device_compute_capability,
    cuda_ctx_create,
    cuda_ctx_destroy,
    cuda_ctx_synchronize,
    cuda_mem_alloc,
    cuda_mem_free,
    cuda_memcpy_htod,
    cuda_memcpy_dtoh,
    cuda_memcpy_dtod,
    cuda_memset,
    cuda_module_load,
    cuda_module_load_data,
    cuda_module_unload,
    cuda_launch_kernel,
    cuda_sync,
    cuda_get_error_string
}
