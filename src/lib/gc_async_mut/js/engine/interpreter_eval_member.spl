# JsInterpreter — member access, assignment, array/object literals, template literals, delete.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.types.ast_types.{DestructProp, JsExpression}
use std.js.types.ast_types.JsStatement
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm_object_store.{ObjectStore}
use std.gc_async_mut.js.engine.interpreter.{JsInterpreter}
use std.gc_async_mut.js.engine.interpreter_object.{JsInterpreter}

fn _js_location_find_text(haystack: text, needle: text, start: i64) -> i64:
    if start < 0 or start > haystack.len() or needle.len() == 0:
        return -1
    var idx = start
    val last = haystack.len() - needle.len()
    val first = needle.slice(0, 1)
    while idx <= last:
        if haystack.slice(idx, idx + 1) == first:
            if haystack.slice(idx, idx + needle.len()) == needle:
                return idx
        idx = idx + 1
    -1

fn _js_location_without_fragment(url: text) -> text:
    val idx = _js_location_find_text(url, "#", 0)
    if idx < 0:
        return url
    url.slice(0, idx)

fn _js_location_without_query(url: text) -> text:
    val clean = _js_location_without_fragment(url)
    val idx = _js_location_find_text(clean, "?", 0)
    if idx < 0:
        return clean
    clean.slice(0, idx)

fn _js_location_protocol(url: text) -> text:
    if url.starts_with("https://"):
        return "https:"
    if url.starts_with("http://"):
        return "http:"
    if url.starts_with("file://"):
        return "file:"
    if url.starts_with("about:"):
        return "about:"
    ""

fn _js_location_host(url: text) -> text:
    val scheme_pos = _js_location_find_text(url, "://", 0)
    if scheme_pos < 0:
        return ""
    val host_start = scheme_pos + 3
    val path_start = _js_location_find_text(url, "/", host_start)
    if path_start < 0:
        return url.slice(host_start, url.len())
    url.slice(host_start, path_start)

fn _js_location_origin(url: text) -> text:
    val scheme_pos = _js_location_find_text(url, "://", 0)
    if scheme_pos < 0:
        return ""
    val host_start = scheme_pos + 3
    val path_start = _js_location_find_text(url, "/", host_start)
    if path_start < 0:
        return url
    url.slice(0, path_start)

fn _js_location_pathname(url: text) -> text:
    if url.starts_with("file://"):
        return _js_location_without_query(url.slice(7, url.len()))
    if url.starts_with("about:"):
        return url
    val scheme_pos = _js_location_find_text(url, "://", 0)
    if scheme_pos < 0:
        return "/"
    val path_start = _js_location_find_text(url, "/", scheme_pos + 3)
    if path_start < 0:
        return "/"
    _js_location_without_query(url.slice(path_start, url.len()))

fn _js_location_search(url: text) -> text:
    val clean = _js_location_without_fragment(url)
    val idx = _js_location_find_text(clean, "?", 0)
    if idx < 0:
        return ""
    clean.slice(idx, clean.len())

fn _js_location_hash(url: text) -> text:
    val idx = _js_location_find_text(url, "#", 0)
    if idx < 0:
        return ""
    url.slice(idx, url.len())

impl JsInterpreter:
    # Member access: obj.prop
    # Look up property on object, with recursive prototype chain fallback
    fn _proto_lookup(obj_id: i64, property: text) -> JsValue:
        var current_id = obj_id
        var depth = 0
        while current_id >= 0 and depth < 64:
            val prop = self.get_object_property(current_id, property)
            if not strict_equals(prop, JsValue.Undefined):
                return prop
            val proto = self.get_object_property(current_id, "__proto__")
            val proto_id = _get_obj_id(proto)
            if proto_id < 0 or proto_id == current_id:
                return JsValue.Undefined
            current_id = proto_id
            depth = depth + 1
        JsValue.Undefined

    me eval_member(object: JsExpression, property: text, env: i64) -> BrowserResult<JsValue>:
        val obj_val = self.eval_expression(object, env)?
        val obj_id = _get_obj_id(obj_val)
        if obj_id >= 0:
            if obj_id == self.host_document_id:
                if property == "title" and not strict_equals(self.host_document_title_value, JsValue.Undefined):
                    return Ok(self.host_document_title_value)
                if property == "cookie":
                    if not strict_equals(self.host_document_cookie_value, JsValue.Undefined):
                        return Ok(self.host_document_cookie_value)
                    match self.get_object_property(obj_id, "cookie"):
                        JsValue.String(v):
                            return Ok(JsValue.String(v: v))
                        _:
                            return Ok(JsValue.String(v: ""))
                if property == "body" and self.host_body_id >= 0:
                    return Ok(JsValue.Object(id: self.host_body_id))
                if property == "location" and self.host_location_id >= 0:
                    return Ok(JsValue.Object(id: self.host_location_id))
            if obj_id == self.host_body_id:
                if property == "innerHTML" and not strict_equals(self.host_body_inner_html_value, JsValue.Undefined):
                    return Ok(self.host_body_inner_html_value)
                if property == "textContent" and not strict_equals(self.host_body_text_content_value, JsValue.Undefined):
                    return Ok(self.host_body_text_content_value)
            # Object or Array — check array length first
            if property == "length":
                val len_val = self.get_object_property(obj_id, "length")
                if not strict_equals(len_val, JsValue.Undefined):
                    return Ok(len_val)
            return Ok(self._proto_lookup(obj_id, property))
        # String — use typeof_value to avoid match destructuring
        val tv = typeof_value(obj_val)
        if tv == "string":
            if property == "length":
                val str_val = js_to_string(obj_val)
                return Ok(JsValue.Number(v: str_val.len().to_f64()))
        # TypeError: Cannot read properties of undefined/null
        if tv == "undefined" or strict_equals(obj_val, JsValue.Null):
            self.thrown_value = JsValue.String(v: "TypeError: Cannot read properties of " + tv)
            self.control_thrown = true
            return Ok(JsValue.Undefined)
        Ok(JsValue.Undefined)

    # Assignment: target = value
    me eval_assignment(target: JsExpression, value: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val rhs = self.eval_expression(value, env)?

        match target:
            JsExpression.Identifier(name):
                self.env_stack.set_var(env, name, rhs)
                return Ok(rhs)
            JsExpression.Member(object, property):
                var handled_host_body_assignment = false
                match object:
                    JsExpression.Member(parent_object, parent_property):
                        if parent_property == "body":
                            match parent_object:
                                JsExpression.Identifier(parent_name):
                                    if parent_name == "document":
                                        if property == "innerHTML":
                                            self.host_body_inner_html_value = rhs
                                            handled_host_body_assignment = true
                                        if property == "textContent":
                                            self.host_body_text_content_value = rhs
                                            handled_host_body_assignment = true
                                _:
                                    pass_dn
                    _:
                        pass_dn
                if handled_host_body_assignment:
                    return Ok(rhs)
                val obj_val = self.eval_expression(object, env)?
                val obj_id = _get_obj_id(obj_val)
                if obj_id >= 0:
                    if obj_id == self.host_document_id:
                        if property == "title":
                            self.host_document_title_value = rhs
                            return Ok(rhs)
                        if property == "cookie":
                            val cookie_text = js_to_string(rhs)
                            self.host_document_cookie_value = JsValue.String(v: cookie_text)
                            self.set_object_property(self.host_document_id, "cookie", JsValue.String(v: cookie_text))
                            if self.host_window_id >= 0:
                                self.set_object_property(self.host_window_id, "__simple_cookie_header", JsValue.String(v: cookie_text))
                            if self.host_chrome_id >= 0:
                                self.set_object_property(self.host_chrome_id, "__simple_cookie_header", JsValue.String(v: cookie_text))
                            return Ok(rhs)
                    if obj_id == self.host_body_id:
                        if property == "innerHTML":
                            self.host_body_inner_html_value = rhs
                            return Ok(rhs)
                        if property == "textContent":
                            self.host_body_text_content_value = rhs
                            return Ok(rhs)
                    if obj_id == self.host_location_id and property == "href":
                        val href = js_to_string(rhs)
                        self.set_object_property_direct(obj_id, "href", JsValue.String(v: href))
                        self.set_object_property_direct(obj_id, "protocol", JsValue.String(v: _js_location_protocol(href)))
                        self.set_object_property_direct(obj_id, "host", JsValue.String(v: _js_location_host(href)))
                        self.set_object_property_direct(obj_id, "origin", JsValue.String(v: _js_location_origin(href)))
                        self.set_object_property_direct(obj_id, "pathname", JsValue.String(v: _js_location_pathname(href)))
                        self.set_object_property_direct(obj_id, "search", JsValue.String(v: _js_location_search(href)))
                        self.set_object_property_direct(obj_id, "hash", JsValue.String(v: _js_location_hash(href)))
                        return Ok(rhs)
                    self.set_object_property_direct(obj_id, property, rhs)
                return Ok(rhs)
            JsExpression.ComputedMember(object, property):
                val obj_val = self.eval_expression(object, env)?
                val key_val = self.eval_expression(property, env)?
                val obj_id = _get_obj_id(obj_val)
                if obj_id >= 0:
                    var key_str = js_to_string(key_val)
                    match key_val:
                        JsValue.Number(n):
                            key_str = "{f64_to_i64(n)}"
                        _:
                            pass_dn
                    self.set_object_property(obj_id, key_str, rhs)
                return Ok(rhs)
            _:
                self.logger.warn("Invalid assignment target")
                return Ok(rhs)

    # Array literal — supports spread: [1, ...arr, 2]
    me eval_array(elements: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val arr_id = self.create_object()
        var idx = 0
        var i = 0
        val len = elements.len()
        while i < len:
            val elem_expr = elements.get(i)
            match elem_expr:
                JsExpression.SpreadElement(arg):
                    val spread_val = self.eval_expression(arg, env)?
                    match spread_val:
                        JsValue.Array(src_id):
                            val src_len = self.object_store.array_length(src_id)
                            var si = 0
                            while si < src_len:
                                val sv = self.object_store.get_by_index(src_id, si)
                                self.set_object_property(arr_id, "{idx}", sv)
                                idx = idx + 1
                                si = si + 1
                        _:
                            self.set_object_property(arr_id, "{idx}", spread_val)
                            idx = idx + 1
                _:
                    val elem = self.eval_expression(elem_expr, env)?
                    self.set_object_property(arr_id, "{idx}", elem)
                    idx = idx + 1
            i = i + 1
        self.set_object_property(arr_id, "length", JsValue.Number(v: idx.to_f64()))
        Ok(JsValue.Array(id: arr_id))

    # Object literal
    me eval_object(properties: [DestructProp], env: i64) -> BrowserResult<JsValue>:
        val obj_id = self.create_object()
        var i = 0
        val len = properties.len()
        while i < len:
            val prop = properties.get(i)
            val pv = self.eval_expression(prop.value, env)?
            self.set_object_property(obj_id, prop.key, pv)
            i = i + 1
        Ok(JsValue.Object(id: obj_id))

    # Template literal: `hello ${name}!`
    me eval_template_literal(quasis: [text], expressions: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        var result = ""
        var i = 0
        val qlen = quasis.len()
        while i < qlen:
            result = result + quasis.get(i)
            if i < expressions.len():
                val expr_val = self.eval_expression(expressions.get(i), env)?
                result = result + js_to_string(expr_val)
            i = i + 1
        Ok(JsValue.String(v: result))

    # Delete operator: delete obj.prop
    me eval_delete(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        match expr:
            JsExpression.Member(object, property):
                val obj_val = self.eval_expression(object, env)?
                match obj_val:
                    JsValue.Object(id):
                        self.object_store.remove_property(id, property)
                        return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: true))
            _:
                return Ok(JsValue.Boolean(v: true))
