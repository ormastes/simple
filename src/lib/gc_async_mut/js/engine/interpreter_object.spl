# JsInterpreter — object store, global scope, and environment setup methods.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm_object_store.{ObjectStore}
use std.gc_async_mut.js.engine.interpreter.{JsInterpreter}

impl JsInterpreter:
    # Register a native function placeholder and return its index
    me _register_native(name: text, native_id: i64) -> i64:
        val fn_idx = self.functions.len()
        val placeholder = JsFunction.create(name, [], [], -1)
        var functions: [JsFunction] = self.functions
        functions.push(placeholder)
        self.functions = functions
        var native_id_map: [Pair<i64, i64>] = self.native_id_map
        native_id_map.push(Pair(first: fn_idx, second: native_id))
        self.native_id_map = native_id_map
        fn_idx

    # Define a native function in the global scope
    me _define_global_native(name: text, native_id: i64):
        val fn_idx = self._register_native(name, native_id)
        self.define_global_value(name, JsValue.Function(id: fn_idx))

    me define_global_value(name: text, value: JsValue):
        var global_var_names: [text] = self.global_var_names
        var global_var_values: [JsValue] = self.global_var_values
        global_var_names.push(name)
        global_var_values.push(value)
        self.global_var_names = global_var_names
        self.global_var_values = global_var_values

    me create_object() -> i64:
        var object_store = self.object_store
        val id = object_store.next_id
        object_store.next_id = object_store.next_id + 1
        var obj_proto_ids: [i64] = object_store.obj_proto_ids
        obj_proto_ids.push(-1)
        object_store.obj_proto_ids = obj_proto_ids
        self.object_store = object_store
        id

    me set_object_property(obj_id: i64, key: text, value: JsValue):
        if key != "__simple_frozen" and self._is_object_frozen(obj_id):
            self.logger.debug("Ignoring write to frozen object {obj_id}.{key}")
            return

        var stored_value = value
        val indexed_key = key.parse_int() ?? -1
        if indexed_key >= 0:
            match self.get_object_property(obj_id, "__simple_typed_array_buffer"):
                JsValue.Number(buffer_id_value):
                    var byte = f64_to_i64(to_number(value))
                    byte = byte & 255
                    self.set_object_property(f64_to_i64(buffer_id_value), key, JsValue.Number(v: byte.to_f64()))
                    stored_value = JsValue.Number(v: byte.to_f64())
                _:
                    match self.get_object_property(obj_id, "__simple_array_buffer"):
                        JsValue.Boolean(is_buffer):
                            if is_buffer:
                                var byte = f64_to_i64(to_number(value))
                                byte = byte & 255
                                stored_value = JsValue.Number(v: byte.to_f64())
                        _:
                            pass_dn

        var object_store = self.object_store
        var prop_obj_ids: [i64] = object_store.prop_obj_ids
        var prop_keys: [text] = object_store.prop_keys
        var prop_values: [JsValue] = object_store.prop_values
        var prop_ref_tags: [text] = object_store.prop_ref_tags
        var prop_ref_ids: [text] = object_store.prop_ref_ids
        var prop_enumerables: [bool] = object_store.prop_enumerables
        var prop_configurables: [bool] = object_store.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push(key)
        prop_values.push(stored_value)
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(true)
        prop_configurables.push(true)
        object_store.prop_obj_ids = prop_obj_ids
        object_store.prop_keys = prop_keys
        object_store.prop_values = prop_values
        object_store.prop_ref_tags = prop_ref_tags
        object_store.prop_ref_ids = prop_ref_ids
        object_store.prop_enumerables = prop_enumerables
        object_store.prop_configurables = prop_configurables
        self.object_store = object_store

    fn get_object_property(obj_id: i64, key: text) -> JsValue:
        val store = self.object_store
        var i = store.prop_keys.len() - 1
        while i >= 0:
            if store.prop_obj_ids.get(i) == obj_id and store.prop_keys.get(i) == key:
                return store.prop_values.get(i)
            i = i - 1
        val indexed_key = key.parse_int() ?? -1
        if indexed_key >= 0:
            match self.get_object_property(obj_id, "__simple_typed_array_buffer"):
                JsValue.Number(buffer_id_value):
                    return self.get_object_property(f64_to_i64(buffer_id_value), key)
                _:
                    pass_dn
            match self.get_object_property(obj_id, "__simple_array_buffer"):
                JsValue.Boolean(is_buffer):
                    if is_buffer:
                        match self.get_object_property(obj_id, "byteLength"):
                            JsValue.Number(byte_length):
                                if indexed_key < f64_to_i64(byte_length):
                                    return JsValue.Number(v: 0.0)
                            _:
                                pass_dn
                _:
                    pass_dn
        JsValue.Undefined

    me set_object_property_direct(obj_id: i64, key: text, value: JsValue):
        self.set_object_property(obj_id, key, value)

    me _mark_object_frozen(obj_id: i64):
        if self._is_object_frozen(obj_id):
            return

        var object_store = self.object_store
        var prop_obj_ids: [i64] = object_store.prop_obj_ids
        var prop_keys: [text] = object_store.prop_keys
        var prop_values: [JsValue] = object_store.prop_values
        var prop_ref_tags: [text] = object_store.prop_ref_tags
        var prop_ref_ids: [text] = object_store.prop_ref_ids
        var prop_enumerables: [bool] = object_store.prop_enumerables
        var prop_configurables: [bool] = object_store.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push("__simple_frozen")
        prop_values.push(JsValue.Boolean(v: true))
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(false)
        prop_configurables.push(false)
        object_store.prop_obj_ids = prop_obj_ids
        object_store.prop_keys = prop_keys
        object_store.prop_values = prop_values
        object_store.prop_ref_tags = prop_ref_tags
        object_store.prop_ref_ids = prop_ref_ids
        object_store.prop_enumerables = prop_enumerables
        object_store.prop_configurables = prop_configurables
        self.object_store = object_store

    fn _is_object_frozen(obj_id: i64) -> bool:
        match self.get_object_property(obj_id, "__simple_frozen"):
            JsValue.Boolean(v): v
            _:
                false

    me lookup_global_value(name: text) -> Option<JsValue>:
        if val Some(found) = self.env_stack.get_var(self.global_env, name):
            return Some(found)
        var i = self.global_var_names.len() - 1
        while i >= 0:
            if self.global_var_names.get(i) == name:
                return Some(self.global_var_values.get(i))
            i = i - 1
        nil

    # Define a native method on an object
    me _define_method_on(obj_id: i64, method_name: text, native_id: i64):
        val fn_idx = self._register_native(method_name, native_id)
        self.set_object_property(obj_id, method_name, JsValue.Function(id: fn_idx))

    # Initialize global environment with built-in objects and functions.
    # Must be a `me` method on JsInterpreter — JsRuntime wrapper hits copy-semantics bug.
    me setup_globals():
        # Global values
        self.define_global_value("undefined", JsValue.Undefined)
        self.define_global_value("NaN", JsValue.Number(v: js_nan()))
        self.define_global_value("Infinity", JsValue.Number(v: js_infinity()))

        # Global functions (native IDs from runtime.spl)
        self._define_global_native("parseInt", -10)
        self._define_global_native("parseFloat", -11)
        self._define_global_native("isNaN", -12)
        self._define_global_native("isFinite", -13)
        self._define_global_native("Symbol", -44)

        # console object
        val console_id = self.create_object()
        self._define_method_on(console_id, "log", -1)
        self._define_method_on(console_id, "error", -2)
        self._define_method_on(console_id, "warn", -3)
        self.define_global_value("console", JsValue.Object(id: console_id))

        # Math object
        val math_id = self.create_object()
        self.set_object_property(math_id, "PI", JsValue.Number(v: 3.141592653589793))
        self.set_object_property(math_id, "E", JsValue.Number(v: 2.718281828459045))
        self.set_object_property(math_id, "SQRT2", JsValue.Number(v: 1.4142135623730951))
        self._define_method_on(math_id, "floor", -20)
        self._define_method_on(math_id, "ceil", -21)
        self._define_method_on(math_id, "round", -22)
        self._define_method_on(math_id, "random", -23)
        self._define_method_on(math_id, "abs", -24)
        self._define_method_on(math_id, "max", -25)
        self._define_method_on(math_id, "min", -26)
        self._define_method_on(math_id, "sqrt", -27)
        self._define_method_on(math_id, "pow", -28)
        self.define_global_value("Math", JsValue.Object(id: math_id))

        # JSON object
        val json_id = self.create_object()
        self._define_method_on(json_id, "parse", -30)
        self._define_method_on(json_id, "stringify", -31)
        self.define_global_value("JSON", JsValue.Object(id: json_id))

        # Timer stubs
        self._define_global_native("setTimeout", -40)
        self._define_global_native("setInterval", -41)
        self._define_global_native("clearTimeout", -42)
        self._define_global_native("clearInterval", -43)

        # Error constructors (empty body — new Error('msg') won't crash)
        val error_fn_id = self.functions.len()
        val error_fn = JsFunction.create("Error", ["message"], [], -1)
        self.functions.push(error_fn)
        self.define_global_value("Error", JsValue.Function(id: error_fn_id))
        self.define_global_value("TypeError", JsValue.Function(id: error_fn_id))
        self.define_global_value("RangeError", JsValue.Function(id: error_fn_id))
        self.define_global_value("ReferenceError", JsValue.Function(id: error_fn_id))
        self.define_global_value("SyntaxError", JsValue.Function(id: error_fn_id))
