# Async GC-Mode Reference Counting — No-Op Wrappers
#
# Same as gc_sync_mut/rc.spl: under GC, Rc/Arc are no-ops.
# This variant exists in gc_async_mut so async GC code resolves
# directly without falling back through the chain.

# ============================================================================
# AsyncGcRc - No-Op Reference Counting (Async GC Mode)
# ============================================================================

class AsyncGcRc:
    """No-op Rc for async GC mode.

    Under GC, all references are already shared and traced.
    """
    value: i64

    static fn new(value: i64) -> AsyncGcRc:
        """Wrap value."""
        AsyncGcRc(value: value)

    fn clone() -> AsyncGcRc:
        """Trivial clone — just copy the reference."""
        AsyncGcRc(value: self.value)

    fn borrow() -> i64:
        """Borrow value directly."""
        self.value

    fn strong_count() -> usize:
        1

    fn weak_count() -> usize:
        0

    me drop():
        """No-op: GC handles deallocation."""

# ============================================================================
# AsyncGcArc - No-Op Atomic Reference Counting (Async GC Mode)
# ============================================================================

class AsyncGcArc:
    """No-op Arc for async GC mode. Thread safety handled by GC."""
    value: i64

    static fn new(value: i64) -> AsyncGcArc:
        AsyncGcArc(value: value)

    fn clone() -> AsyncGcArc:
        AsyncGcArc(value: self.value)

    fn borrow() -> i64:
        self.value

    fn strong_count() -> usize:
        1

    fn weak_count() -> usize:
        0

    me drop():
        """No-op: GC handles deallocation."""
