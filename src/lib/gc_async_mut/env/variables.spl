# GC-async environment variables — gc_async_mut.env.variables
#
# Provides env_get for reading environment variables in GC-async contexts.
# Consumer: gc_async_mut/oauth2.spl

use std.gc_async_mut.io.mod_stub.{env_get as gc_env_get}

fn env_get(key: text) -> text?:
    """Get an environment variable value. Returns nil if not set or empty."""
    val v = gc_env_get(key)
    if v == "":
        return nil
    v
