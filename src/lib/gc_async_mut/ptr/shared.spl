# Async GC-Aware Shared Pointer
#
# GC-managed shared reference for async contexts.
# Same semantics as gc_sync_mut/ptr/shared.spl but in the async variant
# so gc_async_mut code resolves directly.

use std.gc.{GcHeap, GcPtr}

# ============================================================================
# AsyncGcShared - Async GC-Managed Shared Reference
# ============================================================================

class AsyncGcShared:
    """Shared reference backed by GC for async contexts.

    Under async GC, sharing is automatic. This wrapper provides
    explicit semantics for code that needs to be clear about
    reference sharing across async task boundaries.
    """
    gc_ptr: GcPtr
    value: i64

    static fn new(heap: GcHeap, value: i64) -> AsyncGcShared:
        """Create an async GC-managed shared reference."""
        val ptr = heap.allocate_ptr(value)
        AsyncGcShared(gc_ptr: ptr, value: value)

fn async_gc_shared_new(heap: GcHeap, value: i64) -> AsyncGcShared:
    """Create a new async GC-managed shared reference."""
    AsyncGcShared.new(heap, value)

fn async_gc_shared_get(shared: AsyncGcShared) -> i64:
    """Get the value from an async shared reference."""
    shared.value
