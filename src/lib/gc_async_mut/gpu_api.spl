# ============================================================================
# Barrier and Copy
# ============================================================================

fn gpu_barrier():
    """Block-level barrier synchronization."""
    pass_dn  # Stub for interpreter mode

fn gpu_copy(dst: GpuPtr, src: GpuPtr, bytes: i64) -> Result<(), GpuError>:
    """Copy bytes between device buffers."""
    val result = cuda_memcpy_dtod(dst.device_ptr, src.device_ptr, bytes)
    if result < 0:
        return Err(GpuError.from_code(result))
    Ok(())

# ============================================================================
# Type Alias
# ============================================================================

type GpuBuffer = GpuPtr

# ============================================================================
# BLAS CPU-fallback Stubs
# ============================================================================

fn gpu_gemm(a: [f32], b: [f32], m: i64, n: i64, k: i64) -> Result<[f32], GpuError>:
    # Matrix multiply C[i,j] = sum(A[i,p] * B[p,j]) for p in 0..k. CPU fallback.
    var result = [for idx in 0..(m * n): 0.0]
    var i = 0
    while i < m:
        var j = 0
        while j < n:
            var sum = 0.0
            var p = 0
            while p < k:
                sum = sum + a[i * k + p] * b[p * n + j]
                p = p + 1
            result[i * n + j] = sum
            j = j + 1
        i = i + 1
    Ok(result)

fn gpu_dot(x: [f32], y: [f32]) -> Result<f32, GpuError>:
    # Dot product of two vectors. CPU fallback.
    var sum = 0.0
    var i = 0
    while i < x.len():
        sum = sum + x[i] * y[i]
        i = i + 1
    Ok(sum)

fn gpu_axpy(alpha: f32, x: [f32], y: [f32]) -> Result<[f32], GpuError>:
    # AXPY: result[i] = alpha * x[i] + y[i]. CPU fallback.
    var result = [for idx in 0..x.len(): 0.0]
    var i = 0
    while i < x.len():
        result[i] = alpha * x[i] + y[i]
        i = i + 1
    Ok(result)

# ============================================================================
# Thrust CPU-fallback Stubs
# ============================================================================

fn gpu_map(data: [f32], op: fn(f32) -> f32) -> Result<[f32], GpuError>:
    # Apply op to each element. CPU fallback.
    var result = [for idx in 0..data.len(): 0.0]
    var i = 0
    while i < data.len():
        result[i] = op(data[i])
        i = i + 1
    Ok(result)

fn gpu_reduce(data: [f32], init: f32, op: fn(f32, f32) -> f32) -> Result<f32, GpuError>:
    # Reduce array with binary op. CPU fallback.
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        i = i + 1
    Ok(acc)

fn gpu_scan(data: [f32], init: f32, op: fn(f32, f32) -> f32) -> Result<[f32], GpuError>:
    # Inclusive prefix scan. CPU fallback.
    var result = [for idx in 0..data.len(): 0.0]
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        result[i] = acc
        i = i + 1
    Ok(result)

fn gpu_filter(data: [f32], pred: fn(f32) -> bool) -> Result<[f32], GpuError>:
    # Filter elements matching predicate. CPU fallback.
    var result: [f32] = []
    var i = 0
    while i < data.len():
        if pred(data[i]):
            result = result + [data[i]]
        i = i + 1
    Ok(result)

fn gpu_sort(data: [f32]) -> Result<[f32], GpuError>:
    # Sort array (insertion sort). CPU fallback.
    var result = [for idx in 0..data.len(): data[idx]]
    var i = 1
    while i < result.len():
        val key = result[i]
        var j = i - 1
        var done = false
        while j >= 0 and not done:
            if result[j] > key:
                result[j + 1] = result[j]
                j = j - 1
            else:
                done = true
        result[j + 1] = key
        i = i + 1
    Ok(result)

