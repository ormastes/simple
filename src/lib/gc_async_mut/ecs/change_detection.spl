# ECS Change Detection (GC-async variant) — parity with nogc_sync_mut.

use std.ecs.entity.{Entity}

struct RemovedEvent:
    entity: Entity
    tick: i64

struct ChangeTracker:
    last_seen_tick: i64
    removed: [RemovedEvent]

    static fn new() -> ChangeTracker:
        ChangeTracker(
            last_seen_tick: 0,
            removed: []
        )

    fn push_removed(self, e: Entity, tick: i64):
        self.removed.push(RemovedEvent(entity: e, tick: tick))

    fn drain_removed(self) -> [RemovedEvent]:
        val out = self.removed
        self.removed = []
        out

    fn is_changed_since(self, slot_tick: i64) -> bool:
        slot_tick > self.last_seen_tick

    fn bookmark(self, tick: i64):
        self.last_seen_tick = tick

fn newer_tick(a: i64, b: i64) -> i64:
    if a > b: a else: b
