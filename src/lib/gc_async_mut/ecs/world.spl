# ECS World (GC-async variant) — services own a World struct with `base: WorldBase`
# + per-component `ComponentStore<T>` fields, same shape as nogc_sync_mut.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.system.{Scheduler}

struct WorldBase:
    alloc: EntityAllocator
    sched: Scheduler
    tick: i64

    static fn new() -> WorldBase:
        WorldBase(
            alloc: EntityAllocator.new(),
            sched: Scheduler.new(),
            tick: 0
        )

    static fn with_capacity(capacity: i32) -> WorldBase:
        WorldBase(
            alloc: EntityAllocator.with_capacity(capacity),
            sched: Scheduler.new(),
            tick: 0
        )

    fn spawn(self) -> Entity:
        self.alloc.alloc()

    fn despawn(self, e: Entity) -> bool:
        self.alloc.free(e)

    fn is_live(self, e: Entity) -> bool:
        self.alloc.is_live(e)

    fn advance(self):
        self.tick = self.tick + 1

    fn now(self) -> i64:
        self.tick
