"""
# I/O Facade

Re-exports all I/O types for convenient access via `use std.io.*`.
Unifies sync and async I/O under a single import path.

## Import

```simple
use std.io.*
```

## Sync File I/O

```simple
use std.io.*

File.write("/tmp/io_facade_test.txt", "hello from facade")?
val content = File.read("/tmp/io_facade_test.txt")?
expect content == "hello from facade"
File.delete("/tmp/io_facade_test.txt")?
```

## Sync Handle-Based I/O

```simple
use std.io.*

val fh = FileHandle.open("/tmp/io_facade_handle.txt", FileMode.WriteOnly)?
fh.write_text("handle data")?
fh.close()?

val fh2 = FileHandle.read_file("/tmp/io_facade_handle.txt")?
val data = fh2.read_text()?
expect data == "handle data"
fh2.close()?
```

## Error Handling

```simple
use std.io.*

val err = IoError(kind: IoErrorKind.NotFound, message: "missing file", source: nil)
expect err.is_not_found() == true
```

## Async File I/O (Mirrors Sync)

```simple
use std.io.*

# Sync:
#   val text = File.read("config.sdn")?
#
# Async — same API, just add await:
#   val text = await AsyncFile.read("config.sdn")?
```

## Async TCP (Mirrors Sync)

```simple
use std.io.*

# Sync:
#   val listener = TcpListener.bind("0.0.0.0:8080")?
#   val stream = listener.accept()?
#
# Async:
#   val listener = await AsyncTcpListener.bind("0.0.0.0:8080")?
#   val stream = await listener.accept()?
```
"""

# --- Shared types ---
use std.io.types.{IoErrorKind, IoError, SeekFrom, IoMode, Interest, ReadyState, IoEvent, FileMode, FileMetadata, Shutdown}

# Re-export the real sync I/O package so `use std.io.{env_get, file_read, ...}`
# resolves to the same runtime helpers as `use std.gc_async_mut.io.{...}`.
use std.gc_async_mut.io.*

# --- Sync traits ---
use std.io.traits.{Read, Write, Seek, Close}

# --- Async traits ---
use std.io.async_traits.{AsyncRead, AsyncWrite, AsyncSeek, AsyncClose}

# --- Sync implementations ---
use std.gc_async_mut.io.file.{FileHandle, File}
use std.gc_async_mut.io.tcp.{TcpListener, TcpStream}
use std.gc_async_mut.io.udp.{UdpSocket}
use std.gc_async_mut.io.buffer.{BufferedReader, BufferedWriter}
use std.gc_async_mut.io.pipe.{Stdin, Stdout, Stderr}

# --- Async implementations ---
use std.gc_async_mut.io.file.{ThreadPool, AsyncFileHandle, AsyncFile}
use std.gc_async_mut.io.tcp.{AsyncTcpListener, AsyncTcpStream}
use std.gc_async_mut.io.udp.{AsyncUdpSocket}
use std.gc_async_mut.io.buffer.{AsyncBufferedReader, AsyncBufferedWriter}
use std.gc_async_mut.io.event_loop.{Waker, EventLoop}

# ============================================================================
# Exports
# ============================================================================

# Shared

# Sync traits

# Async traits

# Sync implementations

# Async implementations

export use std.nogc_sync_mut.io.{
    file_exists, file_read, file_write, file_copy, file_delete, file_atomic_write,
    file_append, file_modified_time, file_remove, file_hash_sha256, file_read_lines,
    file_read_text, file_read_bytes, file_write_bytes, file_mmap_read_text, file_mmap_read_bytes,
    file_read_text_at, file_write_text_at, file_fsync, file_fsync_cached,
    time_now_unix_micros, current_time_unix, current_time_ms, time_now_nanos, time_now_micros,
    cwd, home, env_get, env_set, env_vars,
    shell, shell_output, shell_bool, shell_output_trimmed, shell_lines, shell_int,
    process_output,
    timestamp_year, timestamp_month, timestamp_day,
    timestamp_hour, timestamp_minute, timestamp_second,
    rt_timestamp_now, rt_sleep_ms
}
export use std.nogc_sync_mut.io.file.{FileHandle, File}
export use std.gc_async_mut.io.file.{ThreadPool, AsyncFileHandle, AsyncFile}
