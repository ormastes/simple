fn _css_named_argb(a: i64, r: i64, g: i64, b: i64) -> i64:
    (a * 16777216) + (r * 65536) + (g * 256) + b

fn css_named_color(name: text) -> i64:
    if name == "black": return _css_named_argb(255, 0, 0, 0)
    elif name == "silver": return _css_named_argb(255, 192, 192, 192)
    elif name == "gray" or name == "grey": return _css_named_argb(255, 128, 128, 128)
    elif name == "white": return _css_named_argb(255, 255, 255, 255)
    elif name == "maroon": return _css_named_argb(255, 128, 0, 0)
