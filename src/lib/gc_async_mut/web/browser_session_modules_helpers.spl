# Browser session — JS module helper functions.
#
# Free functions for:
# - split_module_statements / scan_js_statement_end / scan_js_block_statement_end
# - module_statement_source / module_import_clause / split_import_bindings
# - normalize_module_binding_name / split_export_binding_declarators
# - module_exported_names / module_variable_decl_kind / normalize_module_variable_declarator
# - declared_function_name / declared_class_name / declared_binding_name
# - strip_trailing_semicolon / starts_with_word / is_js_space
# - append_unique_text / remove_text_once / text_in_list
# - split_text (re-exported for use by modules.spl and cookies.spl)

use std.gc_async_mut.web.browser_session_url.{find_text}

fn split_text(input: text, delimiter: text) -> [text]:
    if delimiter.len() == 0:
        return [input]
    var out: [text] = []
    var pos = 0
    while pos <= input.len():
        val next = find_text(input, delimiter, pos)
        if next < 0:
            out.push(input.slice(pos, input.len()))
            return out
        out.push(input.slice(pos, next))
        pos = next + delimiter.len()
    out

fn split_module_statements(source: text) -> [text]:
    var items: [text] = []
    var pos = 0
    while pos < source.len():
        while pos < source.len() and is_js_space(source.slice(pos, pos + 1)):
            pos = pos + 1
        if pos >= source.len():
            break
        val start = pos
        val needs_block_scan =
            starts_with_word(source, pos, "export default function") or
            starts_with_word(source, pos, "export function") or
            starts_with_word(source, pos, "export default class") or
            starts_with_word(source, pos, "export class")
        if needs_block_scan:
            pos = scan_js_block_statement_end(source, pos)
        else:
            pos = scan_js_statement_end(source, pos)
        items = items + [source.slice(start, pos)]
    items

fn scan_js_statement_end(source: text, start: i32) -> i32:
    var i = start
    var brace = 0
    var paren = 0
    var bracket = 0
    var quote = ""
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 2
                continue
            if ch == quote:
                quote = ""
            i = i + 1
            continue
        if ch == "\"" or ch == "'" or ch == "`":
            quote = ch
            i = i + 1
            continue
        if ch == "{":
            brace = brace + 1
        else if ch == "}":
            if brace > 0:
                brace = brace - 1
        else if ch == "(":
            paren = paren + 1
        else if ch == ")":
            if paren > 0:
                paren = paren - 1
        else if ch == "[":
            bracket = bracket + 1
        else if ch == "]":
            if bracket > 0:
                bracket = bracket - 1
        else if ch == ";" and brace == 0 and paren == 0 and bracket == 0:
            return i + 1
        i = i + 1
    source.len()

fn scan_js_block_statement_end(source: text, start: i32) -> i32:
    val open = find_text(source, "{", start)
    if open < 0:
        return scan_js_statement_end(source, start)
    var i = open
    var brace = 0
    var quote = ""
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 2
                continue
            if ch == quote:
                quote = ""
            i = i + 1
            continue
        if ch == "\"" or ch == "'" or ch == "`":
            quote = ch
            i = i + 1
            continue
        if ch == "{":
            brace = brace + 1
        else if ch == "}":
            brace = brace - 1
            if brace == 0:
                i = i + 1
                while i < source.len() and is_js_space(source.slice(i, i + 1)):
                    i = i + 1
                if i < source.len() and source.slice(i, i + 1) == ";":
                    i = i + 1
                return i
        i = i + 1
    source.len()

fn module_statement_source(stmt: text) -> text:
    val single_quote = find_text(stmt, "'", 0)
    if single_quote >= 0:
        val end = find_text(stmt, "'", single_quote + 1)
        if end > single_quote:
            return stmt.slice(single_quote + 1, end)
    val double_quote = find_text(stmt, "\"", 0)
    if double_quote >= 0:
        val end = find_text(stmt, "\"", double_quote + 1)
        if end > double_quote:
            return stmt.slice(double_quote + 1, end)
    ""

fn module_import_clause(stmt: text) -> text:
    val source = module_statement_source(stmt)
    if source == "":
        return ""
    val import_start = find_text(stmt, "import", 0)
    if import_start < 0:
        return ""
    val from_idx = find_text(stmt, " from ", import_start)
    if from_idx < 0:
        return ""
    stmt.slice(import_start + 6, from_idx).trim()

fn split_import_bindings(clause: text) -> [text]:
    var items: [text] = []
    val trimmed = clause.trim()
    if trimmed == "":
        return items
    if trimmed.contains(","):
        var depth = 0
        var start = 0
        var i = 0
        while i < trimmed.len():
            val ch = trimmed.slice(i, i + 1)
            if ch == "{":
                depth = depth + 1
            else if ch == "}":
                depth = depth - 1
            else if ch == "," and depth == 0:
                items = items + [trimmed.slice(start, i)]
                start = i + 1
            i = i + 1
        items = items + [trimmed.slice(start, trimmed.len())]
        return items
    items + [trimmed]

fn normalize_module_binding_name(name: text) -> text:
    var out = name.trim()
    if out.starts_with("<fn:") and out.ends_with(">"):
        out = out.slice(4, out.len() - 1).trim()
    if out.starts_with("{") and out.ends_with("}") and out.len() >= 2:
        out = out.slice(1, out.len() - 1).trim()
    if out.starts_with(":"):
        out = out.slice(1, out.len()).trim()
    out

fn split_export_binding_declarators(decl: text) -> [text]:
    var items: [text] = []
    val trimmed = decl.trim()
    if trimmed == "":
        return items
    var brace = 0
    var paren = 0
    var bracket = 0
    var quote = ""
    var start = 0
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 2
                continue
            if ch == quote:
                quote = ""
        else if ch == "\"" or ch == "'" or ch == "`":
            quote = ch
        else if ch == "{":
            brace = brace + 1
        else if ch == "}":
            if brace > 0:
                brace = brace - 1
        else if ch == "(":
            paren = paren + 1
        else if ch == ")":
            if paren > 0:
                paren = paren - 1
        else if ch == "[":
            bracket = bracket + 1
        else if ch == "]":
            if bracket > 0:
                bracket = bracket - 1
        else if ch == "," and brace == 0 and paren == 0 and bracket == 0:
            items = items + [trimmed.slice(start, i)]
            start = i + 1
        i = i + 1
    items + [trimmed.slice(start, trimmed.len())]

fn module_exported_names(source: text, include_default: bool) -> [text]:
    var names: [text] = []
    for stmt in split_module_statements(source):
        val trimmed = strip_trailing_semicolon(stmt.trim())
        if trimmed.starts_with("export default "):
            if include_default:
                names = append_unique_text(names, "default")
        else if trimmed.starts_with("export function "):
            val name = normalize_module_binding_name(declared_function_name(trimmed.slice(7, trimmed.len()).trim()))
            if name != "":
                names = append_unique_text(names, name)
        else if trimmed.starts_with("export class "):
            val name = normalize_module_binding_name(declared_class_name(trimmed.slice(7, trimmed.len()).trim()))
            if name != "":
                names = append_unique_text(names, name)
        else if trimmed.starts_with("export const ") or trimmed.starts_with("export let ") or trimmed.starts_with("export var "):
            val decl = trimmed.slice(7, trimmed.len()).trim()
            for declarator in split_export_binding_declarators(decl):
                val name = normalize_module_binding_name(declared_binding_name(declarator))
                if name != "":
                    names = append_unique_text(names, name)
        else if trimmed.starts_with("export {"):
            val open = find_text(trimmed, "{", 0)
            val close = find_text(trimmed, "}", open + 1)
            if open >= 0 and close >= 0:
                val inner = trimmed.slice(open + 1, close)
                for named in split_text(inner, ","):
                    val named_trimmed = named.trim()
                    if named_trimmed != "":
                        val alias_idx = find_text(named_trimmed, " as ", 0)
                        val exported = if alias_idx >= 0:
                            normalize_module_binding_name(named_trimmed.slice(alias_idx + 4, named_trimmed.len()).trim())
                        else:
                            normalize_module_binding_name(named_trimmed)
                        if exported != "" and (include_default or exported != "default"):
                            names = append_unique_text(names, exported)
    names

fn module_variable_decl_kind(decl: text) -> text:
    val trimmed = decl.trim()
    if trimmed.starts_with("const "):
        return "const"
    if trimmed.starts_with("let "):
        return "let"
    if trimmed.starts_with("var "):
        return "var"
    "var"

fn normalize_module_variable_declarator(kind: text, declarator: text) -> text:
    val trimmed = declarator.trim()
    if trimmed == "":
        return ""
    if trimmed.starts_with("const ") or trimmed.starts_with("let ") or trimmed.starts_with("var "):
        val first_space = find_text(trimmed, " ", 0)
        if first_space >= 0:
            return "var " + trimmed.slice(first_space + 1, trimmed.len()).trim()
        return ""
    "var " + trimmed

fn declared_function_name(stmt: text) -> text:
    val open = find_text(stmt, "(", 0)
    if open < 0:
        return ""
    val before = stmt.slice(0, open).trim()
    val parts = split_text(before, " ")
    if parts.len() == 0:
        return ""
    val name = parts[parts.len() - 1].trim()
    if name == "function":
        return ""
    name

fn declared_class_name(stmt: text) -> text:
    val brace = find_text(stmt, "{", 0)
    val before = if brace >= 0: stmt.slice(0, brace) else: stmt
    val words = split_text(before.trim(), " ")
    if words.len() == 0:
        return ""
    var i = words.len() - 1
    while i >= 0:
        val word = words[i].trim()
        if word != "" and word != "extends" and word != "class":
            return word
        i = i - 1
    ""

fn declared_binding_name(stmt: text) -> text:
    val eq = find_text(stmt, "=", 0)
    val before = if eq >= 0: stmt.slice(0, eq) else: stmt
    val words = split_text(before.trim(), " ")
    if words.len() == 0:
        return ""
    words[words.len() - 1].trim()

fn strip_trailing_semicolon(text_value: text) -> text:
    if text_value.ends_with(";"):
        return text_value.slice(0, text_value.len() - 1)
    text_value

fn starts_with_word(source: text, pos: i32, word: text) -> bool:
    if pos + word.len() > source.len():
        return false
    source.slice(pos, pos + word.len()) == word

fn is_js_space(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\t" or ch == "\r"

fn append_unique_text(items: [text], value: text) -> [text]:
    if text_in_list(items, value):
        return items
    items + [value]

fn remove_text_once(items: [text], value: text) -> [text]:
    var out: [text] = []
    var removed = false
    for item in items:
        if not removed and item == value:
            removed = true
        else:
            out = out + [item]
    out

fn text_in_list(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false
