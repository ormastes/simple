# Browser session — HTML/text utilities and stylesheet handling.
#
# Free functions for:
# - extract_title_text / extract_body_inner_html / own_text / html_to_text
# - escape_html_text / escape_js_string
# - strip_script_blocks / strip_tag_block
# - _guest_runtime_probe_url / _extract_simple_js_assignment
# - BrowserStylesheetExpansion class
# - extract_stylesheet_sources / extract_attr_value / has_tag_attr / rel_contains_stylesheet
# - expand_stylesheet_text / extract_css_import_sources / strip_css_imports
# - extract_css_import_href / trim_css_import_url / insert_stylesheet_sources

use common.string_builder.{StringBuilder}
use std.gc_async_mut.web.browser_session.{BrowserStylesheetSource, BrowserStylesheetExpansion}
use std.gc_async_mut.web.browser_session_url.{find_text, resolve_relative_url}

fn extract_title_text(html: text) -> text:
    val start = find_text(html, "<title>", 0)
    if start < 0:
        return ""
    val content_start = start + 7
    val end = find_text(html, "</title>", content_start)
    if end < 0:
        return ""
    html[content_start:end].trim()

fn extract_body_inner_html(html: text) -> text:
    val body_open = find_text(html, "<body", 0)
    if body_open < 0:
        return ""
    val open_end = find_text(html, ">", body_open)
    if open_end < 0:
        return ""
    val body_close = find_text(html, "</body>", open_end + 1)
    if body_close < 0:
        return html[open_end + 1:html.len()]
    html[open_end + 1:body_close]

fn own_text(value: text) -> text:
    # Force a fresh owned text value instead of retaining a borrowed slice.
    "{value}"

fn html_to_text(html: text) -> text:
    var out = ""
    var in_tag = false
    var pos = 0
    while pos < html.len():
        val ch = html.slice(pos, pos + 1)
        if ch == "<":
            in_tag = true
        else if ch == ">":
            in_tag = false
        else if not in_tag:
            out = out + ch
        pos = pos + 1
    out.trim()

fn escape_html_text(text_value: text) -> text:
    val sb = StringBuilder.new()
    var i = 0
    while i < text_value.len():
        val ch = text_value.slice(i, i + 1)
        if ch == "&":
            sb.push("&amp;")
        else if ch == "<":
            sb.push("&lt;")
        else if ch == ">":
            sb.push("&gt;")
        else if ch == "\"":
            sb.push("&quot;")
        else:
            sb.push(ch)
        i = i + 1
    sb.to_text()

fn escape_js_string(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if ch == "\\":
            out = out + "\\\\"
        else if ch == "\"":
            out = out + "\\\""
        else:
            out = out + ch
        i = i + 1
    out

fn strip_script_blocks(html: text) -> text:
    strip_tag_block(html, "script")

fn strip_tag_block(html: text, tag_name: text) -> text:
    var result = ""
    var pos = 0
    val open_tag = "<{tag_name}"
    val close_tag = "</{tag_name}>"
    while pos < html.len():
        val start = find_text(html, open_tag, pos)
        if start < 0:
            result = "{result}{html[pos:html.len()]}"
            return result
        result = "{result}{html[pos:start]}"
        val open_end = find_text(html, ">", start)
        if open_end < 0:
            return result
        val end = find_text(html, close_tag, open_end + 1)
        if end < 0:
            return result
        pos = end + close_tag.len()
    result

fn _guest_runtime_probe_url(url: text) -> bool:
    url.starts_with("https://guest.runtime/")

fn _extract_simple_js_assignment(script: text, prefix: text) -> Option<text>:
    if not script.contains(prefix):
        return nil
    if val Some(start_idx) = script.index_of(prefix):
        val value_start = start_idx + prefix.len()
        if value_start >= script.len():
            return nil
        val quote = script[value_start:value_start + 1]
        if quote != "'" and quote != "\"":
            return nil
        val rest = script.substring(value_start + 1, script.len())
        if val Some(rel_end) = rest.index_of(quote):
            return Some(rest.substring(0, rel_end))
    nil

fn extract_attr_value(tag_content: text, attr_name: text) -> text:
    val lower = tag_content.lower()
    val needle = attr_name.lower() + "="
    val idx = find_text(lower, needle, 0)
    if idx < 0:
        return ""
    val start = idx + needle.len()
    if start >= tag_content.len():
        return ""
    val quote = tag_content.slice(start, start + 1)
    if quote == "\"" or quote == "'":
        val end = find_text(tag_content, quote, start + 1)
        if end < 0:
            return ""
        return tag_content.slice(start + 1, end)
    var end = start
    while end < tag_content.len():
        val ch = tag_content.slice(end, end + 1)
        if ch == " " or ch == ">" or ch == "\n" or ch == "\t":
            return tag_content.slice(start, end)
        end = end + 1
    tag_content.slice(start, tag_content.len())

fn has_tag_attr(tag_content: text, attr_name: text) -> bool:
    val lower = tag_content.lower()
    val padded = " " + attr_name.lower()
    lower.contains(padded + " ") or
        lower.contains(padded + ">") or
        lower.contains(padded + "=") or
        lower.ends_with(padded)

fn extract_stylesheet_sources(html: text) -> [BrowserStylesheetSource]:
    var sources: [BrowserStylesheetSource] = []
    var style_pos = 0
    while style_pos < html.len():
        val start = find_text(html, "<style", style_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val close = find_text(html, "</style>", tag_end + 1)
        if close < 0:
            break
        val content = html[tag_end + 1:close].trim()
        if content != "":
            sources.push(BrowserStylesheetSource.inline(content))
        style_pos = close + 8
    var link_pos = 0
    while link_pos < html.len():
        val start = find_text(html, "<link", link_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val tag_content = html[start:tag_end + 1]
        val rel_value = extract_attr_value(tag_content, "rel").lower()
        val href_value = extract_attr_value(tag_content, "href")
        if href_value != "" and rel_contains_stylesheet(rel_value):
            sources.push(BrowserStylesheetSource.external(href_value))
        link_pos = tag_end + 1
    sources

fn rel_contains_stylesheet(rel_value: text) -> bool:
    for part in rel_value.split(" "):
        if part.trim() == "stylesheet":
            return true
    false

fn expand_stylesheet_text(document_url: text, base_url: text, css_text: text) -> BrowserStylesheetExpansion:
    val imports = extract_css_import_sources(base_url, css_text)
    val cleaned = strip_css_imports(css_text).trim()
    val html = if cleaned != "": "<style>{cleaned}</style>" else: ""
    BrowserStylesheetExpansion.create(html, imports)

fn extract_css_import_sources(base_url: text, css_text: text) -> [BrowserStylesheetSource]:
    var sources: [BrowserStylesheetSource] = []
    var pos = 0
    while pos < css_text.len():
        val at = find_text(css_text, "@import", pos)
        if at < 0:
            return sources
        val semi = find_text(css_text, ";", at)
        if semi < 0:
            return sources
        val stmt = css_text.slice(at, semi + 1)
        val href = extract_css_import_href(stmt)
        if href != "":
            sources.push(BrowserStylesheetSource.external(resolve_relative_url(base_url, href)))
        pos = semi + 1
    sources

fn strip_css_imports(css_text: text) -> text:
    var out = ""
    var pos = 0
    while pos < css_text.len():
        val at = find_text(css_text, "@import", pos)
        if at < 0:
            return out + css_text.slice(pos, css_text.len())
        out = out + css_text.slice(pos, at)
        val semi = find_text(css_text, ";", at)
        if semi < 0:
            return out
        pos = semi + 1
    out

fn extract_css_import_href(stmt: text) -> text:
    val url_idx = find_text(stmt.lower(), "url(", 0)
    if url_idx >= 0:
        val close = find_text(stmt, ")", url_idx + 4)
        if close > url_idx:
            return trim_css_import_url(stmt.slice(url_idx + 4, close))
    val single = find_text(stmt, "'", 0)
    if single >= 0:
        val end = find_text(stmt, "'", single + 1)
        if end > single:
            return stmt.slice(single + 1, end)
    val double = find_text(stmt, "\"", 0)
    if double >= 0:
        val end = find_text(stmt, "\"", double + 1)
        if end > double:
            return stmt.slice(double + 1, end)
    ""

fn trim_css_import_url(value: text) -> text:
    var trimmed = value.trim()
    if trimmed.starts_with("'") and trimmed.ends_with("'") and trimmed.len() >= 2:
        trimmed = trimmed.slice(1, trimmed.len() - 1)
    else if trimmed.starts_with("\"") and trimmed.ends_with("\"") and trimmed.len() >= 2:
        trimmed = trimmed.slice(1, trimmed.len() - 1)
    trimmed

fn insert_stylesheet_sources(existing: [BrowserStylesheetSource], index: i32, additions: [BrowserStylesheetSource]) -> [BrowserStylesheetSource]:
    if additions.len() == 0:
        return existing
    var out: [BrowserStylesheetSource] = []
    var i = 0
    while i < existing.len():
        if i == index:
            for addition in additions:
                out.push(addition)
        out.push(existing[i])
        i = i + 1
    if index >= existing.len():
        for addition in additions:
            out.push(addition)
    out
