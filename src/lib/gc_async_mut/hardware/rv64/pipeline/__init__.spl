"""
RV64I 5-stage pipeline: IF -> ID -> EX -> MEM -> WB.

Modules:
  types      -- Shared data structures (register file, latches, memory)
  decoder    -- RV64I instruction decoder and encoding helpers
  if_stage   -- Instruction Fetch
  id_stage   -- Instruction Decode
  ex_stage   -- Execute (64-bit ALU)
  mem_stage  -- Memory Access
  wb_stage   -- Writeback
"""

export types
export decoder
export if_stage
export id_stage
export ex_stage
export mem_stage
export wb_stage
