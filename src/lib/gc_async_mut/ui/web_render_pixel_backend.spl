# Shared facade from WebRenderRequest envelopes to Simple Web pixels.
#
# This module intentionally sits above the concrete browser-engine renderer so
# UI and compositor code can depend on the common web-render API shape without
# importing the low-level Simple Web renderer directly.

use std.common.ui.web_render_api.{
    WEB_RENDER_QUEUE_STATUS_DRAINED,
    WEB_RENDER_QUEUE_STATUS_NOT_REQUESTED,
    WEB_RENDER_QUEUE_STATUS_SUBMITTED,
    WEB_RENDER_QUEUE_STATUS_UNAVAILABLE,
    WEB_RENDER_TARGET_PURE_SIMPLE,
    WebRenderArtifact,
    WebRenderRequest,
    web_render_artifact_with_backend_readback_source,
    web_render_artifact_with_runtime_queue_handle,
    web_render_dynamic_region_count,
    web_render_engine2d_rendered_artifact,
    web_render_engine2d_unavailable_artifact,
    web_render_full_html,
    web_render_pixel_artifact,
    web_render_url_request
}
use std.common.ui.draw_ir.{DrawIrComposition}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels,
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_render_html_to_readback_with_engine2d_backend,
    simple_web_render_url_to_pixels,
    simple_web_resolved_engine2d_backend_name
}
use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{SimpleWebEngine2DStaticPixelCache}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{engine2d_draw_ir_adv_composition}
use std.gc_async_mut.gpu.engine2d.backend_lane.{
    ENGINE2D_HOST_GPU_LANE_GPU,
    ENGINE2D_HOST_GPU_LANE_HOST,
    engine2d_host_gpu_lane_schedule
}
use std.gc_async_mut.gpu.engine2d.host_gpu_event_queue.{
    engine2d_host_gpu_event,
    engine2d_host_gpu_event_handler_decision,
    engine2d_host_gpu_event_submit_to_runtime_payload_text,
    engine2d_host_gpu_runtime_drain,
    engine2d_host_gpu_runtime_queue_with_backend_handle
}

fn web_render_runtime_queue_available(backend_name: text) -> bool:
    if backend_name == "metal":
        return true
    if backend_name == "cuda":
        return true
    if backend_name == "rocm" or backend_name == "hip":
        return true
    if backend_name == "vulkan":
        return true
    false

fn web_render_backend_readback_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = (checksum + pixels[i].to_i64() * (i.to_i64() + 1)) % 2147483647
        i = i + 1
    checksum

fn web_render_proven_backend_name(requested_backend: text, backend_handle: i64, readback_source: text) -> text:
    if readback_source == "device_readback" and backend_handle > 0:
        return requested_backend
    "software"

fn web_render_artifact_with_backend_readback_source_evidence(artifact: WebRenderArtifact, backend_name: text, source: text) -> WebRenderArtifact:
    if artifact.pixels.len() == 0:
        return artifact
    val receipt_source = if source == "": "engine2d_pixel_readback" else: source
    web_render_artifact_with_backend_readback_source(artifact, "readback", backend_name, artifact.pixels.len().to_i64(), web_render_backend_readback_checksum(artifact.pixels), "same-frame Engine2D read_pixels", receipt_source)

fn web_render_artifact_with_runtime_queue_evidence(artifact: WebRenderArtifact, backend_name: text, backend_handle: i64, readback_source: text) -> WebRenderArtifact:
    if not web_render_runtime_queue_available(backend_name) or readback_source != "device_readback" or backend_handle <= 0:
        return artifact
    val packet_bytes = artifact.viewport_w.to_i64() * artifact.viewport_h.to_i64() * 4
    val queue = engine2d_host_gpu_runtime_queue_with_backend_handle(backend_name, 1, backend_handle, true, packet_bytes + 4096)
    val lane_result = engine2d_host_gpu_lane_schedule(
        ENGINE2D_HOST_GPU_LANE_HOST,
        ENGINE2D_HOST_GPU_LANE_GPU,
        "frame_batch",
        packet_bytes,
        queue.max_packet_bytes,
        false,
        false,
        true,
        1
    )
    val event = engine2d_host_gpu_event("web-render-frame", ENGINE2D_HOST_GPU_LANE_GPU, "frame_batch", packet_bytes, queue.max_packet_bytes, false, false, false, true)
    val decision = engine2d_host_gpu_event_handler_decision(event, lane_result)
    val payload_text = "web-render-frame;backend={backend_name};pixels={artifact.pixels.len()};checksum={artifact.readback_checksum}"
    val submit = engine2d_host_gpu_event_submit_to_runtime_payload_text(queue, decision, lane_result, artifact.readback_checksum, payload_text)
    val drain = if submit.submitted: engine2d_host_gpu_runtime_drain(queue, 1) else: engine2d_host_gpu_runtime_drain(queue, 0)
    if not submit.submitted or drain.drained <= 0 or drain.last_backend_handle != backend_handle or drain.last_payload_size != packet_bytes or drain.last_payload_hash != artifact.readback_checksum or drain.last_payload_text != payload_text:
        return artifact
    web_render_artifact_with_runtime_queue_handle(artifact, WEB_RENDER_QUEUE_STATUS_SUBMITTED, WEB_RENDER_QUEUE_STATUS_DRAINED, submit.packet_id, drain.drained, drain.last_backend_handle, drain.diagnostic)

pub fn web_render_draw_ir_request_to_pixel_artifact(req: WebRenderRequest, composition: DrawIrComposition, backend_name: text) -> WebRenderArtifact:
    val backend = simple_web_resolved_engine2d_backend_name(req.viewport_w, req.viewport_h, backend_name)
    val empty = web_render_pixel_artifact(req.with_pixel_output(), [])
    if req.viewport_w <= 0 or req.viewport_h <= 0:
        return web_render_engine2d_unavailable_artifact(empty, backend, "invalid Draw IR viewport")
    var engine = Engine2D.create_with_backend_fast(req.viewport_w, req.viewport_h, backend)
    engine.clear(0u32)
    val selected = engine.backend_name()
    val result = engine2d_draw_ir_adv_composition(engine, composition, true)
    engine.shutdown()
    if result.skipped_command_count != 0 or result.pixels.len() != req.viewport_w * req.viewport_h:
        return web_render_engine2d_unavailable_artifact(empty, selected, "Draw IR execution incomplete")
    val proven_backend = web_render_proven_backend_name(selected, result.backend_handle, result.readback_source)
    val rendered = web_render_engine2d_rendered_artifact(web_render_pixel_artifact(req.with_pixel_output(), result.pixels), proven_backend)
    val artifact = web_render_artifact_with_backend_readback_source_evidence(rendered, proven_backend, result.readback_source)
    web_render_artifact_with_runtime_queue_evidence(artifact, proven_backend, result.backend_handle, result.readback_source)

class WebRenderPixelArtifactCache:
    width: i32
    height: i32
    backend_name: text
    resolved_backend_name: text
    pixel_cache: SimpleWebEngine2DStaticPixelCache

impl WebRenderPixelArtifactCache:
    static fn create(width: i32, height: i32, backend_name: text) -> WebRenderPixelArtifactCache:
        val resolved = web_render_resolved_engine2d_backend_name(width, height, backend_name)
        WebRenderPixelArtifactCache(
            width: width,
            height: height,
            backend_name: backend_name,
            resolved_backend_name: resolved,
            pixel_cache: SimpleWebEngine2DStaticPixelCache.create(width, height, resolved)
        )

    me html_request_to_pixel_artifact(req: WebRenderRequest, full_html: text) -> WebRenderArtifact:
        if req.viewport_w != self.width or req.viewport_h != self.height:
            return web_render_html_request_to_pixel_artifact_with_backend(req, full_html, self.backend_name)
        if web_render_dynamic_region_count(req) > 0:
            return web_render_html_request_to_pixel_artifact_with_backend(req, full_html, self.backend_name)
        val pixels = self.pixel_cache.pixels_for_html(full_html)
        val rendered = web_render_engine2d_rendered_artifact(web_render_pixel_artifact(req.with_pixel_output(), pixels), "software")
        web_render_artifact_with_backend_readback_source(rendered, "readback", "software", pixels.len().to_i64(), web_render_backend_readback_checksum(pixels), "cached Engine2D pixel mirror", "cpu_mirror")

    me request_to_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
        self.html_request_to_pixel_artifact(req, web_render_full_html(req))

    fn hits() -> i32:
        self.pixel_cache.hits

    fn stores() -> i32:
        self.pixel_cache.stores

pub fn web_render_request_to_pixels(req: WebRenderRequest) -> [u32]:
    simple_web_render_html_to_pixels(web_render_full_html(req), req.viewport_w, req.viewport_h)

pub fn web_render_request_to_pixels_with_backend(req: WebRenderRequest, backend_name: text) -> [u32]:
    simple_web_render_html_to_pixels_with_engine2d_backend(web_render_full_html(req), req.viewport_w, req.viewport_h, backend_name)

pub fn web_render_html_request_to_pixels(req: WebRenderRequest, full_html: text) -> [u32]:
    simple_web_render_html_to_pixels(full_html, req.viewport_w, req.viewport_h)

pub fn web_render_html_request_to_pixels_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> [u32]:
    simple_web_render_html_to_pixels_with_engine2d_backend(full_html, req.viewport_w, req.viewport_h, backend_name)

pub fn web_render_request_to_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
    val backend = web_render_resolved_engine2d_backend_name(req.viewport_w, req.viewport_h, "auto")
    val readback = simple_web_render_html_to_readback_with_engine2d_backend(web_render_full_html(req), req.viewport_w, req.viewport_h, backend)
    val proven_backend = web_render_proven_backend_name(backend, readback.backend_handle, readback.source)
    val artifact = web_render_artifact_with_backend_readback_source_evidence(web_render_engine2d_rendered_artifact(web_render_pixel_artifact(req.with_pixel_output(), readback.pixels), proven_backend), proven_backend, readback.source)
    web_render_artifact_with_runtime_queue_evidence(artifact, proven_backend, readback.backend_handle, readback.source)

pub fn web_render_html_request_to_pixel_artifact(req: WebRenderRequest, full_html: text) -> WebRenderArtifact:
    val backend = web_render_resolved_engine2d_backend_name(req.viewport_w, req.viewport_h, "auto")
    val readback = simple_web_render_html_to_readback_with_engine2d_backend(full_html, req.viewport_w, req.viewport_h, backend)
    val proven_backend = web_render_proven_backend_name(backend, readback.backend_handle, readback.source)
    val artifact = web_render_artifact_with_backend_readback_source_evidence(web_render_engine2d_rendered_artifact(web_render_pixel_artifact(req.with_pixel_output(), readback.pixels), proven_backend), proven_backend, readback.source)
    web_render_artifact_with_runtime_queue_evidence(artifact, proven_backend, readback.backend_handle, readback.source)

pub fn web_render_html_request_to_pixel_artifact_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> WebRenderArtifact:
    val backend = web_render_resolved_engine2d_backend_name(req.viewport_w, req.viewport_h, backend_name)
    val readback = simple_web_render_html_to_readback_with_engine2d_backend(full_html, req.viewport_w, req.viewport_h, backend_name)
    val proven_backend = web_render_proven_backend_name(backend, readback.backend_handle, readback.source)
    val artifact = web_render_artifact_with_backend_readback_source_evidence(web_render_engine2d_rendered_artifact(web_render_pixel_artifact(req.with_pixel_output(), readback.pixels), proven_backend), proven_backend, readback.source)
    web_render_artifact_with_runtime_queue_evidence(artifact, proven_backend, readback.backend_handle, readback.source)

pub fn web_render_pixel_artifact_cache(width: i32, height: i32, backend_name: text) -> WebRenderPixelArtifactCache:
    WebRenderPixelArtifactCache.create(width, height, backend_name)

pub fn web_render_url_request_to_pixels(req: WebRenderRequest) -> [u32]:
    web_render_request_to_pixels(req.with_pixel_output())

pub fn web_render_url_to_request(target: text, url: text, width: i32, height: i32) -> WebRenderRequest:
    web_render_url_request(target, url, width, height).with_pixel_output()

pub fn web_render_url_to_pixels(url: text, width: i64, height: i64) -> [u8]:
    simple_web_render_url_to_pixels(url, width, height)

pub fn web_render_default_page_html(url: text) -> text:
    web_render_full_html(web_render_url_request(WEB_RENDER_TARGET_PURE_SIMPLE, url, 0, 0))

pub fn web_render_resolved_engine2d_backend_name(width: i32, height: i32, backend_name: text) -> text:
    simple_web_resolved_engine2d_backend_name(width, height, backend_name)
