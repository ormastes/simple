# Pure-Simple software WebRender facade for production WM entry closures.
use std.common.ui.web_render_api.{
    WEB_RENDER_TARGET_PURE_SIMPLE,
    WebRenderArtifact,
    WebRenderMaterialFallbackProvenance,
    WebRenderRequest,
    web_render_artifact_with_material_fallback,
    web_render_engine2d_compatibility_artifact,
    web_render_full_html,
    web_render_pixel_artifact,
    web_render_url_request
}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    SimpleWebLayoutPixelResult,
    simple_web_layout_render_html_software_pixels,
    simple_web_layout_render_html_software_result
}
use std.common.ui.glyph_bitmap_5x7.{glyph_index_for_char_code, glyph_row_bits}

fn _native_safe_wm_pixels(req: WebRenderRequest, full_html: text) -> [u32]:
    val width = req.viewport_w
    val height = req.viewport_h
    if width <= 0 or height <= 0:
        return []
    val background = 0xFF182230u32
    val foreground = 0xFFE5E7EBu32
    val accent = 0xFF60A5FAu32
    var pixels: [u32] = [background; width * height]
    var x: i32 = 10
    var y: i32 = 10
    var i = 0
    var skip_style = false
    var heading = false
    while i < full_html.len() and y + 14 < height:
        val code = full_html.char_code_at(i)
        if code == 60:
            val closing = i + 1 < full_html.len() and full_html.char_code_at(i + 1) == 47
            val first = i + (if closing: 2 else: 1)
            val c0 = if first < full_html.len(): full_html.char_code_at(first) else: 0
            val c1 = if first + 1 < full_html.len(): full_html.char_code_at(first + 1) else: 0
            if c0 == 115 and c1 == 116:
                skip_style = not closing
            if c0 == 104 and c1 >= 49 and c1 <= 54:
                heading = not closing
                x = 10
                y = y + 18
            elif closing or c0 == 98 or c0 == 112 or c0 == 100:
                x = 10
                y = y + 16
            while i < full_html.len() and full_html.char_code_at(i) != 62:
                i = i + 1
            i = i + 1
        elif skip_style:
            i = i + 1
        elif code == 10 or code == 13:
            x = 10
            y = y + 16
            i = i + 1
        elif code == 32 or code == 9:
            x = x + 12
            if x + 12 >= width:
                x = 10
                y = y + 16
            i = i + 1
        else:
            if x + 10 >= width:
                x = 10
                y = y + 16
            val glyph = glyph_index_for_char_code(code as i32)
            var row = 0
            while row < 7:
                val bits = glyph_row_bits(glyph, row)
                var col = 0
                while col < 5:
                    if (bits & (1 << (4 - col))) != 0:
                        val color = if heading: accent else: foreground
                        val px = x + col * 2
                        val py = y + row * 2
                        if px >= 0 and py >= 0 and px + 1 < width and py + 1 < height:
                            pixels[py * width + px] = color
                            pixels[py * width + px + 1] = color
                            pixels[(py + 1) * width + px] = color
                            pixels[(py + 1) * width + px + 1] = color
                    col = col + 1
                row = row + 1
            x = x + 12
            i = i + 1
    pixels

fn _software_pixels(req: WebRenderRequest, full_html: text) -> [u32]:
    simple_web_layout_render_html_software_pixels(full_html, req.viewport_w, req.viewport_h)

fn _software_result(req: WebRenderRequest, full_html: text) -> SimpleWebLayoutPixelResult:
    simple_web_layout_render_html_software_result(full_html, req.viewport_w, req.viewport_h)

# _native_safe_wm_pixels is a degraded tag-stripping/bitmap-glyph renderer
# meant only as an explicit crash-recovery fallback when the full HTML
# layout engine (_software_pixels) cannot be used. Its artifact is stamped
# with engine2d_status=compatibility_renderer and engine2d_backend
# ="native-safe-fallback" so evidence capture / pixel-diff tooling can
# detect and reject a fallback frame that leaked into a path expecting the
# real renderer, instead of silently treating tag-strip output as authentic.
fn _native_safe_fallback_provenance(base: WebRenderArtifact) -> WebRenderArtifact:
    web_render_engine2d_compatibility_artifact(base, "native-safe-fallback", "tag-strip bitmap-glyph fallback renderer (crash-recovery path, not the full HTML layout engine)")

class WebRenderPixelArtifactCache:
    width: i32
    height: i32
    backend_name: text
    last_html: text
    cached_pixels: [u32]
    cached_material_fallback: WebRenderMaterialFallbackProvenance
    hit_count: i32
    store_count: i32

impl WebRenderPixelArtifactCache:
    static fn create(width: i32, height: i32, backend_name: text) -> WebRenderPixelArtifactCache:
        WebRenderPixelArtifactCache(
            width: width,
            height: height,
            backend_name: "software",
            last_html: "",
            cached_pixels: [],
            cached_material_fallback: WebRenderMaterialFallbackProvenance.none(),
            hit_count: 0,
            store_count: 0
        )

    me html_request_to_pixel_artifact(req: WebRenderRequest, full_html: text) -> WebRenderArtifact:
        if req.viewport_w == self.width and req.viewport_h == self.height and self.last_html == full_html and self.cached_pixels.len() == self.width * self.height:
            self.hit_count = self.hit_count + 1
        else:
            self.width = req.viewport_w
            self.height = req.viewport_h
            self.last_html = full_html
            val result = _software_result(req, full_html)
            self.cached_pixels = result.pixels
            self.cached_material_fallback = result.material_fallback
            self.store_count = self.store_count + 1
        web_render_artifact_with_material_fallback(
            web_render_pixel_artifact(req.with_pixel_output(), self.cached_pixels),
            self.cached_material_fallback
        )

    me request_to_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
        self.html_request_to_pixel_artifact(req, web_render_full_html(req))

    # Explicit crash-recovery fallback only — see _native_safe_fallback_provenance.
    # Production content-frame rendering should use request_to_pixel_artifact
    # (the full HTML layout engine) instead; this tag-strip path must be
    # invoked explicitly by a caller that has actually hit the failure mode
    # it exists for, not wired in as a default.
    me request_to_native_safe_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
        val full_html = web_render_full_html(req)
        if req.viewport_w == self.width and req.viewport_h == self.height and self.last_html == full_html and self.cached_pixels.len() == self.width * self.height:
            self.hit_count = self.hit_count + 1
        else:
            self.width = req.viewport_w
            self.height = req.viewport_h
            self.last_html = full_html
            self.cached_pixels = _native_safe_wm_pixels(req, full_html)
            self.store_count = self.store_count + 1
        _native_safe_fallback_provenance(web_render_pixel_artifact(req.with_pixel_output(), self.cached_pixels))

    fn hits() -> i32:
        self.hit_count

    fn stores() -> i32:
        self.store_count

fn web_render_request_to_pixels(req: WebRenderRequest) -> [u32]:
    _software_pixels(req, web_render_full_html(req))

fn web_render_request_to_pixels_with_backend(req: WebRenderRequest, backend_name: text) -> [u32]:
    web_render_request_to_pixels(req)

fn web_render_html_request_to_pixels(req: WebRenderRequest, full_html: text) -> [u32]:
    _software_pixels(req, full_html)

fn web_render_html_request_to_pixels_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> [u32]:
    _software_pixels(req, full_html)

fn web_render_request_to_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
    val result = _software_result(req, web_render_full_html(req))
    web_render_artifact_with_material_fallback(
        web_render_pixel_artifact(req.with_pixel_output(), result.pixels),
        result.material_fallback
    )

fn web_render_request_to_native_safe_pixel_artifact(req: WebRenderRequest) -> WebRenderArtifact:
    _native_safe_fallback_provenance(web_render_pixel_artifact(req.with_pixel_output(), _native_safe_wm_pixels(req, web_render_full_html(req))))

fn web_render_html_request_to_pixel_artifact(req: WebRenderRequest, full_html: text) -> WebRenderArtifact:
    val result = _software_result(req, full_html)
    web_render_artifact_with_material_fallback(
        web_render_pixel_artifact(req.with_pixel_output(), result.pixels),
        result.material_fallback
    )

fn web_render_html_request_to_pixel_artifact_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> WebRenderArtifact:
    web_render_html_request_to_pixel_artifact(req, full_html)

fn web_render_pixel_artifact_cache(width: i32, height: i32, backend_name: text) -> WebRenderPixelArtifactCache:
    WebRenderPixelArtifactCache.create(width, height, "software")

fn web_render_url_request_to_pixels(req: WebRenderRequest) -> [u32]:
    web_render_request_to_pixels(req.with_pixel_output())

fn web_render_url_to_request(target: text, url: text, width: i32, height: i32) -> WebRenderRequest:
    web_render_url_request(target, url, width, height).with_pixel_output()

fn web_render_default_page_html(url: text) -> text:
    web_render_full_html(web_render_url_request(WEB_RENDER_TARGET_PURE_SIMPLE, url, 0, 0))

fn web_render_resolved_engine2d_backend_name(width: i32, height: i32, backend_name: text) -> text:
    "software"
