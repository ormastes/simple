use std.storage.shared.btree.{BTree, BTreeKey}

struct NsDentryKey:
    parent_ino: i64
    name_hash:  i64

struct NsIno:
    value: i64

struct BTreeValue:
    value: i64
    gen:   i64

struct NsBTreeSnapshot:
    gen: i64

fn ns_dentry_to_btk(key: NsDentryKey) -> BTreeKey:
    BTreeKey(a: key.parent_ino, b: key.name_hash)

fn ns_dentry_from_btk(key: BTreeKey) -> NsDentryKey:
    NsDentryKey(parent_ino: key.a, name_hash: key.b)

struct NsBTree:
    inner: BTree<BTreeValue>

    static fn new() -> NsBTree:
        NsBTree(inner: BTree<BTreeValue>.new(4))

    me fn lookup(key: NsDentryKey) -> Option<BTreeValue>:
        me.inner.lookup(ns_dentry_to_btk(key))

    me fn current_gen() -> i64:
        me.inner.current_gen()

    me fn lookup_at_gen(key: NsDentryKey, target_gen: i64) -> Option<BTreeValue>:
        val opt = me.inner.lookup(ns_dentry_to_btk(key))
        match opt:
            case None: None
            case Some(v):
                if v.gen <= target_gen:
                    Some(v)
                else:
                    None

    me fn insert(key: NsDentryKey, ino: NsIno) -> Result<(), text>:
        val cur_gen = me.inner.next_gen
        me.inner.insert(ns_dentry_to_btk(key), BTreeValue(value: ino.value, gen: cur_gen))

    me fn delete(key: NsDentryKey) -> Result<(), text>:
        me.inner.delete(ns_dentry_to_btk(key))

    me fn range_scan(lo: NsDentryKey, hi: NsDentryKey) -> Result<[(NsDentryKey, BTreeValue)], text>:
        val raw = me.inner.range_scan(ns_dentry_to_btk(lo), ns_dentry_to_btk(hi))?
        var result: [(NsDentryKey, BTreeValue)] = []
        for pair in raw:
            result.push((ns_dentry_from_btk(pair.0), pair.1))
        Ok(result)

    me fn snapshot() -> NsBTreeSnapshot:
        NsBTreeSnapshot(gen: me.inner.next_gen - 1)

    me fn lookup_at_snapshot(key: NsDentryKey, snap: NsBTreeSnapshot) -> Option<BTreeValue>:
        me.lookup_at_gen(key, snap.gen)
