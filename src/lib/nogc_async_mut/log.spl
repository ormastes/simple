"""
# No-GC Async Log

Compatibility facade over the no-GC sync logging backend.
"""

export use std.nogc_sync_mut.log.{
    LOG_OFF, LOG_FATAL, LOG_ERROR, LOG_WARN, LOG_INFO,
    LOG_DEBUG, LOG_TRACE, LOG_VERBOSE, LOG_ALL,
    GLOBAL_LOG_LEVEL, SCOPE_LEVELS,
    get_log_level, level_name, parse_level, set_level,
    get_global_level, set_scope_level, get_level, clear_scopes,
    is_enabled, fatal, error, warn, info, debug, trace, verbose,
    log_info, log_error, log_debug, log_verbose, log
}
