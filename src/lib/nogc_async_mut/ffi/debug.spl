"""
# No-GC async FFI debug

Compatibility facade over the no-GC sync backend boundary.
"""

export use std.nogc_sync_mut.ffi.debug.{
    debug_is_active, debug_set_active, debug_set_step_mode,
    debug_get_step_mode, debug_set_step_start_depth,
    debug_get_step_start_depth, debug_pause, debug_continue,
    debug_is_paused, debug_wait_for_continue, debug_set_current_location,
    debug_current_file, debug_current_line, debug_current_column,
    debug_add_breakpoint, debug_remove_breakpoint, debug_clear_breakpoints,
    debug_has_breakpoint, debug_should_break, debug_push_frame,
    debug_pop_frame, debug_stack_depth, debug_stack_trace,
    debug_set_local, debug_set_global, debug_locals, debug_globals,
    debug_clear_locals, debug_clear_globals,
    ptrace_attach, ptrace_detach, ptrace_continue, ptrace_single_step,
    ptrace_wait_stop, ptrace_get_registers, ptrace_read_memory,
    ptrace_write_memory, dwarf_load, dwarf_free, dwarf_addr_to_line,
    dwarf_line_to_addr, dwarf_function_at, dwarf_locals_at
}
