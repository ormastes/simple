"""
# No-GC Async Thread Facade

Thread operations are synchronous runtime primitives, so the async family
reuses the no-GC sync runtime-hook owner instead of declaring duplicate hooks.
"""

export use std.nogc_sync_mut.concurrent.thread.{
    ThreadHandle,
    thread_spawn,
    thread_spawn_with_args,
    thread_spawn2,
    thread_available_parallelism,
    thread_sleep,
    thread_yield
}
