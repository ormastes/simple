# Concurrent Collections Module - Pure Simple Compatibility
# @tag:stdlib
# @tag:api
#
# The compatibility API keeps the historical collection names but stores data in
# pure Simple containers. Hosted thread synchronization belongs in the
# concurrency primitives; this module no longer owns Rust collection handles.

class HashMap:
    entries_: [BTreeEntry]

    me insert(key: text, value: Any) -> bool:
        for i in 0..self.entries_.len():
            if self.entries_[i].key == key:
                self.entries_[i] = BTreeEntry(key: key, value: value)
                return false
        self.entries_.append(BTreeEntry(key: key, value: value))
        true

    fn get(key: text) -> Any:
        for entry in self.entries_:
            if entry.key == key:
                return entry.value
        nil

    fn contains_key(key: text) -> bool:
        for entry in self.entries_:
            if entry.key == key:
                return true
        false

    me remove(key: text) -> Any:
        for i in 0..self.entries_.len():
            if self.entries_[i].key == key:
                val value = self.entries_[i].value
                self.entries_ = _btree_entries_remove(self.entries_, i)
                return value
        nil

    fn len() -> i64:
        self.entries_.len() as i64

    fn keys() -> Any:
        var result: [text] = []
        for entry in self.entries_:
            result.append(entry.key)
        result

    fn values() -> Any:
        var result: [Any] = []
        for entry in self.entries_:
            result.append(entry.value)
        result

    fn entries() -> Any:
        var result: [(text, Any)] = []
        for entry in self.entries_:
            result.append((entry.key, entry.value))
        result

class HashSet:
    values_: [text]

    me insert(value: text) -> bool:
        for item in self.values_:
            if item == value:
                return false
        self.values_.append(value)
        true

    fn contains(value: text) -> bool:
        for item in self.values_:
            if item == value:
                return true
        false

    me remove(value: text) -> bool:
        for i in 0..self.values_.len():
            if self.values_[i] == value:
                self.values_ = _text_array_remove(self.values_, i)
                return true
        false

    fn len() -> i64:
        self.values_.len() as i64

    fn to_array() -> Any:
        self.values_

    fn intersection(other: HashSet) -> HashSet:
        var result = HashSet(values_: [])
        for item in self.values_:
            if other.contains(item):
                result.insert(item)
        result

    fn difference(other: HashSet) -> HashSet:
        var result = HashSet(values_: [])
        for item in self.values_:
            if not other.contains(item):
                result.insert(item)
        result

    fn symmetric_difference(other: HashSet) -> HashSet:
        var result = self.difference(other)
        val other_only = other.difference(self)
        for item in other_only.values_:
            result.insert(item)
        result

    fn is_subset(other: HashSet) -> bool:
        for item in self.values_:
            if not other.contains(item):
                return false
        true

    fn is_superset(other: HashSet) -> bool:
        other.is_subset(self)

    fn drop():
        ()

struct BTreeEntry:
    key: text
    value: Any

class BTreeMap:
    entries_: [BTreeEntry]

    me insert(key: text, value: Any) -> bool:
        for i in 0..self.entries_.len():
            if self.entries_[i].key == key:
                self.entries_[i] = BTreeEntry(key: key, value: value)
                return false
            if key < self.entries_[i].key:
                self.entries_ = _btree_entries_insert(self.entries_, i, BTreeEntry(key: key, value: value))
                return true
        self.entries_.append(BTreeEntry(key: key, value: value))
        true

    fn get(key: text) -> Any:
        for entry in self.entries_:
            if entry.key == key:
                return entry.value
        nil

    fn contains_key(key: text) -> bool:
        for entry in self.entries_:
            if entry.key == key:
                return true
        false

    me remove(key: text) -> Any:
        for i in 0..self.entries_.len():
            if self.entries_[i].key == key:
                val value = self.entries_[i].value
                self.entries_ = _btree_entries_remove(self.entries_, i)
                return value
        nil

    fn len() -> i64:
        self.entries_.len() as i64

    me clear() -> bool:
        self.entries_ = []
        true

    fn keys() -> Any:
        var result: [text] = []
        for entry in self.entries_:
            result.append(entry.key)
        result

    fn values() -> Any:
        var result: [Any] = []
        for entry in self.entries_:
            result.append(entry.value)
        result

    fn entries() -> Any:
        var result: [(text, Any)] = []
        for entry in self.entries_:
            result.append((entry.key, entry.value))
        result

    fn first_key() -> Any:
        if self.entries_.len() == 0:
            return nil
        self.entries_[0].key

    fn last_key() -> Any:
        val n = self.entries_.len()
        if n == 0:
            return nil
        self.entries_[n - 1].key

class BTreeSet:
    values_: [text]

    me insert(value: text) -> bool:
        for i in 0..self.values_.len():
            if self.values_[i] == value:
                return false
            if value < self.values_[i]:
                self.values_ = _text_array_insert(self.values_, i, value)
                return true
        self.values_.append(value)
        true

    fn contains(value: text) -> bool:
        for item in self.values_:
            if item == value:
                return true
        false

    me remove(value: text) -> bool:
        for i in 0..self.values_.len():
            if self.values_[i] == value:
                self.values_ = _text_array_remove(self.values_, i)
                return true
        false

    fn len() -> i64:
        self.values_.len() as i64

    me clear() -> bool:
        self.values_ = []
        true

    fn to_array() -> Any:
        self.values_

    fn first() -> Any:
        if self.values_.len() == 0:
            return nil
        self.values_[0]

    fn last() -> Any:
        val n = self.values_.len()
        if n == 0:
            return nil
        self.values_[n - 1]

    fn union(other: BTreeSet) -> BTreeSet:
        var result = BTreeSet(values_: [])
        for item in self.values_:
            result.insert(item)
        for item in other.values_:
            result.insert(item)
        result

    fn intersection(other: BTreeSet) -> BTreeSet:
        var result = BTreeSet(values_: [])
        for item in self.values_:
            if other.contains(item):
                result.insert(item)
        result

    fn difference(other: BTreeSet) -> BTreeSet:
        var result = BTreeSet(values_: [])
        for item in self.values_:
            if not other.contains(item):
                result.insert(item)
        result

    fn symmetric_difference(other: BTreeSet) -> BTreeSet:
        var result = self.difference(other)
        val other_only = other.difference(self)
        for item in other_only.values_:
            result.insert(item)
        result

    fn is_subset(other: BTreeSet) -> bool:
        for item in self.values_:
            if not other.contains(item):
                return false
        true

    fn is_superset(other: BTreeSet) -> bool:
        other.is_subset(self)

fn _btree_entries_insert(items: [BTreeEntry], idx: i64, value: BTreeEntry) -> [BTreeEntry]:
    var result: [BTreeEntry] = []
    for i in 0..items.len():
        if i == idx:
            result.append(value)
        result.append(items[i])
    if idx >= items.len():
        result.append(value)
    result

fn _btree_entries_remove(items: [BTreeEntry], idx: i64) -> [BTreeEntry]:
    var result: [BTreeEntry] = []
    for i in 0..items.len():
        if i != idx:
            result.append(items[i])
    result

fn _text_array_insert(items: [text], idx: i64, value: text) -> [text]:
    var result: [text] = []
    for i in 0..items.len():
        if i == idx:
            result.append(value)
        result.append(items[i])
    if idx >= items.len():
        result.append(value)
    result

fn _text_array_remove(items: [text], idx: i64) -> [text]:
    var result: [text] = []
    for i in 0..items.len():
        if i != idx:
            result.append(items[i])
    result

fn hashmap_new() -> HashMap:
    HashMap(entries_: [])

fn hashset_new() -> HashSet:
    HashSet(values_: [])

fn btreemap_new() -> BTreeMap:
    BTreeMap(entries_: [])

fn btreeset_new() -> BTreeSet:
    BTreeSet(values_: [])
