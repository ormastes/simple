# Cooperative Green - semantic facade for the single-carrier green queue.
#
# This module names the implemented cooperative model explicitly. It delegates
# to std.concurrent.green_thread, which runs queued work on the current OS
# thread and does not provide CPU parallelism or preemption.

export use std.concurrent.green_thread.{
    GreenThreadHandle,
    green_spawn,
    green_spawn_value,
    green_ready_count,
    green_run_one,
    green_run_all
}

fn cooperative_green_spawn(task: fn() -> i64) -> GreenThreadHandle:
    """Schedule a closure on the cooperative green-thread queue."""
    green_spawn(task)

fn cooperative_green_spawn_value(result: i64) -> GreenThreadHandle:
    """Schedule an already computed result on the cooperative green queue."""
    green_spawn_value(result)

fn cooperative_green_ready_count() -> usize:
    """Return the number of cooperative green tasks ready to run."""
    green_ready_count()

fn cooperative_green_run_one() -> bool:
    """Run one ready cooperative green task to completion."""
    green_run_one()

fn cooperative_green_run_all() -> usize:
    """Run all currently ready cooperative green tasks."""
    green_run_all()
