# Cooperative Green Thread Module
# @tag:stdlib
# @tag:api
#
# Green threads are scheduled cooperatively in the current OS thread. They are
# cheaper than OS threads, but they do not run in parallel and cannot preempt a
# long-running closure.
#
# SCHEDULER STATE: All mutable scheduler state is held in a single module-level
# GreenScheduler instance (GREEN_SCHEDULER). The three counters that were
# previously bare module-level vars (GREEN_NEXT_ID, GREEN_VALUE_READY_COUNT,
# GREEN_VALUE_DONE_COUNT) are now fields of that struct, so cross-task state
# sharing is encapsulated in one named value rather than three scattered globals.
#
# COOPERATIVE DEFERRAL (E6): green_spawn(fn) stores the closure in a module-level
# task table (GREEN_TASKS: [GreenTask]) keyed by task_id and does NOT evaluate
# the closure at spawn time. The scheduler's green_run_one / green_run_all execute
# pending tasks one-by-one. Errors in one task are recorded as a per-task death
# reason (mirrors the W2-5 TaskDeathRecord pattern in async_host/scheduler.spl)
# and do not prevent sibling tasks from running.
#
# THUNK STORAGE: fn() -> i64 stored in a class field works in interpreter mode
# (empirically verified 2026-06-11: probe storing make_value fn in ThunkHolder.thunk,
# calling via me run() → output 0/1/42 confirming deferred execution).
# Module-level array of GreenTask objects is the backing store. Arrays are value
# types so green_run_one rebuilds GREEN_TASKS on each execution step.
#
# BACKWARD COMPAT: green_spawn_eager(fn) preserves the old eager-evaluation
# semantics (evaluates at spawn, enqueues result via green_spawn_value).
# Existing callers using green_spawn get cooperative deferral; green_spawn_value
# is unchanged (pre-computed values use value_mode:1, always consistent).

class GreenScheduler:
    """Encapsulated scheduler state for the cooperative green-thread queue."""
    next_id: usize
    ready_count: usize
    done_count: usize

class GreenTask:
    """A pending deferred task stored in the module-level task table."""
    task_id: usize
    thunk: fn() -> i64
    result: i64
    has_result: bool
    has_error: bool
    error_reason: text

class GreenThreadHandle:
    """Handle for a cooperative green thread."""
    task_id: usize
    value_mode: usize
    value_order: usize
    value_result: i64

    fn id() -> usize:
        self.task_id

    fn is_done() -> bool:
        if self.value_mode == 1:
            return self.value_order <= GREEN_SCHEDULER.done_count
        if self.value_mode == 2:
            var i: usize = 0
            while i < GREEN_TASKS.len():
                val t = GREEN_TASKS[i]
                if t.task_id == self.task_id:
                    return t.has_result or t.has_error
                i = i + 1
            return false
        false

    fn join() -> i64:
        if not self.is_done():
            return 0
        if self.value_mode == 1:
            return self.value_result
        if self.value_mode == 2:
            var i: usize = 0
            while i < GREEN_TASKS.len():
                val t = GREEN_TASKS[i]
                if t.task_id == self.task_id:
                    return t.result
                i = i + 1
            return 0
        0

var GREEN_SCHEDULER: GreenScheduler = GreenScheduler(next_id: 1, ready_count: 0, done_count: 0)
var GREEN_TASKS: [GreenTask] = []

export GreenThreadHandle
export green_spawn, green_spawn_eager, green_spawn_value
export green_task_error, green_ready_count, green_run_one, green_run_all

fn green_spawn(task: fn() -> i64) -> GreenThreadHandle:
    """Schedule a closure cooperatively — body executes on green_run_one/green_run_all, not at spawn."""
    val task_id = GREEN_SCHEDULER.next_id
    GREEN_SCHEDULER.next_id = GREEN_SCHEDULER.next_id + 1
    GREEN_SCHEDULER.ready_count = GREEN_SCHEDULER.ready_count + 1
    val pending = GreenTask(
        task_id: task_id,
        thunk: task,
        result: 0,
        has_result: false,
        has_error: false,
        error_reason: ""
    )
    GREEN_TASKS = GREEN_TASKS.push(pending)
    GreenThreadHandle(task_id: task_id, value_mode: 2, value_order: 0, value_result: 0)

fn green_spawn_eager(task: fn() -> i64) -> GreenThreadHandle:
    """Schedule a closure eagerly — body executes immediately at spawn (old behavior)."""
    green_spawn_value(task())

fn green_spawn_value(result: i64) -> GreenThreadHandle:
    """Schedule an already computed result on the cooperative queue."""
    val task_id = GREEN_SCHEDULER.next_id
    GREEN_SCHEDULER.next_id = GREEN_SCHEDULER.next_id + 1
    val value_order = GREEN_SCHEDULER.ready_count + 1
    GREEN_SCHEDULER.ready_count = GREEN_SCHEDULER.ready_count + 1
    GreenThreadHandle(task_id: task_id, value_mode: 1, value_order: value_order, value_result: result)

fn green_task_error(task_id: usize) -> text:
    """Return the per-task death reason if the task errored, empty string otherwise."""
    var i: usize = 0
    while i < GREEN_TASKS.len():
        val t = GREEN_TASKS[i]
        if t.task_id == task_id:
            if t.has_error:
                return t.error_reason
            return ""
        i = i + 1
    ""

fn green_ready_count() -> usize:
    GREEN_SCHEDULER.ready_count - GREEN_SCHEDULER.done_count

fn green_run_one() -> bool:
    """Run one pending deferred task or advance one pre-computed value to done."""
    # First, find the next deferred task that hasn't run yet.
    var found_idx: usize = 0
    var found: bool = false
    var i: usize = 0
    while i < GREEN_TASKS.len():
        val t = GREEN_TASKS[i]
        if (not t.has_result) and (not t.has_error):
            found_idx = i
            found = true
            i = GREEN_TASKS.len()
        i = i + 1
    if found:
        val t = GREEN_TASKS[found_idx]
        var ran_result: i64 = 0
        var ran_ok: bool = true
        ran_result = t.thunk()
        var updated = GreenTask(
            task_id: t.task_id,
            thunk: t.thunk,
            result: ran_result,
            has_result: ran_ok,
            has_error: false,
            error_reason: ""
        )
        var new_tasks: [GreenTask] = []
        var j: usize = 0
        while j < GREEN_TASKS.len():
            if j == found_idx:
                new_tasks = new_tasks.push(updated)
            else:
                new_tasks = new_tasks.push(GREEN_TASKS[j])
            j = j + 1
        GREEN_TASKS = new_tasks
        GREEN_SCHEDULER.done_count = GREEN_SCHEDULER.done_count + 1
        return true
    # No deferred tasks; advance a pre-computed slot if any remain.
    if GREEN_SCHEDULER.done_count < GREEN_SCHEDULER.ready_count:
        GREEN_SCHEDULER.done_count = GREEN_SCHEDULER.done_count + 1
        return true
    false

fn green_run_all() -> usize:
    """Run all currently ready green threads (deferred + pre-computed)."""
    var ran: usize = 0
    while green_run_one():
        ran = ran + 1
    ran
