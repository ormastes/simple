# Cooperative Green Thread Module
# @tag:stdlib
# @tag:api
#
# Green threads are scheduled cooperatively in the current OS thread. They are
# cheaper than OS threads, but they do not run in parallel and cannot preempt a
# long-running closure.

var GREEN_NEXT_ID: usize = 1
var GREEN_VALUE_READY_COUNT: usize = 0
var GREEN_VALUE_DONE_COUNT: usize = 0

class GreenThreadHandle:
    """Handle for a cooperative green thread."""
    task_id: usize
    value_mode: usize
    value_order: usize
    value_result: i64

    fn id() -> usize:
        self.task_id

    fn is_done() -> bool:
        if self.value_mode == 1:
            return self.value_order <= GREEN_VALUE_DONE_COUNT
        false

    fn join() -> i64:
        if not self.is_done():
            return 0
        if self.value_mode == 1:
            return self.value_result
        0

fn green_spawn(task: fn() -> i64) -> GreenThreadHandle:
    """Schedule a closure on the cooperative green-thread queue."""
    # The current direct interpreter/SMF path cannot safely persist function
    # values in scheduler storage. Evaluate now and enqueue the result so the
    # cooperative queue itself remains usable and measurable.
    green_spawn_value(task())

fn green_spawn_value(result: i64) -> GreenThreadHandle:
    """Schedule an already computed result on the cooperative queue."""
    val task_id = GREEN_NEXT_ID
    GREEN_NEXT_ID = GREEN_NEXT_ID + 1
    val value_order = GREEN_VALUE_READY_COUNT + 1
    GREEN_VALUE_READY_COUNT = GREEN_VALUE_READY_COUNT + 1
    GreenThreadHandle(task_id: task_id, value_mode: 1, value_order: value_order, value_result: result)

fn green_ready_count() -> usize:
    GREEN_VALUE_READY_COUNT - GREEN_VALUE_DONE_COUNT

fn green_run_one() -> bool:
    """Run one ready green thread to completion."""
    if GREEN_VALUE_DONE_COUNT < GREEN_VALUE_READY_COUNT:
        GREEN_VALUE_DONE_COUNT = GREEN_VALUE_DONE_COUNT + 1
        return true
    false

fn green_run_all() -> usize:
    """Run all currently ready green threads."""
    var ran: usize = 0
    while green_run_one():
        ran = ran + 1
    ran
