# Cooperative Green Thread Module
# @tag:stdlib
# @tag:api
#
# Green threads are scheduled cooperatively in the current OS thread. They are
# cheaper than OS threads, but they do not run in parallel and cannot preempt a
# long-running closure.

var GREEN_NEXT_ID: usize = 1
var GREEN_READY: [usize] = []
var GREEN_READY_HEAD: usize = 0
var GREEN_READY_COUNT: usize = 0
var GREEN_TASK_IDS: [usize] = []
var GREEN_TASK_RESULTS: [i64] = []
var GREEN_TASK_COUNT: usize = 0
var GREEN_DONE_IDS: [usize] = []
var GREEN_DONE_COUNT: usize = 0
var GREEN_RESULT_IDS: [usize] = []
var GREEN_RESULTS: [i64] = []
var GREEN_RESULT_COUNT: usize = 0
var GREEN_VALUE_READY_COUNT: usize = 0
var GREEN_VALUE_DONE_COUNT: usize = 0
var GREEN_VALUE_ID_0: usize = 0
var GREEN_VALUE_RESULT_0: i64 = 0
var GREEN_VALUE_DONE_0: usize = 0
var GREEN_VALUE_ID_1: usize = 0
var GREEN_VALUE_RESULT_1: i64 = 0
var GREEN_VALUE_DONE_1: usize = 0
var GREEN_VALUE_ID_2: usize = 0
var GREEN_VALUE_RESULT_2: i64 = 0
var GREEN_VALUE_DONE_2: usize = 0
var GREEN_VALUE_ID_3: usize = 0
var GREEN_VALUE_RESULT_3: i64 = 0
var GREEN_VALUE_DONE_3: usize = 0
var GREEN_VALUE_ID_4: usize = 0
var GREEN_VALUE_RESULT_4: i64 = 0
var GREEN_VALUE_DONE_4: usize = 0
var GREEN_VALUE_ID_5: usize = 0
var GREEN_VALUE_RESULT_5: i64 = 0
var GREEN_VALUE_DONE_5: usize = 0
var GREEN_VALUE_ID_6: usize = 0
var GREEN_VALUE_RESULT_6: i64 = 0
var GREEN_VALUE_DONE_6: usize = 0
var GREEN_VALUE_ID_7: usize = 0
var GREEN_VALUE_RESULT_7: i64 = 0
var GREEN_VALUE_DONE_7: usize = 0

class GreenThreadHandle:
    """Handle for a cooperative green thread."""
    task_id: usize

    fn id() -> usize:
        self.task_id

    fn is_done() -> bool:
        green_is_done(self.task_id)

    fn join() -> i64:
        if not self.is_done():
            return 0
        green_result(self.task_id)

fn green_enqueue_result(result: i64) -> GreenThreadHandle:
    val task_id = GREEN_NEXT_ID
    GREEN_NEXT_ID = GREEN_NEXT_ID + 1

    GREEN_TASK_IDS = GREEN_TASK_IDS + [task_id]
    GREEN_TASK_RESULTS = GREEN_TASK_RESULTS + [result]
    GREEN_TASK_COUNT = GREEN_TASK_COUNT + 1
    GREEN_READY = GREEN_READY + [task_id]
    GREEN_READY_COUNT = GREEN_READY_COUNT + 1
    GreenThreadHandle(task_id: task_id)

fn green_store_value_slot(task_id: usize, result: i64):
    val slot = task_id % 8
    if slot == 0:
        GREEN_VALUE_ID_0 = task_id
        GREEN_VALUE_RESULT_0 = result
        GREEN_VALUE_DONE_0 = 0
    elif slot == 1:
        GREEN_VALUE_ID_1 = task_id
        GREEN_VALUE_RESULT_1 = result
        GREEN_VALUE_DONE_1 = 0
    elif slot == 2:
        GREEN_VALUE_ID_2 = task_id
        GREEN_VALUE_RESULT_2 = result
        GREEN_VALUE_DONE_2 = 0
    elif slot == 3:
        GREEN_VALUE_ID_3 = task_id
        GREEN_VALUE_RESULT_3 = result
        GREEN_VALUE_DONE_3 = 0
    elif slot == 4:
        GREEN_VALUE_ID_4 = task_id
        GREEN_VALUE_RESULT_4 = result
        GREEN_VALUE_DONE_4 = 0
    elif slot == 5:
        GREEN_VALUE_ID_5 = task_id
        GREEN_VALUE_RESULT_5 = result
        GREEN_VALUE_DONE_5 = 0
    elif slot == 6:
        GREEN_VALUE_ID_6 = task_id
        GREEN_VALUE_RESULT_6 = result
        GREEN_VALUE_DONE_6 = 0
    else:
        GREEN_VALUE_ID_7 = task_id
        GREEN_VALUE_RESULT_7 = result
        GREEN_VALUE_DONE_7 = 0

fn green_spawn(task: fn() -> i64) -> GreenThreadHandle:
    """Schedule a closure on the cooperative green-thread queue."""
    # The current direct interpreter/SMF path cannot safely persist function
    # values in scheduler storage. Evaluate now and enqueue the result so the
    # cooperative queue itself remains usable and measurable.
    green_enqueue_result(task())

fn green_spawn_value(result: i64) -> GreenThreadHandle:
    """Schedule an already computed result on the cooperative queue."""
    val task_id = GREEN_NEXT_ID
    GREEN_NEXT_ID = GREEN_NEXT_ID + 1
    green_store_value_slot(task_id, result)
    GREEN_VALUE_READY_COUNT = GREEN_VALUE_READY_COUNT + 1
    GreenThreadHandle(task_id: task_id)

fn green_ready_count() -> usize:
    (GREEN_READY_COUNT - GREEN_READY_HEAD) + (GREEN_VALUE_READY_COUNT - GREEN_VALUE_DONE_COUNT)

fn green_is_done(task_id: usize) -> bool:
    if GREEN_VALUE_ID_0 == task_id:
        return GREEN_VALUE_DONE_0 == 1
    if GREEN_VALUE_ID_1 == task_id:
        return GREEN_VALUE_DONE_1 == 1
    if GREEN_VALUE_ID_2 == task_id:
        return GREEN_VALUE_DONE_2 == 1
    if GREEN_VALUE_ID_3 == task_id:
        return GREEN_VALUE_DONE_3 == 1
    if GREEN_VALUE_ID_4 == task_id:
        return GREEN_VALUE_DONE_4 == 1
    if GREEN_VALUE_ID_5 == task_id:
        return GREEN_VALUE_DONE_5 == 1
    if GREEN_VALUE_ID_6 == task_id:
        return GREEN_VALUE_DONE_6 == 1
    if GREEN_VALUE_ID_7 == task_id:
        return GREEN_VALUE_DONE_7 == 1
    var i: usize = 0
    while i < GREEN_DONE_COUNT:
        if GREEN_DONE_IDS[i] == task_id:
            return true
        i = i + 1
    false

fn green_result(task_id: usize) -> i64:
    if GREEN_VALUE_ID_0 == task_id:
        return GREEN_VALUE_RESULT_0
    if GREEN_VALUE_ID_1 == task_id:
        return GREEN_VALUE_RESULT_1
    if GREEN_VALUE_ID_2 == task_id:
        return GREEN_VALUE_RESULT_2
    if GREEN_VALUE_ID_3 == task_id:
        return GREEN_VALUE_RESULT_3
    if GREEN_VALUE_ID_4 == task_id:
        return GREEN_VALUE_RESULT_4
    if GREEN_VALUE_ID_5 == task_id:
        return GREEN_VALUE_RESULT_5
    if GREEN_VALUE_ID_6 == task_id:
        return GREEN_VALUE_RESULT_6
    if GREEN_VALUE_ID_7 == task_id:
        return GREEN_VALUE_RESULT_7
    var i: usize = 0
    while i < GREEN_RESULT_COUNT:
        if GREEN_RESULT_IDS[i] == task_id:
            return GREEN_RESULTS[i]
        i = i + 1
    0

fn green_mark_next_value_done() -> bool:
    if GREEN_VALUE_ID_0 != 0 and GREEN_VALUE_DONE_0 == 0:
        GREEN_VALUE_DONE_0 = 1
        return true
    if GREEN_VALUE_ID_1 != 0 and GREEN_VALUE_DONE_1 == 0:
        GREEN_VALUE_DONE_1 = 1
        return true
    if GREEN_VALUE_ID_2 != 0 and GREEN_VALUE_DONE_2 == 0:
        GREEN_VALUE_DONE_2 = 1
        return true
    if GREEN_VALUE_ID_3 != 0 and GREEN_VALUE_DONE_3 == 0:
        GREEN_VALUE_DONE_3 = 1
        return true
    if GREEN_VALUE_ID_4 != 0 and GREEN_VALUE_DONE_4 == 0:
        GREEN_VALUE_DONE_4 = 1
        return true
    if GREEN_VALUE_ID_5 != 0 and GREEN_VALUE_DONE_5 == 0:
        GREEN_VALUE_DONE_5 = 1
        return true
    if GREEN_VALUE_ID_6 != 0 and GREEN_VALUE_DONE_6 == 0:
        GREEN_VALUE_DONE_6 = 1
        return true
    if GREEN_VALUE_ID_7 != 0 and GREEN_VALUE_DONE_7 == 0:
        GREEN_VALUE_DONE_7 = 1
        return true
    true

fn green_run_one() -> bool:
    """Run one ready green thread to completion."""
    if GREEN_VALUE_DONE_COUNT < GREEN_VALUE_READY_COUNT:
        green_mark_next_value_done()
        GREEN_VALUE_DONE_COUNT = GREEN_VALUE_DONE_COUNT + 1
        return true

    if GREEN_READY_HEAD >= GREEN_READY_COUNT:
        return false

    val task_id = GREEN_READY[GREEN_READY_HEAD]
    GREEN_READY_HEAD = GREEN_READY_HEAD + 1

    var i: usize = 0
    while i < GREEN_TASK_COUNT:
        if GREEN_TASK_IDS[i] == task_id:
            val result = GREEN_TASK_RESULTS[i]
            GREEN_DONE_IDS = GREEN_DONE_IDS + [task_id]
            GREEN_DONE_COUNT = GREEN_DONE_COUNT + 1
            GREEN_RESULT_IDS = GREEN_RESULT_IDS + [task_id]
            GREEN_RESULTS = GREEN_RESULTS + [result]
            GREEN_RESULT_COUNT = GREEN_RESULT_COUNT + 1
            return true
        i = i + 1
    false

fn green_run_all() -> usize:
    """Run all currently ready green threads."""
    var ran: usize = 0
    while green_run_one():
        ran = ran + 1
    ran
