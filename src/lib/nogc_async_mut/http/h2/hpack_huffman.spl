# HPACK Huffman Coding — RFC 7541 Appendix B
#
# Implements the static Huffman code used for HPACK string literal encoding.
# All 257 symbols (0-255 byte values + EOS) with their RFC 7541 Appendix B codes.
#
# Encoding: bits packed left-to-right (MSB first); padded to octet boundary with
# high bits of EOS code (all 1s) per RFC 7541 §5.2.
#
# Depends on: nothing in this codebase (pure arithmetic)

# ============================================================================
# Huffman table — RFC 7541 Appendix B
# Each entry: (code_as_hex: i64, bit_length: i64)
# code_as_hex is the code value aligned to LSB (as in the RFC table).
# During encoding, bits are shifted left so MSB is emitted first.
# ============================================================================

fn hpack_huffman_table_codes() -> [i64]:
    """Return the 257 Huffman code values (LSB-aligned hex) from RFC 7541 Appendix B."""
    var t: [i64] = []
