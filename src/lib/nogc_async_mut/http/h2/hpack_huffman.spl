# ============================================================================
# Encode
# ============================================================================

pub fn hpack_huffman_encoded_length(input: [u8]) -> i64:
    """Calculate the byte length of Huffman-encoding `input` without encoding it.

    Returns the ceiling of total bits divided by 8.
    Useful for deciding whether Huffman encoding saves space.
    """
    val lengths = hpack_huffman_table_lengths()
    var total_bits: i64 = 0
    var i = 0
    while i < input.len():
        val sym = input[i] & 0xff
        total_bits = total_bits + lengths[sym]
        i = i + 1
    # Ceiling division: round up to next byte
    (total_bits + 7) / 8

pub fn hpack_huffman_encode(input: [u8]) -> [u8]:
    """Huffman-encode `input` bytes per RFC 7541 Appendix B.

    Bits are packed left-to-right (MSB first). The output is padded to an
    octet boundary using the most significant bits of the EOS code (all 1s).
    Returns the encoded byte sequence.
    """
    val codes = hpack_huffman_table_codes()
    val lengths = hpack_huffman_table_lengths()

    # Bit accumulator: we accumulate up to 64 bits then flush bytes
    var acc: i64 = 0      # current bit buffer (MSB = next bit to emit)
    var acc_bits: i64 = 0 # how many valid bits are in acc (from the top)
    var out: [u8] = []

    var i = 0
    while i < input.len():
        val sym = input[i] & 0xff
        val code = codes[sym]
        val nbits = lengths[sym]

        # Shift code left so its MSB aligns with the top of a 64-bit word,
        # then OR into accumulator at position acc_bits from the top.
        # We use 64-bit space; safe as long as acc_bits + nbits <= 64.
        # Max code length is 30 bits; acc_bits is at most 7 before flush loop,
        # so max sum is 37 bits — fits comfortably in 63 bits.
        val shift = 64 - nbits - acc_bits
        acc = acc | (code << shift)
        acc_bits = acc_bits + nbits

        # Flush complete bytes
        while acc_bits >= 8:
            val byte_val = (acc >> 56) & 0xff
            out.push(byte_val)
            acc = (acc << 8) & 0xffffffffffffffff
            acc_bits = acc_bits - 8

        i = i + 1

    # Flush remaining partial byte, padded with high bits of EOS (all 1s)
    if acc_bits > 0:
        val pad_bits = 8 - acc_bits
        # Fill low `pad_bits` with 1s (EOS prefix padding)
        val pad_mask = (1 << pad_bits) - 1
        val last_byte = ((acc >> 56) & 0xff) | pad_mask
        out.push(last_byte)

    out

# ============================================================================
# Decode
# ============================================================================

pub fn hpack_huffman_decode(input: [u8], bit_count: i64) -> [u8]:
    """Decode Huffman-encoded `input` bytes, consuming exactly `bit_count` bits.

    Uses a linear scan against the Huffman table for each symbol.
    The EOS padding bits at the end are consumed but produce no output.
    Returns the decoded byte sequence.
    """
    val codes = hpack_huffman_table_codes()
    val lengths = hpack_huffman_table_lengths()

    var out: [u8] = []
    var bit_pos: i64 = 0   # current bit offset into input (0 = MSB of input[0])

    while bit_pos < bit_count:
        # Try to match each table entry at the current bit position
        var matched = false
        var sym = 0
        while sym < 257:
            val code_len = lengths[sym]
            val bits_left = bit_count - bit_pos
            if bits_left < code_len:
                sym = sym + 1
                continue
            # Extract `code_len` bits from input starting at bit_pos
            var extracted: i64 = 0
            var b = 0
            while b < code_len:
                val abs_bit = bit_pos + b
                val byte_idx = abs_bit / 8
                val bit_in_byte = 7 - (abs_bit & 7)
                val bit_val = (input[byte_idx] >> bit_in_byte) & 1
                extracted = (extracted << 1) | bit_val
                b = b + 1
            if extracted == codes[sym]:
                if sym < 256:
                    out.push(sym & 0xff)
                # sym == 256 is EOS padding — skip
                bit_pos = bit_pos + code_len
                matched = true
                break
            sym = sym + 1
        if not matched:
            # Unrecognised code — stop decoding (malformed or trailing pad)
            break

    out
