"""
Server Runtime — Thread-Per-Core Async Server Infrastructure

Provides configuration, worker state, and bounded logging for a
thread-per-core server runtime targeting I/O-bound HTTP workloads.

Components:
- WorkerConfig: tuning knobs (worker count, backpressure, log bound, SO_REUSEPORT)
- WorkerState: per-worker bookkeeping (event count, arena usage, connections)
- RuntimeStatus: lifecycle enum (Idle → Running → Draining → Stopped)
- ServerRuntime: top-level runtime holding config, workers, and status
- BoundedLogger: fixed-capacity log buffer with drop counting

Design:
- Thread-per-core: each worker owns its event loop and arena (no cross-thread sharing)
- SO_REUSEPORT: kernel-level load balancing across worker accept sockets
- Backpressure: per-worker connection cap prevents overload cascades
- Bounded logging: hot-path log entries are capped; excess is counted, not queued
"""

# =============================================================================
# Worker Configuration
# =============================================================================

struct WorkerConfig:
    """Per-runtime tuning knobs."""
    worker_count: i64
    backpressure_limit: i64
    log_bound: i64
    enable_reuseport: bool

fn default_worker_config() -> WorkerConfig:
    """Sensible defaults: 4 workers, 1024 connection cap, 4096 log entries."""
    WorkerConfig(
        worker_count: 4,
        backpressure_limit: 1024,
        log_bound: 4096,
        enable_reuseport: true
    )

fn worker_config_for_cores(n: i64) -> WorkerConfig:
    """One worker per core with scaled backpressure."""
    var count = n
    if count < 1:
        count = 1
    WorkerConfig(
        worker_count: count,
        backpressure_limit: 1024,
        log_bound: 4096,
        enable_reuseport: true
    )

# =============================================================================
# Worker State
# =============================================================================

struct WorkerState:
    """Per-worker bookkeeping — one instance per event loop thread."""
    worker_id: i64
    event_count: i64
    arena_usage_bytes: i64
    active_connections: i64

fn create_worker_state(id: i64) -> WorkerState:
    """Fresh worker state with zeroed counters."""
    WorkerState(
        worker_id: id,
        event_count: 0,
        arena_usage_bytes: 0,
        active_connections: 0
    )

fn worker_is_overloaded(state: WorkerState, config: WorkerConfig) -> bool:
    """True when active connections exceed the backpressure limit."""
    state.active_connections > config.backpressure_limit

# =============================================================================
# Runtime Status
# =============================================================================

enum RuntimeStatus:
    Idle
    Running
    Draining
    Stopped

fn runtime_status_name(status: RuntimeStatus) -> text:
    """Human-readable status label."""
    match status:
        case Idle: "idle"
        case Running: "running"
        case Draining: "draining"
        case Stopped: "stopped"

fn runtime_status_is_accepting(status: RuntimeStatus) -> bool:
    """Only Running status accepts new connections."""
    match status:
        case Running: true
        case Idle: false
        case Draining: false
        case Stopped: false

# =============================================================================
# Server Runtime
# =============================================================================

class ServerRuntime:
    """Top-level runtime: holds config, worker list, and lifecycle status."""
    config: WorkerConfig
    workers: [WorkerState]
    status: RuntimeStatus

    static fn new(config: WorkerConfig) -> ServerRuntime:
        """Create runtime with workers pre-allocated per config."""
        var workers: [WorkerState] = []
        var i = 0
        while i < config.worker_count:
            workers = workers + [create_worker_state(i)]
            i = i + 1
        ServerRuntime(config: config, workers: workers, status: RuntimeStatus.Idle)

    fn worker_count() -> i64:
        """Number of workers in this runtime."""
        self.workers.length()

    fn is_running() -> bool:
        """True when status is Running."""
        runtime_status_is_accepting(self.status)

# =============================================================================
# SO_REUSEPORT Detection
# =============================================================================

fn supports_reuseport() -> bool:
    """Platform probe for SO_REUSEPORT support.

    Linux ≥ 3.9 and recent BSDs support SO_REUSEPORT. Returns true on
    Linux (the primary target); a real implementation would attempt
    setsockopt and catch ENOPROTOOPT.
    """
    true

# =============================================================================
# Bounded Logger
# =============================================================================

struct BoundedLogger:
    """Fixed-capacity log buffer for hot paths.

    When the buffer is full, new entries are silently dropped and the
    drop counter increments. This prevents unbounded memory growth on
    sustained traffic spikes.
    """
    max_entries: i64
    entries: [text]
    drop_count: i64

fn bounded_logger_new(capacity: i64) -> BoundedLogger:
    """Create logger with given capacity."""
    BoundedLogger(max_entries: capacity, entries: [], drop_count: 0)

fn bounded_logger_log(logger: BoundedLogger, message: text) -> BoundedLogger:
    """Append entry if capacity remains; otherwise increment drop count.

    Returns a new BoundedLogger with the updated state (value-semantic).
    """
    if logger.entries.length() >= logger.max_entries:
        BoundedLogger(
            max_entries: logger.max_entries,
            entries: logger.entries,
            drop_count: logger.drop_count + 1
        )
    else:
        BoundedLogger(
            max_entries: logger.max_entries,
            entries: logger.entries + [message],
            drop_count: logger.drop_count
        )

fn bounded_logger_entry_count(logger: BoundedLogger) -> i64:
    """Number of stored entries."""
    logger.entries.length()

fn bounded_logger_dropped(logger: BoundedLogger) -> i64:
    """Number of entries dropped due to capacity limit."""
    logger.drop_count

fn bounded_logger_is_full(logger: BoundedLogger) -> bool:
    """True when stored entries have reached capacity."""
    logger.entries.length() >= logger.max_entries

# Exports
export WorkerConfig, WorkerState, RuntimeStatus, ServerRuntime, BoundedLogger
export default_worker_config, worker_config_for_cores
export create_worker_state, worker_is_overloaded
export supports_reuseport
export runtime_status_name, runtime_status_is_accepting
export bounded_logger_new, bounded_logger_log
export bounded_logger_entry_count, bounded_logger_dropped, bounded_logger_is_full
