"""
# No-GC Async Vulkan I/O FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.vulkan_ffi.{
    vulkan_available, vulkan_init, vulkan_shutdown, vulkan_device_count,
    vulkan_select_device, vulkan_get_device, VulkanDeviceType, parse_device_type,
    VulkanDeviceInfo, vulkan_device_info, VulkanBufferUsage, buffer_usage_to_flags,
    VulkanBuffer, vulkan_alloc_buffer, vulkan_alloc_storage, vulkan_free_buffer,
    vulkan_copy_to, vulkan_copy_from, vulkan_copy_buffer, VulkanShader, vulkan_compile_spirv,
    vulkan_compile_glsl, vulkan_destroy_shader, VulkanPipeline, vulkan_create_pipeline,
    vulkan_create_pipeline_with_push, vulkan_destroy_pipeline, VulkanDescriptorSet,
    vulkan_create_descriptors, vulkan_bind_buffer, vulkan_destroy_descriptors,
    VulkanCommandBuffer, vulkan_begin_compute, vulkan_cmd_bind_pipeline,
    vulkan_cmd_bind_descriptors, vulkan_cmd_push_constants, vulkan_cmd_dispatch,
    vulkan_end_compute, vulkan_submit_and_wait, vulkan_wait_idle, vulkan_last_error,
    VulkanDispatchConfig, vulkan_dispatch_1d, VulkanRenderPass, VulkanGraphicsPipeline,
    VulkanImage, VulkanSampler, VulkanFramebuffer, VulkanSwapchain,
    vulkan_create_render_pass, vulkan_create_graphics_pipeline, vulkan_create_image,
    vulkan_create_sampler, vulkan_create_framebuffer, vulkan_create_swapchain
}
