# HTTP/3 Stream Handler — RFC 9114
#
# Implements HTTP/3 request/response framing over QUIC streams:
#   - H3 frame types: DATA (0x00), HEADERS (0x01), SETTINGS (0x04), GOAWAY (0x07)
#   - QPACK header compression (static-table-only, no dynamic table)
#   - Request/response mapping over QUIC streams
#   - Static file serving (same pattern as worker.spl inline_static_handler)
#
# Scope matches the codebase's stub pattern:
#   - Static-table-only QPACK (mirrors H2's static-table-only HPACK)
#   - No PUSH_PROMISE, no CANCEL_PUSH
#   - No server push
#
# Reference: RFC 9114 (HTTP/3), RFC 9204 (QPACK)

use std.io.quic.quic_transport.{QuicTransport, TransportEvent}
use std.io.quic.quic_connection.{QuicConnection}
use std.nogc_sync_mut.io.file_ops.{file_read_text, file_exists, file_size}

extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_bytes_to_text(data: [u8]) -> text

# ============================================================================
# HTTP/3 Frame Types — RFC 9114 §7.2
# ============================================================================

val H3_FRAME_DATA: i64 = 0x00
val H3_FRAME_HEADERS: i64 = 0x01
val H3_FRAME_CANCEL_PUSH: i64 = 0x03
val H3_FRAME_SETTINGS: i64 = 0x04
val H3_FRAME_PUSH_PROMISE: i64 = 0x05
val H3_FRAME_GOAWAY: i64 = 0x07
val H3_FRAME_MAX_PUSH_ID: i64 = 0x0d

# ============================================================================
# HTTP/3 Settings — RFC 9114 §7.2.4.1
# ============================================================================

val H3_SETTINGS_MAX_FIELD_SECTION_SIZE: i64 = 0x06
val H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY: i64 = 0x01
val H3_SETTINGS_QPACK_BLOCKED_STREAMS: i64 = 0x07

# ============================================================================
# HTTP/3 stream types — RFC 9114 §6.2
# ============================================================================

val H3_STREAM_CONTROL: i64 = 0x00
val H3_STREAM_PUSH: i64 = 0x01
val H3_STREAM_QPACK_ENCODER: i64 = 0x02
val H3_STREAM_QPACK_DECODER: i64 = 0x03

# ============================================================================
# QPACK Static Table — RFC 9204 §Appendix A (subset)
# ============================================================================

struct QpackEntry:
    """One entry in the QPACK static table."""
    index: i64
    name: text
    value: text

fn qpack_static_table() -> [QpackEntry]:
    """Return the QPACK static table (subset of commonly used entries).

    Full table has 99 entries; we include the most common ones for
    HTTP request/response headers.
    """
    var table: [QpackEntry] = []
    table.push(QpackEntry(index: 0, name: ":authority", value: ""))
    table.push(QpackEntry(index: 1, name: ":path", value: "/"))
    table.push(QpackEntry(index: 2, name: "age", value: "0"))
    table.push(QpackEntry(index: 3, name: "content-disposition", value: ""))
    table.push(QpackEntry(index: 4, name: "content-length", value: "0"))
    table.push(QpackEntry(index: 5, name: "content-type", value: ""))
    table.push(QpackEntry(index: 6, name: "cookie", value: ""))
    table.push(QpackEntry(index: 7, name: "date", value: ""))
    table.push(QpackEntry(index: 8, name: "etag", value: ""))
    table.push(QpackEntry(index: 9, name: "if-modified-since", value: ""))
    table.push(QpackEntry(index: 10, name: "if-none-match", value: ""))
    table.push(QpackEntry(index: 11, name: "last-modified", value: ""))
    table.push(QpackEntry(index: 12, name: "link", value: ""))
    table.push(QpackEntry(index: 13, name: "location", value: ""))
    table.push(QpackEntry(index: 14, name: "referer", value: ""))
    table.push(QpackEntry(index: 15, name: "set-cookie", value: ""))
    table.push(QpackEntry(index: 16, name: ":method", value: "CONNECT"))
    table.push(QpackEntry(index: 17, name: ":method", value: "DELETE"))
    table.push(QpackEntry(index: 18, name: ":method", value: "GET"))
    table.push(QpackEntry(index: 19, name: ":method", value: "HEAD"))
    table.push(QpackEntry(index: 20, name: ":method", value: "OPTIONS"))
    table.push(QpackEntry(index: 21, name: ":method", value: "POST"))
    table.push(QpackEntry(index: 22, name: ":method", value: "PUT"))
    table.push(QpackEntry(index: 23, name: ":scheme", value: "http"))
    table.push(QpackEntry(index: 24, name: ":scheme", value: "https"))
    table.push(QpackEntry(index: 25, name: ":status", value: "103"))
    table.push(QpackEntry(index: 26, name: ":status", value: "200"))
    table.push(QpackEntry(index: 27, name: ":status", value: "304"))
    table.push(QpackEntry(index: 28, name: ":status", value: "404"))
    table.push(QpackEntry(index: 29, name: ":status", value: "503"))
    table.push(QpackEntry(index: 30, name: "accept", value: "*/*"))
    table.push(QpackEntry(index: 31, name: "accept", value: "application/dns-message"))
    table.push(QpackEntry(index: 32, name: "accept-encoding", value: "gzip, deflate, br"))
    table.push(QpackEntry(index: 33, name: "accept-ranges", value: "bytes"))
    table.push(QpackEntry(index: 34, name: "access-control-allow-headers", value: "cache-control"))
    table.push(QpackEntry(index: 35, name: "access-control-allow-headers", value: "content-type"))
    table.push(QpackEntry(index: 36, name: "access-control-allow-origin", value: "*"))
    table.push(QpackEntry(index: 37, name: "cache-control", value: "max-age=0"))
    table.push(QpackEntry(index: 38, name: "cache-control", value: "max-age=2592000"))
    table.push(QpackEntry(index: 39, name: "cache-control", value: "max-age=604800"))
    table.push(QpackEntry(index: 40, name: "cache-control", value: "no-cache"))
    table.push(QpackEntry(index: 41, name: "cache-control", value: "no-store"))
    table.push(QpackEntry(index: 42, name: "cache-control", value: "public, max-age=31536000"))
    table.push(QpackEntry(index: 43, name: "content-encoding", value: "br"))
    table.push(QpackEntry(index: 44, name: "content-encoding", value: "gzip"))
    table.push(QpackEntry(index: 45, name: "content-type", value: "application/dns-message"))
    table.push(QpackEntry(index: 46, name: "content-type", value: "application/javascript"))
    table.push(QpackEntry(index: 47, name: "content-type", value: "application/json"))
    table.push(QpackEntry(index: 48, name: "content-type", value: "application/x-www-form-urlencoded"))
    table.push(QpackEntry(index: 49, name: "content-type", value: "image/gif"))
    table.push(QpackEntry(index: 50, name: "content-type", value: "image/jpeg"))
    table.push(QpackEntry(index: 51, name: "content-type", value: "image/png"))
    table.push(QpackEntry(index: 52, name: "content-type", value: "text/css"))
    table.push(QpackEntry(index: 53, name: "content-type", value: "text/html; charset=utf-8"))
    table.push(QpackEntry(index: 54, name: "content-type", value: "text/plain"))
    table.push(QpackEntry(index: 55, name: "content-type", value: "text/plain;charset=utf-8"))
    table.push(QpackEntry(index: 56, name: "range", value: "bytes=0-"))
    table.push(QpackEntry(index: 57, name: "strict-transport-security", value: "max-age=31536000"))
    table.push(QpackEntry(index: 58, name: "strict-transport-security", value: "max-age=31536000; includesubdomains"))
    table.push(QpackEntry(index: 59, name: "strict-transport-security", value: "max-age=31536000; includesubdomains; preload"))
    table.push(QpackEntry(index: 60, name: "vary", value: "accept-encoding"))
    table.push(QpackEntry(index: 61, name: "vary", value: "origin"))
    table.push(QpackEntry(index: 62, name: "x-content-type-options", value: "nosniff"))
    table.push(QpackEntry(index: 63, name: "x-xss-protection", value: "1; mode=block"))
    return table

# ============================================================================
# QPACK Encoder/Decoder — static-table-only (RFC 9204)
# ============================================================================

class QpackCodec:
    """QPACK codec using static table only (no dynamic table).

    Encodes headers as:
      - Static table index match: 0xff mask + index (indexed field line)
      - Literal with name reference: 0x5f mask + index + value length + value
      - Literal: 0x2f mask + name length + name + value length + value
    """
    static_table: [QpackEntry]

    static fn create() -> QpackCodec:
        return QpackCodec(static_table: qpack_static_table())

    fn encode_headers(headers: [(text, text)]) -> [u8]:
        """Encode a list of (name, value) header pairs using QPACK.

        Returns the encoded header block (without the Required Insert Count
        and Delta Base prefix bytes, which are both 0 for static-only).
        """
        var encoded: [u8] = []
        # Required Insert Count = 0 (no dynamic table)
        encoded.push(0x00)
        # Delta Base = 0
        encoded.push(0x00)

        var i = 0
        loop:
            if i >= headers.len():
                break
            val hdr = headers[i]
            val name = hdr.0
            val value = hdr.1

            # Try exact match in static table
            val exact_idx = self._find_exact(name, value)
            if exact_idx >= 0:
                # Indexed field line (static): 1xxxxxxx with T=1
                # 0xc0 | index (for indices < 64)
                encoded.push(0xc0 | (exact_idx & 0x3f))
                i = i + 1
                continue

            # Try name match in static table
            val name_idx = self._find_name(name)
            if name_idx >= 0:
                # Literal with name reference (static): 01NTxxxx
                # N=0 (not never-indexed), T=1 (static), index < 16
                encoded.push(0x50 | (name_idx & 0x0f))
                # Value: length-prefixed, no Huffman (H=0)
                val vbytes = rt_text_to_bytes(value)
                self._encode_length(encoded, vbytes.len())
                _h3_append(encoded, vbytes)
                i = i + 1
                continue

            # Literal without name reference: 001NXXXX
            encoded.push(0x20)
            val nbytes = rt_text_to_bytes(name)
            self._encode_length(encoded, nbytes.len())
            _h3_append(encoded, nbytes)
            val vbytes2 = rt_text_to_bytes(value)
            self._encode_length(encoded, vbytes2.len())
            _h3_append(encoded, vbytes2)
            i = i + 1

        return encoded

    fn decode_headers(data: [u8]) -> [(text, text)]:
        """Decode a QPACK-encoded header block into (name, value) pairs.

        Handles static-table-only encoding. Dynamic table references
        are not supported and will be skipped.
        """
        var headers: [(text, text)] = []
        if data.len() < 2:
            return headers

        # Skip Required Insert Count (byte 0) and Delta Base (byte 1)
        var pos = 2

        loop:
            if pos >= data.len():
                break

            val byte0 = data[pos]

            if (byte0 & 0xc0) == 0xc0:
                # Indexed field line (static): 11xxxxxx
                val idx = byte0 & 0x3f
                if idx < self.static_table.len():
                    val entry = self.static_table[idx]
                    headers.push((entry.name, entry.value))
                pos = pos + 1

            elif (byte0 & 0xf0) == 0x50:
                # Literal with static name reference: 0101xxxx
                val idx = byte0 & 0x0f
                pos = pos + 1
                val vr = self._decode_length(data, pos)
                val vlen = vr.0
                pos = vr.1
                val value = self._extract_text(data, pos, vlen)
                pos = pos + vlen
                if idx < self.static_table.len():
                    headers.push((self.static_table[idx].name, value))

            elif (byte0 & 0xe0) == 0x20:
                # Literal without name reference: 001xxxxx
                pos = pos + 1
                val nr = self._decode_length(data, pos)
                val nlen = nr.0
                pos = nr.1
                val name = self._extract_text(data, pos, nlen)
                pos = pos + nlen
                val vr2 = self._decode_length(data, pos)
                val vlen2 = vr2.0
                pos = vr2.1
                val value2 = self._extract_text(data, pos, vlen2)
                pos = pos + vlen2
                headers.push((name, value2))

            else:
                # Unknown or dynamic table reference — skip byte
                pos = pos + 1

        return headers

    # ------------------------------------------------------------------
    # Internal helpers
    # ------------------------------------------------------------------

    fn _find_exact(name: text, value: text) -> i64:
        """Find an exact (name, value) match in the static table. Returns -1 if not found."""
        var i = 0
        loop:
            if i >= self.static_table.len():
                break
            val entry = self.static_table[i]
            if entry.name == name and entry.value == value:
                return entry.index
            i = i + 1
        return -1

    fn _find_name(name: text) -> i64:
        """Find the first name match in the static table. Returns -1 if not found."""
        var i = 0
        loop:
            if i >= self.static_table.len():
                break
            if self.static_table[i].name == name:
                return self.static_table[i].index
            i = i + 1
        return -1

    fn _encode_length(buf: [u8], length: i64):
        """Encode a length prefix (7-bit prefix, no Huffman)."""
        if length < 127:
            buf.push(length & 0x7f)
        else:
            buf.push(0x7f)
            var remaining = length - 127
            loop:
                if remaining < 128:
                    buf.push(remaining & 0xff)
                    break
                buf.push((remaining & 0x7f) | 0x80)
                remaining = remaining >> 7

    fn _decode_length(data: [u8], start: i64) -> (i64, i64):
        """Decode a length prefix. Returns (length, new_position)."""
        if start >= data.len():
            return (0, start)
        val first = data[start] & 0x7f
        if first < 127:
            return (first, start + 1)
        var length = 127
        var pos = start + 1
        var shift = 0
        loop:
            if pos >= data.len():
                break
            val b = data[pos]
            length = length + ((b & 0x7f) << shift)
            pos = pos + 1
            if (b & 0x80) == 0:
                break
            shift = shift + 7
        return (length, pos)

    fn _extract_text(data: [u8], start: i64, length: i64) -> text:
        """Extract a text string from data[start..start+length]."""
        var bytes: [u8] = []
        var i = 0
        loop:
            if i >= length:
                break
            if (start + i) >= data.len():
                break
            bytes.push(data[start + i])
            i = i + 1
        return rt_bytes_to_text(bytes)

# ============================================================================
# H3 Frame encoding/decoding — RFC 9114 §7.2
# ============================================================================

struct H3Frame:
    """A decoded HTTP/3 frame."""
    frame_type: i64
    payload: [u8]

fn h3_encode_frame(frame_type: i64, payload: [u8]) -> [u8]:
    """Encode an HTTP/3 frame: varint(type) + varint(length) + payload."""
    var frame: [u8] = []
    _h3_append(frame, _h3_varint_encode(frame_type))
    _h3_append(frame, _h3_varint_encode(payload.len()))
    _h3_append(frame, payload)
    return frame

fn h3_decode_frame(data: [u8], offset: i64) -> (H3Frame, i64)?:
    """Decode one HTTP/3 frame from data starting at offset.

    Returns (frame, new_offset) or nil if insufficient data.
    """
    if offset >= data.len():
        return nil

    val type_r = _h3_varint_decode(data, offset)
    if type_r == nil:
        return nil
    val ftype = type_r.0
    var pos = type_r.1

    val len_r = _h3_varint_decode(data, pos)
    if len_r == nil:
        return nil
    val flen = len_r.0
    pos = len_r.1

    if pos + flen > data.len():
        return nil

    var payload: [u8] = []
    var i = 0
    loop:
        if i >= flen:
            break
        payload.push(data[pos + i])
        i = i + 1

    val frame = H3Frame(frame_type: ftype, payload: payload)
    return (frame, pos + flen)

# ============================================================================
# H3 SETTINGS frame — RFC 9114 §7.2.4
# ============================================================================

struct H3Settings:
    """HTTP/3 settings parameters."""
    max_field_section_size: i64
    qpack_max_table_capacity: i64
    qpack_blocked_streams: i64

fn default_h3_settings() -> H3Settings:
    """Default settings: no dynamic QPACK table, 16KB header limit."""
    return H3Settings(
        max_field_section_size: 16384,
        qpack_max_table_capacity: 0,
        qpack_blocked_streams: 0
    )

fn h3_encode_settings(settings: H3Settings) -> [u8]:
    """Encode settings as an H3 SETTINGS frame payload.

    Each setting is encoded as varint(id) + varint(value).
    """
    var payload: [u8] = []
    # QPACK_MAX_TABLE_CAPACITY
    _h3_append(payload, _h3_varint_encode(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY))
    _h3_append(payload, _h3_varint_encode(settings.qpack_max_table_capacity))
    # MAX_FIELD_SECTION_SIZE
    _h3_append(payload, _h3_varint_encode(H3_SETTINGS_MAX_FIELD_SECTION_SIZE))
    _h3_append(payload, _h3_varint_encode(settings.max_field_section_size))
    # QPACK_BLOCKED_STREAMS
    _h3_append(payload, _h3_varint_encode(H3_SETTINGS_QPACK_BLOCKED_STREAMS))
    _h3_append(payload, _h3_varint_encode(settings.qpack_blocked_streams))
    return h3_encode_frame(H3_FRAME_SETTINGS, payload)

fn h3_decode_settings(payload: [u8]) -> H3Settings:
    """Decode an H3 SETTINGS frame payload."""
    var settings = default_h3_settings()
    var pos = 0
    loop:
        if pos >= payload.len():
            break
        val id_r = _h3_varint_decode(payload, pos)
        if id_r == nil:
            break
        val setting_id = id_r.0
        pos = id_r.1
        val val_r = _h3_varint_decode(payload, pos)
        if val_r == nil:
            break
        val setting_val = val_r.0
        pos = val_r.1

        if setting_id == H3_SETTINGS_MAX_FIELD_SECTION_SIZE:
            settings.max_field_section_size = setting_val
        elif setting_id == H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY:
            settings.qpack_max_table_capacity = setting_val
        elif setting_id == H3_SETTINGS_QPACK_BLOCKED_STREAMS:
            settings.qpack_blocked_streams = setting_val
    return settings

# ============================================================================
# H3 GOAWAY frame — RFC 9114 §7.2.6
# ============================================================================

fn h3_encode_goaway(stream_id: i64) -> [u8]:
    """Encode a GOAWAY frame with the given stream ID."""
    val payload = _h3_varint_encode(stream_id)
    return h3_encode_frame(H3_FRAME_GOAWAY, payload)

# ============================================================================
# H3Request / H3Response — HTTP/3 request/response types
# ============================================================================

struct H3Request:
    """Decoded HTTP/3 request."""
    method: text
    path: text
    scheme: text
    authority: text
    headers: [(text, text)]
    body: [u8]

struct H3Response:
    """HTTP/3 response to send."""
    status: i64
    headers: [(text, text)]
    body: [u8]

# ============================================================================
# H3Stream — manages one HTTP/3 request/response exchange
# ============================================================================

class H3Stream:
    """One HTTP/3 request/response exchange on a QUIC stream.

    Accumulates received H3 frames, decodes request headers via QPACK,
    and produces response frames (HEADERS + DATA).
    """
    stream_id: i64
    conn_key: text
    codec: QpackCodec
    recv_buf: [u8]
    request: H3Request?
    response_sent: bool
    settings: H3Settings

    static fn create(stream_id: i64, conn_key: text) -> H3Stream:
        return H3Stream(
            stream_id: stream_id,
            conn_key: conn_key,
            codec: QpackCodec.create(),
            recv_buf: [],
            request: nil,
            response_sent: false,
            settings: default_h3_settings()
        )

    me on_data(data: [u8]):
        """Append received stream data. Call try_decode_request() after."""
        var i = 0
        loop:
            if i >= data.len():
                break
            self.recv_buf.push(data[i])
            i = i + 1

    me try_decode_request() -> H3Request?:
        """Try to decode a complete HTTP/3 request from buffered data.

        Parses HEADERS frame, decodes via QPACK, then collects DATA frames.
        Returns nil if the request is incomplete.
        """
        if self.request != nil:
            return self.request

        var pos = 0
        var method = ""
        var path = "/"
        var scheme = "https"
        var authority = ""
        var req_headers: [(text, text)] = []
        var body: [u8] = []
        var got_headers = false

        # Parse H3 frames from recv buffer
        loop:
            val fr = h3_decode_frame(self.recv_buf, pos)
            if fr == nil:
                break
            val frame = fr.0
            pos = fr.1

            if frame.frame_type == H3_FRAME_HEADERS and not got_headers:
                # Decode QPACK headers
                val decoded = self.codec.decode_headers(frame.payload)
                var k = 0
                loop:
                    if k >= decoded.len():
                        break
                    val hdr = decoded[k]
                    if hdr.0 == ":method":
                        method = hdr.1
                    elif hdr.0 == ":path":
                        path = hdr.1
                    elif hdr.0 == ":scheme":
                        scheme = hdr.1
                    elif hdr.0 == ":authority":
                        authority = hdr.1
                    else:
                        req_headers.push(hdr)
                    k = k + 1
                got_headers = true

            elif frame.frame_type == H3_FRAME_DATA:
                _h3_append(body, frame.payload)

        if not got_headers:
            return nil

        val req = H3Request(
            method: method,
            path: path,
            scheme: scheme,
            authority: authority,
            headers: req_headers,
            body: body
        )
        self.request = req
        return req

    me encode_response(resp: H3Response) -> [u8]:
        """Encode an H3Response into HEADERS + DATA frames for transmission.

        Returns the concatenated frame bytes to send on the QUIC stream.
        """
        var result: [u8] = []

        # Build response pseudo-headers + headers
        var resp_headers: [(text, text)] = []
        resp_headers.push((":status", "{resp.status}"))
        var i = 0
        loop:
            if i >= resp.headers.len():
                break
            resp_headers.push(resp.headers[i])
            i = i + 1

        # Encode HEADERS frame
        val header_block = self.codec.encode_headers(resp_headers)
        val headers_frame = h3_encode_frame(H3_FRAME_HEADERS, header_block)
        _h3_append(result, headers_frame)

        # Encode DATA frame (if body is non-empty)
        if resp.body.len() > 0:
            val data_frame = h3_encode_frame(H3_FRAME_DATA, resp.body)
            _h3_append(result, data_frame)

        self.response_sent = true
        return result

# ============================================================================
# Static file handler — same pattern as worker.spl inline_static_handler
# ============================================================================

fn h3_static_file_response(root_dir: text, request_path: text) -> H3Response:
    """Serve a static file over HTTP/3.

    Mirrors the logic from worker.spl's inline_static_handler:
    check file existence, determine content type by extension,
    read file content, build response.
    """
    val full_path = root_dir + request_path
    if not file_exists(full_path):
        return H3Response(
            status: 404,
            headers: [("content-type", "text/plain")],
            body: rt_text_to_bytes("Not Found")
        )

    val fsize = file_size(full_path)
    var ctype = "application/octet-stream"
    if request_path.ends_with(".html"):
        ctype = "text/html; charset=utf-8"
    elif request_path.ends_with(".htm"):
        ctype = "text/html; charset=utf-8"
    elif request_path.ends_with(".css"):
        ctype = "text/css"
    elif request_path.ends_with(".js"):
        ctype = "application/javascript"
    elif request_path.ends_with(".json"):
        ctype = "application/json"
    elif request_path.ends_with(".png"):
        ctype = "image/png"
    elif request_path.ends_with(".jpg"):
        ctype = "image/jpeg"
    elif request_path.ends_with(".jpeg"):
        ctype = "image/jpeg"
    elif request_path.ends_with(".gif"):
        ctype = "image/gif"
    elif request_path.ends_with(".svg"):
        ctype = "image/svg+xml"
    elif request_path.ends_with(".ico"):
        ctype = "image/x-icon"
    elif request_path.ends_with(".txt"):
        ctype = "text/plain"
    elif request_path.ends_with(".xml"):
        ctype = "application/xml"
    elif request_path.ends_with(".wasm"):
        ctype = "application/wasm"

    val content = file_read_text(full_path)
    val body = rt_text_to_bytes(content)

    var headers: [(text, text)] = []
    headers.push(("content-type", ctype))
    headers.push(("content-length", "{body.len()}"))

    return H3Response(
        status: 200,
        headers: headers,
        body: body
    )

# ============================================================================
# H3Connection — manages HTTP/3 control streams + request streams
# ============================================================================

class H3Connection:
    """HTTP/3 connection state over a QUIC connection.

    Manages the control stream, QPACK encoder/decoder streams, and
    request streams. Call on_transport_event() to feed QUIC events.
    """
    conn_key: text
    codec: QpackCodec
    settings: H3Settings
    peer_settings: H3Settings
    streams: Dict<i64, H3Stream>
    control_stream_id: i64
    settings_sent: bool
    goaway_sent: bool
    static_root: text

    static fn create(conn_key: text, static_root: text) -> H3Connection:
        return H3Connection(
            conn_key: conn_key,
            codec: QpackCodec.create(),
            settings: default_h3_settings(),
            peer_settings: default_h3_settings(),
            streams: {},
            control_stream_id: -1,
            settings_sent: false,
            goaway_sent: false,
            static_root: static_root
        )

    me on_stream_data(stream_id: i64, data: [u8]) -> [(i64, [u8])]:
        """Process data received on a QUIC stream.

        Returns a list of (stream_id, response_bytes) pairs to send.
        """
        var responses: [(i64, [u8])] = []

        # Create stream tracker if new
        if not self.streams.contains(stream_id):
            val stream = H3Stream.create(stream_id, self.conn_key)
            self.streams[stream_id] = stream

        var stream = self.streams[stream_id]
        stream.on_data(data)

        # Try to decode and handle the request
        val req = stream.try_decode_request()
        if req != nil and not stream.response_sent:
            val resp = self._handle_request(req)
            val resp_bytes = stream.encode_response(resp)
            responses.push((stream_id, resp_bytes))

        return responses

    me initial_settings_frame() -> [u8]:
        """Produce the SETTINGS frame to send on the control stream."""
        self.settings_sent = true
        return h3_encode_settings(self.settings)

    me send_goaway(last_stream_id: i64) -> [u8]:
        """Produce a GOAWAY frame."""
        self.goaway_sent = true
        return h3_encode_goaway(last_stream_id)

    # ------------------------------------------------------------------
    # Internal request handling
    # ------------------------------------------------------------------

    me _handle_request(req: H3Request) -> H3Response:
        """Handle an HTTP/3 request. Serves static files from static_root."""
        if self.static_root != "":
            return h3_static_file_response(self.static_root, req.path)

        # Default: return 200 with empty body
        return H3Response(
            status: 200,
            headers: [("content-type", "text/plain")],
            body: rt_text_to_bytes("OK")
        )

# ============================================================================
# Internal helpers
# ============================================================================

fn _h3_append(dest: [u8], src: [u8]):
    """Append src bytes to dest."""
    var i = 0
    loop:
        if i >= src.len():
            break
        dest.push(src[i])
        i = i + 1

fn _h3_varint_encode(value: i64) -> [u8]:
    """Encode a value as a QUIC variable-length integer (RFC 9000 §16)."""
    var result: [u8] = []
    if value < 64:
        result.push(value & 0xff)
    elif value < 16384:
        result.push(((value >> 8) & 0x3f) | 0x40)
        result.push(value & 0xff)
    elif value < 1073741824:
        result.push(((value >> 24) & 0x3f) | 0x80)
        result.push((value >> 16) & 0xff)
        result.push((value >> 8) & 0xff)
        result.push(value & 0xff)
    else:
        result.push(((value >> 56) & 0x3f) | 0xc0)
        result.push((value >> 48) & 0xff)
        result.push((value >> 40) & 0xff)
        result.push((value >> 32) & 0xff)
        result.push((value >> 24) & 0xff)
        result.push((value >> 16) & 0xff)
        result.push((value >> 8) & 0xff)
        result.push(value & 0xff)
    return result

fn _h3_varint_decode(data: [u8], offset: i64) -> (i64, i64)?:
    """Decode a QUIC variable-length integer. Returns (value, new_offset) or nil."""
    if offset < 0:
        return nil
    if offset >= data.len():
        return nil
    val first = data[offset]
    val prefix = (first >> 6) & 0x03

    if prefix == 0:
        return (first & 0x3f, offset + 1)
    elif prefix == 1:
        if offset + 1 >= data.len():
            return nil
        val v = ((first & 0x3f) << 8) | data[offset + 1]
        return (v, offset + 2)
    elif prefix == 2:
        if offset + 3 >= data.len():
            return nil
        val v = ((first & 0x3f) << 24) | (data[offset + 1] << 16) | (data[offset + 2] << 8) | data[offset + 3]
        return (v, offset + 4)
    else:
        if offset + 7 >= data.len():
            return nil
        val v = ((first & 0x3f) << 56) | (data[offset + 1] << 48) | (data[offset + 2] << 40) | (data[offset + 3] << 32) | (data[offset + 4] << 24) | (data[offset + 5] << 16) | (data[offset + 6] << 8) | data[offset + 7]
        return (v, offset + 8)
