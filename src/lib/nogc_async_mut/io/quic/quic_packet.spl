# QUIC Packet Types and Parsing — RFC 9000 §17
#
# Implements the QUIC packet wire format:
#   - Variable-length integer encoding (RFC 9000 §16)
#   - Long header packets: Initial, Handshake, 0-RTT, Retry (§17.2)
#   - Short header packets: 1-RTT (§17.3)
#   - Version Negotiation (§17.2.1)
#
# Packet header parsing extracts: type, version, connection IDs, packet
# number, and payload offset. Crypto protection is NOT applied here —
# the header is parsed from plaintext or after header-protection removal.
#
# Reference: RFC 9000 §17, §16

# ============================================================================
# Constants — QUIC version and packet type markers
# ============================================================================

val QUIC_VERSION_1: i64 = 0x00000001

# Long header form bit (bit 7 of first byte)
val QUIC_LONG_HEADER_BIT: i64 = 0x80
# Fixed bit (bit 6, must be 1 in QUIC v1)
val QUIC_FIXED_BIT: i64       = 0x40

# Long header type field (bits 5-4 of first byte) — RFC 9000 §17.2
val QUIC_LH_TYPE_INITIAL: i64   = 0x00
val QUIC_LH_TYPE_ZERO_RTT: i64  = 0x01
val QUIC_LH_TYPE_HANDSHAKE: i64 = 0x02
val QUIC_LH_TYPE_RETRY: i64     = 0x03

# ============================================================================
# Packet type enum — RFC 9000 §17
# ============================================================================

enum QuicPacketType:
    """Classification of a QUIC packet by its header form."""
    # Long header: client initial (§17.2.2)
    Initial
    # Long header: 0-RTT protected (§17.2.3)
    ZeroRTT
    # Long header: handshake (§17.2.4)
    Handshake
    # Long header: retry (§17.2.5)
    Retry
    # Short header: 1-RTT protected (§17.3)
    OneRTT
    # Version negotiation (§17.2.1)
    VersionNeg

# ============================================================================
# Result types
# ============================================================================

class QuicVarintOk:
    """Successful varint decode: decoded value and number of bytes consumed."""
    value: i64
    consumed: i64

enum QuicVarintResult:
    """Result of decoding a QUIC variable-length integer."""
    Ok(QuicVarintOk)
    Err(msg: text)

class QuicPacketHeader:
    """Parsed QUIC packet header fields.

    For long headers all fields are populated. For short (1-RTT) headers,
    src_conn_id is empty and version is zero.
    """
    packet_type: QuicPacketType
    version: i64
    dest_conn_id: [u8]
    src_conn_id: [u8]
    packet_number: i64
    payload_offset: i64

enum QuicHeaderResult:
    """Result of parsing a QUIC packet header."""
    Ok(QuicPacketHeader)
    Err(msg: text)

# ============================================================================
# Variable-length integer encoding — RFC 9000 §16
#
# Two high bits of the first byte give the encoded length:
#   00 → 1 byte  (6-bit value,  0..63)
#   01 → 2 bytes (14-bit value, 0..16383)
#   10 → 4 bytes (30-bit value, 0..1073741823)
#   11 → 8 bytes (62-bit value, 0..4611686018427387903)
#
# Value bits are big-endian and share the first byte with the 2-bit prefix.
# ============================================================================

pub fn quic_varint_decode(data: [u8], offset: i64) -> QuicVarintResult:
    """Decode one QUIC variable-length integer from data at offset."""
    if offset >= data.len():
        return QuicVarintResult.Err("varint: truncated at first byte")
    val first = data[offset]
    val prefix = (first >> 6) & 0x03

    if prefix == 0:
        # 1-byte encoding: 6-bit value
        return QuicVarintResult.Ok(QuicVarintOk(
            value: first & 0x3f,
            consumed: 1
        ))

    if prefix == 1:
        # 2-byte encoding: 14-bit value
        if offset + 2 > data.len():
            return QuicVarintResult.Err("varint: need 2 bytes, truncated")
        val v = ((first & 0x3f) << 8) | data[offset + 1]
        return QuicVarintResult.Ok(QuicVarintOk(value: v, consumed: 2))

    if prefix == 2:
        # 4-byte encoding: 30-bit value
        if offset + 4 > data.len():
            return QuicVarintResult.Err("varint: need 4 bytes, truncated")
        var v = (first & 0x3f) << 24
        v = v | (data[offset + 1] << 16)
        v = v | (data[offset + 2] << 8)
        v = v | data[offset + 3]
        return QuicVarintResult.Ok(QuicVarintOk(value: v, consumed: 4))

    # prefix == 3: 8-byte encoding: 62-bit value
    if offset + 8 > data.len():
        return QuicVarintResult.Err("varint: need 8 bytes, truncated")
    var v = (first & 0x3f) << 56
    v = v | (data[offset + 1] << 48)
    v = v | (data[offset + 2] << 40)
    v = v | (data[offset + 3] << 32)
    v = v | (data[offset + 4] << 24)
    v = v | (data[offset + 5] << 16)
    v = v | (data[offset + 6] << 8)
    v = v | data[offset + 7]
    return QuicVarintResult.Ok(QuicVarintOk(value: v, consumed: 8))

pub fn quic_varint_encode(value: i64) -> [u8]:
    """Encode a QUIC variable-length integer."""
    if value < 0:
        return [0]

    if value <= 63:
        # 1-byte: 6-bit
        return [value & 0x3f]

    if value <= 16383:
        # 2-byte: 14-bit, prefix 01
        return [
            0x40 | ((value >> 8) & 0x3f),
            value & 0xff
        ]

    if value <= 1073741823:
        # 4-byte: 30-bit, prefix 10
        return [
            0x80 | ((value >> 24) & 0x3f),
            (value >> 16) & 0xff,
            (value >> 8) & 0xff,
            value & 0xff
        ]

    # 8-byte: 62-bit, prefix 11
    return [
        0xc0 | ((value >> 56) & 0x3f),
        (value >> 48) & 0xff,
        (value >> 40) & 0xff,
        (value >> 32) & 0xff,
        (value >> 24) & 0xff,
        (value >> 16) & 0xff,
        (value >> 8) & 0xff,
        value & 0xff
    ]

# ============================================================================
# Internal helpers
# ============================================================================

fn _read_conn_id(data: [u8], offset: i64) -> ([u8], i64):
    """Read a connection ID: 1-byte length prefix + that many bytes.

    Returns (conn_id_bytes, new_offset).
    """
    if offset >= data.len():
        return ([], offset)
    val id_len = data[offset]
    var cid: [u8] = []
    var i = 0
    loop:
        if i >= id_len:
            break
        if offset + 1 + i >= data.len():
            break
        cid.push(data[offset + 1 + i])
        i = i + 1
    return (cid, offset + 1 + id_len)

fn _append_bytes(out: [u8], src: [u8]):
    """Append all bytes of src onto out."""
    var i = 0
    loop:
        if i >= src.len():
            break
        out.push(src[i])
        i = i + 1

# ============================================================================
# Packet header parsing — RFC 9000 §17
# ============================================================================

pub fn parse_quic_header(data: [u8]) -> QuicHeaderResult:
    """Parse a QUIC packet header from raw bytes.

    Handles both long-header (Initial, Handshake, 0-RTT, Retry,
    Version Negotiation) and short-header (1-RTT) forms.
    Does NOT remove header protection — caller must do that first.

    Returns QuicHeaderResult.Ok with parsed fields or Err on truncation.
    """
    if data.len() < 1:
        return QuicHeaderResult.Err("empty packet")

    val first = data[0]
    val is_long = (first & QUIC_LONG_HEADER_BIT) != 0

    if not is_long:
        # Short header (1-RTT) — RFC 9000 §17.3
        # First byte: 0 | Fixed(1) | Spin | Reserved(2) | Key Phase | PN Len(2)
        # Followed by Destination Connection ID (length known from context)
        # Then packet number (1-4 bytes based on PN Len bits)
        # We cannot know the DCID length without connection state, so we
        # return a minimal header. Caller must supply DCID length.
        return QuicHeaderResult.Ok(QuicPacketHeader(
            packet_type: QuicPacketType.OneRTT,
            version: 0,
            dest_conn_id: [],
            src_conn_id: [],
            packet_number: 0,
            payload_offset: 1
        ))

    # Long header — RFC 9000 §17.2
    # Bytes: first(1) | version(4) | DCID len(1) | DCID | SCID len(1) | SCID | ...
    if data.len() < 6:
        return QuicHeaderResult.Err("long header truncated: need >= 6 bytes")

    val version = (data[1] << 24) | (data[2] << 16) | (data[3] << 8) | data[4]

    # Version Negotiation: version field is 0 — RFC 9000 §17.2.1
    if version == 0:
        val (dcid, after_dcid) = _read_conn_id(data, 5)
        val (scid, after_scid) = _read_conn_id(data, after_dcid)
        return QuicHeaderResult.Ok(QuicPacketHeader(
            packet_type: QuicPacketType.VersionNeg,
            version: 0,
            dest_conn_id: dcid,
            src_conn_id: scid,
            packet_number: 0,
            payload_offset: after_scid
        ))

    # Determine long-header type from bits 5-4
    val lh_type = (first >> 4) & 0x03

    val (dcid, after_dcid) = _read_conn_id(data, 5)
    val (scid, after_scid) = _read_conn_id(data, after_dcid)

    var pkt_type = QuicPacketType.Initial
    var payload_off = after_scid

    if lh_type == QUIC_LH_TYPE_INITIAL:
        pkt_type = QuicPacketType.Initial
        # Initial packets have a token length varint + token before payload
        val tok_r = quic_varint_decode(data, after_scid)
        match tok_r:
            case Ok(tr):
                payload_off = after_scid + tr.consumed + tr.value
            case Err(msg):
                return QuicHeaderResult.Err("initial token length: {msg}")

    if lh_type == QUIC_LH_TYPE_ZERO_RTT:
        pkt_type = QuicPacketType.ZeroRTT
        payload_off = after_scid

    if lh_type == QUIC_LH_TYPE_HANDSHAKE:
        pkt_type = QuicPacketType.Handshake
        payload_off = after_scid

    if lh_type == QUIC_LH_TYPE_RETRY:
        pkt_type = QuicPacketType.Retry
        # Retry has no packet number; rest is retry token + integrity tag
        return QuicHeaderResult.Ok(QuicPacketHeader(
            packet_type: QuicPacketType.Retry,
            version: version,
            dest_conn_id: dcid,
            src_conn_id: scid,
            packet_number: 0,
            payload_offset: after_scid
        ))

    # For Initial, Handshake, 0-RTT: read payload length varint, then PN
    val len_r = quic_varint_decode(data, payload_off)
    match len_r:
        case Ok(lr):
            val pn_offset = payload_off + lr.consumed
            # Packet number is 1-4 bytes; length encoded in low 2 bits of first byte
            val pn_len = (first & 0x03) + 1
            var pn: i64 = 0
            var pi = 0
            loop:
                if pi >= pn_len:
                    break
                if pn_offset + pi < data.len():
                    pn = (pn << 8) | data[pn_offset + pi]
                pi = pi + 1

            return QuicHeaderResult.Ok(QuicPacketHeader(
                packet_type: pkt_type,
                version: version,
                dest_conn_id: dcid,
                src_conn_id: scid,
                packet_number: pn,
                payload_offset: pn_offset + pn_len
            ))
        case Err(msg):
            return QuicHeaderResult.Err("payload length: {msg}")

    return QuicHeaderResult.Err("unreachable")

# ============================================================================
# Packet header encoding — RFC 9000 §17
# ============================================================================

pub fn encode_quic_header(header: QuicPacketHeader) -> [u8]:
    """Encode a QUIC packet header to bytes.

    Builds the wire header for the given packet type. Payload is NOT
    included — caller appends payload after the returned header bytes.
    Crypto protection is NOT applied.
    """
    var out: [u8] = []

    match header.packet_type:
        case OneRTT:
            # Short header: Fixed bit set, long-header bit clear
            val first = QUIC_FIXED_BIT
            out.push(first)
            _append_bytes(out, header.dest_conn_id)
            return out

        case VersionNeg:
            # Version Negotiation: long bit set, version = 0
            out.push(QUIC_LONG_HEADER_BIT | QUIC_FIXED_BIT)
            # Version = 0 (4 bytes)
            out.push(0)
            out.push(0)
            out.push(0)
            out.push(0)
            # DCID
            out.push(header.dest_conn_id.len())
            _append_bytes(out, header.dest_conn_id)
            # SCID
            out.push(header.src_conn_id.len())
            _append_bytes(out, header.src_conn_id)
            return out

        case _:
            pass

    # Long header: Initial, Handshake, ZeroRTT, Retry
    var lh_type = QUIC_LH_TYPE_INITIAL
    match header.packet_type:
        case Initial:
            lh_type = QUIC_LH_TYPE_INITIAL
        case ZeroRTT:
            lh_type = QUIC_LH_TYPE_ZERO_RTT
        case Handshake:
            lh_type = QUIC_LH_TYPE_HANDSHAKE
        case Retry:
            lh_type = QUIC_LH_TYPE_RETRY
        case _:
            pass

    val first = QUIC_LONG_HEADER_BIT | QUIC_FIXED_BIT | (lh_type << 4)
    out.push(first)

    # Version (4 bytes big-endian)
    out.push((header.version >> 24) & 0xff)
    out.push((header.version >> 16) & 0xff)
    out.push((header.version >> 8) & 0xff)
    out.push(header.version & 0xff)

    # DCID
    out.push(header.dest_conn_id.len())
    _append_bytes(out, header.dest_conn_id)

    # SCID
    out.push(header.src_conn_id.len())
    _append_bytes(out, header.src_conn_id)

    # Initial packets: token length = 0 (no token in this skeleton)
    match header.packet_type:
        case Initial:
            out.push(0)
        case _:
            pass

    return out

export QUIC_VERSION_1, QUIC_LONG_HEADER_BIT, QUIC_FIXED_BIT
export QUIC_LH_TYPE_INITIAL, QUIC_LH_TYPE_ZERO_RTT, QUIC_LH_TYPE_HANDSHAKE, QUIC_LH_TYPE_RETRY
export QuicPacketType, QuicVarintOk, QuicVarintResult, QuicPacketHeader, QuicHeaderResult
