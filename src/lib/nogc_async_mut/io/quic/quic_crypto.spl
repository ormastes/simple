# QUIC Crypto — Initial Packet Protection & TLS 1.3 Key Schedule
#
# Implements QUIC-TLS (RFC 9001) cryptographic operations:
#   - QUIC Initial salt and secret derivation (RFC 9001 §5.2)
#   - HKDF-Expand-Label with "tls13 " prefix (RFC 8446 §7.1)
#   - derive_initial_secrets: client_in / server_in from connection ID
#   - derive_quic_keys: key / iv / hp from a traffic secret
#   - QUIC AEAD encrypt/decrypt (AES-128-GCM) for packet payload
#   - Header protection mask (AES-ECB sample) — stub pending pure AES-ECB
#   - QUIC CRYPTO frame buffer for TLS handshake message reassembly
#   - TLS 1.3 key schedule advancement (early → handshake → application)
#
# Pure Simple implementation using existing crypto primitives:
#   - std.common.crypto.hkdf  (HKDF-SHA-256)
#   - std.common.crypto.sha256 (SHA-256)
#   - std.common.crypto.hmac  (HMAC-SHA-256)
#   - rt_aes_gcm_encrypt_hex / rt_aes_gcm_decrypt_hex (AEAD externs)
#
# Reference: RFC 9001 §5 (QUIC-TLS), RFC 8446 §7.1 (Key Schedule)

use std.common.crypto.hkdf.{hkdf_extract_sha256, hkdf_expand_sha256}
use std.common.crypto.sha256.{sha256_bytes}
use std.common.crypto.hmac.{hmac_sha256_bytes}

# ============================================================================
# AEAD externs — AES-128-GCM via runtime (hex domain)
# ============================================================================

extern fn rt_aes_gcm_encrypt_hex(key_hex: text, iv_hex: text, plaintext_hex: text, aad_hex: text) -> text
extern fn rt_aes_gcm_decrypt_hex(key_hex: text, iv_hex: text, ciphertext_hex: text, aad_hex: text) -> text

# ============================================================================
# Constants — RFC 9001 §5.2
# ============================================================================

# QUIC v1 Initial salt (20 bytes) — RFC 9001 §5.2
# 0x38762cf7f55934b34d179ae6a4c80cadccbb7f0a
val QUIC_INITIAL_SALT_V1: [i64] = [
    0x38, 0x76, 0x2c, 0xf7, 0xf5, 0x59, 0x34, 0xb3, 0x4d, 0x17,
    0x9a, 0xe6, 0xa4, 0xc8, 0x0c, 0xad, 0xcc, 0xbb, 0x7f, 0x0a
]

# SHA-256 hash length
val SHA256_HASH_LEN: i64 = 32

# AES-128-GCM key length
val AES_128_KEY_LEN: i64 = 16

# AEAD IV length for QUIC
val QUIC_IV_LEN: i64 = 12

# Header protection key length (AES-128)
val QUIC_HP_KEY_LEN: i64 = 16

# AES-128-GCM tag length
val QUIC_AEAD_TAG_LEN: i64 = 16

# ============================================================================
# TLS 1.3 handshake encryption levels — RFC 9001 §4
# ============================================================================

enum QuicEncryptionLevel:
    """QUIC encryption level, corresponding to TLS key phases."""
    # Initial: keys derived from connection ID (no TLS state)
    Initial
    # Handshake: keys from TLS handshake traffic secrets
    Handshake
    # Application (1-RTT): keys from TLS application traffic secrets
    Application
    # 0-RTT: keys from early traffic secret (PSK/resumption)
    ZeroRTT

# ============================================================================
# TLS 1.3 handshake state — tracks key schedule progress
# ============================================================================

enum QuicTlsState:
    """TLS 1.3 handshake state as seen by QUIC."""
    # Waiting for/sending ClientHello
    WaitClientHello
    # Waiting for/sending ServerHello
    WaitServerHello
    # Processing EncryptedExtensions, Certificate, CertificateVerify
    WaitEncryptedExtensions
    # Waiting for Finished message
    WaitFinished
    # Handshake complete, application data may flow
    Connected
    # Error state
    Failed

# ============================================================================
# QuicPacketKeys — AEAD key material for one direction at one level
# ============================================================================

class QuicPacketKeys:
    """AEAD key material for encrypting/decrypting QUIC packets.

    Holds the AES-128-GCM key, IV, and header protection key for
    one direction (client→server or server→client) at one encryption level.
    """
    aead_key: [i64]
    iv: [i64]
    hp_key: [i64]

# ============================================================================
# QuicCryptoState — full crypto context for a QUIC connection
# ============================================================================

class QuicCryptoState:
    """Crypto state for a QUIC connection.

    Tracks the TLS handshake state, holds keys for each encryption level,
    and buffers CRYPTO frame data for handshake message reassembly.
    """
    tls_state: QuicTlsState
    # Keys for each direction and level
    client_initial_keys: QuicPacketKeys?
    server_initial_keys: QuicPacketKeys?
    client_handshake_keys: QuicPacketKeys?
    server_handshake_keys: QuicPacketKeys?
    client_app_keys: QuicPacketKeys?
    server_app_keys: QuicPacketKeys?
    # CRYPTO frame reassembly buffers (per level)
    initial_crypto_buf: [u8]
    handshake_crypto_buf: [u8]
    # Consumed byte offsets — tracks how far extract_handshake_messages has
    # scanned so we never re-emit previously completed messages.
    initial_crypto_consumed: i64
    handshake_crypto_consumed: i64
    # Current key schedule secrets (for advancing to next level)
    handshake_secret: [i64]
    master_secret: [i64]
    # Packet number trackers (per level)
    initial_pn: i64
    handshake_pn: i64
    app_pn: i64

    static fn create() -> QuicCryptoState:
        """Create a new crypto state in initial (pre-handshake) state."""
        return QuicCryptoState(
            tls_state: QuicTlsState.WaitClientHello,
            client_initial_keys: nil,
            server_initial_keys: nil,
            client_handshake_keys: nil,
            server_handshake_keys: nil,
            client_app_keys: nil,
            server_app_keys: nil,
            initial_crypto_buf: [],
            handshake_crypto_buf: [],
            initial_crypto_consumed: 0,
            handshake_crypto_consumed: 0,
            handshake_secret: [],
            master_secret: [],
            initial_pn: 0,
            handshake_pn: 0,
            app_pn: 0
        )

# ============================================================================
# HKDF-Expand-Label — RFC 8446 §7.1, adapted for QUIC (RFC 9001 §5.1)
#
# HkdfLabel = struct {
#     uint16 length;
#     opaque label<7..255>;         // "tls13 " + label
#     opaque context<0..255>;
# };
# ============================================================================

fn quic_hkdf_expand_label(secret: [i64], label: text, ctx: [i64], length: i64) -> [i64]:
    """HKDF-Expand-Label per RFC 8446 §7.1 with 'tls13 ' prefix.

    Builds the HkdfLabel struct as the info parameter for HKDF-Expand:
      length(2) || label_len(1) || "tls13 " || label || ctx_len(1) || ctx

    Parameters:
        secret: PRK (32 bytes for SHA-256)
        label: ASCII label WITHOUT the "tls13 " prefix
        ctx: context hash (may be empty)
        length: desired output bytes
    Returns: length-byte OKM
    """
    val prefix = "tls13 "
    val full_label_len = prefix.len() + label.len()

    # Build info: length(2) || label_len(1) || "tls13 " || label || ctx_len(1) || ctx
    var info: [i64] = []

    # uint16 length
    info.push((length >> 8) & 0xff)
    info.push(length & 0xff)

    # opaque label<7..255>: length prefix + "tls13 " + label
    info.push(full_label_len & 0xff)

    # "tls13 " bytes
    info.push(0x74)  # t
    info.push(0x6c)  # l
    info.push(0x73)  # s
    info.push(0x31)  # 1
    info.push(0x33)  # 3
    info.push(0x20)  # space

    # label bytes
    var li = 0
    loop:
        if li >= label.len():
            break
        info.push(_char_code_at(label, li))
        li = li + 1

    # opaque context<0..255>: length prefix + context bytes
    info.push(ctx.len() & 0xff)
    var ci = 0
    loop:
        if ci >= ctx.len():
            break
        info.push(ctx[ci])
        ci = ci + 1

    return hkdf_expand_sha256(secret, info, length)

# ============================================================================
# Initial Secret Derivation — RFC 9001 §5.2
#
# initial_secret = HKDF-Extract(QUIC_INITIAL_SALT, client_dst_connection_id)
# client_initial_secret = HKDF-Expand-Label(initial_secret, "client in", "", 32)
# server_initial_secret = HKDF-Expand-Label(initial_secret, "server in", "", 32)
# ============================================================================

fn derive_initial_secret(client_dst_cid: [u8]) -> [i64]:
    """Derive the Initial secret from client's destination connection ID.

    initial_secret = HKDF-Extract(QUIC_INITIAL_SALT_V1, cid)

    Parameters:
        client_dst_cid: Destination Connection ID from client's Initial packet
    Returns: 32-byte initial secret
    """
    # Convert [u8] to [i64] for crypto APIs
    var ikm: [i64] = []
    var i = 0
    loop:
        if i >= client_dst_cid.len():
            break
        ikm.push(client_dst_cid[i])
        i = i + 1

    return hkdf_extract_sha256(QUIC_INITIAL_SALT_V1, ikm)

fn derive_initial_secrets(client_dst_cid: [u8]) -> (QuicPacketKeys, QuicPacketKeys):
    """Derive both client and server Initial packet keys from connection ID.

    Returns: (client_keys, server_keys)
    """
    val initial_secret = derive_initial_secret(client_dst_cid)

    val empty_ctx: [i64] = []

    # Derive client/server initial traffic secrets
    val client_secret = quic_hkdf_expand_label(initial_secret, "client in", empty_ctx, SHA256_HASH_LEN)
    val server_secret = quic_hkdf_expand_label(initial_secret, "server in", empty_ctx, SHA256_HASH_LEN)

    # Derive keys from secrets
    val client_keys = derive_quic_keys(client_secret)
    val server_keys = derive_quic_keys(server_secret)

    return (client_keys, server_keys)

# ============================================================================
# QUIC Key Derivation — RFC 9001 §5.1
#
# key = HKDF-Expand-Label(secret, "quic key", "", key_len)
# iv  = HKDF-Expand-Label(secret, "quic iv",  "", iv_len)
# hp  = HKDF-Expand-Label(secret, "quic hp",  "", hp_key_len)
# ============================================================================

fn derive_quic_keys(secret: [i64]) -> QuicPacketKeys:
    """Derive QUIC AEAD key, IV, and header protection key from a traffic secret.

    Parameters:
        secret: 32-byte traffic secret
    Returns: QuicPacketKeys with key(16), iv(12), hp(16)
    """
    val empty_ctx: [i64] = []

    val aead_key = quic_hkdf_expand_label(secret, "quic key", empty_ctx, AES_128_KEY_LEN)
    val iv = quic_hkdf_expand_label(secret, "quic iv", empty_ctx, QUIC_IV_LEN)
    val hp_key = quic_hkdf_expand_label(secret, "quic hp", empty_ctx, QUIC_HP_KEY_LEN)

    return QuicPacketKeys(
        aead_key: aead_key,
        iv: iv,
        hp_key: hp_key
    )

# ============================================================================
# TLS 1.3 Key Schedule — RFC 8446 §7.1, RFC 9001 §5.1
#
# Advances the key schedule through handshake and application phases.
# Full derivation path:
#   Early Secret = HKDF-Extract(0, 0)       [no PSK]
#   Handshake Secret = HKDF-Extract(derived, ECDHE)
#   Master Secret = HKDF-Extract(derived, 0)
#
# "derived" = HKDF-Expand-Label(secret, "derived", SHA256(""), 32)
# ============================================================================

fn derive_secret(secret: [i64], label: text, messages_hash: [i64]) -> [i64]:
    """Derive-Secret per RFC 8446 §7.1.

    Derive-Secret(Secret, Label, Messages) =
        HKDF-Expand-Label(Secret, Label, Transcript-Hash(Messages), Hash.length)

    Parameters:
        secret: current secret in the key schedule
        label: derivation label (e.g., "derived", "c hs traffic")
        messages_hash: SHA-256 hash of handshake transcript
    Returns: 32-byte derived secret
    """
    return quic_hkdf_expand_label(secret, label, messages_hash, SHA256_HASH_LEN)

fn derive_early_secret() -> [i64]:
    """Derive Early Secret with no PSK (all zeros).

    Early Secret = HKDF-Extract(salt=0, IKM=0)
    """
    val zero_salt: [i64] = _zeros_i64(SHA256_HASH_LEN)
    val zero_ikm: [i64] = _zeros_i64(SHA256_HASH_LEN)
    return hkdf_extract_sha256(zero_salt, zero_ikm)

fn derive_handshake_secrets(shared_secret: [i64], transcript_hash: [i64]) -> ([i64], QuicPacketKeys, QuicPacketKeys):
    """Derive handshake-level secrets and keys from ECDHE shared secret.

    Parameters:
        shared_secret: ECDHE shared secret (from key exchange)
        transcript_hash: SHA-256(ClientHello || ServerHello)
    Returns: (handshake_secret, client_hs_keys, server_hs_keys)
    """
    val early_secret = derive_early_secret()
    val empty_hash = sha256_bytes([])

    # derived_secret = Derive-Secret(early_secret, "derived", "")
    val derived = derive_secret(early_secret, "derived", empty_hash)

    # handshake_secret = HKDF-Extract(derived, shared_secret)
    val hs_secret = hkdf_extract_sha256(derived, shared_secret)

    # client/server handshake traffic secrets
    val c_hs = derive_secret(hs_secret, "c hs traffic", transcript_hash)
    val s_hs = derive_secret(hs_secret, "s hs traffic", transcript_hash)

    val client_keys = derive_quic_keys(c_hs)
    val server_keys = derive_quic_keys(s_hs)

    return (hs_secret, client_keys, server_keys)

fn derive_application_secrets(handshake_secret: [i64], transcript_hash: [i64]) -> (QuicPacketKeys, QuicPacketKeys):
    """Derive application-level (1-RTT) secrets and keys.

    Parameters:
        handshake_secret: from derive_handshake_secrets
        transcript_hash: SHA-256(ClientHello..server Finished)
    Returns: (client_app_keys, server_app_keys)
    """
    val empty_hash = sha256_bytes([])

    # derived_secret for master
    val derived = derive_secret(handshake_secret, "derived", empty_hash)

    # master_secret = HKDF-Extract(derived, 0)
    val zero_ikm: [i64] = _zeros_i64(SHA256_HASH_LEN)
    val master = hkdf_extract_sha256(derived, zero_ikm)

    # client/server application traffic secrets
    val c_ap = derive_secret(master, "c ap traffic", transcript_hash)
    val s_ap = derive_secret(master, "s ap traffic", transcript_hash)

    val client_keys = derive_quic_keys(c_ap)
    val server_keys = derive_quic_keys(s_ap)

    return (client_keys, server_keys)

# ============================================================================
# AEAD Encrypt / Decrypt — RFC 9001 §5.3
#
# QUIC uses AES-128-GCM for Initial and most handshake/app packets.
# Nonce = IV XOR packet_number (left-padded to IV length).
# AAD = QUIC packet header (up to and including the packet number).
# ============================================================================

fn quic_compute_nonce(iv: [i64], packet_number: i64) -> [i64]:
    """Compute AEAD nonce by XORing IV with left-padded packet number.

    RFC 9001 §5.3: nonce = iv XOR pn (pn zero-extended to iv length).
    """
    var nonce: [i64] = []
    var i = 0
    loop:
        if i >= iv.len():
            break
        nonce.push(iv[i])
        i = i + 1

    # XOR packet number into the rightmost bytes of nonce
    val pn_offset = nonce.len() - 1
    nonce[pn_offset] = nonce[pn_offset] ^ (packet_number & 0xff)
    if pn_offset >= 1:
        nonce[pn_offset - 1] = nonce[pn_offset - 1] ^ ((packet_number >> 8) & 0xff)
    if pn_offset >= 2:
        nonce[pn_offset - 2] = nonce[pn_offset - 2] ^ ((packet_number >> 16) & 0xff)
    if pn_offset >= 3:
        nonce[pn_offset - 3] = nonce[pn_offset - 3] ^ ((packet_number >> 24) & 0xff)

    return nonce

fn quic_aead_encrypt(keys: QuicPacketKeys, pn: i64, header: [u8], payload: [u8]) -> text:
    """Encrypt a QUIC packet payload with AES-128-GCM.

    Parameters:
        keys: AEAD key material
        pn: packet number (for nonce derivation)
        header: packet header bytes (used as AAD)
        payload: plaintext payload
    Returns: hex-encoded ciphertext+tag, or empty text on error
    """
    val nonce = quic_compute_nonce(keys.iv, pn)

    val key_hex = _bytes_to_hex_i64(keys.aead_key)
    val nonce_hex = _bytes_to_hex_i64(nonce)
    val payload_hex = _bytes_to_hex_u8(payload)
    val header_hex = _bytes_to_hex_u8(header)

    return rt_aes_gcm_encrypt_hex(key_hex, nonce_hex, payload_hex, header_hex)

fn quic_aead_decrypt(keys: QuicPacketKeys, pn: i64, header: [u8], ciphertext: [u8]) -> text:
    """Decrypt a QUIC packet payload with AES-128-GCM.

    Parameters:
        keys: AEAD key material
        pn: packet number (for nonce derivation)
        header: packet header bytes (used as AAD)
        ciphertext: ciphertext+tag
    Returns: hex-encoded plaintext, or empty text on auth failure
    """
    val nonce = quic_compute_nonce(keys.iv, pn)

    val key_hex = _bytes_to_hex_i64(keys.aead_key)
    val nonce_hex = _bytes_to_hex_i64(nonce)
    val ct_hex = _bytes_to_hex_u8(ciphertext)
    val header_hex = _bytes_to_hex_u8(header)

    return rt_aes_gcm_decrypt_hex(key_hex, nonce_hex, ct_hex, header_hex)

# ============================================================================
# Header Protection — RFC 9001 §5.4
#
# QUIC header protection uses AES-ECB to generate a 5-byte mask from
# a sample of the ciphertext. The mask is XORed with the first header
# byte (partially) and the packet number bytes.
#
# For AES-128, sample = ciphertext[pn_offset+4 .. pn_offset+4+16]
# mask = AES-ECB(hp_key, sample)  (first 5 bytes used)
#
# Pure AES-ECB is not yet available in std.common.crypto — this
# provides the interface and a documented stub.
# ============================================================================

fn quic_header_protect_mask(hp_key: [i64], sample: [u8]) -> [u8]:
    """Compute header protection mask from ciphertext sample.

    Uses AES-ECB(hp_key, sample) → first 5 bytes as mask.
    TODO: [quic-crypto][P2] wire pure-Simple AES-ECB once available in std.common.crypto

    Parameters:
        hp_key: 16-byte header protection key
        sample: 16-byte ciphertext sample
    Returns: 5-byte mask (stubbed as zeros until AES-ECB is available)
    """
    # Stub: return zero mask (no header protection applied)
    # Real implementation: mask = AES_ECB_encrypt(hp_key, sample)[0..4]
    return [0, 0, 0, 0, 0]

fn quic_apply_header_protection(header: [u8], mask: [u8], pn_offset: i64, pn_len: i64) -> [u8]:
    """Apply header protection by XORing mask into header bytes.

    RFC 9001 §5.4.1:
    - Long header: first byte mask = mask[0] & 0x0f (protect low 4 bits)
    - Short header: first byte mask = mask[0] & 0x1f (protect low 5 bits)
    - PN bytes: XOR with mask[1..pn_len]
    """
    var out: [u8] = []
    var i = 0
    loop:
        if i >= header.len():
            break
        out.push(header[i])
        i = i + 1

    if out.len() == 0 or mask.len() < 5:
        return out

    # Determine if long header
    val is_long = (out[0] & 0x80) != 0
    if is_long:
        out[0] = out[0] ^ (mask[0] & 0x0f)
    else:
        out[0] = out[0] ^ (mask[0] & 0x1f)

    # XOR packet number bytes
    var pi = 0
    loop:
        if pi >= pn_len:
            break
        if pn_offset + pi < out.len() and pi + 1 < mask.len():
            out[pn_offset + pi] = out[pn_offset + pi] ^ mask[pi + 1]
        pi = pi + 1

    return out

# ============================================================================
# CRYPTO frame buffer — reassemble handshake messages from CRYPTO frames
# ============================================================================

fn crypto_buffer_append(buf: [u8], data: [u8], offset: i64) -> [u8]:
    """Append CRYPTO frame data to the reassembly buffer.

    Simple contiguous-only reassembly: if offset matches buffer length,
    append. Otherwise, extend buffer with zeros to fill gap.

    Parameters:
        buf: existing buffer
        data: new CRYPTO frame payload
        offset: stream offset of this data
    Returns: updated buffer
    """
    var out: [u8] = []
    # Copy existing buffer
    var i = 0
    loop:
        if i >= buf.len():
            break
        out.push(buf[i])
        i = i + 1

    # Fill gap if offset is beyond current length
    loop:
        if out.len() >= offset:
            break
        out.push(0)

    # Append new data
    var di = 0
    loop:
        if di >= data.len():
            break
        if offset + di < out.len():
            # Overwrite (retransmission)
            out[offset + di] = data[di]
        else:
            out.push(data[di])
        di = di + 1

    return out

# ============================================================================
# TLS 1.3 Handshake Message Parsing — minimal for QUIC dispatch
# ============================================================================

# TLS 1.3 handshake message types (RFC 8446 §4)
val TLS_HS_CLIENT_HELLO: i64         = 1
val TLS_HS_SERVER_HELLO: i64         = 2
val TLS_HS_ENCRYPTED_EXTENSIONS: i64 = 8
val TLS_HS_CERTIFICATE: i64          = 11
val TLS_HS_CERTIFICATE_VERIFY: i64   = 15
val TLS_HS_FINISHED: i64             = 20

enum QuicCryptoEvent:
    """Events from processing CRYPTO frame data."""
    # A complete TLS handshake message was received
    HandshakeMessage(msg_type: i64, data: [u8])
    # Need to send a TLS handshake message
    SendHandshake(level: QuicEncryptionLevel, data: [u8])
    # Keys are ready for a new encryption level
    KeysReady(level: QuicEncryptionLevel)
    # Handshake complete
    HandshakeComplete
    # Error during handshake
    Error(msg: text)
    # Need more data (incomplete message)
    NeedMore

fn parse_tls_handshake_header(data: [u8], offset: i64) -> (i64, i64, i64):
    """Parse a TLS handshake message header.

    Header: type(1) || length(3)

    Returns: (msg_type, msg_length, new_offset)
    Returns (0, 0, 0) on truncation.
    """
    if offset + 4 > data.len():
        return (0, 0, 0)

    val msg_type = data[offset]
    val msg_len = (data[offset + 1] << 16) | (data[offset + 2] << 8) | data[offset + 3]

    return (msg_type, msg_len, offset + 4)

fn extract_handshake_messages(buf: [u8], start_pos: i64) -> ([QuicCryptoEvent], i64):
    """Extract complete TLS handshake messages from a CRYPTO buffer.

    Parses contiguous handshake messages (type(1) || length(3) || body)
    starting at start_pos (the previously consumed offset) so that
    already-processed messages are never re-emitted.

    Returns: (events, new_consumed_pos)
    """
    var events: [QuicCryptoEvent] = []
    var pos = start_pos

    loop:
        if pos + 4 > buf.len():
            break

        val (msg_type, msg_len, hdr_end) = parse_tls_handshake_header(buf, pos)
        if msg_type == 0 and msg_len == 0:
            break

        if hdr_end + msg_len > buf.len():
            # Incomplete message — need more CRYPTO data
            events.push(QuicCryptoEvent.NeedMore)
            break

        # Extract message body
        var body: [u8] = []
        var i = 0
        loop:
            if i >= msg_len:
                break
            body.push(buf[hdr_end + i])
            i = i + 1

        events.push(QuicCryptoEvent.HandshakeMessage(msg_type: msg_type, data: body))
        pos = hdr_end + msg_len

    return (events, pos)

# ============================================================================
# Internal helpers
# ============================================================================

fn _zeros_i64(n: i64) -> [i64]:
    """Return an n-element [i64] list of zeros."""
    var out: [i64] = []
    var i = 0
    loop:
        if i >= n:
            break
        out.push(0)
        i = i + 1
    return out

fn _char_code_at(s: text, idx: i64) -> i64:
    """Get the byte value of the character at index idx in text s.

    Uses ASCII code points. Simple text is UTF-8, but HKDF labels
    are always ASCII so single-byte indexing is safe.
    """
    val c = s[idx]
    if c == "a": return 0x61
    if c == "b": return 0x62
    if c == "c": return 0x63
    if c == "d": return 0x64
    if c == "e": return 0x65
    if c == "f": return 0x66
    if c == "g": return 0x67
    if c == "h": return 0x68
    if c == "i": return 0x69
    if c == "j": return 0x6a
    if c == "k": return 0x6b
    if c == "l": return 0x6c
    if c == "m": return 0x6d
    if c == "n": return 0x6e
    if c == "o": return 0x6f
    if c == "p": return 0x70
    if c == "q": return 0x71
    if c == "r": return 0x72
    if c == "s": return 0x73
    if c == "t": return 0x74
    if c == "u": return 0x75
    if c == "v": return 0x76
    if c == "w": return 0x77
    if c == "x": return 0x78
    if c == "y": return 0x79
    if c == "z": return 0x7a
    if c == "A": return 0x41
    if c == "B": return 0x42
    if c == "C": return 0x43
    if c == "D": return 0x44
    if c == "E": return 0x45
    if c == "F": return 0x46
    if c == "0": return 0x30
    if c == "1": return 0x31
    if c == "2": return 0x32
    if c == "3": return 0x33
    if c == "4": return 0x34
    if c == "5": return 0x35
    if c == "6": return 0x36
    if c == "7": return 0x37
    if c == "8": return 0x38
    if c == "9": return 0x39
    if c == " ": return 0x20
    if c == "_": return 0x5f
    if c == "-": return 0x2d
    if c == ".": return 0x2e
    return 0x3f  # '?' for unknown

fn _hex_nibble(v: i64) -> text:
    """Single nibble (0-15) to hex char."""
    if v < 10:
        return "{v}"
    if v == 10: return "a"
    if v == 11: return "b"
    if v == 12: return "c"
    if v == 13: return "d"
    if v == 14: return "e"
    return "f"

fn _bytes_to_hex_i64(data: [i64]) -> text:
    """Convert [i64] byte list to hex string."""
    var out = ""
    var i = 0
    loop:
        if i >= data.len():
            break
        val b = data[i] & 0xff
        out = out + _hex_nibble((b >> 4) & 0x0f) + _hex_nibble(b & 0x0f)
        i = i + 1
    return out

fn _bytes_to_hex_u8(data: [u8]) -> text:
    """Convert [u8] byte list to hex string."""
    var out = ""
    var i = 0
    loop:
        if i >= data.len():
            break
        val b = data[i]
        out = out + _hex_nibble((b >> 4) & 0x0f) + _hex_nibble(b & 0x0f)
        i = i + 1
    return out
