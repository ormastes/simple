# QUIC Connection State Machine — RFC 9000 §5, §10
#
# Models the lifecycle of a QUIC connection:
#   - Connection state machine (Initial → Handshake → Connected → Draining → Closed)
#   - Stream multiplexing: open/close/lookup streams by ID
#   - Packet processing: demux incoming packets, produce outgoing actions
#   - Connection ID management
#
# Crypto handshake (TLS 1.3) is STUBBED — this skeleton provides the
# structural scaffolding for a future crypto module to plug into.
#
# Congestion control and loss detection are also deferred.
#
# Reference: RFC 9000 §5, §10, §19 (frame types)

use std.io.quic.quic_packet.{
    QuicPacketType, QuicPacketHeader, QuicHeaderResult,
    parse_quic_header, encode_quic_header,
    quic_varint_decode, quic_varint_encode, QuicVarintResult,
    QUIC_VERSION_1
}
use std.io.quic.quic_stream.{
    QuicStream, StreamState, StreamEvent,
    stream_id_is_client_initiated, stream_id_is_bidi,
    next_client_bidi_stream_id
}
use std.io.quic.quic_crypto.{
    QuicCryptoState, QuicPacketKeys, QuicEncryptionLevel,
    QuicTlsState, QuicCryptoEvent,
    derive_initial_secrets, derive_quic_keys,
    quic_aead_encrypt, quic_aead_decrypt,
    crypto_buffer_append, extract_handshake_messages,
    TLS_HS_CLIENT_HELLO, TLS_HS_SERVER_HELLO, TLS_HS_FINISHED
}

# ============================================================================
# Connection state enum — RFC 9000 §5
# ============================================================================

enum QuicConnectionState:
    """QUIC connection lifecycle state."""
    # No handshake started yet.
    Initial
    # Crypto handshake in progress (Initial/Handshake packets).
    Handshake
    # Handshake complete; 1-RTT data may flow.
    Connected
    # CONNECTION_CLOSE sent or received; draining period active.
    Draining
    # Connection fully closed; resources may be reclaimed.
    Closed

# ============================================================================
# Action enum — instructions returned from packet processing
# ============================================================================

enum QuicAction:
    """Action the transport layer should take after processing a packet."""
    # Send raw packet bytes to a peer address.
    SendPacket(data: [u8], addr: text)
    # A stream is ready for reading/writing.
    StreamReady(stream_id: i64)
    # Data arrived on a stream.
    StreamData(stream_id: i64, data: [u8])
    # A stream was closed.
    StreamClosed(stream_id: i64)
    # The connection was closed (graceful or error).
    ConnectionClosed(reason: text)
    # Crypto handshake data is needed (stub — TLS integration point).
    NeedCryptoHandshake
    # CRYPTO frame data received at a given encryption level.
    CryptoData(level: QuicEncryptionLevel, data: [u8])
    # A complete TLS handshake message was extracted from CRYPTO frames.
    HandshakeMessage(level: QuicEncryptionLevel, msg_type: i64, data: [u8])
    # Encryption keys are ready for a new level.
    KeysReady(level: QuicEncryptionLevel)

# ============================================================================
# QUIC frame type constants — RFC 9000 §19
# ============================================================================

val QUIC_FRAME_PADDING: i64          = 0x00
val QUIC_FRAME_PING: i64             = 0x01
val QUIC_FRAME_ACK: i64              = 0x02
val QUIC_FRAME_CRYPTO: i64           = 0x06
val QUIC_FRAME_NEW_TOKEN: i64        = 0x07
val QUIC_FRAME_STREAM_BASE: i64      = 0x08
val QUIC_FRAME_STREAM_MAX: i64       = 0x0f
val QUIC_FRAME_MAX_DATA: i64         = 0x10
val QUIC_FRAME_MAX_STREAM_DATA: i64  = 0x11
val QUIC_FRAME_STREAMS_BLOCKED: i64  = 0x16
val QUIC_FRAME_CONNECTION_CLOSE: i64 = 0x1c
val QUIC_FRAME_HANDSHAKE_DONE: i64   = 0x1e

# ============================================================================
# Default limits
# ============================================================================

val DEFAULT_STREAM_FLOW_LIMIT: i64 = 65536
val DEFAULT_MAX_STREAMS: i64 = 100

# ============================================================================
# QuicConnection — mutable connection with stream map
# ============================================================================

class QuicConnection:
    """One QUIC connection: state, streams, connection IDs.

    Processes incoming packets and returns QuicAction lists for the
    transport layer to execute (send packets, signal stream events).
    """
    local_conn_id: [u8]
    remote_conn_id: [u8]
    state: QuicConnectionState
    streams: Dict<i64, QuicStream>
    next_stream_id: i64
    is_server: bool
    peer_addr: text
    crypto: QuicCryptoState

    static fn create_client(local_cid: [u8], remote_cid: [u8], peer: text) -> QuicConnection:
        """Create a new client-side connection in Initial state.

        Derives Initial packet protection keys from the server's
        connection ID (the client's destination CID) per RFC 9001 §5.2.
        """
        var cs = QuicCryptoState.create()
        # Client derives Initial keys from the server's CID (remote_cid)
        val (client_keys, server_keys) = derive_initial_secrets(remote_cid)
        cs.client_initial_keys = client_keys
        cs.server_initial_keys = server_keys
        return QuicConnection(
            local_conn_id: local_cid,
            remote_conn_id: remote_cid,
            state: QuicConnectionState.Initial,
            streams: {},
            next_stream_id: 0,
            is_server: false,
            peer_addr: peer,
            crypto: cs
        )

    static fn create_server(local_cid: [u8], remote_cid: [u8], peer: text) -> QuicConnection:
        """Create a new server-side connection in Initial state.

        Derives Initial packet protection keys from the client's
        destination connection ID (local_cid) per RFC 9001 §5.2.
        """
        var cs = QuicCryptoState.create()
        # Server derives Initial keys from the client's DCID (its own local_cid)
        val (client_keys, server_keys) = derive_initial_secrets(local_cid)
        cs.client_initial_keys = client_keys
        cs.server_initial_keys = server_keys
        return QuicConnection(
            local_conn_id: local_cid,
            remote_conn_id: remote_cid,
            state: QuicConnectionState.Initial,
            streams: {},
            next_stream_id: 1,
            is_server: true,
            peer_addr: peer,
            crypto: cs
        )

    # ------------------------------------------------------------------
    # Packet processing
    # ------------------------------------------------------------------

    me on_packet(data: [u8]) -> [QuicAction]:
        """Process an incoming QUIC packet and return resulting actions.

        Parses the packet header, dispatches by type, processes QUIC
        frames in the payload, and returns a list of actions for the
        transport layer.
        """
        var actions: [QuicAction] = []

        val header_r = parse_quic_header(data)
        match header_r:
            case Err(msg):
                return actions
            case Ok(header):
                match header.packet_type:
                    case Initial:
                        actions = self._handle_initial(header, data)
                    case Handshake:
                        actions = self._handle_handshake(header, data)
                    case OneRTT:
                        actions = self._handle_one_rtt(header, data)
                    case Retry:
                        # Retry triggers re-send of Initial with new token
                        self.remote_conn_id = header.src_conn_id
                        actions.push(QuicAction.NeedCryptoHandshake)
                    case VersionNeg:
                        actions.push(QuicAction.ConnectionClosed(
                            reason: "version negotiation received"
                        ))
                    case ZeroRTT:
                        # 0-RTT: treat like 1-RTT for skeleton
                        actions = self._handle_one_rtt(header, data)

        return actions

    # ------------------------------------------------------------------
    # Stream management
    # ------------------------------------------------------------------

    me open_stream(stream_type: i64) -> i64:
        """Open a new stream and return its stream ID.

        stream_type: 0 = bidirectional, 1 = unidirectional.
        The returned ID follows RFC 9000 §2.1 encoding.
        """
        var sid = self.next_stream_id
        # Encode initiator + directionality in low 2 bits
        if self.is_server:
            sid = sid | 0x01
        if stream_type == 1:
            sid = sid | 0x02

        val stream = QuicStream.create(sid, DEFAULT_STREAM_FLOW_LIMIT)
        self.streams[sid] = stream
        self.next_stream_id = self.next_stream_id + 4
        return sid

    me close_stream(stream_id: i64):
        """Close a stream by ID. Transitions to Closed state."""
        if self.streams.contains(stream_id):
            var stream = self.streams[stream_id]
            stream.apply_event(StreamEvent.LocalFinished)
            stream.apply_event(StreamEvent.RemoteFinished)

    me send_data(stream_id: i64, data: [u8]) -> [u8]:
        """Enqueue data on a stream and return a QUIC packet to send.

        Builds a STREAM frame containing the data, wraps it in a 1-RTT
        short-header packet, and returns the raw bytes. Crypto protection
        is NOT applied (stub).
        """
        if not self.streams.contains(stream_id):
            return []

        var stream = self.streams[stream_id]
        stream.enqueue_send(data)

        # Build STREAM frame: type(1) | stream_id(varint) | offset(varint) | length(varint) | data
        val frame_data = stream.drain_send(data.len())
        var frame: [u8] = []
        # STREAM frame type: 0x08 + flags (OFF=0x04, LEN=0x02, FIN=0x01)
        # We set OFF + LEN bits: 0x08 | 0x04 | 0x02 = 0x0e
        frame.push(0x0e)
        val sid_bytes = quic_varint_encode(stream_id)
        _frame_append(frame, sid_bytes)
        val off_bytes = quic_varint_encode(stream.send_offset - frame_data.len())
        _frame_append(frame, off_bytes)
        val len_bytes = quic_varint_encode(frame_data.len())
        _frame_append(frame, len_bytes)
        _frame_append(frame, frame_data)

        # Wrap in 1-RTT packet
        val header = QuicPacketHeader(
            packet_type: QuicPacketType.OneRTT,
            version: QUIC_VERSION_1,
            dest_conn_id: self.remote_conn_id,
            src_conn_id: self.local_conn_id,
            packet_number: 0,
            payload_offset: 0
        )
        var packet = encode_quic_header(header)
        _frame_append(packet, frame)
        return packet

    fn get_stream(stream_id: i64) -> QuicStream?:
        """Look up a stream by ID. Returns nil if not found."""
        if self.streams.contains(stream_id):
            return self.streams[stream_id]
        return nil

    fn is_connected() -> bool:
        """True if the connection handshake is complete."""
        match self.state:
            case Connected:
                return true
            case _:
                return false

    fn is_closed() -> bool:
        """True if the connection is fully closed."""
        match self.state:
            case Closed:
                return true
            case _:
                return false

    # ------------------------------------------------------------------
    # Internal: packet type handlers
    # ------------------------------------------------------------------

    me _handle_initial(header: QuicPacketHeader, data: [u8]) -> [QuicAction]:
        """Handle an Initial packet (crypto handshake start)."""
        var actions: [QuicAction] = []

        match self.state:
            case Initial:
                self.state = QuicConnectionState.Handshake
                self.remote_conn_id = header.src_conn_id
                # Signal that crypto handshake data is needed
                actions.push(QuicAction.NeedCryptoHandshake)
            case _:
                # Already past Initial — process crypto frames if present
                actions = self._process_frames(data, header.payload_offset)

        return actions

    me _handle_handshake(header: QuicPacketHeader, data: [u8]) -> [QuicAction]:
        """Handle a Handshake packet (crypto handshake continuation)."""
        var actions: [QuicAction] = []

        match self.state:
            case Handshake:
                # Process CRYPTO frames in payload
                actions = self._process_frames(data, header.payload_offset)
                # Check for HANDSHAKE_DONE to transition to Connected
                # (For skeleton, transition after processing any Handshake packet
                # if we're the server receiving client's Handshake finished)
                pass
            case _:
                actions = self._process_frames(data, header.payload_offset)

        return actions

    me _handle_one_rtt(header: QuicPacketHeader, data: [u8]) -> [QuicAction]:
        """Handle a 1-RTT (short header) packet — application data."""
        var actions: [QuicAction] = []

        # If we receive 1-RTT data, handshake must be complete
        match self.state:
            case Handshake:
                self.state = QuicConnectionState.Connected
            case Initial:
                self.state = QuicConnectionState.Connected
            case _:
                pass

        actions = self._process_frames(data, header.payload_offset)
        return actions

    me _process_frames(data: [u8], offset: i64) -> [QuicAction]:
        """Process QUIC frames starting at offset in the packet payload.

        Iterates through frames, handling STREAM, CONNECTION_CLOSE,
        HANDSHAKE_DONE, and skipping PADDING/PING.
        """
        var actions: [QuicAction] = []
        var pos = offset

        loop:
            if pos >= data.len():
                break

            # Read frame type
            val type_r = quic_varint_decode(data, pos)
            match type_r:
                case Err(msg):
                    break
                case Ok(tr):
                    val frame_type = tr.value
                    pos = pos + tr.consumed

                    if frame_type == QUIC_FRAME_PADDING:
                        # PADDING: single zero byte, no length — skip one
                        pass

                    if frame_type == QUIC_FRAME_PING:
                        # PING: no payload
                        pass

                    if frame_type == QUIC_FRAME_CONNECTION_CLOSE:
                        self.state = QuicConnectionState.Draining
                        actions.push(QuicAction.ConnectionClosed(reason: "peer sent CONNECTION_CLOSE"))
                        break

                    if frame_type == QUIC_FRAME_HANDSHAKE_DONE:
                        self.state = QuicConnectionState.Connected
                        pass

                    if frame_type >= QUIC_FRAME_STREAM_BASE and frame_type <= QUIC_FRAME_STREAM_MAX:
                        # STREAM frame
                        val stream_actions = self._parse_stream_frame(frame_type, data, pos)
                        var ai = 0
                        loop:
                            if ai >= stream_actions.len():
                                break
                            actions.push(stream_actions[ai])
                            ai = ai + 1
                        # Advance pos past STREAM frame payload (simplified)
                        break

                    if frame_type == QUIC_FRAME_CRYPTO:
                        # CRYPTO frame: offset(varint) + length(varint) + data
                        # Parse and buffer for TLS handshake reassembly
                        val off_r = quic_varint_decode(data, pos)
                        match off_r:
                            case Ok(or2):
                                val crypto_offset = or2.value
                                pos = pos + or2.consumed
                                val len_r = quic_varint_decode(data, pos)
                                match len_r:
                                    case Ok(lr):
                                        val crypto_len = lr.value
                                        pos = pos + lr.consumed
                                        # Extract CRYPTO frame payload
                                        var crypto_data: [u8] = []
                                        var cdi = 0
                                        loop:
                                            if cdi >= crypto_len:
                                                break
                                            if pos + cdi >= data.len():
                                                break
                                            crypto_data.push(data[pos + cdi])
                                            cdi = cdi + 1
                                        pos = pos + crypto_len
                                        # Determine encryption level from connection state
                                        var level = QuicEncryptionLevel.Initial
                                        match self.state:
                                            case Handshake:
                                                level = QuicEncryptionLevel.Handshake
                                            case Connected:
                                                level = QuicEncryptionLevel.Application
                                            case _:
                                                pass
                                        # Buffer CRYPTO data and extract handshake messages
                                        val crypto_events = self._process_crypto_data(level, crypto_data, crypto_offset)
                                        var cei = 0
                                        loop:
                                            if cei >= crypto_events.len():
                                                break
                                            actions.push(crypto_events[cei])
                                            cei = cei + 1
                                    case Err(msg):
                                        break
                            case Err(msg):
                                break

        return actions

    me _parse_stream_frame(frame_type: i64, data: [u8], start: i64) -> [QuicAction]:
        """Parse a STREAM frame and deliver data to the appropriate stream.

        STREAM frame type bits (§19.8):
          0x08 base | 0x04 OFF | 0x02 LEN | 0x01 FIN
        """
        var actions: [QuicAction] = []
        var pos = start

        val has_offset = (frame_type & 0x04) != 0
        val has_length = (frame_type & 0x02) != 0
        val has_fin    = (frame_type & 0x01) != 0

        # Stream ID
        val sid_r = quic_varint_decode(data, pos)
        match sid_r:
            case Err(msg):
                return actions
            case Ok(sr):
                val stream_id = sr.value
                pos = pos + sr.consumed

                # Offset (if present)
                var stream_offset: i64 = 0
                if has_offset:
                    val off_r = quic_varint_decode(data, pos)
                    match off_r:
                        case Ok(or2):
                            stream_offset = or2.value
                            pos = pos + or2.consumed
                        case Err(msg):
                            return actions

                # Length (if present, else rest of packet)
                var frame_len = data.len() - pos
                if has_length:
                    val len_r = quic_varint_decode(data, pos)
                    match len_r:
                        case Ok(lr):
                            frame_len = lr.value
                            pos = pos + lr.consumed
                        case Err(msg):
                            return actions

                # Extract frame data
                var frame_data: [u8] = []
                var i = 0
                loop:
                    if i >= frame_len:
                        break
                    if pos + i >= data.len():
                        break
                    frame_data.push(data[pos + i])
                    i = i + 1

                # Create stream if it doesn't exist
                if not self.streams.contains(stream_id):
                    val new_stream = QuicStream.create(stream_id, DEFAULT_STREAM_FLOW_LIMIT)
                    self.streams[stream_id] = new_stream
                    actions.push(QuicAction.StreamReady(stream_id: stream_id))

                # Deliver data to stream
                var stream = self.streams[stream_id]
                stream.receive_data(frame_data, stream_offset)
                actions.push(QuicAction.StreamData(stream_id: stream_id, data: frame_data))

                # Handle FIN
                if has_fin:
                    stream.apply_event(StreamEvent.RemoteFinished)
                    match stream.state:
                        case Closed:
                            actions.push(QuicAction.StreamClosed(stream_id: stream_id))
                        case _:
                            pass

        return actions

    # ------------------------------------------------------------------
    # CRYPTO frame processing — TLS handshake message dispatch
    # ------------------------------------------------------------------

    me _process_crypto_data(level: QuicEncryptionLevel, data: [u8], offset: i64) -> [QuicAction]:
        """Buffer CRYPTO frame data, extract complete TLS messages, and emit actions.

        Appends data to the per-level CRYPTO reassembly buffer, then
        scans for complete TLS handshake messages. Each complete message
        is emitted as a QuicAction.HandshakeMessage.
        """
        var actions: [QuicAction] = []

        # Append to the appropriate reassembly buffer, then extract
        # only *new* handshake messages using the consumed-offset tracker.
        match level:
            case Initial:
                self.crypto.initial_crypto_buf = crypto_buffer_append(
                    self.crypto.initial_crypto_buf, data, offset
                )
                val (events, new_consumed) = extract_handshake_messages(
                    self.crypto.initial_crypto_buf,
                    self.crypto.initial_crypto_consumed
                )
                self.crypto.initial_crypto_consumed = new_consumed
                var ei = 0
                loop:
                    if ei >= events.len():
                        break
                    val evt = events[ei]
                    match evt:
                        case HandshakeMessage(msg_type, msg_data):
                            actions.push(QuicAction.HandshakeMessage(
                                level: QuicEncryptionLevel.Initial,
                                msg_type: msg_type,
                                data: msg_data
                            ))
                            # Track TLS state transitions
                            if msg_type == TLS_HS_CLIENT_HELLO:
                                self.crypto.tls_state = QuicTlsState.WaitServerHello
                            if msg_type == TLS_HS_SERVER_HELLO:
                                self.crypto.tls_state = QuicTlsState.WaitEncryptedExtensions
                        case _:
                            pass
                    ei = ei + 1
            case Handshake:
                self.crypto.handshake_crypto_buf = crypto_buffer_append(
                    self.crypto.handshake_crypto_buf, data, offset
                )
                val (events, new_consumed) = extract_handshake_messages(
                    self.crypto.handshake_crypto_buf,
                    self.crypto.handshake_crypto_consumed
                )
                self.crypto.handshake_crypto_consumed = new_consumed
                var ei = 0
                loop:
                    if ei >= events.len():
                        break
                    val evt = events[ei]
                    match evt:
                        case HandshakeMessage(msg_type, msg_data):
                            actions.push(QuicAction.HandshakeMessage(
                                level: QuicEncryptionLevel.Handshake,
                                msg_type: msg_type,
                                data: msg_data
                            ))
                            # Finished message completes the handshake
                            if msg_type == TLS_HS_FINISHED:
                                self.crypto.tls_state = QuicTlsState.Connected
                                self.state = QuicConnectionState.Connected
                                actions.push(QuicAction.KeysReady(
                                    level: QuicEncryptionLevel.Application
                                ))
                        case _:
                            pass
                    ei = ei + 1
            case _:
                # Application-level CRYPTO frames are not expected in TLS 1.3
                pass

        # Also emit raw CryptoData for transport-level consumers
        actions.push(QuicAction.CryptoData(level: level, data: data))

        return actions

    me close_connection(reason: text):
        """Initiate graceful connection close."""
        self.state = QuicConnectionState.Draining

# ============================================================================
# Internal helper
# ============================================================================

fn _frame_append(out: [u8], src: [u8]):
    """Append all bytes of src onto out."""
    var i = 0
    loop:
        if i >= src.len():
            break
        out.push(src[i])
        i = i + 1
