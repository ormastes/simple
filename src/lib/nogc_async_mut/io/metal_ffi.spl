"""
# No-GC Async Metal I/O FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.metal_ffi.{
    metal_available, metal_init, metal_device_count, MetalDeviceInfo, metal_device_info,
    MetalDevice, metal_create_device, metal_destroy_device, MetalBuffer, metal_alloc_buffer,
    metal_free_buffer, metal_upload, metal_download, MetalShader, metal_compile_shader,
    metal_destroy_shader, MetalComputePipeline, metal_create_compute_pipeline,
    metal_destroy_pipeline, MetalRenderPipeline, metal_create_render_pipeline,
    metal_destroy_render_pipeline, MetalTexture, metal_create_texture, metal_free_texture,
    MetalCommandQueue, metal_create_command_queue, metal_destroy_command_queue,
    MetalCommandBuffer, metal_create_command_buffer, metal_commit, metal_wait,
    metal_ffi_init, metal_ffi_is_available, metal_ffi_device_count, metal_ffi_create_device,
    metal_ffi_destroy_device, metal_ffi_alloc_buffer, metal_ffi_free_buffer,
    metal_ffi_compile_shader, metal_ffi_destroy_shader, metal_ffi_create_compute_pipeline,
    metal_ffi_destroy_pipeline, metal_ffi_create_command_queue,
    metal_ffi_destroy_command_queue, metal_ffi_create_command_buffer,
    metal_ffi_commit_command_buffer, metal_ffi_wait_completed, metal_ffi_dispatch_compute,
    metal_ffi_create_compute_encoder, metal_ffi_end_compute_encoder, metal_ffi_set_buffer,
    metal_ffi_set_bytes, metal_ffi_buffer_download, metal_ffi_buffer_upload,
    metal_last_error, MetalSampler, MetalSwapchain, metal_create_sampler,
    metal_create_swapchain
}
