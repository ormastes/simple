"""
# No-GC Async TCP Backend

Compatibility facade over the no-GC sync TCP backend functions.
The raw fd-level backend is owned by `nogc_sync_mut.io.tcp`.
"""

export use std.nogc_sync_mut.io.tcp.{
    tcp_backend_bind,
    tcp_backend_bind_with_reuseport,
    tcp_backend_close,
    tcp_backend_local_addr,
    tcp_backend_set_nodelay,
    tcp_backend_set_nonblocking
}
