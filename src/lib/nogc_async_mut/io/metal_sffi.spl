"""
# No-GC Async Metal I/O SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.metal_sffi.{
    metal_available, metal_init, metal_device_count, MetalDeviceInfo, metal_device_info,
    MetalDevice, metal_create_device, metal_destroy_device, MetalBuffer, metal_alloc_buffer,
    metal_free_buffer, metal_upload, metal_download, MetalShader, metal_compile_shader,
    metal_destroy_shader, MetalComputePipeline, metal_create_compute_pipeline,
    metal_destroy_pipeline, MetalRenderPipeline, metal_create_render_pipeline,
    metal_destroy_render_pipeline, MetalTexture, metal_create_texture, metal_free_texture,
    MetalCommandQueue, metal_create_command_queue, metal_destroy_command_queue,
    MetalCommandBuffer, metal_create_command_buffer, metal_destroy_command_buffer,
    metal_commit, metal_wait,
    metal_sffi_init, metal_sffi_is_available, metal_sffi_device_count, metal_sffi_create_device,
    metal_sffi_destroy_device, metal_sffi_alloc_buffer, metal_sffi_free_buffer,
    metal_sffi_compile_shader, metal_sffi_destroy_shader, metal_sffi_create_compute_pipeline,
    metal_sffi_destroy_pipeline, metal_sffi_create_command_queue,
    metal_sffi_destroy_command_queue, metal_sffi_create_command_buffer,
    metal_sffi_destroy_command_buffer, metal_sffi_commit_command_buffer,
    metal_sffi_wait_completed, metal_sffi_dispatch_compute,
    metal_sffi_create_compute_encoder, metal_sffi_end_compute_encoder,
    metal_sffi_destroy_compute_encoder, metal_sffi_set_buffer,
    metal_sffi_set_bytes, metal_sffi_buffer_download, metal_sffi_buffer_upload,
    metal_sffi_run_compute_frame,
    metal_last_error, MetalSampler, MetalSwapchain, metal_create_sampler,
    metal_create_swapchain
}
