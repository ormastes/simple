    rt_debug_get_breakpoint_info, rt_debug_list_breakpoints,
    rt_debug_get_pending_condition, rt_debug_report_condition_result,
    rt_debug_select_frame, rt_debug_get_selected_frame,
    rt_debug_frame_locals, rt_debug_get_source_lines,
    rt_debug_add_watch, rt_debug_remove_watch, rt_debug_list_watches,
    rt_debug_set_variable, rt_debug_eval_expression, rt_debug_terminate,
    rt_fault_set_stack_overflow_detection, rt_fault_set_max_recursion_depth,
