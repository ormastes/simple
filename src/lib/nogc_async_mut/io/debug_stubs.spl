    rt_debug_set_active, rt_hook_enable_debugging,
    rt_debug_add_breakpoint_at, rt_debug_remove_breakpoint_at,
    rt_debug_continue_exec, rt_debug_pause_exec, rt_debug_set_step_mode_val,
    rt_debug_stack_trace_lines, rt_debug_local_vars,
    rt_debug_get_current_file, rt_debug_get_current_line,
    rt_debug_run_file_debug, rt_debug_add_breakpoint_rich,
