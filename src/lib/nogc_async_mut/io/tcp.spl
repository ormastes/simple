"""
# Async TCP I/O

No-GC async TCP is a ready-future facade over the no-GC synchronous TCP
backend. This keeps one runtime-facing TCP implementation while preserving the
async API shape used by higher-level async networking code.
"""

use std.async.future.{Future}
use std.common.io.async_traits.{AsyncRead, AsyncWrite, AsyncClose}
use std.common.io.types.{IoError, Shutdown}
use std.nogc_sync_mut.io.tcp.{TcpListener as SyncTcpListener, TcpStream as SyncTcpStream}

class AsyncTcpListener with AsyncClose:
    """Future-returning TCP listener backed by no-GC sync TCP."""
    listener: SyncTcpListener

    static fn bind(addr: text) -> Future<Result<AsyncTcpListener, IoError>>:
        """Bind to address and start listening."""
        match SyncTcpListener.bind(addr):
            case Ok(listener):
                Future.from_value(Ok(AsyncTcpListener(listener: listener)))
            case Err(e):
                Future.from_value(Err(e))

    fn accept() -> Future<Result<AsyncTcpStream, IoError>>:
        """Accept incoming connection."""
        match self.listener.accept():
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    fn local_addr() -> Result<text, IoError>:
        """Get local bound address."""
        self.listener.local_addr()

    me close() -> Future<Result<(), IoError>>:
        """Close listener."""
        Future.from_value(self.listener.close())

    fn is_open() -> bool:
        """Check if listener is open."""
        self.listener.is_open()

class AsyncTcpStream with AsyncRead, AsyncWrite, AsyncClose:
    """Future-returning TCP stream backed by no-GC sync TCP."""
    stream: SyncTcpStream

    static fn connect(addr: text) -> Future<Result<AsyncTcpStream, IoError>>:
        """Connect to remote address."""
        match SyncTcpStream.connect(addr):
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    static fn connect_timeout(addr: text, ms: i64) -> Future<Result<AsyncTcpStream, IoError>>:
        """Connect with timeout."""
        match SyncTcpStream.connect_timeout(addr, ms):
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    fn read(size: i64) -> Future<Result<[u8], IoError>>:
        """Read up to size bytes."""
        Future.from_value(self.stream.read(size))

    fn read_exact(size: i64) -> Future<Result<[u8], IoError>>:
        """Read exactly size bytes."""
        Future.from_value(self.stream.read_exact(size))

    fn read_all() -> Future<Result<[u8], IoError>>:
        """Read all bytes until EOF."""
        Future.from_value(self.stream.read_all())

    fn read_text() -> Future<Result<text, IoError>>:
        """Read all content as text."""
        Future.from_value(self.stream.read_text())

    fn read_line() -> Future<Result<text, IoError>>:
        """Read a single line."""
        Future.from_value(self.stream.read_line())

    fn write(data: [u8]) -> Future<Result<i64, IoError>>:
        """Write bytes."""
        Future.from_value(self.stream.write(data))

    fn write_all(data: [u8]) -> Future<Result<(), IoError>>:
        """Write all bytes."""
        Future.from_value(self.stream.write_all(data))

    fn write_text(s: text) -> Future<Result<(), IoError>>:
        """Write text."""
        Future.from_value(self.stream.write_text(s))

    fn flush() -> Future<Result<(), IoError>>:
        """Flush write buffer."""
        Future.from_value(self.stream.flush())

    me close() -> Future<Result<(), IoError>>:
        """Close stream."""
        Future.from_value(self.stream.close())

    fn is_open() -> bool:
        """Check if stream is open."""
        self.stream.is_open()

    fn peer_addr() -> Result<text, IoError>:
        """Get remote peer address."""
        self.stream.peer_addr()

    fn local_addr() -> Result<text, IoError>:
        """Get local address."""
        self.stream.local_addr()

    fn set_nodelay(enabled: bool) -> Result<(), IoError>:
        """Set TCP_NODELAY."""
        self.stream.set_nodelay(enabled)

    fn shutdown(how: Shutdown) -> Future<Result<(), IoError>>:
        """Shutdown one or both directions."""
        Future.from_value(self.stream.shutdown(how))

export use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
