"""
# Async UDP I/O — Completion-Driver Implementation

**Feature IDs:** #IO-100
**Category:** Runtime
**Status:** In Progress

## Overview

Completion-based async UDP socket that submits operations to the IoDriver.
Returns op_ids for send/recv so callers can poll for completion. This enables
non-blocking UDP needed by QUIC/H3 transport.

## Usage

```simple
val driver = IoDriver.new()
val sock = AsyncUdpSocket.bind(driver, "127.0.0.1:0")
match sock:
    case Ok(s):
        val send_op = s.send_to("hello", "127.0.0.1:9001")
        val recv_op = s.recv_from(1024)
        driver.flush()
        val completions = driver.poll(64, 200)
    case Err(e):
        print "bind failed: {e.message}"
```
"""

use std.io.types.{IoError, IoErrorKind}
use std.nogc_async_mut.io.driver.{IoDriver}

extern fn rt_io_udp_bind(addr: text) -> i64
extern fn rt_io_udp_close(fd: i64) -> bool

class AsyncUdpSocket:
    """Completion-based async UDP socket backed by IoDriver."""
    _driver: IoDriver
    _fd: i64

    static fn bind(driver: IoDriver, addr: text) -> Result<AsyncUdpSocket, IoError>:
        """Bind a UDP socket to address and return an async wrapper.

        Args:
            driver: The IoDriver to submit operations to
            addr: Address in "host:port" format

        Returns:
            Result with AsyncUdpSocket or error
        """
        val fd = rt_io_udp_bind(addr)
        if fd < 0:
            return Err(IoError(kind: IoErrorKind.AddrInUse, message: "udp bind failed: {addr}", source: nil))
        Ok(AsyncUdpSocket(_driver: driver, _fd: fd))

    me send_to(data: text, addr: text) -> i64:
        """Submit a UDP send_to operation.

        Args:
            data: Text data to send
            addr: Destination address in "host:port" format

        Returns:
            Op ID for polling completion
        """
        if self._fd < 0:
            return -1
        self._driver.submit_udp_send(self._fd, data, addr)

    me recv_from(buf_size: i64) -> i64:
        """Submit a UDP recv_from operation.

        Args:
            buf_size: Maximum bytes to receive

        Returns:
            Op ID for polling completion
        """
        if self._fd < 0:
            return -1
        self._driver.submit_udp_recv(self._fd, buf_size)

    fn fd() -> i64:
        """Get the underlying socket file descriptor."""
        self._fd

    me close():
        """Close the UDP socket and cancel pending driver ops."""
        if self._fd < 0:
            return
        self._driver.cancel_fd(self._fd)
        rt_io_udp_close(self._fd)
        self._fd = -1

export use std.nogc_sync_mut.io.udp.{UdpSocket}
