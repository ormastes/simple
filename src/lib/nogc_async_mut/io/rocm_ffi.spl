"""
# No-GC Async ROCm I/O FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.rocm_ffi.{
    rocm_available, rocm_init, rocm_device_count, rocm_set_device, rocm_get_device,
    RocmDeviceInfo, rocm_device_info, RocmPtr, rocm_alloc, rocm_free, rocm_copy_to_device,
    rocm_copy_from_device, rocm_copy_device_to_device, rocm_memset, RocmModule, rocm_compile,
    rocm_unload, RocmFunc, rocm_get_kernel, RocmLaunchConfig, rocm_launch_config_1d,
    rocm_launch, rocm_sync, RocmStream, rocm_stream_create, rocm_stream_destroy,
    rocm_stream_sync, rocm_last_error, rocm_run_1d, rocm_alloc_from_host
}
