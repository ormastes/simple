"""
# No-GC async io sqlite ffi

Compatibility facade over the no-GC sync backend.
"""

export use std.nogc_sync_mut.io.sqlite_sffi.{
    SqliteConnection, SqliteStatement, SqliteRow, SqliteType,
    sqlite_open, sqlite_open_memory, sqlite_close,
    sqlite_execute, sqlite_execute_batch,
    sqlite_query_all, sqlite_query_one, sqlite_query_value,
    sqlite_prepare, sqlite_bind_text, sqlite_bind_int, sqlite_bind_float,
    sqlite_bind_null, sqlite_reset, sqlite_finalize,
    sqlite_begin, sqlite_commit, sqlite_rollback,
    sqlite_last_insert_rowid, sqlite_changes, sqlite_error_message,
    sqlite_table_exists, sqlite_count, sqlite_insert,
    sqlite_row_get, sqlite_row_get_int
}
