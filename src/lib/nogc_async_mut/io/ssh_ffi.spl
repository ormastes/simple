"""
# No-GC async io ssh ffi

Compatibility facade over the no-GC sync backend.
"""

export use std.nogc_sync_mut.io.ssh_ffi.{
    SshSession, SshChannel, SftpSession, SshExecResult, SftpFileInfo,
    ssh_connect, ssh_disconnect, ssh_auth_password, ssh_auth_pubkey,
    ssh_auth_agent, ssh_exec, ssh_shell, ssh_channel_read, ssh_channel_write,
    ssh_channel_close, sftp_init, sftp_shutdown, sftp_upload, sftp_download,
    sftp_mkdir, sftp_rmdir, sftp_delete, sftp_rename, sftp_list, sftp_stat,
    ssh_is_authenticated, ssh_get_banner, ssh_set_timeout
}
