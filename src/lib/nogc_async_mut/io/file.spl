"""
# Async File I/O

Completion-driven async file operations using the IoDriver backend
(io_uring on Linux 5.1+, epoll fallback, kqueue on BSD/macOS).

## Usage

```simple
val driver = IoDriver.new()
val file = AsyncFile.open(driver, "/tmp/test.txt", O_RDWR | O_CREAT, 0o644)?
val data = file.read(driver, 4096, 0)?
file.write(driver, "hello", 0)?
file.fsync(driver)?
file.close(driver)?
```

## Convenience API

```simple
val content = AsyncFile.read_all(driver, "/tmp/test.txt")?
AsyncFile.write_all(driver, "/tmp/out.txt", content)?
```
"""

use std.nogc_async_mut.io.driver.{IoDriver, Completion}
use std.io.types.{IoError, IoErrorKind}
use std.async.future.{Future}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_size, file_modified_time}
use std.nogc_sync_mut.io.dir_entry_ops.{
    rt_readdir, rt_readdir_count, rt_readdir_entry, rt_readdir_free,
    rt_mkdir, rt_remove
}

# ============================================================================
# File Open Flags (POSIX)
# ============================================================================

val O_RDONLY: i64   = 0
val O_WRONLY: i64   = 1
val O_RDWR: i64     = 2
val O_CREAT: i64    = 64
val O_TRUNC: i64    = 512
val O_APPEND: i64   = 1024
val O_NONBLOCK: i64 = 2048
val O_EXCL: i64     = 128

val DEFAULT_MODE: i64 = 420  # 0o644

# ============================================================================
# FileStat
# ============================================================================

struct FileStat:
    size: i64
    modified_at: i64
    is_dir: bool
    is_file: bool

# ============================================================================
# File metadata fallback
# ============================================================================

# ============================================================================
# Helpers
# ============================================================================

fn errno_to_io_error(errno_neg: i64) -> IoError:
    val code = 0 - errno_neg
    if code == 2:
        IoError(kind: IoErrorKind.NotFound, message: "file not found")
    else if code == 13:
        IoError(kind: IoErrorKind.PermissionDenied, message: "permission denied")
    else if code == 17:
        IoError(kind: IoErrorKind.AlreadyExists, message: "already exists")
    else if code == 21:
        IoError(kind: IoErrorKind.InvalidInput, message: "is a directory")
    else if code == 28:
        IoError(kind: IoErrorKind.Other, message: "no space left on device")
    else:
        IoError(kind: IoErrorKind.Other, message: "I/O error (errno={code})")

fn complete_one(driver: IoDriver, op_id: i64, timeout_ms: i64) -> Result<i64, IoError>:
    driver.flush()
    val completions = driver.poll(64, timeout_ms)
    var i = 0
    while i < completions.len():
        val c = completions[i]
        if c.id == op_id:
            if c.result < 0:
                return Err(errno_to_io_error(c.result))
            return Ok(c.result)
        i = i + 1
    Err(IoError(kind: IoErrorKind.TimedOut, message: "operation timed out"))

# ============================================================================
# AsyncFile
# ============================================================================

class AsyncFile:
    fd: i64

    static fn open(driver: IoDriver, path: text, flags: i64, mode: i64) -> Result<AsyncFile, IoError>:
        val op_id = driver.submit_open(path, flags, mode)
        val result = complete_one(driver, op_id, 30000)?
        if result < 0:
            return Err(errno_to_io_error(result))
        Ok(AsyncFile(fd: result))

    fn read(driver: IoDriver, buf_size: i64, offset: i64) -> Result<text, IoError>:
        val op_id = driver.submit_read(self.fd, buf_size, offset)
        driver.flush()
        val completions = driver.poll(64, 30000)
        var i = 0
        while i < completions.len():
            val c = completions[i]
            if c.id == op_id:
                if c.result < 0:
                    return Err(errno_to_io_error(c.result))
                if c.result == 0:
                    return Ok("")
                return Ok(driver.poll_data(i))
            i = i + 1
        Err(IoError(kind: IoErrorKind.TimedOut, message: "read timed out"))

    fn write(driver: IoDriver, data: text, offset: i64) -> Result<i64, IoError>:
        val op_id = driver.submit_write(self.fd, data, offset)
        complete_one(driver, op_id, 30000)

    fn fsync(driver: IoDriver) -> Result<(), IoError>:
        val op_id = driver.submit_fsync(self.fd)
        complete_one(driver, op_id, 30000)?
        Ok(())

    me close(driver: IoDriver) -> Result<(), IoError>:
        if self.fd >= 0:
            val op_id = driver.submit_close(self.fd)
            complete_one(driver, op_id, 30000)?
            self.fd = -1
        Ok(())

    fn is_open() -> bool:
        self.fd >= 0

    static fn read_all(driver: IoDriver, path: text) -> Result<text, IoError>:
        val file = AsyncFile.open(driver, path, O_RDONLY, 0)?
        val stat_info: FileStat = stat(path)?
        val data_result = file.read(driver, stat_info.size, 0)
        var f = file
        f.close(driver)?
        data_result

    static fn write_all(driver: IoDriver, path: text, data: text) -> Result<i64, IoError>:
        val file = AsyncFile.open(driver, path, O_WRONLY + O_CREAT + O_TRUNC, DEFAULT_MODE)?
        val write_result = file.write(driver, data, 0)
        var f = file
        f.close(driver)?
        write_result

# ============================================================================
# stat (portable metadata subset)
# ============================================================================

fn stat(path: text) -> Result<FileStat, IoError>:
    if not file_exists(path):
        return Err(IoError(kind: IoErrorKind.NotFound, message: "stat failed: {path}"))
    val dir_handle = rt_readdir(path)
    val is_dir = dir_handle != 0
    if is_dir:
        rt_readdir_free(dir_handle)
    val s = FileStat(
        size: file_size(path),
        modified_at: file_modified_time(path),
        is_dir: is_dir,
        is_file: not is_dir
    )
    Ok(s)

# ============================================================================
# AsyncDir
# ============================================================================

class AsyncDir:
    static fn readdir(path: text) -> Result<[text], IoError>:
        val handle = rt_readdir(path)
        if handle == 0:
            return Err(IoError(kind: IoErrorKind.NotFound, message: "readdir failed: {path}"))
        val count = rt_readdir_count(handle)
        var entries: [text] = []
        var i: i64 = 0
        while i < count:
            entries.push(rt_readdir_entry(handle, i))
            i = i + 1
        rt_readdir_free(handle)
        Ok(entries)

    static fn mkdir(path: text, mode: i64) -> Result<(), IoError>:
        val result = rt_mkdir(path, mode)
        if result < 0:
            return Err(errno_to_io_error(result))
        Ok(())

    static fn remove(path: text) -> Result<(), IoError>:
        val result = rt_remove(path)
        if result < 0:
            return Err(errno_to_io_error(result))
        Ok(())

# ============================================================================
# ThreadPool (fallback for platforms without io_uring file support)
# ============================================================================

class ThreadPool:
    size: i64

    static fn new(size: i64) -> ThreadPool:
        ThreadPool(size: size)

    static fn default() -> ThreadPool:
        ThreadPool.new(4)

    fn exec(task: fn() -> i64) -> Future<i64>:
        Future.from_value(task())

# Type aliases for compatibility
type AsyncFileHandle = AsyncFile
type File = AsyncFile
type FileHandle = AsyncFile

export FileStat, AsyncFile, AsyncDir, ThreadPool, stat
export AsyncFileHandle, File, FileHandle
export errno_to_io_error
