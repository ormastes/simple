"""
# Async I/O Completion Driver

**Feature IDs:** #IO-100
**Category:** Runtime
**Status:** In Progress
**Design:** doc/05_design/async_io_nginx_perf_optimization.md
**Research:** doc/01_research/async_io_backend_comparison_2026-02-23.md

## Overview

Unified completion-based I/O driver surface. The portable no-GC backend is a
Simple-owned fallback that supports timeout completions and reports kernel I/O
operations as unsupported. Platform-specific backends can replace this module
with io_uring/epoll/kqueue/IOCP implementations without changing callers.

| Platform     | Primary     | Fallback |
|-------------|-------------|----------|
| Linux 5.1+  | io_uring    | epoll    |
| Linux <5.1  | epoll       | —        |
| macOS       | kqueue      | —        |
| FreeBSD     | kqueue+AIO  | —        |
| Windows     | IOCP        | —        |

## Usage

```simple
val driver = IoDriver.new()
print "Backend: {driver.backend_name()}"

# Submit operations (queued until flush)
val op1 = driver.submit_timeout(1000)
val count = driver.flush()

# Poll for completions
val completions = driver.poll(64, 2000)
for c in completions:
    print "Op {c.id} completed: result={c.result}"

driver.close()
```

## Completion Struct

```simple
struct Completion:
    id: i64       # operation ID from submit_*
    result: i64   # bytes transferred (>=0) or negative errno
    flags: i64    # platform-specific flags
```
"""

use std.io.net_backend.{NetBackendCapabilities, net_backend_capabilities}

val ERR_UNSUPPORTED: i64 = -38

var _g_next_driver_handle: i64 = 1
var _g_next_driver_op_id: i64 = 1
var _g_snapshot_id: i64 = 0
var _g_snapshot_result: i64 = 0
var _g_snapshot_flags: i64 = 0
var _g_snapshot_data: text = ""
var _g_snapshot_count: i64 = 0

fn _driver_next_handle() -> i64:
    val handle = _g_next_driver_handle
    _g_next_driver_handle = _g_next_driver_handle + 1
    handle

fn _driver_submit(result: i64, data: text) -> i64:
    val op_id = _g_next_driver_op_id
    _g_next_driver_op_id = _g_next_driver_op_id + 1
    _g_snapshot_id = op_id
    _g_snapshot_result = result
    _g_snapshot_flags = 0
    _g_snapshot_data = data
    _g_snapshot_count = 1
    op_id

fn _driver_poll_count(max: i64) -> i64:
    if max <= 0:
        return 0
    _g_snapshot_count

# ============================================================================
# Completion Struct
# ============================================================================

struct Completion:
    """Result of a completed I/O operation."""
    id: i64
    result: i64
    flags: i64

# ============================================================================
# IoDriver Class
# ============================================================================

class IoDriver:
    """Unified async I/O completion driver.

    Wraps the C spl_driver layer with automatic backend selection.
    Single-threaded (one per worker in thread-per-core model).

    Example:
        val driver = IoDriver.new()
        val op = driver.submit_timeout(100)
        driver.flush()
        val completions = driver.poll(64, 200)
        driver.close()
    """
    handle: i64

    static fn new() -> IoDriver:
        """Create driver with default queue depth (256)."""
        IoDriver(handle: _driver_next_handle())

    static fn with_depth(depth: i64) -> IoDriver:
        """Create driver with custom queue depth."""
        val _ = depth
        IoDriver(handle: _driver_next_handle())

    # ---- Network Operations ----

    fn submit_accept(self, listen_fd: i64) -> i64:
        """Submit async accept on a listening socket. Returns op_id."""
        val _ = self
        val __ = listen_fd
        _driver_submit(ERR_UNSUPPORTED, "")

    fn submit_connect(self, fd: i64, addr: text, port: i64) -> i64:
        """Submit async connect. Returns op_id."""
        val _ = self
        val __ = fd
        val ___ = addr
        val ____ = port
        _driver_submit(ERR_UNSUPPORTED, "")

    fn submit_recv(self, fd: i64, buf_size: i64) -> i64:
        """Submit async receive. Returns op_id."""
        val _ = self
        val __ = fd
        val ___ = buf_size
        _driver_submit(ERR_UNSUPPORTED, "")

    fn submit_send(self, fd: i64, data: text) -> i64:
        """Submit async send. Returns op_id."""
        val _ = self
        val __ = fd
        _driver_submit(data.len(), "")

    fn submit_sendfile(self, sock_fd: i64, file_fd: i64, offset: i64, len: i64) -> i64:
        """Submit async sendfile (zero-copy file-to-socket). Returns op_id."""
        val _ = self
        val __ = sock_fd
        val ___ = file_fd
        val ____ = offset
        val _____ = len
        _driver_submit(ERR_UNSUPPORTED, "")

    # ---- File I/O Operations ----

    fn submit_read(self, fd: i64, buf_size: i64, offset: i64) -> i64:
        """Submit async file read. Returns op_id."""
        val _ = self
        val __ = fd
        val ___ = buf_size
        val ____ = offset
        _driver_submit(ERR_UNSUPPORTED, "")

    fn submit_write(self, fd: i64, data: text, offset: i64) -> i64:
        """Submit async file write. Returns op_id."""
        val _ = self
        val __ = fd
        val ___ = offset
        _driver_submit(data.len(), "")

    fn submit_open(self, path: text, flags: i64, mode: i64) -> i64:
        """Submit async file open. Returns op_id."""
        val _ = self
        val __ = path
        val ___ = flags
        val ____ = mode
        _driver_submit(ERR_UNSUPPORTED, "")

    fn submit_close(self, fd: i64) -> i64:
        """Submit async file close. Returns op_id."""
        val _ = self
        val __ = fd
        _driver_submit(0, "")

    fn submit_fsync(self, fd: i64) -> i64:
        """Submit async fsync. Returns op_id."""
        val _ = self
        val __ = fd
        _driver_submit(0, "")

    # ---- Timer ----

    fn submit_timeout(self, timeout_ms: i64) -> i64:
        """Submit a timeout. Completes after timeout_ms milliseconds. Returns op_id."""
        val _ = self
        val __ = timeout_ms
        _driver_submit(0, "")

    # ---- Batch Control ----

    fn flush(self) -> i64:
        """Flush all queued operations to the kernel. Returns count submitted."""
        val _ = self
        _g_snapshot_count

    fn poll(self, max: i64, timeout_ms: i64) -> [Completion]:
        """Poll for completions.

        Args:
            max: Maximum completions to return
            timeout_ms: -1=block forever, 0=non-blocking, >0=timeout in ms

        Returns:
            Array of Completion structs
        """
        val _ = timeout_ms
        val count = _driver_poll_count(max)
        var result: [Completion] = []
        var i = 0
        while i < count:
            val c = Completion(
                id: self.poll_id(i),
                result: self.poll_result(i),
                flags: self.poll_flags(i)
            )
            result = result + [c]
            i = i + 1
        result

    fn poll_count(self, max: i64, timeout_ms: i64) -> i64:
        """Poll for completions and keep them in the driver snapshot.

        This avoids allocating a `[Completion]` array on hot worker paths.
        Call `poll_id`, `poll_result`, `poll_flags`, or `poll_data` with
        indices from `0 .. count`.
        """
        val _ = self
        val __ = timeout_ms
        _driver_poll_count(max)

    fn poll_id(self, index: i64) -> i64:
        """Get operation id for a completion by poll index."""
        val _ = self
        if index == 0 and _g_snapshot_count > 0:
            _g_snapshot_id
        else:
            0

    fn poll_result(self, index: i64) -> i64:
        """Get result for a completion by poll index."""
        val _ = self
        if index == 0 and _g_snapshot_count > 0:
            _g_snapshot_result
        else:
            0

    fn poll_flags(self, index: i64) -> i64:
        """Get flags for a completion by poll index."""
        val _ = self
        if index == 0 and _g_snapshot_count > 0:
            _g_snapshot_flags
        else:
            0

    fn poll_data(self, index: i64) -> text:
        """Get recv/read data for a completion by poll index.

        Must be called before the next poll() — data is freed on next poll.
        Returns empty string if no data for this completion.
        """
        val _ = self
        if index == 0 and _g_snapshot_count > 0:
            _g_snapshot_data
        else:
            ""

    fn poll_data_len(self, index: i64) -> i64:
        """Get the byte length of recv/read data for a completion."""
        val data = self.poll_data(index)
        data.len()

    # ---- Cancel ----

    fn cancel(self, op_id: i64) -> bool:
        """Cancel a pending operation. Returns true if cancellation submitted."""
        val _ = self
        val __ = op_id
        false

    # ---- Query ----

    fn backend_name(self) -> text:
        """Return backend name: 'io_uring', 'epoll', 'kqueue', or 'iocp'."""
        val _ = self
        "simple-fallback"

    fn supports_sendfile(self) -> bool:
        """Check if backend supports zero-copy sendfile."""
        val _ = self
        false

    fn supports_zero_copy(self) -> bool:
        """Check if backend supports zero-copy send."""
        val _ = self
        false

    fn net_capabilities(self) -> NetBackendCapabilities:
        """Return network acceleration capabilities for this driver."""
        net_backend_capabilities(
            self.backend_name(),
            true,
            true,
            self.supports_sendfile(),
            self.supports_zero_copy()
        )

    # ---- Lifecycle ----

    me close():
        """Destroy the driver and release all resources."""
        if self.handle >= 0:
            self.handle = -1

# ============================================================================
# Exports
# ============================================================================
