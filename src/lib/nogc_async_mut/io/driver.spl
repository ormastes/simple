"""
# Async I/O Completion Driver — Native Backend

**Feature IDs:** #IO-100
**Category:** Runtime
**Status:** Active

Completion-based I/O driver backed by platform-specific kernel
mechanisms: epoll (Linux), kqueue (macOS/FreeBSD), IOCP (Windows).
All operations use submit-flush-poll batching for zero-copy throughput.
"""

use std.io.net_backend.{NetBackendCapabilities, net_backend_capabilities}

extern fn rt_driver_create(depth: i64) -> i64
extern fn rt_driver_destroy(handle: i64)
extern fn rt_driver_submit_accept(handle: i64, listen_fd: i64) -> i64
extern fn rt_driver_submit_connect(handle: i64, fd: i64, addr: text, port: i64) -> i64
extern fn rt_driver_submit_recv(handle: i64, fd: i64, buf_size: i64) -> i64
extern fn rt_driver_submit_send(handle: i64, fd: i64, data: text, len: i64) -> i64
extern fn rt_driver_submit_sendfile(handle: i64, sock_fd: i64, file_fd: i64, offset: i64, len: i64) -> i64
extern fn rt_driver_submit_read(handle: i64, fd: i64, buf_size: i64, offset: i64) -> i64
extern fn rt_driver_submit_write(handle: i64, fd: i64, data: text, len: i64, offset: i64) -> i64
extern fn rt_driver_submit_open(handle: i64, path: text, flags: i64, mode: i64) -> i64
extern fn rt_driver_submit_close(handle: i64, fd: i64) -> i64
extern fn rt_driver_submit_fsync(handle: i64, fd: i64) -> i64
extern fn rt_driver_submit_timeout(handle: i64, timeout_ms: i64) -> i64
extern fn rt_driver_flush(handle: i64) -> i64
extern fn rt_driver_poll(handle: i64, max: i64, timeout_ms: i64) -> i64
extern fn rt_driver_poll_id(handle: i64, index: i64) -> i64
extern fn rt_driver_poll_result(handle: i64, index: i64) -> i64
extern fn rt_driver_poll_flags(handle: i64, index: i64) -> i64
extern fn rt_driver_poll_data(handle: i64, index: i64) -> text
extern fn rt_driver_poll_data_len(handle: i64, index: i64) -> i64
extern fn rt_driver_cancel(handle: i64, op_id: i64) -> bool
extern fn rt_driver_backend_name(handle: i64) -> text
extern fn rt_driver_supports_sendfile(handle: i64) -> bool
extern fn rt_driver_supports_zero_copy(handle: i64) -> bool

struct Completion:
    id: i64
    result: i64
    flags: i64

class IoDriver:
    _handle: i64

    static fn new() -> IoDriver:
        IoDriver(_handle: rt_driver_create(256))

    static fn with_depth(depth: i64) -> IoDriver:
        IoDriver(_handle: rt_driver_create(depth))

    me submit_accept(listen_fd: i64) -> i64:
        rt_driver_submit_accept(self._handle, listen_fd)

    me submit_connect(fd: i64, addr: text, port: i64) -> i64:
        rt_driver_submit_connect(self._handle, fd, addr, port)

    me submit_recv(fd: i64, buf_size: i64) -> i64:
        rt_driver_submit_recv(self._handle, fd, buf_size)

    me submit_send(fd: i64, data: text) -> i64:
        rt_driver_submit_send(self._handle, fd, data, data.len())

    me submit_sendfile(sock_fd: i64, file_fd: i64, offset: i64, len: i64) -> i64:
        rt_driver_submit_sendfile(self._handle, sock_fd, file_fd, offset, len)

    me submit_read(fd: i64, buf_size: i64, offset: i64) -> i64:
        rt_driver_submit_read(self._handle, fd, buf_size, offset)

    me submit_write(fd: i64, data: text, offset: i64) -> i64:
        rt_driver_submit_write(self._handle, fd, data, data.len(), offset)

    me submit_open(path: text, flags: i64, mode: i64) -> i64:
        rt_driver_submit_open(self._handle, path, flags, mode)

    me submit_close(fd: i64) -> i64:
        rt_driver_submit_close(self._handle, fd)

    me submit_fsync(fd: i64) -> i64:
        rt_driver_submit_fsync(self._handle, fd)

    me submit_timeout(timeout_ms: i64) -> i64:
        rt_driver_submit_timeout(self._handle, timeout_ms)

    me flush() -> i64:
        rt_driver_flush(self._handle)

    me poll(max: i64, timeout_ms: i64) -> [Completion]:
        val count = self.poll_count(max, timeout_ms)
        var result: [Completion] = []
        var i = 0
        while i < count:
            result.push(Completion(
                id: rt_driver_poll_id(self._handle, i),
                result: rt_driver_poll_result(self._handle, i),
                flags: rt_driver_poll_flags(self._handle, i)
            ))
            i = i + 1
        result

    me poll_count(max: i64, timeout_ms: i64) -> i64:
        rt_driver_poll(self._handle, max, timeout_ms)

    fn poll_id(self, index: i64) -> i64:
        rt_driver_poll_id(self._handle, index)

    fn poll_result(self, index: i64) -> i64:
        rt_driver_poll_result(self._handle, index)

    fn poll_flags(self, index: i64) -> i64:
        rt_driver_poll_flags(self._handle, index)

    fn poll_data(self, index: i64) -> text:
        rt_driver_poll_data(self._handle, index)

    fn poll_data_len(self, index: i64) -> i64:
        rt_driver_poll_data_len(self._handle, index)

    me cancel(op_id: i64) -> bool:
        rt_driver_cancel(self._handle, op_id)

    fn backend_name(self) -> text:
        rt_driver_backend_name(self._handle)

    fn supports_sendfile(self) -> bool:
        rt_driver_supports_sendfile(self._handle)

    fn supports_zero_copy(self) -> bool:
        rt_driver_supports_zero_copy(self._handle)

    fn net_capabilities(self) -> NetBackendCapabilities:
        net_backend_capabilities(
            self.backend_name(),
            true,
            true,
            self.supports_sendfile(),
            self.supports_zero_copy()
        )

    me close():
        if self._handle >= 0:
            rt_driver_destroy(self._handle)
            self._handle = -1
