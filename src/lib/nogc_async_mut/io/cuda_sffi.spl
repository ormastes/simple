"""
# No-GC Async CUDA I/O SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.cuda_sffi.{
    cuda_available, cuda_device_count, cuda_set_device, cuda_get_device, CudaDeviceInfo,
    cuda_device_info, CudaPtr, cuda_alloc, cuda_free, cuda_copy_to_device,
    cuda_copy_from_device, cuda_copy_device_to_device, cuda_memset, CudaModule, cuda_compile,
    cuda_unload, CudaFunc, cuda_get_kernel, CudaLaunchConfig, cuda_launch_config_3d,
    cuda_launch_config_1d, cuda_launch, cuda_sync, CudaStream, cuda_stream_create,
    cuda_stream_destroy, cuda_stream_sync, cuda_last_error, cuda_peek_error, cuda_run_1d,
    cuda_alloc_from_host
}
