"""
TCP Connection Behavior

Socket-visible TCP state machine for connect completion, data path semantics,
and terminal state transitions (FIN, RST, TIME_WAIT).

Feature IDs: FR-NET-0001, FR-NET-0002
Plan: doc/03_plan/agent_tasks/net_acceleration_remaining_2026-04-21.md
"""

# TCP connection states visible at the socket layer.
struct TcpSocketState:
    """Socket-visible TCP connection state."""
    name: text

fn tcp_state_closed() -> TcpSocketState:
    TcpSocketState(name: "CLOSED")

fn tcp_state_connecting() -> TcpSocketState:
    TcpSocketState(name: "CONNECTING")

fn tcp_state_established() -> TcpSocketState:
    TcpSocketState(name: "ESTABLISHED")

fn tcp_state_close_wait() -> TcpSocketState:
    TcpSocketState(name: "CLOSE_WAIT")

fn tcp_state_time_wait() -> TcpSocketState:
    TcpSocketState(name: "TIME_WAIT")

fn tcp_state_reset() -> TcpSocketState:
    TcpSocketState(name: "RESET")

# Connect completion results reported back to the socket caller.
struct TcpConnectResult:
    """Result of a TCP active-open connect attempt."""
    success: bool
    in_progress: bool
    refused: bool
    timed_out: bool
    unreachable: bool
    error_msg: text

fn tcp_connect_established() -> TcpConnectResult:
    """Connect handshake completed; socket moves to ESTABLISHED."""
    TcpConnectResult(
        success: true,
        in_progress: false,
        refused: false,
        timed_out: false,
        unreachable: false,
        error_msg: ""
    )

fn tcp_connect_in_progress() -> TcpConnectResult:
    """Nonblocking connect: SYN sent, waiting for SYN-ACK."""
    TcpConnectResult(
        success: false,
        in_progress: true,
        refused: false,
        timed_out: false,
        unreachable: false,
        error_msg: "EINPROGRESS"
    )

fn tcp_connect_refused() -> TcpConnectResult:
    """Peer sent RST; connection refused."""
    TcpConnectResult(
        success: false,
        in_progress: false,
        refused: true,
        timed_out: false,
        unreachable: false,
        error_msg: "ECONNREFUSED"
    )

fn tcp_connect_timed_out() -> TcpConnectResult:
    """SYN retransmission exhausted; no response from peer."""
    TcpConnectResult(
        success: false,
        in_progress: false,
        refused: false,
        timed_out: true,
        unreachable: false,
        error_msg: "ETIMEDOUT"
    )

fn tcp_connect_unreachable() -> TcpConnectResult:
    """ICMP unreachable or no route to host."""
    TcpConnectResult(
        success: false,
        in_progress: false,
        refused: false,
        timed_out: false,
        unreachable: true,
        error_msg: "EHOSTUNREACH"
    )

# Receive semantics.
struct TcpRecvResult:
    """Result of a TCP recv call."""
    bytes_read: i64
    would_block: bool
    peer_closed: bool
    reset: bool

fn tcp_recv_data(n: i64) -> TcpRecvResult:
    """Bytes available; return the count."""
    TcpRecvResult(bytes_read: n, would_block: false, peer_closed: false, reset: false)

fn tcp_recv_would_block() -> TcpRecvResult:
    """No data ready; nonblocking socket reports would-block."""
    TcpRecvResult(bytes_read: 0, would_block: true, peer_closed: false, reset: false)

fn tcp_recv_peer_closed() -> TcpRecvResult:
    """Peer sent FIN; EOF on receive side."""
    TcpRecvResult(bytes_read: 0, would_block: false, peer_closed: true, reset: false)

fn tcp_recv_reset() -> TcpRecvResult:
    """Peer sent RST; receive aborted."""
    TcpRecvResult(bytes_read: 0, would_block: false, peer_closed: false, reset: true)

# Send buffer with window-aware queuing.
struct TcpSendBuffer:
    """Send buffer tracking window, capacity, and queued bytes."""
    capacity: i64
    queued: i64
    window: i64

fn tcp_send_buffer(cap: i64, win: i64) -> TcpSendBuffer:
    """Create a send buffer with given capacity and initial window."""
    TcpSendBuffer(capacity: cap, queued: 0, window: win)

fn tcp_send_buffer_can_queue(buf: TcpSendBuffer, n: i64) -> bool:
    """True when both capacity and window permit queuing n more bytes."""
    (buf.queued + n <= buf.capacity) and (buf.queued + n <= buf.window)

fn tcp_send_buffer_after_queue(buf: TcpSendBuffer, n: i64) -> TcpSendBuffer:
    """Return updated buffer after queuing n bytes."""
    TcpSendBuffer(capacity: buf.capacity, queued: buf.queued + n, window: buf.window)

fn tcp_send_buffer_after_ack(buf: TcpSendBuffer, acked: i64) -> TcpSendBuffer:
    """Return updated buffer after remote ACK releases acked bytes."""
    val new_queued = buf.queued - acked
    TcpSendBuffer(capacity: buf.capacity, queued: new_queued, window: buf.window)

# Terminal state helpers.
fn tcp_state_after_fin(current: TcpSocketState) -> TcpSocketState:
    """Transition from ESTABLISHED to CLOSE_WAIT on peer FIN."""
    if current.name == "ESTABLISHED":
        return tcp_state_close_wait()
    current

fn tcp_state_after_rst(current: TcpSocketState) -> TcpSocketState:
    """Any state moves to RESET on RST."""
    tcp_state_reset()

fn tcp_state_after_time_wait(current: TcpSocketState) -> TcpSocketState:
    """Active closer enters TIME_WAIT before final CLOSED."""
    TcpSocketState(name: "TIME_WAIT")

fn tcp_connect_result_is_terminal(r: TcpConnectResult) -> bool:
    """True when the connect attempt is finished (success or hard error)."""
    r.success or r.refused or r.timed_out or r.unreachable
