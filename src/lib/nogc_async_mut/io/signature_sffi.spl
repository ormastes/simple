"""
# No-GC async signature SFFI

Compatibility facade over the no-GC sync backend boundary.
"""

export use std.nogc_sync_mut.io.signature_sffi.{
    rsa_sha256_verify, rsa_sha512_verify, ed25519_verify, ecdsa_p256_verify,
    rsa_sha256_sign, rsa_sha512_sign, ed25519_sign_pkcs8, ecdsa_p256_sign,
    ecdsa_p384_verify, ecdsa_p384_sign, ecdsa_p521_verify, ecdsa_p521_sign,
    rsa_pss_sha256_verify, rsa_pss_sha384_verify, rsa_pss_sha512_verify,
    verify_host_key
}
