"""
# Packet I/O Ring Boundary

Pure Simple ownership model for AF_XDP/DPDK-style packet rings. Portable
socket backends do not use this API; callers must opt into a backend whose
network capabilities report packet I/O support.
"""

use std.io.dma.{SharedDmaBuffer}

struct PacketRingCapabilities:
    """Configured packet-ring limits for an explicit packet backend."""
    supports_packet_io: bool
    rx_entries: u32
    tx_entries: u32
    zero_copy: bool

struct PacketBufferLease:
    """Application lease for a packet-ring buffer."""
    ring_id: u64
    buffer_id: u64
    direction: text
    owner: text
    len: u64
    completed: bool

struct PacketDmaLease:
    """Application lease for a packet-ring DMA descriptor."""
    ring_id: u64
    direction: text
    owner: text
    buffer: SharedDmaBuffer
    completed: bool

struct PacketIoBenchmarkReport:
    """Small comparable packet I/O benchmark summary."""
    fixture_name: text
    portable_packets_per_sec: u64
    packet_io_packets_per_sec: u64
    portable_latency_us: u64
    packet_io_latency_us: u64
    backend_summary: text

fn packet_io_disabled_capabilities() -> PacketRingCapabilities:
    """Portable default: no packet-ring ownership is available."""
    PacketRingCapabilities(
        supports_packet_io: false,
        rx_entries: 0u32,
        tx_entries: 0u32,
        zero_copy: false
    )

fn packet_io_opt_in_capabilities(rx_entries: u32,
                                 tx_entries: u32,
                                 zero_copy: bool) -> PacketRingCapabilities:
    """Declare an explicitly configured packet-ring backend."""
    PacketRingCapabilities(
        supports_packet_io: true,
        rx_entries: rx_entries,
        tx_entries: tx_entries,
        zero_copy: zero_copy
    )

fn packet_rx_lease(ring_id: u64, buffer_id: u64, len: u64) -> PacketBufferLease:
    """Lease a received packet buffer to the application."""
    PacketBufferLease(
        ring_id: ring_id,
        buffer_id: buffer_id,
        direction: "rx",
        owner: "application",
        len: len,
        completed: false
    )

fn packet_tx_lease(ring_id: u64, buffer_id: u64, len: u64) -> PacketBufferLease:
    """Lease a transmit packet buffer to the application."""
    PacketBufferLease(
        ring_id: ring_id,
        buffer_id: buffer_id,
        direction: "tx",
        owner: "application",
        len: len,
        completed: false
    )

fn packet_complete(lease: PacketBufferLease) -> PacketBufferLease:
    """Return a buffer lease to the driver completion queue."""
    PacketBufferLease(
        ring_id: lease.ring_id,
        buffer_id: lease.buffer_id,
        direction: lease.direction,
        owner: "driver",
        len: lease.len,
        completed: true
    )

fn packet_rx_dma_lease(ring_id: u64, buffer: SharedDmaBuffer) -> PacketDmaLease:
    """Lease a received shared DMA buffer to the application."""
    PacketDmaLease(
        ring_id: ring_id,
        direction: "rx",
        owner: "application",
        buffer: buffer,
        completed: false
    )

fn packet_tx_dma_lease(ring_id: u64, buffer: SharedDmaBuffer) -> PacketDmaLease:
    """Lease a transmit shared DMA buffer to the application."""
    PacketDmaLease(
        ring_id: ring_id,
        direction: "tx",
        owner: "application",
        buffer: buffer,
        completed: false
    )

fn packet_dma_complete(lease: PacketDmaLease) -> PacketDmaLease:
    """Return a shared DMA lease to the packet-ring driver."""
    PacketDmaLease(
        ring_id: lease.ring_id,
        direction: lease.direction,
        owner: "driver",
        buffer: lease.buffer,
        completed: true
    )

fn packet_io_benchmark_report(fixture_name: text,
                              portable_packets_per_sec: u64,
                              packet_io_packets_per_sec: u64,
                              portable_latency_us: u64,
                              packet_io_latency_us: u64,
                              backend_summary: text) -> PacketIoBenchmarkReport:
    """Compare portable sockets with an explicit packet-ring backend."""
    PacketIoBenchmarkReport(
        fixture_name: fixture_name,
        portable_packets_per_sec: portable_packets_per_sec,
        packet_io_packets_per_sec: packet_io_packets_per_sec,
        portable_latency_us: portable_latency_us,
        packet_io_latency_us: packet_io_latency_us,
        backend_summary: backend_summary
    )

fn packet_io_benchmark_line(report: PacketIoBenchmarkReport) -> text:
    """Render a stable one-line benchmark summary for CI logs."""
    "{report.fixture_name}: portable_pps={report.portable_packets_per_sec}, packet_io_pps={report.packet_io_packets_per_sec}, portable_p50_us={report.portable_latency_us}, packet_io_p50_us={report.packet_io_latency_us}, backend={report.backend_summary}"
