"""
# Packet I/O Ring Boundary

Pure Simple ownership model for AF_XDP/DPDK-style packet rings. Portable
socket backends do not use this API; callers must opt into a backend whose
network capabilities report packet I/O support.
"""

struct PacketRingCapabilities:
    """Configured packet-ring limits for an explicit packet backend."""
    supports_packet_io: bool
    rx_entries: u32
    tx_entries: u32
    zero_copy: bool

struct PacketBufferLease:
    """Application lease for a packet-ring buffer."""
    ring_id: u64
    buffer_id: u64
    direction: text
    owner: text
    len: u64
    completed: bool

fn packet_io_disabled_capabilities() -> PacketRingCapabilities:
    """Portable default: no packet-ring ownership is available."""
    PacketRingCapabilities(
        supports_packet_io: false,
        rx_entries: 0u32,
        tx_entries: 0u32,
        zero_copy: false
    )

fn packet_io_opt_in_capabilities(rx_entries: u32,
                                 tx_entries: u32,
                                 zero_copy: bool) -> PacketRingCapabilities:
    """Declare an explicitly configured packet-ring backend."""
    PacketRingCapabilities(
        supports_packet_io: true,
        rx_entries: rx_entries,
        tx_entries: tx_entries,
        zero_copy: zero_copy
    )

fn packet_rx_lease(ring_id: u64, buffer_id: u64, len: u64) -> PacketBufferLease:
    """Lease a received packet buffer to the application."""
    PacketBufferLease(
        ring_id: ring_id,
        buffer_id: buffer_id,
        direction: "rx",
        owner: "application",
        len: len,
        completed: false
    )

fn packet_tx_lease(ring_id: u64, buffer_id: u64, len: u64) -> PacketBufferLease:
    """Lease a transmit packet buffer to the application."""
    PacketBufferLease(
        ring_id: ring_id,
        buffer_id: buffer_id,
        direction: "tx",
        owner: "application",
        len: len,
        completed: false
    )

fn packet_complete(lease: PacketBufferLease) -> PacketBufferLease:
    """Return a buffer lease to the driver completion queue."""
    PacketBufferLease(
        ring_id: lease.ring_id,
        buffer_id: lease.buffer_id,
        direction: lease.direction,
        owner: "driver",
        len: lease.len,
        completed: true
    )
