"""
# TLS Common Types and Wire Encoding

Shared types and byte-level wire helpers used across the TLS sub-modules.

All byte-level wire data uses `text` strings where each character is one
byte produced by `rt_byte_char(v)`. Byte arrays are [i64] internally;
convert at the I/O boundary with `bytes_to_wire` / `wire_to_bytes`.
"""

use std.tls.certificate.{TlsCertificateChain, TlsPrivateKey}
use std.io.types.{IoError, IoErrorKind}
use std.tls.types.{TLS_VERSION_1_2}
use std.tls.ech.{EchServerConfig, ech_server_config_disabled}
use std.nogc_sync_mut.io.tls_common_hooks.{
    tls_hook_byte_char,
    tls_hook_rsa_decrypt,
    tls_hook_aes_gcm_encrypt,
    tls_hook_aes_gcm_decrypt,
    tls_hook_aes_gcm_encrypt_hex,
    tls_hook_aes_gcm_decrypt_hex,
    tls_hook_wire_to_hex,
    tls_hook_hex_to_wire
}

# ============================================================================
# Crypto Externs (implemented in C runtime)
# ============================================================================

fn tls_rsa_decrypt(ciphertext: text, private_key: text) -> text:
    tls_hook_rsa_decrypt(ciphertext, private_key)

fn tls_aes_gcm_encrypt(key: text, iv: text, plaintext: text, aad: text) -> text:
    tls_hook_aes_gcm_encrypt(key, iv, plaintext, aad)

fn tls_aes_gcm_decrypt(key: text, iv: text, ciphertext: text, aad: text) -> text:
    tls_hook_aes_gcm_decrypt(key, iv, ciphertext, aad)

fn tls_aes_gcm_encrypt_hex(key_hex: text, iv_hex: text, plaintext_hex: text, aad_hex: text) -> text:
    tls_hook_aes_gcm_encrypt_hex(key_hex, iv_hex, plaintext_hex, aad_hex)

fn tls_aes_gcm_decrypt_hex(key_hex: text, iv_hex: text, ciphertext_hex: text, aad_hex: text) -> text:
    tls_hook_aes_gcm_decrypt_hex(key_hex, iv_hex, ciphertext_hex, aad_hex)

fn tls_wire_to_hex(wire: text, wire_len: i64) -> text:
    tls_hook_wire_to_hex(wire, wire_len)

fn tls_hex_to_wire(hex_str: text) -> text:
    tls_hook_hex_to_wire(hex_str)

# ============================================================================
# Wire Encoding Helpers
# ============================================================================

fn bytes_to_wire(bytes: [i64]) -> text:
    """Convert a byte array [i64] to a wire-format text string."""
    var result = ""
    var i = 0
    val n = len(bytes)
    while i < n:
        result = result + tls_hook_byte_char(bytes[i] & 255)
        i = i + 1
    result

fn wire_to_bytes(wire: text) -> [i64]:
    """Convert a wire-format text string to a byte array [i64]."""
    to_bytes(wire)

fn encode_u16_be(value: i64) -> text:
    """Encode a 16-bit value as 2-byte big-endian wire text."""
    tls_hook_byte_char((value >> 8) & 255) + tls_hook_byte_char(value & 255)

fn encode_u24_be(value: i64) -> text:
    """Encode a 24-bit value as 3-byte big-endian wire text."""
    tls_hook_byte_char((value >> 16) & 255) + tls_hook_byte_char((value >> 8) & 255) + tls_hook_byte_char(value & 255)

fn encode_u8(value: i64) -> text:
    """Encode a single byte as wire text."""
    tls_hook_byte_char(value & 255)

# ============================================================================
# TLS Configuration
# ============================================================================

class TlsConfig:
    cert_chain: TlsCertificateChain
    private_key: TlsPrivateKey
    min_version: i64
    max_version: i64
    ech_config: EchServerConfig

    static fn server(chain: TlsCertificateChain, key: TlsPrivateKey) -> TlsConfig:
        TlsConfig(
            cert_chain: chain,
            private_key: key,
            min_version: TLS_VERSION_1_2,
            max_version: TLS_VERSION_1_2,
            ech_config: ech_server_config_disabled()
        )

# ============================================================================
# TLS Session Keys
# ============================================================================

struct TlsSessionKeys:
    client_write_key: text
    server_write_key: text
    client_write_iv: text
    server_write_iv: text
    client_write_mac_key: text
    server_write_mac_key: text

# ============================================================================
# TLS Handshake State
# ============================================================================

struct TlsHandshakeState:
    client_random: [i64]
    server_random: [i64]
    cipher_suite: i64
    master_secret: [i64]
    handshake_messages: text
    session_keys: TlsSessionKeys?
    client_seq: i64
    server_seq: i64
