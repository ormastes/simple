"""
# Network Backend Capabilities

Pure Simple capability model for async network backends. The HTTP server and
socket libraries use this to choose portable paths first and opt into kernel or
hardware acceleration only when a backend explicitly reports support.
"""

use std.io.sriov.{SriovVfAssignment}
use std.io.rdma.{RdmaTransportConfig, rdma_is_enabled}

struct NetBackendCapabilities:
    """Feature flags for a network I/O backend."""
    backend_name: text
    supports_async: bool
    supports_batch_io: bool
    supports_sendfile: bool
    supports_zero_copy: bool
    supports_packet_io: bool
    supports_sriov: bool
    supports_rdma: bool

fn net_backend_capabilities(backend_name: text,
                            supports_async: bool,
                            supports_batch_io: bool,
                            supports_sendfile: bool,
                            supports_zero_copy: bool) -> NetBackendCapabilities:
    """Build host async-driver capabilities for the current runtime backend."""
    NetBackendCapabilities(
        backend_name: backend_name,
        supports_async: supports_async,
        supports_batch_io: supports_batch_io,
        supports_sendfile: supports_sendfile,
        supports_zero_copy: supports_zero_copy,
        supports_packet_io: false,
        supports_sriov: false,
        supports_rdma: false
    )

fn portable_net_backend_capabilities() -> NetBackendCapabilities:
    """Baseline socket backend used by QEMU and hosted CI."""
    NetBackendCapabilities(
        backend_name: "portable-socket",
        supports_async: false,
        supports_batch_io: false,
        supports_sendfile: false,
        supports_zero_copy: false,
        supports_packet_io: false,
        supports_sriov: false,
        supports_rdma: false
    )

fn accelerated_net_backend_capabilities(backend_name: text,
                                        packet_io: bool,
                                        sriov: bool,
                                        rdma: bool) -> NetBackendCapabilities:
    """Declare an explicitly enabled high-performance backend."""
    NetBackendCapabilities(
        backend_name: backend_name,
        supports_async: true,
        supports_batch_io: true,
        supports_sendfile: true,
        supports_zero_copy: true,
        supports_packet_io: packet_io,
        supports_sriov: sriov,
        supports_rdma: rdma
    )

fn packet_io_net_backend_capabilities(backend_name: text,
                                      sriov: bool,
                                      rdma: bool) -> NetBackendCapabilities:
    """Declare an explicitly configured packet-ring network backend."""
    accelerated_net_backend_capabilities(backend_name, true, sriov, rdma)

fn sriov_net_backend_capabilities(backend_name: text, assignment: SriovVfAssignment) -> NetBackendCapabilities:
    """Declare SR-IOV support only for assigned and isolated virtual functions."""
    accelerated_net_backend_capabilities(
        backend_name,
        true,
        assignment.assigned and assignment.isolated,
        false
    )

fn net_backend_sriov_isolation_state(sriov_available: bool, caps: NetBackendCapabilities) -> text:
    """Distinguish available-but-unisolated SR-IOV from isolated SR-IOV."""
    if caps.supports_sriov:
        return "sriov-isolated"
    if sriov_available:
        return "sriov-available"
    "sriov-unavailable"

fn rdma_net_backend_capabilities(config: RdmaTransportConfig) -> NetBackendCapabilities:
    """Declare RDMA only when explicitly enabled by configuration."""
    accelerated_net_backend_capabilities(
        config.backend_name,
        true,
        false,
        rdma_is_enabled(config)
    )

fn net_backend_acceleration_tier(caps: NetBackendCapabilities) -> text:
    """Return the strongest acceleration tier available for routing decisions."""
    if caps.supports_rdma:
        return "rdma"
    if caps.supports_sriov and caps.supports_packet_io:
        return "sriov-packet"
    if caps.supports_zero_copy:
        return "zero-copy"
    if caps.supports_sendfile:
        return "sendfile"
    if caps.supports_batch_io:
        return "batched-async"
    "portable"

fn net_backend_can_accelerate_static_files(caps: NetBackendCapabilities) -> bool:
    """Static file responses can accelerate when sendfile or zero-copy exists."""
    caps.supports_sendfile or caps.supports_zero_copy

fn net_backend_static_file_route(caps: NetBackendCapabilities, has_body_file: bool) -> text:
    """Return the safe static-file route for backend capabilities."""
    if not has_body_file:
        return "body"
    if caps.supports_sendfile:
        return "sendfile"
    "portable-read"

fn net_backend_summary(caps: NetBackendCapabilities) -> text:
    """Compact human-readable capability summary."""
    "{caps.backend_name}:{net_backend_acceleration_tier(caps)}"
