# std.game2d.render.evidence — Pixel-evidence oracles for capture-backed game specs.
#
# Extracted from rollball (src/app/game.rollball/game.spl), which was the
# first game to need pixel-level proof (centroid tracking, frame divergence,
# PPM dumps for visual review). Pure functions, zero game logic: any game can
# use these to build MOTION/DISTINCT/OCCLUSION-style gates without
# reimplementing pixel scanning.

use std.gpu.engine3d.types3d.{color3d_r, color3d_g, color3d_b}
use std.io_runtime.{write_file}

# --- Centroid of pixels matching `color`: [cx, cy, count]. [-1, -1, 0] if none match. ---
fn find_centroid(pixels: [u32], w: i32, h: i32, color: u32) -> [i64]:
    var sx: i64 = 0
    var sy: i64 = 0
    var n: i64 = 0
    var y = 0
    while y < h:
        var x = 0
        while x < w:
            if pixels[y * w + x] == color:
                sx = sx + x
                sy = sy + y
                n = n + 1
            x = x + 1
        y = y + 1
    if n == 0:
        return [-1, -1, 0]
    [sx / n, sy / n, n]

# --- Count differing pixels between two same-sized framebuffers. ---
fn diff_count(a: [u32], b: [u32], n: i32) -> i64:
    var d: i64 = 0
    var i = 0
    while i < n:
        if a[i] != b[i]:
            d = d + 1
        i = i + 1
    d

# --- Dump a P3 (ASCII) PPM framebuffer to disk. ---
fn dump_ppm(path: text, pixels: [u32], w: i32, h: i32) -> bool:
    var body = ""
    var y = 0
    while y < h:
        var row = ""
        var x = 0
        while x < w:
            val p = pixels[y * w + x]
            row = row + "{color3d_r(p)} {color3d_g(p)} {color3d_b(p)}\n"
            x = x + 1
        body = body + row
        y = y + 1
    write_file(path, "P3\n{w} {h}\n255\n" + body)
