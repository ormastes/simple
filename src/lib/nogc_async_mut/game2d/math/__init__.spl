# std.game2d.math — re-exports of common/engine math primitives.
# No redefinition: Vec2, Rect, Color, Transform2D are the engine originals.

use std.common.engine.math2d.{Vec2, Transform2D}
use std.common.engine.rect.{Rect2}
use std.common.engine.color.{EngineColor}

# Public aliases expected by std.game2d consumers.
type Rect = Rect2
type Color = EngineColor

# DrawMode — net-new enum; not in engine primitives.
enum DrawMode:
    Stroke
    Fill
