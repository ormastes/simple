"""
# WebSocket Async Upgrade

HTTP/1.1 101 Switching Protocols handshake for async WebSocket connections.
Validates upgrade requests, computes Sec-WebSocket-Accept, and wraps the
underlying fd into an AsyncWsConnection for frame-level I/O.

## Upgrade Flow

```
Client                          Server
  |--- GET / (Upgrade: websocket) --->|
  |<-- 101 Switching Protocols -------|
  |<========= WsFrame I/O ==========>|
```
"""

use std.nogc_async_mut.io.driver.{IoDriver}
use std.http_server.types.{HttpRequestData, HttpResponseData}
use std.websocket.types.{WEBSOCKET_GUID, OPCODE_TEXT, OPCODE_BINARY, OPCODE_CLOSE, OPCODE_PING, OPCODE_PONG}
use std.websocket.handshake.{sha1, base64_encode, bytes_to_text, text_to_bytes}
use std.websocket.frame.{create_text_frame, create_binary_frame, create_frame, parse_frame_header, extract_mask_key, extract_payload, generate_masking_key}
use std.websocket.connection.{create_close_frame}
use std.common.io.types.{IoError, IoErrorKind}

# ============================================================================
# Constants
# ============================================================================

val WS_TEXT = 1
val WS_BINARY = 2
val WS_CLOSE = 8
val WS_PING = 9
val WS_PONG = 10

# ============================================================================
# WsFrame
# ============================================================================

struct WsFrame:
    """Single WebSocket frame."""
    opcode: i64
    payload: text
    is_final: bool

# ============================================================================
# WsUpgradeRequest
# ============================================================================

struct WsUpgradeRequest:
    """Parsed WebSocket upgrade request headers."""
    key: text
    protocol: text
    extensions: text

    static fn from_request(req: HttpRequestData) -> Option<WsUpgradeRequest>:
        """Validate upgrade headers and extract Sec-WebSocket-Key.

        Returns nil if the request is not a valid WebSocket upgrade.
        """
        var has_upgrade = false
        var has_connection = false
        var ws_key = ""
        var ws_protocol = ""
        var ws_extensions = ""

        for header in req.headers:
            val name = header.0.to_lower()
            val value = header.1

            if name == "upgrade":
                if value.to_lower() == "websocket":
                    has_upgrade = true

            if name == "connection":
                if value.to_lower().contains("upgrade"):
                    has_connection = true

            if name == "sec-websocket-key":
                ws_key = value

            if name == "sec-websocket-protocol":
                ws_protocol = value

            if name == "sec-websocket-extensions":
                ws_extensions = value

        if not has_upgrade:
            return nil
        if not has_connection:
            return nil
        if ws_key == "":
            return nil

        Some(WsUpgradeRequest(key: ws_key, protocol: ws_protocol, extensions: ws_extensions))

# ============================================================================
# WsUpgradeResponse
# ============================================================================

struct WsUpgradeResponse:
    """Builds the 101 Switching Protocols response."""

    static fn accept(ws_key: text) -> HttpResponseData:
        """Create 101 response with Sec-WebSocket-Accept derived from the client key."""
        val accept_value = compute_accept_value(ws_key)
        HttpResponseData(
            status: 101,
            reason: "Switching Protocols",
            headers: [
                ("Upgrade", "websocket"),
                ("Connection", "Upgrade"),
                ("Sec-WebSocket-Accept", accept_value)
            ],
            body: "",
            body_bytes: [],
            body_file: "",
            body_offset: 0,
            body_length: 0,
            chunked: false
        )

# ============================================================================
# AsyncWsConnection
# ============================================================================

class AsyncWsConnection:
    """Async WebSocket connection wrapping a raw TCP fd + IoDriver.

    After a successful 101 handshake the server constructs this from the
    hijacked socket fd and the worker's IoDriver.
    """
    fd: i64
    driver: IoDriver
    is_open: bool

    fn read_frame(driver: IoDriver) -> Result<WsFrame, IoError>:
        """Read one WebSocket frame from the async TCP socket.

        Loops until a complete frame is received, handling TCP
        fragmentation and large payloads.
        """
        if not self.is_open:
            return Err(IoError(kind: IoErrorKind.Other, message: "connection is closed", source: nil))

        var buf: List<i64> = []
        while true:
            val chunk = rt_async_ws_read_raw(self.fd, 65536)
            if chunk.len() == 0:
                if buf.length() == 0:
                    return Err(IoError(kind: IoErrorKind.UnexpectedEof, message: "peer closed", source: nil))
                return Err(IoError(kind: IoErrorKind.UnexpectedEof, message: "incomplete frame", source: nil))
            var i = 0
            while i < chunk.len():
                buf.push(chunk.at(i))
                i = i + 1

            val header = parse_frame_header(buf)
            if header.length() == 0:
                continue

            val fin = header.at(0)
            val opcode = header.at(1)
            val masked = header.at(2)
            val payload_length = header.at(3)
            val header_size = header.at(4)
            val total_needed = header_size + payload_length

            if buf.length() < total_needed:
                continue

            val mask_key = extract_mask_key(data: buf, header_size: header_size, is_masked: masked)
            val payload_bytes = extract_payload(data: buf, header_size: header_size, payload_length: payload_length, mask_key: mask_key)
            val payload_text = bytes_to_text(payload_bytes)

            return Ok(WsFrame(opcode: opcode, payload: payload_text, is_final: fin == 1))

        Err(IoError(kind: IoErrorKind.Other, message: "unreachable", source: nil))

    fn write_frame(driver: IoDriver, frame: WsFrame) -> Result<(), IoError>:
        """Serialize and send a WebSocket frame."""
        if not self.is_open:
            return Err(IoError(kind: IoErrorKind.Other, message: "connection is closed", source: nil))

        val payload_bytes = text_to_bytes(frame.payload)
        val is_fin = if frame.is_final: 1 else: 0
        val raw = create_frame(is_final: is_fin, opcode: frame.opcode, is_masked: 0, payload: payload_bytes, mask_key: [])
        val written = rt_async_ws_write_raw(self.fd, raw)
        if written <= 0:
            return Err(IoError(kind: IoErrorKind.BrokenPipe, message: "write failed", source: nil))
        Ok(())

    fn send_text(driver: IoDriver, data: text) -> Result<(), IoError>:
        """Send a text frame."""
        self.write_frame(driver, WsFrame(opcode: WS_TEXT, payload: data, is_final: true))

    fn send_binary(driver: IoDriver, data: [u8]) -> Result<(), IoError>:
        """Send a binary frame.

        Binary payload is sent raw via the frame encoder to avoid
        text-encoding byte corruption.
        """
        if not self.is_open:
            return Err(IoError(kind: IoErrorKind.Other, message: "connection is closed", source: nil))

        val raw = create_binary_frame(data: data, is_final: 1, is_masked: 0)
        val written = rt_async_ws_write_raw(self.fd, raw)
        if written <= 0:
            return Err(IoError(kind: IoErrorKind.BrokenPipe, message: "write failed", source: nil))
        Ok(())

    me close(driver: IoDriver) -> Result<(), IoError>:
        """Send a close frame and mark the connection closed."""
        if not self.is_open:
            return Ok(())

        val close_bytes = create_close_frame(status_code: 1000, reason: "", is_masked: 0)
        rt_async_ws_write_raw(self.fd, close_bytes)
        self.is_open = false
        val ok = rt_io_tcp_close(self.fd)
        if not ok:
            return Err(IoError(kind: IoErrorKind.Other, message: "close failed", source: nil))
        Ok(())

# ============================================================================
# Upgrade Handler
# ============================================================================

fn ws_upgrade_handler(req: HttpRequestData, stream_fd: i64, driver: IoDriver, on_connect: fn(AsyncWsConnection)) -> HttpResponseData:
    """Handle a WebSocket upgrade request.

    If the request is a valid upgrade, returns the 101 response and
    invokes on_connect with the new AsyncWsConnection. The caller
    (HTTP server worker) must send the 101 response before the
    callback's frames go out on the wire.

    If the request is not a valid upgrade, returns 400.
    """
    val maybe_upgrade = WsUpgradeRequest.from_request(req)
    if not maybe_upgrade.?:
        return HttpResponseData(
            status: 400,
            reason: "Bad Request",
            headers: [("Content-Type", "text/plain")],
            body: "Not a valid WebSocket upgrade request",
            body_bytes: [],
            body_file: "",
            body_offset: 0,
            body_length: 0,
            chunked: false
        )

    val upgrade_req = maybe_upgrade.unwrap()
    val response = WsUpgradeResponse.accept(upgrade_req.key)
    val conn = AsyncWsConnection(fd: stream_fd, driver: driver, is_open: true)
    on_connect(conn)
    response

# ============================================================================
# Internal Helpers
# ============================================================================

fn compute_accept_value(key: text) -> text:
    """SHA-1(key + GUID) then base64-encode the 20-byte digest."""
    val concatenated = key + WEBSOCKET_GUID
    val hash_bytes = sha1(concatenated)
    val hash_text = bytes_to_text(hash_bytes)
    base64_encode(hash_text)

# ============================================================================
# FFI
# ============================================================================

extern fn rt_async_ws_read_raw(fd: i64, max_size: i64) -> List<i64>
extern fn rt_async_ws_write_raw(fd: i64, data: List<i64>) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool
