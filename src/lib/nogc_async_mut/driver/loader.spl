# Driver loader — parses `.drv_manifest` section bytes and produces a
# DriverManifest. Pure-byte decoding, so the same function works whether
# the section was mmap'd from disk or embedded in a kernel image.
#
# The companion SMF reader (in `src/compiler/70.backend/linker/lib_smf.spl`)
# will gain a `.drv_manifest` section kind; this file decodes those bytes.
#
# Binary layout — kept in one place, defined in manifest.spl. This file
# only reads; writing is the compiler's job.

use std.driver.error.{DriverError}
use std.driver.manifest.{DriverManifest, ManifestKind,
                         DRVS_MAGIC, DRVS_ABI_REV, DRVS_HEADER_BYTES,
                         DRVS_NAME_LEN, DRVS_VERSION_LEN}
use std.driver.registry.{DriverRegistry, DriverOps}
use std.driver.types.{DriverClass}

# Decode the first manifest record in `bytes`, starting at `offset`.
# Returns the manifest and the byte-offset of the record end.
fn decode_manifest(bytes: [u8], offset: i32) -> Result<DriverManifest, DriverError>:
    if (bytes.len() as i32) - offset < DRVS_HEADER_BYTES:
        return Err(DriverError.BadConfig)

    val magic: i32 = read_u32_le(bytes, offset + 0)
    if magic != DRVS_MAGIC:
        return Err(DriverError.BadConfig)

    val kind_raw: i32 = bytes[offset + 4] as i32
    val class_raw: i32 = bytes[offset + 5] as i32
    val abi_rev:   i32 = read_u16_le(bytes, offset + 6)
    if abi_rev != DRVS_ABI_REV:
        return Err(DriverError.AbiMismatch)

    val vendor:        i32 = read_u32_le(bytes, offset + 8)
    val device_count:  i32 = read_u32_le(bytes, offset + 12)

    val version: text = read_ascii(bytes, at: offset + 16, max_len: DRVS_VERSION_LEN)
    val name:    text = read_ascii(bytes, at: offset + 32, max_len: DRVS_NAME_LEN)

    var ids: [i32] = []
    var i: i32 = 0
    while i < device_count:
        val id: i32 = read_u32_le(bytes, offset + DRVS_HEADER_BYTES + i * 8 + 4)
        ids.append(id)
        i = i + 1

    val kind: ManifestKind = kind_from_byte(kind_raw)
    val cls:  DriverClass  = class_from_byte(class_raw)

    if kind == ManifestKind.Driver:
        return Ok(DriverManifest.for_driver(name, version, cls, vendor, ids))
    return Ok(DriverManifest.for_native_lib(name, version))

# Register an already-loaded module with the given registry. The caller
# supplies the `DriverOps` record — the loader cannot synthesize it
# because the function-pointer targets live in the loaded module's
# image. In static mode the driver itself calls `register_static_driver`
# in its init; in dynamic mode this helper is invoked by the SMF loader
# after resolving the entry-point symbols.
fn register_loaded(reg: DriverRegistry, manifest: DriverManifest,
                   ops: DriverOps) -> Result<i32, DriverError>:
    return reg.register(ops, manifest)

# --- Little-endian byte helpers (kept local; std has no bulk LE reader) ---

fn read_u16_le(buf: [u8], at: i32) -> i32:
    val lo: i32 = buf[at]     as i32
    val hi: i32 = buf[at + 1] as i32
    return lo | (hi << 8)

fn read_u32_le(buf: [u8], at: i32) -> i32:
    val b0: i32 = buf[at]     as i32
    val b1: i32 = buf[at + 1] as i32
    val b2: i32 = buf[at + 2] as i32
    val b3: i32 = buf[at + 3] as i32
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn read_ascii(buf: [u8], at: i32, max_len: i32) -> text:
    # Stop at first NUL. Pure Simple, no stdlib text-builder dependency
    # because the loader path may run before std text helpers are set up.
    var end: i32 = at
    var limit: i32 = at + max_len
    var chars: [text] = []
    while end < limit:
        if buf[end] == 0:
            break
        chars.push(driver_ascii_char(buf[end]))
        end = end + 1
    return chars.join("")

fn driver_ascii_char(b: u8) -> text:
    val ascii_table = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    val idx = (b as i32) - 32
    if idx >= 0 and idx < (ascii_table.len() as i32):
        return ascii_table.slice(idx, idx + 1)
    "?"

fn kind_from_byte(b: i32) -> ManifestKind:
    match b:
        0 -> return ManifestKind.Driver
        _ -> return ManifestKind.NativeLib

fn class_from_byte(b: i32) -> DriverClass:
    match b:
        0  -> return DriverClass.Block
        1  -> return DriverClass.Char
        2  -> return DriverClass.Net
        3  -> return DriverClass.Input
        4  -> return DriverClass.Display
        5  -> return DriverClass.Storage
        6  -> return DriverClass.Bus
        7  -> return DriverClass.Fs
        8  -> return DriverClass.Gpu
        9  -> return DriverClass.Audio
        10 -> return DriverClass.Sensor
        11 -> return DriverClass.Timer
        12 -> return DriverClass.Irq
        13 -> return DriverClass.Power
        14 -> return DriverClass.Virt
        _  -> return DriverClass.Misc

# FR-DRIVER-0004: encoder — the producer side of the .drv_manifest
# section. The compiler's codegen glue calls this to convert a
# DriverManifest (synthesized from @driver / @native_lib HIR attributes)
# into the DRVS byte record described in manifest.spl. The resulting
# bytes feed `SmfWriter.add_section(SectionType.DrvManifest, bytes)`.
#
# Kept in the same file as `decode_manifest` so the two sides of the
# wire contract live side-by-side; any future layout change must update
# both in one commit.
fn encode_manifest(m: DriverManifest) -> [u8]:
    var buf: [u8] = []
    buf = buf.concat(driver_u32_le_bytes(DRVS_MAGIC))
    buf = buf.push(kind_to_byte(m.kind) as u8)
    buf = buf.push(class_to_byte(m.dclass) as u8)
    buf = buf.concat(driver_u16_le_bytes(m.abi_rev))
    buf = buf.concat(driver_u32_le_bytes(m.vendor))
    val device_count: i32 = m.device_ids.len() as i32
    buf = buf.concat(driver_u32_le_bytes(device_count))
    buf = buf.concat(driver_fixed_ascii_bytes(m.version, DRVS_VERSION_LEN))
    buf = buf.concat(driver_fixed_ascii_bytes(m.name, DRVS_NAME_LEN))

    var j: i32 = 0
    while j < device_count:
        buf = buf.concat(driver_u32_le_bytes(0))
        buf = buf.concat(driver_u32_le_bytes(m.device_ids[j]))
        j = j + 1

    return buf

# --- Little-endian byte writers — mirror of the readers above ---

fn driver_u16_le_bytes(value: i32) -> [u8]:
    [
        (value & 0xff) as u8,
        ((value >> 8) & 0xff) as u8
    ]

fn driver_u32_le_bytes(value: i32) -> [u8]:
    [
        (value & 0xff) as u8,
        ((value >> 8) & 0xff) as u8,
        ((value >> 16) & 0xff) as u8,
        ((value >> 24) & 0xff) as u8
    ]

fn driver_fixed_ascii_bytes(s: text, max_len: i32) -> [u8]:
    val src: [u8] = rt_text_to_bytes(s)
    var out: [u8] = []
    var i: i32 = 0
    while i < max_len:
        if i < (src.len() as i32):
            out = out.push(src[i])
        else:
            out = out.push(0 as u8)
        i = i + 1
    out

fn write_u16_le(buf: [u8], at: i32, value: i32):
    buf[at]     = (value        & 0xff) as u8
    buf[at + 1] = ((value >> 8)  & 0xff) as u8

fn write_u32_le(buf: [u8], at: i32, value: i32):
    buf[at]     = (value         & 0xff) as u8
    buf[at + 1] = ((value >> 8)  & 0xff) as u8
    buf[at + 2] = ((value >> 16) & 0xff) as u8
    buf[at + 3] = ((value >> 24) & 0xff) as u8

# Write an ASCII string into `buf[at .. at+max_len]`, zero-padding the
# tail. Truncates silently if `s` is longer than `max_len` (decoder
# reads at most `max_len` bytes regardless).
extern fn rt_text_to_bytes(s: text) -> [u8]

fn write_ascii(buf: [u8], at: i32, max_len: i32, s: text):
    val src: [u8] = rt_text_to_bytes(s)
    var i: i32 = 0
    var n: i32 = src.len() as i32
    if n > max_len:
        n = max_len
    while i < n:
        buf[at + i] = src[i]
        i = i + 1
    # remaining bytes already zero from allocation

# utf8_bytes_of is now rt_text_to_bytes (declared above)

fn kind_to_byte(k: ManifestKind) -> i32:
    match k:
        case Driver:    return 0
        case NativeLib: return 1

fn class_to_byte(c: DriverClass) -> i32:
    match c:
        case Block:   return 0
        case Char:    return 1
        case Net:     return 2
        case Input:   return 3
        case Display: return 4
        case Storage: return 5
        case Bus:     return 6
        case Fs:      return 7
        case Gpu:     return 8
        case Audio:   return 9
        case Sensor:  return 10
        case Timer:   return 11
        case Irq:     return 12
        case Power:   return 13
        case Virt:    return 14
        case Misc:    return 15
