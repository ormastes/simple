"""
# Async DNS Resolver

Cache-aware async DNS resolver using UDP transport.
Builds queries via the sync DNS packet builder and parses responses
via the sync DNS parser, but sends/receives over async UDP.

## Components

| Type | Description |
|------|-------------|
| CacheEntry | Single cached hostname -> addresses mapping with TTL |
| DnsCache | TTL-aware DNS lookup cache |
| AsyncResolver | Async DNS A-record resolver with cache and nameserver failover |

## Usage

```simple
# val driver = IoDriver.new()
# val resolver = AsyncResolver.new(driver)
# val addrs = resolver.resolve("example.com")?
# resolver.clear_cache()
```
"""

use std.common.io.types.{IoError, IoErrorKind}
use std.nogc_async_mut.io.driver.{IoDriver}
use std.nogc_async_mut.io.udp.{AsyncUdpSocket}
use std.async.future.{Future}
use std.async.poll.{Poll}
use std.nogc_async_mut.dns.build.{dns_build_a_query}
use std.nogc_async_mut.dns.parse.{dns_parse_response, dns_extract_answers, dns_filter_a_records}
use std.nogc_async_mut.dns.query.{dns_get_message_header, dns_get_rcode, dns_is_success, dns_get_rr_data, dns_get_rr_ttl}
use std.nogc_async_mut.dns.utilities.{dns_rcode_to_string}
use std.nogc_sync_mut.io.file_ops.{file_read_text}
use std.nogc_sync_mut.io.time_ops.{current_time_unix}

extern fn rt_text_to_bytes(t: text) -> [u8]
extern fn rt_bytes_to_text(b: [u8]) -> text

val DEFAULT_TIMEOUT_MS = 5000
val MAX_UDP_SIZE = 512
val DEFAULT_TTL = 300

# ============================================================================
# CacheEntry
# ============================================================================

struct CacheEntry:
    """Single cached DNS result."""
    hostname: text
    addresses: [text]
    expires_at: i64

# ============================================================================
# DnsCache
# ============================================================================

class DnsCache:
    """TTL-aware DNS lookup cache.

    Stores hostname -> address list mappings that expire after their TTL.
    """
    entries: [CacheEntry]

    static fn new() -> DnsCache:
        DnsCache(entries: [])

    fn lookup(hostname: text) -> Option<[text]>:
        val now = current_time_unix()
        var i = 0
        while i < self.entries.size():
            val entry = self.entries.get(i)
            if entry.hostname == hostname:
                if entry.expires_at > now:
                    return Some(entry.addresses)
                return nil
            i = i + 1
        nil

    me insert(hostname: text, addresses: [text], ttl: i64):
        val now = current_time_unix()
        val expires = now + ttl
        val entry = CacheEntry(hostname: hostname, addresses: addresses, expires_at: expires)

        var new_entries: [CacheEntry] = []
        var i = 0
        while i < self.entries.size():
            val existing = self.entries.get(i)
            if existing.hostname != hostname:
                new_entries = new_entries + [existing]
            i = i + 1
        new_entries = new_entries + [entry]
        self.entries = new_entries

    me evict_expired():
        val now = current_time_unix()
        var kept: [CacheEntry] = []
        var i = 0
        while i < self.entries.size():
            val entry = self.entries.get(i)
            if entry.expires_at > now:
                kept = kept + [entry]
            i = i + 1
        self.entries = kept

# ============================================================================
# AsyncResolver
# ============================================================================

class AsyncResolver:
    """Async DNS resolver with caching and nameserver failover.

    Reads /etc/resolv.conf for nameservers on creation, falling back
    to Google Public DNS (8.8.8.8, 8.8.4.4).

    Example:
        val driver = IoDriver.new()
        val resolver = AsyncResolver.new(driver)
        val addrs = resolver.resolve("example.com")?
    """
    driver: IoDriver
    nameservers: [text]
    cache: DnsCache
    timeout_ms: i64

    static fn new(driver: IoDriver) -> AsyncResolver:
        val servers = parse_resolv_conf()
        AsyncResolver(
            driver: driver,
            nameservers: servers,
            cache: DnsCache.new(),
            timeout_ms: DEFAULT_TIMEOUT_MS
        )

    static fn with_nameservers(driver: IoDriver, servers: [text]) -> AsyncResolver:
        AsyncResolver(
            driver: driver,
            nameservers: servers,
            cache: DnsCache.new(),
            timeout_ms: DEFAULT_TIMEOUT_MS
        )

    fn resolve(hostname: text) -> Result<[text], IoError>:
        val cached = self.cache.lookup(hostname)
        if cached.?:
            return Ok(cached.unwrap())
        self.resolve_uncached(hostname)

    fn resolve_uncached(hostname: text) -> Result<[text], IoError>:
        if self.nameservers.size() == 0:
            return Err(IoError(
                kind: IoErrorKind.Other,
                message: "no nameservers configured",
                source: nil
            ))

        var last_err: IoError = IoError(
            kind: IoErrorKind.Other,
            message: "no nameservers tried",
            source: nil
        )

        # Try each nameserver until one succeeds
        var ns_idx = 0
        while ns_idx < self.nameservers.size():
            val ns = self.nameservers.get(ns_idx)
            val result = self.query_nameserver(hostname, ns)
            match result:
                case Ok(addrs):
                    return Ok(addrs)
                case Err(e):
                    last_err = e
            ns_idx = ns_idx + 1

        Err(last_err)

    me clear_cache():
        self.cache = DnsCache.new()

    # --- internal helpers ---

    fn query_nameserver(hostname: text, nameserver: text) -> Result<[text], IoError>:
        val query_id = dns_query_id_from_hostname(hostname)
        val query_packet = dns_build_a_query(query_id, hostname)
        val query_bytes = rt_text_to_bytes(query_packet)

        # Bind ephemeral UDP socket (bind returns Future.from_value -- always ready)
        val bind_future = AsyncUdpSocket.bind("0.0.0.0:0")
        val bind_result = poll_bind_with_timeout(bind_future, self.timeout_ms)
        if bind_result.is_err():
            return Err(bind_result.unwrap_err())
        val socket = bind_result.unwrap()

        # Send query to nameserver:53
        val dest = nameserver + ":53"
        val send_future = socket.send_to(query_bytes, dest)
        val send_result = poll_future_with_timeout(send_future, self.timeout_ms)
        if send_result.is_err():
            return Err(send_result.unwrap_err())
        val sent = send_result.unwrap()
        if sent <= 0:
            return Err(IoError(kind: IoErrorKind.Other, message: "dns send returned 0 bytes", source: nil))

        # Receive response
        val recv_future = socket.recv_from(MAX_UDP_SIZE)
        val recv_result = poll_recv_with_timeout(recv_future, self.timeout_ms)
        if recv_result.is_err():
            return Err(recv_result.unwrap_err())
        val pair = recv_result.unwrap()
        val data = pair.0
        val response_text = rt_bytes_to_text(data)

        val message = dns_parse_response(response_text)
        if message == nil:
            return Err(IoError(kind: IoErrorKind.InvalidData, message: "failed to parse dns response from {nameserver}", source: nil))

        val header = dns_get_message_header(message)
        val rcode = dns_get_rcode(header)
        if dns_is_success(rcode) != 1:
            val rcode_str = dns_rcode_to_string(rcode)
            return Err(IoError(kind: IoErrorKind.Other, message: "dns error from {nameserver}: {rcode_str}", source: nil))

        val answers = dns_extract_answers(message)
        val a_records = dns_filter_a_records(answers)
        var addresses: [text] = []
        var ttl = DEFAULT_TTL
        var ri = 0
        while ri < a_records.size():
            val rr = a_records.get(ri)
            addresses = addresses + [dns_get_rr_data(rr)]
            val record_ttl = dns_get_rr_ttl(rr)
            if record_ttl > 0:
                ttl = record_ttl
            ri = ri + 1

        if addresses.size() == 0:
            return Err(IoError(kind: IoErrorKind.Other, message: "no A records in response from {nameserver}", source: nil))

        self.cache.insert(hostname, addresses, ttl)
        Ok(addresses)

# ============================================================================
# Poll Helpers
# ============================================================================

fn poll_bind_with_timeout(future: Future<Result<AsyncUdpSocket, IoError>>, timeout_ms: i64) -> Result<AsyncUdpSocket, IoError>:
    var steps = 0
    val max_steps = timeout_ms * 10
    while steps < max_steps:
        val p = future.poll()
        match p:
            case Poll.Ready(result):
                return result
            case Poll.Pending:
                steps = steps + 1
    Err(IoError(kind: IoErrorKind.TimedOut, message: "udp bind timed out", source: nil))

fn poll_future_with_timeout(future: Future<Result<i64, IoError>>, timeout_ms: i64) -> Result<i64, IoError>:
    var steps = 0
    val max_steps = timeout_ms * 10
    while steps < max_steps:
        val p = future.poll()
        match p:
            case Poll.Ready(result):
                return result
            case Poll.Pending:
                steps = steps + 1
    Err(IoError(kind: IoErrorKind.TimedOut, message: "dns operation timed out", source: nil))

fn poll_recv_with_timeout(future: Future<Result<([u8], text), IoError>>, timeout_ms: i64) -> Result<([u8], text), IoError>:
    var steps = 0
    val max_steps = timeout_ms * 10
    while steps < max_steps:
        val p = future.poll()
        match p:
            case Poll.Ready(result):
                return result
            case Poll.Pending:
                steps = steps + 1
    Err(IoError(kind: IoErrorKind.TimedOut, message: "dns recv timed out", source: nil))

# ============================================================================
# /etc/resolv.conf Parser
# ============================================================================

fn parse_resolv_conf() -> [text]:
    # Falls back to Google Public DNS if file missing or has no entries
    val fallback: [text] = ["8.8.8.8", "8.8.4.4"]
    val content = file_read_text("/etc/resolv.conf")
    if content == "":
        return fallback

    val lines = content.split("\n")
    var servers: [text] = []
    var i = 0
    while i < lines.size():
        val line = lines.get(i).trim()
        if line.starts_with("nameserver "):
            val addr = line.substring(11, line.size()).trim()
            if addr.size() > 0:
                servers = servers + [addr]
        i = i + 1

    if servers.size() == 0:
        return fallback
    servers

# ============================================================================
# DNS Query ID Helper
# ============================================================================

fn dns_query_id_from_hostname(hostname: text) -> i64:
    var h = 0
    var i = 0
    while i < hostname.size():
        h = (h * 31 + i + 1) % 65536
        i = i + 1
    if h == 0:
        h = 1
    h
