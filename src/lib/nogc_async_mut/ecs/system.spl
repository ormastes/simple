# ECS System + Scheduler
#
# A System is a named free function the service registers with the Scheduler.
# The scheduler runs systems in insertion order on each tick.

struct SystemEntry:
    name: str
    run: fn(u64, i64)
    enabled: bool

struct Scheduler:
    systems: [SystemEntry]
    tick: i64

    static fn new() -> Scheduler:
        Scheduler(systems: [], tick: 0)

    fn add(self, name: str, run: fn(u64, i64)):
        self.systems.push(SystemEntry(name: name, run: run, enabled: true))

    fn disable(self, name: str) -> bool:
        var i: i32 = 0
        val n = self.systems.len() as i32
        while i < n:
            if self.systems[i].name == name:
                self.systems[i].enabled = false
                return true
            i = i + 1
        false

    fn enable(self, name: str) -> bool:
        var i: i32 = 0
        val n = self.systems.len() as i32
        while i < n:
            if self.systems[i].name == name:
                self.systems[i].enabled = true
                return true
            i = i + 1
        false

    fn step(self, ctx_ptr: u64):
        """Advance the tick and run every enabled system once."""
        self.tick = self.tick + 1
        val n = self.systems.len() as i32
        var i: i32 = 0
        while i < n:
            if self.systems[i].enabled:
                (self.systems[i].run)(ctx_ptr, self.tick)
            i = i + 1

    fn now(self) -> i64:
        self.tick
