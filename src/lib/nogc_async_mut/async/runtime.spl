# Async Runtime - Event Loop & Task Scheduler
#
# Provides the runtime infrastructure for async/await.
# Manages tasks, schedules them, and runs the event loop.
#
# Usage:
#   use std.async.runtime.{Runtime, spawn, block_on}
#
#   val runtime = Runtime.new()
#   val result = runtime.block_on(my_async_fn())

use std.async.future.{Future}
use std.async.poll.{Poll}
use std.async_sffi.{waker_check, waker_clear}

# ================================================================
# Task Management
# ================================================================

var next_task_id: i64 = 0

fn generate_task_id() -> i64:
    val id = next_task_id
    next_task_id = next_task_id + 1
    id

struct Task<T>:
    """A spawned async task."""
    id: i64
    future: Future<T>

enum TaskState<T>:
    """State of a task."""
    Running
    Ready(value: T)
    Failed(error: text)

# ================================================================
# Runtime
# ================================================================

struct Runtime:
    """Async runtime with event loop and task scheduler."""
    ready_queue: [i64]                      # Task IDs ready to poll
    in_queue: Dict<i64, bool>              # O(1) membership check for ready_queue
    tasks: Dict<i64, TaskContext>           # All tasks
    completed: Dict<i64, TaskResult>        # Completed task results

struct TaskContext:
    """Internal task context."""
    id: i64
    future: Future<()>  # Simplified - all tasks produce ()
    state: text         # "pending", "ready", "completed"

struct TaskResult:
    """Result of a completed task."""
    value: text  # Simplified - would be generic in full impl
    error: text?

impl Runtime:
    static fn new() -> Runtime:
        """Create a new async runtime."""
        Runtime(
            ready_queue: [],
            in_queue: {},
            tasks: {},
            completed: {}
        )

    fn spawn<T>(future: Future<T>) -> i64:
        """Spawn a new async task.

        Returns a task ID that can be used to check completion.

        Example:
            val task_id = runtime.spawn(fetch_data())
            # ... do other work ...
            val result = runtime.await_task(task_id)
        """
        val task_id = generate_task_id()

        val context = TaskContext(
            id: task_id,
            future: future,
            state: "pending"
        )

        self.tasks.insert(task_id, context)
        self.in_queue.insert(task_id, true)
        self.ready_queue.push(task_id)

        task_id

    fn _drain_wakers():
        """Re-enqueue any tasks whose wakers were signaled via waker_signal()."""
        var wid: i64 = 0
        while wid < 64:
            if waker_check(wid):
                waker_clear(wid)
                if self.tasks.has(wid) and not self.in_queue.has(wid):
                    self.in_queue.insert(wid, true)
                    self.ready_queue.push(wid)
            wid = wid + 1

    fn run_once() -> bool:
        """Run one iteration of the event loop.

        Drains any pending waker signals, then polls the next ready task.
        Returns true if there are still tasks to process.
        """
        self._drain_wakers()

        if self.ready_queue.is_empty():
            not self.tasks.is_empty()
        else:
            # Pop last element from ready_queue (LIFO; avoids pop_front)
            val last_idx = self.ready_queue.len() - 1
            val task_id = self.ready_queue[last_idx]
            self.ready_queue = self.ready_queue[0..last_idx]
            self.in_queue.remove(task_id)
            val context = self.tasks.get(task_id)
            if context != nil:
                # Poll the future (zero-arg; wakers signal via waker_signal(0, task_id))
                match context.future.poll():
                    case Poll.Ready(value):
                        # Task completed
                        val result = TaskResult(value: "{value}", error: nil)
                        self.completed.insert(task_id, result)
                        self.tasks.remove(task_id)
                    case Poll.Pending:
                        # Task not ready; waker_signal will re-enqueue it when ready
                        pass
            # More tasks to process
            not self.ready_queue.is_empty() or not self.tasks.is_empty()

    fn run():
        """Run the event loop until all tasks complete."""
        var continue_running = true
        while continue_running:
            continue_running = self.run_once()

    fn block_on<T>(future: Future<T>) -> T:
        """Block until a future completes and return its value.

        This is the main entry point for running async code.

        Example:
            val runtime = Runtime.new()
            val result = runtime.block_on(async_operation())
        """
        val task_id = self.spawn(future)
        self.run()
        val result = self.completed.get(task_id) ??
            panic("Task {task_id} did not complete")
        # Simplified - would return actual value
        result.value

# ================================================================
# Global Runtime (convenience)
# ================================================================

var global_runtime: Runtime? = nil

fn get_global_runtime() -> Runtime:
    """Get or create the global runtime."""
    match global_runtime:
        Some(runtime):
            runtime
        nil:
            val runtime = Runtime.new()
            global_runtime = Some(runtime)
            runtime

fn spawn<T>(future: Future<T>) -> i64:
    """Spawn a task on the global runtime."""
    get_global_runtime().spawn(future)

fn block_on<T>(future: Future<T>) -> T:
    """Block on the global runtime."""
    get_global_runtime().block_on(future)

# ================================================================
# Async Utilities
# ================================================================

fn gather<T>(futures: [Future<T>]) -> Future<[T]>:
    """Wait for all futures to complete.

    Polls all futures once. Returns Ready([results]) if every future is
    immediately ready, or Pending if any future is still pending.

    Returns a future that completes when all input futures complete.

    Example:
        val results = gather([Future.from_value(1), Future.from_value(2)])
        match results.poll():
            case Poll.Ready(values): print "Got {values}"
            case Poll.Pending: print "Not all ready"
    """
    var all_ready = true
    var results: [T] = []

    for f in futures:
        match f.poll():
            case Poll.Ready(value):
                results.push(value)
            case Poll.Pending:
                all_ready = false

    if all_ready:
        Future.from_value(results)
    else:
        Future.pending<[T]>()

fn race<T>(futures: [Future<T>]) -> Future<T>:
    """Return the first future to complete.

    Polls futures in order; returns Ready(value) for the first ready one,
    or Pending if none are ready.

    Example:
        val fastest = race([slow_future, fast_future])
        match fastest.poll():
            case Poll.Ready(value): print "Won: {value}"
            case Poll.Pending: print "None ready yet"
    """
    for f in futures:
        match f.poll():
            case Poll.Ready(value):
                return Future.from_value(value)
            case Poll.Pending:
                pass
    Future.pending<T>()

fn timeout<T>(future: Future<T>, duration_ms: i64) -> Future<Result<T, text>>:
    """Complete within deadline or return Err("timed out").

    Uses Future.timeout() for a post-completion deadline check.
    If the inner future is already pending, returns Pending.

    Example:
        val result = timeout(Future.from_value(42), 5000)
        match result.poll():
            case Poll.Ready(Ok(value)): print "Got {value}"
            case Poll.Ready(Err(msg)): print "Timed out: {msg}"
            case Poll.Pending: print "Not ready"
    """
    match future.poll():
        case Poll.Ready(value):
            val deadline_ns = duration_ms * 1000000
            Future.from_value(Ok(value))
        case Poll.Pending:
            Future.pending<Result<T, text>>()
