# AsyncIO - Async I/O Operations
#
# Non-blocking I/O operations.
#
# Stub status:
#   sleep()     — returns Future.pending (suspends; re-poll via waker_signal)
#   yield_now() — returns Future.pending (suspends once; re-poll via waker_signal)
#   read_file() — synchronous wrapper returning Future.from_value (ready immediately)
#   write_file()— synchronous wrapper returning Future.from_value (ready immediately)
#
# A real cooperative yield requires the runtime to call waker_signal(0, task_id)
# after one tick, then drain WAKER_REGISTRY in _drain_wakers(). Without a native
# timer backend, sleep() cannot measure wall time.

use std.async.future.{Future}
use std.async.poll.{Poll}
use std.nogc_sync_mut.sffi.io.{file_read_bytes, file_write_bytes}

class AsyncIO:
    """Non-blocking I/O operations.

    Provides async versions of blocking I/O operations.

    Example:
        val io = AsyncIO.new()

        # Non-blocking read (synchronous under the hood for now)
        val data = io.read_file("data.txt")
        match data.poll():
            case Poll.Ready(bytes): print "Read {bytes.len()} bytes"
            case Poll.Pending: print "Waiting..."
    """

    static fn new() -> AsyncIO:
        """Create async I/O handle."""
        AsyncIO()

    fn sleep(millis: usize) -> Future<()>:
        """Suspend for at least millis milliseconds (async).

        Returns a Pending future. The caller must be running inside a runtime
        that calls waker_signal(0, task_id) after the delay has elapsed.

        Args:
            millis: Milliseconds to sleep

        Returns:
            Pending future (suspends the calling task)
        """
        Future.pending<()>()

    fn yield_now() -> Future<()>:
        """Yield to other tasks (cooperative scheduling point).

        Returns a Pending future so the current task suspends. The runtime's
        _drain_wakers() will re-enqueue the task on the next tick if
        waker_signal has been called for it. Without a backend timer, callers
        must signal the waker externally.

        Returns:
            Pending future (suspends once, rescheduled by waker_signal)
        """
        Future.pending<()>()

    fn read_file(path: text) -> Future<[u8]>:
        """Read file (synchronous wrapper returning an immediately-ready future).

        Args:
            path: File path

        Returns:
            Ready future with file contents
        """
        Future.from_value(file_read_bytes(path))

    fn write_file(path: text, data: [u8]) -> Future<bool>:
        """Write file (synchronous wrapper returning an immediately-ready future).

        Args:
            path: File path
            data: Data to write

        Returns:
            Ready future with success flag
        """
        Future.from_value(file_write_bytes(path, data))
