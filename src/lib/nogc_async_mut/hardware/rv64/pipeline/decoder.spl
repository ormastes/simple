@allow(unnamed_duplicate_typed_args) # reason: instruction encoding APIs use positional i64 params
# RV64I Instruction Decoder
#
# Extracts fields from a 32-bit RISC-V instruction word: opcode, rd, rs1,
# rs2, funct3, funct7, and immediates for all six instruction formats
# (R/I/S/B/U/J). Determines ALU operation and control signals.
#
# Reference: RISC-V ISA Manual, Volume I, Chapters 2 (RV32I) and 5 (RV64I).
#
# Feature IDs: #HW-RV64-PIPE-DEC
# Category: Hardware / RTL Simulation
# Status: Implemented

use std.hardware.rv64.pipeline.types.{
    Rv64AluOp, Rv64InstType, Rv64IdExLatch, create_id_ex_latch
}

# ============================================================================
# Instruction Field Extractors
# ============================================================================

fn rv64_opcode(inst: i64) -> i64:
    """Extract opcode field -- bits [6:0]."""
    inst & 0x7F

fn rv64_rd(inst: i64) -> i64:
    """Extract rd field -- bits [11:7]."""
    (inst >> 7) & 0x1F

fn rv64_funct3(inst: i64) -> i64:
    """Extract funct3 field -- bits [14:12]."""
    (inst >> 12) & 0x7

fn rv64_rs1(inst: i64) -> i64:
    """Extract rs1 field -- bits [19:15]."""
    (inst >> 15) & 0x1F

fn rv64_rs2(inst: i64) -> i64:
    """Extract rs2 field -- bits [24:20]."""
    (inst >> 20) & 0x1F

fn rv64_funct7(inst: i64) -> i64:
    """Extract funct7 field -- bits [31:25]."""
    (inst >> 25) & 0x7F

# ============================================================================
# Immediate Decoders
# ============================================================================

fn sign_extend(value: i64, bits: i64) -> i64:
    """Sign-extend a value from `bits` width to 64 bits."""
    val mask = 1 << (bits - 1)
    if (value & mask) != 0:
        # Negative: fill upper bits with 1s
        val fill = -1 << bits
        return value | fill
    value

fn rv64_imm_i(inst: i64) -> i64:
    """I-type immediate -- bits [31:20], sign-extended."""
    val raw = (inst >> 20) & 0xFFF
    sign_extend(raw, 12)

fn rv64_imm_s(inst: i64) -> i64:
    """S-type immediate -- bits [31:25] | [11:7], sign-extended."""
    val hi = (inst >> 25) & 0x7F
    val lo = (inst >> 7) & 0x1F
    val raw = (hi << 5) | lo
    sign_extend(raw, 12)

fn rv64_imm_b(inst: i64) -> i64:
    """B-type immediate -- sign-extended, bit [12|10:5|4:1|11]."""
    val b12 = (inst >> 31) & 1
    val b10_5 = (inst >> 25) & 0x3F
    val b4_1 = (inst >> 8) & 0xF
    val b11 = (inst >> 7) & 1
    val raw = (b12 << 12) | (b11 << 11) | (b10_5 << 5) | (b4_1 << 1)
    sign_extend(raw, 13)

fn rv64_imm_u(inst: i64) -> i64:
    """U-type immediate -- bits [31:12] << 12, sign-extended."""
    val raw = inst & 0xFFFFF000
    sign_extend(raw, 32)

fn rv64_imm_j(inst: i64) -> i64:
    """J-type immediate -- sign-extended, bit [20|10:1|11|19:12]."""
    val b20 = (inst >> 31) & 1
    val b10_1 = (inst >> 21) & 0x3FF
    val b11 = (inst >> 20) & 1
    val b19_12 = (inst >> 12) & 0xFF
    val raw = (b20 << 20) | (b19_12 << 12) | (b11 << 11) | (b10_1 << 1)
    sign_extend(raw, 21)

# ============================================================================
# RISC-V Base Opcode Constants
# ============================================================================

val OP_LUI: i64     = 0x37
val OP_AUIPC: i64   = 0x17
val OP_JAL: i64     = 0x6F
val OP_JALR: i64    = 0x67
val OP_BRANCH: i64  = 0x63
val OP_LOAD: i64    = 0x03
val OP_STORE: i64   = 0x23
val OP_OP_IMM: i64  = 0x13
val OP_OP: i64      = 0x33
val OP_OP_IMM_32: i64 = 0x1B  # RV64I: W-suffix immediate ops
val OP_OP_32: i64     = 0x3B  # RV64I: W-suffix register ops

# ============================================================================
# Decoder
# ============================================================================

struct Rv64Decoder:
    """Stateless instruction decoder for RV64I.

    Decodes a 32-bit instruction word and produces control signals
    plus extracted operand values for the ID/EX latch.
    """
    placeholder: i64

fn create_rv64_decoder() -> Rv64Decoder:
    Rv64Decoder(placeholder: 0)

impl Rv64Decoder:
    fn decode(inst: i64, pc: i64, rs1_val: i64, rs2_val: i64) -> Rv64IdExLatch:
        """Decode an instruction and produce an ID/EX latch.

        Args:
            inst: 32-bit instruction word.
            pc: PC of this instruction.
            rs1_val: Value read from register file for rs1.
            rs2_val: Value read from register file for rs2.

        Returns:
            Populated ID/EX latch with control signals and operands.
        """
        val opcode = rv64_opcode(inst)
        val rd = rv64_rd(inst)
        val f3 = rv64_funct3(inst)
        val rs1 = rv64_rs1(inst)
        val rs2 = rv64_rs2(inst)
        val f7 = rv64_funct7(inst)

        # Defaults
        var alu_op = Rv64AluOp.Add
        var alu_src_b_imm = false
        var mem_rd = false
        var mem_wr = false
        var mem_to_reg = false
        var reg_wr = false
        var is_branch = false
        var is_jump = false
        var imm: i64 = 0
        var itype = Rv64InstType.Unknown

        if opcode == OP_LUI:
            imm = rv64_imm_u(inst)
            alu_op = Rv64AluOp.PassB
            alu_src_b_imm = true
            reg_wr = true
            itype = Rv64InstType.UType

        else if opcode == OP_AUIPC:
            imm = rv64_imm_u(inst)
            alu_op = Rv64AluOp.Add
            alu_src_b_imm = true
            reg_wr = true
            itype = Rv64InstType.UType

        else if opcode == OP_JAL:
            imm = rv64_imm_j(inst)
            alu_op = Rv64AluOp.Add
            reg_wr = true
            is_jump = true
            itype = Rv64InstType.JType

        else if opcode == OP_JALR:
            imm = rv64_imm_i(inst)
            alu_op = Rv64AluOp.Add
            alu_src_b_imm = true
            reg_wr = true
            is_jump = true
            itype = Rv64InstType.IType

        else if opcode == OP_BRANCH:
            imm = rv64_imm_b(inst)
            is_branch = true
            itype = Rv64InstType.BType

        else if opcode == OP_LOAD:
            imm = rv64_imm_i(inst)
            alu_op = Rv64AluOp.Add
            alu_src_b_imm = true
            mem_rd = true
            mem_to_reg = true
            reg_wr = true
            itype = Rv64InstType.IType

        else if opcode == OP_STORE:
            imm = rv64_imm_s(inst)
            alu_op = Rv64AluOp.Add
            alu_src_b_imm = true
            mem_wr = true
            itype = Rv64InstType.SType

        else if opcode == OP_OP_IMM:
            imm = rv64_imm_i(inst)
            alu_src_b_imm = true
            reg_wr = true
            alu_op = decode_alu_op_imm(f3, f7, inst)
            itype = Rv64InstType.IType

        else if opcode == OP_OP:
            reg_wr = true
            alu_op = decode_alu_op_reg(f3, f7)
            itype = Rv64InstType.RType

        else if opcode == OP_OP_IMM_32:
            # RV64I W-suffix immediate (ADDIW, SLLIW, SRLIW, SRAIW)
            imm = rv64_imm_i(inst)
            alu_src_b_imm = true
            reg_wr = true
            alu_op = decode_alu_op_imm_w(f3, f7, inst)
            itype = Rv64InstType.IType

        else if opcode == OP_OP_32:
            # RV64I W-suffix register (ADDW, SUBW, SLLW, SRLW, SRAW)
            reg_wr = true
            alu_op = decode_alu_op_reg_w(f3, f7)
            itype = Rv64InstType.RType

        Rv64IdExLatch(
            pc: pc,
            rs1_val: rs1_val,
            rs2_val: rs2_val,
            imm: imm,
            rd: rd,
            rs1: rs1,
            rs2: rs2,
            alu_op: alu_op,
            alu_src_b_imm: alu_src_b_imm,
            mem_read: mem_rd,
            mem_write: mem_wr,
            mem_to_reg: mem_to_reg,
            reg_write: reg_wr,
            branch: is_branch,
            jump: is_jump,
            inst_type: itype,
            funct3: f3,
            valid: true
        )

# ============================================================================
# ALU Op Decoders
# ============================================================================

fn decode_alu_op_imm(f3: i64, f7: i64, inst: i64) -> Rv64AluOp:
    """Decode ALU op for OP-IMM instructions."""
    if f3 == 0:
        return Rv64AluOp.Add       # ADDI
    if f3 == 1:
        return Rv64AluOp.Sll       # SLLI
    if f3 == 2:
        return Rv64AluOp.Slt       # SLTI
    if f3 == 3:
        return Rv64AluOp.Sltu      # SLTIU
    if f3 == 4:
        return Rv64AluOp.Xor       # XORI
    if f3 == 5:
        # SRLI vs SRAI: funct7 bit distinguishes
        val shtype = (inst >> 26) & 0x3F
        if shtype == 0x10:
            return Rv64AluOp.Sra   # SRAI
        return Rv64AluOp.Srl       # SRLI
    if f3 == 6:
        return Rv64AluOp.Or        # ORI
    if f3 == 7:
        return Rv64AluOp.And       # ANDI
    Rv64AluOp.Add

fn decode_alu_op_reg(f3: i64, f7: i64) -> Rv64AluOp:
    """Decode ALU op for OP (register-register) instructions."""
    if f3 == 0:
        if f7 == 0x20:
            return Rv64AluOp.Sub   # SUB
        return Rv64AluOp.Add       # ADD
    if f3 == 1:
        return Rv64AluOp.Sll       # SLL
    if f3 == 2:
        return Rv64AluOp.Slt       # SLT
    if f3 == 3:
        return Rv64AluOp.Sltu      # SLTU
    if f3 == 4:
        return Rv64AluOp.Xor       # XOR
    if f3 == 5:
        if f7 == 0x20:
            return Rv64AluOp.Sra   # SRA
        return Rv64AluOp.Srl       # SRL
    if f3 == 6:
        return Rv64AluOp.Or        # OR
    if f3 == 7:
        return Rv64AluOp.And       # AND
    Rv64AluOp.Add

fn decode_alu_op_imm_w(f3: i64, f7: i64, inst: i64) -> Rv64AluOp:
    """Decode ALU op for OP-IMM-32 (W-suffix immediate) instructions."""
    if f3 == 0:
        return Rv64AluOp.Addw      # ADDIW
    if f3 == 1:
        return Rv64AluOp.Sllw      # SLLIW
    if f3 == 5:
        val shtype = (inst >> 25) & 0x7F
        if shtype == 0x20:
            return Rv64AluOp.Sraw  # SRAIW
        return Rv64AluOp.Srlw      # SRLIW
    Rv64AluOp.Addw

fn decode_alu_op_reg_w(f3: i64, f7: i64) -> Rv64AluOp:
    """Decode ALU op for OP-32 (W-suffix register) instructions."""
    if f3 == 0:
        if f7 == 0x20:
            return Rv64AluOp.Subw  # SUBW
        return Rv64AluOp.Addw      # ADDW
    if f3 == 1:
        return Rv64AluOp.Sllw      # SLLW
    if f3 == 5:
        if f7 == 0x20:
            return Rv64AluOp.Sraw  # SRAW
        return Rv64AluOp.Srlw      # SRLW
    Rv64AluOp.Addw

# ============================================================================
# Instruction Encoding Helpers (for tests / program generation)
# ============================================================================

fn encode_rv64_r(f7: i64, rs2: i64, rs1: i64, f3: i64, rd: i64, opcode: i64) -> i64:
    """Encode an R-type instruction."""
    (f7 << 25) | (rs2 << 20) | (rs1 << 15) | (f3 << 12) | (rd << 7) | opcode

fn encode_rv64_i(imm: i64, rs1: i64, f3: i64, rd: i64, opcode: i64) -> i64:
    """Encode an I-type instruction."""
    ((imm & 0xFFF) << 20) | (rs1 << 15) | (f3 << 12) | (rd << 7) | opcode

fn encode_rv64_s(imm: i64, rs2: i64, rs1: i64, f3: i64, opcode: i64) -> i64:
    """Encode an S-type instruction."""
    val hi = (imm >> 5) & 0x7F
    val lo = imm & 0x1F
    (hi << 25) | (rs2 << 20) | (rs1 << 15) | (f3 << 12) | (lo << 7) | opcode

fn encode_rv64_b(imm: i64, rs2: i64, rs1: i64, f3: i64, opcode: i64) -> i64:
    """Encode a B-type instruction."""
    val b12 = (imm >> 12) & 1
    val b10_5 = (imm >> 5) & 0x3F
    val b4_1 = (imm >> 1) & 0xF
    val b11 = (imm >> 11) & 1
    (b12 << 31) | (b10_5 << 25) | (rs2 << 20) | (rs1 << 15) | (f3 << 12) | (b4_1 << 8) | (b11 << 7) | opcode

fn encode_rv64_u(imm: i64, rd: i64, opcode: i64) -> i64:
    """Encode a U-type instruction (LUI/AUIPC). imm is the upper 20 bits."""
    (imm & 0xFFFFF000) | (rd << 7) | opcode

fn encode_rv64_j(imm: i64, rd: i64, opcode: i64) -> i64:
    """Encode a J-type instruction (JAL)."""
    val b20 = (imm >> 20) & 1
    val b10_1 = (imm >> 1) & 0x3FF
    val b11 = (imm >> 11) & 1
    val b19_12 = (imm >> 12) & 0xFF
    (b20 << 31) | (b10_1 << 21) | (b11 << 20) | (b19_12 << 12) | (rd << 7) | opcode

# ============================================================================
# Convenience Encoders for Common Instructions
# ============================================================================

fn encode_addi(rd: i64, rs1: i64, imm: i64) -> i64:
    """ADDI rd, rs1, imm"""
    encode_rv64_i(imm, rs1, 0, rd, OP_OP_IMM)

fn encode_add(rd: i64, rs1: i64, rs2: i64) -> i64:
    """ADD rd, rs1, rs2"""
    encode_rv64_r(0, rs2, rs1, 0, rd, OP_OP)

fn encode_sub(rd: i64, rs1: i64, rs2: i64) -> i64:
    """SUB rd, rs1, rs2"""
    encode_rv64_r(0x20, rs2, rs1, 0, rd, OP_OP)

fn encode_lui(rd: i64, imm: i64) -> i64:
    """LUI rd, imm (imm is upper 20 bits, pre-shifted)"""
    encode_rv64_u(imm, rd, OP_LUI)

fn encode_sw(rs2: i64, rs1: i64, offset: i64) -> i64:
    """SW rs2, offset(rs1)"""
    encode_rv64_s(offset, rs2, rs1, 2, OP_STORE)

fn encode_lw(rd: i64, rs1: i64, offset: i64) -> i64:
    """LW rd, offset(rs1)"""
    encode_rv64_i(offset, rs1, 2, rd, OP_LOAD)

fn encode_sd(rs2: i64, rs1: i64, offset: i64) -> i64:
    """SD rs2, offset(rs1) -- RV64 only, 64-bit store"""
    encode_rv64_s(offset, rs2, rs1, 3, OP_STORE)

fn encode_ld(rd: i64, rs1: i64, offset: i64) -> i64:
    """LD rd, offset(rs1) -- RV64 only, 64-bit load"""
    encode_rv64_i(offset, rs1, 3, rd, OP_LOAD)

fn encode_beq(rs1: i64, rs2: i64, offset: i64) -> i64:
    """BEQ rs1, rs2, offset"""
    encode_rv64_b(offset, rs2, rs1, 0, OP_BRANCH)

fn encode_bne(rs1: i64, rs2: i64, offset: i64) -> i64:
    """BNE rs1, rs2, offset"""
    encode_rv64_b(offset, rs2, rs1, 1, OP_BRANCH)

fn encode_jal(rd: i64, offset: i64) -> i64:
    """JAL rd, offset"""
    encode_rv64_j(offset, rd, OP_JAL)

fn encode_addw(rd: i64, rs1: i64, rs2: i64) -> i64:
    """ADDW rd, rs1, rs2 -- RV64I only"""
    encode_rv64_r(0, rs2, rs1, 0, rd, OP_OP_32)

fn encode_addiw(rd: i64, rs1: i64, imm: i64) -> i64:
    """ADDIW rd, rs1, imm -- RV64I only"""
    encode_rv64_i(imm, rs1, 0, rd, OP_OP_IMM_32)
