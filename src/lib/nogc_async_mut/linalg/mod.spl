use std.ndarray.*
use std.linalg.linalg_core.*
use std.linalg.torch_ndarray.{TorchNDArray}
use std.linalg.simd_ops.{simd_dot_values, simd_dot4_values, simd_dot_f32_values, simd_dot4_f32_values, simd_axpy_values, simd_axpy4_values, simd_axpy_f32_values, simd_axpy4_f32_values}
use std.linalg.backend_ops.{openblas_dot, openblas_dot_values, openblas_axpy, openblas_axpy_values, openblas_gemm, openblas_gemv, openblas_solve, torch_dot, torch_dot_values, torch_gemm, torch_gemv, torch_solve, torch_inv, cuda_dot, cuda_dot_values, cuda_gemm, cuda_gemv, cuda_solve, cuda_inv}

fn dot(left: NDArray, right: NDArray) -> Result<Float64, LinalgError>:
    if left.len() != right.len():
        return Err(LinalgError.DimensionMismatch)
    val backend = _configured_linalg_backend()
    if backend == "openblas":
        match openblas_dot(left, right):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "cuda":
        match cuda_dot(left, right):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "torch" or backend == "pytorch":
        match torch_dot(left, right):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if left.shape.dims.len() == 1 and left.len().value >= 4 and left.is_contiguous() and right.is_contiguous():
        var left_values: [Float64] = []
        var right_values: [Float64] = []
        var i = 0
        while i < left.len().value:
            left_values.push(left.get_f64(Index.new(i)))
            right_values.push(right.get_f64(Index.new(i)))
            i = i + 1
        return simd_dot_values(left_values, right_values)
    var total = 0.0
    var i = 0
    while i < left.len().value:
        total = total + left.get_f64(Index.new(i)).value * right.get_f64(Index.new(i)).value
        i = i + 1
    Ok(Float64.new(total))

fn dot_f32(left: NDArray, right: NDArray) -> Result<Float32, LinalgError>:
    if left.dtype != DType.F32 or right.dtype != DType.F32 or left.len() != right.len():
        return Err(LinalgError.DimensionMismatch)
    if left.shape.dims.len() == 1 and left.len().value >= 4 and left.is_contiguous() and right.is_contiguous():
        var left_values: [Float32] = []
        var right_values: [Float32] = []
        var i = 0
        while i < left.len().value:
            left_values.push(left.get_f32(Index.new(i)))
            right_values.push(right.get_f32(Index.new(i)))
            i = i + 1
        return simd_dot_f32_values(left_values, right_values)
    var total: f32 = 0.0
    var i = 0
    while i < left.len().value:
        total = total + left.flat_f32(i).value * right.flat_f32(i).value
        i = i + 1
    Ok(Float32.new(total))

fn axpy(alpha: Float64, x: NDArray, y: NDArray) -> NDArray:
    try_axpy(alpha, x, y).unwrap()

fn try_axpy(alpha: Float64, x: NDArray, y: NDArray) -> Result<NDArray, LinalgError>:
    if x.shape != y.shape:
        return Err(LinalgError.DimensionMismatch)
    if _configured_linalg_backend() == "openblas":
        match openblas_axpy(alpha, x, y):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if x.shape.dims.len() == 1 and x.len().value >= 4 and x.is_contiguous() and y.is_contiguous():
        var x_values: [Float64] = []
        var y_values: [Float64] = []
        var i = 0
        while i < x.len().value:
            x_values.push(x.get_f64(Index.new(i)))
            y_values.push(y.get_f64(Index.new(i)))
            i = i + 1
        return Ok(vector_from(simd_axpy_values(alpha, x_values, y_values)?))
    Ok(x.mul_scalar(alpha).add(y))

fn axpy_f32(alpha: Float32, x: NDArray, y: NDArray) -> NDArray:
    try_axpy_f32(alpha, x, y).unwrap()

fn try_axpy_f32(alpha: Float32, x: NDArray, y: NDArray) -> Result<NDArray, LinalgError>:
    if x.dtype != DType.F32 or y.dtype != DType.F32 or x.shape != y.shape:
        return Err(LinalgError.DimensionMismatch)
    if x.shape.dims.len() == 1 and x.len().value >= 4 and x.is_contiguous() and y.is_contiguous():
        var x_values: [Float32] = []
        var y_values: [Float32] = []
        var i = 0
        while i < x.len().value:
            x_values.push(x.get_f32(Index.new(i)))
            y_values.push(y.get_f32(Index.new(i)))
            i = i + 1
        return Ok(vector_from_f32(simd_axpy_f32_values(alpha, x_values, y_values)?))
    var out: [Float32] = []
    var i = 0
    while i < x.len().value:
        out.push(Float32.new(alpha.value * x.flat_f32(i).value + y.flat_f32(i).value))
        i = i + 1
    Ok(make_f32_array(out, x.shape))

fn gemv(matrix: NDArray, vector: NDArray) -> Result<NDArray, LinalgError>:
    if matrix.cols() != vector.len():
        return Err(LinalgError.DimensionMismatch)
    val backend = _configured_linalg_backend()
    if backend == "openblas":
        val y_in = zeros(Shape.new([matrix.rows()]))
        match openblas_gemv(Float64.new(1.0), matrix, vector, Float64.new(0.0), y_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "cuda":
        val y_in = zeros(Shape.new([matrix.rows()]))
        match cuda_gemv(Float64.new(1.0), matrix, vector, Float64.new(0.0), y_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "torch" or backend == "pytorch":
        val y_in = zeros(Shape.new([matrix.rows()]))
        match torch_gemv(Float64.new(1.0), matrix, vector, Float64.new(0.0), y_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    var out: [Float64] = []
    var row = 0
    while row < matrix.rows().value:
        var total = 0.0
        var col = 0
        while col < matrix.cols().value:
            total = total + matrix.get_f64_at([Index.new(row), Index.new(col)]).value * vector.get_f64(Index.new(col)).value
            col = col + 1
        out.push(Float64.new(total))
        row = row + 1
    Ok(make_f64_array(out, Shape.new([matrix.rows()])))

fn gemm(alpha: Float64, a: NDArray, b: NDArray, beta: Float64, c_in: NDArray) -> NDArray:
    try_gemm(alpha, a, b, beta, c_in).unwrap()

fn try_gemm(alpha: Float64, a: NDArray, b: NDArray, beta: Float64, c_in: NDArray) -> Result<NDArray, LinalgError>:
    if a.cols() != b.rows():
        return Err(LinalgError.DimensionMismatch)
    if c_in.rows() != a.rows() or c_in.cols() != b.cols():
        return Err(LinalgError.DimensionMismatch)
    val backend = _configured_linalg_backend()
    if backend == "openblas":
        match openblas_gemm(alpha, a, b, beta, c_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "cuda":
        match cuda_gemm(alpha, a, b, beta, c_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if backend == "torch" or backend == "pytorch":
        match torch_gemm(alpha, a, b, beta, c_in):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    val rows = a.rows().value
    val cols = b.cols().value
    val inner = a.cols().value
    var out: [Float64] = []
    var i = 0
    while i < rows * cols:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < rows:
        var j = 0
        while j < cols:
            var total = beta.value * c_in.get_f64_at([Index.new(i), Index.new(j)]).value
            var k = 0
            while k < inner:
                total = total + alpha.value
                    * a.get_f64_at([Index.new(i), Index.new(k)]).value
                    * b.get_f64_at([Index.new(k), Index.new(j)]).value
                k = k + 1
            out[i * cols + j] = Float64.new(total)
            j = j + 1
        i = i + 1
    Ok(make_f64_array(out, Shape.new([a.rows(), b.cols()])))

fn norm(input: NDArray) -> Float64:
    val squared = dot(input, input).unwrap()
    Float64.new(sqrt_f64(squared.value))

fn trace(matrix: NDArray) -> Result<Float64, LinalgError>:
    if matrix.dtype != DType.F64 or matrix.shape.dims.len() != 2:
        return Err(LinalgError.DimensionMismatch)
    var diagonal = matrix.rows().value
    if matrix.cols().value < diagonal:
        diagonal = matrix.cols().value
    var total = 0.0
    var i = 0
    while i < diagonal:
        total = total + matrix.get_f64_at([Index.new(i), Index.new(i)]).value
        i = i + 1
    Ok(Float64.new(total))

fn inv(a: NDArray) -> Result<NDArray, LinalgError>:
    if a.rows() != a.cols():
        return Err(LinalgError.DimensionMismatch)
    val n = a.rows().value
    if _configured_linalg_backend() == "cuda" and n >= 16:
        match cuda_inv(a):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if (_configured_linalg_backend() == "torch" or _configured_linalg_backend() == "pytorch") and n >= 16:
        match torch_inv(a):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    var out: [Float64] = []
    var i = 0
    while i < n * n:
        out.push(Float64.new(0.0))
        i = i + 1
    var col = 0
    while col < n:
        var rhs: [Float64] = []
        var row = 0
        while row < n:
            if row == col:
                rhs.push(Float64.new(1.0))
            else:
                rhs.push(Float64.new(0.0))
            row = row + 1
        val solution = solve(a, make_f64_array(rhs, Shape.new([Index.new(n)])))?
        row = 0
        while row < n:
            out[row * n + col] = solution.get_f64(Index.new(row))
            row = row + 1
        col = col + 1
    Ok(make_f64_array(out, Shape.new([Index.new(n), Index.new(n)])))

fn det(a: NDArray) -> Result<Float64, LinalgError>:
    val n = a.rows().value
    if a.rows() != a.cols():
        return Err(LinalgError.DimensionMismatch)
    var mat: [f64] = []
    var row = 0
    while row < n:
        var col = 0
        while col < n:
            mat.push(a.get_f64_at([Index.new(row), Index.new(col)]).value)
            col = col + 1
        row = row + 1
    var sign = 1.0
    var product = 1.0
    var pivot = 0
    while pivot < n:
        var pivot_row = pivot
        var max_abs = abs_f64(mat[pivot * n + pivot])
        var probe = pivot + 1
        while probe < n:
            val candidate_abs = abs_f64(mat[probe * n + pivot])
            if candidate_abs > max_abs:
                max_abs = candidate_abs
                pivot_row = probe
            probe = probe + 1
        if max_abs == 0.0:
            return Ok(Float64.new(0.0))
        if pivot_row != pivot:
            var swap_col = 0
            while swap_col < n:
                val pivot_idx = pivot * n + swap_col
                val pivot_row_idx = pivot_row * n + swap_col
                val tmp = mat[pivot_idx]
                mat[pivot_idx] = mat[pivot_row_idx]
                mat[pivot_row_idx] = tmp
                swap_col = swap_col + 1
            sign = -sign
        val pivot_value = mat[pivot * n + pivot]
        product = product * pivot_value
        var lower = pivot + 1
        while lower < n:
            val factor = mat[lower * n + pivot] / pivot_value
            var col = pivot
            while col < n:
                mat[lower * n + col] = mat[lower * n + col] - factor * mat[pivot * n + col]
                col = col + 1
            lower = lower + 1
        pivot = pivot + 1
    Ok(Float64.new(sign * product))

fn solve(a: NDArray, b: NDArray) -> Result<NDArray, LinalgError>:
    val n = a.rows().value
    if a.rows() != a.cols():
        return Err(LinalgError.DimensionMismatch)
    if b.len().value != n:
        return Err(LinalgError.DimensionMismatch)
    if _configured_linalg_backend() == "openblas" and n >= 16:
        match openblas_solve(a, b):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if _configured_linalg_backend() == "cuda" and n >= 16:
        match cuda_solve(a, b):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    if (_configured_linalg_backend() == "torch" or _configured_linalg_backend() == "pytorch") and n >= 16:
        match torch_solve(a, b):
            case Ok(value):
                return Ok(value)
            case Err(_):
                pass
    var mat: [f64] = []
    var rhs: [f64] = []
    var row = 0
    while row < n:
        var col = 0
        while col < n:
            mat.push(a.get_f64_at([Index.new(row), Index.new(col)]).value)
            col = col + 1
        rhs.push(b.get_f64(Index.new(row)).value)
        row = row + 1
    var pivot = 0
    while pivot < n:
        var pivot_row = pivot
        var max_abs = if mat[pivot * n + pivot] < 0.0: -mat[pivot * n + pivot] else: mat[pivot * n + pivot]
        var probe = pivot + 1
        while probe < n:
            val candidate = mat[probe * n + pivot]
            val candidate_abs = if candidate < 0.0: -candidate else: candidate
            if candidate_abs > max_abs:
                max_abs = candidate_abs
                pivot_row = probe
            probe = probe + 1
        if max_abs == 0.0:
            return Err(LinalgError.Singular)
        if pivot_row != pivot:
            var swap_col = 0
            while swap_col < n:
                val pivot_idx = pivot * n + swap_col
                val pivot_row_idx = pivot_row * n + swap_col
                val tmp = mat[pivot_idx]
                mat[pivot_idx] = mat[pivot_row_idx]
                mat[pivot_row_idx] = tmp
                swap_col = swap_col + 1
            val rhs_tmp = rhs[pivot]
            rhs[pivot] = rhs[pivot_row]
            rhs[pivot_row] = rhs_tmp
        var lower = pivot + 1
        while lower < n:
            val factor = mat[lower * n + pivot] / mat[pivot * n + pivot]
            var col = pivot
            while col < n:
                mat[lower * n + col] = mat[lower * n + col] - factor * mat[pivot * n + col]
                col = col + 1
            rhs[lower] = rhs[lower] - factor * rhs[pivot]
            lower = lower + 1
        pivot = pivot + 1
    var x: [f64] = []
    var i = 0
    while i < n:
        x.push(0.0)
        i = i + 1
    i = n - 1
    while i >= 0:
        var total = rhs[i]
        var col = i + 1
        while col < n:
            total = total - mat[i * n + col] * x[col]
            col = col + 1
        val diag = mat[i * n + i]
        if diag == 0.0:
            return Err(LinalgError.Singular)
        x[i] = total / diag
        i = i - 1
    var out: [Float64] = []
    i = 0
    while i < n:
        var value = x[i]
        val nearest_i = if value >= 0.0: (value + 0.5) as i64 else: (value - 0.5) as i64
        val nearest = nearest_i as f64
        var diff = value - nearest
        if diff < 0.0:
            diff = -diff
        if diff <= 1e-9:
            value = nearest
        out.push(Float64.new(value))
        i = i + 1
    Ok(make_f64_array(out, Shape.new([Index.new(n)])))
