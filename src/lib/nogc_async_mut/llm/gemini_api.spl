@allow(unnamed_duplicate_typed_args)
# LLM Caret - Gemini API (Google Generative Language API)
#
# Builds HTTP requests for the Google Gemini API.
# Pure functions for request/response JSON building/parsing.

extern fn rt_http_request(method: text, url: text, headers: text, body: text) -> (i64, text, text)

use common.text.{escape_json}
use std.nogc_async_mut.mcp.helpers.{Q, LB, RB}
use std.nogc_async_mut.llm.json_helpers.{_unwrap_idx, extract_json_string, extract_json_value, extract_json_int}

# ============================================================================
# Response struct
# ============================================================================

struct GeminiApiResponse:
    content: text
    model: text
    finish_reason: text
    prompt_tokens: i64
    candidates_tokens: i64
    error: text
    is_error: bool
    raw: text

# ============================================================================
# Pure Function: build Gemini contents array from role/content pairs
# ============================================================================

fn build_gemini_messages_json(roles: [text], contents: [text]) -> text:
    var items: [text] = []
    var i = 0
    while i < roles.len():
        var role = roles[i]
        if role == "assistant":
            role = "model"
        var msg_parts = []
        msg_parts.append(LB())
        msg_parts.append(Q() + "role" + Q() + ":" + Q() + role + Q() + ",")
        msg_parts.append(Q() + "parts" + Q() + ":[" + LB() + Q() + "text" + Q() + ":" + Q() + escape_json(contents[i]) + Q() + RB() + "]")
        msg_parts.append(RB())
        items = items + [msg_parts.join("")]
        i = i + 1
    var parts = []
    parts.append("[")
    var j = 0
    for item in items:
        if j > 0:
            parts.append(",")
        parts.append(item)
        j = j + 1
    parts.append("]")
    parts.join("")

# ============================================================================
# Pure Function: build request body JSON
# ============================================================================

fn build_gemini_api_body(messages_json: text, system_prompt: text, max_tokens: i64) -> text:
    var parts: [text] = []
    # Contents (messages in Gemini format)
    parts = parts + [Q() + "contents" + Q() + ":" + messages_json]
    # System instruction
    if system_prompt != "":
        parts = parts + [Q() + "systemInstruction" + Q() + ":" + LB() + Q() + "parts" + Q() + ":[" + LB() + Q() + "text" + Q() + ":" + Q() + escape_json(system_prompt) + Q() + RB() + "]" + RB()]
    # Generation config
    var tokens = max_tokens
    if tokens <= 0:
        tokens = 4096
    parts = parts + [Q() + "generationConfig" + Q() + ":" + LB() + Q() + "maxOutputTokens" + Q() + ":" + tokens.to_text() + RB()]
    # Join parts
    var body_parts = []
    body_parts.append(LB())
    var i = 0
    for part in parts:
        if i > 0:
            body_parts.append(",")
        body_parts.append(part)
        i = i + 1
    body_parts.append(RB())
    body_parts.join("")

# ============================================================================
# Pure Function: parse response JSON
# ============================================================================

fn parse_gemini_api_response(raw: text) -> GeminiApiResponse:
    if raw.trim() == "":
        return GeminiApiResponse(
            content: "",
            model: "",
            finish_reason: "",
            prompt_tokens: 0,
            candidates_tokens: 0,
            error: "empty response",
            is_error: true,
            raw: ""
        )
    # Check for error response
    val error_msg = extract_json_string(raw, "message")
    val error_status = extract_json_string(raw, "status")
    if error_status != "":
        return GeminiApiResponse(
            content: "",
            model: "",
            finish_reason: "error",
            prompt_tokens: 0,
            candidates_tokens: 0,
            error: error_msg,
            is_error: true,
            raw: raw
        )
    # Extract content from candidates[0].content.parts[0].text
    val content_text = extract_json_string(raw, "text")
    val finish = extract_json_string(raw, "finishReason")
    val prompt_tok = extract_json_int(raw, "promptTokenCount")
    val cand_tok = extract_json_int(raw, "candidatesTokenCount")
    var final_finish = finish
    if final_finish == "":
        final_finish = "STOP"
    GeminiApiResponse(
        content: content_text,
        model: "",
        finish_reason: final_finish,
        prompt_tokens: prompt_tok,
        candidates_tokens: cand_tok,
        error: "",
        is_error: false,
        raw: raw
    )

# ============================================================================
# Impure Function: send request
# ============================================================================

fn gemini_api_send(api_key: text, base_url: text, model: text, messages_json: text, system_prompt: text, max_tokens: i64) -> GeminiApiResponse:
    if api_key == "":
        return GeminiApiResponse(
            content: "",
            model: "",
            finish_reason: "error",
            prompt_tokens: 0,
            candidates_tokens: 0,
            error: "GEMINI_API_KEY not set",
            is_error: true,
            raw: ""
        )
    var base = base_url
    if base == "":
        base = "https://generativelanguage.googleapis.com"
    var model_val = model
    if model_val == "":
        model_val = "gemini-2.5-flash"
    val url = base + "/v1beta/models/" + model_val + ":generateContent?key=" + api_key
    val headers = "Content-Type: application/json"
    val body = build_gemini_api_body(messages_json, system_prompt, max_tokens)
    val result = rt_http_request("POST", url, headers, body)
    val status_code = result.0
    val resp_body = result.1 ?? ""
    val http_error = result.2 ?? ""
    if http_error != "":
        return GeminiApiResponse(
            content: "",
            model: model_val,
            finish_reason: "error",
            prompt_tokens: 0,
            candidates_tokens: 0,
            error: "HTTP error: " + http_error,
            is_error: true,
            raw: resp_body
        )
    parse_gemini_api_response(resp_body)
