# Window Manager Service — MDSOC+ capsule surface for WM port + window lifecycle (M2, REQ-5).
#
# wm_port_open   — open a connection port to the WM service
# wm_window_create — create a window record on an open port
#
# In interpreter mode these operate against in-process state arrays.
#
# @cover wm_service

# ============================================================================
# Handle types
# ============================================================================

struct WmPort:
    """Opaque WM connection port handle."""
    is_valid: bool
    id:       i64

struct WmWindow:
    """Opaque window handle."""
    is_valid: bool
    id:       i64

# ============================================================================
# Storage
# ============================================================================

var _wm_port_ctr:   i64    = 0
var _wm_window_ctr: i64    = 0
var _wm_port_ids:   [i64]  = []
var _wm_port_alive: [bool] = []
var _wm_win_ids:    [i64]  = []
var _wm_win_titles: [text] = []
var _wm_win_alive:  [bool] = []

# ============================================================================
# Public API
# ============================================================================

pub fn wm_port_open() -> WmPort:
    """Open a connection port to the WM service.

    Returns:
        WmPort with is_valid=true and a positive id.
    """
    _wm_port_ctr = _wm_port_ctr + 1
    val id = _wm_port_ctr
    _wm_port_ids.push(id)
    _wm_port_alive.push(true)
    WmPort(is_valid: true, id: id)

pub fn wm_window_create(port: WmPort, title: text, width: i64, height: i64) -> WmWindow:
    """Create a new window on the given WM port.

    Args:
        port:   Open WM port from wm_port_open()
        title:  Window title string
        width:  Width in pixels
        height: Height in pixels

    Returns:
        WmWindow with is_valid=true on success, is_valid=false if port is invalid.
    """
    if not port.is_valid:
        return WmWindow(is_valid: false, id: 0)
    _wm_window_ctr = _wm_window_ctr + 1
    val id = _wm_window_ctr
    _wm_win_ids.push(id)
    _wm_win_titles.push(title)
    _wm_win_alive.push(true)
    WmWindow(is_valid: true, id: id)

pub fn wm_port_close(port: WmPort) -> bool:
    """Close a WM port.

    Returns:
        true if the port was valid and closed.
    """
    val n = _wm_port_ids.len()
    var i: i64 = 0
    while i < n:
        if _wm_port_alive[i] and _wm_port_ids[i] == port.id:
            _wm_port_alive[i] = false
            return true
        i = i + 1
    false
