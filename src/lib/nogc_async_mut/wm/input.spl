"""WM Input Protocol — keyboard/mouse/scroll event FIFO queue per window."""

class WmKeyEvent:
    window_id: u64
    key_code: i32
    scan_code: i32
    modifiers: i32
    pressed: bool

class WmMouseEvent:
    window_id: u64
    x: i32
    y: i32
    button: i32
    pressed: bool

class WmScrollEvent:
    window_id: u64
    delta_x: i32
    delta_y: i32

class WmInputEntry:
    kind: text
    window_id: u64
    key_code: i32
    scan_code: i32
    modifiers: i32
    pressed: bool
    mouse_x: i32
    mouse_y: i32
    button: i32
    delta_x: i32
    delta_y: i32

class WmInputQueue:
    entries: [WmInputEntry]

class WmInputPoll:
    ok: bool
    state: text
    queue: WmInputQueue
    entry: WmInputEntry

fn _empty_entry() -> WmInputEntry:
    WmInputEntry(kind: "", window_id: 0, key_code: 0, scan_code: 0, modifiers: 0, pressed: false, mouse_x: 0, mouse_y: 0, button: 0, delta_x: 0, delta_y: 0)

pub fn wm_input_queue_new() -> WmInputQueue:
    WmInputQueue(entries: [])

pub fn wm_input_queue_len(queue: WmInputQueue) -> i64:
    queue.entries.len()

pub fn wm_input_push_key(queue: WmInputQueue, event: WmKeyEvent) -> WmInputQueue:
    val entry = WmInputEntry(kind: "key", window_id: event.window_id, key_code: event.key_code, scan_code: event.scan_code, modifiers: event.modifiers, pressed: event.pressed, mouse_x: 0, mouse_y: 0, button: 0, delta_x: 0, delta_y: 0)
    var entries = queue.entries
    entries.push(entry)
    WmInputQueue(entries: entries)

pub fn wm_input_push_mouse(queue: WmInputQueue, event: WmMouseEvent) -> WmInputQueue:
    val entry = WmInputEntry(kind: "mouse", window_id: event.window_id, key_code: 0, scan_code: 0, modifiers: 0, pressed: event.pressed, mouse_x: event.x, mouse_y: event.y, button: event.button, delta_x: 0, delta_y: 0)
    var entries = queue.entries
    entries.push(entry)
    WmInputQueue(entries: entries)

pub fn wm_input_push_scroll(queue: WmInputQueue, event: WmScrollEvent) -> WmInputQueue:
    val entry = WmInputEntry(kind: "scroll", window_id: event.window_id, key_code: 0, scan_code: 0, modifiers: 0, pressed: false, mouse_x: 0, mouse_y: 0, button: 0, delta_x: event.delta_x, delta_y: event.delta_y)
    var entries = queue.entries
    entries.push(entry)
    WmInputQueue(entries: entries)

pub fn wm_input_poll(queue: WmInputQueue) -> WmInputPoll:
    if queue.entries.len() == 0:
        return WmInputPoll(ok: false, state: "queue-empty", queue: queue, entry: _empty_entry())
    val entry = queue.entries[0]
    var rest: [WmInputEntry] = []
    var i = 1
    while i < queue.entries.len():
        rest.push(queue.entries[i])
        i = i + 1
    WmInputPoll(ok: true, state: "event", queue: WmInputQueue(entries: rest), entry: entry)
