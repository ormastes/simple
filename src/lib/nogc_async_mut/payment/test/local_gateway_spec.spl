use std.spec
use std.io_runtime

enum PaymentStatus:
    Created
    Authorized
    Captured
    Settled
    Refunded
    Voided
    Failed

enum TxnState:
    TxnAuthorized
    TxnCaptured
    TxnSettled
    TxnRefunded
    TxnVoided
    TxnFailed

struct Amount:
    cents: int
    currency: text

struct PaymentResult:
    success: bool
    status: PaymentStatus
    transaction_id: text
    error_message: text

struct AuthorizeRequest:
    token: text
    amount: Amount
    merchant_ref: text
    idempotency_key: text

struct CaptureRequest:
    transaction_id: text
    amount: Amount

struct RefundRequest:
    transaction_id: text
    amount: Amount
    reason: text

struct VoidRequest:
    transaction_id: text
    reason: text

struct ChargeRequest:
    token: text
    amount: Amount
    merchant_ref: text
    idempotency_key: text

struct TokenizeRequest:
    card_number: text
    expiry_month: int
    expiry_year: int
    cardholder_name: text

struct TokenizeResult:
    success: bool
    token: text
    error_message: text

enum CardBrand:
    Visa
    Mastercard
    Amex
    Discover
    JCB
    UnionPay
    Unknown

fn _char_to_digit(ch: text) -> int:
    if ch == "0": return 0 as int
    if ch == "1": return 1 as int
    if ch == "2": return 2 as int
    if ch == "3": return 3 as int
    if ch == "4": return 4 as int
    if ch == "5": return 5 as int
    if ch == "6": return 6 as int
    if ch == "7": return 7 as int
    if ch == "8": return 8 as int
    if ch == "9": return 9 as int
    return -1 as int

fn _text_to_int(s: text) -> int:
    var result: int = 0 as int
    var i: int = 0 as int
    while i < s.length():
        val d = _char_to_digit(s.char_at(i))
        if d < 0: return 0 as int
        result = result * 10 + d
        i = i + 1
    return result

fn _int_to_text(n: int) -> text:
    if n == 0: return "0"
    var result = ""
    var v = n
    while v > 0:
        val digit = v % 10
        val ch = if digit == 0: "0" else if digit == 1: "1" else if digit == 2: "2" else if digit == 3: "3" else if digit == 4: "4" else if digit == 5: "5" else if digit == 6: "6" else if digit == 7: "7" else if digit == 8: "8" else: "9"
        result = ch + result
        v = v / 10
    return result

fn luhn_check(card_number: text) -> bool:
    if card_number == "": return false
    var sum = 0
    var double_next = false
    var i = card_number.length() - 1
    while i >= 0:
        val ch = card_number.char_at(i)
        val digit = _char_to_digit(ch)
        if digit < 0: return false
        if double_next:
            var doubled = digit * 2
            if doubled > 9: doubled = doubled - 9
            sum = sum + doubled
        else:
            sum = sum + digit
        double_next = !double_next
        i = i - 1
    return sum > 0 and sum % 10 == 0

fn validate_expiry(month: int, year: int) -> bool:
    if month < 1 or month > 12: return false
    if year < 2025: return false
    return true

fn extract_last4(card_number: text) -> text:
    val len = card_number.length()
    if len <= 4: return card_number
    return card_number.substring(len - 4, len)

fn detect_brand(card_number: text) -> CardBrand:
    if card_number.length() < 4: return CardBrand.Unknown
    val d1 = card_number.substring(0, 1)
    if d1 == "4": return CardBrand.Visa
    val d2 = card_number.substring(0, 2)
    if d2 == "34" or d2 == "37": return CardBrand.Amex
    val mc2 = _text_to_int(d2)
    if mc2 >= 51 and mc2 <= 55: return CardBrand.Mastercard
    return CardBrand.Unknown

struct Transaction:
    id: text
    token: text
    amount_cents: int
    currency: text
    merchant_ref: text
    state: TxnState
    refunded_cents: int
    error_code: text

struct LocalGateway:
    ledger: list<Transaction>
    idempotency_keys: list<text>
    idempotency_txns: list<text>
    next_seq: int

fn new_local_gateway() -> LocalGateway:
    return LocalGateway { ledger: [], idempotency_keys: [], idempotency_txns: [], next_seq: 1000 }

fn _local_gen_id(gw: LocalGateway) -> text:
    return "txn_local_" + _int_to_text(gw.next_seq)

fn _test_card_behavior(token: text) -> text:
    if token == "tok_visa_declined" or token == "tok_local_0002":
        return "card_declined"
    if token == "tok_visa_insufficient" or token == "tok_local_9995":
        return "insufficient_funds"
    if token == "tok_visa_expired" or token == "tok_local_0069":
        return "expired_card"
    if token == "tok_visa_cvc_fail":
        return "incorrect_cvc"
    return "ok"

fn local_authorize(gw: LocalGateway, req: AuthorizeRequest) -> PaymentResult:
    if req.token == "":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "empty token" }
    if req.amount.cents <= 0:
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "amount must be positive" }
    val card_check = _test_card_behavior(req.token)
    if card_check != "ok":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: card_check }
    val txn_id = _local_gen_id(gw)
    return PaymentResult { success: true, status: PaymentStatus.Authorized, transaction_id: txn_id, error_message: "" }

fn local_charge(gw: LocalGateway, req: ChargeRequest) -> PaymentResult:
    if req.token == "":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "empty token" }
    if req.amount.cents <= 0:
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "amount must be positive" }
    val card_check = _test_card_behavior(req.token)
    if card_check != "ok":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: card_check }
    val txn_id = _local_gen_id(gw)
    return PaymentResult { success: true, status: PaymentStatus.Captured, transaction_id: txn_id, error_message: "" }

fn local_refund(gw: LocalGateway, req: RefundRequest) -> PaymentResult:
    if req.transaction_id == "":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "missing transaction_id" }
    if req.amount.cents <= 0:
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "refund amount must be positive" }
    return PaymentResult { success: true, status: PaymentStatus.Refunded, transaction_id: req.transaction_id, error_message: "" }

fn local_void(gw: LocalGateway, req: VoidRequest) -> PaymentResult:
    if req.transaction_id == "":
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: "missing transaction_id" }
    return PaymentResult { success: true, status: PaymentStatus.Voided, transaction_id: req.transaction_id, error_message: "" }

fn local_tokenize(gw: LocalGateway, req: TokenizeRequest) -> TokenizeResult:
    if req.card_number == "":
        return TokenizeResult { success: false, token: "", error_message: "empty card number" }
    if !luhn_check(req.card_number):
        return TokenizeResult { success: false, token: "", error_message: "invalid card number (Luhn check failed)" }
    if !validate_expiry(req.expiry_month, req.expiry_year):
        return TokenizeResult { success: false, token: "", error_message: "card expired" }
    val last4 = extract_last4(req.card_number)
    val tok = "tok_local_" + last4 + "_" + _int_to_text(gw.next_seq)
    return TokenizeResult { success: true, token: tok, error_message: "" }

describe "LocalGateway — self-contained payment processor":

    describe "authorize":
        it "authorizes valid token and amount":
            val gw = new_local_gateway()
            val req = AuthorizeRequest { token: "tok_local_1111_1000", amount: Amount { cents: 5000, currency: "USD" }, merchant_ref: "order-1", idempotency_key: "idem-1" }
            val result = local_authorize(gw, req)
            expect result.success == true
            expect result.status == PaymentStatus.Authorized
            expect result.transaction_id != ""

        it "rejects empty token":
            val gw = new_local_gateway()
            val req = AuthorizeRequest { token: "", amount: Amount { cents: 1000, currency: "USD" }, merchant_ref: "x", idempotency_key: "x" }
            val result = local_authorize(gw, req)
            expect result.success == false

        it "rejects zero amount":
            val gw = new_local_gateway()
            val req = AuthorizeRequest { token: "tok_valid", amount: Amount { cents: 0, currency: "USD" }, merchant_ref: "x", idempotency_key: "x" }
            val result = local_authorize(gw, req)
            expect result.success == false

    describe "test card decline simulation":
        it "declines tok_visa_declined":
            val gw = new_local_gateway()
            val req = AuthorizeRequest { token: "tok_visa_declined", amount: Amount { cents: 1000, currency: "USD" }, merchant_ref: "decline-test", idempotency_key: "dec-1" }
            val result = local_authorize(gw, req)
            expect result.success == false
            expect result.error_message == "card_declined"

        it "returns insufficient_funds for test token":
            val gw = new_local_gateway()
            val req = ChargeRequest { token: "tok_visa_insufficient", amount: Amount { cents: 1000, currency: "USD" }, merchant_ref: "insuf-test", idempotency_key: "insuf-1" }
            val result = local_charge(gw, req)
            expect result.success == false
            expect result.error_message == "insufficient_funds"

        it "returns expired_card for test token":
            val gw = new_local_gateway()
            val req = ChargeRequest { token: "tok_visa_expired", amount: Amount { cents: 1000, currency: "USD" }, merchant_ref: "exp-test", idempotency_key: "exp-1" }
            val result = local_charge(gw, req)
            expect result.success == false
            expect result.error_message == "expired_card"

    describe "charge (authorize + capture)":
        it "charges valid token":
            val gw = new_local_gateway()
            val req = ChargeRequest { token: "tok_local_1111_1000", amount: Amount { cents: 2500, currency: "EUR" }, merchant_ref: "order-2", idempotency_key: "idem-2" }
            val result = local_charge(gw, req)
            expect result.success == true
            expect result.status == PaymentStatus.Captured

    describe "refund":
        it "refunds with valid transaction":
            val gw = new_local_gateway()
            val req = RefundRequest { transaction_id: "txn_local_1000", amount: Amount { cents: 500, currency: "USD" }, reason: "customer request" }
            val result = local_refund(gw, req)
            expect result.success == true
            expect result.status == PaymentStatus.Refunded

        it "rejects refund with zero amount":
            val gw = new_local_gateway()
            val req = RefundRequest { transaction_id: "txn_local_1000", amount: Amount { cents: 0, currency: "USD" }, reason: "test" }
            val result = local_refund(gw, req)
            expect result.success == false

    describe "void":
        it "voids an authorized transaction":
            val gw = new_local_gateway()
            val req = VoidRequest { transaction_id: "txn_local_1000", reason: "order canceled" }
            val result = local_void(gw, req)
            expect result.success == true
            expect result.status == PaymentStatus.Voided

    describe "tokenize":
        it "tokenizes valid Visa card":
            val gw = new_local_gateway()
            val req = TokenizeRequest { card_number: "4111111111111111", expiry_month: 12, expiry_year: 2028, cardholder_name: "Test User" }
            val result = local_tokenize(gw, req)
            expect result.success == true
            expect result.token != ""

        it "rejects invalid card number":
            val gw = new_local_gateway()
            val req = TokenizeRequest { card_number: "1234567890123456", expiry_month: 12, expiry_year: 2028, cardholder_name: "Bad Card" }
            val result = local_tokenize(gw, req)
            expect result.success == false

        it "rejects expired card":
            val gw = new_local_gateway()
            val req = TokenizeRequest { card_number: "4111111111111111", expiry_month: 1, expiry_year: 2020, cardholder_name: "Expired" }
            val result = local_tokenize(gw, req)
            expect result.success == false

    describe "connector registry with local + btcpay":
        it "registers multiple connectors and routes by priority":
            var entries = []
            entries.push("local")
            entries.push("btcpay")
            entries.push("stripe")
            expect entries.length() == 3
