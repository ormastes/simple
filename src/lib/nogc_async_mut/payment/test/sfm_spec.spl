use std.spec
use std.io_runtime

describe "SFM manifest — payment module packaging":

    describe "manifest structure":
        it "has Trusted security level":
            val manifest = payment_sfm_manifest()
            expect manifest.security_level == SfmSecurityLevel.Trusted

        it "has correct module name":
            val manifest = payment_sfm_manifest()
            expect manifest.name == "simple-payment"

        it "has version 0.1.0":
            val manifest = payment_sfm_manifest()
            expect manifest.version == "0.1.0"

    describe "layers":
        it "exposes 4 layers (gateway, vault, cli, agent)":
            val manifest = payment_sfm_manifest()
            expect manifest.layers.length() == 4

        it "gateway layer is privileged back-service":
            val manifest = payment_sfm_manifest()
            val gw = manifest.layers[0]
            expect gw.role == "gateway"
            expect gw.kind == LayerKind.BackService
            expect gw.privileged == true

        it "vault layer is privileged back-service":
            val manifest = payment_sfm_manifest()
            val v = manifest.layers[1]
            expect v.role == "vault"
            expect v.kind == LayerKind.BackService
            expect v.privileged == true

        it "cli layer is non-privileged front-cli":
            val manifest = payment_sfm_manifest()
            val cli = manifest.layers[2]
            expect cli.role == "cli"
            expect cli.kind == LayerKind.FrontCli
            expect cli.privileged == false

        it "agent layer is non-privileged front-agent":
            val manifest = payment_sfm_manifest()
            val ag = manifest.layers[3]
            expect ag.role == "agent"
            expect ag.kind == LayerKind.FrontAgent
            expect ag.privileged == false

    describe "authz gate":
        it "privileged layers require PaymentAuthz capability":
            val manifest = payment_sfm_manifest()
            # TODO(M4): verify authz gate enforcement on gateway + vault layers
            # direct access without capability must be denied
            expect manifest.security_level == SfmSecurityLevel.Trusted
