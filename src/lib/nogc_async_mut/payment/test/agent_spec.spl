use std.spec
use std.io_runtime

struct PaymentToolRequest:
    action: text
    token: text
    amount_cents: int
    currency: text

struct PaymentToolResponse:
    success: bool
    message: text
    transaction_id: text

fn _char_to_digit(ch: text) -> int:
    if ch == "0": return 0 as int
    if ch == "1": return 1 as int
    if ch == "2": return 2 as int
    if ch == "3": return 3 as int
    if ch == "4": return 4 as int
    if ch == "5": return 5 as int
    if ch == "6": return 6 as int
    if ch == "7": return 7 as int
    if ch == "8": return 8 as int
    if ch == "9": return 9 as int
    return -1 as int

fn _looks_like_card_number(s: text) -> bool:
    val len = s.length()
    if len < 13 or len > 19: return false
    var i = 0
    while i < len:
        val d = _char_to_digit(s.char_at(i))
        if d < 0: return false
        i = i + 1
    return true

fn _looks_like_cvv(s: text) -> bool:
    val len = s.length()
    if len < 3 or len > 4: return false
    var i = 0
    while i < len:
        val d = _char_to_digit(s.char_at(i))
        if d < 0: return false
        i = i + 1
    return true

fn validate_agent_request(req: PaymentToolRequest) -> bool:
    if req.action == "list": return true
    if req.token == "": return false
    if _looks_like_card_number(req.token): return false
    if _looks_like_cvv(req.token): return false
    if req.token.length() < 5: return false
    return true

fn handle_payment_tool(req: PaymentToolRequest) -> PaymentToolResponse:
    if !validate_agent_request(req):
        return PaymentToolResponse { success: false, message: "invalid request: token must be an opaque vault token", transaction_id: "" }
    if req.action == "charge":
        return PaymentToolResponse { success: true, message: "charged", transaction_id: "txn_agent_1" }
    if req.action == "refund":
        return PaymentToolResponse { success: true, message: "refunded", transaction_id: req.token }
    if req.action == "list":
        return PaymentToolResponse { success: true, message: "no payment methods stored", transaction_id: "" }
    if req.action == "status":
        return PaymentToolResponse { success: true, message: "status", transaction_id: req.token }
    return PaymentToolResponse { success: false, message: "unknown action", transaction_id: "" }

fn list_payment_methods_for_agent() -> list<text>:
    return []

describe "Agent payment tool — LLM-safe interface":

    describe "validate_agent_request":
        it "rejects request with raw card number in token field":
            val req = PaymentToolRequest { action: "charge", token: "4111111111111111", amount_cents: 1000, currency: "USD" }
            expect validate_agent_request(req) == false

        it "accepts request with opaque vault token":
            val req = PaymentToolRequest { action: "charge", token: "tok_abc123def456", amount_cents: 1000, currency: "USD" }
            expect validate_agent_request(req) == true

        it "rejects empty token":
            val req = PaymentToolRequest { action: "charge", token: "", amount_cents: 1000, currency: "USD" }
            expect validate_agent_request(req) == false

        it "rejects request with CVV-like data":
            val req = PaymentToolRequest { action: "charge", token: "123", amount_cents: 1000, currency: "USD" }
            expect validate_agent_request(req) == false

    describe "handle_payment_tool":
        it "charges with valid opaque token":
            val req = PaymentToolRequest { action: "charge", token: "tok_test_123", amount_cents: 2000, currency: "USD" }
            val result = handle_payment_tool(req)
            expect result.success == true

        it "refunds with valid token":
            val req = PaymentToolRequest { action: "refund", token: "tok_test_123", amount_cents: 500, currency: "USD" }
            val result = handle_payment_tool(req)
            expect result.success == true

    describe "list_payment_methods_for_agent":
        it "returns empty list when no methods stored":
            val methods = list_payment_methods_for_agent()
            expect methods.length() == 0

    describe "security guardrails":
        it "agent never receives raw PAN in any response":
            val req = PaymentToolRequest { action: "list", token: "", amount_cents: 0, currency: "" }
            val result = handle_payment_tool(req)
            expect result.message.contains("4111") == false
            expect result.message.contains("5500") == false
