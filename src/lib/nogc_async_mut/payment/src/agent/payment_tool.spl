use std.io_runtime

struct PaymentToolRequest:
    action: text
    token: text
    amount_cents: int
    currency: text

struct PaymentToolResponse:
    success: bool
    message: text
    transaction_id: text

fn handle_payment_tool(req: PaymentToolRequest) -> PaymentToolResponse:
    if !validate_agent_request(req):
        return PaymentToolResponse { success: false, message: "invalid request: token must be an opaque vault token", transaction_id: "" }
    if req.action == "charge":
        return _agent_charge(req)
    if req.action == "refund":
        return _agent_refund(req)
    if req.action == "list":
        return _agent_list()
    if req.action == "status":
        return _agent_status(req)
    return PaymentToolResponse { success: false, message: "unknown action: " + req.action, transaction_id: "" }

fn validate_agent_request(req: PaymentToolRequest) -> bool:
    if req.action == "list":
        return true
    if req.token == "":
        return false
    if _looks_like_card_number(req.token):
        return false
    if _looks_like_cvv(req.token):
        return false
    if req.token.length() < 5:
        return false
    return true

fn _looks_like_card_number(s: text) -> bool:
    val len = s.length()
    if len < 13 or len > 19:
        return false
    var all_digits = true
    var i = 0
    while i < len:
        val ch = s.char_at(i)
        val d = _char_to_digit(ch)
        if d < 0:
            all_digits = false
            break
        i = i + 1
    return all_digits

fn _looks_like_cvv(s: text) -> bool:
    val len = s.length()
    if len < 3 or len > 4:
        return false
    var all_digits = true
    var i = 0
    while i < len:
        val ch = s.char_at(i)
        val d = _char_to_digit(ch)
        if d < 0:
            all_digits = false
            break
        i = i + 1
    return all_digits

fn list_payment_methods_for_agent() -> list<text>:
    return []

fn _agent_charge(req: PaymentToolRequest) -> PaymentToolResponse:
    val gw = new_local_gateway()
    val charge_req = ChargeRequest {
        token: req.token,
        amount: Amount { cents: req.amount_cents, currency: req.currency },
        merchant_ref: "agent-charge",
        idempotency_key: "agent-" + req.token
    }
    val result = local_charge(gw, charge_req)
    if result.success:
        return PaymentToolResponse { success: true, message: "charged " + _int_to_text(req.amount_cents) + " cents", transaction_id: result.transaction_id }
    return PaymentToolResponse { success: false, message: result.error_message, transaction_id: "" }

fn _agent_refund(req: PaymentToolRequest) -> PaymentToolResponse:
    val gw = new_local_gateway()
    val refund_req = RefundRequest {
        transaction_id: req.token,
        amount: Amount { cents: req.amount_cents, currency: req.currency },
        reason: "agent-initiated refund"
    }
    val result = local_refund(gw, refund_req)
    if result.success:
        return PaymentToolResponse { success: true, message: "refunded", transaction_id: result.transaction_id }
    return PaymentToolResponse { success: false, message: result.error_message, transaction_id: "" }

fn _agent_list() -> PaymentToolResponse:
    val methods = list_payment_methods_for_agent()
    if methods.length() == 0:
        return PaymentToolResponse { success: true, message: "no payment methods stored", transaction_id: "" }
    return PaymentToolResponse { success: true, message: "found methods", transaction_id: "" }

fn _agent_status(req: PaymentToolRequest) -> PaymentToolResponse:
    return PaymentToolResponse { success: true, message: "status lookup for " + req.token, transaction_id: req.token }
