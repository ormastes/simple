use std.io_runtime

fn cli_add_card() -> text:
    println("Enter card number:")
    val card_number = readline()
    println("Enter expiry month (1-12):")
    val month_str = readline()
    println("Enter expiry year (e.g. 2028):")
    val year_str = readline()
    println("Enter cardholder name:")
    val name = readline()
    val month = _text_to_int(month_str)
    val year = _text_to_int(year_str)
    if !luhn_check(card_number):
        println("ERROR: invalid card number")
        return ""
    if !validate_expiry(month, year):
        println("ERROR: invalid expiry date")
        return ""
    val vault = new_memory_vault()
    val req = StoreRequest {
        card_number: card_number,
        expiry_month: month,
        expiry_year: year,
        cardholder_name: name
    }
    val result = vault.store_token(req)
    if result.success:
        val t = result.token
        println("Card stored: " + t.card_brand + " ****" + t.card_last4 + " token=" + t.token_id)
        return t.token_id
    println("ERROR: " + result.error_message)
    return ""

fn cli_list_cards() -> list<text>:
    val vault = new_memory_vault()
    val tokens = vault.list_tokens()
    if tokens.length() == 0:
        println("No payment methods stored.")
        return []
    var names = []
    var i = 0
    while i < tokens.length():
        val t = tokens[i]
        val display = t.card_brand + " ****" + t.card_last4 + " exp " + _int_to_text(t.expiry_month) + "/" + _int_to_text(t.expiry_year)
        println(display)
        names.push(t.token_id)
        i = i + 1
    return names

fn cli_charge(token_id: text, amount_cents: int, currency: text) -> text:
    val gw = new_mock_gateway()
    val req = ChargeRequest {
        token: token_id,
        amount: Amount { cents: amount_cents, currency: currency },
        merchant_ref: "cli-charge",
        idempotency_key: "cli-" + token_id + "-" + _int_to_text(amount_cents)
    }
    val result = gw.charge(req)
    if result.success:
        println("Charged " + _int_to_text(amount_cents) + " " + currency + " -> txn " + result.transaction_id)
        return result.transaction_id
    println("ERROR: " + result.error_message)
    return ""

fn cli_refund(transaction_id: text, amount_cents: int) -> text:
    val gw = new_mock_gateway()
    val req = RefundRequest {
        transaction_id: transaction_id,
        amount: Amount { cents: amount_cents, currency: "USD" },
        reason: "cli-initiated refund"
    }
    val result = gw.refund(req)
    if result.success:
        println("Refunded " + _int_to_text(amount_cents) + " cents for txn " + transaction_id)
        return result.transaction_id
    println("ERROR: " + result.error_message)
    return ""

fn cli_payment_main(args: list<text>) -> int:
    if args.length() == 0:
        _print_usage()
        return 1
    val cmd = args[0]
    if cmd == "add-card":
        cli_add_card()
        return 0
    if cmd == "list-cards":
        cli_list_cards()
        return 0
    if cmd == "charge":
        if args.length() < 4:
            println("Usage: charge <token> <amount_cents> <currency>")
            return 1
        val token = args[1]
        val cents = _text_to_int(args[2])
        val currency = args[3]
        cli_charge(token, cents, currency)
        return 0
    if cmd == "refund":
        if args.length() < 3:
            println("Usage: refund <transaction_id> <amount_cents>")
            return 1
        val txn_id = args[1]
        val cents = _text_to_int(args[2])
        cli_refund(txn_id, cents)
        return 0
    if cmd == "help":
        _print_usage()
        return 0
    println("Unknown command: " + cmd)
    _print_usage()
    return 1

fn _print_usage():
    println("simple-payment CLI")
    println("")
    println("Commands:")
    println("  add-card               Add a payment card (interactive)")
    println("  list-cards             List stored payment methods")
    println("  charge <tok> <cents> <cur>  Charge a payment method")
    println("  refund <txn> <cents>   Refund a transaction")
    println("  help                   Show this help")
