use std.io_runtime

struct MemoryVault:
    val tokens: list<VaultToken>

fn new_memory_vault() -> MemoryVault:
    return MemoryVault { tokens: [] }

impl Vault for MemoryVault:
    fn store_token(self, req: StoreRequest) -> VaultResult:
        # TODO(M2): tokenize card data, store VaultToken in list, never persist raw PAN
        return VaultResult {
            success: false,
            token: VaultToken {
                token_id: "",
                card_last4: "",
                card_brand: "",
                expiry_month: 0,
                expiry_year: 0,
                created_at: ""
            },
            error_message: "TODO: not implemented"
        }

    fn retrieve(self, token_id: text) -> VaultResult:
        # TODO(M2): look up token by ID, return metadata (never raw PAN)
        return VaultResult {
            success: false,
            token: VaultToken {
                token_id: "",
                card_last4: "",
                card_brand: "",
                expiry_month: 0,
                expiry_year: 0,
                created_at: ""
            },
            error_message: "TODO: not implemented"
        }

    fn delete(self, token_id: text) -> VaultDeleteResult:
        # TODO(M2): remove token from store
        return VaultDeleteResult {
            success: false,
            error_message: "TODO: not implemented"
        }

    fn list_tokens(self) -> list<VaultToken>:
        # TODO(M2): return all stored tokens (metadata only)
        return []
