use std.io_runtime

struct VaultToken:
    token_id: text
    card_last4: text
    card_brand: text
    expiry_month: int
    expiry_year: int
    created_at: text

struct StoreRequest:
    card_number: text
    expiry_month: int
    expiry_year: int
    cardholder_name: text

struct VaultResult:
    success: bool
    token: VaultToken
    error_message: text

struct VaultDeleteResult:
    success: bool
    error_message: text

trait Vault:
    fn store_token(self, req: StoreRequest) -> VaultResult
    fn retrieve(self, token_id: text) -> VaultResult
    fn delete(self, token_id: text) -> VaultDeleteResult
    fn list_tokens(self) -> list<VaultToken>
