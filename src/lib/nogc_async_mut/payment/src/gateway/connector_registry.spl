use std.io_runtime

struct ConnectorEntry:
    val name: text
    val priority: int
    val currencies: list<text>

struct ConnectorRegistry:
    val entries: list<ConnectorEntry>

fn new_connector_registry() -> ConnectorRegistry:
    return ConnectorRegistry { entries: [] }

fn register(self: ConnectorRegistry, name: text, priority: int) -> ConnectorRegistry:
    val entry = ConnectorEntry { name: name, priority: priority, currencies: [] }
    var new_entries = self.entries
    new_entries.push(entry)
    return ConnectorRegistry { entries: new_entries }

fn register_with_currencies(self: ConnectorRegistry, name: text, priority: int, currencies: list<text>) -> ConnectorRegistry:
    val entry = ConnectorEntry { name: name, priority: priority, currencies: currencies }
    var new_entries = self.entries
    new_entries.push(entry)
    return ConnectorRegistry { entries: new_entries }

fn route(self: ConnectorRegistry, amount: Amount) -> text:
    if self.entries.length() == 0:
        return ""
    var best_name = ""
    var best_priority = 999999
    var i = 0
    while i < self.entries.length():
        val entry = self.entries[i]
        val supports = _supports_currency(entry, amount.currency)
        if supports and entry.priority < best_priority:
            best_priority = entry.priority
            best_name = entry.name
        i = i + 1
    if best_name == "":
        var j = 0
        var fallback_priority = 999999
        while j < self.entries.length():
            val e = self.entries[j]
            if e.priority < fallback_priority:
                fallback_priority = e.priority
                best_name = e.name
            j = j + 1
    return best_name

fn list_connectors(self: ConnectorRegistry) -> list<text>:
    var names = []
    var i = 0
    while i < self.entries.length():
        names.push(self.entries[i].name)
        i = i + 1
    return names

fn _supports_currency(entry: ConnectorEntry, currency: text) -> bool:
    if entry.currencies.length() == 0:
        return true
    var i = 0
    while i < entry.currencies.length():
        if entry.currencies[i] == currency:
            return true
        i = i + 1
    return false
