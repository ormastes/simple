use std.io_runtime

struct MockGateway:
    val fail_mode: bool

fn new_mock_gateway() -> MockGateway:
    return MockGateway { fail_mode: false }

fn new_failing_mock_gateway() -> MockGateway:
    return MockGateway { fail_mode: true }

impl Gateway for MockGateway:
