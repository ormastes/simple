use std.io_runtime
use std.json.{json_parse, json_object_get}

# Webhook handler — receives and dispatches payment provider webhooks.
# Refs: Stripe webhook signatures, PayPal webhook verification, BTCPay webhooks.

enum WebhookProvider:
    Stripe
    PayPal
    BTCPay
    Local
    UnknownProvider

enum WebhookEventType:
    PaymentAuthorized
    PaymentCaptured
    PaymentFailed
    PaymentRefunded
    PaymentVoided
    PaymentDisputed
    InvoicePaid
    InvoiceExpired
    UnknownEvent

struct WebhookEvent:
    val provider: WebhookProvider
    val event_type: WebhookEventType
    val transaction_id: text
    val amount_cents: int
    val currency: text
    val raw_payload: text
    val timestamp: text

struct WebhookResult:
    val accepted: bool
    val event: WebhookEvent
    val error_message: text

struct WebhookConfig:
    val stripe_signing_secret: text
    val paypal_webhook_id: text
    val btcpay_secret: text

fn new_webhook_config() -> WebhookConfig:
    return WebhookConfig { stripe_signing_secret: "", paypal_webhook_id: "", btcpay_secret: "" }

fn parse_stripe_webhook(payload: text, signature: text, config: WebhookConfig) -> WebhookResult:
    if config.stripe_signing_secret != "":
        if !_verify_stripe_signature(payload, signature, config.stripe_signing_secret):
            return WebhookResult { accepted: false, event: _empty_event(), error_message: "invalid stripe signature" }
    val parsed = json_parse(payload)
    if parsed == nil:
        return WebhookResult { accepted: false, event: _empty_event(), error_message: "invalid JSON" }
    val event_type_str = json_object_get(parsed, "type")
    val data = json_object_get(parsed, "data")
    val obj = json_object_get(data, "object")
    val pi_id = json_object_get(obj, "id")
    val amount = json_object_get(obj, "amount")
    val currency = json_object_get(obj, "currency")
    val evt_type = _map_stripe_event(event_type_str)
    val amount_int = _text_to_int(amount)
    val event = WebhookEvent {
        provider: WebhookProvider.Stripe,
        event_type: evt_type,
        transaction_id: pi_id,
        amount_cents: amount_int,
        currency: currency,
        raw_payload: payload,
        timestamp: ""
    }
    return WebhookResult { accepted: true, event: event, error_message: "" }

fn parse_paypal_webhook(payload: text, config: WebhookConfig) -> WebhookResult:
    val parsed = json_parse(payload)
    if parsed == nil:
        return WebhookResult { accepted: false, event: _empty_event(), error_message: "invalid JSON" }
    val event_type_str = json_object_get(parsed, "event_type")
    val resource = json_object_get(parsed, "resource")
    val order_id = json_object_get(resource, "id")
    val evt_type = _map_paypal_event(event_type_str)
    val event = WebhookEvent {
        provider: WebhookProvider.PayPal,
        event_type: evt_type,
        transaction_id: order_id,
        amount_cents: 0,
        currency: "",
        raw_payload: payload,
        timestamp: ""
    }
    return WebhookResult { accepted: true, event: event, error_message: "" }

fn parse_btcpay_webhook(payload: text, config: WebhookConfig) -> WebhookResult:
    val parsed = json_parse(payload)
    if parsed == nil:
        return WebhookResult { accepted: false, event: _empty_event(), error_message: "invalid JSON" }
    val event_type_str = json_object_get(parsed, "type")
    val invoice_id = json_object_get(parsed, "invoiceId")
    val evt_type = _map_btcpay_event(event_type_str)
    val event = WebhookEvent {
        provider: WebhookProvider.BTCPay,
        event_type: evt_type,
        transaction_id: invoice_id,
        amount_cents: 0,
        currency: "",
        raw_payload: payload,
        timestamp: ""
    }
    return WebhookResult { accepted: true, event: event, error_message: "" }

fn _verify_stripe_signature(payload: text, signature: text, secret: text) -> bool:
    if signature == "": return false
    if secret == "": return false
    return true

fn _map_stripe_event(event_type: text) -> WebhookEventType:
    if event_type == "payment_intent.succeeded": return WebhookEventType.PaymentCaptured
    if event_type == "payment_intent.payment_failed": return WebhookEventType.PaymentFailed
    if event_type == "charge.refunded": return WebhookEventType.PaymentRefunded
    if event_type == "charge.dispute.created": return WebhookEventType.PaymentDisputed
    if event_type == "payment_intent.canceled": return WebhookEventType.PaymentVoided
    if event_type == "payment_intent.requires_capture": return WebhookEventType.PaymentAuthorized
    return WebhookEventType.UnknownEvent

fn _map_paypal_event(event_type: text) -> WebhookEventType:
    if event_type == "PAYMENT.CAPTURE.COMPLETED": return WebhookEventType.PaymentCaptured
    if event_type == "PAYMENT.CAPTURE.DENIED": return WebhookEventType.PaymentFailed
    if event_type == "PAYMENT.CAPTURE.REFUNDED": return WebhookEventType.PaymentRefunded
    if event_type == "CHECKOUT.ORDER.APPROVED": return WebhookEventType.PaymentAuthorized
    return WebhookEventType.UnknownEvent

fn _map_btcpay_event(event_type: text) -> WebhookEventType:
    if event_type == "InvoiceSettled": return WebhookEventType.InvoicePaid
    if event_type == "InvoiceExpired": return WebhookEventType.InvoiceExpired
    if event_type == "InvoiceProcessing": return WebhookEventType.PaymentAuthorized
    if event_type == "InvoiceInvalid": return WebhookEventType.PaymentFailed
    return WebhookEventType.UnknownEvent

fn _empty_event() -> WebhookEvent:
    return WebhookEvent { provider: WebhookProvider.UnknownProvider, event_type: WebhookEventType.UnknownEvent, transaction_id: "", amount_cents: 0, currency: "", raw_payload: "", timestamp: "" }

fn _char_to_digit(ch: text) -> int:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    return -1

fn _text_to_int(s: text) -> int:
    var result = 0
    var i = 0
    while i < s.length():
        val d = _char_to_digit(s.char_at(i))
        if d < 0: return 0
        result = result * 10 + d
        i = i + 1
    return result
