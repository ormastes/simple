use std.io_runtime
use std.nogc_sync_mut.http_client.{http_post, response_get_status_code, response_get_body}
use std.json.{json_parse, json_object_get, json_serialize}

struct StripeConfig:
    val api_key: text
    val api_base: text

fn new_stripe_config(api_key: text) -> StripeConfig:
    return StripeConfig {
        api_key: api_key,
        api_base: "https://api.stripe.com"
    }

fn _stripe_post(config: StripeConfig, path: text, body: text) -> (int, text):
    val url = config.api_base + path
    val auth_header = "Bearer " + config.api_key
    val response = http_post(url, body)
    val status = response_get_status_code(response)
    val resp_body = response_get_body(response)
    return (status, resp_body)

fn _url_encode(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.length():
        val ch = s.char_at(i)
        if ch == " ":
            result = result + "%20"
        else if ch == "&":
            result = result + "%26"
        else if ch == "=":
            result = result + "%3D"
        else:
            result = result + ch
        i = i + 1
    return result

struct StripeGateway:
    val config: StripeConfig

fn new_stripe_gateway(api_key: text) -> StripeGateway:
    return StripeGateway { config: new_stripe_config(api_key) }

impl Gateway for StripeGateway:
    fn name(self) -> text:
        return "stripe"

    fn authorize(self, req: AuthorizeRequest) -> PaymentResult:
        val body = "amount=" + _int_to_text(req.amount.cents) + "&currency=" + req.amount.currency + "&payment_method=" + req.token + "&capture_method=manual&confirm=true"
        val resp = _stripe_post(self.config, "/v1/payment_intents", body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: resp_body }
        val parsed = json_parse(resp_body)
        val pi_id = json_object_get(parsed, "id")
        val pi_status = json_object_get(parsed, "status")
        if pi_status == "requires_capture":
            return PaymentResult { success: true, status: PaymentStatus.Authorized, transaction_id: pi_id, error_message: "" }
        return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: pi_id, error_message: "unexpected status: " + pi_status }

    fn capture(self, req: CaptureRequest) -> PaymentResult:
        val body = "amount_to_capture=" + _int_to_text(req.amount.cents)
        val path = "/v1/payment_intents/" + req.transaction_id + "/capture"
        val resp = _stripe_post(self.config, path, body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: req.transaction_id, error_message: resp_body }
        return PaymentResult { success: true, status: PaymentStatus.Captured, transaction_id: req.transaction_id, error_message: "" }

    fn charge(self, req: ChargeRequest) -> PaymentResult:
        val body = "amount=" + _int_to_text(req.amount.cents) + "&currency=" + req.amount.currency + "&payment_method=" + req.token + "&confirm=true"
        val resp = _stripe_post(self.config, "/v1/payment_intents", body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: "", error_message: resp_body }
        val parsed = json_parse(resp_body)
        val pi_id = json_object_get(parsed, "id")
        return PaymentResult { success: true, status: PaymentStatus.Captured, transaction_id: pi_id, error_message: "" }

    fn refund(self, req: RefundRequest) -> PaymentResult:
        val body = "payment_intent=" + req.transaction_id + "&amount=" + _int_to_text(req.amount.cents)
        val resp = _stripe_post(self.config, "/v1/refunds", body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: req.transaction_id, error_message: resp_body }
        return PaymentResult { success: true, status: PaymentStatus.Refunded, transaction_id: req.transaction_id, error_message: "" }

    fn void_payment(self, req: VoidRequest) -> PaymentResult:
        val path = "/v1/payment_intents/" + req.transaction_id + "/cancel"
        val body = "cancellation_reason=requested_by_customer"
        val resp = _stripe_post(self.config, path, body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return PaymentResult { success: false, status: PaymentStatus.Failed, transaction_id: req.transaction_id, error_message: resp_body }
        return PaymentResult { success: true, status: PaymentStatus.Voided, transaction_id: req.transaction_id, error_message: "" }

    fn tokenize(self, req: TokenizeRequest) -> TokenizeResult:
        val body = "card[number]=" + req.card_number + "&card[exp_month]=" + _int_to_text(req.expiry_month) + "&card[exp_year]=" + _int_to_text(req.expiry_year) + "&card[name]=" + _url_encode(req.cardholder_name)
        val resp = _stripe_post(self.config, "/v1/tokens", body)
        val status = resp[0]
        val resp_body = resp[1]
        if status < 200 or status >= 300:
            return TokenizeResult { success: false, token: "", error_message: resp_body }
        val parsed = json_parse(resp_body)
        val tok_id = json_object_get(parsed, "id")
        return TokenizeResult { success: true, token: tok_id, error_message: "" }
