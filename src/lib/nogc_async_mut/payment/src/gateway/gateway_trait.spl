use std.io_runtime

enum PaymentStatus:
    Created
    Authorized
    Captured
    Settled
    Refunded
    Voided
    Failed

struct Amount:
    val cents: int
    val currency: text

struct PaymentResult:
    val success: bool
    val status: PaymentStatus
    val transaction_id: text
    val error_message: text

struct AuthorizeRequest:
    val token: text
    val amount: Amount
    val merchant_ref: text
    val idempotency_key: text

struct CaptureRequest:
    val transaction_id: text
    val amount: Amount

struct RefundRequest:
    val transaction_id: text
    val amount: Amount
    val reason: text

struct VoidRequest:
    val transaction_id: text
    val reason: text

struct ChargeRequest:
    val token: text
    val amount: Amount
    val merchant_ref: text
    val idempotency_key: text

struct TokenizeRequest:
    val card_number: text
    val expiry_month: int
    val expiry_year: int
    val cardholder_name: text

struct TokenizeResult:
    val success: bool
    val token: text
    val error_message: text

trait Gateway:
    fn name(self) -> text
    fn authorize(self, req: AuthorizeRequest) -> PaymentResult
    fn capture(self, req: CaptureRequest) -> PaymentResult
    fn charge(self, req: ChargeRequest) -> PaymentResult
    fn refund(self, req: RefundRequest) -> PaymentResult
    fn void_payment(self, req: VoidRequest) -> PaymentResult
    fn tokenize(self, req: TokenizeRequest) -> TokenizeResult
