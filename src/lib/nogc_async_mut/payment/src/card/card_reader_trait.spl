use std.io_runtime

enum ReaderStatus:
    Connected
    Disconnected
    ReadyForCard
    Reading
    Error

enum ReadMethod:
    EMV
    NFC
    MagStripe

struct CardReadResult:
    success: bool
    token: text
    method: ReadMethod
    error_message: text

trait CardReader:
    fn status(self) -> ReaderStatus
    fn read_card(self) -> CardReadResult
    fn cancel_read(self) -> bool
    fn reset(self) -> bool

struct MockCardReader:
    connected: bool

fn new_mock_card_reader() -> MockCardReader:
    return MockCardReader { connected: true }

impl CardReader for MockCardReader:
    fn status(self) -> ReaderStatus:
        # TODO(M5): return actual connection status
        return ReaderStatus.Disconnected

    fn read_card(self) -> CardReadResult:
        # TODO(M5): simulate card read with fake encrypted token
        return CardReadResult {
            success: false,
            token: "",
            method: ReadMethod.EMV,
            error_message: "TODO: not implemented"
        }

    fn cancel_read(self) -> bool:
        # TODO(M5): cancel in-progress read
        return false

    fn reset(self) -> bool:
        # TODO(M5): reset reader state
        return false
