use std.io_runtime

enum CardBrand:
    Visa
    Mastercard
    Amex
    Discover
    JCB
    UnionPay
    Unknown

struct CardNumber:
    masked: text
    last4: text
    brand: CardBrand

struct CardExpiry:
    month: int
    year: int

struct CardToken:
    token: text
    last4: text
    brand: CardBrand
    expiry: CardExpiry

enum PaymentIntentStatus:
    Created
    RequiresConfirmation
    Confirmed
    Processing
    Captured
    Canceled
    Failed

struct PaymentIntent:
    id: text
    amount: int
    currency: text
    status: PaymentIntentStatus
    token: text
    merchant_ref: text
    created_at: text
