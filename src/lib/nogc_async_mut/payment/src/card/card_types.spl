use std.io_runtime

enum CardBrand:
    Visa
    Mastercard
    Amex
    Discover
    JCB
    UnionPay
    Unknown

struct CardNumber:
    val masked: text
    val last4: text
    val brand: CardBrand

struct CardExpiry:
    val month: int
    val year: int

struct CardToken:
    val token: text
    val last4: text
    val brand: CardBrand
    val expiry: CardExpiry

enum PaymentIntentStatus:
    Created
    RequiresConfirmation
    Confirmed
    Processing
    Captured
    Canceled
    Failed

struct PaymentIntent:
    val id: text
    val amount: int
    val currency: text
    val status: PaymentIntentStatus
    val token: text
    val merchant_ref: text
    val created_at: text
