fn cuda_f64_slice_1d(dst: i64, src: i64, start: i64, step: i64, n: i64) -> i64:
    rt_cuda_f64_slice_1d(dst, src, start, step, n)

fn cuda_f64_slice_2d(dst: i64, src: i64, source_cols: i64, row_start: i64, row_step: i64, row_count: i64, col_start: i64, col_step: i64, col_count: i64) -> i64:
    rt_cuda_f64_slice_2d(dst, src, source_cols, row_start, row_step, row_count, col_start, col_step, col_count)

fn slice_length(start: i64, stop: i64, step: i64) -> i64:
    if step == 0:
        return 0
    var count = 0
    var cursor = start
    if step > 0:
        while cursor < stop:
            count = count + 1
            cursor = cursor + step
    else:
        while cursor > stop:
            count = count + 1
            cursor = cursor + step
    count

fn normalize_cuda_axis(axis: Axis, ndim: i64) -> Result<i64, i64>:
    var value = axis.value
    if value < 0:
        value = ndim + value
    if value < 0 or value >= ndim:
        return Err(CUDA_ERROR_INVALID_VALUE)
    Ok(value)

