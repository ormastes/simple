# CUDA Simple API (NoGC Async)
#
# Thin, hand-maintained wrapper over the canonical runtime CUDA ABI.

use std.nogc_async_mut.cuda.ffi.*
use std.types.{DeviceId, KernelHandle, ThreadCount}

val CUDA_SUCCESS = 0
val CUDA_ERROR_INVALID_VALUE = -1
val CUDA_ERROR_OUT_OF_MEMORY = -2
val CUDA_ERROR_NOT_INITIALIZED = -3
val CUDA_ERROR_NO_DEVICE = -100

fn cuda_available() -> bool:
    rt_cuda_available() != 0

fn cuda_init() -> i64:
    rt_cuda_init()

fn cuda_device_count() -> i64:
    rt_cuda_device_count()

fn cuda_device_get(device_id: DeviceId) -> i64:
    rt_cuda_device_get(device_id.value)

fn cuda_device_name(device: DeviceId) -> text:
    rt_cuda_device_name(device.value)

fn cuda_device_compute_capability(device: DeviceId) -> i64:
    rt_cuda_device_compute_capability(device.value)

fn cuda_ctx_create(device: DeviceId) -> i64:
    rt_cuda_ctx_create(device.value)

fn cuda_ctx_destroy(ctx: i64) -> i64:
    rt_cuda_ctx_destroy(ctx)

fn cuda_ctx_synchronize() -> i64:
    rt_cuda_ctx_synchronize()

fn cuda_mem_alloc(size: i64) -> i64:
    rt_cuda_mem_alloc(size)

fn cuda_mem_free(ptr: i64) -> i64:
    rt_cuda_mem_free(ptr)

fn cuda_memcpy_htod(dst: i64, src: i64, size: i64) -> i64:
    rt_cuda_memcpy_htod(dst, src, size)

fn cuda_memcpy_dtoh(dst: i64, src: i64, size: i64) -> i64:
    rt_cuda_memcpy_dtoh(dst, src, size)

fn cuda_memcpy_dtod(dst: i64, src: i64, size: i64) -> i64:
    rt_cuda_memcpy_dtod(dst, src, size)

fn cuda_memset(ptr: i64, value: i64, size: i64) -> i64:
    rt_cuda_memset(ptr, value, size)

fn cuda_module_load(path: text) -> KernelHandle:
    KernelHandle(value: rt_cuda_module_load(path))

fn cuda_module_load_data(ptx: text) -> KernelHandle:
    KernelHandle(value: rt_cuda_module_load_data(ptx))

fn cuda_module_unload(module: KernelHandle) -> i64:
    rt_cuda_module_unload(module.value)

fn cuda_module_get_function(module: KernelHandle, func_name: text) -> KernelHandle:
    KernelHandle(value: rt_cuda_module_get_function(module.value, func_name))

fn cuda_launch_kernel(module: KernelHandle, func_name: text, grid_x: ThreadCount, grid_y: ThreadCount, grid_z: ThreadCount, block_x: ThreadCount, block_y: ThreadCount, block_z: ThreadCount, args_ptr: i64) -> i64:
    rt_cuda_launch_kernel(module.value, func_name, grid_x.value, grid_y.value, grid_z.value, block_x.value, block_y.value, block_z.value, args_ptr)

fn cuda_sync() -> i64:
    rt_cuda_sync()

fn cuda_get_error_string(error_code: i64) -> text:
    rt_cuda_get_error_string(error_code)

