# Host Stdio - Thin wrapper for stdin/stdout with async variants.
#
# Sync core:
#   - read_line()  delegates to rt_stdin_read_line (works in interpreter mode)
#   - read_char()  delegates to stdin_read_char (compiled mode only; crashes
#                  in interpreter mode when called from a std.* module —
#                  the same constraint as mcp_sdk/transport/stdio.spl)
#   - read_bytes() delegates to stdin_read_char (same constraint as above)
#   - write/write_line use print_raw (always works)
#
# Async variants wrap each blocking call in HostFuture.ready() so callers
# can sequence them with other HostFuture work.  The future is completed
# inline — no background thread is needed and no GC allocation occurs.
# Blocking stdin read is the correct idle state; NO timeout is added
# (see plan rule R4: MCP servers must idle indefinitely).
#
# Import as: use std.nogc_async_mut.host_io.stdio

use std.async_host.future.{HostFuture}

# =========================================================================
# Extern declarations  (reuse existing runtime symbols — no duplication)
# =========================================================================

# rt_read_stdin_line: read one line from stdin (strips trailing newline).
# Returns "" on EOF.  Works in both interpreter and compiled mode.
# NOTE: The interpreter registers this symbol via rt_stdin_read_line_stub
# mapped to "rt_stdin_read_line"; the native runtime exports "rt_read_stdin_line".
# In Simple source, declare as rt_read_stdin_line — the compiler maps it.
extern fn rt_read_stdin_line() -> text

# stdin_read_char: returns one UTF-8 character, or "" on EOF.
# Same symbol used by mcp_sdk/transport/stdio.spl (as extern fn n()
# alias in app-local modules).  COMPILED MODE ONLY — crashes in interpreter
# mode when declared in a std.* module.
extern fn stdin_read_char() -> text

# =========================================================================
# Sync core
# =========================================================================

# Read one line from stdin (newline is stripped by the runtime).
# Returns "" on EOF.  Uses rt_read_stdin_line which works in both
# interpreter mode and compiled mode.
fn read_line() -> text:
    val line = rt_read_stdin_line()
    line

# Read one character from stdin.  Returns "" on EOF.
# NOTE: Only works in compiled mode (stdin_read_char interpreter limitation).
fn read_char() -> text:
    stdin_read_char()

# Read exactly n characters from stdin.
# Returns fewer characters only on EOF.
# NOTE: Only works in compiled mode (stdin_read_char interpreter limitation).
fn read_bytes(n: i64) -> text:
    var parts: [text] = []
    var i = 0
    while i < n:
        val ch = stdin_read_char()
        if ch == "":
            break
        parts.push(ch)
        i = i + 1
    parts.join("")

# Write text to stdout without a trailing newline.
fn write(text_val: text):
    print_raw(text_val)

# Write text to stdout followed by a newline.
fn write_line(text_val: text):
    print_raw(text_val + "\n")

# =========================================================================
# Async variants (HostFuture wrappers)
# =========================================================================

# Async read_line: wraps the blocking rt_stdin_read_line call.
# Returns a ready future; callers may sequence with block_on or compose.
fn read_line_async() -> HostFuture<text>:
    val line = read_line()
    HostFuture.ready(line)

# Async read_char: wraps stdin_read_char (compiled mode only).
fn read_char_async() -> HostFuture<text>:
    val ch = read_char()
    HostFuture.ready(ch)

# Async read_bytes: wraps stdin_read_char (compiled mode only).
fn read_bytes_async(n: i64) -> HostFuture<text>:
    val data = read_bytes(n)
    HostFuture.ready(data)

# Async write: performs write then returns a completed unit future.
fn write_async(text_val: text) -> HostFuture<()>:
    write(text_val)
    HostFuture.ready(())

# Async write_line: performs write_line then returns a completed unit future.
fn write_line_async(text_val: text) -> HostFuture<()>:
    write_line(text_val)
    HostFuture.ready(())

# =========================================================================
# Exports
# =========================================================================

pub fn read_line() -> text
pub fn read_char() -> text
pub fn read_bytes(n: i64) -> text
pub fn write(text_val: text)
pub fn write_line(text_val: text)
pub fn read_line_async() -> HostFuture<text>
pub fn read_char_async() -> HostFuture<text>
pub fn read_bytes_async(n: i64) -> HostFuture<text>
pub fn write_async(text_val: text) -> HostFuture<()>
pub fn write_line_async(text_val: text) -> HostFuture<()>
