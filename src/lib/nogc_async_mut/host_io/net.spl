"""
# Host Net — Async TCP/UDP Wrapper

Thin async wrapper over the no-GC synchronous TCP and UDP facades.

## Async Execution Model

All futures in this module are *eager-completing*: the underlying sync
operations run immediately inside the future constructor, and the returned
`Future<T>` is always in `Poll.Ready` state before it reaches the caller.
This matches the v1 pattern established in `nogc_async_mut/io/tcp.spl`.
True non-blocking I/O (waker-driven) is out of scope for v1; callers should
not assume the scheduler ever needs to poll these futures more than once.

## Usage

```simple
use std.nogc_async_mut.host_io.net.{AsyncTcpListener, AsyncTcpStream}
use std.nogc_async_mut.host_io.net.{AsyncUdpSocket}

# TCP server
val listener = AsyncTcpListener.bind("127.0.0.1:0")
match listener:
    case Ok(l):
        val addr = l.local_addr()?
        val client_future = l.accept()
        match client_future.poll():
            case Poll.Ready(Ok(stream)):
                val _ = stream.write([72, 105])
            case _: pass
    case Err(e): pass

# UDP datagram
val sock = AsyncUdpSocket.bind("127.0.0.1:0")
match sock:
    case Ok(s):
        val addr = s.local_addr()?
        val _ = s.send_to([72, 105], addr)
    case Err(e): pass
```
"""

use std.async.future.{Future}
use std.io.async_traits.{AsyncRead, AsyncWrite, AsyncClose}
use std.io.types.{IoError, IoErrorKind, Shutdown}
use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.nogc_sync_mut.io.udp.{UdpSocket}

# ============================================================================
# AsyncTcpListener - Host-Layer TCP Server Socket
# ============================================================================

class AsyncTcpListener with AsyncClose:
    """Async TCP listener backed by no-GC sync TCP.

    Binds and listens immediately; accept/close return eager futures.
    """
    inner_listener: TcpListener

    static fn bind(addr: text) -> Result<AsyncTcpListener, IoError>:
        """Bind to address and start listening.

        Args:
            addr: Address in "host:port" format

        Returns:
            Result with AsyncTcpListener or IoError
        """
        match TcpListener.bind(addr):
            case Ok(l):
                Ok(AsyncTcpListener(inner_listener: l))
            case Err(e):
                Err(e)

    fn accept() -> Future<Result<AsyncTcpStream, IoError>>:
        """Accept one incoming connection (eager).

        The sync accept() blocks until a client connects.
        Returns an immediately-ready future.
        """
        match self.inner_listener.accept():
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(inner_stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    fn accept_timeout(ms: i64) -> Future<Result<AsyncTcpStream, IoError>>:
        """Accept with timeout (eager).

        Args:
            ms: Timeout in milliseconds
        """
        match self.inner_listener.accept_timeout(ms):
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(inner_stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    fn local_addr() -> Result<text, IoError>:
        """Get the local bound address."""
        self.inner_listener.local_addr()

    me close() -> Future<Result<(), IoError>>:
        """Close the listener."""
        Future.from_value(self.inner_listener.close())

    fn is_open() -> bool:
        """Check if listener is open."""
        self.inner_listener.is_open()

# ============================================================================
# AsyncTcpStream - Host-Layer TCP Connection
# ============================================================================

class AsyncTcpStream with AsyncRead, AsyncWrite, AsyncClose:
    """Async TCP stream backed by no-GC sync TCP.

    Read/write/close return eager futures; the underlying call completes
    before the future is returned to the caller.
    """
    inner_stream: TcpStream

    static fn connect(addr: text) -> Future<Result<AsyncTcpStream, IoError>>:
        """Connect to remote address (eager).

        Args:
            addr: Address in "host:port" format
        """
        match TcpStream.connect(addr):
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(inner_stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    static fn connect_timeout(addr: text, ms: i64) -> Future<Result<AsyncTcpStream, IoError>>:
        """Connect with timeout (eager).

        Args:
            addr: Address in "host:port" format
            ms: Timeout in milliseconds
        """
        match TcpStream.connect_timeout(addr, ms):
            case Ok(stream):
                Future.from_value(Ok(AsyncTcpStream(inner_stream: stream)))
            case Err(e):
                Future.from_value(Err(e))

    # --- AsyncRead ---

    fn read(size: i64) -> Future<Result<[u8], IoError>>:
        """Read up to size bytes (eager)."""
        Future.from_value(self.inner_stream.read(size))

    fn read_exact(size: i64) -> Future<Result<[u8], IoError>>:
        """Read exactly size bytes (eager)."""
        Future.from_value(self.inner_stream.read_exact(size))

    fn read_all() -> Future<Result<[u8], IoError>>:
        """Read until EOF (eager)."""
        Future.from_value(self.inner_stream.read_all())

    fn read_text() -> Future<Result<text, IoError>>:
        """Read all content as text (eager)."""
        Future.from_value(self.inner_stream.read_text())

    fn read_line() -> Future<Result<text, IoError>>:
        """Read one line (eager)."""
        Future.from_value(self.inner_stream.read_line())

    # --- AsyncWrite ---

    fn write(data: [u8]) -> Future<Result<i64, IoError>>:
        """Write bytes (eager)."""
        Future.from_value(self.inner_stream.write(data))

    fn write_all(data: [u8]) -> Future<Result<(), IoError>>:
        """Write all bytes (eager)."""
        Future.from_value(self.inner_stream.write_all(data))

    fn write_text(s: text) -> Future<Result<(), IoError>>:
        """Write text (eager)."""
        Future.from_value(self.inner_stream.write_text(s))

    fn flush() -> Future<Result<(), IoError>>:
        """Flush write buffer (eager)."""
        Future.from_value(self.inner_stream.flush())

    # --- AsyncClose ---

    me close() -> Future<Result<(), IoError>>:
        """Close stream (eager)."""
        Future.from_value(self.inner_stream.close())

    fn is_open() -> bool:
        """Check if stream is open."""
        self.inner_stream.is_open()

    # --- Metadata ---

    fn peer_addr() -> Result<text, IoError>:
        """Get remote peer address."""
        self.inner_stream.peer_addr()

    fn local_addr() -> Result<text, IoError>:
        """Get local address."""
        self.inner_stream.local_addr()

    fn set_nodelay(enabled: bool) -> Result<(), IoError>:
        """Set TCP_NODELAY option."""
        self.inner_stream.set_nodelay(enabled)

    fn shutdown(how: Shutdown) -> Future<Result<(), IoError>>:
        """Shutdown one or both directions (eager)."""
        Future.from_value(self.inner_stream.shutdown(how))

# ============================================================================
# AsyncUdpSocket - Host-Layer UDP Datagram Socket
# ============================================================================

class AsyncUdpSocket with AsyncClose:
    """Async UDP socket backed by no-GC sync UDP.

    All operations return eager futures (v1).
    """
    inner_socket: UdpSocket

    static fn bind(addr: text) -> Result<AsyncUdpSocket, IoError>:
        """Bind UDP socket to address.

        Args:
            addr: Address in "host:port" format

        Returns:
            Result with AsyncUdpSocket or IoError
        """
        match UdpSocket.bind(addr):
            case Ok(s):
                Ok(AsyncUdpSocket(inner_socket: s))
            case Err(e):
                Err(e)

    fn local_addr() -> Result<text, IoError>:
        """Get local bound address."""
        self.inner_socket.local_addr()

    fn send_to(data: [u8], addr: text) -> Future<Result<i64, IoError>>:
        """Send datagram to address (eager).

        Args:
            data: Bytes to send
            addr: Destination "host:port"
        """
        Future.from_value(self.inner_socket.send_to(data, addr))

    fn recv_from(size: i64) -> Future<Result<([u8], text), IoError>>:
        """Receive datagram with sender address (eager, blocks until data arrives).

        Args:
            size: Maximum bytes to receive
        """
        Future.from_value(self.inner_socket.recv_from(size))

    fn connect(addr: text) -> Result<(), IoError>:
        """Set default peer address for send/recv."""
        self.inner_socket.connect(addr)

    fn send(data: [u8]) -> Future<Result<i64, IoError>>:
        """Send to connected peer (eager)."""
        Future.from_value(self.inner_socket.send(data))

    fn recv(size: i64) -> Future<Result<[u8], IoError>>:
        """Receive from connected peer (eager)."""
        Future.from_value(self.inner_socket.recv(size))

    me close() -> Future<Result<(), IoError>>:
        """Close socket (eager)."""
        Future.from_value(self.inner_socket.close())

    fn is_open() -> bool:
        """Check if socket is open."""
        self.inner_socket.is_open()

# ============================================================================
# Exports
# ============================================================================

export AsyncTcpListener
export AsyncTcpStream
export AsyncUdpSocket
