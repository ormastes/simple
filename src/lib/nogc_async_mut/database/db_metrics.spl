# Database Observability Counters
# Tracks read/write/compaction/WAL-replay counts and timing for reporting.

class DbMetrics:
    read_count: i64
    write_count: i64
    compaction_count: i64
    wal_replay_count: i64
    last_write_us: i64
    last_read_us: i64
    row_count: i64
    deleted_row_count: i64

    static fn new() -> DbMetrics:
        DbMetrics(
            read_count: 0,
            write_count: 0,
            compaction_count: 0,
            wal_replay_count: 0,
            last_write_us: 0,
            last_read_us: 0,
            row_count: 0,
            deleted_row_count: 0
        )

    me record_read():
        self.read_count = self.read_count + 1

    me record_write():
        self.write_count = self.write_count + 1

    me record_compaction():
        self.compaction_count = self.compaction_count + 1

    me record_wal_replay():
        self.wal_replay_count = self.wal_replay_count + 1

    fn snapshot() -> DbMetrics:
        DbMetrics(
            read_count: self.read_count,
            write_count: self.write_count,
            compaction_count: self.compaction_count,
            wal_replay_count: self.wal_replay_count,
            last_write_us: self.last_write_us,
            last_read_us: self.last_read_us,
            row_count: self.row_count,
            deleted_row_count: self.deleted_row_count
        )
