"""
# No-GC Async Atomic Database

Compatibility facade over the no-GC sync database backend.
"""

export use std.nogc_sync_mut.database.atomic.{
    file_read, file_write, file_exists, file_delete,
    get_timestamp, sleep_ms, is_process_alive, FileLock,
    atomic_read, atomic_write, atomic_write_batch, atomic_append
}
