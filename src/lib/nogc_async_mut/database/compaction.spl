# Online compaction: removes soft-deleted rows and rewrites table compactly.

use nogc_async_mut.database.core (SdnTable, SdnRow, SdnDatabase)
use nogc_async_mut.database.atomic (get_timestamp)

struct CompactionStats:
    rows_before: i64
    rows_after: i64
    deleted_removed: i64
    duration_us: i64

fn compact_table(table: SdnTable) -> (SdnTable, CompactionStats):
    val start = get_timestamp()
    val rows_before: i64 = table.rows.len()
    val valid = table.valid_rows()
    val rows_after: i64 = valid.len()
    val deleted_removed = rows_before - rows_after

    val new_table = SdnTable(
        name: table.name,
        columns: table.columns,
        rows: valid,
        index: {}
    )
    new_table.rebuild_index()

    val duration_us = get_timestamp() - start
    val stats = CompactionStats(
        rows_before: rows_before,
        rows_after: rows_after,
        deleted_removed: deleted_removed,
        duration_us: duration_us
    )
    (new_table, stats)

fn compact_database(db: SdnDatabase) -> CompactionStats:
    val start = get_timestamp()
    var total_before: i64 = 0
    var total_after: i64 = 0
    var total_deleted: i64 = 0

    for (name, table) in db.tables:
        val typed_table: SdnTable = table
        val (compacted, stats) = compact_table(typed_table)
        db.tables[name] = compacted
        total_before = total_before + stats.rows_before
        total_after = total_after + stats.rows_after
        total_deleted = total_deleted + stats.deleted_removed

    db.modified = true
    val duration_us = get_timestamp() - start
    CompactionStats(
        rows_before: total_before,
        rows_after: total_after,
        deleted_removed: total_deleted,
        duration_us: duration_us
    )

fn should_compact(table: SdnTable, threshold: f64) -> bool:
    val total: i64 = table.rows.len()
    if total == 0:
        return false
    val valid_count: i64 = table.valid_rows().len()
    val deleted = total - valid_count
    val ratio = deleted.to_float() / total.to_float()
    ratio > threshold
