# Shared JIT Core
#
# Shared Pure Simple JIT abstractions for local and remote execution.
# Unified pipeline: types -> layout -> backend -> runner.

# Types (shared across all backends)
export JitBackendKind, JitMemoryLimits, JitBinary, JitLayoutPlan, JitExecResult

# Layout planning
export append_halt_trampoline_arm32, plan_binary_layout_arm32
export append_halt_trampoline_rv32, plan_binary_layout_rv32, plan_binary_layout
export jit_entry_pc_arm32, jit_return_pc_arm32

# Backend interface
export JitBackendOps, DisconnectedBackendOps
export local_backend, mock_backend, disconnected_ops

# Unified runner
export JitRunnerConfig
export jit_run, jit_run_simple, jit_run_disconnected
export validate_binary, plan_layout, append_halt_trampoline

# Utilities
export hex_i64, hex_0x_i64, hex_i32, hex_byte, hex_char
export parse_i64, parse_hex, extract_reg_value, parse_mdw_bytes
