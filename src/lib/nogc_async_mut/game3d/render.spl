# Game3D Render - Rendering command wrappers
#
# Mesh, material, light, and camera management via engine_render_* imports.

use .wasm_abi
use .entity.{Entity}
use .math.{Vec3, Vec4}

# ============================================================================
# Primitive Mesh Types
# ============================================================================

enum PrimitiveType:
    Cube = 0
    Sphere = 1
    Cylinder = 2
    Capsule = 3
    Plane = 4
    Quad = 5

impl PrimitiveType:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Light Types
# ============================================================================

enum LightType:
    Directional = 0
    Point = 1
    Spot = 2

impl LightType:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Material Handle
# ============================================================================

class Material:
    """Handle to an engine-managed material."""
    id: i32

    static fn create() -> Material:
        """Create a new material."""
        Material(id: engine_render_create_material())

    fn is_valid() -> bool:
        self.id >= 0

    fn set_color(r: f32, g: f32, b: f32, a: f32):
        """Set the material's base color."""
        engine_render_set_material_color(self.id, r, g, b, a)

    fn set_color_vec(color: Vec4):
        """Set the material's base color from a Vec4."""
        engine_render_set_material_color(self.id, color.x, color.y, color.z, color.w)

    fn set_texture(slot: i32, texture_id: i32):
        """Bind a texture to a material slot."""
        engine_render_set_material_texture(self.id, slot, texture_id)

    fn set_float(param: i32, value: f32):
        """Set a float parameter on the material."""
        engine_render_set_material_float(self.id, param, value)

# ============================================================================
# Material Parameter Slots
# ============================================================================

val MAT_PARAM_ROUGHNESS: i32 = 0
val MAT_PARAM_METALLIC: i32 = 1
val MAT_PARAM_EMISSIVE: i32 = 2

# Texture slots
val TEX_SLOT_ALBEDO: i32 = 0
val TEX_SLOT_NORMAL: i32 = 1
val TEX_SLOT_ROUGHNESS: i32 = 2
val TEX_SLOT_METALLIC: i32 = 3
val TEX_SLOT_EMISSIVE: i32 = 4

# ============================================================================
# Rendering Functions
# ============================================================================

fn set_mesh(entity: Entity, mesh_type: PrimitiveType):
    """Set a primitive mesh on an entity."""
    engine_render_set_mesh(entity.id, mesh_type.to_i32())

fn set_mesh_asset(entity: Entity, asset_id: i32):
    """Set a loaded mesh asset on an entity."""
    engine_render_set_mesh_asset(entity.id, asset_id)

fn set_material(entity: Entity, material: Material):
    """Set a material on an entity."""
    engine_render_set_material(entity.id, material.id)

fn create_primitive(prim_type: PrimitiveType) -> Entity:
    """Create an entity with a primitive mesh already attached."""
    val id = engine_render_create_primitive(prim_type.to_i32())
    Entity(id: id)

# ============================================================================
# Light Functions
# ============================================================================

class Light:
    """Handle to an engine-managed light."""
    id: i32

    static fn create(light_type: LightType) -> Light:
        Light(id: engine_render_create_light(light_type.to_i32()))

    fn set_color(r: f32, g: f32, b: f32):
        engine_render_set_light_color(self.id, r, g, b)

    fn set_color_vec(color: Vec3):
        engine_render_set_light_color(self.id, color.x, color.y, color.z)

    fn set_intensity(intensity: f32):
        engine_render_set_light_intensity(self.id, intensity)

# ============================================================================
# Camera Functions
# ============================================================================

class Camera:
    """Handle to an engine-managed camera."""
    id: i32

    static fn create() -> Camera:
        Camera(id: engine_render_create_camera())

    fn set_fov(fov: f32):
        engine_render_set_camera_fov(self.id, fov)

    fn set_active(active: bool):
        val flag = if active { 1 } else { 0 }
        engine_render_set_camera_active(self.id, flag)

