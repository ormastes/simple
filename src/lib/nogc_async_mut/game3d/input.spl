# Game3D Input - Input polling wrappers
#
# Wraps engine_input_* extern calls with typed Simple API.

use .wasm_abi
use .key_codes.{KeyCode, MouseButton}
use .math.{Vec2}

# ============================================================================
# Keyboard Input
# ============================================================================

fn is_key_pressed(key: KeyCode) -> bool:
    """Check if a key is currently held down."""
    engine_input_is_key_pressed(key.to_i32()) != 0

fn is_key_just_pressed(key: KeyCode) -> bool:
    """Check if a key was pressed this frame."""
    engine_input_is_key_just_pressed(key.to_i32()) != 0

fn is_key_just_released(key: KeyCode) -> bool:
    """Check if a key was released this frame."""
    engine_input_is_key_just_released(key.to_i32()) != 0

# ============================================================================
# Mouse Input
# ============================================================================

fn get_mouse_position() -> Vec2:
    """Get current mouse position in screen coordinates."""
    var buf = [0.0; 2]
    engine_input_get_mouse_position(buf.ptr())
    Vec2(buf[0], buf[1])

fn get_mouse_delta() -> Vec2:
    """Get mouse movement delta this frame."""
    var buf = [0.0; 2]
    engine_input_get_mouse_delta(buf.ptr())
    Vec2(buf[0], buf[1])

fn is_mouse_pressed(button: MouseButton) -> bool:
    """Check if a mouse button is currently held."""
    engine_input_is_mouse_button_pressed(button.to_i32()) != 0

# ============================================================================
# Axis / Action Input
# ============================================================================

fn get_axis(axis_name: text) -> f32:
    """Get value of a named axis (-1.0 to 1.0)."""
    engine_input_get_axis(axis_name.ptr(), axis_name.len())

fn is_action_pressed(action: text) -> bool:
    """Check if a named action is pressed."""
    engine_input_is_action_pressed(action.ptr(), action.len()) != 0

# ============================================================================
# Movement Helpers
# ============================================================================

fn get_wasd_direction() -> Vec2:
    """Get WASD movement direction as a normalized Vec2."""
    var x = 0.0
    var y = 0.0
    if is_key_pressed(KeyCode.W):
        y = y + 1.0
    if is_key_pressed(KeyCode.S):
        y = y - 1.0
    if is_key_pressed(KeyCode.A):
        x = x - 1.0
    if is_key_pressed(KeyCode.D):
        x = x + 1.0
    val dir = Vec2(x, y)
    if dir.length_squared() > 0.0:
        return dir.normalize()
    dir

fn get_arrow_direction() -> Vec2:
    """Get arrow key movement direction as a normalized Vec2."""
    var x = 0.0
    var y = 0.0
    if is_key_pressed(KeyCode.Up):
        y = y + 1.0
    if is_key_pressed(KeyCode.Down):
        y = y - 1.0
    if is_key_pressed(KeyCode.Left):
        x = x - 1.0
    if is_key_pressed(KeyCode.Right):
        x = x + 1.0
    val dir = Vec2(x, y)
    if dir.length_squared() > 0.0:
        return dir.normalize()
    dir

