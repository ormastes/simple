# Game3D Component - Pure Simple component registry
#
# Lightweight component system for organizing game logic.
# Components are trait objects attached to entities by type tag.

# ============================================================================
# Component Type Tags
# ============================================================================

enum ComponentTag:
    Transform = 0
    Render = 1
    Physics = 2
    Audio = 3
    Script = 4
    Camera = 5
    Light = 6
    Custom = 7

impl ComponentTag:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Component Entry
# ============================================================================

class ComponentEntry:
    """A component attached to an entity."""
    entity_id: i32
    tag: ComponentTag
    data_id: i32
    enabled: bool

    static fn create(entity_id: i32, tag: ComponentTag, data_id: i32) -> ComponentEntry:
        ComponentEntry(
            entity_id: entity_id,
            tag: tag,
            data_id: data_id,
            enabled: true
        )

# ============================================================================
# Component Registry
# ============================================================================

class ComponentRegistry:
    """Registry mapping entities to their components."""
    entries: [ComponentEntry]

    static fn create() -> ComponentRegistry:
        ComponentRegistry(entries: [])

    fn add(entity_id: i32, tag: ComponentTag, data_id: i32):
        """Register a component for an entity."""
        val entry = ComponentEntry.create(entity_id, tag, data_id)
        self.entries.push(entry)

    fn remove(entity_id: i32, tag: ComponentTag):
        """Remove a component from an entity."""
        var new_entries: [ComponentEntry] = []
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if not (entry.entity_id == entity_id and entry.tag.to_i32() == tag.to_i32()):
                new_entries.push(entry)
            i = i + 1
        self.entries = new_entries

    fn remove_all(entity_id: i32):
        """Remove all components from an entity."""
        var new_entries: [ComponentEntry] = []
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if entry.entity_id != entity_id:
                new_entries.push(entry)
            i = i + 1
        self.entries = new_entries

    fn has(entity_id: i32, tag: ComponentTag) -> bool:
        """Check if an entity has a component of the given type."""
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if entry.entity_id == entity_id and entry.tag.to_i32() == tag.to_i32():
                return true
            i = i + 1
        false

    fn get_data_id(entity_id: i32, tag: ComponentTag) -> i32:
        """Get the data_id for a component. Returns -1 if not found."""
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if entry.entity_id == entity_id and entry.tag.to_i32() == tag.to_i32():
                return entry.data_id
            i = i + 1
        -1

    fn count() -> i32:
        self.entries.len()

    fn count_by_tag(tag: ComponentTag) -> i32:
        """Count components of a specific type."""
        var result = 0
        var i = 0
        while i < self.entries.len():
            if self.entries[i].tag.to_i32() == tag.to_i32():
                result = result + 1
            i = i + 1
        result

