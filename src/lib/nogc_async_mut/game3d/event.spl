# Game3D Event - Pure Simple pub/sub event system
#
# No engine calls. Game-side event dispatching for decoupled communication.

# ============================================================================
# Event Types
# ============================================================================

enum GameEventType:
    Custom = 0
    EntityCreated = 1
    EntityDestroyed = 2
    CollisionEnter = 3
    CollisionExit = 4
    TriggerEnter = 5
    TriggerExit = 6
    InputAction = 7
    SceneLoaded = 8
    TimerExpired = 9

impl GameEventType:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Event Data
# ============================================================================

class GameEvent:
    """A game event with type and payload."""
    event_type: GameEventType
    entity_a: i32
    entity_b: i32
    param_x: f32
    param_y: f32
    param_z: f32

    static fn simple(event_type: GameEventType) -> GameEvent:
        GameEvent(
            event_type: event_type,
            entity_a: -1,
            entity_b: -1,
            param_x: 0.0,
            param_y: 0.0,
            param_z: 0.0
        )

    static fn collision(a: i32, b: i32, nx: f32, ny: f32, nz: f32) -> GameEvent:
        GameEvent(
            event_type: GameEventType.CollisionEnter,
            entity_a: a,
            entity_b: b,
            param_x: nx,
            param_y: ny,
            param_z: nz
        )

    static fn trigger(a: i32, b: i32, entered: bool) -> GameEvent:
        val etype = if entered { GameEventType.TriggerEnter } else { GameEventType.TriggerExit }
        GameEvent(
            event_type: etype,
            entity_a: a,
            entity_b: b,
            param_x: 0.0,
            param_y: 0.0,
            param_z: 0.0
        )

# ============================================================================
# Event Queue
# ============================================================================

class EventQueue:
    """Simple event queue for decoupled communication."""
    events: [GameEvent]
    max_size: i32

    static fn create(max_size: i32) -> EventQueue:
        EventQueue(events: [], max_size: max_size)

    me push(event: GameEvent):
        """Add an event to the queue."""
        if self.events.len() < self.max_size:
            self.events.push(event)

    fn count() -> i32:
        self.events.len()

    fn get(index: i32) -> GameEvent:
        self.events[index]

    me clear():
        """Clear all events from the queue."""
        self.events = []

    fn has_events() -> bool:
        self.events.len() > 0

