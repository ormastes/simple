# Game3D Entity - Opaque entity handle wrapping engine-managed i32
#
# Entity handles reference engine-side objects (GameObjects, Nodes, Actors).
# The engine owns the actual object; WASM only holds the handle.

use .wasm_abi
use .math.{Vec3, Quat}

# ============================================================================
# Entity Handle
# ============================================================================

class Entity:
    """Opaque handle to an engine-managed game entity."""
    id: i32

    static fn invalid() -> Entity:
        """Create an invalid entity handle."""
        Entity(id: -1)

    static fn create() -> Entity:
        """Create a new entity in the engine."""
        val id = engine_entity_create()
        Entity(id: id)

    static fn create_named(name: text) -> Entity:
        """Create a new entity with a name."""
        val id = engine_entity_create_named(name.ptr(), name.len())
        Entity(id: id)

    static fn find(name: text) -> Entity:
        """Find an entity by name. Returns invalid if not found."""
        val id = engine_entity_find_by_name(name.ptr(), name.len())
        Entity(id: id)

    fn is_valid() -> bool:
        self.id >= 0

    fn destroy():
        """Destroy this entity in the engine."""
        if self.is_valid():
            engine_entity_destroy(self.id)

    fn set_active(active: bool):
        val flag = if active { 1 } else { 0 }
        engine_entity_set_active(self.id, flag)

    fn is_active() -> bool:
        engine_entity_is_active(self.id) != 0

    fn set_parent(parent: Entity):
        engine_entity_set_parent(self.id, parent.id)

    fn set_name(name: text):
        engine_entity_set_name(self.id, name.ptr(), name.len())

    # ========================================================================
    # Transform shortcuts
    # ========================================================================

    fn get_position() -> Vec3:
        var buf = [0.0; 3]
        engine_transform_get_position(self.id, buf.ptr())
        Vec3(buf[0], buf[1], buf[2])

    fn set_position(pos: Vec3):
        engine_transform_set_position(self.id, pos.x, pos.y, pos.z)

    fn get_rotation() -> Quat:
        var buf = [0.0; 4]
        engine_transform_get_rotation(self.id, buf.ptr())
        Quat(buf[3], buf[0], buf[1], buf[2])

    fn set_rotation(rot: Quat):
        engine_transform_set_rotation(self.id, rot.x, rot.y, rot.z, rot.w)

    fn get_scale() -> Vec3:
        var buf = [0.0; 3]
        engine_transform_get_scale(self.id, buf.ptr())
        Vec3(buf[0], buf[1], buf[2])

    fn set_scale(s: Vec3):
        engine_transform_set_scale(self.id, s.x, s.y, s.z)

    fn look_at(target: Vec3):
        engine_transform_look_at(self.id, target.x, target.y, target.z)

    fn translate(delta: Vec3):
        engine_transform_translate(self.id, delta.x, delta.y, delta.z)

    fn rotate(axis: Vec3, angle: f32):
        engine_transform_rotate(self.id, axis.x, axis.y, axis.z, angle)

    fn get_forward() -> Vec3:
        var buf = [0.0; 3]
        engine_transform_get_forward(self.id, buf.ptr())
        Vec3(buf[0], buf[1], buf[2])

    fn get_up() -> Vec3:
        var buf = [0.0; 3]
        engine_transform_get_up(self.id, buf.ptr())
        Vec3(buf[0], buf[1], buf[2])

    fn get_right() -> Vec3:
        var buf = [0.0; 3]
        engine_transform_get_right(self.id, buf.ptr())
        Vec3(buf[0], buf[1], buf[2])

