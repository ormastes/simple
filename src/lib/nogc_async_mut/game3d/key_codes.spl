# Game3D Key Codes - Engine-neutral keyboard and mouse button constants

# ============================================================================
# KeyCode - Engine-neutral key codes
# ============================================================================

enum KeyCode:
    Unknown = 0
    Space = 32
    Apostrophe = 39
    Comma = 44
    Minus = 45
    Period = 46
    Slash = 47
    Num0 = 48
    Num1 = 49
    Num2 = 50
    Num3 = 51
    Num4 = 52
    Num5 = 53
    Num6 = 54
    Num7 = 55
    Num8 = 56
    Num9 = 57
    A = 65
    B = 66
    C = 67
    D = 68
    E = 69
    F = 70
    G = 71
    H = 72
    I = 73
    J = 74
    K = 75
    L = 76
    M = 77
    N = 78
    O = 79
    P = 80
    Q = 81
    R = 82
    S = 83
    T = 84
    U = 85
    V = 86
    W = 87
    X = 88
    Y = 89
    Z = 90
    Escape = 256
    Enter = 257
    Tab = 258
    Backspace = 259
    Insert = 260
    Delete = 261
    Right = 262
    Left = 263
    Down = 264
    Up = 265
    PageUp = 266
    PageDown = 267
    Home = 268
    End = 269
    CapsLock = 280
    F1 = 290
    F2 = 291
    F3 = 292
    F4 = 293
    F5 = 294
    F6 = 295
    F7 = 296
    F8 = 297
    F9 = 298
    F10 = 299
    F11 = 300
    F12 = 301
    LeftShift = 340
    LeftCtrl = 341
    LeftAlt = 342
    RightShift = 344
    RightCtrl = 345
    RightAlt = 346

impl KeyCode:
    fn to_i32() -> i32:
        self as i32

    fn is_letter() -> bool:
        val v = self as i32
        v >= 65 and v <= 90

    fn is_digit() -> bool:
        val v = self as i32
        v >= 48 and v <= 57

    fn is_arrow() -> bool:
        match self:
            case Left | Right | Up | Down: true
            case _: false

    fn is_modifier() -> bool:
        match self:
            case LeftShift | LeftCtrl | LeftAlt | RightShift | RightCtrl | RightAlt: true
            case _: false

    fn is_function_key() -> bool:
        val v = self as i32
        v >= 290 and v <= 301

# ============================================================================
# MouseButton
# ============================================================================

enum MouseButton:
    Left = 0
    Right = 1
    Middle = 2
    Button4 = 3
    Button5 = 4

impl MouseButton:
    fn to_i32() -> i32:
        self as i32

