# Game3D Audio - Audio API wrappers
#
# Load, play, and control audio via engine_audio_* imports.

use .wasm_abi
use .entity.{Entity}
use .math.{Vec3}

# ============================================================================
# AudioClip Handle
# ============================================================================

class AudioClip:
    """Handle to a loaded audio clip."""
    id: i32

    static fn invalid() -> AudioClip:
        AudioClip(id: -1)

    static fn load(path: text) -> AudioClip:
        """Load an audio clip from a file path."""
        val id = engine_audio_load(path.ptr(), path.len())
        AudioClip(id: id)

    fn is_valid() -> bool:
        self.id >= 0

    fn play():
        """Play this audio clip."""
        if self.is_valid():
            engine_audio_play(self.id)

    fn stop():
        """Stop this audio clip."""
        if self.is_valid():
            engine_audio_stop(self.id)

    fn is_playing() -> bool:
        """Check if this clip is currently playing."""
        if not self.is_valid():
            return false
        engine_audio_is_playing(self.id) != 0

    fn set_volume(volume: f32):
        """Set volume (0.0 to 1.0)."""
        if self.is_valid():
            engine_audio_set_volume(self.id, volume)

    fn set_pitch(pitch: f32):
        """Set pitch multiplier (1.0 = normal)."""
        if self.is_valid():
            engine_audio_set_pitch(self.id, pitch)

    fn set_spatial(entity: Entity):
        """Attach this audio clip to an entity for spatial audio."""
        if self.is_valid():
            engine_audio_set_spatial(self.id, entity.id)

    fn set_position(pos: Vec3):
        """Set 3D position for spatial audio."""
        if self.is_valid():
            engine_audio_set_position(self.id, pos.x, pos.y, pos.z)

