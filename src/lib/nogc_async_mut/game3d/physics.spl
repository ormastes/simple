# Game3D Physics - Physics API wrappers
#
# Rigidbody, colliders, forces, raycasting via engine_physics_* imports.

use .wasm_abi
use .entity.{Entity}
use .math.{Vec3}

# ============================================================================
# RigidBody Type
# ============================================================================

enum BodyType:
    Static = 0
    Kinematic = 1
    Dynamic = 2

impl BodyType:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Collider Type (for primitives)
# ============================================================================

enum ColliderShape:
    Box = 0
    Sphere = 1
    Capsule = 2

# ============================================================================
# RaycastHit Result
# ============================================================================

class RaycastHit:
    """Result of a physics raycast."""
    entity: Entity
    point: Vec3
    normal: Vec3
    distance: f32
    hit: bool

# ============================================================================
# Physics Functions
# ============================================================================

fn add_rigidbody(entity: Entity, body_type: BodyType):
    """Add a rigidbody component to an entity."""
    engine_physics_add_rigidbody(entity.id, body_type.to_i32())

fn set_mass(entity: Entity, mass: f32):
    """Set the mass of an entity's rigidbody."""
    engine_physics_set_mass(entity.id, mass)

fn set_velocity(entity: Entity, velocity: Vec3):
    """Set the linear velocity of an entity's rigidbody."""
    engine_physics_set_velocity(entity.id, velocity.x, velocity.y, velocity.z)

fn get_velocity(entity: Entity) -> Vec3:
    """Get the linear velocity of an entity's rigidbody."""
    var buf = [0.0; 3]
    engine_physics_get_velocity(entity.id, buf.ptr())
    Vec3(buf[0], buf[1], buf[2])

fn add_force(entity: Entity, force: Vec3):
    """Apply a continuous force to an entity's rigidbody."""
    engine_physics_add_force(entity.id, force.x, force.y, force.z)

fn add_impulse(entity: Entity, impulse: Vec3):
    """Apply an instant impulse to an entity's rigidbody."""
    engine_physics_add_impulse(entity.id, impulse.x, impulse.y, impulse.z)

# ============================================================================
# Colliders
# ============================================================================

fn add_box_collider(entity: Entity, half_extents: Vec3):
    """Add a box collider to an entity."""
    engine_physics_add_collider_box(entity.id, half_extents.x, half_extents.y, half_extents.z)

fn add_sphere_collider(entity: Entity, radius: f32):
    """Add a sphere collider to an entity."""
    engine_physics_add_collider_sphere(entity.id, radius)

fn add_capsule_collider(entity: Entity, radius: f32, height: f32):
    """Add a capsule collider to an entity."""
    engine_physics_add_collider_capsule(entity.id, radius, height)

# ============================================================================
# Raycasting
# ============================================================================

fn raycast(origin: Vec3, direction: Vec3, max_distance: f32) -> RaycastHit:
    """Cast a ray and return the first hit."""
    # Out buffer: [entity_id, px, py, pz, nx, ny, nz, distance]
    var buf = [0.0; 8]
    val did_hit = engine_physics_raycast(
        origin.x, origin.y, origin.z,
        direction.x, direction.y, direction.z,
        max_distance, buf.ptr()
    )
    if did_hit != 0:
        return RaycastHit(
            entity: Entity(id: buf[0] as i32),
            point: Vec3(buf[1], buf[2], buf[3]),
            normal: Vec3(buf[4], buf[5], buf[6]),
            distance: buf[7],
            hit: true
        )
    RaycastHit(
        entity: Entity.invalid(),
        point: Vec3.zero(),
        normal: Vec3.zero(),
        distance: 0.0,
        hit: false
    )

# ============================================================================
# World Settings
# ============================================================================

fn set_gravity(gravity: Vec3):
    """Set the world gravity vector."""
    engine_physics_set_gravity(gravity.x, gravity.y, gravity.z)

fn set_collision_layer(entity: Entity, layer: i32, mask: i32):
    """Set collision layer and mask for an entity."""
    engine_physics_set_collision_layer(entity.id, layer, mask)

