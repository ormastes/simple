# Game3D - Cross-engine 3D game library for Simple → WASM
#
# @tag:stdlib
# @tag:game3d
# @tag:wasm
#
# Write game logic once in Simple, compile to WASM, run on Unity/Godot/Unreal.
# Uses opaque entity handles (i32) with engine-implemented imports.

# Re-exported from math.spl
use nogc_async_mut.game3d.math.{Vec2, Vec3, Vec4, Quat, Mat4, Transform, AABB, Ray}
use nogc_async_mut.game3d.math.{PI, TAU, DEG_TO_RAD, RAD_TO_DEG}
