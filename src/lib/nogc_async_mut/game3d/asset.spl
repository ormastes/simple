# Game3D Asset - Asset loading wrappers
#
# Load, query, and unload assets via engine_asset_* imports.

use .wasm_abi

# ============================================================================
# Asset Types
# ============================================================================

enum AssetType:
    Mesh = 0
    Texture = 1
    Material = 2
    Sound = 3
    Model = 4
    Scene = 5

impl AssetType:
    fn to_i32() -> i32:
        self as i32

# ============================================================================
# Asset Handle
# ============================================================================

class Asset:
    """Handle to a loaded engine asset."""
    id: i32
    asset_type: AssetType

    static fn invalid() -> Asset:
        Asset(id: -1, asset_type: AssetType.Mesh)

    static fn load(path: text, asset_type: AssetType) -> Asset:
        """Load an asset from a file path."""
        val id = engine_asset_load(path.ptr(), path.len(), asset_type.to_i32())
        Asset(id: id, asset_type: asset_type)

    static fn load_texture(path: text) -> Asset:
        """Load a texture asset (convenience)."""
        val id = engine_asset_load_texture(path.ptr(), path.len())
        Asset(id: id, asset_type: AssetType.Texture)

    fn is_valid() -> bool:
        self.id >= 0

    fn is_loaded() -> bool:
        """Check if the asset has finished loading."""
        if not self.is_valid():
            return false
        engine_asset_is_loaded(self.id) != 0

    fn unload():
        """Unload this asset and free engine resources."""
        if self.is_valid():
            engine_asset_unload(self.id)

