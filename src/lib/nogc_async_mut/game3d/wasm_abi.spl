# Game3D WASM ABI - Engine import declarations
#
# All 68 extern functions that the engine host must implement.
# These are imported from the "engine" WASM module.
# Entity handles are opaque i32 values managed by the host.

# ============================================================================
# Entity Management (8 functions)
# ============================================================================

extern fn engine_entity_create() -> i32
extern fn engine_entity_create_named(name_ptr: i32, name_len: i32) -> i32
extern fn engine_entity_destroy(entity: i32)
extern fn engine_entity_set_active(entity: i32, active: i32)
extern fn engine_entity_is_active(entity: i32) -> i32
extern fn engine_entity_set_parent(entity: i32, parent: i32)
extern fn engine_entity_set_name(entity: i32, name_ptr: i32, name_len: i32)
extern fn engine_entity_find_by_name(name_ptr: i32, name_len: i32) -> i32

# ============================================================================
# Transform (12 functions)
# ============================================================================

extern fn engine_transform_get_position(entity: i32, out_ptr: i32)
extern fn engine_transform_set_position(entity: i32, x: f32, y: f32, z: f32)
extern fn engine_transform_get_rotation(entity: i32, out_ptr: i32)
extern fn engine_transform_set_rotation(entity: i32, x: f32, y: f32, z: f32, w: f32)
extern fn engine_transform_get_scale(entity: i32, out_ptr: i32)
extern fn engine_transform_set_scale(entity: i32, x: f32, y: f32, z: f32)
extern fn engine_transform_look_at(entity: i32, x: f32, y: f32, z: f32)
extern fn engine_transform_translate(entity: i32, dx: f32, dy: f32, dz: f32)
extern fn engine_transform_rotate(entity: i32, axis_x: f32, axis_y: f32, axis_z: f32, angle: f32)
extern fn engine_transform_get_forward(entity: i32, out_ptr: i32)
extern fn engine_transform_get_up(entity: i32, out_ptr: i32)
extern fn engine_transform_get_right(entity: i32, out_ptr: i32)

