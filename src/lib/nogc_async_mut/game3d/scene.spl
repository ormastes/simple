# Game3D Scene - Scene graph operations via entity + transform
#
# High-level scene management built on entity handles.

use .entity.{Entity}
use .math.{Vec3, Quat, Transform}

# ============================================================================
# Scene Node (convenience wrapper around Entity)
# ============================================================================

class SceneNode:
    """Entity with scene graph convenience methods."""
    entity: Entity

    fn __init__(entity: Entity):
        self.entity = entity

    static fn create(name: text) -> SceneNode:
        SceneNode(entity: Entity.create_named(name))

    fn id() -> i32:
        self.entity.id

    fn destroy():
        self.entity.destroy()

    fn add_child(child: SceneNode):
        child.entity.set_parent(self.entity)

    fn set_position(pos: Vec3):
        self.entity.set_position(pos)

    fn get_position() -> Vec3:
        self.entity.get_position()

    fn set_rotation(rot: Quat):
        self.entity.set_rotation(rot)

    fn get_rotation() -> Quat:
        self.entity.get_rotation()

    fn set_scale(s: Vec3):
        self.entity.set_scale(s)

    fn get_scale() -> Vec3:
        self.entity.get_scale()

    fn look_at(target: Vec3):
        self.entity.look_at(target)

    fn translate(delta: Vec3):
        self.entity.translate(delta)

    fn rotate(axis: Vec3, angle: f32):
        self.entity.rotate(axis, angle)

    fn get_transform() -> Transform:
        Transform(
            position: self.entity.get_position(),
            rotation: self.entity.get_rotation(),
            scale_: self.entity.get_scale()
        )

    fn set_transform(t: Transform):
        self.entity.set_position(t.position)
        self.entity.set_rotation(t.rotation)
        self.entity.set_scale(t.scale_)

    fn set_active(active: bool):
        self.entity.set_active(active)

    fn is_active() -> bool:
        self.entity.is_active()

    fn forward() -> Vec3:
        self.entity.get_forward()

    fn up_dir() -> Vec3:
        self.entity.get_up()

    fn right_dir() -> Vec3:
        self.entity.get_right()

