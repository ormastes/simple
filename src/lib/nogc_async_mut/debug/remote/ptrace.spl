"""
# No-GC async ptrace debug

Compatibility facade over the no-GC sync backend.
"""

export use std.nogc_sync_mut.debug.remote.ptrace.{
    PTRACE_OK, PTRACE_ERROR, PtraceSession, ptrace_attach, ptrace_detach,
    ptrace_continue, ptrace_single_step, ptrace_wait_stop,
    ptrace_read_memory, ptrace_write_memory
}
