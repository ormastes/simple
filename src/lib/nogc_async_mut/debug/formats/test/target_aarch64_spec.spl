"""AArch64 target definition specification tests."""

use std.debug.remote.target.aarch64.Aarch64Target

describe "Aarch64Target":
    it "has 34 registers":
        val t = Aarch64Target.create()
        expect(t.register_count()).to_equal(34)

    it "maps x0 to index 0 and x30 to index 30":
        val t = Aarch64Target.create()
        expect(t.register_index("x0")).to_equal(0)
        expect(t.register_name(0)).to_equal("x0")
        expect(t.register_index("x30")).to_equal(30)
        expect(t.register_name(30)).to_equal("x30")

    it "maps sp to index 31 and pc to index 32":
        val t = Aarch64Target.create()
        expect(t.register_index("sp")).to_equal(31)
        expect(t.register_name(31)).to_equal("sp")
        expect(t.register_index("pc")).to_equal(32)
        expect(t.register_name(32)).to_equal("pc")

    it "maps cpsr to index 33":
        val t = Aarch64Target.create()
        expect(t.register_index("cpsr")).to_equal(33)
        expect(t.register_name(33)).to_equal("cpsr")

    it "returns 8-byte register size for all registers":
        val t = Aarch64Target.create()
        expect(t.register_size(0)).to_equal(8)
        expect(t.register_size(31)).to_equal(8)
        expect(t.register_size(33)).to_equal(8)

    it "reports Architecture.Arm64":
        val t = Aarch64Target.create()
        expect(t.arch().to_string()).to_equal("arm64")
        expect(t.name()).to_equal("AArch64")

    it "returns AAPCS64 arg registers x0-x7":
        val t = Aarch64Target.create()
        val args = t.arg_registers()
        expect(args.len()).to_equal(8)
        expect(args[0]).to_equal(0)
        expect(args[7]).to_equal(7)

    it "returns callee-saved registers x19-x28 and x29":
        val t = Aarch64Target.create()
        val saved = t.callee_saved_registers()
        expect(saved.len()).to_equal(11)
        expect(saved[0]).to_equal(19)
        expect(saved[9]).to_equal(28)
        expect(saved[10]).to_equal(29)

    it "returns correct pc sp fp indices":
        val t = Aarch64Target.create()
        expect(t.pc_register_index()).to_equal(32)
        expect(t.sp_register_index()).to_equal(31)
        expect(t.fp_register_index()).to_equal(29)
        expect(t.return_register_index()).to_equal(0)

    it "returns BRK #0 breakpoint instruction":
        val t = Aarch64Target.create()
        val brk = t.breakpoint_instruction()
        expect(brk.len()).to_equal(4)
        expect(brk[0]).to_equal(0x00)
        expect(brk[1]).to_equal(0x00)
        expect(brk[2]).to_equal(0x20)
        expect(brk[3]).to_equal(0xD4)

    it "returns unknown for out-of-range register":
        val t = Aarch64Target.create()
        expect(t.register_name(99)).to_equal("unknown")
        expect(t.register_name(-1)).to_equal("unknown")
        expect(t.register_index("nonexistent")).to_equal(-1)
