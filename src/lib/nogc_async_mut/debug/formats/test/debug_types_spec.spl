"""Debug types specification tests."""

use std.debug.formats.debug_types.{SourceLocation, DebugLineEntry, DebugFunction, DebugCompilationUnit, DebugFormatKind}

describe "Debug Types":
    it "creates a valid SourceLocation":
        val loc = SourceLocation(file: "main.spl", line: 42, column: 5)
        expect(loc.file).to_equal("main.spl")
        expect(loc.line).to_equal(42)
        expect(loc.column).to_equal(5)
        expect(loc.is_valid()).to_equal(true)
        expect(loc.to_string()).to_equal("main.spl:42:5")

    it "formats SourceLocation without column":
        val loc = SourceLocation(file: "test.spl", line: 10, column: 0)
        expect(loc.to_string()).to_equal("test.spl:10")

    it "detects invalid SourceLocation":
        val loc = SourceLocation(file: "", line: 0, column: 0)
        expect(loc.is_valid()).to_equal(false)

    it "DebugFunction contains_address":
        val func = DebugFunction(name: "main", low_pc: 0x1000, high_pc: 0x1100, comp_unit_index: 0)
        expect(func.contains_address(0x1000)).to_equal(true)
        expect(func.contains_address(0x1050)).to_equal(true)
        expect(func.contains_address(0x1100)).to_equal(false)
        expect(func.contains_address(0x0fff)).to_equal(false)
        expect(func.size()).to_equal(0x100)

    it "DebugCompilationUnit contains_address":
        val cu = DebugCompilationUnit(
            name: "main.spl", comp_dir: "/src", language: 0,
            low_pc: 0x1000, high_pc: 0x2000,
            line_entries: [], functions: [],
        )
        expect(cu.contains_address(0x1500)).to_equal(true)
        expect(cu.contains_address(0x2000)).to_equal(false)

    it "DebugFormatKind to_string":
        expect(DebugFormatKind.Dwarf.to_string()).to_equal("DWARF")
        expect(DebugFormatKind.Pdb.to_string()).to_equal("PDB")
        expect(DebugFormatKind.Dsym.to_string()).to_equal("dSYM")
