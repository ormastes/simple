# Debug Format Types
# Format-agnostic types shared across DWARF, PDB, and dSYM parsers.

struct SourceLocation:
    file: text
    line: i64
    column: i64

    fn to_string() -> text:
        if self.column > 0:
            return "{self.file}:{self.line}:{self.column}"
        return "{self.file}:{self.line}"

    fn is_valid() -> bool:
        self.file.len() > 0 and self.line > 0

struct DebugLineEntry:
    address: i64
    location: SourceLocation
    is_stmt: bool
    end_sequence: bool
    prologue_end: bool
    epilogue_begin: bool

struct DebugFunction:
    name: text
    low_pc: i64
    high_pc: i64
    comp_unit_index: i64

    fn contains_address(addr: i64) -> bool:
        addr >= self.low_pc and addr < self.high_pc

    fn size() -> i64:
        self.high_pc - self.low_pc

struct DebugVariable:
    name: text
    type_name: text
    location_expr: [u8]
    is_parameter: bool

struct DebugCompilationUnit:
    name: text
    comp_dir: text
    language: i64
    low_pc: i64
    high_pc: i64
    line_entries: [DebugLineEntry]
    functions: [DebugFunction]

    fn contains_address(addr: i64) -> bool:
        addr >= self.low_pc and addr < self.high_pc

enum DebugFormatKind:
    Dwarf
    Pdb
    Dsym

    fn to_string() -> text:
        match self:
            Dwarf: "DWARF"
            Pdb: "PDB"
            Dsym: "dSYM"
