# Gizmo3D — 3D transform handles with X/Y/Z axes
#
# Provides translate/rotate/scale gizmo for 3D editing with per-axis
# drag tracking, snapping, and delta computation.

use std.common.engine.math3d.{Vec3}

# ============================================================================
# GizmoMode3D — which transform the 3D gizmo controls
# ============================================================================

enum GizmoMode3D:
    Translate3D
    Rotate3D
    Scale3D

impl GizmoMode3D:
    fn to_text(self) -> text:
        match self:
            GizmoMode3D.Translate3D => "Translate3D"
            GizmoMode3D.Rotate3D => "Rotate3D"
            GizmoMode3D.Scale3D => "Scale3D"

# ============================================================================
# GizmoAxis3D — which axis or plane is active
# ============================================================================

enum GizmoAxis3D:
    Axis3DNone
    Axis3DX
    Axis3DY
    Axis3DZ
    Axis3DXY
    Axis3DXZ
    Axis3DYZ

impl GizmoAxis3D:
    fn to_text(self) -> text:
        match self:
            GizmoAxis3D.Axis3DNone => "None"
            GizmoAxis3D.Axis3DX => "X"
            GizmoAxis3D.Axis3DY => "Y"
            GizmoAxis3D.Axis3DZ => "Z"
            GizmoAxis3D.Axis3DXY => "XY"
            GizmoAxis3D.Axis3DXZ => "XZ"
            GizmoAxis3D.Axis3DYZ => "YZ"

    fn eq(self, other: GizmoAxis3D) -> bool:
        self.to_text() == other.to_text()

    fn is_none(self) -> bool:
        self.eq(GizmoAxis3D.Axis3DNone)

# ============================================================================
# GizmoConfig3D — appearance and snapping settings for 3D gizmo
# ============================================================================

struct GizmoConfig3D:
    handle_size: f64
    axis_length: f64
    snap_translate: f64
    snap_rotate_degrees: f64
    snap_scale: f64
    snapping: bool

fn default_gizmo_config_3d() -> GizmoConfig3D:
    """Default config: 8px handles, 60px axes, no snapping."""
    GizmoConfig3D(
        handle_size: 8.0,
        axis_length: 60.0,
        snap_translate: 1.0,
        snap_rotate_degrees: 15.0,
        snap_scale: 0.1,
        snapping: false
    )

# ============================================================================
# GizmoDelta3D — result of a completed 3D drag operation
# ============================================================================

struct GizmoDelta3D:
    mode: GizmoMode3D
    dx: f64
    dy: f64
    dz: f64
    d_rotation_x: f64
    d_rotation_y: f64
    d_rotation_z: f64
    d_scale_x: f64
    d_scale_y: f64
    d_scale_z: f64

impl GizmoDelta3D:
    static fn zero() -> GizmoDelta3D:
        """A delta with no change."""
        GizmoDelta3D(
            mode: GizmoMode3D.Translate3D,
            dx: 0.0, dy: 0.0, dz: 0.0,
            d_rotation_x: 0.0, d_rotation_y: 0.0, d_rotation_z: 0.0,
            d_scale_x: 0.0, d_scale_y: 0.0, d_scale_z: 0.0
        )

    fn has_change(self) -> bool:
        """Return true if any component is non-zero."""
        val threshold = 0.0001
        var adx = self.dx
        if adx < 0.0:
            adx = -adx
        var ady = self.dy
        if ady < 0.0:
            ady = -ady
        var adz = self.dz
        if adz < 0.0:
            adz = -adz
        var arx = self.d_rotation_x
        if arx < 0.0:
            arx = -arx
        var ary = self.d_rotation_y
        if ary < 0.0:
            ary = -ary
        var arz = self.d_rotation_z
        if arz < 0.0:
            arz = -arz
        var asx = self.d_scale_x
        if asx < 0.0:
            asx = -asx
        var asy = self.d_scale_y
        if asy < 0.0:
            asy = -asy
        var asz = self.d_scale_z
        if asz < 0.0:
            asz = -asz
        (adx > threshold or ady > threshold or adz > threshold or
         arx > threshold or ary > threshold or arz > threshold or
         asx > threshold or asy > threshold or asz > threshold)

# ============================================================================
# snap_value — round to nearest multiple
# ============================================================================

fn snap_value(value: f64, snap: f64) -> f64:
    """Round value to the nearest multiple of snap."""
    if snap < 0.000001:
        return value
    # floor(value / snap + 0.5) * snap
    val ratio = value / snap
    # Compute floor: integer truncation toward negative infinity
    var floored = ratio
    # Truncate toward zero
    var truncated = ratio - (ratio % 1.0)
    # Adjust for negative: if ratio is negative and not exact integer, subtract 1
    if ratio < 0.0 and (ratio % 1.0) != 0.0:
        truncated = truncated - 1.0
    val rounded = truncated + 1.0
    # Actually simpler: round = floor(ratio + 0.5) * snap
    val shifted = ratio + 0.5
    var shifted_trunc = shifted - (shifted % 1.0)
    if shifted < 0.0 and (shifted % 1.0) != 0.0:
        shifted_trunc = shifted_trunc - 1.0
    shifted_trunc * snap

# ============================================================================
# Gizmo3D — interactive 3D transform manipulator
# ============================================================================

class Gizmo3D:
    mode: GizmoMode3D
    active_axis: GizmoAxis3D
    config: GizmoConfig3D
    dragging: bool
    drag_start_x: f64
    drag_start_y: f64
    drag_current_x: f64
    drag_current_y: f64
    origin_x: f64
    origin_y: f64
    origin_z: f64

impl Gizmo3D:
    static fn new() -> Gizmo3D:
        """Create a 3D gizmo in translate mode at the origin."""
        Gizmo3D(
            mode: GizmoMode3D.Translate3D,
            active_axis: GizmoAxis3D.Axis3DNone,
            config: default_gizmo_config_3d(),
            dragging: false,
            drag_start_x: 0.0,
            drag_start_y: 0.0,
            drag_current_x: 0.0,
            drag_current_y: 0.0,
            origin_x: 0.0,
            origin_y: 0.0,
            origin_z: 0.0
        )

    me set_mode(mode: GizmoMode3D):
        """Switch gizmo mode (translate/rotate/scale)."""
        self.mode = mode

    me set_origin(x: f64, y: f64, z: f64):
        """Move the gizmo to a new origin."""
        self.origin_x = x
        self.origin_y = y
        self.origin_z = z

    me begin_drag(screen_x: f64, screen_y: f64, axis: GizmoAxis3D):
        """Start a drag interaction on the specified axis."""
        self.dragging = true
        self.active_axis = axis
        self.drag_start_x = screen_x
        self.drag_start_y = screen_y
        self.drag_current_x = screen_x
        self.drag_current_y = screen_y

    me update_drag(screen_x: f64, screen_y: f64):
        """Update the current drag position."""
        self.drag_current_x = screen_x
        self.drag_current_y = screen_y

    me end_drag() -> GizmoDelta3D:
        """End the drag and compute the resulting delta."""
        self.dragging = false
        val raw_dx = self.drag_current_x - self.drag_start_x
        val raw_dy = self.drag_current_y - self.drag_start_y

        match self.mode:
            GizmoMode3D.Translate3D:
                # Map screen drag to axis-constrained translation
                var dx = 0.0
                var dy = 0.0
                var dz = 0.0
                match self.active_axis:
                    GizmoAxis3D.Axis3DX:
                        dx = raw_dx
                    GizmoAxis3D.Axis3DY:
                        dy = -raw_dy
                    GizmoAxis3D.Axis3DZ:
                        dz = raw_dx
                    GizmoAxis3D.Axis3DXY:
                        dx = raw_dx
                        dy = -raw_dy
                    GizmoAxis3D.Axis3DXZ:
                        dx = raw_dx
                        dz = -raw_dy
                    GizmoAxis3D.Axis3DYZ:
                        dy = -raw_dy
                        dz = raw_dx
                    _ =>
                        pass_dn
                if self.config.snapping:
                    dx = snap_value(dx, self.config.snap_translate)
                    dy = snap_value(dy, self.config.snap_translate)
                    dz = snap_value(dz, self.config.snap_translate)
                GizmoDelta3D(
                    mode: GizmoMode3D.Translate3D,
                    dx: dx, dy: dy, dz: dz,
                    d_rotation_x: 0.0, d_rotation_y: 0.0, d_rotation_z: 0.0,
                    d_scale_x: 0.0, d_scale_y: 0.0, d_scale_z: 0.0
                )
            GizmoMode3D.Rotate3D:
                # Compute rotation angle from drag distance
                val dist = (raw_dx * raw_dx + raw_dy * raw_dy) ** 0.5
                var angle = dist * 0.9
                if raw_dx < 0.0:
                    angle = -angle
                if self.config.snapping:
                    angle = snap_value(angle, self.config.snap_rotate_degrees)
                var rx = 0.0
                var ry = 0.0
                var rz = 0.0
                match self.active_axis:
                    GizmoAxis3D.Axis3DX:
                        rx = angle
                    GizmoAxis3D.Axis3DY:
                        ry = angle
                    GizmoAxis3D.Axis3DZ:
                        rz = angle
                    _ =>
                        ry = angle
                GizmoDelta3D(
                    mode: GizmoMode3D.Rotate3D,
                    dx: 0.0, dy: 0.0, dz: 0.0,
                    d_rotation_x: rx, d_rotation_y: ry, d_rotation_z: rz,
                    d_scale_x: 0.0, d_scale_y: 0.0, d_scale_z: 0.0
                )
            GizmoMode3D.Scale3D:
                var sx = raw_dx / 100.0
                var sy = raw_dy / 100.0
                var sz = 0.0
                if self.config.snapping:
                    sx = snap_value(sx, self.config.snap_scale)
                    sy = snap_value(sy, self.config.snap_scale)
                var dsx = 0.0
                var dsy = 0.0
                var dsz = 0.0
                match self.active_axis:
                    GizmoAxis3D.Axis3DX:
                        dsx = sx
                    GizmoAxis3D.Axis3DY:
                        dsy = -sy
                    GizmoAxis3D.Axis3DZ:
                        dsz = sx
                    GizmoAxis3D.Axis3DXY:
                        dsx = sx
                        dsy = -sy
                    GizmoAxis3D.Axis3DXZ:
                        dsx = sx
                        dsz = -sy
                    GizmoAxis3D.Axis3DYZ:
                        dsy = -sy
                        dsz = sx
                    _ =>
                        # Uniform scale on all axes
                        dsx = sx
                        dsy = sx
                        dsz = sx
                GizmoDelta3D(
                    mode: GizmoMode3D.Scale3D,
                    dx: 0.0, dy: 0.0, dz: 0.0,
                    d_rotation_x: 0.0, d_rotation_y: 0.0, d_rotation_z: 0.0,
                    d_scale_x: dsx, d_scale_y: dsy, d_scale_z: dsz
                )

    me cancel_drag():
        """Cancel the current drag without producing a delta."""
        self.dragging = false
        self.active_axis = GizmoAxis3D.Axis3DNone

    fn is_active(self) -> bool:
        """Return true if a drag is in progress."""
        self.dragging
