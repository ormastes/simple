# QUIC Provider — Availability boundary for quiche/SFFI runtime
#
# Mirrors the TLS ECH provider pattern (ech.spl): pure-Simple types that
# describe QUIC/H3 capabilities without importing any extern symbols.
# Native quiche calls go through quic_connection.spl only when the provider
# reports Available.
#
# This module is safe to import in pure tests — no transitive externs.

# ============================================================================
# Provider availability (mirrors EchDecision pattern from ech.spl)
# ============================================================================

enum QuicProvider:
    """Runtime availability of the native quiche QUIC implementation."""
    # quiche library is linked and ready.
    Available
    # quiche library is not linked; calls would fail.
    Unavailable
    # Stub mode — types exist but no real I/O.
    Stub

fn quic_provider_check() -> QuicProvider:
    """Check whether the native quiche provider is available.

    In pure-Simple builds this always returns Unavailable.  A runtime
    that links quiche overrides this at startup.  Callers should inspect
    the result before calling any function in quic_connection.spl.
    """
    QuicProvider.Unavailable

fn quic_provider_label(p: QuicProvider) -> text:
    """Human-readable label for a provider state."""
    match p:
        case QuicProvider.Available:
            "available"
        case QuicProvider.Unavailable:
            "unavailable"
        case QuicProvider.Stub:
            "stub"

fn quic_provider_is_usable(p: QuicProvider) -> bool:
    """True when the provider can actually perform I/O."""
    match p:
        case QuicProvider.Available:
            true
        case QuicProvider.Unavailable:
            false
        case QuicProvider.Stub:
            false

# ============================================================================
# QUIC Transport Parameters (RFC 9000 Section 18)
# ============================================================================

class QuicTransportParams:
    """Subset of QUIC transport parameters that the wrapper layer exposes.

    All values are i64 to match the wire varint encoding.  Fields default
    to RFC 9000 initial values via quic_transport_params_default().
    """
    max_idle_timeout: i64
    max_udp_payload_size: i64
    initial_max_data: i64
    initial_max_stream_data_bidi_local: i64
    initial_max_stream_data_bidi_remote: i64
    initial_max_stream_data_uni: i64
    initial_max_streams_bidi: i64
    initial_max_streams_uni: i64

fn quic_transport_params_default() -> QuicTransportParams:
    """RFC 9000 Section 18 defaults."""
    QuicTransportParams {
        max_idle_timeout: 30000,
        max_udp_payload_size: 1200,
        initial_max_data: 1048576,
        initial_max_stream_data_bidi_local: 262144,
        initial_max_stream_data_bidi_remote: 262144,
        initial_max_stream_data_uni: 262144,
        initial_max_streams_bidi: 100,
        initial_max_streams_uni: 100
    }

# ============================================================================
# H3 frame type constants (mirrored from h3_frame.spl — no import needed)
# ============================================================================

val H3_PROVIDER_FRAME_DATA: i64        = 0x00
val H3_PROVIDER_FRAME_HEADERS: i64     = 0x01
val H3_PROVIDER_FRAME_CANCEL_PUSH: i64 = 0x03
val H3_PROVIDER_FRAME_SETTINGS: i64    = 0x04
val H3_PROVIDER_FRAME_PUSH_PROMISE: i64 = 0x05
val H3_PROVIDER_FRAME_GOAWAY: i64      = 0x07
val H3_PROVIDER_FRAME_MAX_PUSH_ID: i64 = 0x0d

# ============================================================================
# Provider-aware result type
# ============================================================================

enum QuicProviderError:
    """Errors returned when the provider is not available."""
    NativeUnavailable
    StubOnly
    InvalidParam

class QuicProviderResult:
    """Result of a provider-gated operation."""
    ok: bool
    error: QuicProviderError?
    provider: QuicProvider

fn quic_provider_gate(p: QuicProvider) -> QuicProviderResult:
    """Gate an operation on provider availability.

    Returns ok=true only when p is Available.  Callers use this before
    dispatching to quic_connection functions.
    """
    match p:
        case QuicProvider.Available:
            QuicProviderResult {
                ok: true,
                error: nil,
                provider: p
            }
        case QuicProvider.Unavailable:
            QuicProviderResult {
                ok: false,
                error: Some(QuicProviderError.NativeUnavailable),
                provider: p
            }
        case QuicProvider.Stub:
            QuicProviderResult {
                ok: false,
                error: Some(QuicProviderError.StubOnly),
                provider: p
            }

# ============================================================================
# Exports
# ============================================================================

export QuicProvider, quic_provider_check, quic_provider_label, quic_provider_is_usable
export QuicTransportParams, quic_transport_params_default
export H3_PROVIDER_FRAME_DATA, H3_PROVIDER_FRAME_HEADERS
export H3_PROVIDER_FRAME_CANCEL_PUSH, H3_PROVIDER_FRAME_SETTINGS
export H3_PROVIDER_FRAME_PUSH_PROMISE, H3_PROVIDER_FRAME_GOAWAY
export H3_PROVIDER_FRAME_MAX_PUSH_ID
export QuicProviderError, QuicProviderResult, quic_provider_gate
