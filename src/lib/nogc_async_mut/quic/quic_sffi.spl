# QUIC SFFI — extern declarations for the quiche C library
#
# Binds to the quiche (Cloudflare) QUIC implementation via SFFI.
# All handles are opaque i64 (pointer-sized integers on the C side).
# Caller is responsible for handle lifecycle; no GC on these values.
#
# Reference: https://docs.quic.tech/quiche/

# ============================================================================
# Configuration
# ============================================================================

extern fn rt_quic_config_new(version: i64) -> i64
extern fn rt_quic_config_set_max_idle_timeout(config: i64, timeout: i64) -> i64
extern fn rt_quic_config_set_initial_max_streams_bidi(config: i64, n: i64) -> i64

# ============================================================================
# Connection lifecycle
# ============================================================================

extern fn rt_quic_accept(scid: text, config: i64) -> i64
extern fn rt_quic_connect(server_name: text, scid: text, config: i64) -> i64
extern fn rt_quic_conn_close(conn: i64, app: i64, reason: text) -> i64

# ============================================================================
# I/O — UDP datagram exchange
# ============================================================================

extern fn rt_quic_recv(conn: i64, buf: text, buf_len: i64) -> i64
extern fn rt_quic_send(conn: i64, buf: text, buf_len: i64) -> i64

# ============================================================================
# Stream I/O
# ============================================================================

extern fn rt_quic_stream_recv(conn: i64, stream_id: i64, buf: text, buf_len: i64) -> i64
extern fn rt_quic_stream_send(conn: i64, stream_id: i64, buf: text, buf_len: i64, fin: i64) -> i64

# ============================================================================
# Timers
# ============================================================================

extern fn rt_quic_timeout_as_millis(conn: i64) -> i64
extern fn rt_quic_on_timeout(conn: i64) -> i64

# ============================================================================
# Connection status predicates
# ============================================================================

extern fn rt_quic_is_established(conn: i64) -> i64
extern fn rt_quic_is_closed(conn: i64) -> i64
