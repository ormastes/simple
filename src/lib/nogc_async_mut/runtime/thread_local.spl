"""
# No-GC Async thread-local runtime facade

Compatibility facade over the no-GC sync runtime hook owner. Thread-local
storage is a synchronous runtime boundary, but async-family allocator adapters
import this facade so higher runtime families route through no-GC async before
reaching the hook owner.
"""

export use std.nogc_sync_mut.runtime.thread_local.{
    rt_thread_local_new, rt_thread_local_get, rt_thread_local_set,
    rt_thread_local_free
}
