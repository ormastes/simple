"""
# No-GC Async Package FFI

Compatibility facade over the no-GC sync package FFI backend. Package archive
and filesystem operations are synchronous runtime calls, so the async family
reuses the shared no-GC declaration owner instead of redeclaring hooks.
"""

export use std.nogc_sync_mut.package_ffi.{
    calculate_checksum, create_tarball, extract_tarball, get_file_size,
    copy_file, mkdir_all, remove_dir_all, create_symlink, set_permissions,
    path_exists, is_directory
}
