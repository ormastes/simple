# Proton Launcher — Steam app launch plan builder (M2, REQ-10).
#
# proton_launcher_plan returns a structured plan record describing how to
# launch a Steam app through Proton. In interpreter mode the plan is built
# entirely from the input arguments without spawning any process.
#
# @cover proton_launcher

# ============================================================================
# Result type
# ============================================================================

struct ProtonLaunchPlan:
    """A structured Proton launch plan."""
    status:     text   # "planned" — plan built; "error" — invalid input
    app_id:     text   # Steam app ID string
    exe:        text   # Executable path inside the app depot
    args:       [text] # Additional arguments
    proton_ver: text   # Proton version tag (default "latest")
    runtime:    text   # pressure-vessel runtime path

fn _plan_error(msg: text) -> ProtonLaunchPlan:
    ProtonLaunchPlan(
        status:     "error",
        app_id:     "",
        exe:        "",
        args:       [],
        proton_ver: "",
        runtime:    ""
    )

# ============================================================================
# Public API
# ============================================================================

pub fn proton_launcher_plan(app_id: text, exe: text, args: [text]) -> ProtonLaunchPlan:
    """Build a Proton launch plan for the given Steam app.

    Does NOT spawn any process. Returns a plan record that the caller can
    inspect or pass to proton_launcher_exec().

    Args:
        app_id: Steam app ID (e.g. "480" for Space War)
        exe:    Executable path within the depot (e.g. "hl2.exe")
        args:   Additional command-line arguments

    Returns:
        ProtonLaunchPlan with status="planned" on success.
    """
    if app_id == "":
        return _plan_error("empty app_id")
    if exe == "":
        return _plan_error("empty exe")
    ProtonLaunchPlan(
        status:     "planned",
        app_id:     app_id,
        exe:        exe,
        args:       args,
        proton_ver: "latest",
        runtime:    "/run/pressure-vessel/runtime"
    )

pub fn proton_launcher_exec(plan: ProtonLaunchPlan) -> bool:
    """Execute a previously built launch plan.

    In interpreter mode returns true (no actual process spawned).

    Args:
        plan: ProtonLaunchPlan from proton_launcher_plan()

    Returns:
        true if plan was valid and submission succeeded.
    """
    if plan.status != "planned":
        return false
    true
