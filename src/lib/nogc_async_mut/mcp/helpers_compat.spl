fn make_resource_link_content_full(uri: String, name: String, title: String, description: String, mime_type: String, size: Int) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "type", value: js(value: "resource_link")))
    parts.push(",")
    parts.push(jp(key: "uri", value: js(value: escape_json(uri))))
    parts.push(",")
    parts.push(jp(key: "name", value: js(value: escape_json(name))))
    if title != "":
        parts.push(",")
        parts.push(jp(key: "title", value: js(value: escape_json(title))))
    if description != "":
        parts.push(",")
        parts.push(jp(key: "description", value: js(value: escape_json(description))))
    if mime_type != "":
        parts.push(",")
        parts.push(jp(key: "mimeType", value: js(value: mime_type)))
    if size >= 0:
        parts.push(",")
        parts.push(jp(key: "size", value: size.to_string()))
    parts.push(RB())
    parts.join("")

fn make_embedded_resource_content(uri: String, text_content: String, mime_type: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "uri", value: js(value: escape_json(uri))))
    parts.push(",")
    parts.push(jp(key: "text", value: js(value: escape_json(text_content))))
    if mime_type != "":
        parts.push(",")
        parts.push(jp(key: "mimeType", value: js(value: mime_type)))
    parts.push(RB())
    jo2(p1: jp(key: "type", value: js(value: "resource")), p2: jp(key: "resource", value: parts.join("")))

fn make_content_annotations(audience: [String], priority: String, last_modified: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    var first = true
    if audience.len() > 0:
        var arr_parts: [text] = []
        for a in audience:
            arr_parts.push(js(value: a))
        val arr = "[" + arr_parts.join(",") + "]"
        parts.push(jp(key: "audience", value: arr))
        first = false
    if priority != "":
        if not first:
            parts.push(",")
        parts.push(jp(key: "priority", value: priority))
        first = false
    if last_modified != "":
        if not first:
            parts.push(",")
        parts.push(jp(key: "lastModified", value: js(value: last_modified)))
    parts.push(RB())
    parts.join("")

fn make_tool_result_with_structured(id: String, content: String, structured_content: String) -> String:
    val text_obj = jo2(p1: jp(key: "type", value: js(value: "text")), p2: jp(key: "text", value: js(value: escape_json(content))))
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "content", value: "[" + text_obj + "]"))
    parts.push(",")
    parts.push(jp(key: "structuredContent", value: structured_content))
    parts.push(RB())
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "result", value: parts.join("")))

fn make_tool_schema_with_output(name: String, desc: String, properties_json: String, required_json: String, output_schema: String, read_only: Bool, destructive: Bool, idempotent: Bool) -> String:
    val schema = jo3(p1: jp(key: "type", value: js(value: "object")), p2: jp(key: "properties", value: properties_json), p3: jp(key: "required", value: required_json))

    var annot_parts: [text] = []
    annot_parts.push(LB())
    var ro = "false"
    if read_only:
        ro = "true"
    annot_parts.push(jp(key: "readOnlyHint", value: ro))
    annot_parts.push(",")
    var dest = "false"
    if destructive:
        dest = "true"
    annot_parts.push(jp(key: "destructiveHint", value: dest))
    annot_parts.push(",")
    var idemp = "false"
    if idempotent:
        idemp = "true"
    annot_parts.push(jp(key: "idempotentHint", value: idemp))
    annot_parts.push(",")
    annot_parts.push(jp(key: "openWorldHint", value: "false"))
    annot_parts.push(RB())
    val annot = annot_parts.join("")

    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "name", value: js(value: name)))
    parts.push(",")
    parts.push(jp(key: "description", value: js(value: desc)))
    parts.push(",")
    parts.push(jp(key: "inputSchema", value: schema))
    parts.push(",")
    parts.push(jp(key: "outputSchema", value: output_schema))
    parts.push(",")
    parts.push(jp(key: "annotations", value: annot))
    parts.push(RB())
    parts.join("")

# --- Server-to-client request helpers ---

fn make_server_request(id: String, method: String, params: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "jsonrpc", value: js(value: "2.0")))
    parts.push(",")
    parts.push(jp(key: "id", value: id))
    parts.push(",")
    parts.push(jp(key: "method", value: js(value: method)))
    parts.push(",")
    parts.push(jp(key: "params", value: params))
    parts.push(RB())
    parts.join("")

fn make_sampling_request(id: String, messages: String, model_prefs: String, system_prompt: String, max_tokens: Int) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "messages", value: messages))
    if model_prefs != "":
        parts.push(",")
        parts.push(jp(key: "modelPreferences", value: model_prefs))
    if system_prompt != "":
        parts.push(",")
        parts.push(jp(key: "systemPrompt", value: js(value: escape_json(system_prompt))))
    parts.push(",")
    parts.push(jp(key: "maxTokens", value: max_tokens.to_string()))
    parts.push(RB())
    make_server_request(id: id, method: "sampling/createMessage", params: parts.join(""))

fn make_sampling_request_full(id: String, messages: String, model_prefs: String, system_prompt: String, max_tokens: Int, temperature: String, stop_sequences_json: String, metadata_json: String, include_context: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "messages", value: messages))
    if model_prefs != "":
        parts.push(",")
        parts.push(jp(key: "modelPreferences", value: model_prefs))
    if system_prompt != "":
        parts.push(",")
        parts.push(jp(key: "systemPrompt", value: js(value: escape_json(system_prompt))))
    parts.push(",")
    parts.push(jp(key: "maxTokens", value: max_tokens.to_string()))
    if temperature != "":
        parts.push(",")
        parts.push(jp(key: "temperature", value: temperature))
    if stop_sequences_json != "" and stop_sequences_json != "[]":
        parts.push(",")
        parts.push(jp(key: "stopSequences", value: stop_sequences_json))
    if metadata_json != "":
        parts.push(",")
        parts.push(jp(key: "metadata", value: metadata_json))
    if include_context != "":
        parts.push(",")
        parts.push(jp(key: "includeContext", value: js(value: include_context)))
    parts.push(RB())
    make_server_request(id: id, method: "sampling/createMessage", params: parts.join(""))

fn make_elicitation_request(id: String, message: String, schema: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "message", value: js(value: escape_json(message))))
    parts.push(",")
    parts.push(jp(key: "requestedSchema", value: schema))
    parts.push(RB())
    make_server_request(id: id, method: "elicitation/create", params: parts.join(""))

# --- Tool registration helper ---

fn register_tool(name: String, desc: String, param_names: [String], param_descs: [String], required_names: [String], read_only: Bool, destructive: Bool, idempotent: Bool) -> String:
    var prop_parts: [text] = []
    var i = 0
    for pname in param_names:
        var pdesc = ""
        if i < param_descs.len():
            pdesc = param_descs[i]
        val prop = jo2(p1: jp(key: "type", value: js(value: "string")), p2: jp(key: "description", value: js(value: pdesc)))
        prop_parts.push(jp(key: pname, value: prop))
        i = i + 1
    val props = LB() + prop_parts.join(",") + RB()

    var req_parts: [text] = []
    for rname in required_names:
        req_parts.push(js(rname))
    val req_arr = "[" + req_parts.join(",") + "]"

    make_tool_schema_multi(name: name, desc: desc, properties_json: props, required_json: req_arr, read_only: read_only, destructive: destructive, idempotent: idempotent)

# --- Content type detection helpers ---

fn detect_file_content_type(path: String) -> String:
    if path.ends_with(".png") or path.ends_with(".jpg") or path.ends_with(".jpeg") or path.ends_with(".gif") or path.ends_with(".svg") or path.ends_with(".webp") or path.ends_with(".ico") or path.ends_with(".bmp"):
        return "image"
    if path.ends_with(".wav") or path.ends_with(".mp3") or path.ends_with(".ogg") or path.ends_with(".flac"):
        return "audio"
    "text"

fn detect_mime_type(path: String) -> String:
    if path.ends_with(".png"):
        return "image/png"
    if path.ends_with(".jpg") or path.ends_with(".jpeg"):
        return "image/jpeg"
    if path.ends_with(".gif"):
        return "image/gif"
    if path.ends_with(".svg"):
        return "image/svg+xml"
    if path.ends_with(".webp"):
        return "image/webp"
    if path.ends_with(".ico"):
        return "image/x-icon"
    if path.ends_with(".bmp"):
        return "image/bmp"
    if path.ends_with(".wav"):
        return "audio/wav"
    if path.ends_with(".mp3"):
        return "audio/mpeg"
    if path.ends_with(".ogg"):
        return "audio/ogg"
    if path.ends_with(".flac"):
        return "audio/flac"
    if path.ends_with(".spl"):
        return "text/x-simple"
    if path.ends_with(".json"):
        return "application/json"
    if path.ends_with(".md"):
        return "text/markdown"
    if path.ends_with(".html"):
        return "text/html"
    if path.ends_with(".css"):
        return "text/css"
    if path.ends_with(".js"):
        return "text/javascript"
    "text/plain"

# --- Send notification over stdio ---

fn send_notification_message(notification: String):
    var parts: [text] = []
    parts.push("Content-Length: ")
    parts.push(notification.len().to_string())
    parts.push("\r{NL}\r{NL}")
    print_raw(parts.join(""))
    print_raw(notification)

fn send_log(level: String, data: String, logger: String, current_log_level: Int):
    val msg_level = log_level_to_int(level)
    if current_log_level < 0:
        return
    if msg_level < current_log_level:
        return
    val notification = make_log_notification(level: level, data: data, logger: logger)
    send_notification_message(notification)

fn send_progress(token: String, progress: Int, total: Int, message: String):
    val notification = make_progress_notification(token: token, progress: progress, total: total, message: message)
    send_notification_message(notification)

fn send_resource_updated(uri: String):
    val notification = make_resource_updated_notification(uri: uri)
    send_notification_message(notification)

# --- Single-property tool schema builder ---

fn make_tool_schema(name: String, desc: String, prop_name: String, prop_desc: String, required: Bool, read_only: Bool, destructive: Bool, idempotent: Bool) -> String:
    val prop = jo2(p1: jp(key: "type", value: js(value: "string")), p2: jp(key: "description", value: js(value: desc)))
    val props = jo1(p1: jp(key: prop_name, value: prop))
    var req_arr = "[]"
    if required:
        req_arr = "[" + js(prop_name) + "]"
    val schema = jo3(p1: jp(key: "type", value: js(value: "object")), p2: jp(key: "properties", value: props), p3: jp(key: "required", value: req_arr))

    var annot_parts: [text] = []
    annot_parts.push(LB())
    var ro = "false"
    if read_only:
        ro = "true"
    annot_parts.push(jp(key: "readOnlyHint", value: ro))
    annot_parts.push(",")
    var dest = "false"
    if destructive:
        dest = "true"
    annot_parts.push(jp(key: "destructiveHint", value: dest))
    annot_parts.push(",")
    var idemp = "false"
    if idempotent:
        idemp = "true"
    annot_parts.push(jp(key: "idempotentHint", value: idemp))
    annot_parts.push(",")
    annot_parts.push(jp(key: "openWorldHint", value: "false"))
    annot_parts.push(RB())
    val annot = annot_parts.join("")

    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "name", value: js(value: name)))
    parts.push(",")
    parts.push(jp(key: "description", value: js(value: escape_json(desc))))
    parts.push(",")
    parts.push(jp(key: "inputSchema", value: schema))
    parts.push(",")
    parts.push(jp(key: "annotations", value: annot))
    parts.push(RB())
    parts.join("")

fn make_no_param_tool(name: String, desc: String, read_only: Bool, destructive: Bool, idempotent: Bool) -> String:
    val schema = jo2(p1: jp(key: "type", value: js(value: "object")), p2: jp(key: "properties", value: LB() + RB()))

    var annot_parts: [text] = []
    annot_parts.push(LB())
    var ro = "false"
    if read_only:
        ro = "true"
    annot_parts.push(jp(key: "readOnlyHint", value: ro))
    annot_parts.push(",")
    var dest = "false"
    if destructive:
        dest = "true"
    annot_parts.push(jp(key: "destructiveHint", value: dest))
    annot_parts.push(",")
    var idemp = "false"
    if idempotent:
        idemp = "true"
    annot_parts.push(jp(key: "idempotentHint", value: idemp))
    annot_parts.push(",")
    annot_parts.push(jp(key: "openWorldHint", value: "false"))
    annot_parts.push(RB())
    val annot = annot_parts.join("")

    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "name", value: js(value: name)))
    parts.push(",")
    parts.push(jp(key: "description", value: js(value: escape_json(desc))))
    parts.push(",")
    parts.push(jp(key: "inputSchema", value: schema))
    parts.push(",")
    parts.push(jp(key: "annotations", value: annot))
    parts.push(RB())
    parts.join("")

fn make_prop(name: String, desc: String) -> String:
    jp(key: name, value: jo2(p1: jp(key: "type", value: js(value: "string")), p2: jp(key: "description", value: js(value: escape_json(desc)))))

fn make_prop_bool(name: String, desc: String) -> String:
    jp(key: name, value: jo2(p1: jp(key: "type", value: js(value: "boolean")), p2: jp(key: "description", value: js(value: escape_json(desc)))))

fn make_prop_int(name: String, desc: String) -> String:
    jp(key: name, value: jo2(p1: jp(key: "type", value: js(value: "integer")), p2: jp(key: "description", value: js(value: escape_json(desc)))))

