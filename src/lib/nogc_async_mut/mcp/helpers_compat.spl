# MCP Helpers - Compatibility layer over MCP SDK
#
# Re-exports SDK functions under the same names used by downstream MCP modules.
# Keeps unique helper functions (notifications, content types, etc.) locally.

use std.io.{file_read}
use std.io.{shell}
use common.text.{NL}

# --- SDK imports (replace local duplicate implementations) ---
use std.mcp_sdk.core.json.{jo1, jo2, jo3, escape_json, unwrap_idx, extract_json_string, extract_json_value, extract_nested_string}
use std.mcp_sdk.core.jsonrpc.{jsonrpc_result, jsonrpc_error}
use std.mcp_sdk.core.types.{make_tool_result}

# Local definitions (runtime can't re-export imported symbols)
fn LB() -> text:
    (123 as char).to_string()

fn RB() -> text:
    (125 as char).to_string()

fn Q() -> text:
    "\""

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

# --- Compatibility wrappers (name mismatches with SDK) ---

fn extract_json_string_v2(json: String, key: String) -> String:
    extract_json_string(json, key)

fn make_result_response(id: String, result: String) -> String:
    jsonrpc_result(id, result)

fn make_error_response(id: String, code: Int, message: String) -> String:
    jsonrpc_error(id, code, message)

# --- Local-only helpers (not in SDK) ---

# Helper: parse integer from string
fn parse_int(s: String) -> Result<Int, String>:
    var result = 0
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch >= '0' and ch <= '9':
            result = result * 10 + (ch as int - '0' as int)
        else:
            return Err("Invalid digit: " + ch.to_string())
        i = i + 1
    Ok(result)

# Helper: minimum of two integers
fn min_int(a: Int, b: Int) -> Int:
    if a < b:
        a
    else:
        b

fn unwrap_str(result: Result<String, String>) -> String:
    match result:
        case Ok(s):
            return s
        case Err(_):
            return ""

# Skip program name and script path to get clean args
fn get_clean_args(all_args: [String]) -> [String]:
    var args = []
    var start_idx = 1
    if all_args.len() > 1 and all_args[1].ends_with(".spl"):
        start_idx = 2
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

# --- Arguments dict extraction (local - returns Dict for mcp_jj compat) ---

fn extract_arguments_dict(body: String) -> Dict<String, String>:
    var result: Dict<String, String> = {}

    # Find params object
    val params_search = Q() + "params" + Q() + ":"
    val params_idx = unwrap_idx(body.index_of(params_search))
    if params_idx < 0:
        return result

    val params_start = params_idx + params_search.len()
    val params_section = body.substring(params_start)

    # Find arguments object within params
    val args_search = Q() + "arguments" + Q() + ":"
    val args_idx = unwrap_idx(params_section.index_of(args_search))
    if args_idx < 0:
        return result

    val args_start = args_idx + args_search.len()
    val after_args = params_section.substring(args_start)
    val trimmed = after_args.trim()

    # Extract content between braces
    if not trimmed.starts_with(LB()):
        return result

    # Find matching closing brace
    var brace_count = 0
    var idx = 0
    var args_content = ""

    for ch in trimmed:
        if ch == LB():
            brace_count = brace_count + 1
        elif ch == RB():
            brace_count = brace_count - 1
            if brace_count == 0:
                # Extract content between braces
                args_content = trimmed.substring(1, idx)
                break
        idx = idx + 1

    if args_content == "":
        return result

    # Parse key-value pairs from args_content
    val pairs = args_content.split(",")
    for pair in pairs:
        val colon_idx = unwrap_idx(pair.index_of(":"))
        if colon_idx >= 0:
            var key = pair.substring(0, colon_idx).trim()
            var value = pair.substring(colon_idx + 1).trim()

            # Remove quotes from key and value
            if key.starts_with(Q()):
                key = key.substring(1)
            if key.ends_with(Q()):
                key = key.substring(0, key.len() - 1)

            if value.starts_with(Q()):
                value = value.substring(1)
            if value.ends_with(Q()):
                value = value.substring(0, value.len() - 1)

            result[key] = value

    result

# --- File helpers ---

fn read_file_safe(path: String) -> String:
    val content = file_read(path)
    if content == "":
        return "Error: could not read file: " + path
    content

fn list_spl_files(dir: String) -> String:
    val result = shell("find " + dir + " -name '*.spl' -type f | sort")
    if result.exit_code != 0:
        var parts: [text] = []
        parts.push(LB())
        parts.push(jp(key: "error", value: js(value: "Failed to list files")))
        parts.push(",")
        parts.push(jp(key: "directory", value: js(value: dir)))
        parts.push(RB())
        return parts.join("")

    val output = result.stdout ?? ""
    if output.trim() == "":
        return "[]"

    val file_paths = output.split(NL)
    var file_parts: [text] = []

    for file_path in file_paths:
        val trimmed = file_path.trim()
        if trimmed != "":
            var obj_parts: [text] = []
            obj_parts.push(LB())
            obj_parts.push(jp(key: "path", value: js(value: trimmed)))
            obj_parts.push(RB())
            file_parts.push(obj_parts.join(""))

    "[" + file_parts.join(",") + "]"

# --- Flag checking ---

fn has_flag(args: [String], flag: String) -> Bool:
    for arg in args:
        if arg == flag:
            return true
    return false

fn make_tool_schema_multi(name: String, desc: String, properties_json: String, required_json: String, read_only: Bool, destructive: Bool, idempotent: Bool) -> String:
    val schema = jo3(p1: jp(key: "type", value: js(value: "object")), p2: jp(key: "properties", value: properties_json), p3: jp(key: "required", value: required_json))

    # Build annotations object
    var annot_parts: [text] = []
    annot_parts.push(LB())
    var ro = "false"
    if read_only:
        ro = "true"
    annot_parts.push(jp(key: "readOnlyHint", value: ro))
    annot_parts.push(",")
    var dest = "false"
    if destructive:
        dest = "true"
    annot_parts.push(jp(key: "destructiveHint", value: dest))
    annot_parts.push(",")
    var idemp = "false"
    if idempotent:
        idemp = "true"
    annot_parts.push(jp(key: "idempotentHint", value: idemp))
    annot_parts.push(",")
    annot_parts.push(jp(key: "openWorldHint", value: "false"))
    annot_parts.push(RB())
    val annot = annot_parts.join("")

    # Return tool schema with annotations
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "name", value: js(value: name)))
    parts.push(",")
    parts.push(jp(key: "description", value: js(value: desc)))
    parts.push(",")
    parts.push(jp(key: "inputSchema", value: schema))
    parts.push(",")
    parts.push(jp(key: "annotations", value: annot))
    parts.push(RB())
    parts.join("")

# --- Notification helpers ---

fn make_notification(method: String, params: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "jsonrpc", value: js(value: "2.0")))
    parts.push(",")
    parts.push(jp(key: "method", value: js(value: method)))
    parts.push(",")
    parts.push(jp(key: "params", value: params))
    parts.push(RB())
    parts.join("")

fn make_notification_no_params(method: String) -> String:
    jo2(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "method", value: js(value: method)))

fn make_progress_notification(token: String, progress: Int, total: Int, message: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "progressToken", value: js(value: token)))
    parts.push(",")
    parts.push(jp(key: "progress", value: progress.to_string()))
    if total > 0:
        parts.push(",")
        parts.push(jp(key: "total", value: total.to_string()))
    if message != "":
        parts.push(",")
        parts.push(jp(key: "message", value: js(value: escape_json(message))))
    parts.push(RB())
    make_notification(method: "notifications/progress", params: parts.join(""))

# --- Log level utilities ---

fn log_level_to_int(level: String) -> Int:
    if level == "debug":
        return 0
    elif level == "info":
        return 1
    elif level == "notice":
        return 2
    elif level == "warning":
        return 3
    elif level == "error":
        return 4
    elif level == "critical":
        return 5
    elif level == "alert":
        return 6
    elif level == "emergency":
        return 7
    return -1

fn make_log_notification(level: String, data: String, logger: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "level", value: js(value: level)))
    parts.push(",")
    parts.push(jp(key: "data", value: js(value: escape_json(data))))
    if logger != "":
        parts.push(",")
        parts.push(jp(key: "logger", value: js(value: escape_json(logger))))
    parts.push(RB())
    make_notification(method: "notifications/message", params: parts.join(""))

fn make_log_notification_raw(level: String, data_json: String, logger: String) -> String:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp(key: "level", value: js(value: level)))
    parts.push(",")
    parts.push(jp(key: "data", value: data_json))
    if logger != "":
        parts.push(",")
        parts.push(jp(key: "logger", value: js(value: escape_json(logger))))
    parts.push(RB())
    make_notification(method: "notifications/message", params: parts.join(""))

# --- List changed notifications ---

fn make_tools_list_changed() -> String:
    make_notification_no_params(method: "notifications/tools/list_changed")

fn make_resources_list_changed() -> String:
    make_notification_no_params(method: "notifications/resources/list_changed")

fn make_prompts_list_changed() -> String:
    make_notification_no_params(method: "notifications/prompts/list_changed")

# --- Resource subscription notifications ---

fn make_resource_updated_notification(uri: String) -> String:
    val params = jo1(p1: jp(key: "uri", value: js(value: escape_json(uri))))
    make_notification(method: "notifications/resources/updated", params: params)

