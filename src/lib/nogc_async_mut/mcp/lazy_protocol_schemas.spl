# MCP Lazy Server — tools list and tool schema definitions

# --- Tools list (all 66 tools, minimal schemas) ---

fn make_tools_list(id: text) -> text:
    if TOOLS_CACHE != "":
        return make_json_result(id, TOOLS_CACHE)

    var tool_parts: [text] = []

    # Debug tools (16)
    tool_parts.push(make_tool_schema(name: "debug_create_session", description: "Create a debug session"))
    tool_parts.push(make_tool_schema(name: "debug_list_sessions", description: "List active debug sessions"))
    tool_parts.push(make_tool_schema(name: "debug_close_session", description: "Close a debug session"))
    tool_parts.push(make_tool_schema(name: "debug_set_breakpoint", description: "Set a breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_remove_breakpoint", description: "Remove a breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_continue", description: "Continue execution"))
    tool_parts.push(make_tool_schema(name: "debug_step", description: "Step through code"))
    tool_parts.push(make_tool_schema(name: "debug_get_variables", description: "Get variable values"))
    tool_parts.push(make_tool_schema(name: "debug_stack_trace", description: "Get stack trace"))
    tool_parts.push(make_tool_schema(name: "debug_evaluate", description: "Evaluate expression"))
    tool_parts.push(make_tool_schema(name: "debug_set_function_breakpoint", description: "Set function breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_enable_breakpoint", description: "Enable/disable breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_get_source", description: "Get source code"))
    tool_parts.push(make_tool_schema(name: "debug_watch", description: "Add watch expression"))
    tool_parts.push(make_tool_schema(name: "debug_set_variable", description: "Set variable value"))
    tool_parts.push(make_tool_schema(name: "debug_set_data_breakpoint", description: "Set variable-change breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_list_data_breakpoints", description: "List variable-change breakpoints"))
    tool_parts.push(make_tool_schema(name: "debug_remove_data_breakpoint", description: "Remove variable-change breakpoint"))
    tool_parts.push(make_tool_schema(name: "debug_terminate", description: "Terminate debug session"))

    # Debug log tools (6)
    tool_parts.push(make_tool_schema(name: "debug_log_enable", description: "Enable debug logging"))
    tool_parts.push(make_tool_schema(name: "debug_log_disable", description: "Disable debug logging"))
    tool_parts.push(make_tool_schema(name: "debug_log_clear", description: "Clear debug logs"))
    tool_parts.push(make_tool_schema(name: "debug_log_query", description: "Query debug logs"))
    tool_parts.push(make_tool_schema(name: "debug_log_tree", description: "Get debug log tree"))
    tool_parts.push(make_tool_schema(name: "debug_log_status", description: "Get debug log status"))

    # Diagnostic read tools (4)
    tool_parts.push(make_tool_schema(name: "simple_read", description: "Read Simple source with diagnostics"))
    tool_parts.push(make_tool_schema(name: "simple_check", description: "Check Simple source for errors"))
    tool_parts.push(make_tool_schema(name: "simple_symbols", description: "List symbols in file with visibility metadata"))
    tool_parts.push(make_tool_schema(name: "simple_status", description: "Get project status"))

    # Diagnostic edit tools (3)
    tool_parts.push(make_tool_schema(name: "simple_edit", description: "Edit Simple source file"))
    tool_parts.push(make_tool_schema(name: "simple_multi_edit", description: "Edit multiple files"))
    tool_parts.push(make_tool_schema(name: "simple_run", description: "Run Simple code"))

    # Diagnostic VCS tools (4)
    tool_parts.push(make_tool_schema(name: "simple_diff", description: "Show file diff"))
    tool_parts.push(make_tool_schema(name: "simple_log", description: "Show git log"))
    tool_parts.push(make_tool_schema(name: "simple_squash", description: "Squash commits"))
    tool_parts.push(make_tool_schema(name: "simple_new", description: "Create new change"))

    # API search tools (1)
    tool_parts.push(make_tool_schema(name: "simple_api", description: "Search module API with visibility-aware filtering"))

    # CLI tools — Tier 1 (6)
    tool_parts.push(make_tool_schema(name: "simple_test", description: "Run tests"))
    tool_parts.push(make_tool_schema(name: "simple_build", description: "Build project"))
    tool_parts.push(make_tool_schema(name: "simple_format", description: "Format file/project"))
    tool_parts.push(make_tool_schema(name: "simple_lint", description: "Lint with output"))
    tool_parts.push(make_tool_schema(name: "simple_fix", description: "Auto-fix issues"))
    tool_parts.push(make_tool_schema(name: "simple_doc_coverage", description: "Doc coverage report"))

    # Query tools — Tier 2 (5)
    tool_parts.push(make_tool_schema(name: "simple_definition", description: "Go-to-definition"))
    tool_parts.push(make_tool_schema(name: "simple_references", description: "Find all references"))
    tool_parts.push(make_tool_schema(name: "simple_hover", description: "Type + docs at position"))
    tool_parts.push(make_tool_schema(name: "simple_completions", description: "Code completions"))
    tool_parts.push(make_tool_schema(name: "simple_type_at", description: "Type info at position"))

    # Analysis tools — Tier 3 (4)
    tool_parts.push(make_tool_schema(name: "simple_dependencies", description: "Module dependency graph"))
    tool_parts.push(make_tool_schema(name: "simple_api_diff", description: "API surface diff"))
    tool_parts.push(make_tool_schema(name: "simple_context", description: "Context pack for AI/docs"))
    tool_parts.push(make_tool_schema(name: "simple_search", description: "Language-aware code search"))

    # LSP tools — Tier 4 (10)
    tool_parts.push(make_tool_schema(name: "simple_signature_help", description: "Function parameter hints at call site"))
    tool_parts.push(make_tool_schema(name: "simple_rename", description: "Rename symbol across project"))
    tool_parts.push(make_tool_schema(name: "simple_code_actions", description: "Quick fixes for diagnostics at position"))
    tool_parts.push(make_tool_schema(name: "simple_workspace_symbols", description: "Search symbols across project"))
    tool_parts.push(make_tool_schema(name: "simple_call_hierarchy", description: "Incoming/outgoing call chains"))
    tool_parts.push(make_tool_schema(name: "simple_type_hierarchy", description: "Super/sub type relationships"))
    tool_parts.push(make_tool_schema(name: "simple_semantic_tokens", description: "Semantic token data for highlighting"))
    tool_parts.push(make_tool_schema(name: "simple_inlay_hints", description: "Inline type/parameter annotations"))
    tool_parts.push(make_tool_schema(name: "simple_selection_range", description: "Smart selection expand/shrink"))
    tool_parts.push(make_tool_schema(name: "simple_document_formatting", description: "Format a document"))

    # LSP extra tools (4)
    tool_parts.push(make_tool_schema(name: "simple_document_highlight", description: "Same-file references with Read/Write classification"))
    tool_parts.push(make_tool_schema(name: "simple_type_definition", description: "Find where a type is defined"))
    tool_parts.push(make_tool_schema(name: "simple_implementation", description: "Find trait implementations"))
    tool_parts.push(make_tool_schema(name: "simple_folding_range", description: "Get folding ranges for a file"))

    # Code query tools (3)
    tool_parts.push(make_tool_schema(name: "simple_ast_query", description: "S-expression structural pattern matching against code outline"))
    tool_parts.push(make_tool_schema(name: "simple_sem_query", description: "CodeQL-style semantic query with SQL-like syntax"))
    tool_parts.push(make_tool_schema(name: "simple_query_schema", description: "List available query node types and predicates"))

    # Terminal tools (8)
    tool_parts.push(make_tool_schema(name: "terminal_connect", description: "Connect to a remote terminal (SSH, telnet, T32 SWD, or relay)"))
    tool_parts.push(make_tool_schema(name: "terminal_disconnect", description: "Disconnect an active terminal connection"))
    tool_parts.push(make_tool_schema(name: "terminal_send", description: "Send data to an active terminal"))
    tool_parts.push(make_tool_schema(name: "terminal_receive", description: "Receive data from an active terminal"))
    tool_parts.push(make_tool_schema(name: "terminal_execute", description: "Execute a command on a remote terminal"))
    tool_parts.push(make_tool_schema(name: "terminal_list", description: "List all active terminal connections"))
    tool_parts.push(make_tool_schema(name: "terminal_status", description: "Get status of a terminal connection"))
    tool_parts.push(make_tool_schema(name: "terminal_upload", description: "Upload a file to a remote terminal via SFTP"))

    # Power tools (6)
    tool_parts.push(make_tool_schema(name: "power_on", description: "Power on a target device"))
    tool_parts.push(make_tool_schema(name: "power_off", description: "Power off a target device"))
    tool_parts.push(make_tool_schema(name: "power_toggle", description: "Toggle power on a target device"))
    tool_parts.push(make_tool_schema(name: "power_reset", description: "Reset a target device"))
    tool_parts.push(make_tool_schema(name: "power_state", description: "Query power state of a target device"))
    tool_parts.push(make_tool_schema(name: "relay_execute", description: "Execute a relay script with custom command"))

    # Remote test tools (3)
    tool_parts.push(make_tool_schema(name: "remote_test_run", description: "Run a test on a remote PC via terminal"))
    tool_parts.push(make_tool_schema(name: "remote_test_status", description: "Query status of a remote test"))
    tool_parts.push(make_tool_schema(name: "remote_test_collect", description: "Collect full result of a completed remote test"))

    val tools = SB_L() + tool_parts.join(",") + SB_R()
    val result = jo1(jp("tools", tools))
    TOOLS_CACHE = result
    make_json_result(id, result)

fn make_tool_schema(name: text, description: text) -> text:
    var props = LB() + RB()
    var req = "[]"

    if name == "debug_create_session":
        props = jo2(
            jp("program", jo2(jp("type", js("string")), jp("description", js("Path to program")))),
            jp("target_type", jo2(jp("type", js("string")), jp("description", js("interpreter|smf|native|remote"))))
        )
        req = "[" + js("program") + "]"
    elif name == "debug_close_session" or name == "debug_continue" or name == "debug_get_variables" or name == "debug_stack_trace" or name == "debug_terminate":
        props = jo1(jp("session_id", jo2(jp("type", js("string")), jp("description", js("Debug session id")))))
        req = "[" + js("session_id") + "]"
    elif name == "debug_set_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("file", jo1(jp("type", js("string"))))
        p = p + "," + jp("line", jo1(jp("type", js("string"))))
        p = p + "," + jp("condition", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("file") + "," + js("line") + "]"
    elif name == "debug_remove_breakpoint":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("breakpoint_id", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("breakpoint_id") + "]"
    elif name == "debug_step":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("mode", jo2(jp("type", js("string")), jp("description", js("over|in|out"))))
        )
        req = "[" + js("session_id") + "," + js("mode") + "]"
    elif name == "debug_evaluate":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("expression", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("expression") + "]"
    elif name == "debug_set_function_breakpoint":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("function_name", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("function_name") + "]"
    elif name == "debug_enable_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("breakpoint_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("enabled", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("breakpoint_id") + "," + js("enabled") + "]"
    elif name == "debug_get_source":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("file", jo1(jp("type", js("string"))))
        p = p + "," + jp("start_line", jo1(jp("type", js("string"))))
        p = p + "," + jp("count", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("file") + "]"
    elif name == "debug_watch":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("action", jo1(jp("type", js("string"))))
        p = p + "," + jp("expression", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("action") + "]"
    elif name == "debug_set_variable":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("name", jo1(jp("type", js("string"))))
        p = p + "," + jp("value", jo1(jp("type", js("string"))))
        p = p + "," + jp("frame_index", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("name") + "," + js("value") + "]"
    elif name == "debug_set_data_breakpoint":
        var p = LB()
        p = p + jp("session_id", jo1(jp("type", js("string"))))
        p = p + "," + jp("name", jo1(jp("type", js("string"))))
        p = p + "," + jp("access_type", jo1(jp("type", js("string"))))
        p = p + "," + jp("condition", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("session_id") + "," + js("name") + "]"
    elif name == "debug_list_data_breakpoints":
        props = jo1(jp("session_id", jo1(jp("type", js("string")))))
        req = "[" + js("session_id") + "]"
    elif name == "debug_remove_data_breakpoint":
        props = jo2(
            jp("session_id", jo1(jp("type", js("string")))),
            jp("breakpoint_id", jo1(jp("type", js("string"))))
        )
        req = "[" + js("session_id") + "," + js("breakpoint_id") + "]"
    elif name == "debug_log_enable":
        props = jo1(jp("pattern", jo1(jp("type", js("string")))))
    elif name == "debug_log_query":
        var p = LB()
        p = p + jp("since_id", jo1(jp("type", js("integer"))))
        p = p + "," + jp("entry_type", jo1(jp("type", js("string"))))
        p = p + "," + jp("max_results", jo1(jp("type", js("integer"))))
        p = p + "," + jp("function_pattern", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
    elif name == "debug_log_tree":
        var p = LB()
        p = p + jp("format", jo1(jp("type", js("string"))))
        p = p + "," + jp("max_depth", jo1(jp("type", js("integer"))))
        p = p + "," + jp("since_id", jo1(jp("type", js("integer"))))
        p = p + "," + jp("expanded_groups", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
    elif name == "simple_read":
        var p = LB()
        p = p + jp("path", jo1(jp("type", js("string"))))
        p = p + "," + jp("show_hints", jo1(jp("type", js("boolean"))))
        p = p + "," + jp("fold_mode", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("path") + "]"
    elif name == "simple_check" or name == "simple_symbols" or name == "simple_run":
        props = jo1(jp("path", jo1(jp("type", js("string")))))
        req = "[" + js("path") + "]"
    elif name == "simple_status":
        props = jo2(jp("directory", jo1(jp("type", js("string")))), jp("paths", jo1(jp("type", js("array")))))
    elif name == "simple_edit":
        var p = LB()
        p = p + jp("path", jo1(jp("type", js("string"))))
        p = p + "," + jp("old_string", jo1(jp("type", js("string"))))
        p = p + "," + jp("new_string", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p
        req = "[" + js("path") + "," + js("old_string") + "," + js("new_string") + "]"
    elif name == "simple_multi_edit":
        props = jo2(jp("path", jo1(jp("type", js("string")))), jp("edits", jo1(jp("type", js("array")))))
        req = "[" + js("path") + "," + js("edits") + "]"
    elif name == "simple_diff":
        props = jo2(jp("revision", jo1(jp("type", js("string")))), jp("paths", jo1(jp("type", js("string")))))
    elif name == "simple_log":
        props = jo2(jp("limit", jo1(jp("type", js("integer")))), jp("revsets", jo1(jp("type", js("string")))))
    elif name == "simple_squash" or name == "simple_new":
        props = jo2(jp("revision", jo1(jp("type", js("string")))), jp("message", jo1(jp("type", js("string")))))
    elif name == "simple_api":
        var p = LB()
        p = p + jp("module", jo1(jp("type", js("string"))))
        p = p + "," + jp("query", jo1(jp("type", js("string"))))
        p = p + "," + jp("visibility", jo1(jp("type", js("string"))))
        p = p + RB()
        props = p

    # --- Tier 1: CLI tools ---
    elif name == "simple_test":
        var p = LB()
        p = p + jp("path", jo2(jp("type", js("string")), jp("description", js("Test file or directory path"))))
        p = p + "," + jp("filter", jo2(jp("type", js("string")), jp("description", js("Filter test names"))))
        p = p + "," + jp("only_slow", jo2(jp("type", js("string")), jp("description", js("Run only slow tests (true/false)"))))
        p = p + "," + jp("list", jo2(jp("type", js("string")), jp("description", js("List tests without running (true/false)"))))
        p = p + RB()
        props = p
    elif name == "simple_build":
        var p = LB()
        p = p + jp("release", jo2(jp("type", js("string")), jp("description", js("Release build (true/false)"))))
        p = p + "," + jp("target", jo2(jp("type", js("string")), jp("description", js("Target architecture"))))
        p = p + "," + jp("warn_docs", jo2(jp("type", js("string")), jp("description", js("Check documentation coverage (true/false)"))))
        p = p + RB()
        props = p
    elif name == "simple_format":
        props = jo2(
            jp("path", jo2(jp("type", js("string")), jp("description", js("File or directory to format")))),
            jp("check", jo2(jp("type", js("string")), jp("description", js("Check only, no changes (true/false)"))))
        )
    elif name == "simple_lint":
        props = jo1(jp("path", jo2(jp("type", js("string")), jp("description", js("File or directory to lint")))))
    elif name == "simple_fix":
        props = jo2(
            jp("path", jo2(jp("type", js("string")), jp("description", js("File path to fix")))),
            jp("dry_run", jo2(jp("type", js("string")), jp("description", js("Preview fixes without applying (true/false)"))))
        )
        req = "[" + js("path") + "]"
    elif name == "simple_doc_coverage":
        props = jo2(
            jp("format", jo2(jp("type", js("string")), jp("description", js("Output format: md, json, csv")))),
            jp("missing", jo2(jp("type", js("string")), jp("description", js("Show only undocumented items (true/false)"))))
        )

    # --- Tier 2: Query tools ---
    elif name == "simple_definition" or name == "simple_references" or name == "simple_hover" or name == "simple_type_at":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "]"
    elif name == "simple_completions":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + "," + jp("prefix", jo2(jp("type", js("string")), jp("description", js("Completion prefix filter"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "]"

    # --- Tier 3: Analysis tools ---
    elif name == "simple_dependencies":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path (optional, omit for project summary)"))))
        p = p + "," + jp("depth", jo2(jp("type", js("string")), jp("description", js("Max dependency depth"))))
        p = p + "," + jp("format", jo2(jp("type", js("string")), jp("description", js("Output format"))))
        p = p + RB()
        props = p
    elif name == "simple_api_diff":
        props = jo2(
            jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path")))),
            jp("revision", jo2(jp("type", js("string")), jp("description", js("Git revision to compare against (default: HEAD)"))))
        )
        req = "[" + js("file") + "]"
    elif name == "simple_context":
        props = jo2(
            jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path")))),
            jp("target", jo2(jp("type", js("string")), jp("description", js("Target symbol or section to highlight"))))
        )
        req = "[" + js("file") + "]"
    elif name == "simple_search":
        var p = LB()
        p = p + jp("query", jo2(jp("type", js("string")), jp("description", js("Search query (regex supported)"))))
        p = p + "," + jp("kind", jo2(jp("type", js("string")), jp("description", js("Symbol kind filter: fn, class, struct, enum, import, type"))))
        p = p + "," + jp("scope", jo2(jp("type", js("string")), jp("description", js("Search scope: src, test, lib, compiler, app, all"))))
        p = p + "," + jp("file", jo2(jp("type", js("string")), jp("description", js("Restrict search to specific file"))))
        p = p + RB()
        props = p
        req = "[" + js("query") + "]"

    # --- Tier 4: LSP tools ---
    elif name == "simple_signature_help" or name == "simple_code_actions" or name == "simple_selection_range":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "]"
    elif name == "simple_rename":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + "," + jp("new_name", jo2(jp("type", js("string")), jp("description", js("New name for the symbol"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "," + js("new_name") + "]"
    elif name == "simple_workspace_symbols":
        var p = LB()
        p = p + jp("query", jo2(jp("type", js("string")), jp("description", js("Symbol search query"))))
        p = p + "," + jp("kind", jo2(jp("type", js("string")), jp("description", js("Symbol kind filter: fn, class, struct, enum, trait"))))
        p = p + RB()
        props = p
        req = "[" + js("query") + "]"
    elif name == "simple_call_hierarchy" or name == "simple_type_hierarchy":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + "," + jp("direction", jo2(jp("type", js("string")), jp("description", js("Direction: incoming|outgoing or supertypes|subtypes"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "]"
    elif name == "simple_semantic_tokens" or name == "simple_inlay_hints":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("start_line", jo2(jp("type", js("string")), jp("description", js("Start line (1-based, optional)"))))
        p = p + "," + jp("end_line", jo2(jp("type", js("string")), jp("description", js("End line (1-based, optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "]"
    elif name == "simple_document_formatting":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("options", jo2(jp("type", js("string")), jp("description", js("Formatting options (optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "]"

    # --- LSP extra tools ---
    elif name == "simple_document_highlight" or name == "simple_type_definition" or name == "simple_implementation":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + "," + jp("line", jo2(jp("type", js("string")), jp("description", js("Line number (1-based)"))))
        p = p + "," + jp("column", jo2(jp("type", js("string")), jp("description", js("Column number (1-based, optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "," + js("line") + "]"
    elif name == "simple_folding_range":
        var p = LB()
        p = p + jp("file", jo2(jp("type", js("string")), jp("description", js("Source file path"))))
        p = p + RB()
        props = p
        req = "[" + js("file") + "]"

    # --- Code query tools ---
    elif name == "simple_ast_query" or name == "simple_sem_query":
        var p = LB()
        p = p + jp("query", jo2(jp("type", js("string")), jp("description", js("Query pattern (S-expression for ast-query, SQL-like for sem-query)"))))
        p = p + "," + jp("files", jo2(jp("type", js("string")), jp("description", js("File or directory to search (default: src/)"))))
        p = p + "," + jp("format", jo2(jp("type", js("string")), jp("description", js("Output format: text, json, compact"))))
        p = p + RB()
        props = p
        req = "[" + js("query") + "]"
    elif name == "simple_query_schema":
        props = jo1(jp("kind", jo2(jp("type", js("string")), jp("description", js("Schema kind: ast, sem, or empty for both")))))

    # --- Terminal tools ---
    elif name == "terminal_connect":
        var p = LB()
        p = p + jp("name", jo2(jp("type", js("string")), jp("description", js("Terminal name from config"))))
        p = p + "," + jp("kind", jo2(jp("type", js("string")), jp("description", js("ssh|telnet|t32_swd|relay"))))
        p = p + "," + jp("host", jo2(jp("type", js("string")), jp("description", js("Remote host address"))))
        p = p + "," + jp("port", jo2(jp("type", js("integer")), jp("description", js("Remote port number"))))
        p = p + "," + jp("username", jo2(jp("type", js("string")), jp("description", js("Username for auth"))))
        p = p + "," + jp("auth_method", jo2(jp("type", js("string")), jp("description", js("password|pubkey|agent|none"))))
        p = p + "," + jp("credential", jo2(jp("type", js("string")), jp("description", js("Password or encrypted credential"))))
        p = p + "," + jp("key_path", jo2(jp("type", js("string")), jp("description", js("SSH private key path"))))
        p = p + RB()
        props = p
        req = "[" + js("name") + "]"
    elif name == "terminal_disconnect" or name == "terminal_status":
        props = jo1(jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Terminal connection ID")))))
        req = "[" + js("connection_id") + "]"
    elif name == "terminal_send":
        props = jo2(
            jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Terminal connection ID")))),
            jp("data", jo2(jp("type", js("string")), jp("description", js("Data to send"))))
        )
        req = "[" + js("connection_id") + "," + js("data") + "]"
    elif name == "terminal_receive":
        props = jo2(
            jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Terminal connection ID")))),
            jp("timeout_ms", jo2(jp("type", js("integer")), jp("description", js("Receive timeout in milliseconds (default: 5000)"))))
        )
        req = "[" + js("connection_id") + "]"
    elif name == "terminal_execute":
        props = jo2(
            jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Terminal connection ID")))),
            jp("command", jo2(jp("type", js("string")), jp("description", js("Command to execute"))))
        )
        req = "[" + js("connection_id") + "," + js("command") + "]"
    elif name == "terminal_list":
        props = LB() + RB()
    elif name == "terminal_upload":
        var p = LB()
        p = p + jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Terminal connection ID"))))
        p = p + "," + jp("local_path", jo2(jp("type", js("string")), jp("description", js("Local file path to upload"))))
        p = p + "," + jp("remote_path", jo2(jp("type", js("string")), jp("description", js("Remote destination path"))))
        p = p + RB()
        props = p
        req = "[" + js("connection_id") + "," + js("local_path") + "," + js("remote_path") + "]"

    # --- Power tools ---
    elif name == "power_on" or name == "power_off" or name == "power_toggle" or name == "power_reset" or name == "power_state":
        props = jo1(jp("config_name", jo2(jp("type", js("string")), jp("description", js("Power config name from SDN config file")))))
        req = "[" + js("config_name") + "]"
    elif name == "relay_execute":
        props = jo2(
            jp("script_path", jo2(jp("type", js("string")), jp("description", js("Path to relay .shs script")))),
            jp("command", jo2(jp("type", js("string")), jp("description", js("Command argument to pass to the script"))))
        )
        req = "[" + js("script_path") + "]"

    # --- Remote test tools ---
    elif name == "remote_test_run":
        var p = LB()
        p = p + jp("terminal_name", jo2(jp("type", js("string")), jp("description", js("Terminal name from config (auto-connects if needed)"))))
        p = p + "," + jp("connection_id", jo2(jp("type", js("integer")), jp("description", js("Existing terminal connection ID"))))
        p = p + "," + jp("test_path", jo2(jp("type", js("string")), jp("description", js("Path to test file (e.g. test/unit/lib/my_spec.spl)"))))
        p = p + RB()
        props = p
        req = "[" + js("test_path") + "]"
    elif name == "remote_test_status" or name == "remote_test_collect":
        props = jo1(jp("test_id", jo2(jp("type", js("integer")), jp("description", js("Remote test ID returned by remote_test_run")))))
        req = "[" + js("test_id") + "]"

    var schema = LB()
    schema = schema + jp("type", js("object"))
    schema = schema + "," + jp("properties", props)
    schema = schema + "," + jp("required", req)
    schema = schema + RB()

    var read_only = "false"
    var destructive = "false"
    var idempotent = "true"
    if (name.starts_with("simple_read") or name == "simple_check" or name == "simple_symbols" or name == "simple_status" or name == "simple_log" or name == "simple_api" or
        name == "simple_test" or name == "simple_lint" or name == "simple_doc_coverage" or
        name == "simple_definition" or name == "simple_references" or name == "simple_hover" or name == "simple_completions" or name == "simple_type_at" or
        name == "simple_dependencies" or name == "simple_api_diff" or name == "simple_context" or name == "simple_search" or
        name == "simple_signature_help" or name == "simple_code_actions" or name == "simple_workspace_symbols" or name == "simple_call_hierarchy" or name == "simple_type_hierarchy" or name == "simple_semantic_tokens" or name == "simple_inlay_hints" or name == "simple_selection_range" or
        name == "simple_document_highlight" or name == "simple_type_definition" or name == "simple_implementation" or name == "simple_folding_range" or
        name == "debug_list_sessions" or name == "debug_get_variables" or name == "debug_stack_trace" or name == "debug_evaluate" or name == "debug_get_source" or name == "debug_log_query" or name == "debug_log_tree" or name == "debug_log_status" or name == "debug_list_data_breakpoints" or
        name == "simple_ast_query" or name == "simple_sem_query" or name == "simple_query_schema" or
        name == "terminal_list" or name == "terminal_status" or name == "terminal_receive" or
        name == "power_state" or
        name == "remote_test_status" or name == "remote_test_collect"):
        read_only = "true"
    if (name == "simple_edit" or name == "simple_multi_edit" or name == "simple_squash" or name == "simple_new" or name == "debug_log_clear" or name == "debug_set_variable" or name == "debug_terminate" or name == "debug_remove_data_breakpoint" or name == "simple_rename" or name == "simple_document_formatting" or
        name == "terminal_disconnect" or name == "power_off" or name == "power_reset"):
        destructive = "true"
    if (name == "simple_run" or name == "simple_new" or name == "simple_squash" or name == "debug_continue" or name == "debug_step" or name == "debug_set_data_breakpoint" or name == "simple_test" or name == "simple_rename" or name == "simple_document_formatting" or
        name == "terminal_connect" or name == "terminal_send" or name == "terminal_execute" or name == "terminal_upload" or
        name == "power_on" or name == "power_off" or name == "power_toggle" or name == "power_reset" or name == "relay_execute" or
        name == "remote_test_run"):
        idempotent = "false"

    var annotations = LB()
    annotations = annotations + jp("readOnlyHint", read_only)
    annotations = annotations + "," + jp("destructiveHint", destructive)
    annotations = annotations + "," + jp("idempotentHint", idempotent)
    annotations = annotations + "," + jp("openWorldHint", "false")
    annotations = annotations + RB()

    var tool_obj = jo3(
        jp("name", js(name)),
        jp("description", js(description)),
        jp("inputSchema", schema)
    )
    tool_obj = tool_obj.substring(0, tool_obj.len() - 1) + "," + jp("annotations", annotations) + RB()
    tool_obj
