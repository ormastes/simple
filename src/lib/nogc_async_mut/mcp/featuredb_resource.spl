# Feature Database MCP Resource
#
# Provides MCP access to the unified feature database
# Supports both read and write operations via JSON API

use std.database.feature.{create_feature_database, load_feature_database, FeatureDatabase, Feature, FeatureStatus, FeatureMode, FeatureStats}
use std.nogc_async_mut.mcp.resource_utils.{
    escape_json,
    extract_json_string,
    current_timestamp, error_json, success_json, items_to_json
}
use std.nogc_sync_mut.io.file_ops.{file_exists as file_exists_backend}

fn file_exists(path: text) -> bool:
    file_exists_backend(path)


# ============================================================================
# Read Operations
# ============================================================================

fn open_or_create_feature_database(db_path: text) -> FeatureDatabase:
    if file_exists(db_path):
        val existing = load_feature_database(db_path)
        match existing:
            Some(db):
                return db
            nil:
                pass_do_nothing("feature database load failed; creating a new database")
    create_feature_database(db_path)

# Get all features from database
fn get_all_features(db_path: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)
    val features = featuredb.all_features()
    features_to_json(features)

# Get features by category
fn get_features_by_category(db_path: text, category: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)
    val features = featuredb.features_by_category(category)

    var raw_items: [text] = []
    for feature in features:
        raw_items.push(feature_to_json(feature))

    "{\"category\":\"" + escape_json(category) + "\",\"total\":" + str(features.len()) + ",\"features\":[" + raw_items.join(",") + "]}"

# Get features by status
fn get_features_by_status(db_path: text, status: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)
    val normalized = mcp_feature_status_to_string(parse_mcp_feature_status(status))
    val all_features = featuredb.all_features()
    val features = all_features.filter(
        mcp_feature_status_to_string(_1.pure_status) == normalized or
        mcp_feature_status_to_string(_1.hybrid_status) == normalized or
        mcp_feature_status_to_string(_1.llvm_status) == normalized
    )

    var raw_items: [text] = []
    for feature in features:
        raw_items.push(feature_to_json(feature))

    "{\"status\":\"" + escape_json(status) + "\",\"total\":" + str(features.len()) + ",\"features\":[" + raw_items.join(",") + "]}"

# Get feature statistics
fn get_feature_stats(db_path: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)
    val stats: FeatureStats = featuredb.stats()

    "{\"total\":" + str(stats.total) + ",\"done\":" + str(stats.done) + ",\"in_progress\":" + str(stats.in_progress) + ",\"planned\":" + str(stats.planned) + ",\"failed\":" + str(stats.failed) + ",\"completion_rate\":" + str(stats.completion_rate) + "}"

# Get feature by ID
fn get_feature_by_id(db_path: text, feature_id: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)
    val feature_opt = featuredb.get_feature(feature_id)

    match feature_opt:
        Some(feature):
            feature_to_json(feature)
        nil:
            error_json("Feature not found: {feature_id}")

# ============================================================================
# Write Operations
# ============================================================================

# Add a new feature from JSON
fn add_feature_from_json(db_path: text, json: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)

    val id = extract_json_string(json, "id")
    val category = extract_json_string(json, "category")
    val name = extract_json_string(json, "name")
    val description = extract_json_string(json, "description")
    val spec_file = extract_json_string(json, "spec_file")
    val pure_status = extract_json_string(json, "pure_status")
    val hybrid_status = extract_json_string(json, "hybrid_status")
    val llvm_status = extract_json_string(json, "llvm_status")

    if id == "":
        return error_json("Missing required field: id")
    if name == "":
        return error_json("Missing required field: name")

    val feature = Feature(
        id: id,
        category: category,
        name: name,
        description: description,
        spec_file: spec_file,
        pure_status: parse_mcp_feature_status(pure_status),
        hybrid_status: parse_mcp_feature_status(hybrid_status),
        llvm_status: parse_mcp_feature_status(llvm_status),
        created_at: current_timestamp(),
        updated_at: current_timestamp(),
        valid: true
    )

    val added = featuredb.add_feature(feature)
    if not added:
        return error_json("Failed to add feature")

    val saved = featuredb.save()
    if not saved:
        return error_json("Failed to save database")

    success_json(id)

# Update an existing feature from JSON
fn update_feature_from_json(db_path: text, feature_id: text, json: text) -> text:
    var featuredb = open_or_create_feature_database(db_path)

    val existing_opt = featuredb.get_feature(feature_id)
    val existing = match existing_opt:
        Some(feature): feature
        nil: return error_json("Feature not found: {feature_id}")

    val pure_status = extract_json_string(json, "pure_status")
    val hybrid_status = extract_json_string(json, "hybrid_status")
    val llvm_status = extract_json_string(json, "llvm_status")
    val name = extract_json_string(json, "name")
    val description = extract_json_string(json, "description")

    val updated_feature = Feature(
        id: feature_id,
        category: existing.category,
        name: if name != "": name else: existing.name,
        description: if description != "": description else: existing.description,
        spec_file: existing.spec_file,
        pure_status: if pure_status != "": parse_mcp_feature_status(pure_status) else: existing.pure_status,
        hybrid_status: if hybrid_status != "": parse_mcp_feature_status(hybrid_status) else: existing.hybrid_status,
        llvm_status: if llvm_status != "": parse_mcp_feature_status(llvm_status) else: existing.llvm_status,
        created_at: existing.created_at,
        updated_at: current_timestamp(),
        valid: true
    )

    val updated = featuredb.update_feature(feature_id, updated_feature)
    if not updated:
        return error_json("Failed to update feature")

    val saved = featuredb.save()
    if not saved:
        return error_json("Failed to save database")

    success_json(feature_id)

# ============================================================================
# JSON Conversion Helpers
# ============================================================================

# Convert list of features to JSON
fn features_to_json(features: [Feature]) -> text:
    items_to_json(features, "features", feature_to_json)

# Convert single feature to JSON
fn feature_to_json(feature: Feature) -> text:
    "{\"id\":\"" + escape_json(feature.id) + "\",\"category\":\"" + escape_json(feature.category) + "\",\"name\":\"" + escape_json(feature.name) + "\",\"description\":\"" + escape_json(feature.description) + "\",\"spec_file\":\"" + escape_json(feature.spec_file) + "\",\"pure_status\":\"" + escape_json(mcp_feature_status_to_string(feature.pure_status)) + "\",\"hybrid_status\":\"" + escape_json(mcp_feature_status_to_string(feature.hybrid_status)) + "\",\"llvm_status\":\"" + escape_json(mcp_feature_status_to_string(feature.llvm_status)) + "\"}"

# ============================================================================
# Status Conversion Helpers
# ============================================================================

fn mcp_feature_status_to_string(status: FeatureStatus) -> text:
    if status == FeatureStatus.Done:
        "done"
    elif status == FeatureStatus.InProgress:
        "in_progress"
    elif status == FeatureStatus.Failed:
        "failed"
    elif status == FeatureStatus.Blocked:
        "blocked"
    else:
        "planned"

fn parse_mcp_feature_status(s: text) -> FeatureStatus:
    if s == "Done" or s == "done":
        FeatureStatus.Done
    elif s == "InProgress" or s == "in_progress":
        FeatureStatus.InProgress
    elif s == "Failed" or s == "failed":
        FeatureStatus.Failed
    elif s == "Blocked" or s == "blocked":
        FeatureStatus.Blocked
    else:
        FeatureStatus.Planned
