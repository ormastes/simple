# MCP Library - Helper Utilities
#
# JSON building, string escaping, parsing utilities.
# Extracted from app.mcp.helpers to enable library reuse.


use std.common.text.{NL, escape_json, parse_i64}

# --- Brace helpers (avoid f-string interpolation issues) ---
fn LB() -> text:
    (123 as char).to_string()

fn RB() -> text:
    (125 as char).to_string()

fn Q() -> text:
    "\""

# --- Integer parsing ---
fn parse_int(s: text) -> i64:
    parse_i64(s)

# --- Math helpers ---
fn min_int(a: i64, b: i64) -> i64:
    if a < b: a else: b

# --- Option unwrap helpers ---
fn unwrap_idx(opt_idx: i64) -> i64:
    if opt_idx == -1: -1 else: opt_idx

fn unwrap_str(s: text) -> text:
    s

# --- Argument processing ---
fn get_clean_args(args: [text]) -> [text]:
    # Filter out runtime-specific args
    var clean = []
    var skip_next = false
    for arg in args:
        if skip_next:
            skip_next = false
        elif arg.starts_with("--jit"):
            skip_next = true
        elif arg.starts_with("--backend"):
            skip_next = true
        elif not arg.starts_with("--"):
            clean = clean + [arg]
    clean

fn has_flag(args: [text], flag: text) -> bool:
    for arg in args:
        if arg == flag:
            return true
    false

# --- JSON Pair Building ---
fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

fn jo1(p1: text) -> text:
    LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

fn jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + RB()

fn jo5(p1: text, p2: text, p3: text, p4: text, p5: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + "," + p5 + RB()

# --- JSON String Extraction (simple parser) ---
fn extract_json_string_v2(json: text, key: text) -> text:
    val pattern = Q() + key + Q() + ":"
    val idx = json.index_of(pattern) ?? -1
    if idx == -1:
        return ""

    val after_colon = json.substring(idx + pattern.len())
    var start = -1
    var i = 0

    # Skip whitespace
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch == '"':
            start = i + 1
            break
        i = i + 1

    if start == -1:
        return ""

    # Find closing quote
    i = start
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch == '"':
            return after_colon.substring(start, i)
        i = i + 1

    ""

fn extract_json_string(json: text, key: text) -> text:
    extract_json_string_v2(json: json, key: key)

# Extract JSON value (numeric or string ID)
fn extract_json_value(json: text, key: text) -> text:
    val pattern = Q() + key + Q() + ":"
    val idx = json.index_of(pattern) ?? -1
    if idx == -1:
        return "null"

    val after_colon = json.substring(idx + pattern.len())
    var start = -1
    var i = 0

    # Skip whitespace
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch != ' ' and ch != '\t' and ch != '\n':
            start = i
            break
        i = i + 1

    if start == -1:
        return "null"

    # Extract until comma or brace
    i = start
    var value = ""
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch == ',' or ch == '}' or ch == '\n':
            break
        value = value + ch.to_string()
        i = i + 1

    value.trim()

# Extract nested string: params.key
fn extract_nested_string(json: text, parent: text, key: text) -> text:
    val parent_pattern = Q() + parent + Q() + ":"
    val idx = json.index_of(parent_pattern) ?? -1
    if idx == -1:
        return ""

    val after_parent = json.substring(idx + parent_pattern.len())
    extract_json_string_v2(json: after_parent, key: key)

# Extract arguments dict from tools/call
fn extract_arguments_dict(json: text) -> text:
    val pattern = Q() + "arguments" + Q() + ":"
    val idx = json.index_of(pattern) ?? -1
    if idx == -1:
        return "{}"

    val after_colon = json.substring(idx + pattern.len())
    var start = -1
    var i = 0

    # Skip whitespace, find opening brace
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch == '{':
            start = i
            break
        i = i + 1

    if start == -1:
        return "{}"

    # Find matching closing brace
    var depth = 1
    i = start + 1
    while i < after_colon.len():
        val ch = after_colon[i]
        if ch == '{':
            depth = depth + 1
        elif ch == '}':
            depth = depth - 1
            if depth == 0:
                return after_colon.substring(start, i + 1)
        i = i + 1

    "{}"

# --- Argument Extraction ---
fn extract_arg(body: text, key: text) -> text:
    # Extract string argument from MCP request body
    val search = Q() + key + Q() + ":"
    val idx = body.index_of(search) ?? -1
    if idx == -1:
        return ""
    val start = idx + search.len()
    val rest = body.substring(start).trim()
    if not rest.starts_with(Q()):
        return ""
    val after_quote = rest.substring(1)
    val end_idx = after_quote.index_of(Q()) ?? -1
    if end_idx == -1:
        return ""
    after_quote.substring(0, end_idx)

# --- MCP Response Builders ---
fn make_result_response(id: text, result: text) -> text:
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "result", value: result))

fn make_error_response(id: text, code: i64, message: text) -> text:
    val error = jo2(p1: jp(key: "code", value: code.to_string()), p2: jp(key: "message", value: js(value: message)))
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "error", value: error))

fn make_tool_result(id: text, content_text: text) -> text:
    val content_obj = jo2(p1: jp(key: "type", value: js(value: "text")), p2: jp(key: "text", value: js(value: content_text)))
    val result = jo2(p1: jp(key: "content", value: "[" + content_obj + "]"), p2: jp(key: "isError", value: "false"))
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "result", value: result))

fn make_notification(method: text, params: text) -> text:
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "method", value: js(value: method)), p3: jp(key: "params", value: params))

fn make_notification_no_params(method: text) -> text:
    jo2(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "method", value: js(value: method)))

# --- List changed notifications ---
fn make_tools_list_changed() -> text:
    make_notification_no_params("notifications/tools/list_changed")

fn make_resources_list_changed() -> text:
    make_notification_no_params("notifications/resources/list_changed")

fn make_prompts_list_changed() -> text:
    make_notification_no_params("notifications/prompts/list_changed")

# --- Diagnostic notification ---
fn emit_diagnostic_notification(uri: text, diagnostics: [text]) -> text:
    """Build a JSON-RPC notification for diagnostics on a file.
    Format: method: "notifications/diagnostics"
    params: {uri: "...", diagnostics: [...]}
    Each diagnostic should be a JSON object string with severity, code, message, line, col fields.
    """
    val diags_array = "[" + diagnostics.join(",") + "]"
    val params = jo2(p1: jp(key: "uri", value: js(value: uri)), p2: jp(key: "diagnostics", value: diags_array))
    make_notification(method: "notifications/diagnostics", params: params)

# --- Log level conversion (syslog-style, MCP protocol) ---
fn log_level_to_int(level: text) -> i64:
    if level == "debug": 0
    elif level == "info": 1
    elif level == "notice": 2
    elif level == "warning": 3
    elif level == "error": 4
    elif level == "critical": 5
    elif level == "alert": 6
    elif level == "emergency": 7
    else: -1

# --- Log notification builder ---
fn make_log_notification(level: text, message: text, logger: text) -> text:
    var params = jo2(p1: jp(key: "level", value: js(value: level)), p2: jp(key: "data", value: jo1(p1: jp(key: "message", value: js(value: message)))))
    if logger != "":
        params = jo3(p1: jp(key: "level", value: js(value: level)), p2: jp(key: "logger", value: js(value: logger)), p3: jp(key: "data", value: jo1(p1: jp(key: "message", value: js(value: message)))))
    make_notification(method: "notifications/message", params: params)

# --- Progress notification builder ---
fn make_progress_notification(progress_token: text, progress: i64, total: i64, message: text) -> text:
    var params = jo3(
        p1: jp(key: "progressToken", value: js(value: progress_token)),
        p2: jp(key: "progress", value: progress.to_string()),
        p3: jp(key: "total", value: total.to_string())
    )
    if message != "":
        params = jo4(
            p1: jp(key: "progressToken", value: js(value: progress_token)),
            p2: jp(key: "progress", value: progress.to_string()),
            p3: jp(key: "total", value: total.to_string()),
            p4: jp(key: "message", value: js(value: message))
        )
    make_notification(method: "notifications/progress", params: params)

# --- Image content builder ---
fn make_image_content(base64_data: text, mime_type: text) -> text:
    jo3(p1: jp(key: "type", value: js(value: "image")), p2: jp(key: "data", value: js(value: base64_data)), p3: jp(key: "mimeType", value: js(value: mime_type)))

# --- Audio content builder ---
fn make_audio_content(base64_data: text, mime_type: text) -> text:
    jo3(p1: jp(key: "type", value: js(value: "audio")), p2: jp(key: "data", value: js(value: base64_data)), p3: jp(key: "mimeType", value: js(value: mime_type)))

# --- Resource link content builders ---
fn make_resource_link_content(uri: text, name: text) -> text:
    jo3(p1: jp(key: "type", value: js(value: "resource_link")), p2: jp(key: "uri", value: js(value: uri)), p3: jp(key: "name", value: js(value: name)))

fn make_resource_link_content_full(uri: text, name: text, title: text, description: text, mime_type: text, size: i64) -> text:
    val parts = jp(key: "type", value: js(value: "resource_link")) + "," + jp(key: "uri", value: js(value: uri)) + "," + jp(key: "name", value: js(value: name)) + "," + jp(key: "title", value: js(value: title)) + "," + jp(key: "description", value: js(value: description)) + "," + jp(key: "mimeType", value: js(value: mime_type))
    LB() + parts + RB()

# --- Embedded resource content builder ---
fn make_embedded_resource_content(uri: text, content: text, mime_type: text) -> text:
    val resource = jo3(p1: jp(key: "uri", value: js(value: uri)), p2: jp(key: "text", value: js(value: content)), p3: jp(key: "mimeType", value: js(value: mime_type)))
    jo2(p1: jp(key: "type", value: js(value: "resource")), p2: jp(key: "resource", value: resource))

# --- Content annotations builder ---
fn make_content_annotations(audience: [text], priority: text, last_modified: text) -> text:
    var parts = ""
    var count = 0
    if audience.len() > 0:
        var arr_parts: [text] = []
        var i = 0
        while i < audience.len():
            if i > 0:
                arr_parts.push(",")
            arr_parts.push(js(value: audience[i]))
            i = i + 1
        val arr = "[" + arr_parts.join("") + "]"
        parts = jp(key: "audience", value: arr)
        count = count + 1
    if priority != "":
        if count > 0:
            parts = parts + ","
        parts = parts + jp(key: "priority", value: priority)
        count = count + 1
    if last_modified != "":
        if count > 0:
            parts = parts + ","
        parts = parts + jp(key: "lastModified", value: js(value: last_modified))
        count = count + 1
    LB() + parts + RB()

# --- Tool result with structured content ---
fn make_tool_result_with_structured(id: text, content: text, structured_content: text) -> text:
    val result = jo3(p1: jp(key: "content", value: content), p2: jp(key: "structuredContent", value: structured_content), p3: jp(key: "isError", value: "false"))
    jo3(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "result", value: result))

# --- Register tool (schema without outputSchema) ---
fn register_tool(name: text, description: text, param_names: [text], param_descs: [text], required: [text], has_input: bool, has_streaming: bool, has_other: bool) -> text:
    var prop_parts: [text] = []
    var i = 0
    while i < param_names.len():
        if i > 0:
            prop_parts.push(",")
        prop_parts.push(jp(key: param_names[i], value: jo2(p1: jp(key: "type", value: js(value: "string")), p2: jp(key: "description", value: js(value: param_descs[i])))))
        i = i + 1
    val props = prop_parts.join("")
    var req_parts: [text] = []
    req_parts.push("[")
    i = 0
    while i < required.len():
        if i > 0:
            req_parts.push(",")
        req_parts.push(js(required[i]))
        i = i + 1
    req_parts.push("]")
    val req_array = req_parts.join("")
    val input_schema = jo3(p1: jp(key: "type", value: js(value: "object")), p2: jp(key: "properties", value: LB() + props + RB()), p3: jp(key: "required", value: req_array))
    jo3(p1: jp(key: "name", value: js(value: name)), p2: jp(key: "description", value: js(value: description)), p3: jp(key: "inputSchema", value: input_schema))

# --- Tool schema with output schema ---
fn make_tool_schema_with_output(name: text, description: text, properties: text, required: text, output_schema: text, has_input_schema: bool, has_streaming: bool, has_other: bool) -> text:
    val input_schema = jo3(
        p1: jp(key: "type", value: js(value: "object")),
        p2: jp(key: "properties", value: properties),
        p3: jp(key: "required", value: required)
    )
    jo4(
        p1: jp(key: "name", value: js(value: name)),
        p2: jp(key: "description", value: js(value: description)),
        p3: jp(key: "inputSchema", value: input_schema),
        p4: jp(key: "outputSchema", value: output_schema)
    )

# --- Tool schema builders ---
fn make_tool_schema_multi(
    name: text,
    description: text,
    required_params: [text],
    param_types: [text],
    param_descs: [text]
) -> text:
    var prop_parts: [text] = []
    var i = 0
    while i < required_params.len():
        if i > 0:
            prop_parts.push(",")
        val param_name = required_params[i]
        val param_type = param_types[i]
        val param_desc = param_descs[i]
        val prop = jo2(p1: jp(key: "type", value: js(value: param_type)), p2: jp(key: "description", value: js(value: param_desc)))
        prop_parts.push(Q() + param_name + Q() + ":" + prop)
        i = i + 1
    val props = prop_parts.join("")

    var req_parts: [text] = []
    req_parts.push("[")
    i = 0
    while i < required_params.len():
        if i > 0:
            req_parts.push(",")
        req_parts.push(js(required_params[i]))
        i = i + 1
    req_parts.push("]")
    val req_array = req_parts.join("")

    val props_obj = LB() + props + RB()
    val input_schema = jo3(
        p1: jp(key: "type", value: js(value: "object")),
        p2: jp(key: "properties", value: props_obj),
        p3: jp(key: "required", value: req_array)
    )

    jo3(
        p1: jp(key: "name", value: js(value: name)),
        p2: jp(key: "description", value: js(value: description)),
        p3: jp(key: "inputSchema", value: input_schema)
    )

# --- File content type detection ---
fn detect_file_content_type(path: text) -> text:
    val ext = _get_extension(path)
    if ext == "png" or ext == "jpg" or ext == "jpeg" or ext == "gif" or ext == "webp" or ext == "svg" or ext == "bmp" or ext == "ico":
        "image"
    elif ext == "wav" or ext == "mp3" or ext == "ogg" or ext == "flac" or ext == "aac":
        "audio"
    elif ext == "mp4" or ext == "webm" or ext == "avi" or ext == "mkv":
        "video"
    elif ext == "pdf" or ext == "zip" or ext == "tar" or ext == "gz" or ext == "wasm":
        "application"
    else:
        "text"

fn detect_mime_type(path: text) -> text:
    val ext = _get_extension(path)
    if ext == "html" or ext == "htm": "text/html"
    elif ext == "css": "text/css"
    elif ext == "js": "text/javascript"
    elif ext == "json": "application/json"
    elif ext == "xml": "text/xml"
    elif ext == "csv": "text/csv"
    elif ext == "md": "text/markdown"
    elif ext == "txt": "text/plain"
    elif ext == "spl": "text/x-simple"
    elif ext == "py": "text/x-python"
    elif ext == "rs": "text/x-rust"
    elif ext == "c" or ext == "h": "text/x-c"
    elif ext == "cpp" or ext == "hpp": "text/x-c++"
    elif ext == "java": "text/x-java"
    elif ext == "go": "text/x-go"
    elif ext == "rb": "text/x-ruby"
    elif ext == "sh": "text/x-shellscript"
    elif ext == "png": "image/png"
    elif ext == "jpg" or ext == "jpeg": "image/jpeg"
    elif ext == "gif": "image/gif"
    elif ext == "svg": "image/svg+xml"
    elif ext == "webp": "image/webp"
    elif ext == "bmp": "image/bmp"
    elif ext == "ico": "image/x-icon"
    elif ext == "wav": "audio/wav"
    elif ext == "mp3": "audio/mpeg"
    elif ext == "ogg": "audio/ogg"
    elif ext == "pdf": "application/pdf"
    elif ext == "zip": "application/zip"
    elif ext == "wasm": "application/wasm"
    elif ext == "yaml" or ext == "yml": "text/yaml"
    elif ext == "toml": "text/toml"
    elif ext == "sdn": "text/x-sdn"
    else: "text/plain"

fn _get_extension(path: text) -> text:
    val dot_idx = path.last_index_of(".") ?? -1
    if dot_idx == -1:
        return ""
    path.substring(dot_idx + 1)

# --- Resource updated notification ---
fn make_resource_updated_notification(uri: text) -> text:
    val params = jo1(p1: jp(key: "uri", value: js(value: uri)))
    make_notification(method: "notifications/resources/updated", params: params)

# --- Sampling request builder ---
fn make_sampling_request(id: text, messages: text, model_preferences: text, max_tokens: i64) -> text:
    val params = jo3(
        p1: jp(key: "messages", value: messages),
        p2: jp(key: "modelPreferences", value: model_preferences),
        p3: jp(key: "maxTokens", value: max_tokens.to_string())
    )
    jo4(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "method", value: js(value: "sampling/createMessage")), p4: jp(key: "params", value: params))

# --- Elicitation request builder ---
fn make_elicitation_request(id: text, message: text, requested_schema: text) -> text:
    val params = jo2(p1: jp(key: "message", value: js(value: message)), p2: jp(key: "requestedSchema", value: requested_schema))
    jo4(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "method", value: js(value: "elicitation/create")), p4: jp(key: "params", value: params))

# --- Server request builder ---
fn make_server_request(id: text, method: text, params: text) -> text:
    jo4(p1: jp(key: "jsonrpc", value: js(value: "2.0")), p2: jp(key: "id", value: id), p3: jp(key: "method", value: js(value: method)), p4: jp(key: "params", value: params))
