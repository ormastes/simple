# Full MCP Server for Simple Language
#
# All debug/diagnostic tools + resources + prompts + completions.
# Protocol: Content-Length framed (std.mcp.protocol).
#
# Tool dispatch uses DI-resolved handler adapters (in-process).
# SessionManager persists across calls for state retention.
#
# Tool groups:
#   debug_*       (19) - Debug session/breakpoint/inspect tools
#   debug_log_*   (6)  - AOP debug logging tools
#   simple_read/check/symbols/status/expand_at (5)  - Diagnostic read tools
#   simple_edit/multi_edit/run       (3)  - Diagnostic edit tools
#   simple_diff/log/squash/new      (4)  - Diagnostic VCS tools

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> text
extern fn rt_env_get(name: text) -> text

# JSON and response helpers
use std.nogc_async_mut.mcp.helpers.{LB, RB, jp, js, jo1, escape_json, extract_json_string_v2, extract_json_value, extract_nested_string, extract_arguments_dict, make_result_response, make_error_response, emit_diagnostic_notification}
use std.nogc_async_mut.mcp.helpers.{make_no_param_tool}

# Protocol I/O
use std.nogc_async_mut.mcp.protocol.{create_protocol_state, protocol_read_message, protocol_write_message}

# SDK server builder + router
use std.mcp_sdk.server.builder.{ServerConfig, server_config, server_set_instructions, server_set_capabilities, server_add_tool_json}
use std.mcp_sdk.server.router.{handle_method}
use std.mcp_sdk.core.types.{McpCapabilities}

# DI runtime
use compiler.di_runtime.{di_register, di_resolve}
use compiler.di_config.{di_setup_from_config}

# Handler adapters (DI-resolved, in-process dispatch)
use std.nogc_async_mut.mcp.handler_adapters.debug_adapter.{create_debug_handler}
use std.nogc_async_mut.mcp.handler_adapters.debug_log_adapter.{create_debug_log_handler, dispatch_debuglog_resource}
use std.nogc_async_mut.mcp.handler_adapters.diag_adapter.{create_diag_handler}

# ============================================================================
# Constants
# ============================================================================

val NL = "\n"

# ============================================================================
# Module state
# ============================================================================

var PROTOCOL = create_protocol_state()

# ============================================================================
# Entry point
# ============================================================================

init_di()
start_server()

fn init_di():
    val lib_root = rt_env_get("SIMPLE_LIB") ?? ""
    var config_path = "config/di.sdn"
    if lib_root != "":
        config_path = lib_root + "/../config/di.sdn"
    val config_content = rt_file_read_text(config_path) ?? ""
    val profile = rt_env_get("SIMPLE_PROFILE") ?? ""
    di_setup_from_config(config_content, profile)
    # Override placeholders with real factories
    di_register("debug_handler", fn(): create_debug_handler(), true)
    di_register("debug_log_handler", fn(): create_debug_log_handler(), true)
    di_register("diag_handler", fn(): create_diag_handler(), true)

# ============================================================================
# Server config (built once at startup)
# ============================================================================

fn build_server_config() -> ServerConfig:
    var cfg = server_config("simple-mcp", "3.0.0")
    cfg = server_set_instructions(cfg, "Simple language MCP server: 33 tools for debugging, diagnostics, editing, and version control.")
    cfg = server_set_capabilities(cfg, McpCapabilities(
        tools: true,
        tools_list_changed: true,
        resources: true,
        resources_subscribe: true,
        resources_list_changed: true,
        prompts: true,
        prompts_list_changed: true,
        logging: true,
        completions: true
    ))

    # Debug tools (16)
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_create_session", description: "Create a debug session"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_list_sessions", description: "List active debug sessions"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_close_session", description: "Close a debug session"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_set_breakpoint", description: "Set a breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_remove_breakpoint", description: "Remove a breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_continue", description: "Continue execution"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_step", description: "Step through code"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_get_variables", description: "Get variable values"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_stack_trace", description: "Get stack trace"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_evaluate", description: "Evaluate expression"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_set_function_breakpoint", description: "Set function breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_enable_breakpoint", description: "Enable/disable breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_get_source", description: "Get source code"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_watch", description: "Add watch expression"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_set_variable", description: "Set variable value"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_set_data_breakpoint", description: "Set variable-change breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_list_data_breakpoints", description: "List variable-change breakpoints"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_remove_data_breakpoint", description: "Remove variable-change breakpoint"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_terminate", description: "Terminate debug session"))

    # Debug log tools (6)
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_enable", description: "Enable debug logging"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_disable", description: "Disable debug logging"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_clear", description: "Clear debug logs"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_query", description: "Query debug logs"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_tree", description: "Get debug log tree"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "debug_log_status", description: "Get debug log status"))

    # Diagnostic tools (12)
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_read", description: "Read Simple source with diagnostics"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_check", description: "Check Simple source for errors"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_diagnostics", description: "Run diagnostics returning MCP-formatted structured content"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_symbols", description: "List symbols in file with visibility metadata"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_status", description: "Get project status"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_expand_at", description: "Expand symbol at position"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_edit", description: "Edit Simple source file"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_multi_edit", description: "Edit multiple files"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_run", description: "Run Simple code"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_diff", description: "Show file diff"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_log", description: "Show version history"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_squash", description: "Squash commits"))
    cfg = server_add_tool_json(cfg, "", make_tool_schema(name: "simple_new", description: "Create new change"))

    cfg

fn make_tool_schema(name: text, description: text) -> text:
    make_no_param_tool(name: name, desc: description, read_only: false, destructive: false, idempotent: false)

# ============================================================================
# Server loop
# ============================================================================

fn start_server():
    val CFG = build_server_config()

    for _iter in range(0, 999999):
        val line = protocol_read_message(PROTOCOL)
        if line == "":
            return
        val method = extract_json_string_v2(line, "method")
        val id = extract_json_value(line, "id")
        var response = ""

        # Intercept methods that need local handling
        if method == "resources/list":
            response = handle_resources_list(id)
        elif method == "resources/templates/list":
            response = handle_resource_templates_list(id)
        elif method == "prompts/list":
            response = handle_prompts_list(id)
        else:
            # SDK router handles builtins + returns sentinels for custom dispatch
            response = handle_method(CFG, method, id, line)
            if response == "TOOLS_CALL":
                val tool_name = extract_nested_string(line, "params", "name")
                response = dispatch_tool(id: id, tool_name: tool_name, body: line)
            elif response == "RESOURCES_READ":
                val uri = extract_nested_string(line, "params", "uri")
                response = handle_resources_read(id: id, uri: uri)
            elif response == "PROMPTS_GET":
                val prompt_name = extract_nested_string(line, "params", "name")
                response = handle_prompts_get(id: id, prompt_name: prompt_name, body: line)
            elif response == "COMPLETION":
                response = handle_completion_req(id: id, body: line)
            elif response == "EXIT":
                return

        if response != "":
            protocol_write_message(PROTOCOL, response)
            # Emit diagnostic notification after simple_check tool calls
            if method == "tools/call":
                val called_tool = extract_nested_string(line, "params", "name")
                if called_tool == "simple_check":
                    val check_path = _extract_tool_arg(body: line, key: "path")
                    if check_path != "":
                        val diag_notif = _build_diagnostic_notification(path: check_path, tool_response: response)
                        if diag_notif != "":
                            protocol_write_message(PROTOCOL, diag_notif)

# ============================================================================
# Tool dispatch
# ============================================================================

fn dispatch_tool(id: text, tool_name: text, body: text) -> text:
    if tool_name == "":
        return make_error_response(id, -32602, "Missing tool name")
    if tool_name.starts_with("debug_log_"):
        val handler = di_resolve("debug_log_handler")
        if handler == nil:
            return make_error_response(id, -32603, "Handler not available: debug_log_handler")
        return handler.handle_fn(tool_name, id, body)
    elif tool_name.starts_with("debug_"):
        val handler = di_resolve("debug_handler")
        if handler == nil:
            return make_error_response(id, -32603, "Handler not available: debug_handler")
        return handler.handle_fn(tool_name, id, body)
    elif tool_name.starts_with("simple_"):
        val handler = di_resolve("diag_handler")
        if handler == nil:
            return make_error_response(id, -32603, "Handler not available: diag_handler")
        return handler.handle_fn(tool_name, id, body)
    make_error_response(id, -32601, "Unknown tool: " + tool_name)

# ============================================================================
# Resources
# ============================================================================

fn make_resource_json(uri: text, name: text, desc: text, mime: text) -> text:
    var rp: [text] = []
    rp.push(LB())
    rp.push(jp("uri", js(uri)))
    rp.push(",")
    rp.push(jp("name", js(name)))
    if desc != "":
        rp.push(",")
        rp.push(jp("description", js(desc)))
    if mime != "":
        rp.push(",")
        rp.push(jp("mimeType", js(mime)))
    rp.push(RB())
    rp.join("")

fn build_resources_json() -> text:
    var res: [text] = []
    res.push(make_resource_json(uri: "project:///info", name: "Project Information", desc: "Project metadata and manifest", mime: "text/plain"))
    res.push(make_resource_json(uri: "file:///*", name: "File Contents", desc: "Read file contents", mime: "text/plain"))
    res.push(make_resource_json(uri: "symbol:///*", name: "Symbol Information", desc: "Get symbol details", mime: "application/json"))
    res.push(make_resource_json(uri: "type:///*", name: "Type Information", desc: "Get type details", mime: "application/json"))
    res.push(make_resource_json(uri: "docs:///*", name: "Documentation", desc: "Get documentation", mime: "text/markdown"))
    res.push(make_resource_json(uri: "tree:///*", name: "Directory Tree", desc: "Get directory structure", mime: "text/plain"))
    # BugDB
    res.push(make_resource_json(uri: "bugdb:///all", name: "All Bugs", desc: "All bugs from bug database", mime: "application/json"))
    res.push(make_resource_json(uri: "bugdb:///open", name: "Open Bugs", desc: "Open bugs from bug database", mime: "application/json"))
    res.push(make_resource_json(uri: "bugdb:///critical", name: "Critical Bugs", desc: "Critical bugs (P0/P1)", mime: "application/json"))
    res.push(make_resource_json(uri: "bugdb:///stats", name: "Bug Statistics", desc: "Bug database statistics", mime: "application/json"))
    # FeatureDB
    res.push(make_resource_json(uri: "featuredb:///all", name: "All Features", desc: "All features from feature database", mime: "application/json"))
    res.push(make_resource_json(uri: "featuredb:///stats", name: "Feature Statistics", desc: "Feature database statistics", mime: "application/json"))
    # TestDB
    res.push(make_resource_json(uri: "testdb:///runs", name: "Test Runs", desc: "All test runs", mime: "application/json"))
    res.push(make_resource_json(uri: "testdb:///stats", name: "Test Statistics", desc: "Test statistics", mime: "application/json"))
    res.push(make_resource_json(uri: "testdb:///flaky", name: "Flaky Tests", desc: "Flaky tests", mime: "application/json"))
    # Debug Log
    res.push(make_resource_json(uri: "debuglog:///tree", name: "Debug Log Tree", desc: "Collapsible call tree from AOP debug logger", mime: "application/json"))
    res.push(make_resource_json(uri: "debuglog:///entries", name: "Debug Log Entries", desc: "All debug log entries", mime: "application/json"))
    res.push(make_resource_json(uri: "debuglog:///status", name: "Debug Log Status", desc: "Current debug logging status", mime: "application/json"))
    res.push(make_resource_json(uri: "debuglog:///text", name: "Debug Log Text", desc: "Plain text call tree", mime: "text/plain"))
    "[" + res.join(",") + "]"

fn handle_resources_list(id: text) -> text:
    val result = jo1(jp("resources", build_resources_json()))
    make_result_response(id: id, result: result)

fn handle_resource_templates_list(id: text) -> text:
    var t1 = LB()
    t1 = t1 + jp("uriTemplate", js("file:///" + LB() + "path" + RB()))
    t1 = t1 + "," + jp("name", js("File Contents"))
    t1 = t1 + "," + jp("description", js("Read file contents by path"))
    t1 = t1 + "," + jp("mimeType", js("text/plain"))
    t1 = t1 + RB()

    var t2 = LB()
    t2 = t2 + jp("uriTemplate", js("symbol:///" + LB() + "symbol_name" + RB()))
    t2 = t2 + "," + jp("name", js("Symbol Information"))
    t2 = t2 + "," + jp("description", js("Get symbol details by name"))
    t2 = t2 + "," + jp("mimeType", js("application/json"))
    t2 = t2 + RB()

    var t3 = LB()
    t3 = t3 + jp("uriTemplate", js("type:///" + LB() + "type_name" + RB()))
    t3 = t3 + "," + jp("name", js("Type Information"))
    t3 = t3 + "," + jp("description", js("Get type details by name"))
    t3 = t3 + "," + jp("mimeType", js("application/json"))
    t3 = t3 + RB()

    var t4 = LB()
    t4 = t4 + jp("uriTemplate", js("docs:///" + LB() + "path" + RB()))
    t4 = t4 + "," + jp("name", js("Documentation"))
    t4 = t4 + "," + jp("description", js("Get documentation by path"))
    t4 = t4 + "," + jp("mimeType", js("text/markdown"))
    t4 = t4 + RB()

    var t5 = LB()
    t5 = t5 + jp("uriTemplate", js("tree:///" + LB() + "path" + RB()))
    t5 = t5 + "," + jp("name", js("Directory Tree"))
    t5 = t5 + "," + jp("description", js("Get directory structure"))
    t5 = t5 + "," + jp("mimeType", js("text/plain"))
    t5 = t5 + RB()

    val templates = "[" + t1 + "," + t2 + "," + t3 + "," + t4 + "," + t5 + "]"
    val result = jo1(jp("resourceTemplates", templates))
    make_result_response(id: id, result: result)

fn handle_resources_read(id: text, uri: text) -> text:
    if uri == "":
        return make_error_response(id, -32602, "Missing required parameter: uri")

    # project:///info
    if uri == "project:///info":
        return handle_resource_project_info(id: id, uri: uri)

    # file:///path
    if uri.starts_with("file:///"):
        val path = uri.substring(8)
        return handle_resource_file(id: id, uri: uri, path: path)

    # debuglog:///... (direct in-process call)
    if uri.starts_with("debuglog:///"):
        val log_content = dispatch_debuglog_resource(uri)
        if log_content.starts_with("Unknown debuglog query:"):
            return make_error_response(id, -32002, log_content)
        if log_content != "":
            var log_mime = "application/json"
            if uri.ends_with("/text"):
                log_mime = "text/plain"
            return make_resource_content_response(id: id, uri: uri, content: log_content, mime: log_mime)
        return make_resource_content_response(id: id, uri: uri, content: "[]", mime: "application/json")

    make_error_response(id, -32002, "Resource not found: " + uri)

fn handle_resource_project_info(id: text, uri: text) -> text:
    var info = "Simple Language Compiler" + NL
    info = info + "Working Dir: " + get_cwd() + NL
    val test_file = rt_file_read_text("doc/08_tracking/test/test_result.md") ?? ""
    if test_file != "":
        # Show first 500 chars of test results
        var limit = test_file.len()
        if limit > 500:
            limit = 500
        info = info + NL + "Recent Test Results:" + NL
        info = info + test_file.substring(0, limit)
    make_resource_content_response(id: id, uri: uri, content: info, mime: "text/plain")

fn handle_resource_file(id: text, uri: text, path: text) -> text:
    val file_found = rt_file_exists(path)
    if not file_found:
        return make_error_response(id, -32002, "File not found: " + path)
    val content = rt_file_read_text(path) ?? ""
    var mime = "text/plain"
    if path.ends_with(".json"):
        mime = "application/json"
    elif path.ends_with(".md"):
        mime = "text/markdown"
    make_resource_content_response(id: id, uri: uri, content: content, mime: mime)

fn make_resource_content_response(id: text, uri: text, content: text, mime: text) -> text:
    var rcp: [text] = []
    rcp.push(LB())
    rcp.push(jp("uri", js(uri)))
    rcp.push(",")
    rcp.push(jp("mimeType", js(mime)))
    rcp.push(",")
    rcp.push(jp("text", js(escape_json(content))))
    rcp.push(RB())
    val result = jo1(jp("contents", "[" + rcp.join("") + "]"))
    make_result_response(id: id, result: result)

# ============================================================================
# Prompts
# ============================================================================

fn make_prompt_arg(name: text, desc: text, required: bool) -> text:
    var rp: [text] = []
    rp.push(LB())
    rp.push(jp("name", js(name)))
    rp.push(",")
    rp.push(jp("description", js(desc)))
    var req_str = "false"
    if required:
        req_str = "true"
    rp.push(",")
    rp.push(jp("required", req_str))
    rp.push(RB())
    rp.join("")

fn make_prompt_json(name: text, desc: text, args_json: text) -> text:
    var rp: [text] = []
    rp.push(LB())
    rp.push(jp("name", js(name)))
    rp.push(",")
    rp.push(jp("description", js(desc)))
    rp.push(",")
    rp.push(jp("arguments", args_json))
    rp.push(RB())
    rp.join("")

fn build_prompts_json() -> text:
    # Refactoring prompts
    var p1 = make_prompt_json(name: "refactor-rename", desc: "Rename a symbol throughout the codebase", args_json: "[" + make_prompt_arg(name: "old_name", desc: "Current symbol name", required: true) + "," + make_prompt_arg(name: "new_name", desc: "New symbol name", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the symbol", required: false) + "]")
    var p2 = make_prompt_json(name: "refactor-extract-function", desc: "Extract code into a new function", args_json: "[" + make_prompt_arg(name: "code", desc: "Code to extract", required: true) + "," + make_prompt_arg(name: "function_name", desc: "Name for new function", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the code", required: true) + "]")
    var p3 = make_prompt_json(name: "refactor-inline", desc: "Inline a function or variable", args_json: "[" + make_prompt_arg(name: "name", desc: "Symbol to inline", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the symbol", required: true) + "]")
    # Code generation prompts
    var p4 = make_prompt_json(name: "generate-tests", desc: "Generate SPipe tests for a function or class", args_json: "[" + make_prompt_arg(name: "target", desc: "Function or class name", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the target", required: true) + "]")
    var p5 = make_prompt_json(name: "generate-trait-impl", desc: "Generate trait implementation for a class", args_json: "[" + make_prompt_arg(name: "class_name", desc: "Class name", required: true) + "," + make_prompt_arg(name: "trait_name", desc: "Trait name", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the class", required: true) + "]")
    var p6 = make_prompt_json(name: "generate-constructor", desc: "Generate constructor for a class", args_json: "[" + make_prompt_arg(name: "class_name", desc: "Class name", required: true) + "," + make_prompt_arg(name: "file", desc: "File containing the class", required: true) + "]")
    # Documentation prompts
    var p7 = make_prompt_json(name: "docs-add-docstrings", desc: "Add documentation comments to functions and classes", args_json: "[" + make_prompt_arg(name: "target", desc: "Function or class name", required: false) + "," + make_prompt_arg(name: "file", desc: "File to document", required: true) + "]")
    var p8 = make_prompt_json(name: "docs-explain-code", desc: "Explain how code works", args_json: "[" + make_prompt_arg(name: "code", desc: "Code to explain", required: false) + "," + make_prompt_arg(name: "file", desc: "File containing the code", required: false) + "]")
    var p9 = make_prompt_json(name: "docs-generate-readme", desc: "Generate README.md for the project", args_json: "[]")
    # Analysis prompts
    var p10 = make_prompt_json(name: "analyze-find-bugs", desc: "Analyze code for potential bugs", args_json: "[" + make_prompt_arg(name: "file", desc: "File to analyze", required: true) + "]")
    var p11 = make_prompt_json(name: "analyze-suggest-improvements", desc: "Suggest code improvements", args_json: "[" + make_prompt_arg(name: "file", desc: "File to analyze", required: true) + "]")
    var p12 = make_prompt_json(name: "analyze-performance", desc: "Analyze code for performance issues", args_json: "[" + make_prompt_arg(name: "file", desc: "File to analyze", required: true) + "]")

    var all = "[" + p1
    all = all + "," + p2
    all = all + "," + p3
    all = all + "," + p4
    all = all + "," + p5
    all = all + "," + p6
    all = all + "," + p7
    all = all + "," + p8
    all = all + "," + p9
    all = all + "," + p10
    all = all + "," + p11
    all = all + "," + p12
    all = all + "]"
    all

fn handle_prompts_list(id: text) -> text:
    val result = jo1(jp("prompts", build_prompts_json()))
    make_result_response(id: id, result: result)

fn handle_prompts_get(id: text, prompt_name: text, body: text) -> text:
    if prompt_name == "":
        return make_error_response(id, -32602, "Missing required parameter: name")

    # Extract arguments from request
    val args_json = extract_arguments_dict(body)

    # Build prompt messages based on prompt name
    if prompt_name == "refactor-rename":
        val old_name = extract_json_string_v2(args_json, "old_name")
        val new_name = extract_json_string_v2(args_json, "new_name")
        val file = extract_json_string_v2(args_json, "file")
        var content = "Rename the symbol '" + old_name + "' to '" + new_name + "' throughout the codebase."
        if file != "":
            content = content + " Start with file: " + file
        return make_prompt_response(id: id, description: "Rename symbol", user_content: content)
    elif prompt_name == "refactor-extract-function":
        val code = extract_json_string_v2(args_json, "code")
        val fn_name = extract_json_string_v2(args_json, "function_name")
        val file = extract_json_string_v2(args_json, "file")
        val content = "Extract the following code into a new function named '" + fn_name + "' in " + file + ":" + NL + NL + code
        return make_prompt_response(id: id, description: "Extract function", user_content: content)
    elif prompt_name == "refactor-inline":
        val sym_name = extract_json_string_v2(args_json, "name")
        val file = extract_json_string_v2(args_json, "file")
        val content = "Inline the symbol '" + sym_name + "' in " + file + ". Replace all uses with the definition and remove the original."
        return make_prompt_response(id: id, description: "Inline symbol", user_content: content)
    elif prompt_name == "generate-tests":
        val target = extract_json_string_v2(args_json, "target")
        val file = extract_json_string_v2(args_json, "file")
        val content = "Generate comprehensive SPipe tests for '" + target + "' defined in " + file + ". Use describe/it blocks with expect().to_equal() matchers."
        return make_prompt_response(id: id, description: "Generate tests", user_content: content)
    elif prompt_name == "generate-trait-impl":
        val cls = extract_json_string_v2(args_json, "class_name")
        val trait_n = extract_json_string_v2(args_json, "trait_name")
        val file = extract_json_string_v2(args_json, "file")
        val content = "Generate trait implementation of '" + trait_n + "' for class '" + cls + "' in " + file + "."
        return make_prompt_response(id: id, description: "Generate trait impl", user_content: content)
    elif prompt_name == "generate-constructor":
        val cls = extract_json_string_v2(args_json, "class_name")
        val file = extract_json_string_v2(args_json, "file")
        val content = "Generate a constructor (static fn create) for class '" + cls + "' in " + file + "."
        return make_prompt_response(id: id, description: "Generate constructor", user_content: content)
    elif prompt_name == "docs-add-docstrings":
        val target = extract_json_string_v2(args_json, "target")
        val file = extract_json_string_v2(args_json, "file")
        var content = "Add documentation comments to all public functions and classes in " + file + "."
        if target != "":
            content = "Add documentation comments to '" + target + "' in " + file + "."
        return make_prompt_response(id: id, description: "Add docstrings", user_content: content)
    elif prompt_name == "docs-explain-code":
        val code = extract_json_string_v2(args_json, "code")
        val file = extract_json_string_v2(args_json, "file")
        var content = "Explain how this code works"
        if file != "":
            content = content + " (from " + file + ")"
        if code != "":
            content = content + ":" + NL + NL + code
        return make_prompt_response(id: id, description: "Explain code", user_content: content)
    elif prompt_name == "docs-generate-readme":
        return make_prompt_response(id: id, description: "Generate README", user_content: "Generate a comprehensive README.md for the Simple language compiler project.")
    elif prompt_name == "analyze-find-bugs":
        val file = extract_json_string_v2(args_json, "file")
        val content = "Analyze " + file + " for potential bugs, null pointer issues, off-by-one errors, and logic flaws."
        return make_prompt_response(id: id, description: "Find bugs", user_content: content)
    elif prompt_name == "analyze-suggest-improvements":
        val file = extract_json_string_v2(args_json, "file")
        val content = "Suggest improvements for " + file + ": refactoring opportunities, better patterns, simplifications."
        return make_prompt_response(id: id, description: "Suggest improvements", user_content: content)
    elif prompt_name == "analyze-performance":
        val file = extract_json_string_v2(args_json, "file")
        val content = "Analyze " + file + " for performance issues: unnecessary allocations, O(n^2) patterns, redundant computations."
        return make_prompt_response(id: id, description: "Analyze performance", user_content: content)
    make_error_response(id, -32601, "Unknown prompt: " + prompt_name)

fn make_prompt_response(id: text, description: text, user_content: text) -> text:
    var co_parts: [text] = []
    co_parts.push(LB())
    co_parts.push(jp("type", js("text")))
    co_parts.push(",")
    co_parts.push(jp("text", js(escape_json(user_content))))
    co_parts.push(RB())
    val content_obj = co_parts.join("")

    var msg_parts: [text] = []
    msg_parts.push(LB())
    msg_parts.push(jp("role", js("user")))
    msg_parts.push(",")
    msg_parts.push(jp("content", content_obj))
    msg_parts.push(RB())
    val msg = msg_parts.join("")

    var res_parts: [text] = []
    res_parts.push(LB())
    res_parts.push(jp("description", js(escape_json(description))))
    res_parts.push(",")
    res_parts.push(jp("messages", "[" + msg + "]"))
    res_parts.push(RB())
    make_result_response(id: id, result: res_parts.join(""))

# ============================================================================
# Completion
# ============================================================================

fn handle_completion_req(id: text, body: text) -> text:
    # Return empty completion results
    var comp_parts: [text] = []
    comp_parts.push(LB())
    comp_parts.push(jp("values", "[]"))
    comp_parts.push(",")
    comp_parts.push(jp("total", "0"))
    comp_parts.push(",")
    comp_parts.push(jp("hasMore", "false"))
    comp_parts.push(RB())
    val result = jo1(jp("completion", comp_parts.join("")))
    make_result_response(id: id, result: result)

# ============================================================================
# Local helpers
# ============================================================================

fn get_cwd() -> text:
    var args: [text] = ["-c", "pwd"]
    val result = rt_process_run("/bin/sh", args)
    var out = result[0]
    if out.ends_with("\n"):
        out = out.substring(0, out.len() - 1)
    out

fn _extract_tool_arg(body: text, key: text) -> text:
    """Extract a string argument from the tool call arguments."""
    val args_json = extract_arguments_dict(body)
    extract_json_string_v2(args_json, key)

fn _build_diagnostic_notification(path: text, tool_response: text) -> text:
    """Build a notifications/diagnostics notification from a simple_check response.
    Extracts diagnostic data from the tool response text content.
    """
    val uri = "file://" + path
    # The tool result contains diagnostics in the text content field.
    # Emit a notification with the file URI and empty diagnostics array
    # (clients should use the tool result for the actual diagnostic data).
    var diags: [text] = []
    emit_diagnostic_notification(uri, diags)
