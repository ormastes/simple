# Test Database MCP Resource
#
# Provides MCP access to the unified test database
# Supports both read and write operations via JSON API

use std.database.test.{create_test_database, load_test_database, TestDatabase, TestRun, TestResult, RunStatus, TestStatus, TestStats}
use std.nogc_async_mut.mcp.resource_utils.{
    escape_json,
    extract_json_string, extract_json_float,
    current_timestamp, error_json, success_json, items_to_json
}
use std.nogc_sync_mut.io.file_ops.{file_exists as file_exists_backend}

fn file_exists(path: text) -> bool:
    file_exists_backend(path)


# ============================================================================
# Read Operations
# ============================================================================

fn open_or_create_test_database(db_path: text) -> TestDatabase:
    if file_exists(db_path):
        val existing = load_test_database(db_path)
        match existing:
            Some(db):
                return db
            nil:
                pass_do_nothing("test database load failed; creating a new database")
    create_test_database(db_path)

fn resolve_run_id(testdb: TestDatabase, run_id: text) -> text:
    if run_id != "":
        return run_id
    testdb.first_run_id()

# Get all test runs
fn get_all_runs(db_path: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val runs = testdb.all_runs()
    runs_to_json(runs)

fn get_all_tests(db_path: text) -> text:
    get_all_runs(db_path)

# Get recent test runs (last N)
fn get_recent_runs(db_path: text, count: i64) -> text:
    var testdb = open_or_create_test_database(db_path)
    val runs = testdb.recent_runs(count)

    var raw_items: [text] = []
    for run in runs:
        raw_items.push(run_to_json(run))

    "{\"count\":" + str(runs.len()) + ",\"runs\":[" + raw_items.join(",") + "]}"

# Get test run by ID
fn get_run_by_id(db_path: text, run_id: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val run_opt = testdb.get_run(run_id)

    match run_opt:
        Some(run):
            run_to_json(run)
        nil:
            error_json("Test run not found: {run_id}")

# Get test results for a run
fn get_test_results(db_path: text, run_id: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val resolved_run_id = resolve_run_id(testdb, run_id)
    val results = testdb.results_for_run(resolved_run_id)

    var raw_items: [text] = []
    for result in results:
        raw_items.push(result_to_json(result))

    "{\"run_id\":\"" + escape_json(resolved_run_id) + "\",\"total\":" + str(results.len()) + ",\"results\":[" + raw_items.join(",") + "]}"

# Get test statistics
fn get_test_stats(db_path: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val stats: TestStats = testdb.stats()

    "{\"total_runs\":" + str(stats.total_runs) + ",\"total_tests\":" + str(stats.total_tests) + ",\"passed\":" + str(stats.passed) + ",\"failed\":" + str(stats.failed) + ",\"pass_rate\":" + str(stats.pass_rate) + ",\"avg_duration_ms\":" + str(stats.avg_duration_ms) + "}"

# Get flaky tests (tests that sometimes pass, sometimes fail)
fn get_flaky_tests(db_path: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val flaky = testdb.flaky_tests()

    "{\"count\":" + str(flaky.len()) + ",\"tests\":" + test_text_array_json(flaky) + "}"

# Get slow tests (above threshold)
fn get_slow_tests(db_path: text, threshold_ms: f64) -> text:
    var testdb = open_or_create_test_database(db_path)
    val slow = testdb.slow_tests(threshold_ms)

    var raw_items: [text] = []
    for (test_name, duration) in slow:
        val item = "{\"name\":\"" + escape_json(test_name) + "\",\"duration_ms\":" + str(duration) + "}"
        raw_items.push(item)

    "{\"threshold_ms\":" + str(threshold_ms) + ",\"count\":" + str(slow.len()) + ",\"tests\":[" + raw_items.join(",") + "]}"

# ============================================================================
# Write Operations
# ============================================================================

# Start a new test run
fn start_test_run(db_path: text) -> text:
    var testdb = open_or_create_test_database(db_path)

    val run_id = testdb.start_run()
    val saved = testdb.save()

    if not saved:
        return error_json("Failed to save database")

    "{\"success\":true,\"run_id\":\"" + escape_json(run_id) + "\"}"

# End a test run
fn end_test_run(db_path: text, run_id: text, status: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val resolved_run_id = resolve_run_id(testdb, run_id)

    val parsed_status = parse_run_status(status)
    val ended = testdb.end_run(resolved_run_id, parsed_status)

    if not ended:
        return error_json("Failed to end run: {resolved_run_id}")

    val saved = testdb.save()
    if not saved:
        return error_json("Failed to save database")

    "{\"success\":true,\"run_id\":\"" + escape_json(resolved_run_id) + "\"}"

# Record a test result
fn record_test_result(db_path: text, run_id: text, json: text) -> text:
    var testdb = open_or_create_test_database(db_path)
    val resolved_run_id = resolve_run_id(testdb, run_id)

    val test_name = extract_json_string(json, "test_name")
    val status = extract_json_string(json, "status")
    val duration_ms = extract_json_float(json, "duration_ms")
    val error_message = extract_json_string(json, "error_message")

    if test_name == "":
        return error_json("Missing required field: test_name")

    val result = TestResult(
        test_name: test_name,
        run_id: resolved_run_id,
        status: parse_test_status(status),
        duration_ms: duration_ms,
        error_message: if error_message != "": Some(error_message) else: nil,
        timestamp: current_timestamp()
    )

    val recorded = testdb.record_result(result)
    if not recorded:
        return error_json("Failed to record result")

    val saved = testdb.save()
    if not saved:
        return error_json("Failed to save database")

    "{\"success\":true,\"test_name\":\"" + escape_json(test_name) + "\"}"

# ============================================================================
# JSON Conversion Helpers
# ============================================================================

# Convert list of runs to JSON
fn runs_to_json(runs: [TestRun]) -> text:
    items_to_json(runs, "runs", run_to_json)

# Convert single run to JSON
fn run_to_json(run: TestRun) -> text:
    var end_json = "null"
    match run.end_time:
        case Some(t):
            end_json = "\"" + escape_json(t) + "\""
        case nil:
            end_json = "null"

    "{\"run_id\":\"" + escape_json(run.run_id) + "\",\"start_time\":\"" + escape_json(run.start_time) + "\",\"end_time\":" + end_json + ",\"pid\":" + str(run.pid) + ",\"hostname\":\"" + escape_json(run.hostname) + "\",\"status\":\"" + escape_json(run_status_to_string(run.status)) + "\",\"test_count\":" + str(run.test_count) + ",\"passed\":" + str(run.passed) + ",\"failed\":" + str(run.failed) + ",\"crashed\":" + str(run.crashed) + ",\"timed_out\":" + str(run.timed_out) + "}"

# Convert single result to JSON
fn result_to_json(result: TestResult) -> text:
    var error_json_value = "null"
    match result.error_message:
        case Some(e):
            error_json_value = "\"" + escape_json(e) + "\""
        case nil:
            error_json_value = "null"

    "{\"test_name\":\"" + escape_json(result.test_name) + "\",\"run_id\":\"" + escape_json(result.run_id) + "\",\"status\":\"" + escape_json(test_status_to_string(result.status)) + "\",\"duration_ms\":" + str(result.duration_ms) + ",\"error_message\":" + error_json_value + ",\"timestamp\":\"" + escape_json(result.timestamp) + "\"}"

fn test_text_array_json(values: [text]) -> text:
    var items: [text] = []
    for value in values:
        items.push("\"" + escape_json(value) + "\"")
    "[" + items.join(",") + "]"

# ============================================================================
# Status Conversion Helpers
# ============================================================================

fn run_status_to_string(status: RunStatus) -> text:
    match status:
        case RunStatus.Running: "Running"
        case RunStatus.Completed: "Completed"
        case RunStatus.Crashed: "Crashed"
        case RunStatus.TimedOut: "TimedOut"
        case RunStatus.Interrupted: "Interrupted"

fn test_status_to_string(status: TestStatus) -> text:
    match status:
        case TestStatus.Passed: "Passed"
        case TestStatus.Failed: "Failed"
        case TestStatus.Crashed: "Crashed"
        case TestStatus.TimedOut: "TimedOut"
        case TestStatus.Skipped: "Skipped"

fn parse_run_status(s: text) -> RunStatus:
    match s:
        case "Running" | "running": RunStatus.Running
        case "Completed" | "completed": RunStatus.Completed
        case "Crashed" | "crashed": RunStatus.Crashed
        case "TimedOut" | "timed_out": RunStatus.TimedOut
        case "Interrupted" | "interrupted": RunStatus.Interrupted
        case _: RunStatus.Completed

fn parse_test_status(s: text) -> TestStatus:
    match s:
        case "Passed" | "passed": TestStatus.Passed
        case "Failed" | "failed": TestStatus.Failed
        case "Crashed" | "crashed": TestStatus.Crashed
        case "TimedOut" | "timed_out": TestStatus.TimedOut
        case "Skipped" | "skipped": TestStatus.Skipped
        case _: TestStatus.Passed
