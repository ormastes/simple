# MCP Debug Log Store - JSON serialization and tree rendering
#
# Converts DebugLogEntry arrays into JSON and collapsible tree text.
# Used by debug_log_tools.spl for MCP tool responses.

use compiler.frontend.core.aop_debug_log.{DebugLogEntry}
use std.nogc_async_mut.mcp.helpers.{LB, RB, Q, jp}

fn _nl() -> text:
    "\n"

fn _escape_json_local(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\"":
            out = out + "\\\""
        elif ch == "\n":
            out = out + "\\n"
        elif ch == "\r":
            out = out + "\\r"
        elif ch == "\t":
            out = out + "\\t"
        else:
            out = out + ch
        i = i + 1
    out

fn _json_string(value: text) -> text:
    Q() + _escape_json_local(value) + Q()


# ============================================================================
# Single Entry JSON
# ============================================================================

fn log_entry_to_json(entry: DebugLogEntry) -> text:
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp("entry_id", entry.entry_id.to_string()))
    parts.push(",")
    parts.push(jp("group_id", entry.group_id.to_string()))
    parts.push(",")
    parts.push(jp("parent_group_id", entry.parent_group_id.to_string()))
    parts.push(",")
    parts.push(jp("depth", entry.depth.to_string()))
    parts.push(",")
    parts.push(jp("entry_type", _json_string(entry.entry_type)))
    parts.push(",")
    parts.push(jp("package_path", _json_string(entry.package_path)))
    parts.push(",")
    parts.push(jp("class_name", _json_string(entry.class_name)))
    parts.push(",")
    parts.push(jp("function_name", _json_string(entry.function_name)))
    parts.push(",")
    parts.push(jp("line_number", entry.line_number.to_string()))
    parts.push(",")
    parts.push(jp("timestamp_ms", entry.timestamp_ms.to_string()))
    parts.push(",")
    parts.push(jp("duration_ms", entry.duration_ms.to_string()))
    parts.push(",")
    parts.push(jp("params_text", _json_string(entry.params_text)))
    parts.push(",")
    parts.push(jp("message", _json_string(entry.message)))
    parts.push(RB())
    parts.join("")

# ============================================================================
# Entry Array JSON
# ============================================================================

fn log_entries_to_json(entries: [DebugLogEntry]) -> text:
    var parts: [text] = []
    parts.push("[")
    var first = true
    for entry in entries:
        if not first:
            parts.push(",")
        first = false
        parts.push(log_entry_to_json(entry))
    parts.push("]")
    parts.join("")

# ============================================================================
# Tree JSON - Hierarchical by group_id/parent
# ============================================================================

fn log_tree_to_json(entries: [DebugLogEntry]) -> text:
    log_tree_to_json_mode(entries, "human")

fn log_tree_to_json_mode(entries: [DebugLogEntry], mode: text) -> text:
    # Build tree nodes from enter entries, attach exit data
    # Root nodes have parent_group_id == 0

    # First pass: collect enter entries, durations, and children-by-parent
    var enter_by_gid: {i64: DebugLogEntry} = {}
    var duration_by_gid: {i64: i64} = {}
    var children_by_parent: {i64: [DebugLogEntry]} = {}
    var root_entries: [DebugLogEntry] = []

    for entry in entries:
        if entry.entry_type == "enter":
            enter_by_gid[entry.group_id] = entry
            # Build children-by-parent lookup
            val pgid = entry.parent_group_id
            if pgid == 0:
                root_entries.push(entry)
            else:
                if children_by_parent.has(pgid):
                    var kids: [DebugLogEntry] = children_by_parent[pgid]
                    kids.push(entry)
                    children_by_parent[pgid] = kids
                else:
                    children_by_parent[pgid] = [entry]
        elif entry.entry_type == "exit":
            duration_by_gid[entry.group_id] = entry.duration_ms

    # Build JSON tree recursively via pre-built lookups
    var parts: [text] = []
    parts.push("[")
    var first_root = true
    for e in root_entries:
        if not first_root:
            parts.push(",")
        first_root = false
        parts.push(_build_tree_node_json(e, children_by_parent, duration_by_gid, mode, ""))
    parts.push("]")
    parts.join("")

fn _build_tree_node_json(entry: DebugLogEntry, children_by_parent: {i64: [DebugLogEntry]}, duration_by_gid: {i64: i64}, mode: text, parent_package: text) -> text:
    # Find duration for this group - O(1) lookup
    var dur = 0
    if duration_by_gid.has(entry.group_id):
        dur = duration_by_gid[entry.group_id]

    # Find children - O(1) lookup
    var child_parts: [text] = []
    child_parts.push("[")
    var first_child = true
    var child_count = 0
    if children_by_parent.has(entry.group_id):
        val kids: [DebugLogEntry] = children_by_parent[entry.group_id]
        child_count = kids.len()
        for child in kids:
            if not first_child:
                child_parts.push(",")
            first_child = false
            child_parts.push(_build_tree_node_json(child, children_by_parent, duration_by_gid, mode, entry.package_path))
    child_parts.push("]")
    val children = child_parts.join("")
    val default_open = _entry_default_open(entry)
    var fold_state = "collapsed"
    if default_open:
        fold_state = "open"
    var has_children = "false"
    if child_count > 0:
        has_children = "true"
    var default_open_json = "false"
    if default_open:
        default_open_json = "true"
    var package_path_delta = entry.package_path
    var repeated_package_json = "false"
    if parent_package == entry.package_path:
        package_path_delta = ""
        repeated_package_json = "true"

    var parts: [text] = []
    parts.push(LB())
    parts.push(jp("mode", _json_string(mode)))
    parts.push(",")
    parts.push(jp("group_id", entry.group_id.to_string()))
    parts.push(",")
    parts.push(jp("parent_group_id", entry.parent_group_id.to_string()))
    parts.push(",")
    parts.push(jp("function_name", _json_string(entry.function_name)))
    parts.push(",")
    parts.push(jp("package_path", _json_string(entry.package_path)))
    parts.push(",")
    parts.push(jp("package_path_delta", _json_string(package_path_delta)))
    parts.push(",")
    parts.push(jp("repeated_package", repeated_package_json))
    parts.push(",")
    parts.push(jp("class_name", _json_string(entry.class_name)))
    parts.push(",")
    parts.push(jp("line_number", entry.line_number.to_string()))
    parts.push(",")
    parts.push(jp("params_text", _json_string(entry.params_text)))
    parts.push(",")
    parts.push(jp("depth", entry.depth.to_string()))
    parts.push(",")
    parts.push(jp("duration_ms", dur.to_string()))
    parts.push(",")
    parts.push(jp("has_children", has_children))
    parts.push(",")
    parts.push(jp("child_count", child_count.to_string()))
    parts.push(",")
    parts.push(jp("collapsed_count", child_count.to_string()))
    parts.push(",")
    parts.push(jp("fold_state", _json_string(fold_state)))
    parts.push(",")
    parts.push(jp("default_open", default_open_json))
    parts.push(",")
    parts.push(jp("children", children))
    parts.push(RB())
    parts.join("")

fn _entry_default_open(entry: DebugLogEntry) -> bool:
    val msg = entry.message.to_lower()
    val fn_name = entry.function_name.to_lower()
    if msg.contains("error") or msg.contains("fail") or msg.contains("panic"):
        return true
    if fn_name.contains("error") or fn_name.contains("fail"):
        return true
    false

# ============================================================================
# Text Tree - Indented with folding markers
# ============================================================================

fn format_log_tree_text(entries: [DebugLogEntry], expanded_groups: [i64]) -> text:
    format_log_tree_text_mode(entries, expanded_groups, "human")

fn format_log_tree_text_mode(entries: [DebugLogEntry], expanded_groups: [i64], mode: text) -> text:
    if mode == "llm":
        return _format_log_tree_llm_text(entries, expanded_groups)
    var parts: [text] = []
    for entry in entries:
        val indent = _make_indent(entry.depth)
        if entry.entry_type == "enter":
            val is_expanded = _is_group_expanded(entry.group_id, expanded_groups)
            var label_parts: [text] = []
            label_parts.push(entry.package_path)
            if entry.class_name != "":
                label_parts.push("::")
                label_parts.push(entry.class_name)
            label_parts.push("::")
            label_parts.push(entry.function_name)
            val label = label_parts.join("")
            val line_info = " (line {entry.line_number})"

            if is_expanded:
                parts.push(indent)
                parts.push("v> ")
                parts.push(label)
                parts.push(line_info)
                parts.push(_nl())
                if entry.params_text != "":
                    parts.push(indent)
                    parts.push("    params: ")
                    parts.push(entry.params_text)
                    parts.push(_nl())
            else:
                parts.push(indent)
                parts.push(">> ")
                parts.push(label)
                parts.push(line_info)
                if entry.params_text != "":
                    parts.push(" > (...)")
                parts.push(_nl())
        elif entry.entry_type == "exit":
            parts.push(indent)
            parts.push("<< ")
            parts.push(entry.package_path)
            parts.push("::")
            parts.push(entry.function_name)
            parts.push(" [")
            parts.push(entry.duration_ms.to_string())
            parts.push("ms]")
            parts.push(_nl())
    parts.join("")

fn _format_log_tree_llm_text(entries: [DebugLogEntry], expanded_groups: [i64]) -> text:
    var parts: [text] = []
    parts.push("log_tree mode=llm entries=")
    parts.push(entries.len().to_string())
    parts.push(_nl())
    for entry in entries:
        if entry.entry_type == "enter":
            val indent = _make_indent(entry.depth)
            parts.push(indent)
            parts.push("- gid=")
            parts.push(entry.group_id.to_string())
            parts.push(" depth=")
            parts.push(entry.depth.to_string())
            parts.push(" fn=")
            parts.push(entry.package_path)
            if entry.class_name != "":
                parts.push("::")
                parts.push(entry.class_name)
            parts.push("::")
            parts.push(entry.function_name)
            if _is_group_expanded(entry.group_id, expanded_groups) and entry.params_text != "":
                parts.push(" params=")
                parts.push(entry.params_text)
            parts.push(_nl())
    parts.join("")

fn _make_indent(depth: i64) -> text:
    var parts: [text] = []
    for i in range(0, depth):
        parts.push("  ")
    parts.join("")

fn _is_group_expanded(group_id: i64, expanded_groups: [i64]) -> bool:
    for gid in expanded_groups:
        if gid == group_id:
            return true
    false

# ============================================================================
# Status JSON
# ============================================================================

fn log_status_to_json(enabled: bool, filter_pattern: text, entry_count: i64, current_depth: i64) -> text:
    var en_str = "false"
    if enabled:
        en_str = "true"
    var parts: [text] = []
    parts.push(LB())
    parts.push(jp("enabled", en_str))
    parts.push(",")
    parts.push(jp("filter_pattern", _json_string(filter_pattern)))
    parts.push(",")
    parts.push(jp("entry_count", entry_count.to_string()))
    parts.push(",")
    parts.push(jp("current_depth", current_depth.to_string()))
    parts.push(RB())
    parts.join("")
