# MCP Lazy Server — Protocol I/O and initialize response

extern fn stdin_read_char() -> text

# --- Protocol I/O ---

fn mcp_read_line() -> text:
    var parts: [text] = []
    while true:
        val ch = stdin_read_char()
        if ch == "":
            if parts.length() == 0:
                return ""
            return parts.join("")
        parts.push(ch)
        if ch == "\n":
            return parts.join("")

fn mcp_read_chars(count: i64) -> text:
    var parts: [text] = []
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        parts.push(ch)
        i = i + 1
    parts.join("")

fn read_stdin_message() -> text:
    var content_length = 0
    while true:
        var line = mcp_read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        if line.ends_with("\r\n"):
            line = line.substring(0, line.len() - 2)
        elif line.ends_with("\n"):
            line = line.substring(0, line.len() - 1)
        elif line.ends_with("\r"):
            line = line.substring(0, line.len() - 1)
        if line.starts_with(LB()):
            USE_JSON_LINES = true
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = int(len_str)
    if content_length <= 0:
        return ""
    mcp_read_chars(content_length)

fn write_stdout_message(body: text):
    if USE_JSON_LINES:
        print_raw(body + NL)
    else:
        var header = "Content-Length: " + str(text_byte_len(body)) + "\r" + NL + "\r" + NL
        print_raw(header)
        print_raw(body)

# --- Initialize response ---

fn make_init_response(id: text) -> text:
    if INIT_CACHE != "":
        return make_json_result(id, INIT_CACHE)
    var tools_cap = jo1(jp("listChanged", "true"))
    var resources_cap = jo2(jp("subscribe", "true"), jp("listChanged", "true"))
    var prompts_cap = jo1(jp("listChanged", "true"))
    var caps = jo3(
        jp("tools", tools_cap),
        jp("resources", resources_cap),
        jp("prompts", prompts_cap)
    )
    caps = caps.substring(0, caps.len() - 1) + "," + jp("logging", LB() + RB()) + "," + jp("completions", LB() + RB()) + "," + jp("roots", jo1(jp("listChanged", "false"))) + RB()
    val server_info = jo2(
        jp("name", js(SERVER_NAME)),
        jp("version", js(SERVER_VERSION))
    )
    val result = jo4(
        jp("protocolVersion", js("2025-06-18")),
        jp("capabilities", caps),
        jp("instructions", js("Full-featured MCP server with inline tool handlers. All 66 tools available with zero-import fast execution.")),
        jp("serverInfo", server_info)
    )
    INIT_CACHE = result
    make_json_result(id, result)
