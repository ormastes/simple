# MCP Lazy Server - Query and Analysis tool handlers (Tier 2 + Tier 3 + Tier 4)
# Tier 2: simple_definition, simple_references, simple_hover, simple_completions, simple_type_at
# Tier 3: simple_dependencies, simple_api_diff, simple_context, simple_search
# Tier 4: simple_signature_help, simple_rename, simple_code_actions, simple_workspace_symbols,
#          simple_call_hierarchy, simple_type_hierarchy, simple_semantic_tokens, simple_inlay_hints,
#          simple_selection_range, simple_document_formatting
# LSP Extras: simple_document_highlight, simple_type_definition, simple_implementation, simple_folding_range

# ============================================================================
# Tier 2 — Query API Tools (via Simple binary query CLI bridge)
# ============================================================================

use std.nogc_sync_mut.io.file_ops.{file_exists}
use std.nogc_async_mut.io.process_ops.{process_run_timeout}
use std.nogc_sync_mut.env.variables.{env_get}
use std.common.ponytail.audit.{ponytail_audit_source, ponytail_simplification_report_source}

fn _mcp_find_simple_binary() -> text:
    # Prefer SIMPLE_BINARY env var, then fall back to bin/simple
    val env_bin = env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    if file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    if file_exists("bin/simple"):
        return "bin/simple"
    if file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    if file_exists("release/x86_64-unknown-linux-gnu/simple"):
        return "release/x86_64-unknown-linux-gnu/simple"
    if file_exists("release/linux-x86_64/simple"):
        return "release/linux-x86_64/simple"
    if file_exists("release/simple"):
        return "release/simple"
    if file_exists("bootstrap/stage3/simple"):
        return "bootstrap/stage3/simple"
    "bin/simple"

fn _mcp_output_format(body: text) -> text:
    val format = extract_field(body, "format")
    if format == "":
        return "text"
    if format == "md":
        return "markdown"
    format

fn _mcp_render_context_pack(format: text, file: text, target: text, line_count: i64, target_report: text, content: text) -> text:
    if format == "json":
        return "{\"source\":\"" + _mcp_json_escape(file) + "\",\"line_count\":" + str(line_count) + ",\"target\":\"" + _mcp_json_escape(target) + "\",\"target_lines\":\"" + _mcp_json_escape(target_report) + "\",\"content\":\"" + _mcp_json_escape(content) + "\"}"
    if format == "markdown":
        return "# Context Pack\n\nsource: " + file + "\nline_count: " + str(line_count) + "\ntarget: " + target + "\ntarget_lines: " + target_report + "\n\n" + content
    "source: " + file + "\nline_count: " + str(line_count) + "\ntarget: " + target + "\ntarget_lines: " + target_report + "\n\n" + content

fn _mcp_json_escape(value: text) -> text:
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.char_code_at(i)
        if ch == 92:
            out = out + "\\\\"
        elif ch == 34:
            out = out + "\\\""
        elif ch == 10:
            out = out + "\\n"
        else:
            out = out + text.from_char_code(ch)
        i = i + 1
    out

fn _mcp_render_ponytail_report(path: text, mode: text, report: text, format: text) -> text:
    if format == "json":
        return "{\"command\":\"ponytail\",\"status\":\"ok\",\"mode\":\"" + _mcp_json_escape(mode) + "\",\"source\":\"" + _mcp_json_escape(path) + "\",\"audit\":\"" + _mcp_json_escape(report) + "\",\"report\":\"" + _mcp_json_escape(report) + "\"}"
    if format == "markdown":
        return "# Ponytail " + mode + "\n\nsource: `" + path + "`\n\n```text\n" + report + "\n```"
    report

# simple_definition — Go-to-definition
fn handle_simple_definition(id: text, body: text) -> text:
    val file = extract_field(body, "file")
    val line = extract_field(body, "line")
    val column = extract_field(body, "column")

    if file == "":
        return make_tool_error(id, -32602, "Missing required parameter: file")
    if line == "":
        return make_tool_error(id, -32602, "Missing required parameter: line")

    var cmd = "timeout 30 " + _mcp_find_simple_binary() + " query definition " + file + " " + line
    if column != "":
        cmd = cmd + " " + column
    cmd = cmd + " 2>&1"

    val (out, exit_code) = shell_cmd(cmd)
    make_tool_result(id, "-- simple_definition (exit: " + str(exit_code) + ") --\n" + out)

