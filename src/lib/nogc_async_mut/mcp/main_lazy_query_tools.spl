# simple_dependencies — Module dependency graph
fn handle_simple_dependencies(id: text, body: text) -> text:
    val file = extract_field(body, "file")
    val depth = extract_field(body, "depth")
    val format_str = extract_field(body, "format")

    var cmd = ""
    if file != "":
        # Show imports for a specific file
        cmd = "timeout 10 grep -n '^use \\|^import ' " + file + " 2>/dev/null"
        val (imports_out, _) = shell_cmd(cmd)

        # Also find reverse dependencies (who imports this module)
        val basename = file
        var module_name = ""
        # Extract module path from file path (e.g. src/lib/common/text/mod.spl -> std.text)
        val (name_out, _2) = shell_cmd("echo " + basename + " | sed 's|src/lib/||;s|src/||;s|/|.|g;s|\\.spl$||;s|\\.mod$||'")
        module_name = name_out.trim()

        var rev_cmd = "timeout 15 grep -rn 'use.*" + module_name + "\\|import.*" + module_name + "' src/ --include='*.spl' 2>/dev/null | head -30"
        val (rev_out, _3) = shell_cmd(rev_cmd)

        var out_parts: [text] = []
        out_parts.push("-- simple_dependencies file=" + file + " --\n")
        out_parts.push("\n--- Imports ---\n")
        if imports_out.trim() == "":
            out_parts.push("(no imports)\n")
        else:
            out_parts.push(imports_out)
        out_parts.push("\n--- Reverse Dependencies ---\n")
        if rev_out.trim() == "":
            out_parts.push("(no reverse dependencies found)\n")
        else:
            out_parts.push(rev_out)
        return make_tool_result(id, out_parts.join(""))
    else:
        # Project-wide dependency summary
        var summary_cmd = r"timeout 15 grep -rch '^use \|^import ' src/ --include='*.spl' 2>/dev/null | awk '{s+=$1} END {print s}'"
        val (total_out, _4) = shell_cmd(summary_cmd)

        var top_cmd = r"timeout 15 grep -roh '^use [^ .]*\.[^ .{]*' src/ --include='*.spl' 2>/dev/null | sort | uniq -c | sort -rn | head -20"
        val (top_out, _5) = shell_cmd(top_cmd)

        var out_parts: [text] = []
        out_parts.push("-- simple_dependencies (project summary) --\n")
        out_parts.push("Total import statements: " + total_out.trim() + "\n")
        out_parts.push("\n--- Most imported modules ---\n")
        out_parts.push(top_out)
        return make_tool_result(id, out_parts.join(""))

# simple_api_diff — API surface diff
fn handle_simple_api_diff(id: text, body: text) -> text:
    val file = extract_field(body, "file")
    val revision = extract_field(body, "revision")

    if file == "":
        return make_tool_error(id, -32602, "Missing required parameter: file")

    var rev = "HEAD"
    if revision != "":
        rev = revision

    # Get current public API (fn, class, struct, enum, export)
    val (current_api, _) = shell_cmd("timeout 10 grep -n '^fn \\|^class \\|^struct \\|^enum \\|^export ' " + file + " 2>/dev/null")

    # Get previous version API
    val (prev_api, prev_exit) = shell_cmd("timeout 10 git show " + rev + ":" + file + " 2>/dev/null | grep -n '^fn \\|^class \\|^struct \\|^enum \\|^export '")

    var out_parts: [text] = []
    out_parts.push("-- simple_api_diff file=" + file + " revision=" + rev + " --\n")

    if prev_exit != 0:
        out_parts.push("(file not found in revision " + rev + ", showing current API only)\n\n")
        out_parts.push("--- Current API ---\n")
        if current_api.trim() == "":
            out_parts.push("(no public symbols)\n")
        else:
            out_parts.push(current_api)
    else:
        out_parts.push("\n--- Previous API (" + rev + ") ---\n")
        out_parts.push(prev_api)
        out_parts.push("\n--- Current API ---\n")
        out_parts.push(current_api)

        # Show unified diff of API lines
        val (diff_out, _2) = shell_cmd("timeout 10 diff <(git show " + rev + ":" + file + " 2>/dev/null | grep '^fn \\|^class \\|^struct \\|^enum \\|^export ') <(grep '^fn \\|^class \\|^struct \\|^enum \\|^export ' " + file + " 2>/dev/null) 2>/dev/null")
        if diff_out.trim() != "":
            out_parts.push("\n--- API Changes ---\n")
            out_parts.push(diff_out)
        else:
            out_parts.push("\n(no API changes)\n")

    make_tool_result(id, out_parts.join(""))

# simple_context — Context pack for AI/docs
fn handle_simple_context(id: text, body: text) -> text:
    val file = extract_field(body, "file")
    val target = extract_field(body, "target")
    val query = extract_field(body, "query")
    val index = extract_field(body, "index")
    val sql = extract_field(body, "sql")
    val db_path = extract_field(body, "db")
    val source_filter = extract_field(body, "source_filter")
    val format = _mcp_output_format(body)

    val sql_enabled = sql == "true" or sql == "1" or sql == "yes"
    val sourceless_sql_query = file == "" and sql_enabled and query != ""
    if file == "" and not sourceless_sql_query:
        return make_tool_error(id, -32602, "Missing required parameter: file")
    if format != "text" and format != "markdown" and format != "json":
        return make_tool_error(id, -32602, "Invalid format: " + format)

    var out_parts: [text] = []
    if sourceless_sql_query:
        out_parts.push("-- simple_context sql query db=" + db_path + " --\n")
    else:
        out_parts.push("-- simple_context file=" + file + " --\n")
    out_parts.push("Budget: bounded\n")

    # 1. Source summary
    var line_num = 0
    if not sourceless_sql_query:
        val source = file_read(file)
        if source == "":
            return make_tool_error(id, -32602, "Could not read file: " + file)

        val lines = source.split("\n")
        for _line in lines:
            line_num = line_num + 1

        out_parts.push("\n--- Source Summary (" + str(line_num) + " lines) ---\n")
        if target == "":
            out_parts.push("Full source omitted; pass target for focused matching lines.\n")

    # 2. Shared bounded context pack.
    out_parts.push("\n--- Context Pack ---\n")
    var ctx_args = ["context"]
    if file != "":
        ctx_args.push(file)
    if target != "" and file != "":
        ctx_args = ["context", file, target]
    if format == "json":
        ctx_args.push("--json")
    elif format == "text":
        ctx_args.push("--text")
    if index == "true" or index == "1" or index == "yes":
        ctx_args.push("--index")
    if query != "":
        ctx_args.push("--query=" + query)
    if sql_enabled:
        ctx_args.push("--sql")
    if db_path != "":
        ctx_args.push("--db=" + db_path)
    if source_filter != "":
        ctx_args.push("--source-filter=" + source_filter)
    val (ctx_out, ctx_err, ctx_exit) = process_run_timeout(_mcp_find_simple_binary(), ctx_args, 15000)
    var target_report = "none"
    if target != "":
        target_report = "requested"
    var content = "(context pack unavailable: exit " + str(ctx_exit) + ")"
    if ctx_exit == 0 and ctx_out != "":
        content = ctx_out
    if sourceless_sql_query:
        out_parts.push(content)
    else:
        out_parts.push(_mcp_render_context_pack(format, file, target, line_num, target_report, content))
    out_parts.push("\n")

    # 3. Diagnostics
    if not sourceless_sql_query:
        val (check_stdout, check_stderr, check_exit) = process_run_timeout(_mcp_find_simple_binary(), ["check", file], 10000)
        val check_out = check_stdout + check_stderr
        out_parts.push("\n--- Diagnostics ---\n")
        if check_exit == 0:
            out_parts.push("clean (no errors)\n")
        else:
            out_parts.push(check_out)

    make_tool_result(id, out_parts.join(""))

fn handle_simple_ponytail(id: text, body: text) -> text:
    val file = extract_field(body, "file")
    val format = _mcp_output_format(body)
    var mode = extract_field(body, "mode")
    if mode == "":
        mode = "audit"
    if mode == "ponytail":
        mode = "audit"
    if mode == "review":
        mode = "audit"
    if mode == "simplify":
        mode = "simplification"
    if file == "":
        return make_tool_error(id, -32602, "Missing required parameter: file")
    if format != "text" and format != "markdown" and format != "json":
        return make_tool_error(id, -32602, "Invalid format: " + format)
    if mode != "audit" and mode != "simplification":
        return make_tool_error(id, -32602, "Invalid mode: " + mode)
    val source = file_read(file)
    if source == "":
        return make_tool_error(id, -32602, "Could not read file: " + file)
    var result = ""
    if mode == "simplification":
        result = ponytail_simplification_report_source(file, source)
    else:
        result = ponytail_audit_source(file, source)
    make_tool_result(id, _mcp_render_ponytail_report(file, mode, result, format))

fn handle_simple_pipe(id: text, body: text) -> text:
    var surface = extract_field(body, "surface")
    if surface == "":
        surface = extract_field(body, "action")
    if surface == "":
        surface = extract_field(body, "mode")

    val file = extract_field(body, "file")
    val query = extract_field(body, "query")
    if surface == "":
        if file == "" and query != "":
            surface = "search"
        else:
            surface = "context"

    if surface == "spipe" or surface == "pipe":
        if file == "" and query == "":
            return make_tool_result(id, "simple_pipe\nstatus: ready\nspipe: linked\nsurfaces: context, codebase, ponytail, search\nspec_docs: doc/06_spec\n")
        surface = "context"

    if surface == "context":
        return handle_simple_context(id, body)
    if surface == "codebase":
        return handle_simple_pipe_codebase(id, body)
    if surface == "search":
        return handle_simple_search(id, body)
    if surface == "ponytail" or surface == "audit" or surface == "review" or surface == "simplification" or surface == "simplify":
        return handle_simple_ponytail(id, body)
    make_tool_error(id, -32602, "Invalid surface: " + surface)

fn _simple_pipe_nonempty_line_count(value: text) -> i64:
    var count: i64 = 0
    for line in value.split("\n"):
        if line.trim() != "":
            count = count + 1
    count

fn _simple_pipe_search_text(query: text, kind: text, scope: text, file: text) -> text:
    var search_dir = "src/"
    if scope == "test":
        search_dir = "test/"
    elif scope == "all":
        search_dir = "."
    elif scope == "lib":
        search_dir = "src/lib/"
    elif scope == "compiler":
        search_dir = "src/compiler/"
    elif scope == "app":
        search_dir = "src/app/"

    var cmd = ""
    if kind == "fn" or kind == "function":
        cmd = "timeout 15 rg -n --glob '*.spl' '^ *fn " + query + "' " + search_dir + " 2>/dev/null | head -51"
    elif kind == "class":
        cmd = "timeout 15 rg -n --glob '*.spl' '^ *class " + query + "' " + search_dir + " 2>/dev/null | head -51"
    elif kind == "struct":
        cmd = "timeout 15 rg -n --glob '*.spl' '^ *struct " + query + "' " + search_dir + " 2>/dev/null | head -51"
    elif kind == "enum":
        cmd = "timeout 15 rg -n --glob '*.spl' '^ *enum " + query + "' " + search_dir + " 2>/dev/null | head -51"
    elif kind == "import" or kind == "use":
        cmd = "timeout 15 rg -n --glob '*.spl' 'use.*" + query + "|import.*" + query + "' " + search_dir + " 2>/dev/null | head -51"
    elif kind == "type":
        cmd = "timeout 15 rg -n --glob '*.spl' '^ *(type|alias|class|struct|enum) " + query + "' " + search_dir + " 2>/dev/null | head -51"
    else:
        cmd = "timeout 15 rg -n --glob '*.spl' '" + query + "' " + search_dir + " 2>/dev/null | head -51"

    if file != "":
        cmd = "timeout 10 rg -n '" + query + "' " + file + " 2>/dev/null | head -51"

    val (out, _) = shell_cmd(cmd)
    out

fn _simple_pipe_workspace_symbols(query: text, kind: text, requester: text) -> text:
    var effective_requester = requester
    if effective_requester == "":
        effective_requester = "src/"
    val (out, exit_code) = shell_cmd("timeout 20 " + _mcp_find_simple_binary() + " run src/app/cli/query.spl lsp-workspace-symbols-json --query " + query + " --requester " + effective_requester + " 2>&1")
    var result = "-- simple_pipe lsp workspace_symbols exit=" + str(exit_code)
    if kind != "":
        result = result + " kind=" + kind
    result = result + " --\n"
    result + out

fn _simple_pipe_context_sql_query(query: text, db_path: text, source_filter: text, format: text) -> text:
    var args = ["context", "--sql", "--query=" + query]
    if db_path != "":
        args.push("--db=" + db_path)
    if source_filter != "":
        args.push("--source-filter=" + source_filter)
    if format == "json":
        args.push("--json")
    else:
        args.push("--text")
    val (out, err, exit_code) = process_run_timeout(_mcp_find_simple_binary(), args, 15000)
    "-- simple_pipe codebase db exit=" + str(exit_code) + " --\n" + out + err

fn handle_simple_pipe_codebase(id: text, body: text) -> text:
    val query = extract_field(body, "query")
    val kind = extract_field(body, "kind")
    val scope = extract_field(body, "scope")
    val file = extract_field(body, "file")
    val requester = extract_field(body, "requester")
    val sql = extract_field(body, "sql")
    val db_path = extract_field(body, "db")
    val source_filter = extract_field(body, "source_filter")
    val format = _mcp_output_format(body)
    if query == "":
        if file != "":
            return handle_simple_context(id, body)
        return make_tool_error(id, -32602, "Missing required parameter: query")

    val sql_enabled = sql == "true" or sql == "1" or sql == "yes" or db_path != ""
    var db_out = ""
    var db_count: i64 = 0
    if sql_enabled:
        db_out = _simple_pipe_context_sql_query(query, db_path, source_filter, format)
        db_count = _simple_pipe_nonempty_line_count(db_out)
    val search_out = _simple_pipe_search_text(query, kind, scope, file)
    val search_count = _simple_pipe_nonempty_line_count(search_out)
    val lsp_out = _simple_pipe_workspace_symbols(query, kind, requester)
    val has_lsp = lsp_out.contains("\"name\"") or lsp_out.contains("\"path\"") or lsp_out.contains("\"file\"")
    val broad_count = search_count + db_count

    var out_parts: [text] = []
    out_parts.push("-- simple_pipe codebase query=" + query + " --\n")
    if sql_enabled:
        out_parts.push("mode: hybrid-codebase-db-search-plus-lsp\n")
    else:
        out_parts.push("mode: hybrid-codebase-search-plus-lsp\n")
    if broad_count >= 50 and has_lsp:
        out_parts.push("note: codebase search returned many matches; showing LSP workspace symbols first. Ask with surface=search for raw search results.\n\n")
        out_parts.push("--- LSP workspace symbols ---\n")
        out_parts.push(lsp_out)
        if sql_enabled:
            out_parts.push("\n--- Codebase DB query sample ---\n")
            out_parts.push(db_out)
        out_parts.push("\n--- Codebase text search sample ---\n")
        out_parts.push(search_out)
    else:
        if sql_enabled:
            out_parts.push("--- Codebase DB query ---\n")
            out_parts.push(db_out)
            out_parts.push("\n")
        out_parts.push("--- Codebase text search ---\n")
        if search_out.trim() == "":
            out_parts.push("No codebase search results.\n")
        else:
            out_parts.push(search_out)
        out_parts.push("\n--- LSP workspace symbols ---\n")
        out_parts.push(lsp_out)
    make_tool_result(id, out_parts.join(""))

# simple_search — Language-aware code search
fn handle_simple_search(id: text, body: text) -> text:
    val query = extract_field(body, "query")
    val kind = extract_field(body, "kind")
    val scope = extract_field(body, "scope")
    val file = extract_field(body, "file")

    if query == "":
        return make_tool_error(id, -32602, "Missing required parameter: query")

    var search_dir = "src/"
    if scope == "test":
        search_dir = "test/"
    elif scope == "all":
        search_dir = "."
    elif scope == "lib":
        search_dir = "src/lib/"
    elif scope == "compiler":
        search_dir = "src/compiler/"
    elif scope == "app":
        search_dir = "src/app/"

    var cmd = ""
    if kind == "fn" or kind == "function":
        cmd = "timeout 15 grep -rn '^fn " + query + "\\|^ *fn " + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    elif kind == "class":
        cmd = "timeout 15 grep -rn '^class " + query + "\\|^ *class " + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    elif kind == "struct":
        cmd = "timeout 15 grep -rn '^struct " + query + "\\|^ *struct " + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    elif kind == "enum":
        cmd = "timeout 15 grep -rn '^enum " + query + "\\|^ *enum " + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    elif kind == "import" or kind == "use":
        cmd = "timeout 15 grep -rn 'use.*" + query + "\\|import.*" + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    elif kind == "type":
        cmd = "timeout 15 grep -rn '^type " + query + "\\|^alias " + query + "\\|^class " + query + "\\|^struct " + query + "\\|^enum " + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"
    else:
        # General search
        cmd = "timeout 15 grep -rn '" + query + "' " + search_dir + " --include='*.spl' 2>/dev/null | head -50"

    if file != "":
        # Restrict to specific file
        cmd = "timeout 10 grep -n '" + query + "' " + file + " 2>/dev/null | head -50"

    val (out, _) = shell_cmd(cmd)

    var out_parts: [text] = []
    out_parts.push("-- simple_search query=" + query)
    if kind != "":
        out_parts.push(" kind=" + kind)
    if scope != "":
        out_parts.push(" scope=" + scope)
    out_parts.push(" --\n")
    if out.trim() == "":
        out_parts.push("No results found.")
    else:
        out_parts.push(out)
    make_tool_result(id, out_parts.join(""))

