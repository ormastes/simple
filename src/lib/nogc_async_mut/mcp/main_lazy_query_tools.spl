# simple_workspace_symbols — Search symbols across project
fn handle_simple_workspace_symbols(id: text, body: text) -> text:
    val query = extract_field(body, "query")
    val kind = extract_field(body, "kind")
    val requester = extract_field(body, "requester")
    if query == "":
        return make_tool_error(id, -32602, "Missing required parameter: query")
    var effective_requester = requester
    if effective_requester == "":
        effective_requester = "src/"
    var cmd = "timeout 30 " + _mcp_find_simple_binary() + " query lsp-workspace-symbols-json --query " + query + " --requester " + effective_requester
    if kind != "":
        # Visibility-aware workspace symbols currently rank/filter across all kinds.
        # Keep kind as inert input here until the JSON surface grows kind filtering.
        val _ = kind
    cmd = cmd + " 2>&1"
    val (out, exit_code) = shell_cmd(cmd)
    make_tool_result(id, "-- simple_workspace_symbols (exit: " + str(exit_code) + ") --\n" + out)

