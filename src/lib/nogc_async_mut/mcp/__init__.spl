# Async MCP stack (shared with sync facade)
#
# NOTE: Do NOT use wildcard imports here. Eagerly loading all submodules
# causes exponential memory growth (~60GB) due to env-cloning in the
# module loader. Submodules should be imported directly by consumers:
#   use std.nogc_async_mut.mcp.error_handler.{ErrorCategory, McpError}
#   use std.nogc_async_mut.mcp.helpers.{jp, js, jo1}

# Primary server entry is loaded lazily via:
#   use std.nogc_async_mut.mcp.main_lazy.{start_server}

