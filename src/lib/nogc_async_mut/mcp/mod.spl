# MCP Library - Public API
#
# Model Context Protocol (MCP) implementation library.
# Provides core types, helpers, schemas, handler registry, and protocol I/O for MCP servers.
#
# Usage:
#   use std.nogc_async_mut.mcp.{McpState, create_mcp_state, dispatch_tool}
#   use std.nogc_async_mut.mcp.{create_protocol_state, protocol_read_message, protocol_write_message}
#
# Modules:
#   - core: Core types (McpState, ToolHandler, ResourceHandler, PromptHandler)
#   - helpers: JSON utilities, string escaping, response builders
#   - schema: Pre-computed tool schemas
#   - handler_registry: Lazy handler loading and dispatch
#   - protocol: Stdin/stdout message handling (Content-Length + JSON Lines)

# Re-export public API from submodules

# Core types and factories
export McpState, ToolHandler, ResourceHandler, PromptHandler, SessionManager
export create_mcp_state, create_tool_handler, create_resource_handler, create_prompt_handler
export create_session_manager, add_session, remove_session, session_exists

# Helper utilities
export LB, RB, Q, parse_int, min_int, unwrap_idx, unwrap_str
export get_clean_args, has_flag, jp, js, jo1, jo2, jo3, jo4, jo5
export extract_json_string_v2, extract_json_string, extract_json_value, extract_nested_string
export extract_arguments_dict, extract_arg
export make_result_response, make_error_response, make_tool_result
export make_notification, make_notification_no_params, log_level_to_int, make_tool_schema_multi

# Schema management
export ToolSchema, get_tool_schema, get_all_tool_schemas, get_tool_count, init_core_schemas

# Handler registry
export register_tool_handler, register_resource_handler, register_prompt_handler
export find_tool_handler, find_resource_handler, find_prompt_handler
export dispatch_tool, get_registered_tools
export get_tool_handler_count, get_resource_handler_count, get_prompt_handler_count
export clear_registries

# Protocol I/O
export ProtocolState, create_protocol_state, protocol_read_message, protocol_write_message
