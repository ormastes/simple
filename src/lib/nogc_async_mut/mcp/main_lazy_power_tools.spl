# ============================================================================
# power_reset — Reset a target device
# ============================================================================

fn handle_power_reset(id: text, body: text) -> text:
    val config = _power_load_config(body)
    match config:
        Some(cfg):
            val ok = power_reset(cfg)
            if ok:
                return make_tool_result(id, LB() + jp("name", js(cfg.name)) + "," + jp("action", js("power_reset")) + "," + jp("status", js("ok")) + RB())
