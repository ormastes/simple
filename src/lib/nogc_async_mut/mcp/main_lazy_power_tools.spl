# ============================================================================
# power_state — Query power state of a target device
# ============================================================================

fn handle_power_state(id: text, body: text) -> text:
    val config = _power_load_config(body)
    match config:
        Some(cfg):
            val state = power_state(cfg)
            var out = LB()
            out = out + jp("name", js(cfg.name))
            out = out + "," + jp("kind", js(cfg.kind))
            out = out + "," + jp("state", js(_power_state_label(state)))
            out = out + "," + jp("state_code", str(state))
            out = out + RB()
            return make_tool_result(id, out)
        nil:
            return make_tool_error(id, -1, "Power config not found. Provide config_name parameter.")

# ============================================================================
# relay_execute — Execute a relay script with custom command
# ============================================================================

fn handle_relay_execute(id: text, body: text) -> text:
    val script_path = extract_nested(body, "script_path")
    val command = extract_nested(body, "command")

    if script_path == "":
        return make_tool_error(id, -1, "Missing required parameter: script_path")

    var cmd = script_path
    if command != "":
        cmd = cmd + " " + command
    cmd = cmd + " 2>&1"

    val (out, exit_code) = shell_cmd(cmd)
    var result = LB()
    result = result + jp("script_path", js(script_path))
    result = result + "," + jp("command", js(command))
    result = result + "," + jp("exit_code", str(exit_code))
    result = result + "," + jp("output", js(out))
    result = result + RB()
    make_tool_result(id, result)
