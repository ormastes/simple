"""DXVK D3D9 -> Vulkan translation stubs (M5, REQ-9).

Maps Direct3D 9 device creation, texture creation, and DrawPrimitive calls to
Vulkan ICD handles. In interpreter mode: returns structured records so callers
can validate the translation surface without a real GPU.
"""

# ============================================================================
# Types
# ============================================================================

class D3d9DeviceResult:
    is_ok:         bool
    error:         text
    device_handle: i64

class D3d9DrawResult:
    is_ok:         bool
    error:         text
    vertex_count:  i64

# ============================================================================
# Private helpers
# ============================================================================

fn _d9_ok(dev: i64) -> D3d9DeviceResult:
    D3d9DeviceResult(is_ok: true, error: "", device_handle: dev)

fn _d9_err(msg: text) -> D3d9DeviceResult:
    D3d9DeviceResult(is_ok: false, error: msg, device_handle: 0)

# ============================================================================
# Storage
# ============================================================================

var _d9_ctr: i64 = 0

# ============================================================================
# Public API
# ============================================================================

pub fn dxvk_d3d9_create_device() -> D3d9DeviceResult:
    """Create a D3D9 device backed by Vulkan.

    In interpreter mode the Vulkan ICD is unavailable; returns a modeled
    device stub with a positive handle so the translation surface can be
    validated without a real GPU.

    Returns:
        D3d9DeviceResult with is_ok=true and a positive device_handle.
    """
    _d9_ctr = _d9_ctr + 1
    _d9_ok(_d9_ctr)

pub fn dxvk_d3d9_create_texture(device_handle: i64, width: i64, height: i64) -> i64:
    """Create a D3D9 texture object.

    Args:
        device_handle: handle from dxvk_d3d9_create_device
        width:         texture width in pixels
        height:        texture height in pixels

    Returns:
        Positive texture handle, or 0 on invalid device.
    """
    if device_handle <= 0:
        return 0
    _d9_ctr = _d9_ctr + 1
    _d9_ctr

pub fn dxvk_d3d9_draw_primitive(device_handle: i64, vertex_count: i64) -> D3d9DrawResult:
    """Submit a DrawPrimitive call through the Vulkan translation layer.

    Args:
        device_handle: handle from dxvk_d3d9_create_device
        vertex_count:  number of vertices to draw

    Returns:
        D3d9DrawResult with is_ok=true when the call is accepted.
    """
    if device_handle <= 0:
        return D3d9DrawResult(is_ok: false, error: "invalid-device", vertex_count: 0)
    D3d9DrawResult(is_ok: true, error: "", vertex_count: vertex_count)
