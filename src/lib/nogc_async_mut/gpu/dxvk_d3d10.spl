"""DXVK D3D10 -> Vulkan translation layer (M5, REQ-9).

Routes through vulkan_icd_sffi dispatch chain. ICD itself uses structured
handles pending rt_dlopen for real libvulkan. The dispatch CHAIN
(D3D10 -> vulkan_icd_sffi -> vulkan_dispatch) is real routing; the leaf
(vulkan_icd_sffi creating actual Vulkan objects) uses structured handles.
"""

use std.nogc_async_mut.gpu.vulkan_icd_sffi.{
    vk_icd_create_instance,
    vk_icd_create_device,
    vk_icd_create_buffer,
    vk_icd_queue_submit,
    vk_icd_queue_present,
    vk_icd_destroy_device
}

class D3d10DeviceResult:
    is_ok:         bool
    error:         text
    device_handle: i64
    icd_instance:  i64
    icd_device:    i64
    icd_dispatch:  i64

class _D3d10DeviceState:
    device_handle: i64
    icd_instance:  i64
    icd_device:    i64
    icd_dispatch:  i64

var _d10_devices:   [_D3d10DeviceState] = []
var _d10_dev_alive: [bool] = []
var _d10_res_ctr:   i64 = 0

fn _d10_ok(dev: i64, inst: i64, idev: i64, idisp: i64) -> D3d10DeviceResult:
    D3d10DeviceResult(is_ok: true, error: "", device_handle: dev, icd_instance: inst, icd_device: idev, icd_dispatch: idisp)

fn _d10_err(msg: text) -> D3d10DeviceResult:
    D3d10DeviceResult(is_ok: false, error: msg, device_handle: 0, icd_instance: 0, icd_device: 0, icd_dispatch: 0)

fn _d10_is_valid(device_handle: i64) -> bool:
    if device_handle <= 0:
        return false
    val idx = device_handle - 1
    if idx >= _d10_dev_alive.len():
        return false
    _d10_dev_alive[idx]

pub fn dxvk_d3d10_create_device() -> D3d10DeviceResult:
    val inst_result = vk_icd_create_instance()
    if inst_result.is_ok == false:
        return _d10_err("icd-instance-failed")
    val dev_result = vk_icd_create_device(inst_result.instance_handle)
    if dev_result.is_ok == false:
        return _d10_err("icd-device-failed")
    val handle = _d10_devices.len() + 1
    val state = _D3d10DeviceState(device_handle: handle, icd_instance: inst_result.instance_handle, icd_device: dev_result.device_handle, icd_dispatch: dev_result.dispatch_handle)
    _d10_devices.push(state)
    _d10_dev_alive.push(true)
    _d10_ok(handle, inst_result.instance_handle, dev_result.device_handle, dev_result.dispatch_handle)

pub fn dxvk_d3d10_draw(device_handle: i64, vertex_count: i64) -> bool:
    if _d10_is_valid(device_handle) == false:
        return false
    if vertex_count <= 0:
        return false
    val idx = device_handle - 1
    val state = _d10_devices[idx]
    vk_icd_queue_submit(state.icd_device)

pub fn dxvk_d3d10_create_render_target(device_handle: i64, width: i64, height: i64) -> i64:
    if _d10_is_valid(device_handle) == false:
        return 0
    if width <= 0:
        return 0
    if height <= 0:
        return 0
    _d10_res_ctr = _d10_res_ctr + 1
    _d10_res_ctr

pub fn dxvk_d3d10_present(device_handle: i64) -> bool:
    if _d10_is_valid(device_handle) == false:
        return false
    val idx = device_handle - 1
    val state = _d10_devices[idx]
    vk_icd_queue_present(state.icd_device)

pub fn dxvk_d3d10_destroy_device(device_handle: i64) -> bool:
    if _d10_is_valid(device_handle) == false:
        return false
    val idx = device_handle - 1
    val state = _d10_devices[idx]
    vk_icd_destroy_device(state.icd_dispatch)
    _d10_dev_alive[idx] = false
    true
