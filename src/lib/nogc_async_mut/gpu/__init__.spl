# GPU Module - GPU operations for graphics and compute workloads
#
# @tag:stdlib
# @tag:api
# @tag:gpu
#
# This module provides GPU device management, context creation, and memory
# operations for both graphics and compute workloads. It supports multiple
# backends including CUDA, Vulkan, and Metal.
#
# Re-exports the flat gpu.spl API so that `use std.gpu.*` works.

use gc_async_mut.gpu.*
use common.pure.list.{List}

export GpuError, GpuDevice, GpuContext, GpuPtr, GpuModule, GpuLaunchConfig
export gpu_init, gpu_alloc, gpu_free, gpu_upload, gpu_download
export gpu_memset, gpu_launch, gpu_sync
export gpu_alloc_f32, gpu_alloc_i32, gpu_alloc_i64, gpu_alloc_f64
export gpu_device_name, gpu_device_compute_capability, gpu_device_total_memory
export gpu_set_device, gpu_device_count
export gpu_upload_f32, gpu_download_f32
export gpu_upload_i32, gpu_upload_i64, gpu_upload_f64
export gpu_download_i32, gpu_download_i64, gpu_download_f64
export gpu_memset_f32, gpu_memset_i32, gpu_copy_f32, gpu_copy_i32
export gpu_block_id_x, gpu_block_id_y, gpu_block_id_z
export gpu_block_dim_x, gpu_block_dim_y, gpu_block_dim_z
export gpu_thread_id_x, gpu_thread_id_y, gpu_thread_id_z
export gpu_local_id_x, gpu_local_id_y, gpu_local_id_z
export gpu_grid_dim_x, gpu_grid_dim_y, gpu_grid_dim_z
export gpu_global_id_x, gpu_global_id_y, gpu_global_id_z
export gpu_syncthreads
export gpu_load_f32, gpu_store_f32, gpu_load_i32, gpu_store_i32
export gpu_atomic_add_i64, gpu_atomic_add_i32, gpu_atomic_add_f32
export gpu_atomic_min_i64, gpu_atomic_max_i64, gpu_atomic_cas_i64
export gpu_load_f64, gpu_store_f64, gpu_load_i64, gpu_store_i64
export gpu_shared_array_f32, gpu_shared_store_f32, gpu_shared_load_f32
export gpu_shared_array_i32, gpu_shared_store_i32, gpu_shared_load_i32
export gpu_barrier, gpu_copy, GpuBuffer
export gpu_gemm, gpu_dot, gpu_axpy
export gpu_map, gpu_reduce, gpu_scan, gpu_filter, gpu_sort
export List

# Re-exported from context.spl
export Context
export create_context_from_config

# Re-exported from device.spl
export GpuBackend, Gpu
export detect_backends, preferred_backend
export gpu_cuda, gpu_vulkan, gpu_none

# Re-exported from memory.spl
export GpuArray
export gpu_alloc, gpu_alloc_upload, gpu_alloc_zeros, gpu_copy

# Re-exported from mod.spl
export GpuBackend    # Enum: Cuda, Vulkan, None_ (backend type)
export Gpu           # Struct: Device handle with backend, device_id, sync()
export detect_backends     # fn() -> [GpuBackend] - List available backends
export preferred_backend   # fn() -> GpuBackend - Best available backend
export gpu_cuda      # fn(device_id) -> Gpu - Create CUDA device handle
export gpu_vulkan    # fn(device_id) -> Gpu - Create Vulkan device handle (future)
export gpu_none      # fn() -> Gpu - Create CPU fallback handle
export GpuArray      # class[T]: Typed GPU array with upload/download/copy_to
export gpu_alloc          # fn[T](gpu, count) -> GpuArray[T] - Allocate uninitialized
export gpu_alloc_upload   # fn[T](gpu, data) -> GpuArray[T] - Allocate + upload
export gpu_alloc_zeros    # fn[T](gpu, count) -> GpuArray[T] - Allocate zeros
export Context            # class: Manages device, streams, allocations
export create_context_from_config  # fn() -> Context - Create from dl.config.sdn
