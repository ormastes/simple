"""GPU Module - GPU operations for graphics and compute workloads (NoGC Async)

@tag:stdlib
@tag:api
@tag:gpu

The no-GC async GPU package root exposes the no-GC async device, memory, and
context surfaces. Runtime FFI ownership stays in no-GC backend modules; this
root must not import GC compatibility packages.
"""

export {GpuBackend, Gpu, detect_backends, preferred_backend, gpu_cuda, gpu_vulkan, gpu_none} from device
export {GpuArray, gpu_alloc, gpu_alloc_upload, gpu_alloc_zeros, gpu_copy} from memory
export {Context, create_context_from_config} from context

# Re-exported from context.spl
export Context
export create_context_from_config

# Re-exported from device.spl
export GpuBackend, Gpu
export detect_backends, preferred_backend
export gpu_cuda, gpu_vulkan, gpu_none

# Re-exported from memory.spl
export GpuArray
export gpu_alloc, gpu_alloc_upload, gpu_alloc_zeros, gpu_copy
