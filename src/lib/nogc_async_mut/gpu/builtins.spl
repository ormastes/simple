# GPU Built-in Functions (Intrinsics)
#
# These are no-GC async declarations for GPU kernel intrinsics. Native GPU
# backends lower calls to hardware instructions. Interpreter fallback values
# are deterministic host-safe values so this package has no TODO bodies.

fn gpu_thread_id_x() -> i32:
    0

fn gpu_thread_id_y() -> i32:
    0

fn gpu_thread_id_z() -> i32:
    0

fn gpu_block_id_x() -> i32:
    0

fn gpu_block_id_y() -> i32:
    0

fn gpu_block_id_z() -> i32:
    0

fn gpu_block_dim_x() -> i32:
    1

fn gpu_block_dim_y() -> i32:
    1

fn gpu_block_dim_z() -> i32:
    1

fn gpu_grid_dim_x() -> i32:
    1

fn gpu_grid_dim_y() -> i32:
    1

fn gpu_grid_dim_z() -> i32:
    1

fn gpu_sync_threads():
    pass_dn

fn gpu_shared_memory<T>(size: i32) -> [T]:
    []

fn gpu_global_id_x() -> i32:
    gpu_block_id_x() * gpu_block_dim_x() + gpu_thread_id_x()

fn gpu_global_id_y() -> i32:
    gpu_block_id_y() * gpu_block_dim_y() + gpu_thread_id_y()

fn gpu_global_id_z() -> i32:
    gpu_block_id_z() * gpu_block_dim_z() + gpu_thread_id_z()

fn gpu_global_size_x() -> i32:
    gpu_grid_dim_x() * gpu_block_dim_x()

fn gpu_global_size_y() -> i32:
    gpu_grid_dim_y() * gpu_block_dim_y()

fn gpu_global_size_z() -> i32:
    gpu_grid_dim_z() * gpu_block_dim_z()
