"""
# No-GC Async Vulkan 2D engine FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.ffi_vulkan.{
    VulkanFfi, vulkan_ffi_init, vulkan_ffi_shutdown, vulkan_ffi_is_available,
    vulkan_ffi_device_count, vulkan_ffi_select_device, vulkan_ffi_alloc_buffer,
    vulkan_ffi_free_buffer, vulkan_ffi_compile_glsl, vulkan_ffi_destroy_shader,
    vulkan_ffi_create_compute_pipeline, vulkan_ffi_destroy_pipeline,
    vulkan_ffi_create_descriptor_set, vulkan_ffi_bind_buffer,
    vulkan_ffi_destroy_descriptor_set, vulkan_ffi_begin_compute, vulkan_ffi_bind_pipeline,
    vulkan_ffi_bind_descriptors, vulkan_ffi_push_constants, vulkan_ffi_dispatch,
    vulkan_ffi_end_compute, vulkan_ffi_submit_and_wait, vulkan_ffi_copy_from_buffer,
    vulkan_ffi_copy_to_buffer, vulkan_ffi_wait_idle
}
