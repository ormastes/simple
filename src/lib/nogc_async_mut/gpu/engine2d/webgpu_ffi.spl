"""
# No-GC Async WebGPU 2D engine FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.webgpu_ffi.{
    webgpu_ffi_is_available, webgpu_ffi_init, webgpu_ffi_shutdown,
    webgpu_ffi_create_surface, webgpu_ffi_destroy_surface, webgpu_ffi_upload_pixels,
    webgpu_ffi_present, webgpu_ffi_compute_draw
}
