"""
# No-GC Async CUDA 2D engine SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.sffi_cuda.{
    cuda_engine2d_pack_args_4, cuda_engine2d_pack_args_8, cuda_engine2d_upload_pixels,
    cuda_engine2d_download_pixels, cuda_engine2d_upload_host_buf, CudaFfi
}
