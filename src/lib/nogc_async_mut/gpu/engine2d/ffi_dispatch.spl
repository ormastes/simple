"""
# No-GC Async GPU FFI dispatch

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.ffi_dispatch.{
    GpuFfiMode, FfiDispatchBase, default_ffi_mode, is_simpleos, gpu_lib_path,
    gpu_lib_candidates, try_load_gpu_lib, resolve_ffi_mode, try_create_dynamic_vulkan
}
