"""
# No-GC Async 2D SIMD kernels

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.simd_kernels.{
    SimdLevel, detect_simd_level, active_feature_text, active_arch_text, active_target_features,
    simd_fill_row, _scalar_fill_row,
    simd_blend_row, _scalar_blend_row,
    simd_blit_row, _scalar_blit_row,
    fill_span, _scalar_fill_span,
    copy_span, _scalar_copy_span,
    alpha_blend_span, _scalar_alpha_blend_span,
    blit_rect, _scalar_blit_rect,
    scroll_region, _scalar_scroll_region,
    CpuSimdProvider, make_cpu_simd_provider
}
