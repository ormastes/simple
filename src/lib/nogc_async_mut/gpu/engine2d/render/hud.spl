# std.gpu.engine2d.render.hud — HUD compositing over a rendered framebuffer.
#
# Extracted from rollball (src/app/game.rollball/game.spl), which overlays a
# dark bar + label text on top of the 3D frame for the win/lose evidence
# PPMs. Any game can reuse this instead of hand-rolling the SoftwareBackend
# composite. Colors are parameters (no game-specific tuning baked in).

use std.gpu.engine2d.backend_software.{SoftwareBackend}

# --- Overlay an opaque bar + label text over `pixels` (top `bar_h` rows). ---
fn composite_hud(pixels: [u32], w: i32, h: i32, label: text, bg: u32, fg: u32) -> [u32]:
    var b = SoftwareBackend.create()
    if not b.init(w, h):
        return pixels
    b.draw_image(0, 0, w, h, pixels)
    b.draw_rect_filled(0, 0, w, 18, bg)
    b.draw_text(4, 5, label, fg, 6)
    b.read_pixels()
