"""
# No-GC Async Intel 2D engine FFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine2d.ffi_intel.{
    intel_engine2d_set_args_clear, intel_engine2d_set_args_rect,
    intel_engine2d_set_args_line, intel_engine2d_set_args_circle,
    intel_engine2d_set_args_rounded_rect, intel_engine2d_set_args_triangle,
    intel_engine2d_set_args_gradient, intel_engine2d_set_args_blit,
    intel_engine2d_upload_pixels, intel_engine2d_download_pixels,
    intel_engine2d_upload_host_buf, IntelFfi
}
