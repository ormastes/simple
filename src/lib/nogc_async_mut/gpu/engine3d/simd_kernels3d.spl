"""
# No-GC Async 3D SIMD kernels

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous FFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine3d.simd_kernels3d.{
    SimdLevel3D, _s3d_sqrt, detect_simd_level_3d, simd_mat4_mul, _scalar_mat4_mul,
    simd_transform_vertices, _scalar_transform_vertices, simd_vec3_normalize_batch
}
