# No-GC async 3D GPU math hooks facade.
#
# Math runtime hooks are synchronous backend operations. Keep ownership in the
# no-GC sync backend and expose this async-family facade for GC compatibility
# backends that need the same API.

export use std.nogc_sync_mut.gpu.engine3d.math_hooks.{
    gpu3d_sqrt_f32, gpu3d_sin_f32, gpu3d_cos_f32
}
