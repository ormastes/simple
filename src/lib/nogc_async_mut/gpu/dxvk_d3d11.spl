"""DXVK D3D11 -> Vulkan translation layer (M5, REQ-9).

Routes through vulkan_icd_sffi dispatch chain. ICD itself uses structured
handles pending rt_dlopen for real libvulkan. The dispatch CHAIN
(D3D11 -> vulkan_icd_sffi -> vulkan_dispatch) is real routing; the leaf
(vulkan_icd_sffi creating actual Vulkan objects) uses structured handles.
"""

use std.nogc_async_mut.gpu.vulkan_icd_sffi.{
    vk_icd_create_instance,
    vk_icd_create_device,
    vk_icd_queue_submit,
    vk_icd_queue_present,
    vk_icd_destroy_device
}

# ============================================================================
# Types
# ============================================================================

class D3d11DeviceResult:
    is_ok:         bool
    error:         text
    device_handle: i64
    icd_instance:  i64
    icd_device:    i64
    icd_dispatch:  i64

class D3d11SwapChainResult:
    is_ok:            bool
    error:            text
    swapchain_handle: i64

class D3d11ReadbackResult:
    is_ok:          bool
    error:          text
    readback_handle: i64
    pixels:         [u32]
    pixel_count:    i64
    checksum:       i64

class D3d11ProbeResult:
    is_ok:         bool
    error:         text
    device_handle: i64
    icd_instance:  i64
    icd_device:    i64
    icd_dispatch:  i64

class D3d11PresentReadbackResult:
    present_ok:       bool
    upload_ok:        bool
    readback_ok:      bool
    error:            text
    readback_handle:  i64
    pixels:           [u32]
    pixel_count:      i64
    checksum:         i64

# ============================================================================
# Per-device ICD state (parallel tombstone arrays)
# ============================================================================

class _D3d11DeviceState:
    device_handle: i64
    icd_instance:  i64
    icd_device:    i64
    icd_dispatch:  i64

class _D3d11SwapchainState:
    swapchain_handle: i64
    device_handle:    i64

class _D3d11ReadbackState:
    readback_handle: i64
    device_handle:   i64
    width:           i64
    height:          i64
    pixels:          [u32]
    checksum:        i64
    uploaded:        bool

var _d11_devices:    [_D3d11DeviceState] = []
var _d11_dev_alive:  [bool] = []
var _d11_swapchains: [_D3d11SwapchainState] = []
var _d11_sc_alive:   [bool] = []
var _d11_readbacks:  [_D3d11ReadbackState] = []
var _d11_rb_alive:   [bool] = []
var _d11_res_ctr:    i64 = 0

# ============================================================================
# Private helpers
# ============================================================================

fn _d11_dev_ok(dev: i64, inst: i64, idev: i64, idisp: i64) -> D3d11DeviceResult:
    D3d11DeviceResult(is_ok: true, error: "", device_handle: dev, icd_instance: inst, icd_device: idev, icd_dispatch: idisp)

fn _d11_dev_err(msg: text) -> D3d11DeviceResult:
    D3d11DeviceResult(is_ok: false, error: msg, device_handle: 0, icd_instance: 0, icd_device: 0, icd_dispatch: 0)

fn _d11_sc_ok(sc: i64) -> D3d11SwapChainResult:
    D3d11SwapChainResult(is_ok: true, error: "", swapchain_handle: sc)

fn _d11_sc_err(msg: text) -> D3d11SwapChainResult:
    D3d11SwapChainResult(is_ok: false, error: msg, swapchain_handle: 0)

fn _d11_rb_ok(readback_handle: i64, pixels: [u32], checksum: i64) -> D3d11ReadbackResult:
    D3d11ReadbackResult(is_ok: true, error: "", readback_handle: readback_handle, pixels: pixels, pixel_count: pixels.len().to_i64(), checksum: checksum)

fn _d11_rb_err(msg: text) -> D3d11ReadbackResult:
    D3d11ReadbackResult(is_ok: false, error: msg, readback_handle: 0, pixels: [], pixel_count: 0, checksum: 0)

fn _d11_probe_from_device(result: D3d11DeviceResult) -> D3d11ProbeResult:
    D3d11ProbeResult(is_ok: result.is_ok, error: result.error, device_handle: result.device_handle, icd_instance: result.icd_instance, icd_device: result.icd_device, icd_dispatch: result.icd_dispatch)

fn _d11_pr_ok(present_ok: bool, readback_handle: i64, pixels: [u32], pixel_count: i64, checksum: i64) -> D3d11PresentReadbackResult:
    D3d11PresentReadbackResult(present_ok: present_ok, upload_ok: true, readback_ok: true, error: "", readback_handle: readback_handle, pixels: pixels, pixel_count: pixel_count, checksum: checksum)

fn _d11_pr_err(present_ok: bool, upload_ok: bool, msg: text) -> D3d11PresentReadbackResult:
    D3d11PresentReadbackResult(present_ok: present_ok, upload_ok: upload_ok, readback_ok: false, error: msg, readback_handle: 0, pixels: [], pixel_count: 0, checksum: 0)

fn _d11_pixel_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var idx = 0
    while idx < pixels.len():
        checksum = (checksum + pixels[idx].to_i64() * (idx.to_i64() + 1)) % 2147483647
        idx = idx + 1
    checksum

fn _d11_copy_pixels(pixels: [u32]) -> [u32]:
    var copy: [u32] = []
    var idx = 0
    while idx < pixels.len():
        copy.push(pixels[idx])
        idx = idx + 1
    copy

fn _d11_is_valid(device_handle: i64) -> bool:
    if device_handle <= 0:
        return false
    val idx = device_handle - 1
    if idx >= _d11_dev_alive.len():
        return false
    _d11_dev_alive[idx]

fn _d11_sc_is_valid(swapchain_handle: i64) -> bool:
    if swapchain_handle <= 0:
        return false
    val idx = swapchain_handle - 1
    if idx >= _d11_sc_alive.len():
        return false
    _d11_sc_alive[idx]

fn _d11_rb_is_valid(readback_handle: i64) -> bool:
    if readback_handle <= 0:
        return false
    val idx = readback_handle - 1
    if idx >= _d11_rb_alive.len():
        return false
    _d11_rb_alive[idx]

# ============================================================================
# Public API
# ============================================================================

pub fn dxvk_d3d11_create_device() -> D3d11DeviceResult:
    """Create a D3D11 device backed by Vulkan.

    Routes through vulkan_icd_sffi dispatch chain. Creates a Vulkan instance
    and logical device via ICD, storing ICD handles in the result for
    validation. ICD itself uses structured handles pending rt_dlopen.

    Returns:
        D3d11DeviceResult with is_ok=true and positive handles.
    """
    val inst_result = vk_icd_create_instance()
    if inst_result.is_ok == false:
        return _d11_dev_err("icd-instance-failed")
    val dev_result = vk_icd_create_device(inst_result.instance_handle)
    if dev_result.is_ok == false:
        return _d11_dev_err("icd-device-failed")
    val handle = _d11_devices.len() + 1
    val state = _D3d11DeviceState(device_handle: handle, icd_instance: inst_result.instance_handle, icd_device: dev_result.device_handle, icd_dispatch: dev_result.dispatch_handle)
    _d11_devices.push(state)
    _d11_dev_alive.push(true)
    _d11_dev_ok(handle, inst_result.instance_handle, dev_result.device_handle, dev_result.dispatch_handle)

pub fn dxvk_d3d11_probe_device() -> D3d11ProbeResult:
    """Probe D3D11 device creation and release the probe device immediately."""
    val result = dxvk_d3d11_create_device()
    if result.is_ok:
        dxvk_d3d11_destroy_device(result.device_handle)
    _d11_probe_from_device(result)

# @tag(device_handle=device_handle, width=pixel_width, height=pixel_height)
pub fn dxvk_d3d11_create_swapchain(device_handle: i64, width: i64, height: i64) -> D3d11SwapChainResult:
    """Create a D3D11 swap chain for the given device.

    Records swapchain with ICD device reference for present validation.

    Args:
        device_handle: handle from dxvk_d3d11_create_device
        width:         back buffer width
        height:        back buffer height

    Returns:
        D3d11SwapChainResult with is_ok=true and a positive swapchain_handle.
    """
    if _d11_is_valid(device_handle) == false:
        return _d11_sc_err("invalid-device")
    val sc_handle = _d11_swapchains.len() + 1
    val sc_state = _D3d11SwapchainState(swapchain_handle: sc_handle, device_handle: device_handle)
    _d11_swapchains.push(sc_state)
    _d11_sc_alive.push(true)
    _d11_sc_ok(sc_handle)

pub fn dxvk_d3d11_present(swapchain_handle: i64) -> bool:
    """Present the current back buffer.

    Validates swapchain -> device -> ICD chain before presenting.

    Args:
        swapchain_handle: handle from dxvk_d3d11_create_swapchain

    Returns:
        true if present was accepted.
    """
    if _d11_sc_is_valid(swapchain_handle) == false:
        return false
    val sc_idx = swapchain_handle - 1
    val sc_state = _d11_swapchains[sc_idx]
    val dev_handle = sc_state.device_handle
    if _d11_is_valid(dev_handle) == false:
        return false
    val dev_idx = dev_handle - 1
    val dev_state = _d11_devices[dev_idx]
    vk_icd_queue_present(dev_state.icd_device)

# @tag(device_handle=device_handle, vertex_count=vertex_count)
pub fn dxvk_d3d11_draw(device_handle: i64, vertex_count: i64) -> bool:
    """Submit a draw call through the Vulkan ICD pipeline.

    Args:
        device_handle: handle from dxvk_d3d11_create_device
        vertex_count:  number of vertices to draw

    Returns:
        true if the draw was accepted.
    """
    if _d11_is_valid(device_handle) == false:
        return false
    if vertex_count <= 0:
        return false
    val idx = device_handle - 1
    val state = _d11_devices[idx]
    vk_icd_queue_submit(state.icd_device)

# @tag(device_handle=device_handle, width=pixel_width, height=pixel_height)
pub fn dxvk_d3d11_create_render_target(device_handle: i64, width: i64, height: i64) -> i64:
    """Create a D3D11 render target view.

    Args:
        device_handle: handle from dxvk_d3d11_create_device
        width:         render target width
        height:        render target height

    Returns:
        Positive render-target handle, or 0 on invalid device.
    """
    if _d11_is_valid(device_handle) == false:
        return 0
    _d11_res_ctr = _d11_res_ctr + 1
    _d11_res_ctr

pub fn dxvk_d3d11_create_readback_target(device_handle: i64, width: i64, height: i64) -> i64:
    """Create a structured D3D11/DXVK readback target.

    The target tracks handle, dimensions, uploaded pixel data, and checksum.
    Native Windows evidence must still prove the real D3D11 staging-texture
    path before production evidence can count DirectX as complete.
    """
    if _d11_is_valid(device_handle) == false:
        return 0
    if width <= 0 or height <= 0:
        return 0
    val handle = _d11_readbacks.len() + 1
    val state = _D3d11ReadbackState(readback_handle: handle, device_handle: device_handle, width: width, height: height, pixels: [], checksum: 0, uploaded: false)
    _d11_readbacks.push(state)
    _d11_rb_alive.push(true)
    handle

pub fn dxvk_d3d11_upload_framebuffer(readback_handle: i64, pixels: [u32], width: i64, height: i64) -> bool:
    """Upload host framebuffer contents into the structured readback target."""
    if _d11_rb_is_valid(readback_handle) == false:
        return false
    val idx = readback_handle - 1
    val state = _d11_readbacks[idx]
    if width != state.width or height != state.height:
        return false
    val expected = width * height
    if pixels.len().to_i64() != expected:
        return false
    val copy = _d11_copy_pixels(pixels)
    _d11_readbacks[idx] = _D3d11ReadbackState(readback_handle: state.readback_handle, device_handle: state.device_handle, width: state.width, height: state.height, pixels: copy, checksum: _d11_pixel_checksum(copy), uploaded: true)
    true

pub fn dxvk_d3d11_readback_pixels(readback_handle: i64) -> D3d11ReadbackResult:
    """Read back pixels from the structured D3D11/DXVK readback target."""
    if _d11_rb_is_valid(readback_handle) == false:
        return _d11_rb_err("invalid-readback-target")
    val idx = readback_handle - 1
    val state = _d11_readbacks[idx]
    if _d11_is_valid(state.device_handle) == false:
        return _d11_rb_err("invalid-device")
    if state.uploaded == false:
        return _d11_rb_err("readback-target-empty")
    _d11_rb_ok(readback_handle, _d11_copy_pixels(state.pixels), state.checksum)

pub fn dxvk_d3d11_present_readback(swapchain_handle: i64, readback_handle: i64, pixels: [u32], width: i64, height: i64) -> D3d11PresentReadbackResult:
    """Present, upload framebuffer pixels, and validate structured readback.

    This keeps D3D11/DXVK readback validity and checksum policy in the no-GC
    runtime layer. Adapters should only store the returned evidence.
    """
    val present_ok = dxvk_d3d11_present(swapchain_handle)
    if readback_handle <= 0:
        return _d11_pr_err(present_ok, false, "invalid-readback-target")
    val upload_ok = dxvk_d3d11_upload_framebuffer(readback_handle, pixels, width, height)
    if upload_ok == false:
        return _d11_pr_err(present_ok, false, "upload-failed")
    val readback = dxvk_d3d11_readback_pixels(readback_handle)
    val expected_count = width * height
    if readback.is_ok == false:
        return _d11_pr_err(present_ok, true, readback.error)
    if readback.pixel_count != expected_count:
        return _d11_pr_err(present_ok, true, "readback-size-mismatch")
    _d11_pr_ok(present_ok, readback.readback_handle, readback.pixels, readback.pixel_count, readback.checksum)

pub fn dxvk_d3d11_destroy_readback_target(readback_handle: i64) -> bool:
    """Destroy a structured D3D11/DXVK readback target."""
    if _d11_rb_is_valid(readback_handle) == false:
        return false
    val idx = readback_handle - 1
    _d11_rb_alive[idx] = false
    true

pub fn dxvk_d3d11_destroy_device(device_handle: i64) -> bool:
    """Destroy a D3D11 device and release ICD resources.

    Calls vk_icd_destroy_device to release the Vulkan dispatch table.

    Args:
        device_handle: handle from dxvk_d3d11_create_device

    Returns:
        true if the device was successfully destroyed.
    """
    if _d11_is_valid(device_handle) == false:
        return false
    val idx = device_handle - 1
    val state = _d11_devices[idx]
    vk_icd_destroy_device(state.icd_dispatch)
    _d11_dev_alive[idx] = false
    true
