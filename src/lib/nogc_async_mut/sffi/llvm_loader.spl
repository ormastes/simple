"""
# No-GC async LLVM SFFI loader

Compatibility facade over the no-GC sync backend boundary.
"""

export use std.nogc_sync_mut.sffi.llvm_loader.{
    llvm_load, llvm_available, llvm_lib,
    _llvm_resolve, _lc0, _lc1, _lc2, _lc3, _lc4, _lcn,
    llvm_make_array, llvm_free_array, llvm_call_arg_push,
    rt_alloc, rt_free, rt_ptr_write_i64, rt_ptr_read_i64,
    llvm_text_ptr, llvm_cstr_ptr
}
