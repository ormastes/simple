# LLVM C API SFFI Bindings via DynLib
#
# Provides runtime dynamic loading of libLLVM.so and wraps ~120 LLVM C API
# functions for in-process IR generation and object code emission.
#
# Pattern: All LLVM handles are opaque i64 (LLVMContextRef, LLVMModuleRef, etc.)
# Strings are passed via text.ptr() (null-terminated).
# Array arguments use rt_alloc + rt_ptr_write_i64 to build contiguous buffers.
#
# Usage:
#   if llvm_load():
#       val ctx = llvm_context_create()
#       val mod = llvm_module_create_with_name_in_context("test", ctx)
#       ...
#       llvm_context_dispose(ctx)
#
# Split into subsystem files:
#   llvm_loader.spl  — library loading, SFFI dispatch helpers, array helpers
#   llvm_types.spl   — enums, context/module, types, constants, functions/globals
#   llvm_codegen.spl — builder, basic blocks, all instruction categories
#   llvm_target.spl  — target machine, pass manager, memory buffer

use std.nogc_async_mut.sffi.llvm_loader.{
    llvm_load,
    llvm_available,
    llvm_lib,
    llvm_make_array,
    llvm_free_array,
    _lc0, _lc1, _lc2, _lc3, _lc4, _lcn,
    _llvm_resolve
}

use std.nogc_async_mut.sffi.llvm_types.{
    LLVM_INT_EQ, LLVM_INT_NE, LLVM_INT_UGT, LLVM_INT_UGE,
    LLVM_INT_ULT, LLVM_INT_ULE, LLVM_INT_SGT, LLVM_INT_SGE,
    LLVM_INT_SLT, LLVM_INT_SLE,
    LLVM_REAL_OEQ, LLVM_REAL_OGT, LLVM_REAL_OGE, LLVM_REAL_OLT,
    LLVM_REAL_OLE, LLVM_REAL_ONE, LLVM_REAL_ORD, LLVM_REAL_UNO,
    LLVM_EXTERNAL_LINKAGE, LLVM_INTERNAL_LINKAGE, LLVM_PRIVATE_LINKAGE,
    LLVM_CODE_GEN_LEVEL_NONE, LLVM_CODE_GEN_LEVEL_LESS,
    LLVM_CODE_GEN_LEVEL_DEFAULT, LLVM_CODE_GEN_LEVEL_AGGRESSIVE,
    LLVM_RELOC_DEFAULT, LLVM_RELOC_STATIC, LLVM_RELOC_PIC,
    LLVM_CODE_MODEL_DEFAULT, LLVM_CODE_MODEL_SMALL, LLVM_CODE_MODEL_LARGE,
    LLVM_ASSEMBLY_FILE, LLVM_OBJECT_FILE,
    llvm_context_create, llvm_context_dispose,
    llvm_module_create_with_name_in_context, llvm_dispose_module,
    llvm_set_target, llvm_set_data_layout, llvm_set_source_file_name,
    llvm_verify_module, llvm_print_module_to_string, llvm_dispose_message,
    llvm_void_type_in_context, llvm_int1_type_in_context,
    llvm_int8_type_in_context, llvm_int16_type_in_context,
    llvm_int32_type_in_context, llvm_int64_type_in_context,
    llvm_float_type_in_context, llvm_double_type_in_context,
    llvm_pointer_type, llvm_function_type, llvm_struct_type_in_context,
    llvm_array_type2, llvm_get_type_kind,
    llvm_type_of, llvm_get_element_type, llvm_count_struct_element_types,
    llvm_get_return_type, llvm_get_int_type_width, llvm_global_get_value_type,
    llvm_const_int, llvm_const_real_of_string, llvm_const_string_in_context,
    llvm_const_null, llvm_get_undef, llvm_const_array,
    llvm_const_struct_in_context, llvm_const_pointer_null,
    llvm_add_function, llvm_get_named_function, llvm_get_param,
    llvm_set_linkage, llvm_add_global, llvm_set_initializer,
    llvm_set_global_constant, llvm_set_unnamed_addr, llvm_count_params,
    llvm_set_function_call_conv, llvm_add_attribute_at_index,
    llvm_create_enum_attribute, llvm_get_enum_attribute_kind_for_name
}

use std.nogc_async_mut.sffi.llvm_codegen.{
    llvm_create_builder_in_context, llvm_dispose_builder,
    llvm_append_basic_block_in_context, llvm_position_builder_at_end,
    llvm_get_insert_block,
    llvm_build_add, llvm_build_nsw_add, llvm_build_sub, llvm_build_nsw_sub,
    llvm_build_mul, llvm_build_nsw_mul, llvm_build_sdiv, llvm_build_udiv,
    llvm_build_srem, llvm_build_urem, llvm_build_neg,
    llvm_build_fadd, llvm_build_fsub, llvm_build_fmul,
    llvm_build_fdiv, llvm_build_frem, llvm_build_fneg,
    llvm_build_and, llvm_build_or, llvm_build_xor,
    llvm_build_shl, llvm_build_ashr, llvm_build_lshr, llvm_build_not,
    llvm_build_icmp, llvm_build_fcmp,
    llvm_build_alloca, llvm_build_load2, llvm_build_store,
    llvm_build_gep2, llvm_build_in_bounds_gep2,
    llvm_build_extract_value, llvm_build_insert_value,
    llvm_build_trunc, llvm_build_zext, llvm_build_sext,
    llvm_build_fptrunc, llvm_build_fpext,
    llvm_build_si_to_fp, llvm_build_fp_to_si,
    llvm_build_ptr_to_int, llvm_build_int_to_ptr, llvm_build_bitcast,
    llvm_build_ret, llvm_build_ret_void, llvm_build_br, llvm_build_cond_br,
    llvm_build_switch, llvm_add_case, llvm_build_unreachable,
    llvm_build_phi, llvm_add_incoming,
    llvm_build_call2, llvm_build_select
}

use std.nogc_async_mut.sffi.llvm_target.{
    llvm_initialize_all_target_infos, llvm_initialize_all_targets,
    llvm_initialize_all_target_mcs, llvm_initialize_all_asm_printers,
    llvm_initialize_all_asm_parsers, llvm_initialize_targets,
    llvm_get_target_from_triple, llvm_create_target_machine,
    llvm_dispose_target_machine, llvm_target_machine_emit_to_file,
    llvm_get_default_target_triple, llvm_create_target_data_layout,
    llvm_run_passes, llvm_create_pass_builder_options,
    llvm_dispose_pass_builder_options,
    llvm_pass_builder_options_set_verify_each,
    llvm_get_buffer_start, llvm_get_buffer_size, llvm_dispose_memory_buffer,
    llvm_target_machine_emit_to_memory_buffer
}
