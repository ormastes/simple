# LLVM SFFI — Target machine, pass manager, and memory buffer.

use std.nogc_async_mut.sffi.llvm_loader.{
    _lc0, _lc1, _lc2, _lc3, _lc4, _lcn,
    rt_alloc, rt_free, rt_ptr_write_i64, rt_ptr_read_i64,
    llvm_call_arg_push,
    llvm_text_ptr
}
use std.nogc_async_mut.sffi.llvm_types.{llvm_dispose_message}

# ============================================================================
# 7. Target Machine
# ============================================================================

var _targets_initialized_tm: bool = false

fn llvm_initialize_all_target_infos():
    _lc0("LLVMInitializeX86TargetInfo")
    _lc0("LLVMInitializeAArch64TargetInfo")
    _lc0("LLVMInitializeARMTargetInfo")
    _lc0("LLVMInitializeRISCVTargetInfo")

fn llvm_initialize_all_targets():
    _lc0("LLVMInitializeX86Target")
    _lc0("LLVMInitializeAArch64Target")
    _lc0("LLVMInitializeARMTarget")
    _lc0("LLVMInitializeRISCVTarget")

fn llvm_initialize_all_target_mcs():
    _lc0("LLVMInitializeX86TargetMC")
    _lc0("LLVMInitializeAArch64TargetMC")
    _lc0("LLVMInitializeARMTargetMC")
    _lc0("LLVMInitializeRISCVTargetMC")

fn llvm_initialize_all_asm_printers():
    _lc0("LLVMInitializeX86AsmPrinter")
    _lc0("LLVMInitializeAArch64AsmPrinter")
    _lc0("LLVMInitializeARMAsmPrinter")
    _lc0("LLVMInitializeRISCVAsmPrinter")

fn llvm_initialize_all_asm_parsers():
    _lc0("LLVMInitializeX86AsmParser")
    _lc0("LLVMInitializeAArch64AsmParser")
    _lc0("LLVMInitializeARMAsmParser")
    _lc0("LLVMInitializeRISCVAsmParser")

fn llvm_initialize_targets():
    if _targets_initialized_tm:
        return
    _targets_initialized_tm = true
    llvm_initialize_all_target_infos()
    llvm_initialize_all_targets()
    llvm_initialize_all_target_mcs()
    llvm_initialize_all_asm_printers()
    llvm_initialize_all_asm_parsers()

fn llvm_get_target_from_triple(triple: text) -> i64:
    # LLVMGetTargetFromTriple(Triple, &Target, &ErrorMessage) -> LLVMBool
    # Returns 0 on success, writes Target to output param
    val target_ptr = rt_alloc(8)
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(target_ptr, 0, 0)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    val triple_z = triple + "\0"
    llvm_call_arg_push(args, llvm_text_ptr(triple_z))
    llvm_call_arg_push(args, target_ptr)
    llvm_call_arg_push(args, err_ptr)
    val result = _lcn("LLVMGetTargetFromTriple", args)
    var target = 0
    if result == 0:
        target = rt_ptr_read_i64(target_ptr, 0)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(target_ptr)
    rt_free(err_ptr)
    target

# reason: positional sffi llvm API
fn llvm_create_target_machine(target: i64, triple: text, cpu: text, features: text, opt_level: i64, reloc: i64, code_model: i64) -> i64:
    val triple_z = triple + "\0"
    val cpu_z = cpu + "\0"
    val features_z = features + "\0"
    var args: [i64] = []
    llvm_call_arg_push(args, target)
    llvm_call_arg_push(args, llvm_text_ptr(triple_z))
    llvm_call_arg_push(args, llvm_text_ptr(cpu_z))
    llvm_call_arg_push(args, llvm_text_ptr(features_z))
    llvm_call_arg_push(args, opt_level)
    llvm_call_arg_push(args, reloc)
    llvm_call_arg_push(args, code_model)
    _lcn("LLVMCreateTargetMachine", args)

fn llvm_dispose_target_machine(tm: i64):
    _lc1("LLVMDisposeTargetMachine", tm)

# reason: positional sffi llvm API
fn llvm_target_machine_emit_to_file(tm: i64, mod_: i64, filename: text, file_type: i64) -> bool:
    # LLVMTargetMachineEmitToFile(TM, M, Filename, FileType, &ErrorMessage) -> LLVMBool
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    llvm_call_arg_push(args, tm)
    llvm_call_arg_push(args, mod_)
    val filename_z = filename + "\0"
    llvm_call_arg_push(args, llvm_text_ptr(filename_z))
    llvm_call_arg_push(args, file_type)
    llvm_call_arg_push(args, err_ptr)
    val result = _lcn("LLVMTargetMachineEmitToFile", args)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(err_ptr)
    result == 0

fn llvm_get_default_target_triple() -> i64:
    _lc0("LLVMGetDefaultTargetTriple")

fn llvm_create_target_data_layout(tm: i64) -> i64:
    _lc1("LLVMCreateTargetDataLayout", tm)

# ============================================================================
# 8. Pass Manager (New Pass Manager API)
# ============================================================================

# reason: positional sffi llvm API
fn llvm_run_passes(mod_: i64, passes: text, tm: i64, options: i64) -> i64:
    # LLVMRunPasses(Module, Passes, TM, Options) -> LLVMErrorRef (0=success)
    val passes_z = passes + "\0"
    _lc4("LLVMRunPasses", mod_, llvm_text_ptr(passes_z), tm, options)

fn llvm_create_pass_builder_options() -> i64:
    _lc0("LLVMCreatePassBuilderOptions")

fn llvm_dispose_pass_builder_options(options: i64):
    _lc1("LLVMDisposePassBuilderOptions", options)

fn llvm_pass_builder_options_set_verify_each(options: i64, verify: bool):
    val v = if verify: 1 else: 0
    _lc2("LLVMPassBuilderOptionsSetVerifyEach", options, v)

# ============================================================================
# 9. Memory Buffer (for reading emitted object code)
# ============================================================================

fn llvm_get_buffer_start(buf: i64) -> i64:
    _lc1("LLVMGetBufferStart", buf)

fn llvm_get_buffer_size(buf: i64) -> i64:
    _lc1("LLVMGetBufferSize", buf)

fn llvm_dispose_memory_buffer(buf: i64):
    _lc1("LLVMDisposeMemoryBuffer", buf)

# reason: positional sffi llvm API
fn llvm_target_machine_emit_to_memory_buffer(tm: i64, mod_: i64, file_type: i64) -> i64:
    # LLVMTargetMachineEmitToMemoryBuffer(TM, M, FileType, &ErrorMessage, &OutMemBuf) -> LLVMBool
    val err_ptr = rt_alloc(8)
    val buf_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    rt_ptr_write_i64(buf_ptr, 0, 0)
    var args: [i64] = []
    llvm_call_arg_push(args, tm)
    llvm_call_arg_push(args, mod_)
    llvm_call_arg_push(args, file_type)
    llvm_call_arg_push(args, err_ptr)
    llvm_call_arg_push(args, buf_ptr)
    val result = _lcn("LLVMTargetMachineEmitToMemoryBuffer", args)
    var buffer = 0
    if result == 0:
        buffer = rt_ptr_read_i64(buf_ptr, 0)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(err_ptr)
    rt_free(buf_ptr)
    buffer
