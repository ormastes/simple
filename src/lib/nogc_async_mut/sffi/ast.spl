"""
# No-GC async SFFI AST

Compatibility facade over the no-GC sync backend boundary.
"""

export use std.nogc_sync_mut.sffi.ast.{
    ast_expr_tag, ast_expr_free, ast_expr_bool_value, ast_expr_int_value,
    ast_expr_float_value, ast_expr_string_value, ast_expr_ident_name,
    ast_expr_binary_left, ast_expr_binary_op, ast_expr_binary_right,
    ast_expr_unary_op, ast_expr_unary_operand,
    ast_expr_field_receiver, ast_expr_field_name,
    ast_expr_method_receiver, ast_expr_method_name,
    ast_expr_method_arg_count, ast_expr_method_arg,
    ast_expr_call_callee, ast_expr_call_arg_count, ast_expr_call_arg,
    ast_expr_array_len, ast_expr_array_get,
    ast_arg_name, ast_arg_value, ast_arg_free,
    ast_node_free, ast_registry_count, ast_registry_clear
}
