"""
# Master HTTP Server

Manages worker lifecycle, configuration, and graceful shutdown.
Mimics nginx's master process role.

## Architecture

```
HttpServer (master thread)
  ├── Supervisor (one_for_one, auto-restart workers)
  ├── N × Worker threads (each with own EventLoop + IoDriver)
  └── Control Channel (shutdown/reload signals)
```

## Usage

```simple
# From SDN config file
val server = HttpServer.from_config_file("server.sdn")?
server.start()?

# Programmatic
val config = default_server_config()
val server = HttpServer.new(config)
server.start()?

# Later...
server.stop()
```
"""

use std.concurrent.channel.{Channel, channel_new}
use std.thread_sffi.{
    spl_thread_create, spl_thread_join, spl_thread_cpu_count
}
use std.supervisor.{
    Supervisor, SupervisorConfig, ChildSpec,
    STRATEGY_ONE_FOR_ONE, RESTART_PERMANENT,
    SHUTDOWN_TIMEOUT
}

use std.http_server.types.{
    ServerConfig, WorkerHandle, default_server_config
}
use std.http_server.config.{load_config}
use std.http_server.worker.{Worker}
use std.http_server.router.{AsyncRouter}
use std.http_server.middleware.{
    MiddlewarePipeline, connection_limit_handler, body_limit_handler
}
use std.http_server.access_log.{access_log_handler}
use std.http_server.handler.{HandlerRegistry, create_default_registry}
use std.http_server.error.{HttpServerError}

# ============================================================================
# HttpServer
# ============================================================================

class HttpServer:
    """Master server managing worker threads.

    Creates N worker threads (default = CPU count), each with its
    own EventLoop and IoDriver. Workers bind their own listeners
    using SO_REUSEPORT so the kernel distributes connections.

    The master manages lifecycle via a Supervisor (one_for_one
    strategy) and communicates shutdown via Channel.
    """
    config: ServerConfig
    workers: [WorkerHandle]
    control_channels: [Channel]
    supervisor: Supervisor
    running: bool
    handler_registry: HandlerRegistry

    static fn new(config: ServerConfig) -> HttpServer:
        """Create server from a ServerConfig.

        Args:
            config: Server configuration
        """
        val sup_config = SupervisorConfig(
            strategy: STRATEGY_ONE_FOR_ONE,
            max_restarts: 10,
            max_seconds: 60
        )
        val sup = Supervisor(
            config: sup_config,
            children: [],
            restart_counts: [],
            running: false
        )

        val registry = create_default_registry(".")

        HttpServer(
            config: config,
            workers: [],
            control_channels: [],
            supervisor: sup,
            running: false,
            handler_registry: registry
        )

    static fn from_config_file(path: text) -> Result<HttpServer, HttpServerError>:
        """Load config from SDN file and create server.

        Args:
            path: Path to SDN config file

        Returns:
            Initialized HttpServer or ConfigError
        """
        val config = load_config(path)?
        Ok(HttpServer.new(config))

    me set_handler_registry(registry: HandlerRegistry):
        """Set a custom handler registry."""
        self.handler_registry = registry

    me start() -> Result<(), HttpServerError>:
        """Start the server and all worker threads.

        Determines worker count (0 = CPU count), creates
        control channels, builds router and middleware pipeline,
        then spawns worker threads.

        Returns:
            Ok on success, or error if any worker fails to bind
        """
        if self.running:
            return Err(HttpServerError.Internal("Server already running"))

        # Determine worker count
        val worker_count = if self.config.worker_count <= 0:
            val cpus = spl_thread_cpu_count()
            if cpus > 0: cpus else: 4
        else:
            self.config.worker_count

        # Build router from config locations
        val router = AsyncRouter.new(self.config.locations)

        # Build default middleware pipeline
        val pipeline = build_default_pipeline()

        # Spawn workers
        var workers: [WorkerHandle] = []
        var channels: [Channel] = []

        var i = 0
        while i < worker_count:
            val control = channel_new()
            channels = channels + [control]

            val worker_result = Worker.create(
                i, self.config, router, pipeline, control
            )
            match worker_result:
                Ok(worker):
                    # Spawn worker thread
                    # Worker.run() is the entry point
                    val handle = spawn_worker(worker)
                    workers = workers + [WorkerHandle(
                        worker_id: i,
                        thread_handle: handle,
                        is_alive: true
                    )]

                    # Register with supervisor
                    val child = ChildSpec(
                        id: "worker_{i}",
                        restart: RESTART_PERMANENT,
                        shutdown: SHUTDOWN_TIMEOUT,
                        shutdown_ms: 5000
                    )
                    self.supervisor.add_child(child)

                Err(e):
                    # Cleanup already-spawned workers
                    self.stop_workers(channels)
                    return Err(e)

            i = i + 1

        self.workers = workers
        self.control_channels = channels
        self.running = true
        self.supervisor.start()

        print "[SimpleServer] Listening on {self.config.listen_addr} with {worker_count} workers"

        Ok(())

    me stop():
        """Gracefully stop the server.

        Sends shutdown to all workers via control channels,
        waits for workers to finish, then cleans up.
        """
        if not self.running:
            return

        print "[SimpleServer] Shutting down..."

        self.stop_workers(self.control_channels)

        self.supervisor.stop()
        self.running = false

        print "[SimpleServer] Stopped"

    me wait():
        """Block until all workers exit.

        Call after start() to keep the master thread alive.
        """
        for wh in self.workers:
            if wh.is_alive:
                spl_thread_join(wh.thread_handle)

    fn is_running() -> bool:
        """Check if the server is running."""
        self.running

    fn worker_count() -> i64:
        """Get the number of running workers."""
        self.workers.len()

    # ========================================================================
    # Internal
    # ========================================================================

    me stop_workers(channels: [Channel]):
        """Send shutdown to all workers and join threads."""
        for ch in channels:
            ch.send("shutdown")

        for wh in self.workers:
            if wh.is_alive:
                spl_thread_join(wh.thread_handle)

# ============================================================================
# Worker Thread Spawning
# ============================================================================

fn spawn_worker(worker: Worker) -> i64:
    """Spawn a worker in a new OS thread.

    Args:
        worker: Initialized worker ready to run

    Returns:
        Thread handle
    """
    # Worker.run() is the entry point for the thread
    # The thread_sffi API takes a function pointer + arg
    # We pass the worker as the arg, entry calls worker.run()
    pass_todo("Implement proper thread spawn with Worker.run() entry point")
    0

# ============================================================================
# Default Pipeline
# ============================================================================

fn build_default_pipeline() -> MiddlewarePipeline:
    """Create the default middleware pipeline with built-in handlers.

    Includes:
    - PostAccept: connection_limit_handler (priority 100)
    - Read: body_limit_handler (priority 100)
    - Log: access_log_handler (priority 50)
    """
    var pipeline = MiddlewarePipeline.new()

    pipeline.add(Phase.PostAccept, 100, "connection_limit",
                 connection_limit_handler)
    pipeline.add(Phase.Read, 100, "body_limit",
                 body_limit_handler)
    pipeline.add(Phase.Log, 50, "access_log",
                 access_log_handler)

    pipeline
