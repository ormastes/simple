"""
# Async HTTP Router

Routes requests to location handlers based on URL pattern matching.
Reuses `match_route_pattern` and `extract_route_params` from the
sync http_server module.

## Location Matching Priority

1. **Exact match** (`= /path`) — highest priority
2. **Prefix match** (longest wins) — `/api/v1/` beats `/api/`
3. **Default** (`/`) — fallback

## Usage

```simple
val router = AsyncRouter.new(config.locations)
val result = router.route(request)
match result:
    Ok((location, params)): handle(location, params)
    Err(e): send_404()
```
"""

use std.http_server.types.{
    HttpRequestData, LocationConfig, default_location_config
}
use std.http_server.error.{HttpServerError}

fn match_route_pattern(pattern: text, path: text) -> bool:
    if pattern == path:
        return true
    val pattern_parts = pattern.split("/")
    val path_parts = path.split("/")
    if pattern_parts.len() != path_parts.len():
        return false
    var i = 0
    while i < pattern_parts.len():
        val pp = pattern_parts[i]
        val rp = path_parts[i]
        if pp.starts_with(":"):
            i = i + 1
            continue
        if pp == "*":
            i = i + 1
            continue
        if pp != rp:
            return false
        i = i + 1
    return true

fn extract_route_params(pattern: text, path: text) -> [(text, text)]:
    var params: [(text, text)] = []
    val pattern_parts = pattern.split("/")
    val path_parts = path.split("/")
    if pattern_parts.len() != path_parts.len():
        return params
    var i = 0
    while i < pattern_parts.len():
        val pp = pattern_parts[i]
        val rp = path_parts[i]
        if pp.starts_with(":"):
            val param_name = pp.slice(1, pp.len())
            params.push((param_name, rp))
        i = i + 1
    return params

# ============================================================================
# Async Router
# ============================================================================

class AsyncRouter:
    """Routes HTTP requests to location handlers.

    Locations are matched by pattern type (exact, prefix) with
    longest-prefix-wins semantics.
    """
    locations: [LocationConfig]

    static fn new(locations: [LocationConfig]) -> AsyncRouter:
        """Create router from location configs.

        Args:
            locations: Location configs from ServerConfig
        """
        AsyncRouter(locations: locations)

    static fn empty() -> AsyncRouter:
        """Create router with no locations."""
        AsyncRouter(locations: [])

    me add_location(loc: LocationConfig):
        """Add a location to the router."""
        var locations: [LocationConfig] = []
        for existing in self.locations:
            locations.push(existing)
        locations.push(loc)
        self.locations = locations

    fn route(request: HttpRequestData) -> Result<(LocationConfig, Dict<text, text>), HttpServerError>:
        """Find the best matching location for a request.

        Matching priority:
        1. Exact matches first
        2. Longest prefix match
        3. RouteNotFound error if nothing matches

        Args:
            request: Parsed HTTP request

        Returns:
            Matched location config and extracted route parameters
        """
        val path = request.path

        # Pass 1: exact matches
        for loc in self.locations:
            if loc.match_type == "exact":
                val pattern = loc.pattern
                # Strip leading "= " if present
                val clean = if pattern.starts_with("= "):
                    pattern.slice(2, pattern.len())
                else:
                    pattern

                if path == clean:
                    return Ok((loc, {}))

        # Pass 2: longest prefix match
        var best_loc: LocationConfig? = nil
        var best_len = -1

        for loc in self.locations:
            if loc.match_type == "prefix" or loc.match_type == "":
                val matched = if loc.pattern == "/":
                    true
                elif path.starts_with(loc.pattern):
                    true
                else:
                    match_route_pattern(loc.pattern, path)
                if matched:
                    val plen = loc.pattern.len()
                    if plen > best_len:
                        best_len = plen
                        best_loc = loc

        if best_loc.?:
            val params = extract_params(best_loc.pattern, path)
            return Ok((best_loc, params))

        # Pass 3: try parametric patterns (any match_type)
        for loc in self.locations:
            if match_route_pattern(loc.pattern, path):
                val params = extract_params(loc.pattern, path)
                return Ok((loc, params))

        Err(HttpServerError.RouteNotFound("No location matches path: {path}"))

# ============================================================================
# Parameter Extraction
# ============================================================================

fn extract_params(pattern: text, path: text) -> Dict<text, text>:
    """Extract route parameters from path using pattern.

    Pattern `/users/:id` with path `/users/42` yields `{"id": "42"}`.

    Args:
        pattern: Route pattern with :param placeholders
        path: Actual request path

    Returns:
        Dict of parameter name → value
    """
    var params: Dict<text, text> = {}

    val raw_params = extract_route_params(pattern, path)
    for pair in raw_params:
        val name = pair.0
        val value = pair.1
        params[name] = value

    params
