"""
# Health Check Endpoint

Kubernetes-style health and readiness probes for the HTTP server.

## Endpoints

- `/health` - liveness probe with uptime and per-check status
- `/ready` - readiness probe, 200 only when all checks pass

## Usage

```simple
var registry = HealthRegistry.new()
registry.register("database", db_health_check)
val response = registry.health_handler(request)
```
"""

use std.json.builder.{JsonBuilder}
use std.http_server.types.{HttpRequestData, HttpResponseData}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}

fn _http_time_now_ms() -> i64:
    current_time_ms()

# ============================================================================
# Health Status
# ============================================================================

enum HealthStatus:
    """Status of a single health check."""
    Healthy
    Degraded
    Unhealthy

fn status_to_text(s: HealthStatus) -> text:
    match s:
        HealthStatus.Healthy: "healthy"
        HealthStatus.Degraded: "degraded"
        HealthStatus.Unhealthy: "unhealthy"

# ============================================================================
# Health Check
# ============================================================================

struct HealthCheck:
    """A named health check with its check function and timeout."""
    name: text
    check_fn: fn() -> HealthStatus
    timeout_ms: i64

# ============================================================================
# Health Registry
# ============================================================================

class HealthRegistry:
    """Registry of health checks for the server."""
    checks: [HealthCheck]
    start_time: i64

    static fn new() -> HealthRegistry:
        HealthRegistry(
            checks: [],
            start_time: _http_time_now_ms()
        )

    me register(name: text, check_fn: fn() -> HealthStatus):
        """Register a health check with default 5s timeout."""
        self.checks.push(HealthCheck(
            name: name,
            check_fn: check_fn,
            timeout_ms: 5000
        ))

    fn check_all() -> (HealthStatus, text):
        """Run all checks, return overall status and JSON body."""
        val now = _http_time_now_ms()
        val uptime_seconds = (now - self.start_time) / 1000

        var overall = HealthStatus.Healthy
        var checks_builder = JsonBuilder.object()

        for check in self.checks:
            val result = check.check_fn()
            checks_builder = checks_builder.field(check.name, status_to_text(result))

            match result:
                HealthStatus.Unhealthy:
                    overall = HealthStatus.Unhealthy
                HealthStatus.Degraded:
                    match overall:
                        HealthStatus.Healthy:
                            overall = HealthStatus.Degraded
                        _:
                            pass_dn
                _:
                    pass_dn

        var body = JsonBuilder.object()
        body = body.field("status", status_to_text(overall))
        body = body.field_int("uptime_seconds", uptime_seconds)
        body = body.field_raw("checks", checks_builder.build())
        (overall, body.build())

    fn health_handler(request: HttpRequestData) -> HttpResponseData:
        """/health endpoint handler."""
        val pair = self.check_all()
        val overall = pair.0
        val json_body = pair.1

        val status_code = match overall:
            HealthStatus.Healthy: 200
            HealthStatus.Degraded: 200
            HealthStatus.Unhealthy: 503

        HttpResponseData(
            status: status_code,
            reason: if status_code == 200: "OK" else: "Service Unavailable",
            headers: [
                ("Content-Type", "application/json"),
                ("Server", "SimpleServer")
            ],
            body: json_body,
            body_bytes: [],
            body_file: "",
            body_offset: 0,
            body_length: 0,
            chunked: false
        )

    fn ready_handler(request: HttpRequestData) -> HttpResponseData:
        """/ready endpoint, 200 only if all checks pass."""
        val pair = self.check_all()
        val overall = pair.0

        match overall:
            HealthStatus.Healthy:
                HttpResponseData(
                    status: 200,
                    reason: "OK",
                    headers: [
                        ("Content-Type", "application/json"),
                        ("Server", "SimpleServer")
                    ],
                    body: "{\"status\":\"ready\"}",
                    body_bytes: [],
                    body_file: "",
                    body_offset: 0,
                    body_length: 0,
                    chunked: false
                )
            _:
                HttpResponseData(
                    status: 503,
                    reason: "Service Unavailable",
                    headers: [
                        ("Content-Type", "application/json"),
                        ("Server", "SimpleServer")
                    ],
                    body: "{\"status\":\"not_ready\"}",
                    body_bytes: [],
                    body_file: "",
                    body_offset: 0,
                    body_length: 0,
                    chunked: false
                )
