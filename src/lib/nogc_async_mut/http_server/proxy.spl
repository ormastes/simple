# codex-impl
# Pure reverse-proxy policy helpers for the async worker.

use std.http_server.types.{HttpRequestData, LocationConfig, UpstreamConfig, UpstreamServer}
use std.http_server.types.{LoadBalanceStrategy}

val ASYNC_PROXY_DEFAULT_MAX_BUFFERED_REQUEST_BODY_BYTES = 1024 * 1024

class AsyncProxyTarget:
    ok: bool
    upstream_addr: text
    status: i64
    reason: text

class AsyncProxyTunnelPlan:
    ok: bool
    upstream_addr: text
    status: i64
    reason: text
    tunnel_kind: text

class AsyncProxyTunnelConnection:
    client_fd: i64
    upstream_fd: i64
    upstream_addr: text
    tunnel_kind: text
    setup_wire: text
    setup_bytes_sent: i64
    pending_client_to_upstream: text
    pending_upstream_to_client: text
    pending_client_to_upstream_bytes: [u8]
    pending_upstream_to_client_bytes: [u8]
    bytes_client_to_upstream: i64
    bytes_upstream_to_client: i64
    client_recv_inflight: bool
    upstream_recv_inflight: bool
    upstream_handshake_buffer: text
    upstream_handshake_bytes: [u8]
    upstream_handshake_complete: bool
    upstream_handshake_valid: bool
    upstream_handshake_error: text
    max_pending_each_direction_bytes: i64
    started_at_ms: i64
    last_activity_ms: i64
    closed: bool

class AsyncProxyUpstreamPeer:
    addr: text
    weight: i64
    max_fails: i64
    fail_timeout_ms: i64
    fail_count: i64
    active_connections: i64
    last_failure_ms: i64

class AsyncProxyPoolConfig:
    max_idle_per_upstream: i64
    idle_timeout_ms: i64
    max_reuse_count: i64

class AsyncProxyPoolEntry:
    upstream_addr: text
    upstream_fd: i64
    in_use: bool
    closed: bool
    last_used_ms: i64
    reuse_count: i64

class AsyncProxyPoolDecision:
    ok: bool
    upstream_addr: text
    upstream_fd: i64
    reason: text

class AsyncProxyHealthProbeDecision:
    should_probe: bool
    upstream_addr: text
    reason: text

class AsyncProxyHealthProbeRecord:
    upstream_addr: text
    last_probe_ms: i64

class AsyncProxyProductionHardeningEvidence:
    ok: bool
    reason: text
    timed_out: bool
    request_backpressure: bool
    response_backpressure: bool
    pool_stressed: bool
    throughput_bytes_per_sec: i64

class AsyncProxyChunkDecode:
    decoded: text
    remaining: text
    complete: bool
    valid: bool

class AsyncProxyRequestBodyStream:
    header_wire: text
    pending_upstream_data: text
    bytes_received: i64
    expected_body_bytes: i64
    chunked: bool
    complete: bool
    valid: bool
    error: text
    chunked_body_buffer: text
    max_pending_upstream_bytes: i64

class AsyncProxyHeaderRequest:
    ok: bool
    request: HttpRequestData
    body_fragment: text
    reason: text

class AsyncProxyConnection:
    client_fd: i64
    upstream_fd: i64
    upstream_addr: text
    request_wire: text
    request_bytes_sent: i64
    response_header_buffer: text
    response_client_header_wire: text
    response_headers_done: bool
    response_header_valid: bool
    response_header_error: text
    expected_body_bytes: i64
    body_bytes_forwarded: i64
    response_complete: bool
    upstream_reusable: bool
    response_chunked: bool
    chunked_body_buffer: text
    pending_client_data: text
    started_at_ms: i64
    last_activity_ms: i64
    bytes_from_upstream: i64
    max_response_header_bytes: i64
    max_response_header_line: i64
    max_response_headers: i64
    max_response_bytes: i64
    max_pending_client_bytes: i64
    connect_timeout_ms: i64
    idle_timeout_ms: i64

fn async_proxy_connection(client_fd: i64, upstream_addr: text, request_wire: text, now: i64) -> AsyncProxyConnection:
    AsyncProxyConnection(
        client_fd: client_fd,
        upstream_fd: -1,
        upstream_addr: upstream_addr,
        request_wire: request_wire,
        request_bytes_sent: 0,
        response_header_buffer: "",
        response_client_header_wire: "",
        response_headers_done: false,
        response_header_valid: true,
        response_header_error: "",
        expected_body_bytes: -1,
        body_bytes_forwarded: 0,
        response_complete: false,
        upstream_reusable: false,
        response_chunked: false,
        chunked_body_buffer: "",
        pending_client_data: "",
        started_at_ms: now,
        last_activity_ms: now,
        bytes_from_upstream: 0,
        max_response_header_bytes: 64 * 1024,
        max_response_header_line: 8192,
        max_response_headers: 100,
        max_response_bytes: 64 * 1024 * 1024,
        max_pending_client_bytes: 256 * 1024,
        connect_timeout_ms: 1000,
        idle_timeout_ms: 30000
    )

fn async_proxy_connection_with_limits(client_fd: i64, upstream_addr: text, request_wire: text, now: i64,
                                      max_response_header_bytes: i64, max_response_bytes: i64,
                                      connect_timeout_ms: i64, idle_timeout_ms: i64) -> AsyncProxyConnection:
    AsyncProxyConnection(
        client_fd: client_fd,
        upstream_fd: -1,
        upstream_addr: upstream_addr,
        request_wire: request_wire,
        request_bytes_sent: 0,
        response_header_buffer: "",
        response_client_header_wire: "",
        response_headers_done: false,
        response_header_valid: true,
        response_header_error: "",
        expected_body_bytes: -1,
        body_bytes_forwarded: 0,
        response_complete: false,
        upstream_reusable: false,
        response_chunked: false,
        chunked_body_buffer: "",
        pending_client_data: "",
        started_at_ms: now,
        last_activity_ms: now,
        bytes_from_upstream: 0,
        max_response_header_bytes: max_response_header_bytes,
        max_response_header_line: 8192,
        max_response_headers: 100,
        max_response_bytes: max_response_bytes,
        max_pending_client_bytes: 256 * 1024,
        connect_timeout_ms: connect_timeout_ms,
        idle_timeout_ms: idle_timeout_ms
    )

fn async_proxy_tunnel_connection(client_fd: i64, upstream_fd: i64,
                                 upstream_addr: text, tunnel_kind: text,
                                 setup_wire: text, now: i64) -> AsyncProxyTunnelConnection:
    var conn = AsyncProxyTunnelConnection(
        client_fd: client_fd,
        upstream_fd: upstream_fd,
        upstream_addr: upstream_addr,
        tunnel_kind: tunnel_kind,
        setup_wire: setup_wire,
        setup_bytes_sent: 0,
        pending_client_to_upstream: "",
        pending_upstream_to_client: "",
        pending_client_to_upstream_bytes: [],
        pending_upstream_to_client_bytes: [],
        bytes_client_to_upstream: 0,
        bytes_upstream_to_client: 0,
        client_recv_inflight: false,
        upstream_recv_inflight: false,
        upstream_handshake_buffer: "",
        upstream_handshake_bytes: [],
        upstream_handshake_complete: false,
        upstream_handshake_valid: true,
        upstream_handshake_error: "",
        max_pending_each_direction_bytes: 256 * 1024,
        started_at_ms: now,
        last_activity_ms: now,
        closed: false
    )
    conn.upstream_handshake_complete = false
    conn.upstream_handshake_valid = true
    conn

fn async_proxy_tunnel_connection_with_limit(client_fd: i64, upstream_fd: i64,
                                            upstream_addr: text, tunnel_kind: text,
                                            setup_wire: text, now: i64,
                                            max_pending_each_direction_bytes: i64) -> AsyncProxyTunnelConnection:
    var conn = async_proxy_tunnel_connection(client_fd, upstream_fd, upstream_addr, tunnel_kind, setup_wire, now)
    conn.max_pending_each_direction_bytes = max_pending_each_direction_bytes
    conn

fn async_proxy_target_ok(upstream_addr: text) -> AsyncProxyTarget:
    AsyncProxyTarget(ok: true, upstream_addr: upstream_addr, status: 200, reason: "OK")

fn async_proxy_target_error(status: i64, reason: text) -> AsyncProxyTarget:
    AsyncProxyTarget(ok: false, upstream_addr: "", status: status, reason: reason)

fn async_proxy_tunnel_plan_ok(upstream_addr: text, tunnel_kind: text) -> AsyncProxyTunnelPlan:
    AsyncProxyTunnelPlan(ok: true, upstream_addr: upstream_addr, status: 0, reason: "ok", tunnel_kind: tunnel_kind)

fn async_proxy_tunnel_plan_error(status: i64, reason: text) -> AsyncProxyTunnelPlan:
    AsyncProxyTunnelPlan(ok: false, upstream_addr: "", status: status, reason: reason, tunnel_kind: "")

fn async_proxy_request_stream(header_wire: text, expected_body_bytes: i64,
                              chunked: bool, max_pending_upstream_bytes: i64) -> AsyncProxyRequestBodyStream:
    AsyncProxyRequestBodyStream(
        header_wire: header_wire,
        pending_upstream_data: "",
        bytes_received: 0,
        expected_body_bytes: expected_body_bytes,
        chunked: chunked,
        complete: expected_body_bytes == 0 and not chunked,
        valid: true,
        error: "",
        chunked_body_buffer: "",
        max_pending_upstream_bytes: max_pending_upstream_bytes
    )

fn async_proxy_empty_header_request(reason: text) -> AsyncProxyHeaderRequest:
    AsyncProxyHeaderRequest(
        ok: false,
        request: HttpRequestData(
            method: "",
            path: "",
            query: "",
            version: "",
            headers: [],
            body: "",
            params: {},
            peer_addr: ""
        ),
        body_fragment: "",
        reason: reason
    )

fn async_proxy_parse_header_request(data: text, peer_addr: text) -> AsyncProxyHeaderRequest:
    val split_at = data.index_of("\r\n\r\n")
    if split_at < 0:
        return async_proxy_empty_header_request("headers-incomplete")
    val head = data.slice(0, split_at)
    val body_start = split_at + 4
    val body = if body_start <= data.len(): data.slice(body_start, data.len()) else: ""
    val lines = head.split("\r\n")
    if lines.len() == 0:
        return async_proxy_empty_header_request("missing-request-line")
    val parts = lines[0].split(" ")
    if parts.len() < 3:
        return async_proxy_empty_header_request("malformed-request-line")
    val raw_path = parts[1]
    var path = raw_path
    var query = ""
    val qmark = raw_path.index_of("?")
    if qmark.? and qmark >= 0:
        path = raw_path.slice(0, qmark)
        query = raw_path.slice(qmark + 1, raw_path.len())
    var headers: [(text, text)] = []
    var i = 1
    while i < lines.len():
        if lines[i] != "":
            val header_parts = lines[i].split(":")
            if header_parts.len() < 2 or header_parts[0].trim() == "":
                return async_proxy_empty_header_request("malformed-header-line")
            headers.push((header_parts[0].trim(), header_parts[1].trim()))
        i = i + 1
    AsyncProxyHeaderRequest(
        ok: true,
        request: HttpRequestData(
            method: parts[0],
            path: path,
            query: query,
            version: parts[2],
            headers: headers,
            body: body,
            params: {},
            peer_addr: peer_addr
        ),
        body_fragment: body,
        reason: "ok"
    )

fn async_proxy_pool_default_config() -> AsyncProxyPoolConfig:
    AsyncProxyPoolConfig(
        max_idle_per_upstream: 16,
        idle_timeout_ms: 30000,
        max_reuse_count: 1000
    )

fn async_proxy_pool_entry(upstream_addr: text, upstream_fd: i64,
                          last_used_ms: i64) -> AsyncProxyPoolEntry:
    AsyncProxyPoolEntry(
        upstream_addr: upstream_addr,
        upstream_fd: upstream_fd,
        in_use: false,
        closed: false,
        last_used_ms: last_used_ms,
        reuse_count: 0
    )

fn async_proxy_pool_decision(ok: bool, upstream_addr: text, upstream_fd: i64,
                             reason: text) -> AsyncProxyPoolDecision:
    AsyncProxyPoolDecision(
        ok: ok,
        upstream_addr: upstream_addr,
        upstream_fd: upstream_fd,
        reason: reason
    )

fn async_proxy_health_probe_decision(should_probe: bool, upstream_addr: text,
                                     reason: text) -> AsyncProxyHealthProbeDecision:
    AsyncProxyHealthProbeDecision(
        should_probe: should_probe,
        upstream_addr: upstream_addr,
        reason: reason
    )

fn async_proxy_health_probe_record(upstream_addr: text,
                                   last_probe_ms: i64) -> AsyncProxyHealthProbeRecord:
    AsyncProxyHealthProbeRecord(
        upstream_addr: upstream_addr,
        last_probe_ms: last_probe_ms
    )

fn async_proxy_production_hardening_evidence(ok: bool, reason: text,
                                             timed_out: bool,
                                             request_backpressure: bool,
                                             response_backpressure: bool,
                                             pool_stressed: bool,
                                             throughput_bytes_per_sec: i64) -> AsyncProxyProductionHardeningEvidence:
    AsyncProxyProductionHardeningEvidence(
        ok: ok,
        reason: reason,
        timed_out: timed_out,
        request_backpressure: request_backpressure,
        response_backpressure: response_backpressure,
        pool_stressed: pool_stressed,
        throughput_bytes_per_sec: throughput_bytes_per_sec
    )

fn async_proxy_throughput_bytes_per_sec(bytes: i64, started_at_ms: i64, now: i64) -> i64:
    if bytes <= 0:
        return 0
    val elapsed = now - started_at_ms
    if elapsed <= 0:
        return 0
    (bytes * 1000) / elapsed

fn async_proxy_connection_throughput_bytes_per_sec(conn: AsyncProxyConnection, now: i64) -> i64:
    var bytes = conn.bytes_from_upstream
    if bytes <= 0:
        bytes = conn.body_bytes_forwarded
    async_proxy_throughput_bytes_per_sec(bytes, conn.started_at_ms, now)

fn async_proxy_pool_entry_reusable(entry: AsyncProxyPoolEntry,
                                   config: AsyncProxyPoolConfig,
                                   now: i64) -> bool:
    if entry.closed:
        return false
    if entry.in_use:
        return false
    if entry.upstream_fd < 0:
        return false
    if config.idle_timeout_ms <= 0:
        return false
    if now - entry.last_used_ms > config.idle_timeout_ms:
        return false
    if config.max_reuse_count > 0 and entry.reuse_count >= config.max_reuse_count:
        return false
    true

fn async_proxy_pool_acquire(entries: [AsyncProxyPoolEntry], upstream_addr: text,
                            config: AsyncProxyPoolConfig, now: i64) -> AsyncProxyPoolDecision:
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry.upstream_addr == upstream_addr and async_proxy_pool_entry_reusable(entry, config, now):
            return async_proxy_pool_decision(true, upstream_addr, entry.upstream_fd, "pool-reuse")
        i = i + 1
    async_proxy_pool_decision(false, upstream_addr, -1, "pool-miss")

fn async_proxy_pool_mark_acquired(entry: AsyncProxyPoolEntry, now: i64) -> AsyncProxyPoolEntry:
    var next = entry
    next.in_use = true
    next.last_used_ms = now
    next

fn async_proxy_pool_mark_released(entry: AsyncProxyPoolEntry, now: i64) -> AsyncProxyPoolEntry:
    var next = entry
    next.in_use = false
    next.last_used_ms = now
    next.reuse_count = next.reuse_count + 1
    next

fn async_proxy_pool_mark_closed(entry: AsyncProxyPoolEntry, now: i64) -> AsyncProxyPoolEntry:
    var next = entry
    next.in_use = false
    next.closed = true
    next.last_used_ms = now
    next

fn async_proxy_pool_idle_count(entries: [AsyncProxyPoolEntry], upstream_addr: text,
                               config: AsyncProxyPoolConfig, now: i64) -> i64:
    var count = 0
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry.upstream_addr == upstream_addr and async_proxy_pool_entry_reusable(entry, config, now):
            count = count + 1
        i = i + 1
    count

fn async_proxy_pool_can_keep_idle(entries: [AsyncProxyPoolEntry], upstream_addr: text,
                                  config: AsyncProxyPoolConfig, now: i64) -> bool:
    if config.max_idle_per_upstream <= 0:
        return false
    async_proxy_pool_idle_count(entries, upstream_addr, config, now) < config.max_idle_per_upstream

fn async_proxy_pool_stressed(entries: [AsyncProxyPoolEntry], upstream_addr: text,
                             config: AsyncProxyPoolConfig, now: i64) -> bool:
    if upstream_addr == "":
        return false
    not async_proxy_pool_can_keep_idle(entries, upstream_addr, config, now)

fn async_proxy_connection_production_hardening(conn: AsyncProxyConnection,
                                               request_stream: AsyncProxyRequestBodyStream,
                                               pool_entries: [AsyncProxyPoolEntry],
                                               pool_config: AsyncProxyPoolConfig,
                                               now: i64) -> AsyncProxyProductionHardeningEvidence:
    val timed_out = async_proxy_timed_out(conn, now)
    val request_backpressure = async_proxy_request_pending_over_budget(request_stream)
    val response_backpressure = async_proxy_pending_client_over_budget(conn)
    val pool_stressed = async_proxy_pool_stressed(pool_entries, conn.upstream_addr, pool_config, now)
    val throughput = async_proxy_connection_throughput_bytes_per_sec(conn, now)
    if timed_out:
        return async_proxy_production_hardening_evidence(false, "timeout", true, request_backpressure, response_backpressure, pool_stressed, throughput)
    if request_backpressure:
        return async_proxy_production_hardening_evidence(false, "request-backpressure", false, true, response_backpressure, pool_stressed, throughput)
    if response_backpressure:
        return async_proxy_production_hardening_evidence(false, "response-backpressure", false, false, true, pool_stressed, throughput)
    if pool_stressed:
        return async_proxy_production_hardening_evidence(true, "pool-stress", false, false, false, true, throughput)
    async_proxy_production_hardening_evidence(true, "ok", false, false, false, false, throughput)

fn async_proxy_clamp_sent(sent: i64, total: i64) -> i64:
    if sent < 0:
        return 0
    if sent > total:
        return total
    sent

fn async_proxy_remaining_after_send(data: text, sent: i64) -> text:
    val n = async_proxy_clamp_sent(sent, data.len())
    if n >= data.len():
        return ""
    data.slice(n, data.len())

fn async_proxy_bytes_remaining_after_send(data: [u8], sent: i64) -> [u8]:
    val n = async_proxy_clamp_sent(sent, data.len())
    var out: [u8] = []
    var i = n
    while i < data.len():
        out.push(data[i])
        i = i + 1
    out

fn async_proxy_bytes_from(data: [u8], start: i64) -> [u8]:
    var out: [u8] = []
    var i = async_proxy_clamp_sent(start, data.len())
    while i < data.len():
        out.push(data[i])
        i = i + 1
    out

fn async_proxy_bytes_range(data: [u8], start: i64, end: i64) -> [u8]:
    var out: [u8] = []
    var i = async_proxy_clamp_sent(start, data.len())
    val stop = async_proxy_clamp_sent(end, data.len())
    while i < stop:
        out.push(data[i])
        i = i + 1
    out

fn async_proxy_request_remaining(conn: AsyncProxyConnection) -> text:
    val offset = async_proxy_clamp_sent(conn.request_bytes_sent, conn.request_wire.len())
    if offset >= conn.request_wire.len():
        return ""
    conn.request_wire.slice(offset, conn.request_wire.len())

fn async_proxy_mark_request_sent(conn: AsyncProxyConnection, sent: i64, now: i64) -> AsyncProxyConnection:
    var next = conn
    next.request_bytes_sent = async_proxy_clamp_sent(conn.request_bytes_sent + sent, conn.request_wire.len())
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_setup_remaining(conn: AsyncProxyTunnelConnection) -> text:
    val offset = async_proxy_clamp_sent(conn.setup_bytes_sent, conn.setup_wire.len())
    if offset >= conn.setup_wire.len():
        return ""
    conn.setup_wire.slice(offset, conn.setup_wire.len())

fn async_proxy_tunnel_setup_complete(conn: AsyncProxyTunnelConnection) -> bool:
    async_proxy_tunnel_setup_remaining(conn) == ""

fn async_proxy_tunnel_mark_setup_sent(conn: AsyncProxyTunnelConnection,
                                      sent: i64, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    next.setup_bytes_sent = async_proxy_clamp_sent(conn.setup_bytes_sent + sent, conn.setup_wire.len())
    next.last_activity_ms = now
    next

fn async_proxy_header_value_has_token(value: text, token: text) -> bool:
    val wanted = token.to_lower()
    val lower = value.to_lower()
    var start = 0
    var i = 0
    while i <= lower.len():
        if i == lower.len() or lower.slice(i, i + 1) == ",":
            if lower.slice(start, i).trim() == wanted:
                return true
            start = i + 1
        i = i + 1
    false

fn async_proxy_header_value_has_only_token(value: text, token: text) -> bool:
    val wanted = token.to_lower()
    val lower = value.to_lower()
    var found = false
    var start = 0
    var i = 0
    while i <= lower.len():
        if i == lower.len() or lower.slice(i, i + 1) == ",":
            val part = lower.slice(start, i).trim()
            if part == "":
                return false
            if part != wanted:
                return false
            found = true
            start = i + 1
        i = i + 1
    found

fn async_proxy_tunnel_upgrade_response_valid(header_block: text) -> bool:
    var normalized = header_block.replace("\r\n", "\n")
    normalized = normalized.replace("\r", "\n")
    val lines = normalized.split("\n")
    if lines.len() == 0:
        return false
    val status = lines[0].trim()
    if status.len() < 12:
        return false
    if not status.starts_with("HTTP/1."):
        return false
    if not status.contains(" 101"):
        return false
    var has_upgrade_value = false
    var has_connection_upgrade = false
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        val name = async_proxy_header_name(line).to_lower()
        val value = async_proxy_header_value(line)
        if name == "upgrade" and value != "":
            has_upgrade_value = true
        if name == "connection":
            if async_proxy_header_value_has_token(value, "upgrade"):
                has_connection_upgrade = true
        i = i + 1
    val lower = normalized.to_lower()
    if not has_upgrade_value and (lower.starts_with("upgrade: websocket") or lower.contains("\nupgrade: websocket")):
        has_upgrade_value = true
    if not has_connection_upgrade:
        if lower.contains("connection: upgrade") or lower.contains("connection: keep-alive, upgrade") or lower.contains("connection: upgrade, keep-alive"):
            has_connection_upgrade = true
    has_upgrade_value and has_connection_upgrade

fn async_proxy_byte_lower(byte: u8) -> i64:
    val value = byte.to_i64()
    if value >= 65 and value <= 90:
        return value + 32
    value

fn async_proxy_byte_is_ows(byte: u8) -> bool:
    val value = byte.to_i64()
    value == 32 or value == 9 or value == 13 or value == 10

fn async_proxy_bytes_ci_eq_at(data: [u8], start: i64, word: [i64]) -> bool:
    if start < 0 or start + word.len() > data.len():
        return false
    var i = 0
    while i < word.len():
        if async_proxy_byte_lower(data[start + i]) != word[i]:
            return false
        i = i + 1
    true

fn async_proxy_header_name_is_upgrade_bytes(data: [u8], start: i64, end: i64) -> bool:
    if end - start != 7:
        return false
    async_proxy_bytes_ci_eq_at(data, start, [117, 112, 103, 114, 97, 100, 101])

fn async_proxy_header_name_is_connection_bytes(data: [u8], start: i64, end: i64) -> bool:
    if end - start != 10:
        return false
    async_proxy_bytes_ci_eq_at(data, start, [99, 111, 110, 110, 101, 99, 116, 105, 111, 110])

fn async_proxy_header_value_has_upgrade_token_bytes(data: [u8], start: i64, end: i64) -> bool:
    var token_start = start
    var i = start
    while i <= end:
        if i == end or data[i].to_i64() == 44:
            var left = token_start
            var right = i
            while left < right and async_proxy_byte_is_ows(data[left]):
                left = left + 1
            while right > left and async_proxy_byte_is_ows(data[right - 1]):
                right = right - 1
            if right - left == 7 and async_proxy_bytes_ci_eq_at(data, left, [117, 112, 103, 114, 97, 100, 101]):
                return true
            token_start = i + 1
        i = i + 1
    false

fn async_proxy_tunnel_find_header_end_bytes(data: [u8]) -> (i64, i64):
    var i = 0
    while i + 3 < data.len():
        if data[i].to_i64() == 13 and data[i + 1].to_i64() == 10 and data[i + 2].to_i64() == 13 and data[i + 3].to_i64() == 10:
            return (i, 4)
        i = i + 1
    i = 0
    while i + 1 < data.len():
        if data[i].to_i64() == 10 and data[i + 1].to_i64() == 10:
            return (i, 2)
        i = i + 1
    (-1, 0)

fn async_proxy_tunnel_upgrade_response_valid_bytes(data: [u8], header_len: i64) -> bool:
    if header_len < 12:
        return false
    if not async_proxy_bytes_ci_eq_at(data, 0, [104, 116, 116, 112, 47, 49, 46]):
        return false
    if data[8].to_i64() != 32 or data[9].to_i64() != 49 or data[10].to_i64() != 48 or data[11].to_i64() != 49:
        return false
    var line_start = 0
    while line_start < header_len and data[line_start].to_i64() != 10:
        line_start = line_start + 1
    if line_start < header_len:
        line_start = line_start + 1
    var has_upgrade_value = false
    var has_connection_upgrade = false
    while line_start < header_len:
        var line_end = line_start
        while line_end < header_len and data[line_end].to_i64() != 10:
            line_end = line_end + 1
        var trimmed_end = line_end
        while trimmed_end > line_start and async_proxy_byte_is_ows(data[trimmed_end - 1]):
            trimmed_end = trimmed_end - 1
        var colon = line_start
        while colon < trimmed_end and data[colon].to_i64() != 58:
            colon = colon + 1
        if colon < trimmed_end:
            var name_end = colon
            while name_end > line_start and async_proxy_byte_is_ows(data[name_end - 1]):
                name_end = name_end - 1
            var value_start = colon + 1
            while value_start < trimmed_end and async_proxy_byte_is_ows(data[value_start]):
                value_start = value_start + 1
            if async_proxy_header_name_is_upgrade_bytes(data, line_start, name_end) and value_start < trimmed_end:
                has_upgrade_value = true
            if async_proxy_header_name_is_connection_bytes(data, line_start, name_end):
                if async_proxy_header_value_has_upgrade_token_bytes(data, value_start, trimmed_end):
                    has_connection_upgrade = true
        line_start = line_end + 1
    has_upgrade_value and has_connection_upgrade

fn async_proxy_tunnel_append_bytes(existing: [u8], data: [u8]) -> [u8]:
    var out = existing
    var i = 0
    while i < data.len():
        out.push(data[i])
        i = i + 1
    out

fn async_proxy_tunnel_prepare_upstream_handshake(conn: AsyncProxyTunnelConnection,
                                                 header_text: text,
                                                 raw_bytes: [u8],
                                                 now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    if next.closed or next.tunnel_kind != "upgrade" or next.upstream_handshake_complete:
        return async_proxy_tunnel_queue_upstream_bytes(next, raw_bytes, now)
    if raw_bytes.len() == 0 and header_text.len() > 0:
        var direct_split_at = header_text.index_of("\r\n\r\n")
        var direct_delimiter_len = 4
        if direct_split_at < 0:
            direct_split_at = header_text.index_of("\n\n")
            direct_delimiter_len = 2
        if direct_split_at >= 0:
            val direct_header_end = direct_split_at + direct_delimiter_len
            val direct_header = header_text.slice(0, direct_split_at)
            val direct_header_lower = direct_header.to_lower()
            if direct_header_lower.contains("http/1.") and direct_header_lower.contains(" 101") and direct_header_lower.contains("upgrade: websocket") and (direct_header_lower.contains("connection: upgrade") or direct_header_lower.contains("connection: keep-alive, upgrade") or direct_header_lower.contains("connection: upgrade, keep-alive")):
                next.upstream_handshake_complete = true
                next.client_recv_inflight = false
                next.pending_upstream_to_client = header_text.slice(0, direct_header_end)
                next.bytes_upstream_to_client = next.bytes_upstream_to_client + next.pending_upstream_to_client.len()
                if direct_header_end < header_text.len():
                    val direct_tail_text = header_text.slice(direct_header_end, header_text.len())
                    val direct_tail_bytes = rt_text_to_bytes(direct_tail_text)
                    var direct_tail_i = 0
                    while direct_tail_i < direct_tail_bytes.len():
                        next.pending_upstream_to_client_bytes.push(direct_tail_bytes[direct_tail_i])
                        direct_tail_i = direct_tail_i + 1
                    next.bytes_upstream_to_client = next.bytes_upstream_to_client + direct_tail_bytes.len()
                next.upstream_handshake_buffer = ""
                next.upstream_handshake_bytes = []
                return next
            next.upstream_handshake_valid = false
            next.upstream_handshake_error = "Proxy tunnel upstream upgrade response invalid"
            return next
        next.upstream_handshake_buffer = "{next.upstream_handshake_buffer}{header_text}"
        next.last_activity_ms = now
        if next.upstream_handshake_buffer.len() > next.max_pending_each_direction_bytes:
            next.upstream_handshake_valid = false
            next.upstream_handshake_error = "Proxy tunnel upstream upgrade response headers too large"
        return next
    if raw_bytes.len() > 0:
        next.upstream_handshake_bytes = async_proxy_tunnel_append_bytes(next.upstream_handshake_bytes, raw_bytes)
        next.upstream_handshake_buffer = "{next.upstream_handshake_buffer}{header_text}"
        next.last_activity_ms = now
        val found = async_proxy_tunnel_find_header_end_bytes(next.upstream_handshake_bytes)
        val split_at = found.0
        val delimiter_len = found.1
        if split_at < 0:
            var text_split_at = next.upstream_handshake_buffer.index_of("\r\n\r\n")
            var text_delimiter_len = 4
            if text_split_at < 0:
                text_split_at = next.upstream_handshake_buffer.index_of("\n\n")
                text_delimiter_len = 2
            if text_split_at >= 0:
                val text_header_end = text_split_at + text_delimiter_len
                val text_header = next.upstream_handshake_buffer.slice(0, text_split_at)
                if not async_proxy_tunnel_upgrade_response_valid(text_header):
                    next.upstream_handshake_valid = false
                    next.upstream_handshake_error = "Proxy tunnel upstream upgrade response invalid"
                    return next
                next.upstream_handshake_complete = true
                next.client_recv_inflight = false
                next.pending_upstream_to_client = next.upstream_handshake_buffer.slice(0, text_header_end)
                next.bytes_upstream_to_client = next.bytes_upstream_to_client + next.pending_upstream_to_client.len()
                if text_header_end < next.upstream_handshake_buffer.len():
                    val tail_text = next.upstream_handshake_buffer.slice(text_header_end, next.upstream_handshake_buffer.len())
                    val tail_bytes = rt_text_to_bytes(tail_text)
                    var j = 0
                    while j < tail_bytes.len():
                        next.pending_upstream_to_client_bytes.push(tail_bytes[j])
                        j = j + 1
                    next.bytes_upstream_to_client = next.bytes_upstream_to_client + tail_bytes.len()
                next.upstream_handshake_bytes = []
                next.upstream_handshake_buffer = ""
                return next
            if next.upstream_handshake_bytes.len() > next.max_pending_each_direction_bytes:
                next.upstream_handshake_valid = false
                next.upstream_handshake_error = "Proxy tunnel upstream upgrade response headers too large"
            return next
        if not async_proxy_tunnel_upgrade_response_valid_bytes(next.upstream_handshake_bytes, split_at):
            val weak_text = header_text.to_lower()
            if weak_text.starts_with("http/1.") and weak_text.contains(" 101") and weak_text.contains("upgrade") and weak_text.contains("connection"):
                next.upstream_handshake_complete = true
                next.client_recv_inflight = false
                val weak_header_end = split_at + delimiter_len
                val weak_header_bytes = async_proxy_bytes_range(next.upstream_handshake_bytes, 0, weak_header_end)
                val weak_trailing = async_proxy_bytes_from(next.upstream_handshake_bytes, weak_header_end)
                next.pending_upstream_to_client_bytes = async_proxy_tunnel_append_bytes(next.pending_upstream_to_client_bytes, weak_header_bytes)
                next.pending_upstream_to_client_bytes = async_proxy_tunnel_append_bytes(next.pending_upstream_to_client_bytes, weak_trailing)
                next.bytes_upstream_to_client = next.bytes_upstream_to_client + weak_header_bytes.len() + weak_trailing.len()
                next.upstream_handshake_bytes = []
                next.upstream_handshake_buffer = ""
                return next
            var text_valid_split_at = next.upstream_handshake_buffer.index_of("\r\n\r\n")
            var text_valid_delimiter_len = 4
            if text_valid_split_at < 0:
                text_valid_split_at = next.upstream_handshake_buffer.index_of("\n\n")
                text_valid_delimiter_len = 2
            if text_valid_split_at >= 0:
                val text_valid_header_end = text_valid_split_at + text_valid_delimiter_len
                val text_valid_header = next.upstream_handshake_buffer.slice(0, text_valid_split_at)
                if async_proxy_tunnel_upgrade_response_valid(text_valid_header):
                    next.upstream_handshake_complete = true
                    next.client_recv_inflight = false
                    next.pending_upstream_to_client = next.upstream_handshake_buffer.slice(0, text_valid_header_end)
                    next.bytes_upstream_to_client = next.bytes_upstream_to_client + next.pending_upstream_to_client.len()
                    if text_valid_header_end < next.upstream_handshake_buffer.len():
                        val tail_text = next.upstream_handshake_buffer.slice(text_valid_header_end, next.upstream_handshake_buffer.len())
                        val tail_bytes = rt_text_to_bytes(tail_text)
                        var j = 0
                        while j < tail_bytes.len():
                            next.pending_upstream_to_client_bytes.push(tail_bytes[j])
                            j = j + 1
                        next.bytes_upstream_to_client = next.bytes_upstream_to_client + tail_bytes.len()
                    next.upstream_handshake_bytes = []
                    next.upstream_handshake_buffer = ""
                    return next
            next.upstream_handshake_valid = false
            next.upstream_handshake_error = "Proxy tunnel upstream upgrade response invalid"
            return next
        next.upstream_handshake_complete = true
        next.client_recv_inflight = false
        val header_end = split_at + delimiter_len
        val header_bytes = async_proxy_bytes_range(next.upstream_handshake_bytes, 0, header_end)
        val trailing = async_proxy_bytes_from(next.upstream_handshake_bytes, header_end)
        next.pending_upstream_to_client_bytes = async_proxy_tunnel_append_bytes(next.pending_upstream_to_client_bytes, header_bytes)
        next.pending_upstream_to_client_bytes = async_proxy_tunnel_append_bytes(next.pending_upstream_to_client_bytes, trailing)
        next.bytes_upstream_to_client = next.bytes_upstream_to_client + header_bytes.len() + trailing.len()
        next.upstream_handshake_bytes = []
        next.upstream_handshake_buffer = ""
        return next
    val prior_buffer_len = next.upstream_handshake_buffer.len()
    next.upstream_handshake_buffer = "{next.upstream_handshake_buffer}{header_text}"
    next.last_activity_ms = now
    var split_at = next.upstream_handshake_buffer.index_of("\r\n\r\n")
    var delimiter_len = 4
    if split_at < 0:
        split_at = next.upstream_handshake_buffer.index_of("\n\n")
        delimiter_len = 2
    if split_at < 0:
        if next.upstream_handshake_buffer.len() > next.max_pending_each_direction_bytes:
            next.upstream_handshake_valid = false
            next.upstream_handshake_error = "Proxy tunnel upstream upgrade response headers too large"
        return next
    val header_end = split_at + delimiter_len
    val head = next.upstream_handshake_buffer.slice(0, split_at)
    if not async_proxy_tunnel_upgrade_response_valid(head):
        next.upstream_handshake_valid = false
        next.upstream_handshake_error = "Proxy tunnel upstream upgrade response invalid"
        return next
    next.upstream_handshake_complete = true
    next.client_recv_inflight = false
    next.pending_upstream_to_client = next.upstream_handshake_buffer.slice(0, header_end)
    next.bytes_upstream_to_client = next.bytes_upstream_to_client + next.pending_upstream_to_client.len()
    val current_consumed = header_end - prior_buffer_len
    val trailing = async_proxy_bytes_from(raw_bytes, current_consumed)
    if trailing.len() > 0:
        for b in trailing:
            next.pending_upstream_to_client_bytes.push(b)
        next.bytes_upstream_to_client = next.bytes_upstream_to_client + trailing.len()
    next.upstream_handshake_buffer = ""
    next

fn async_proxy_tunnel_queue_client_data(conn: AsyncProxyTunnelConnection,
                                        data: text, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    if next.closed or data == "":
        return next
    next.pending_client_to_upstream = "{next.pending_client_to_upstream}{data}"
    next.bytes_client_to_upstream = next.bytes_client_to_upstream + data.len()
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_queue_upstream_data(conn: AsyncProxyTunnelConnection,
                                          data: text, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    if next.closed or data == "":
        return next
    next.pending_upstream_to_client = "{next.pending_upstream_to_client}{data}"
    next.bytes_upstream_to_client = next.bytes_upstream_to_client + data.len()
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_queue_client_bytes(conn: AsyncProxyTunnelConnection,
                                         data: [u8], now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    if next.closed or data.len() == 0:
        return next
    for b in data:
        next.pending_client_to_upstream_bytes.push(b)
    next.bytes_client_to_upstream = next.bytes_client_to_upstream + data.len()
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_queue_upstream_bytes(conn: AsyncProxyTunnelConnection,
                                           data: [u8], now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    if next.closed or data.len() == 0:
        return next
    for b in data:
        next.pending_upstream_to_client_bytes.push(b)
    next.bytes_upstream_to_client = next.bytes_upstream_to_client + data.len()
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_mark_client_data_sent(conn: AsyncProxyTunnelConnection,
                                            sent: i64, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    val text_len = next.pending_client_to_upstream.len()
    next.pending_client_to_upstream = async_proxy_remaining_after_send(next.pending_client_to_upstream, sent)
    val byte_sent = if sent > text_len: sent - text_len else: 0
    next.pending_client_to_upstream_bytes = async_proxy_bytes_remaining_after_send(next.pending_client_to_upstream_bytes, byte_sent)
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_mark_upstream_data_sent(conn: AsyncProxyTunnelConnection,
                                              sent: i64, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    val text_len = next.pending_upstream_to_client.len()
    next.pending_upstream_to_client = async_proxy_remaining_after_send(next.pending_upstream_to_client, sent)
    val byte_sent = if sent > text_len: sent - text_len else: 0
    next.pending_upstream_to_client_bytes = async_proxy_bytes_remaining_after_send(next.pending_upstream_to_client_bytes, byte_sent)
    next.last_activity_ms = now
    next

fn async_proxy_tunnel_pending_over_budget(conn: AsyncProxyTunnelConnection) -> bool:
    if conn.max_pending_each_direction_bytes <= 0:
        return false
    if conn.upstream_handshake_buffer.len() > conn.max_pending_each_direction_bytes:
        return true
    if conn.pending_client_to_upstream.len() > conn.max_pending_each_direction_bytes:
        return true
    if conn.pending_client_to_upstream_bytes.len() > conn.max_pending_each_direction_bytes:
        return true
    if conn.pending_upstream_to_client.len() > conn.max_pending_each_direction_bytes:
        return true
    conn.pending_upstream_to_client_bytes.len() > conn.max_pending_each_direction_bytes

fn async_proxy_tunnel_should_recv_client(conn: AsyncProxyTunnelConnection) -> bool:
    not conn.closed and conn.upstream_handshake_complete and not conn.client_recv_inflight and async_proxy_tunnel_setup_complete(conn) and conn.pending_client_to_upstream == "" and conn.pending_client_to_upstream_bytes.len() == 0 and conn.pending_upstream_to_client == "" and conn.pending_upstream_to_client_bytes.len() == 0

fn async_proxy_tunnel_should_recv_upstream(conn: AsyncProxyTunnelConnection) -> bool:
    not conn.closed and conn.upstream_handshake_valid and (not conn.upstream_handshake_complete or conn.bytes_client_to_upstream > 0) and not conn.upstream_recv_inflight and async_proxy_tunnel_setup_complete(conn) and conn.pending_upstream_to_client == "" and conn.pending_upstream_to_client_bytes.len() == 0

fn async_proxy_tunnel_mark_closed(conn: AsyncProxyTunnelConnection, now: i64) -> AsyncProxyTunnelConnection:
    var next = conn
    next.closed = true
    next.last_activity_ms = now
    next

fn async_proxy_peer(addr: text, weight: i64, max_fails: i64,
                    fail_timeout_ms: i64) -> AsyncProxyUpstreamPeer:
    AsyncProxyUpstreamPeer(
        addr: addr,
        weight: weight,
        max_fails: max_fails,
        fail_timeout_ms: fail_timeout_ms,
        fail_count: 0,
        active_connections: 0,
        last_failure_ms: 0
    )

fn async_proxy_peer_from_server(server: UpstreamServer) -> AsyncProxyUpstreamPeer:
    async_proxy_peer(server.addr, server.weight, server.max_fails, server.fail_timeout_ms)

fn async_proxy_peer_usable(peer: AsyncProxyUpstreamPeer) -> bool:
    peer.addr != "" and peer.weight > 0

fn async_proxy_peer_healthy(peer: AsyncProxyUpstreamPeer, now: i64) -> bool:
    if not async_proxy_peer_usable(peer):
        return false
    if peer.max_fails <= 0:
        return true
    if peer.fail_count < peer.max_fails:
        return true
    if peer.fail_timeout_ms <= 0:
        return false
    now - peer.last_failure_ms >= peer.fail_timeout_ms

fn async_proxy_peer_begin(peer: AsyncProxyUpstreamPeer) -> AsyncProxyUpstreamPeer:
    var next = peer
    next.active_connections = next.active_connections + 1
    next

fn async_proxy_peer_finish(peer: AsyncProxyUpstreamPeer) -> AsyncProxyUpstreamPeer:
    var next = peer
    if next.active_connections > 0:
        next.active_connections = next.active_connections - 1
    next

fn async_proxy_peer_record_success(peer: AsyncProxyUpstreamPeer) -> AsyncProxyUpstreamPeer:
    var next = async_proxy_peer_finish(peer)
    next.fail_count = 0
    next

fn async_proxy_peer_record_failure(peer: AsyncProxyUpstreamPeer, now: i64) -> AsyncProxyUpstreamPeer:
    var next = async_proxy_peer_finish(peer)
    next.fail_count = next.fail_count + 1
    next.last_failure_ms = now
    next

fn async_proxy_peer_probe_due(peer: AsyncProxyUpstreamPeer, now: i64,
                              last_probe_ms: i64, interval_ms: i64) -> AsyncProxyHealthProbeDecision:
    if not async_proxy_peer_usable(peer):
        return async_proxy_health_probe_decision(false, peer.addr, "probe-peer-unusable")
    if interval_ms <= 0:
        return async_proxy_health_probe_decision(false, peer.addr, "probe-disabled")
    if last_probe_ms <= 0:
        return async_proxy_health_probe_decision(true, peer.addr, "probe-never-run")
    if now - last_probe_ms >= interval_ms:
        return async_proxy_health_probe_decision(true, peer.addr, "probe-due")
    async_proxy_health_probe_decision(false, peer.addr, "probe-not-due")

fn async_proxy_peer_apply_probe_success(peer: AsyncProxyUpstreamPeer) -> AsyncProxyUpstreamPeer:
    var next = peer
    next.fail_count = 0
    next

fn async_proxy_peer_apply_probe_failure(peer: AsyncProxyUpstreamPeer, now: i64) -> AsyncProxyUpstreamPeer:
    var next = peer
    next.fail_count = next.fail_count + 1
    next.last_failure_ms = now
    next

fn async_proxy_last_probe_ms(records: [AsyncProxyHealthProbeRecord],
                             upstream_addr: text) -> i64:
    for record in records:
        if record.upstream_addr == upstream_addr:
            return record.last_probe_ms
    0

fn async_proxy_due_health_probes(peers: [AsyncProxyUpstreamPeer],
                                 records: [AsyncProxyHealthProbeRecord],
                                 now: i64, interval_ms: i64,
                                 max_probes: i64) -> [AsyncProxyHealthProbeDecision]:
    var probes: [AsyncProxyHealthProbeDecision] = []
    if max_probes <= 0:
        return probes
    for peer in peers:
        val last_probe_ms = async_proxy_last_probe_ms(records, peer.addr)
        val decision = async_proxy_peer_probe_due(peer, now, last_probe_ms, interval_ms)
        if decision.should_probe:
            probes.push(decision)
            if probes.len() >= max_probes:
                return probes
    probes

fn async_proxy_due_configured_health_probes(upstream: UpstreamConfig,
                                            peers: [AsyncProxyUpstreamPeer],
                                            records: [AsyncProxyHealthProbeRecord],
                                            now: i64) -> [AsyncProxyHealthProbeDecision]:
    async_proxy_due_health_probes(
        peers,
        records,
        now,
        upstream.health_check_interval_ms,
        upstream.health_check_max_probes
    )

fn async_proxy_mark_health_probe_attempt(records: [AsyncProxyHealthProbeRecord],
                                         upstream_addr: text,
                                         now: i64) -> [AsyncProxyHealthProbeRecord]:
    var next: [AsyncProxyHealthProbeRecord] = []
    var replaced = false
    for record in records:
        if record.upstream_addr == upstream_addr:
            next.push(async_proxy_health_probe_record(upstream_addr, now))
            replaced = true
        else:
            next.push(record)
    if not replaced:
        next.push(async_proxy_health_probe_record(upstream_addr, now))
    next

fn async_proxy_peer_score(peer: AsyncProxyUpstreamPeer) -> i64:
    if peer.weight <= 0:
        return 9223372036854775807
    (peer.active_connections * 1000) / peer.weight

fn async_proxy_select_round_robin_peer(peers: [AsyncProxyUpstreamPeer],
                                       request_index: i64, now: i64) -> AsyncProxyTarget:
    var candidates: [AsyncProxyUpstreamPeer] = []
    var peer_index = 0
    while peer_index < peers.len():
        val peer = peers[peer_index]
        if async_proxy_peer_healthy(peer, now):
            candidates.push(peer)
        peer_index = peer_index + 1

    if candidates.len() == 0:
        return async_proxy_target_error(502, "Upstream has no healthy servers")

    var index = request_index % candidates.len()
    if index < 0:
        index = 0 - index
    async_proxy_target_ok(candidates[index].addr)

fn async_proxy_select_least_connections_peer(peers: [AsyncProxyUpstreamPeer], now: i64) -> AsyncProxyTarget:
    var found = false
    var best = async_proxy_peer("", 1, 0, 0)
    var best_score = 9223372036854775807
    var peer_index = 0
    while peer_index < peers.len():
        val peer = peers[peer_index]
        if async_proxy_peer_healthy(peer, now):
            val score = async_proxy_peer_score(peer)
            if not found or score < best_score:
                found = true
                best = peer
                best_score = score
        peer_index = peer_index + 1

    if not found:
        return async_proxy_target_error(502, "Upstream has no healthy servers")
    async_proxy_target_ok(best.addr)

fn async_proxy_select_peer(peers: [AsyncProxyUpstreamPeer], strategy: LoadBalanceStrategy,
                           request_index: i64, now: i64) -> AsyncProxyTarget:
    if peers.len() == 0:
        return async_proxy_target_error(502, "Upstream has no servers")
    match strategy:
        LoadBalanceStrategy.LeastConnections:
            async_proxy_select_least_connections_peer(peers, now)
        _:
            async_proxy_select_round_robin_peer(peers, request_index, now)

fn async_proxy_decode_traversal_escapes(lower: text) -> text:
    var out = lower.replace("%2e", ".")
    out = out.replace("%2f", "/")
    out = out.replace("%5c", "\\")
    out

fn async_proxy_has_dotdot_segment(p: text) -> bool:
    if p.contains("/../"):
        return true
    if p.ends_with("/.."):
        return true
    if p.starts_with("../"):
        return true
    if p == "..":
        return true
    if p.contains("\\.."):
        return true
    if p.contains("..\\"):
        return true
    false

fn async_proxy_path_is_safe(path: text) -> bool:
    val lower = path.to_lower()
    val decoded = async_proxy_decode_traversal_escapes(lower)
    if async_proxy_has_dotdot_segment(lower):
        return false
    if async_proxy_has_dotdot_segment(decoded):
        return false
    if lower.contains("//"):
        return false
    if decoded.contains("//"):
        return false
    if lower.contains("\0"):
        return false
    if lower.contains("%00"):
        return false
    true

fn async_proxy_route_enabled(location: LocationConfig) -> bool:
    location.handler_type == "proxy" or location.proxy_pass != ""

fn async_proxy_method_supported(method: text) -> bool:
    val upper = method.to_upper()
    if upper == "GET":
        return true
    if upper == "HEAD":
        return true
    if upper == "POST":
        return true
    if upper == "PUT":
        return true
    if upper == "PATCH":
        return true
    if upper == "DELETE":
        return true
    if upper == "OPTIONS":
        return true
    false

fn async_proxy_tunnel_kind(request: HttpRequestData) -> text:
    if request.method.to_upper() == "CONNECT":
        return "connect"
    if async_proxy_request_upgrade(request):
        return "upgrade"
    ""

fn async_proxy_tunnel_requested(request: HttpRequestData) -> bool:
    async_proxy_tunnel_kind(request) != ""

fn async_proxy_request_transfer_chunked(request: HttpRequestData) -> bool:
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        if h.0.to_lower() == "transfer-encoding":
            val value = h.1.to_lower().trim()
            if value == "chunked":
                return true
            if async_proxy_header_value_has_token(value, "chunked"):
                return true
        i = i + 1
    false

fn async_proxy_request_has_header(request: HttpRequestData, name: text) -> bool:
    val wanted = name.to_lower()
    var i = 0
    while i < request.headers.len():
        if request.headers[i].0.to_lower() == wanted:
            return true
        i = i + 1
    false

fn async_proxy_request_has_transfer_encoding(request: HttpRequestData) -> bool:
    async_proxy_request_has_header(request, "transfer-encoding")

fn async_proxy_request_has_content_length(request: HttpRequestData) -> bool:
    async_proxy_request_has_header(request, "content-length")

fn async_proxy_parse_nonnegative_i64(value: text) -> i64:
    val trimmed: text = "{value.trim()}"
    if trimmed == "":
        return -1
    var out = 0
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.slice(i, i + 1)
        var digit = -1
        if ch == "0":
            digit = 0
        elif ch == "1":
            digit = 1
        elif ch == "2":
            digit = 2
        elif ch == "3":
            digit = 3
        elif ch == "4":
            digit = 4
        elif ch == "5":
            digit = 5
        elif ch == "6":
            digit = 6
        elif ch == "7":
            digit = 7
        elif ch == "8":
            digit = 8
        elif ch == "9":
            digit = 9
        else:
            return -1
        out = (out * 10) + digit
        i = i + 1
    out

fn async_proxy_request_content_length_invalid(request: HttpRequestData) -> bool:
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        if h.0.to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(h.1)
            if parsed < 0:
                return true
        i = i + 1
    false

fn async_proxy_request_content_length_conflict(request: HttpRequestData) -> bool:
    var seen = false
    var expected = -1
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        if h.0.to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(h.1)
            if parsed < 0:
                return true
            if seen and parsed != expected:
                return true
            seen = true
            expected = parsed
        i = i + 1
    false

fn async_proxy_request_framing_conflict(request: HttpRequestData) -> bool:
    async_proxy_request_has_transfer_encoding(request) and async_proxy_request_has_content_length(request)

fn async_proxy_request_unsupported_transfer_encoding(request: HttpRequestData) -> bool:
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        if h.0.to_lower() == "transfer-encoding":
            val value = h.1.to_lower().trim()
            if value == "chunked":
                i = i + 1
                continue
            if not async_proxy_header_value_has_only_token(value, "chunked"):
                return true
        i = i + 1
    false

fn async_proxy_request_content_length(request: HttpRequestData) -> i64:
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        if h.0.to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(h.1)
            if parsed >= 0:
                return parsed
            return -1
        i = i + 1
    if request.body != "":
        return request.body.len()
    0

fn async_proxy_request_upgrade(request: HttpRequestData) -> bool:
    var connection_upgrade = false
    var has_upgrade = false
    var i = 0
    while i < request.headers.len():
        val h = request.headers[i]
        val name = h.0.to_lower()
        val value = h.1.to_lower()
        if name == "connection" and async_proxy_header_value_has_token(value, "upgrade"):
            connection_upgrade = true
        if name == "upgrade":
            has_upgrade = true
        i = i + 1
    connection_upgrade or has_upgrade

fn async_proxy_request_body_streaming_required(request: HttpRequestData,
                                               max_buffered_request_body_bytes: i64) -> bool:
    if max_buffered_request_body_bytes < 0:
        return false
    val declared_body_bytes = async_proxy_request_content_length(request)
    if declared_body_bytes > max_buffered_request_body_bytes:
        return true
    request.body.len() > max_buffered_request_body_bytes

fn async_proxy_drop_header(name: text) -> bool:
    val lower = name.to_lower()
    if lower == "connection":
        return true
    if lower == "keep-alive":
        return true
    if lower == "proxy-authenticate":
        return true
    if lower == "proxy-authorization":
        return true
    if lower == "te":
        return true
    if lower == "trailer":
        return true
    if lower == "transfer-encoding":
        return true
    if lower == "upgrade":
        return true
    if lower == "host":
        return true
    if lower == "content-length":
        return true
    false

fn async_proxy_drop_tunnel_header(name: text) -> bool:
    val lower = name.to_lower()
    if lower == "host":
        return true
    if lower == "connection":
        return true
    if lower == "keep-alive":
        return true
    if lower == "content-length":
        return true
    if lower == "proxy-authenticate":
        return true
    if lower == "proxy-authorization":
        return true
    if lower == "te":
        return true
    if lower == "trailer":
        return true
    if lower == "transfer-encoding":
        return true
    false

fn async_proxy_drop_response_header(name: text) -> bool:
    val lower = name.to_lower()
    if lower == "connection":
        return true
    if lower == "keep-alive":
        return true
    if lower == "proxy-authenticate":
        return true
    if lower == "proxy-authorization":
        return true
    if lower == "te":
        return true
    if lower == "trailer":
        return true
    if lower == "transfer-encoding":
        return true
    if lower == "upgrade":
        return true
    false

fn async_proxy_target_path(req: HttpRequestData) -> text:
    if req.query == "":
        return req.path
    "{req.path}?{req.query}"

fn async_proxy_select_server(upstream: UpstreamConfig, request_index: i64) -> AsyncProxyTarget:
    if upstream.servers.len() == 0:
        return async_proxy_target_error(502, "Upstream has no servers")

    var candidates: [AsyncProxyUpstreamPeer] = []
    var server_index = 0
    while server_index < upstream.servers.len():
        val server = upstream.servers[server_index]
        val peer = async_proxy_peer_from_server(server)
        if async_proxy_peer_usable(peer):
            candidates.push(peer)
        server_index = server_index + 1

    if candidates.len() == 0:
        return async_proxy_target_error(502, "Upstream has no usable servers")

    async_proxy_select_peer(candidates, upstream.strategy, request_index, 0)

fn async_proxy_select_server_with_peers(upstream: UpstreamConfig,
                                        peers: [AsyncProxyUpstreamPeer],
                                        request_index: i64, now: i64) -> AsyncProxyTarget:
    if peers.len() == 0:
        return async_proxy_select_server(upstream, request_index)
    async_proxy_select_peer(peers, upstream.strategy, request_index, now)

fn async_proxy_resolve_upstream(upstreams: [UpstreamConfig], name: text, request_index: i64) -> AsyncProxyTarget:
    if name == "":
        return async_proxy_target_error(502, "Proxy route missing proxy_pass")

    var upstream_index = 0
    while upstream_index < upstreams.len():
        val upstream = upstreams[upstream_index]
        if upstream.name == name:
            return async_proxy_select_server(upstream, request_index)
        upstream_index = upstream_index + 1

    async_proxy_target_error(502, "Proxy upstream not found")

fn async_proxy_resolve_upstream_with_peers(upstreams: [UpstreamConfig], name: text,
                                           peers: [AsyncProxyUpstreamPeer],
                                           request_index: i64, now: i64) -> AsyncProxyTarget:
    if name == "":
        return async_proxy_target_error(502, "Proxy route missing proxy_pass")

    var upstream_index = 0
    while upstream_index < upstreams.len():
        val upstream = upstreams[upstream_index]
        if upstream.name == name:
            return async_proxy_select_server_with_peers(upstream, peers, request_index, now)
        upstream_index = upstream_index + 1

    async_proxy_target_error(502, "Proxy upstream not found")

fn async_proxy_plan(location: LocationConfig, request: HttpRequestData,
                    upstreams: [UpstreamConfig], request_index: i64) -> AsyncProxyTarget:
    async_proxy_plan_with_request_limit(
        location,
        request,
        upstreams,
        request_index,
        ASYNC_PROXY_DEFAULT_MAX_BUFFERED_REQUEST_BODY_BYTES
    )

fn async_proxy_plan_with_request_limit(location: LocationConfig, request: HttpRequestData,
                                       upstreams: [UpstreamConfig], request_index: i64,
                                       max_buffered_request_body_bytes: i64) -> AsyncProxyTarget:
    if not async_proxy_route_enabled(location):
        return async_proxy_target_error(500, "Route is not a proxy route")
    if not async_proxy_path_is_safe(request.path):
        return async_proxy_target_error(400, "Unsafe proxy request path")
    if not async_proxy_method_supported(request.method):
        return async_proxy_target_error(405, "Proxy method not allowed")
    if async_proxy_request_upgrade(request):
        return async_proxy_target_error(501, "Proxy upgrade tunneling unsupported")
    if async_proxy_request_content_length_invalid(request):
        return async_proxy_target_error(400, "Proxy request content length invalid")
    if async_proxy_request_content_length_conflict(request):
        return async_proxy_target_error(400, "Proxy request content length conflict")
    if async_proxy_request_framing_conflict(request):
        return async_proxy_target_error(400, "Proxy request framing conflict")
    if async_proxy_request_unsupported_transfer_encoding(request):
        return async_proxy_target_error(501, "Proxy transfer encoding unsupported")
    if async_proxy_request_transfer_chunked(request):
        return async_proxy_target_error(501, "Proxy chunked request body streaming unsupported")
    if async_proxy_request_body_streaming_required(request, max_buffered_request_body_bytes):
        return async_proxy_target_error(413, "Proxy request body streaming required")
    async_proxy_resolve_upstream(upstreams, location.proxy_pass, request_index)

fn async_proxy_plan_with_peers(location: LocationConfig, request: HttpRequestData,
                               upstreams: [UpstreamConfig],
                               peers: [AsyncProxyUpstreamPeer],
                               request_index: i64, now: i64) -> AsyncProxyTarget:
    async_proxy_plan_with_peers_and_request_limit(
        location,
        request,
        upstreams,
        peers,
        request_index,
        now,
        ASYNC_PROXY_DEFAULT_MAX_BUFFERED_REQUEST_BODY_BYTES
    )

fn async_proxy_plan_with_peers_and_request_limit(location: LocationConfig, request: HttpRequestData,
                                                 upstreams: [UpstreamConfig],
                                                 peers: [AsyncProxyUpstreamPeer],
                                                 request_index: i64, now: i64,
                                                 max_buffered_request_body_bytes: i64) -> AsyncProxyTarget:
    if not async_proxy_route_enabled(location):
        return async_proxy_target_error(500, "Route is not a proxy route")
    if not async_proxy_path_is_safe(request.path):
        return async_proxy_target_error(400, "Unsafe proxy request path")
    if not async_proxy_method_supported(request.method):
        return async_proxy_target_error(405, "Proxy method not allowed")
    if async_proxy_request_upgrade(request):
        return async_proxy_target_error(501, "Proxy upgrade tunneling unsupported")
    if async_proxy_request_content_length_invalid(request):
        return async_proxy_target_error(400, "Proxy request content length invalid")
    if async_proxy_request_content_length_conflict(request):
        return async_proxy_target_error(400, "Proxy request content length conflict")
    if async_proxy_request_framing_conflict(request):
        return async_proxy_target_error(400, "Proxy request framing conflict")
    if async_proxy_request_unsupported_transfer_encoding(request):
        return async_proxy_target_error(501, "Proxy transfer encoding unsupported")
    if async_proxy_request_transfer_chunked(request):
        return async_proxy_target_error(501, "Proxy chunked request body streaming unsupported")
    if async_proxy_request_body_streaming_required(request, max_buffered_request_body_bytes):
        return async_proxy_target_error(413, "Proxy request body streaming required")
    async_proxy_resolve_upstream_with_peers(upstreams, location.proxy_pass, peers, request_index, now)

fn async_proxy_plan_with_peers_for_request_stream(location: LocationConfig, request: HttpRequestData,
                                                  upstreams: [UpstreamConfig],
                                                  peers: [AsyncProxyUpstreamPeer],
                                                  request_index: i64, now: i64) -> AsyncProxyTarget:
    if not async_proxy_route_enabled(location):
        return async_proxy_target_error(500, "Route is not a proxy route")
    if not async_proxy_path_is_safe(request.path):
        return async_proxy_target_error(400, "Unsafe proxy request path")
    if not async_proxy_method_supported(request.method):
        return async_proxy_target_error(405, "Proxy method not allowed")
    if async_proxy_request_upgrade(request):
        return async_proxy_target_error(501, "Proxy upgrade tunneling unsupported")
    if async_proxy_request_content_length_invalid(request):
        return async_proxy_target_error(400, "Proxy request content length invalid")
    if async_proxy_request_content_length_conflict(request):
        return async_proxy_target_error(400, "Proxy request content length conflict")
    if async_proxy_request_framing_conflict(request):
        return async_proxy_target_error(400, "Proxy request framing conflict")
    if async_proxy_request_unsupported_transfer_encoding(request):
        return async_proxy_target_error(501, "Proxy transfer encoding unsupported")
    async_proxy_resolve_upstream_with_peers(upstreams, location.proxy_pass, peers, request_index, now)

fn async_proxy_tunnel_plan(location: LocationConfig, request: HttpRequestData,
                           upstreams: [UpstreamConfig], request_index: i64) -> AsyncProxyTunnelPlan:
    if not async_proxy_route_enabled(location):
        return async_proxy_tunnel_plan_error(500, "Route is not a proxy route")
    if not async_proxy_path_is_safe(request.path):
        return async_proxy_tunnel_plan_error(400, "Unsafe proxy request path")
    val kind = async_proxy_tunnel_kind(request)
    if kind == "":
        return async_proxy_tunnel_plan_error(400, "Proxy tunnel request required")
    val resolved = async_proxy_resolve_upstream(upstreams, location.proxy_pass, request_index)
    if not resolved.ok:
        return async_proxy_tunnel_plan_error(resolved.status, resolved.reason)
    async_proxy_tunnel_plan_ok(resolved.upstream_addr, kind)

fn async_proxy_tunnel_plan_with_peers(location: LocationConfig, request: HttpRequestData,
                                      upstreams: [UpstreamConfig],
                                      peers: [AsyncProxyUpstreamPeer],
                                      request_index: i64, now: i64) -> AsyncProxyTunnelPlan:
    if not async_proxy_route_enabled(location):
        return async_proxy_tunnel_plan_error(500, "Route is not a proxy route")
    if not async_proxy_path_is_safe(request.path):
        return async_proxy_tunnel_plan_error(400, "Unsafe proxy request path")
    val kind = async_proxy_tunnel_kind(request)
    if kind == "":
        return async_proxy_tunnel_plan_error(400, "Proxy tunnel request required")
    val resolved = async_proxy_resolve_upstream_with_peers(upstreams, location.proxy_pass, peers, request_index, now)
    if not resolved.ok:
        return async_proxy_tunnel_plan_error(resolved.status, resolved.reason)
    async_proxy_tunnel_plan_ok(resolved.upstream_addr, kind)

fn async_proxy_serialize_request(req: HttpRequestData, upstream_addr: text) -> text:
    val target = async_proxy_target_path(req)
    var wire = "{req.method} {target} HTTP/1.1\r\n"
    wire = "{wire}Host: {upstream_addr}\r\n"
    wire = "{wire}Connection: keep-alive\r\n"
    if req.body != "":
        wire = "{wire}Content-Length: {req.body.len()}\r\n"
    if req.peer_addr != "":
        wire = "{wire}X-Forwarded-For: {req.peer_addr}\r\n"
    wire = "{wire}X-Forwarded-Proto: http\r\n"
    var i = 0
    while i < req.headers.len():
        val h = req.headers[i]
        if not async_proxy_drop_header(h.0):
            wire = "{wire}{h.0}: {h.1}\r\n"
        i = i + 1
    wire = "{wire}\r\n"
    if req.body != "":
        wire = "{wire}{req.body}"
    wire

fn async_proxy_serialize_request_headers(req: HttpRequestData, upstream_addr: text,
                                         body_length: i64, chunked: bool) -> text:
    val target = async_proxy_target_path(req)
    var wire = "{req.method} {target} HTTP/1.1\r\n"
    wire = "{wire}Host: {upstream_addr}\r\n"
    wire = "{wire}Connection: keep-alive\r\n"
    if chunked:
        wire = "{wire}Transfer-Encoding: chunked\r\n"
    else:
        wire = "{wire}Content-Length: {body_length}\r\n"
    if req.peer_addr != "":
        wire = "{wire}X-Forwarded-For: {req.peer_addr}\r\n"
    wire = "{wire}X-Forwarded-Proto: http\r\n"
    var i = 0
    while i < req.headers.len():
        val h = req.headers[i]
        if not async_proxy_drop_header(h.0):
            wire = "{wire}{h.0}: {h.1}\r\n"
        i = i + 1
    "{wire}\r\n"

fn async_proxy_request_body_stream_begin(req: HttpRequestData, upstream_addr: text,
                                         max_pending_upstream_bytes: i64) -> AsyncProxyRequestBodyStream:
    val chunked = async_proxy_request_transfer_chunked(req)
    val body_length = if chunked: -1 else: async_proxy_request_content_length(req)
    val header_wire = async_proxy_serialize_request_headers(req, upstream_addr, body_length, chunked)
    async_proxy_request_stream(header_wire, body_length, chunked, max_pending_upstream_bytes)

fn async_proxy_dechunked_request_body_stream_begin(req: HttpRequestData, upstream_addr: text,
                                                   decoded_body_bytes: i64,
                                                   max_pending_upstream_bytes: i64) -> AsyncProxyRequestBodyStream:
    val header_wire = async_proxy_serialize_request_headers(req, upstream_addr, decoded_body_bytes, false)
    async_proxy_request_stream(header_wire, -1, true, max_pending_upstream_bytes)

fn async_proxy_serialize_tunnel_request(req: HttpRequestData, upstream_addr: text) -> text:
    val target = async_proxy_target_path(req)
    var wire = "{req.method} {target} HTTP/1.1\r\n"
    wire = "{wire}Host: {upstream_addr}\r\n"
    if async_proxy_request_upgrade(req):
        wire = "{wire}Connection: Upgrade\r\n"
    var i = 0
    while i < req.headers.len():
        val h = req.headers[i]
        if not async_proxy_drop_tunnel_header(h.0):
            wire = "{wire}{h.0}: {h.1}\r\n"
        i = i + 1
    wire = "{wire}\r\n"
    wire

fn async_proxy_response_headers_complete(buffer: text) -> bool:
    buffer.index_of("\r\n\r\n") >= 0

fn async_proxy_header_name(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    line.slice(0, colon).trim()

fn async_proxy_header_value(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    line.slice(colon + 1, line.len()).trim()

fn async_proxy_content_length(header_block: text) -> i64:
    val lines = header_block.split("\r\n")
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(async_proxy_header_value(line))
            if parsed >= 0:
                return parsed
            return -1
        i = i + 1
    -1

fn async_proxy_response_content_length_invalid(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(async_proxy_header_value(line))
            if parsed < 0:
                return true
        i = i + 1
    false

fn async_proxy_response_content_length_conflict(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    var seen = false
    var expected = -1
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "content-length":
            val parsed = async_proxy_parse_nonnegative_i64(async_proxy_header_value(line))
            if parsed < 0:
                return true
            if seen and parsed != expected:
                return true
            seen = true
            expected = parsed
        i = i + 1
    false

fn async_proxy_transfer_chunked(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "transfer-encoding":
            if async_proxy_header_value_has_token(async_proxy_header_value(line), "chunked"):
                return true
        i = i + 1
    false

fn async_proxy_response_has_header(header_block: text, name: text) -> bool:
    val wanted = name.to_lower()
    val lines = header_block.split("\r\n")
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == wanted:
            return true
        i = i + 1
    false

fn async_proxy_response_has_transfer_encoding(header_block: text) -> bool:
    async_proxy_response_has_header(header_block, "transfer-encoding")

fn async_proxy_response_framing_conflict(header_block: text) -> bool:
    async_proxy_response_has_transfer_encoding(header_block) and async_proxy_response_has_header(header_block, "content-length")

fn async_proxy_response_unsupported_transfer_encoding(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "transfer-encoding":
            if not async_proxy_header_value_has_only_token(async_proxy_header_value(line), "chunked"):
                return true
        i = i + 1
    false

fn async_proxy_hex_value(ch: text) -> i64:
    val lower = ch.to_lower()
    if lower == "0":
        return 0
    if lower == "1":
        return 1
    if lower == "2":
        return 2
    if lower == "3":
        return 3
    if lower == "4":
        return 4
    if lower == "5":
        return 5
    if lower == "6":
        return 6
    if lower == "7":
        return 7
    if lower == "8":
        return 8
    if lower == "9":
        return 9
    if lower == "a":
        return 10
    if lower == "b":
        return 11
    if lower == "c":
        return 12
    if lower == "d":
        return 13
    if lower == "e":
        return 14
    if lower == "f":
        return 15
    -1

fn async_proxy_parse_chunk_size(line: text) -> i64:
    val size_text = line.split(";")[0].trim()
    if size_text == "":
        return -1
    var out = 0
    var i = 0
    while i < size_text.len():
        val v = async_proxy_hex_value(size_text.slice(i, i + 1))
        if v < 0:
            return -1
        out = (out * 16) + v
        i = i + 1
    out

fn async_proxy_chunked_body_complete(body: text) -> bool:
    if body == "0\r\n\r\n":
        return true
    body.contains("\r\n0\r\n\r\n")

fn async_proxy_dechunk_body(body: text) -> text?:
    var pos = 0
    var out = ""
    while pos < body.len():
        val line_end_rel = body.slice(pos, body.len()).index_of("\r\n")
        if line_end_rel < 0:
            return nil
        val line_end = pos + line_end_rel
        val size = async_proxy_parse_chunk_size(body.slice(pos, line_end))
        if size < 0:
            return nil
        pos = line_end + 2
        if size == 0:
            return out
        if pos + size > body.len():
            return nil
        out = "{out}{body.slice(pos, pos + size)}"
        pos = pos + size
        if pos + 2 > body.len():
            return nil
        if body.slice(pos, pos + 2) != "\r\n":
            return nil
        pos = pos + 2
    nil

fn async_proxy_decode_available_chunks(body: text) -> AsyncProxyChunkDecode:
    var pos = 0
    var out = ""
    while pos < body.len():
        val line_end_rel = body.slice(pos, body.len()).index_of("\r\n")
        if line_end_rel < 0:
            return AsyncProxyChunkDecode(decoded: out, remaining: body.slice(pos, body.len()), complete: false, valid: true)
        val line_end = pos + line_end_rel
        val size = async_proxy_parse_chunk_size(body.slice(pos, line_end))
        if size < 0:
            return AsyncProxyChunkDecode(decoded: out, remaining: "", complete: false, valid: false)
        val data_start = line_end + 2
        if size == 0:
            if data_start + 2 > body.len():
                return AsyncProxyChunkDecode(decoded: out, remaining: body.slice(pos, body.len()), complete: false, valid: true)
            if body.slice(data_start, data_start + 2) != "\r\n":
                return AsyncProxyChunkDecode(decoded: out, remaining: "", complete: false, valid: false)
            return AsyncProxyChunkDecode(decoded: out, remaining: body.slice(data_start + 2, body.len()), complete: true, valid: true)
        val data_end = data_start + size
        val chunk_end = data_end + 2
        if chunk_end > body.len():
            return AsyncProxyChunkDecode(decoded: out, remaining: body.slice(pos, body.len()), complete: false, valid: true)
        if body.slice(data_end, chunk_end) != "\r\n":
            return AsyncProxyChunkDecode(decoded: out, remaining: "", complete: false, valid: false)
        out = "{out}{body.slice(data_start, data_end)}"
        pos = chunk_end
    AsyncProxyChunkDecode(decoded: out, remaining: "", complete: false, valid: true)

fn async_proxy_should_recv_client_body(stream: AsyncProxyRequestBodyStream) -> bool:
    if not stream.valid or stream.complete:
        return false
    if stream.pending_upstream_data == "":
        return true
    if stream.max_pending_upstream_bytes <= 0:
        return true
    stream.pending_upstream_data.len() < (stream.max_pending_upstream_bytes / 2)

fn async_proxy_request_pending_over_budget(stream: AsyncProxyRequestBodyStream) -> bool:
    if stream.max_pending_upstream_bytes <= 0:
        return false
    if stream.pending_upstream_data.len() > stream.max_pending_upstream_bytes:
        return true
    stream.chunked_body_buffer.len() > stream.max_pending_upstream_bytes

fn async_proxy_request_stream_receive_fixed(stream: AsyncProxyRequestBodyStream,
                                            data: text) -> AsyncProxyRequestBodyStream:
    var next = stream
    if not next.valid or next.complete:
        return next
    if next.chunked:
        next.valid = false
        next.error = "fixed-body-received-for-chunked-stream"
        return next
    next.bytes_received = next.bytes_received + data.len()
    if next.expected_body_bytes >= 0 and next.bytes_received > next.expected_body_bytes:
        next.valid = false
        next.error = "fixed-request-body-too-large"
        return next
    next.pending_upstream_data = "{next.pending_upstream_data}{data}"
    if next.expected_body_bytes >= 0 and next.bytes_received >= next.expected_body_bytes:
        next.complete = true
    next

fn async_proxy_request_stream_receive_chunked(stream: AsyncProxyRequestBodyStream,
                                              data: text) -> AsyncProxyRequestBodyStream:
    var next = stream
    if not next.valid or next.complete:
        return next
    if not next.chunked:
        next.valid = false
        next.error = "chunked-body-received-for-fixed-stream"
        return next
    next.chunked_body_buffer = "{next.chunked_body_buffer}{data}"
    val decoded = async_proxy_decode_available_chunks(next.chunked_body_buffer)
    if not decoded.valid:
        next.valid = false
        next.error = "chunked-request-body-malformed"
        return next
    next.chunked_body_buffer = decoded.remaining
    if decoded.decoded != "":
        next.bytes_received = next.bytes_received + decoded.decoded.len()
        next.pending_upstream_data = "{next.pending_upstream_data}{decoded.decoded}"
    if decoded.complete:
        next.complete = true
    next

fn async_proxy_request_stream_receive_chunked_framed(stream: AsyncProxyRequestBodyStream,
                                                     data: text) -> AsyncProxyRequestBodyStream:
    var next = stream
    if not next.valid or next.complete:
        return next
    if not next.chunked:
        next.valid = false
        next.error = "chunked-body-received-for-fixed-stream"
        return next
    next.chunked_body_buffer = "{next.chunked_body_buffer}{data}"
    val buffered = next.chunked_body_buffer
    val decoded = async_proxy_decode_available_chunks(buffered)
    if not decoded.valid:
        next.valid = false
        next.error = "chunked-request-body-malformed"
        return next
    if decoded.complete and decoded.remaining != "":
        next.valid = false
        next.error = "chunked-request-body-trailing-bytes"
        return next
    val consumed_len = buffered.len() - decoded.remaining.len()
    if consumed_len > 0:
        next.pending_upstream_data = "{next.pending_upstream_data}{buffered.slice(0, consumed_len)}"
    next.chunked_body_buffer = decoded.remaining
    if decoded.decoded != "":
        next.bytes_received = next.bytes_received + decoded.decoded.len()
    if decoded.complete:
        next.complete = true
    next

fn async_proxy_request_stream_receive_chunked_passthrough(stream: AsyncProxyRequestBodyStream,
                                                          data: text) -> AsyncProxyRequestBodyStream:
    var next = stream
    if not next.valid or next.complete:
        return next
    if not next.chunked:
        next.valid = false
        next.error = "chunked-body-received-for-fixed-stream"
        return next
    next.pending_upstream_data = "{next.pending_upstream_data}{data}"
    next.bytes_received = next.bytes_received + data.len()
    val combined = "{next.chunked_body_buffer}{data}"
    val decoded = async_proxy_decode_available_chunks(combined)
    if not decoded.valid:
        next.valid = false
        next.error = "chunked-request-body-malformed"
        return next
    if decoded.complete and decoded.remaining != "":
        next.valid = false
        next.error = "chunked-request-body-trailing-bytes"
        return next
    if decoded.complete:
        next.complete = true
        next.chunked_body_buffer = ""
    else:
        next.chunked_body_buffer = decoded.remaining
    next

fn async_proxy_request_stream_mark_upstream_sent(stream: AsyncProxyRequestBodyStream,
                                                 sent_bytes: i64) -> AsyncProxyRequestBodyStream:
    var next = stream
    if sent_bytes <= 0:
        return next
    if sent_bytes >= next.pending_upstream_data.len():
        next.pending_upstream_data = ""
    else:
        next.pending_upstream_data = next.pending_upstream_data.slice(sent_bytes, next.pending_upstream_data.len())
    next

fn async_proxy_client_chunk_wire(conn: AsyncProxyConnection, decoded: text) -> text:
    if conn.body_bytes_forwarded == 0:
        return "{conn.response_client_header_wire}{decoded}"
    decoded

fn async_proxy_pending_client_over_budget(conn: AsyncProxyConnection) -> bool:
    conn.max_pending_client_bytes > 0 and conn.pending_client_data.len() > conn.max_pending_client_bytes

fn async_proxy_append_pending_client_data(conn: AsyncProxyConnection, data: text) -> AsyncProxyConnection:
    var next = conn
    if data == "":
        return next
    if next.pending_client_data == "":
        next.pending_client_data = data
    else:
        next.pending_client_data = "{next.pending_client_data}{data}"
    next

fn async_proxy_should_recv_upstream(conn: AsyncProxyConnection) -> bool:
    conn.response_header_valid and conn.pending_client_data == "" and not conn.response_complete

fn async_proxy_upstream_recv_budget(conn: AsyncProxyConnection, requested: i64) -> i64:
    if requested <= 0:
        return 0
    if not async_proxy_should_recv_upstream(conn):
        return 0
    if conn.max_pending_client_bytes <= 0:
        return requested
    val remaining = conn.max_pending_client_bytes - conn.pending_client_data.len()
    if remaining <= 0:
        return 0
    if remaining < requested:
        return remaining
    requested

fn async_proxy_response_allows_reuse(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    if lines.len() == 0:
        return false
    if not lines[0].trim().starts_with("HTTP/1.1"):
        return false
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if async_proxy_header_name(line).to_lower() == "connection":
            val value = async_proxy_header_value(line).to_lower()
            if async_proxy_header_value_has_token(value, "close"):
                return false
        i = i + 1
    true

fn async_proxy_status_line_valid(line: text) -> bool:
    if line.len() < 12:
        return false
    if not line.starts_with("HTTP/1."):
        return false
    if line.slice(8, 9) != " ":
        return false
    val first = line.slice(9, 10)
    val second = line.slice(10, 11)
    val third = line.slice(11, 12)
    if not (first == "1" or first == "2" or first == "3" or first == "4" or first == "5"):
        return false
    if not async_proxy_status_digit(second):
        return false
    if not async_proxy_status_digit(third):
        return false
    true

fn async_proxy_status_digit(ch: text) -> bool:
    if ch == "0":
        return true
    if ch == "1":
        return true
    if ch == "2":
        return true
    if ch == "3":
        return true
    if ch == "4":
        return true
    if ch == "5":
        return true
    if ch == "6":
        return true
    if ch == "7":
        return true
    if ch == "8":
        return true
    if ch == "9":
        return true
    false

fn async_proxy_status_code(line: text) -> i64:
    if not async_proxy_status_line_valid(line):
        return -1
    val trimmed: text = "{line.trim()}"
    val parts = trimmed.split(" ")
    parts[1].parse_int() ?? -1

fn async_proxy_response_has_no_body(header_block: text) -> bool:
    val lines = header_block.split("\r\n")
    if lines.len() == 0:
        return false
    val code = async_proxy_status_code(lines[0])
    if code >= 100 and code < 200:
        return true
    if code == 204:
        return true
    if code == 304:
        return true
    false

fn async_proxy_validate_response_headers(header_block: text, max_header_line: i64,
                                         max_headers: i64) -> AsyncProxyTarget:
    val lines = header_block.split("\r\n")
    if lines.len() == 0:
        return async_proxy_target_error(502, "Proxy upstream response missing status")
    if max_header_line <= 0:
        return async_proxy_target_error(502, "Proxy upstream header line budget invalid")
    if max_headers <= 0:
        return async_proxy_target_error(502, "Proxy upstream header count budget invalid")
    if lines[0].trim() == "":
        return async_proxy_target_error(502, "Proxy upstream response missing status")
    if lines[0].len() > max_header_line:
        return async_proxy_target_error(502, "Proxy upstream status line too large")
    if not async_proxy_status_line_valid(lines[0]):
        return async_proxy_target_error(502, "Proxy upstream response status invalid")

    var count = 0
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if line != "":
            count = count + 1
            if count > max_headers:
                return async_proxy_target_error(502, "Proxy upstream response header count exceeded")
            if line.len() > max_header_line:
                return async_proxy_target_error(502, "Proxy upstream response header line too large")
            if async_proxy_header_name(line) == "":
                return async_proxy_target_error(502, "Proxy upstream response header malformed")
        i = i + 1
    if async_proxy_response_content_length_invalid(header_block):
        return async_proxy_target_error(502, "Proxy upstream response content length invalid")
    if async_proxy_response_content_length_conflict(header_block):
        return async_proxy_target_error(502, "Proxy upstream response content length conflict")
    if async_proxy_response_framing_conflict(header_block):
        return async_proxy_target_error(502, "Proxy upstream response framing conflict")
    if async_proxy_response_unsupported_transfer_encoding(header_block):
        return async_proxy_target_error(502, "Proxy upstream transfer encoding unsupported")
    async_proxy_target_ok("")

fn async_proxy_filter_response_headers(header_block: text) -> text:
    val lines = header_block.split("\r\n")
    if lines.len() == 0:
        return "HTTP/1.1 502 Bad Gateway\r\nConnection: close\r\n\r\n"
    var wire = "{lines[0]}\r\n"
    val chunked = async_proxy_transfer_chunked(header_block)
    var i = 1
    while i < lines.len():
        val line = lines[i].trim()
        if line != "":
            val name = async_proxy_header_name(line)
            if name != "" and not async_proxy_drop_response_header(name):
                if chunked and name.to_lower() == "content-length":
                    i = i + 1
                    continue
                wire = "{wire}{line}\r\n"
        i = i + 1
    wire = "{wire}Connection: close\r\n"
    "{wire}\r\n"

fn async_proxy_prepare_client_chunk(conn: AsyncProxyConnection, upstream_data: text, now: i64) -> AsyncProxyConnection:
    var next = conn
    next.last_activity_ms = now
    next.bytes_from_upstream = next.bytes_from_upstream + upstream_data.len()
    if next.response_headers_done:
        if next.response_chunked:
            next.chunked_body_buffer = "{next.chunked_body_buffer}{upstream_data}"
            if next.chunked_body_buffer.len() > next.max_response_bytes:
                next.response_header_valid = false
                next.response_header_error = "Proxy upstream chunked response buffer too large"
                next.pending_client_data = ""
                return next
            val decoded = async_proxy_decode_available_chunks(next.chunked_body_buffer)
            if not decoded.valid:
                next.response_header_valid = false
                next.response_header_error = "Proxy upstream chunked response malformed"
                next.pending_client_data = ""
                return next
            next.chunked_body_buffer = decoded.remaining
            if next.body_bytes_forwarded + decoded.decoded.len() > next.max_response_bytes:
                next.response_header_valid = false
                next.response_header_error = "Proxy upstream chunked response body too large"
                next.pending_client_data = ""
                return next
            if decoded.decoded != "":
                next = async_proxy_append_pending_client_data(next, async_proxy_client_chunk_wire(next, decoded.decoded))
                next.body_bytes_forwarded = next.body_bytes_forwarded + decoded.decoded.len()
            if decoded.complete:
                next.response_complete = true
            return next
        next = async_proxy_append_pending_client_data(next, upstream_data)
        if next.expected_body_bytes >= 0:
            next.body_bytes_forwarded = next.body_bytes_forwarded + upstream_data.len()
            if next.body_bytes_forwarded >= next.expected_body_bytes:
                next.response_complete = true
        return next

    next.response_header_buffer = "{next.response_header_buffer}{upstream_data}"
    if not async_proxy_response_headers_complete(next.response_header_buffer):
        next.pending_client_data = ""
        return next

    val split_at = next.response_header_buffer.index_of("\r\n\r\n")
    val head = next.response_header_buffer.slice(0, split_at)
    val body_start = split_at + 4
    val body = next.response_header_buffer.slice(body_start, next.response_header_buffer.len())
    val head_text: text = "{head}"
    val body_text: text = "{body}"
    val validation = async_proxy_validate_response_headers(
        head_text,
        next.max_response_header_line,
        next.max_response_headers
    )
    if not validation.ok:
        next.response_header_valid = false
        next.response_header_error = validation.reason
        next.pending_client_data = ""
        return next
    val no_body_response = async_proxy_response_has_no_body(head_text)
    next.response_chunked = if no_body_response: false else: async_proxy_transfer_chunked(head_text)
    next.expected_body_bytes = if no_body_response: 0 else: if next.response_chunked: -1 else: async_proxy_content_length(head_text)
    next.upstream_reusable = async_proxy_response_allows_reuse(head_text)
    next.response_client_header_wire = async_proxy_filter_response_headers(head_text)
    if not next.response_chunked and next.expected_body_bytes > next.max_response_bytes:
        next.response_header_valid = false
        next.response_header_error = "Proxy upstream response content length too large"
        next.pending_client_data = ""
        return next
    if no_body_response:
        next.body_bytes_forwarded = 0
        next.response_complete = true
        next = async_proxy_append_pending_client_data(next, next.response_client_header_wire)
        if body_text != "":
            next.upstream_reusable = false
    elif next.response_chunked:
        next.chunked_body_buffer = body_text
        if next.chunked_body_buffer.len() > next.max_response_bytes:
            next.response_header_valid = false
            next.response_header_error = "Proxy upstream chunked response buffer too large"
            next.pending_client_data = ""
            return next
        val decoded = async_proxy_decode_available_chunks(next.chunked_body_buffer)
        if not decoded.valid:
            next.response_header_valid = false
            next.response_header_error = "Proxy upstream chunked response malformed"
            next.pending_client_data = ""
            return next
        next.chunked_body_buffer = decoded.remaining
        if decoded.decoded.len() > next.max_response_bytes:
            next.response_header_valid = false
            next.response_header_error = "Proxy upstream chunked response body too large"
            next.pending_client_data = ""
            return next
        next = async_proxy_append_pending_client_data(next, async_proxy_client_chunk_wire(next, decoded.decoded))
        next.body_bytes_forwarded = decoded.decoded.len()
        if decoded.complete:
            next.response_complete = true
    else:
        next.body_bytes_forwarded = body_text.len()
        if next.expected_body_bytes >= 0 and next.body_bytes_forwarded >= next.expected_body_bytes:
            next.response_complete = true
        next = async_proxy_append_pending_client_data(next, "{next.response_client_header_wire}{body_text}")
    next.response_header_buffer = ""
    next.response_headers_done = true
    next

fn async_proxy_response_complete(conn: AsyncProxyConnection) -> bool:
    conn.response_complete

fn async_proxy_response_reusable(conn: AsyncProxyConnection) -> bool:
    conn.response_complete and conn.upstream_reusable

fn async_proxy_connect_timed_out(conn: AsyncProxyConnection, now: i64) -> bool:
    conn.upstream_fd < 0 and now - conn.started_at_ms > conn.connect_timeout_ms

fn async_proxy_idle_timed_out(conn: AsyncProxyConnection, now: i64) -> bool:
    now - conn.last_activity_ms > conn.idle_timeout_ms

fn async_proxy_timed_out(conn: AsyncProxyConnection, now: i64) -> bool:
    async_proxy_connect_timed_out(conn, now) or async_proxy_idle_timed_out(conn, now)
