"""
HTTP Capability Router

Routes static-file responses through backend capability gates.
Uses sendfile when the backend supports it; falls back to portable async
read-plus-send otherwise. Records backend name and acceleration tier on startup.

Feature IDs: FR-NET-0003
Plan: doc/03_plan/agent_tasks/net_acceleration_remaining_2026-04-21.md
"""

# Backend capability flags relevant to HTTP static-file routing.
struct HttpBackendCaps:
    """Subset of backend capabilities used by the HTTP server router."""
    backend_name: text
    supports_sendfile: bool
    supports_zero_copy: bool

fn http_backend_caps_portable(name: text) -> HttpBackendCaps:
    """Portable backend: no kernel or hardware acceleration."""
    HttpBackendCaps(backend_name: name, supports_sendfile: false, supports_zero_copy: false)

fn http_backend_caps_sendfile(name: text) -> HttpBackendCaps:
    """Backend with sendfile support (Linux sendfile(2) or equivalent)."""
    HttpBackendCaps(backend_name: name, supports_sendfile: true, supports_zero_copy: false)

fn http_backend_caps_zero_copy(name: text) -> HttpBackendCaps:
    """Backend with zero-copy DMA transfer support."""
    HttpBackendCaps(backend_name: name, supports_sendfile: true, supports_zero_copy: true)

# Connection actions the worker emits per request.
struct ConnectionAction:
    """Action the worker takes for a single HTTP response."""
    action_type: text
    use_sendfile: bool
    use_portable_read: bool

fn connection_action_send_file_sendfile() -> ConnectionAction:
    """Use IoDriver.submit_sendfile for the response body."""
    ConnectionAction(action_type: "SendFile", use_sendfile: true, use_portable_read: false)

fn connection_action_send_file_portable() -> ConnectionAction:
    """Use async read + write for the response body."""
    ConnectionAction(action_type: "SendFile", use_sendfile: false, use_portable_read: true)

fn connection_action_send_body() -> ConnectionAction:
    """Response body is in-memory; no file I/O needed."""
    ConnectionAction(action_type: "Body", use_sendfile: false, use_portable_read: false)

fn http_route_static_file(caps: HttpBackendCaps, has_file_body: bool) -> ConnectionAction:
    """
    Choose the ConnectionAction for a static-file response.

    - has_file_body=false → Body action (body already in memory)
    - supports_sendfile=true → sendfile path
    - otherwise → portable async read
    """
    if has_file_body == false:
        return connection_action_send_body()
    if caps.supports_sendfile:
        return connection_action_send_file_sendfile()
    connection_action_send_file_portable()

# Worker startup diagnostics.
struct WorkerStartupInfo:
    """Recorded on worker launch for diagnostics and access logs."""
    worker_id: i64
    backend_name: text
    acceleration_tier: text

fn http_acceleration_tier(caps: HttpBackendCaps) -> text:
    """Return the highest static-file acceleration tier for this backend."""
    if caps.supports_zero_copy:
        return "zero-copy"
    if caps.supports_sendfile:
        return "sendfile"
    "portable"

fn worker_startup_info(worker_id: i64, caps: HttpBackendCaps) -> WorkerStartupInfo:
    """Build startup record for a worker given its backend capabilities."""
    WorkerStartupInfo(
        worker_id: worker_id,
        backend_name: caps.backend_name,
        acceleration_tier: http_acceleration_tier(caps)
    )

fn worker_startup_summary(info: WorkerStartupInfo) -> text:
    """Compact one-line diagnostic string."""
    "worker={info.worker_id} backend={info.backend_name} tier={info.acceleration_tier}"
