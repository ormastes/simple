# HTTP/2 Stream — Per-stream state for async H2 connections
#
# Tracks a single H2 stream through its lifecycle. HPACK decoding is
# deferred (W16+) — header_block payloads stay opaque [u8]. Without
# HPACK, we cannot extract :method/:path/:status pseudo-headers, so
# request/response assembly is stubbed.
#
# Scope:
#   - Stream state machine (idle → open → half-closed → closed)
#   - Accumulate HEADERS + DATA frame payloads per stream
#   - Track per-stream flow-control window
#
# Out of scope (W16+ / HPACK milestone):
#   - HPACK decode of header_block → HttpRequestData
#   - HPACK encode of HttpResponseData → header_block
#   - CONTINUATION frame assembly (requires header-block buffer merging)
#   - Server push (PUSH_PROMISE)

use std.http.h2.h2_frame.{
    H2_FLAG_END_STREAM, H2_FLAG_END_HEADERS,
    H2_SETTINGS_INITIAL_WINDOW_SIZE
}

# ============================================================================
# Stream state
# ============================================================================

enum H2StreamState:
    """RFC 9113 §5.1 stream lifecycle states."""
    Idle
    Open
    HalfClosedRemote
    HalfClosedLocal
    Closed

# ============================================================================
# H2Stream
# ============================================================================

class H2Stream:
    """Per-stream state within an H2 connection.

    Accumulates received header blocks and data payloads.
    State transitions follow RFC 9113 section 5.1.
    """
    stream_id: i64
    state: H2StreamState
    recv_header_blocks: [[u8]]
    recv_data: [[u8]]
    recv_end_headers: bool
    recv_end_stream: bool
    send_window: i64
    recv_window: i64

    static fn new(stream_id: i64, initial_window: i64) -> H2Stream:
        """Create a new stream in Idle state.

        Args:
            stream_id: Stream identifier (odd = client-initiated)
            initial_window: SETTINGS_INITIAL_WINDOW_SIZE value
        """
        H2Stream(
            stream_id: stream_id,
            state: H2StreamState.Idle,
            recv_header_blocks: [],
            recv_data: [],
            recv_end_headers: false,
            recv_end_stream: false,
            send_window: initial_window,
            recv_window: 65535
        )

    me on_headers(header_block: [u8], flags: i64):
        """Process a received HEADERS frame payload.

        Transitions Idle → Open (or HalfClosedRemote if END_STREAM).
        Accumulates header_block for future HPACK decode (W16+).

        Args:
            header_block: Opaque HPACK-encoded header block fragment
            flags: Frame flags (END_STREAM, END_HEADERS)
        """
        self.recv_header_blocks.push(header_block)
        if (flags & H2_FLAG_END_HEADERS) != 0:
            self.recv_end_headers = true
        if (flags & H2_FLAG_END_STREAM) != 0:
            self.recv_end_stream = true

        match self.state:
            H2StreamState.Idle:
                if self.recv_end_stream:
                    self.state = H2StreamState.HalfClosedRemote
                else:
                    self.state = H2StreamState.Open
            _:
                pass_dn

    me on_data(data: [u8], flags: i64):
        """Process a received DATA frame payload.

        Accumulates body data. Sets END_STREAM flag when present.

        Args:
            data: Application data bytes
            flags: Frame flags (END_STREAM)
        """
        self.recv_data.push(data)
        if (flags & H2_FLAG_END_STREAM) != 0:
            self.recv_end_stream = true
            match self.state:
                H2StreamState.Open:
                    self.state = H2StreamState.HalfClosedRemote
                _:
                    pass_dn

    fn is_request_complete() -> bool:
        """True when we have received END_HEADERS and END_STREAM."""
        self.recv_end_headers and self.recv_end_stream

    me close():
        """Transition stream to Closed."""
        self.state = H2StreamState.Closed

    me on_local_end_stream():
        """Mark local side as finished sending."""
        match self.state:
            H2StreamState.Open:
                self.state = H2StreamState.HalfClosedLocal
            H2StreamState.HalfClosedRemote:
                self.state = H2StreamState.Closed
            _:
                pass_dn

    me adjust_recv_window(increment: i64):
        """Credit the receive window by increment bytes."""
        self.recv_window = self.recv_window + increment

    me adjust_send_window(increment: i64):
        """Credit the send window by increment bytes."""
        self.send_window = self.send_window + increment
