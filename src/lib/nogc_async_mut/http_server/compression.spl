# HTTP server response-body compression dispatcher.
#
# Maps a negotiated Content-Encoding name (from `negotiate_encoding` in
# `lib/nogc_sync_mut/http/accept_encoding.spl`) to a concrete encoder call,
# returning the compressed bytes.
#
# Wired codecs:
#
# - `"br"` (brotli) — highest compression ratio; preferred when client supports it.
# - `"gzip"` — widest client support.
# - `"deflate"` — fallback deflate.
# - `"zstd"` and `"lz4"` — fast codecs for internal/modern clients.
#
# MIME-type filtering:
#
# Already-compressed formats (images, video, audio, zip, pdf, fonts) are
# skipped. Only text/*, application/json, application/javascript,
# application/xml, and svg types are eligible.
#
# - `"identity"` and `""` — no compression; callers should detect these
#   before invoking this dispatcher.

use std.common.compress.types.{
    CompressionCodec,
}
use std.common.compress.utilities.{
    default_compression_options,
}
use std.common.compress.zstd.{zstd_compress_frame}
use std.common.compress.lz4.{lz4_compress_frame}
use std.common.compress.gzip.{gzip_compress}
use std.common.compress.brotli.{brotli_compress}
use std.common.compress.deflate.{deflate_compress_sync_flush}
use std.http_server.types.{HttpRequestData, HttpResponseData, ServerConfig, Phase, PhaseResult}
use std.nogc_async_mut.http.accept_encoding.{negotiate_encoding}

# Minimum body size below which compression is not worth the framing overhead.
# Tuned conservatively — Brotli/Zstd both need >= ~150 bytes input to break
# even on small payloads.
val COMPRESSION_MIN_BODY_BYTES: i64 = 256

# Apply Content-Encoding negotiation and compression to a response.
#
# - Reads `Accept-Encoding` from the request side (already extracted to
#   `accept_header`; pass "" if absent).
# - Negotiates against `supported_encodings()`.
# - If a codec is chosen and the response is eligible (see below), compresses
#   the body, sets `body_bytes`, clears `body: text`, adds `Content-Encoding`,
#   and removes any pre-existing `Content-Length`.
# - Otherwise returns `resp` unchanged.
#
# A response is INELIGIBLE for compression when:
#
# - `body_file != ""` — sendfile path; the kernel does the I/O and we cannot
#   intercept the bytes.
# - `chunked == true` — chunked transfer; full-buffer compression would break
#   streaming. Per-chunk compression is a separate (HTTP/2-style) feature.
# - Total payload < COMPRESSION_MIN_BODY_BYTES — overhead exceeds savings.
# - Existing `Content-Encoding` header present — already encoded; do not
#   double-compress.
#
# This is a pure function over the response — caller is responsible for
# choosing whether to ultimately route through `set_response` (text path) or
# `set_response_bytes` (binary path) based on the returned `body_bytes.len()`.
fn compress_response_for(resp: HttpResponseData, accept_header: text) -> HttpResponseData:
    if not _is_compression_eligible(resp):
        return resp
    val content_type = _find_header_value(resp.headers, "content-type")
    if not _is_compressible_content_type(content_type):
        return resp
    val chosen = negotiate_encoding(accept_header, supported_encodings())
    if chosen.len() == 0:
        return resp
    val body_bytes = _resp_body_as_bytes(resp)
    if body_bytes.len() < COMPRESSION_MIN_BODY_BYTES:
        return resp
    val compressed_res = compress_response_body(body_bytes, chosen)
    if compressed_res.is_err():
        # Compression failed — fall through to identity.
        # DO NOT silently emit a Content-Encoding header without compressed bytes.
        return resp
    val compressed = compressed_res.unwrap()
    # Only use compressed form when it is actually smaller.
    if compressed.len() >= body_bytes.len():
        return resp
    val new_headers = _set_content_encoding_with_length(
        _strip_content_length(resp.headers), chosen, compressed.len()
    )
    HttpResponseData(
        status: resp.status,
        reason: resp.reason,
        headers: new_headers,
        body: "",
        body_bytes: compressed,
        body_file: resp.body_file,
        body_offset: resp.body_offset,
        body_length: compressed.len(),
        chunked: resp.chunked
    )

# Public alias: compress a response given the full request (reads Accept-Encoding).
pub fn compress_response(request: HttpRequestData, resp: HttpResponseData) -> HttpResponseData:
    """Apply response compression based on the request's Accept-Encoding.

    Compressed body bytes are stored in body_bytes; the worker's send_response
    uses submit_send_bytes for non-empty body_bytes to avoid text corruption.

    Args:
        request: Parsed HTTP request (for Accept-Encoding header)
        resp:    Response to potentially compress

    Returns:
        Compressed HttpResponseData, or original if compression is not applicable
    """
    val accept_header = _find_header_value(request.headers, "accept-encoding")
    compress_response_for(resp, accept_header)

# Content-phase middleware stub for the pipeline registry.
# Compression is applied in the worker's send path (compress_response),
# not here, because the middleware pipeline does not see the response.
pub fn compression_handler(request: HttpRequestData, config: ServerConfig) -> PhaseResult:
    """Content-phase registration stub. Always returns Continue.

    Actual compression happens in the worker send path via compress_response.
    """
    PhaseResult.Continue

# ----------------------------------------------------------------------------
# Eligibility + header helpers (pure)
# ----------------------------------------------------------------------------

fn _is_compression_eligible(resp: HttpResponseData) -> bool:
    if resp.body_file.len() > 0:
        return false
    if resp.chunked:
        return false
    if _has_content_encoding(resp.headers):
        return false
    true

fn _has_content_encoding(headers: [(text, text)]) -> bool:
    for h in headers:
        if h.0.lower() == "content-encoding":
            return true
    false

fn _find_header_value(headers: [(text, text)], name: text) -> text:
    """Return the value of the first header matching `name` (case-insensitive), or ""."""
    for h in headers:
        if h.0.lower() == name.lower():
            return h.1
    ""

fn _is_compressible_content_type(content_type: text) -> bool:
    """Return true if the MIME type is worth compressing.

    Already-compressed formats (images, audio, video, zip, pdf, fonts) are
    excluded. Text-based and structured application types are eligible.
    """
    val ct = content_type.lower()
    # Skip already-compressed binary formats
    if ct.starts_with("image/"):
        return false
    if ct.starts_with("video/"):
        return false
    if ct.starts_with("audio/"):
        return false
    if ct.contains("zip"):
        return false
    if ct.contains("gzip"):
        return false
    if ct.starts_with("application/pdf"):
        return false
    if ct.starts_with("font/woff"):
        return false
    if ct.starts_with("application/font-woff"):
        return false
    # Compressible types
    if ct.starts_with("text/"):
        return true
    if ct.starts_with("application/json"):
        return true
    if ct.starts_with("application/javascript"):
        return true
    if ct.starts_with("application/x-javascript"):
        return true
    if ct.starts_with("application/xml"):
        return true
    if ct.starts_with("application/xhtml"):
        return true
    if ct.contains("svg"):
        return true
    false

fn _strip_content_length(headers: [(text, text)]) -> [(text, text)]:
    var out: [(text, text)] = []
    for h in headers:
        if h.0.lower() != "content-length":
            out.push(h)
    out

fn _set_content_encoding(headers: [(text, text)], encoding: text) -> [(text, text)]:
    # Replace any existing Content-Encoding (defensive — eligibility check
    # above already rejects responses that have one) and append.
    var out: [(text, text)] = []
    for h in headers:
        if h.0.lower() != "content-encoding":
            out.push(h)
    out.push(("Content-Encoding", encoding))
    out

fn _set_content_encoding_with_length(
    headers: [(text, text)],
    encoding: text,
    compressed_len: i64
) -> [(text, text)]:
    """Set Content-Encoding and add updated Content-Length for compressed body."""
    var out = _set_content_encoding(headers, encoding)
    out.push(("Content-Length", "{compressed_len}"))
    out

fn _resp_body_as_bytes(resp: HttpResponseData) -> [u8]:
    # Prefer existing body_bytes if populated; else convert text body via
    # the same helper response.spl uses.
    if resp.body_bytes.len() > 0:
        return resp.body_bytes
    _compression_text_to_bytes(resp.body)

fn _compression_text_to_bytes(s: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < s.len():
        out.push(s.byte_at(i))
        i = i + 1
    out

# Compress `body` with the named encoding. Returns the compressed bytes or an
# error message describing why the encoding is not supported.
#
# `encoding` is a lowercase token like "gzip", "br", "zstd", "lz4", "deflate",
# or "" (identity). Identity is treated as a programmer error — the caller
# should not have invoked this dispatcher with no encoding to apply.
fn compress_response_body(body: [u8], encoding: text) -> Result<[u8], text>:
    match encoding:
        "br":
            val compressed = brotli_compress(body)
            if compressed.len() == 0 and body.len() > 0:
                Err("brotli_compress returned empty output")
            else:
                Ok(compressed)
        "gzip":
            val compressed = gzip_compress(body)
            if compressed.len() == 0 and body.len() > 0:
                Err("gzip_compress returned empty output")
            else:
                Ok(compressed)
        "deflate":
            val result = deflate_compress_sync_flush(body)
            if result.is_err():
                Err("deflate_compress_sync_flush failed")
            else:
                Ok(result.unwrap())
        "zstd":
            Ok(zstd_compress_frame(body, default_compression_options(CompressionCodec.zstd)))
        "lz4":
            Ok(lz4_compress_frame(body, default_compression_options(CompressionCodec.lz4)))
        "":
            Err("compress_response_body called with empty encoding (caller should skip compression)")
        "identity":
            Err("compress_response_body called with 'identity' encoding (caller should skip compression)")
        _:
            Err("unknown Content-Encoding '" + encoding + "'")

# Returns the list of Content-Encoding names this dispatcher can produce,
# in server-preference order (strongest/most desirable first).
# Used as input to `negotiate_encoding`.
pub fn supported_encodings() -> [text]:
    ["br", "gzip", "deflate", "zstd", "lz4"]
