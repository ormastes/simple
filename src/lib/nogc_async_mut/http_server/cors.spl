"""
# CORS Middleware

Cross-Origin Resource Sharing (CORS) enforcement for the Access phase.
Handles preflight OPTIONS requests and validates Origin headers against
a configured allowlist.

## Usage

```simple
val config = CorsConfig(
    allowed_origins: ["https://example.com", "https://app.example.com"],
    allowed_methods: ["GET", "POST", "PUT", "DELETE"],
    allowed_headers: ["Content-Type", "Authorization", "X-CSRF-Token"],
    expose_headers: ["X-Request-Id"],
    allow_credentials: false,
    max_age_seconds: 86400
)
pipeline.add(Phase.Access, 180, "cors",
    \req, srv_cfg: cors_handler(req, srv_cfg, config))
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, ServerConfig
}
use std.http_server.csrf.{get_header_value}

# ============================================================================
# Configuration
# ============================================================================

class CorsConfig:
    """CORS policy configuration."""
    allowed_origins: [text]
    allowed_methods: [text]
    allowed_headers: [text]
    expose_headers: [text]
    allow_credentials: bool
    max_age_seconds: i64

    static fn default() -> CorsConfig:
        """Restrictive default: no origins allowed."""
        CorsConfig(
            allowed_origins: [],
            allowed_methods: ["GET", "HEAD", "OPTIONS"],
            allowed_headers: ["Content-Type", "Accept"],
            expose_headers: [],
            allow_credentials: false,
            max_age_seconds: 86400
        )

    static fn permissive() -> CorsConfig:
        """Permissive config for development: allow all origins."""
        CorsConfig(
            allowed_origins: ["*"],
            allowed_methods: ["GET", "HEAD", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
            allowed_headers: ["*"],
            expose_headers: [],
            allow_credentials: false,
            max_age_seconds: 86400
        )

# ============================================================================
# Handler
# ============================================================================

fn cors_handler(request: HttpRequestData,
                server_config: ServerConfig,
                config: CorsConfig) -> PhaseResult:
    """Access phase handler: enforce CORS policy.

    For preflight OPTIONS requests, responds with appropriate CORS
    headers. For all other requests, validates the Origin header
    against the allowed origins list.

    Args:
        request: Incoming request
        server_config: Server configuration
        config: CORS settings

    Returns:
        Continue if allowed, Respond for preflight, Error(403) for blocked origins
    """
    val origin = get_header_value(request.headers, "Origin")

    # No Origin header — not a CORS request, allow through
    if origin == "":
        return PhaseResult.Continue

    # Validate origin against allowlist
    if not is_origin_allowed(origin, config.allowed_origins):
        return PhaseResult.Error(403, "Origin not allowed")

    # Handle preflight OPTIONS
    if request.method == "OPTIONS":
        return handle_preflight(origin, request, config)

    # Normal CORS request — add response headers via Respond
    # The server layer reads these headers from the PhaseResult
    val headers = build_cors_headers(origin, config)
    PhaseResult.Respond(200, "OK", headers)

# ============================================================================
# Preflight Handling
# ============================================================================

fn handle_preflight(origin: text, request: HttpRequestData,
                    config: CorsConfig) -> PhaseResult:
    """Handle a CORS preflight OPTIONS request.

    Returns a 204 No Content response with full CORS headers.
    """
    val methods = join_list(config.allowed_methods, ", ")
    val headers = join_list(config.allowed_headers, ", ")
    val max_age = "{config.max_age_seconds}"

    var body_parts: [text] = []
    body_parts.push("Access-Control-Allow-Origin: {origin}\r\n")
    body_parts.push("Access-Control-Allow-Methods: {methods}\r\n")
    body_parts.push("Access-Control-Allow-Headers: {headers}\r\n")
    body_parts.push("Access-Control-Max-Age: {max_age}\r\n")

    if config.allow_credentials:
        body_parts.push("Access-Control-Allow-Credentials: true\r\n")

    if config.expose_headers.len() > 0:
        val exposed = join_list(config.expose_headers, ", ")
        body_parts.push("Access-Control-Expose-Headers: {exposed}\r\n")

    PhaseResult.Respond(204, "No Content", body_parts.join(""))

# ============================================================================
# Header Building
# ============================================================================

fn build_cors_headers(origin: text, config: CorsConfig) -> text:
    """Build CORS response headers for a normal (non-preflight) request.

    Returns headers as a string block for the response layer to parse.
    """
    var parts: [text] = []
    parts.push("Access-Control-Allow-Origin: {origin}\r\n")

    if config.allow_credentials:
        parts.push("Access-Control-Allow-Credentials: true\r\n")

    if config.expose_headers.len() > 0:
        val exposed = join_list(config.expose_headers, ", ")
        parts.push("Access-Control-Expose-Headers: {exposed}\r\n")

    parts.join("")

# ============================================================================
# Origin Validation
# ============================================================================

fn is_origin_allowed(origin: text, allowed: [text]) -> bool:
    """Check if an origin is in the allowlist.

    Supports wildcard "*" to allow all origins.
    """
    for entry in allowed:
        if entry == "*":
            return true
        if entry == origin:
            return true
    false

# ============================================================================
# Helpers
# ============================================================================

fn join_list(items: [text], separator: text) -> text:
    """Join a list of strings with a separator."""
    items.join(separator)
