"""
# Worker Thread

Each worker owns its own EventLoop + IoDriver and handles
thousands of connections via non-blocking I/O. Workers are
spawned by the master HttpServer.

## Architecture

```
Worker Thread
  ├── EventLoop (epoll/kqueue)
  ├── IoDriver (submit/poll completions)
  ├── TcpListener (SO_REUSEPORT, own bind)
  ├── connections: Dict<fd, Connection>
  ├── AsyncRouter
  ├── MiddlewarePipeline
  └── HandlerRegistry
```

## Main Loop

```
while not shutdown:
  1. Check control channel for shutdown/reload
  2. driver.flush()
  3. completions = driver.poll(max_events, timeout_ms)
  4. For each completion: advance connection state machine
  5. Reap expired keepalive connections
```
"""

use std.io.driver.{IoDriver}
use std.io.event_loop.{EventLoop, Waker}
use std.net.ffi.{
    rt_io_tcp_bind, rt_io_tcp_close, rt_io_tcp_local_addr,
    rt_io_tcp_set_nodelay, rt_socket_set_nonblocking,
    rt_socket_set_reuseport, rt_socket_set_reuseaddr
}
use std.concurrent.channel.{Channel}
use std.thread_sffi.{spl_thread_sleep}

use std.http_server.types.{
    ConnectionState, ConnectionAction, HttpRequestData, HttpResponseData,
    ServerConfig, LocationConfig, PhaseResult
}
use std.http_server.connection.{Connection}
use std.http_server.parser.{HttpRequestParser}
use std.http_server.router.{AsyncRouter}
use std.http_server.middleware.{MiddlewarePipeline, body_limit_handler}
use std.http_server.response.{
    serialize_response, build_error, build_not_found, build_internal_error,
    build_too_large, build_request_timeout
}
use std.http_server.handler.{HandlerRegistry}
use std.http_server.error.{HttpServerError}

# Time FFI
extern fn rt_time_now_ms() -> i64

# Completion type constants
val OP_RECV = 1
val OP_SEND = 2
val OP_SENDFILE = 3

# ============================================================================
# Worker
# ============================================================================

class Worker:
    """Event-driven worker thread for the async HTTP server.

    Each worker binds its own listener (SO_REUSEPORT), owns an IoDriver,
    and manages a pool of non-blocking connections. The kernel distributes
    incoming connections across workers.
    """
    worker_id: i64
    driver: IoDriver
    listener_fd: i64
    connections: Dict<i64, Connection>
    op_to_fd: Dict<i64, i64>
    op_type: Dict<i64, i64>
    sendfile_pending: Dict<i64, (text, i64, i64)>
    router: AsyncRouter
    pipeline: MiddlewarePipeline
    handler_registry: HandlerRegistry
    config: ServerConfig
    control: Channel
    active_count: i64
    shutdown_requested: bool
    accept_op_id: i64

    static fn create(worker_id: i64, config: ServerConfig,
                     router: AsyncRouter, pipeline: MiddlewarePipeline,
                     handler_registry: HandlerRegistry,
                     control: Channel) -> Result<Worker, HttpServerError>:
        """Create a new worker and bind its listener.

        Args:
            worker_id: Worker index (0-based)
            config: Server configuration
            router: Router (read-only after init)
            pipeline: Middleware pipeline (read-only after init)
            handler_registry: Content handler dispatch registry
            control: Channel for shutdown signals from master

        Returns:
            Initialized Worker or BindFailed error
        """
        val driver = IoDriver.new()

        val listen_fd = rt_io_tcp_bind(config.listen_addr)
        if listen_fd < 0:
            return Err(HttpServerError.BindFailed(
                "Worker {worker_id}: failed to bind {config.listen_addr}"
            ))

        rt_socket_set_reuseport(listen_fd, true)
        rt_socket_set_reuseaddr(listen_fd, true)
        rt_socket_set_nonblocking(listen_fd, true)

        Ok(Worker(
            worker_id: worker_id,
            driver: driver,
            listener_fd: listen_fd,
            connections: {},
            op_to_fd: {},
            op_type: {},
            sendfile_pending: {},
            router: router,
            pipeline: pipeline,
            handler_registry: handler_registry,
            config: config,
            control: control,
            active_count: 0,
            shutdown_requested: false,
            accept_op_id: 0
        ))

    me run():
        """Main worker loop. Runs until shutdown is requested.

        This method is called in a dedicated OS thread. It submits
        an initial accept, then loops polling for completions.
        """
        self.accept_op_id = self.driver.submit_accept(self.listener_fd)
        self.driver.flush()

        while not self.shutdown_requested:
            val msg = self.control.try_recv()
            if msg.?:
                val cmd = msg as text
                if cmd == "shutdown":
                    self.shutdown_requested = true
                    break

            self.driver.flush()
            val completions = self.driver.poll(64, 10)
            val now = rt_time_now_ms()

            for completion in completions:
                val op_id = completion.id
                val result = completion.result
                val flags = completion.flags

                if op_id == self.accept_op_id:
                    self.handle_accept(result, now)
                else:
                    self.handle_completion(op_id, result, flags, now)

            self.reap_expired(now)

        self.close_all_connections()
        rt_io_tcp_close(self.listener_fd)
        self.driver.close()

    # ========================================================================
    # Accept
    # ========================================================================

    me handle_accept(client_fd: i64, now: i64):
        """Handle a new connection accept completion."""
        self.accept_op_id = self.driver.submit_accept(self.listener_fd)

        if client_fd < 0:
            return

        if self.active_count >= self.config.max_connections:
            rt_io_tcp_close(client_fd)
            return

        rt_socket_set_nonblocking(client_fd, true)
        rt_io_tcp_set_nodelay(client_fd, true)

        val peer = rt_io_tcp_local_addr(client_fd) ?? "unknown"
        val conn = Connection.new(client_fd, peer, now)

        self.connections[client_fd] = conn
        self.active_count = self.active_count + 1

        # Submit recv and track op_id → fd
        val recv_op = self.driver.submit_recv(client_fd, 8192)
        self.op_to_fd[recv_op] = client_fd
        self.op_type[recv_op] = OP_RECV

    # ========================================================================
    # I/O Completions
    # ========================================================================

    me handle_completion(op_id: i64, result: i64, flags: i64, now: i64):
        """Handle a non-accept I/O completion.

        Uses op_to_fd/op_type maps to dispatch to the correct connection.
        """
        val fd = self.op_to_fd.get(op_id)
        if not fd.?:
            return

        val typ = self.op_type.get(op_id) ?? 0

        # Clean up tracking maps
        self.op_to_fd.remove(op_id)
        self.op_type.remove(op_id)

        if result < 0:
            self.close_connection(fd)
            return

        if typ == OP_RECV:
            if result == 0:
                # EOF — peer closed
                self.close_connection(fd)
            else:
                val data = self.driver.poll_data(op_id)
                self.handle_recv(fd, data, now)

        elif typ == OP_SEND:
            # Check if there's a pending sendfile for this fd
            val pending = self.sendfile_pending.get(fd)
            if pending.?:
                val file_path = pending.0
                val offset = pending.1
                val length = pending.2
                self.sendfile_pending.remove(fd)
                val sf_op = self.driver.submit_open(file_path, 0, 0)
                self.op_to_fd[sf_op] = fd
                self.op_type[sf_op] = OP_SENDFILE
            else:
                self.handle_send_complete(fd, now)

        elif typ == OP_SENDFILE:
            self.handle_send_complete(fd, now)

    me handle_recv(fd: i64, data: text, now: i64):
        """Handle data received on a connection."""
        val conn = self.connections.get(fd)
        if not conn.?:
            return

        var c = conn
        val action = c.on_data_received(data, now)
        self.connections[fd] = c

        match action:
            ConnectionAction.ContinueReading:
                val op = self.driver.submit_recv(fd, 8192)
                self.op_to_fd[op] = fd
                self.op_type[op] = OP_RECV

            ConnectionAction.RequestReady:
                self.process_request(fd, now)

            ConnectionAction.Close:
                self.close_connection(fd)

            ConnectionAction.Error(status, msg):
                self.send_error(fd, status, msg, now)

            _:
                pass_do_nothing

    me handle_send_complete(fd: i64, now: i64):
        """Handle write completion on a connection."""
        val conn = self.connections.get(fd)
        if not conn.?:
            return

        var c = conn
        val action = c.on_write_complete(now)
        self.connections[fd] = c

        match action:
            ConnectionAction.ContinueReading:
                val op = self.driver.submit_recv(fd, 8192)
                self.op_to_fd[op] = fd
                self.op_type[op] = OP_RECV

            ConnectionAction.Close:
                self.close_connection(fd)

            _:
                pass_do_nothing

    # ========================================================================
    # Request Processing
    # ========================================================================

    me process_request(fd: i64, now: i64):
        """Process a complete HTTP request through the pipeline.

        Runs middleware phases, routes to handler, generates response.
        """
        val conn = self.connections.get(fd)
        if not conn.?:
            return

        var c = conn
        val request = c.request
        if not request.?:
            self.send_error(fd, 500, "No request data", now)
            return

        # Run pre-content middleware phases
        val phase_result = self.pipeline.run_all_phases(request, self.config)
        match phase_result:
            PhaseResult.Respond(status, reason, body):
                val resp = build_error(status, body)
                self.send_response(fd, resp, now)
                return
            PhaseResult.Error(status, msg):
                self.send_error(fd, status, msg, now)
                return
            _:
                pass_do_nothing

        # Route request
        val route_result = self.router.route(request)
        match route_result:
            Ok((location, params)):
                var req = HttpRequestData(
                    method: request.method,
                    path: request.path,
                    query: request.query,
                    version: request.version,
                    headers: request.headers,
                    body: request.body,
                    params: params,
                    peer_addr: request.peer_addr
                )
                val resp = self.execute_handler(location, req)
                self.send_response(fd, resp, now)

            Err(e):
                self.send_response(fd, build_not_found(), now)

        # Run log phase
        self.pipeline.run_log_phase(request, self.config)

    me execute_handler(location: LocationConfig,
                       request: HttpRequestData) -> HttpResponseData:
        """Execute the content handler for a matched location.

        Delegates to handler_registry which maps handler_type to
        the appropriate ContentHandler.
        """
        self.handler_registry.dispatch(location.handler_type, request, location)

    # ========================================================================
    # Response Sending
    # ========================================================================

    me send_response(fd: i64, resp: HttpResponseData, now: i64):
        """Send a response on a connection."""
        val conn = self.connections.get(fd)
        if not conn.?:
            return

        var c = conn
        val keepalive_s = self.config.keepalive_timeout_ms / 1000
        c.set_response(resp, keepalive_s)
        self.connections[fd] = c

        val bytes = c.get_response_bytes()

        if resp.body_file.len() > 0:
            # Send headers first, then chain sendfile on completion
            self.sendfile_pending[fd] = (resp.body_file, resp.body_offset, resp.body_length)
            val op = self.driver.submit_send(fd, bytes)
            self.op_to_fd[op] = fd
            self.op_type[op] = OP_SEND
        else:
            val op = self.driver.submit_send(fd, bytes)
            self.op_to_fd[op] = fd
            self.op_type[op] = OP_SEND

    me send_error(fd: i64, status: i64, msg: text, now: i64):
        """Send an error response and close."""
        val resp = build_error(status, msg)
        self.send_response(fd, resp, now)

    # ========================================================================
    # Connection Lifecycle
    # ========================================================================

    me close_connection(fd: i64):
        """Close a connection and remove from tracking."""
        rt_io_tcp_close(fd)
        self.connections.remove(fd)
        self.active_count = self.active_count - 1

    me close_all_connections():
        """Close all active connections during shutdown."""
        val fds = self.connections.keys()
        for fd in fds:
            rt_io_tcp_close(fd)
        self.connections = {}
        self.active_count = 0

    me reap_expired(now: i64):
        """Close connections that have exceeded their timeout."""
        var to_close: [i64] = []

        for fd in self.connections.keys():
            val conn = self.connections[fd]
            if conn.is_keepalive_expired(now, self.config.keepalive_timeout_ms):
                to_close = to_close + [fd]
            elif conn.is_read_timeout(now, self.config.read_timeout_ms):
                to_close = to_close + [fd]

        for fd in to_close:
            self.close_connection(fd)
