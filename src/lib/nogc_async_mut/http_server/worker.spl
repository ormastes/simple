fn _http_time_now_ms() -> i64:
    current_time_ms()

class StaticMetadataCacheEntry:
    path: text
    size: i64
    mtime: i64
    cached_at_ms: i64
    content_type: text
    etag: text
    response_header: text

fn worker_static_metadata_cache_ttl_ms() -> i64:
    val raw = rt_env_get("SIMPLE_HTTP_STATIC_METADATA_CACHE_MS") ?? ""
    if raw.len() == 0:
        return 0
    val parsed = int(raw)
    if parsed > 0:
        parsed
    else:
        0

# Completion type constants
val OP_RECV = 1
val OP_SEND = 2
val OP_SENDFILE = 3
val OP_OPEN_SENDFILE = 4
val OP_CLOSE_SENDFILE = 5
val OP_DIRECT_STATIC_SENDFILE = 6
val OP_ACCEPT = 10
val OP_PROXY_CONNECT = 20
val OP_PROXY_SEND_REQUEST = 21
val OP_PROXY_RECV_RESPONSE = 22
val OP_PROXY_SEND_CLIENT = 23
val OP_PROXY_TUNNEL_CONNECT = 24
val OP_PROXY_TUNNEL_SEND_SETUP = 25
val OP_PROXY_TUNNEL_RECV_CLIENT = 26
val OP_PROXY_TUNNEL_SEND_UPSTREAM = 27
val OP_PROXY_TUNNEL_RECV_UPSTREAM = 28
val OP_PROXY_TUNNEL_SEND_CLIENT = 29
val OP_PROXY_SEND_REQUEST_BODY = 30
val OP_PROXY_RECV_CLIENT_BODY = 31
val OP_PROXY_POLL_CLIENT_BODY = 32
val OP_PROXY_RETRY_SEND_REQUEST_BODY = 33
val WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES = 1024 * 1024
val WORKER_PROXY_REQUEST_BODY_CHUNK_BYTES = 256 * 1024
val WORKER_PROXY_UPSTREAM_BODY_WRITE_BYTES = 256 * 1024

fn worker_op_is(actual: i64, expected: i64) -> bool:
    actual >= expected and actual <= expected

fn worker_tracked_op_exists(op_fds: [i64], op_kinds: [i64], fd: i64, kind: i64) -> bool:
    var i = 0
    while i < op_fds.len() and i < op_kinds.len():
        if op_fds[i] == fd and worker_op_is(op_kinds[i], kind):
            return true
        i = i + 1
    false

fn worker_config_has_proxy_routes(config: ServerConfig) -> bool:
    var i = 0
    while i < config.locations.len():
        if async_proxy_route_enabled(config.locations[i]):
            return true
        i = i + 1
    false

fn worker_static_content_type(path: text) -> text:
    if path.ends_with(".html") or path.ends_with(".htm"):
        return "text/html; charset=utf-8"
    if path.ends_with(".txt"):
        return "text/plain; charset=utf-8"
    if path.ends_with(".css"):
        return "text/css"
    if path.ends_with(".js"):
        return "application/javascript"
    if path.ends_with(".json"):
        return "application/json"
    if path.ends_with(".png"):
        return "image/png"
    if path.ends_with(".jpg") or path.ends_with(".jpeg"):
        return "image/jpeg"
    "application/octet-stream"

# ============================================================================
# TLS Session State (per-connection)
# ============================================================================

struct TlsSessionState:
    """Per-connection TLS session keys and sequence counters.

    Stored in Worker.tls_sessions keyed by fd. Enables decryption of
    incoming TLS records and encryption of outgoing application data
    after the TLS handshake completes.
    """
    keys: TlsSessionKeys
    cipher_suite: i64
    client_seq: i64
    server_seq: i64

# ============================================================================
# Worker
# ============================================================================

class Worker:
    """Event-driven worker thread for the async HTTP server.

    Each worker binds its own listener (SO_REUSEPORT), owns an IoDriver,
    and manages a pool of non-blocking connections. The kernel distributes
    incoming connections across workers.
    """
    worker_id: i64
    driver: IoDriver
    net_capabilities: NetBackendCapabilities
    net_backend_summary: text
    listener_fd: i64
    connections: Dict<i64, Connection>
    connection_items: [Connection]
    h2_connections: Dict<i64, H2Connection>
    proxy_connections: Dict<i64, AsyncProxyConnection>
    proxy_connection_items: [AsyncProxyConnection]
    proxy_request_streams: Dict<i64, AsyncProxyRequestBodyStream>
    proxy_request_stream_items: [AsyncProxyRequestBodyStream]
    proxy_tunnels: Dict<i64, AsyncProxyTunnelConnection>
    proxy_tunnel_items: [AsyncProxyTunnelConnection]
    connection_fds: [i64]
    h2_connection_fds: [i64]
    proxy_connection_fds: [i64]
    proxy_request_stream_fds: [i64]
    proxy_request_body_send_inflight_fds: [i64]
    proxy_request_body_recv_inflight_fds: [i64]
    proxy_tunnel_fds: [i64]
    proxy_tunnel_client_by_upstream: Dict<i64, i64>
    proxy_client_by_upstream: Dict<i64, i64>
    proxy_upstream_peers: Dict<text, AsyncProxyUpstreamPeer>
    proxy_health_probe_records: [AsyncProxyHealthProbeRecord]
    proxy_upstream_pool: [AsyncProxyPoolEntry]
    proxy_pool_config: AsyncProxyPoolConfig
    last_proxy_hardening_evidence: AsyncProxyProductionHardeningEvidence?
    op_ids: [i64]
    op_fds: [i64]
    op_io_fds: [i64]
    op_kinds: [i64]
    sendfile_pending: Dict<i64, (text, i64, i64)>
    sendfile_open_files: Dict<i64, i64>
    router: AsyncRouter
    pipeline: MiddlewarePipeline
    handler_registry: HandlerRegistry
    config: ServerConfig
    control: Channel
    active_count: i64
    shutdown_requested: bool
    draining: bool
    accept_op_id: i64
    static_file_sendfile_count: i64
    static_file_fallback_count: i64
    static_metadata_cache_ttl_ms: i64
    static_metadata_cache: Dict<text, StaticMetadataCacheEntry>
    has_proxy_routes: bool
    tls_config: TlsConfig?
    tls_sessions: Dict<i64, TlsSessionState>
    tls_rx_buf: Dict<i64, [u8]>

    static fn create(worker_id: i64, config: ServerConfig,
                     router: AsyncRouter, pipeline: MiddlewarePipeline,
                     handler_registry: HandlerRegistry,
                     control: Channel) -> Result<Worker, HttpServerError>:
        """Create a new worker and bind its listener.

        Args:
            worker_id: Worker index (0-based)
            config: Server configuration
            router: Router (read-only after init)
            pipeline: Middleware pipeline (read-only after init)
            handler_registry: Content handler dispatch registry
            control: Channel for shutdown signals from master

        Returns:
            Initialized Worker or BindFailed error
        """
        val driver = IoDriver.new()
        val caps = driver.net_capabilities()
        val backend_summary = net_backend_summary(caps)

        val listen_fd = tcp_backend_bind_with_reuseport(config.listen_addr)
        if listen_fd < 0:
            return Err(HttpServerError.BindFailed(
                "Worker {worker_id}: failed to bind {config.listen_addr}"
            ))

        tcp_backend_set_nonblocking(listen_fd, true)

        # Build TLS config when TLS is enabled (no separate bind — reuse TCP listener fd)
        var tls_cfg: TlsConfig? = nil
        if config.tls_enabled:
            val chain_result = TlsCertificateChain.from_pem_file(config.tls_cert_path)
            var chain: TlsCertificateChain
            match chain_result:
                Ok(c):
                    chain = c
                Err(msg):
                    return Err(HttpServerError.TlsError("Worker {worker_id}: certificate load failed: {msg}"))
            val key_result = TlsPrivateKey.from_pem_file(config.tls_key_path)
            var key: TlsPrivateKey
            match key_result:
                Ok(k):
                    key = k
                Err(msg):
                    return Err(HttpServerError.TlsError("Worker {worker_id}: private key load failed: {msg}"))
            tls_cfg = TlsConfig.server(chain, key)

        Ok(Worker(
            worker_id: worker_id,
            driver: driver,
            net_capabilities: caps,
            net_backend_summary: backend_summary,
            listener_fd: listen_fd,
            connections: {},
            connection_items: [],
            h2_connections: {},
            proxy_connections: {},
            proxy_connection_items: [],
            proxy_request_streams: {},
            proxy_request_stream_items: [],
            proxy_tunnels: {},
            proxy_tunnel_items: [],
            connection_fds: [],
            h2_connection_fds: [],
            proxy_connection_fds: [],
            proxy_request_stream_fds: [],
            proxy_request_body_send_inflight_fds: [],
            proxy_request_body_recv_inflight_fds: [],
            proxy_tunnel_fds: [],
            proxy_tunnel_client_by_upstream: {},
            proxy_client_by_upstream: {},
            proxy_upstream_peers: {},
            proxy_health_probe_records: [],
            proxy_upstream_pool: [],
            proxy_pool_config: async_proxy_pool_default_config(),
            last_proxy_hardening_evidence: nil,
            op_ids: [],
            op_fds: [],
            op_io_fds: [],
            op_kinds: [],
            sendfile_pending: {},
            sendfile_open_files: {},
            router: router,
            pipeline: pipeline,
            handler_registry: handler_registry,
            config: config,
            control: control,
            active_count: 0,
            shutdown_requested: false,
            draining: false,
            accept_op_id: 0,
            static_file_sendfile_count: 0,
            static_file_fallback_count: 0,
            static_metadata_cache_ttl_ms: worker_static_metadata_cache_ttl_ms(),
            static_metadata_cache: {},
            has_proxy_routes: worker_config_has_proxy_routes(config),
            tls_config: tls_cfg,
            tls_sessions: {},
            tls_rx_buf: {}
        ))

    me run():
        """Main worker loop. Runs until shutdown is requested.

        This method is called in a dedicated OS thread. It submits
        an initial accept, then loops polling for completions.
        """
        self.accept_op_id = self.driver.submit_accept(self.listener_fd)
        self.track_op(self.accept_op_id, self.listener_fd, OP_ACCEPT)
        self.driver.flush()

        while not self.shutdown_requested:
            val msg = self.control.try_recv()
            if msg.?:
                val cmd = msg as text
                if cmd == "shutdown":
                    self.shutdown_requested = true
                    break
                elif cmd == "drain":
                    self.draining = true

            self.driver.flush()
            val completion_count = self.driver.poll_count(64, 10)
            val now = _http_time_now_ms()

            var completion_index = 0
            while completion_index < completion_count:
                val op_id = self.driver.poll_id(completion_index)
                val result = self.driver.poll_result(completion_index)
                val tracked_kind = self.op_kind(op_id)
                if worker_op_is(tracked_kind, OP_ACCEPT):
                    self.remove_op(op_id)
                    if self.draining:
                        if result >= 0:
                            tcp_backend_close(result)
                    else:
                        self.handle_accept(result, now)
                else:
                    self.handle_completion(op_id, result, completion_index, now)
                completion_index = completion_index + 1

            self.reap_expired(now)

            if self.draining and self.active_count == 0:
                self.control.send("drained")
                self.shutdown_requested = true

        self.close_all_connections()
        tcp_backend_close(self.listener_fd)
        self.driver.close()

    # ========================================================================
    # Accept
    # ========================================================================

    me handle_accept(client_fd: i64, now: i64):
        """Handle a new connection accept completion.

        When TLS is enabled, performs TLS handshake and dispatches
        by ALPN protocol. Plain TCP otherwise.
        """
        self.accept_op_id = self.driver.submit_accept(self.listener_fd)
        self.track_op(self.accept_op_id, self.listener_fd, OP_ACCEPT)

        if client_fd < 0:
            return

        if self.active_count >= self.config.max_connections:
            tcp_backend_close(client_fd)
            return

        tcp_backend_set_nonblocking(client_fd, true)
        tcp_backend_set_nodelay(client_fd, true)

        # TLS path: handshake then ALPN dispatch
        if self.tls_config.?:
            self.handle_tls_accept(client_fd, now)
            return

        val peer = tcp_backend_local_addr(client_fd) ?? "unknown"
        val conn = Connection.new(client_fd, peer, now)

        self.http1_connection_set(client_fd, conn)
        self.track_http1_fd(client_fd)
        self.active_count = self.active_count + 1

        val recv_op = self.driver.submit_recv(client_fd, 8192)
        self.track_op(recv_op, client_fd, OP_RECV)

    me handle_tls_accept(client_fd: i64, now: i64):
        """Perform TLS handshake on an accepted fd and dispatch by ALPN.

        Uses perform_server_handshake from the TLS module to complete the
        handshake synchronously. On success, stores session keys for
        record-layer encrypt/decrypt, then dispatches via dispatch_by_alpn
        for HTTP/1.1 or HTTP/2. On failure, closes the fd.

        Note: current TLS 1.2 implementation does not negotiate ALPN,
        so all connections default to HTTP/1.1. When ALPN support
        lands in tls_handshake.spl, extract it from the handshake
        state and pass to dispatch_by_alpn.
        """
        var cfg = self.tls_config
        val hs_result = perform_server_handshake(
            self.driver,
            client_fd,
            cfg
        )
        match hs_result:
            Ok(state):
                val keys = state.session_keys
                if keys == nil:
                    tcp_backend_close(client_fd)
                    return
                # Store TLS session keys for this connection so recv/send
                # paths can decrypt/encrypt TLS application data records.
                # Use seq values from the handshake state: both Finished messages
                # consume seq 0, so application data begins at client_seq=1, server_seq=1.
                self.tls_sessions[client_fd] = TlsSessionState(
                    keys: keys.unwrap(),
                    cipher_suite: state.cipher_suite,
                    client_seq: state.client_seq,
                    server_seq: state.server_seq
                )
                # TODO: [stdlib][P2] extract ALPN from handshake state when ALPN is implemented
                self.dispatch_by_alpn("", client_fd, now)
            Err(e):
                tcp_backend_close(client_fd)

    # ========================================================================
    # I/O Completions
    # ========================================================================

    me track_op(op_id: i64, fd: i64, kind: i64):
        self.track_io_op(op_id, fd, fd, kind)

    me track_io_op(op_id: i64, owner_fd: i64, io_fd: i64, kind: i64):
        var i = 0
        while i < self.op_ids.len():
            if self.op_ids[i] == op_id:
                self.op_fds[i] = owner_fd
                if i < self.op_io_fds.len():
                    self.op_io_fds[i] = io_fd
                self.op_kinds[i] = kind
                return
            i = i + 1
        self.op_ids.push(op_id)
        self.op_fds.push(owner_fd)
        self.op_io_fds.push(io_fd)
        self.op_kinds.push(kind)

    me op_fd(op_id: i64) -> i64:
        var i = 0
        while i < self.op_ids.len():
            if self.op_ids[i] == op_id:
                return self.op_fds[i]
            i = i + 1
        -1

    me op_kind(op_id: i64) -> i64:
        var i = 0
        while i < self.op_ids.len():
            if self.op_ids[i] == op_id:
                return self.op_kinds[i]
            i = i + 1
        0

    me op_io_fd(op_id: i64) -> i64:
        var i = 0
        while i < self.op_ids.len():
            if self.op_ids[i] == op_id:
                if i < self.op_io_fds.len():
                    return self.op_io_fds[i]
                return self.op_fds[i]
            i = i + 1
        -1

    me take_op(op_id: i64) -> (i64, i64, i64):
        var next_ids: [i64] = []
        var next_fds: [i64] = []
        var next_io_fds: [i64] = []
        var next_kinds: [i64] = []
        var found_fd = -1
        var found_io_fd = -1
        var found_kind = 0
        var i = 0
        while i < self.op_ids.len():
            val io_fd = if i < self.op_io_fds.len(): self.op_io_fds[i] else: self.op_fds[i]
            if self.op_ids[i] == op_id:
                found_fd = self.op_fds[i]
                found_io_fd = io_fd
                found_kind = self.op_kinds[i]
            else:
                next_ids.push(self.op_ids[i])
                next_fds.push(self.op_fds[i])
                next_io_fds.push(io_fd)
                next_kinds.push(self.op_kinds[i])
            i = i + 1
        self.op_ids = next_ids
        self.op_fds = next_fds
        self.op_io_fds = next_io_fds
        self.op_kinds = next_kinds
        (found_fd, found_io_fd, found_kind)

    me remove_op(op_id: i64):
        var next_ids: [i64] = []
        var next_fds: [i64] = []
        var next_io_fds: [i64] = []
        var next_kinds: [i64] = []
        var i = 0
        while i < self.op_ids.len():
            if self.op_ids[i] != op_id:
                next_ids.push(self.op_ids[i])
                next_fds.push(self.op_fds[i])
                if i < self.op_io_fds.len():
                    next_io_fds.push(self.op_io_fds[i])
                else:
                    next_io_fds.push(self.op_fds[i])
                next_kinds.push(self.op_kinds[i])
            i = i + 1
        self.op_ids = next_ids
        self.op_fds = next_fds
        self.op_io_fds = next_io_fds
        self.op_kinds = next_kinds

    me remove_ops_for_fd(fd: i64):
        var next_ids: [i64] = []
        var next_fds: [i64] = []
        var next_io_fds: [i64] = []
        var next_kinds: [i64] = []
        var i = 0
        while i < self.op_ids.len():
            val io_fd = if i < self.op_io_fds.len(): self.op_io_fds[i] else: self.op_fds[i]
            if self.op_fds[i] != fd and io_fd != fd:
                next_ids.push(self.op_ids[i])
                next_fds.push(self.op_fds[i])
                next_io_fds.push(io_fd)
                next_kinds.push(self.op_kinds[i])
            i = i + 1
        self.op_ids = next_ids
        self.op_fds = next_fds
        self.op_io_fds = next_io_fds
        self.op_kinds = next_kinds

    me fd_list_contains(fds: [i64], fd: i64) -> bool:
        var i = 0
        while i < fds.len():
            if fds[i] == fd:
                return true
            i = i + 1
        false

    me fd_list_without(fds: [i64], fd: i64) -> [i64]:
        var result: [i64] = []
        var i = 0
        while i < fds.len():
            if fds[i] != fd:
                result.push(fds[i])
            i = i + 1
        result

    me track_http1_fd(fd: i64):
        if not self.fd_list_contains(self.connection_fds, fd):
            self.connection_fds.push(fd)

    me untrack_http1_fd(fd: i64):
        self.connection_fds = self.fd_list_without(self.connection_fds, fd)

    me http1_connection_get(fd: i64) -> Connection?:
        var i = 0
        while i < self.connection_fds.len() and i < self.connection_items.len():
            if self.connection_fds[i] == fd:
                return self.connection_items[i]
            i = i + 1
        nil

    me http1_connection_set(fd: i64, conn: Connection):
        var i = 0
        while i < self.connection_fds.len() and i < self.connection_items.len():
            if self.connection_fds[i] == fd:
                self.connection_items[i] = conn
                return
            i = i + 1
        self.connection_fds.push(fd)
        self.connection_items.push(conn)

    me http1_connection_remove(fd: i64):
        var next_fds: [i64] = []
        var next_items: [Connection] = []
        var i = 0
        while i < self.connection_fds.len() and i < self.connection_items.len():
            if self.connection_fds[i] != fd:
                next_fds.push(self.connection_fds[i])
                next_items.push(self.connection_items[i])
            i = i + 1
        self.connection_fds = next_fds
        self.connection_items = next_items

    me track_h2_fd(fd: i64):
        if not self.fd_list_contains(self.h2_connection_fds, fd):
            self.h2_connection_fds.push(fd)

    me untrack_h2_fd(fd: i64):
        self.h2_connection_fds = self.fd_list_without(self.h2_connection_fds, fd)

    me track_proxy_fd(fd: i64):
        if not self.fd_list_contains(self.proxy_connection_fds, fd):
            self.proxy_connection_fds.push(fd)

    me untrack_proxy_fd(fd: i64):
        self.proxy_connection_fds = self.fd_list_without(self.proxy_connection_fds, fd)

    me proxy_connection_get(fd: i64) -> AsyncProxyConnection?:
        var i = 0
        while i < self.proxy_connection_fds.len() and i < self.proxy_connection_items.len():
            if self.proxy_connection_fds[i] == fd:
                return self.proxy_connection_items[i]
            i = i + 1
        nil

    me proxy_connection_set(fd: i64, proxy: AsyncProxyConnection):
        var i = 0
        while i < self.proxy_connection_fds.len() and i < self.proxy_connection_items.len():
            if self.proxy_connection_fds[i] == fd:
                self.proxy_connection_items[i] = proxy
                return
            i = i + 1
        self.proxy_connection_fds.push(fd)
        self.proxy_connection_items.push(proxy)

    me proxy_connection_remove(fd: i64):
        var next_fds: [i64] = []
        var next_items: [AsyncProxyConnection] = []
        var i = 0
        while i < self.proxy_connection_fds.len() and i < self.proxy_connection_items.len():
            if self.proxy_connection_fds[i] != fd:
                next_fds.push(self.proxy_connection_fds[i])
                next_items.push(self.proxy_connection_items[i])
            i = i + 1
        self.proxy_connection_fds = next_fds
        self.proxy_connection_items = next_items

    me proxy_client_for_upstream_fd(upstream_fd: i64) -> i64:
        if upstream_fd < 0:
            return -1
        val mapped = self.proxy_client_by_upstream.get(upstream_fd)
        if mapped.?:
            return mapped
        var i = 0
        while i < self.proxy_connection_fds.len() and i < self.proxy_connection_items.len():
            if self.proxy_connection_items[i].upstream_fd == upstream_fd:
                return self.proxy_connection_fds[i]
            i = i + 1
        return -1

    me proxy_tunnel_client_for_upstream_fd(upstream_fd: i64) -> i64:
        if upstream_fd < 0:
            return -1
        val mapped = self.proxy_tunnel_client_by_upstream.get(upstream_fd)
        if mapped.?:
            return mapped
        var i = 0
        while i < self.proxy_tunnel_fds.len() and i < self.proxy_tunnel_items.len():
            if self.proxy_tunnel_items[i].upstream_fd == upstream_fd:
                return self.proxy_tunnel_fds[i]
            i = i + 1
        return -1

    me proxy_client_by_upstream_remove(upstream_fd: i64):
        var next: Dict<i64, i64> = {}
        var i = 0
        while i < self.proxy_connection_fds.len() and i < self.proxy_connection_items.len():
            val proxy = self.proxy_connection_items[i]
            if proxy.upstream_fd >= 0 and proxy.upstream_fd != upstream_fd:
                next[proxy.upstream_fd] = self.proxy_connection_fds[i]
            i = i + 1
        self.proxy_client_by_upstream = next

    fn proxy_response_completion_text(index: i64, result: i64) -> text:
        val data = self.driver.poll_data(index)
        if data != "" or result <= 0:
            return data
        val bytes = self.driver.poll_recv_bytes(index)
        if bytes.len() == 0:
            return data
        rt_bytes_to_text(bytes)

    fn proxy_tunnel_completion_text(index: i64, bytes: [u8], result: i64) -> text:
        if result <= 0:
            return ""
        val data = self.driver.poll_data(index)
        if data != "":
            return data
        if bytes.len() > 0:
            return rt_bytes_to_text(bytes)
        ""

    fn proxy_tunnel_completion_bytes(index: i64, bytes: [u8], result: i64) -> [u8]:
        if bytes.len() > 0 or result <= 0:
            return bytes
        val data = self.driver.poll_data(index)
        if data == "":
            return []
        rt_text_to_bytes(data)

    me proxy_request_stream_get(fd: i64) -> AsyncProxyRequestBodyStream?:
        var i = 0
        while i < self.proxy_request_stream_fds.len() and i < self.proxy_request_stream_items.len():
            if self.proxy_request_stream_fds[i] == fd:
                return self.proxy_request_stream_items[i]
            i = i + 1
        nil

    me proxy_request_stream_set(fd: i64, stream: AsyncProxyRequestBodyStream):
        var i = 0
        while i < self.proxy_request_stream_fds.len() and i < self.proxy_request_stream_items.len():
            if self.proxy_request_stream_fds[i] == fd:
                self.proxy_request_stream_items[i] = stream
                return
            i = i + 1
        self.proxy_request_stream_fds.push(fd)
        self.proxy_request_stream_items.push(stream)

    me proxy_request_stream_remove(fd: i64):
        var next_fds: [i64] = []
        var next_items: [AsyncProxyRequestBodyStream] = []
        var i = 0
        while i < self.proxy_request_stream_fds.len() and i < self.proxy_request_stream_items.len():
            if self.proxy_request_stream_fds[i] != fd:
                next_fds.push(self.proxy_request_stream_fds[i])
                next_items.push(self.proxy_request_stream_items[i])
            i = i + 1
        self.proxy_request_stream_fds = next_fds
        self.proxy_request_stream_items = next_items
        self.proxy_request_body_send_inflight_fds = self.fd_list_without(self.proxy_request_body_send_inflight_fds, fd)
        self.proxy_request_body_recv_inflight_fds = self.fd_list_without(self.proxy_request_body_recv_inflight_fds, fd)

    me proxy_last_hardening_evidence() -> AsyncProxyProductionHardeningEvidence?:
        self.last_proxy_hardening_evidence

    me record_proxy_hardening_evidence(client_fd: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        var stream = async_proxy_request_stream("", 0, false, WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES)
        val active_stream = self.proxy_request_stream_get(client_fd)
        if active_stream.?:
            stream = active_stream
        self.last_proxy_hardening_evidence = async_proxy_connection_production_hardening(
            proxy,
            stream,
            self.proxy_upstream_pool,
            self.proxy_pool_config,
            now
        )

    me proxy_request_body_send_inflight(client_fd: i64) -> bool:
        if not self.fd_list_contains(self.proxy_request_body_send_inflight_fds, client_fd):
            return false
        worker_tracked_op_exists(self.op_fds, self.op_kinds, client_fd, OP_PROXY_SEND_REQUEST_BODY)

    me proxy_request_body_recv_inflight(client_fd: i64) -> bool:
        if not self.fd_list_contains(self.proxy_request_body_recv_inflight_fds, client_fd):
            return false
        worker_tracked_op_exists(self.op_fds, self.op_kinds, client_fd, OP_PROXY_RECV_CLIENT_BODY)

    me proxy_request_body_mark_send_inflight(client_fd: i64):
        if not self.proxy_request_body_send_inflight(client_fd):
            self.proxy_request_body_send_inflight_fds.push(client_fd)

    me proxy_request_body_mark_recv_inflight(client_fd: i64):
        if not self.proxy_request_body_recv_inflight(client_fd):
            self.proxy_request_body_recv_inflight_fds.push(client_fd)

    me proxy_request_body_clear_send_inflight(client_fd: i64):
        self.proxy_request_body_send_inflight_fds = self.fd_list_without(self.proxy_request_body_send_inflight_fds, client_fd)

    me proxy_request_body_clear_recv_inflight(client_fd: i64):
        self.proxy_request_body_recv_inflight_fds = self.fd_list_without(self.proxy_request_body_recv_inflight_fds, client_fd)

    me track_tunnel_fd(fd: i64):
        if not self.fd_list_contains(self.proxy_tunnel_fds, fd):
            self.proxy_tunnel_fds.push(fd)

    me untrack_tunnel_fd(fd: i64):
        self.proxy_tunnel_fds = self.fd_list_without(self.proxy_tunnel_fds, fd)

    me proxy_tunnel_get(fd: i64) -> AsyncProxyTunnelConnection?:
        var i = 0
        while i < self.proxy_tunnel_fds.len() and i < self.proxy_tunnel_items.len():
            if self.proxy_tunnel_fds[i] == fd:
                return self.proxy_tunnel_items[i]
            i = i + 1
        nil

    me proxy_tunnel_set(fd: i64, tunnel: AsyncProxyTunnelConnection):
        var i = 0
        while i < self.proxy_tunnel_fds.len() and i < self.proxy_tunnel_items.len():
            if self.proxy_tunnel_fds[i] == fd:
                self.proxy_tunnel_items[i] = tunnel
                return
            i = i + 1
        self.proxy_tunnel_fds.push(fd)
        self.proxy_tunnel_items.push(tunnel)

    me proxy_tunnel_remove(fd: i64):
        var next_fds: [i64] = []
        var next_items: [AsyncProxyTunnelConnection] = []
        var i = 0
        while i < self.proxy_tunnel_fds.len() and i < self.proxy_tunnel_items.len():
            if self.proxy_tunnel_fds[i] != fd:
                next_fds.push(self.proxy_tunnel_fds[i])
                next_items.push(self.proxy_tunnel_items[i])
            i = i + 1
        self.proxy_tunnel_fds = next_fds
        self.proxy_tunnel_items = next_items

    me handle_completion(op_id: i64, result: i64, completion_index: i64, now: i64):
        """Handle a non-accept I/O completion."""
        val tracked = self.take_op(op_id)
        val fd = tracked.0
        if fd < 0:
            val io_fd = self.driver.poll_fd(completion_index)
            if io_fd >= 0:
                val tunnel_client_fd = self.proxy_tunnel_client_for_upstream_fd(io_fd)
                if tunnel_client_fd >= 0 and result > 0:
                    val raw = self.driver.poll_recv_bytes(completion_index)
                    val data = self.proxy_tunnel_completion_bytes(completion_index, raw, result)
                    val text = self.proxy_tunnel_completion_text(completion_index, data, result)
                    self.handle_proxy_tunnel_recv_upstream(tunnel_client_fd, text, data, result, now)
                    return
                val client_fd = self.proxy_client_for_upstream_fd(io_fd)
                if client_fd >= 0 and result > 0:
                    val data = self.proxy_response_completion_text(completion_index, result)
                    self.handle_proxy_recv_response(client_fd, data, result, now)
                    return
            return

        var typ = tracked.2
        val io_fd = tracked.1
        if typ == 0 and self.fd_list_contains(self.connection_fds, fd):
            typ = OP_RECV

        if typ >= 1 and typ <= 1:
            val recv_is_h2 = self.fd_list_contains(self.h2_connection_fds, fd)
            if result == 0:
                if recv_is_h2:
                    self.close_h2_connection(fd)
                else:
                    self.close_connection(fd)
            else:
                val recv_data = self.driver.poll_data(completion_index)
                val recv_raw_bytes = if recv_is_h2: self.driver.poll_recv_bytes(completion_index) else: []
                self.handle_recv(fd, recv_data, recv_raw_bytes, now)
            return

        if worker_op_is(typ, 20):
            if result < 0:
                self.proxy_mark_failure_for_client(fd, now)
                self.cleanup_proxy_for_client(fd)
                self.send_error(fd, 504, "Proxy upstream connect failed", now)
            else:
                self.handle_proxy_connect(fd, result, now)
            return
        elif worker_op_is(typ, 21):
            if result < 0:
                self.proxy_mark_failure_for_client(fd, now)
                self.cleanup_proxy_for_client(fd)
                self.send_error(fd, 502, "Proxy upstream request failed", now)
            else:
                self.handle_proxy_send_request(fd, result, now)
            return
        elif worker_op_is(typ, 30):
            self.proxy_request_body_clear_send_inflight(fd)
            self.handle_proxy_send_request_body(fd, result, now)
            return
        elif worker_op_is(typ, 31):
            self.proxy_request_body_clear_recv_inflight(fd)
            if result == 0:
                val stream = self.proxy_request_stream_get(fd)
                if stream.? and stream.complete:
                    self.proxy_request_stream_remove(fd)
                    val proxy = self.proxy_connection_get(fd)
                    if proxy.?:
                        val upstream_fd = proxy.upstream_fd
                        val recv_op = self.driver.submit_recv(upstream_fd, 8192)
                        self.track_io_op(recv_op, fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
                    return
                if stream.?:
                    val retry_body_recv_op = self.driver.submit_timeout(1)
                    self.track_op(retry_body_recv_op, fd, OP_PROXY_POLL_CLIENT_BODY)
                    return
                self.proxy_mark_failure_for_client(fd, now)
                self.cleanup_proxy_for_client(fd)
                self.send_error(fd, 400, "Proxy client request body ended early", now)
            elif result < 0:
                self.proxy_mark_failure_for_client(fd, now)
                self.cleanup_proxy_for_client(fd)
                self.send_error(fd, 400, "Proxy client request body ended early", now)
            else:
                val data = self.driver.poll_data(completion_index)
                self.handle_proxy_recv_client_body(fd, data, now)
            return
        elif worker_op_is(typ, 32):
            self.poll_proxy_client_body_now(fd, now)
            return
        elif worker_op_is(typ, 33):
            self.retry_proxy_send_request_body(fd, now)
            return
        elif worker_op_is(typ, 22):
            val response_client_fd = fd
            if result < 0:
                self.proxy_mark_failure_for_client(response_client_fd, now)
                self.cleanup_proxy_for_client(response_client_fd)
                self.send_error(response_client_fd, 502, "Proxy upstream read failed", now)
            else:
                val data = self.proxy_response_completion_text(completion_index, result)
                self.handle_proxy_recv_response(response_client_fd, data, result, now)
            return
        elif worker_op_is(typ, 23):
            if result < 0:
                self.close_proxy_connection(fd)
            else:
                self.handle_proxy_send_client(fd, result, now)
            return
        elif worker_op_is(typ, 24):
            if result < 0:
                self.proxy_mark_tunnel_failure_for_client(fd, now)
                self.cleanup_proxy_tunnel_for_client(fd)
                self.send_error(fd, 504, "Proxy tunnel upstream connect failed", now)
            else:
                self.handle_proxy_tunnel_connect(fd, result, now)
            return
        elif worker_op_is(typ, 25):
            if result < 0:
                self.proxy_mark_tunnel_failure_for_client(fd, now)
                self.close_proxy_tunnel_connection(fd)
            else:
                self.handle_proxy_tunnel_send_setup(fd, result, now)
            return
        elif worker_op_is(typ, 26):
            if result <= 0:
                self.close_proxy_tunnel_connection(fd)
            else:
                val raw = self.driver.poll_recv_bytes(completion_index)
                val data = self.proxy_tunnel_completion_bytes(completion_index, raw, result)
                self.handle_proxy_tunnel_recv_client(fd, data, result, now)
            return
        elif worker_op_is(typ, 27):
            if result < 0:
                self.proxy_mark_tunnel_failure_for_client(fd, now)
                self.close_proxy_tunnel_connection(fd)
            else:
                self.handle_proxy_tunnel_send_upstream(fd, result, now)
            return
        elif worker_op_is(typ, 28):
            if result <= 0:
                self.close_proxy_tunnel_connection(fd)
            else:
                var tunnel_client_fd = fd
                if not self.proxy_tunnel_get(tunnel_client_fd).?:
                    tunnel_client_fd = self.proxy_tunnel_client_for_upstream_fd(io_fd)
                if tunnel_client_fd < 0:
                    tunnel_client_fd = self.proxy_tunnel_client_for_upstream_fd(fd)
                if tunnel_client_fd < 0:
                    tunnel_client_fd = self.proxy_tunnel_client_for_upstream_fd(self.driver.poll_fd(completion_index))
                if tunnel_client_fd < 0 or not self.proxy_tunnel_get(tunnel_client_fd).?:
                    return
                val raw = self.driver.poll_recv_bytes(completion_index)
                val data = self.proxy_tunnel_completion_bytes(completion_index, raw, result)
                val text = self.proxy_tunnel_completion_text(completion_index, data, result)
                self.handle_proxy_tunnel_recv_upstream(tunnel_client_fd, text, data, result, now)
            return
        elif worker_op_is(typ, 29):
            if result < 0:
                self.close_proxy_tunnel_connection(fd)
            else:
                self.handle_proxy_tunnel_send_client(fd, result, now)
            return

        val is_h2 = self.fd_list_contains(self.h2_connection_fds, fd)

        if result < 0:
            if worker_op_is(typ, 4):
                self.sendfile_pending.remove(fd)
            if worker_op_is(typ, 3):
                val open_file = self.sendfile_open_files.get(fd)
                if open_file.?:
                    self.driver.submit_close(open_file)
                    self.sendfile_open_files.remove(fd)
            if is_h2:
                self.close_h2_connection(fd)
            else:
                self.close_connection(fd)
            return

        if worker_op_is(typ, 1):
            if result == 0:
                if is_h2:
                    self.close_h2_connection(fd)
                else:
                    self.close_connection(fd)
            else:
                val data = self.driver.poll_data(completion_index)
                val raw_bytes = if is_h2: self.driver.poll_recv_bytes(completion_index) else: []
                self.handle_recv(fd, data, raw_bytes, now)

        elif worker_op_is(typ, 2):
            # Check if there's a pending sendfile for this fd
            val pending = self.sendfile_pending.get(fd)
            if pending.?:
                self.sendfile_pending.remove(fd)
                val sf_op = self.driver.submit_sendfile_path(fd, pending.0, pending.1, pending.2)
                self.track_op(sf_op, fd, OP_SENDFILE)
            else:
                self.handle_send_complete(fd, now)

        elif worker_op_is(typ, 4):
            val pending = self.sendfile_pending.get(fd)
            if not pending.?:
                self.driver.submit_close(result)
                if is_h2:
                    self.close_h2_connection(fd)
                else:
                    self.close_connection(fd)
                return
            val offset = pending.1
            val length = pending.2
            self.sendfile_pending.remove(fd)
            self.sendfile_open_files[fd] = result
            val sf_op = self.driver.submit_sendfile(fd, result, offset, length)
            self.track_op(sf_op, fd, OP_SENDFILE)

        elif worker_op_is(typ, OP_DIRECT_STATIC_SENDFILE):
            self.handle_direct_static_sendfile_complete(fd, now)

        elif worker_op_is(typ, 3):
            val open_file = self.sendfile_open_files.get(fd)
            if open_file.?:
                self.sendfile_open_files.remove(fd)
                val close_op = self.driver.submit_close(open_file)
                self.track_op(close_op, fd, OP_CLOSE_SENDFILE)
            else:
                self.handle_send_complete(fd, now)

        elif worker_op_is(typ, 5):
            self.handle_send_complete(fd, now)

    me handle_recv(fd: i64, data: text, raw_bytes: [u8], now: i64):
        """Handle data received on a connection.

        When a TLS session exists for this fd, raw bytes are accumulated in
        tls_rx_buf, complete TLS records are decrypted with tls_decrypt_record,
        and the plaintext is fed to the connection parser. Partial records are
        held in the accumulator until the next recv completes them.
        """
        # H2 connections are routed separately — feed raw bytes to avoid UTF-8 corruption.
        # Keep the HTTP/1 hot path off native Dict.get; only H2 fds touch the H2 map.
        if self.fd_list_contains(self.h2_connection_fds, fd):
            val h2conn = self.h2_connections.get(fd)
            if h2conn.?:
                self.handle_h2_recv(fd, raw_bytes, now)
            return

        # h2c (cleartext HTTP/2) preface detection
        val h2c_ok = raw_bytes.len() >= 5 and raw_bytes[0] == 80 and raw_bytes[1] == 82 and raw_bytes[2] == 73
        if h2c_ok:
            self.http1_connection_remove(fd)
            val peer = tcp_backend_local_addr(fd) ?? "unknown"
            var h2conn = H2Connection.new(fd, peer, now)
            # Send server SETTINGS (empty = use defaults)
            var server_settings: [u8] = [0, 0, 0, 4, 0, 0, 0, 0, 0]
            val ss_op = self.driver.submit_send_bytes(fd, server_settings)
            self.track_op(ss_op, fd, OP_SEND)
            h2conn.settings_sent = true
            # Process initial bytes (preface + client SETTINGS)
            h2conn.h2_on_data_received(raw_bytes, now)
            h2conn.consume_frames()
            # Flush pending writes (SETTINGS ACK from consume_frames)
            val out = h2conn.take_pending_writes()
            if out.len() > 0:
                val out_op = self.driver.submit_send_bytes(fd, out)
                self.track_op(out_op, fd, OP_SEND)
            self.h2_connections[fd] = h2conn
            self.track_h2_fd(fd)
            val recv_op = self.driver.submit_recv(fd, 8192)
            self.track_op(recv_op, fd, OP_RECV)
            return

        # TLS application data decryption path. Plain HTTP/1 workers skip the
        # TLS session map entirely because native Dict.get is not reliable yet.
        val tls_session = if self.tls_config.?: self.tls_sessions.get(fd) else: nil
        if tls_session.?:
            var session = tls_session
            # Append new bytes to per-connection accumulator
            var acc = self.tls_rx_buf.get(fd) ?? []
            for b in raw_bytes:
                acc.push(b)
            # Process all complete TLS records in the accumulator
            var plaintext_all = ""
            var consumed = 0
            var tls_more = true
            while tls_more and (acc.len() - consumed >= TLS_RECORD_HEADER_SIZE):
                val rec_len = (acc[consumed + 3].to_i64() * 256) + acc[consumed + 4].to_i64()
                val total_needed = TLS_RECORD_HEADER_SIZE + rec_len
                if acc.len() - consumed < total_needed:
                    # Partial record — stop and wait for more data
                    tls_more = false
                else:
                    # Extract one complete record
                    var rec: [u8] = []
                    var ri = consumed
                    while ri < consumed + total_needed:
                        rec.push(acc[ri])
                        ri = ri + 1
                    val pt = tls_decrypt_record(rec, session)
                    if pt.?:
                        plaintext_all = plaintext_all + pt
                        session.client_seq = session.client_seq + 1
                    consumed = consumed + total_needed
            # Keep un-consumed bytes in the accumulator
            var remaining: [u8] = []
            var ri2 = consumed
            while ri2 < acc.len():
                remaining.push(acc[ri2])
                ri2 = ri2 + 1
            self.tls_rx_buf[fd] = remaining
            self.tls_sessions[fd] = session
            if plaintext_all.len() == 0:
                # No complete records yet — keep reading
                val op = self.driver.submit_recv(fd, 8192)
                self.track_op(op, fd, OP_RECV)
                return
            # Feed decrypted plaintext into the connection parser
            val conn_tls = self.http1_connection_get(fd)
            if not conn_tls.?:
                return
            var c_tls = conn_tls
            val action_tls = c_tls.on_data_received(plaintext_all, now)
            self.http1_connection_set(fd, c_tls)
            match action_tls:
                ConnectionAction.ContinueReading:
                    val op = self.driver.submit_recv(fd, 8192)
                    self.track_op(op, fd, OP_RECV)
                ConnectionAction.RequestReady:
                    self.process_request(fd, now)
                ConnectionAction.Close:
                    self.close_connection(fd)
                ConnectionAction.Error(status, msg):
                    self.send_error(fd, status, msg, now)
                ConnectionAction.WriteResponse(body):
                    self.send_response(fd, default_response_data(200, "OK", body), now)
                ConnectionAction.SendFile(path, offset, length):
                    var resp_tls = default_response_data(200, "OK", "")
                    resp_tls.body_file = path
                    resp_tls.body_offset = offset
                    resp_tls.body_length = length
                    self.send_response(fd, resp_tls, now)
            return

        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return

        if self.try_direct_static_get(fd, data, now):
            return

        if self.has_proxy_routes:
            if self.try_start_proxy_from_streaming_headers(fd, data, now):
                return
            if self.try_start_proxy_from_complete_headers(fd, data, now):
                return

        var c = conn
        val action = c.on_data_received_bytes(data, raw_bytes, now)
        self.http1_connection_set(fd, c)
        if self.has_proxy_routes:
            if self.try_start_proxy_from_parser_streaming_body(fd, c, now):
                return

        match action:
            ConnectionAction.ContinueReading:
                val op = self.driver.submit_recv(fd, 8192)
                self.track_op(op, fd, OP_RECV)

            ConnectionAction.RequestReady:
                self.process_request(fd, now)

            ConnectionAction.Close:
                self.close_connection(fd)

            ConnectionAction.Error(status, msg):
                self.send_error(fd, status, msg, now)

            ConnectionAction.WriteResponse(body):
                self.send_response(fd, default_response_data(200, "OK", body), now)

            ConnectionAction.SendFile(path, offset, length):
                var resp = default_response_data(200, "OK", "")
                resp.body_file = path
                resp.body_offset = offset
                resp.body_length = length
                self.send_response(fd, resp, now)

    me try_direct_static_get(fd: i64, data: text, now: i64) -> bool:
        # ponytail: only bypass parser for one safe static GET shape; parser handles everything else.
        if self.has_proxy_routes or self.tls_config.?:
            return false
        if self.config.locations.len() != 1:
            return false
        val location = self.config.locations[0]
        if location.handler_type != "static" or location.pattern != "/" or location.middlewares.len() != 0:
            return false
        if location.match_type != "prefix" and location.match_type != "":
            return false
        if not data.starts_with("GET "):
            return false
        val header_end = data.index_of("\r\n\r\n")
        if header_end < 0 or header_end + 4 != data.len():
            return false
        val target_end_rel = data.slice(4, data.len()).index_of(" ")
        if target_end_rel <= 0:
            return false
        val path = data.slice(4, 4 + target_end_rel)
        if not path.starts_with("/") or path.contains("?"):
            return false

        val head = data.slice(0, header_end)
        var keepalive = false
        val first_eol = head.index_of("\r\n")
        val one_host_header = if first_eol > 0:
            val rest = head.slice(first_eol + 2, head.len())
            rest.index_of("\r\n") < 0 and (rest.starts_with("Host:") or rest.starts_with("host:"))
        else:
            false
        if one_host_header:
            keepalive = head.contains("HTTP/1.1")
        else:
            val lower_head = head.lower()
            if lower_head.contains("\r\nrange:") or lower_head.contains("\r\nif-range:"):
                return false
            keepalive = lower_head.contains("http/1.1") and not lower_head.contains("\r\nconnection: close")

        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return false
        var c = conn
        c.keepalive = keepalive
        c.last_activity = now
        self.http1_connection_set(fd, c)

        self.try_send_static_path(fd, location, path, now)

    me try_start_proxy_streaming_request(fd: i64, request: HttpRequestData, now: i64) -> bool:
        val location_opt = self.find_config_location(request)
        if not location_opt.?:
            return false
        val location = location_opt
        if not async_proxy_route_enabled(location):
            return false
        if async_proxy_tunnel_requested(request):
            self.start_proxy_tunnel(fd, request, location, [], now)
            return true
        val phase_result = self.run_builtin_request_phases(request)
        match phase_result:
            PhaseResult.Respond(status, reason, headers, body):
                val resp = build_phase_response(status, reason, headers, body)
                self.send_response(fd, resp, now)
                return true
            PhaseResult.Error(status, msg):
                self.send_error(fd, status, msg, now)
                return true
            PhaseResult.Continue:
                val phase_allowed = true
            PhaseResult.Skip:
                val phase_allowed = true
        val location_for_proxy = location
        self.start_proxy(fd, request, location_for_proxy, now)
        true

    me try_start_proxy_from_parser_streaming_body(fd: i64, conn: Connection, now: i64) -> bool:
        if not conn.parser.streaming_request_ready(WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES):
            return false
        val request = conn.parser.to_streaming_request(conn.peer_addr)
        self.try_start_proxy_streaming_request(fd, request, now)

    me try_start_proxy_from_streaming_headers(fd: i64, data: text, now: i64) -> bool:
        """Start fixed-body proxy streaming as soon as headers are complete.

        The normal HTTP parser waits for the full Content-Length body before
        yielding RequestReady. For large proxy uploads, that defeats worker-level
        streaming and forces request buffering. This path only takes ownership
        when the header block is complete, the request is a fixed-length body
        that requires streaming, and routing selects a proxy location.
        """
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return false
        val parsed = async_proxy_parse_header_request(data, conn.peer_addr)
        if not parsed.ok:
            return false
        val request_body_is_chunked = async_proxy_request_transfer_chunked(parsed.request)
        val declared_body_bytes = async_proxy_request_content_length(parsed.request)
        val fixed_body_requires_stream = declared_body_bytes > WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES
        var should_stream_request_body = request_body_is_chunked
        if fixed_body_requires_stream:
            should_stream_request_body = true
        if not should_stream_request_body:
            return false
        self.try_start_proxy_streaming_request(fd, parsed.request, now)

    me try_start_proxy_from_complete_headers(fd: i64, data: text, now: i64) -> bool:
        """Start proxy routes from complete headers without waiting on parser state."""
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return false
        val parsed = async_proxy_parse_header_request(data, conn.peer_addr)
        if not parsed.ok:
            return false
        if async_proxy_request_transfer_chunked(parsed.request):
            return false
        val expected_body = async_proxy_request_content_length(parsed.request)
        if expected_body > parsed.body_fragment.len():
            return false
        val location_opt = self.find_config_location(parsed.request)
        if not location_opt.?:
            return false
        val location = location_opt
        if not async_proxy_route_enabled(location):
            var req = parsed.request
            req.params = {}
            var c = conn
            c.request = req
            c.state = ConnectionState.Routing
            self.http1_connection_set(fd, c)
            self.process_request(fd, now)
            return true
        if async_proxy_tunnel_requested(parsed.request):
            self.start_proxy_tunnel(fd, parsed.request, location, [], now)
            return true
        val phase_result = self.run_builtin_request_phases(parsed.request)
        match phase_result:
            PhaseResult.Respond(status, reason, headers, body):
                val resp = build_phase_response(status, reason, headers, body)
                self.send_response(fd, resp, now)
                return true
            PhaseResult.Error(status, msg):
                self.send_error(fd, status, msg, now)
                return true
            PhaseResult.Continue:
                val phase_allowed = true
            PhaseResult.Skip:
                val phase_allowed = true
        self.start_proxy(fd, parsed.request, location, now)
        return true

    me handle_send_complete(fd: i64, now: i64):
        """Handle write completion on a connection."""
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return

        var c = conn
        val action = c.on_write_complete(now)
        self.http1_connection_set(fd, c)

        match action:
            ConnectionAction.ContinueReading:
                val op = self.driver.submit_recv(fd, 8192)
                self.track_op(op, fd, OP_RECV)

            ConnectionAction.Close:
                self.close_connection(fd)

            ConnectionAction.ContinueReading:
                return

            ConnectionAction.RequestReady:
                self.process_request(fd, now)

            ConnectionAction.WriteResponse(body):
                self.send_response(fd, default_response_data(200, "OK", body), now)

            ConnectionAction.SendFile(path, offset, length):
                var resp = default_response_data(200, "OK", "")
                resp.body_file = path
                resp.body_offset = offset
                resp.body_length = length
                self.send_response(fd, resp, now)

            ConnectionAction.Error(status, msg):
                self.send_error(fd, status, msg, now)

    me handle_direct_static_sendfile_complete(fd: i64, now: i64):
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return
        var c = conn
        c.last_activity = now
        c.requests_count = c.requests_count + 1
        if c.is_draining():
            c.state = ConnectionState.Closing
            self.http1_connection_set(fd, c)
            self.close_connection(fd)
            return
        if c.keepalive:
            c.reset_for_keepalive()
            self.http1_connection_set(fd, c)
            val op = self.driver.submit_recv(fd, 8192)
            self.track_op(op, fd, OP_RECV)
        else:
            c.state = ConnectionState.Closing
            self.http1_connection_set(fd, c)
            self.close_connection(fd)

    # ========================================================================
    # Request Processing
    # ========================================================================

    me start_proxy_tunnel(fd: i64, request: HttpRequestData, location: LocationConfig,
                          initial_client_bytes: [u8], now: i64):
        """Start a worker-owned bidirectional tunnel for Upgrade/CONNECT routes."""
        val peers = self.proxy_peers_for_upstream(location.proxy_pass)
        val plan = async_proxy_tunnel_plan_with_peers(location, request, self.config.upstreams, peers, fd, now)
        if not plan.ok:
            self.send_response(fd, build_error(plan.status, plan.reason), now)
            return

        val setup_wire = if plan.tunnel_kind == "connect": "" else: async_proxy_serialize_tunnel_request(request, plan.upstream_addr)
        var tunnel = async_proxy_tunnel_connection(fd, -1, plan.upstream_addr, plan.tunnel_kind, setup_wire, now)
        if initial_client_bytes.len() > 0:
            tunnel = async_proxy_tunnel_queue_client_bytes(tunnel, initial_client_bytes, now)
        self.proxy_mark_peer_begin(plan.upstream_addr)
        self.proxy_tunnel_set(fd, tunnel)
        self.track_tunnel_fd(fd)

        val op = self.driver.submit_connect_timeout(plan.upstream_addr, 1000)
        self.track_op(op, fd, OP_PROXY_TUNNEL_CONNECT)

    me start_proxy(fd: i64, request: HttpRequestData, location: LocationConfig, now: i64):
        """Start the worker-level reverse proxy state machine."""
        val peers = self.proxy_peers_for_upstream(location.proxy_pass)
        val request_body_is_chunked = async_proxy_request_transfer_chunked(request)
        val declared_body_bytes = async_proxy_request_content_length(request)
        var stream_request_body = request_body_is_chunked
        if declared_body_bytes > WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES:
            stream_request_body = true
        val plan = if stream_request_body:
            async_proxy_plan_with_peers_for_request_stream(location, request, self.config.upstreams, peers, fd, now)
        else:
            async_proxy_plan_with_peers(location, request, self.config.upstreams, peers, fd, now)
        if not plan.ok:
            self.send_response(fd, build_error(plan.status, plan.reason), now)
            return

        var wire = ""
        if stream_request_body:
            var body_stream: AsyncProxyRequestBodyStream
            if request_body_is_chunked:
                body_stream = async_proxy_request_body_stream_begin(
                    request,
                    plan.upstream_addr,
                    WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES
                )
                if request.body != "":
                    body_stream = async_proxy_request_stream_receive_chunked_passthrough(body_stream, request.body)
            else:
                body_stream = async_proxy_request_body_stream_begin(
                    request,
                    plan.upstream_addr,
                    WORKER_PROXY_MAX_BUFFERED_REQUEST_BODY_BYTES
                )
                body_stream = async_proxy_request_stream_receive_fixed(body_stream, request.body)
            var startup_body_over_budget = false
            if not request_body_is_chunked:
                startup_body_over_budget = async_proxy_request_pending_over_budget(body_stream)
            if not body_stream.valid or startup_body_over_budget:
                self.send_response(fd, build_error(413, "Proxy request body streaming failed"), now)
                return
            if body_stream.pending_upstream_data != "":
                wire = "{body_stream.header_wire}{body_stream.pending_upstream_data}"
                body_stream = async_proxy_request_stream_mark_upstream_sent(
                    body_stream,
                    body_stream.pending_upstream_data.len()
                )
            else:
                wire = body_stream.header_wire
            self.proxy_request_stream_set(fd, body_stream)
        else:
            wire = async_proxy_serialize_request(request, plan.upstream_addr)
        val proxy = async_proxy_connection(fd, plan.upstream_addr, wire, now)
        self.proxy_mark_peer_begin(plan.upstream_addr)
        self.proxy_connection_set(fd, proxy)
        self.track_proxy_fd(fd)
        if stream_request_body:
            val stream_op = self.driver.submit_connect_timeout(plan.upstream_addr, proxy.connect_timeout_ms)
            self.track_op(stream_op, fd, OP_PROXY_CONNECT)
            return
        val pooled = async_proxy_pool_acquire(
            self.proxy_upstream_pool,
            plan.upstream_addr,
            self.proxy_pool_config,
            now
        )
        if pooled.ok:
            self.proxy_pool_mark_fd_acquired(pooled.upstream_fd, now)
            var p = proxy
            p.upstream_fd = pooled.upstream_fd
            p.last_activity_ms = now
            self.proxy_connection_set(fd, p)
            self.proxy_client_by_upstream[pooled.upstream_fd] = fd
            val send_op = self.driver.submit_send(pooled.upstream_fd, p.request_wire)
            self.track_io_op(send_op, fd, pooled.upstream_fd, OP_PROXY_SEND_REQUEST)
            return
        val op = self.driver.submit_connect_timeout(plan.upstream_addr, proxy.connect_timeout_ms)
        self.track_op(op, fd, OP_PROXY_CONNECT)

    me proxy_mark_tunnel_failure_for_client(client_fd: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if tunnel.?:
            self.proxy_mark_peer_failure_open(tunnel.upstream_addr, now)

    me handle_proxy_tunnel_connect(client_fd: i64, upstream_fd: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            tcp_backend_close(upstream_fd)
            return

        tcp_backend_set_nonblocking(upstream_fd, true)
        tcp_backend_set_nodelay(upstream_fd, true)

        var t = tunnel
        t.upstream_fd = upstream_fd
        t.last_activity_ms = now
        self.proxy_tunnel_set(client_fd, t)
        self.proxy_tunnel_client_by_upstream[upstream_fd] = client_fd

        val setup = async_proxy_tunnel_setup_remaining(t)
        if setup != "":
            val send_op = self.driver.submit_send(upstream_fd, setup)
            self.track_io_op(send_op, client_fd, upstream_fd, OP_PROXY_TUNNEL_SEND_SETUP)
            return

        val connect_ok = "HTTP/1.1 200 Connection Established\r\nConnection: close\r\n\r\n"
        t.upstream_handshake_complete = true
        t = async_proxy_tunnel_queue_upstream_data(t, connect_ok, now)
        self.proxy_tunnel_set(client_fd, t)
        val send_client_op = self.driver.submit_send(client_fd, t.pending_upstream_to_client)
        self.track_op(send_client_op, client_fd, OP_PROXY_TUNNEL_SEND_CLIENT)

    me handle_proxy_tunnel_send_setup(client_fd: i64, sent: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        if sent <= 0:
            self.proxy_mark_tunnel_failure_for_client(client_fd, now)
            self.close_proxy_tunnel_connection(client_fd)
            return
        var t = async_proxy_tunnel_mark_setup_sent(tunnel, sent, now)
        self.proxy_tunnel_set(client_fd, t)
        val remaining = async_proxy_tunnel_setup_remaining(t)
        if remaining != "":
            val send_op = self.driver.submit_send(t.upstream_fd, remaining)
            self.track_io_op(send_op, client_fd, t.upstream_fd, OP_PROXY_TUNNEL_SEND_SETUP)
            return
        self.schedule_proxy_tunnel_reads(client_fd)

    me schedule_proxy_tunnel_reads(client_fd: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        var t = tunnel
        if async_proxy_tunnel_should_recv_client(tunnel):
            val client_op = self.driver.submit_recv(client_fd, 8192)
            self.track_op(client_op, client_fd, OP_PROXY_TUNNEL_RECV_CLIENT)
            t.client_recv_inflight = true
        if async_proxy_tunnel_should_recv_upstream(t):
            val upstream_op = self.driver.submit_recv(t.upstream_fd, 8192)
            self.track_io_op(upstream_op, client_fd, t.upstream_fd, OP_PROXY_TUNNEL_RECV_UPSTREAM)
            t.upstream_recv_inflight = true
        self.proxy_tunnel_set(client_fd, t)

    me send_proxy_tunnel_pending_client_data(client_fd: i64) -> bool:
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return false
        if not tunnel.upstream_handshake_complete:
            return false
        if tunnel.pending_client_to_upstream_bytes.len() > 0:
            val send_op = self.driver.submit_send_bytes(tunnel.upstream_fd, tunnel.pending_client_to_upstream_bytes)
            self.track_io_op(send_op, client_fd, tunnel.upstream_fd, OP_PROXY_TUNNEL_SEND_UPSTREAM)
            return true
        if tunnel.pending_client_to_upstream != "":
            val send_op = self.driver.submit_send(tunnel.upstream_fd, tunnel.pending_client_to_upstream)
            self.track_io_op(send_op, client_fd, tunnel.upstream_fd, OP_PROXY_TUNNEL_SEND_UPSTREAM)
            return true
        false

    me handle_proxy_tunnel_recv_client(client_fd: i64, data: [u8], size: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        var cleared = tunnel
        cleared.client_recv_inflight = false
        var t = cleared
        t.pending_client_to_upstream_bytes = data
        t.bytes_client_to_upstream = t.bytes_client_to_upstream + data.len()
        t.last_activity_ms = now
        if async_proxy_tunnel_pending_over_budget(t):
            self.proxy_mark_tunnel_failure_for_client(client_fd, now)
            self.close_proxy_tunnel_connection(client_fd)
            return
        self.proxy_tunnel_set(client_fd, t)
        val send_op = self.driver.submit_send_bytes(t.upstream_fd, t.pending_client_to_upstream_bytes)
        self.track_io_op(send_op, client_fd, t.upstream_fd, OP_PROXY_TUNNEL_SEND_UPSTREAM)

    me handle_proxy_tunnel_send_upstream(client_fd: i64, sent: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        if sent <= 0:
            self.proxy_mark_tunnel_failure_for_client(client_fd, now)
            self.close_proxy_tunnel_connection(client_fd)
            return
        var t = async_proxy_tunnel_mark_client_data_sent(tunnel, sent, now)
        self.proxy_tunnel_set(client_fd, t)
        if t.pending_client_to_upstream != "" or t.pending_client_to_upstream_bytes.len() > 0:
            if t.pending_client_to_upstream_bytes.len() > 0:
                val send_op = self.driver.submit_send_bytes(t.upstream_fd, t.pending_client_to_upstream_bytes)
                self.track_io_op(send_op, client_fd, t.upstream_fd, OP_PROXY_TUNNEL_SEND_UPSTREAM)
                return
            val send_op = self.driver.submit_send(t.upstream_fd, t.pending_client_to_upstream)
            self.track_io_op(send_op, client_fd, t.upstream_fd, OP_PROXY_TUNNEL_SEND_UPSTREAM)
            return
        self.schedule_proxy_tunnel_reads(client_fd)

    me handle_proxy_tunnel_recv_upstream(client_fd: i64, header_text: text, data: [u8], size: i64, now: i64):
        var resolved_client_fd = client_fd
        var tunnel = self.proxy_tunnel_get(resolved_client_fd)
        if not tunnel.?:
            resolved_client_fd = self.proxy_tunnel_client_for_upstream_fd(client_fd)
            tunnel = self.proxy_tunnel_get(resolved_client_fd)
        if not tunnel.?:
            return
        var cleared = tunnel
        cleared.upstream_recv_inflight = false
        var t = if cleared.upstream_handshake_complete:
            cleared
        else:
            async_proxy_tunnel_prepare_upstream_handshake(cleared, header_text, [], now)
        if cleared.upstream_handshake_complete:
            t.pending_upstream_to_client_bytes = data
            t.bytes_upstream_to_client = t.bytes_upstream_to_client + data.len()
            t.last_activity_ms = now
        if not t.upstream_handshake_valid:
            self.proxy_mark_tunnel_failure_for_client(resolved_client_fd, now)
            self.cleanup_proxy_tunnel_for_client(resolved_client_fd)
            self.send_error(resolved_client_fd, 502, t.upstream_handshake_error, now)
            return
        if async_proxy_tunnel_pending_over_budget(t):
            self.proxy_mark_tunnel_failure_for_client(resolved_client_fd, now)
            self.close_proxy_tunnel_connection(resolved_client_fd)
            return
        self.proxy_tunnel_set(resolved_client_fd, t)
        if t.pending_upstream_to_client != "":
            val send_op = self.driver.submit_send(resolved_client_fd, t.pending_upstream_to_client)
            self.track_op(send_op, resolved_client_fd, OP_PROXY_TUNNEL_SEND_CLIENT)
            return
        if t.pending_upstream_to_client_bytes.len() == 0:
            self.schedule_proxy_tunnel_reads(resolved_client_fd)
            return
        val send_op = self.driver.submit_send_bytes(resolved_client_fd, t.pending_upstream_to_client_bytes)
        self.track_op(send_op, resolved_client_fd, OP_PROXY_TUNNEL_SEND_CLIENT)

    me handle_proxy_tunnel_send_client(client_fd: i64, sent: i64, now: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        if sent <= 0:
            self.close_proxy_tunnel_connection(client_fd)
            return
        val pending_text_len = tunnel.pending_upstream_to_client.len()
        val pending_byte_len = tunnel.pending_upstream_to_client_bytes.len()
        var t = async_proxy_tunnel_mark_upstream_data_sent(tunnel, sent, now)
        if tunnel.upstream_handshake_complete and tunnel.bytes_client_to_upstream == 0:
            t.pending_upstream_to_client = ""
            t.pending_upstream_to_client_bytes = []
        elif sent >= pending_text_len + pending_byte_len:
            t.pending_upstream_to_client = ""
            t.pending_upstream_to_client_bytes = []
        if t.upstream_handshake_complete and t.pending_upstream_to_client == "" and t.pending_upstream_to_client_bytes.len() == 0:
            t.client_recv_inflight = false
        self.proxy_tunnel_set(client_fd, t)
        if t.pending_upstream_to_client != "" or t.pending_upstream_to_client_bytes.len() > 0:
            val send_op = if t.pending_upstream_to_client != "":
                self.driver.submit_send(client_fd, t.pending_upstream_to_client)
            else:
                self.driver.submit_send_bytes(client_fd, t.pending_upstream_to_client_bytes)
            self.track_op(send_op, client_fd, OP_PROXY_TUNNEL_SEND_CLIENT)
            return
        if self.send_proxy_tunnel_pending_client_data(client_fd):
            return
        self.schedule_proxy_tunnel_reads(client_fd)

    me proxy_config_peer(addr: text) -> AsyncProxyUpstreamPeer:
        var upstream_index = 0
        while upstream_index < self.config.upstreams.len():
            val upstream = self.config.upstreams[upstream_index]
            var server_index = 0
            while server_index < upstream.servers.len():
                val server = upstream.servers[server_index]
                if server.addr == addr:
                    return async_proxy_peer_from_server(server)
                server_index = server_index + 1
            upstream_index = upstream_index + 1
        AsyncProxyUpstreamPeer(
            addr: addr,
            weight: 1,
            max_fails: 0,
            fail_timeout_ms: 0,
            fail_count: 0,
            active_connections: 0,
            last_failure_ms: 0
        )

    me proxy_peer_state(addr: text) -> AsyncProxyUpstreamPeer:
        self.proxy_config_peer(addr)

    me proxy_peers_for_upstream(name: text) -> [AsyncProxyUpstreamPeer]:
        var peers: [AsyncProxyUpstreamPeer] = []
        var upstream_index = 0
        while upstream_index < self.config.upstreams.len():
            val upstream = self.config.upstreams[upstream_index]
            if upstream.name == name:
                var server_index = 0
                while server_index < upstream.servers.len():
                    val server = upstream.servers[server_index]
                    peers.push(async_proxy_peer_from_server(server))
                    server_index = server_index + 1
            upstream_index = upstream_index + 1
        peers

    me proxy_due_health_probes(name: text, now: i64,
                               interval_ms: i64,
                               max_probes: i64) -> [AsyncProxyHealthProbeDecision]:
        val peers = self.proxy_peers_for_upstream(name)
        async_proxy_due_health_probes(peers, self.proxy_health_probe_records, now, interval_ms, max_probes)

    me proxy_due_configured_health_probes(name: text, now: i64) -> [AsyncProxyHealthProbeDecision]:
        val peers = self.proxy_peers_for_upstream(name)
        var upstream_index = 0
        while upstream_index < self.config.upstreams.len():
            val upstream = self.config.upstreams[upstream_index]
            if upstream.name == name:
                return async_proxy_due_configured_health_probes(
                    upstream,
                    peers,
                    self.proxy_health_probe_records,
                    now
                )
            upstream_index = upstream_index + 1
        []

    me proxy_mark_health_probe_attempt(addr: text, now: i64):
        self.proxy_health_probe_records = async_proxy_mark_health_probe_attempt(
            self.proxy_health_probe_records,
            addr,
            now
        )

    me proxy_apply_health_probe_success(addr: text):
        val peer = self.proxy_peer_state(addr)

    me proxy_apply_health_probe_failure(addr: text, now: i64):
        val peer = self.proxy_peer_state(addr)

    me proxy_mark_peer_begin(addr: text):
        val peer = self.proxy_peer_state(addr)

    me proxy_mark_peer_finish(addr: text):
        val peer = self.proxy_peer_state(addr)

    me proxy_mark_peer_success_open(addr: text):
        var peer = self.proxy_peer_state(addr)
        peer.fail_count = 0

    me proxy_mark_peer_failure_open(addr: text, now: i64):
        var peer = self.proxy_peer_state(addr)
        peer.fail_count = peer.fail_count + 1
        peer.last_failure_ms = now

    me proxy_mark_failure_for_client(client_fd: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if proxy.?:
            self.proxy_mark_peer_failure_open(proxy.upstream_addr, now)

    me proxy_pool_mark_fd_acquired(upstream_fd: i64, now: i64):
        var i = 0
        while i < self.proxy_upstream_pool.len():
            if self.proxy_upstream_pool[i].upstream_fd == upstream_fd:
                self.proxy_upstream_pool[i] = async_proxy_pool_mark_acquired(self.proxy_upstream_pool[i], now)
                return
            i = i + 1

    me proxy_pool_mark_fd_closed(upstream_fd: i64, now: i64):
        var i = 0
        while i < self.proxy_upstream_pool.len():
            if self.proxy_upstream_pool[i].upstream_fd == upstream_fd:
                self.proxy_upstream_pool[i] = async_proxy_pool_mark_closed(self.proxy_upstream_pool[i], now)
                return
            i = i + 1

    me proxy_pool_release_fd(upstream_addr: text, upstream_fd: i64, now: i64):
        var i = 0
        while i < self.proxy_upstream_pool.len():
            if self.proxy_upstream_pool[i].upstream_fd == upstream_fd:
                self.proxy_upstream_pool[i] = async_proxy_pool_mark_released(self.proxy_upstream_pool[i], now)
                return
            i = i + 1
        var entry = async_proxy_pool_entry(upstream_addr, upstream_fd, now)
        entry = async_proxy_pool_mark_acquired(entry, now)
        self.proxy_upstream_pool.push(async_proxy_pool_mark_released(entry, now))

    me handle_proxy_connect(client_fd: i64, upstream_fd: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            tcp_backend_close(upstream_fd)
            return

        tcp_backend_set_nonblocking(upstream_fd, true)
        tcp_backend_set_nodelay(upstream_fd, true)

        var p = proxy
        p.upstream_fd = upstream_fd
        p.last_activity_ms = now
        self.proxy_connection_set(client_fd, p)
        self.proxy_client_by_upstream[upstream_fd] = client_fd

        val op = self.driver.submit_send(upstream_fd, p.request_wire)
        self.track_io_op(op, client_fd, upstream_fd, OP_PROXY_SEND_REQUEST)

    me handle_proxy_send_request(client_fd: i64, sent: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        if sent <= 0:
            self.proxy_mark_failure_for_client(client_fd, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, "Proxy upstream request stalled", now)
            return
        var p = async_proxy_mark_request_sent(proxy, sent, now)
        val remaining = async_proxy_request_remaining(p)
        self.proxy_connection_set(client_fd, p)
        val upstream_fd = proxy.upstream_fd
        if remaining != "":
            val send_op = self.driver.submit_send(upstream_fd, remaining)
            self.track_io_op(send_op, client_fd, upstream_fd, OP_PROXY_SEND_REQUEST)
            return
        val stream = self.proxy_request_stream_get(client_fd)
        if stream.?:
            if async_proxy_request_pending_over_budget(stream):
                self.proxy_mark_failure_for_client(client_fd, now)
                self.cleanup_proxy_for_client(client_fd)
                self.send_error(client_fd, 502, "Proxy request body backpressure exceeded", now)
                return
            if stream.pending_upstream_data != "":
                self.submit_proxy_request_body_send(client_fd, upstream_fd, stream.pending_upstream_data)
                return
            if stream.complete:
                self.proxy_request_stream_remove(client_fd)
            else:
                self.schedule_proxy_client_body_recv(client_fd)
                return
        val op = self.driver.submit_recv(upstream_fd, 8192)
        self.track_io_op(op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)

    me schedule_proxy_client_body_recv(client_fd: i64):
        val stream = self.proxy_request_stream_get(client_fd)
        if not stream.?:
            return
        if not async_proxy_should_recv_client_body(stream):
            return
        if self.proxy_request_body_recv_inflight(client_fd):
            return
        val op = self.driver.submit_recv(client_fd, WORKER_PROXY_REQUEST_BODY_CHUNK_BYTES)
        self.proxy_request_body_mark_recv_inflight(client_fd)
        self.track_op(op, client_fd, OP_PROXY_RECV_CLIENT_BODY)

    me submit_proxy_request_body_send(client_fd: i64, upstream_fd: i64, data: text):
        if self.proxy_request_body_send_inflight(client_fd):
            if worker_tracked_op_exists(self.op_fds, self.op_kinds, client_fd, OP_PROXY_RETRY_SEND_REQUEST_BODY):
                return
            val retry_op = self.driver.submit_timeout(1)
            self.track_op(retry_op, client_fd, OP_PROXY_RETRY_SEND_REQUEST_BODY)
            return
        var body_op: i64
        if data.len() > WORKER_PROXY_UPSTREAM_BODY_WRITE_BYTES:
            val chunk = data.slice(0, WORKER_PROXY_UPSTREAM_BODY_WRITE_BYTES)
            body_op = self.driver.submit_send(upstream_fd, chunk)
        else:
            body_op = self.driver.submit_send(upstream_fd, data)
        self.proxy_request_body_mark_send_inflight(client_fd)
        self.track_io_op(body_op, client_fd, upstream_fd, OP_PROXY_SEND_REQUEST_BODY)

    me poll_proxy_client_body_now(client_fd: i64, now: i64):
        val stream = self.proxy_request_stream_get(client_fd)
        if not stream.?:
            return
        if not async_proxy_should_recv_client_body(stream):
            return
        val bytes = rt_io_tcp_read(client_fd, WORKER_PROXY_REQUEST_BODY_CHUNK_BYTES)
        if bytes.len() > 0:
            val data = rt_bytes_to_text(bytes)
            self.handle_proxy_recv_client_body(client_fd, data, now)
            return
        val proxy = self.proxy_connection_get(client_fd)
        if proxy.? and async_proxy_timed_out(proxy, now):
            self.proxy_mark_failure_for_client(client_fd, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 408, "Proxy client request body timed out", now)
            return
        self.proxy_request_body_clear_recv_inflight(client_fd)
        self.schedule_proxy_client_body_recv(client_fd)

    me handle_proxy_recv_client_body(client_fd: i64, data: text, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        val stream = self.proxy_request_stream_get(client_fd)
        if not stream.?:
            return
        var next = if stream.chunked:
            async_proxy_request_stream_receive_chunked_passthrough(stream, data)
        else:
            async_proxy_request_stream_receive_fixed(stream, data)
        self.proxy_request_stream_set(client_fd, next)
        val upstream_fd = proxy.upstream_fd
        if not next.valid or async_proxy_request_pending_over_budget(next):
            self.proxy_mark_failure_for_client(client_fd, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 413, "Proxy request body streaming failed", now)
            return
        if next.pending_upstream_data != "":
            self.submit_proxy_request_body_send(client_fd, upstream_fd, next.pending_upstream_data)
            return
        if next.complete:
            self.proxy_request_stream_remove(client_fd)
            val op = self.driver.submit_recv(upstream_fd, 8192)
            self.track_io_op(op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
            return
        self.proxy_request_body_clear_recv_inflight(client_fd)
        self.schedule_proxy_client_body_recv(client_fd)

    me retry_proxy_send_request_body(client_fd: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        var active = proxy
        active.last_activity_ms = now
        self.proxy_connection_set(client_fd, active)
        val stream = self.proxy_request_stream_get(client_fd)
        if not stream.?:
            return
        if stream.pending_upstream_data != "":
            self.submit_proxy_request_body_send(client_fd, active.upstream_fd, stream.pending_upstream_data)
            return
        if stream.complete:
            self.proxy_request_stream_remove(client_fd)
            val upstream_fd = proxy.upstream_fd
            val op = self.driver.submit_recv(upstream_fd, 8192)
            self.track_io_op(op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
            return
        self.schedule_proxy_client_body_recv(client_fd)

    me handle_proxy_send_request_body(client_fd: i64, sent: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        val stream = self.proxy_request_stream_get(client_fd)
        if not stream.?:
            return
        if sent == 0:
            if stream.pending_upstream_data != "":
                val retry_body_op = self.driver.submit_timeout(1)
                self.track_op(retry_body_op, client_fd, OP_PROXY_RETRY_SEND_REQUEST_BODY)
                return
            self.schedule_proxy_client_body_recv(client_fd)
            return
        if sent < 0:
            if stream.pending_upstream_data != "":
                val retry_blocked_body_op = self.driver.submit_timeout(1)
                self.track_op(retry_blocked_body_op, client_fd, OP_PROXY_RETRY_SEND_REQUEST_BODY)
                return
            self.schedule_proxy_client_body_recv(client_fd)
            return
        var next = async_proxy_request_stream_mark_upstream_sent(stream, sent)
        self.proxy_request_stream_set(client_fd, next)
        val upstream_fd = proxy.upstream_fd
        if async_proxy_request_pending_over_budget(next):
            self.proxy_mark_failure_for_client(client_fd, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, "Proxy request body backpressure exceeded", now)
            return
        if next.pending_upstream_data != "":
            self.submit_proxy_request_body_send(client_fd, upstream_fd, next.pending_upstream_data)
            return
        if next.complete:
            self.proxy_request_stream_remove(client_fd)
            val op = self.driver.submit_recv(upstream_fd, 8192)
            self.track_io_op(op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
            return
        self.schedule_proxy_client_body_recv(client_fd)

    me handle_proxy_recv_response(client_fd: i64, data: text, size: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        if size == 0:
            if not proxy.response_headers_done and proxy.response_header_buffer == "":
                val upstream_fd = proxy.upstream_fd
                val retry_op = self.driver.submit_recv(upstream_fd, 8192)
                self.track_io_op(retry_op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
                return
            self.proxy_mark_peer_success_open(proxy.upstream_addr)
            self.close_proxy_connection(client_fd)
            return

        val response_looks_http1 = data.len() >= 7 and data.slice(0, 7) == "HTTP/1."
        val response_header_end = data.index_of("\r\n\r\n")
        if not proxy.response_headers_done and proxy.response_header_buffer == "" and response_looks_http1 and response_header_end >= 0:
            val split_at = response_header_end
            val head = data.slice(0, split_at)
            val body = data.slice(split_at + 4, data.len())
            var fast = proxy
            fast.response_headers_done = true
            fast.response_header_valid = true
            val response_wire = async_proxy_filter_response_headers(head)
            val pending_wire = "{response_wire}{body}"
            fast.response_client_header_wire = response_wire
            fast.expected_body_bytes = async_proxy_content_length(head)
            fast.upstream_reusable = async_proxy_response_allows_reuse(head)
            if not fast.upstream_reusable and head.starts_with("HTTP/1.1") and not head.to_lower().contains("connection: close"):
                fast.upstream_reusable = true
            fast.body_bytes_forwarded = body.len()
            if fast.expected_body_bytes >= 0 and fast.body_bytes_forwarded >= fast.expected_body_bytes:
                fast.response_complete = true
            fast.pending_client_data = pending_wire
            fast.last_activity_ms = now
            self.proxy_connection_set(client_fd, fast)
            val fast_send = self.driver.submit_send(client_fd, pending_wire)
            self.track_op(fast_send, client_fd, OP_PROXY_SEND_CLIENT)
            return

        var p = async_proxy_prepare_client_chunk(proxy, data, now)
        if p.bytes_from_upstream > p.max_response_bytes:
            self.proxy_mark_peer_failure_open(p.upstream_addr, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, "Proxy upstream response too large", now)
            return
        if not p.response_headers_done and p.response_header_buffer.len() > p.max_response_header_bytes:
            self.proxy_mark_peer_failure_open(p.upstream_addr, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, "Proxy upstream response headers too large", now)
            return
        if not p.response_header_valid:
            self.proxy_mark_peer_failure_open(p.upstream_addr, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, p.response_header_error, now)
            return
        if async_proxy_pending_client_over_budget(p):
            self.proxy_mark_peer_failure_open(p.upstream_addr, now)
            self.cleanup_proxy_for_client(client_fd)
            self.send_error(client_fd, 502, "Proxy client backpressure buffer too large", now)
            return

        self.proxy_connection_set(client_fd, p)
        if async_proxy_should_recv_upstream(p):
            val upstream_fd = p.upstream_fd
            val recv_budget = async_proxy_upstream_recv_budget(p, 8192)
            if recv_budget > 0:
                val recv_op = self.driver.submit_recv(upstream_fd, recv_budget)
                self.track_io_op(recv_op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)
            return
        if p.pending_client_data == "":
            return

        val send_op = self.driver.submit_send(client_fd, p.pending_client_data)
        self.proxy_connection_set(client_fd, p)
        self.track_op(send_op, client_fd, OP_PROXY_SEND_CLIENT)

    me handle_proxy_send_client(client_fd: i64, sent: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        if sent <= 0:
            self.close_proxy_connection(client_fd)
            return
        var p = proxy
        p.pending_client_data = async_proxy_remaining_after_send(p.pending_client_data, sent)
        p.last_activity_ms = now
        self.proxy_connection_set(client_fd, p)
        if p.pending_client_data != "":
            val send_op = self.driver.submit_send(client_fd, p.pending_client_data)
            self.track_op(send_op, client_fd, OP_PROXY_SEND_CLIENT)
            return
        if async_proxy_response_complete(p):
            self.proxy_mark_peer_success_open(p.upstream_addr)
            if async_proxy_response_reusable(p):
                self.release_proxy_connection_to_pool(client_fd, now)
                self.close_client_after_proxy_release(client_fd)
            else:
                self.close_proxy_connection(client_fd)
            return
        if not async_proxy_should_recv_upstream(p):
            return
        val upstream_fd = p.upstream_fd
        val recv_budget = async_proxy_upstream_recv_budget(p, 8192)
        if recv_budget <= 0:
            return
        val recv_op = self.driver.submit_recv(upstream_fd, recv_budget)
        self.track_io_op(recv_op, client_fd, upstream_fd, OP_PROXY_RECV_RESPONSE)

    me process_request(fd: i64, now: i64):
        """Process a complete HTTP request through the pipeline.

        Runs middleware phases, routes to handler, generates response.
        """
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return

        var c = conn
        val request = c.request
        if not request.?:
            self.send_error(fd, 500, "No request data", now)
            return

        if self.config.locations.len() == 1:
            val only_location = self.config.locations[0]
            if (only_location.handler_type == "static" and only_location.pattern == "/" and
                (only_location.match_type == "prefix" or only_location.match_type == "") and
                only_location.middlewares.len() == 0 and
                (request.method == "GET" or request.method == "HEAD")):
                if self.try_send_static_sendfile_fast_path(fd, only_location, request, now):
                    return
                var fast_resp = self.inline_static_handler(only_location, request)
                self.send_response(fd, fast_resp, now)
                return

        # Run pre-content middleware phases
        val phase_result = self.run_builtin_request_phases(request)
        match phase_result:
            PhaseResult.Respond(status, reason, headers, body):
                val resp = build_phase_response(status, reason, headers, body)
                self.send_response(fd, resp, now)
                return
            PhaseResult.Error(status, msg):
                self.send_error(fd, status, msg, now)
                return
            PhaseResult.Continue:
                val phase_allowed = true
            PhaseResult.Skip:
                val phase_allowed = true

        # Route request. Use a worker-local config matcher on the native hot
        # path; AsyncRouter currently trips native null dispatch.
        val location_opt = self.find_config_location(request)
        if location_opt.?:
            val location = location_opt
            if async_proxy_route_enabled(location):
                if async_proxy_tunnel_requested(request):
                    val initial_tunnel_bytes = c.drain_pending_tunnel_bytes()
                    self.http1_connection_set(fd, c)
                    self.start_proxy_tunnel(fd, request, location, initial_tunnel_bytes, now)
                    return
                self.start_proxy(fd, request, location, now)
                return
            var resp = self.inline_static_handler(location, request)
            self.send_response(fd, resp, now)
        else:
            self.send_response(fd, build_not_found(), now)

        # Native function-pointer lowering is not reliable for middleware yet.
        # Built-in access logging is skipped on the native live hot path until
        # function-pointer dispatch is fixed.

    me run_builtin_request_phases(request: HttpRequestData) -> PhaseResult:
        """Run built-in request checks without middleware function pointers."""
        body_limit_handler(request, self.config)

    me find_config_location(request: HttpRequestData) -> LocationConfig?:
        """Find exact or longest-prefix location without router function calls."""
        var i = 0
        while i < self.config.locations.len():
            val loc = self.config.locations[i]
            if loc.match_type == "exact":
                var clean = loc.pattern
                if clean.starts_with("= "):
                    clean = clean.slice(2, clean.len())
                if request.path == clean:
                    return loc
            i = i + 1

        var best: LocationConfig? = nil
        var best_len = -1
        var p = 0
        while p < self.config.locations.len():
            val loc = self.config.locations[p]
            if loc.match_type == "prefix" or loc.match_type == "":
                var matched = false
                if loc.pattern == "/":
                    matched = true
                elif request.path.starts_with(loc.pattern):
                    matched = true
                if matched:
                    val plen = loc.pattern.len()
                    if plen > best_len:
                        best_len = plen
                        best = loc
            p = p + 1
        best

    me inline_static_handler(location: LocationConfig, request: HttpRequestData) -> HttpResponseData:
        val root = location.root
        val path = request.path
        val full_path = root + path
        val meta = self.static_metadata_for_path(full_path, path)
        if not meta.?:
            return build_not_found()
        val entry = meta

        val size = entry.size
        val ctype = entry.content_type
        val etag = entry.etag

        # Check for Range header
        val range_hdr = self.find_request_header(request, "Range")
        if range_hdr.?:
            # If-Range: only honor Range when ETag matches
            var honor_range = true
            val if_range_val = self.find_request_header(request, "If-Range")
            if if_range_val.?:
                val ir = "" + if_range_val
                if ir != etag:
                    honor_range = false

            if honor_range:
                val parsed = parse_range_header(range_hdr, size)
                match parsed:
                    Ok(ranges):
                        if ranges.len() == 1:
                            return build_range_response(ranges, size, ctype, full_path, etag)
                        else:
                            val boundary = generate_boundary()
                            return build_multipart_range_response(ranges, size, ctype, boundary, full_path, etag)
                    Err(e):
                        # 416 Range Not Satisfiable
                        return HttpResponseData(
                            status: 416,
                            reason: "Range Not Satisfiable",
                            headers: [
                                ("Content-Range", "bytes */{size}"),
                                ("Accept-Ranges", "bytes"),
                                ("Server", "SimpleServer")
                            ],
                            body: "",
                            body_bytes: [],
                            body_file: "",
                            body_offset: 0,
                            body_length: 0,
                            chunked: false
                        )

        # Full 200 response with Accept-Ranges and ETag
        return HttpResponseData(
            status: 200,
            reason: "OK",
            headers: [
                ("Content-Type", ctype),
                ("Content-Length", "{size}"),
                ("Accept-Ranges", "bytes"),
                ("ETag", etag),
                ("Server", "SimpleServer")
            ],
            body: "",
            body_bytes: [],
            body_file: full_path,
            body_offset: 0,
            body_length: size,
            chunked: false
        )

    me static_metadata_for_path(full_path: text, request_path: text) -> StaticMetadataCacheEntry?:
        val now = current_time_ms()
        if self.static_metadata_cache_ttl_ms > 0:
            val cached = self.static_metadata_cache.get(full_path)
            if cached.?:
                val age = now - cached.cached_at_ms
                if age >= 0 and age <= self.static_metadata_cache_ttl_ms:
                    return cached
                val current_mtime = file_stat(full_path)
                if current_mtime > 0 and current_mtime == cached.mtime:
                    val refreshed = StaticMetadataCacheEntry(
                        path: cached.path,
                        size: cached.size,
                        mtime: cached.mtime,
                        cached_at_ms: now,
                        content_type: cached.content_type,
                        etag: cached.etag,
                        response_header: cached.response_header
                    )
                    self.static_metadata_cache[full_path] = refreshed
                    return refreshed

        val size = self.driver.file_size_bytes(full_path)
        if size < 0:
            return nil
        val mtime = file_stat(full_path)
        val ctype = worker_static_content_type(request_path)
        val etag = "\"{size}\""
        val header = "HTTP/1.1 200 OK\r\nContent-Type: {ctype}\r\nContent-Length: {size}\r\nAccept-Ranges: bytes\r\nETag: {etag}\r\nServer: SimpleServer\r\n\r\n"
        val entry = StaticMetadataCacheEntry(
            path: full_path,
            size: size,
            mtime: mtime,
            cached_at_ms: now,
            content_type: ctype,
            etag: etag,
            response_header: header
        )
        if self.static_metadata_cache_ttl_ms > 0 and mtime > 0:
            self.static_metadata_cache[full_path] = entry
        entry

    me try_send_static_sendfile_fast_path(fd: i64, location: LocationConfig, request: HttpRequestData, now: i64) -> bool:
        if self.tls_config.? and self.tls_sessions.get(fd).?:
            return false
        if self.find_request_header(request, "Range").?:
            return false

        self.try_send_static_path(fd, location, request.path, now)

    me try_send_static_path(fd: i64, location: LocationConfig, path: text, now: i64) -> bool:
        val full_path = location.root + path
        val meta = self.static_metadata_for_path(full_path, path)
        if not meta.?:
            self.send_response(fd, build_not_found(), now)
            return true
        val entry = meta

        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return true
        var c = conn
        c.response_bytes = ""
        c.write_offset = 0
        c.state = ConnectionState.SendingResponse
        self.http1_connection_set(fd, c)

        self.static_file_sendfile_count = self.static_file_sendfile_count + 1
        val op = self.driver.submit_sendfile_path_with_header(fd, entry.response_header, full_path, 0, entry.size)
        self.track_op(op, fd, OP_DIRECT_STATIC_SENDFILE)
        true

    me find_request_header(request: HttpRequestData, name: text) -> text?:
        var i = 0
        while i < request.headers.len():
            val pair = request.headers[i]
            if pair.0.lower() == name.lower():
                return pair.1
            i = i + 1
        nil

    me execute_handler(location: LocationConfig,
                       request: HttpRequestData) -> HttpResponseData:
        """Execute the content handler for a matched location.

        Delegates to handler_registry which maps handler_type to
        the appropriate ContentHandler.
        """
        self.handler_registry.dispatch(location.handler_type, request, location)

    me security_task_id() -> text:
        current_unified_task_key("scheduler-task-missing")

    me execute_handler_with_remote_security_context(location: LocationConfig,
                                                    request: HttpRequestData) -> HttpResponseData:
        """Execute handler under a server-side SecurityContext.

        Client-provided UI permission snapshots are not used as authority. This
        transport boundary only propagates safe headers and establishes an
        anonymous context unless an upstream auth layer has validated identity.
        """
        val task_id = allocate_scheduler_task_id()
        val previous_task_id = enter_scheduler_task_id(task_id)
        val response = dispatch_with_task_remote_security_context(self.handler_registry, self.security_task_id(), location, request)
        exit_scheduler_task_id(previous_task_id)
        return response

    # ========================================================================
    # Response Sending
    # ========================================================================

    me send_response(fd: i64, resp: HttpResponseData, now: i64):
        """Send a response on a connection.

        When a TLS session exists for this fd, the response bytes are chunked
        into TLS_MAX_FRAGMENT_LENGTH-byte segments, each encrypted with
        tls_encrypt_record, and sent as a single contiguous byte buffer.
        sendfile is transparently fallen back to portable-read for TLS
        connections since kernel sendfile cannot encrypt in-flight.
        """
        val conn = self.http1_connection_get(fd)
        if not conn.?:
            return

        var response = resp

        # TLS connections must use portable-read for file bodies (sendfile bypasses encryption)
        val tls_session_send = if self.tls_config.?: self.tls_sessions.get(fd) else: nil
        if tls_session_send.?:
            if (worker_static_file_route(self.net_capabilities, resp) == "sendfile" or
                worker_static_file_route(self.net_capabilities, resp) == "portable-read"):
                response = worker_static_file_fallback_response(resp)
                self.static_file_fallback_count = self.static_file_fallback_count + 1
        else:
            if worker_static_file_route(self.net_capabilities, resp) == "sendfile":
                self.static_file_sendfile_count = self.static_file_sendfile_count + 1

        var c = conn
        val keepalive_s = self.config.keepalive_timeout_ms / 1000

        # TLS encryption path: encrypt response bytes into TLS records
        if tls_session_send.?:
            var session_send = tls_session_send
            c.set_response(response, keepalive_s)
            self.http1_connection_set(fd, c)
            val plain_text = c.get_response_bytes()
            # Chunk into TLS records (max TLS_MAX_FRAGMENT_LENGTH bytes each)
            var encrypted_buf: [u8] = []
            var offset_s = 0
            val plain_len = len(plain_text)
            while offset_s < plain_len:
                val remaining_s = plain_len - offset_s
                val chunk_len = if remaining_s > TLS_MAX_FRAGMENT_LENGTH: TLS_MAX_FRAGMENT_LENGTH else: remaining_s
                val chunk = plain_text.slice(offset_s, offset_s + chunk_len)
                val rec = tls_encrypt_record(chunk, session_send)
                for b in rec:
                    encrypted_buf.push(b)
                session_send.server_seq = session_send.server_seq + 1
                offset_s = offset_s + chunk_len
            self.tls_sessions[fd] = session_send
            val op = self.driver.submit_send_bytes(fd, encrypted_buf)
            self.track_op(op, fd, OP_SEND)
            return

        if worker_static_file_route(self.net_capabilities, response) == "sendfile":
            c.keepalive = c.keepalive and response.status != 101 and response.status < 400
            c.response_bytes = ""
            c.write_offset = 0
            c.state = ConnectionState.SendingResponse
            self.http1_connection_set(fd, c)
            val bytes = serialize_response(response)
            val op = self.driver.submit_sendfile_path_with_header(fd, bytes, response.body_file, response.body_offset, response.body_length)
            self.track_op(op, fd, OP_DIRECT_STATIC_SENDFILE)
        elif response.body_bytes.len() > 0:
            # Compressed or binary body — use bytes path to avoid text corruption
            c.set_response_bytes(response, keepalive_s)
            self.http1_connection_set(fd, c)
            val buf = c.get_response_bytes_buf()
            val op = self.driver.submit_send_bytes(fd, buf)
            self.track_op(op, fd, OP_SEND)
        else:
            c.keepalive = c.keepalive and response.status != 101 and response.status < 400
            c.response_bytes = self.serialize_plain_response(response)
            c.write_offset = 0
            c.state = ConnectionState.SendingResponse
            self.http1_connection_set(fd, c)
            val bytes = c.get_response_bytes()
            val op = self.driver.submit_send(fd, bytes)
            self.track_op(op, fd, OP_SEND)

    me send_error(fd: i64, status: i64, msg: text, now: i64):
        """Send an error response and close."""
        val resp = build_error(status, msg)
        self.send_response(fd, resp, now)

    me serialize_plain_response(resp: HttpResponseData) -> text:
        """Serialize a plain buffered response without shared header helpers."""
        var content_type = ""
        var server = "SimpleServer"
        var content_length = "{resp.body.len()}"
        var i = 0
        while i < resp.headers.len():
            val pair = resp.headers[i]
            val name = pair.0
            val value = pair.1
            if name.lower() == "content-type":
                content_type = value
            elif name.lower() == "server":
                server = value
            elif name.lower() == "content-length":
                content_length = value
            i = i + 1

        var out = "HTTP/1.1 {resp.status} {resp.reason}\r\n"
        if content_type != "":
            out = out + "Content-Type: {content_type}\r\n"
        out = out + "Content-Length: {content_length}\r\n"
        out = out + "Connection: close\r\n"
        out = out + "Server: {server}\r\n"
        out = out + "\r\n"
        out + resp.body

    # ========================================================================
    # Connection Lifecycle
    # ========================================================================

    me close_connection(fd: i64):
        """Close a connection and remove from tracking (including TLS state)."""
        self.cleanup_proxy_for_client(fd)
        self.cleanup_proxy_tunnel_for_client(fd)
        self.driver.cancel_fd(fd)
        self.remove_ops_for_fd(fd)
        tcp_backend_close(fd)
        self.http1_connection_remove(fd)
        self.untrack_http1_fd(fd)
        self.active_count = self.active_count - 1

    me cleanup_proxy_tunnel_for_client(client_fd: i64):
        val tunnel = self.proxy_tunnel_get(client_fd)
        if not tunnel.?:
            return
        self.proxy_request_stream_remove(client_fd)
        val closed = async_proxy_tunnel_mark_closed(tunnel, _http_time_now_ms())
        self.proxy_tunnel_set(client_fd, closed)
        self.proxy_mark_peer_finish(tunnel.upstream_addr)
        val upstream_fd = tunnel.upstream_fd
        if upstream_fd >= 0:
            self.driver.cancel_fd(upstream_fd)
            tcp_backend_close(upstream_fd)
        self.proxy_tunnel_remove(client_fd)
        self.untrack_tunnel_fd(client_fd)

    me cleanup_proxy_for_client(client_fd: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        self.record_proxy_hardening_evidence(client_fd, _http_time_now_ms())
        self.proxy_request_stream_remove(client_fd)
        self.proxy_mark_peer_finish(proxy.upstream_addr)
        val upstream_fd = proxy.upstream_fd
        if upstream_fd >= 0:
            self.proxy_client_by_upstream_remove(upstream_fd)
        if upstream_fd >= 0:
            self.driver.cancel_fd(upstream_fd)
            self.proxy_pool_mark_fd_closed(upstream_fd, _http_time_now_ms())
            tcp_backend_close(upstream_fd)
        self.proxy_connection_remove(client_fd)
        self.untrack_proxy_fd(client_fd)

    me release_proxy_connection_to_pool(client_fd: i64, now: i64):
        val proxy = self.proxy_connection_get(client_fd)
        if not proxy.?:
            return
        self.record_proxy_hardening_evidence(client_fd, now)
        self.proxy_request_stream_remove(client_fd)
        self.proxy_mark_peer_finish(proxy.upstream_addr)
        val upstream_fd = proxy.upstream_fd
        if upstream_fd >= 0:
            self.proxy_client_by_upstream_remove(upstream_fd)
        if upstream_fd >= 0:
            self.driver.cancel_fd(upstream_fd)
            if async_proxy_pool_can_keep_idle(self.proxy_upstream_pool, proxy.upstream_addr, self.proxy_pool_config, now):
                self.proxy_pool_release_fd(proxy.upstream_addr, upstream_fd, now)
            else:
                self.proxy_pool_mark_fd_closed(upstream_fd, now)
                tcp_backend_close(upstream_fd)
        self.proxy_connection_remove(client_fd)
        self.untrack_proxy_fd(client_fd)

    me close_client_after_proxy_release(client_fd: i64):
        self.cleanup_proxy_tunnel_for_client(client_fd)
        self.driver.cancel_fd(client_fd)
        self.remove_ops_for_fd(client_fd)
        tcp_backend_close(client_fd)
        self.http1_connection_remove(client_fd)
        self.untrack_http1_fd(client_fd)
        self.active_count = self.active_count - 1

    me close_proxy_connection(client_fd: i64):
        self.cleanup_proxy_for_client(client_fd)
        self.close_connection(client_fd)

    me close_proxy_tunnel_connection(client_fd: i64):
        self.cleanup_proxy_tunnel_for_client(client_fd)
        self.close_connection(client_fd)

    me close_all_connections():
        """Close all active connections during shutdown."""
        val proxy_fds = self.proxy_connection_fds
        var proxy_i = 0
        while proxy_i < proxy_fds.len():
            self.cleanup_proxy_for_client(proxy_fds[proxy_i])
            proxy_i = proxy_i + 1
        self.proxy_request_stream_fds = []
        self.proxy_request_stream_items = []
        val tunnel_fds = self.proxy_tunnel_fds
        var tunnel_i = 0
        while tunnel_i < tunnel_fds.len():
            self.cleanup_proxy_tunnel_for_client(tunnel_fds[tunnel_i])
            tunnel_i = tunnel_i + 1

        val fds = self.connection_fds
        var fd_i = 0
        while fd_i < fds.len():
            tcp_backend_close(fds[fd_i])
            fd_i = fd_i + 1
        self.connection_items = []
        self.connection_fds = []
        # Close H2 connections
        val h2_fds = self.h2_connection_fds
        var h2_i = 0
        while h2_i < h2_fds.len():
            tcp_backend_close(h2_fds[h2_i])
            h2_i = h2_i + 1
        self.h2_connections = {}
        self.h2_connection_fds = []
        self.proxy_connection_fds = []
        self.proxy_tunnel_fds = []
        self.active_count = 0

    # ========================================================================
    # HTTP/2 Connection Handling
    # ========================================================================

    me handle_h2_accept(fd: i64, now: i64):
        """Accept a new HTTP/2 connection after ALPN negotiation.

        Called from dispatch_by_alpn after TLS handshake. The fd is
        already accepted — this sets up H2 framing, sends server
        SETTINGS, and starts reading.
        """
        if self.active_count >= self.config.max_connections:
            tcp_backend_close(fd)
            return

        tcp_backend_set_nonblocking(fd, true)
        tcp_backend_set_nodelay(fd, true)

        val peer = tcp_backend_local_addr(fd) ?? "unknown"
        var h2conn = H2Connection.new(fd, peer, now)

        # Send server preface (SETTINGS frame queued by H2Connection.new)
        val initial_bytes = h2conn.take_pending_writes()
        if initial_bytes.len() > 0:
            val send_op = self.driver.submit_send_bytes(fd, initial_bytes)
            self.track_op(send_op, fd, OP_SEND)

        self.h2_connections[fd] = h2conn
        self.track_h2_fd(fd)
        self.active_count = self.active_count + 1

        # Start reading client preface + frames
        val recv_op = self.driver.submit_recv(fd, 8192)
        self.track_op(recv_op, fd, OP_RECV)

    me handle_h2_recv(fd: i64, data: [u8], now: i64):
        """Feed received raw bytes to an H2 connection and flush outbound frames."""
        val h2conn = self.h2_connections.get(fd)
        if not h2conn.?:
            return

        var conn = h2conn
        conn.h2_on_data_received(data, now)
        val keep_going = conn.consume_frames()

        # Process fully decoded H2 requests through the pipeline
        val decoded = conn.take_decoded_requests()
        for pair in decoded:
            val stream_id = pair.0
            val request = pair.1
            var resp = build_not_found()
            val route_result = self.router.route(request)
            match route_result:
                Ok((location, params)):
                    resp = self.inline_static_handler(location, request)
                Err(e):
                    resp = build_not_found()
            if resp.body_file.len() > 0:
                resp = worker_static_file_fallback_response(resp)
            conn.queue_h2_response(stream_id, resp)

        # Drain any pending outbound frames (SETTINGS ACK, PING echo, responses)
        val out_bytes = conn.take_pending_writes()
        self.h2_connections[fd] = conn

        if out_bytes.len() > 0:
            val send_op = self.driver.submit_send_bytes(fd, out_bytes)
            self.track_op(send_op, fd, OP_SEND)

        if keep_going and not conn.is_goaway_sent():
            # Continue reading
            val recv_op = self.driver.submit_recv(fd, 8192)
            self.track_op(recv_op, fd, OP_RECV)
        else:
            self.close_h2_connection(fd)

    me close_h2_connection(fd: i64):
        """Close an H2 connection and clean up tracking state."""
        self.driver.cancel_fd(fd)
        self.remove_ops_for_fd(fd)
        tcp_backend_close(fd)
        self.h2_connections.remove(fd)
        self.untrack_h2_fd(fd)
        self.active_count = self.active_count - 1

    me dispatch_by_alpn(alpn: text, fd: i64, now: i64):
        """Dispatch a new TLS connection based on the negotiated ALPN protocol.

        Called after TLS accept when the handshake result carries a negotiated
        ALPN string. Logs the chosen protocol and routes accordingly.

        Currently:
          - Http1 (or empty ALPN) → standard handle_accept() H1 path
          - Http2                 → log + fall through to H1 for now
                                    TODO(AC-4): wire h2_server_conn_new() here
          - Http3                 → reject (H3 arrives on UDP, not TCP)

        Args:
            alpn: Negotiated ALPN string from TLS handshake. May be "".
            fd:   Accepted client socket fd.
            now:  Current epoch-ms timestamp from _http_time_now_ms().
        """
        val kind = protocol_from_alpn(alpn)
        val label = protocol_handler_label(kind)
        match kind:
            ProtocolKind.Http2:
                # H2 connection via ALPN — create H2Connection and start recv.
                self.handle_h2_accept(fd, now)
            ProtocolKind.Http3:
                # H3 over TCP is a client error — reject immediately.
                tcp_backend_close(fd)
            ProtocolKind.Http1:
                self.handle_accept(fd, now)

    me reap_expired(now: i64):
        """Close connections that have exceeded their timeout."""
        if self.active_count <= 0:
            return
        var proxy_to_close: [i64] = []
        var proxy_i = 0
        while proxy_i < self.proxy_connection_fds.len():
            val fd = self.proxy_connection_fds[proxy_i]
            val proxy = self.proxy_connection_get(fd)
            if proxy.?:
                if async_proxy_timed_out(proxy, now):
                    proxy_to_close.push(fd)
            proxy_i = proxy_i + 1

        var proxy_close_i = 0
        while proxy_close_i < proxy_to_close.len():
            val fd = proxy_to_close[proxy_close_i]
            self.proxy_mark_failure_for_client(fd, now)
            self.close_proxy_connection(fd)
            proxy_close_i = proxy_close_i + 1

        var to_close: [i64] = []

        var conn_i = 0
        while conn_i < self.connection_fds.len():
            val fd = self.connection_fds[conn_i]
            val conn = self.http1_connection_get(fd)
            if conn.?:
                if not self.fd_list_contains(self.proxy_connection_fds, fd) and not self.fd_list_contains(self.proxy_tunnel_fds, fd):
                    if conn.is_keepalive_expired(now, self.config.keepalive_timeout_ms):
                        to_close.push(fd)
                    elif conn.is_read_timeout(now, self.config.read_timeout_ms):
                        to_close.push(fd)
            conn_i = conn_i + 1

        var close_i = 0
        while close_i < to_close.len():
            self.close_connection(to_close[close_i])
            close_i = close_i + 1

        # Reap idle H2 connections
        var h2_to_close: [i64] = []
        var h2_i = 0
        while h2_i < self.h2_connection_fds.len():
            val fd = self.h2_connection_fds[h2_i]
            val h2conn = self.h2_connections.get(fd)
            if h2conn.?:
                if h2conn.is_idle_timeout(now, self.config.idle_timeout_ms):
                    h2_to_close.push(fd)
            h2_i = h2_i + 1

        var h2_close_i = 0
        while h2_close_i < h2_to_close.len():
            self.close_h2_connection(h2_to_close[h2_close_i])
            h2_close_i = h2_close_i + 1

fn worker_static_file_route(caps: NetBackendCapabilities, resp: HttpResponseData) -> text:
    """Return the worker route for a response body."""
    if resp.body_file.len() > 0:
        return "sendfile"
    "body"

fn worker_static_file_fallback_response(resp: HttpResponseData) -> HttpResponseData:
    """Convert a body_file hint into a portable in-memory response."""
    val body = file_read_text(resp.body_file)
    HttpResponseData(
        status: resp.status,
        reason: resp.reason,
        headers: resp.headers,
        body: body,
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: resp.chunked
    )

fn worker_sendfile_open_path_for_pending(pending: Dict<i64, (text, i64, i64)>, fd: i64) -> text:
    """Return the path to open after headers are sent without consuming state."""
    val entry = pending.get(fd)
    if entry.?:
        entry.0
    else:
        ""

# ============================================================================
# TLS Record-Layer Helpers (reserved for future application data wiring)
#
# These functions implement correct TLS 1.2 record-layer encrypt/decrypt
# with AES-128-GCM. They are NOT yet called from the main worker paths
# because handle_recv and send_response need a record accumulator to handle
# TCP framing (split records, multi-record recvs, >16384-byte responses).
# See the TODO comments in handle_recv and send_response for the full plan.
# ============================================================================

fn tls_decrypt_record(raw_bytes: [u8], session: TlsSessionState) -> text?:
    """Decrypt a TLS application data record from raw wire bytes.

    NOT YET WIRED — reserved for future TLS application data transport.

    Parses the 5-byte TLS record header, validates the content type is
    application data, then decrypts the payload with AES-128-GCM using
    the client write key and current sequence number.

    Args:
        raw_bytes: Raw bytes received from the socket (header + encrypted payload)
        session: Current TLS session state with keys and sequence counters

    Returns:
        Decrypted plaintext on success, nil on failure
    """
    if raw_bytes.len() < TLS_RECORD_HEADER_SIZE:
        return nil

    val content_type = raw_bytes[0].to_i64()
    if content_type != CONTENT_TYPE_APPLICATION_DATA:
        return nil

    val record_len = (raw_bytes[3].to_i64() * 256) + raw_bytes[4].to_i64()
    if record_len > TLS_MAX_FRAGMENT_LENGTH:
        return nil
    if raw_bytes.len() < TLS_RECORD_HEADER_SIZE + record_len:
        return nil

    # Extract payload wire text (after 5-byte header)
    var payload_wire = ""
    var i = TLS_RECORD_HEADER_SIZE
    while i < TLS_RECORD_HEADER_SIZE + record_len:
        payload_wire = payload_wire + encode_u8(raw_bytes[i].to_i64())
        i = i + 1

    val key_hex = tls_wire_to_hex(session.keys.client_write_key, 16)
    val iv_hex = tls_wire_to_hex(session.keys.client_write_iv, 4)
    val payload_hex = tls_wire_to_hex(payload_wire, record_len)
    val nonce_hex = build_gcm_nonce_hex(iv_hex, session.client_seq)
    val aad_hex = build_aead_aad_hex(session.client_seq, content_type, TLS_VERSION_1_2, record_len)
    val pt_hex = tls_aes_gcm_decrypt_hex(key_hex, nonce_hex, payload_hex, aad_hex)
    if pt_hex == nil:
        return nil
    tls_hex_to_wire(pt_hex)

fn tls_encrypt_record(plaintext: text, session: TlsSessionState) -> [u8]:
    """Encrypt plaintext into a TLS application data record.

    NOT YET WIRED — reserved for future TLS application data transport.

    Builds a TLS 1.2 record with AES-128-GCM encryption using the server
    write key and current sequence number.

    Args:
        plaintext: Response data to encrypt
        session: Current TLS session state with keys and sequence counters

    Returns:
        Complete TLS record bytes (header + encrypted payload) ready for wire
    """
    val data_len = len(plaintext)
    val key_hex = tls_wire_to_hex(session.keys.server_write_key, 16)
    val iv_hex = tls_wire_to_hex(session.keys.server_write_iv, 4)
    val nonce_hex = build_gcm_nonce_hex(iv_hex, session.server_seq)
    # The nonce is implicit from fixed IV + sequence; AES-GCM appends a 16-byte tag.
    val encrypted_len = data_len + 16
    val aad_hex = build_aead_aad_hex(session.server_seq, CONTENT_TYPE_APPLICATION_DATA, TLS_VERSION_1_2, encrypted_len)
    val data_hex = tls_wire_to_hex(plaintext, data_len)
    val ct_hex = tls_aes_gcm_encrypt_hex(key_hex, nonce_hex, data_hex, aad_hex)

    # Build TLS record: 1-byte type + 2-byte version + 2-byte length + ciphertext
    var record: [u8] = []
    record.push(CONTENT_TYPE_APPLICATION_DATA.to_u8())
    record.push(3)   # TLS 1.2 major
    record.push(3)   # TLS 1.2 minor
    record.push((encrypted_len / 256).to_u8())
    record.push((encrypted_len % 256).to_u8())

    # Append encrypted payload
    val ct_wire = tls_hex_to_wire(ct_hex)
    var j = 0
    while j < encrypted_len:
        record.push(byte_at(ct_wire, j).to_u8())
        j = j + 1
    record

fn build_gcm_nonce_hex(iv_hex: text, seq: i64) -> text:
    """Build 12-byte GCM nonce = 4-byte IV + 8-byte sequence (big-endian)."""
    var nonce = iv_hex
    var s = seq
    var seq_bytes: [i64] = [0, 0, 0, 0, 0, 0, 0, 0]
    var k = 7
    while k >= 0:
        seq_bytes[k] = s % 256
        s = s / 256
        k = k - 1
    var idx = 0
    while idx < 8:
        val b = seq_bytes[idx]
        val hi = b / 16
        val lo = b % 16
        nonce = nonce + hex_digit(hi) + hex_digit(lo)
        idx = idx + 1
    nonce

fn build_aead_aad_hex(seq: i64, content_type: i64, version: i64, length: i64) -> text:
    """Build AEAD additional authenticated data (13 bytes) as hex.

    Format: 8-byte seq + 1-byte content_type + 2-byte version + 2-byte length.
    """
    var aad = ""
    # 8-byte sequence number
    var s = seq
    var seq_bytes: [i64] = [0, 0, 0, 0, 0, 0, 0, 0]
    var k = 7
    while k >= 0:
        seq_bytes[k] = s % 256
        s = s / 256
        k = k - 1
    var idx = 0
    while idx < 8:
        val b = seq_bytes[idx]
        aad = aad + hex_digit(b / 16) + hex_digit(b % 16)
        idx = idx + 1
    # 1-byte content type
    aad = aad + hex_digit(content_type / 16) + hex_digit(content_type % 16)
    # 2-byte version
    aad = aad + hex_digit(3 / 16) + hex_digit(3 % 16)
    aad = aad + hex_digit(3 / 16) + hex_digit(3 % 16)
    # 2-byte length
    val len_hi = length / 256
    val len_lo = length % 256
    aad = aad + hex_digit(len_hi / 16) + hex_digit(len_hi % 16)
    aad = aad + hex_digit(len_lo / 16) + hex_digit(len_lo % 16)
    aad

fn hex_digit(n: i64) -> text:
    """Convert 0-15 to hex character."""
    if n < 10:
        return "{n}"
    if n == 10:
        return "a"
    if n == 11:
        return "b"
    if n == 12:
        return "c"
    if n == 13:
        return "d"
    if n == 14:
        return "e"
    "f"
