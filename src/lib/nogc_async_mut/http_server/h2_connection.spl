# HTTP/2 Connection — Async H2 connection multiplexer
#
# Manages a single HTTP/2 connection: preface validation, settings
# exchange, stream tracking, and frame dispatch. Composes the sync
# framing layer (h2_frame, h2_parser, h2_writer, h2_preface) with the
# async IoDriver-based worker.
#
# Scope (HPACK wiring — W16):
#   - Connection preface validation (RFC 9113 §3.4)
#   - SETTINGS exchange (server SETTINGS + client SETTINGS ACK)
#   - PING echo
#   - WINDOW_UPDATE tracking (connection-level)
#   - GOAWAY on unimplemented stream paths
#   - Stream creation and frame routing to H2Stream
#   - HPACK decode of request HEADERS → HttpRequestData
#   - HPACK encode of response HttpResponseData → HEADERS+DATA frames
#
# Out of scope (follow-up milestones):
#   - CONTINUATION frame header-block merging
#   - Server push (PUSH_PROMISE)
#   - Priority / weighted scheduling
#   - Dynamic table updates (static-table-only HPACK)
#
# Worker drains decoded requests via take_decoded_requests() and feeds
# responses back via queue_h2_response(stream_id, resp).

use std.http.h2.h2_frame.{
    H2Frame, H2DataFrame, H2HeadersFrame, H2SettingsFrame,
    H2PingFrame, H2GoawayFrame, H2WindowUpdateFrame,
    H2RstStreamFrame, H2Setting,
    H2_FRAME_HEADER_LEN,
    H2_FLAG_END_STREAM, H2_FLAG_END_HEADERS, H2_FLAG_ACK,
    H2_SETTINGS_MAX_CONCURRENT_STREAMS, H2_SETTINGS_INITIAL_WINDOW_SIZE,
    H2_SETTINGS_MAX_FRAME_SIZE,
    H2_ERR_NO_ERROR, H2_ERR_PROTOCOL_ERROR, H2_ERR_INTERNAL_ERROR,
    H2_ERR_COMPRESSION_ERROR
}
use std.http.h2.h2_parser.{h2_parse_frame, h2_parse_frame_header, H2FrameHeader}
use std.http.h2.h2_writer.{h2_write_frame}
use std.http.h2.h2_preface.{h2_validate_preface, H2_CONNECTION_PREFACE_LEN}
use std.http.h2.h2_hpack.{
    hpack_static_table, hpack_encode, hpack_decode,
    HpackEntry, HpackTable, HpackEncodeResult, HpackDecodeResult
}
use std.http_server.h2_stream.{H2Stream, H2StreamState}
use std.http_server.types.{HttpRequestData, HttpResponseData}

# ============================================================================
# Connection-level defaults (RFC 9113 §6.5.2)
# ============================================================================

val DEFAULT_MAX_CONCURRENT_STREAMS: i64 = 100
val DEFAULT_INITIAL_WINDOW_SIZE: i64 = 65535
val DEFAULT_MAX_FRAME_SIZE: i64 = 16384
val DEFAULT_CONNECTION_WINDOW: i64 = 65535

# ============================================================================
# H2Connection
# ============================================================================

class H2Connection:
    """Manages one HTTP/2 connection (multiple streams over a single TCP fd).

    The worker feeds raw bytes via `on_data_received`; this class validates
    the preface, parses frames, dispatches to per-stream H2Stream instances,
    and accumulates outbound frame bytes in `pending_writes`.

    Worker drains `pending_writes` via `take_pending_writes()` and submits
    them through the IoDriver.
    """
    fd: i64
    peer_addr: text
    created_at: i64
    last_activity: i64

    # Receive buffer — bytes accumulate across on_data_received calls
    recv_buf: [u8]

    # Connection state
    preface_validated: bool
    settings_sent: bool
    goaway_sent: bool
    last_stream_id: i64
    next_server_stream_id: i64

    # Negotiated settings (peer values)
    peer_max_concurrent_streams: i64
    peer_initial_window_size: i64
    peer_max_frame_size: i64

    # Local settings (what we advertise)
    local_max_concurrent_streams: i64
    local_initial_window_size: i64
    local_max_frame_size: i64

    # Flow control — connection-level windows
    send_window: i64
    recv_window: i64

    # Active streams
    streams: Dict<i64, H2Stream>

    # Outbound frame buffer — worker drains this after each on_data_received
    pending_writes: [u8]

    # HPACK static table (shared across all streams on this connection)
    hpack_table: HpackTable

    # Decoded requests waiting for worker to drain via take_decoded_requests()
    pending_requests: [(i64, HttpRequestData)]

    static fn new(fd: i64, peer_addr: text, now: i64) -> H2Connection:
        """Create a new H2 connection after ALPN negotiation selects h2.

        Immediately queues the server connection preface (SETTINGS frame).

        Args:
            fd: TCP socket file descriptor
            peer_addr: Remote address string
            now: Current epoch-ms timestamp
        """
        var conn = H2Connection(
            fd: fd,
            peer_addr: peer_addr,
            created_at: now,
            last_activity: now,
            recv_buf: [],
            preface_validated: false,
            settings_sent: false,
            goaway_sent: false,
            last_stream_id: 0,
            next_server_stream_id: 2,
            peer_max_concurrent_streams: DEFAULT_MAX_CONCURRENT_STREAMS,
            peer_initial_window_size: DEFAULT_INITIAL_WINDOW_SIZE,
            peer_max_frame_size: DEFAULT_MAX_FRAME_SIZE,
            local_max_concurrent_streams: DEFAULT_MAX_CONCURRENT_STREAMS,
            local_initial_window_size: DEFAULT_INITIAL_WINDOW_SIZE,
            local_max_frame_size: DEFAULT_MAX_FRAME_SIZE,
            send_window: DEFAULT_CONNECTION_WINDOW,
            recv_window: DEFAULT_CONNECTION_WINDOW,
            streams: {},
            pending_writes: [],
            hpack_table: hpack_static_table(),
            pending_requests: []
        )
        # Server MUST send its SETTINGS as connection preface (RFC 9113 §3.4).
        conn.queue_server_settings()
        return conn

    # ========================================================================
    # Public interface — called by Worker
    # ========================================================================

    me h2_on_data_received(data: [u8], now: i64) -> bool:
        self.last_activity = now
        var i = 0
        while i < data.len():
            self.recv_buf.push(data[i])
            i = i + 1
        print "[H2] appended {data.len()} bytes, recv_buf={self.recv_buf.len()}"
        if not self.preface_validated:
            if self.recv_buf.len() < H2_CONNECTION_PREFACE_LEN:
                return true
            print "[H2] checking preface..."
            if not h2_validate_preface(self.recv_buf):
                print "[H2] invalid preface, sending goaway"
                self.queue_goaway(0, H2_ERR_PROTOCOL_ERROR)
                return false
            self.preface_validated = true
            self.recv_buf = _slice_from(self.recv_buf, H2_CONNECTION_PREFACE_LEN)
            print "[H2] preface validated, remaining={self.recv_buf.len()}"
        return true

    me take_pending_writes() -> [u8]:
        """Drain and return all queued outbound bytes.

        Worker calls this after on_data_received and submits via
        IoDriver.submit_send.
        """
        val out = self.pending_writes
        self.pending_writes = []
        return out

    me is_goaway_sent() -> bool:
        """True if GOAWAY has been sent (connection is shutting down)."""
        self.goaway_sent

    me is_idle_timeout(now: i64, timeout_ms: i64) -> bool:
        """Check if connection has exceeded idle timeout."""
        (now - self.last_activity) > timeout_ms

    me take_decoded_requests() -> [(i64, HttpRequestData)]:
        """Drain and return all decoded H2 requests ready for processing.

        Each entry is (stream_id, request). Worker should call
        queue_h2_response(stream_id, response) for each entry after
        routing through the middleware/handler pipeline.
        """
        val out = self.pending_requests
        self.pending_requests = []
        return out

    me _queue_bytes(src: [u8]):
        var i = 0
        while i < src.len():
            self.pending_writes.push(src[i])
            i = i + 1

    me queue_h2_response(stream_id: i64, resp: HttpResponseData):
        """Encode and queue an HTTP response for a specific H2 stream.

        Encodes response headers via HPACK, then queues:
          - HEADERS frame (END_HEADERS; END_STREAM if no body)
          - DATA frame with END_STREAM (when body is non-empty)

        Transitions the stream to Closed via on_local_end_stream().

        Args:
            stream_id: H2 stream to respond on
            resp: Response data to encode and send
        """
        # Build response pseudo-headers + regular headers
        var resp_headers: [HpackEntry] = []
        resp_headers.push(HpackEntry(name: ":status", value: "{resp.status}"))
        var hi = 0
        while hi < resp.headers.len():
            val hpair = resp.headers[hi]
            resp_headers.push(HpackEntry(name: hpair.0, value: hpair.1))
            hi = hi + 1

        val enc = hpack_encode(resp_headers, self.hpack_table)

        # Determine body bytes
        var body_bytes: [u8] = []
        if resp.body_bytes.len() > 0:
            body_bytes = resp.body_bytes
        elif resp.body.len() > 0:
            # Convert body text to bytes via byte_at
            var bi = 0
            while bi < resp.body.len():
                body_bytes.push(resp.body.byte_at(bi))
                bi = bi + 1

        if body_bytes.len() == 0:
            val hframe = H2Frame.Headers(H2HeadersFrame(
                stream_id: stream_id,
                flags: H2_FLAG_END_HEADERS | H2_FLAG_END_STREAM,
                header_block: enc.bytes
            ))
            val bytes = h2_write_frame(hframe)
            var qi = 0
            while qi < bytes.len():
                self.pending_writes.push(bytes[qi])
                qi = qi + 1
        else:
            val hframe = H2Frame.Headers(H2HeadersFrame(
                stream_id: stream_id,
                flags: H2_FLAG_END_HEADERS,
                header_block: enc.bytes
            ))
            val hbytes = h2_write_frame(hframe)
            var qi = 0
            while qi < hbytes.len():
                self.pending_writes.push(hbytes[qi])
                qi = qi + 1
            val dframe = H2Frame.Data(H2DataFrame(
                stream_id: stream_id,
                flags: H2_FLAG_END_STREAM,
                data: body_bytes
            ))
            val dbytes = h2_write_frame(dframe)
            qi = 0
            while qi < dbytes.len():
                self.pending_writes.push(dbytes[qi])
                qi = qi + 1

        # Transition stream state via on_local_end_stream (handles all transitions)
        val stream = self.streams.get(stream_id)
        if stream.?:
            var s = stream
            s.on_local_end_stream()
            self.streams[stream_id] = s

    # ========================================================================
    # Frame consumption loop
    # ========================================================================

    me consume_frames() -> bool:
        print "[CF] consume_frames: recv_buf.len={self.recv_buf.len()}"
        var offset = 0
        var keep_going = true
        var has_frames = true
        while has_frames:
            if self.recv_buf.len() < offset + H2_FRAME_HEADER_LEN:
                has_frames = false
            else:
                val maybe_header = h2_parse_frame_header(self.recv_buf, offset)
                if maybe_header == nil:
                    print "[CF] header parse nil at offset={offset}"
                    has_frames = false
                else:
                    val header = maybe_header ?? H2FrameHeader(length: 0, frame_type: 0, flags: 0, stream_id: 0)
                    val frame_len = H2_FRAME_HEADER_LEN + header.length
                    print "[CF] frame: type={header.frame_type} flags={header.flags} sid={header.stream_id} len={header.length}"
                    if self.recv_buf.len() < offset + frame_len:
                        has_frames = false
                    else:
                        val maybe_frame = h2_parse_frame(self.recv_buf, offset)
                        offset = offset + frame_len
                        if maybe_frame == nil:
                            print "[CF] h2_parse_frame returned nil for ft={header.frame_type}"
                            has_frames = false
                        else:
                            val frame = maybe_frame ?? H2Frame.Data(H2DataFrame(stream_id: 0, flags: 0, data: []))
                            val ft = header.frame_type
                            print "[CF] dispatching ft={ft}"
                            if ft == 4:
                                val is_ack = (header.flags & 1) != 0
                                if not is_ack:
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(4)
                                    self.pending_writes.push(1)
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(0)
                                    self.pending_writes.push(0)
                                    print "[CF] queued SETTINGS ACK"
                                else:
                                    print "[CF] received SETTINGS ACK"
                            elif ft == 8:
                                pass_dn
                            elif ft == 1:
                                val sid = header.stream_id
                                val hblock = _slice_bytes(self.recv_buf, offset - header.length, header.length)
                                print "[CF] HEADERS stream={sid} hblock_len={hblock.len()}"
                                var hb_dbg = ""
                                var hbi = 0
                                while hbi < hblock.len():
                                    val b = hblock[hbi]
                                    hb_dbg = "{hb_dbg} {b}"
                                    hbi = hbi + 1
                                print "[CF] hblock bytes:{hb_dbg}"
                                print "[CF] calling hpack_decode..."
                                val dec = hpack_decode(hblock, self.hpack_table)
                                print "[CF] HPACK decoded {dec.headers.len()} headers"
                                var method = "GET"
                                var path = "/"
                                var authority = ""
                                var di = 0
                                while di < dec.headers.len():
                                    val entry = dec.headers[di]
                                    print "[CF]   header: {entry.name}={entry.value}"
                                    if entry.name == ":method":
                                        method = entry.value
                                    elif entry.name == ":path":
                                        path = entry.value
                                    elif entry.name == ":authority":
                                        authority = entry.value
                                    di = di + 1
                                print "[CF] request: {method} {path}"
                                var req = HttpRequestData(
                                    method: method,
                                    path: path,
                                    version: "HTTP/2",
                                    headers: [],
                                    body: "",
                                    query_string: "",
                                    remote_addr: self.peer_addr
                                )
                                self.pending_requests.push((sid, req))
                                print "[CF] pending_requests.len={self.pending_requests.len()}"
                            elif ft == 6:
                                # PING — need opaque_data from payload
                                val ping_payload = _slice_bytes(self.recv_buf, offset - header.length, header.length)
                                self.pending_writes.push(0)
                                self.pending_writes.push(0)
                                self.pending_writes.push(8)
                                self.pending_writes.push(6)
                                self.pending_writes.push(1)
                                self.pending_writes.push(0)
                                self.pending_writes.push(0)
                                self.pending_writes.push(0)
                                self.pending_writes.push(0)
                                var pi = 0
                                while pi < ping_payload.len():
                                    self.pending_writes.push(ping_payload[pi])
                                    pi = pi + 1
                            elif ft == 0:
                                pass_dn
                            elif ft == 7:
                                keep_going = false
                                has_frames = false
        if offset > 0:
            self.recv_buf = _slice_from(self.recv_buf, offset)
        return keep_going

    # ========================================================================
    # Frame dispatch
    # ========================================================================

    me dispatch_frame(frame: H2Frame) -> bool:
        """Route a parsed frame to the appropriate handler.

        Returns true to continue, false to close.
        """
        match frame:
            H2Frame.Settings(sf):
                self.handle_settings(sf)
                return true

            H2Frame.Ping(pf):
                self.handle_ping(pf)
                return true

            H2Frame.WindowUpdate(wf):
                self.handle_window_update(wf)
                return true

            H2Frame.Goaway(gf):
                # Peer is shutting down — stop accepting new streams
                return false

            H2Frame.Headers(hf):
                self.handle_headers(hf)
                return true

            H2Frame.Data(df):
                self.handle_data(df)
                return true

            H2Frame.RstStream(rf):
                self.handle_rst_stream(rf)
                return true

            H2Frame.Priority(pr):
                # Priority is deprecated in RFC 9113; ignore
                return true

            H2Frame.PushPromise(pp):
                # Server does not receive PUSH_PROMISE; protocol error
                self.queue_goaway(self.last_stream_id, H2_ERR_PROTOCOL_ERROR)
                return false

            H2Frame.Continuation(cf):
                # Merge continuation header block into the stream accumulator
                val cstream = self.streams.get(cf.stream_id)
                if cstream.?:
                    var cs = cstream
                    cs.on_headers(cf.header_block, cf.flags)
                    self.streams[cf.stream_id] = cs
                    if cs.is_request_complete() and not cs.request_dispatched:
                        self._decode_and_buffer_request(cf.stream_id, cs)
                return true

    # ========================================================================
    # SETTINGS handling
    # ========================================================================

    me handle_settings(sf: H2SettingsFrame):
        """Process a SETTINGS frame from the peer.

        If ACK, this acknowledges our SETTINGS. If not ACK, apply peer
        settings and send ACK back.
        """
        if (sf.flags & H2_FLAG_ACK) != 0:
            # Peer acknowledged our SETTINGS — nothing to update
            return

        # Apply peer settings
        var idx = 0
        while idx < sf.settings.len():
            val s = sf.settings[idx]
            if s.identifier == H2_SETTINGS_MAX_CONCURRENT_STREAMS:
                self.peer_max_concurrent_streams = s.value
            elif s.identifier == H2_SETTINGS_INITIAL_WINDOW_SIZE:
                self.peer_initial_window_size = s.value
            elif s.identifier == H2_SETTINGS_MAX_FRAME_SIZE:
                self.peer_max_frame_size = s.value
            idx = idx + 1

        # ACK the peer's SETTINGS
        self.queue_settings_ack()

    me queue_server_settings():
        """Queue our initial SETTINGS frame (server connection preface)."""
        var settings: [H2Setting] = []
        settings.push(H2Setting(
            identifier: H2_SETTINGS_MAX_CONCURRENT_STREAMS,
            value: self.local_max_concurrent_streams
        ))
        settings.push(H2Setting(
            identifier: H2_SETTINGS_INITIAL_WINDOW_SIZE,
            value: self.local_initial_window_size
        ))
        val frame = H2Frame.Settings(H2SettingsFrame(
            flags: 0,
            settings: settings
        ))
        val bytes = h2_write_frame(frame)
        self._queue_bytes(bytes)
        self.settings_sent = true

    me queue_settings_ack():
        """Queue a SETTINGS ACK frame."""
        var empty: [H2Setting] = []
        val frame = H2Frame.Settings(H2SettingsFrame(
            flags: H2_FLAG_ACK,
            settings: empty
        ))
        val bytes = h2_write_frame(frame)
        self._queue_bytes(bytes)

    # ========================================================================
    # PING handling
    # ========================================================================

    me handle_ping(pf: H2PingFrame):
        """Echo a PING frame back with ACK flag set."""
        if (pf.flags & H2_FLAG_ACK) != 0:
            # This is a PING ACK — nothing to do
            return
        val ack_frame = H2Frame.Ping(H2PingFrame(
            flags: H2_FLAG_ACK,
            opaque_data: pf.opaque_data
        ))
        val bytes = h2_write_frame(ack_frame)
        self._queue_bytes(bytes)

    # ========================================================================
    # WINDOW_UPDATE handling
    # ========================================================================

    me handle_window_update(wf: H2WindowUpdateFrame):
        """Process a WINDOW_UPDATE frame (connection or stream level)."""
        if wf.stream_id == 0:
            # Connection-level window update
            self.send_window = self.send_window + wf.increment
        else:
            val stream = self.streams.get(wf.stream_id)
            if stream.?:
                var s = stream
                s.adjust_send_window(wf.increment)
                self.streams[wf.stream_id] = s

    # ========================================================================
    # HEADERS handling
    # ========================================================================

    me handle_headers(hf: H2HeadersFrame):
        """Process a HEADERS frame — create or update a stream.

        Accumulates header blocks, then when END_HEADERS + END_STREAM are
        both received, decodes via HPACK and buffers an HttpRequestData in
        pending_requests for worker to drain and route.
        """
        val sid = hf.stream_id
        if sid > self.last_stream_id:
            self.last_stream_id = sid

        # Create stream if new
        val existing = self.streams.get(sid)
        if not existing.?:
            var new_stream = H2Stream.new(sid, self.local_initial_window_size)
            new_stream.on_headers(hf.header_block, hf.flags)
            self.streams[sid] = new_stream
        else:
            var s = existing
            s.on_headers(hf.header_block, hf.flags)
            self.streams[sid] = s

        # Check if request is complete (END_HEADERS + END_STREAM received)
        val stream = self.streams.get(sid)
        if stream.?:
            if stream.is_request_complete() and not stream.request_dispatched:
                self._decode_and_buffer_request(sid, stream)

    me _decode_and_buffer_request(sid: i64, stream: H2Stream):
        """Decode HPACK header blocks and build an HttpRequestData.

        Concatenates all received header block fragments, decodes via HPACK
        static table, extracts pseudo-headers (:method, :path, :authority)
        and regular headers, then buffers result in pending_requests.

        On HPACK decode failure sends GOAWAY(COMPRESSION_ERROR) per RFC 7541 §6.
        """
        # Concatenate all header block fragments
        val combined = stream.combined_header_block()

        # HPACK decode
        val decode_result = hpack_decode(combined, self.hpack_table)

        if decode_result.bytes_consumed == 0 and decode_result.headers.len() == 0 and combined.len() > 0:
            # Decode produced nothing from non-empty input — compression error
            self.queue_goaway(self.last_stream_id, H2_ERR_COMPRESSION_ERROR)
            return

        # Extract pseudo-headers and regular headers
        var method = "GET"
        var path = "/"
        var query = ""
        var authority = ""
        var req_headers: [(text, text)] = []

        var di = 0
        while di < decode_result.headers.len():
            val entry = decode_result.headers[di]
            if entry.name == ":method":
                method = entry.value
            elif entry.name == ":path":
                # Split path on first '?' into path + query
                val qpos = _find_char(entry.value, 63)  # 63 = '?'
                if qpos >= 0:
                    path = _slice_text(entry.value, 0, qpos)
                    query = _slice_text(entry.value, qpos + 1, entry.value.len())
                else:
                    path = entry.value
            elif entry.name == ":authority":
                authority = entry.value
            elif entry.name == ":scheme":
                pass_dn  # Ignore :scheme pseudo-header
            else:
                # Regular header — skip any remaining pseudo-headers defensively
                if entry.name.len() > 0 and entry.name.byte_at(0) != 58:  # 58 = ':'
                    req_headers.push((entry.name, entry.value))
            di = di + 1

        # Synthesize Host header from :authority (RFC 7540 §8.1.2.3)
        if authority.len() > 0:
            req_headers.push(("Host", authority))

        # Assemble body from accumulated DATA frames
        val body_bytes = stream.combined_data()
        val body = rt_bytes_to_text(body_bytes)

        # Build HttpRequestData
        val request = HttpRequestData(
            method: method,
            path: path,
            query: query,
            version: "HTTP/2",
            headers: req_headers,
            body: body,
            params: {},
            peer_addr: self.peer_addr
        )

        self.pending_requests.push((sid, request))

        # Mark stream so stray frames do not re-trigger decode
        val done_stream = self.streams.get(sid)
        if done_stream.?:
            var ds = done_stream
            ds.request_dispatched = true
            self.streams[sid] = ds

    # ========================================================================
    # DATA handling
    # ========================================================================

    me handle_data(df: H2DataFrame):
        """Process a DATA frame — append to stream body.

        When END_STREAM arrives on DATA and END_HEADERS was already received,
        the request is complete — decode and buffer it for worker to drain.
        """
        val sid = df.stream_id
        val stream = self.streams.get(sid)
        if not stream.?:
            # DATA on unknown stream — connection error
            self.queue_rst_stream(sid, H2_ERR_PROTOCOL_ERROR)
            return

        var s = stream
        s.on_data(df.data, df.flags)
        self.streams[sid] = s

        # Credit connection-level receive window
        val data_len = df.data.len()
        if data_len > 0:
            self.recv_window = self.recv_window - data_len
            if self.recv_window < DEFAULT_CONNECTION_WINDOW / 2:
                val increment = DEFAULT_CONNECTION_WINDOW - self.recv_window
                self.queue_window_update(0, increment)
                self.recv_window = self.recv_window + increment

        # If DATA completed the request (END_STREAM after prior END_HEADERS),
        # decode headers + body and buffer in pending_requests.
        val updated_stream = self.streams.get(sid)
        if updated_stream.?:
            if updated_stream.is_request_complete() and not updated_stream.request_dispatched:
                self._decode_and_buffer_request(sid, updated_stream)

    # ========================================================================
    # RST_STREAM handling
    # ========================================================================

    me handle_rst_stream(rf: H2RstStreamFrame):
        """Process a RST_STREAM — close the stream."""
        val stream = self.streams.get(rf.stream_id)
        if stream.?:
            var s = stream
            s.close()
            self.streams[rf.stream_id] = s

    # ========================================================================
    # Outbound frame helpers
    # ========================================================================

    me queue_goaway(last_sid: i64, error_code: i64):
        """Queue a GOAWAY frame and mark connection as shutting down."""
        var empty: [u8] = []
        val frame = H2Frame.Goaway(H2GoawayFrame(
            last_stream_id: last_sid,
            error_code: error_code,
            debug_data: empty
        ))
        val bytes = h2_write_frame(frame)
        self._queue_bytes(bytes)
        self.goaway_sent = true

    me queue_rst_stream(stream_id: i64, error_code: i64):
        """Queue a RST_STREAM frame for a specific stream."""
        val frame = H2Frame.RstStream(H2RstStreamFrame(
            stream_id: stream_id,
            error_code: error_code
        ))
        val bytes = h2_write_frame(frame)
        self._queue_bytes(bytes)

    me queue_window_update(stream_id: i64, increment: i64):
        """Queue a WINDOW_UPDATE frame."""
        val frame = H2Frame.WindowUpdate(H2WindowUpdateFrame(
            stream_id: stream_id,
            increment: increment
        ))
        val bytes = h2_write_frame(frame)
        self._queue_bytes(bytes)

# ============================================================================
# Buffer helpers
# ============================================================================

fn _slice_from(buf: [u8], start: i64) -> [u8]:
    """Return buf[start..] as a new [u8]."""
    var out: [u8] = []
    var i = start
    while i < buf.len():
        out.push(buf[i])
        i = i + 1
    return out

fn _append_to(dst: [u8], src: [u8]):
    """Append all bytes from src onto dst."""
    var i = 0
    while i < src.len():
        dst.push(src[i])
        i = i + 1

fn _find_char(s: text, byte_val: i64) -> i64:
    """Return index of first occurrence of byte_val in s, or -1."""
    var i = 0
    while i < s.len():
        if s.byte_at(i) == byte_val:
            return i
        i = i + 1
    return -1

fn _slice_text(s: text, start: i64, end: i64) -> text:
    """Return s[start..end) as a new text string."""
    var buf: [u8] = []
    var i = start
    while i < end and i < s.len():
        buf.push(s.byte_at(i))
        i = i + 1
    return rt_bytes_to_text(buf)

fn _byte_to_text(b: i64) -> text:
    """Convert a single byte value to a one-character text string."""
    var scratch: [u8] = []
    scratch.push(b)
    return rt_bytes_to_text(scratch)

extern fn rt_bytes_to_text(bytes: [u8]) -> text
