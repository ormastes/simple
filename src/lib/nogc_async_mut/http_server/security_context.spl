# HTTP transport bridge for SecurityContext propagation.

use std.http_server.handler.{HandlerRegistry}
use std.http_server.types.{HttpRequestData, HttpResponseData, LocationConfig, default_response_data}
use std.security.auth.context_propagation.{enter_security_context, exit_security_context, enter_task_security_context, exit_task_security_context}
use std.security.types.{SecurityContext, RemoteSecurityKeyRolloutProvider, RemoteSecuritySessionStore, RemoteSecuritySessionStoreAdapter, RemoteSecuritySigningKeyRing, reconstruct_remote_security_context, remote_security_headers_from_pairs, remote_security_session_id_from_pairs, validate_remote_security_context, validate_remote_security_context_with_adapters, validate_remote_security_context_with_key_ring}

fn security_context_from_request(request: HttpRequestData) -> SecurityContext:
    val remote_headers = remote_security_headers_from_pairs(request.headers)
    val session_id = remote_security_session_id_from_pairs(request.headers)
    reconstruct_remote_security_context(remote_headers, request.peer_addr, session_id, "", [])

fn validated_security_context_from_request(request: HttpRequestData,
                                           signing_key: text,
                                           now_ms: i64) -> SecurityContext:
    val remote_headers = remote_security_headers_from_pairs(request.headers)
    val session_id = remote_security_session_id_from_pairs(request.headers)
    validate_remote_security_context(remote_headers, request.peer_addr, session_id, signing_key, now_ms)

fn validated_security_context_from_request_with_key_ring(request: HttpRequestData,
                                                        key_ring: RemoteSecuritySigningKeyRing,
                                                        session_store: RemoteSecuritySessionStore,
                                                        now_ms: i64) -> SecurityContext:
    val remote_headers = remote_security_headers_from_pairs(request.headers)
    val session_id = remote_security_session_id_from_pairs(request.headers)
    validate_remote_security_context_with_key_ring(remote_headers, request.peer_addr, session_id, key_ring, session_store, now_ms)

fn validated_security_context_from_request_with_adapters(request: HttpRequestData,
                                                        key_provider: RemoteSecurityKeyRolloutProvider,
                                                        session_adapter: RemoteSecuritySessionStoreAdapter,
                                                        now_ms: i64) -> SecurityContext:
    val remote_headers = remote_security_headers_from_pairs(request.headers)
    val session_id = remote_security_session_id_from_pairs(request.headers)
    validate_remote_security_context_with_adapters(remote_headers, request.peer_addr, session_id, key_provider, session_adapter, now_ms)

fn dispatch_with_remote_security_context(registry: HandlerRegistry,
                                         location: LocationConfig,
                                         request: HttpRequestData) -> HttpResponseData:
    val ctx = security_context_from_request(request)
    val prev_id = enter_security_context(ctx)
    val response = registry.dispatch(location.handler_type, request, location)
    exit_security_context(ctx, prev_id)
    return response

fn dispatch_with_task_remote_security_context(registry: HandlerRegistry,
                                              task_id: text,
                                              location: LocationConfig,
                                              request: HttpRequestData) -> HttpResponseData:
    val ctx = security_context_from_request(request)
    val previous = enter_task_security_context(task_id, ctx)
    val response = registry.dispatch(location.handler_type, request, location)
    exit_task_security_context(task_id, previous)
    return response

fn dispatch_handler_with_remote_security_context(handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                 location: LocationConfig,
                                                 request: HttpRequestData) -> HttpResponseData:
    val ctx = security_context_from_request(request)
    val prev_id = enter_security_context(ctx)
    val response = handler(request, location)
    exit_security_context(ctx, prev_id)
    return response

fn dispatch_handler_with_validated_remote_security_context(handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                           location: LocationConfig,
                                                           request: HttpRequestData,
                                                           signing_key: text,
                                                           now_ms: i64) -> HttpResponseData:
    val ctx = validated_security_context_from_request(request, signing_key, now_ms)
    val prev_id = enter_security_context(ctx)
    val response = handler(request, location)
    exit_security_context(ctx, prev_id)
    return response

fn dispatch_handler_with_key_ring_validated_remote_security_context(handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                                    location: LocationConfig,
                                                                    request: HttpRequestData,
                                                                    key_ring: RemoteSecuritySigningKeyRing,
                                                                    session_store: RemoteSecuritySessionStore,
                                                                    now_ms: i64) -> HttpResponseData:
    val ctx = validated_security_context_from_request_with_key_ring(request, key_ring, session_store, now_ms)
    val prev_id = enter_security_context(ctx)
    val response = handler(request, location)
    exit_security_context(ctx, prev_id)
    return response

fn dispatch_handler_with_adapter_validated_remote_security_context(handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                                   location: LocationConfig,
                                                                   request: HttpRequestData,
                                                                   key_provider: RemoteSecurityKeyRolloutProvider,
                                                                   session_adapter: RemoteSecuritySessionStoreAdapter,
                                                                   now_ms: i64) -> HttpResponseData:
    val ctx = validated_security_context_from_request_with_adapters(request, key_provider, session_adapter, now_ms)
    val prev_id = enter_security_context(ctx)
    val response = handler(request, location)
    exit_security_context(ctx, prev_id)
    return response

fn dispatch_handler_with_task_security_context(task_id: text,
                                               handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                               location: LocationConfig,
                                               request: HttpRequestData) -> HttpResponseData:
    val ctx = security_context_from_request(request)
    val previous = enter_task_security_context(task_id, ctx)
    val response = handler(request, location)
    exit_task_security_context(task_id, previous)
    return response

fn dispatch_handler_with_validated_task_security_context(task_id: text,
                                                         handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                         location: LocationConfig,
                                                         request: HttpRequestData,
                                                         signing_key: text,
                                                         now_ms: i64) -> HttpResponseData:
    val ctx = validated_security_context_from_request(request, signing_key, now_ms)
    val previous = enter_task_security_context(task_id, ctx)
    val response = handler(request, location)
    exit_task_security_context(task_id, previous)
    return response

fn dispatch_handler_with_adapter_validated_task_security_context(task_id: text,
                                                                handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData,
                                                                location: LocationConfig,
                                                                request: HttpRequestData,
                                                                key_provider: RemoteSecurityKeyRolloutProvider,
                                                                session_adapter: RemoteSecuritySessionStoreAdapter,
                                                                now_ms: i64) -> HttpResponseData:
    val ctx = validated_security_context_from_request_with_adapters(request, key_provider, session_adapter, now_ms)
    val previous = enter_task_security_context(task_id, ctx)
    val response = handler(request, location)
    exit_task_security_context(task_id, previous)
    return response
