"""
# Content Handler Trait and Registry

Defines the ContentHandler trait that all request handlers implement.
The HandlerRegistry maps handler type names to handler instances.

## Built-in Handlers

| Type | Handler | Description |
|------|---------|-------------|
| "static" | StaticFileHandler | Serve files from root directory |
| "proxy" | (future) | Reverse proxy to upstream |
| "app" | (future) | Custom application handler |

## Usage

```simple
val registry = HandlerRegistry.new()
registry.register("static", static_handler)

val handler = registry.get("static")
val response = handler.handle(request, location)
```
"""

use std.http_server.types.{
    HttpRequestData, HttpResponseData, LocationConfig
}
use std.http_server.response.{build_error}
use std.http_server.static_file.{StaticFileHandler}

# ============================================================================
# Content Handler Trait
# ============================================================================

trait ContentHandler:
    """Trait for content generation handlers.

    Implement this to create custom handlers for different
    location handler_type values (static, proxy, app, etc.).
    """
    fn handle(request: HttpRequestData, location: LocationConfig) -> HttpResponseData

# ============================================================================
# Handler Registry
# ============================================================================

class HandlerRegistry:
    """Maps handler type names to ContentHandler instances.

    The Worker uses this to dispatch requests to the correct
    handler based on the location's handler_type field.
    """
    static_handler: StaticFileHandler?
    custom_handlers: Dict<text, fn(HttpRequestData, LocationConfig) -> HttpResponseData>

    static fn new() -> HandlerRegistry:
        """Create an empty registry."""
        HandlerRegistry(
            static_handler: nil,
            custom_handlers: {}
        )

    me set_static_handler(handler: StaticFileHandler):
        """Register the static file handler."""
        self.static_handler = handler

    me register(name: text,
                handler: fn(HttpRequestData, LocationConfig) -> HttpResponseData):
        """Register a custom handler function.

        Args:
            name: Handler type name (matches location.handler_type)
            handler: Function to handle requests
        """
        self.custom_handlers[name] = handler

    fn dispatch(handler_type: text, request: HttpRequestData,
                location: LocationConfig) -> HttpResponseData:
        """Dispatch a request to the appropriate handler.

        Args:
            handler_type: Type from location config
            request: HTTP request to handle
            location: Matched location config

        Returns:
            Response from handler, or 501 if handler not found
        """
        match handler_type:
            "static":
                match self.static_handler:
                    Some(h): h.handle(request, location)
                    nil: build_error(501, "Static file handler not configured")

            _:
                val custom = self.custom_handlers.get(handler_type)
                match custom:
                    Some(h): h(request, location)
                    nil: build_error(501, "No handler registered for type: {handler_type}")

# ============================================================================
# Default Handler Setup
# ============================================================================

fn create_default_registry(default_root: text) -> HandlerRegistry:
    """Create a HandlerRegistry with default static file handler.

    Args:
        default_root: Default root directory for static files

    Returns:
        Registry with static handler configured
    """
    var registry = HandlerRegistry.new()
    val static_h = StaticFileHandler.new(default_root, "index.html")
    registry.set_static_handler(static_h)
    registry
