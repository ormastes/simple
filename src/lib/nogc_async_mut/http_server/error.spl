"""
# HTTP Server Errors

Error types for the async HTTP server.

## Error Categories

| Variant | When |
|---------|------|
| BindFailed | Cannot bind to address |
| AcceptFailed | Cannot accept connection |
| ReadError | Socket read failure |
| WriteError | Socket write failure |
| ParseError | Malformed HTTP request |
| RouteNotFound | No matching location |
| Timeout | Read/write/keepalive timeout |
| ConfigError | Invalid SDN config |
| TooManyConnections | Worker at max_connections |
| BodyTooLarge | Exceeds client_max_body_size |
| TlsError | TLS cert/key loading or handshake failure |
| Internal | Unexpected server error |
"""

use std.http.problem.{ProblemDetail}
use std.http_server.types.{HttpResponseData}

# ============================================================================
# HttpServerError
# ============================================================================

enum HttpServerError:
    """Error type for async HTTP server operations."""
    BindFailed(text)
    AcceptFailed(text)
    ReadError(text)
    WriteError(text)
    ParseError(text)
    RouteNotFound(text)
    Timeout(text)
    ConfigError(text)
    TooManyConnections(text)
    BodyTooLarge(text)
    TlsError(text)
    Internal(text)

fn error_message(err: HttpServerError) -> text:
    """Extract message from any error variant."""
    match err:
        HttpServerError.BindFailed(msg): msg
        HttpServerError.AcceptFailed(msg): msg
        HttpServerError.ReadError(msg): msg
        HttpServerError.WriteError(msg): msg
        HttpServerError.ParseError(msg): msg
        HttpServerError.RouteNotFound(msg): msg
        HttpServerError.Timeout(msg): msg
        HttpServerError.ConfigError(msg): msg
        HttpServerError.TooManyConnections(msg): msg
        HttpServerError.BodyTooLarge(msg): msg
        HttpServerError.TlsError(msg): msg
        HttpServerError.Internal(msg): msg

fn error_status_code(err: HttpServerError) -> i64:
    """Map error to HTTP status code."""
    match err:
        HttpServerError.ParseError(_): 400
        HttpServerError.RouteNotFound(_): 404
        HttpServerError.Timeout(_): 408
        HttpServerError.BodyTooLarge(_): 413
        HttpServerError.TooManyConnections(_): 503
        HttpServerError.TlsError(_): 500
        _: 500

# ============================================================================
# Error Page Generation
# ============================================================================

fn error_page(status: i64, reason: text, message: text) -> text:
    """Generate a minimal HTML error page."""
    "<html><head><title>{status} {reason}</title></head>" +
    "<body><h1>{status} {reason}</h1><p>{message}</p>" +
    "<hr><p>SimpleServer</p></body></html>"

fn error_response_body(err: HttpServerError) -> text:
    """Generate error page from HttpServerError."""
    val status = error_status_code(err)
    val reason = status_reason_for(status)
    val msg = error_message(err)
    error_page(status, reason, msg)

fn status_reason_for(code: i64) -> text:
    """Quick status reason lookup for error pages."""
    match code:
        400: "Bad Request"
        404: "Not Found"
        408: "Request Timeout"
        413: "Content Too Large"
        429: "Too Many Requests"
        500: "Internal Server Error"
        502: "Bad Gateway"
        503: "Service Unavailable"
        _: "Error"

# ============================================================================
# RFC 7807 Problem Detail Integration
# ============================================================================

fn error_to_problem_detail(err: HttpServerError) -> ProblemDetail:
    """Convert an HttpServerError to an RFC 7807 ProblemDetail."""
    val status = error_status_code(err)
    val title = status_reason_for(status)
    val detail = error_message(err)
    ProblemDetail.new(status, title, detail)

fn error_to_problem_response(err: HttpServerError) -> HttpResponseData:
    """Convert an HttpServerError to an RFC 7807 JSON response."""
    val problem = error_to_problem_detail(err)
    problem.to_response()
