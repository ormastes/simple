"""
Embedded HTTP Server — Re-export Module

Re-exports the EmbeddedHttpServer from std.http_server.embedded for
alternative import path. The implementation lives in embedded.spl.

## Usage

```simple
use std.http_server.embedded_server.{EmbeddedHttpServer}

val server = EmbeddedHttpServer.new(":8080")
server.set_static_root("/var/www")
server.add_memory_file("/health", "application/json", "{\"ok\": true}")
server.get("/api/data", \req: "Hello")
server.start()
```
"""

use std.http_server.embedded.{EmbeddedHttpServer}
