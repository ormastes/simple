"""
# HTTP Server Types

Configuration structs, connection state machine enums, and shared types
for the SimpleServer async HTTP server.

## Configuration Hierarchy

```
ServerConfig
  ├── [LocationConfig]     # URL pattern → handler mapping
  ├── [UpstreamConfig]     # Reverse proxy pools (future)
  └── timeouts, limits
```

## Connection Lifecycle

```
Accepting → ReadingRequest → ProcessingHeaders → Routing
  → ExecutingHandler → SendingResponse → KeepAlive → (loop or Close)
```
"""

# ============================================================================
# Connection State Machine
# ============================================================================

enum ConnectionState:
    """State of a single HTTP connection."""
    Accepting
    ReadingRequest
    ProcessingHeaders
    Routing
    ExecutingHandler
    SendingResponse
    KeepAlive
    Closing

enum ConnectionAction:
    """Action returned by connection state machine to worker."""
    ContinueReading
    RequestReady
    WriteResponse(text)
    SendFile(text, i64, i64)
    Close
    Error(i64, text)

# ============================================================================
# Load Balancing (for future upstream support)
# ============================================================================

enum LoadBalanceStrategy:
    """Strategy for distributing requests across upstream servers."""
    RoundRobin
    LeastConnections
    IpHash

# ============================================================================
# Request Processing Phases (nginx-style)
# ============================================================================

enum Phase:
    """nginx-style request processing phase."""
    PostAccept
    PreRead
    Read
    Rewrite
    Access
    Content
    Log

enum PhaseResult:
    """Result of middleware/phase handler execution."""
    Continue
    Skip
    Respond(i64, text, text)
    Error(i64, text)

# ============================================================================
# Server Configuration
# ============================================================================

class ServerConfig:
    """Top-level server configuration."""
    listen_addr: text
    worker_count: i64
    max_connections: i64
    keepalive_timeout_ms: i64
    read_timeout_ms: i64
    write_timeout_ms: i64
    client_max_body_size: i64
    server_name: text
    locations: [LocationConfig]
    upstreams: [UpstreamConfig]
    access_log: text
    error_log: text

class LocationConfig:
    """Maps a URL pattern to a handler."""
    pattern: text
    match_type: text
    handler_type: text
    root: text
    proxy_pass: text
    middlewares: [text]

class UpstreamConfig:
    """Pool of backend servers for reverse proxy."""
    name: text
    servers: [UpstreamServer]
    strategy: LoadBalanceStrategy

class UpstreamServer:
    """Single backend server in an upstream pool."""
    addr: text
    weight: i64
    max_fails: i64
    fail_timeout_ms: i64

# ============================================================================
# Parsed HTTP Request Data
# ============================================================================

class HttpRequestData:
    """Parsed HTTP request ready for routing."""
    method: text
    path: text
    query: text
    version: text
    headers: [(text, text)]
    body: text
    params: Dict<text, text>
    peer_addr: text

class HttpResponseData:
    """HTTP response to serialize and send."""
    status: i64
    reason: text
    headers: [(text, text)]
    body: text
    body_file: text
    body_offset: i64
    body_length: i64
    chunked: bool

# ============================================================================
# Worker Handle
# ============================================================================

class WorkerHandle:
    """Handle to a running worker thread."""
    worker_id: i64
    thread_handle: i64
    is_alive: bool

# ============================================================================
# Default Configuration Constructors
# ============================================================================

fn default_server_config() -> ServerConfig:
    """Create ServerConfig with sensible defaults."""
    ServerConfig(
        listen_addr: "0.0.0.0:8080",
        worker_count: 0,
        max_connections: 10000,
        keepalive_timeout_ms: 65000,
        read_timeout_ms: 60000,
        write_timeout_ms: 60000,
        client_max_body_size: 1048576,
        server_name: "SimpleServer",
        locations: [],
        upstreams: [],
        access_log: "",
        error_log: ""
    )

fn default_location_config() -> LocationConfig:
    """Create empty LocationConfig."""
    LocationConfig(
        pattern: "/",
        match_type: "prefix",
        handler_type: "static",
        root: ".",
        proxy_pass: "",
        middlewares: []
    )

fn default_response_data(status: i64, reason: text, body: text) -> HttpResponseData:
    """Create a simple text response."""
    HttpResponseData(
        status: status,
        reason: reason,
        headers: [("Content-Type", "text/html"), ("Server", "SimpleServer")],
        body: body,
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )
