"""
# Phase-Based Middleware Pipeline

nginx-style request processing phases. Each phase runs zero or more
handlers in priority order. Any handler can short-circuit with a
response or error.

## Phases

| Phase | Purpose | Built-in Handler |
|-------|---------|------------------|
| PostAccept | Connection-level checks | connection_limit |
| PreRead | Pre-body rate limiting | (app layer) |
| Read | Body validation | body_limit |
| Rewrite | URL normalization | (app layer) |
| Access | Auth, CORS | (app layer) |
| Content | Handler dispatch | static_file |
| Log | Access logging | access_log |

## Usage

```simple
val pipeline = MiddlewarePipeline.new()
pipeline.add(Phase.PostAccept, 100, "conn_limit", connection_limit_handler)
pipeline.add(Phase.Log, 50, "access_log", access_log_handler)

val result = pipeline.run_phase(Phase.PostAccept, request, config)
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, HttpResponseData, ServerConfig
}

# ============================================================================
# Middleware Entry
# ============================================================================

class MiddlewareEntry:
    """A middleware handler registered for a specific phase."""
    phase: Phase
    priority: i64
    name: text
    handler: fn(HttpRequestData, ServerConfig) -> PhaseResult

# ============================================================================
# Middleware Pipeline
# ============================================================================

class MiddlewarePipeline:
    """Ordered pipeline of middleware handlers grouped by phase.

    Handlers within a phase run in descending priority order
    (highest priority first). Any handler returning Respond or
    Error short-circuits the pipeline.
    """
    entries: [MiddlewareEntry]

    static fn new() -> MiddlewarePipeline:
        """Create an empty pipeline."""
        MiddlewarePipeline(entries: [])

    me add(phase: Phase, priority: i64, name: text,
           handler: fn(HttpRequestData, ServerConfig) -> PhaseResult):
        """Register a middleware handler for a phase.

        Args:
            phase: Which processing phase to run in
            priority: Higher runs first within the phase
            name: Identifier for logging
            handler: Function to execute
        """
        val entry = MiddlewareEntry(
            phase: phase,
            priority: priority,
            name: name,
            handler: handler
        )
        self.entries = self.entries + [entry]

    fn run_phase(phase: Phase, request: HttpRequestData,
                 config: ServerConfig) -> PhaseResult:
        """Run all handlers for a specific phase.

        Handlers execute in descending priority order. If any returns
        Respond or Error, the remaining handlers are skipped.

        Args:
            phase: Phase to execute
            request: Current request
            config: Server config

        Returns:
            Continue if all passed, or the first short-circuit result
        """
        # Collect handlers for this phase, sorted by priority desc
        var phase_handlers: [MiddlewareEntry] = []
        for entry in self.entries:
            if phase_matches(entry.phase, phase):
                phase_handlers = insert_by_priority(phase_handlers, entry)

        for entry in phase_handlers:
            val result = entry.handler(request, config)
            match result:
                PhaseResult.Continue:
                    pass_do_nothing
                PhaseResult.Skip:
                    return PhaseResult.Continue
                PhaseResult.Respond(status, reason, body):
                    return result
                PhaseResult.Error(status, msg):
                    return result

        PhaseResult.Continue

    fn run_all_phases(request: HttpRequestData,
                      config: ServerConfig) -> PhaseResult:
        """Run all phases in order: PostAccept through Log.

        Short-circuits on the first Respond or Error.

        Args:
            request: Current request
            config: Server config

        Returns:
            Continue if all passed, or the first short-circuit result
        """
        val phases = [
            Phase.PostAccept,
            Phase.PreRead,
            Phase.Read,
            Phase.Rewrite,
            Phase.Access
        ]

        for phase in phases:
            val result = self.run_phase(phase, request, config)
            match result:
                PhaseResult.Continue:
                    pass_do_nothing
                _:
                    return result

        PhaseResult.Continue

    fn run_log_phase(request: HttpRequestData,
                     config: ServerConfig) -> PhaseResult:
        """Run the Log phase (after response is sent).

        Args:
            request: Completed request
            config: Server config
        """
        self.run_phase(Phase.Log, request, config)

# ============================================================================
# Built-in Phase Handlers
# ============================================================================

fn connection_limit_handler(request: HttpRequestData,
                            config: ServerConfig) -> PhaseResult:
    """PostAccept: Stub for connection limit checking.

    Actual connection counting is done in the Worker, but this
    handler can add additional per-IP or per-route limits.
    """
    PhaseResult.Continue

fn body_limit_handler(request: HttpRequestData,
                      config: ServerConfig) -> PhaseResult:
    """Read: Reject requests with body exceeding client_max_body_size."""
    if request.body.len() > config.client_max_body_size:
        return PhaseResult.Error(413, "Request body too large")
    PhaseResult.Continue

# ============================================================================
# Helpers
# ============================================================================

fn phase_matches(a: Phase, b: Phase) -> bool:
    """Compare two Phase enum values."""
    match (a, b):
        (Phase.PostAccept, Phase.PostAccept): true
        (Phase.PreRead, Phase.PreRead): true
        (Phase.Read, Phase.Read): true
        (Phase.Rewrite, Phase.Rewrite): true
        (Phase.Access, Phase.Access): true
        (Phase.Content, Phase.Content): true
        (Phase.Log, Phase.Log): true
        _: false

fn insert_by_priority(list: [MiddlewareEntry], entry: MiddlewareEntry) -> [MiddlewareEntry]:
    """Insert entry into list maintaining descending priority order."""
    var result: [MiddlewareEntry] = []
    var inserted = false

    for existing in list:
        if not inserted and entry.priority > existing.priority:
            result = result + [entry]
            inserted = true
        result = result + [existing]

    if not inserted:
        result = result + [entry]

    result
