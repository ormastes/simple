}

# Shared utilities (used by both full and embedded servers)
use std.http_server.shared.{
    parse_http_request, serialize_http_response,
    match_route, RouteMatch, SimpleRoute
}

# Middleware
use std.http_server.middleware.{
    MiddlewarePipeline, MiddlewareEntry,
    connection_limit_handler, body_limit_handler
}

# Compression middleware
use std.http_server.compression.{
    compress_response, compression_handler, supported_encodings
}

# Handlers
use std.http_server.handler.{
    ContentHandler, HandlerRegistry, create_default_registry
}

# Static files
use std.http_server.static_file.{StaticFileHandler, mime_from_extension}

# Range requests (RFC 7233)
use std.http_server.range.{
    find_header, parse_range_header,
    build_range_response, build_multipart_range_response,
    generate_boundary
}

# Access log
use std.http_server.access_log.{
    access_log_handler, format_log_entry, format_log_entry_with_status
}

# Embedded server (lightweight single-thread variant)
use std.http_server.embedded.{EmbeddedHttpServer}

# Multi-file download (ZIP/TAR archive streaming)
use std.http_server.multipart_response.{MultipartResponse}

# Response cache (per-worker, avoids re-serialization)
use std.http_server.response_cache.{ResponseCache, CacheEntry}
