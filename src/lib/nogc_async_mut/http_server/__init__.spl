    async_proxy_status_line_valid,
    async_proxy_validate_response_headers,
    async_proxy_idle_timed_out,
    async_proxy_clamp_sent,
    async_proxy_mark_request_sent,
    async_proxy_method_supported,
    async_proxy_pool_acquire,
    async_proxy_pool_can_keep_idle,
    async_proxy_pool_decision,
    async_proxy_pool_default_config,
    async_proxy_pool_entry,
    async_proxy_pool_entry_reusable,
    async_proxy_pool_idle_count,
    async_proxy_pool_mark_acquired,
    async_proxy_pool_mark_closed,
    async_proxy_pool_mark_released,
    async_proxy_pool_stressed,
    async_proxy_production_hardening_evidence,
    async_proxy_peer,
    async_proxy_peer_apply_probe_failure,
    async_proxy_peer_apply_probe_success,
    async_proxy_peer_begin,
    async_proxy_peer_finish,
    async_proxy_peer_from_server,
    async_proxy_peer_healthy,
    async_proxy_peer_probe_due,
    async_proxy_peer_record_failure,
    async_proxy_peer_record_success,
    async_proxy_peer_score,
    async_proxy_peer_usable,
    async_proxy_last_probe_ms,
    async_proxy_mark_health_probe_attempt,
    async_proxy_plan,
    async_proxy_plan_with_peers,
    async_proxy_parse_header_request,
    async_proxy_prepare_client_chunk,
    async_proxy_remaining_after_send,
    async_proxy_request_remaining,
    async_proxy_request_stream,
    async_proxy_request_transfer_chunked,
    async_proxy_response_headers_complete,
    async_proxy_response_allows_reuse,
    async_proxy_response_complete,
    async_proxy_response_reusable,
    async_proxy_transfer_chunked,
    async_proxy_resolve_upstream,
    async_proxy_resolve_upstream_with_peers,
    async_proxy_route_enabled,
    async_proxy_select_least_connections_peer,
    async_proxy_select_peer,
    async_proxy_select_round_robin_peer,
    async_proxy_select_server,
    async_proxy_select_server_with_peers,
    async_proxy_serialize_request,
    async_proxy_serialize_tunnel_request,
    async_proxy_timed_out,
    async_proxy_throughput_bytes_per_sec,
    async_proxy_tunnel_connection,
    async_proxy_tunnel_connection_with_limit,
    async_proxy_tunnel_kind,
    async_proxy_tunnel_mark_client_data_sent,
    async_proxy_tunnel_mark_closed,
    async_proxy_tunnel_mark_setup_sent,
    async_proxy_tunnel_mark_upstream_data_sent,
    async_proxy_tunnel_pending_over_budget,
    async_proxy_tunnel_plan,
    async_proxy_tunnel_plan_with_peers,
    async_proxy_tunnel_prepare_upstream_handshake,
    async_proxy_tunnel_requested,
    async_proxy_tunnel_setup_complete,
