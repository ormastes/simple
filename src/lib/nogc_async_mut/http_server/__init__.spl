"""
# SimpleServer — Async HTTP Server

High-performance async HTTP server with nginx-inspired master-worker
architecture. Written entirely in Simple.

## Quick Start

```simple
use std.http_server.{HttpServer, ServerConfig}
use std.http_server.config.{load_config}

# From config file
val server = HttpServer.from_config_file("server.sdn")?
server.start()?
server.wait()

# Or programmatic
val config = ServerConfig(
    listen_addr: "0.0.0.0:8080",
    worker_count: 0,
    max_connections: 10000,
    keepalive_timeout_ms: 65000,
    read_timeout_ms: 60000,
    write_timeout_ms: 60000,
    client_max_body_size: 1048576,
    server_name: "SimpleServer",
    locations: [],
    upstreams: [],
    access_log: "",
    error_log: ""
)
val server = HttpServer.new(config)
server.start()?
server.wait()
```

## Architecture

```
HttpServer (master)
  ├── Supervisor (one_for_one restart)
  ├── Worker 0 (EventLoop + IoDriver + connections)
  ├── Worker 1
  └── Worker N  (N = CPU count by default)
```

Each worker:
- Binds its own listener via SO_REUSEPORT
- Owns its own EventLoop (epoll/kqueue)
- Manages thousands of connections via IoDriver completions
- Processes requests through nginx-style phase pipeline

## Modules

| Module | Purpose |
|--------|---------|
| server | Master HttpServer, lifecycle, supervisor |
| worker | Worker thread, event loop, I/O dispatch |
| connection | Connection state machine |
| parser | Incremental HTTP/1.1 request parser |
| response | HTTP response serialization and builders |
| router | URL pattern matching and routing |
| middleware | Phase-based middleware pipeline |
| compression | Response compression (gzip, brotli, deflate, zstd, lz4) |
| handler | ContentHandler trait and registry |
| static_file | Static file serving with sendfile |
| access_log | Request logging |
| config | SDN configuration parser |
| types | Shared types and enums |
| error | Error types and error pages |
| embedded | Lightweight single-thread embedded server |
| embedded_server | Re-export of embedded server |
| multipart_response | Multi-file ZIP/TAR download builder |
"""

# Core server
use std.http_server.server.{HttpServer}
use std.http_server.config.{load_config, parse_config_text}

# Types
use std.http_server.types.{
    ServerConfig, LocationConfig, UpstreamConfig, UpstreamServer,
    HttpRequestData, HttpResponseData, WorkerHandle,
    ConnectionState, ConnectionAction,
    LoadBalanceStrategy, Phase, PhaseResult,
    default_server_config, default_location_config, default_response_data
}

# Error handling
use std.http_server.error.{
    HttpServerError, error_message, error_status_code, error_page
}

# Response builders
use std.http_server.response.{
    serialize_response,
    build_ok, build_json, build_html, build_text,
    build_redirect, build_error, build_not_found,
    build_method_not_allowed, build_request_timeout,
    build_too_large, build_internal_error, build_service_unavailable,
    build_file_response, build_not_modified,
    add_keepalive_headers
}

# Router
use std.http_server.router.{AsyncRouter}

