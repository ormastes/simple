# Brush — configuration for painting tools
#
# Defines brush tip shapes and brush parameters used by
# the rasterizer to stamp pixels onto layers.

# ============================================================================
# Brush Tip
# ============================================================================

enum BrushTip:
    Round
    Square

# ============================================================================
# Brush Config
# ============================================================================

struct BrushConfig:
    size: f64
    hardness: f64
    opacity: f64
    spacing: f64
    color: i64
    tip: BrushTip
    pressure_size: bool
    pressure_opacity: bool

impl BrushConfig:
    static fn default_brush() -> BrushConfig:
        """A soft round brush with medium size."""
        BrushConfig(
            size: 20.0,
            hardness: 0.8,
            opacity: 1.0,
            spacing: 0.25,
            color: 4278190080,  # 0xFF000000 — opaque black (RGBA packed)
            tip: BrushTip.Round,
            pressure_size: true,
            pressure_opacity: false
        )

    static fn default_eraser() -> BrushConfig:
        """An eraser brush — paints with transparent."""
        BrushConfig(
            size: 30.0,
            hardness: 1.0,
            opacity: 1.0,
            spacing: 0.2,
            color: 0,  # transparent
            tip: BrushTip.Round,
            pressure_size: true,
            pressure_opacity: true
        )

    static fn pencil() -> BrushConfig:
        """A hard, small, 1-pixel-spaced pencil."""
        BrushConfig(
            size: 1.0,
            hardness: 1.0,
            opacity: 1.0,
            spacing: 1.0,
            color: 4278190080,  # opaque black
            tip: BrushTip.Square,
            pressure_size: false,
            pressure_opacity: false
        )

    fn effective_size(self, pressure: f64) -> f64:
        """Return brush size scaled by pressure if pressure_size is enabled."""
        if self.pressure_size:
            return self.size * pressure
        self.size

    fn effective_opacity(self, pressure: f64) -> f64:
        """Return opacity scaled by pressure if pressure_opacity is enabled."""
        if self.pressure_opacity:
            return self.opacity * pressure
        self.opacity
