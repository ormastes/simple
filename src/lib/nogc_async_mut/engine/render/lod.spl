# LOD System — Distance-based mesh/detail level switching
#
# Provides level-of-detail management for rendering. Each LODGroup
# holds sorted LOD levels with distance thresholds. LODManager
# owns multiple groups and provides convenience lookups.

# ============================================================================
# LODLevel — a single level-of-detail threshold
# ============================================================================

struct LODLevel:
    """A single LOD threshold.

    Fields:
        level: LOD index (0 = highest detail / closest)
        max_distance: Maximum camera distance for this level
        detail_name: Human-readable name for this detail tier
    """
    level: i32
    max_distance: f64
    detail_name: text

impl LODLevel:
    static fn new(level: i32, max_distance: f64, detail_name: text) -> LODLevel:
        """Create a new LOD level."""
        LODLevel(
            level: level,
            max_distance: max_distance,
            detail_name: detail_name
        )

# ============================================================================
# LODGroup — a named collection of LOD levels sorted by distance
# ============================================================================

class LODGroup:
    """A named group of LOD levels, sorted by ascending max_distance.

    Fields:
        name: Identifier for this LOD group
        levels: Sorted array of LODLevel entries
    """
    name: text
    levels: [LODLevel]

impl LODGroup:
    static fn new(name: text) -> LODGroup:
        """Create an empty LOD group."""
        LODGroup(
            name: name,
            levels: []
        )

    me add_level(level: i32, max_distance: f64, detail_name: text):
        """Insert a new LOD level, keeping levels sorted by max_distance."""
        val new_level = LODLevel.new(level, max_distance, detail_name)
        var result: [LODLevel] = []
        var inserted = false
        var i = 0
        while i < self.levels.len():
            val existing = self.levels[i]
            if not inserted and max_distance < existing.max_distance:
                result = result.push(new_level)
                inserted = true
            result = result.push(existing)
            i = i + 1
        if not inserted:
            result = result.push(new_level)
        self.levels = result

    fn select_level(distance: f64) -> i32:
        """Return the LOD level index for the given camera distance.

        Walks levels in order and returns the first whose max_distance
        exceeds the query distance. If the distance is beyond all
        thresholds, returns the last level index.
        """
        var i = 0
        while i < self.levels.len():
            val lod = self.levels[i]
            if distance < lod.max_distance:
                return lod.level
            i = i + 1
        # Beyond all levels — return last
        if self.levels.len() > 0:
            val last = self.levels[self.levels.len() - 1]
            return last.level
        0

    fn get_detail_name(level: i32) -> text:
        """Return the detail_name for a given level index, or 'unknown'."""
        var i = 0
        while i < self.levels.len():
            val lod = self.levels[i]
            if lod.level == level:
                return lod.detail_name
            i = i + 1
        "unknown"

    fn level_count() -> i32:
        """Return the number of LOD levels in this group."""
        self.levels.len()

# ============================================================================
# LODManager — owns multiple LOD groups
# ============================================================================

class LODManager:
    """Manages a collection of LODGroups, indexed by insertion order."""
    groups: [LODGroup]

impl LODManager:
    static fn new() -> LODManager:
        """Create an empty LOD manager."""
        LODManager(
            groups: []
        )

    me add_group(group: LODGroup) -> i32:
        """Add a group and return its index."""
        self.groups = self.groups.push(group)
        self.groups.len() - 1

    fn get_group(index: i32) -> LODGroup?:
        """Return the group at the given index, or nil."""
        if index >= 0 and index < self.groups.len():
            return self.groups[index]
        nil

    fn select_for_distance(group_index: i32, distance: f64) -> i32:
        """Convenience: select the LOD level for a given group and distance."""
        if group_index >= 0 and group_index < self.groups.len():
            val group = self.groups[group_index]
            return group.select_level(distance)
        0

    fn group_count() -> i32:
        """Return the number of managed groups."""
        self.groups.len()
