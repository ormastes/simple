# Material3D — 3D surface appearance description
#
# PBR, Phong, and Unlit material types for the 3D render pipeline.
#
# Usage:
#   val mat = pbr_material(EngineColor.red(), 0.5, 0.3)
#   val unlit = unlit_material(EngineColor.white())

use std.common.engine.color.{EngineColor}
use std.common.engine.ids.{TextureId}
use std.nogc_async_mut.engine.render.backend3d.{RenderBackend3D, RenderPassHandle, PipelineHandle}
use std.nogc_async_mut.engine.render.texture3d.{TextureCache3D, texture_cache_get}

# ============================================================================
# MaterialType3D
# ============================================================================

enum MaterialType3D:
    PBR
    Phong
    Unlit

# ============================================================================
# Material3D
# ============================================================================

class Material3D:
    material_type: MaterialType3D
    albedo: EngineColor
    albedo_texture: TextureId
    metallic: f64
    roughness: f64
    emissive: EngineColor
    emissive_intensity: f64

impl Material3D:
    fn has_texture() -> bool:
        """Check whether this material references a valid albedo texture."""
        self.albedo_texture.is_valid()

# ============================================================================
# Material constructors
# ============================================================================

fn pbr_material(albedo: EngineColor, metallic: f64, roughness: f64) -> Material3D:
    """Create a PBR material with given albedo, metallic, and roughness."""
    Material3D(
        material_type: MaterialType3D.PBR,
        albedo: albedo,
        albedo_texture: TextureId.invalid(),
        metallic: metallic,
        roughness: roughness,
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )

fn phong_material(diffuse: EngineColor, shininess: f64) -> Material3D:
    """Create a Phong material. Shininess maps to inverse roughness."""
    Material3D(
        material_type: MaterialType3D.Phong,
        albedo: diffuse,
        albedo_texture: TextureId.invalid(),
        metallic: 0.0,
        roughness: 1.0 / (shininess + 1.0),
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )

fn unlit_material(color: EngineColor) -> Material3D:
    """Create an unlit material (no lighting calculations)."""
    Material3D(
        material_type: MaterialType3D.Unlit,
        albedo: color,
        albedo_texture: TextureId.invalid(),
        metallic: 0.0,
        roughness: 1.0,
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )

# ============================================================================
# material_bind — bind material textures to a render pass
# ============================================================================

fn material_bind(mat: Material3D, cache: TextureCache3D, backend: RenderBackend3D, rph: RenderPassHandle):
    """Bind material GPU textures to the given render pass.

    Albedo texture is bound to slot 0 when the material has a valid texture id.
    """
    if mat.has_texture():
        val h = texture_cache_get(cache, mat.albedo_texture.to_index())
        backend.bind_texture(rph, h, 0)

# ============================================================================
# pipeline_for_mat_type — select pipeline by material type
# ============================================================================

fn pipeline_for_mat_type(mat_type: MaterialType3D) -> PipelineHandle:
    """Return a placeholder PipelineHandle discriminated by material type.

    Actual pipeline creation is performed by the Engine3D outer layer.
    IDs are reserved: 0 = PBR, 1 = Phong, 2 = Unlit.
    """
    match mat_type:
        MaterialType3D.PBR => PipelineHandle(id: 0)
        MaterialType3D.Phong => PipelineHandle(id: 1)
        MaterialType3D.Unlit => PipelineHandle(id: 2)
