# std.nogc_async_mut.engine.render.webgpu_backend3d — WebGpuRenderBackend3D
#
# Implements RenderBackend3D for WebGPU via rt_wgpu_3d_* externs.
#
# Command recording model (matches Vulkan sibling):
#   - Resource creation (create_pipeline, create_*_buffer, create_texture):
#     synchronous — calls extern immediately, registers id→native mapping.
#   - upload_buffer, upload_texture: synchronous.
#   - begin_render_pass, set_pipeline, bind_*, draw_indexed, end_render_pass:
#     recorded into cmds[]. The active pass handle id is cmds.len() at
#     the moment of begin_render_pass recording.
#   - begin_frame, end_frame, present, shutdown: call extern directly;
#     end_frame drains cmds[] first.
#
# Key difference from Vulkan backend: create_pipeline takes WGSL text via
# desc.vertex_shader_wgsl / desc.fragment_shader_wgsl (not SPIR-V bytes).

use std.nogc_async_mut.engine.render.backend3d.{
    PipelineHandle, BufferHandle, TextureHandle, RenderPassHandle,
    PipelineDesc3D, TextureFormat3D, RenderBackend3D
}
use std.nogc_async_mut.engine.render.capability3d.{RenderCapability3D, capability_webgpu_3d}
use std.nogc_async_mut.engine.render.webgpu_commands.{
    WebGpuCommand3D, WebGpuCommand3DKind,
    wgpu_cmd3d_begin_render_pass, wgpu_cmd3d_set_pipeline,
    wgpu_cmd3d_bind_vertex_buffer, wgpu_cmd3d_bind_index_buffer,
    wgpu_cmd3d_bind_texture, wgpu_cmd3d_bind_uniform_buffer,
    wgpu_cmd3d_draw_indexed, wgpu_cmd3d_end_render_pass
}

# ============================================================================
# rt_wgpu_3d_* extern declarations — 3D WebGPU surface
# ============================================================================

extern fn rt_wgpu_3d_init(width: i64, height: i64) -> i64
extern fn rt_wgpu_3d_create_buffer(byte_count: i64, usage: i64) -> i64
extern fn rt_wgpu_3d_upload_buffer(handle: i64, data: [u8], offset: i64)
extern fn rt_wgpu_3d_create_texture(width: i64, height: i64, format: i64) -> i64
extern fn rt_wgpu_3d_upload_texture(handle: i64, data: [u8])
extern fn rt_wgpu_3d_create_pipeline(wgsl_vert: text, wgsl_frag: text) -> i64
extern fn rt_wgpu_3d_begin_frame()
extern fn rt_wgpu_3d_begin_render_pass(color: i64, depth: i64) -> i64
extern fn rt_wgpu_3d_end_render_pass(rph: i64)
extern fn rt_wgpu_3d_cmd_set_pipeline(rph: i64, pipeline: i64)
extern fn rt_wgpu_3d_cmd_bind_vertex_buffer(rph: i64, buf: i64, slot: i64)
extern fn rt_wgpu_3d_cmd_bind_index_buffer(rph: i64, buf: i64)
extern fn rt_wgpu_3d_cmd_bind_texture(rph: i64, tex: i64, slot: i64)
extern fn rt_wgpu_3d_cmd_bind_uniform_buffer(rph: i64, buf: i64, slot: i64)
extern fn rt_wgpu_3d_cmd_draw_indexed(rph: i64, index_count: i64, base_vertex: i64)
extern fn rt_wgpu_3d_end_frame()
extern fn rt_wgpu_3d_present()
extern fn rt_wgpu_3d_shutdown()

# ============================================================================
# TextureFormat3D → i64 helper (maps enum to WebGPU format constant)
# ============================================================================

fn _texture_format_to_i64(fmt: TextureFormat3D) -> i64:
    if fmt == TextureFormat3D.Rgba8Unorm:   0
    else: if fmt == TextureFormat3D.Rgba8Srgb:   1
    else: if fmt == TextureFormat3D.R8Unorm:     2
    else: if fmt == TextureFormat3D.Depth32Float: 3
    else: 0

# ============================================================================
# WebGpuRenderBackend3D — command-recording WebGPU backend
# ============================================================================

class WebGpuRenderBackend3D:
    cmds:           [WebGpuCommand3D]
    cap:            RenderCapability3D
    pipeline_ids:   [i64]
    pipeline_native: [i64]
    buffer_ids:     [i64]
    buffer_native:  [i64]
    texture_ids:    [i64]
    texture_native: [i64]
    next_id:        i64
    width:          i64
    height:         i64
    active_pass_ids: [i64]
    last_errors:    [text]

    static fn create() -> WebGpuRenderBackend3D:
        WebGpuRenderBackend3D(
            cmds:            [],
            cap:             capability_webgpu_3d(),
            pipeline_ids:    [],
            pipeline_native: [],
            buffer_ids:      [],
            buffer_native:   [],
            texture_ids:     [],
            texture_native:  [],
            next_id:         1,
            width:           0,
            height:          0,
            active_pass_ids: [],
            last_errors:     []
        )

# ============================================================================
# Internal lookup helpers
# ============================================================================

fn _find_native_pipeline(ids: [i64], natives: [i64], id: i64) -> i64:
    var i = 0
    var found = -1 as i64
    while i < ids.len():
        if ids[i] == id:
            found = natives[i]
        i = i + 1
    found

fn _find_native_buffer(ids: [i64], natives: [i64], id: i64) -> i64:
    var i = 0
    var found = -1 as i64
    while i < ids.len():
        if ids[i] == id:
            found = natives[i]
        i = i + 1
    found

fn _find_native_texture(ids: [i64], natives: [i64], id: i64) -> i64:
    var i = 0
    var found = -1 as i64
    while i < ids.len():
        if ids[i] == id:
            found = natives[i]
        i = i + 1
    found

impl WebGpuRenderBackend3D:

    me _clear_error():
        self.last_errors.clear()

    me _record_error(message: text):
        self.last_errors.clear()
        self.last_errors.push(message)

    me _has_pipeline(pipeline: PipelineHandle) -> bool:
        _find_native_pipeline(self.pipeline_ids, self.pipeline_native, pipeline.id) >= 0

    me _has_buffer(buf: BufferHandle) -> bool:
        _find_native_buffer(self.buffer_ids, self.buffer_native, buf.id) >= 0

    me _has_texture(tex: TextureHandle) -> bool:
        _find_native_texture(self.texture_ids, self.texture_native, tex.id) >= 0

    me _is_active_pass(rph: RenderPassHandle) -> bool:
        self.active_pass_ids.len() > 0 and self.active_pass_ids[0] == rph.id

# ============================================================================
# impl RenderBackend3D for WebGpuRenderBackend3D
# ============================================================================

impl RenderBackend3D for WebGpuRenderBackend3D:

    fn capabilities(self) -> RenderCapability3D:
        self.cap

    fn init(self, width: i64, height: i64) -> bool:
        val ok = rt_wgpu_3d_init(width, height)
        self.width = width
        self.height = height
        ok != 0

    # --- Resource creation (synchronous) ---

    fn create_pipeline(self, desc: PipelineDesc3D) -> PipelineHandle:
        val native = rt_wgpu_3d_create_pipeline(
            desc.vertex_shader_wgsl,
            desc.fragment_shader_wgsl
        )
        val id = self.pipeline_ids.len() as i64 + 1
        self.pipeline_ids.push(id)
        self.pipeline_native.push(native)
        PipelineHandle(id: id)

    fn create_vertex_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 0 = vertex
        val native = rt_wgpu_3d_create_buffer(byte_count, 0)
        val id = self.buffer_ids.len() as i64 + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn create_index_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 1 = index
        val native = rt_wgpu_3d_create_buffer(byte_count, 1)
        val id = self.buffer_ids.len() as i64 + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn create_uniform_buffer(self, byte_count: i64) -> BufferHandle:
        # usage 2 = uniform
        val native = rt_wgpu_3d_create_buffer(byte_count, 2)
        val id = self.buffer_ids.len() as i64 + 1
        self.buffer_ids.push(id)
        self.buffer_native.push(native)
        BufferHandle(id: id)

    fn upload_buffer(self, buf: BufferHandle, data: [u8], offset: i64):
        val native = _find_native_buffer(self.buffer_ids, self.buffer_native, buf.id)
        if native >= 0:
            rt_wgpu_3d_upload_buffer(native, data, offset)

    fn create_texture(self, width: i64, height: i64, format: TextureFormat3D) -> TextureHandle:
        val fmt_i64 = _texture_format_to_i64(format)
        val native = rt_wgpu_3d_create_texture(width, height, fmt_i64)
        val id = self.texture_ids.len() as i64 + 1
        self.texture_ids.push(id)
        self.texture_native.push(native)
        TextureHandle(id: id)

    fn upload_texture(self, tex: TextureHandle, data: [u8]):
        val native = _find_native_texture(self.texture_ids, self.texture_native, tex.id)
        if native >= 0:
            rt_wgpu_3d_upload_texture(native, data)

    # --- Frame control (direct extern calls) ---

    fn begin_frame(self):
        self.active_pass_ids.clear()
        self._clear_error()
        rt_wgpu_3d_begin_frame()

    # --- Command recording ---

    fn begin_render_pass(self, color_tex: TextureHandle, depth_tex: TextureHandle) -> RenderPassHandle:
        if self.active_pass_ids.len() > 0:
            self._record_error("WebGPU render pass already active")
            return RenderPassHandle.invalid()
        if not self._has_texture(color_tex):
            self._record_error("invalid WebGPU color attachment")
            return RenderPassHandle.invalid()
        if not self._has_texture(depth_tex):
            self._record_error("invalid WebGPU depth attachment")
            return RenderPassHandle.invalid()
        val pass_id = self.cmds.len() as i64
        self.cmds.push(wgpu_cmd3d_begin_render_pass(color_tex.id, depth_tex.id))
        self.active_pass_ids.push(pass_id)
        self._clear_error()
        RenderPassHandle(id: pass_id)

    fn set_pipeline(self, rph: RenderPassHandle, pipeline: PipelineHandle):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if not self._has_pipeline(pipeline):
            self._record_error("invalid WebGPU pipeline handle")
            return
        self.cmds.push(wgpu_cmd3d_set_pipeline(pipeline.id))
        self._clear_error()

    fn bind_vertex_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if slot < 0:
            self._record_error("invalid WebGPU vertex buffer slot")
            return
        if not self._has_buffer(buf):
            self._record_error("invalid WebGPU vertex buffer handle")
            return
        self.cmds.push(wgpu_cmd3d_bind_vertex_buffer(buf.id, slot))
        self._clear_error()

    fn bind_index_buffer(self, rph: RenderPassHandle, buf: BufferHandle):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if not self._has_buffer(buf):
            self._record_error("invalid WebGPU index buffer handle")
            return
        self.cmds.push(wgpu_cmd3d_bind_index_buffer(buf.id))
        self._clear_error()

    fn bind_texture(self, rph: RenderPassHandle, tex: TextureHandle, slot: i64):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if slot < 0:
            self._record_error("invalid WebGPU texture slot")
            return
        if not self._has_texture(tex):
            self._record_error("invalid WebGPU texture handle")
            return
        self.cmds.push(wgpu_cmd3d_bind_texture(tex.id, slot))
        self._clear_error()

    fn bind_uniform_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if slot < 0:
            self._record_error("invalid WebGPU uniform buffer slot")
            return
        if not self._has_buffer(buf):
            self._record_error("invalid WebGPU uniform buffer handle")
            return
        self.cmds.push(wgpu_cmd3d_bind_uniform_buffer(buf.id, slot))
        self._clear_error()

    fn draw_indexed(self, rph: RenderPassHandle, index_count: i64, base_vertex: i64):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        if index_count <= 0:
            self._record_error("invalid WebGPU draw index count")
            return
        self.cmds.push(wgpu_cmd3d_draw_indexed(index_count, base_vertex))
        self._clear_error()

    fn end_render_pass(self, rph: RenderPassHandle):
        if not self._is_active_pass(rph):
            self._record_error("invalid WebGPU render pass handle")
            return
        self.cmds.push(wgpu_cmd3d_end_render_pass())
        self.active_pass_ids.clear()
        self._clear_error()

    # --- end_frame: dispatch cmds[] to rt_wgpu_3d_cmd_* externs ---
    # Uses kind-tag field access (WebGpuCommand3DKind) — no enum destructuring.

    fn end_frame(self):
        var active_pass = -1 as i64
        var i = 0
        while i < self.cmds.len():
            val cmd = self.cmds[i]
            if cmd.kind == WebGpuCommand3DKind.BeginRenderPass:
                val color_native = _find_native_texture(
                    self.texture_ids, self.texture_native, cmd.color_tex_id)
                val depth_native = _find_native_texture(
                    self.texture_ids, self.texture_native, cmd.depth_tex_id)
                active_pass = rt_wgpu_3d_begin_render_pass(color_native, depth_native)
            else: if cmd.kind == WebGpuCommand3DKind.SetPipeline:
                val p_native = _find_native_pipeline(
                    self.pipeline_ids, self.pipeline_native, cmd.pipeline_id)
                if (active_pass >= 0 and p_native >= 0):
                    rt_wgpu_3d_cmd_set_pipeline(active_pass, p_native)
            else: if cmd.kind == WebGpuCommand3DKind.BindVertexBuffer:
                val b_native = _find_native_buffer(
                    self.buffer_ids, self.buffer_native, cmd.buffer_id)
                if (active_pass >= 0 and b_native >= 0):
                    rt_wgpu_3d_cmd_bind_vertex_buffer(active_pass, b_native, cmd.slot)
            else: if cmd.kind == WebGpuCommand3DKind.BindIndexBuffer:
                val b_native = _find_native_buffer(
                    self.buffer_ids, self.buffer_native, cmd.buffer_id)
                if (active_pass >= 0 and b_native >= 0):
                    rt_wgpu_3d_cmd_bind_index_buffer(active_pass, b_native)
            else: if cmd.kind == WebGpuCommand3DKind.BindTexture:
                val t_native = _find_native_texture(
                    self.texture_ids, self.texture_native, cmd.texture_id)
                if (active_pass >= 0 and t_native >= 0):
                    rt_wgpu_3d_cmd_bind_texture(active_pass, t_native, cmd.slot)
            else: if cmd.kind == WebGpuCommand3DKind.BindUniformBuffer:
                val b_native = _find_native_buffer(
                    self.buffer_ids, self.buffer_native, cmd.buffer_id)
                if (active_pass >= 0 and b_native >= 0):
                    rt_wgpu_3d_cmd_bind_uniform_buffer(active_pass, b_native, cmd.slot)
            else: if cmd.kind == WebGpuCommand3DKind.DrawIndexed:
                if active_pass >= 0:
                    rt_wgpu_3d_cmd_draw_indexed(active_pass, cmd.index_count, cmd.base_vertex)
            else: if cmd.kind == WebGpuCommand3DKind.EndRenderPass:
                if active_pass >= 0:
                    rt_wgpu_3d_end_render_pass(active_pass)
                    active_pass = -1
            i = i + 1
        self.cmds.clear()
        rt_wgpu_3d_end_frame()

    fn present(self):
        rt_wgpu_3d_present()

    fn shutdown(self):
        rt_wgpu_3d_shutdown()
