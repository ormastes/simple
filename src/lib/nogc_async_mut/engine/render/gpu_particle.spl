# GPU Particle — compute shader dispatch for particle simulation
#
# When a GPU backend is available, particle update and rendering
# can be offloaded. This module provides the buffer layout and
# dispatch configuration. Falls back to CPU ParticleEmitter.

use std.nogc_async_mut.engine.render.particle.{Particle, EmitterConfig, ParticleEmitter}

# ============================================================================
# GpuParticleBuffer — GPU-side storage descriptor
# ============================================================================

struct GpuParticleBuffer:
    buffer_handle: i64
    max_count: i32
    alive_count: i32
    stride_bytes: i32

impl GpuParticleBuffer:
    static fn new(max_count: i32) -> GpuParticleBuffer:
        """Create a GPU buffer descriptor.
        Stride = 64 bytes per particle (x,y,vx,vy,life,max_life,size,color = 8 floats)."""
        GpuParticleBuffer(
            buffer_handle: 0,
            max_count: max_count,
            alive_count: 0,
            stride_bytes: 64
        )

    fn is_valid(self) -> bool:
        """A buffer is valid when its handle is non-zero (GPU allocated)."""
        self.buffer_handle != 0

# ============================================================================
# GpuParticleConfig — dispatch configuration
# ============================================================================

struct GpuParticleConfig:
    workgroup_size: i32
    use_gpu: bool

fn default_gpu_particle_config() -> GpuParticleConfig:
    """Default GPU particle config: workgroup size 64, GPU enabled."""
    GpuParticleConfig(
        workgroup_size: 64,
        use_gpu: true
    )

# ============================================================================
# ParticleBackend — selects compute path
# ============================================================================

enum ParticleBackend:
    CpuBackend
    GpuBackend

# ============================================================================
# GpuParticleSystem — unified GPU/CPU particle system
# ============================================================================

class GpuParticleSystem:
    config: GpuParticleConfig
    backend: ParticleBackend
    cpu_fallback: ParticleEmitter
    buffer: GpuParticleBuffer
    dispatch_count: i64

impl GpuParticleSystem:
    static fn new(emitter_config: EmitterConfig, gpu_config: GpuParticleConfig) -> GpuParticleSystem:
        """Create a particle system. If gpu_config.use_gpu is true, attempts
        GPU allocation. Falls back to CPU when buffer handle is 0."""
        val buf = GpuParticleBuffer.new(emitter_config.max_particles)
        # Buffer handle remains 0 (no real GPU alloc yet), so we fall back
        var chosen_backend = ParticleBackend.CpuBackend
        if gpu_config.use_gpu:
            if buf.is_valid():
                chosen_backend = ParticleBackend.GpuBackend
        GpuParticleSystem(
            config: gpu_config,
            backend: chosen_backend,
            cpu_fallback: ParticleEmitter.new(emitter_config),
            buffer: buf,
            dispatch_count: 0
        )

    me update(dt: f64):
        """Advance simulation. GPU path increments dispatch_count;
        CPU path delegates to the fallback emitter."""
        if self.is_gpu():
            # GPU path: actual dispatch would use SFFI compute call
            self.dispatch_count = self.dispatch_count + 1
        else:
            self.cpu_fallback.update(dt)

    me set_position(x: f64, y: f64):
        """Set emitter position on both GPU and CPU paths."""
        self.cpu_fallback.set_position(x, y)

    me start():
        """Activate the particle system."""
        self.cpu_fallback.start()

    me stop():
        """Deactivate spawning. Existing particles continue until death."""
        self.cpu_fallback.stop()

    fn alive_count(self) -> i32:
        """Return the number of living particles."""
        if self.is_gpu():
            self.buffer.alive_count
        else:
            self.cpu_fallback.alive_count()

    fn is_gpu(self) -> bool:
        """Return true if running on the GPU backend."""
        if val ParticleBackend.GpuBackend = self.backend:
            true
        else:
            false

    fn dispatch_count_total(self) -> i64:
        """Return total number of GPU compute dispatches."""
        self.dispatch_count

    me reset():
        """Clear all particles, reset counters."""
        self.cpu_fallback.reset()
        self.buffer = GpuParticleBuffer.new(self.buffer.max_count)
        self.dispatch_count = 0
