# 3D Lighting System
#
# Directional, point, and spot lights with a central LightManager.
#
# Usage:
#   var mgr = LightManager.new()
#   mgr.set_ambient(LightColor.warm(), 0.2)
#   val idx = mgr.add_point(PointLight.new(0.0, 5.0, 0.0, LightColor.white(), 1.0, 10.0))

struct LightColor:
    r: f64
    g: f64
    b: f64

impl LightColor:
    static fn white() -> LightColor:
        LightColor(r: 1.0, g: 1.0, b: 1.0)

    static fn warm() -> LightColor:
        LightColor(r: 1.0, g: 0.9, b: 0.7)

    static fn cool() -> LightColor:
        LightColor(r: 0.7, g: 0.85, b: 1.0)

    fn intensity_scaled(factor: f64) -> LightColor:
        LightColor(r: self.r * factor, g: self.g * factor, b: self.b * factor)

struct DirectionalLight:
    direction_x: f64
    direction_y: f64
    direction_z: f64
    color: LightColor
    intensity: f64
    cast_shadows: bool
    active: bool

impl DirectionalLight:
    static fn new(dx: f64, dy: f64, dz: f64, color: LightColor, intensity: f64) -> DirectionalLight:
        DirectionalLight(
            direction_x: dx,
            direction_y: dy,
            direction_z: dz,
            color: color,
            intensity: intensity,
            cast_shadows: true,
            active: true
        )

struct PointLight:
    position_x: f64
    position_y: f64
    position_z: f64
    color: LightColor
    intensity: f64
    radius: f64
    falloff: f64
    active: bool

impl PointLight:
    static fn new(x: f64, y: f64, z: f64, color: LightColor, intensity: f64, radius: f64) -> PointLight:
        PointLight(
            position_x: x,
            position_y: y,
            position_z: z,
            color: color,
            intensity: intensity,
            radius: radius,
            falloff: 1.0,
            active: true
        )

    fn attenuation_at(distance: f64) -> f64:
        if distance > self.radius:
            return 0.0
        1.0 / (1.0 + self.falloff * distance * distance)

struct SpotLight:
    position_x: f64
    position_y: f64
    position_z: f64
    direction_x: f64
    direction_y: f64
    direction_z: f64
    color: LightColor
    intensity: f64
    inner_angle: f64
    outer_angle: f64
    range: f64
    active: bool

impl SpotLight:
    static fn new(x: f64, y: f64, z: f64, dx: f64, dy: f64, dz: f64, intensity: f64, inner: f64, outer: f64, range_val: f64) -> SpotLight:
        SpotLight(
            position_x: x,
            position_y: y,
            position_z: z,
            direction_x: dx,
            direction_y: dy,
            direction_z: dz,
            color: LightColor.white(),
            intensity: intensity,
            inner_angle: inner,
            outer_angle: outer,
            range: range_val,
            active: true
        )

class LightManager:
    directional_lights: [DirectionalLight]
    point_lights: [PointLight]
    spot_lights: [SpotLight]
    ambient_color: LightColor
    ambient_intensity: f64

impl LightManager:
    static fn new() -> LightManager:
        LightManager(
            directional_lights: [],
            point_lights: [],
            spot_lights: [],
            ambient_color: LightColor.white(),
            ambient_intensity: 0.1
        )

    me set_ambient(color: LightColor, intensity: f64):
        self.ambient_color = color
        self.ambient_intensity = intensity

    me add_directional(light: DirectionalLight) -> i32:
        self.directional_lights.push(light)
        var idx: i32 = self.directional_lights.len() - 1
        idx

    me add_point(light: PointLight) -> i32:
        self.point_lights.push(light)
        var idx: i32 = self.point_lights.len() - 1
        idx

    me add_spot(light: SpotLight) -> i32:
        self.spot_lights.push(light)
        var idx: i32 = self.spot_lights.len() - 1
        idx

    me remove_point(index: i32) -> bool:
        var idx: i64 = index
        if idx < 0:
            return false
        if idx >= self.point_lights.len():
            return false
        self.point_lights.remove(idx)
        true

    fn directional_count() -> i32:
        var count: i32 = self.directional_lights.len()
        count

    fn point_count() -> i32:
        var count: i32 = self.point_lights.len()
        count

    fn spot_count() -> i32:
        var count: i32 = self.spot_lights.len()
        count

    fn total_light_count() -> i32:
        var total: i32 = self.directional_lights.len() + self.point_lights.len() + self.spot_lights.len()
        total

    me clear():
        self.directional_lights = []
        self.point_lights = []
        self.spot_lights = []
