# GPU Instancing — batched draw calls for repeated objects

struct InstanceData:
    position_x: f64
    position_y: f64
    position_z: f64
    scale_x: f64
    scale_y: f64
    scale_z: f64
    rotation: f64

impl InstanceData:
    static fn new(x: f64, y: f64, z: f64) -> InstanceData:
        InstanceData(
            position_x: x, position_y: y, position_z: z,
            scale_x: 1.0, scale_y: 1.0, scale_z: 1.0, rotation: 0.0
        )

    static fn with_scale(x: f64, y: f64, z: f64, sx: f64, sy: f64, sz: f64) -> InstanceData:
        InstanceData(
            position_x: x, position_y: y, position_z: z,
            scale_x: sx, scale_y: sy, scale_z: sz, rotation: 0.0
        )

class InstanceBatch:
    mesh_name: text
    material_name: text
    instances: [InstanceData]
    max_instances: i32
    visible: bool

impl InstanceBatch:
    static fn new(mesh_name: text, material_name: text, max_instances: i32) -> InstanceBatch:
        InstanceBatch(
            mesh_name: mesh_name, material_name: material_name,
            instances: [], max_instances: max_instances, visible: true
        )

    me add_instance(inst: InstanceData) -> i32:
        if self.instances.len().to_i32() >= self.max_instances:
            return -1
        val idx: i32 = self.instances.len()
        self.instances.push(inst)
        idx

    me remove_instance(index: i32) -> bool:
        if index < 0 or index >= self.instances.len().to_i32():
            return false
        var new_list: [InstanceData] = []
        var i = 0
        while i < self.instances.len():
            if i != index:
                new_list.push(self.instances[i])
            i = i + 1
        self.instances = new_list
        true

    me set_visible(vis: bool):
        self.visible = vis

    fn instance_count() -> i32:
        self.instances.len().to_i32()

    fn is_visible() -> bool:
        self.visible

    fn get_instance(index: i32) -> InstanceData?:
        if index < 0 or index >= self.instances.len().to_i32():
            return nil
        self.instances[index]

    me clear():
        self.instances = []

class InstanceRenderer:
    batches: [InstanceBatch]

impl InstanceRenderer:
    static fn new() -> InstanceRenderer:
        InstanceRenderer(batches: [])

    me add_batch(batch: InstanceBatch) -> i32:
        val idx: i32 = self.batches.len()
        self.batches.push(batch)
        idx

    fn batch_count() -> i32:
        self.batches.len().to_i32()

    fn total_instance_count() -> i32:
        var total = 0
        var i = 0
        while i < self.batches.len():
            if self.batches[i].visible:
                total = total + self.batches[i].instance_count()
            i = i + 1
        total
