# std.nogc_async_mut.engine.render.any_backend3d — AnyRenderBackend3D tagged enum
#
# Provides the polymorphism boundary used by Engine3D outer layer to hold any
# RenderBackend3D implementation without boxing.  Defined here (not in
# backend3d.spl) to avoid a circular import: backend3d.spl defines the trait
# and handle types; the three backend modules import backend3d.spl; this file
# imports all four so it sits at the top of the dependency graph.
#
# Engine3D stores one field of type AnyRenderBackend3D and dispatches all
# frame calls through match + trait call.

use std.nogc_async_mut.engine.render.backend3d.{
    RenderBackend3D,
    PipelineHandle, BufferHandle, TextureHandle, RenderPassHandle,
    PipelineDesc3D, TextureFormat3D
}
use std.nogc_async_mut.engine.render.capability3d.{RenderCapability3D}
use std.nogc_async_mut.engine.render.software_backend3d.{SoftwareRenderBackend3D}
use std.nogc_async_mut.engine.render.vulkan_backend3d.{VulkanRenderBackend3D}
use std.nogc_async_mut.engine.render.webgpu_backend3d.{WebGpuRenderBackend3D}

# ============================================================================
# AnyRenderBackend3D — tagged union over all backends
# ============================================================================

enum AnyRenderBackend3D:
    Software(SoftwareRenderBackend3D)
    Vulkan(VulkanRenderBackend3D)
    WebGpu(WebGpuRenderBackend3D)

impl RenderBackend3D for AnyRenderBackend3D:
    fn capabilities(self) -> RenderCapability3D:
        match self:
            AnyRenderBackend3D.Software(b) => b.capabilities()
            AnyRenderBackend3D.Vulkan(b) => b.capabilities()
            AnyRenderBackend3D.WebGpu(b) => b.capabilities()

    fn init(self, width: i64, height: i64) -> bool:
        match self:
            AnyRenderBackend3D.Software(b) => b.init(width, height)
            AnyRenderBackend3D.Vulkan(b) => b.init(width, height)
            AnyRenderBackend3D.WebGpu(b) => b.init(width, height)

    fn create_pipeline(self, desc: PipelineDesc3D) -> PipelineHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.create_pipeline(desc)
            AnyRenderBackend3D.Vulkan(b) => b.create_pipeline(desc)
            AnyRenderBackend3D.WebGpu(b) => b.create_pipeline(desc)

    fn create_vertex_buffer(self, byte_count: i64) -> BufferHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.create_vertex_buffer(byte_count)
            AnyRenderBackend3D.Vulkan(b) => b.create_vertex_buffer(byte_count)
            AnyRenderBackend3D.WebGpu(b) => b.create_vertex_buffer(byte_count)

    fn create_index_buffer(self, byte_count: i64) -> BufferHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.create_index_buffer(byte_count)
            AnyRenderBackend3D.Vulkan(b) => b.create_index_buffer(byte_count)
            AnyRenderBackend3D.WebGpu(b) => b.create_index_buffer(byte_count)

    fn create_uniform_buffer(self, byte_count: i64) -> BufferHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.create_uniform_buffer(byte_count)
            AnyRenderBackend3D.Vulkan(b) => b.create_uniform_buffer(byte_count)
            AnyRenderBackend3D.WebGpu(b) => b.create_uniform_buffer(byte_count)

    fn upload_buffer(self, buf: BufferHandle, data: [u8], offset: i64):
        match self:
            AnyRenderBackend3D.Software(b) => b.upload_buffer(buf, data, offset)
            AnyRenderBackend3D.Vulkan(b) => b.upload_buffer(buf, data, offset)
            AnyRenderBackend3D.WebGpu(b) => b.upload_buffer(buf, data, offset)

    fn create_texture(self, width: i64, height: i64, format: TextureFormat3D) -> TextureHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.create_texture(width, height, format)
            AnyRenderBackend3D.Vulkan(b) => b.create_texture(width, height, format)
            AnyRenderBackend3D.WebGpu(b) => b.create_texture(width, height, format)

    fn upload_texture(self, tex: TextureHandle, data: [u8]):
        match self:
            AnyRenderBackend3D.Software(b) => b.upload_texture(tex, data)
            AnyRenderBackend3D.Vulkan(b) => b.upload_texture(tex, data)
            AnyRenderBackend3D.WebGpu(b) => b.upload_texture(tex, data)

    fn begin_frame(self):
        match self:
            AnyRenderBackend3D.Software(b) => b.begin_frame()
            AnyRenderBackend3D.Vulkan(b) => b.begin_frame()
            AnyRenderBackend3D.WebGpu(b) => b.begin_frame()

    fn begin_render_pass(self, color_tex: TextureHandle, depth_tex: TextureHandle) -> RenderPassHandle:
        match self:
            AnyRenderBackend3D.Software(b) => b.begin_render_pass(color_tex, depth_tex)
            AnyRenderBackend3D.Vulkan(b) => b.begin_render_pass(color_tex, depth_tex)
            AnyRenderBackend3D.WebGpu(b) => b.begin_render_pass(color_tex, depth_tex)

    fn set_pipeline(self, rph: RenderPassHandle, pipeline: PipelineHandle):
        match self:
            AnyRenderBackend3D.Software(b) => b.set_pipeline(rph, pipeline)
            AnyRenderBackend3D.Vulkan(b) => b.set_pipeline(rph, pipeline)
            AnyRenderBackend3D.WebGpu(b) => b.set_pipeline(rph, pipeline)

    fn bind_vertex_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        match self:
            AnyRenderBackend3D.Software(b) => b.bind_vertex_buffer(rph, buf, slot)
            AnyRenderBackend3D.Vulkan(b) => b.bind_vertex_buffer(rph, buf, slot)
            AnyRenderBackend3D.WebGpu(b) => b.bind_vertex_buffer(rph, buf, slot)

    fn bind_index_buffer(self, rph: RenderPassHandle, buf: BufferHandle):
        match self:
            AnyRenderBackend3D.Software(b) => b.bind_index_buffer(rph, buf)
            AnyRenderBackend3D.Vulkan(b) => b.bind_index_buffer(rph, buf)
            AnyRenderBackend3D.WebGpu(b) => b.bind_index_buffer(rph, buf)

    fn bind_texture(self, rph: RenderPassHandle, tex: TextureHandle, slot: i64):
        match self:
            AnyRenderBackend3D.Software(b) => b.bind_texture(rph, tex, slot)
            AnyRenderBackend3D.Vulkan(b) => b.bind_texture(rph, tex, slot)
            AnyRenderBackend3D.WebGpu(b) => b.bind_texture(rph, tex, slot)

    fn bind_uniform_buffer(self, rph: RenderPassHandle, buf: BufferHandle, slot: i64):
        match self:
            AnyRenderBackend3D.Software(b) => b.bind_uniform_buffer(rph, buf, slot)
            AnyRenderBackend3D.Vulkan(b) => b.bind_uniform_buffer(rph, buf, slot)
            AnyRenderBackend3D.WebGpu(b) => b.bind_uniform_buffer(rph, buf, slot)

    fn draw_indexed(self, rph: RenderPassHandle, index_count: i64, base_vertex: i64):
        match self:
            AnyRenderBackend3D.Software(b) => b.draw_indexed(rph, index_count, base_vertex)
            AnyRenderBackend3D.Vulkan(b) => b.draw_indexed(rph, index_count, base_vertex)
            AnyRenderBackend3D.WebGpu(b) => b.draw_indexed(rph, index_count, base_vertex)

    fn end_render_pass(self, rph: RenderPassHandle):
        match self:
            AnyRenderBackend3D.Software(b) => b.end_render_pass(rph)
            AnyRenderBackend3D.Vulkan(b) => b.end_render_pass(rph)
            AnyRenderBackend3D.WebGpu(b) => b.end_render_pass(rph)

    fn end_frame(self):
        match self:
            AnyRenderBackend3D.Software(b) => b.end_frame()
            AnyRenderBackend3D.Vulkan(b) => b.end_frame()
            AnyRenderBackend3D.WebGpu(b) => b.end_frame()

    fn present(self):
        match self:
            AnyRenderBackend3D.Software(b) => b.present()
            AnyRenderBackend3D.Vulkan(b) => b.present()
            AnyRenderBackend3D.WebGpu(b) => b.present()

    fn shutdown(self):
        match self:
            AnyRenderBackend3D.Software(b) => b.shutdown()
            AnyRenderBackend3D.Vulkan(b) => b.shutdown()
            AnyRenderBackend3D.WebGpu(b) => b.shutdown()
