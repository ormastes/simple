# Physics System — 3D Collider Shapes
#
# Shape definitions for the pure Simple 3D physics engine.
# Each shape stores its own geometry; ColliderShape3D wraps them
# with a type code for dispatch in narrow-phase collision detection.
#
# Usage:
#   val sphere = ColliderShape3D.sphere(0.5)
#   val box = ColliderShape3D.box_shape(1.0, 0.5, 0.5)
#   val capsule = ColliderShape3D.capsule(0.3, 1.0)

# ============================================================================
# Sphere3D
# ============================================================================

class Sphere3D:
    radius: f64

    static fn create(radius: f64) -> Sphere3D:
        Sphere3D(radius: radius)

# ============================================================================
# Box3D
# ============================================================================

class Box3D:
    half_x: f64
    half_y: f64
    half_z: f64

    static fn create(hx: f64, hy: f64, hz: f64) -> Box3D:
        Box3D(half_x: hx, half_y: hy, half_z: hz)

# ============================================================================
# Capsule3D — cylinder with hemispherical caps along local Y axis
# ============================================================================

class Capsule3D:
    radius: f64
    half_height: f64

    static fn create(radius: f64, half_height: f64) -> Capsule3D:
        Capsule3D(radius: radius, half_height: half_height)

# ============================================================================
# ColliderShape3D — tagged union via shape_type code
#   0 = sphere, 1 = box, 2 = capsule
# ============================================================================

class ColliderShape3D:
    shape_type: i64
    sphere: Sphere3D
    box_shape: Box3D
    capsule: Capsule3D

    static fn sphere(radius: f64) -> ColliderShape3D:
        ColliderShape3D(
            shape_type: 0,
            sphere: Sphere3D.create(radius),
            box_shape: Box3D.create(0.0, 0.0, 0.0),
            capsule: Capsule3D.create(0.0, 0.0)
        )

    static fn box_shape(hx: f64, hy: f64, hz: f64) -> ColliderShape3D:
        ColliderShape3D(
            shape_type: 1,
            sphere: Sphere3D.create(0.0),
            box_shape: Box3D.create(hx, hy, hz),
            capsule: Capsule3D.create(0.0, 0.0)
        )

    static fn capsule(radius: f64, half_height: f64) -> ColliderShape3D:
        ColliderShape3D(
            shape_type: 2,
            sphere: Sphere3D.create(0.0),
            box_shape: Box3D.create(0.0, 0.0, 0.0),
            capsule: Capsule3D.create(radius, half_height)
        )

    fn is_sphere() -> bool:
        self.shape_type == 0

    fn is_box() -> bool:
        self.shape_type == 1

    fn is_capsule() -> bool:
        self.shape_type == 2
