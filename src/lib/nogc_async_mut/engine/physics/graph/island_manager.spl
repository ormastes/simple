# Physics2 — Island Manager (Union-Find)
#
# Groups bodies into simulation islands. Sleeping islands skip the solver
# entirely. Uses union-find (disjoint set) for O(α(n)) merge/find.

struct IslandManager:
    parent: [i64]
    rank: [i64]
    sleeping: [bool]
    sleep_timer: [f64]
    body_count: i64
    sleep_threshold: f64
    sleep_time_required: f64

impl IslandManager:
    static fn create(body_count: i64, threshold: f64, time_req: f64) -> IslandManager:
        var parent: [i64] = []
        var rank: [i64] = []
        var sleeping: [bool] = []
        var timer: [f64] = []
        var i = 0
        while i < body_count:
            parent.push(i)
            rank.push(0)
            sleeping.push(false)
            timer.push(0.0)
            i = i + 1
        IslandManager(
            parent: parent,
            rank: rank,
            sleeping: sleeping,
            sleep_timer: timer,
            body_count: body_count,
            sleep_threshold: threshold,
            sleep_time_required: time_req
        )

    me find(x: i64) -> i64:
        var node = x
        while self.parent[node] != node:
            self.parent[node] = self.parent[self.parent[node]]
            node = self.parent[node]
        node

    me union(a: i64, b: i64):
        val ra = self.find(a)
        val rb = self.find(b)
        if ra == rb:
            return
        if self.rank[ra] < self.rank[rb]:
            self.parent[ra] = rb
        elif self.rank[ra] > self.rank[rb]:
            self.parent[rb] = ra
        else:
            self.parent[rb] = ra
            self.rank[ra] = self.rank[ra] + 1

    me is_island_sleeping(body_idx: i64) -> bool:
        val root = self.find(body_idx)
        self.sleeping[root]

    me wake_island(body_idx: i64):
        val root = self.find(body_idx)
        self.sleeping[root] = false
        self.sleep_timer[root] = 0.0

    me update_sleep(body_idx: i64, kinetic_energy: f64, dt: f64):
        val root = self.find(body_idx)
        if kinetic_energy > self.sleep_threshold:
            self.sleeping[root] = false
            self.sleep_timer[root] = 0.0
        else:
            self.sleep_timer[root] = self.sleep_timer[root] + dt
            if self.sleep_timer[root] >= self.sleep_time_required:
                self.sleeping[root] = true

    me reset(new_body_count: i64):
        self.parent = []
        self.rank = []
        self.sleeping = []
        self.sleep_timer = []
        var i = 0
        while i < new_body_count:
            self.parent.push(i)
            self.rank.push(0)
            self.sleeping.push(false)
            self.sleep_timer.push(0.0)
            i = i + 1
        self.body_count = new_body_count
