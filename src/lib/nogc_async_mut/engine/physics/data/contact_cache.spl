# Physics2 — Persistent Contact Cache
#
# Matches contacts across frames using feature IDs. Warm-starts the solver
# by preserving accumulated impulses (lambda_n, lambda_t) from the previous
# step. This significantly improves stacking stability and convergence.

struct CachedContact:
    body_a: i64
    body_b: i64
    feature_id_a: i64
    feature_id_b: i64
    lambda_n: f64
    lambda_t: f64

struct ContactCache:
    entries: [CachedContact]
    count: i64

impl ContactCache:
    static fn create() -> ContactCache:
        ContactCache(entries: [], count: 0)

    me store_from_constraints(body_a: [i64], body_b: [i64], feat_a: [i64], feat_b: [i64], lambda_n: [f64], lambda_t: [f64], n: i64):
        self.entries = []
        self.count = 0
        var i = 0
        while i < n:
            self.entries.push(CachedContact(
                body_a: body_a[i],
                body_b: body_b[i],
                feature_id_a: feat_a[i],
                feature_id_b: feat_b[i],
                lambda_n: lambda_n[i],
                lambda_t: lambda_t[i]
            ))
            self.count = self.count + 1
            i = i + 1

    me find_cached(ba: i64, bb: i64, fa: i64, fb: i64) -> (f64, f64, bool):
        var i = 0
        while i < self.count:
            val e = self.entries[i]
            if e.body_a == ba and e.body_b == bb and e.feature_id_a == fa and e.feature_id_b == fb:
                return (e.lambda_n, e.lambda_t, true)
            if e.body_a == bb and e.body_b == ba and e.feature_id_a == fb and e.feature_id_b == fa:
                return (e.lambda_n, e.lambda_t, true)
            i = i + 1
        (0.0, 0.0, false)

    me clear():
        self.entries = []
        self.count = 0
