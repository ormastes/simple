# Set Operations Benchmarks
# Detailed performance analysis of Set<T> operations

use std.nogc_async_mut.src.testing.benchmark.{BenchmarkConfig, BenchmarkStats, compare, benchmark}
use std.nogc_async_mut.src.set.{Set, set_from_list}
use std.nogc_async_mut.src.map.{Map}

# ============================================================================
# Basic Operations Benchmarks
# ============================================================================

fn benchmark_basic_operations():
    print "=== Set Basic Operations ==="
    print ""

    val benchmarks = Map.new()

    # Insert benchmarks - different sizes
    benchmarks.insert("Insert 10 elements", \:
        val s: Set<i64> = Set.new()
        for i in 0..10:
            s.insert(i)
    )

    benchmarks.insert("Insert 100 elements", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)
    )

    benchmarks.insert("Insert 1000 elements", \:
        val s: Set<i64> = Set.with_capacity(1024)
        for i in 0..1000:
            s.insert(i)
    )

    benchmarks.insert("Insert 10000 elements", \:
        val s: Set<i64> = Set.with_capacity(16384)
        for i in 0..10000:
            s.insert(i)
    )

    # Contains benchmarks
    benchmarks.insert("Contains check (100 items, hit)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        for i in 0..100:
            s.contains(i)
    )

    benchmarks.insert("Contains check (100 items, miss)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        for i in 100000..100100:
            s.contains(i)
    )

    # Remove benchmarks
    benchmarks.insert("Remove 50% (from 100)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        for i in 0..50:
            s.remove(i)
    )

    benchmarks.insert("Remove all (from 100)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        for i in 0..100:
            s.remove(i)
    )

    # Run and display
    val results = compare(benchmarks, BenchmarkConfig.quick())

    for (name, stats) in results.entries():
        print "{name}:"
        print "  Mean: {BenchmarkStats.format_time(stats.mean_ns)}"
        print "  Median: {BenchmarkStats.format_time(stats.median_ns)}"
        print ""

# ============================================================================
# Set Operations Benchmarks (Union, Intersection, etc.)
# ============================================================================

fn benchmark_set_operations():
    print "=== Set Operations (Union, Intersection, Difference) ==="
    print ""

    val benchmarks = Map.new()

    # Union benchmarks
    benchmarks.insert("Union (50 + 50, no overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 100000..100050:
            s2.insert(i)

        s1.union(s2)
    )

    benchmarks.insert("Union (50 + 50, full overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
            s2.insert(i)

        s1.union(s2)
    )

    benchmarks.insert("Union (50 + 50, 50% overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 25..75:
            s2.insert(i)

        s1.union(s2)
    )

    benchmarks.insert("Union (1000 + 1000, 50% overlap)", \:
        val s1: Set<i64> = Set.with_capacity(2048)
        val s2: Set<i64> = Set.with_capacity(2048)

        for i in 0..1000:
            s1.insert(i)
        for i in 500..1500:
            s2.insert(i)

        s1.union(s2)
    )

    # Intersection benchmarks
    benchmarks.insert("Intersection (50 + 50, no overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 100000..100050:
            s2.insert(i)

        s1.intersect(s2)
    )

    benchmarks.insert("Intersection (50 + 50, full overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
            s2.insert(i)

        s1.intersect(s2)
    )

    benchmarks.insert("Intersection (50 + 50, 50% overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 25..75:
            s2.insert(i)

        s1.intersect(s2)
    )

    # Difference benchmarks
    benchmarks.insert("Difference (100 - 50, 50% overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..100:
            s1.insert(i)
        for i in 0..50:
            s2.insert(i)

        s1.diff(s2)
    )

    benchmarks.insert("Difference (100 - 100, full overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..100:
            s1.insert(i)
            s2.insert(i)

        s1.diff(s2)
    )

    # Symmetric difference
    benchmarks.insert("Symmetric Difference (50 + 50, 50% overlap)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 25..75:
            s2.insert(i)

        s1.sym_diff(s2)
    )

    # Run and display
    val results = compare(benchmarks, BenchmarkConfig.quick())

    for (name, stats) in results.entries():
        print "{name}:"
        print "  Mean: {BenchmarkStats.format_time(stats.mean_ns)}"
        print "  Median: {BenchmarkStats.format_time(stats.median_ns)}"
        print ""

# ============================================================================
# Set Predicates Benchmarks
# ============================================================================

fn benchmark_set_predicates():
    print "=== Set Predicates (is_subset, is_superset, is_disjoint) ==="
    print ""

    val benchmarks = Map.new()

    # is_subset benchmarks
    benchmarks.insert("is_subset (50 subset of 100, true)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 0..100:
            s2.insert(i)

        s1.is_subset(s2)
    )

    benchmarks.insert("is_subset (50 subset of 100, false)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 50..150:
            s2.insert(i)

        s1.is_subset(s2)
    )

    # is_superset benchmarks
    benchmarks.insert("is_superset (100 superset of 50, true)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..100:
            s1.insert(i)
        for i in 0..50:
            s2.insert(i)

        s1.is_superset(s2)
    )

    # is_disjoint benchmarks
    benchmarks.insert("is_disjoint (50 + 50, disjoint)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 100000..100050:
            s2.insert(i)

        s1.is_disjoint(s2)
    )

    benchmarks.insert("is_disjoint (50 + 50, not disjoint)", \:
        val s1: Set<i64> = Set.new()
        val s2: Set<i64> = Set.new()

        for i in 0..50:
            s1.insert(i)
        for i in 25..75:
            s2.insert(i)

        s1.is_disjoint(s2)
    )

    # Run and display
    val results = compare(benchmarks, BenchmarkConfig.quick())

    for (name, stats) in results.entries():
        print "{name}:"
        print "  Mean: {BenchmarkStats.format_time(stats.mean_ns)}"
        print "  Median: {BenchmarkStats.format_time(stats.median_ns)}"
        print ""

# ============================================================================
# Functional Operations Benchmarks
# ============================================================================

fn benchmark_functional_operations():
    print "=== Set Functional Operations (filter, map, any, all) ==="
    print ""

    val benchmarks = Map.new()

    # Filter benchmarks
    benchmarks.insert("Filter (100 items, 50% match)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.filter(_ % 2 == 0)
    )

    benchmarks.insert("Filter (100 items, 10% match)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.filter(_ % 10 == 0)
    )

    benchmarks.insert("Filter (1000 items, 50% match)", \:
        val s: Set<i64> = Set.with_capacity(1024)
        for i in 0..1000:
            s.insert(i)

        s.filter(_ % 2 == 0)
    )

    # Map benchmarks
    benchmarks.insert("Map (100 items, unique values)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.map(_ * 2)
    )

    benchmarks.insert("Map (100 items, duplicate values)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.map(_ / 10)
    )

    # Any benchmarks
    benchmarks.insert("Any (100 items, match early)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.any(_ < 10)
    )

    benchmarks.insert("Any (100 items, match late)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.any(_ > 90)
    )

    benchmarks.insert("Any (100 items, no match)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.any(_ > 1000)
    )

    # All benchmarks
    benchmarks.insert("All (100 items, all true)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.all(_ >= 0)
    )

    benchmarks.insert("All (100 items, fail early)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.all(_ > 10)
    )

    # Run and display
    val results = compare(benchmarks, BenchmarkConfig.quick())

    for (name, stats) in results.entries():
        print "{name}:"
        print "  Mean: {BenchmarkStats.format_time(stats.mean_ns)}"
        print "  Median: {BenchmarkStats.format_time(stats.median_ns)}"
        print ""

# ============================================================================
# Utility Operations Benchmarks
# ============================================================================

fn benchmark_utility_operations():
    print "=== Set Utility Operations (clone, extend, to_list) ==="
    print ""

    val benchmarks = Map.new()

    # Clone benchmarks
    benchmarks.insert("Clone (100 items)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.clone()
    )

    benchmarks.insert("Clone (1000 items)", \:
        val s: Set<i64> = Set.with_capacity(1024)
        for i in 0..1000:
            s.insert(i)

        s.clone()
    )

    # Extend benchmarks
    benchmarks.insert("Extend (100 items, no duplicates)", \:
        val s: Set<i64> = Set.new()
        var items: [i64] = []
        for i in 0..100:
            items.append(i)

        s.extend(items)
    )

    benchmarks.insert("Extend (100 items, 50% duplicates)", \:
        val s: Set<i64> = Set.new()
        for i in 0..50:
            s.insert(i)

        var items: [i64] = []
        for i in 0..100:
            items.append(i)

        s.extend(items)
    )

    # to_list benchmarks
    benchmarks.insert("to_list (100 items)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        s.to_list()
    )

    benchmarks.insert("to_list (1000 items)", \:
        val s: Set<i64> = Set.with_capacity(1024)
        for i in 0..1000:
            s.insert(i)

        s.to_list()
    )

    # for_each benchmarks
    benchmarks.insert("for_each (100 items)", \:
        val s: Set<i64> = Set.new()
        for i in 0..100:
            s.insert(i)

        var count = 0
        s.for_each(\_:
            count = count + 1
        )
    )

    # Run and display
    val results = compare(benchmarks, BenchmarkConfig.quick())

    for (name, stats) in results.entries():
        print "{name}:"
        print "  Mean: {BenchmarkStats.format_time(stats.mean_ns)}"
        print "  Median: {BenchmarkStats.format_time(stats.median_ns)}"
        print ""

# ============================================================================
# Helper Functions Benchmarks
# ============================================================================

fn benchmark_helper_functions():
    print "=== Set Helper Functions ==="
    print ""

    val set_from_list_unique = benchmark(
        "set_from_list (100 items, unique)",
        \:
            var items: [i64] = []
            for i in 0..100:
                items.append(i)
            set_from_list(items)
        ,
        BenchmarkConfig.quick()
    )
    print "set_from_list (100 items, unique):"
    print "  Median: {BenchmarkStats.format_time(set_from_list_unique.median_ns)}"

    val set_from_list_duplicates = benchmark(
        "set_from_list (100 items, 50% duplicates)",
        \:
            var items: [i64] = []
            for i in 0..100:
                items.append(i % 50)
            set_from_list(items)
        ,
        BenchmarkConfig.quick()
    )
    print "set_from_list (100 items, 50% duplicates):"
    print "  Median: {BenchmarkStats.format_time(set_from_list_duplicates.median_ns)}"

    print ""

# ============================================================================
# Scalability Analysis
# ============================================================================

fn benchmark_scalability():
    print "=== Set Scalability Analysis ==="
    print ""

    val sizes = [10, 100, 1000, 10000]

    for size in sizes:
        print "Size: {size} items"

        # Insert scalability
        val insert_stats = benchmark(
            "Insert {size}",
            \:
                val capacity = size * 2
                val s: Set<i64> = Set.with_capacity(capacity)
                for i in 0..size:
                    s.insert(i)
            ,
            BenchmarkConfig.quick()
        )
        print "  Insert: {BenchmarkStats.format_time(insert_stats.mean_ns)}"

        # Contains scalability
        val contains_stats = benchmark(
            "Contains {size}",
            \:
                val s: Set<i64> = Set.with_capacity(size * 2)
                for i in 0..size:
                    s.insert(i)

                for i in 0..size:
                    s.contains(i)
            ,
            BenchmarkConfig.quick()
        )
        print "  Contains: {BenchmarkStats.format_time(contains_stats.mean_ns)}"

        # Union scalability
        val union_stats = benchmark(
            "Union {size}",
            \:
                val s1: Set<i64> = Set.with_capacity(size)
                val s2: Set<i64> = Set.with_capacity(size)

                for i in 0..(size / 2):
                    s1.insert(i)
                for i in (size / 4)..(size * 3 / 4):
                    s2.insert(i)

                s1.union(s2)
            ,
            BenchmarkConfig.quick()
        )
        print "  Union: {BenchmarkStats.format_time(union_stats.mean_ns)}"

        print ""

# ============================================================================
# Main Entry Point
# ============================================================================

fn main():
    val section_line = "======================================================================"
    print "Set Operations Performance Benchmarks"
    print section_line
    print ""

    benchmark_basic_operations()
    print section_line
    print ""

    benchmark_set_operations()
    print section_line
    print ""

    benchmark_set_predicates()
    print section_line
    print ""

    benchmark_functional_operations()
    print section_line
    print ""

    benchmark_utility_operations()
    print section_line
    print ""

    benchmark_helper_functions()
    print section_line
    print ""

    benchmark_scalability()
    print section_line
    print ""

    print "Set operations benchmarking complete! 🎉"
