# @gc — module uses GC runtime
#
# std.fs-backed transport for the svllm streaming loader.
#
# Round 6 supplied an in-memory transport (MemNvfsClient); this is the real
# on-disk path: it reads a pack's manifest + chunk files off the filesystem
# through the read-capable StdFsNvfsClient (read_text / read_bytes) and drives
# the Round-5 streaming loader. It mirrors load_model_from_pack_via but the
# bytes come from real files.
#
# Layering note: this module deliberately bridges two runtime families — the
# FS adapter (nogc) and the model_loader orchestration (gc) — so the linter
# emits a `gc_boundary_crossing` (nogc_imports_gc_family) warning, the same
# inherent cross the nvfs subsystem already carries (std_fs.spl crosses into
# nogc_sync_mut for SFFI I/O). The svllm loader spans families by nature; this
# is the documented bridge, isolated to this one file.

use std.nogc_async_mut.svllm.nvfs_client.std_fs.{StdFsNvfsClient}
use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{parse_manifest, TensorPackManifest}
use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoadResult, LoaderError, load_model_from_pack_streamed}

# Load a pack from real on-disk files. Reads `<pack_root>/manifest.sdn`, parses
# it to learn the chunk layout, reads each chunk file, then drives the streaming
# loader. Error mapping mirrors the in-memory transport:
#   manifest file absent    -> PackRootNotFound
#   manifest unparseable     -> ManifestInvalid
#   a chunk file absent      -> ChunkOpenFailed
# A build_tensor_pack inconsistency surfaces as ManifestInvalid via the streamed
# path; a tensor/chunk shape mismatch surfaces as ChunkDataInvalid there.
fn load_model_from_pack_fs(client: StdFsNvfsClient, pack_root: text, granule: i64) -> Result<LoadResult, LoaderError>:
    # Native-AOT note: cross-module `Result<[u8], NvfsError>` method dispatch
    # (`is_err`/`unwrap`) is mis-resolved in large compilation units (returns
    # garbage / "function not found"), so this path destructures with `match`
    # instead. Chunk payloads land in the typed `[[u8]]` container, which
    # re-establishes the static element type for safe downstream indexing.
    # See doc/08_tracking/bug/native_sffi_file_byte_io_u8_marshalling_2026-06-20.md
    val manifest_path = pack_root + "/manifest.sdn"
    match client.read_text(manifest_path):
        Err(_) => Err(LoaderError.PackRootNotFound)
        Ok(mtext) =>
            match parse_manifest(mtext):
                Err(_) => Err(LoaderError.ManifestInvalid)
                Ok(m) =>
                    var chunk_data: [[u8]] = []
                    var i = 0
                    var chunk_failed = false
                    while i < m.chunks.len() and not chunk_failed:
                        val chunk_path = pack_root + "/" + m.chunks[i].relative_path
                        match client.read_bytes(chunk_path):
                            Err(_) => chunk_failed = true
                            Ok(cb) => chunk_data.push(cb)
                        i = i + 1
                    if chunk_failed:
                        Err(LoaderError.ChunkOpenFailed)
                    else:
                        load_model_from_pack_streamed(pack_root, mtext, granule, chunk_data)
