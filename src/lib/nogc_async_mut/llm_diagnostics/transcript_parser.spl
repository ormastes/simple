#![allow(unnamed_duplicate_typed_args)]
# LLM Diagnostics — Transcript Parser
#
# Reads Claude Code JSONL transcript files to extract:
# - Per-turn token usage (input, output, cache_read, cache_creation)
# - Message content and roles
# - Model usage breakdown
# - Parent tool use IDs for subagent linkage

use std.nogc_async_mut.llm_diagnostics.types.{
    TokenUsage, DiagEvent, new_token_usage, new_diag_event,
    EVENT_TRANSCRIPT_TURN
}
use std.nogc_async_mut.llm_diagnostics.hook_handler.{extract_str, extract_int}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_time_millis() -> i64

# --- Transcript Turn ---

struct TranscriptTurn:
    turn_index: i64
    role: text                  # "user", "assistant", "system", "tool_result"
    content: text               # message content (truncated if config says so)
    model: text                 # model id
    usage: TokenUsage
    parent_tool_use_id: text    # for subagent linkage
    timestamp: i64

fn new_transcript_turn(index: i64) -> TranscriptTurn:
    TranscriptTurn(
        turn_index: index,
        role: "",
        content: "",
        model: "",
        usage: new_token_usage(),
        parent_tool_use_id: "",
        timestamp: 0
    )

# --- Transcript Summary ---

struct TranscriptSummary:
    path: text
    turn_count: i64
    total_usage: TokenUsage
    turns: [TranscriptTurn]
    models_used: [text]

fn new_transcript_summary(path: text) -> TranscriptSummary:
    TranscriptSummary(
        path: path,
        turn_count: 0,
        total_usage: new_token_usage(),
        turns: [],
        models_used: []
    )

# --- Parser ---

fn parse_transcript(path: text) -> TranscriptSummary:
    """Parse a Claude Code JSONL transcript file."""
    val content = rt_file_read_text(path)
    if content.len() == 0:
        return new_transcript_summary(path)

    var summary = new_transcript_summary(path)
    val lines = content.split("\n")
    var idx = 0
    var models_seen: [text] = []

    for line in lines:
        val trimmed = line.trim()
        if trimmed.len() == 0:
            idx = idx + 1
            continue

        var turn = new_transcript_turn(idx)
        turn.role = extract_str(trimmed, "role")
        turn.model = extract_str(trimmed, "model")
        turn.parent_tool_use_id = extract_str(trimmed, "parent_tool_use_id")

        # Extract usage block
        turn.usage = parse_usage_from_line(trimmed)

        # Track content (first 200 chars for summary)
        val msg_content = extract_str(trimmed, "content")
        if msg_content.len() > 200:
            turn.content = msg_content.slice(0, 200)
        else:
            turn.content = msg_content

        # Track model
        if turn.model.len() > 0 and not models_seen.contains(turn.model):
            models_seen.push(turn.model)

        summary.turns.push(turn)
        summary.total_usage = token_usage_add_inline(summary.total_usage, turn.usage)
        idx = idx + 1

    summary.turn_count = summary.turns.len()
    summary.models_used = models_seen
    summary

fn parse_usage_from_line(json: text) -> TokenUsage:
    """Extract token usage fields from a transcript JSONL line."""
    var u = new_token_usage()
    u.input_tokens = extract_int(json, "input_tokens")
    u.output_tokens = extract_int(json, "output_tokens")
    u.cache_read_input_tokens = extract_int(json, "cache_read_input_tokens")
    u.cache_creation_input_tokens = extract_int(json, "cache_creation_input_tokens")
    u

fn token_usage_add_inline(a: TokenUsage, b: TokenUsage) -> TokenUsage:
    TokenUsage(
        input_tokens: a.input_tokens + b.input_tokens,
        output_tokens: a.output_tokens + b.output_tokens,
        cache_read_input_tokens: a.cache_read_input_tokens + b.cache_read_input_tokens,
        cache_creation_input_tokens: a.cache_creation_input_tokens + b.cache_creation_input_tokens
    )

fn transcript_turns_to_events(turns: [TranscriptTurn], session_id: text) -> [DiagEvent]:
    """Convert transcript turns into DiagEvents for timeline merging."""
    var events: [DiagEvent] = []
    for turn in turns:
        var event = new_diag_event(EVENT_TRANSCRIPT_TURN, session_id)
        event.timestamp = turn.timestamp
        event.data = turn.role + ":" + turn.content
        events.push(event)
    events

# --- Model Usage Summary ---

struct ModelUsage:
    model: text
    input_tokens: i64
    output_tokens: i64
    turn_count: i64

fn new_model_usage(model: text) -> ModelUsage:
    ModelUsage(
        model: model,
        input_tokens: 0,
        output_tokens: 0,
        turn_count: 0
    )

fn summarize_model_usage(turns: [TranscriptTurn]) -> [ModelUsage]:
    """Aggregate token usage per model."""
    var models: [text] = []
    var usages: [ModelUsage] = []

    for turn in turns:
        if turn.model.len() == 0:
            continue
        var found = false
        var i = 0
        while i < models.len():
            if models[i] == turn.model:
                usages[i].input_tokens = usages[i].input_tokens + turn.usage.input_tokens
                usages[i].output_tokens = usages[i].output_tokens + turn.usage.output_tokens
                usages[i].turn_count = usages[i].turn_count + 1
                found = true
                break
            i = i + 1
        if not found:
            models.push(turn.model)
            var mu = new_model_usage(turn.model)
            mu.input_tokens = turn.usage.input_tokens
            mu.output_tokens = turn.usage.output_tokens
            mu.turn_count = 1
            usages.push(mu)
    usages
