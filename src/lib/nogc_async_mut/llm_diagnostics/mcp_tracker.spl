# LLM Diagnostics — MCP Tracker
#
# Per-server and per-tool MCP call statistics.
# Provides aggregation, ranking, and filtering over tool calls.

use std.nogc_async_mut.llm_diagnostics.types.{
    McpServerStats, ToolCall, mcp_stats_avg_latency, tool_call_latency_ms
}

# --- Server-Level Queries ---

fn mcp_servers_by_call_count(stats: [McpServerStats]) -> [McpServerStats]:
    """Sort servers by call count (descending)."""
    # Simple insertion sort (server count is small)
    var sorted: [McpServerStats] = []
    for s in stats:
        sorted.push(s)
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and sorted[j].call_count > sorted[j - 1].call_count:
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    sorted

fn mcp_servers_by_latency(stats: [McpServerStats]) -> [McpServerStats]:
    """Sort servers by total latency (descending)."""
    var sorted: [McpServerStats] = []
    for s in stats:
        sorted.push(s)
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and sorted[j].total_latency_ms > sorted[j - 1].total_latency_ms:
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    sorted

fn mcp_servers_by_tokens(stats: [McpServerStats]) -> [McpServerStats]:
    """Sort servers by total estimated tokens (descending)."""
    var sorted: [McpServerStats] = []
    for s in stats:
        sorted.push(s)
    var i = 1
    while i < sorted.len():
        val total_j = sorted[j].estimated_request_tokens + sorted[j].estimated_response_tokens
        val total_prev = sorted[j - 1].estimated_request_tokens + sorted[j - 1].estimated_response_tokens
        var j = i
        while j > 0 and total_j > total_prev:
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    sorted

# --- Tool-Level Queries ---

fn all_tool_calls(stats: [McpServerStats]) -> [ToolCall]:
    """Flatten all tool calls across servers."""
    var calls: [ToolCall] = []
    for s in stats:
        for tc in s.calls:
            calls.push(tc)
    calls

fn tool_calls_for_server(stats: [McpServerStats], server_name: text) -> [ToolCall]:
    """Get all tool calls for a specific server."""
    for s in stats:
        if s.server_name == server_name:
            return s.calls
    []

fn slowest_tool_calls(calls: [ToolCall], limit: i64) -> [ToolCall]:
    """Get the N slowest tool calls."""
    # Sort by latency descending
    var sorted: [ToolCall] = []
    for tc in calls:
        sorted.push(tc)
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and tool_call_latency_ms(sorted[j]) > tool_call_latency_ms(sorted[j - 1]):
            val tmp = sorted[j]
            sorted[j] = sorted[j - 1]
            sorted[j - 1] = tmp
            j = j - 1
        i = i + 1
    # Take first N
    var result: [ToolCall] = []
    var k = 0
    while k < limit and k < sorted.len():
        result.push(sorted[k])
        k = k + 1
    result

fn failed_tool_calls(calls: [ToolCall]) -> [ToolCall]:
    """Get all failed tool calls."""
    var failed: [ToolCall] = []
    for tc in calls:
        if tc.error.len() > 0:
            failed.push(tc)
    failed

# --- Summary ---

fn mcp_total_calls(stats: [McpServerStats]) -> i64:
    var total = 0
    for s in stats:
        total = total + s.call_count
    total

fn mcp_total_latency(stats: [McpServerStats]) -> i64:
    var total = 0
    for s in stats:
        total = total + s.total_latency_ms
    total

fn mcp_total_estimated_tokens(stats: [McpServerStats]) -> i64:
    var total = 0
    for s in stats:
        total = total + s.estimated_request_tokens + s.estimated_response_tokens
    total

fn mcp_server_summary_line(s: McpServerStats) -> text:
    """One-line summary: server — N calls, avg Xms, ~Y tokens."""
    var parts: [text] = []
    parts.push(s.server_name)
    parts.push(" — ")
    parts.push(s.call_count.to_text())
    parts.push(" calls, avg ")
    parts.push(mcp_stats_avg_latency(s).to_text())
    parts.push("ms, ~")
    val tokens = s.estimated_request_tokens + s.estimated_response_tokens
    parts.push(tokens.to_text())
    parts.push(" tokens")
    parts.join("")
