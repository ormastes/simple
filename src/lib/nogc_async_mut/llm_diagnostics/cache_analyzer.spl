# LLM Diagnostics — Cache Analyzer
#
# Analyzes prompt caching behavior across turns.
# Cache reads are cheaper than uncached input, so high cache_efficiency = lower cost.

use std.nogc_async_mut.llm_diagnostics.types.{
    TokenUsage, CacheAnalysis, TurnCache,
    new_cache_analysis, new_turn_cache
}

fn analyze_cache(turns: [TokenUsage]) -> CacheAnalysis:
    var result = new_cache_analysis()
    var per_turn: [TurnCache] = []
    var idx = 0
    for usage in turns:
        var tc = new_turn_cache(idx)
        tc.cache_read = usage.cache_read_input_tokens
        tc.cache_write = usage.cache_creation_input_tokens
        tc.uncached = usage.input_tokens
        tc.was_hit = usage.cache_read_input_tokens > 0
        per_turn.push(tc)
        result.total_cache_reads = result.total_cache_reads + usage.cache_read_input_tokens
        result.total_cache_writes = result.total_cache_writes + usage.cache_creation_input_tokens
        result.total_uncached = result.total_uncached + usage.input_tokens
        idx = idx + 1
    result.per_turn = per_turn
    val total_input = result.total_cache_reads + result.total_cache_writes + result.total_uncached
    if total_input > 0:
        result.cache_efficiency = (result.total_cache_reads as f64) / (total_input as f64)
    else:
        result.cache_efficiency = 0.0
    result

fn cache_cost_savings(analysis: CacheAnalysis, read_discount: f64) -> f64:
    # read_discount is typically 0.9 (90% cheaper for cached reads)
    val saved_tokens = analysis.total_cache_reads as f64
    saved_tokens * read_discount

fn is_cache_efficient(analysis: CacheAnalysis) -> bool:
    analysis.cache_efficiency > 0.5

fn first_cache_hit_turn(analysis: CacheAnalysis) -> i64:
    for tc in analysis.per_turn:
        if tc.was_hit:
            return tc.turn_index
    -1
