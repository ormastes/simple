# LLM Diagnostics — Token Estimator
#
# Heuristic token counting from content length.
# Default ratio: ~4 characters per token (empirically close for English text).

fn estimate_tokens(content: text, ratio: f64) -> i64:
    if content.len() == 0:
        return 0
    val chars = content.len() as f64
    (chars / ratio + 0.5) as i64

fn estimate_tokens_default(content: text) -> i64:
    estimate_tokens(content, 4.0)

fn estimate_json_tokens(json: text) -> i64:
    # JSON has more punctuation, slightly lower ratio
    estimate_tokens(json, 3.5)

fn truncate_content(content: text, max_size: i64) -> text:
    if content.len() <= max_size:
        content
    else:
        content.slice(0, max_size)
