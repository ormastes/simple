# LLM Diagnostics — WebSocket Exporter
#
# Sends events to dashboard via WebSocket for live streaming.
# This is a stub — actual WebSocket send uses the HTTP/net library.

use std.nogc_async_mut.llm_diagnostics.types.{DiagEvent, SessionDiag}
use std.nogc_async_mut.llm_diagnostics.formatters.json_formatter.{
    format_event_json, format_session_json
}
use std.nogc_sync_mut.io.http_ffi.{ws_send_handle}

# WebSocket state (set by dashboard when it connects)
var WS_CONNECTED = false
var WS_PORT = 3002

fn ws_set_port(port: i64):
    WS_PORT = port

fn ws_set_connected(connected: bool):
    WS_CONNECTED = connected

fn ws_export_event(event: DiagEvent):
    """Send single event to connected WebSocket clients."""
    if not WS_CONNECTED:
        return
    val json = format_event_json(event)
    ws_send_handle(WS_PORT, json)

fn ws_export_session(session: SessionDiag):
    """Send full session snapshot to connected WebSocket clients."""
    if not WS_CONNECTED:
        return
    val json = format_session_json(session)
    ws_send_handle(WS_PORT, json)
