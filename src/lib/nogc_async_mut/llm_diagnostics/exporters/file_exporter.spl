# LLM Diagnostics — File Exporter
#
# Appends events as JSONL (one JSON object per line) for durable logging.

use std.nogc_async_mut.llm_diagnostics.types.{DiagEvent, SessionDiag}
use std.nogc_async_mut.llm_diagnostics.formatters.json_formatter.{
    format_event_json, format_session_json
}

extern fn rt_file_append_text(path: text, content: text)
extern fn rt_file_write_text(path: text, content: text)

fn append_event_jsonl(path: text, event: DiagEvent):
    """Append a single event as one JSONL line."""
    val json = format_event_json(event)
    rt_file_append_text(path, json + "\n")

fn write_session_jsonl(path: text, session: SessionDiag):
    """Write full session diagnostics as a single JSON document."""
    val json = format_session_json(session)
    rt_file_write_text(path, json + "\n")

fn append_raw_jsonl(path: text, json_line: text):
    """Append a raw JSON line (for hook passthrough)."""
    rt_file_append_text(path, json_line + "\n")
