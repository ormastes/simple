# LLM Diagnostics — Agent Graph
#
# Builds agent topology tree from SubagentStart/Stop events
# and parent_tool_use_id linkage from transcripts.

use std.nogc_async_mut.llm_diagnostics.types.{
    AgentNode, TokenUsage, new_token_usage, token_usage_add
}
use std.nogc_async_mut.llm_diagnostics.transcript_parser.{
    TranscriptSummary, parse_transcript
}

# --- Tree Building ---

fn build_agent_tree(agents: [AgentNode]) -> [AgentNode]:
    """Link parent→child relationships and return root agents."""
    # Build parent linkage: if agent B has parent_tool_use_id matching agent A's context,
    # then B is a child of A.
    # For now, agents without parent_tool_use_id are roots.
    var roots: [AgentNode] = []
    for agent in agents:
        if agent.parent_tool_use_id.len() == 0:
            roots.push(agent)
    roots

fn find_agent_by_id(agents: [AgentNode], agent_id: text) -> AgentNode:
    """Find agent node by ID. Returns empty node if not found."""
    for agent in agents:
        if agent.agent_id == agent_id:
            return agent
    AgentNode(
        agent_id: "",
        agent_type: "",
        parent_tool_use_id: "",
        transcript_path: "",
        start_time: 0,
        end_time: 0,
        total_usage: new_token_usage(),
        children: []
    )

fn agent_children(agents: [AgentNode], parent_id: text) -> [AgentNode]:
    """Get all direct children of an agent."""
    var children: [AgentNode] = []
    for agent in agents:
        if agent.children.contains(parent_id):
            children.push(agent)
    children

# --- Token Attribution ---

fn enrich_agent_usage(agents: [AgentNode]) -> [AgentNode]:
    """Parse each agent's transcript to fill in token usage."""
    var enriched: [AgentNode] = []
    for agent in agents:
        var node = agent
        if agent.transcript_path.len() > 0:
            val summary = parse_transcript(agent.transcript_path)
            node.total_usage = summary.total_usage
        enriched.push(node)
    enriched

fn total_agent_tree_usage(agents: [AgentNode]) -> TokenUsage:
    """Sum token usage across all agents."""
    var total = new_token_usage()
    for agent in agents:
        total = token_usage_add(total, agent.total_usage)
    total

# --- Formatting Helpers ---

fn agent_tree_depth(agents: [AgentNode], agent_id: text) -> i64:
    """Compute depth of agent in tree (root = 0)."""
    val agent = find_agent_by_id(agents, agent_id)
    if agent.agent_id.len() == 0:
        return 0
    if agent.parent_tool_use_id.len() == 0:
        return 0
    # Walk up (simplified: just check if parent exists)
    1

fn agent_summary_line(agent: AgentNode) -> text:
    """One-line summary: [type] id — duration, tokens."""
    var parts: [text] = []
    parts.push("[")
    parts.push(agent.agent_type)
    parts.push("] ")
    parts.push(agent.agent_id)
    if agent.end_time > agent.start_time:
        val dur = agent.end_time - agent.start_time
        parts.push(" — ")
        parts.push(dur.to_text())
        parts.push("ms")
    val total_in = agent.total_usage.input_tokens + agent.total_usage.cache_read_input_tokens + agent.total_usage.cache_creation_input_tokens
    val total_out = agent.total_usage.output_tokens
    if total_in > 0 or total_out > 0:
        parts.push(", in=")
        parts.push(total_in.to_text())
        parts.push(" out=")
        parts.push(total_out.to_text())
    parts.join("")
