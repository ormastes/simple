#![allow(export_outside_init)]
# LLM Diagnostics Library
#
# Observability library for Claude Code sessions.
# Captures token usage, MCP tool traffic, subagent lifecycle,
# cache behavior, and inter-agent communication.
#
# Usage:
#   use std.nogc_async_mut.llm_diagnostics.{diag_init, diag_push_event, diag_get_session}
#
# Architecture:
#   Hooks (stdin JSON) → hook_handler → collector → exporters
#   Transcripts (JSONL) → transcript_parser → collector
#   Combined → timeline → formatters → text/json output

# --- Core Types ---
export types.{
    DiagConfig, DiagEvent, TokenUsage, ToolCall,
    AgentNode, McpServerStats, SessionDiag,
    CacheAnalysis, TurnCache,
    new_diag_config, new_diag_event, new_token_usage,
    new_tool_call, new_agent_node, new_mcp_server_stats,
    new_session_diag, new_cache_analysis, new_turn_cache,
    diag_config_with_log, diag_config_with_content,
    token_usage_total_input, token_usage_total, token_usage_add,
    tool_call_latency_ms, agent_node_duration_ms, mcp_stats_avg_latency
}

# --- Event Type Constants ---
export types.{
    EVENT_SESSION_START, EVENT_SESSION_END,
    EVENT_TOOL_PRE, EVENT_TOOL_POST, EVENT_TOOL_FAILURE,
    EVENT_SUBAGENT_START, EVENT_SUBAGENT_STOP,
    EVENT_ELICITATION, EVENT_ELICITATION_RESULT,
    EVENT_PERMISSION_REQUEST, EVENT_PERMISSION_DENIED,
    EVENT_USER_PROMPT, EVENT_PRE_COMPACT,
    EVENT_NOTIFICATION, EVENT_STOP, EVENT_TASK_COMPLETED,
    EVENT_TRANSCRIPT_TURN
}

# --- Collector (main API) ---
export collector.{
    diag_init, diag_reset, diag_is_initialized,
    diag_push_event, diag_get_session,
    diag_get_events, diag_get_mcp_stats, diag_get_agents,
    diag_get_event_count, diag_get_mcp_server_count, diag_get_agent_count
}

# --- Hook Handler ---
export hook_handler.{
    parse_hook_json, read_hook_stdin,
    parse_tool_call_from_pre, parse_tool_call_from_post, parse_tool_call_from_failure,
    parse_subagent_start, parse_subagent_stop, parse_session_start_info,
    is_mcp_tool, parse_mcp_tool_name,
    extract_str, extract_int
}

# --- Transcript Parser ---
export transcript_parser.{
    TranscriptTurn, TranscriptSummary, ModelUsage,
    new_transcript_turn, new_transcript_summary, new_model_usage,
    parse_transcript, summarize_model_usage,
    transcript_turns_to_events
}

# --- Token Estimator ---
export token_estimator.{
    estimate_tokens, estimate_tokens_default, estimate_json_tokens,
    truncate_content
}

# --- Cache Analyzer ---
export cache_analyzer.{
    analyze_cache, cache_cost_savings, is_cache_efficient, first_cache_hit_turn
}

# --- Agent Graph ---
export agent_graph.{
    build_agent_tree, find_agent_by_id, agent_children,
    enrich_agent_usage, total_agent_tree_usage,
    agent_summary_line
}

# --- MCP Tracker ---
export mcp_tracker.{
    mcp_servers_by_call_count, mcp_servers_by_latency, mcp_servers_by_tokens,
    all_tool_calls, tool_calls_for_server, slowest_tool_calls, failed_tool_calls,
    mcp_total_calls, mcp_total_latency, mcp_total_estimated_tokens,
    mcp_server_summary_line
}

# --- Timeline ---
export timeline.{
    sort_events_by_time, merge_timelines,
    filter_events_by_type, filter_events_by_types,
    filter_events_by_agent, exclude_event_types,
    events_in_time_range, events_last_n_seconds,
    tool_events_only, mcp_events_only, agent_events_only, session_events_only
}

# --- Formatters ---
export formatters.json_formatter.{
    format_session_json, format_mcp_stats_json,
    format_agent_tree_json, format_event_json,
    format_token_usage_json, format_tool_call_json,
    format_cache_analysis_json
}
export formatters.text_formatter.{
    format_session_text, format_mcp_stats_text,
    format_agent_tree_text, format_timeline_text,
    format_token_usage_text, format_cache_text,
    format_tokens_k
}

# --- Exporters ---
export exporters.file_exporter.{
    append_event_jsonl, write_session_jsonl, append_raw_jsonl
}
export exporters.ws_exporter.{
