# Stacking context and z-index ordering.
# Implements CSS 2.1 Appendix E painting order by building a tree of
# stacking contexts and flattening them in the correct composite order.
#
# Generic compositor module — no browser-specific dependencies.
# Uses generic display entries instead of browser-specific DOM types.

use std.compositor.layer.{DisplayEntry}
use std.common.core.collections.{List}

# ---------------------------------------------------------------------------
# StackingContext — a node in the stacking context tree.
# Each context has its own z-index, opacity, and list of display entries.
# ---------------------------------------------------------------------------

class StackingContext:
    node_id: i64
    z_index: i64
    children: List<StackingContext>
    display_items: List<DisplayEntry>
    opacity: f64
    is_root: bool

    static fn root(node_id: i64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: 0,
            children: List<StackingContext>(),
            display_items: List<DisplayEntry>(),
            opacity: 1.0,
            is_root: true
        )

    static fn create(node_id: i64, z_index: i64, opacity: f64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: z_index,
            children: List<StackingContext>(),
            display_items: List<DisplayEntry>(),
            opacity: opacity,
            is_root: false
        )

# ---------------------------------------------------------------------------
# StackingOrderBuilder — builds the stacking context tree generically.
# ---------------------------------------------------------------------------

class StackingOrderBuilder:
    root: StackingContext
    # Stack of indices into root.children for tracking the current parent.
    # Empty means the current parent is root itself.
    parent_stack: List<i64>
    next_node_id: i64

    static fn new() -> StackingOrderBuilder:
        StackingOrderBuilder(
            root: StackingContext.root(0),
            parent_stack: List<i64>(),
            next_node_id: 1
        )

    # Push a new child stacking context under the current parent.
    # Returns the index of the new context within the parent's children list.
    me push_context(z_index: i64, opacity: f64) -> i64:
        val nid = self.next_node_id
        self.next_node_id = self.next_node_id + 1
        val ctx = StackingContext.create(nid, z_index, opacity)
        val parent = self._current_parent()
        val idx = parent.children.len()
        parent.children.push(ctx)
        self.parent_stack.push(idx)
        idx

    # Pop the current stacking context, returning to the parent.
    me pop_context():
        val n = self.parent_stack.len()
        if n > 0:
            self.parent_stack = _list_drop_last(self.parent_stack)

    # Add a display item to the current stacking context.
    me add_display_item(entry: DisplayEntry):
        val parent = self._current_parent()
        parent.display_items.push(entry)

    # Build and return the completed root stacking context.
    me build() -> StackingContext:
        self.root

    # Navigate to the current parent context via the index stack.
    me _current_parent() -> StackingContext:
        var ctx = self.root
        for idx in self.parent_stack:
            val child = ctx.children.get(idx)
            if val c = child:
                ctx = c
        ctx

# Drop the last element from a list, returning a new list without it.
fn _list_drop_last(xs: List<i64>) -> List<i64>:
    var result = List<i64>()
    val n = xs.len()
    var i = 0
    while i < n - 1:
        val v = xs.get(i)
        if val x = v:
            result.push(x)
        i = i + 1
    result

# ---------------------------------------------------------------------------
# WindowStack — z-order management for top-level windows.
# Supports raise, lower, and restack operations.
# ---------------------------------------------------------------------------

class WindowEntry:
    window_id: i64
    z_order: i64    # Higher values are painted on top.

    static fn create(window_id: i64, z_order: i64) -> WindowEntry:
        WindowEntry(window_id: window_id, z_order: z_order)

class WindowStack:
    windows: List<WindowEntry>
    next_z: i64

    static fn new() -> WindowStack:
        WindowStack(
            windows: List<WindowEntry>(),
            next_z: 0
        )

    # Add a new window to the top of the stack.
    me add(window_id: i64):
        val entry = WindowEntry.create(window_id, self.next_z)
        self.next_z = self.next_z + 1
        self.windows.push(entry)

    # Remove a window from the stack.
    me remove(window_id: i64):
        var result = List<WindowEntry>()
        for w in self.windows:
            if w.window_id != window_id:
                result.push(w)
        self.windows = result

    # Raise a window to the top (highest z_order).
    me raise_window(window_id: i64):
        for w in self.windows:
            if w.window_id == window_id:
                w.z_order = self.next_z
                self.next_z = self.next_z + 1

    # Lower a window to the bottom (z_order below all others).
    me lower_window(window_id: i64):
        # Find current minimum z_order
        var min_z = self.next_z
        for w in self.windows:
            if w.z_order < min_z:
                min_z = w.z_order
        for w in self.windows:
            if w.window_id == window_id:
                w.z_order = min_z - 1

    # Restack: place window_id directly above sibling_id in z-order.
    me restack_above(window_id: i64, sibling_id: i64):
        var sibling_z = -1
        for w in self.windows:
            if w.window_id == sibling_id:
                sibling_z = w.z_order
        if sibling_z < 0:
            return
        for w in self.windows:
            if w.window_id == window_id:
                w.z_order = sibling_z + 1

    # Restack: place window_id directly below sibling_id in z-order.
    me restack_below(window_id: i64, sibling_id: i64):
        var sibling_z = -1
        for w in self.windows:
            if w.window_id == sibling_id:
                sibling_z = w.z_order
        if sibling_z < 0:
            return
        for w in self.windows:
            if w.window_id == window_id:
                w.z_order = sibling_z - 1

    # Return windows sorted from bottom to top (ascending z_order).
    me paint_order() -> List<WindowEntry>:
        var sorted = List<WindowEntry>()
        for w in self.windows:
            sorted.push(w)
        # Insertion sort by z_order ascending
        var i = 1
        while i < sorted.len():
            var j = i
            while j > 0:
                val a = sorted.get(j - 1)
                val b = sorted.get(j)
                if val wa = a:
                    if val wb = b:
                        if wa.z_order > wb.z_order:
                            sorted.set(j - 1, wb)
                            sorted.set(j, wa)
                j = j - 1
            i = i + 1
        sorted

    # Get the z_order of a window. Returns -1 if not found.
    fn get_z_order(window_id: i64) -> i64:
        for w in self.windows:
            if w.window_id == window_id:
                return w.z_order
        -1

# ---------------------------------------------------------------------------
# Sorting and flattening
# ---------------------------------------------------------------------------

# Sort stacking contexts by z-index (stable sort, insertion sort for simplicity).
fn sort_stacking_contexts(contexts: List<StackingContext>) -> List<StackingContext>:
    var sorted = List<StackingContext>()
    for ctx in contexts:
        sorted.push(ctx)

    # Simple insertion sort by z-index
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0:
            val a = sorted.get(j - 1)
            val b = sorted.get(j)
            if val sa = a:
                if val sb = b:
                    if compare_z_index(sa, sb) > 0:
                        # Swap
                        sorted.set(j - 1, sb)
                        sorted.set(j, sa)
            j = j - 1
        i = i + 1
    sorted

# Flatten stacking context tree into paint order per CSS 2.1 Appendix E:
# 1. Background + borders of stacking context element
# 2. Negative z-index children (sorted)
# 3. Block-level descendants (non-positioned, non-float)
# 4. Float descendants
# 5. Inline-level descendants (including text)
# 6. z-index: 0 and positioned descendants (in tree order)
# 7. Positive z-index children (sorted)
fn flatten_to_paint_order(root_ctx: StackingContext) -> List<DisplayEntry>:
    var result = List<DisplayEntry>()

    # Step 1: Own display items (background + borders)
    for item in root_ctx.display_items:
        result.push(item)

    # Partition children by z-index
    var negative = List<StackingContext>()
    var zero = List<StackingContext>()
    var positive = List<StackingContext>()

    for child in root_ctx.children:
        if child.z_index < 0:
            negative.push(child)
        elif child.z_index == 0:
            zero.push(child)
        else:
            positive.push(child)

    # Step 2: Negative z-index children
    val sorted_neg = sort_stacking_contexts(negative)
    for ctx in sorted_neg:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    # Steps 3-5: Block, float, inline descendants are in zero-z-index
    # (simplified — in a full implementation these would be separated)

    # Step 6: z-index: 0 and positioned descendants
    for ctx in zero:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    # Step 7: Positive z-index children
    val sorted_pos = sort_stacking_contexts(positive)
    for ctx in sorted_pos:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    result

# Compare two stacking contexts by z-index.
# Returns negative if a < b, 0 if equal, positive if a > b.
fn compare_z_index(a: StackingContext, b: StackingContext) -> i64:
    a.z_index - b.z_index
