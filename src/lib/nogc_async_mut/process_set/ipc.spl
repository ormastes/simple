use nogc_async_mut.process_set.types.{ProcessSetError}
use std.nogc_sync_mut.io.file_ops.{file_read_text, file_write, file_delete}
use std.nogc_sync_mut.io.process_ops.{process_run}
use std.nogc_sync_mut.io.time_ops.{current_time_ms, rt_sleep_ms}

extern fn rt_getpid() -> i64

struct IpcMessage:
    id: text
    source: text
    target: text
    method: text
    payload: text
    timestamp: i64
    reply_to: text

struct IpcReply:
    id: text
    in_reply_to: text
    payload: text
    error: text

fn _ipc_serialize_message(msg: IpcMessage) -> text:
    "id: {msg.id}\nsource: {msg.source}\ntarget: {msg.target}\nmethod: {msg.method}\npayload: {msg.payload}\ntimestamp: {msg.timestamp}\nreply_to: {msg.reply_to}\n"

fn _ipc_parse_field(lines: [text], key: text) -> text:
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("{key}: "):
            val prefix_len = key.len() + 2
            return trimmed[prefix_len..trimmed.len()]
        elif trimmed == "{key}:":
            return ""
    ""

fn _ipc_parse_message(content: text) -> IpcMessage:
    val lines = content.split("\n")
    val ts_text = _ipc_parse_field(lines, "timestamp")
    val ts = ts_text.to_int() ?? 0
    IpcMessage(
        id: _ipc_parse_field(lines, "id"),
        source: _ipc_parse_field(lines, "source"),
        target: _ipc_parse_field(lines, "target"),
        method: _ipc_parse_field(lines, "method"),
        payload: _ipc_parse_field(lines, "payload"),
        timestamp: ts,
        reply_to: _ipc_parse_field(lines, "reply_to")
    )

fn _ipc_parse_reply(content: text) -> IpcReply:
    val lines = content.split("\n")
    IpcReply(
        id: _ipc_parse_field(lines, "id"),
        in_reply_to: _ipc_parse_field(lines, "in_reply_to"),
        payload: _ipc_parse_field(lines, "payload"),
        error: _ipc_parse_field(lines, "error")
    )

fn _ipc_serialize_reply(reply: IpcReply) -> text:
    "id: {reply.id}\nin_reply_to: {reply.in_reply_to}\npayload: {reply.payload}\nerror: {reply.error}\n"

fn _ipc_get_timestamp() -> i64:
    current_time_ms()

fn _ipc_mkdir(dir: text):
    process_run("mkdir", ["-p", dir])

fn _ipc_list_files(dir: text) -> [text]:
    val result = process_run("ls", [dir])
    if result.2 != 0:
        return []
    val raw = result.0.trim()
    if raw == "":
        return []
    raw.split("\n")

class FileQueueTransport:
    queue_dir: text
    process_name: text
    sequence: i64

    static fn create(queue_dir: text, process_name: text) -> FileQueueTransport:
        val inbox = "{queue_dir}/{process_name}/inbox"
        val replies = "{queue_dir}/{process_name}/replies"
        _ipc_mkdir(inbox)
        _ipc_mkdir(replies)
        FileQueueTransport(
            queue_dir: queue_dir,
            process_name: process_name,
            sequence: 0
        )

    me send(msg: IpcMessage) -> Result<(), ProcessSetError>:
        val inbox_dir = "{self.queue_dir}/{msg.target}/inbox"
        _ipc_mkdir(inbox_dir)
        val path = "{inbox_dir}/{msg.id}.msg"
        val content = _ipc_serialize_message(msg)
        val ok = file_write(path, content)
        if not ok:
            return Err(ProcessSetError.IpcError(message: "failed to write message to {path}"))
        Ok(())

    fn receive() -> [IpcMessage]:
        val inbox_dir = "{self.queue_dir}/{self.process_name}/inbox"
        val files = _ipc_list_files(inbox_dir)
        var messages: [IpcMessage] = []
        for fname in files:
            if not fname.ends_with(".msg"):
                continue
            val path = "{inbox_dir}/{fname}"
            val content = file_read_text(path)
            if content == "" or content == nil:
                continue
            val msg = _ipc_parse_message(content)
            file_delete(path)
            messages.push(msg)
        messages

    me reply(original: IpcMessage, payload: text) -> Result<(), ProcessSetError>:
        val pid = rt_getpid()
        self.sequence = self.sequence + 1
        val reply_id = "reply_{pid}_{self.sequence}"
        val reply_dir = "{self.queue_dir}/{original.source}/replies"
        _ipc_mkdir(reply_dir)
        val path = "{reply_dir}/{reply_id}.msg"
        val r = IpcReply(
            id: reply_id,
            in_reply_to: original.id,
            payload: payload,
            error: ""
        )
        val content = _ipc_serialize_reply(r)
        val ok = file_write(path, content)
        if not ok:
            return Err(ProcessSetError.IpcError(message: "failed to write reply to {path}"))
        Ok(())

    fn wait_reply(msg_id: text, timeout_ms: i64) -> Result<IpcReply, ProcessSetError>:
        val replies_dir = "{self.queue_dir}/{self.process_name}/replies"
        var elapsed: i64 = 0
        val poll_ms: i64 = 10
        while elapsed < timeout_ms:
            val files = _ipc_list_files(replies_dir)
            for fname in files:
                if not fname.ends_with(".msg"):
                    continue
                val path = "{replies_dir}/{fname}"
                val content = file_read_text(path)
                if content == "" or content == nil:
                    continue
                val reply = _ipc_parse_reply(content)
                if reply.in_reply_to == msg_id:
                    file_delete(path)
                    return Ok(reply)
            rt_sleep_ms(poll_ms)
            elapsed = elapsed + poll_ms
        Err(ProcessSetError.IpcError(message: "timeout waiting for reply to {msg_id}"))

    me cleanup():
        val inbox_dir = "{self.queue_dir}/{self.process_name}/inbox"
        val replies_dir = "{self.queue_dir}/{self.process_name}/replies"
        val inbox_files = _ipc_list_files(inbox_dir)
        for fname in inbox_files:
            if fname.ends_with(".msg"):
                file_delete("{inbox_dir}/{fname}")
        val reply_files = _ipc_list_files(replies_dir)
        for fname in reply_files:
            if fname.ends_with(".msg"):
                file_delete("{replies_dir}/{fname}")

fn ipc_new_message(source: text, target: text, method: text, payload: text) -> IpcMessage:
    val pid = rt_getpid()
    val ts = _ipc_get_timestamp()
    IpcMessage(
        id: "{pid}_{ts}",
        source: source,
        target: target,
        method: method,
        payload: payload,
        timestamp: ts,
        reply_to: ""
    )

fn ipc_new_request(source: text, target: text, method: text, payload: text, reply_to: text) -> IpcMessage:
    val pid = rt_getpid()
    val ts = _ipc_get_timestamp()
    IpcMessage(
        id: "{pid}_{ts}",
        source: source,
        target: target,
        method: method,
        payload: payload,
        timestamp: ts,
        reply_to: reply_to
    )
