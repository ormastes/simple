@no_gc

# backend_dispatch — honest GPU/CPU dispatch for a compute op.
#
# Routes a compute op to a real device backend (cuda/hip/opencl/vulkan/metal/
# webgpu) ONLY when that backend is REALLY available, otherwise falls back to the
# pure-Simple CPU reference (compute_ops.spl is the correctness oracle).
#
# "Really available" is proven by PAYLOAD-GATING — the same discriminator the
# engine2d GPU-offload path uses: a backend only counts as "ran on GPU" when a
# real kernel+data payload is present. There is no GPU here, so a present payload
# is simulated by an env var (SIMPLE_COMPUTE_GPU_PAYLOAD == backend name). Absent
# the payload, the CPU did the work — and we record that honestly (no masquerade).

use std.nogc_async_mut.compute.exec_target.{ExecTarget, ComputeBackend}
use std.nogc_async_mut.compute.compute_ops.{ComputeStats, compute_reduce}
use std.nogc_async_mut.io.env_ops.{env_get}

fn dispatch_backend_name(b: ComputeBackend) -> text:
    if b == ComputeBackend.Cuda:
        return "cuda"
    if b == ComputeBackend.Hip:
        return "hip"
    if b == ComputeBackend.OpenCl:
        return "opencl"
    if b == ComputeBackend.Vulkan:
        return "vulkan"
    if b == ComputeBackend.Metal:
        return "metal"
    if b == ComputeBackend.WebGpu:
        return "webgpu"
    if b == ComputeBackend.Scalar:
        return "scalar"
    if b == ComputeBackend.PureSimple:
        return "pure_simple"
    return "none"

# True iff a real backend payload (kernel+data) is present for `backend_name`.
# Simulated by env: SIMPLE_COMPUTE_GPU_PAYLOAD must equal the backend name.
fn gpu_payload_present(backend_name: text) -> bool:
    env_get("SIMPLE_COMPUTE_GPU_PAYLOAD") == backend_name

# True when the target names a real device backend (not the CPU reference).
fn dispatch_is_device(target: ExecTarget) -> bool:
    val b = target.backend
    b == ComputeBackend.Cuda or b == ComputeBackend.Hip or b == ComputeBackend.OpenCl or b == ComputeBackend.Vulkan or b == ComputeBackend.Metal or b == ComputeBackend.WebGpu

# Outcome of a dispatched op: the value plus honest provenance stats.
class DispatchOutcome:
    value: i64
    stats: ComputeStats

    static fn create(value: i64, stats: ComputeStats) -> DispatchOutcome:
        DispatchOutcome(value: value, stats: stats)

# Dispatch a reduce. The CPU reference is ALWAYS computed (correctness oracle).
# If the target is a device backend AND its payload is present, the result is
# reported as having run on the GPU (ran_on_cpu=false) with the SAME value as the
# reference. Otherwise the CPU fallback ran (ran_on_cpu=true) — even if the target
# said gpu, because no real payload means the CPU did the work.
fn dispatch_reduce_i64(data: [i64], init: i64, op: fn(i64, i64) -> i64, target: ExecTarget) -> DispatchOutcome:
    val name = dispatch_backend_name(target.backend)
    val present = gpu_payload_present(name)
    return dispatch_reduce_i64_forced(data, init, op, target, present)

# Same as dispatch_reduce_i64 but with the payload gate supplied explicitly, so
# the GPU-ran branch can be exercised deterministically without setting env.
fn dispatch_reduce_i64_forced(data: [i64], init: i64, op: fn(i64, i64) -> i64, target: ExecTarget, payload_present: bool) -> DispatchOutcome:
    # CPU reference — always computed, the differential-correctness oracle.
    val reference = compute_reduce(data, init, op, target)
    val name = dispatch_backend_name(target.backend)
    if dispatch_is_device(target) and payload_present:
        # Real backend payload present: the GPU ran. Value matches the reference.
        val gpu_stats = ComputeStats(backend: name, ran_on_cpu: false)
        return DispatchOutcome.create(reference, gpu_stats)
    # No payload (or not a device target): the CPU reference did the work.
    return DispatchOutcome.create(reference, ComputeStats.cpu(name))

# Fail-closed requirement signal for `require` mode. A caller uses this to decide
# whether to rt_exit 70 (the lib never calls rt_exit itself). True only when the
# target resolved AND, for a device backend, a real payload is present.
fn dispatch_requirement_met(target: ExecTarget) -> bool:
    if target.backend == ComputeBackend.NoneBackend:
        return false
    if dispatch_is_device(target):
        return gpu_payload_present(dispatch_backend_name(target.backend))
    return true

export DispatchOutcome
export gpu_payload_present, dispatch_is_device, dispatch_backend_name
export dispatch_reduce_i64, dispatch_reduce_i64_forced, dispatch_requirement_met
