@no_gc

# compute_ops — generic, ExecTarget-dispatched algorithm surface (Thrust-parity core).
#
# The pure-Simple CPU path here is the REFERENCE ORACLE: every backend cell
# (cuda/metal/vulkan/…) must differential-match these results. Algorithms are
# generic over T and take an ExecTarget so the SAME call runs on CPU or a GPU
# backend selected only by config (see exec_target.spl). Until a backend cell
# provides a real kernel, a non-CPU target computes the reference result and the
# dispatch is recorded honestly via ComputeStats (no silent "gpu" masquerade).

use std.nogc_async_mut.compute.exec_target.{ExecTarget, ComputeBackend}

# Observability for a dispatched op: which backend ran, and whether it fell back
# to the CPU reference because no real kernel exists for that backend yet.
class ComputeStats:
    backend: text       # resolved backend name (e.g. "cuda", "scalar")
    ran_on_cpu: bool    # true => executed by the pure-Simple reference path

    static fn cpu(name: text) -> ComputeStats:
        ComputeStats(backend: name, ran_on_cpu: true)

# True when the target names a real device backend (not the CPU reference).
fn target_is_device(target: ExecTarget) -> bool:
    val b = target.backend
    b == ComputeBackend.Cuda or b == ComputeBackend.Hip or b == ComputeBackend.OpenCl or b == ComputeBackend.Vulkan or b == ComputeBackend.Metal or b == ComputeBackend.WebGpu

fn compute_ops_backend_name(b: ComputeBackend) -> text:
    if b == ComputeBackend.Cuda:
        return "cuda"
    if b == ComputeBackend.Hip:
        return "hip"
    if b == ComputeBackend.OpenCl:
        return "opencl"
    if b == ComputeBackend.Vulkan:
        return "vulkan"
    if b == ComputeBackend.Metal:
        return "metal"
    if b == ComputeBackend.WebGpu:
        return "webgpu"
    if b == ComputeBackend.Scalar:
        return "scalar"
    if b == ComputeBackend.PureSimple:
        return "pure_simple"
    return "none"

fn compute_stats_for(target: ExecTarget) -> ComputeStats:
    # Backend cells will set ran_on_cpu=false once they execute a real kernel.
    ComputeStats.cpu(compute_ops_backend_name(target.backend))

# ---------------------------------------------------------------------------
# Generic algorithm surface (CPU reference). Each is pure and deterministic.
# ---------------------------------------------------------------------------

fn compute_reduce<T>(data: [T], init: T, op: fn(T, T) -> T, target: ExecTarget) -> T:
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        i = i + 1
    return acc

fn compute_transform<T>(data: [T], op: fn(T) -> T, target: ExecTarget) -> [T]:
    var out = [for i in 0..data.len(): data[i]]
    var i = 0
    while i < data.len():
        out[i] = op(data[i])
        i = i + 1
    return out

fn compute_inclusive_scan<T>(data: [T], init: T, op: fn(T, T) -> T, target: ExecTarget) -> [T]:
    var out = [for i in 0..data.len(): data[i]]
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        out[i] = acc
        i = i + 1
    return out

fn compute_count<T>(data: [T], pred: fn(T) -> bool, target: ExecTarget) -> i64:
    var n = 0
    var i = 0
    while i < data.len():
        if pred(data[i]):
            n = n + 1
        i = i + 1
    return n

fn compute_filter<T>(data: [T], pred: fn(T) -> bool, target: ExecTarget) -> [T]:
    var out: [T] = []
    var i = 0
    while i < data.len():
        if pred(data[i]):
            out.push(data[i])
        i = i + 1
    return out

# Index of first element satisfying pred, or -1.
fn compute_find<T>(data: [T], pred: fn(T) -> bool, target: ExecTarget) -> i64:
    var i = 0
    while i < data.len():
        if pred(data[i]):
            return i
        i = i + 1
    return -1

# Comparator-based generic sort (insertion sort; stable, oracle-simple).
# `less(a, b)` returns true when a must come before b.
fn compute_sort<T>(data: [T], less: fn(T, T) -> bool, target: ExecTarget) -> [T]:
    var out = [for i in 0..data.len(): data[i]]
    var i = 1
    while i < out.len():
        val key = out[i]
        var j = i - 1
        while j >= 0 and less(key, out[j]):
            out[j + 1] = out[j]
            j = j - 1
        out[j + 1] = key
        i = i + 1
    return out

export ComputeStats, target_is_device, compute_ops_backend_name, compute_stats_for
export compute_reduce, compute_transform, compute_inclusive_scan
export compute_count, compute_filter, compute_find, compute_sort
