"""
# No-GC Async Atomics

Compatibility facade over the no-GC sync atomic backend. Atomic runtime handles
are synchronous low-level operations, so the async family reuses the shared
no-GC declaration owner.
"""

export use std.nogc_sync_mut.atomic.{
    MemoryOrdering, ordering_to_i32,
    AtomicI64, AtomicUsize, AtomicBool,
    atomic_i64_new, atomic_usize_new, atomic_bool_new, fence
}
