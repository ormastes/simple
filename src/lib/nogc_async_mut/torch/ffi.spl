"""
# No-GC Async Torch FFI

Compatibility facade over the no-GC sync Torch FFI backend. Torch runtime
operations are synchronous FFI calls; async-family Torch modules reuse the
same no-GC backend surface rather than redeclaring runtime hooks.
"""

export use std.nogc_sync_mut.torch.ffi.{
    rt_torch_tensor_zeros, rt_torch_tensor_from_data
}
