# Unified Editor Backend
#
# Composes buffer, undo, syntax facade, project navigator, and config
# into a single entry point. Implements EditorBackendTrait.
#
# Provides: UnifiedEditorBackend.

use std.editor.buffer.buffer.{EditorBuffer}
use std.editor.core.document.{EditorDocument}
use std.editor.core.session.{EditSession}
use std.editor.unified.backend_trait.{EditorBackendTrait, EditorResult, editor_ok, editor_err}
use std.editor.unified.edit_operation.{EditOperation, OperationKind, OperationHistory, op_insert, op_delete}
use std.editor.unified.syntax_facade.{SyntaxTreeFacade, SyntaxNode}
use std.editor.unified.project_navigator.{ProjectNavigator}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

class UnifiedEditorBackend:
    """Shared editor backend for TUI, GUI, and VSCode shells."""
    session: EditSession
    history: OperationHistory
    syntax: SyntaxTreeFacade
    navigator: ProjectNavigator
    config_entries: [text]
    config_values: [text]

    static fn new() -> UnifiedEditorBackend:
        UnifiedEditorBackend(
            session: EditSession.new(),
            history: OperationHistory.with_defaults(),
            syntax: SyntaxTreeFacade.new("", "plaintext"),
            navigator: ProjectNavigator.new(""),
            config_entries: [],
            config_values: []
        )

    static fn with_project(root: text) -> UnifiedEditorBackend:
        var nav = ProjectNavigator.new(root)
        nav.scan()
        UnifiedEditorBackend(
            session: EditSession.new(),
            history: OperationHistory.with_defaults(),
            syntax: SyntaxTreeFacade.new("", "plaintext"),
            navigator: nav,
            config_entries: [],
            config_values: []
        )

    # --- EditorBackendTrait implementation ---

    me open_file(path: text) -> EditorResult:
        me.session.open_file(path)
        val doc = me.session.active_document()
        me.syntax = SyntaxTreeFacade.new(doc.content, doc.language_id)
        me.syntax.parse()
        me.history = OperationHistory.with_defaults()
        editor_ok("Opened: " + path)

    me save_active() -> EditorResult:
        val ok = me.session.save_active()
        if ok:
            return editor_ok("Saved")
        editor_err("Nothing to save")

    me close_active() -> EditorResult:
        me.session.close_tab()
        if me.session.documents.len() > 0:
            val doc = me.session.active_document()
            me.syntax = SyntaxTreeFacade.new(doc.content, doc.language_id)
            me.syntax.parse()
        me.history = OperationHistory.with_defaults()
        editor_ok("Closed tab")

    me insert_text(content: text) -> EditorResult:
        val buf = me.session.active_buffer()
        val cur_line = buf.cursor_line
        val cur_col = buf.cursor_col
        val op = op_insert(cur_line, cur_col, content, cur_line, cur_col)
        buf.insert_at_cursor(content)
        me.history.record(op)
        me._refresh_syntax()
        editor_ok("Inserted " + content.len().to_text() + " chars")

    me delete_range(line: i64, col: i64, count: i64) -> EditorResult:
        val buf = me.session.active_buffer()
        val deleted = buf.line_at(line).slice(col, col + count)
        val op = op_delete(line, col, deleted, buf.cursor_line, buf.cursor_col)
        buf.table.delete(line, col, count)
        buf.modified = true
        me.history.record(op)
        me._refresh_syntax()
        editor_ok("Deleted " + count.to_text() + " chars")

    me move_cursor(line: i64, col: i64) -> EditorResult:
        val buf = me.session.active_buffer()
        buf.cursor_line = line
        buf.cursor_col = col
        editor_ok("Cursor at " + line.to_text() + ":" + col.to_text())

    me undo() -> EditorResult:
        val maybe_op = me.history.undo()
        if maybe_op.?:
            val op = maybe_op.unwrap()
            me._apply_operation(op)
            me._refresh_syntax()
            return editor_ok("Undo")
        editor_err("Nothing to undo")

    me redo() -> EditorResult:
        val maybe_op = me.history.redo()
        if maybe_op.?:
            val op = maybe_op.unwrap()
            me._apply_operation(op)
            me._refresh_syntax()
            return editor_ok("Redo")
        editor_err("Nothing to redo")

    me goto_line(line: i64) -> EditorResult:
        val buf = me.session.active_buffer()
        if line < 0 or line >= buf.line_count():
            return editor_err("Line out of range")
        buf.cursor_line = line
        buf.cursor_col = 0
        editor_ok("Jumped to line " + line.to_text())

    me goto_file(path: text) -> EditorResult:
        me.open_file(path)

    me search_text(query: text) -> EditorResult:
        val buf = me.session.active_buffer()
        val content = buf.full_text()
        val idx = content.index_of(query)
        if idx < 0:
            return editor_err("Not found: " + query)
        # Convert offset to line/col
        val before = content.slice(0, idx)
        val lines = before.split("\n")
        val found_line = lines.len() - 1
        val found_col = lines[lines.len() - 1].len()
        buf.cursor_line = found_line
        buf.cursor_col = found_col
        editor_ok("Found at " + found_line.to_text() + ":" + found_col.to_text())

    fn active_path() -> text:
        me.session.active_document().path()

    fn active_content() -> text:
        me.session.active_buffer().full_text()

    fn line_count() -> i64:
        me.session.active_buffer().line_count()

    fn cursor_position() -> (i64, i64):
        val buf = me.session.active_buffer()
        (buf.cursor_line, buf.cursor_col)

    fn get_config(key: text) -> text:
        var i = 0
        while i < me.config_entries.len():
            if me.config_entries[i] == key:
                return me.config_values[i]
            i = i + 1
        ""

    me set_config(key: text, value: text) -> EditorResult:
        var i = 0
        while i < me.config_entries.len():
            if me.config_entries[i] == key:
                me.config_values[i] = value
                return editor_ok("Config set: " + key)
            i = i + 1
        me.config_entries.push(key)
        me.config_values.push(value)
        editor_ok("Config set: " + key)

    # --- Accessors for composed components ---

    fn get_syntax() -> SyntaxTreeFacade:
        me.syntax

    fn get_navigator() -> ProjectNavigator:
        me.navigator

    fn get_session() -> EditSession:
        me.session

    fn get_history() -> OperationHistory:
        me.history

    # --- Internal helpers ---

    me _refresh_syntax():
        val buf = me.session.active_buffer()
        val doc = me.session.active_document()
        me.syntax = SyntaxTreeFacade.new(buf.full_text(), doc.language_id)
        me.syntax.parse()

    me _apply_operation(op: EditOperation):
        val buf = me.session.active_buffer()
        if op.kind == OperationKind.Insert:
            buf.table.insert(op.line, op.col, op.content)
            buf.modified = true
        elif op.kind == OperationKind.Delete:
            buf.table.delete(op.line, op.col, op.replaced.len())
            buf.modified = true
        elif op.kind == OperationKind.Replace:
            buf.table.delete(op.line, op.col, op.replaced.len())
            buf.table.insert(op.line, op.col, op.content)
            buf.modified = true
        buf.cursor_line = op.cursor_after_line
        buf.cursor_col = op.cursor_after_col
