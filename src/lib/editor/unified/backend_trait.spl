# Unified Editor Backend Trait
#
# Defines the common interface that both TUI (svim) and VSCode extension
# backends implement. Each method returns an EditorResult for uniform
# error handling.
#
# Provides: EditorBackendTrait, EditorResult, editor_ok, editor_err.

struct EditorResult:
    ok: bool
    message: text
    changed: bool

fn editor_ok(msg: text) -> EditorResult:
    EditorResult(ok: true, message: msg, changed: true)

fn editor_err(msg: text) -> EditorResult:
    EditorResult(ok: false, message: msg, changed: false)

trait EditorBackendTrait:
    """Common surface for any editor shell (TUI, GUI, VSCode, headless)."""

    # Document lifecycle
    fn open_file(path: text) -> EditorResult
    fn save_active() -> EditorResult
    fn close_active() -> EditorResult

    # Buffer editing
    fn insert_text(content: text) -> EditorResult
    fn delete_range(line: i64, col: i64, count: i64) -> EditorResult
    fn move_cursor(line: i64, col: i64) -> EditorResult

    # Undo / redo
    fn undo() -> EditorResult
    fn redo() -> EditorResult

    # Navigation
    fn goto_line(line: i64) -> EditorResult
    fn goto_file(path: text) -> EditorResult
    fn search_text(query: text) -> EditorResult

    # Query
    fn active_path() -> text
    fn active_content() -> text
    fn line_count() -> i64
    fn cursor_position() -> (i64, i64)

    # Configuration
    fn get_config(key: text) -> text
    fn set_config(key: text, value: text) -> EditorResult
