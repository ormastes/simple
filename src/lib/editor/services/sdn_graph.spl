# Editor SDN Graph
#
# Parses compact graph blocks used by Markdown preview and graph plugins.
# Source syntax attaches visual names with @foo, while the normalized model keeps
# the field name `css` for node and edge style labels.

struct SdnGraphNode:
    id: text
    label: text
    css: text
    role: text
    shape: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    parent: text

struct SdnGraphEdge:
    from_id: text
    to_id: text
    label: text
    css: text
    kind: text
    route: text
    waypoints: text
    start_anchor: text
    end_anchor: text

struct SdnGraphNodeInspector:
    found: bool
    reason: text
    id: text
    label: text
    css: text
    role: text
    shape: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    parent: text

struct SdnGraphEdgeInspector:
    found: bool
    reason: text
    edge_index: i64
    from_id: text
    to_id: text
    label: text
    css: text
    kind: text
    route: text
    waypoints: text
    start_anchor: text
    end_anchor: text
    path: text

struct SdnGraphCss:
    name: text
    parent_css: text
    target: text

struct SdnGraphStyle:
    css: text
    key: text
    value: text

struct SdnGraphWeave:
    target: text
    field: text
    value: text
    add_css: text
    shape: text
    x: text
    y: text
    width: text
    height: text
    layer: text
    parent: text

struct SdnGraph:
    name: text
    direction: text
    theme: text
    css_file: text
    canvas_width: text
    canvas_height: text
    canvas_grid: text
    canvas_snap: text
    canvas_zoom: text
    canvas_background: text
    nodes: [SdnGraphNode]
    edges: [SdnGraphEdge]
    css_defs: [SdnGraphCss]
    styles: [SdnGraphStyle]
    weaves: [SdnGraphWeave]

struct SdnGraphEditResult:
    accepted: bool
    reason: text
    diff: text
    graph: SdnGraph

struct SdnGraphI64Result:
    ok: bool
    value: i64

struct SdnGraphBounds:
    ok: bool
    min_x: i64
    min_y: i64
    max_x: i64
    max_y: i64

struct SdnGraphAlignedNode:
    ok: bool
    node: SdnGraphNode

fn sdn_graph_empty() -> SdnGraph:
    SdnGraph(
        name: "",
        direction: "",
        theme: "",
        css_file: "",
        canvas_width: "",
        canvas_height: "",
        canvas_grid: "",
        canvas_snap: "",
        canvas_zoom: "",
        canvas_background: "",
        nodes: [],
        edges: [],
        css_defs: [],
        styles: [],
        weaves: []
    )

fn sdn_graph_format_name() -> text:
    "SDD: Simple Diagram Document"

fn sdn_graph_file_extension() -> text:
    ".sdd.sdn"

fn sdn_graph_parse(content: text) -> SdnGraph:
    var graph = sdn_graph_empty()
    val lines = _sg_split_lines(content)
    var current_css = ""
    var current_weave_target = ""
    var current_weave_field = ""
    var current_weave_value = ""
    var current_weave_add = ""
    var current_weave_shape = ""
    var current_weave_x = ""
    var current_weave_y = ""
    var current_weave_width = ""
    var current_weave_height = ""
    var current_weave_layer = ""
    var current_weave_parent = ""
    var in_weave = false
    var i = 0
    while i < lines.len():
        val raw = lines[i]
        val line = raw.trim()
        if line == "" or line.starts_with("#"):
            i = i + 1
            continue
        if line.starts_with("graph:"):
            graph.name = line.slice(6, line.len()).trim()
            current_css = ""
            in_weave = false
        elif line.starts_with("direction:"):
            graph.direction = line.slice(10, line.len()).trim()
            current_css = ""
        elif line.starts_with("theme:"):
            graph.theme = line.slice(6, line.len()).trim()
            current_css = ""
        elif line.starts_with("css_file:"):
            graph.css_file = _sg_unquote(line.slice(9, line.len()).trim())
            current_css = ""
        elif line.starts_with("canvas:"):
            val canvas = line.slice(7, line.len()).trim()
            graph.canvas_width = _sg_meta_value(canvas, "width")
            graph.canvas_height = _sg_meta_value(canvas, "height")
            graph.canvas_grid = _sg_meta_value(canvas, "grid")
            graph.canvas_snap = _sg_meta_value(canvas, "snap")
            graph.canvas_zoom = _sg_meta_value(canvas, "zoom")
            graph.canvas_background = _sg_meta_value(canvas, "background")
            current_css = ""
        elif line.starts_with("css ") and line.ends_with(":"):
            current_css = line.slice(4, line.len() - 1).trim()
            in_weave = false
            graph.css_defs.push(SdnGraphCss(name: current_css, parent_css: "none", target: "node"))
        elif line == "weave @:" or line == "weave css:":
            current_css = ""
            in_weave = true
        elif in_weave and (line.starts_with("node where ") or line.starts_with("edge where ")):
            if current_weave_target != "":
                graph.weaves.push(SdnGraphWeave(target: current_weave_target, field: current_weave_field, value: current_weave_value, add_css: current_weave_add, shape: current_weave_shape, x: current_weave_x, y: current_weave_y, width: current_weave_width, height: current_weave_height, layer: current_weave_layer, parent: current_weave_parent))
            val selector = _sg_parse_weave_selector(line)
            current_weave_target = selector.0
            current_weave_field = selector.1
            current_weave_value = selector.2
            current_weave_add = ""
            current_weave_shape = ""
            current_weave_x = ""
            current_weave_y = ""
            current_weave_width = ""
            current_weave_height = ""
            current_weave_layer = ""
            current_weave_parent = ""
        elif in_weave and line.starts_with("add:"):
            current_weave_add = line.slice(4, line.len()).trim()
        elif in_weave and line.starts_with("shape:"):
            current_weave_shape = line.slice(6, line.len()).trim()
        elif in_weave and line.starts_with("x:"):
            current_weave_x = line.slice(2, line.len()).trim()
        elif in_weave and line.starts_with("y:"):
            current_weave_y = line.slice(2, line.len()).trim()
        elif in_weave and line.starts_with("width:"):
            current_weave_width = line.slice(6, line.len()).trim()
        elif in_weave and line.starts_with("height:"):
            current_weave_height = line.slice(7, line.len()).trim()
        elif in_weave and line.starts_with("layer:"):
            current_weave_layer = line.slice(6, line.len()).trim()
        elif in_weave and line.starts_with("parent:"):
            current_weave_parent = line.slice(7, line.len()).trim()
        elif current_css != "" and line.contains(":"):
            val sep = line.index_of(":")
            val key = line.slice(0, sep).trim()
            val value = line.slice(sep + 1, line.len()).trim()
            if key == "extends":
                graph = _sg_update_css_extends(graph, current_css, value)
            elif key == "target":
                graph = _sg_update_css_target(graph, current_css, value)
            elif key == "shape":
                graph.styles.push(SdnGraphStyle(css: current_css, key: key, value: value))
                graph = _sg_update_css_target(graph, current_css, "node")
            else:
                graph.styles.push(SdnGraphStyle(css: current_css, key: key, value: value))
        elif _sg_is_table_header(line, "nodes"):
            val parsed = _sg_parse_nodes_table(lines, i)
            for node in parsed.0:
                graph.nodes.push(node)
            i = parsed.1
            continue
        elif _sg_is_table_header(line, "edges"):
            val parsed_edges = _sg_parse_edges_table(lines, i)
            for edge in parsed_edges.0:
                graph.edges.push(edge)
            i = parsed_edges.1
            continue
        elif _sg_is_table_header(line, "css"):
            val parsed_css = _sg_parse_css_table(lines, i)
            for css in parsed_css.0:
                graph.css_defs.push(css)
            i = parsed_css.1
            continue
        elif _sg_is_table_header(line, "styles"):
            val parsed_styles = _sg_parse_styles_table(lines, i)
            for style in parsed_styles.0:
                graph.styles.push(style)
            i = parsed_styles.1
            continue
        elif _sg_has_edge_operator(line):
            graph.edges.push(_sg_parse_dense_edge(line))
            current_css = ""
        elif line.contains(":"):
            graph.nodes.push(_sg_parse_dense_node(line))
            current_css = ""
        i = i + 1
    if current_weave_target != "":
        graph.weaves.push(SdnGraphWeave(target: current_weave_target, field: current_weave_field, value: current_weave_value, add_css: current_weave_add, shape: current_weave_shape, x: current_weave_x, y: current_weave_y, width: current_weave_width, height: current_weave_height, layer: current_weave_layer, parent: current_weave_parent))
    sdn_graph_apply_weave(graph)

fn sdn_graph_apply_weave(graph: SdnGraph) -> SdnGraph:
    var out = graph
    var wi = 0
    while wi < graph.weaves.len():
        val rule = graph.weaves[wi]
        if rule.target == "node":
            var ni = 0
            while ni < out.nodes.len():
                var node = out.nodes[ni]
                if _sg_node_matches(node, rule.field, rule.value):
                    node.css = _sg_merge_css(node.css, rule.add_css)
                    if rule.shape != "":
                        node.shape = rule.shape
                    if rule.x != "":
                        node.x = rule.x
                    if rule.y != "":
                        node.y = rule.y
                    if rule.width != "":
                        node.width = rule.width
                    if rule.height != "":
                        node.height = rule.height
                    if rule.layer != "":
                        node.layer = rule.layer
                    if rule.parent != "":
                        node.parent = rule.parent
                    out.nodes[ni] = node
                ni = ni + 1
        elif rule.target == "edge":
            var ei = 0
            while ei < out.edges.len():
                var edge = out.edges[ei]
                if _sg_edge_matches(edge, rule.field, rule.value):
                    edge.css = _sg_merge_css(edge.css, rule.add_css)
                    out.edges[ei] = edge
                ei = ei + 1
        wi = wi + 1
    out

fn sdn_graph_to_canonical_sdn(graph: SdnGraph) -> text:
    var out: [text] = []
    out.push("graph: " + graph.name)
    if graph.direction != "":
        out.push("direction: " + graph.direction)
    if graph.theme != "":
        out.push("theme: " + graph.theme)
    if graph.css_file != "":
        out.push("css_file: \"" + graph.css_file + "\"")
    if _sg_has_canvas(graph):
        out.push("canvas: width: " + graph.canvas_width + " height: " + graph.canvas_height + " grid: " + graph.canvas_grid + " snap: " + graph.canvas_snap + " zoom: " + graph.canvas_zoom + " background: " + graph.canvas_background)
    out.push("")
    out.push("nodes |id, label, css, role, shape, x, y, width, height, layer, parent|")
    for node in graph.nodes:
        out.push("    " + node.id + ", " + node.label + ", " + _sg_quote_if_space(node.css) + ", " + node.role + ", " + node.shape + ", " + node.x + ", " + node.y + ", " + node.width + ", " + node.height + ", " + node.layer + ", " + node.parent)
    out.push("")
    out.push("edges |from, to, label, css, kind, route, waypoints, start_anchor, end_anchor|")
    for edge in graph.edges:
        out.push("    " + edge.from_id + ", " + edge.to_id + ", " + edge.label + ", " + _sg_quote_if_space(edge.css) + ", " + edge.kind + ", " + edge.route + ", " + _sg_quote_if_space(edge.waypoints) + ", " + edge.start_anchor + ", " + edge.end_anchor)
    out.push("")
    out.push("css |name, extends, target|")
    for css in graph.css_defs:
        out.push("    " + css.name + ", " + css.parent_css + ", " + css.target)
    out.push("")
    out.push("styles |css, key, value|")
    for style in graph.styles:
        out.push("    " + style.css + ", " + style.key + ", " + style.value)
    out.join("\n") + "\n"

fn sdn_graph_render_edge_path(edge: SdnGraphEdge, from_node: SdnGraphNode, to_node: SdnGraphNode) -> text:
    val start = _sg_anchor_point(from_node, edge.start_anchor)
    val finish = _sg_anchor_point(to_node, edge.end_anchor)
    val waypoints = _sg_parse_waypoints(edge.waypoints)
    if edge.route == "orthogonal":
        return _sg_build_orthogonal_path(waypoints, start, finish)
    _sg_build_straight_path(waypoints, start, finish)

fn sdn_graph_update_edge_at(graph: SdnGraph, edge_index: i64, route: text, waypoints: text, start_anchor: text, end_anchor: text) -> SdnGraph:
    var out_edges: [SdnGraphEdge] = []
    var i = 0
    while i < graph.edges.len():
        val current = graph.edges[i]
        var next = _sg_clone_edge(current)
        if i == edge_index:
            next.route = route
            next.waypoints = waypoints
            next.start_anchor = start_anchor
            next.end_anchor = end_anchor
        out_edges.push(next)
        i = i + 1
    SdnGraph(name: graph.name, direction: graph.direction, theme: graph.theme, css_file: graph.css_file, canvas_width: graph.canvas_width, canvas_height: graph.canvas_height, canvas_grid: graph.canvas_grid, canvas_snap: graph.canvas_snap, canvas_zoom: graph.canvas_zoom, canvas_background: graph.canvas_background, nodes: graph.nodes, edges: out_edges, css_defs: graph.css_defs, styles: graph.styles, weaves: graph.weaves)

fn sdn_graph_update_node_at(graph: SdnGraph, node_index: i64, css: text, role: text, shape: text, x: text, y: text, width: text, height: text, layer: text) -> SdnGraph:
    var out_nodes: [SdnGraphNode] = []
    var i = 0
    while i < graph.nodes.len():
        val current = graph.nodes[i]
        var next = _sg_clone_node(current)
        if i == node_index:
            next.css = css
            next.role = role
            next.shape = shape
            next.x = x
            next.y = y
            next.width = width
            next.height = height
            next.layer = layer
        out_nodes.push(next)
        i = i + 1
    SdnGraph(name: graph.name, direction: graph.direction, theme: graph.theme, css_file: graph.css_file, canvas_width: graph.canvas_width, canvas_height: graph.canvas_height, canvas_grid: graph.canvas_grid, canvas_snap: graph.canvas_snap, canvas_zoom: graph.canvas_zoom, canvas_background: graph.canvas_background, nodes: out_nodes, edges: graph.edges, css_defs: graph.css_defs, styles: graph.styles, weaves: graph.weaves)

fn sdn_graph_update_node_shape_at(graph: SdnGraph, node_index: i64, shape: text) -> SdnGraph:
    if node_index < 0 or node_index >= graph.nodes.len():
        return graph
    val node = graph.nodes[node_index]
    sdn_graph_update_node_at(graph, node_index, node.css, node.role, shape, node.x, node.y, node.width, node.height, node.layer)

fn sdn_graph_update_node_style_at(graph: SdnGraph, node_index: i64, css: text) -> SdnGraph:
    if node_index < 0 or node_index >= graph.nodes.len():
        return graph
    val node = graph.nodes[node_index]
    sdn_graph_update_node_at(graph, node_index, css, node.role, node.shape, node.x, node.y, node.width, node.height, node.layer)

fn sdn_graph_update_node_parent_at(graph: SdnGraph, node_index: i64, parent: text) -> SdnGraph:
    if node_index < 0 or node_index >= graph.nodes.len():
        return graph
    var out_nodes: [SdnGraphNode] = []
    var i = 0
    while i < graph.nodes.len():
        val current = graph.nodes[i]
        var next = _sg_clone_node(current)
        if i == node_index:
            next.parent = parent
        out_nodes.push(next)
        i = i + 1
    SdnGraph(name: graph.name, direction: graph.direction, theme: graph.theme, css_file: graph.css_file, canvas_width: graph.canvas_width, canvas_height: graph.canvas_height, canvas_grid: graph.canvas_grid, canvas_snap: graph.canvas_snap, canvas_zoom: graph.canvas_zoom, canvas_background: graph.canvas_background, nodes: out_nodes, edges: graph.edges, css_defs: graph.css_defs, styles: graph.styles, weaves: graph.weaves)

fn sdn_graph_update_canvas(graph: SdnGraph, new_width: text, new_height: text, new_grid: text, new_snap: text, new_zoom: text, new_background: text) -> SdnGraph:
    SdnGraph(name: graph.name, direction: graph.direction, theme: graph.theme, css_file: graph.css_file, canvas_width: new_width, canvas_height: new_height, canvas_grid: new_grid, canvas_snap: new_snap, canvas_zoom: new_zoom, canvas_background: new_background, nodes: graph.nodes, edges: graph.edges, css_defs: graph.css_defs, styles: graph.styles, weaves: graph.weaves)

fn sdn_graph_geometry_signature(graph: SdnGraph, node_ids: [text]) -> text:
    var parts: [text] = []
    for node in graph.nodes:
        if _sg_id_in_list(node.id, node_ids):
            parts.push(node.id + ":" + node.x + "," + node.y + "," + node.width + "," + node.height)
    parts.join(";")

fn sdn_graph_align_checked(graph: SdnGraph, node_ids: [text], expected_signature: text, mode: text) -> SdnGraphEditResult:
    val actual_signature = sdn_graph_geometry_signature(graph, node_ids)
    if actual_signature != expected_signature:
        return SdnGraphEditResult(accepted: false, reason: "stale-selection", diff: "@@ sdd-align " + mode + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, graph: graph)
    if node_ids.len() < 2:
        return SdnGraphEditResult(accepted: false, reason: "invalid-selection", diff: "@@ sdd-align " + mode + " @@\nexpected: at least 2 nodes\nactual: " + node_ids.len().to_text(), graph: graph)
    val selected_count = _sg_selected_count(graph, node_ids)
    if selected_count != node_ids.len():
        return SdnGraphEditResult(accepted: false, reason: "missing-node", diff: "@@ sdd-align " + mode + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, graph: graph)
    if not _sg_align_mode_supported(mode):
        return SdnGraphEditResult(accepted: false, reason: "unsupported-align-mode", diff: "@@ sdd-align " + mode + " @@\nexpected: left|center|right|top|middle|bottom\nactual: " + mode, graph: graph)
    val bounds = _sg_selected_bounds(graph, node_ids)
    if not bounds.ok:
        return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
    var out_nodes: [SdnGraphNode] = []
    for original in graph.nodes:
        out_nodes.push(_sg_clone_node(original))
    var out = _sg_graph_with_nodes(graph, out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _sg_id_in_list(node.id, node_ids):
            val aligned = _sg_align_node(node, mode, bounds)
            if not aligned.ok:
                return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-align " + mode + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
            out.nodes[i] = aligned.node
        i = i + 1
    val new_signature = sdn_graph_geometry_signature(out, node_ids)
    SdnGraphEditResult(accepted: true, reason: "updated", diff: "@@ sdd-align " + mode + " @@\n- " + expected_signature + "\n+ " + new_signature, graph: out)

fn sdn_graph_distribute_checked(graph: SdnGraph, node_ids: [text], expected_signature: text, axis: text) -> SdnGraphEditResult:
    val actual_signature = sdn_graph_geometry_signature(graph, node_ids)
    if actual_signature != expected_signature:
        return SdnGraphEditResult(accepted: false, reason: "stale-selection", diff: "@@ sdd-distribute " + axis + " @@\nexpected: " + expected_signature + "\nactual: " + actual_signature, graph: graph)
    if node_ids.len() < 3:
        return SdnGraphEditResult(accepted: false, reason: "invalid-selection", diff: "@@ sdd-distribute " + axis + " @@\nexpected: at least 3 nodes\nactual: " + node_ids.len().to_text(), graph: graph)
    val selected_count = _sg_selected_count(graph, node_ids)
    if selected_count != node_ids.len():
        return SdnGraphEditResult(accepted: false, reason: "missing-node", diff: "@@ sdd-distribute " + axis + " @@\nexpected: " + node_ids.join(",") + "\nactual: " + actual_signature, graph: graph)
    if axis != "horizontal" and axis != "vertical":
        return SdnGraphEditResult(accepted: false, reason: "unsupported-distribute-axis", diff: "@@ sdd-distribute " + axis + " @@\nexpected: horizontal|vertical\nactual: " + axis, graph: graph)
    val bounds = _sg_selected_bounds(graph, node_ids)
    if not bounds.ok:
        return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
    val total_span = _sg_selected_axis_size(graph, node_ids, axis)
    if not total_span.ok:
        return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
    val available = if axis == "horizontal" then bounds.max_x - bounds.min_x else bounds.max_y - bounds.min_y
    val gap = (available - total_span.value) / (selected_count - 1)
    var out_nodes: [SdnGraphNode] = []
    for original in graph.nodes:
        out_nodes.push(_sg_clone_node(original))
    var out = _sg_graph_with_nodes(graph, out_nodes)
    var i = 0
    while i < out.nodes.len():
        val node = out.nodes[i]
        if _sg_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal" then _sg_parse_i64_result(node.width) else _sg_parse_i64_result(node.height)
            if not size.ok:
                return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
            val cursor = _sg_distribution_cursor_for_node(graph, node_ids, axis, node.id, bounds, gap)
            if not cursor.ok:
                return SdnGraphEditResult(accepted: false, reason: "invalid-geometry", diff: "@@ sdd-distribute " + axis + " @@\nexpected: integer geometry\nactual: " + actual_signature, graph: graph)
            var updated = _sg_clone_node(node)
            if axis == "horizontal":
                updated.x = cursor.value.to_text()
            else:
                updated.y = cursor.value.to_text()
            out.nodes[i] = updated
        i = i + 1
    val new_signature = sdn_graph_geometry_signature(out, node_ids)
    SdnGraphEditResult(accepted: true, reason: "updated", diff: "@@ sdd-distribute " + axis + " @@\n- " + expected_signature + "\n+ " + new_signature, graph: out)

fn sdn_graph_inspect_node(graph: SdnGraph, node_id: text) -> SdnGraphNodeInspector:
    val node_index = _sg_find_node_index(graph, node_id)
    if node_index < 0:
        return SdnGraphNodeInspector(found: false, reason: "missing-node", id: node_id, label: "", css: "", role: "", shape: "", x: "", y: "", width: "", height: "", layer: "", parent: "")
    val node = graph.nodes[node_index]
    SdnGraphNodeInspector(found: true, reason: "selected", id: node.id, label: node.label, css: node.css, role: node.role, shape: node.shape, x: node.x, y: node.y, width: node.width, height: node.height, layer: node.layer, parent: node.parent)

fn sdn_graph_inspect_edge(graph: SdnGraph, edge_index: i64) -> SdnGraphEdgeInspector:
    if edge_index < 0 or edge_index >= graph.edges.len():
        return SdnGraphEdgeInspector(found: false, reason: "missing-edge", edge_index: edge_index, from_id: "", to_id: "", label: "", css: "", kind: "", route: "", waypoints: "", start_anchor: "", end_anchor: "", path: "")
    val edge = graph.edges[edge_index]
    SdnGraphEdgeInspector(found: true, reason: "selected", edge_index: edge_index, from_id: edge.from_id, to_id: edge.to_id, label: edge.label, css: edge.css, kind: edge.kind, route: edge.route, waypoints: edge.waypoints, start_anchor: edge.start_anchor, end_anchor: edge.end_anchor, path: _sg_edge_svg_path(graph, edge))

fn sdn_graph_render_html(graph: SdnGraph) -> text:
    sdn_graph_render_html_with_selection(graph, "", -1)

fn sdn_graph_render_html_with_selection(graph: SdnGraph, selected_node_id: text, selected_edge_index: i64) -> text:
    var html: [text] = []
    var canvas_style = ""
    if graph.canvas_width != "":
        canvas_style = canvas_style + "width:" + _sg_safe_length(graph.canvas_width) + ";"
    if graph.canvas_height != "":
        canvas_style = canvas_style + "height:" + _sg_safe_length(graph.canvas_height) + ";"
    val style_attr = if canvas_style != "" then " style=\"" + canvas_style + "\"" else: ""
    html.push("<div class=\"sdn-graph sdd-diagram\" data-format=\"sdd\" data-format-name=\"" + sdn_graph_format_name() + "\" data-graph=\"" + _sg_escape_html(graph.name) + "\" data-direction=\"" + _sg_escape_html(graph.direction) + "\" data-theme=\"" + _sg_escape_html(graph.theme) + "\" data-css-file=\"" + _sg_escape_html(graph.css_file) + "\" data-canvas-width=\"" + _sg_escape_html(graph.canvas_width) + "\" data-canvas-height=\"" + _sg_escape_html(graph.canvas_height) + "\" data-canvas-grid=\"" + _sg_escape_html(graph.canvas_grid) + "\" data-canvas-snap=\"" + _sg_escape_html(graph.canvas_snap) + "\" data-canvas-zoom=\"" + _sg_escape_html(graph.canvas_zoom) + "\" data-canvas-background=\"" + _sg_escape_html(graph.canvas_background) + "\" data-selected-node-id=\"" + _sg_escape_html(selected_node_id) + "\" data-selected-edge-index=\"" + selected_edge_index.to_text() + "\"" + style_attr + ">")
    if graph.edges.len() > 0:
        html.push("<svg class=\"sdd-connector-layer\" aria-hidden=\"true\" focusable=\"false\">")
        var edge_index = 0
        for edge in graph.edges:
            val path = _sg_edge_svg_path(graph, edge)
            val edge_selected = edge_index == selected_edge_index
            val edge_selected_text = _sg_bool_text(edge_selected)
            val edge_selected_class = if edge_selected then " sdd-selected" else: ""
            if path != "":
                html.push("<path class=\"sdd-connector-path " + _sg_css_classes(edge.css) + edge_selected_class + "\" data-edge-index=\"" + edge_index.to_text() + "\" data-selected=\"" + edge_selected_text + "\" aria-selected=\"" + edge_selected_text + "\" data-from=\"" + _sg_escape_html(edge.from_id) + "\" data-to=\"" + _sg_escape_html(edge.to_id) + "\" data-route=\"" + _sg_escape_html(edge.route) + "\" data-waypoints=\"" + _sg_escape_html(edge.waypoints) + "\" data-start-anchor=\"" + _sg_escape_html(edge.start_anchor) + "\" data-end-anchor=\"" + _sg_escape_html(edge.end_anchor) + "\" data-path=\"" + path + "\" d=\"" + path + "\" fill=\"none\" stroke=\"currentColor\"><title>" + _sg_escape_html(edge.label) + "</title></path>")
            edge_index = edge_index + 1
        html.push("</svg>")
    var i = 0
    while i < graph.nodes.len():
        val node = graph.nodes[i]
        val node_selected = selected_node_id != "" and node.id == selected_node_id
        val node_selected_text = _sg_bool_text(node_selected)
        val node_selected_class = if node_selected then " sdd-selected" else: ""
        val auto_x = (8 + (i % 4) * 23).to_text() + "%"
        val auto_y = (12 + (i / 4) * 22).to_text() + "%"
        val x = if node.x != "" then _sg_safe_length(node.x) else: auto_x
        val y = if node.y != "" then _sg_safe_length(node.y) else: auto_y
        var style = "left:" + x + ";top:" + y
        if node.width != "":
            style = style + ";width:" + _sg_safe_length(node.width)
        if node.height != "":
            style = style + ";height:" + _sg_safe_length(node.height)
        html.push("<button type=\"button\" class=\"sdn-graph-node sdd-node " + _sg_css_classes(node.css) + node_selected_class + "\" data-node=\"" + _sg_escape_html(node.id) + "\" data-selected=\"" + node_selected_text + "\" aria-selected=\"" + node_selected_text + "\" data-role=\"" + _sg_escape_html(node.role) + "\" data-shape=\"" + _sg_escape_html(node.shape) + "\" data-layer=\"" + _sg_escape_html(node.layer) + "\" data-parent=\"" + _sg_escape_html(node.parent) + "\" data-x=\"" + _sg_escape_html(node.x) + "\" data-y=\"" + _sg_escape_html(node.y) + "\" data-width=\"" + _sg_escape_html(node.width) + "\" data-height=\"" + _sg_escape_html(node.height) + "\" style=\"" + style + "\">" + _sg_escape_html(node.label) + "</button>")
        i = i + 1
    var edge_div_index = 0
    for edge in graph.edges:
        val path = _sg_edge_svg_path(graph, edge)
        val edge_selected = edge_div_index == selected_edge_index
        val edge_selected_text = _sg_bool_text(edge_selected)
        val edge_selected_class = if edge_selected then " sdd-selected" else: ""
        html.push("<div class=\"sdn-graph-edge sdd-connector " + _sg_css_classes(edge.css) + edge_selected_class + "\" data-edge-index=\"" + edge_div_index.to_text() + "\" data-selected=\"" + edge_selected_text + "\" aria-selected=\"" + edge_selected_text + "\" data-from=\"" + _sg_escape_html(edge.from_id) + "\" data-to=\"" + _sg_escape_html(edge.to_id) + "\" data-kind=\"" + _sg_escape_html(edge.kind) + "\" data-route=\"" + _sg_escape_html(edge.route) + "\" data-waypoints=\"" + _sg_escape_html(edge.waypoints) + "\" data-start-anchor=\"" + _sg_escape_html(edge.start_anchor) + "\" data-end-anchor=\"" + _sg_escape_html(edge.end_anchor) + "\" data-path=\"" + path + "\">" + _sg_escape_html(edge.label) + "</div>")
        edge_div_index = edge_div_index + 1
    html.push("</div>")
    html.join("")

fn _sg_bool_text(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _sg_has_canvas(graph: SdnGraph) -> bool:
    graph.canvas_width != "" or graph.canvas_height != "" or graph.canvas_grid != "" or graph.canvas_snap != "" or graph.canvas_zoom != "" or graph.canvas_background != ""

fn _sg_edge_svg_path(graph: SdnGraph, edge: SdnGraphEdge) -> text:
    val from_idx = _sg_find_node_index(graph, edge.from_id)
    val to_idx = _sg_find_node_index(graph, edge.to_id)
    if from_idx < 0 or to_idx < 0:
        return ""
    sdn_graph_render_edge_path(edge, graph.nodes[from_idx], graph.nodes[to_idx])

fn _sg_find_node_index(graph: SdnGraph, id: text) -> i64:
    var i = 0
    while i < graph.nodes.len():
        if graph.nodes[i].id == id:
            return i
        i = i + 1
    -1

fn _sg_anchor_point(node: SdnGraphNode, anchor: text) -> tuple:
    val x = _sg_int_length(node.x)
    val y = _sg_int_length(node.y)
    val w = _sg_int_length_or(node.width, 120)
    val h = _sg_int_length_or(node.height, 48)
    if anchor == "left":
        return (x, y + h / 2)
    if anchor == "right":
        return (x + w, y + h / 2)
    if anchor == "top":
        return (x + w / 2, y)
    if anchor == "bottom":
        return (x + w / 2, y + h)
    (x + w / 2, y + h / 2)

fn _sg_parse_waypoints(value: text) -> [tuple]:
    var points: [tuple] = []
    val trimmed = value.trim()
    if trimmed == "":
        return points
    val tokens = trimmed.split(";")
    for token in tokens:
        val t = token.trim()
        val sep = t.index_of("x")
        if sep > 0:
            val x_text = t.slice(0, sep).trim()
            val y_text = t.slice(sep + 1, t.len()).trim()
            points.push((_sg_int_length(x_text), _sg_int_length(y_text)))
    points

fn _sg_build_straight_path(points: [tuple], start: tuple, finish: tuple) -> text:
    var d = "M " + start.0.to_text() + "," + start.1.to_text()
    for point in points:
        d = d + " L " + point.0.to_text() + "," + point.1.to_text()
    d + " L " + finish.0.to_text() + "," + finish.1.to_text()

fn _sg_build_orthogonal_path(points: [tuple], start: tuple, finish: tuple) -> text:
    var d = "M " + start.0.to_text() + "," + start.1.to_text()
    var current_x = start.0
    var current_y = start.1
    for point in points:
        if current_x != point.0:
            d = d + " L " + point.0.to_text() + "," + current_y.to_text()
            current_x = point.0
        if current_y != point.1:
            d = d + " L " + current_x.to_text() + "," + point.1.to_text()
            current_y = point.1
    if current_x != finish.0:
        d = d + " L " + finish.0.to_text() + "," + current_y.to_text()
        current_x = finish.0
    if current_y != finish.1:
        d = d + " L " + current_x.to_text() + "," + finish.1.to_text()
    d

fn _sg_clone_edge(edge: SdnGraphEdge) -> SdnGraphEdge:
    SdnGraphEdge(
        from_id: edge.from_id,
        to_id: edge.to_id,
        label: edge.label,
        css: edge.css,
        kind: edge.kind,
        route: edge.route,
        waypoints: edge.waypoints,
        start_anchor: edge.start_anchor,
        end_anchor: edge.end_anchor
    )

fn _sg_clone_node(node: SdnGraphNode) -> SdnGraphNode:
    SdnGraphNode(
        id: node.id,
        label: node.label,
        css: node.css,
        role: node.role,
        shape: node.shape,
        x: node.x,
        y: node.y,
        width: node.width,
        height: node.height,
        layer: node.layer,
        parent: node.parent
    )

fn _sg_graph_with_nodes(graph: SdnGraph, nodes: [SdnGraphNode]) -> SdnGraph:
    SdnGraph(name: graph.name, direction: graph.direction, theme: graph.theme, css_file: graph.css_file, canvas_width: graph.canvas_width, canvas_height: graph.canvas_height, canvas_grid: graph.canvas_grid, canvas_snap: graph.canvas_snap, canvas_zoom: graph.canvas_zoom, canvas_background: graph.canvas_background, nodes: nodes, edges: graph.edges, css_defs: graph.css_defs, styles: graph.styles, weaves: graph.weaves)

fn _sg_id_in_list(id: text, ids: [text]) -> bool:
    for item in ids:
        if item == id:
            return true
    false

fn _sg_selected_count(graph: SdnGraph, node_ids: [text]) -> i64:
    var count: i64 = 0
    for node in graph.nodes:
        if _sg_id_in_list(node.id, node_ids):
            count = count + 1
    count

fn _sg_selected_axis_size(graph: SdnGraph, node_ids: [text], axis: text) -> SdnGraphI64Result:
    var total: i64 = 0
    for node in graph.nodes:
        if _sg_id_in_list(node.id, node_ids):
            val size = if axis == "horizontal" then _sg_parse_i64_result(node.width) else _sg_parse_i64_result(node.height)
            if not size.ok:
                return SdnGraphI64Result(ok: false, value: 0)
            total = total + size.value
    SdnGraphI64Result(ok: true, value: total)

fn _sg_distribution_cursor_for_node(graph: SdnGraph, node_ids: [text], axis: text, node_id: text, bounds: SdnGraphBounds, gap: i64) -> SdnGraphI64Result:
    val target_index = _sg_find_node_index(graph, node_id)
    if target_index < 0:
        return SdnGraphI64Result(ok: false, value: 0)
    val target_pos = _sg_node_axis_position(graph.nodes[target_index], axis)
    if not target_pos.ok:
        return SdnGraphI64Result(ok: false, value: 0)
    var cursor = if axis == "horizontal" then bounds.min_x else bounds.min_y
    var i = 0
    while i < graph.nodes.len():
        val candidate = graph.nodes[i]
        if _sg_id_in_list(candidate.id, node_ids):
            val candidate_pos = _sg_node_axis_position(candidate, axis)
            val candidate_size = if axis == "horizontal" then _sg_parse_i64_result(candidate.width) else _sg_parse_i64_result(candidate.height)
            if not candidate_pos.ok or not candidate_size.ok:
                return SdnGraphI64Result(ok: false, value: 0)
            if candidate_pos.value < target_pos.value or (candidate_pos.value == target_pos.value and i < target_index):
                cursor = cursor + candidate_size.value + gap
        i = i + 1
    SdnGraphI64Result(ok: true, value: cursor)

fn _sg_node_axis_position(node: SdnGraphNode, axis: text) -> SdnGraphI64Result:
    if axis == "horizontal":
        return _sg_parse_i64_result(node.x)
    _sg_parse_i64_result(node.y)

fn _sg_align_mode_supported(mode: text) -> bool:
    mode == "left" or mode == "center" or mode == "right" or mode == "top" or mode == "middle" or mode == "bottom"

fn _sg_selected_bounds(graph: SdnGraph, node_ids: [text]) -> SdnGraphBounds:
    var initialized = false
    var min_x: i64 = 0
    var min_y: i64 = 0
    var max_x: i64 = 0
    var max_y: i64 = 0
    for node in graph.nodes:
        if _sg_id_in_list(node.id, node_ids):
            val x = _sg_parse_i64_result(node.x)
            val y = _sg_parse_i64_result(node.y)
            val w = _sg_parse_i64_result(node.width)
            val h = _sg_parse_i64_result(node.height)
            if not x.ok or not y.ok or not w.ok or not h.ok:
                return SdnGraphBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
            val right = x.value + w.value
            val bottom = y.value + h.value
            if not initialized:
                min_x = x.value
                min_y = y.value
                max_x = right
                max_y = bottom
                initialized = true
            else:
                if x.value < min_x:
                    min_x = x.value
                if y.value < min_y:
                    min_y = y.value
                if right > max_x:
                    max_x = right
                if bottom > max_y:
                    max_y = bottom
    if not initialized:
        return SdnGraphBounds(ok: false, min_x: 0, min_y: 0, max_x: 0, max_y: 0)
    SdnGraphBounds(ok: true, min_x: min_x, min_y: min_y, max_x: max_x, max_y: max_y)

fn _sg_align_node(node: SdnGraphNode, mode: text, bounds: SdnGraphBounds) -> SdnGraphAlignedNode:
    val x = _sg_parse_i64_result(node.x)
    val y = _sg_parse_i64_result(node.y)
    val w = _sg_parse_i64_result(node.width)
    val h = _sg_parse_i64_result(node.height)
    if not x.ok or not y.ok or not w.ok or not h.ok:
        return SdnGraphAlignedNode(ok: false, node: node)
    var updated = _sg_clone_node(node)
    if mode == "left":
        updated.x = bounds.min_x.to_text()
    elif mode == "center":
        val center = (bounds.min_x + bounds.max_x) / 2
        updated.x = (center - (w.value / 2)).to_text()
    elif mode == "right":
        updated.x = (bounds.max_x - w.value).to_text()
    elif mode == "top":
        updated.y = bounds.min_y.to_text()
    elif mode == "middle":
        val middle = (bounds.min_y + bounds.max_y) / 2
        updated.y = (middle - (h.value / 2)).to_text()
    elif mode == "bottom":
        updated.y = (bounds.max_y - h.value).to_text()
    SdnGraphAlignedNode(ok: true, node: updated)

fn _sg_parse_i64_result(value: text) -> SdnGraphI64Result:
    val trimmed = value.trim()
    if not _sg_is_i64_token(trimmed):
        return SdnGraphI64Result(ok: false, value: 0)
    var negative = false
    var i = 0
    if trimmed.char_at(0) == "-":
        negative = true
        i = 1
    var out: i64 = 0
    while i < trimmed.len():
        out = out * 10 + (trimmed.char_at(i).char_code_at(0) - 48).to_i64()
        i = i + 1
    if negative:
        out = 0 - out
    SdnGraphI64Result(ok: true, value: out)

fn _sg_is_i64_token(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    if value.char_at(0) == "-":
        if value.len() == 1:
            return false
        i = 1
    while i < value.len():
        val ch = value.char_at(i)
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    true

fn _sg_int_length_or(value: text, fallback: i64) -> i64:
    val parsed = _sg_int_length(value)
    if parsed == 0 and value.trim() == "":
        return fallback
    parsed

fn _sg_int_length(value: text) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return 0
    var numeric = ""
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if (ch >= "0" and ch <= "9") or (ch == "-" and i == 0):
            numeric = numeric + ch
        elif ch == ".":
            i = trimmed.len()
        else:
            i = trimmed.len()
        i = i + 1
    if numeric == "" or numeric == "-":
        return 0
    numeric.to_i64()

fn _sg_parse_dense_node(line: text) -> SdnGraphNode:
    val sep = line.index_of(":")
    val id = line.slice(0, sep).trim()
    val rest = line.slice(sep + 1, line.len()).trim()
    val label = _sg_label_before_meta(rest)
    SdnGraphNode(id: id, label: label, css: _sg_collect_at(rest), role: _sg_meta_value(rest, "role"), shape: _sg_meta_value(rest, "shape"), x: _sg_meta_value(rest, "x"), y: _sg_meta_value(rest, "y"), width: _sg_meta_value(rest, "width"), height: _sg_meta_value(rest, "height"), layer: _sg_meta_value(rest, "layer"), parent: _sg_meta_value(rest, "parent"))

fn _sg_parse_dense_edge(line: text) -> SdnGraphEdge:
    val op = _sg_edge_operator(line)
    val op_pos = line.index_of(op)
    val from_id = line.slice(0, op_pos).trim()
    val rest = line.slice(op_pos + op.len(), line.len()).trim()
    var to_id = rest
    var label = ""
    val colon = rest.index_of(":")
    if colon >= 0:
        to_id = rest.slice(0, colon).trim()
        val after = rest.slice(colon + 1, rest.len()).trim()
        label = _sg_label_before_meta(after)
        return SdnGraphEdge(from_id: from_id, to_id: to_id, label: label, css: _sg_collect_at(after), kind: _sg_edge_kind(op, _sg_meta_value(after, "kind")), route: _sg_meta_value(after, "route"), waypoints: _sg_meta_value(after, "waypoints"), start_anchor: _sg_meta_value(after, "start"), end_anchor: _sg_meta_value(after, "end"))
    SdnGraphEdge(from_id: from_id, to_id: to_id, label: "", css: "", kind: _sg_edge_kind(op, ""), route: "", waypoints: "", start_anchor: "", end_anchor: "")

fn _sg_parse_weave_selector(line: text) -> tuple:
    val target = if line.starts_with("node where ") then "node" else: "edge"
    val prefix_len = if target == "node" then 11 else: 11
    val body = line.slice(prefix_len, line.len() - 1).trim()
    val eq = body.index_of("=")
    if eq < 0:
        return (target, "", "")
    (target, body.slice(0, eq).trim(), _sg_unquote(body.slice(eq + 1, body.len()).trim()))

fn _sg_parse_nodes_table(lines: [text], start: i64) -> ([SdnGraphNode], i64):
    var nodes: [SdnGraphNode] = []
    var i = start + 1
    while i < lines.len():
        val line = lines[i].trim()
        if line == "" or line.contains("|") or line.ends_with(":"):
            return (nodes, i)
        val cols = _sg_split_csv(line)
        if cols.len() >= 4:
            val shape = if cols.len() >= 5 then cols[4].trim() else: ""
            val x = if cols.len() >= 6 then cols[5].trim() else: ""
            val y = if cols.len() >= 7 then cols[6].trim() else: ""
            val width = if cols.len() >= 8 then cols[7].trim() else: ""
            val height = if cols.len() >= 9 then cols[8].trim() else: ""
            val layer = if cols.len() >= 10 then cols[9].trim() else: ""
            val parent = if cols.len() >= 11 then _sg_unquote(cols[10].trim()) else: ""
            nodes.push(SdnGraphNode(id: cols[0].trim(), label: _sg_unquote(cols[1].trim()), css: _sg_unquote(cols[2].trim()), role: cols[3].trim(), shape: shape, x: x, y: y, width: width, height: height, layer: layer, parent: parent))
        i = i + 1
    (nodes, i)

fn _sg_parse_edges_table(lines: [text], start: i64) -> ([SdnGraphEdge], i64):
    var edges: [SdnGraphEdge] = []
    var i = start + 1
    while i < lines.len():
        val line = lines[i].trim()
        if line == "" or line.contains("|") or line.ends_with(":"):
            return (edges, i)
        val cols = _sg_split_csv(line)
        if cols.len() >= 5:
            val route = if cols.len() >= 6 then cols[5].trim() else: ""
            val waypoints = if cols.len() >= 7 then _sg_unquote(cols[6].trim()) else: ""
            val start_anchor = if cols.len() >= 8 then cols[7].trim() else: ""
            val end_anchor = if cols.len() >= 9 then cols[8].trim() else: ""
            edges.push(SdnGraphEdge(from_id: cols[0].trim(), to_id: cols[1].trim(), label: _sg_unquote(cols[2].trim()), css: _sg_unquote(cols[3].trim()), kind: cols[4].trim(), route: route, waypoints: waypoints, start_anchor: start_anchor, end_anchor: end_anchor))
        i = i + 1
    (edges, i)

fn _sg_parse_css_table(lines: [text], start: i64) -> ([SdnGraphCss], i64):
    var css_defs: [SdnGraphCss] = []
    var i = start + 1
    while i < lines.len():
        val line = lines[i].trim()
        if line == "" or line.contains("|") or line.ends_with(":"):
            return (css_defs, i)
        val cols = _sg_split_csv(line)
        if cols.len() >= 3:
            css_defs.push(SdnGraphCss(name: cols[0].trim(), parent_css: cols[1].trim(), target: cols[2].trim()))
        i = i + 1
    (css_defs, i)

fn _sg_parse_styles_table(lines: [text], start: i64) -> ([SdnGraphStyle], i64):
    var styles: [SdnGraphStyle] = []
    var i = start + 1
    while i < lines.len():
        val line = lines[i].trim()
        if line == "" or line.contains("|") or line.ends_with(":"):
            return (styles, i)
        val cols = _sg_split_csv(line)
        if cols.len() >= 3:
            styles.push(SdnGraphStyle(css: cols[0].trim(), key: cols[1].trim(), value: _sg_unquote(cols[2].trim())))
        i = i + 1
    (styles, i)

fn _sg_is_table_header(line: text, name: text) -> bool:
    line.starts_with(name + " |")

fn _sg_has_edge_operator(line: text) -> bool:
    line.contains("->") or line.contains("~>") or line.contains("-x")

fn _sg_edge_operator(line: text) -> text:
    if line.contains("-x"):
        return "-x"
    if line.contains("~>"):
        return "~>"
    "->"

fn _sg_edge_kind(op: text, explicit_kind: text) -> text:
    if explicit_kind != "":
        return explicit_kind
    if op == "~>":
        return "async"
    if op == "-x":
        return "forbidden"
    "normal"

fn _sg_label_before_meta(rest: text) -> text:
    val parts = rest.split(" ")
    var label: [text] = []
    for part in parts:
        if part.starts_with("@") or part.ends_with(":"):
            break
        label.push(part)
    label.join(" ")

fn _sg_collect_at(rest: text) -> text:
    val parts = rest.split(" ")
    var css: [text] = []
    for part in parts:
        val token = part.trim()
        if token.starts_with("@") and token.len() > 1:
            css.push(token.slice(1, token.len()))
    css.join(" ")

fn _sg_meta_value(rest: text, key: text) -> text:
    val parts = rest.split(" ")
    var i = 0
    while i < parts.len():
        if parts[i].trim() == key + ":" and i + 1 < parts.len():
            return _sg_unquote(parts[i + 1].trim())
        i = i + 1
    ""

fn _sg_node_matches(node: SdnGraphNode, field: text, value: text) -> bool:
    if field == "role":
        return node.role == value
    if field == "shape":
        return node.shape == value
    if field == "id":
        return node.id == value
    false

fn _sg_edge_matches(edge: SdnGraphEdge, field: text, value: text) -> bool:
    if field == "kind":
        return edge.kind == value
    if field == "from":
        return edge.from_id == value
    if field == "to":
        return edge.to_id == value
    if field == "route":
        return edge.route == value
    false

fn _sg_merge_css(existing: text, added: text) -> text:
    if existing == "":
        return added
    if added == "":
        return existing
    existing + " " + added

fn _sg_update_css_extends(graph: SdnGraph, name: text, parent_css: text) -> SdnGraph:
    var out = graph
    var i = 0
    while i < out.css_defs.len():
        if out.css_defs[i].name == name:
            out.css_defs[i] = SdnGraphCss(name: name, parent_css: parent_css, target: out.css_defs[i].target)
        i = i + 1
    out

fn _sg_update_css_target(graph: SdnGraph, name: text, target: text) -> SdnGraph:
    var out = graph
    var i = 0
    while i < out.css_defs.len():
        if out.css_defs[i].name == name:
            out.css_defs[i] = SdnGraphCss(name: name, parent_css: out.css_defs[i].parent_css, target: target)
        i = i + 1
    out

fn _sg_split_lines(content: text) -> [text]:
    content.split("\n")

fn _sg_split_csv(line: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var in_quote = false
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "\"":
            in_quote = not in_quote
            current = current + ch
        elif ch == "," and not in_quote:
            parts.push(current.trim())
            current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "" or parts.len() > 0:
        parts.push(current.trim())
    parts

fn _sg_quote_if_space(value: text) -> text:
    if value.contains(" "):
        return "\"" + value + "\""
    value

fn _sg_unquote(value: text) -> text:
    if value.len() >= 2 and value.starts_with("\"") and value.ends_with("\""):
        return value.slice(1, value.len() - 1)
    value

fn _sg_css_classes(css: text) -> text:
    val parts = css.split(" ")
    var out: [text] = []
    for part in parts:
        val token = part.trim()
        if _sg_safe_style_token(token):
            out.push("sdn-css-" + token)
    out.join(" ")

fn _sg_kind_class(kind: text) -> text:
    val token = kind.trim()
    if token == "" or token == "normal" or not _sg_safe_style_token(token):
        return ""
    " sdd-kind-" + token

fn _sg_shape_class(shape: text) -> text:
    val token = shape.trim()
    if token == "" or not _sg_safe_style_token(token):
        return ""
    " sdd-shape-" + token

fn _sg_resolved_style_attr(graph: SdnGraph, css: text, target: text) -> text:
    val style = _sg_resolved_style(graph, css, target)
    if style == "":
        return ""
    " style=\"" + style + "\""

fn _sg_resolved_style(graph: SdnGraph, css: text, target: text) -> text:
    var out: [text] = []
    for raw in css.split(" "):
        val token = raw.trim()
        if token != "":
            val rule = _sg_resolved_style_for_token(graph, token, target, 0)
            if rule != "":
                out.push(rule)
    out.join(";")

fn _sg_resolved_style_value(graph: SdnGraph, css: text, target: text, key: text) -> text:
    var value = ""
    for raw in css.split(" "):
        val token = raw.trim()
        if token != "":
            val token_value = _sg_resolved_style_value_for_token(graph, token, target, key, 0)
            if token_value != "":
                value = token_value
    value

fn _sg_resolved_style_value_for_token(graph: SdnGraph, css: text, target: text, key: text, depth: i64) -> text:
    if depth > 4:
        return ""
    val css_target = _sg_css_target_for(graph, css)
    if css_target != "" and css_target != target:
        return ""
    var value = ""
    val parent = _sg_css_parent_for(graph, css)
    if parent != "" and parent != "none" and parent != css:
        value = _sg_resolved_style_value_for_token(graph, parent, target, key, depth + 1)
    for style in graph.styles:
        if style.css == css and style.key == key and _sg_safe_css_value(style.value) != "":
            value = style.value
    value

fn _sg_resolved_style_for_token(graph: SdnGraph, css: text, target: text, depth: i64) -> text:
    if depth > 4:
        return ""
    val css_target = _sg_css_target_for(graph, css)
    if css_target != "" and css_target != target:
        return ""
    var out: [text] = []
    val parent = _sg_css_parent_for(graph, css)
    if parent != "" and parent != "none" and parent != css:
        val inherited = _sg_resolved_style_for_token(graph, parent, target, depth + 1)
        if inherited != "":
            out.push(inherited)
    for style in graph.styles:
        if style.css == css:
            val declaration = _sg_style_declaration(style.key, style.value, target)
            if declaration != "":
                out.push(declaration)
    out.join(";")

fn _sg_css_target_for(graph: SdnGraph, css: text) -> text:
    for css_def in graph.css_defs:
        if css_def.name == css:
            return css_def.target
    ""

fn _sg_css_parent_for(graph: SdnGraph, css: text) -> text:
    for css_def in graph.css_defs:
        if css_def.name == css:
            return css_def.parent_css
    ""

fn _sg_style_declaration(key: text, value: text, target: text) -> text:
    val safe = _sg_safe_css_value(value)
    if safe == "":
        return ""
    if target == "node":
        if key == "fill":
            return "background-color:" + safe
        if key == "stroke":
            return "border-color:" + safe + ";border-style:solid"
        if key == "stroke_width":
            val width = if safe.starts_with("var(") and safe.ends_with(")") then safe else: _sg_safe_length(safe)
            return "border-width:" + width + ";border-style:solid"
        if key == "radius":
            return "border-radius:" + safe
        if key == "shape":
            return _sg_shape_style(safe)
        if key == "text":
            return "color:" + safe
    elif target == "edge":
        if key == "stroke" or key == "fill" or key == "text":
            return "color:" + safe
        if key == "stroke_width":
            return "stroke-width:" + safe
    ""

fn _sg_safe_css_value(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        return ""
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if not ((ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "#" or ch == "." or ch == "-" or ch == "_" or ch == "%" or ch == " " or ch == "(" or ch == ")"):
            return ""
        i = i + 1
    trimmed

fn _sg_safe_style_token(value: text) -> bool:
    val trimmed = value.trim()
    if trimmed == "":
        return false
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if not ((ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "-" or ch == "_"):
            return false
        i = i + 1
    true

fn _sg_safe_style_token_list(value: text) -> bool:
    for part in value.split(" "):
        val token = part.trim()
        if token != "" and not _sg_safe_style_token(token):
            return false
    true

fn _sg_safe_resource_url(value: text) -> text:
    val trimmed = value.trim()
    val lowered = trimmed.to_lower()
    if lowered.starts_with("javascript:") or lowered.starts_with("data:"):
        return "#"
    trimmed

fn _sg_escape_html(s: text) -> text:
    var result: [text] = []
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "<":
            result.push("&lt;")
        elif ch == ">":
            result.push("&gt;")
        elif ch == "&":
            result.push("&amp;")
        elif ch == "\"":
            result.push("&quot;")
        else:
            result.push(ch)
        i = i + 1
    result.join("")

fn _sg_escape_attr_token(s: text) -> text:
    var result: [text] = []
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "-" or ch == "_":
            result.push(ch)
        else:
            result.push("-")
        i = i + 1
    result.join("")

fn _sg_safe_length(value: text) -> text:
    val trimmed = value.trim()
    if trimmed == "":
        return ""
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if not ((ch >= "0" and ch <= "9") or ch == "." or ch == "-" or ch == "%" or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z")):
            return "0px"
        i = i + 1
    if trimmed.ends_with("%") or trimmed.ends_with("px") or trimmed.ends_with("em") or trimmed.ends_with("rem"):
        return trimmed
    trimmed + "px"
