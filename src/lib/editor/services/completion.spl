# Editor Completion State
#
# Lightweight popup state for LSP completion candidates.

struct CompletionItem:
    label: text
    detail: text
    insert_text: text
    kind: text

class CompletionState:
    visible: bool
    items: [CompletionItem]
    prefix: text
    selected_index: i64

    static fn new() -> CompletionState:
        CompletionState(
            visible: false,
            items: [],
            prefix: "",
            selected_index: 0
        )

    me show(items: [CompletionItem], prefix: text):
        me.items = items
        me.prefix = prefix
        me.visible = true
        me.selected_index = 0

    me hide():
        me.visible = false
        me.prefix = ""
        me.selected_index = 0

    me select_next():
        if me.items.len() == 0:
            me.selected_index = 0
            return
        me.selected_index = (me.selected_index + 1) % me.items.len()

    me select_prev():
        if me.items.len() == 0:
            me.selected_index = 0
            return
        me.selected_index = (me.selected_index - 1 + me.items.len()) % me.items.len()

    fn selected() -> CompletionItem:
        if me.items.len() == 0:
            return CompletionItem(label: "", detail: "", insert_text: "", kind: "")
        me.items[me.selected_index]

fn completion_handle_response(state: CompletionState, result_json: text, prefix: text):
    val items = _completion_parse_items(result_json)
    state.show(items, prefix)

fn _completion_parse_items(json: text) -> [CompletionItem]:
    var items: [CompletionItem] = []
    val arr_start = _completion_find_items_array(json)
    if arr_start < 0:
        return items
    val entries = _completion_split_array_entries(json, arr_start)
    for entry in entries:
        val label = _completion_extract_string(entry, "\"label\"")
        val detail = _completion_extract_string(entry, "\"detail\"")
        var insert_text = _completion_extract_string(entry, "\"insertText\"")
        if insert_text == "":
            insert_text = label
        val kind_code = _completion_extract_int(entry, "\"kind\"")
        items.push(CompletionItem(
            label: label,
            detail: detail,
            insert_text: insert_text,
            kind: _completion_kind_name(kind_code)
        ))
    items

fn _completion_kind_name(code: i64) -> text:
    if code == 1:
        return "text"
    if code == 2:
        return "method"
    if code == 3:
        return "function"
    if code == 4:
        return "constructor"
    if code == 5:
        return "field"
    if code == 6:
        return "variable"
    if code == 7:
        return "class"
    if code == 8:
        return "interface"
    if code == 9:
        return "module"
    if code == 10:
        return "property"
    if code == 14:
        return "keyword"
    if code == 15:
        return "snippet"
    "unknown"

fn _completion_find_items_array(json: text) -> i64:
    val marker = "\"items\":"
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(marker):
            var j = i + marker.len()
            while j < json.len() and json.char_at(j) == " ":
                j = j + 1
            if j < json.len() and json.char_at(j) == "[":
                return j
        i = i + 1
    _completion_find_array_start(json)

fn _completion_find_array_start(json: text) -> i64:
    var i = 0
    while i < json.len():
        if json.char_at(i) == "[":
            return i
        i = i + 1
    -1

fn _completion_split_array_entries(json: text, arr_start: i64) -> [text]:
    var entries: [text] = []
    val arr_end = _completion_extract_balanced_end(json, arr_start, "[")
    if arr_end <= arr_start:
        return entries
    var i = arr_start + 1
    var in_str = false
    while i < arr_end:
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == "{":
                val entry_end = _completion_extract_balanced_end(json, i, "{")
                if entry_end > i:
                    entries.push(json.slice(i, entry_end + 1))
                    i = entry_end
        i = i + 1
    entries

fn _completion_extract_balanced_end(json: text, start: i64, open_ch: text) -> i64:
    val close_ch = if open_ch == "{" then "}" else "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _completion_extract_string(json: text, field: text) -> text:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            if j < json.len() and json.char_at(j) == "\"":
                var result = ""
                j = j + 1
                while j < json.len() and json.char_at(j) != "\"":
                    if json.char_at(j) == "\\":
                        j = j + 1
                        if j < json.len():
                            result = result + json.char_at(j)
                    else:
                        result = result + json.char_at(j)
                    j = j + 1
                return result
        i = i + 1
    ""

fn _completion_extract_int(json: text, field: text) -> i64:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            var num = ""
            while j < json.len():
                val ch = json.char_at(j)
                if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
                    num = num + ch
                else:
                    break
                j = j + 1
            return num.to_i64() ?? 0
        i = i + 1
    0
