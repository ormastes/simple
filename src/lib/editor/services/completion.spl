# Editor Completion State
#
# Lightweight popup state for LSP completion candidates.

struct CompletionItem:
    label: text
    detail: text
    insert_text: text
    kind: text

class CompletionState:
    visible: bool
    items: [CompletionItem]
    prefix: text
    selected_index: i64

    static fn new() -> CompletionState:
        CompletionState(
            visible: false,
            items: [],
            prefix: "",
            selected_index: 0
        )

    me show(items: [CompletionItem], prefix: text):
        me.items = items
        me.prefix = prefix
        me.visible = true
        me.selected_index = 0

    me hide():
        me.visible = false
        me.prefix = ""
        me.selected_index = 0

    me select_next():
        if me.items.len() == 0:
            me.selected_index = 0
            return
        me.selected_index = (me.selected_index + 1) % me.items.len()

    me select_prev():
        if me.items.len() == 0:
            me.selected_index = 0
            return
        me.selected_index = (me.selected_index - 1 + me.items.len()) % me.items.len()

    fn selected() -> CompletionItem:
        if me.items.len() == 0:
            return CompletionItem(label: "", detail: "", insert_text: "", kind: "")
        me.items[me.selected_index]
