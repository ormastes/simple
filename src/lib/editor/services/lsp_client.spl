# Editor LSP Client
#
# Language Server Protocol client for editor integration.
# Communicates via JSON-RPC 2.0 over Content-Length framed stdio transport.

use std.editor.services.lsp_transport.*

struct LspClientConfig:
    server_command: text
    root_path: text
    language_id: text

struct LspRequest:
    id: i64
    method: text
    params_json: text

struct LspResponse:
    id: i64
    ok: bool
    result_json: text
    error_text: text

struct LspNotification:
    method: text
    params_json: text

struct LspCompletedResponse:
    method: text
    id: i64
    ok: bool
    result_json: text
    error_text: text
    raw_json: text

struct LspPendingRequest:
    id: i64
    method: text

class LspClient:
    config: LspClientConfig
    transport: StdioTransport
    next_id: i64
    initialized: bool
    capabilities_json: text
    pending_requests: [LspPendingRequest]
    completed_responses: [LspCompletedResponse]

impl LspClient:

    static fn new(config: LspClientConfig) -> LspClient:
        val transport_config = LspTransportConfig(
            server_command: config.server_command,
            server_args: [],
            root_uri: lsp_path_to_uri(config.root_path)
        )
        LspClient(
            config: config,
            transport: stdio_transport_new(transport_config),
            next_id: 1,
            initialized: false,
            capabilities_json: "",
            pending_requests: [],
            completed_responses: []
        )

    me start() -> bool:
        self.transport.running = true
        true

    me stop():
        self.transport.running = false

    me initialize() -> LspResponse:
        pass_todo

    me initialized_notification():
        pass_todo

    me open_document(path: text, content: text):
        pass_todo

    me close_document(path: text):
        pass_todo

    me change_document(path: text, content: text, version: i64):
        pass_todo

    me completion(path: text, line: i64, col: i64) -> LspResponse:
        pass_todo

    me hover(path: text, line: i64, col: i64) -> LspResponse:
        pass_todo

    me definition(path: text, line: i64, col: i64) -> LspResponse:
        pass_todo

    me references(path: text, line: i64, col: i64) -> LspResponse:
        pass_todo

    me diagnostics_for(path: text) -> LspResponse:
        pass_todo

    me poll() -> [LspCompletedResponse]:
        pass_todo
