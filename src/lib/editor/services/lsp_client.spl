# Editor LSP Client
#
# Language Server Protocol client for editor integration.
# Communicates via JSON-RPC 2.0 over Content-Length framed stdio transport.

use std.editor.services.lsp_transport.*

struct LspClientConfig:
    server_command: text
    root_path: text
    language_id: text

struct LspRequest:
    id: i64
    method: text
    params_json: text

struct LspResponse:
    id: i64
    ok: bool
    result_json: text
    error_text: text

struct LspNotification:
    method: text
    params_json: text

struct LspCompletedResponse:
    method: text
    id: i64
    ok: bool
    result_json: text
    error_text: text
    raw_json: text

struct LspPendingRequest:
    id: i64
    method: text

class LspClient:
    config: LspClientConfig
    transport: StdioTransport
    next_id: i64
    initialized: bool
    capabilities_json: text
    pending_requests: [LspPendingRequest]
    completed_responses: [LspCompletedResponse]

impl LspClient:

    static fn new(config: LspClientConfig) -> LspClient:
        val transport_config = LspTransportConfig(
            server_command: config.server_command,
            server_args: [],
            root_uri: lsp_path_to_uri(config.root_path)
        )
        LspClient(
            config: config,
            transport: stdio_transport_new(transport_config),
            next_id: 1,
            initialized: false,
            capabilities_json: "",
            pending_requests: [],
            completed_responses: []
        )

    me start() -> bool:
        self.transport.running = true
        true

    me stop():
        self.transport.running = false

    me initialize() -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val root_uri = lsp_path_to_uri(self.config.root_path)
        val params = lsp_build_initialize_params(root_uri, "simple-editor")
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"initialize\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        self.initialized = true
        LspResponse(id: id, ok: true, result_json: "{}", error_text: "")

    me initialized_notification():
        val json = "{\"jsonrpc\":\"2.0\",\"method\":\"initialized\",\"params\":{}}"
        stdio_transport_send(self.transport, json)

    me open_document(path: text, content: text):
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_did_open_params(uri, self.config.language_id, 1, content)
        val json = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)

    me close_document(path: text):
        val uri = lsp_path_to_uri(path)
        val params = "{\"textDocument\":{\"uri\":\"" + uri + "\"}}"
        val json = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didClose\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)

    me change_document(path: text, content: text, version: i64):
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_did_change_params(uri, version, content)
        val json = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didChange\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)

    me completion(path: text, line: i64, col: i64) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_position_params(uri, line, col)
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"textDocument/completion\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        LspResponse(id: id, ok: true, result_json: "{\"items\":[]}", error_text: "")

    me hover(path: text, line: i64, col: i64) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_position_params(uri, line, col)
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"textDocument/hover\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        LspResponse(id: id, ok: true, result_json: "null", error_text: "")

    me definition(path: text, line: i64, col: i64) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_position_params(uri, line, col)
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"textDocument/definition\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        LspResponse(id: id, ok: true, result_json: "null", error_text: "")

    me references(path: text, line: i64, col: i64) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_references_params(uri, line, col)
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"textDocument/references\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        LspResponse(id: id, ok: true, result_json: "[]", error_text: "")

    me diagnostics_for(path: text) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val uri = lsp_path_to_uri(path)
        val params = lsp_build_document_params(uri)
        val json = "{\"jsonrpc\":\"2.0\",\"id\":" + id.to_text() + ",\"method\":\"textDocument/diagnostic\",\"params\":" + params + "}"
        stdio_transport_send(self.transport, json)
        LspResponse(id: id, ok: true, result_json: "{\"items\":[]}", error_text: "")

    me poll() -> [LspCompletedResponse]:
        val raw = stdio_transport_receive(self.transport)
        if raw == "":
            return self.completed_responses
        val resp_id = lsp_parse_response_id(raw)
        val result = lsp_parse_response_result(raw)
        val completed = LspCompletedResponse(
            method: "",
            id: resp_id,
            ok: true,
            result_json: result,
            error_text: "",
            raw_json: raw
        )
        self.completed_responses.push(completed)
        self.completed_responses
