# Editor Markdown Renderer
#
# TUI markdown renderer. Applies styling for headings, code blocks,
# lists, tables, and inline formatting using ANSI escape codes.

fn md_render_block(block: RenderBlock) -> [text]:
    match block.kind:
        "heading":
            _mdr_render_heading(block)
        "code":
            _mdr_render_code(block)
        "list":
            block.rendered_lines
        "table":
            _mdr_render_table(block)
        "paragraph":
            block.rendered_lines
        _:
            block.rendered_lines

fn md_render_blocks(model: BlockModel) -> [text]:
    var result: [text] = []
    var i = 0
    while i < model.block_count():
        val block = model.block_at(i)
        if model.is_active(i):
            val raw_lines = _mdr_split_lines(block.content)
            for line in raw_lines:
                result.push(line)
        else:
            val rendered = md_render_block(block)
            for line in rendered:
                result.push(line)
        i = i + 1
    result

fn md_render_inline(line: text) -> text:
    var result = ""
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "*" and i + 1 < line.len() and line.char_at(i + 1) == "*":
            val end = _mdr_find_double(line, "**", i + 2)
            if end > 0:
                val bold_text = line.slice(i + 2, end)
                result = result + "\x1b[1m" + bold_text + "\x1b[0m"
                i = end + 2
                continue
        if ch == "*":
            val end = _mdr_find_single(line, "*", i + 1)
            if end > 0:
                val italic_text = line.slice(i + 1, end)
                result = result + "\x1b[3m" + italic_text + "\x1b[0m"
                i = end + 1
                continue
        if ch == "`":
            val end = _mdr_find_single(line, "`", i + 1)
            if end > 0:
                val code_text = line.slice(i + 1, end)
                result = result + "\x1b[36m" + code_text + "\x1b[0m"
                i = end + 1
                continue
        result = result + ch
        i = i + 1
    result


fn _mdr_render_heading(block: RenderBlock) -> [text]:
    if block.rendered_lines.len() == 0:
        return [""]
    val line = block.rendered_lines[0]
    val level = _mdr_heading_level(line)
    val text_content = line.slice(level, line.len()).trim()
    if level == 1:
        return ["\x1b[1;33m" + text_content + "\x1b[0m"]
    if level == 2:
        return ["\x1b[1;36m" + text_content + "\x1b[0m"]
    if level == 3:
        return ["\x1b[1;32m" + text_content + "\x1b[0m"]
    ["\x1b[1m" + text_content + "\x1b[0m"]

fn _mdr_render_code(block: RenderBlock) -> [text]:
    var result: [text] = []
    for line in block.rendered_lines:
        val trimmed = line.trim()
        if trimmed.starts_with("```"):
            if trimmed.len() > 3:
                result.push("\x1b[90m── " + trimmed.slice(3, trimmed.len()) + " ──\x1b[0m")
            else:
                result.push("\x1b[90m────────\x1b[0m")
        else:
            result.push("\x1b[90m│\x1b[0m " + line)
    result

fn _mdr_render_table(block: RenderBlock) -> [text]:
    var result: [text] = []
    for line in block.rendered_lines:
        val trimmed = line.trim()
        if _mdr_is_separator_row(trimmed):
            result.push("\x1b[90m" + trimmed + "\x1b[0m")
        else:
            result.push(trimmed)
    result

fn _mdr_is_separator_row(line: text) -> bool:
    var i = 0
    var has_dash = false
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "-":
            has_dash = true
        elif ch != "|" and ch != ":" and ch != " ":
            return false
        i = i + 1
    has_dash

fn _mdr_heading_level(line: text) -> i64:
    var level = 0
    while level < line.len() and line.char_at(level) == "#":
        level = level + 1
    level

fn _mdr_find_double(s: text, marker: text, start: i64) -> i64:
    var i = start
    while i + 1 < s.len():
        if s.char_at(i) == marker.char_at(0) and s.char_at(i + 1) == marker.char_at(1):
            return i
        i = i + 1
    -1

fn _mdr_find_single(s: text, ch: text, start: i64) -> i64:
    var i = start
    while i < s.len():
        if s.char_at(i) == ch:
            return i
        i = i + 1
    -1

fn _mdr_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines
