# Editor Block Model
#
# Block-level document model for Obsidian-like markdown rendering.
# Each block maps a range of source lines to rendered output.
# Active block reveals raw source; inactive blocks show rendered output.

struct RenderBlock:
    id: i64
    kind: text
    from_line: i64
    to_line: i64
    content: text
    rendered_lines: [text]
    status: text

class BlockModel:
    blocks: [RenderBlock]
    active_block: i64
    next_id: i64

impl BlockModel:

    static fn new() -> BlockModel:
        BlockModel(blocks: [], active_block: -1, next_id: 1)

    static fn from_markdown(content: text) -> BlockModel:
        var model = BlockModel.new()
        model.blocks = _bm_parse_blocks(content, model)
        model.next_id = model.blocks.len() + 1
        model

    fn block_count() -> i64:
        self.blocks.len()

    fn block_at(index: i64) -> RenderBlock:
        if index < 0 or index >= self.blocks.len():
            return RenderBlock(id: 0, kind: "empty", from_line: 0, to_line: 0, content: "", rendered_lines: [], status: "error")
        self.blocks[index]

    fn block_for_line(line: i64) -> i64:
        var i = 0
        while i < self.blocks.len():
            if line >= self.blocks[i].from_line and line <= self.blocks[i].to_line:
                return i
            i = i + 1
        -1

    me activate_block(index: i64):
        self.active_block = index

    me deactivate_block():
        self.active_block = -1

    fn is_active(index: i64) -> bool:
        self.active_block == index

    me rebuild(content: text):
        val old_active = self.active_block
        self.blocks = _bm_parse_blocks(content, self)
        self.next_id = self.blocks.len() + 1
        if old_active >= 0 and old_active < self.blocks.len():
            self.active_block = old_active
        else:
            self.active_block = -1


fn _bm_parse_blocks(content: text, model: BlockModel) -> [RenderBlock]:
    var blocks: [RenderBlock] = []
    val lines = _bm_split_lines(content)
    var i = 0
    var block_id = 1
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()
        if trimmed.starts_with("```"):
            val start = i
            i = i + 1
            while i < lines.len() and not lines[i].trim().starts_with("```"):
                i = i + 1
            val end = if i < lines.len() then i else: i - 1
            val block_content = _bm_join_lines(lines, start, end + 1)
            val rendered = _bm_render_code_block(lines, start, end)
            blocks.push(RenderBlock(
                id: block_id, kind: "code", from_line: start, to_line: end,
                content: block_content, rendered_lines: rendered, status: "ok"
            ))
            block_id = block_id + 1
            i = i + 1
        elif trimmed.starts_with("#"):
            val level = _bm_heading_level(trimmed)
            val heading_text = trimmed.slice(level, trimmed.len()).trim()
            var prefix = ""
            var h = 0
            while h < level:
                prefix = prefix + "#"
                h = h + 1
            blocks.push(RenderBlock(
                id: block_id, kind: "heading", from_line: i, to_line: i,
                content: line, rendered_lines: [prefix + " " + heading_text], status: "ok"
            ))
            block_id = block_id + 1
            i = i + 1
        elif trimmed.starts_with("- ") or trimmed.starts_with("* ") or trimmed.starts_with("1."):
            val start = i
            while i < lines.len():
                val next_trim = lines[i].trim()
                if next_trim == "":
                    break
                if not (next_trim.starts_with("- ") or next_trim.starts_with("* ") or _bm_is_ordered_list(next_trim) or next_trim.starts_with("  ")):
                    break
                i = i + 1
            val block_content = _bm_join_lines(lines, start, i)
            val rendered = _bm_render_list(lines, start, i)
            blocks.push(RenderBlock(
                id: block_id, kind: "list", from_line: start, to_line: i - 1,
                content: block_content, rendered_lines: rendered, status: "ok"
            ))
            block_id = block_id + 1
        elif trimmed.starts_with("|"):
            val start = i
            while i < lines.len() and lines[i].trim().starts_with("|"):
                i = i + 1
            val block_content = _bm_join_lines(lines, start, i)
            blocks.push(RenderBlock(
                id: block_id, kind: "table", from_line: start, to_line: i - 1,
                content: block_content, rendered_lines: _bm_split_range(lines, start, i), status: "ok"
            ))
            block_id = block_id + 1
        elif trimmed == "":
            i = i + 1
        else:
            val start = i
            while i < lines.len():
                val next_trim = lines[i].trim()
                if next_trim == "" or next_trim.starts_with("#") or next_trim.starts_with("```") or next_trim.starts_with("|") or next_trim.starts_with("- ") or next_trim.starts_with("* "):
                    break
                i = i + 1
            val block_content = _bm_join_lines(lines, start, i)
            blocks.push(RenderBlock(
                id: block_id, kind: "paragraph", from_line: start, to_line: i - 1,
                content: block_content, rendered_lines: _bm_split_range(lines, start, i), status: "ok"
            ))
            block_id = block_id + 1
    blocks


fn _bm_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines

fn _bm_join_lines(lines: [text], start: i64, end: i64) -> text:
    var result = ""
    var i = start
    while i < end and i < lines.len():
        if i > start:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result

fn _bm_split_range(lines: [text], start: i64, end: i64) -> [text]:
    var result: [text] = []
    var i = start
    while i < end and i < lines.len():
        result.push(lines[i])
        i = i + 1
    result

fn _bm_heading_level(line: text) -> i64:
    var level = 0
    while level < line.len() and line.char_at(level) == "#":
        level = level + 1
    if level > 6:
        level = 6
    level

fn _bm_is_ordered_list(line: text) -> bool:
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        val code = ch.char_code_at(0)
        if code >= 48 and code <= 57:
            i = i + 1
        elif ch == ".":
            return true
        else:
            return false
    false

fn _bm_render_code_block(lines: [text], start: i64, end: i64) -> [text]:
    var result: [text] = []
    var i = start
    while i <= end and i < lines.len():
        result.push(lines[i])
        i = i + 1
    result

fn bm_cursor_block_index(model: BlockModel, cursor_row: i64) -> i64:
    model.block_for_line(cursor_row)

fn bm_cursor_block_changed(model: BlockModel, cursor_row: i64) -> bool:
    val current = model.block_for_line(cursor_row)
    current != model.active_block

fn bm_active_block_range(model: BlockModel) -> i64:
    val idx = model.active_block
    if idx < 0 or idx >= model.blocks.len():
        return -1
    model.blocks[idx].from_line


fn _bm_render_list(lines: [text], start: i64, end: i64) -> [text]:
    var result: [text] = []
    var i = start
    while i < end and i < lines.len():
        result.push(lines[i])
        i = i + 1
    result
