# Editor Syntax Highlighting
#
# Keyword-based syntax highlighting for .spl files.
# Token categories: keyword, type, string, number, comment, operator.

struct StyledSegment:
    text_content: text
    style_code: text

struct HighlightedLine:
    segments: [StyledSegment]

fn highlight_line(line: text, language_id: text) -> text:
    if language_id == "simple":
        val hl = highlight_spl_line(line)
        return highlight_render(hl)
    line

fn highlight_spl_line(line: text) -> HighlightedLine:
    var segments: [StyledSegment] = []
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "#":
            segments.push(StyledSegment(text_content: line.slice(i, line.len()), style_code: "\x1b[90m"))
            i = line.len()
        elif ch == "\"":
            val end = _hl_find_string_end(line, i + 1)
            segments.push(StyledSegment(text_content: line.slice(i, end), style_code: "\x1b[32m"))
            i = end
        elif _hl_is_digit(ch):
            val end = _hl_find_number_end(line, i)
            segments.push(StyledSegment(text_content: line.slice(i, end), style_code: "\x1b[33m"))
            i = end
        elif _hl_is_ident_start(ch):
            val end = _hl_find_ident_end(line, i)
            val word = line.slice(i, end)
            if _hl_is_keyword(word):
                segments.push(StyledSegment(text_content: word, style_code: "\x1b[35m"))
            elif _hl_is_type(word):
                segments.push(StyledSegment(text_content: word, style_code: "\x1b[36m"))
            elif _hl_is_builtin(word):
                segments.push(StyledSegment(text_content: word, style_code: "\x1b[34m"))
            else:
                segments.push(StyledSegment(text_content: word, style_code: ""))
            i = end
        elif _hl_is_operator(ch):
            segments.push(StyledSegment(text_content: ch, style_code: "\x1b[91m"))
            i = i + 1
        else:
            segments.push(StyledSegment(text_content: ch, style_code: ""))
            i = i + 1
    HighlightedLine(segments: segments)

fn highlight_render(hl: HighlightedLine) -> text:
    var result = ""
    for seg in hl.segments:
        if seg.style_code != "":
            result = result + seg.style_code + seg.text_content + "\x1b[0m"
        else:
            result = result + seg.text_content
    result

fn _hl_is_keyword(word: text) -> bool:
    if word == "fn" or word == "val" or word == "var" or word == "if" or word == "else" or word == "elif":
        return true
    if word == "while" or word == "for" or word == "in" or word == "return" or word == "match" or word == "class":
        return true
    if word == "struct" or word == "enum" or word == "impl" or word == "use" or word == "import" or word == "extern":
        return true
    if word == "static" or word == "me" or word == "self" or word == "not" or word == "and" or word == "or":
        return true
    if word == "true" or word == "false" or word == "nil" or word == "break" or word == "continue":
        return true
    if word == "then" or word == "describe" or word == "it" or word == "expect":
        return true
    false

fn _hl_is_type(word: text) -> bool:
    if word == "text" or word == "bool" or word == "i8" or word == "i16" or word == "i32" or word == "i64":
        return true
    if word == "u8" or word == "u16" or word == "u32" or word == "u64" or word == "f32" or word == "f64":
        return true
    if word == "ptr" or word == "void":
        return true
    val first = word.char_at(0)
    val code = first.char_code_at(0)
    code >= 65 and code <= 90

fn _hl_is_builtin(word: text) -> bool:
    word == "len" or word == "push" or word == "contains" or word == "starts_with" or word == "ends_with"

fn _hl_is_ident_start(ch: text) -> bool:
    val code = ch.char_code_at(0)
    (code >= 65 and code <= 90) or (code >= 97 and code <= 122) or ch == "_"

fn _hl_is_digit(ch: text) -> bool:
    val code = ch.char_code_at(0)
    code >= 48 and code <= 57

fn _hl_is_operator(ch: text) -> bool:
    ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "=" or ch == "<" or ch == ">" or ch == "!" or ch == "&" or ch == "|"

fn _hl_find_string_end(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        if line.char_at(i) == "\\":
            i = i + 2
            continue
        if line.char_at(i) == "\"":
            return i + 1
        i = i + 1
    line.len()

fn _hl_find_number_end(line: text, start: i64) -> i64:
    var i = start
    while i < line.len() and (_hl_is_digit(line.char_at(i)) or line.char_at(i) == "." or line.char_at(i) == "x"):
        i = i + 1
    i

fn _hl_find_ident_end(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line.char_at(i)
        if _hl_is_ident_start(ch) or _hl_is_digit(ch):
            i = i + 1
        else:
            break
    i
