# Editor Buffer Undo — undo/redo stack for the editor buffer.
#
# Provides: BufferUndoEntry, BufferUndoStack.

struct BufferUndoEntry:
    before: text
    after: text
    cursor_line: i64
    cursor_col: i64

class BufferUndoStack:
    past: [BufferUndoEntry]
    future: [BufferUndoEntry]
    max_size: i64

    static fn new(max_size: i64) -> BufferUndoStack:
        BufferUndoStack(past: [], future: [], max_size: max_size)

    static fn with_defaults() -> BufferUndoStack:
        BufferUndoStack(past: [], future: [], max_size: 200)

    me record(before: text, after: text, cursor_line: i64, cursor_col: i64):
        me.future = []
        me.past.push(BufferUndoEntry(
            before: before,
            after: after,
            cursor_line: cursor_line,
            cursor_col: cursor_col
        ))
        if me.past.len() > me.max_size:
            var trimmed: [BufferUndoEntry] = []
            var i = me.past.len() - me.max_size
            while i < me.past.len():
                trimmed.push(me.past[i])
                i = i + 1
            me.past = trimmed

    me undo() -> Option<BufferUndoEntry>:
        if me.past.len() == 0:
            return Option.None
        val entry = me.past[me.past.len() - 1]
        var new_past: [BufferUndoEntry] = []
        var i = 0
        while i < me.past.len() - 1:
            new_past.push(me.past[i])
            i = i + 1
        me.past = new_past
        me.future.push(entry)
        Option.Some(entry)

    me redo() -> Option<BufferUndoEntry>:
        if me.future.len() == 0:
            return Option.None
        val entry = me.future[me.future.len() - 1]
        var new_future: [BufferUndoEntry] = []
        var i = 0
        while i < me.future.len() - 1:
            new_future.push(me.future[i])
            i = i + 1
        me.future = new_future
        me.past.push(entry)
        Option.Some(entry)

    fn can_undo() -> bool:
        me.past.len() > 0

    fn can_redo() -> bool:
        me.future.len() > 0
