# Piece Table — gap-buffer-style text storage for the editor buffer.
#
# Provides: PieceTable.

class PieceTable:
    # Simplified implementation: backed by a flat text with lines split on demand.
    content: text

    static fn new(initial: text) -> PieceTable:
        PieceTable(content: initial)

    me insert(line: i64, col: i64, text_to_insert: text):
        val lines = me.content.split("\n")
        if line < 0 or line >= lines.len():
            me.content = me.content + text_to_insert
            return
        val target_line = lines[line]
        val before = if col <= target_line.len(): target_line.slice(0, col) else: target_line
        val after = if col <= target_line.len(): target_line.slice(col, target_line.len()) else: ""
        var new_lines: [text] = []
        var i = 0
        while i < lines.len():
            if i == line:
                new_lines.push(before + text_to_insert + after)
            else:
                new_lines.push(lines[i])
            i = i + 1
        me.content = new_lines.join("\n")

    me delete(line: i64, col: i64, count: i64):
        val lines = me.content.split("\n")
        if line < 0 or line >= lines.len():
            return
        val target_line = lines[line]
        if col < 0 or col >= target_line.len():
            return
        val end = if col + count <= target_line.len(): col + count else: target_line.len()
        val new_line = target_line.slice(0, col) + target_line.slice(end, target_line.len())
        var new_lines: [text] = []
        var i = 0
        while i < lines.len():
            if i == line:
                new_lines.push(new_line)
            else:
                new_lines.push(lines[i])
            i = i + 1
        me.content = new_lines.join("\n")

    fn line_count() -> i64:
        me.content.split("\n").len()

    fn line_at(n: i64) -> text:
        val lines = me.content.split("\n")
        if n < 0 or n >= lines.len():
            return ""
        lines[n]

    fn to_text() -> text:
        me.content
