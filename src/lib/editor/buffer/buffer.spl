# Editor Buffer — mutable text buffer with cursor and line access.
#
# Provides: EditorBuffer, EditCommand, EditResult, edit_ok, edit_fail.

use std.editor.buffer.piece_table.{PieceTable}

struct EditCommand:
    name: text
    payload: text
    count: i64

struct EditResult:
    ok: bool
    message: text
    redraw: bool

fn edit_ok(message: text) -> EditResult:
    EditResult(ok: true, message: message, redraw: true)

fn edit_fail(message: text) -> EditResult:
    EditResult(ok: false, message: message, redraw: false)

class EditorBuffer:
    table: PieceTable
    cursor_line: i64
    cursor_col: i64
    file_path: text
    modified: bool

    static fn new() -> EditorBuffer:
        EditorBuffer(
            table: PieceTable.new(""),
            cursor_line: 0,
            cursor_col: 0,
            file_path: "",
            modified: false
        )

    static fn from_text(content: text) -> EditorBuffer:
        EditorBuffer(
            table: PieceTable.new(content),
            cursor_line: 0,
            cursor_col: 0,
            file_path: "",
            modified: false
        )

    me move_relative(line_delta: i64, col_delta: i64):
        me.cursor_line = me.cursor_line + line_delta
        me.cursor_col = me.cursor_col + col_delta
        if me.cursor_line < 0:
            me.cursor_line = 0
        if me.cursor_col < 0:
            me.cursor_col = 0

    me move_to_line_start():
        me.cursor_col = 0

    me move_to_line_end():
        val line = me.table.line_at(me.cursor_line)
        me.cursor_col = line.len()

    me insert_at_cursor(text_to_insert: text):
        me.table.insert(me.cursor_line, me.cursor_col, text_to_insert)
        me.cursor_col = me.cursor_col + text_to_insert.len()
        me.modified = true

    me delete_char_before():
        if me.cursor_col > 0:
            me.table.delete(me.cursor_line, me.cursor_col - 1, 1)
            me.cursor_col = me.cursor_col - 1
            me.modified = true

    fn line_count() -> i64:
        me.table.line_count()

    fn line_at(n: i64) -> text:
        me.table.line_at(n)

    fn full_text() -> text:
        me.table.to_text()
