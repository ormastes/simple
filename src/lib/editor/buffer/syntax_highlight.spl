# Editor Buffer Syntax Highlight
#
# Per-line syntax highlighting for the buffer. Maps line indices to
# ANSI-styled output strings.

struct HighlightSpan:
    start: i64
    end: i64
    scope: text

struct HighlightLine:
    line_index: i64
    spans: [HighlightSpan]
    rendered: text

struct StyledSegment:
    text_content: text
    style_code: text

struct HighlightedLine:
    segments: [StyledSegment]

struct SyntaxHighlight:
    language_id: text
    lines: [HighlightLine]
    version: i64

fn syntax_highlight_new(language_id: text) -> SyntaxHighlight:
    SyntaxHighlight(language_id: language_id, lines: [], version: 0)

fn syntax_highlight_update(hl: SyntaxHighlight, content: text) -> SyntaxHighlight:
    val raw_lines = content.split("\n")
    var new_lines: [HighlightLine] = []
    var idx = 0
    for raw in raw_lines:
        new_lines.push(HighlightLine(line_index: idx, spans: [], rendered: raw))
        idx = idx + 1
    SyntaxHighlight(language_id: hl.language_id, lines: new_lines, version: hl.version + 1)

fn syntax_highlight_for_line(hl: SyntaxHighlight, line_index: i64) -> HighlightLine:
    for l in hl.lines:
        if l.line_index == line_index:
            return l
    HighlightLine(line_index: line_index, spans: [], rendered: "")

fn syntax_highlight_rendered_line(hl: SyntaxHighlight, line_index: i64, raw: text) -> text:
    val hl_line = syntax_highlight_for_line(hl, line_index)
    if hl_line.rendered != "":
        return hl_line.rendered
    raw

fn highlight_spl_line(line: text) -> HighlightedLine:
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "#":
            return HighlightedLine(segments: [StyledSegment(text_content: line, style_code: "\x1b[90m")])
        if ch == "\"":
            return HighlightedLine(segments: [StyledSegment(text_content: line, style_code: "\x1b[32m")])
        if _hl_is_digit(ch):
            return HighlightedLine(segments: [StyledSegment(text_content: line, style_code: "\x1b[36m")])
        i = i + 1
    HighlightedLine(segments: [StyledSegment(text_content: line, style_code: "")])

fn highlight_render(hl: HighlightedLine) -> text:
    var out = ""
    for segment in hl.segments:
        if segment.style_code != "":
            out = out + segment.style_code + segment.text_content + "\x1b[0m"
        else:
            out = out + segment.text_content
    out

fn highlight_line(line: text, language_id: text) -> text:
    if language_id == "simple":
        val hl = highlight_spl_line(line)
        return highlight_render(hl)
    line

fn _hl_is_keyword(word: text) -> bool:
    word == "fn" or word == "val" or word == "var" or word == "class" or word == "struct"

fn _hl_is_type(word: text) -> bool:
    word == "i64" or word == "text" or word == "bool" or word == "f64"

fn _hl_is_digit(ch: text) -> bool:
    ch >= "0" and ch <= "9"
