# Editor Buffer Syntax Highlight
#
# Per-line syntax highlighting for the buffer. Maps line indices to
# ANSI-styled output strings.

struct HighlightSpan:
    start: i64
    end: i64
    scope: text

struct HighlightLine:
    line_index: i64
    spans: [HighlightSpan]
    rendered: text

struct SyntaxHighlight:
    language_id: text
    lines: [HighlightLine]
    version: i64

fn syntax_highlight_new(language_id: text) -> SyntaxHighlight:
    SyntaxHighlight(language_id: language_id, lines: [], version: 0)

fn syntax_highlight_update(hl: SyntaxHighlight, content: text) -> SyntaxHighlight:
    val raw_lines = content.split("\n")
    var new_lines: [HighlightLine] = []
    var idx = 0
    for raw in raw_lines:
        new_lines.push(HighlightLine(line_index: idx, spans: [], rendered: raw))
        idx = idx + 1
    SyntaxHighlight(language_id: hl.language_id, lines: new_lines, version: hl.version + 1)

fn syntax_highlight_for_line(hl: SyntaxHighlight, line_index: i64) -> HighlightLine:
    for l in hl.lines:
        if l.line_index == line_index:
            return l
    HighlightLine(line_index: line_index, spans: [], rendered: "")

fn syntax_highlight_rendered_line(hl: SyntaxHighlight, line_index: i64, raw: text) -> text:
    val hl_line = syntax_highlight_for_line(hl, line_index)
    if hl_line.rendered != "":
        return hl_line.rendered
    raw
