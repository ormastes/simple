# Editor Terminal Renderer
#
# Renders editor view state to ANSI terminal output.
# Writes styled lines to stdout via terminal_write/terminal_move_cursor.

use std.editor.common.types.*

struct TerminalRenderCell:
    ch: text
    fg: text
    bg: text
    bold: bool

struct TerminalRenderLine:
    cells: [TerminalRenderCell]
    raw: text

struct TerminalRenderer:
    width: i64
    height: i64
    cursor_row: i64
    cursor_col: i64
    last_lines: [TerminalRenderLine]

fn terminal_renderer_new(width: i64, height: i64) -> TerminalRenderer:
    TerminalRenderer(
        width: width,
        height: height,
        cursor_row: 0,
        cursor_col: 0,
        last_lines: []
    )

fn terminal_renderer_resize(renderer: TerminalRenderer, width: i64, height: i64) -> TerminalRenderer:
    TerminalRenderer(
        width: width,
        height: height,
        cursor_row: renderer.cursor_row,
        cursor_col: renderer.cursor_col,
        last_lines: []
    )

fn terminal_renderer_render_lines(renderer: TerminalRenderer, lines: [text], x: i64, y: i64, width: i64, height: i64):
    pass_dn

fn terminal_renderer_clear(renderer: TerminalRenderer):
    pass_dn

fn terminal_renderer_move_cursor(renderer: TerminalRenderer, row: i64, col: i64) -> TerminalRenderer:
    TerminalRenderer(
        width: renderer.width,
        height: renderer.height,
        cursor_row: row,
        cursor_col: col,
        last_lines: renderer.last_lines
    )

fn terminal_renderer_ansi_fg(color: text) -> text:
    if color == "":
        return ""
    "\x1b[38;2;" + color + "m"

fn terminal_renderer_ansi_bg(color: text) -> text:
    if color == "":
        return ""
    "\x1b[48;2;" + color + "m"

fn terminal_renderer_ansi_reset() -> text:
    "\x1b[0m"
