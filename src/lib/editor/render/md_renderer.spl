# Editor Markdown Renderer
#
# TUI markdown renderer. Applies styling for headings, code blocks,
# lists, tables, and inline formatting using ANSI escape codes.

use std.editor.services.md_wiki_index.*
use std.editor.render.block_model.{RenderBlock, BlockModel}
use std.editor.services.sdn_graph.{sdn_graph_parse, SdnGraph, SdnGraphNode, SdnGraphEdge}
use std.common.render_scene.office_style_resolver.{resolve_style, style_to_sgr}

# Style decisions (bold/italic) for headings, code, and quotes flow from the
# shared office_style_resolver cascade — the SAME cascade the GUI/web path uses
# via style_to_css_text. style_to_sgr projects the resolved CSS to an SGR
# parameter string ("1" bold, "3" italic, ...). The TUI layers a terminal color
# palette (a presentation choice the cross-surface cascade does not encode) on
# top of those shared attributes. This keeps md_renderer's STYLE decisions
# consistent with the web renderer without forking a third cascade, and pulls in
# only office_style_resolver (pure functions) — no gpu/engine2d/draw_ir weight.
#
# _mdr_sgr combines the resolver-derived SGR parameters for `tag` with an
# optional leading color code and wraps as ESC[ ... m. Empty -> no escape.
fn _mdr_sgr(tag: text, color: text) -> text:
    val attrs = style_to_sgr(resolve_style(tag, []))
    var params = color
    if attrs != "":
        if params == "":
            params = attrs
        else:
            params = "{params};{attrs}"
    if params == "":
        return ""
    "\x1b[" + params + "m"

fn md_render_block(block: RenderBlock) -> [text]:
    match block.kind:
        "heading":
            _mdr_render_heading(block)
        "code":
            _mdr_render_code(block)
        "sdn_graph":
            _mdr_render_sdn_graph(block)
        "md_css":
            _mdr_render_md_css(block)
        "list":
            block.rendered_lines
        "table":
            _mdr_render_table(block)
        "callout":
            _mdr_render_callout(block)
        "embed":
            _mdr_render_embed(block)
        "frontmatter":
            []
        "math":
            _mdr_render_math(block)
        "paragraph":
            block.rendered_lines
        _:
            block.rendered_lines

fn md_render_block_with_wiki(block: RenderBlock, index: MdWikiIndex) -> [text]:
    _mdr_render_block_with_wiki_depth_visited(block, index, 0, [])

fn _mdr_render_block_with_wiki_depth(block: RenderBlock, index: MdWikiIndex, depth: i64) -> [text]:
    _mdr_render_block_with_wiki_depth_visited(block, index, depth, [])

fn _mdr_render_block_with_wiki_depth_visited(block: RenderBlock, index: MdWikiIndex, depth: i64, visited: [text]) -> [text]:
    if block.kind == "embed":
        val transcluded = _mdr_render_embed_transclusion_depth_visited(block, index, depth, visited)
        if transcluded.len() > 0:
            return transcluded
    md_render_block(block)

fn md_render_blocks(model: BlockModel) -> [text]:
    var result: [text] = []
    var i = 0
    while i < model.block_count():
        val block = model.block_at(i)
        if model.is_active(i):
            val raw_lines = _mdr_split_lines(block.content)
            for line in raw_lines:
                result.push(line)
        else:
            val rendered = md_render_block(block)
            for line in rendered:
                result.push(line)
        i = i + 1
    result

fn md_render_blocks_with_wiki(model: BlockModel, index: MdWikiIndex) -> [text]:
    _mdr_render_blocks_with_wiki_depth_visited(model, index, 0, [])

fn _mdr_render_blocks_with_wiki_depth(model: BlockModel, index: MdWikiIndex, depth: i64) -> [text]:
    _mdr_render_blocks_with_wiki_depth_visited(model, index, depth, [])

fn _mdr_render_blocks_with_wiki_depth_visited(model: BlockModel, index: MdWikiIndex, depth: i64, visited: [text]) -> [text]:
    var result: [text] = []
    var i = 0
    while i < model.block_count():
        val block = model.block_at(i)
        if model.is_active(i):
            val raw_lines = _mdr_split_lines(block.content)
            for line in raw_lines:
                result.push(line)
        else:
            val rendered = _mdr_render_block_with_wiki_depth_visited(block, index, depth, visited)
            for line in rendered:
                result.push(line)
        i = i + 1
    result

fn md_render_inline(line: text) -> text:
    var result = ""
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        # Handle escaped markers: \* \` — emit the literal character, skip escape
        if ch == "\\" and i + 1 < line.len():
            val next = line.char_at(i + 1)
            if next == "*" or next == "`" or next == "\\":
                result = result + "\\" + next
                i = i + 2
                continue
        if ch == "*" and i + 1 < line.len() and line.char_at(i + 1) == "*":
            val end = _mdr_find_double(line, "**", i + 2)
            if end >= 0 and end > i + 1:
                val bold_text = line.slice(i + 2, end)
                result = result + "\x1b[1m" + bold_text + "\x1b[0m"
                i = end + 2
                continue
        if ch == "*":
            val end = _mdr_find_single(line, "*", i + 1)
            if end > i:
                val italic_text = line.slice(i + 1, end)
                result = result + "\x1b[3m" + italic_text + "\x1b[0m"
                i = end + 1
                continue
        if ch == "`":
            val end = _mdr_find_single(line, "`", i + 1)
            if end > i:
                val code_text = line.slice(i + 1, end)
                result = result + "\x1b[36m" + code_text + "\x1b[0m"
                i = end + 1
                continue
        result = result + ch
        i = i + 1
    result


fn md_render_blocks_for_tui(model: BlockModel, viewport_start: i64, viewport_height: i64) -> [text]:
    if viewport_height <= 0:
        return []
    if viewport_start < 0:
        return []
    val end = viewport_start + viewport_height
    if end <= viewport_start:
        return []

    var result: [text] = []
    val block_count = model.block_count()
    var cursor = 0
    var i = 0
    while i < block_count:
        val block = model.block_at(i)
        val estimated = if model.is_active(i) then _mdr_split_lines(block.content).len() else block.rendered_lines.len()
        if cursor + estimated <= viewport_start:
            cursor = cursor + estimated
            i = i + 1
            continue
        if cursor >= end:
            break
        val rendered = if model.is_active(i) then _mdr_split_lines(block.content) else md_render_block(block)
        val rendered_len = rendered.len()
        val start = if viewport_start > cursor then viewport_start - cursor else 0
        val finish = if end - cursor < rendered_len then end - cursor else rendered_len
        var j = start
        while j < finish:
            result.push(rendered[j])
            j = j + 1
        cursor = cursor + rendered_len
        i = i + 1
    result

fn md_render_blocks_for_tui_with_wiki(model: BlockModel, index: MdWikiIndex, viewport_start: i64, viewport_height: i64) -> [text]:
    if viewport_height <= 0:
        return []
    if viewport_start < 0:
        return []
    val end = viewport_start + viewport_height
    if end <= viewport_start:
        return []

    var result: [text] = []
    val block_count = model.block_count()
    var cursor = 0
    var i = 0
    while i < block_count:
        val block = model.block_at(i)
        val estimated = if model.is_active(i) then _mdr_split_lines(block.content).len() else block.rendered_lines.len()
        if cursor + estimated <= viewport_start:
            cursor = cursor + estimated
            i = i + 1
            continue
        if cursor >= end:
            break
        val rendered = if model.is_active(i) then _mdr_split_lines(block.content) else _mdr_render_block_with_wiki_depth_visited(block, index, 0, [])
        val rendered_len = rendered.len()
        val start = if viewport_start > cursor then viewport_start - cursor else 0
        val finish = if end - cursor < rendered_len then end - cursor else rendered_len
        var j = start
        while j < finish:
            result.push(rendered[j])
            j = j + 1
        cursor = cursor + rendered_len
        i = i + 1
    result


fn _mdr_render_heading(block: RenderBlock) -> [text]:
    if block.rendered_lines.len() == 0:
        return [""]
    val line = block.rendered_lines[0]
    val level = _mdr_heading_level(line)
    val text_content = _mdr_trim(line.slice(level, line.len()))
    # Bold attribute is resolved from the shared cascade (heading_N -> font-weight
    # bold -> SGR "1"); the per-level color is the TUI palette layered on top.
    if level == 1:
        return [_mdr_sgr("heading_1", "33") + text_content + "\x1b[0m"]
    if level == 2:
        return [_mdr_sgr("heading_2", "36") + text_content + "\x1b[0m"]
    if level == 3:
        return [_mdr_sgr("heading_3", "32") + text_content + "\x1b[0m"]
    val tag = if level == 4 then "heading_4" elif level == 5 then "heading_5" else: "heading_6"
    [_mdr_sgr(tag, "") + text_content + "\x1b[0m"]

fn _mdr_render_code(block: RenderBlock) -> [text]:
    var result: [text] = []
    # code_block style decision routed through the shared cascade; the dim "90"
    # color is the TUI palette layered on the resolved attributes.
    val sgr = _mdr_sgr("code_block", "90")
    for line in block.rendered_lines:
        val trimmed = _mdr_trim(line)
        if trimmed.starts_with("```") or trimmed.starts_with("~~~"):
            if trimmed.len() > 3:
                result.push(sgr + "── " + trimmed.slice(3, trimmed.len()) + " ──\x1b[0m")
            else:
                result.push(sgr + "────────\x1b[0m")
        else:
            result.push(sgr + "│\x1b[0m " + line)
    result

fn _mdr_render_sdn_graph(block: RenderBlock) -> [text]:
    val graph = sdn_graph_parse(_mdr_fence_body(block.rendered_lines))
    var result: [text] = []
    result.push("\x1b[1;36m[graph: " + graph.name + "]\x1b[0m")
    for node in graph.nodes:
        result.push("\x1b[90mnode\x1b[0m " + node.id + " " + node.label + " @" + node.css)
    for edge in graph.edges:
        result.push("\x1b[90medge\x1b[0m " + edge.from_id + " -> " + edge.to_id + " " + edge.label + " @" + edge.css)
    result

fn _mdr_render_md_css(block: RenderBlock) -> [text]:
    ["\x1b[90m[css]\x1b[0m"]

fn _mdr_fence_body(lines: [text]) -> text:
    var body: [text] = []
    var i = 1
    while i < lines.len():
        val line = lines[i]
        if line.trim().starts_with("```"):
            return body.join("\n")
        body.push(line)
        i = i + 1
    body.join("\n")

# Render a table padded to a uniform column grid, honoring the separator
# row's `:--` / `:-:` / `--:` alignment markers (0=left, 1=center, 2=right).
fn _mdr_render_table(block: RenderBlock) -> [text]:
    val rows = block.rendered_lines
    # Pass 1: locate the separator row and the widest cell per column.
    var sep_row = -1
    var col_count = 0
    var r = 0
    while r < rows.len():
        if sep_row < 0 and _mdr_is_separator_row(_mdr_trim(rows[r])):
            sep_row = r
        val cells = _mdr_table_cells(rows[r])
        if cells.len() > col_count:
            col_count = cells.len()
        r = r + 1
    if col_count == 0:
        return rows
    var aligns: [i64] = []
    var c = 0
    while c < col_count:
        var align = 0
        if sep_row >= 0:
            val sep_cells = _mdr_table_cells(rows[sep_row])
            if c < sep_cells.len():
                val spec = sep_cells[c]
                if spec.starts_with(":") and spec.ends_with(":"):
                    align = 1
                elif spec.ends_with(":"):
                    align = 2
        aligns.push(align)
        c = c + 1
    var widths: [i64] = []
    c = 0
    while c < col_count:
        var w = 3
        r = 0
        while r < rows.len():
            if r != sep_row:
                val row_cells = _mdr_table_cells(rows[r])
                if c < row_cells.len():
                    val cell_len = row_cells[c].len()
                    if cell_len > w:
                        w = cell_len
            r = r + 1
        widths.push(w)
        c = c + 1
    # Pass 2: re-emit every row padded to the grid.
    var result: [text] = []
    r = 0
    while r < rows.len():
        if r == sep_row:
            var sep = "|"
            c = 0
            while c < col_count:
                sep = sep + " " + _mdr_table_separator_cell(widths[c], aligns[c]) + " |"
                c = c + 1
            result.push("\x1b[90m" + sep + "\x1b[0m")
        else:
            val row_cells = _mdr_table_cells(rows[r])
            var out = "|"
            c = 0
            while c < col_count:
                var cell = ""
                if c < row_cells.len():
                    cell = row_cells[c]
                out = out + " " + _mdr_table_pad(cell, widths[c], aligns[c]) + " |"
                c = c + 1
            result.push(out)
        r = r + 1
    result

fn _mdr_table_cells(line: text) -> [text]:
    var trimmed = _mdr_trim(line)
    if trimmed.starts_with("|"):
        trimmed = trimmed.slice(1, trimmed.len())
    if trimmed.ends_with("|"):
        trimmed = trimmed.slice(0, trimmed.len() - 1)
    val parts = trimmed.split("|")
    var cells: [text] = []
    for part in parts:
        cells.push(_mdr_trim(part))
    cells

fn _mdr_table_pad(cell: text, width: i64, align: i64) -> text:
    val gap = width - cell.len()
    if gap <= 0:
        return cell
    if align == 2:
        return _mdr_repeat(" ", gap) + cell
    if align == 1:
        val left = gap / 2
        return _mdr_repeat(" ", left) + cell + _mdr_repeat(" ", gap - left)
    cell + _mdr_repeat(" ", gap)

fn _mdr_table_separator_cell(width: i64, align: i64) -> text:
    if align == 1:
        return ":" + _mdr_repeat("-", width - 2) + ":"
    if align == 2:
        return _mdr_repeat("-", width - 1) + ":"
    _mdr_repeat("-", width)

fn _mdr_repeat(ch: text, n: i64) -> text:
    var out = ""
    var i = 0
    while i < n:
        out = out + ch
        i = i + 1
    out

# Verbatim math rendering: dim "── math ──" delimiters, cyan body.
# No formula layout — the $$ fences are replaced, content passes through.
fn _mdr_render_math(block: RenderBlock) -> [text]:
    var result: [text] = []
    for line in block.rendered_lines:
        val trimmed = _mdr_trim(line)
        if trimmed.starts_with("$$") and trimmed.ends_with("$$") and trimmed.len() >= 4:
            val body = _mdr_trim(trimmed.slice(2, trimmed.len() - 2))
            result.push("\x1b[90m──\x1b[0m \x1b[36m" + body + "\x1b[0m \x1b[90m──\x1b[0m")
        elif trimmed == "$$":
            result.push("\x1b[90m── math ──\x1b[0m")
        elif trimmed.starts_with("$$"):
            result.push("\x1b[90m── math ──\x1b[0m")
            val opener_rest = _mdr_trim(trimmed.slice(2, trimmed.len()))
            if opener_rest != "":
                result.push("\x1b[36m" + opener_rest + "\x1b[0m")
        elif trimmed.ends_with("$$"):
            val closer_body = _mdr_trim(trimmed.slice(0, trimmed.len() - 2))
            if closer_body != "":
                result.push("\x1b[36m" + closer_body + "\x1b[0m")
            result.push("\x1b[90m── math ──\x1b[0m")
        else:
            result.push("\x1b[36m" + line + "\x1b[0m")
    result

fn _mdr_render_callout(block: RenderBlock) -> [text]:
    var result: [text] = []
    val lines = block.rendered_lines
    if lines.len() == 0:
        return result
    val info = _mdr_parse_callout_marker(lines[0])
    val ctype = info.0
    val title = info.1
    val folded = info.2
    var heading = ctype.upper()
    if title != "":
        heading = heading + " " + title
    if folded:
        heading = heading + " -"
    result.push("\x1b[1;36m| " + heading + "\x1b[0m")
    if folded:
        return result
    # Quote/callout body marker style routed through the shared cascade
    # (quote -> font-style italic -> SGR "3") with the dim "90" TUI palette color.
    val quote_sgr = _mdr_sgr("quote", "90")
    var i = 1
    while i < lines.len():
        val body = _mdr_strip_blockquote_prefix(lines[i])
        result.push(quote_sgr + "|\x1b[0m " + md_render_inline(body))
        i = i + 1
    result

fn _mdr_render_embed(block: RenderBlock) -> [text]:
    if block.rendered_lines.len() == 0:
        return []
    val info = _mdr_parse_embed_marker(block.rendered_lines[0])
    val kind = info.0
    val target = info.1
    val label = info.2
    var rendered = "\x1b[1;35m[embed: " + label
    if target != "" and target != label:
        rendered = rendered + " -> " + target
    if kind == "image":
        rendered = "\x1b[1;35m[image: " + label
        if target != "" and target != label:
            rendered = rendered + " -> " + target
    [rendered + "]\x1b[0m"]

fn _mdr_render_embed_transclusion(block: RenderBlock, index: MdWikiIndex) -> [text]:
    _mdr_render_embed_transclusion_depth_visited(block, index, 0, [])

fn _mdr_render_embed_transclusion_depth(block: RenderBlock, index: MdWikiIndex, depth: i64) -> [text]:
    _mdr_render_embed_transclusion_depth_visited(block, index, depth, [])

fn _mdr_render_embed_transclusion_depth_visited(block: RenderBlock, index: MdWikiIndex, depth: i64, visited: [text]) -> [text]:
    if block.rendered_lines.len() == 0:
        return []
    val info = _mdr_parse_embed_marker(block.rendered_lines[0])
    if info.0 != "note":
        return []
    if depth >= 4:
        return []
    # Normalize target: strip trailing #heading anchor for cycle detection
    val raw_target = info.1
    val anchor_pos = _mdr_find_single(raw_target, "#", 0)
    val target_key = if anchor_pos > 0 then raw_target.slice(0, anchor_pos) else: raw_target
    # Cycle guard: if this target is already on the visited path, stop
    if _mdr_list_contains(visited, target_key):
        return []
    val target = raw_target
    val body = md_wiki_transclusion_content(index, target)
    if body == "":
        return []
    val nested = BlockModel.from_markdown(body)
    # Pass visited with target_key appended — arrays are value types so push returns new copy
    var next_visited = visited
    next_visited.push(target_key)
    val rendered_body = _mdr_render_blocks_with_wiki_depth_visited(nested, index, depth + 1, next_visited)
    var result: [text] = []
    val label = if info.2 == "" then target else: info.2
    result.push("\x1b[1;35m[transclude: " + label + "]\x1b[0m")
    for line in rendered_body:
        result.push("\x1b[90m>\x1b[0m " + line)
    result

fn _mdr_list_contains(lst: [text], item: text) -> bool:
    var i = 0
    while i < lst.len():
        if lst[i] == item:
            return true
        i = i + 1
    false

fn _mdr_parse_embed_marker(line: text) -> tuple:
    val trimmed = _mdr_trim(line)
    if trimmed.starts_with("![["):
        val close = _mdr_find_double(trimmed, "]]", 3)
        if close > 3:
            val raw = trimmed.slice(3, close)
            val split = _mdr_find_single(raw, "|", 0)
            if split >= 0:
                return ("note", raw.slice(0, split), raw.slice(split + 1, raw.len()))
            return ("note", raw, raw)
    if trimmed.starts_with("!["):
        val close_label = _mdr_find_single(trimmed, "]", 2)
        if close_label > 1 and close_label + 1 < trimmed.len() and trimmed.char_at(close_label + 1) == "(":
            val close_target = _mdr_find_single(trimmed, ")", close_label + 2)
            if close_target > close_label:
                val label = trimmed.slice(2, close_label)
                val target = trimmed.slice(close_label + 2, close_target)
                return ("image", target, label)
    ("note", trimmed, trimmed)

fn _mdr_parse_callout_marker(line: text) -> tuple:
    val trimmed = _mdr_trim(line)
    var ctype = "note"
    var title = ""
    var folded = false
    if trimmed.starts_with("> [!"):
        val close = _mdr_find_single(trimmed, "]", 4)
        if close > 4:
            val marker = trimmed.slice(4, close)
            ctype = marker
            if marker.ends_with("+") or marker.ends_with("-"):
                folded = marker.ends_with("-")
                ctype = marker.slice(0, marker.len() - 1)
            var title_start = close + 1
            if title_start < trimmed.len() and (trimmed.char_at(title_start) == "+" or trimmed.char_at(title_start) == "-"):
                folded = trimmed.char_at(title_start) == "-"
                title_start = title_start + 1
            title = _mdr_trim(trimmed.slice(title_start, trimmed.len()))
    (ctype, title, folded)

fn _mdr_strip_blockquote_prefix(line: text) -> text:
    val trimmed = _mdr_trim(line)
    if trimmed.starts_with(">"):
        var body = trimmed.slice(1, trimmed.len())
        if body.starts_with(" "):
            body = body.slice(1, body.len())
        return body
    line

fn _mdr_is_separator_row(line: text) -> bool:
    var i = 0
    var has_dash = false
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "-":
            has_dash = true
        elif ch != "|" and ch != ":" and ch != " ":
            return false
        i = i + 1
    has_dash

fn _mdr_heading_level(line: text) -> i64:
    var level = 0
    while level < line.len() and line.char_at(level) == "#":
        level = level + 1
    level

fn _mdr_trim(line: text) -> text:
    var start = 0
    var end = line.len()
    while start < end and _mdr_is_space(line.char_at(start)):
        start = start + 1
    while end > start and _mdr_is_space(line.char_at(end - 1)):
        end = end - 1
    line.slice(start, end)

fn _mdr_is_space(ch: text) -> bool:
    ch == " " or ch == "\t" or ch == "\r" or ch == "\n"

fn _mdr_find_double(s: text, marker: text, start: i64) -> i64:
    var i = start
    while i + 1 < s.len():
        if s.char_at(i) == marker.char_at(0) and s.char_at(i + 1) == marker.char_at(1):
            return i
        i = i + 1
    -1

fn _mdr_find_single(s: text, ch: text, start: i64) -> i64:
    var i = start
    while i < s.len():
        if s.char_at(i) == ch:
            return i
        i = i + 1
    -1

fn _mdr_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    # Only push trailing segment when there is actual content after last newline.
    # Prevents empty string input from emitting a spurious empty line.
    if start < content.len():
        lines.push(content.slice(start, content.len()))
    lines
