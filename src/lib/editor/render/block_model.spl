# Editor Block Model — parsed Markdown document as a list of render blocks.
#
# Provides: BlockModel, RenderBlock.

# A single rendered block in the document.
# kind: "heading" | "paragraph" | "code" | "list" | "table" | "callout" |
#       "embed" | "sdn_graph" | "md_css"
struct RenderBlock:
    kind: text
    content: text
    rendered_lines: [text]
    level: i64

# A parsed document represented as an ordered sequence of RenderBlocks.
class BlockModel:
    blocks: [RenderBlock]
    active_index: i64

impl BlockModel:
    # Parse Markdown source text into a BlockModel.
    static fn from_markdown(source: text) -> BlockModel:
        var blocks: [RenderBlock] = []
        val lines = source.split("\n")
        var i = 0
        var para_lines: [text] = []
        while i < lines.len():
            val line = lines[i]
            if line.starts_with("# "):
                if para_lines.len() > 0:
                    blocks.push(RenderBlock(kind: "paragraph", content: para_lines.join("\n"), rendered_lines: para_lines, level: 0))
                    para_lines = []
                blocks.push(RenderBlock(kind: "heading", content: line.slice(2, line.len()), rendered_lines: [line], level: 1))
            else if line.starts_with("## "):
                if para_lines.len() > 0:
                    blocks.push(RenderBlock(kind: "paragraph", content: para_lines.join("\n"), rendered_lines: para_lines, level: 0))
                    para_lines = []
                blocks.push(RenderBlock(kind: "heading", content: line.slice(3, line.len()), rendered_lines: [line], level: 2))
            else if line.starts_with("```"):
                if para_lines.len() > 0:
                    blocks.push(RenderBlock(kind: "paragraph", content: para_lines.join("\n"), rendered_lines: para_lines, level: 0))
                    para_lines = []
                var code_lines: [text] = []
                i = i + 1
                while i < lines.len() and not lines[i].starts_with("```"):
                    code_lines.push(lines[i])
                    i = i + 1
                val code_content = code_lines.join("\n")
                blocks.push(RenderBlock(kind: "code", content: code_content, rendered_lines: code_lines, level: 0))
            else if line.len() == 0:
                if para_lines.len() > 0:
                    blocks.push(RenderBlock(kind: "paragraph", content: para_lines.join("\n"), rendered_lines: para_lines, level: 0))
                    para_lines = []
            else:
                para_lines.push(line)
            i = i + 1
        if para_lines.len() > 0:
            blocks.push(RenderBlock(kind: "paragraph", content: para_lines.join("\n"), rendered_lines: para_lines, level: 0))
        BlockModel(blocks: blocks, active_index: -1)

    fn block_count(self) -> i64:
        self.blocks.len()

    fn block_at(self, idx: i64) -> RenderBlock:
        self.blocks[idx]

    fn is_active(self, idx: i64) -> bool:
        self.active_index == idx

    fn set_active(self, idx: i64) -> BlockModel:
        BlockModel(blocks: self.blocks, active_index: idx)
