# Multi-buffer manager for the text editor.

struct EditorDocument:
    id: i64
    content: text
    dirty: bool

class MultiBufferManager:
    buffers: [EditorDocument]
    next_id: i64

fn multi_buffer_create() -> MultiBufferManager:
    MultiBufferManager(buffers: [], next_id: 1)

fn multi_buffer_open_empty(mgr: MultiBufferManager) -> i64:
    val id = mgr.next_id
    mgr.buffers.push(EditorDocument(id: id, content: "", dirty: false))
    mgr.next_id = mgr.next_id + 1
    id

fn multi_buffer_get(mgr: MultiBufferManager, id: i64) -> EditorDocument:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].id == id:
            return mgr.buffers[i]
        i = i + 1
    nil

fn multi_buffer_dirty_count(mgr: MultiBufferManager) -> i64:
    var count = 0
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].dirty:
            count = count + 1
        i = i + 1
    count

fn multi_buffer_close(mgr: MultiBufferManager, id: i64):
    var new_buffers: [EditorDocument] = []
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].id != id:
            new_buffers.push(mgr.buffers[i])
        i = i + 1
    mgr.buffers = new_buffers
