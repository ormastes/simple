# Editor File Watcher
#
# Poll-based file change detection. Portable across Desktop and SimpleOS.
# Detects external modifications by tracking file content hashes.

extern fn rt_file_read_text(path: text) -> text

struct WatchedFile:
    path: text
    last_hash: i64
    last_length: i64

class FileWatcher:
    watched: [WatchedFile]
    poll_interval_ms: i64

impl FileWatcher:

    static fn new() -> FileWatcher:
        FileWatcher(watched: [], poll_interval_ms: 2000)

    me watch(path: text):
        var i = 0
        while i < self.watched.len():
            if self.watched[i].path == path:
                return
            i = i + 1
        val content = rt_file_read_text(path) ?? ""
        self.watched.push(WatchedFile(
            path: path,
            last_hash: _fw_hash(content),
            last_length: content.len()
        ))

    me unwatch(path: text):
        var new_list: [WatchedFile] = []
        for w in self.watched:
            if w.path != path:
                new_list.push(w)
        self.watched = new_list

    me check_changes() -> [text]:
        var changed: [text] = []
        var i = 0
        while i < self.watched.len():
            val w = self.watched[i]
            val content = rt_file_read_text(w.path) ?? ""
            val new_hash = _fw_hash(content)
            val new_length = content.len()
            if new_hash != w.last_hash or new_length != w.last_length:
                changed.push(w.path)
                var updated = self.watched[i]
                updated.last_hash = new_hash
                updated.last_length = new_length
                self.watched[i] = updated
            i = i + 1
        changed

    fn watched_count() -> i64:
        self.watched.len()


fn _fw_hash(content: text) -> i64:
    var hash = 5381
    var i = 0
    while i < content.len():
        val code = content.char_code_at(i)
        hash = hash * 33 + code
        i = i + 1
    hash
