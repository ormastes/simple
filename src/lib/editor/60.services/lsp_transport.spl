# LSP Transport
#
# Content-Length framed JSON-RPC transport for LSP communication.
# StdioTransport is a stub awaiting rt_process_spawn_piped runtime support.
# WebSocket transport can be wired via std.nogc_sync_mut.websocket.

extern fn rt_process_spawn_piped(cmd: text, args: [text]) -> i64
extern fn rt_process_write_stdin(pid: i64, data: text) -> bool
extern fn rt_process_read_stdout(pid: i64) -> text
extern fn rt_process_is_alive(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool

struct LspTransportConfig:
    server_command: text
    server_args: [text]
    root_uri: text

enum LspTransportKind:
    Stdio
    WebSocket

struct LspMessage:
    json: text
    is_request: bool
    id: i64

struct StdioTransport:
    config: LspTransportConfig
    running: bool
    send_buffer: [text]
    recv_buffer: [text]

fn stdio_transport_new(config: LspTransportConfig) -> StdioTransport:
    StdioTransport(
        config: config,
        running: false,
        send_buffer: [],
        recv_buffer: []
    )

fn stdio_transport_start(transport: StdioTransport) -> bool:
    transport.running = true
    true

fn stdio_transport_stop(transport: StdioTransport):
    transport.running = false

fn stdio_transport_send(transport: StdioTransport, json: text) -> bool:
    if not transport.running:
        return false
    val framed = lsp_frame_message(json)
    transport.send_buffer.push(framed)
    true

fn stdio_transport_receive(transport: StdioTransport) -> text:
    if transport.recv_buffer.len() > 0:
        val msg = transport.recv_buffer[0]
        var new_buf: [text] = []
        var i = 1
        while i < transport.recv_buffer.len():
            new_buf.push(transport.recv_buffer[i])
            i = i + 1
        transport.recv_buffer = new_buf
        return msg
    ""

fn stdio_transport_inject_response(transport: StdioTransport, json: text):
    transport.recv_buffer.push(json)

fn stdio_transport_pending_count(transport: StdioTransport) -> i64:
    transport.send_buffer.len()

fn lsp_frame_message(json: text) -> text:
    val content_length = str(json.len())
    "Content-Length: " + content_length + "\r\n\r\n" + json

fn lsp_parse_frame(buf: text) -> (text, i64):
    val header_end = _lsp_find_header_end(buf)
    if header_end < 0:
        return ("", 0)
    val header = buf.slice(0, header_end)
    val content_start = header_end + 4
    val content_length = _lsp_parse_content_length(header)
    if content_length <= 0:
        return ("", 0)
    val total = content_start + content_length
    if buf.len() < total:
        return ("", 0)
    val json = buf.slice(content_start, total)
    (json, total)

fn _lsp_find_header_end(buf: text) -> i64:
    var i = 0
    while i < buf.len() - 3:
        if buf.char_at(i) == "\r" and buf.char_at(i + 1) == "\n" and buf.char_at(i + 2) == "\r" and buf.char_at(i + 3) == "\n":
            return i
        i = i + 1
    -1

fn _lsp_parse_content_length(header: text) -> i64:
    var i = 0
    while i < header.len():
        if header.slice(i, header.len()).starts_with("Content-Length:"):
            var j = i + 15
            while j < header.len() and header.char_at(j) == " ":
                j = j + 1
            var num_str = ""
            while j < header.len() and header.char_at(j) != "\r" and header.char_at(j) != "\n":
                num_str = num_str + header.char_at(j)
                j = j + 1
            return num_str.trim().to_i64() ?? 0
        i = i + 1
    0

fn lsp_build_initialize_params(root_uri: text, client_name: text) -> text:
    "{\"processId\": null, \"clientInfo\": {\"name\": \"" + client_name + "\"}, \"rootUri\": \"" + root_uri + "\", \"capabilities\": {\"textDocument\": {\"completion\": {\"completionItem\": {\"snippetSupport\": false}}, \"hover\": {\"contentFormat\": [\"plaintext\"]}, \"publishDiagnostics\": {\"relatedInformation\": true}}}}"

fn lsp_build_did_open_params(uri: text, language_id: text, version: i64, content: text) -> text:
    val escaped = _lsp_transport_escape(content)
    val ver = str(version)
    "{\"textDocument\": {\"uri\": \"" + uri + "\", \"languageId\": \"" + language_id + "\", \"version\": " + ver + ", \"text\": \"" + escaped + "\"}}"

fn lsp_build_did_change_params(uri: text, version: i64, content: text) -> text:
    val escaped = _lsp_transport_escape(content)
    val ver = str(version)
    "{\"textDocument\": {\"uri\": \"" + uri + "\", \"version\": " + ver + "}, \"contentChanges\": [{\"text\": \"" + escaped + "\"}]}"

fn lsp_build_position_params(uri: text, line: i64, col: i64) -> text:
    val l = str(line)
    val c = str(col)
    "{\"textDocument\": {\"uri\": \"" + uri + "\"}, \"position\": {\"line\": " + l + ", \"character\": " + c + "}}"

fn lsp_path_to_uri(path: text) -> text:
    "file://" + path

fn lsp_uri_to_path(uri: text) -> text:
    if uri.starts_with("file://"):
        return uri.slice(7, uri.len())
    uri

fn lsp_parse_response_id(json: text) -> i64:
    val id_start = _lsp_find_field(json, "\"id\"")
    if id_start < 0:
        return -1
    _lsp_extract_number(json, id_start)

fn lsp_parse_response_result(json: text) -> text:
    val start = _lsp_find_field(json, "\"result\"")
    if start < 0:
        return ""
    _lsp_extract_value(json, start)

fn lsp_parse_response_error(json: text) -> text:
    val start = _lsp_find_field(json, "\"error\"")
    if start < 0:
        return ""
    _lsp_extract_value(json, start)

fn lsp_parse_notification_params(json: text) -> text:
    val start = _lsp_find_field(json, "\"params\"")
    if start < 0:
        return ""
    _lsp_extract_value(json, start)

fn lsp_parse_notification_method(json: text) -> text:
    val start = _lsp_find_field(json, "\"method\"")
    if start < 0:
        return ""
    _lsp_extract_string(json, start)

fn lsp_is_response(json: text) -> bool:
    json.contains("\"result\"") or json.contains("\"error\"")

fn lsp_is_notification(json: text) -> bool:
    json.contains("\"method\"") and not json.contains("\"id\"")

fn _lsp_find_field(json: text, field: text) -> i64:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            return j
        i = i + 1
    -1

fn _lsp_extract_number(json: text, start: i64) -> i64:
    var num_str = ""
    var i = start
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
            num_str = num_str + ch
        else:
            break
        i = i + 1
    num_str.to_i64() ?? -1

fn _lsp_extract_string(json: text, start: i64) -> text:
    if start >= json.len() or json.char_at(start) != "\"":
        return ""
    var result = ""
    var i = start + 1
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "\"":
            return result
        if ch == "\\":
            i = i + 1
            if i < json.len():
                result = result + json.char_at(i)
        else:
            result = result + ch
        i = i + 1
    result

fn _lsp_extract_value(json: text, start: i64) -> text:
    if start >= json.len():
        return ""
    val ch = json.char_at(start)
    if ch == "{" or ch == "[":
        return _lsp_extract_balanced(json, start, ch)
    if ch == "\"":
        return "\"" + _lsp_extract_string(json, start) + "\""
    var result = ""
    var i = start
    while i < json.len():
        val c = json.char_at(i)
        if c == "," or c == "}" or c == "]":
            return result.trim()
        result = result + c
        i = i + 1
    result.trim()

fn _lsp_extract_balanced(json: text, start: i64, open_ch: text) -> text:
    val close_ch = if open_ch == "{" then "}" else: "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return json.slice(start, i + 1)
        i = i + 1
    json.slice(start, json.len())

class StdioProcessTransport:
    pid: i64
    server_cmd: text
    server_args: [text]
    buffer: text

impl StdioProcessTransport:

    static fn new(cmd: text, args: [text]) -> StdioProcessTransport:
        val pid = rt_process_spawn_piped(cmd, args)
        StdioProcessTransport(
            pid: pid,
            server_cmd: cmd,
            server_args: args,
            buffer: ""
        )

    me send(message: text) -> bool:
        if not rt_process_is_alive(self.pid):
            return false
        val framed = lsp_frame_message(message)
        rt_process_write_stdin(self.pid, framed)

    me receive() -> text:
        val chunk = rt_process_read_stdout(self.pid)
        self.buffer = self.buffer + chunk
        val result = lsp_parse_frame(self.buffer)
        val json = result.0
        val consumed = result.1
        if json == "":
            return ""
        self.buffer = self.buffer.slice(consumed, self.buffer.len())
        json

    fn is_connected() -> bool:
        rt_process_is_alive(self.pid)

    me close():
        rt_process_kill(self.pid)

fn _lsp_transport_escape(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        elif ch == "\n":
            result = result + "\\n"
        elif ch == "\r":
            result = result + "\\r"
        elif ch == "\t":
            result = result + "\\t"
        else:
            result = result + ch
        i = i + 1
    result
