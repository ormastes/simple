# Command Palette Service
#
# Fuzzy-matching command palette for the editor.
# Provides filtering, scoring, and selection over a list of palette entries.

struct PaletteEntry:
    name: text
    description: text
    command_name: text
    command_payload: text

struct PaletteState:
    all_entries: [PaletteEntry]
    filtered: [PaletteEntry]
    query: text
    selected_index: i64
    visible: bool

fn palette_new(entries: [PaletteEntry]) -> PaletteState:
    PaletteState(
        all_entries: entries,
        filtered: entries,
        query: "",
        selected_index: 0,
        visible: false
    )

fn palette_show(state: PaletteState) -> PaletteState:
    PaletteState(
        all_entries: state.all_entries,
        filtered: state.all_entries,
        query: "",
        selected_index: 0,
        visible: true
    )

fn palette_hide(state: PaletteState) -> PaletteState:
    PaletteState(
        all_entries: state.all_entries,
        filtered: state.filtered,
        query: state.query,
        selected_index: state.selected_index,
        visible: false
    )

fn palette_update_query(state: PaletteState, query: text) -> PaletteState:
    var result: [PaletteEntry] = []
    var scored: [[i64, i64]] = []
    var i = 0
    while i < state.all_entries.len():
        val entry = state.all_entries[i]
        if fuzzy_match(query, entry.name):
            val sc = fuzzy_score(query, entry.name)
            result.push(entry)
            scored.push([sc, result.len() - 1])
        i = i + 1
    # Sort by score (simple insertion sort -- palette lists are small)
    var sorted_entries: [PaletteEntry] = []
    var used: [bool] = []
    var k = 0
    while k < scored.len():
        used.push(false)
        k = k + 1
    var s = 0
    while s < scored.len():
        var best_idx = 0 - 1
        var best_sc = 99999
        var j = 0
        while j < scored.len():
            if not used[j]:
                val pair = scored[j]
                if pair[0] < best_sc:
                    best_sc = pair[0]
                    best_idx = j
            j = j + 1
        if best_idx >= 0:
            used[best_idx] = true
            val pair2 = scored[best_idx]
            sorted_entries.push(result[pair2[1]])
        s = s + 1
    PaletteState(
        all_entries: state.all_entries,
        filtered: sorted_entries,
        query: query,
        selected_index: 0,
        visible: state.visible
    )

fn palette_select_next(state: PaletteState) -> PaletteState:
    var idx = state.selected_index + 1
    val max_idx = state.filtered.len() - 1
    if max_idx < 0:
        idx = 0
    else:
        if idx > max_idx:
            idx = max_idx
    PaletteState(
        all_entries: state.all_entries,
        filtered: state.filtered,
        query: state.query,
        selected_index: idx,
        visible: state.visible
    )

fn palette_select_prev(state: PaletteState) -> PaletteState:
    var idx = state.selected_index - 1
    if idx < 0:
        idx = 0
    PaletteState(
        all_entries: state.all_entries,
        filtered: state.filtered,
        query: state.query,
        selected_index: idx,
        visible: state.visible
    )

fn palette_selected(state: PaletteState) -> PaletteEntry:
    if state.filtered.len() == 0:
        return PaletteEntry(name: "", description: "", command_name: "", command_payload: "")
    if state.selected_index >= 0 and state.selected_index < state.filtered.len():
        return state.filtered[state.selected_index]
    PaletteEntry(name: "", description: "", command_name: "", command_payload: "")

fn fuzzy_match(query: text, candidate: text) -> bool:
    if query.len() == 0:
        return true
    val q = query.lower()
    val c = candidate.lower()
    var qi = 0
    var ci = 0
    while qi < q.len() and ci < c.len():
        val qch = q.char_at(qi)
        val cch = c.char_at(ci)
        if qch == cch:
            qi = qi + 1
        ci = ci + 1
    qi >= q.len()

fn fuzzy_score(query: text, candidate: text) -> i64:
    if query.len() == 0:
        return 0
    val q = query.lower()
    val c = candidate.lower()
    var qi = 0
    var ci = 0
    var score = 0
    var last_match_pos = 0 - 1
    while qi < q.len() and ci < c.len():
        val qch = q.char_at(qi)
        val cch = c.char_at(ci)
        if qch == cch:
            if last_match_pos >= 0:
                val gap = ci - last_match_pos - 1
                score = score + gap
            last_match_pos = ci
            qi = qi + 1
        ci = ci + 1
    if qi < q.len():
        return 9999
    score
