# Editor Diagnostics
#
# Diagnostic collection and display for the problems panel.

use std.editor.services.lsp_transport.*

struct EditorDiagnostic:
    path: text
    line: i64
    col: i64
    end_line: i64
    end_col: i64
    severity: text
    message: text
    source: text

struct EditorCodeAction:
    title: text
    kind: text
    edit_json: text
    command: text

struct DiagnosticPublishVersion:
    path: text
    version: i64

class DiagnosticStore:
    diagnostics: [EditorDiagnostic]
    publish_versions: [DiagnosticPublishVersion]

impl DiagnosticStore:

    static fn new() -> DiagnosticStore:
        DiagnosticStore(diagnostics: [], publish_versions: [])

    me set_diagnostics(path: text, diags: [EditorDiagnostic]):
        var new_list: [EditorDiagnostic] = []
        for d in self.diagnostics:
            if d.path != path:
                new_list.push(d)
        for d in diags:
            new_list.push(d)
        self.diagnostics = new_list

    me clear_diagnostics(path: text):
        var new_list: [EditorDiagnostic] = []
        for d in self.diagnostics:
            if d.path != path:
                new_list.push(d)
        self.diagnostics = new_list

    fn diagnostics_for(path: text) -> [EditorDiagnostic]:
        var result: [EditorDiagnostic] = []
        for d in self.diagnostics:
            if d.path == path:
                result.push(d)
        result

    fn error_count() -> i64:
        var count = 0
        for d in self.diagnostics:
            if d.severity == "error":
                count = count + 1
        count

    fn warning_count() -> i64:
        var count = 0
        for d in self.diagnostics:
            if d.severity == "warning":
                count = count + 1
        count

    fn total_count() -> i64:
        self.diagnostics.len()

    fn all_paths() -> [text]:
        var paths: [text] = []
        for d in self.diagnostics:
            var found = false
            for p in paths:
                if p == d.path:
                    found = true
                    break
            if not found:
                paths.push(d.path)
        paths

    me replace_from_publish(params_json: text) -> text:
        val path = diagnostics_publish_path(params_json)
        val version = diagnostics_publish_version(params_json)
        if not _diag_publish_should_apply(self, path, version):
            return path
        val diags = _diag_parse_diagnostics(params_json, path)
        var new_list: [EditorDiagnostic] = []
        for d in self.diagnostics:
            if d.path != path:
                new_list.push(d)
        for d in diags:
            new_list.push(d)
        self.diagnostics = new_list
        self.publish_versions = _diag_publish_versions_with(self.publish_versions, path, version)
        path

fn diagnostic_severity_icon(severity: text) -> text:
    if severity == "error":
        return "E"
    if severity == "warning":
        return "W"
    if severity == "info":
        return "I"
    "H"

fn diagnostics_handle_publish(store: DiagnosticStore, params_json: text):
    store.replace_from_publish(params_json)

fn diagnostics_handle_publish_path(store: DiagnosticStore, params_json: text) -> text:
    store.replace_from_publish(params_json)

fn diagnostics_store_with_publish(store: DiagnosticStore, params_json: text) -> DiagnosticStore:
    val path = diagnostics_publish_path(params_json)
    val version = diagnostics_publish_version(params_json)
    if not _diag_publish_should_apply(store, path, version):
        return store
    val diags = _diag_parse_diagnostics(params_json, path)
    var new_list: [EditorDiagnostic] = []
    for d in store.diagnostics:
        if d.path != path:
            new_list.push(d)
    for d in diags:
        new_list.push(d)
    DiagnosticStore(diagnostics: new_list, publish_versions: _diag_publish_versions_with(store.publish_versions, path, version))

fn diagnostics_publish_path(params_json: text) -> text:
    val uri = _diag_extract_uri(params_json)
    lsp_uri_to_path(uri)

fn diagnostics_publish_version(params_json: text) -> i64:
    _diag_extract_optional_int(params_json, "\"version\"", -1)

fn diagnostics_handle_code_actions(store: DiagnosticStore, path: text, result_json: text) -> [EditorCodeAction]:
    code_actions_handle_response(result_json)

fn code_actions_handle_response(result_json: text) -> [EditorCodeAction]:
    var actions: [EditorCodeAction] = []
    val arr_start = _diag_find_array_start(result_json)
    if arr_start < 0:
        return actions
    val entries = _diag_split_array_entries(result_json, arr_start)
    for entry in entries:
        actions.push(EditorCodeAction(
            title: _diag_extract_string(entry, "\"title\""),
            kind: _diag_extract_string(entry, "\"kind\""),
            edit_json: _diag_extract_value_for_field(entry, "\"edit\""),
            command: _diag_extract_value_for_field(entry, "\"command\"")
        ))
    actions

fn _diag_extract_uri(json: text) -> text:
    val marker = "\"uri\":"
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(marker):
            var j = i + marker.len()
            while j < json.len() and json.char_at(j) == " ":
                j = j + 1
            if j < json.len() and json.char_at(j) == "\"":
                var result = ""
                j = j + 1
                while j < json.len() and json.char_at(j) != "\"":
                    result = result + json.char_at(j)
                    j = j + 1
                return result
        i = i + 1
    ""

fn _diag_parse_diagnostics(json: text, path: text) -> [EditorDiagnostic]:
    var diags: [EditorDiagnostic] = []
    val diags_start = _diag_find_diagnostics_array(json)
    if diags_start < 0:
        return diags
    var entries = _diag_split_array_entries(json, diags_start)
    for entry in entries:
        val diag = _diag_parse_single(entry, path)
        diags.push(diag)
    diags

fn _diag_find_diagnostics_array(json: text) -> i64:
    val marker = "\"diagnostics\":"
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(marker):
            var j = i + marker.len()
            while j < json.len() and json.char_at(j) == " ":
                j = j + 1
            if j < json.len() and json.char_at(j) == "[":
                return j
        i = i + 1
    -1

fn _diag_find_array_start(json: text) -> i64:
    var i = 0
    while i < json.len():
        if json.char_at(i) == "[":
            return i
        i = i + 1
    -1

fn _diag_split_array_entries(json: text, arr_start: i64) -> [text]:
    var entries: [text] = []
    val arr_end = _diag_find_array_end(json, arr_start)
    if arr_end <= arr_start:
        return entries
    var i = arr_start + 1
    var in_str = false
    while i < arr_end:
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == "{":
                val entry_end = _diag_extract_balanced_end(json, i, "{")
                if entry_end > i:
                    entries.push(json.slice(i, entry_end + 1))
                    i = entry_end
        i = i + 1
    entries

fn _diag_find_array_end(json: text, arr_start: i64) -> i64:
    _diag_extract_balanced_end(json, arr_start, "[")

fn _diag_extract_balanced_end(json: text, start: i64, open_ch: text) -> i64:
    val close_ch = if open_ch == "{" then "}" else "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _diag_parse_single(entry: text, path: text) -> EditorDiagnostic:
    val line = _diag_extract_int(entry, "\"line\"")
    val col = _diag_extract_int(entry, "\"character\"")
    val sev_num = _diag_extract_int(entry, "\"severity\"")
    val severity = _diag_severity_from_lsp(sev_num)
    val message = _diag_extract_string(entry, "\"message\"")
    val source = _diag_extract_string(entry, "\"source\"")
    EditorDiagnostic(
        path: path,
        line: line,
        col: col,
        end_line: line,
        end_col: col,
        severity: severity,
        message: message,
        source: source
    )

fn _diag_severity_from_lsp(code: i64) -> text:
    if code == 1:
        return "error"
    if code == 2:
        return "warning"
    if code == 3:
        return "info"
    "hint"

fn _diag_extract_int(json: text, field: text) -> i64:
    _diag_extract_optional_int(json, field, 0)

fn _diag_extract_optional_int(json: text, field: text, missing: i64) -> i64:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            var num = ""
            while j < json.len():
                val ch = json.char_at(j)
                if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
                    num = num + ch
                else:
                    break
                j = j + 1
            return num.to_i64() ?? missing
        i = i + 1
    missing

fn _diag_publish_should_apply(store: DiagnosticStore, path: text, version: i64) -> bool:
    if version < 0:
        return true
    for known in store.publish_versions:
        if known.path == path:
            return version >= known.version
    true

fn _diag_publish_versions_with(versions: [DiagnosticPublishVersion], path: text, version: i64) -> [DiagnosticPublishVersion]:
    if version < 0:
        return versions
    var next: [DiagnosticPublishVersion] = []
    var replaced = false
    for known in versions:
        if known.path == path:
            next.push(DiagnosticPublishVersion(path: path, version: version))
            replaced = true
        else:
            next.push(known)
    if not replaced:
        next.push(DiagnosticPublishVersion(path: path, version: version))
    next

fn _diag_extract_string(json: text, field: text) -> text:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            if j < json.len() and json.char_at(j) == "\"":
                var result = ""
                j = j + 1
                while j < json.len() and json.char_at(j) != "\"":
                    if json.char_at(j) == "\\":
                        j = j + 1
                        if j < json.len():
                            result = result + json.char_at(j)
                    else:
                        result = result + json.char_at(j)
                    j = j + 1
                return result
        i = i + 1
    ""

fn _diag_extract_value_for_field(json: text, field: text) -> text:
    var i = 0
    while i < json.len():
        if json.slice(i, json.len()).starts_with(field):
            var j = i + field.len()
            while j < json.len() and (json.char_at(j) == " " or json.char_at(j) == ":"):
                j = j + 1
            if j >= json.len():
                return ""
            val ch = json.char_at(j)
            if ch == "{" or ch == "[":
                return _diag_extract_balanced(json, j, ch)
            if ch == "\"":
                return "\"" + _diag_extract_string(json, field) + "\""
            var result = ""
            while j < json.len():
                val c = json.char_at(j)
                if c == "," or c == "}":
                    return result.trim()
                result = result + c
                j = j + 1
            return result.trim()
        i = i + 1
    ""

fn _diag_extract_balanced(json: text, start: i64, open_ch: text) -> text:
    val close_ch = if open_ch == "{" then "}" else "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return json.slice(start, i + 1)
        i = i + 1
    json.slice(start, json.len())
