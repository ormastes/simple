# LSP Client
#
# Language Server Protocol client for editor integration.
# Communicates via JSON-RPC 2.0 over Content-Length framed stdio transport.
# Uses lsp_transport.spl for framing, message building, and response parsing.

struct LspClientConfig:
    server_command: text
    root_path: text
    language_id: text

struct LspRequest:
    id: i64
    method: text
    params_json: text

struct LspResponse:
    id: i64
    ok: bool
    result_json: text
    error_text: text

struct LspNotification:
    method: text
    params_json: text

class LspClient:
    config: LspClientConfig
    transport: StdioTransport
    next_id: i64
    initialized: bool
    capabilities_json: text
    pending_requests: [LspPendingRequest]

impl LspClient:

    static fn new(config: LspClientConfig) -> LspClient:
        val transport_config = LspTransportConfig(
            server_command: config.server_command,
            server_args: [],
            root_uri: lsp_path_to_uri(config.root_path)
        )
        LspClient(
            config: config,
            transport: stdio_transport_new(transport_config),
            next_id: 1,
            initialized: false,
            capabilities_json: "",
            pending_requests: []
        )

    me start() -> bool:
        stdio_transport_start(self.transport)

    me stop():
        stdio_transport_stop(self.transport)

    me initialize() -> LspResponse:
        val params = lsp_build_initialize_params(
            lsp_path_to_uri(self.config.root_path),
            "simple-editor"
        )
        val resp = self._send_request("initialize", params)
        if resp.ok:
            self.initialized = true
            self.capabilities_json = resp.result_json
        resp

    me initialized_notification():
        self._send_notification("initialized", "{}")

    me did_open(path: text, content: text, language_id: text):
        val params = lsp_build_did_open_params(
            lsp_path_to_uri(path), language_id, 1, content
        )
        self._send_notification("textDocument/didOpen", params)

    me did_change(path: text, content: text, version: i64):
        val params = lsp_build_did_change_params(
            lsp_path_to_uri(path), version, content
        )
        self._send_notification("textDocument/didChange", params)

    me completion(path: text, line: i64, col: i64) -> LspResponse:
        val params = lsp_build_position_params(lsp_path_to_uri(path), line, col)
        self._send_request("textDocument/completion", params)

    me definition(path: text, line: i64, col: i64) -> LspResponse:
        val params = lsp_build_position_params(lsp_path_to_uri(path), line, col)
        self._send_request("textDocument/definition", params)

    me hover(path: text, line: i64, col: i64) -> LspResponse:
        val params = lsp_build_position_params(lsp_path_to_uri(path), line, col)
        self._send_request("textDocument/hover", params)

    me shutdown():
        self._send_request("shutdown", "{}")
        self.initialized = false

    me exit():
        self._send_notification("exit", "")
        self.stop()

    me poll_notifications() -> [LspNotification]:
        var notifications: [LspNotification] = []
        var json = stdio_transport_receive(self.transport)
        while json != "":
            if lsp_is_notification(json):
                val method = lsp_parse_notification_method(json)
                val params = lsp_parse_notification_params(json)
                notifications.push(LspNotification(method: method, params_json: params))
            elif lsp_is_response(json):
                self._handle_response(json)
            json = stdio_transport_receive(self.transport)
        notifications

    me _send_request(method: text, params_json: text) -> LspResponse:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val id_str = str(id)
        val json = lsp_jsonrpc_request(id_str, method, params_json)
        stdio_transport_send(self.transport, json)
        self.pending_requests.push(LspPendingRequest(id: id, method: method))
        LspResponse(id: id, ok: true, result_json: "", error_text: "")

    me _send_notification(method: text, params_json: text):
        val json = lsp_jsonrpc_notification(method, params_json)
        stdio_transport_send(self.transport, json)

    me _handle_response(json: text):
        val id = lsp_parse_response_id(json)
        val error = lsp_parse_response_error(json)
        var new_pending: [LspPendingRequest] = []
        for p in self.pending_requests:
            if p.id != id:
                new_pending.push(p)
        self.pending_requests = new_pending

    me _make_request(method: text, params_json: text) -> LspRequest:
        val id = self.next_id
        self.next_id = self.next_id + 1
        LspRequest(id: id, method: method, params_json: params_json)

    me _notify(method: text, params_json: text):
        val _ = LspNotification(method: method, params_json: params_json)


struct LspPendingRequest:
    id: i64
    method: text

fn lsp_jsonrpc_request(id: text, method: text, params: text) -> text:
    "{\"jsonrpc\": \"2.0\", \"id\": " + id + ", \"method\": \"" + method + "\", \"params\": " + params + "}"

fn lsp_jsonrpc_notification(method: text, params: text) -> text:
    if params == "":
        return "{\"jsonrpc\": \"2.0\", \"method\": \"" + method + "\"}"
    "{\"jsonrpc\": \"2.0\", \"method\": \"" + method + "\", \"params\": " + params + "}"

fn lsp_response_from_json(json: text) -> LspResponse:
    val id = lsp_parse_response_id(json)
    val error = lsp_parse_response_error(json)
    if error != "":
        return LspResponse(id: id, ok: false, result_json: "", error_text: error)
    val result = lsp_parse_response_result(json)
    LspResponse(id: id, ok: true, result_json: result, error_text: "")

fn _lsp_escape(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        elif ch == "\n":
            result = result + "\\n"
        else:
            result = result + ch
        i = i + 1
    result
