# Markdown LSP Configuration
#
# Wires the md_lsp server into the editor's LspClient.
# Auto-starts on .md file open, manages lifecycle.

struct MdLspState:
    client: LspClient
    running: bool
    version: i64

fn md_lsp_config(root_path: text) -> LspClientConfig:
    LspClientConfig(
        server_command: "bin/simple run src/app/md_lsp/md_lsp_main.spl",
        root_path: root_path,
        language_id: "markdown"
    )

fn md_lsp_state_new(root_path: text) -> MdLspState:
    val config = md_lsp_config(root_path)
    val client = LspClient.new(config)
    MdLspState(client: client, running: false, version: 0)

fn md_lsp_is_markdown_file(path: text) -> bool:
    if path.len() < 3:
        return false
    val ext = path.slice(path.len() - 3, path.len())
    if ext == ".md":
        return true
    if path.len() < 9:
        return false
    val ext_long = path.slice(path.len() - 9, path.len())
    ext_long == ".markdown"

fn md_lsp_start(state: MdLspState) -> MdLspState:
    if state.running:
        return state
    var client = state.client
    val started = client.start()
    if not started:
        return MdLspState(client: client, running: false, version: 0)
    val resp = client.initialize()
    if resp.ok:
        client.initialized_notification()
    MdLspState(client: client, running: true, version: 0)

fn md_lsp_open_file(state: MdLspState, path: text, content: text) -> MdLspState:
    if not state.running:
        return state
    var client = state.client
    client.did_open(path, content, "markdown")
    MdLspState(client: client, running: state.running, version: 1)

fn md_lsp_change_file(state: MdLspState, path: text, content: text) -> MdLspState:
    if not state.running:
        return state
    var client = state.client
    val new_version = state.version + 1
    client.did_change(path, content, new_version)
    MdLspState(client: client, running: state.running, version: new_version)

fn md_lsp_completion(state: MdLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.completion(path, line, col)

fn md_lsp_hover(state: MdLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.hover(path, line, col)

fn md_lsp_definition(state: MdLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.definition(path, line, col)

fn md_lsp_code_action(state: MdLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.code_action(path, line, col)

fn md_lsp_poll(state: MdLspState) -> [LspNotification]:
    if not state.running:
        var empty: [LspNotification] = []
        return empty
    var client = state.client
    client.poll_notifications()

fn md_lsp_stop(state: MdLspState) -> MdLspState:
    if not state.running:
        return state
    var client = state.client
    client.shutdown()
    client.exit()
    MdLspState(client: client, running: false, version: 0)

fn md_lsp_ensure_started(state: MdLspState, path: text, content: text) -> MdLspState:
    if not md_lsp_is_markdown_file(path):
        return state
    if state.running:
        return state
    var started = md_lsp_start(state)
    if started.running:
        started = md_lsp_open_file(started, path, content)
    started
