# Simple LSP Configuration
#
# Wires the native Simple language server command into the editor LSP client.

struct SimpleLspState:
    client: LspClient
    running: bool
    version: i64

fn simple_lsp_config(root_path: text) -> LspClientConfig:
    LspClientConfig(
        server_command: "bin/simple lsp",
        root_path: root_path,
        language_id: "simple"
    )

fn simple_lsp_state_new(root_path: text) -> SimpleLspState:
    val config = simple_lsp_config(root_path)
    val client = LspClient.new(config)
    SimpleLspState(client: client, running: false, version: 0)

fn simple_lsp_is_simple_file(path: text) -> bool:
    path.ends_with(".spl") or path.ends_with(".shs")

fn simple_lsp_start(state: SimpleLspState) -> SimpleLspState:
    if state.running:
        return state
    var client = state.client
    val started = client.start()
    if not started:
        return SimpleLspState(client: client, running: false, version: 0)
    val resp = client.initialize()
    if resp.ok:
        client.initialized_notification()
    SimpleLspState(client: client, running: true, version: 0)

fn simple_lsp_open_file(state: SimpleLspState, path: text, content: text) -> SimpleLspState:
    if not state.running:
        return state
    var client = state.client
    client.did_open(path, content, "simple")
    SimpleLspState(client: client, running: state.running, version: 1)

fn simple_lsp_change_file(state: SimpleLspState, path: text, content: text) -> SimpleLspState:
    if not state.running:
        return state
    var client = state.client
    val new_version = state.version + 1
    client.did_change(path, content, new_version)
    SimpleLspState(client: client, running: state.running, version: new_version)

fn simple_lsp_completion(state: SimpleLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.completion(path, line, col)

fn simple_lsp_hover(state: SimpleLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.hover(path, line, col)

fn simple_lsp_definition(state: SimpleLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.definition(path, line, col)

fn simple_lsp_code_action(state: SimpleLspState, path: text, line: i64, col: i64) -> LspResponse:
    if not state.running:
        return LspResponse(id: 0, ok: false, result_json: "", error_text: "not running")
    var client = state.client
    client.code_action(path, line, col)
