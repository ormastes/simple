# Editor Debug Session Model
#
# VSCode-style debug state independent of the concrete DAP runtime. This keeps
# launch configs, breakpoints, watches, and sessions testable before interpreter
# backed stepping is wired to the DAP adapter.

extern fn rt_process_spawn_piped(cmd: text, args: [text]) -> i64
extern fn rt_process_write_stdin(pid: i64, data: text) -> bool
extern fn rt_process_read_stdout(pid: i64) -> text
extern fn rt_process_is_alive(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool

struct EditorDebugEnv:
    key: text
    value: text

struct EditorDebugLaunchConfig:
    name: text
    debug_type: text
    request: text
    program: text
    cwd: text
    args: [text]
    pre_launch_task: text
    env: [EditorDebugEnv]

struct EditorDebugCompoundConfig:
    name: text
    configuration_names: [text]
    pre_launch_task: text

fn editor_debug_launch_config_debug_type(config: EditorDebugLaunchConfig) -> text:
    config.debug_type

fn editor_debug_launch_config_name(config: EditorDebugLaunchConfig) -> text:
    config.name

fn editor_debug_launch_config_program(config: EditorDebugLaunchConfig) -> text:
    config.program

fn editor_debug_launch_config_request(config: EditorDebugLaunchConfig) -> text:
    config.request

fn editor_debug_launch_config_matches_type(config: EditorDebugLaunchConfig, debug_type: text) -> bool:
    debug_type == "" or config.debug_type == debug_type

fn editor_debug_launch_config_with_program(config: EditorDebugLaunchConfig, program: text) -> EditorDebugLaunchConfig:
    if config.program != "":
        return config
    EditorDebugLaunchConfig(
        name: config.name,
        debug_type: config.debug_type,
        request: config.request,
        program: program,
        cwd: config.cwd,
        args: config.args,
        pre_launch_task: config.pre_launch_task,
        env: config.env
    )

fn editor_debug_launch_config_detail(config: EditorDebugLaunchConfig) -> text:
    var detail = config.debug_type + " " + config.request + " " + config.program
    if config.pre_launch_task != "":
        detail = detail + " task:" + config.pre_launch_task
    if config.env.len() > 0:
        detail = detail + " env:" + config.env.len().to_text()
    detail

fn editor_debug_launch_config_is_compound(config: EditorDebugLaunchConfig) -> bool:
    config.request == "compound"

fn editor_debug_compound_config_name(compound: EditorDebugCompoundConfig) -> text:
    compound.name

fn editor_debug_compound_config_member_names(compound: EditorDebugCompoundConfig) -> [text]:
    compound.configuration_names

struct EditorDebugBreakpoint:
    id: i64
    path: text
    line: i64
    enabled: bool
    condition: text
    log_message: text
    hit_condition: text

struct EditorDebugWatch:
    expression: text
    last_value: text
    status: text

struct EditorDebugConsoleEntry:
    kind: text
    text_content: text

struct EditorDebugStackFrame:
    id: i64
    name: text
    path: text
    line: i64
    col: i64

struct EditorDebugVariable:
    name: text
    value: text
    debug_type: text
    variables_reference: i64

struct EditorDebugScope:
    name: text
    variables_reference: i64
    variables: [EditorDebugVariable]

struct EditorDebugSession:
    id: i64
    config: EditorDebugLaunchConfig
    status: text
    stack_frames: [EditorDebugStackFrame]
    scopes: [EditorDebugScope]
    breakpoints: [EditorDebugBreakpoint]
    watches: [EditorDebugWatch]
    console: [EditorDebugConsoleEntry]
    exception_filters: [text]

struct EditorDebugRegistry:
    sessions: [EditorDebugSession]
    next_session_id: i64
    next_breakpoint_id: i64

struct EditorDebugDapPendingRequest:
    seq: i64
    command: text

struct EditorDebugDapInboundMessage:
    message_type: text
    command: text
    event_name: text
    raw_json: text

fn editor_debug_dap_inbound_message_type(message: EditorDebugDapInboundMessage) -> text:
    message.message_type

fn editor_debug_dap_inbound_raw_json(message: EditorDebugDapInboundMessage) -> text:
    message.raw_json

class EditorDebugDapClient:
    running: bool
    next_seq: i64
    send_buffer: [text]
    recv_buffer: [text]
    pending_requests: [EditorDebugDapPendingRequest]
    process_pid: i64
    process_buffer: text
    process_command: text
    process_args: [text]

impl EditorDebugDapClient:

    static fn new() -> EditorDebugDapClient:
        EditorDebugDapClient(
            running: false,
            next_seq: 1,
            send_buffer: [],
            recv_buffer: [],
            pending_requests: [],
            process_pid: 0,
            process_buffer: "",
            process_command: "",
            process_args: []
        )

    me start():
        self.running = true

    me start_process(command: text, args: [text]) -> bool:
        val pid = rt_process_spawn_piped(command, args)
        if pid <= 0:
            self.running = false
            self.process_pid = 0
            return false
        self.running = true
        self.process_pid = pid
        self.process_buffer = ""
        true

    me stop():
        if self.process_pid > 0:
            rt_process_kill(self.process_pid)
            self.process_pid = 0
            self.process_buffer = ""
        self.running = false

    fn is_process_backed() -> bool:
        self.process_pid > 0

    me send_request(command: text, arguments_json: text) -> i64:
        if not self.running:
            return 0
        val seq = self.next_seq
        self.next_seq = self.next_seq + 1
        val json = editor_debug_dap_request(seq, command, arguments_json)
        self._send_framed_json(json)
        self.pending_requests.push(EditorDebugDapPendingRequest(seq: seq, command: command))
        seq

fn editor_debug_dap_client_start_process(client: EditorDebugDapClient, command: text, args: [text]) -> (EditorDebugDapClient, bool):
    val pid = rt_process_spawn_piped(command, args)
    if pid <= 0:
        return (
            EditorDebugDapClient(
                running: false,
                next_seq: 1,
                send_buffer: [],
                recv_buffer: [],
                pending_requests: [],
                process_pid: 0,
                process_buffer: "",
                process_command: "",
                process_args: []
            ),
            false
        )
    (
            EditorDebugDapClient(
                running: true,
                next_seq: 1,
                send_buffer: [],
                recv_buffer: [],
                pending_requests: [],
            process_pid: pid,
            process_buffer: "",
            process_command: command,
            process_args: args
        ),
        true
    )

fn editor_debug_dap_client_start(client: EditorDebugDapClient) -> EditorDebugDapClient:
    EditorDebugDapClient(
        running: true,
        next_seq: client.next_seq,
        send_buffer: client.send_buffer,
        recv_buffer: client.recv_buffer,
        pending_requests: client.pending_requests,
        process_pid: client.process_pid,
        process_buffer: client.process_buffer,
        process_command: client.process_command,
        process_args: client.process_args
    )

fn editor_debug_dap_client_start_process_with_pid(command: text, args: [text]) -> (EditorDebugDapClient, bool, i64):
    val pid = rt_process_spawn_piped(command, args)
    if pid <= 0:
        return (
            EditorDebugDapClient(
                running: false,
                next_seq: 1,
                send_buffer: [],
                recv_buffer: [],
                pending_requests: [],
                process_pid: 0,
                process_buffer: "",
                process_command: "",
                process_args: []
            ),
            false,
            0
        )
    (
        EditorDebugDapClient(
            running: true,
            next_seq: 1,
            send_buffer: [],
            recv_buffer: [],
            pending_requests: [],
            process_pid: pid,
            process_buffer: "",
            process_command: command,
            process_args: args
        ),
        true,
        pid
    )

fn editor_debug_dap_client_stop_process(client: EditorDebugDapClient) -> EditorDebugDapClient:
    if client.process_pid > 0:
        rt_process_kill(client.process_pid)
    EditorDebugDapClient(
        running: false,
        next_seq: 1,
        send_buffer: [],
        recv_buffer: [],
        pending_requests: [],
        process_pid: 0,
        process_buffer: "",
        process_command: "",
        process_args: []
    )

fn editor_debug_dap_stop_process_pid(pid: i64) -> EditorDebugDapClient:
    if pid > 0:
        rt_process_kill(pid)
    EditorDebugDapClient.new()

fn editor_debug_dap_client_is_process_backed(client: EditorDebugDapClient) -> bool:
    client.process_pid > 0

fn editor_debug_dap_client_request(client: EditorDebugDapClient, command: text, arguments_json: text) -> (EditorDebugDapClient, i64):
    if not client.running:
        return (client, 0)
    val seq = client.next_seq
    val json = editor_debug_dap_request(seq, command, arguments_json)
    val framed = editor_debug_dap_frame_message(json)
    if client.process_pid > 0 and rt_process_is_alive(client.process_pid):
        rt_process_write_stdin(client.process_pid, framed)
    var send_buffer = client.send_buffer
    send_buffer.push(framed)
    var pending_requests = client.pending_requests
    pending_requests.push(EditorDebugDapPendingRequest(seq: seq, command: command))
    (
        EditorDebugDapClient(
            running: client.running,
            next_seq: seq + 1,
            send_buffer: send_buffer,
            recv_buffer: [],
            pending_requests: pending_requests,
            process_pid: client.process_pid,
            process_buffer: client.process_buffer,
            process_command: client.process_command,
            process_args: client.process_args
        ),
        seq
    )

fn editor_debug_dap_client_initialize(client: EditorDebugDapClient) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "initialize", "{\"adapterID\":\"simple\"}")

fn editor_debug_dap_client_launch(client: EditorDebugDapClient, config: EditorDebugLaunchConfig) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "launch", editor_debug_launch_config_dap_arguments(config))

fn editor_debug_launch_config_dap_arguments(config: EditorDebugLaunchConfig) -> text:
    var args_json = "{\"program\":\"" + _ed_json_escape(config.program) + "\",\"cwd\":\"" + _ed_json_escape(config.cwd) + "\""
    if config.args.len() > 0:
        args_json = args_json + ",\"args\":" + _ed_json_text_array(config.args)
    if config.pre_launch_task != "":
        args_json = args_json + ",\"preLaunchTask\":\"" + _ed_json_escape(config.pre_launch_task) + "\""
    if config.env.len() > 0:
        args_json = args_json + ",\"env\":" + _ed_json_env_map(config.env)
    args_json + "}"

fn editor_debug_dap_client_set_breakpoints(client: EditorDebugDapClient, path: text, breakpoints: [EditorDebugBreakpoint]) -> (EditorDebugDapClient, i64):
    var items = "["
    var first = true
    for bp in breakpoints:
        if bp.path == path and bp.enabled:
            if not first:
                items = items + ","
            items = items + "{\"line\":" + bp.line.to_text()
            if bp.condition != "":
                items = items + ",\"condition\":\"" + _ed_json_escape(bp.condition) + "\""
            if bp.hit_condition != "":
                items = items + ",\"hitCondition\":\"" + _ed_json_escape(bp.hit_condition) + "\""
            if bp.log_message != "":
                items = items + ",\"logMessage\":\"" + _ed_json_escape(bp.log_message) + "\""
            items = items + "}"
            first = false
    items = items + "]"
    editor_debug_dap_client_request(client, "setBreakpoints", "{\"source\":{\"path\":\"" + _ed_json_escape(path) + "\"},\"breakpoints\":" + items + "}")

fn editor_debug_dap_client_continue_thread(client: EditorDebugDapClient, thread_id: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "continue", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_client_pause_thread(client: EditorDebugDapClient, thread_id: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "pause", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_client_step_thread(client: EditorDebugDapClient, step_kind: text, thread_id: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, step_kind, "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_client_stack_trace(client: EditorDebugDapClient, thread_id: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "stackTrace", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_client_scopes(client: EditorDebugDapClient, frame_id: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "scopes", "{\"frameId\":" + frame_id.to_text() + "}")

fn editor_debug_dap_client_variables(client: EditorDebugDapClient, variables_reference: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "variables", "{\"variablesReference\":" + variables_reference.to_text() + "}")

fn editor_debug_dap_client_evaluate(client: EditorDebugDapClient, expression: text, frame_id: i64) -> (EditorDebugDapClient, i64):
    var args = "{\"expression\":\"" + _ed_json_escape(expression) + "\""
    if frame_id > 0:
        args = args + ",\"frameId\":" + frame_id.to_text()
    editor_debug_dap_client_request(client, "evaluate", args + "}")

fn editor_debug_dap_client_set_exception_breakpoints(client: EditorDebugDapClient, filters: [text]) -> (EditorDebugDapClient, i64):
    var items = "["
    var first = true
    for filter in filters:
        if filter != "":
            if not first:
                items = items + ","
            items = items + "\"" + _ed_json_escape(filter) + "\""
            first = false
    items = items + "]"
    editor_debug_dap_client_request(client, "setExceptionBreakpoints", "{\"filters\":" + items + "}")

fn editor_debug_dap_client_disconnect(client: EditorDebugDapClient) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "disconnect", "{\"terminateDebuggee\":true}")

fn editor_debug_dap_client_terminate(client: EditorDebugDapClient) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "terminate", "{}")

fn editor_debug_dap_client_restart(client: EditorDebugDapClient) -> (EditorDebugDapClient, i64):
    editor_debug_dap_client_request(client, "restart", "{}")

fn editor_debug_dap_client_inject_message(client: EditorDebugDapClient, json: text) -> EditorDebugDapClient:
    var next = client
    next.recv_buffer.push(json)
    next

fn editor_debug_dap_client_poll_messages(client: EditorDebugDapClient) -> (EditorDebugDapClient, [EditorDebugDapInboundMessage]):
    var next = client
    var messages: [EditorDebugDapInboundMessage] = []
    while next.recv_buffer.len() > 0:
        val json = next.recv_buffer[0]
        var remaining: [text] = []
        var i = 1
        while i < next.recv_buffer.len():
            remaining.push(next.recv_buffer[i])
            i = i + 1
        next.recv_buffer = remaining
        val kind = editor_debug_dap_message_type(json)
        val command = editor_debug_dap_response_command(json)
        if kind == "response":
            var pending: [EditorDebugDapPendingRequest] = []
            val request_seq = _ed_json_number_key(json, "request_seq")
            for request in next.pending_requests:
                if request.seq != request_seq:
                    pending.push(request)
            next.pending_requests = pending
        messages.push(EditorDebugDapInboundMessage(
            message_type: kind,
            command: command,
            event_name: editor_debug_dap_event_name(json),
            raw_json: json
        ))
    (next, messages)

fn editor_debug_dap_process_request(pid: i64, seq: i64, command: text, arguments_json: text) -> (EditorDebugDapClient, i64):
    val json = editor_debug_dap_request(seq, command, arguments_json)
    val framed = editor_debug_dap_frame_message(json)
    if pid > 0:
        rt_process_write_stdin(pid, framed)
    (
        EditorDebugDapClient(
            running: true,
            next_seq: seq + 1,
            send_buffer: [framed],
            recv_buffer: [],
            pending_requests: [EditorDebugDapPendingRequest(seq: seq, command: command)],
            process_pid: pid,
            process_buffer: "",
            process_command: "",
            process_args: []
        ),
        seq
    )

fn editor_debug_dap_process_initialize(pid: i64) -> (EditorDebugDapClient, i64):
    editor_debug_dap_process_request(pid, 1, "initialize", "{\"adapterID\":\"simple\"}")

fn editor_debug_dap_process_launch(pid: i64, seq: i64, config: EditorDebugLaunchConfig) -> (EditorDebugDapClient, i64):
    editor_debug_dap_process_request(pid, seq, "launch", editor_debug_launch_config_dap_arguments(config))

fn editor_debug_dap_poll_process_pid(pid: i64) -> [EditorDebugDapInboundMessage]:
    var messages: [EditorDebugDapInboundMessage] = []
    if pid <= 0:
        return messages
    var buf = rt_process_read_stdout(pid)
    if buf == "":
        return messages
    var parsed = true
    while parsed:
        val result = editor_debug_dap_parse_frame(buf)
        val json = result.0
        val consumed = result.1
        if json == "" or consumed <= 0:
            parsed = false
        else:
            messages.push(EditorDebugDapInboundMessage(
                message_type: editor_debug_dap_message_type(json),
                command: editor_debug_dap_response_command(json),
                event_name: editor_debug_dap_event_name(json),
                raw_json: json
            ))
            buf = buf.slice(consumed, buf.len())
    messages

    me _send_framed_json(json: text):
        val framed = editor_debug_dap_frame_message(json)
        self.send_buffer.push(framed)
        if self.process_pid > 0 and rt_process_is_alive(self.process_pid):
            rt_process_write_stdin(self.process_pid, framed)

    me initialize() -> i64:
        self.send_request("initialize", "{\"adapterID\":\"simple\"}")

    me launch(config: EditorDebugLaunchConfig) -> i64:
        self.send_request("launch", editor_debug_launch_config_dap_arguments(config))

    me continue_thread(thread_id: i64) -> i64:
        self.send_request("continue", "{\"threadId\":" + thread_id.to_text() + "}")

    me pause_thread(thread_id: i64) -> i64:
        self.send_request("pause", "{\"threadId\":" + thread_id.to_text() + "}")

    me step_thread(step_kind: text, thread_id: i64) -> i64:
        val request = editor_debug_dap_step_request(self.next_seq, step_kind, thread_id)
        if not self.running:
            return 0
        val seq = self.next_seq
        self.next_seq = self.next_seq + 1
        val command = editor_debug_dap_response_command(request)
        self._send_framed_json(request)
        self.pending_requests.push(EditorDebugDapPendingRequest(seq: seq, command: command))
        seq

    me stack_trace(thread_id: i64) -> i64:
        self.send_request("stackTrace", "{\"threadId\":" + thread_id.to_text() + "}")

    me scopes(frame_id: i64) -> i64:
        self.send_request("scopes", "{\"frameId\":" + frame_id.to_text() + "}")

    me variables(variables_reference: i64) -> i64:
        self.send_request("variables", "{\"variablesReference\":" + variables_reference.to_text() + "}")

    me evaluate(expression: text, frame_id: i64) -> i64:
        var args = "{\"expression\":\"" + _ed_json_escape(expression) + "\""
        if frame_id > 0:
            args = args + ",\"frameId\":" + frame_id.to_text()
        self.send_request("evaluate", args + "}")

    me set_breakpoints(path: text, breakpoints: [EditorDebugBreakpoint]) -> i64:
        var items = "["
        var first = true
        for bp in breakpoints:
            if bp.path == path and bp.enabled:
                if not first:
                    items = items + ","
                items = items + "{\"line\":" + bp.line.to_text()
                if bp.condition != "":
                    items = items + ",\"condition\":\"" + _ed_json_escape(bp.condition) + "\""
                if bp.hit_condition != "":
                    items = items + ",\"hitCondition\":\"" + _ed_json_escape(bp.hit_condition) + "\""
                if bp.log_message != "":
                    items = items + ",\"logMessage\":\"" + _ed_json_escape(bp.log_message) + "\""
                items = items + "}"
                first = false
        items = items + "]"
        self.send_request("setBreakpoints", "{\"source\":{\"path\":\"" + _ed_json_escape(path) + "\"},\"breakpoints\":" + items + "}")

    me set_exception_breakpoints(filters: [text]) -> i64:
        var items = "["
        var first = true
        for filter in filters:
            if filter != "":
                if not first:
                    items = items + ","
                items = items + "\"" + _ed_json_escape(filter) + "\""
                first = false
        items = items + "]"
        self.send_request("setExceptionBreakpoints", "{\"filters\":" + items + "}")

    me inject_message(json: text):
        self.recv_buffer.push(json)

    me poll_messages() -> [EditorDebugDapInboundMessage]:
        self._poll_process_stdout()
        var messages: [EditorDebugDapInboundMessage] = []
        while self.recv_buffer.len() > 0:
            val json = self.recv_buffer[0]
            var remaining: [text] = []
            var i = 1
            while i < self.recv_buffer.len():
                remaining.push(self.recv_buffer[i])
                i = i + 1
            self.recv_buffer = remaining
            val kind = editor_debug_dap_message_type(json)
            val command = editor_debug_dap_response_command(json)
            if kind == "response":
                var pending: [EditorDebugDapPendingRequest] = []
                val request_seq = _ed_json_number_key(json, "request_seq")
                for request in self.pending_requests:
                    if request.seq != request_seq:
                        pending.push(request)
                self.pending_requests = pending
            messages.push(EditorDebugDapInboundMessage(
                message_type: kind,
                command: command,
                event_name: editor_debug_dap_event_name(json),
                raw_json: json
            ))
        messages

    me _poll_process_stdout():
        if self.process_pid <= 0:
            return
        val chunk = rt_process_read_stdout(self.process_pid)
        if chunk != "":
            self.process_buffer = self.process_buffer + chunk
        var parsed = true
        while parsed:
            val result = editor_debug_dap_parse_frame(self.process_buffer)
            val json = result.0
            val consumed = result.1
            if json == "" or consumed <= 0:
                parsed = false
            else:
                self.recv_buffer.push(json)
                self.process_buffer = self.process_buffer.slice(consumed, self.process_buffer.len())

fn editor_debug_registry_new() -> EditorDebugRegistry:
    EditorDebugRegistry(sessions: [], next_session_id: 1, next_breakpoint_id: 1)

fn editor_debug_launch_config_default(program: text) -> EditorDebugLaunchConfig:
    EditorDebugLaunchConfig(
        name: "Launch Simple",
        debug_type: "simple",
        request: "launch",
        program: program,
        cwd: ".",
        args: [],
        pre_launch_task: "",
        env: []
    )

fn editor_debug_launch_config_from_json(json: text) -> EditorDebugLaunchConfig:
    val name = _ed_json_string(json, "\"name\"")
    val dtype = _ed_json_string(json, "\"type\"")
    val request = _ed_json_string(json, "\"request\"")
    val program = _ed_json_string(json, "\"program\"")
    val cwd = _ed_json_string(json, "\"cwd\"")
    val pre_launch_task = _ed_json_string(json, "\"preLaunchTask\"")
    EditorDebugLaunchConfig(
        name: if name == "" then "Launch Simple" else: name,
        debug_type: if dtype == "" then "simple" else: dtype,
        request: if request == "" then "launch" else: request,
        program: program,
        cwd: if cwd == "" then "." else: cwd,
        args: _ed_json_string_array(json, "\"args\""),
        pre_launch_task: pre_launch_task,
        env: _ed_json_env_object(json, "\"env\"")
    )

fn editor_debug_launch_configs_from_json(json: text) -> [EditorDebugLaunchConfig]:
    var configs: [EditorDebugLaunchConfig] = []
    val marker = _ed_find_text(json, "\"configurations\"", 0)
    if marker < 0:
        configs.push(editor_debug_launch_config_from_json(json))
        return configs
    val open = _ed_find_char(json, "[", marker)
    if open < 0:
        return configs
    var i = open + 1
    var depth = 0
    var config_start = -1
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "{":
            if depth == 0:
                config_start = i
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0 and config_start >= 0:
                configs.push(editor_debug_launch_config_from_json(json.slice(config_start, i + 1)))
                config_start = -1
        elif ch == "]" and depth == 0:
            return configs
        i = i + 1
    configs

fn editor_debug_compound_config_from_json(json: text) -> EditorDebugCompoundConfig:
    val name = _ed_json_string(json, "\"name\"")
    EditorDebugCompoundConfig(
        name: if name == "" then "Compound" else: name,
        configuration_names: _ed_json_string_array(json, "\"configurations\""),
        pre_launch_task: _ed_json_string(json, "\"preLaunchTask\"")
    )

fn editor_debug_compound_configs_from_json(json: text) -> [EditorDebugCompoundConfig]:
    var compounds: [EditorDebugCompoundConfig] = []
    val marker = _ed_find_text(json, "\"compounds\"", 0)
    if marker < 0:
        return compounds
    val open = _ed_find_char(json, "[", marker)
    if open < 0:
        return compounds
    var i = open + 1
    var depth = 0
    var compound_start = -1
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "{":
            if depth == 0:
                compound_start = i
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0 and compound_start >= 0:
                compounds.push(editor_debug_compound_config_from_json(json.slice(compound_start, i + 1)))
                compound_start = -1
        elif ch == "]" and depth == 0:
            return compounds
        i = i + 1
    compounds

fn editor_debug_compound_as_launch_config(compound: EditorDebugCompoundConfig) -> EditorDebugLaunchConfig:
    EditorDebugLaunchConfig(
        name: compound.name,
        debug_type: "compound",
        request: "compound",
        program: _ed_join_text(compound.configuration_names, "|"),
        cwd: ".",
        args: [],
        pre_launch_task: compound.pre_launch_task,
        env: []
    )

fn editor_debug_select_launch_config(json: text, debug_type: text, fallback_program: text) -> EditorDebugLaunchConfig:
    val configs = editor_debug_launch_configs_from_json(json)
    var first = editor_debug_launch_config_default(fallback_program)
    var seen = false
    for config in configs:
        if not seen:
            first = config
            seen = true
        if debug_type == "" or config.debug_type == debug_type:
            var selected = config
            if selected.program == "":
                selected.program = fallback_program
            return selected
    if seen:
        if first.program == "":
            first.program = fallback_program
        return first
    editor_debug_launch_config_default(fallback_program)

fn editor_debug_resolve_launch_config(config: EditorDebugLaunchConfig, workspace_folder: text, file_path: text) -> EditorDebugLaunchConfig:
    var args: [text] = []
    for arg in config.args:
        args.push(_ed_resolve_debug_vars(arg, workspace_folder, file_path))
    var env: [EditorDebugEnv] = []
    for entry in config.env:
        env.push(EditorDebugEnv(
            key: entry.key,
            value: _ed_resolve_debug_vars(entry.value, workspace_folder, file_path)
        ))
    EditorDebugLaunchConfig(
        name: config.name,
        debug_type: config.debug_type,
        request: config.request,
        program: _ed_resolve_debug_vars(config.program, workspace_folder, file_path),
        cwd: _ed_resolve_debug_vars(config.cwd, workspace_folder, file_path),
        args: args,
        pre_launch_task: _ed_resolve_debug_vars(config.pre_launch_task, workspace_folder, file_path),
        env: env
    )

fn editor_debug_registry_start(registry: EditorDebugRegistry, config: EditorDebugLaunchConfig) -> EditorDebugRegistry:
    var sessions = registry.sessions
    sessions.push(EditorDebugSession(
        id: registry.next_session_id,
        config: config,
        status: "starting",
        stack_frames: [],
        scopes: [],
        breakpoints: [],
        watches: [],
        console: [],
        exception_filters: []
    ))
    EditorDebugRegistry(
        sessions: sessions,
        next_session_id: registry.next_session_id + 1,
        next_breakpoint_id: registry.next_breakpoint_id
    )

fn editor_debug_registry_start_fresh(config: EditorDebugLaunchConfig) -> EditorDebugRegistry:
    EditorDebugRegistry(
        sessions: [
            EditorDebugSession(
                id: 1,
                config: config,
                status: "starting",
                stack_frames: [],
                scopes: [],
                breakpoints: [],
                watches: [],
                console: [],
                exception_filters: []
            )
        ],
        next_session_id: 2,
        next_breakpoint_id: 1
    )

fn editor_debug_registry_terminate(registry: EditorDebugRegistry, session_id: i64) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.status = "terminated"
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_registry_restart(registry: EditorDebugRegistry, session_id: i64) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.status = "restarting"
            next.console.push(EditorDebugConsoleEntry(kind: "control", text_content: "restart"))
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_set_status(registry: EditorDebugRegistry, session_id: i64, status: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.status = status
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_continue(registry: EditorDebugRegistry, session_id: i64) -> EditorDebugRegistry:
    editor_debug_set_status(
        editor_debug_console_append(registry, session_id, "control", "continue"),
        session_id,
        "running"
    )

fn editor_debug_pause(registry: EditorDebugRegistry, session_id: i64) -> EditorDebugRegistry:
    editor_debug_set_status(
        editor_debug_console_append(registry, session_id, "control", "pause"),
        session_id,
        "paused"
    )

fn editor_debug_step(registry: EditorDebugRegistry, session_id: i64, step_kind: text) -> EditorDebugRegistry:
    editor_debug_set_status(
        editor_debug_console_append(registry, session_id, "control", step_kind),
        session_id,
        "stepping"
    )

fn editor_debug_session_count(registry: EditorDebugRegistry) -> i64:
    registry.sessions.len()

fn editor_debug_session_at(registry: EditorDebugRegistry, index: i64) -> EditorDebugSession:
    if index < 0 or index >= registry.sessions.len():
        return editor_debug_first_session(registry)
    registry.sessions[index]

fn editor_debug_session_id(session: EditorDebugSession) -> i64:
    session.id

fn editor_debug_session_status(session: EditorDebugSession) -> text:
    session.status

fn editor_debug_session_config(session: EditorDebugSession) -> EditorDebugLaunchConfig:
    session.config

fn editor_debug_session_breakpoints(session: EditorDebugSession) -> [EditorDebugBreakpoint]:
    session.breakpoints

fn editor_debug_breakpoint_path(bp: EditorDebugBreakpoint) -> text:
    bp.path

fn editor_debug_breakpoint_line(bp: EditorDebugBreakpoint) -> i64:
    bp.line

fn editor_debug_breakpoint_enabled(bp: EditorDebugBreakpoint) -> bool:
    bp.enabled

fn editor_debug_breakpoint_condition(bp: EditorDebugBreakpoint) -> text:
    bp.condition

fn editor_debug_breakpoint_hit_condition(bp: EditorDebugBreakpoint) -> text:
    bp.hit_condition

fn editor_debug_first_session(registry: EditorDebugRegistry) -> EditorDebugSession:
    if registry.sessions.len() == 0:
        return EditorDebugSession(
            id: 0,
            config: editor_debug_launch_config_default(""),
            status: "none",
            stack_frames: [],
            scopes: [],
            breakpoints: [],
            watches: [],
            console: [],
            exception_filters: []
        )
    registry.sessions[0]

fn editor_debug_registry_select(registry: EditorDebugRegistry, session_id: i64) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    var selected: [EditorDebugSession] = []
    for session in registry.sessions:
        if session.id == session_id:
            selected.push(session)
        else:
            sessions.push(session)
    if selected.len() == 0:
        return registry
    var ordered: [EditorDebugSession] = []
    ordered.push(selected[0])
    for session in sessions:
        ordered.push(session)
    EditorDebugRegistry(sessions: ordered, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_add_breakpoint(registry: EditorDebugRegistry, session_id: i64, path: text, line: i64, condition: text, log_message: text, hit_condition: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    var next_breakpoint_id = registry.next_breakpoint_id
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.breakpoints.push(EditorDebugBreakpoint(
                id: next_breakpoint_id,
                path: path,
                line: line,
                enabled: true,
                condition: condition,
                log_message: log_message,
                hit_condition: hit_condition
            ))
            next_breakpoint_id = next_breakpoint_id + 1
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: next_breakpoint_id)

fn editor_debug_enable_breakpoint(registry: EditorDebugRegistry, breakpoint_id: i64, enabled: bool) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        var breakpoints: [EditorDebugBreakpoint] = []
        for bp in session.breakpoints:
            var nbp = bp
            if bp.id == breakpoint_id:
                nbp.enabled = enabled
            breakpoints.push(nbp)
        next.breakpoints = breakpoints
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_add_watch(registry: EditorDebugRegistry, session_id: i64, expression: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.watches.push(EditorDebugWatch(expression: expression, last_value: "", status: "pending"))
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_console_append(registry: EditorDebugRegistry, session_id: i64, kind: text, text_content: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.console.push(EditorDebugConsoleEntry(kind: kind, text_content: text_content))
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_evaluate(registry: EditorDebugRegistry, session_id: i64, expression: text) -> EditorDebugRegistry:
    editor_debug_console_append(registry, session_id, "evaluate", expression)

fn editor_debug_update_stack_frames(registry: EditorDebugRegistry, session_id: i64, frames: [EditorDebugStackFrame]) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.stack_frames = frames
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_update_scopes(registry: EditorDebugRegistry, session_id: i64, scopes: [EditorDebugScope]) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.scopes = scopes
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_update_scope_variables(registry: EditorDebugRegistry, session_id: i64, scope_name: text, variables: [EditorDebugVariable]) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            var scopes: [EditorDebugScope] = []
            var matched = false
            for scope in session.scopes:
                var updated = scope
                if scope.name == scope_name:
                    updated.variables = variables
                    matched = true
                scopes.push(updated)
            if not matched:
                scopes.push(EditorDebugScope(name: scope_name, variables_reference: 0, variables: variables))
            next.scopes = scopes
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_update_watch(registry: EditorDebugRegistry, session_id: i64, expression: text, value: text, status: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            var watches: [EditorDebugWatch] = []
            var matched = false
            for watch in session.watches:
                var updated = watch
                if watch.expression == expression:
                    updated.last_value = value
                    updated.status = if status == "" then "ok" else: status
                    matched = true
                watches.push(updated)
            if not matched:
                watches.push(EditorDebugWatch(expression: expression, last_value: value, status: if status == "" then "ok" else: status))
            next.watches = watches
            next.console.push(EditorDebugConsoleEntry(kind: "watch", text_content: expression + " = " + value))
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_evaluate_result(registry: EditorDebugRegistry, session_id: i64, expression: text, value: text, status: text) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            val prefix = if status == "" or status == "ok" then "" else: status + ": "
            next.console.push(EditorDebugConsoleEntry(kind: "evaluate-result", text_content: prefix + expression + " = " + value))
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_set_exception_filters(registry: EditorDebugRegistry, session_id: i64, filters: [text]) -> EditorDebugRegistry:
    var sessions: [EditorDebugSession] = []
    for session in registry.sessions:
        var next = session
        if session.id == session_id:
            next.exception_filters = filters
        sessions.push(next)
    EditorDebugRegistry(sessions: sessions, next_session_id: registry.next_session_id, next_breakpoint_id: registry.next_breakpoint_id)

fn editor_debug_session_summary(session: EditorDebugSession) -> text:
    session.status + " " + session.config.debug_type + " " + session.config.program

fn editor_debug_session_wiki_panel(session: EditorDebugSession) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    if session.id == 0:
        rows.push(WikiPanelRow(icon: "debug", label: "No debug session", detail: "", path: "", line: 0))
        return wiki_panel_with_rows("Debug Session", rows)
    rows.push(WikiPanelRow(icon: "debug", label: "Status", detail: editor_debug_session_summary(session), path: session.config.program, line: 0))
    for frame in session.stack_frames:
        val frame_detail = frame.path + ":" + frame.line.to_text() + ":" + frame.col.to_text()
        rows.push(WikiPanelRow(icon: "stack", label: frame.name, detail: frame_detail, path: frame.path, line: frame.line))
    for scope in session.scopes:
        rows.push(WikiPanelRow(icon: "scope", label: scope.name, detail: "ref " + scope.variables_reference.to_text(), path: session.config.program, line: 0))
        for variable in scope.variables:
            var variable_detail = variable.value
            if variable.debug_type != "":
                variable_detail = variable_detail + " : " + variable.debug_type
            if variable.variables_reference > 0:
                variable_detail = variable_detail + " ref " + variable.variables_reference.to_text()
            rows.push(WikiPanelRow(icon: "variable", label: variable.name, detail: variable_detail, path: session.config.program, line: 0))
    for filter in session.exception_filters:
        rows.push(WikiPanelRow(icon: "exception", label: filter, detail: "break on " + filter, path: session.config.program, line: 0))
    for bp in session.breakpoints:
        val enabled = if bp.enabled then "enabled" else: "disabled"
        var detail = enabled
        if bp.condition != "":
            detail = detail + " if " + bp.condition
        if bp.hit_condition != "":
            detail = detail + " hit " + bp.hit_condition
        rows.push(WikiPanelRow(icon: "breakpoint", label: bp.path + ":" + bp.line.to_text(), detail: detail, path: bp.path, line: bp.line))
    for watch in session.watches:
        val value = if watch.last_value == "" then watch.status else: watch.last_value
        rows.push(WikiPanelRow(icon: "watch", label: watch.expression, detail: value, path: session.config.program, line: 0))
    for entry in session.console:
        rows.push(WikiPanelRow(icon: "console", label: entry.kind, detail: entry.text_content, path: session.config.program, line: 0))
    wiki_panel_with_rows("Debug Session", rows)

fn editor_debug_dap_request(seq: i64, command: text, arguments_json: text) -> text:
    var json = "{\"seq\":" + str(seq) + ",\"type\":\"request\",\"command\":\"" + _ed_json_escape(command) + "\""
    if arguments_json != "":
        json = json + ",\"arguments\":" + arguments_json
    json + "}"

fn editor_debug_dap_frame_message(json: text) -> text:
    "Content-Length: " + str(json.len()) + "\r\n\r\n" + json

fn editor_debug_dap_parse_frame(buf: text) -> (text, i64):
    if buf == "":
        return ("", 0)
    val header_end = _ed_dap_find_header_end(buf)
    if header_end < 0:
        return ("", 0)
    val header = buf.slice(0, header_end)
    val content_start = header_end + 4
    val content_length = _ed_dap_parse_content_length(header)
    if content_length <= 0:
        return ("", 0)
    val total = content_start + content_length
    if buf.len() < total:
        return ("", 0)
    (buf.slice(content_start, total), total)

fn _ed_dap_find_header_end(buf: text) -> i64:
    if buf.len() < 4:
        return -1
    var i = 0
    while i < buf.len() - 3:
        if buf.char_at(i) == "\r" and buf.char_at(i + 1) == "\n" and buf.char_at(i + 2) == "\r" and buf.char_at(i + 3) == "\n":
            return i
        i = i + 1
    -1

fn _ed_dap_parse_content_length(header: text) -> i64:
    var i = 0
    while i < header.len():
        if header.slice(i, header.len()).starts_with("Content-Length:"):
            var j = i + 15
            while j < header.len() and header.char_at(j) == " ":
                j = j + 1
            var num = ""
            while j < header.len() and header.char_at(j) != "\r" and header.char_at(j) != "\n":
                num = num + header.char_at(j)
                j = j + 1
            return num.trim().to_i64() ?? 0
        i = i + 1
    0

fn editor_debug_dap_stack_trace_request(seq: i64, thread_id: i64) -> text:
    editor_debug_dap_request(seq, "stackTrace", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_scopes_request(seq: i64, frame_id: i64) -> text:
    editor_debug_dap_request(seq, "scopes", "{\"frameId\":" + frame_id.to_text() + "}")

fn editor_debug_dap_variables_request(seq: i64, variables_reference: i64) -> text:
    editor_debug_dap_request(seq, "variables", "{\"variablesReference\":" + variables_reference.to_text() + "}")

fn editor_debug_dap_evaluate_request(seq: i64, expression: text, frame_id: i64) -> text:
    var args = "{\"expression\":\"" + _ed_json_escape(expression) + "\""
    if frame_id > 0:
        args = args + ",\"frameId\":" + frame_id.to_text()
    editor_debug_dap_request(seq, "evaluate", args + "}")

fn editor_debug_dap_continue_request(seq: i64, thread_id: i64) -> text:
    editor_debug_dap_request(seq, "continue", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_pause_request(seq: i64, thread_id: i64) -> text:
    editor_debug_dap_request(seq, "pause", "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_step_request(seq: i64, command: text, thread_id: i64) -> text:
    val step_command = if command == "stepIn" or command == "stepOut" then command else: "next"
    editor_debug_dap_request(seq, step_command, "{\"threadId\":" + thread_id.to_text() + "}")

fn editor_debug_dap_set_breakpoints_request(seq: i64, path: text, breakpoints: [EditorDebugBreakpoint]) -> text:
    var items = "["
    var first = true
    for bp in breakpoints:
        if bp.path == path and bp.enabled:
            if not first:
                items = items + ","
            items = items + "{\"line\":" + bp.line.to_text()
            if bp.condition != "":
                items = items + ",\"condition\":\"" + _ed_json_escape(bp.condition) + "\""
            if bp.hit_condition != "":
                items = items + ",\"hitCondition\":\"" + _ed_json_escape(bp.hit_condition) + "\""
            if bp.log_message != "":
                items = items + ",\"logMessage\":\"" + _ed_json_escape(bp.log_message) + "\""
            items = items + "}"
            first = false
    items = items + "]"
    editor_debug_dap_request(seq, "setBreakpoints", "{\"source\":{\"path\":\"" + _ed_json_escape(path) + "\"},\"breakpoints\":" + items + "}")

fn editor_debug_dap_set_exception_breakpoints_request(seq: i64, filters: [text]) -> text:
    var items = "["
    var first = true
    for filter in filters:
        if filter != "":
            if not first:
                items = items + ","
            items = items + "\"" + _ed_json_escape(filter) + "\""
            first = false
    items = items + "]"
    editor_debug_dap_request(seq, "setExceptionBreakpoints", "{\"filters\":" + items + "}")

fn editor_debug_dap_response_command(json: text) -> text:
    _ed_json_string(json, "\"command\":")

fn editor_debug_dap_response_success(json: text) -> bool:
    val value = _ed_json_value(json, "\"success\"")
    value == "true"

fn editor_debug_dap_message_type(json: text) -> text:
    _ed_json_string(json, "\"type\":")

fn editor_debug_dap_event_name(json: text) -> text:
    _ed_json_string(json, "\"event\":")

fn editor_debug_dap_event_status(json: text) -> text:
    val event = editor_debug_dap_event_name(json)
    if event == "stopped":
        return "paused"
    if event == "continued":
        return "running"
    if event == "terminated" or event == "exited":
        return "terminated"
    ""

fn editor_debug_dap_event_summary(json: text) -> text:
    val event = editor_debug_dap_event_name(json)
    if event == "stopped":
        val reason = _ed_json_string(json, "\"reason\":")
        if reason != "":
            return "debug stopped: " + reason
        return "debug stopped"
    if event == "continued":
        return "debug continued"
    if event == "terminated":
        return "debug terminated"
    if event == "exited":
        val code = _ed_json_value(json, "\"exitCode\"")
        if code != "":
            return "debug exited: " + code
        return "debug exited"
    "debug event: " + event

fn editor_debug_stack_frames_from_dap_response(json: text) -> [EditorDebugStackFrame]:
    var result: [EditorDebugStackFrame] = []
    val frames_start = _ed_find_text(json, "\"stackFrames\"", 0)
    if frames_start < 0:
        return result
    val array_start = _ed_find_char(json, "[", frames_start)
    if array_start < 0:
        return result
    val array_end = _ed_find_char(json, "]", array_start + 1)
    if array_end < 0:
        return result
    var i = array_start + 1
    while i < array_end:
        val frame_start = _ed_find_text(json, "\"id\"", i)
        if frame_start < 0 or frame_start >= array_end:
            return result
        val source_start = _ed_find_text(json, "\"source\"", frame_start)
        if source_start < 0 or source_start >= array_end:
            return result
        val next_frame = _ed_find_text(json, "\"id\"", source_start + 8)
        val frame_end = if next_frame > 0 and next_frame < array_end then next_frame else: array_end
        val frame_header = json.slice(frame_start, source_start)
        val source_json = json.slice(source_start, frame_end)
        result.push(EditorDebugStackFrame(
            id: _ed_dap_number_field(frame_header, "id"),
            name: _ed_json_string(frame_header, "\"name\""),
            path: _ed_json_string(source_json, "\"path\""),
            line: _ed_dap_number_field(frame_header, "line"),
            col: _ed_dap_number_field(frame_header, "column")
        ))
        i = frame_end
    result

fn editor_debug_scopes_from_dap_response(json: text) -> [EditorDebugScope]:
    var result: [EditorDebugScope] = []
    val scopes = _ed_json_array(json, "\"scopes\"")
    var i = 0
    while i < scopes.len():
        val scope_json = scopes[i]
        result.push(EditorDebugScope(
            name: _ed_json_string(scope_json, "\"name\""),
            variables_reference: _ed_json_number_key(scope_json, "variablesReference"),
            variables: []
        ))
        i = i + 1
    result

fn editor_debug_variables_from_dap_response(json: text) -> [EditorDebugVariable]:
    var result: [EditorDebugVariable] = []
    val variables = _ed_json_array(json, "\"variables\"")
    var i = 0
    while i < variables.len():
        val variable_json = variables[i]
        result.push(EditorDebugVariable(
            name: _ed_json_string(variable_json, "\"name\""),
            value: _ed_json_string(variable_json, "\"value\""),
            debug_type: _ed_json_string(variable_json, "\"type\""),
            variables_reference: _ed_json_number_key(variable_json, "variablesReference")
        ))
        i = i + 1
    result

fn editor_debug_evaluate_result_from_dap_response(json: text) -> text:
    _ed_json_string(json, "\"result\":")

fn _ed_resolve_debug_vars(value: text, workspace_folder: text, file_path: text) -> text:
    val file_dir = _ed_dirname(file_path)
    val file_base = _ed_basename(file_path)
    var result = value.replace(r"${workspaceFolder}", workspace_folder)
    result = result.replace(r"${file}", file_path)
    result = result.replace(r"${fileDirname}", file_dir)
    result.replace(r"${fileBasename}", file_base)

fn _ed_dirname(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last <= 0:
        return ""
    path.slice(0, last)

fn _ed_basename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last < 0:
        return path
    path.slice(last + 1, path.len())

fn _ed_json_string(json: text, field: text) -> text:
    val start = _ed_find_text(json, field, 0)
    if start < 0:
        return ""
    var i = start + field.len()
    while i < json.len() and (json.char_at(i) == " " or json.char_at(i) == "\n" or json.char_at(i) == "\r" or json.char_at(i) == "\t" or json.char_at(i) == ":"):
        i = i + 1
    if i >= json.len() or json.char_at(i) != "\"":
        return ""
    _ed_extract_string(json, i)

fn _ed_json_string_array(json: text, field: text) -> [text]:
    var result: [text] = []
    val start = _ed_find_text(json, field, 0)
    if start < 0:
        return result
    val open = _ed_find_char(json, "[", start + field.len())
    if open < 0:
        return result
    val close = _ed_find_char(json, "]", open + 1)
    if close < 0:
        return result
    var i = open + 1
    while i < close:
        if json.char_at(i) == "\"":
            val value = _ed_extract_string(json, i)
            result.push(value)
            i = i + value.len() + 2
        else:
            i = i + 1
    result

fn _ed_json_env_object(json: text, field: text) -> [EditorDebugEnv]:
    var result: [EditorDebugEnv] = []
    val start = _ed_find_text(json, field, 0)
    if start < 0:
        return result
    val open = _ed_find_char(json, "{", start + field.len())
    if open < 0:
        return result
    var i = open + 1
    while i < json.len() and json.char_at(i) != "}":
        if json.char_at(i) == "\"":
            val key = _ed_extract_string(json, i)
            i = i + key.len() + 2
            while i < json.len() and json.char_at(i) != ":":
                i = i + 1
            if i < json.len():
                i = i + 1
            while i < json.len() and (json.char_at(i) == " " or json.char_at(i) == "\n"):
                i = i + 1
            if i < json.len() and json.char_at(i) == "\"":
                val value = _ed_extract_string(json, i)
                result.push(EditorDebugEnv(key: key, value: value))
                i = i + value.len() + 2
            else:
                while i < json.len() and json.char_at(i) != "," and json.char_at(i) != "}":
                    i = i + 1
        else:
            i = i + 1
    result

fn _ed_json_text_array(values: [text]) -> text:
    var out = "["
    var first = true
    for value in values:
        if not first:
            out = out + ","
        out = out + "\"" + _ed_json_escape(value) + "\""
        first = false
    out + "]"

fn _ed_json_env_map(env: [EditorDebugEnv]) -> text:
    var out = "{"
    var first = true
    for entry in env:
        if not first:
            out = out + ","
        out = out + "\"" + _ed_json_escape(entry.key) + "\":\"" + _ed_json_escape(entry.value) + "\""
        first = false
    out + "}"

fn _ed_join_text(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn _ed_json_i64(json: text, field: text) -> i64:
    _ed_json_value(json, field).to_i64() ?? 0

fn _ed_json_number(json: text, field: text) -> i64:
    val start = _ed_find_text(json, field, 0)
    if start < 0:
        return 0
    var i = start + field.len()
    while i < json.len():
        val ch = json.char_at(i)
        if _ed_is_digit(ch) or ch == "-":
            var digits = ""
            var negative = false
            while i < json.len():
                val c = json.char_at(i)
                if c == "-":
                    negative = true
                    digits = digits + c
                    i = i + 1
                elif _ed_is_digit(c):
                    digits = digits + c
                    i = i + 1
                else:
                    return _ed_digits_to_i64(digits, negative)
            return _ed_digits_to_i64(digits, negative)
        if ch == "," or ch == "}":
            return 0
        i = i + 1
    0

fn _ed_json_number_key(json: text, key: text) -> i64:
    val marker = "\"" + key + "\""
    var i = 0
    while i + marker.len() <= json.len():
        if json.slice(i, i + marker.len()) == marker:
            var j = i + marker.len()
            while j < json.len() and json.char_at(j) != ":":
                j = j + 1
            if j < json.len():
                j = j + 1
            while j < json.len():
                val ch = json.char_at(j)
                if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
                    j = j + 1
                elif _ed_is_digit(ch) or ch == "-":
                    var digits = ""
                    var negative = false
                    while j < json.len():
                        val c = json.char_at(j)
                        if c == "-":
                            negative = true
                            digits = digits + c
                            j = j + 1
                        elif _ed_is_digit(c):
                            digits = digits + c
                            j = j + 1
                        else:
                            return _ed_digits_to_i64(digits, negative)
                    return _ed_digits_to_i64(digits, negative)
                else:
                    return 0
            return 0
        i = i + 1
    0

fn _ed_dap_number_field(json: text, key: text) -> i64:
    val marker = "\"" + key + "\""
    val start = _ed_find_text(json, marker, 0)
    if start < 0:
        return 0
    var i = start + marker.len()
    while i < json.len() and json.char_at(i) != ":":
        i = i + 1
    if i < json.len():
        i = i + 1
    while i < json.len() and (json.char_at(i) == " " or json.char_at(i) == "\n" or json.char_at(i) == "\r" or json.char_at(i) == "\t"):
        i = i + 1
    var negative = false
    if i < json.len() and json.char_at(i) == "-":
        negative = true
        i = i + 1
    var result: i64 = 0
    while i < json.len() and _ed_is_digit(json.char_at(i)):
        result = result * 10 + _ed_digit_value(json.char_at(i))
        i = i + 1
    if negative:
        return 0 - result
    result

fn _ed_is_digit(ch: text) -> bool:
    ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9"

fn _ed_digit_value(ch: text) -> i64:
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn _ed_digits_to_i64(digits: text, negative: bool) -> i64:
    var result: i64 = 0
    var i = 0
    while i < digits.len():
        val ch = digits.char_at(i)
        if _ed_is_digit(ch):
            result = result * 10 + _ed_digit_value(ch)
        i = i + 1
    if negative:
        return 0 - result
    result

fn _ed_json_value(json: text, field: text) -> text:
    val start = _ed_find_text(json, field, 0)
    if start < 0:
        return ""
    var i = start + field.len()
    while i < json.len() and (json.char_at(i) == " " or json.char_at(i) == "\n" or json.char_at(i) == "\r" or json.char_at(i) == "\t" or json.char_at(i) == ":"):
        i = i + 1
    if i >= json.len():
        return ""
    val ch = json.char_at(i)
    if ch == "{":
        return _ed_json_balanced(json, i, "{")
    if ch == "[":
        return _ed_json_balanced(json, i, "[")
    if ch == "\"":
        return "\"" + _ed_json_escape(_ed_extract_string(json, i)) + "\""
    var result = ""
    while i < json.len():
        val c = json.char_at(i)
        if c == "," or c == "}":
            return result.trim()
        result = result + c
        i = i + 1
    result.trim()

fn _ed_json_array(json: text, field: text) -> [text]:
    var result: [text] = []
    val field_start = _ed_find_text(json, field, 0)
    if field_start < 0:
        return result
    var array_start = field_start + field.len()
    while array_start < json.len() and json.char_at(array_start) != "[":
        array_start = array_start + 1
    if array_start >= json.len():
        return result
    val array_json = _ed_json_balanced(json, array_start, "[")
    if array_json == "":
        return result
    var i = 1
    while i < array_json.len() - 1:
        val ch = array_json.char_at(i)
        if ch == " " or ch == "\n" or ch == "\r" or ch == "\t" or ch == ",":
            i = i + 1
        elif ch == "{":
            val item = _ed_json_balanced(array_json, i, "{")
            if item != "":
                result.push(item)
                i = i + item.len()
            else:
                i = i + 1
        else:
            i = i + 1
    result

fn _ed_json_balanced(json: text, start: i64, open_ch: text) -> text:
    val close_ch = if open_ch == "{" then "}" else: "]"
    var depth = 0
    var i = start
    var in_str = false
    while i < json.len():
        val ch = json.char_at(i)
        if in_str:
            if ch == "\\":
                i = i + 1
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == open_ch:
                depth = depth + 1
            elif ch == close_ch:
                depth = depth - 1
                if depth == 0:
                    return json.slice(start, i + 1)
        i = i + 1
    ""

fn _ed_json_escape(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        elif ch == "\n":
            result = result + "\\n"
        elif ch == "\r":
            result = result + "\\r"
        elif ch == "\t":
            result = result + "\\t"
        else:
            result = result + ch
        i = i + 1
    result

fn _ed_extract_string(json: text, start: i64) -> text:
    var result = ""
    var i = start + 1
    while i < json.len():
        val ch = json.char_at(i)
        if ch == "\"":
            return result
        if ch == "\\":
            i = i + 1
            if i < json.len():
                result = result + json.char_at(i)
        else:
            result = result + ch
        i = i + 1
    result

fn _ed_find_char(haystack: text, needle: text, start: i64) -> i64:
    var i = start
    while i < haystack.len():
        if haystack.char_at(i) == needle:
            return i
        i = i + 1
    -1

fn _ed_find_text(haystack: text, needle: text, start: i64) -> i64:
    var i = start
    while i + needle.len() <= haystack.len():
        if haystack.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1
