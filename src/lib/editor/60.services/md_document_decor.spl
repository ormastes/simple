# Markdown Document Decoration
#
# Extracts document-level rendering hints from Markdown frontmatter and CSS
# fences so GUI preview can render page view, header/footer, and custom CSS.

struct MdDocumentDecor:
    page_view: bool
    header: text
    footer: text
    css_file: text
    inline_css: text
    layout: text

struct MdDocumentSlide:
    index: i64
    title: text
    content: text
    css: text

struct MdSheetCell:
    address: text
    row: i64
    col: i64
    raw: text
    value: text

struct MdScriptEmbed:
    language: text
    code: text

struct MdSgridFormula:
    target: text
    expr: text

struct MdSgridFormat:
    target: text
    expr: text

struct MdSgridBlock:
    carrier: text
    line: i64
    id: text
    table_ref: text
    formulas: [MdSgridFormula]
    formats: [MdSgridFormat]
    body: text

struct MdSgridBinding:
    index: i64
    id: text
    table_ref: text
    table_start: i64
    table_end: i64

struct MdSgridPivotRow:
    key: text
    value: text

fn md_document_decor_empty() -> MdDocumentDecor:
    MdDocumentDecor(page_view: false, header: "", footer: "", css_file: "", inline_css: "", layout: "document")

fn md_document_decor_parse(content: text) -> MdDocumentDecor:
    var decor = md_document_decor_empty()
    val lines = _mdd_split_lines(content)
    var body_start = 0
    if lines.len() > 0 and lines[0].trim() == "---":
        var i = 1
        while i < lines.len():
            val line = lines[i].trim()
            if line == "---":
                body_start = i + 1
                break
            val sep = line.index_of(":")
            if sep >= 0:
                val key = line.slice(0, sep).trim()
                val value = _mdd_unquote(line.slice(sep + 1, line.len()).trim())
                if key == "page_view":
                    decor.page_view = _mdd_truthy(value)
                elif key == "header":
                    decor.header = value
                elif key == "footer":
                    decor.footer = value
                elif key == "css_file":
                    decor.css_file = value
                elif key == "layout":
                    decor.layout = value
            i = i + 1
    decor.inline_css = _mdd_collect_css_fences(lines, body_start)
    if decor.page_view and decor.layout == "document":
        decor.layout = "paper"
    decor

fn md_document_body_without_decor(content: text) -> text:
    val lines = _mdd_split_lines(content)
    var result: [text] = []
    var i = 0
    if lines.len() > 0 and lines[0].trim() == "---":
        i = 1
        while i < lines.len() and lines[i].trim() != "---":
            i = i + 1
        if i < lines.len() and lines[i].trim() == "---":
            i = i + 1
    var in_css = false
    while i < lines.len():
        val trimmed = lines[i].trim()
        if not in_css and _mdd_is_css_fence(trimmed):
            in_css = true
            i = i + 1
            continue
        if in_css:
            if trimmed.starts_with("```"):
                in_css = false
            i = i + 1
            continue
        result.push(lines[i])
        i = i + 1
    _mdd_compact_blank_runs(_mdd_trim_outer_blank_lines(result)).join("\n")

fn md_document_split_ppt_pages(content: text) -> [MdDocumentSlide]:
    val body = md_document_body_without_decor(content)
    val lines = _mdd_split_lines(body)
    var slides: [MdDocumentSlide] = []
    var current_title = ""
    var current_lines: [text] = []
    var current_css = ""
    var seen_slide = false
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("## "):
            if seen_slide:
                slides.push(MdDocumentSlide(index: slides.len() + 1, title: current_title, content: _mdd_trim_outer_blank_lines(current_lines).join("\n"), css: current_css))
            current_title = trimmed.slice(3, trimmed.len()).trim()
            current_lines = []
            current_css = _mdd_heading_css(trimmed)
            seen_slide = true
        elif seen_slide:
            current_lines.push(line)
    if seen_slide:
        slides.push(MdDocumentSlide(index: slides.len() + 1, title: current_title, content: _mdd_trim_outer_blank_lines(current_lines).join("\n"), css: current_css))
    slides

fn md_document_render_ppt_html(content: text) -> text:
    val decor = md_document_decor_parse(content)
    val slides = md_document_split_ppt_pages(content)
    var html: [text] = []
    html.push("<section class=\"md-ppt-deck\" data-layout=\"" + _mdd_escape_html(decor.layout) + "\">")
    if decor.css_file != "":
        html.push("<link rel=\"stylesheet\" href=\"" + _mdd_escape_html(decor.css_file) + "\">")
    if decor.inline_css != "":
        html.push("<style class=\"md-inline-css\">" + _mdd_escape_html(decor.inline_css) + "</style>")
    for slide in slides:
        val css_class = if slide.css != "" then " " + _mdd_css_classes(slide.css) else: ""
        html.push("<article class=\"md-ppt-slide" + css_class + "\" data-slide=\"" + slide.index.to_text() + "\"><h2>" + _mdd_escape_html(slide.title) + "</h2><div class=\"md-ppt-body\">" + _mdd_render_plain_markdown_lines(slide.content) + "</div></article>")
    html.push("</section>")
    html.join("")

fn md_document_replace_ppt_page(content: text, slide_index: i64, new_content: text) -> text:
    val lines = _mdd_split_lines(content)
    val replacement = _mdd_trim_outer_blank_lines(_mdd_split_lines(new_content))
    var result: [text] = []
    var current_slide = 0
    var skipping_target = false
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("## "):
            current_slide = current_slide + 1
            skipping_target = current_slide == slide_index
            result.push(line)
            if skipping_target:
                for replacement_line in replacement:
                    result.push(replacement_line)
        elif not skipping_target:
            result.push(line)
    result.join("\n")

fn md_document_render_paper_html(content: text) -> text:
    val decor = md_document_decor_parse(content)
    val body = _mdd_body_without_script_fences(md_document_body_without_decor(content))
    var html: [text] = []
    html.push("<article class=\"md-paper-layout\" data-layout=\"paper\">")
    if decor.css_file != "":
        html.push("<link rel=\"stylesheet\" href=\"" + _mdd_escape_html(decor.css_file) + "\">")
    if decor.inline_css != "":
        html.push("<style class=\"md-inline-css\">" + _mdd_escape_html(decor.inline_css) + "</style>")
    if decor.header != "":
        html.push("<header class=\"md-page-header\">" + _mdd_escape_html(decor.header) + "</header>")
    html.push("<main class=\"md-page-body\">" + _mdd_render_plain_markdown_lines(body) + "</main>")
    if decor.footer != "":
        html.push("<footer class=\"md-page-footer\">" + _mdd_escape_html(decor.footer) + "</footer>")
    val scripts = md_document_render_script_embeds_html(content)
    if scripts != "":
        html.push("<aside class=\"md-script-region\">" + scripts + "</aside>")
    html.push("</article>")
    html.join("")

fn md_document_render_office_html(content: text) -> text:
    val decor = md_document_decor_parse(content)
    if decor.layout == "ppt" or decor.layout == "slides" or decor.layout == "presentation":
        return md_document_render_ppt_html(content)
    if decor.layout == "sheet" or decor.layout == "excel" or decor.layout == "spreadsheet":
        return "<section class=\"md-sheet-layout\" data-layout=\"" + _mdd_escape_html(decor.layout) + "\">" + md_document_render_sheet_html(content) + md_document_render_script_embeds_html(content) + "</section>"
    md_document_render_paper_html(content)

fn md_document_sheet_cells(content: text) -> [MdSheetCell]:
    val body = md_document_body_without_decor(content)
    val lines = _mdd_split_lines(body)
    var table_lines: [text] = []
    var in_table = false
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("|") and trimmed.ends_with("|"):
            if not _mdd_is_table_separator(trimmed):
                table_lines.push(trimmed)
            in_table = true
        elif in_table:
            break
    var cells: [MdSheetCell] = []
    var row = 1
    for table_line in table_lines:
        val cols = _mdd_split_table_row(table_line)
        var col = 1
        for raw_cell in cols:
            val raw = raw_cell.trim()
            cells.push(MdSheetCell(address: _mdd_cell_address(row, col), row: row, col: col, raw: raw, value: raw))
            col = col + 1
        row = row + 1
    _mdd_evaluate_sheet_cells(cells)

fn md_document_render_sheet_html(content: text) -> text:
    val cells = md_document_sheet_cells(content)
    var html: [text] = []
    html.push("<table class=\"md-sheet\" data-calculated=\"true\">")
    var current_row = 0
    for cell in cells:
        if cell.row != current_row:
            if current_row != 0:
                html.push("</tr>")
            current_row = cell.row
            html.push("<tr data-row=\"" + current_row.to_text() + "\">")
        val tag = if cell.row == 1 then "th" else: "td"
        html.push("<" + tag + " data-cell=\"" + cell.address + "\" data-raw=\"" + _mdd_escape_html(cell.raw) + "\">" + _mdd_escape_html(cell.value) + "</" + tag + ">")
    if current_row != 0:
        html.push("</tr>")
    html.push("</table>")
    html.join("")

fn md_sgrid_scan(content: text) -> [MdSgridBlock]:
    val lines = _mdd_split_lines(content)
    var blocks: [MdSgridBlock] = []
    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed.starts_with("<!-- sgrid"):
            val carrier_line = i
            var body: [text] = []
            i = i + 1
            while i < lines.len() and not lines[i].trim().starts_with("-->"):
                body.push(lines[i])
                i = i + 1
            var parsed = _mdd_parse_sgrid_body(body.join("\n"), "html")
            parsed.line = carrier_line
            blocks.push(parsed)
        elif trimmed.starts_with("```sgrid") or trimmed.starts_with("~~~sgrid"):
            val carrier_line2 = i
            val fence = if trimmed.starts_with("~~~") then "~~~" else: "```"
            var body2: [text] = []
            i = i + 1
            while i < lines.len() and not lines[i].trim().starts_with(fence):
                body2.push(lines[i])
                i = i + 1
            var parsed2 = _mdd_parse_sgrid_body(body2.join("\n"), "fence")
            parsed2.line = carrier_line2
            blocks.push(parsed2)
        i = i + 1
    blocks

fn md_sgrid_bind_tables(content: text) -> [MdSgridBinding]:
    val blocks = md_sgrid_scan(content)
    var bindings: [MdSgridBinding] = []
    var i = 0
    while i < blocks.len():
        val block = blocks[i]
        val span = _mdd_bind_sgrid_table(content, block.table_ref, block.line)
        bindings.push(MdSgridBinding(index: i + 1, id: block.id, table_ref: block.table_ref, table_start: span.0, table_end: span.1))
        i = i + 1
    bindings

fn md_sgrid_apply(content: text) -> [MdSheetCell]:
    val blocks = md_sgrid_scan(content)
    if blocks.len() == 0:
        return md_document_sheet_cells(content)
    val table = _mdd_table_text_for_ref(content, blocks[0].table_ref, blocks[0].line)
    var cells = md_document_sheet_cells(table)
    for block in blocks:
        for formula in block.formulas:
            cells = _mdd_apply_sgrid_formula(cells, formula)
    cells

fn md_sgrid_selection_sum(content: text, range: text) -> text:
    val cells = md_sgrid_apply(content)
    var total = 0
    for cell in cells:
        if _mdd_cell_in_range(cell.address, range):
            total = total + (cell.value.to_i64() ?? 0)
    total.to_text()

fn md_sgrid_copy_selection(content: text, range: text) -> text:
    val cells = md_sgrid_apply(content)
    val span = _mdd_range_span(range)
    var rows: [text] = []
    var row = span.0
    while row <= span.2:
        var cols: [text] = []
        var col = span.1
        while col <= span.3:
            cols.push(_mdd_cell_value_at(cells, row, col))
            col = col + 1
        rows.push(cols.join("\t"))
        row = row + 1
    rows.join("\n")

fn md_sgrid_pivot_sum(content: text, key_col: text, value_col: text) -> [MdSgridPivotRow]:
    val cells = md_sgrid_apply(content)
    val key_index = _mdd_address_col(key_col + "1")
    val value_index = _mdd_address_col(value_col + "1")
    var rows: [MdSgridPivotRow] = []
    var row = 2
    while row <= _mdd_max_cell_row(cells):
        val key = _mdd_cell_value_at(cells, row, key_index)
        val amount = _mdd_cell_value_at(cells, row, value_index).to_i64() ?? 0
        if key != "":
            rows = _mdd_pivot_add(rows, key, amount)
        row = row + 1
    rows

fn md_sgrid_common_libraries() -> [text]:
    ["sum(range)", "avg(range)", "min(range)", "max(range)", "count(range)", "money(USD)", "copy(range)", "pivot_sum(key_col,value_col)", "selection_sum(range)"]

fn md_sgrid_inline_annotations(content: text) -> [MdSgridFormula]:
    val cells = md_document_sheet_cells(content)
    var formulas: [MdSgridFormula] = []
    for cell in cells:
        val inline = _mdd_inline_formula(cell.raw)
        if inline != "":
            formulas.push(MdSgridFormula(target: cell.address, expr: inline))
    formulas

fn md_sgrid_header_types(content: text) -> [MdSgridFormat]:
    val cells = md_document_sheet_cells(content)
    var types: [MdSgridFormat] = []
    for cell in cells:
        if cell.row == 1 and cell.raw.contains(":"):
            val sep = cell.raw.index_of(":")
            types.push(MdSgridFormat(target: _mdd_col_name(cell.col), expr: "type(" + cell.raw.slice(sep + 1, cell.raw.len()).trim() + ")"))
    types

fn md_document_replace_sheet_cell_value(content: text, address: text, value: text) -> text:
    val target_row = _mdd_address_row(address)
    val target_col = _mdd_address_col(address)
    val lines = _mdd_split_lines(content)
    var result: [text] = []
    var table_row = 0
    var in_table = false
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("|") and trimmed.ends_with("|"):
            in_table = true
            if _mdd_is_table_separator(trimmed):
                result.push(line)
            else:
                table_row = table_row + 1
                if table_row == target_row:
                    var cells = _mdd_split_table_row(trimmed)
                    if target_col > 0 and target_col <= cells.len():
                        cells[target_col - 1] = value
                    result.push(_mdd_join_table_row(cells))
                else:
                    result.push(line)
        else:
            if in_table:
                in_table = false
            result.push(line)
    result.join("\n")

fn md_document_script_embeds(content: text) -> [MdScriptEmbed]:
    val lines = _mdd_split_lines(md_document_body_without_decor(content))
    var embeds: [MdScriptEmbed] = []
    var in_script = false
    var language = ""
    var code_lines: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if not in_script and (trimmed == "```simple" or trimmed == "```script" or trimmed == "```spl"):
            in_script = true
            language = trimmed.slice(3, trimmed.len()).trim()
            code_lines = []
        elif in_script and trimmed.starts_with("```"):
            embeds.push(MdScriptEmbed(language: language, code: code_lines.join("\n")))
            in_script = false
        elif in_script:
            code_lines.push(line)
    embeds

fn md_document_render_script_embeds_html(content: text) -> text:
    val embeds = md_document_script_embeds(content)
    var html: [text] = []
    for embed in embeds:
        html.push("<pre class=\"md-script-embed\" data-language=\"" + _mdd_escape_html(embed.language) + "\"><code>" + _mdd_escape_html(embed.code) + "</code></pre>")
    html.join("")

fn _mdd_body_without_script_fences(content: text) -> text:
    val lines = _mdd_split_lines(content)
    var result: [text] = []
    var in_script = false
    for line in lines:
        val trimmed = line.trim()
        if not in_script and (trimmed == "```simple" or trimmed == "```script" or trimmed == "```spl"):
            in_script = true
        elif in_script and trimmed.starts_with("```"):
            in_script = false
        elif not in_script:
            result.push(line)
    _mdd_compact_blank_runs(_mdd_trim_outer_blank_lines(result)).join("\n")

fn _mdd_collect_css_fences(lines: [text], start: i64) -> text:
    var blocks: [text] = []
    var current: [text] = []
    var in_css = false
    var i = start
    while i < lines.len():
        val trimmed = lines[i].trim()
        if not in_css and _mdd_is_css_fence(trimmed):
            in_css = true
            current = []
        elif in_css and trimmed.starts_with("```"):
            blocks.push(current.join("\n"))
            in_css = false
        elif in_css:
            current.push(lines[i])
        i = i + 1
    blocks.join("\n")

fn _mdd_is_css_fence(line: text) -> bool:
    line == "```css" or line == "```style"

fn _mdd_heading_css(line: text) -> text:
    val parts = line.split(" ")
    var css: [text] = []
    for part in parts:
        val token = part.trim()
        if token.starts_with("@") and token.len() > 1:
            css.push(token.slice(1, token.len()))
    css.join(" ")

fn _mdd_split_table_row(line: text) -> [text]:
    var cells: [text] = []
    var current = ""
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "|":
            val cell = current.trim()
            if cells.len() > 0 or cell != "":
                cells.push(cell)
            current = ""
        else:
            current = current + ch
        i = i + 1
    val tail = current.trim()
    if tail != "":
        cells.push(tail)
    cells

fn _mdd_parse_sgrid_body(body: text, carrier: text) -> MdSgridBlock:
    val lines = _mdd_split_lines(body)
    var block = MdSgridBlock(carrier: carrier, line: 0, id: "", table_ref: "previous", formulas: [], formats: [], body: body)
    var section = ""
    for raw_line in lines:
        val line = raw_line.trim()
        if line == "":
            continue
        if line.ends_with(":") and not line.contains("="):
            section = line.slice(0, line.len() - 1).trim()
        elif section == "" and line.contains(":"):
            val sep = line.index_of(":")
            val key = line.slice(0, sep).trim()
            val value = line.slice(sep + 1, line.len()).trim()
            if key == "id":
                block.id = value
            elif key == "table":
                block.table_ref = value
        elif section == "f" and line.contains("="):
            val sep2 = line.index_of("=")
            block.formulas.push(MdSgridFormula(target: line.slice(0, sep2).trim(), expr: line.slice(sep2 + 1, line.len()).trim()))
        elif section == "fmt" and line.contains("="):
            val sep3 = line.index_of("=")
            block.formats.push(MdSgridFormat(target: line.slice(0, sep3).trim(), expr: line.slice(sep3 + 1, line.len()).trim()))
    block

fn _mdd_bind_sgrid_table(content: text, table_ref: text, carrier_line: i64) -> tuple:
    val lines = _mdd_split_lines(content)
    var tables_start: [i64] = []
    var tables_end: [i64] = []
    var i = 0
    while i < lines.len():
        if lines[i].trim().starts_with("|"):
            val start = i
            while i < lines.len() and lines[i].trim().starts_with("|"):
                i = i + 1
            tables_start.push(start)
            tables_end.push(i - 1)
        i = i + 1
    if tables_start.len() == 0:
        return (-1, -1)
    if table_ref.starts_with("#"):
        val named = _mdd_find_named_table(lines, tables_start, tables_end, table_ref.slice(1, table_ref.len()))
        if named.0 >= 0:
            return named
    if table_ref == "next":
        var ni = 0
        while ni < tables_start.len():
            if tables_start[ni] > carrier_line:
                return (tables_start[ni], tables_end[ni])
            ni = ni + 1
        return (tables_start[0], tables_end[0])
    if table_ref == "previous":
        var pi = tables_start.len() - 1
        while pi >= 0:
            if tables_end[pi] < carrier_line:
                return (tables_start[pi], tables_end[pi])
            pi = pi - 1
        return (tables_start[0], tables_end[0])
    if table_ref.to_i64() != nil:
        val idx = (table_ref.to_i64() ?? 1) - 1
        if idx >= 0 and idx < tables_start.len():
            return (tables_start[idx], tables_end[idx])
    (tables_start[0], tables_end[0])

fn _mdd_table_text_for_ref(content: text, table_ref: text, carrier_line: i64) -> text:
    val span = _mdd_bind_sgrid_table(content, table_ref, carrier_line)
    if span.0 < 0:
        return content
    val lines = _mdd_split_lines(content)
    var table: [text] = []
    var i = span.0
    while i <= span.1 and i < lines.len():
        table.push(lines[i])
        i = i + 1
    table.join("\n")

fn _mdd_find_named_table(lines: [text], starts: [i64], ends: [i64], name: text) -> tuple:
    var i = 0
    while i < starts.len():
        var scan = starts[i] - 1
        while scan >= 0 and lines[scan].trim() == "":
            scan = scan - 1
        if scan >= 0:
            val marker = lines[scan].trim()
            if marker.contains(name) or marker.contains("#" + name):
                return (starts[i], ends[i])
        i = i + 1
    (-1, -1)

fn _mdd_apply_sgrid_formula(cells: [MdSheetCell], formula: MdSgridFormula) -> [MdSheetCell]:
    var out = cells
    if formula.target.contains(":"):
        val span = _mdd_range_span(formula.target)
        var row = span.0
        while row <= span.2:
            val value = _mdd_eval_sgrid_expr_for_row(formula.expr, out, row)
            val address = _mdd_cell_address(row, span.1)
            out = _mdd_set_cell_value(out, address, value)
            row = row + 1
    else:
        out = _mdd_set_cell_value(out, formula.target, _mdd_eval_sgrid_expr_for_row(formula.expr, out, _mdd_address_row(formula.target)))
    out

fn _mdd_eval_sgrid_expr_for_row(expr: text, cells: [MdSheetCell], row: i64) -> text:
    val trimmed = expr.trim()
    if trimmed.starts_with("sum(") and trimmed.ends_with(")"):
        val range = trimmed.slice(4, trimmed.len() - 1).trim()
        return _mdd_range_sum(cells, range).to_text()
    if trimmed.starts_with("avg(") and trimmed.ends_with(")"):
        val range2 = trimmed.slice(4, trimmed.len() - 1).trim()
        val count = _mdd_range_count(cells, range2)
        if count == 0:
            return "0"
        return (_mdd_range_sum(cells, range2) / count).to_text()
    if trimmed.starts_with("min(") and trimmed.ends_with(")"):
        return _mdd_range_min(cells, trimmed.slice(4, trimmed.len() - 1).trim()).to_text()
    if trimmed.starts_with("max(") and trimmed.ends_with(")"):
        return _mdd_range_max(cells, trimmed.slice(4, trimmed.len() - 1).trim()).to_text()
    if trimmed.starts_with("count(") and trimmed.ends_with(")"):
        return _mdd_range_count(cells, trimmed.slice(6, trimmed.len() - 1).trim()).to_text()
    val mul = trimmed.index_of("*")
    if mul >= 0:
        val left = _mdd_expr_value(trimmed.slice(0, mul).trim(), cells, row)
        val right = _mdd_expr_value(trimmed.slice(mul + 1, trimmed.len()).trim(), cells, row)
        return (left * right).to_text()
    _mdd_expr_value(trimmed, cells, row).to_text()

fn _mdd_expr_value(token: text, cells: [MdSheetCell], row: i64) -> i64:
    if token.len() == 1:
        return _mdd_cell_value_at(cells, row, _mdd_address_col(token + "1")).to_i64() ?? 0
    if _mdd_address_row(token) > 0:
        return _mdd_cell_value_at(cells, _mdd_address_row(token), _mdd_address_col(token)).to_i64() ?? 0
    token.to_i64() ?? 0

fn _mdd_range_sum(cells: [MdSheetCell], range: text) -> i64:
    var total = 0
    for cell in cells:
        if _mdd_cell_in_range(cell.address, range):
            total = total + (cell.value.to_i64() ?? 0)
    total

fn _mdd_range_count(cells: [MdSheetCell], range: text) -> i64:
    var count = 0
    for cell in cells:
        if _mdd_cell_in_range(cell.address, range) and cell.value != "":
            count = count + 1
    count

fn _mdd_range_min(cells: [MdSheetCell], range: text) -> i64:
    var found = false
    var best = 0
    for cell in cells:
        if _mdd_cell_in_range(cell.address, range) and cell.value != "":
            val value = cell.value.to_i64() ?? 0
            if not found or value < best:
                best = value
                found = true
    best

fn _mdd_range_max(cells: [MdSheetCell], range: text) -> i64:
    var found = false
    var best = 0
    for cell in cells:
        if _mdd_cell_in_range(cell.address, range) and cell.value != "":
            val value = cell.value.to_i64() ?? 0
            if not found or value > best:
                best = value
                found = true
    best

fn _mdd_set_cell_value(cells: [MdSheetCell], address: text, value: text) -> [MdSheetCell]:
    var out = cells
    var i = 0
    while i < out.len():
        var cell = out[i]
        if cell.address == address:
            cell.value = value
            out[i] = cell
        i = i + 1
    out

fn _mdd_inline_formula(raw: text) -> text:
    if not raw.contains("`="):
        return ""
    val parts = raw.split("`=")
    if parts.len() < 2:
        return ""
    val tail = parts[1]
    val end_parts = tail.split("`")
    if end_parts.len() == 0:
        return ""
    end_parts[0].trim()

fn _mdd_range_span(range: text) -> tuple:
    val sep = range.index_of(":")
    if sep < 0:
        val row = _mdd_address_row(range)
        val col = _mdd_address_col(range)
        return (row, col, row, col)
    val left = range.slice(0, sep).trim()
    val right = range.slice(sep + 1, range.len()).trim()
    (_mdd_address_row(left), _mdd_address_col(left), _mdd_address_row(right), _mdd_address_col(right))

fn _mdd_cell_in_range(address: text, range: text) -> bool:
    val span = _mdd_range_span(range)
    val row = _mdd_address_row(address)
    val col = _mdd_address_col(address)
    row >= span.0 and row <= span.2 and col >= span.1 and col <= span.3

fn _mdd_cell_value_at(cells: [MdSheetCell], row: i64, col: i64) -> text:
    val address = _mdd_cell_address(row, col)
    for cell in cells:
        if cell.address == address:
            return cell.value
    ""

fn _mdd_max_cell_row(cells: [MdSheetCell]) -> i64:
    var max_row = 0
    for cell in cells:
        if cell.row > max_row:
            max_row = cell.row
    max_row

fn _mdd_pivot_add(rows: [MdSgridPivotRow], key: text, amount: i64) -> [MdSgridPivotRow]:
    var out = rows
    var i = 0
    while i < out.len():
        var row = out[i]
        if row.key == key:
            row.value = ((row.value.to_i64() ?? 0) + amount).to_text()
            out[i] = row
            return out
        i = i + 1
    out.push(MdSgridPivotRow(key: key, value: amount.to_text()))
    out

fn _mdd_join_table_row(cells: [text]) -> text:
    var out = "|"
    for cell in cells:
        out = out + " " + cell.trim() + " |"
    out

fn _mdd_is_table_separator(line: text) -> bool:
    var non_marker = false
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch != "|" and ch != "-" and ch != ":" and ch != " ":
            non_marker = true
        i = i + 1
    not non_marker

fn _mdd_evaluate_sheet_cells(cells: [MdSheetCell]) -> [MdSheetCell]:
    var out = cells
    var i = 0
    while i < out.len():
        var cell = out[i]
        if cell.raw.starts_with("="):
            cell.value = _mdd_eval_formula(cell.raw.slice(1, cell.raw.len()), out)
            out[i] = cell
        i = i + 1
    out

fn _mdd_eval_formula(formula: text, cells: [MdSheetCell]) -> text:
    val expr = formula.trim()
    val plus = expr.index_of("+")
    if plus >= 0:
        val left = _mdd_formula_value(expr.slice(0, plus).trim(), cells)
        val right = _mdd_formula_value(expr.slice(plus + 1, expr.len()).trim(), cells)
        return (left + right).to_text()
    _mdd_formula_value(expr, cells).to_text()

fn _mdd_formula_value(token: text, cells: [MdSheetCell]) -> i64:
    val raw = _mdd_cell_raw(token, cells)
    if raw != "":
        return raw.to_i64() ?? 0
    token.to_i64() ?? 0

fn _mdd_cell_raw(address: text, cells: [MdSheetCell]) -> text:
    for cell in cells:
        if cell.address == address:
            if cell.raw.starts_with("="):
                return cell.value
            return cell.raw
    ""

fn _mdd_cell_address(row: i64, col: i64) -> text:
    _mdd_col_name(col) + row.to_text()

fn _mdd_address_col(address: text) -> i64:
    if address.len() == 0:
        return 0
    val col = address.char_at(0)
    if col == "A":
        return 1
    if col == "B":
        return 2
    if col == "C":
        return 3
    if col == "D":
        return 4
    if col == "E":
        return 5
    0

fn _mdd_address_row(address: text) -> i64:
    if address.len() <= 1:
        return 0
    address.slice(1, address.len()).to_i64() ?? 0

fn _mdd_col_name(col: i64) -> text:
    if col == 1:
        return "A"
    if col == 2:
        return "B"
    if col == 3:
        return "C"
    if col == 4:
        return "D"
    if col == 5:
        return "E"
    "C" + col.to_text()

fn _mdd_css_classes(css: text) -> text:
    val parts = css.split(" ")
    var classes: [text] = []
    for part in parts:
        val token = part.trim()
        if token != "":
            classes.push("md-css-" + token)
    classes.join(" ")

fn _mdd_render_plain_markdown_lines(content: text) -> text:
    val lines = _mdd_split_lines(content)
    var html: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed != "":
            html.push("<p>" + _mdd_escape_html(trimmed) + "</p>")
    html.join("")

fn _mdd_escape_html(s: text) -> text:
    var result: [text] = []
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "<":
            result.push("&lt;")
        elif ch == ">":
            result.push("&gt;")
        elif ch == "&":
            result.push("&amp;")
        elif ch == "\"":
            result.push("&quot;")
        else:
            result.push(ch)
        i = i + 1
    result.join("")

fn _mdd_truthy(value: text) -> bool:
    val lower = value.lower()
    lower == "true" or lower == "yes" or lower == "on" or lower == "1"

fn _mdd_unquote(value: text) -> text:
    if value.len() >= 2:
        val first = value.char_at(0)
        val last = value.char_at(value.len() - 1)
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return value.slice(1, value.len() - 1)
    value

fn _mdd_trim_outer_blank_lines(lines: [text]) -> [text]:
    var start = 0
    var end = lines.len()
    while start < end and lines[start].trim() == "":
        start = start + 1
    while end > start and lines[end - 1].trim() == "":
        end = end - 1
    var result: [text] = []
    var i = start
    while i < end:
        result.push(lines[i])
        i = i + 1
    result

fn _mdd_compact_blank_runs(lines: [text]) -> [text]:
    var result: [text] = []
    var previous_blank = false
    for line in lines:
        val blank = line.trim() == ""
        if blank and previous_blank:
            continue
        result.push(line)
        previous_blank = blank
    result

fn _mdd_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines
