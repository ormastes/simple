# Editor Tab — a single tab in the editor tab bar.
#
# Provides: EditorTab, TabBar, tab_bar_new.

struct EditorTab:
    pane_id: i64
    path: text
    title: text
    modified: bool
    pinned: bool

struct TabBar:
    tabs: [EditorTab]
    active_index: i64

fn tab_bar_new() -> TabBar:
    TabBar(tabs: [], active_index: -1)

fn tab_bar_add(bar: TabBar, tab: EditorTab) -> TabBar:
    val new_tabs = bar.tabs.push(tab)
    val idx = new_tabs.len() - 1
    TabBar(tabs: new_tabs, active_index: idx)

fn tab_bar_close(bar: TabBar, pane_id: i64) -> TabBar:
    var new_tabs: [EditorTab] = []
    for t in bar.tabs:
        if t.pane_id != pane_id:
            new_tabs.push(t)
    val new_active = if new_tabs.len() > 0: new_tabs.len() - 1 else: -1
    TabBar(tabs: new_tabs, active_index: new_active)

fn tab_bar_activate(bar: TabBar, idx: i64) -> TabBar:
    TabBar(tabs: bar.tabs, active_index: idx)
