# Editor Split Compute — reusable pane rectangle helpers.

use std.editor.view.layout.{SplitRect}
use std.editor.view.split_tree.{SplitTree}

fn split_compute_rects(tree: SplitTree, x: i64, y: i64, w: i64, h: i64) -> [SplitRect]:
    val border = 1
    if tree.leaf_count() <= 1:
        return [SplitRect(group_id: tree.active_pane_id, x: x, y: y, w: w, h: h)]
    val left_w = (w - border) / 2
    val right_w = w - left_w - border
    [
        SplitRect(group_id: tree.active_pane_id, x: x, y: y, w: left_w, h: h),
        SplitRect(group_id: tree.active_pane_id + 1, x: x + left_w + border, y: y, w: right_w, h: h)
    ]

fn split_find_rect(rects: [SplitRect], group_id: i64) -> SplitRect:
    for rect in rects:
        if rect.group_id == group_id:
            return rect
    if rects.len() > 0:
        return rects[0]
    SplitRect(group_id: group_id, x: 0, y: 0, w: 0, h: 0)

fn split_find_neighbor(rects: [SplitRect], group_id: i64, direction: text) -> i64:
    val cur = split_find_rect(rects, group_id)
    var best_id = group_id
    var best_distance = 999999999
    for rect in rects:
        if rect.group_id != group_id:
            val distance = _split_direction_distance(cur, rect, direction)
            if distance >= 0 and distance < best_distance:
                best_distance = distance
                best_id = rect.group_id
    best_id

fn _split_direction_distance(cur: SplitRect, candidate: SplitRect, direction: text) -> i64:
    if direction == "left" and candidate.x + candidate.w <= cur.x:
        return cur.x - (candidate.x + candidate.w)
    if direction == "right" and candidate.x >= cur.x + cur.w:
        return candidate.x - (cur.x + cur.w)
    if direction == "up" and candidate.y + candidate.h <= cur.y:
        return cur.y - (candidate.y + candidate.h)
    if direction == "down" and candidate.y >= cur.y + cur.h:
        return candidate.y - (cur.y + cur.h)
    -1
