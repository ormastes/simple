# Editor Outline Panel — document structure overview (headings, functions, classes).
#
# Provides: OutlineItem, OutlinePanel, outline_panel_new.

struct OutlineItem:
    kind: text
    label: text
    line: i64
    depth: i64

struct OutlinePanel:
    title: text
    items: [OutlineItem]
    selected: i64
    scroll_offset: i64

fn outline_panel_new() -> OutlinePanel:
    OutlinePanel(title: "Outline", items: [], selected: 0, scroll_offset: 0)

fn outline_panel_from_items(items: [OutlineItem]) -> OutlinePanel:
    OutlinePanel(title: "Outline", items: items, selected: 0, scroll_offset: 0)

fn outline_panel_select(panel: OutlinePanel, idx: i64) -> OutlinePanel:
    OutlinePanel(title: panel.title, items: panel.items, selected: idx, scroll_offset: panel.scroll_offset)
