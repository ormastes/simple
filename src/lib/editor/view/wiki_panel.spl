# Editor Wiki Panel
#
# Side panel for wiki-style navigation: backlinks, tasks, properties,
# tags, graph edges, document quick-switch, vault search, and more.

use std.editor.services.md_wiki_index.*
use std.editor.services.md_search.*

struct WikiPanelRow:
    icon: text
    label: text
    detail: text
    path: text
    line: i64

struct WikiPanel:
    title: text
    rows: [WikiPanelRow]
    selected: i64
    scroll_offset: i64

struct WikiPropertyFormField:
    key: text
    value: text
    path: text
    line: i64
    payload: text

fn wiki_panel_new(title: text) -> WikiPanel:
    WikiPanel(title: title, rows: [], selected: 0, scroll_offset: 0)

fn wiki_panel_with_rows(title: text, rows: [WikiPanelRow]) -> WikiPanel:
    WikiPanel(title: title, rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_select(panel: WikiPanel, index: i64) -> WikiPanel:
    var idx = index
    if idx < 0:
        idx = 0
    if panel.rows.len() == 0:
        idx = 0
    elif idx >= panel.rows.len():
        idx = panel.rows.len() - 1
    WikiPanel(title: panel.title, rows: panel.rows, selected: idx, scroll_offset: panel.scroll_offset)

fn wiki_panel_target_path(panel: WikiPanel) -> text:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return ""
    panel.rows[panel.selected].path

fn wiki_panel_target_line(panel: WikiPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return 0
    panel.rows[panel.selected].line

fn wiki_panel_from_backlinks(links: [MdWikiLink]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for link in links:
        rows.push(WikiPanelRow(
            icon: "backlink",
            label: link.display,
            detail: link.source_path + ":" + (link.line + 1).to_text(),
            path: link.source_path,
            line: link.line
        ))
    WikiPanel(title: "Backlinks", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_tasks(tasks: [MdWikiTask]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for task in tasks:
        val icon = if task.checked then "[x]" else: "[ ]"
        rows.push(WikiPanelRow(
            icon: icon,
            label: task.text_content,
            detail: task.path + ":" + (task.line + 1).to_text(),
            path: task.path,
            line: task.line
        ))
    WikiPanel(title: "Tasks", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_properties(properties: [MdWikiProperty]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for prop in properties:
        rows.push(WikiPanelRow(
            icon: "property",
            label: prop.key,
            detail: prop.value,
            path: prop.path,
            line: 0
        ))
    WikiPanel(title: "Properties", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_tags(tags: [MdWikiTag]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for tag in tags:
        rows.push(WikiPanelRow(
            icon: "#",
            label: tag.tag,
            detail: tag.path + ":" + (tag.line + 1).to_text(),
            path: tag.path,
            line: tag.line
        ))
    WikiPanel(title: "Tags", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_graph_edges_with_index(edges: [MdWikiGraphEdge], index: MdWikiIndex) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for edge in edges:
        rows.push(WikiPanelRow(
            icon: "->",
            label: edge.target,
            detail: edge.source_path + " -> " + edge.target + " " + edge.edge_type + if edge.resolved then " resolved" else: " unresolved",
            path: edge.source_path,
            line: 0
        ))
    WikiPanel(title: "Graph", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_graph_edges(edges: [MdWikiGraphEdge]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for edge in edges:
        rows.push(WikiPanelRow(
            icon: "link",
            label: edge.target,
            detail: edge.edge_type,
            path: edge.source_path,
            line: 0
        ))
    WikiPanel(title: "Graph", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_documents(documents: [MdWikiDocument]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for doc in documents:
        rows.push(WikiPanelRow(
            icon: "doc",
            label: doc.title,
            detail: doc.path,
            path: doc.path,
            line: 0
        ))
    WikiPanel(title: "Quick Switch", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_panel_from_vault_search(matches: [MdVaultSearchMatch]) -> WikiPanel:
    var rows: [WikiPanelRow] = []
    for m in matches:
        rows.push(WikiPanelRow(
            icon: "search",
            label: m.context_text,
            detail: m.path + ":" + (m.line + 1).to_text(),
            path: m.path,
            line: m.line
        ))
    WikiPanel(title: "Vault Search", rows: rows, selected: 0, scroll_offset: 0)

fn wiki_property_form_fields(panel: WikiPanel) -> [WikiPropertyFormField]:
    var fields: [WikiPropertyFormField] = []
    for row in panel.rows:
        var key = row.label
        var value = row.detail
        if row.icon != "property":
            value = ""
            val sep = row.label.index_of(":")
            if sep >= 0:
                key = row.label.slice(0, sep).trim()
                value = row.label.slice(sep + 1, row.label.len()).trim()
        val payload = key + "|" + value
        fields.push(WikiPropertyFormField(key: key, value: value, path: row.path, line: row.line, payload: payload))
    fields

fn wiki_property_form_render(panel: WikiPanel, height: i64) -> [text]:
    var lines: [text] = []
    val fields = wiki_property_form_fields(panel)
    var i = 0
    while i < fields.len() and lines.len() < height:
        val field = fields[i]
        val prefix = if i == panel.selected then "> " else: "  "
        lines.push(prefix + "property " + field.key + " = " + field.value)
        i = i + 1
    lines

fn wiki_panel_render(panel: WikiPanel, height: i64) -> [text]:
    var lines: [text] = []
    var i = 0
    while i < panel.rows.len() and lines.len() < height:
        lines.push(wiki_panel_render_row(panel, i))
        i = i + 1
    lines

fn wiki_panel_render_row(panel: WikiPanel, index: i64) -> text:
    if index < 0 or index >= panel.rows.len():
        return ""
    val row = panel.rows[index]
    val prefix = if index == panel.selected then "> " else: "  "
    prefix + row.icon + " " + row.label + if row.detail != "" then "  " + row.detail else: ""
