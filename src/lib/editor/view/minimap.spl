# Editor Minimap
#
# Scaled-down overview of the file content with viewport highlight.

struct Minimap:
    enabled: bool
    width: i64
    total_lines: i64
    viewport_start: i64
    viewport_height: i64
    lines: [text]

fn minimap_new() -> Minimap:
    Minimap(
        enabled: false,
        width: 12,
        total_lines: 0,
        viewport_start: 0,
        viewport_height: 0,
        lines: []
    )

fn minimap_from_content(content: text, viewport_start: i64, viewport_height: i64, width: i64) -> Minimap:
    pass_todo

fn minimap_render(map: Minimap, height: i64) -> [text]:
    pass_todo
