# Editor Markdown Editing.
#
# Provides: MdMotionResult, MdTableEdit, MdCommandResult, MdEditorState,
# md_table_*/md_callout_*/md_assist_* helpers, md_commands_dispatch glue.

use std.editor.buffer.buffer.{EditorBuffer}

# Result of a vim-style markdown motion or table cell navigation.
struct MdMotionResult:
    found: bool
    line: i64
    col: i64
    message: text

fn md_motion_none(line: i64, col: i64) -> MdMotionResult:
    MdMotionResult(found: false, line: line, col: col, message: "")

# Result of a markdown table / callout structural edit.
struct MdTableEdit:
    changed: bool
    content: text
    line: i64
    col: i64
    message: text

fn md_table_edit_none(message: text) -> MdTableEdit:
    MdTableEdit(changed: false, content: "", line: 0, col: 0, message: message)

# Per-document markdown command state (visibility flags).
struct MdEditorState:
    preview_visible: bool
    outline_visible: bool

fn md_editor_state_new() -> MdEditorState:
    MdEditorState(preview_visible: false, outline_visible: false)

fn md_editor_state_preview_visible(state: MdEditorState) -> bool:
    state.preview_visible

fn md_editor_state_outline_visible(state: MdEditorState) -> bool:
    state.outline_visible

# Result of dispatching a markdown editor command.
struct MdCommandResult:
    status_message: text
    replace_line: text
    insert_text: text
    cursor_delta_line: i64
    cursor_delta_col: i64
    preview_visible: bool
    outline_visible: bool

# --- Markdown table query helpers (used by the render path) ---

fn md_table_is_row(line: text) -> bool:
    line.starts_with("|") or line.index_of("|") >= 0 and line.trim_start().starts_with("|")

fn md_table_is_separator_row(line: text) -> bool:
    val t = line.trim()
    if t.len() == 0:
        return false
    var i = 0
    while i < t.len():
        val ch = t.char_at(i)
        if ch != "|" and ch != "-" and ch != ":" and ch != " ":
            return false
        i = i + 1
    t.index_of("-") >= 0

fn md_table_cell_start_columns(line: text) -> [i64]:
    var starts: [i64] = []
    var i = 0
    while i < line.len():
        if line.char_at(i) == "|":
            var start = i + 1
            while start < line.len() and line.char_at(start) == " ":
                start = start + 1
            if start < line.len() and line.char_at(start) != "|":
                starts.push(start)
        i = i + 1
    starts

fn md_table_column_at(line: text, col: i64) -> i64:
    val starts = md_table_cell_start_columns(line)
    var idx = -1
    var i = 0
    while i < starts.len():
        if col >= starts[i]:
            idx = i
        i = i + 1
    idx

# --- Markdown table edits ---

fn md_table_insert_row_after(content: text, cursor_line: i64) -> MdTableEdit:
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len() or not md_table_is_row(lines[cursor_line]):
        return md_table_edit_none("no markdown table")
    val cells = _md_table_cells(lines[cursor_line])
    if cells.len() == 0:
        return md_table_edit_none("no markdown table")
    var empty: [text] = []
    var i = 0
    while i < cells.len():
        empty.push("")
        i = i + 1
    var out: [text] = []
    i = 0
    while i < lines.len():
        out.push(lines[i])
        if i == cursor_line:
            out.push(_md_table_build_row(empty, false))
        i = i + 1
    MdTableEdit(changed: true, content: out.join("\n"), line: cursor_line + 1, col: 2, message: "table row inserted")

fn md_table_insert_column_after(content: text, cursor_line: i64, cursor_col: i64) -> MdTableEdit:
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len() or not md_table_is_row(lines[cursor_line]):
        return md_table_edit_none("no markdown table")
    var column = md_table_column_at(lines[cursor_line], cursor_col)
    if column < 0:
        column = 0
    val insert_at = column + 1
    var out: [text] = []
    var changed = false
    var i = 0
    while i < lines.len():
        if md_table_is_row(lines[i]):
            var cells = _md_table_cells(lines[i])
            if insert_at <= cells.len():
                cells = _md_table_insert_cell(cells, insert_at, if md_table_is_separator_row(lines[i]) then "---" else: "")
                out.push(_md_table_build_row(cells, md_table_is_separator_row(lines[i])))
                changed = true
            else:
                out.push(lines[i])
        else:
            out.push(lines[i])
        i = i + 1
    if not changed:
        return md_table_edit_none("no markdown table")
    val starts = md_table_cell_start_columns(out[cursor_line])
    val next_col = if insert_at >= 0 and insert_at < starts.len() then starts[insert_at] else: cursor_col
    MdTableEdit(changed: true, content: out.join("\n"), line: cursor_line, col: next_col, message: "table column inserted")

fn md_table_set_cell(content: text, line: i64, col: i64, value: text) -> MdTableEdit:
    val lines = content.split("\n")
    if line < 0 or line >= lines.len() or not md_table_is_row(lines[line]) or md_table_is_separator_row(lines[line]):
        return md_table_edit_none("no markdown table")
    var cells = _md_table_cells(lines[line])
    if col < 0 or col >= cells.len():
        return md_table_edit_none("table cell out of range")
    cells[col] = value
    lines[line] = _md_table_build_row(cells, false)
    MdTableEdit(changed: true, content: lines.join("\n"), line: line, col: md_table_cell_start_columns(lines[line])[col], message: "table cell updated")

fn md_table_next_cell(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len() or not md_table_is_row(lines[cursor_line]):
        return MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "no table cell")
    val starts = md_table_cell_start_columns(lines[cursor_line])
    val current = md_table_column_at(lines[cursor_line], cursor_col)
    if current + 1 < starts.len():
        return MdMotionResult(found: true, line: cursor_line, col: starts[current + 1], message: "next table cell")
    var i = cursor_line + 1
    while i < lines.len():
        if md_table_is_row(lines[i]):
            if not md_table_is_separator_row(lines[i]):
                val next_starts = md_table_cell_start_columns(lines[i])
                if next_starts.len() > 0:
                    return MdMotionResult(found: true, line: i, col: next_starts[0], message: "next table cell")
        elif lines[i].trim() != "":
            return MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "last table cell")
        i = i + 1
    MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "last table cell")

fn md_table_prev_cell(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len() or not md_table_is_row(lines[cursor_line]):
        return MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "no table cell")
    val starts = md_table_cell_start_columns(lines[cursor_line])
    val current = md_table_column_at(lines[cursor_line], cursor_col)
    if current > 0:
        return MdMotionResult(found: true, line: cursor_line, col: starts[current - 1], message: "previous table cell")
    var i = cursor_line - 1
    while i >= 0:
        if md_table_is_row(lines[i]):
            if not md_table_is_separator_row(lines[i]):
                val prev_starts = md_table_cell_start_columns(lines[i])
                if prev_starts.len() > 0:
                    return MdMotionResult(found: true, line: i, col: prev_starts[prev_starts.len() - 1], message: "previous table cell")
        elif lines[i].trim() != "":
            return MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "first table cell")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "first table cell")

# --- Markdown callout edits ---

fn md_callout_toggle_fold(content: text, cursor_line: i64) -> MdTableEdit:
    val lines = content.split("\n")
    val header = _md_callout_header_line(lines, cursor_line)
    if header < 0:
        return md_table_edit_none("no callout")
    val line = lines[header]
    val marker_end = line.index_of("]")
    if marker_end < 0:
        return md_table_edit_none("no callout")
    val next_idx = marker_end + 1
    var rest_start = next_idx
    var folded = false
    if next_idx < line.len() and (line.char_at(next_idx) == "-" or line.char_at(next_idx) == "+"):
        folded = line.char_at(next_idx) == "-"
        rest_start = next_idx + 1
    val next_marker = if folded then "+" else: "-"
    lines[header] = line.slice(0, marker_end + 1) + next_marker + line.slice(rest_start, line.len())
    MdTableEdit(changed: true, content: lines.join("\n"), line: header, col: 0, message: if folded then "callout unfolded" else: "callout folded")

fn md_vim_toggle_fold_heading(content: text, cursor_line: i64) -> (i64, i64):
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len():
        return (cursor_line, cursor_line)
    var header = cursor_line
    var level = _md_heading_level(lines[header])
    while header >= 0 and level == 0:
        header = header - 1
        if header >= 0:
            level = _md_heading_level(lines[header])
    if header < 0 or level == 0:
        return (cursor_line, cursor_line)
    var end_line = lines.len() - 1
    var scan = header + 1
    while scan < lines.len():
        val scan_level = _md_heading_level(lines[scan])
        if scan_level > 0 and scan_level <= level:
            end_line = scan - 1
            scan = lines.len()
        else:
            scan = scan + 1
    if end_line <= header:
        return (header, header)
    (header, end_line)

# --- Markdown insert assists ---

fn md_assist_on_enter(current_line: text, cursor_col: i64) -> text:
    val prefix = _md_line_indent(current_line)
    val trimmed = current_line.trim_start()
    if trimmed.starts_with("> "):
        return prefix + "> "
    if trimmed.starts_with("- [ ] ") or trimmed.starts_with("- [x] "):
        return prefix + "- [ ] "
    if trimmed.starts_with("* [ ] ") or trimmed.starts_with("* [x] "):
        return prefix + "* [ ] "
    if trimmed.starts_with("- "):
        return prefix + "- "
    if trimmed.starts_with("* "):
        return prefix + "* "
    val dot = trimmed.index_of(". ")
    if dot > 0:
        val num = _md_parse_i64(trimmed.slice(0, dot), 0)
        if num > 0:
            return prefix + (num + 1).to_text() + ". "
    ""

fn md_assist_on_tab(current_line: text, cursor_col: i64) -> i64:
    val task = current_line.index_of("[")
    if task >= 0 and cursor_col <= task:
        return task + 4
    val starts = md_table_cell_start_columns(current_line)
    var i = 0
    while i < starts.len():
        if starts[i] > cursor_col:
            return starts[i]
        i = i + 1
    -1

fn md_assist_toggle_task(line: text) -> text:
    val open = line.index_of("[ ]")
    if open >= 0:
        return line.slice(0, open) + "[x]" + line.slice(open + 3, line.len())
    val done = line.index_of("[x]")
    if done >= 0:
        return line.slice(0, done) + "[ ]" + line.slice(done + 3, line.len())
    val done_upper = line.index_of("[X]")
    if done_upper >= 0:
        return line.slice(0, done_upper) + "[ ]" + line.slice(done_upper + 3, line.len())
    line

fn md_tasks_set_checked(content: text, checked: bool) -> text:
    val lines = content.split("\n")
    var out: [text] = []
    for line in lines:
        val toggled = md_assist_toggle_task(line)
        if toggled != line:
            val marker = if checked then "[x]" else: "[ ]"
            val idx = toggled.index_of("[")
            out.push(toggled.slice(0, idx) + marker + toggled.slice(idx + 3, toggled.len()))
        else:
            out.push(line)
    out.join("\n")

# --- Buffer content + motion dispatch (used by core controller) ---

fn md_editing_buffer_content(buffer: EditorBuffer) -> text:
    var content = ""
    var i = 0
    while i < buffer.line_count():
        if i > 0:
            content = content + "\n"
        content = content + buffer.line_at(i)
        i = i + 1
    content

fn md_dispatch_motion(prefix: text, key: text, content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    if prefix == "]" and key == "]":
        return md_vim_next_heading(content, cursor_line)
    if prefix == "[" and key == "[":
        return md_vim_prev_heading(content, cursor_line)
    if prefix == "]" and key == "h":
        return md_vim_next_sibling_heading(content, cursor_line)
    if prefix == "[" and key == "h":
        return md_vim_prev_sibling_heading(content, cursor_line)
    if prefix == "[" and key == "p":
        return md_vim_parent_heading(content, cursor_line)
    if prefix == "]" and key == "l":
        return md_vim_next_link(content, cursor_line, cursor_col)
    if prefix == "[" and key == "l":
        return md_vim_prev_link(content, cursor_line, cursor_col)
    if prefix == "]" and key == "c":
        return md_vim_next_code_block(content, cursor_line)
    if prefix == "[" and key == "c":
        return md_vim_prev_code_block(content, cursor_line)
    md_motion_none(cursor_line, cursor_col)

# --- Command dispatch glue ---

fn md_commands_dispatch(command_name: text, state: MdEditorState, content: text, cursor_line: i64, cursor_col: i64) -> MdCommandResult:
    var preview = state.preview_visible
    var outline = state.outline_visible
    if command_name == "markdown.togglePreview":
        preview = not preview
    if command_name == "markdown.toggleOutline":
        outline = not outline
    if command_name == "markdown.togglePreview":
        return _md_command_result(if preview then "Preview shown" else: "Preview hidden", "", "", 0, 0, preview, outline)
    if command_name == "markdown.toggleOutline":
        return _md_command_result(if outline then "Outline shown" else: "Outline hidden", "", "", 0, 0, preview, outline)
    if command_name == "markdown.insertTable":
        return _md_command_result("", "", "| Header 1 | Header 2 | Header 3 |\n| --- | --- | --- |\n|  |  |  |", 0, 2, preview, outline)
    if command_name == "markdown.insertLink":
        return _md_command_result("link inserted", "", "[text](url)", 0, 1, preview, outline)
    if command_name == "markdown.insertCodeBlock":
        return _md_command_result("code block inserted", "", "```\n\n```", 1, 0, preview, outline)
    if command_name == "markdown.toggleTask":
        val lines = content.split("\n")
        if cursor_line >= 0 and cursor_line < lines.len():
            val toggled = md_assist_toggle_task(lines[cursor_line])
            if toggled != lines[cursor_line]:
                return _md_command_result("task toggled", toggled, "", 0, 0, preview, outline)
        return _md_command_result("not a task", "", "", 0, 0, preview, outline)
    if command_name == "markdown.documentStats":
        return _md_command_result(_md_document_stats_message(content), "", "", 0, 0, preview, outline)
    _md_command_result(command_name, "", "", 0, 0, preview, outline)

fn md_command_result_state(result: MdCommandResult) -> MdEditorState:
    MdEditorState(preview_visible: result.preview_visible, outline_visible: result.outline_visible)

fn md_apply_result(buffer: EditorBuffer, result: MdCommandResult):
    if result.replace_line != "":
        val row = buffer.cursor_row
        val old_line = buffer.line_at(row)
        buffer.move_to_line_start()
        var i = 0
        while i < old_line.len():
            buffer.delete_at_cursor()
            i = i + 1
        buffer.insert_at_cursor(result.replace_line)
    if result.insert_text != "":
        buffer.insert_at_cursor(result.insert_text)
    if result.cursor_delta_line != 0 or result.cursor_delta_col != 0:
        buffer.move_relative(result.cursor_delta_line, result.cursor_delta_col)

fn _md_command_result(status: text, replace_line: text, insert_text: text, delta_line: i64, delta_col: i64, preview: bool, outline: bool) -> MdCommandResult:
    MdCommandResult(
        status_message: status,
        replace_line: replace_line,
        insert_text: insert_text,
        cursor_delta_line: delta_line,
        cursor_delta_col: delta_col,
        preview_visible: preview,
        outline_visible: outline
    )

fn _md_table_cells(line: text) -> [text]:
    var t = line.trim()
    if t.starts_with("|"):
        t = t.slice(1, t.len())
    if t.ends_with("|"):
        t = t.slice(0, t.len() - 1)
    val raw = t.split("|")
    var cells: [text] = []
    for cell in raw:
        cells.push(cell.trim())
    cells

fn _md_table_build_row(cells: [text], separator: bool) -> text:
    var out = "|"
    var i = 0
    while i < cells.len():
        val cell = if separator then "---" else: cells[i]
        out = out + " " + cell + " |"
        i = i + 1
    out

fn _md_table_insert_cell(cells: [text], index: i64, value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < cells.len():
        if i == index:
            out.push(value)
        out.push(cells[i])
        i = i + 1
    if index >= cells.len():
        out.push(value)
    out

fn _md_callout_header_line(lines: [text], cursor_line: i64) -> i64:
    if cursor_line < 0 or cursor_line >= lines.len():
        return -1
    var i = cursor_line
    while i >= 0:
        val trimmed = lines[i].trim_start()
        if trimmed.starts_with("> [!"):
            return i
        if not trimmed.starts_with(">"):
            return -1
        i = i - 1
    -1

fn _md_line_indent(line: text) -> text:
    var out = ""
    var i = 0
    while i < line.len() and line.char_at(i) == " ":
        out = out + " "
        i = i + 1
    out

fn _md_parse_i64(raw: text, fallback: i64) -> i64:
    var value: i64 = 0
    if raw.len() == 0:
        return fallback
    var i = 0
    while i < raw.len():
        val ch = raw.char_at(i)
        if ch < "0" or ch > "9":
            return fallback
        value = value * 10 + (raw.char_code_at(i) - "0".char_code_at(0))
        i = i + 1
    value

fn _md_heading_level(line: text) -> i64:
    var level = 0
    while level < line.len() and line.char_at(level) == "#":
        level = level + 1
    if level > 0 and level < line.len() and line.char_at(level) == " ":
        return level
    0

fn md_vim_next_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line + 1
    while i < lines.len():
        if _md_heading_level(lines[i]) > 0:
            return MdMotionResult(found: true, line: i, col: 0, message: "next heading")
        i = i + 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no next heading")

fn md_vim_prev_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line - 1
    while i >= 0:
        if _md_heading_level(lines[i]) > 0:
            return MdMotionResult(found: true, line: i, col: 0, message: "previous heading")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no previous heading")

fn _md_current_heading_level(lines: [text], cursor_line: i64) -> i64:
    var i = cursor_line
    while i >= 0:
        val level = _md_heading_level(lines[i])
        if level > 0:
            return level
        i = i - 1
    0

fn md_vim_next_sibling_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    val level = _md_current_heading_level(lines, cursor_line)
    if level == 0:
        return md_vim_next_heading(content, cursor_line)
    var i = cursor_line + 1
    while i < lines.len():
        val h = _md_heading_level(lines[i])
        if h == level:
            return MdMotionResult(found: true, line: i, col: 0, message: "next sibling heading")
        if h > 0 and h < level:
            return MdMotionResult(found: false, line: cursor_line, col: 0, message: "no next sibling heading")
        i = i + 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no next sibling heading")

fn md_vim_prev_sibling_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    val level = _md_current_heading_level(lines, cursor_line)
    if level == 0:
        return md_vim_prev_heading(content, cursor_line)
    var i = cursor_line - 1
    while i >= 0:
        val h = _md_heading_level(lines[i])
        if h == level:
            return MdMotionResult(found: true, line: i, col: 0, message: "previous sibling heading")
        if h > 0 and h < level:
            return MdMotionResult(found: false, line: cursor_line, col: 0, message: "no previous sibling heading")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no previous sibling heading")

fn md_vim_parent_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    val level = _md_current_heading_level(lines, cursor_line)
    var i = cursor_line - 1
    while i >= 0:
        val h = _md_heading_level(lines[i])
        if h > 0 and h < level:
            return MdMotionResult(found: true, line: i, col: 0, message: "parent heading")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no parent heading")

fn _md_line_has_link(line: text) -> bool:
    line.contains("](") or line.contains("[[")

fn _md_first_link_col(line: text) -> i64:
    val wiki = line.index_of("[[")
    val md = line.index_of("](")
    if wiki >= 0 and (md < 0 or wiki < md):
        return wiki
    if md >= 0:
        var i = md
        while i >= 0:
            if line.char_at(i) == "[":
                return i
            i = i - 1
        return md
    -1

fn md_vim_next_link(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line
    while i < lines.len():
        val col = _md_first_link_col(lines[i])
        if col >= 0 and (i > cursor_line or col > cursor_col):
            return MdMotionResult(found: true, line: i, col: col, message: "next link")
        i = i + 1
    MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "no next link")

fn md_vim_prev_link(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line
    while i >= 0:
        val col = _md_first_link_col(lines[i])
        if col >= 0 and (i < cursor_line or col < cursor_col):
            return MdMotionResult(found: true, line: i, col: col, message: "previous link")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: cursor_col, message: "no previous link")

fn md_vim_next_code_block(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line + 1
    while i < lines.len():
        if lines[i].trim_start().starts_with("```"):
            return MdMotionResult(found: true, line: i, col: 0, message: "next code block")
        i = i + 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no next code block")

fn md_vim_prev_code_block(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = content.split("\n")
    var i = cursor_line - 1
    while i >= 0:
        if lines[i].trim_start().starts_with("```"):
            return MdMotionResult(found: true, line: i, col: 0, message: "previous code block")
        i = i - 1
    MdMotionResult(found: false, line: cursor_line, col: 0, message: "no previous code block")

fn md_vim_open_link_under_cursor(content: text, cursor_line: i64, cursor_col: i64) -> text:
    val lines = content.split("\n")
    if cursor_line < 0 or cursor_line >= lines.len():
        return ""
    _md_link_target_at(lines[cursor_line], cursor_col)

fn _md_link_target_at(line: text, cursor_col: i64) -> text:
    val wiki_start = line.index_of("[[")
    if wiki_start >= 0:
        val wiki_end = line.index_of("]]")
        if wiki_end > wiki_start and cursor_col >= wiki_start and cursor_col <= wiki_end + 1:
            return line.slice(wiki_start + 2, wiki_end)
    val close_label = line.index_of("](")
    if close_label >= 0:
        var open_label = close_label
        while open_label >= 0 and line.char_at(open_label) != "[":
            open_label = open_label - 1
        val close_target = line.index_of(")")
        if open_label >= 0 and close_target > close_label and cursor_col >= open_label and cursor_col <= close_target:
            return line.slice(close_label + 2, close_target)
    ""

fn _md_document_stats_message(content: text) -> text:
    val lines = content.split("\n")
    var words = 0
    for line in lines:
        val trimmed = line.trim()
        val parts = trimmed.split(" ")
        for part in parts:
            if part.trim() != "":
                words = words + 1
    "Lines: " + lines.len().to_text() + " Words: ~" + words.to_text()
