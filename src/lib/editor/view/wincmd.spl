# Editor window-command dispatch for Ctrl+W style pane actions.

use std.editor.core.session.*
use std.editor.view.layout.*
use std.editor.view.split_tree.*
use std.editor.view.split_compute.{split_find_neighbor}

struct WincmdResult:
    handled: bool
    message: text
    quit: bool

fn wincmd_result_handled(result: WincmdResult) -> bool:
    result.handled

fn wincmd_result_message(result: WincmdResult) -> text:
    result.message

fn wincmd_result_quit(result: WincmdResult) -> bool:
    result.quit

fn wincmd_dispatch(session: EditSession, key: text, rects: [SplitRect]) -> WincmdResult:
    if key == "h":
        session.focus_direction("left", _wincmd_rect_ids(rects))
        return WincmdResult(handled: true, message: "focus left", quit: false)
    if key == "j":
        session.focus_direction("down", _wincmd_rect_ids(rects))
        return WincmdResult(handled: true, message: "focus down", quit: false)
    if key == "k":
        session.focus_direction("up", _wincmd_rect_ids(rects))
        return WincmdResult(handled: true, message: "focus up", quit: false)
    if key == "l":
        session.focus_direction("right", _wincmd_rect_ids(rects))
        return WincmdResult(handled: true, message: "focus right", quit: false)
    if key == "H" or key == "J" or key == "K" or key == "L":
        val direction = if key == "H" then "left" else: if key == "J" then "down" else: if key == "K" then "up" else: "right"
        val neighbor = split_find_neighbor(rects, session.layout.active_group_id, direction)
        session.layout.tree.swap(session.layout.active_group_id, neighbor)
        return WincmdResult(handled: true, message: "swap " + direction, quit: false)
    if key == "v":
        session.split_editor()
        return WincmdResult(handled: true, message: "split vertical", quit: false)
    if key == "s":
        session.split_editor_horizontal()
        return WincmdResult(handled: true, message: "split horizontal", quit: false)
    if key == "c" or key == "q":
        session.close_active_group()
        return WincmdResult(handled: true, message: "close", quit: false)
    if key == "o":
        session.close_other_groups()
        return WincmdResult(handled: true, message: "only", quit: false)
    if key == "+":
        session.layout.tree.resize(session.layout.active_group_id, 5)
        return WincmdResult(handled: true, message: "resize grow", quit: false)
    if key == "-":
        session.layout.tree.resize(session.layout.active_group_id, 0 - 5)
        return WincmdResult(handled: true, message: "resize shrink", quit: false)
    if key == "=":
        session.layout.tree.equalize()
        return WincmdResult(handled: true, message: "equalize", quit: false)
    WincmdResult(handled: false, message: "", quit: false)

fn _wincmd_rect_ids(rects: [SplitRect]) -> [i64]:
    var ids: [i64] = []
    for rect in rects:
        ids.push(rect.group_id)
    ids
