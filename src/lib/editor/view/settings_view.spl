# Editor Settings View — UI model for the settings/preferences panel.
#
# Provides: SettingsEntry, SettingsView, settings_view_new.

enum SettingKind:
    Toggle
    TextInput
    Select
    Keybinding

struct SettingsEntry:
    key: text
    label: text
    description: text
    kind: SettingKind
    value: text

struct SettingsView:
    title: text
    entries: [SettingsEntry]
    selected: i64
    scroll_offset: i64
    filter: text

struct SettingsViewState:
    title: text
    categories: [text]
    category_index: i64
    filtered: [SettingsEntry]
    selected_index: i64
    editing: bool
    edit_value: text

fn settings_view_new() -> SettingsView:
    SettingsView(title: "Settings", entries: [], selected: 0, scroll_offset: 0, filter: "")

fn settings_view_filter(view: SettingsView, query: text) -> SettingsView:
    SettingsView(title: view.title, entries: view.entries, selected: 0, scroll_offset: 0, filter: query)
