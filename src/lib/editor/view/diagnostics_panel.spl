# Editor Diagnostics Panel
#
# Displays compiler and LSP diagnostics in a panel.
# Supports filtering by severity/source, grouping, sorting, and navigation.

use std.editor.services.diagnostics.*

struct DiagnosticsPanelRow:
    icon: text
    label: text
    detail: text
    path: text
    line: i64
    col: i64

struct DiagnosticsPanel:
    title: text
    rows: [DiagnosticsPanelRow]
    selected: i64
    scroll_offset: i64

fn diagnostics_panel_new() -> DiagnosticsPanel:
    DiagnosticsPanel(title: "Problems", rows: [], selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store(store: DiagnosticStore) -> DiagnosticsPanel:
    var rows: [DiagnosticsPanelRow] = []
    for d in store.diagnostics:
        val icon = _diagnostics_panel_severity_icon(d.severity)
        rows.push(DiagnosticsPanelRow(
            icon: icon,
            label: d.message,
            detail: d.source,
            path: d.path,
            line: d.line,
            col: d.col
        ))
    DiagnosticsPanel(title: "Problems", rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_filtered(store: DiagnosticStore, severity: text, source: text) -> DiagnosticsPanel:
    var rows: [DiagnosticsPanelRow] = []
    for d in store.diagnostics:
        val sev_match = severity == "" or d.severity == severity
        val src_match = source == "" or d.source == source
        if sev_match and src_match:
            val icon = _diagnostics_panel_severity_icon(d.severity)
            rows.push(DiagnosticsPanelRow(
                icon: icon,
                label: d.message,
                detail: d.source,
                path: d.path,
                line: d.line,
                col: d.col
            ))
    if rows.len() == 0:
        rows.push(DiagnosticsPanelRow(icon: "ok", label: "No problems", detail: "", path: "", line: 0, col: 0))
    var title = "Problems (filtered)"
    if severity != "" and source != "":
        title = "Problems (" + severity + " " + source + ")"
    elif severity != "":
        title = "Problems (" + severity + ")"
    elif source != "":
        title = "Problems (" + source + ")"
    DiagnosticsPanel(title: title, rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_grouped(store: DiagnosticStore, group_by: text) -> DiagnosticsPanel:
    var rows: [DiagnosticsPanelRow] = []
    var groups: [text] = []
    for d in store.diagnostics:
        val group_key = if group_by == "source" then d.source elif group_by == "severity" then d.severity else: d.path
        if not _diagnostics_panel_text_list_contains(groups, group_key):
            groups.push(group_key)
    for group in groups:
        rows.push(DiagnosticsPanelRow(
            icon: "",
            label: group,
            detail: "",
            path: "",
            line: 0,
            col: 0
        ))
        for d in store.diagnostics:
            val group_key = if group_by == "source" then d.source elif group_by == "severity" then d.severity else: d.path
            if group_key != group:
                continue
            val icon = _diagnostics_panel_severity_icon(d.severity)
            rows.push(DiagnosticsPanelRow(
                icon: icon,
                label: d.message,
                detail: d.source,
                path: d.path,
                line: d.line,
                col: d.col
            ))
    DiagnosticsPanel(title: "Problems grouped by " + group_by, rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_sorted(store: DiagnosticStore, sort_by: text) -> DiagnosticsPanel:
    var remaining = store.diagnostics
    var rows: [DiagnosticsPanelRow] = []
    while remaining.len() > 0:
        var best = 0
        var i = 1
        while i < remaining.len():
            if _diagnostics_panel_diag_before(remaining[i], remaining[best], sort_by):
                best = i
            i = i + 1
        val d = remaining[best]
        rows.push(DiagnosticsPanelRow(
            icon: _diagnostics_panel_severity_icon(d.severity),
            label: d.message,
            detail: d.source,
            path: d.path,
            line: d.line,
            col: d.col
        ))
        var next: [EditorDiagnostic] = []
        i = 0
        while i < remaining.len():
            if i != best:
                next.push(remaining[i])
            i = i + 1
        remaining = next
    DiagnosticsPanel(title: "Problems sorted by " + sort_by, rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_select(panel: DiagnosticsPanel, index: i64) -> DiagnosticsPanel:
    var idx = index
    if idx < 0:
        idx = 0
    if panel.rows.len() > 0 and idx >= panel.rows.len():
        idx = panel.rows.len() - 1
    DiagnosticsPanel(
        title: panel.title,
        rows: panel.rows,
        selected: idx,
        scroll_offset: panel.scroll_offset
    )

fn diagnostics_panel_render(panel: DiagnosticsPanel, height: i64) -> [text]:
    var lines: [text] = []
    var i = panel.scroll_offset
    while i < panel.rows.len() and lines.len() < height:
        val row = panel.rows[i]
        val prefix = if i == panel.selected then "> " else: "  "
        val loc = if row.path != "" then row.path + ":" + (row.line + 1).to_text() else: ""
        val line = prefix + row.icon + " " + row.label + if loc != "" then "  " + loc else: ""
        lines.push(line)
        i = i + 1
    lines

fn diagnostics_panel_target_path(panel: DiagnosticsPanel) -> text:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return ""
    panel.rows[panel.selected].path

fn diagnostics_panel_target_line(panel: DiagnosticsPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return 0
    panel.rows[panel.selected].line

fn diagnostics_panel_target_col(panel: DiagnosticsPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return 0
    panel.rows[panel.selected].col

fn _diagnostics_panel_severity_icon(severity: text) -> text:
    match severity:
        "error" => "E"
        "warning" => "W"
        "information" => "I"
        "hint" => "H"
        _ => "?"

fn _diagnostics_panel_text_list_contains(items: [text], needle: text) -> bool:
    for item in items:
        if item == needle:
            return true
    false

fn _diagnostics_panel_diag_before(a: EditorDiagnostic, b: EditorDiagnostic, sort_by: text) -> bool:
    if sort_by == "path":
        if a.path != b.path:
            return false
        return a.line < b.line
    if sort_by == "source":
        if a.source != b.source:
            return a.source < b.source
        return _diagnostics_panel_severity_rank(a.severity) < _diagnostics_panel_severity_rank(b.severity)
    if _diagnostics_panel_severity_rank(a.severity) != _diagnostics_panel_severity_rank(b.severity):
        return _diagnostics_panel_severity_rank(a.severity) < _diagnostics_panel_severity_rank(b.severity)
    a.line < b.line

fn _diagnostics_panel_severity_rank(severity: text) -> i64:
    if severity == "error":
        return 0
    if severity == "warning":
        return 1
    if severity == "information":
        return 2
    if severity == "hint":
        return 3
    4
