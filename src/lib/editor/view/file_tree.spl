# Editor File Tree — hierarchical directory/file listing panel.
#
# Provides: FileTreeNode, FileTree, file_tree_new.

enum FileNodeKind:
    File
    Directory

struct FileTreeNode:
    name: text
    path: text
    kind: FileNodeKind
    expanded: bool
    children: [FileTreeNode]

struct FileTree:
    root: FileTreeNode
    selected_path: text
    scroll_offset: i64

fn file_tree_new(root_path: text) -> FileTree:
    FileTree(
        root: FileTreeNode(name: root_path, path: root_path, kind: FileNodeKind.Directory, expanded: true, children: []),
        selected_path: "",
        scroll_offset: 0)

fn file_tree_select(tree: FileTree, path: text) -> FileTree:
    FileTree(root: tree.root, selected_path: path, scroll_offset: tree.scroll_offset)

struct FileTreeVisibleNode:
    name: text
    path: text
    depth: i64
    is_dir: bool
    expanded: bool

struct FileTreeState:
    tree: FileTree
    selected_index: i64

impl FileTreeState:
    static fn new(root_path: text) -> FileTreeState:
        FileTreeState(tree: file_tree_new(root_path), selected_index: 0)

    fn visible_nodes() -> [FileTreeVisibleNode]:
        _ft_flatten(me.tree.root, 0)

    fn selected_is_dir() -> bool:
        val nodes = me.visible_nodes()
        if me.selected_index >= 0 and me.selected_index < nodes.len():
            val n = nodes[me.selected_index]
            return n.is_dir
        false

    fn selected_path() -> text:
        val nodes = me.visible_nodes()
        if me.selected_index >= 0 and me.selected_index < nodes.len():
            val n = nodes[me.selected_index]
            return n.path
        ""

    me select_next():
        val nodes = me.visible_nodes()
        if me.selected_index < nodes.len() - 1:
            me.selected_index = me.selected_index + 1

    me select_prev():
        if me.selected_index > 0:
            me.selected_index = me.selected_index - 1

    me toggle_expand():
        if me.selected_index == 0:
            val r = me.tree.root
            val newroot = FileTreeNode(name: r.name, path: r.path, kind: r.kind, expanded: not r.expanded, children: r.children)
            me.tree = FileTree(root: newroot, selected_path: me.tree.selected_path, scroll_offset: me.tree.scroll_offset)

fn _ft_flatten(node: FileTreeNode, depth: i64) -> [FileTreeVisibleNode]:
    val is_dir = node.kind == FileNodeKind.Directory
    var out: [FileTreeVisibleNode] = [FileTreeVisibleNode(name: node.name, path: node.path, depth: depth, is_dir: is_dir, expanded: node.expanded)]
    if node.expanded:
        for child in node.children:
            val sub = _ft_flatten(child, depth + 1)
            for vn in sub:
                out.push(vn)
    out
