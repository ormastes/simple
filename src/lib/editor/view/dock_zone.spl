# Editor Dock Zone — describes where a panel is docked within the editor layout.
#
# Provides: DockZone, DockPosition.

enum DockPosition:
    Left
    Right
    Bottom
    Top
    Center
    Float

struct DockZone:
    id: i64
    position: DockPosition
    size: i64
    visible: bool

fn dock_zone_new(id: i64, position: DockPosition) -> DockZone:
    DockZone(id: id, position: position, size: 250, visible: true)

fn dock_zone_toggle(zone: DockZone) -> DockZone:
    DockZone(id: zone.id, position: zone.position, size: zone.size, visible: not zone.visible)
