# Editor Markdown Preview Pane
#
# Live preview pane for Markdown files. Wraps a BlockModel and renders
# it via md_render_blocks_for_tui. Supports scroll sync that maps the
# source cursor line to a viewport offset in the rendered output.

use std.editor.services.md_wiki_index.*
use std.editor.render.md_renderer.*

struct PreviewPane:
    pane_id: i64
    source_pane_id: i64
    model: BlockModel
    wiki_index: MdWikiIndex
    viewport_start: i64
    scroll_sync: bool

fn preview_pane_create(source_pane_id: i64) -> PreviewPane:
    val model = BlockModel.from_markdown("")
    val wiki_index = md_wiki_index_documents([])
    PreviewPane(
        pane_id: source_pane_id + 1000,
        source_pane_id: source_pane_id,
        model: model,
        wiki_index: wiki_index,
        viewport_start: 0,
        scroll_sync: true
    )

fn preview_pane_update(pane: PreviewPane, content: text) -> PreviewPane:
    val new_model = BlockModel.from_markdown(content)
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: new_model,
        wiki_index: pane.wiki_index,
        viewport_start: pane.viewport_start,
        scroll_sync: pane.scroll_sync
    )

fn preview_pane_update_with_wiki(pane: PreviewPane, content: text, wiki_index: MdWikiIndex) -> PreviewPane:
    val new_model = BlockModel.from_markdown(content)
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: new_model,
        wiki_index: wiki_index,
        viewport_start: pane.viewport_start,
        scroll_sync: pane.scroll_sync
    )

fn preview_pane_update_for_cursor(pane: PreviewPane, content: text, source_cursor_line: i64) -> PreviewPane:
    preview_pane_update_with_wiki_for_cursor(pane, content, pane.wiki_index, source_cursor_line)

fn preview_pane_update_with_wiki_for_cursor(pane: PreviewPane, content: text, wiki_index: MdWikiIndex, source_cursor_line: i64) -> PreviewPane:
    var new_model = BlockModel.from_markdown(content)
    new_model.activate_block(new_model.block_for_line(source_cursor_line))
    val updated = PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: new_model,
        wiki_index: wiki_index,
        viewport_start: pane.viewport_start,
        scroll_sync: pane.scroll_sync
    )
    preview_pane_sync_scroll(updated, source_cursor_line)

fn preview_pane_render(pane: PreviewPane, height: i64) -> [text]:
    md_render_blocks_for_tui_with_wiki(pane.model, pane.wiki_index, pane.viewport_start, height)

fn preview_pane_render_for_editor(pane: PreviewPane, buffer: EditorBuffer, height: i64) -> [text]:
    if buffer == nil:
        return preview_pane_render(pane, height)
    var model = pane.model
    val active_idx = model.block_for_line(buffer.cursor_row_value())
    model.activate_block(active_idx)
    val rendered = md_render_blocks_for_tui_with_wiki(model, pane.wiki_index, pane.viewport_start, height)
    if active_idx < 0:
        return rendered
    val active_offset = preview_pane_source_line_to_render_line(pane, buffer.cursor_row_value()) - (buffer.cursor_row_value() - model.block_at(active_idx).from_line)
    var out: [text] = []
    var i = 0
    while i < rendered.len():
        val absolute_line = pane.viewport_start + i
        val source_row = model.block_at(active_idx).from_line + (absolute_line - active_offset)
        if source_row >= model.block_at(active_idx).from_line and source_row <= model.block_at(active_idx).to_line:
            out.push(_preview_pane_mark_source_line(rendered[i], buffer, source_row))
        else:
            out.push(rendered[i])
        i = i + 1
    out

fn preview_pane_source_line_to_render_line(pane: PreviewPane, source_line: i64) -> i64:
    val block_idx = pane.model.block_for_line(source_line)
    if block_idx < 0:
        return -1
    var offset = 0
    var i = 0
    while i < block_idx:
        offset = offset + render_block_line_span(pane.model.block_at(i))
        i = i + 1
    offset + (source_line - pane.model.block_at(block_idx).from_line)

fn _preview_pane_mark_source_line(line: text, buffer: EditorBuffer, source_row: i64) -> text:
    var out = ""
    var marked = false
    var i = 0
    while i < line.len():
        val selected = buffer.position_selected(source_row, i)
        val cursor = source_row == buffer.cursor_row_value() and i == buffer.cursor_col_value()
        val highlight = selected or cursor
        if highlight and not marked:
            out = out + "\x1b[7m"
            marked = true
        elif marked and not highlight:
            out = out + "\x1b[0m"
            marked = false
        out = out + line.char_at(i)
        i = i + 1
    if source_row == buffer.cursor_row_value() and buffer.cursor_col_value() >= line.len():
        if not marked:
            out = out + "\x1b[7m"
        out = out + " "
        marked = true
    if marked:
        out = out + "\x1b[0m"
    out

fn preview_pane_sync_scroll(pane: PreviewPane, source_cursor_line: i64) -> PreviewPane:
    if not pane.scroll_sync:
        return pane
    val block_idx = pane.model.block_for_line(source_cursor_line)
    var offset = 0
    if block_idx > 0:
        var i = 0
        while i < block_idx:
            val block = pane.model.block_at(i)
            offset = offset + render_block_line_span(block)
            i = i + 1
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        wiki_index: pane.wiki_index,
        viewport_start: offset,
        scroll_sync: pane.scroll_sync
    )

fn preview_pane_toggle_scroll_sync(pane: PreviewPane) -> PreviewPane:
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        wiki_index: pane.wiki_index,
        viewport_start: pane.viewport_start,
        scroll_sync: not pane.scroll_sync
    )

fn preview_pane_scroll(pane: PreviewPane, delta: i64, max_lines: i64) -> PreviewPane:
    var new_start = pane.viewport_start + delta
    if new_start < 0:
        new_start = 0
    if new_start >= max_lines:
        new_start = max_lines - 1
    if new_start < 0:
        new_start = 0
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        wiki_index: pane.wiki_index,
        viewport_start: new_start,
        scroll_sync: pane.scroll_sync
    )
