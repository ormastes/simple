# Editor Undo Stack
#
# Snapshot-based undo/redo. Each entry captures full text + cursor position.

struct UndoEntry:
    content: text
    cursor_row: i64
    cursor_col: i64

class UndoStack:
    undo_entries: [UndoEntry]
    redo_entries: [UndoEntry]
    max_depth: i64

impl UndoStack:

    static fn new() -> UndoStack:
        UndoStack(undo_entries: [], redo_entries: [], max_depth: 64)

    me push(content: text, cursor_row: i64, cursor_col: i64):
        self.undo_entries.push(UndoEntry(
            content: content,
            cursor_row: cursor_row,
            cursor_col: cursor_col
        ))
        self.redo_entries = []
        if self.undo_entries.len() > self.max_depth:
            self.undo_entries = _undo_trim(self.undo_entries)

    fn can_undo() -> bool:
        self.undo_entries.len() > 0

    fn can_redo() -> bool:
        self.redo_entries.len() > 0

    me undo(current_content: text, current_row: i64, current_col: i64) -> UndoEntry:
        if self.undo_entries.len() == 0:
            return UndoEntry(content: current_content, cursor_row: current_row, cursor_col: current_col)
        self.redo_entries.push(UndoEntry(
            content: current_content,
            cursor_row: current_row,
            cursor_col: current_col
        ))
        val last = self.undo_entries[self.undo_entries.len() - 1]
        self.undo_entries = _undo_drop_last(self.undo_entries)
        last

    me redo(current_content: text, current_row: i64, current_col: i64) -> UndoEntry:
        if self.redo_entries.len() == 0:
            return UndoEntry(content: current_content, cursor_row: current_row, cursor_col: current_col)
        self.undo_entries.push(UndoEntry(
            content: current_content,
            cursor_row: current_row,
            cursor_col: current_col
        ))
        val last = self.redo_entries[self.redo_entries.len() - 1]
        self.redo_entries = _undo_drop_last(self.redo_entries)
        last


fn _undo_trim(items: [UndoEntry]) -> [UndoEntry]:
    var out: [UndoEntry] = []
    var i = 1
    while i < items.len():
        out.push(items[i])
        i = i + 1
    out

fn _undo_drop_last(items: [UndoEntry]) -> [UndoEntry]:
    var out: [UndoEntry] = []
    var i = 0
    while i + 1 < items.len():
        out.push(items[i])
        i = i + 1
    out
