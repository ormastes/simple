# Editor Diagnostics Panel
#
# Displays compiler and LSP diagnostics in a panel.
# Supports filtering by severity/source, grouping, sorting, and navigation.

use std.editor.services.diagnostics.*

struct DiagnosticsPanelRow:
    icon: text
    label: text
    detail: text
    path: text
    line: i64
    col: i64

struct DiagnosticsPanel:
    title: text
    rows: [DiagnosticsPanelRow]
    selected: i64
    scroll_offset: i64

fn diagnostics_panel_new() -> DiagnosticsPanel:
    DiagnosticsPanel(title: "Problems", rows: [], selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store(store: DiagnosticStore) -> DiagnosticsPanel:
    var rows: [DiagnosticsPanelRow] = []
    for d in store.diagnostics:
        val icon = _diagnostics_panel_severity_icon(d.severity)
        rows.push(DiagnosticsPanelRow(
            icon: icon,
            label: d.message,
            detail: d.source,
            path: d.path,
            line: d.line,
            col: d.col
        ))
    DiagnosticsPanel(title: "Problems", rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_filtered(store: DiagnosticStore, severity: text, source: text) -> DiagnosticsPanel:
    var rows: [DiagnosticsPanelRow] = []
    for d in store.diagnostics:
        val sev_match = severity == "" or d.severity == severity
        val src_match = source == "" or d.source == source
        if sev_match and src_match:
            val icon = _diagnostics_panel_severity_icon(d.severity)
            rows.push(DiagnosticsPanelRow(
                icon: icon,
                label: d.message,
                detail: d.source,
                path: d.path,
                line: d.line,
                col: d.col
            ))
    DiagnosticsPanel(title: "Problems (filtered)", rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_grouped(store: DiagnosticStore, group_by: text) -> DiagnosticsPanel:
    # Group diagnostics by path (group_by="file") or severity (group_by="severity")
    # For now, fall back to flat view with group headers prepended
    var rows: [DiagnosticsPanelRow] = []
    var last_group = ""
    for d in store.diagnostics:
        val group_key = if group_by == "severity": d.severity else: d.path
        if group_key != last_group:
            rows.push(DiagnosticsPanelRow(
                icon: "",
                label: group_key,
                detail: "",
                path: d.path,
                line: 0,
                col: 0
            ))
            last_group = group_key
        val icon = _diagnostics_panel_severity_icon(d.severity)
        rows.push(DiagnosticsPanelRow(
            icon: icon,
            label: d.message,
            detail: d.source,
            path: d.path,
            line: d.line,
            col: d.col
        ))
    DiagnosticsPanel(title: "Problems (grouped by {group_by})", rows: rows, selected: 0, scroll_offset: 0)

fn diagnostics_panel_from_store_sorted(store: DiagnosticStore, sort_by: text) -> DiagnosticsPanel:
    # Sorting requires reordering; return flat panel for now (sort not yet implemented)
    diagnostics_panel_from_store(store)

fn diagnostics_panel_select(panel: DiagnosticsPanel, index: i64) -> DiagnosticsPanel:
    var idx = index
    if idx < 0:
        idx = 0
    if panel.rows.len() > 0 and idx >= panel.rows.len():
        idx = panel.rows.len() - 1
    DiagnosticsPanel(
        title: panel.title,
        rows: panel.rows,
        selected: idx,
        scroll_offset: panel.scroll_offset
    )

fn diagnostics_panel_render(panel: DiagnosticsPanel, height: i64) -> [text]:
    var lines: [text] = []
    var i = panel.scroll_offset
    while i < panel.rows.len() and lines.len() < height:
        val row = panel.rows[i]
        val prefix = if i == panel.selected then "> " else: "  "
        val loc = if row.path != "" then row.path + ":" + (row.line + 1).to_text() else: ""
        val line = prefix + row.icon + " " + row.label + if loc != "" then "  " + loc else: ""
        lines.push(line)
        i = i + 1
    lines

fn diagnostics_panel_target_path(panel: DiagnosticsPanel) -> text:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return ""
    panel.rows[panel.selected].path

fn diagnostics_panel_target_line(panel: DiagnosticsPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return 0
    panel.rows[panel.selected].line

fn diagnostics_panel_target_col(panel: DiagnosticsPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.rows.len():
        return 0
    panel.rows[panel.selected].col

fn _diagnostics_panel_severity_icon(severity: text) -> text:
    match severity:
        "error" => "E"
        "warning" => "W"
        "information" => "I"
        "hint" => "H"
        _ => "?"
