# Outline Panel
#
# Displays a heading tree extracted from markdown content.
# Supports selection, navigation, scrolling, and visibility toggle.
# All state changes return new structs (no mutation).

struct OutlineEntry:
    level: i64
    title: text
    line: i64

struct OutlinePanel:
    entries: [OutlineEntry]
    selected: i64
    scroll_offset: i64
    visible: bool

fn outline_panel_new() -> OutlinePanel:
    OutlinePanel(
        entries: [],
        selected: 0,
        scroll_offset: 0,
        visible: true
    )

# Scan lines for heading markers, tracking fenced-code state to avoid
# treating `#` inside code blocks as headings.
fn _op_extract_entries(lines: array) -> [OutlineEntry]:
    var entries: [OutlineEntry] = []
    var in_fence = false
    var line_idx = 0
    var total = lines.length()
    while line_idx < total:
        val raw = lines.get(line_idx)
        val trimmed = trim(raw)
        if starts_with(trimmed, "```") or starts_with(trimmed, "~~~"):
            in_fence = not in_fence
            line_idx = line_idx + 1
        else:
            if not in_fence:
                val level = _op_heading_level(trimmed)
                if level > 0:
                    val title = _op_heading_text(trimmed, level)
                    entries.push(OutlineEntry(level: level, title: title, line: line_idx))
            line_idx = line_idx + 1
    entries

# Count leading `#` chars; returns 0 if not a heading line.
fn _op_heading_level(line: text) -> i64:
    var count = 0
    var i = 0
    var len = line.length()
    while i < len and line.char_at(i) == "#":
        count = count + 1
        i = i + 1
    if count == 0:
        return 0
    if count > 6:
        return 0
    if i >= len:
        return 0
    val after = line.char_at(i)
    if after != " ":
        return 0
    count

# Extract plain text after the `# ` prefix.
fn _op_heading_text(line: text, level: i64) -> text:
    val skip = level + 1
    if skip >= line.length():
        return ""
    line.substring(skip, line.length())

fn outline_panel_update(panel: OutlinePanel, content: text) -> OutlinePanel:
    val lines = split_lines(content)
    val entries = _op_extract_entries(lines)
    var new_selected = panel.selected
    var new_scroll = panel.scroll_offset
    val count = entries.length()
    if new_selected >= count:
        if count > 0:
            new_selected = count - 1
        else:
            new_selected = 0
    if new_scroll >= count:
        if count > 0:
            new_scroll = count - 1
        else:
            new_scroll = 0
    OutlinePanel(
        entries: entries,
        selected: new_selected,
        scroll_offset: new_scroll,
        visible: panel.visible
    )

# Build indented prefix: h1 = "", h2 = "  ", h3 = "    ", etc.
fn _op_indent(level: i64) -> text:
    var spaces = ""
    var i = 1
    while i < level:
        spaces = spaces + "  "
        i = i + 1
    spaces

fn outline_panel_render(panel: OutlinePanel, height: i64) -> [text]:
    var lines: [text] = []
    if not panel.visible:
        return lines
    val count = panel.entries.length()
    var i = panel.scroll_offset
    var rendered = 0
    while i < count and rendered < height:
        val entry = panel.entries.get(i)
        val indent = _op_indent(entry.level)
        var prefix = "  "
        if i == panel.selected:
            prefix = "> "
        val row = prefix + indent + entry.title
        lines.push(row)
        i = i + 1
        rendered = rendered + 1
    lines

fn outline_panel_select(panel: OutlinePanel, index: i64) -> OutlinePanel:
    val count = panel.entries.length()
    var clamped = index
    if clamped < 0:
        clamped = 0
    if clamped >= count:
        if count > 0:
            clamped = count - 1
        else:
            clamped = 0
    OutlinePanel(
        entries: panel.entries,
        selected: clamped,
        scroll_offset: panel.scroll_offset,
        visible: panel.visible
    )

fn outline_panel_target_line(panel: OutlinePanel) -> i64:
    val count = panel.entries.length()
    if count == 0:
        return 0
    if panel.selected < 0 or panel.selected >= count:
        return 0
    val entry = panel.entries.get(panel.selected)
    entry.line

fn outline_panel_navigate(panel: OutlinePanel, delta: i64) -> OutlinePanel:
    val count = panel.entries.length()
    if count == 0:
        return panel
    var new_idx = panel.selected + delta
    if new_idx < 0:
        new_idx = 0
    if new_idx >= count:
        new_idx = count - 1
    # Adjust scroll so selected stays in view; caller must pass height context.
    # Here we just update the index and let the render clip.
    OutlinePanel(
        entries: panel.entries,
        selected: new_idx,
        scroll_offset: panel.scroll_offset,
        visible: panel.visible
    )

fn outline_panel_toggle(panel: OutlinePanel) -> OutlinePanel:
    OutlinePanel(
        entries: panel.entries,
        selected: panel.selected,
        scroll_offset: panel.scroll_offset,
        visible: not panel.visible
    )
