# Wincmd Dispatch
#
# Ctrl+W window-command handler. Translates a sub-key into
# focus, split, resize, swap, or close operations on the session.

struct WincmdResult:
    handled: bool
    message: text
    quit: bool

fn wincmd_ok(msg: text) -> WincmdResult:
    WincmdResult(handled: true, message: msg, quit: false)

fn wincmd_quit() -> WincmdResult:
    WincmdResult(handled: true, message: "quit", quit: true)

fn wincmd_ignored() -> WincmdResult:
    WincmdResult(handled: false, message: "", quit: false)

fn wincmd_dispatch(session: EditSession, key: text, rects: [SplitRect]) -> WincmdResult:
    # Focus direction: h/j/k/l
    if key == "h":
        session.focus_direction("left", rects)
        return wincmd_ok("focus left")
    if key == "j":
        session.focus_direction("down", rects)
        return wincmd_ok("focus down")
    if key == "k":
        session.focus_direction("up", rects)
        return wincmd_ok("focus up")
    if key == "l":
        session.focus_direction("right", rects)
        return wincmd_ok("focus right")

    # Move window (swap): H/J/K/L
    if key == "H":
        val left_id = split_find_neighbor(rects, session.layout.active_group_id, "left")
        if left_id >= 0:
            session.layout.tree.swap(session.layout.active_group_id, left_id)
        return wincmd_ok("move left")
    if key == "J":
        val down_id = split_find_neighbor(rects, session.layout.active_group_id, "down")
        if down_id >= 0:
            session.layout.tree.swap(session.layout.active_group_id, down_id)
        return wincmd_ok("move down")
    if key == "K":
        val up_id = split_find_neighbor(rects, session.layout.active_group_id, "up")
        if up_id >= 0:
            session.layout.tree.swap(session.layout.active_group_id, up_id)
        return wincmd_ok("move up")
    if key == "L":
        val right_id = split_find_neighbor(rects, session.layout.active_group_id, "right")
        if right_id >= 0:
            session.layout.tree.swap(session.layout.active_group_id, right_id)
        return wincmd_ok("move right")

    # Split: v = vertical, s = horizontal
    if key == "v":
        session.split_editor()
        return wincmd_ok("split vertical")
    if key == "s":
        session.split_editor_horizontal()
        return wincmd_ok("split horizontal")

    # Close: c/q = close active group
    if key == "c":
        session.close_active_group()
        return wincmd_ok("close group")
    if key == "q":
        val count = session.group_count()
        if count <= 1:
            return wincmd_quit()
        session.close_active_group()
        return wincmd_ok("close group")

    # Only: o = close all other groups
    if key == "o":
        session.close_other_groups()
        return wincmd_ok("only")

    # Resize: +/- = grow/shrink, = = equalize
    if key == "+":
        session.layout.tree.resize(session.layout.active_group_id, 5)
        return wincmd_ok("resize grow")
    if key == "-":
        session.layout.tree.resize(session.layout.active_group_id, 0 - 5)
        return wincmd_ok("resize shrink")
    if key == "=":
        session.layout.tree.equalize()
        return wincmd_ok("equalize")

    wincmd_ignored()
