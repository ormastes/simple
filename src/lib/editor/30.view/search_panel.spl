# Editor Search Panel
#
# Find-in-files panel with query input and match display.

struct SearchPanelMatch:
    path: text
    line: i64
    col: i64
    text: text

struct SearchPanel:
    query: text
    matches: [SearchPanelMatch]
    selected: i64
    active: bool

fn search_panel_new() -> SearchPanel:
    SearchPanel(query: "", matches: [], selected: 0, active: false)

fn search_panel_with_query(query: text, matches: [SearchPanelMatch]) -> SearchPanel:
    SearchPanel(query: query, matches: matches, selected: 0, active: true)

fn search_panel_select(panel: SearchPanel, index: i64) -> SearchPanel:
    var idx = index
    if idx < 0:
        idx = 0
    if panel.matches.len() > 0 and idx >= panel.matches.len():
        idx = panel.matches.len() - 1
    SearchPanel(query: panel.query, matches: panel.matches, selected: idx, active: panel.active)

fn search_panel_render(panel: SearchPanel, height: i64) -> [text]:
    var lines: [text] = []
    lines.push("Search: " + panel.query)
    var i = 0
    while i < panel.matches.len() and lines.len() < height:
        val m = panel.matches[i]
        val prefix = if i == panel.selected then "> " else: "  "
        lines.push(prefix + m.path + ":" + (m.line + 1).to_text() + "  " + m.text)
        i = i + 1
    lines

fn search_panel_target_path(panel: SearchPanel) -> text:
    if panel.selected < 0 or panel.selected >= panel.matches.len():
        return ""
    panel.matches[panel.selected].path

fn search_panel_target_line(panel: SearchPanel) -> i64:
    if panel.selected < 0 or panel.selected >= panel.matches.len():
        return 0
    panel.matches[panel.selected].line
