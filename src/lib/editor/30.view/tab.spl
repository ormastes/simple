# Editor Tab and Group
#
# EditorTab references a document by ID (not directly).
# EditorGroup holds a list of tabs with an active index.
# Multiple tabs can reference the same document (split view of same file).

class EditorTabId:
    value: i64

class EditorGroupId:
    value: i64

struct EditorTab:
    id: EditorTabId
    doc_id: EditorDocumentId
    label: text
    is_preview: bool

struct EditorGroup:
    id: EditorGroupId
    tabs: [EditorTab]
    active_tab_index: i64
    viewport: EditorViewport

impl EditorGroup:

    static fn new(id: EditorGroupId) -> EditorGroup:
        EditorGroup(
            id: id,
            tabs: [],
            active_tab_index: -1,
            viewport: EditorViewport(top_row: 0, left_col: 0, width: 80, height: 24)
        )

    fn active_tab() -> EditorTab:
        if self.active_tab_index < 0 or self.active_tab_index >= self.tabs.len():
            return EditorTab(id: EditorTabId(value: 0), doc_id: EditorDocumentId(value: 0), label: "", is_preview: false)
        self.tabs[self.active_tab_index]

    fn tab_count() -> i64:
        self.tabs.len()

    me add_tab(tab: EditorTab):
        var existing_idx = -1
        var i = 0
        while i < self.tabs.len():
            if self.tabs[i].doc_id.value == tab.doc_id.value:
                existing_idx = i
                break
            i = i + 1
        if existing_idx >= 0:
            self.active_tab_index = existing_idx
        else:
            self.tabs.push(tab)
            self.active_tab_index = self.tabs.len() - 1

    me close_tab(index: i64):
        if index < 0 or index >= self.tabs.len():
            return
        var new_tabs: [EditorTab] = []
        var i = 0
        while i < self.tabs.len():
            if i != index:
                new_tabs.push(self.tabs[i])
            i = i + 1
        self.tabs = new_tabs
        if self.active_tab_index >= self.tabs.len():
            self.active_tab_index = self.tabs.len() - 1

    me select_tab(index: i64):
        if index >= 0 and index < self.tabs.len():
            self.active_tab_index = index

    me next_tab():
        if self.tabs.len() == 0:
            return
        self.active_tab_index = (self.active_tab_index + 1) % self.tabs.len()

    me prev_tab():
        if self.tabs.len() == 0:
            return
        self.active_tab_index = (self.active_tab_index - 1 + self.tabs.len()) % self.tabs.len()
