# Editor Layout
#
# Manages split pane layout. An EditorLayout holds multiple EditorGroups
# arranged horizontally or vertically.

struct EditorLayout:
    groups: [EditorGroup]
    active_group_index: i64
    split_direction: text

fn editor_layout_new() -> EditorLayout:
    val group = EditorGroup.new(EditorGroupId(value: 1))
    EditorLayout(
        groups: [group],
        active_group_index: 0,
        split_direction: "horizontal"
    )

fn editor_layout_active_group(layout: EditorLayout) -> EditorGroup:
    if layout.active_group_index < 0 or layout.active_group_index >= layout.groups.len():
        return EditorGroup.new(EditorGroupId(value: 0))
    layout.groups[layout.active_group_index]

fn editor_layout_split(layout: EditorLayout, next_group_id: i64) -> EditorLayout:
    var groups = layout.groups
    val new_group = EditorGroup.new(EditorGroupId(value: next_group_id))
    groups.push(new_group)
    EditorLayout(
        groups: groups,
        active_group_index: groups.len() - 1,
        split_direction: layout.split_direction
    )

fn editor_layout_close_group(layout: EditorLayout, index: i64) -> EditorLayout:
    if layout.groups.len() <= 1 or index < 0 or index >= layout.groups.len():
        return layout
    var new_groups: [EditorGroup] = []
    var i = 0
    while i < layout.groups.len():
        if i != index:
            new_groups.push(layout.groups[i])
        i = i + 1
    var active = layout.active_group_index
    if active >= new_groups.len():
        active = new_groups.len() - 1
    EditorLayout(
        groups: new_groups,
        active_group_index: active,
        split_direction: layout.split_direction
    )

fn editor_layout_focus_group(layout: EditorLayout, index: i64) -> EditorLayout:
    if index < 0 or index >= layout.groups.len():
        return layout
    EditorLayout(
        groups: layout.groups,
        active_group_index: index,
        split_direction: layout.split_direction
    )

fn editor_layout_focus_next(layout: EditorLayout) -> EditorLayout:
    if layout.groups.len() == 0:
        return layout
    val next = (layout.active_group_index + 1) % layout.groups.len()
    editor_layout_focus_group(layout, next)

fn editor_layout_focus_prev(layout: EditorLayout) -> EditorLayout:
    if layout.groups.len() == 0:
        return layout
    val prev = (layout.active_group_index - 1 + layout.groups.len()) % layout.groups.len()
    editor_layout_focus_group(layout, prev)

fn editor_layout_group_count(layout: EditorLayout) -> i64:
    layout.groups.len()
