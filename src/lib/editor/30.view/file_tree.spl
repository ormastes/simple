# Editor File Tree
#
# File browser sidebar with expand/collapse navigation.
# Uses rt_dir_list for directory listing.

extern fn rt_dir_list(path: text) -> [text]

struct FileTreeNode:
    path: text
    name: text
    is_dir: bool
    depth: i64
    expanded: bool
    children: [FileTreeNode]

class FileTreeState:
    root_path: text
    nodes: [FileTreeNode]
    selected_index: i64
    visible_count: i64

impl FileTreeState:

    static fn new(root_path: text) -> FileTreeState:
        var state = FileTreeState(
            root_path: root_path,
            nodes: [],
            selected_index: 0,
            visible_count: 0
        )
        state.refresh()
        state

    me refresh():
        self.nodes = _ft_list_dir(self.root_path, 0)
        self.visible_count = _ft_count_visible(self.nodes)

    me select_next():
        if self.selected_index < self.visible_count - 1:
            self.selected_index = self.selected_index + 1

    me select_prev():
        if self.selected_index > 0:
            self.selected_index = self.selected_index - 1

    me toggle_expand():
        val node = _ft_get_visible_node(self.nodes, self.selected_index)
        if node.is_dir:
            self.nodes = _ft_toggle_at(self.nodes, self.selected_index)
            self.visible_count = _ft_count_visible(self.nodes)

    fn selected_path() -> text:
        val node = _ft_get_visible_node(self.nodes, self.selected_index)
        node.path

    fn selected_is_dir() -> bool:
        val node = _ft_get_visible_node(self.nodes, self.selected_index)
        node.is_dir

    fn visible_nodes() -> [FileTreeNode]:
        _ft_collect_visible(self.nodes)


fn _ft_list_dir(path: text, depth: i64) -> [FileTreeNode]:
    val entries = rt_dir_list(path) ?? []
    var nodes: [FileTreeNode] = []
    var dirs: [FileTreeNode] = []
    var files: [FileTreeNode] = []
    for entry in entries:
        if entry == "." or entry == ".." or entry == ".git":
            continue
        val full_path = path + "/" + entry
        val is_dir = _ft_is_dir_heuristic(entry)
        val node = FileTreeNode(
            path: full_path,
            name: entry,
            is_dir: is_dir,
            depth: depth,
            expanded: false,
            children: []
        )
        if is_dir:
            dirs.push(node)
        else:
            files.push(node)
    for d in dirs:
        nodes.push(d)
    for f in files:
        nodes.push(f)
    nodes

fn _ft_is_dir_heuristic(name: text) -> bool:
    var i = 0
    while i < name.len():
        if name.char_at(i) == ".":
            return false
        i = i + 1
    true

fn _ft_count_visible(nodes: [FileTreeNode]) -> i64:
    var count = 0
    for node in nodes:
        count = count + 1
        if node.expanded:
            count = count + _ft_count_visible(node.children)
    count

fn _ft_collect_visible(nodes: [FileTreeNode]) -> [FileTreeNode]:
    var result: [FileTreeNode] = []
    for node in nodes:
        result.push(node)
        if node.expanded:
            val children = _ft_collect_visible(node.children)
            for child in children:
                result.push(child)
    result

fn _ft_get_visible_node(nodes: [FileTreeNode], target_index: i64) -> FileTreeNode:
    val visible = _ft_collect_visible(nodes)
    if target_index >= 0 and target_index < visible.len():
        return visible[target_index]
    FileTreeNode(path: "", name: "", is_dir: false, depth: 0, expanded: false, children: [])

fn _ft_toggle_at(nodes: [FileTreeNode], target_index: i64) -> [FileTreeNode]:
    var result: [FileTreeNode] = []
    var counter = 0
    for node in nodes:
        if counter == target_index:
            var toggled = node
            if toggled.expanded:
                toggled.expanded = false
                toggled.children = []
            else:
                toggled.expanded = true
                toggled.children = _ft_list_dir(toggled.path, toggled.depth + 1)
            result.push(toggled)
        else:
            if node.expanded:
                var updated = node
                val sub_count = _ft_count_visible(node.children)
                if target_index > counter and target_index <= counter + sub_count:
                    updated.children = _ft_toggle_at(node.children, target_index - counter - 1)
                result.push(updated)
            else:
                result.push(node)
        counter = counter + 1
        if node.expanded:
            counter = counter + _ft_count_visible(node.children)
    result
