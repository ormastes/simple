# Editor AI Panel
#
# AI assistant panel for in-editor code completion, explanation,
# and refactoring suggestions.

struct AiPanelMessage:
    role: text
    content: text

struct AiPanel:
    title: text
    messages: [AiPanelMessage]
    input: text
    active: bool
    loading: bool

fn ai_panel_new() -> AiPanel:
    AiPanel(
        title: "AI Assistant",
        messages: [],
        input: "",
        active: false,
        loading: false
    )

fn ai_panel_append(panel: AiPanel, role: text, content: text) -> AiPanel:
    var new_messages = panel.messages
    new_messages.push(AiPanelMessage(role: role, content: content))
    AiPanel(
        title: panel.title,
        messages: new_messages,
        input: panel.input,
        active: panel.active,
        loading: false
    )

fn ai_panel_render(panel: AiPanel, height: i64) -> [text]:
    var lines: [text] = []
    for msg in panel.messages:
        val prefix = if msg.role == "user" then "You: " else: "AI: "
        lines.push(prefix + msg.content)
    if panel.loading:
        lines.push("...")
    lines.push("> " + panel.input)
    lines
