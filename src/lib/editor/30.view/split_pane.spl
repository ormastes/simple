# Split Pane Layout
#
# Higher-level split management built on existing SplitTree.
# Uses PaneNode (tagged struct) to avoid collision with SplitNode in split_tree.spl.

val PANE_LEAF: i64 = 0
val PANE_BRANCH: i64 = 1
val PANE_DIR_HORIZONTAL: i64 = 0
val PANE_DIR_VERTICAL: i64 = 1

enum SplitDirection:
    Horizontal
    Vertical

struct PaneNode:
    kind: i64
    pane_id: i64
    buffer_id_value: i64
    direction: i64
    ratio: i64
    left_id: i64
    right_id: i64

fn _pane_node_leaf(pane_id: i64) -> PaneNode:
    PaneNode(kind: PANE_LEAF, pane_id: pane_id, buffer_id_value: -1,
             direction: 0, ratio: 50, left_id: -1, right_id: -1)

fn _pane_node_branch(direction: i64, left_id: i64, right_id: i64) -> PaneNode:
    PaneNode(kind: PANE_BRANCH, pane_id: -1, buffer_id_value: -1,
             direction: direction, ratio: 50, left_id: left_id, right_id: right_id)

struct SplitPaneLayout:
    nodes: [PaneNode]
    root_id: i64
    active_pane_id: i64
    pane_counter: i64

fn split_pane_create() -> SplitPaneLayout:
    val root = _pane_node_leaf(1)
    SplitPaneLayout(nodes: [root], root_id: 0, active_pane_id: 1, pane_counter: 2)

fn split_pane_split(layout: SplitPaneLayout, direction: SplitDirection) -> i64:
    val dir_val = match direction:
        SplitDirection.Horizontal => PANE_DIR_HORIZONTAL
        SplitDirection.Vertical   => PANE_DIR_VERTICAL
    val leaf_idx = _pane_find_leaf(layout, layout.active_pane_id)
    if leaf_idx < 0:
        return -1
    val old_leaf = layout.nodes[leaf_idx]
    val left_id = layout.nodes.len()
    layout.nodes.push(_pane_node_leaf(old_leaf.pane_id))
    val new_pane_id = layout.pane_counter
    layout.pane_counter = layout.pane_counter + 1
    val right_id = layout.nodes.len()
    layout.nodes.push(_pane_node_leaf(new_pane_id))
    layout.nodes[leaf_idx] = _pane_node_branch(dir_val, left_id, right_id)
    layout.active_pane_id = new_pane_id
    new_pane_id

fn split_pane_close(layout: SplitPaneLayout, pane_id: i64) -> bool:
    if _pane_leaf_count(layout) <= 1:
        return false
    val leaf_idx = _pane_find_leaf(layout, pane_id)
    if leaf_idx < 0:
        return false
    val parent_idx = _pane_find_parent(layout, leaf_idx)
    if parent_idx < 0:
        return false
    val parent = layout.nodes[parent_idx]
    val sibling_idx = if parent.left_id == leaf_idx then parent.right_id else: parent.left_id
    val sibling = layout.nodes[sibling_idx]
    layout.nodes[parent_idx] = PaneNode(
        kind: sibling.kind,
        pane_id: sibling.pane_id,
        buffer_id_value: sibling.buffer_id_value,
        direction: sibling.direction,
        ratio: sibling.ratio,
        left_id: sibling.left_id,
        right_id: sibling.right_id
    )
    if layout.active_pane_id == pane_id:
        layout.active_pane_id = sibling.pane_id
    true

fn split_pane_focus(layout: SplitPaneLayout, pane_id: i64):
    val idx = _pane_find_leaf(layout, pane_id)
    if idx >= 0:
        layout.active_pane_id = pane_id

fn split_pane_focus_direction(layout: SplitPaneLayout, direction: text):
    val ids = split_pane_list_panes(layout)
    if ids.len() == 0:
        return
    val cur = layout.active_pane_id
    val cur_pos = _pane_index_of(ids, cur)
    if direction == "right" or direction == "down":
        val next = cur_pos + 1
        if next < ids.len():
            layout.active_pane_id = ids[next]
    elif direction == "left" or direction == "up":
        val prev = cur_pos - 1
        if prev >= 0:
            layout.active_pane_id = ids[prev]

fn split_pane_resize(layout: SplitPaneLayout, pane_id: i64, delta: f64):
    val leaf_idx = _pane_find_leaf(layout, pane_id)
    if leaf_idx < 0:
        return
    val parent_idx = _pane_find_parent(layout, leaf_idx)
    if parent_idx < 0:
        return
    val parent = layout.nodes[parent_idx]
    val delta_i = delta as i64
    var new_ratio = parent.ratio + delta_i
    if new_ratio < 10:
        new_ratio = 10
    if new_ratio > 90:
        new_ratio = 90
    val p = layout.nodes[parent_idx]
    layout.nodes[parent_idx] = PaneNode(
        kind: p.kind, pane_id: p.pane_id, buffer_id_value: p.buffer_id_value,
        direction: p.direction, ratio: new_ratio,
        left_id: p.left_id, right_id: p.right_id
    )

fn split_pane_set_buffer(layout: SplitPaneLayout, pane_id: i64, buffer_id: EditorBufferId):
    val idx = _pane_find_leaf(layout, pane_id)
    if idx < 0:
        return
    val n = layout.nodes[idx]
    layout.nodes[idx] = PaneNode(
        kind: n.kind, pane_id: n.pane_id, buffer_id_value: buffer_id.value,
        direction: n.direction, ratio: n.ratio,
        left_id: n.left_id, right_id: n.right_id
    )

fn split_pane_get_buffer(layout: SplitPaneLayout, pane_id: i64) -> EditorBufferId:
    val idx = _pane_find_leaf(layout, pane_id)
    if idx < 0:
        return nil
    val n = layout.nodes[idx]
    if n.buffer_id_value < 0:
        return nil
    EditorBufferId(value: n.buffer_id_value)

fn split_pane_list_panes(layout: SplitPaneLayout) -> [i64]:
    var result: [i64] = []
    _pane_collect_leaves(layout, layout.root_id, result)
    result

fn split_pane_active(layout: SplitPaneLayout) -> i64:
    layout.active_pane_id

# --- internal helpers ---

fn _pane_find_leaf(layout: SplitPaneLayout, pane_id: i64) -> i64:
    var i = 0
    while i < layout.nodes.len():
        if layout.nodes[i].kind == PANE_LEAF and layout.nodes[i].pane_id == pane_id:
            return i
        i = i + 1
    -1

fn _pane_find_parent(layout: SplitPaneLayout, child_idx: i64) -> i64:
    var i = 0
    while i < layout.nodes.len():
        val node = layout.nodes[i]
        if node.kind == PANE_BRANCH:
            if node.left_id == child_idx or node.right_id == child_idx:
                return i
        i = i + 1
    -1

fn _pane_leaf_count(layout: SplitPaneLayout) -> i64:
    var count = 0
    var i = 0
    while i < layout.nodes.len():
        if layout.nodes[i].kind == PANE_LEAF:
            count = count + 1
        i = i + 1
    count

fn _pane_collect_leaves(layout: SplitPaneLayout, node_id: i64, result: [i64]):
    if node_id < 0 or node_id >= layout.nodes.len():
        return
    val node = layout.nodes[node_id]
    if node.kind == PANE_LEAF:
        result.push(node.pane_id)
        return
    _pane_collect_leaves(layout, node.left_id, result)
    _pane_collect_leaves(layout, node.right_id, result)

fn _pane_index_of(ids: [i64], target: i64) -> i64:
    var i = 0
    while i < ids.len():
        if ids[i] == target:
            return i
        i = i + 1
    -1
