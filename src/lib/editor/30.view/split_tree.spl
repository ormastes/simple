# Editor Split Tree — binary tree of horizontal/vertical pane splits.
#
# Provides: SplitNode, SplitTree, split_tree_leaf, split_tree_split.

enum SplitDirection:
    Horizontal
    Vertical

# A node in the split tree.
# Leaf nodes hold a pane_id; internal nodes split two children.
enum SplitNode:
    Leaf(pane_id: i64)
    Split(direction: SplitDirection, ratio: f64, left: SplitNode, right: SplitNode)

struct SplitTree:
    root: SplitNode
    active_pane_id: i64

fn split_tree_leaf(pane_id: i64) -> SplitTree:
    SplitTree(root: SplitNode.Leaf(pane_id: pane_id), active_pane_id: pane_id)

fn split_tree_split(tree: SplitTree, pane_id: i64, new_pane_id: i64, direction: SplitDirection) -> SplitTree:
    val new_root = SplitNode.Split(
        direction: direction,
        ratio: 0.5,
        left: SplitNode.Leaf(pane_id: pane_id),
        right: SplitNode.Leaf(pane_id: new_pane_id))
    SplitTree(root: new_root, active_pane_id: new_pane_id)
