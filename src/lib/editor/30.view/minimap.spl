# Editor Minimap
#
# Scaled-down overview of the file content with viewport highlight.

struct Minimap:
    enabled: bool
    width: i64
    total_lines: i64
    viewport_start: i64
    viewport_height: i64
    lines: [text]

fn minimap_new() -> Minimap:
    Minimap(
        enabled: false,
        width: 12,
        total_lines: 0,
        viewport_start: 0,
        viewport_height: 0,
        lines: []
    )

fn minimap_from_content(content: text, viewport_start: i64, viewport_height: i64, width: i64) -> Minimap:
    val all_lines = content.split("\n")
    val total = all_lines.len()
    # Truncate each line to minimap width
    var minimap_lines: [text] = []
    for line in all_lines:
        if line.len() > width:
            minimap_lines.push(line.slice(0, width))
        else:
            minimap_lines.push(line)
    Minimap(
        enabled: true,
        width: width,
        total_lines: total,
        viewport_start: viewport_start,
        viewport_height: viewport_height,
        lines: minimap_lines
    )

fn minimap_render(map: Minimap, height: i64) -> [text]:
    if not map.enabled or map.lines.len() == 0:
        return []
    # Scale: pick evenly-spaced lines to fill `height` rows
    val total = map.lines.len()
    var result: [text] = []
    var i = 0
    while i < height:
        val line_idx = if total <= height: i else: (i * total) / height
        if line_idx < total:
            result.push(map.lines[line_idx])
        else:
            result.push("")
        i = i + 1
    result
