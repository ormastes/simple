# Editor Dock Zone — dock layout, zones, and positions.
#
# Provides: DockZone, DockPosition, DockLayout.

enum DockPosition:
    Left
    Right
    Bottom
    Top
    Center
    Float

struct DockZone:
    id: i64
    position: DockPosition
    size: i64
    visible: bool

fn dock_zone_new(id: i64, position: DockPosition) -> DockZone:
    DockZone(id: id, position: position, size: 250, visible: true)

fn dock_zone_toggle(zone: DockZone) -> DockZone:
    DockZone(id: zone.id, position: zone.position, size: zone.size, visible: not zone.visible)

class DockLayout:
    left: DockZone
    right: DockZone
    bottom: DockZone

    static fn new() -> DockLayout:
        DockLayout(
            left: dock_zone_new(1, DockPosition.Left),
            right: dock_zone_new(2, DockPosition.Right),
            bottom: dock_zone_new(3, DockPosition.Bottom)
        )

    me left_width_value() -> i64:
        me.left.size

    me right_width_value() -> i64:
        me.right.size

    me is_right_visible() -> bool:
        me.right.visible

    me toggle_left() -> DockLayout:
        DockLayout(left: dock_zone_toggle(me.left), right: me.right, bottom: me.bottom)

    me toggle_right() -> DockLayout:
        DockLayout(left: me.left, right: dock_zone_toggle(me.right), bottom: me.bottom)

    me toggle_bottom() -> DockLayout:
        DockLayout(left: me.left, right: me.right, bottom: dock_zone_toggle(me.bottom))
