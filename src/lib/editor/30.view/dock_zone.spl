# Dock Zone Layout
#
# Manages side and bottom dock panels (file tree, problems, terminal, etc.).
# Each panel belongs to a zone (left, right, bottom) and zones can be
# toggled, resized, and have an active panel selection.

val DOCK_LEFT: i64 = 0
val DOCK_RIGHT: i64 = 1
val DOCK_BOTTOM: i64 = 2

struct DockPanel:
    id: text
    label: text
    zone: i64
    icon: text
    visible: bool

class DockZoneLayout:
    panels: [DockPanel]
    left_width: i64
    right_width: i64
    bottom_height: i64
    left_visible: bool
    right_visible: bool
    bottom_visible: bool
    active_left: text
    active_right: text
    active_bottom: text

impl DockZoneLayout:

    static fn new() -> DockZoneLayout:
        DockZoneLayout(
            panels: [],
            left_width: 30,
            right_width: 30,
            bottom_height: 10,
            left_visible: false,
            right_visible: false,
            bottom_visible: false,
            active_left: "",
            active_right: "",
            active_bottom: ""
        )

    me toggle(zone: i64):
        if zone == DOCK_LEFT:
            self.left_visible = not self.left_visible
        if zone == DOCK_RIGHT:
            self.right_visible = not self.right_visible
        if zone == DOCK_BOTTOM:
            self.bottom_visible = not self.bottom_visible

    me set_active(zone: i64, panel_id: text):
        if zone == DOCK_LEFT:
            self.active_left = panel_id
        if zone == DOCK_RIGHT:
            self.active_right = panel_id
        if zone == DOCK_BOTTOM:
            self.active_bottom = panel_id

    me resize_zone(zone: i64, delta: i64):
        if zone == DOCK_LEFT:
            var w = self.left_width + delta
            if w < 10:
                w = 10
            if w > 80:
                w = 80
            self.left_width = w
        if zone == DOCK_RIGHT:
            var w = self.right_width + delta
            if w < 10:
                w = 10
            if w > 80:
                w = 80
            self.right_width = w
        if zone == DOCK_BOTTOM:
            var h = self.bottom_height + delta
            if h < 10:
                h = 10
            if h > 80:
                h = 80
            self.bottom_height = h

    fn compute_editor_rect(total_w: i64, total_h: i64, tab_bar_h: i64, status_h: i64) -> SplitRect:
        var x = 0
        var w = total_w
        var y = tab_bar_h
        var h = total_h - tab_bar_h - status_h
        if self.left_visible:
            x = x + self.left_width
            w = w - self.left_width
        if self.right_visible:
            w = w - self.right_width
        if self.bottom_visible:
            h = h - self.bottom_height
        if w < 1:
            w = 1
        if h < 1:
            h = 1
        SplitRect(group_id: 0, x: x, y: y, w: w, h: h)

    me add_panel(panel: DockPanel):
        self.panels.push(panel)

    me remove_panel(panel_id: text):
        var result: [DockPanel] = []
        var i = 0
        while i < self.panels.len():
            if self.panels[i].id != panel_id:
                result.push(self.panels[i])
            i = i + 1
        self.panels = result

    fn panel_count() -> i64:
        self.panels.len()

    fn visible_panels_in(zone: i64) -> [DockPanel]:
        var result: [DockPanel] = []
        var i = 0
        while i < self.panels.len():
            if self.panels[i].zone == zone and self.panels[i].visible:
                result.push(self.panels[i])
            i = i + 1
        result

fn dock_zone_layout_new() -> DockZoneLayout:
    DockZoneLayout.new()

fn dock_zone_layout_default() -> DockZoneLayout:
    var layout = DockZoneLayout(
        panels: [],
        left_width: 30,
        right_width: 30,
        bottom_height: 10,
        left_visible: true,
        right_visible: false,
        bottom_visible: true,
        active_left: "file_tree",
        active_right: "",
        active_bottom: "problems"
    )
    layout.add_panel(DockPanel(
        id: "file_tree",
        label: "Explorer",
        zone: DOCK_LEFT,
        icon: "files",
        visible: true
    ))
    layout.add_panel(DockPanel(
        id: "problems",
        label: "Problems",
        zone: DOCK_BOTTOM,
        icon: "warning",
        visible: true
    ))
    layout
