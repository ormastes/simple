# Editor LSP Result Panel — shows hover, definition, and reference results.
#
# Provides: LspResultPanel, LspResultItem, lsp_result_panel_new.

struct LspResultItem:
    kind: text
    label: text
    detail: text
    path: text
    line: i64
    col: i64

struct LspResultPanel:
    title: text
    items: [LspResultItem]
    selected: i64
    scroll_offset: i64
    visible: bool

fn lsp_result_panel_new() -> LspResultPanel:
    LspResultPanel(title: "LSP Results", items: [], selected: 0, scroll_offset: 0, visible: false)

fn lsp_result_panel_show(panel: LspResultPanel, title: text, items: [LspResultItem]) -> LspResultPanel:
    LspResultPanel(title: title, items: items, selected: 0, scroll_offset: 0, visible: true)

fn lsp_result_panel_hide(panel: LspResultPanel) -> LspResultPanel:
    LspResultPanel(title: panel.title, items: panel.items, selected: panel.selected,
                   scroll_offset: panel.scroll_offset, visible: false)
