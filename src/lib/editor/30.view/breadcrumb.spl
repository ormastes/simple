# Editor Breadcrumb
#
# Path and symbol breadcrumb bar showing current file location in
# the document hierarchy (e.g. file > class > method).

struct BreadcrumbSegment:
    label: text
    kind: text
    path: text
    line: i64

struct Breadcrumb:
    segments: [BreadcrumbSegment]
    file_path: text

fn breadcrumb_new() -> Breadcrumb:
    Breadcrumb(segments: [], file_path: "")

fn breadcrumb_for_path(file_path: text) -> Breadcrumb:
    Breadcrumb(segments: [], file_path: file_path)

fn breadcrumb_with_segments(file_path: text, segments: [BreadcrumbSegment]) -> Breadcrumb:
    Breadcrumb(segments: segments, file_path: file_path)

fn breadcrumb_render(crumb: Breadcrumb) -> text:
    if crumb.segments.len() == 0:
        return crumb.file_path
    var result = crumb.file_path
    for seg in crumb.segments:
        result = result + " > " + seg.label
    result
