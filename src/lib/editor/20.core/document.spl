# Editor Document
#
# Wraps an EditorBuffer with document-level metadata:
# language ID, encoding, line ending style.

class EditorDocumentId:
    value: i64

class EditorDocument:
    id: EditorDocumentId
    buffer: EditorBuffer
    language_id: text
    encoding: text
    line_ending: text

impl EditorDocument:

    static fn from_buffer(id: EditorDocumentId, buffer: EditorBuffer) -> EditorDocument:
        val lang = _doc_detect_language(buffer.path)
        EditorDocument(
            id: id,
            buffer: buffer,
            language_id: lang,
            encoding: "utf-8",
            line_ending: "lf"
        )

    static fn open_file(doc_id: EditorDocumentId, buf_id: EditorBufferId, path: text) -> EditorDocument:
        val buffer = EditorBuffer.from_file(buf_id, path)
        EditorDocument.from_buffer(doc_id, buffer)

    static fn empty(doc_id: EditorDocumentId, buf_id: EditorBufferId) -> EditorDocument:
        val buffer = EditorBuffer.from_text(buf_id, "")
        EditorDocument.from_buffer(doc_id, buffer)

    fn path() -> text:
        self.buffer.path

    fn is_dirty() -> bool:
        self.buffer.dirty

    fn display_name() -> text:
        if self.buffer.path != "":
            val p = self.buffer.path
            val last_sep = _doc_last_index_of(p, "/")
            if last_sep >= 0:
                return p.slice(last_sep + 1, p.len())
            return p
        "[No Name]"


fn _doc_detect_language(path: text) -> text:
    if path == "":
        return "plain"
    if path.ends_with(".spl"):
        return "simple"
    if path.ends_with(".md"):
        return "markdown"
    if path.ends_with(".sdn"):
        return "sdn"
    if path.ends_with(".json"):
        return "json"
    if path.ends_with(".c") or path.ends_with(".h"):
        return "c"
    if path.ends_with(".rs"):
        return "rust"
    if path.ends_with(".py"):
        return "python"
    if path.ends_with(".js") or path.ends_with(".ts"):
        return "javascript"
    if path.ends_with(".shs"):
        return "shell"
    "plain"

fn _doc_last_index_of(s: text, ch: text) -> i64:
    var last = -1
    var i = 0
    while i < s.len():
        if s.char_at(i) == ch:
            last = i
        i = i + 1
    last
