# Editor Recent Files
#
# Recent file list persisted as SDN text table.
# FIFO eviction at max 50 entries, atomic writes.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

struct RecentFiles:
    entries: [text]
    max_entries: i64
    storage_path: text

fn recent_files_new(storage_path: text) -> RecentFiles:
    RecentFiles(entries: [], max_entries: 50, storage_path: storage_path)

fn recent_files_load(storage_path: text) -> RecentFiles:
    val content = rt_file_read_text(storage_path) ?? ""
    var entries: [text] = []
    if content != "":
        var start = 0
        var i = 0
        while i < content.len():
            if content.char_at(i) == "\n":
                val line = content.slice(start, i).trim()
                if line != "" and not line.starts_with("#"):
                    entries.push(line)
                start = i + 1
            i = i + 1
        if start < content.len():
            val line = content.slice(start, content.len()).trim()
            if line != "" and not line.starts_with("#"):
                entries.push(line)
    RecentFiles(entries: entries, max_entries: 50, storage_path: storage_path)

fn recent_files_add(recent: RecentFiles, path: text) -> RecentFiles:
    var new_entries: [text] = [path]
    for entry in recent.entries:
        if entry != path:
            new_entries.push(entry)
    while new_entries.len() > recent.max_entries:
        new_entries = _recent_drop_last(new_entries)
    RecentFiles(entries: new_entries, max_entries: recent.max_entries, storage_path: recent.storage_path)

fn recent_files_save(recent: RecentFiles) -> bool:
    var content = "# Recent Files\n"
    for entry in recent.entries:
        content = content + entry + "\n"
    rt_file_write_text(recent.storage_path, content)

fn recent_files_remove(recent: RecentFiles, path: text) -> RecentFiles:
    var new_entries: [text] = []
    for entry in recent.entries:
        if entry != path:
            new_entries.push(entry)
    RecentFiles(entries: new_entries, max_entries: recent.max_entries, storage_path: recent.storage_path)

fn _recent_drop_last(items: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i + 1 < items.len():
        out.push(items[i])
        i = i + 1
    out
