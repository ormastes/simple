# Editor Workspace Extension
#
# Workspace management: root path, open folders, recent files,
# and per-workspace settings.

use std.editor.core.path_text.*

struct WorkspaceFolder:
    path: text
    name: text

struct WorkspaceState:
    root_path: text
    folders: [WorkspaceFolder]
    recent_files: [text]
    settings_path: text

fn workspace_state_new(root_path: text) -> WorkspaceState:
    val name = editor_path_basename(root_path)
    val folder = WorkspaceFolder(path: root_path, name: name)
    WorkspaceState(
        root_path: root_path,
        folders: [folder],
        recent_files: [],
        settings_path: root_path + "/.editor/settings.sdn"
    )

fn workspace_add_recent(state: WorkspaceState, path: text) -> WorkspaceState:
    var recent = state.recent_files
    var filtered: [text] = []
    for p in recent:
        if p != path:
            filtered.push(p)
    filtered.push(path)
    var trimmed: [text] = []
    val start = if filtered.len() > 20 then filtered.len() - 20 else: 0
    var i = start
    while i < filtered.len():
        trimmed.push(filtered[i])
        i = i + 1
    WorkspaceState(
        root_path: state.root_path,
        folders: state.folders,
        recent_files: trimmed,
        settings_path: state.settings_path
    )

fn workspace_contains_path(state: WorkspaceState, path: text) -> bool:
    for folder in state.folders:
        if path.starts_with(folder.path):
            return true
    false
