# Editor Multi-Cursor Extension
#
# Multi-cursor editing support: add, remove, and merge cursor positions.

struct CursorPos:
    row: i64
    col: i64
    anchor_row: i64
    anchor_col: i64

struct MultiCursorState:
    cursors: [CursorPos]
    primary: i64
    active: bool

fn multi_cursor_state_new() -> MultiCursorState:
    MultiCursorState(cursors: [], primary: 0, active: false)

fn multi_cursor_state_from_single(row: i64, col: i64) -> MultiCursorState:
    val cursor = CursorPos(row: row, col: col, anchor_row: row, anchor_col: col)
    MultiCursorState(cursors: [cursor], primary: 0, active: false)

fn multi_cursor_add(state: MultiCursorState, row: i64, col: i64) -> MultiCursorState:
    var cursors = state.cursors
    cursors.push(CursorPos(row: row, col: col, anchor_row: row, anchor_col: col))
    MultiCursorState(cursors: cursors, primary: state.primary, active: true)

fn multi_cursor_remove_all_except_primary(state: MultiCursorState) -> MultiCursorState:
    if state.cursors.len() == 0:
        return state
    val primary_idx = if state.primary < state.cursors.len() then state.primary else: 0
    val primary = state.cursors[primary_idx]
    MultiCursorState(cursors: [primary], primary: 0, active: false)

fn multi_cursor_primary(state: MultiCursorState) -> CursorPos:
    if state.cursors.len() == 0:
        return CursorPos(row: 0, col: 0, anchor_row: 0, anchor_col: 0)
    val idx = if state.primary < state.cursors.len() then state.primary else: 0
    state.cursors[idx]
