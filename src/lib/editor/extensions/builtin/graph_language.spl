# Built-in SDN Graph Language Extension
#
# Registers compact SDN graph blocks and files with the editor extension host.

fn graph_language_manifest() -> ExtensionManifest:
    ExtensionManifest(
        name: "sdn-graph-language",
        version: "1.0.0",
        main: "",
        activation_events: ["onLanguage:sdn-graph"],
        contributes_commands: [
            ExtensionCommand(id: "graph.render", title: "Render SDN Graph"),
            ExtensionCommand(id: "graph.showCanonical", title: "Show Canonical SDN Graph")
        ],
        contributes_languages: [
            ExtensionLanguage(id: "sdn-graph", extensions: [".graph.sdn", ".sdngraph"])
        ],
        contributes_debug_adapters: [],
        contributes_themes: [],
        contributes_keybindings: []
    )

fn graph_language_id() -> text:
    "sdn-graph"

fn graph_language_block_fences() -> [text]:
    ["sdn-graph", "graph"]
