# Markdown Edit Assist — auto-completion and smart-edit helpers for Markdown.
#
# Provides markdown edit-assist local property validation helpers.

struct MdEditAssistPropertySchemaRule:
    property: text
    required: bool
    value_type: text

fn md_edit_assist_check_frontmatter_property_schema(content: text, path: text, rules: [MdEditAssistPropertySchemaRule]) -> [text]:
    var violations: [text] = []
    for rule in rules:
        if rule.required:
            if not content.contains(rule.property + ":"):
                violations.push("missing required frontmatter property: {rule.property} in {path}")
    violations
