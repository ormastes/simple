# Editor extension root policy.
#
# Runtime-neutral default extension locations. App adapters inject environment
# values so this policy can be reused by host, SimpleOS, IDE, and examples.

use std.editor.core.path_text.{editor_split_path_list}

fn editor_extension_workspace_roots() -> [text]:
    [
        ".simple/editor/extensions",
        ".vscode/simple-editor/extensions"
    ]

fn editor_extension_user_roots(home: text) -> [text]:
    if home.trim() == "":
        return []
    [
        home + "/.simple/editor/extensions",
        home + "/.simple/extensions"
    ]

fn editor_extension_system_roots() -> [text]:
    [
        "/usr/local/share/simple/editor/extensions",
        "/usr/share/simple/editor/extensions"
    ]

fn editor_extension_roots_from_inputs(configured_path_list: text, home: text) -> [text]:
    var roots: [text] = []
    for root in editor_extension_workspace_roots():
        roots.push(root)
    for root in editor_split_path_list(configured_path_list):
        roots.push(root)
    for root in editor_extension_user_roots(home):
        roots.push(root)
    for root in editor_extension_system_roots():
        roots.push(root)
    roots
