fn platform_settings_schema() -> [SettingDescriptor]:
    [
        SettingDescriptor(
            key: "max_open_files",
            label: "Max Open Files",
            description: "Maximum number of files open simultaneously",
            category: "Platform",
            setting_type: "i64",
            default_value: "256",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "max_undo_depth",
            label: "Max Undo Depth",
            description: "Maximum number of undo steps retained",
            category: "Platform",
            setting_type: "i64",
            default_value: "128",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "auto_save_interval_ms",
            label: "Auto Save Interval",
            description: "Interval in milliseconds between auto-save triggers",
            category: "Platform",
            setting_type: "i64",
            default_value: "30000",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "file_watcher_enabled",
            label: "File Watcher",
            description: "Watch files for external changes on disk",
            category: "Platform",
            setting_type: "bool",
            default_value: "true",
            enum_options: [],
            platform: "desktop"
        )
    ]

fn full_settings_schema() -> [SettingDescriptor]:
    editor_settings_schema() + keybinding_settings_schema() + platform_settings_schema()

fn settings_categories() -> [text]:
    ["Editor", "Appearance", "Files", "Keybindings", "Platform"]

fn settings_filter_by_category(schema: [SettingDescriptor], category: text) -> [SettingDescriptor]:
    var result: [SettingDescriptor] = []
    var i = 0
    while i < schema.len():
        val d = schema[i]
        if d.category == category:
            result = result + [d]
        i = i + 1
    result

fn settings_filter_by_platform(schema: [SettingDescriptor], platform: text) -> [SettingDescriptor]:
    var result: [SettingDescriptor] = []
    var i = 0
    while i < schema.len():
        val d = schema[i]
        if d.platform == platform or d.platform == "all":
            result = result + [d]
        i = i + 1
    result

fn settings_search(schema: [SettingDescriptor], query: text) -> [SettingDescriptor]:
    var result: [SettingDescriptor] = []
    var i = 0
    while i < schema.len():
        val d = schema[i]
        val combined = d.key + " " + d.label + " " + d.description
        if combined.contains(query):
            result = result + [d]
        i = i + 1
    result
