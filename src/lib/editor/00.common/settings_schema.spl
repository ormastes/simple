# Editor Settings Schema
#
# Provides SettingDescriptor records describing every EditorConfig field,
# plus filter/search helpers used by UI settings panels.

struct SettingDescriptor:
    key: text
    label: text
    description: text
    category: text
    setting_type: text
    default_value: text
    enum_options: [text]
    platform: text

fn editor_settings_schema() -> [SettingDescriptor]:
    [
        SettingDescriptor(
            key: "theme",
            label: "Theme",
            description: "Color theme for the editor",
            category: "Appearance",
            setting_type: "enum",
            default_value: "dark",
            enum_options: ["dark", "light", "solarized"],
            platform: "all"
        ),
        SettingDescriptor(
            key: "font_size",
            label: "Font Size",
            description: "Editor font size in points",
            category: "Appearance",
            setting_type: "i64",
            default_value: "14",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "tab_size",
            label: "Tab Size",
            description: "Number of spaces per tab stop",
            category: "Editor",
            setting_type: "i64",
            default_value: "4",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "insert_spaces",
            label: "Insert Spaces",
            description: "Insert spaces instead of tab characters",
            category: "Editor",
            setting_type: "bool",
            default_value: "true",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "word_wrap",
            label: "Word Wrap",
            description: "Wrap long lines at viewport edge",
            category: "Editor",
            setting_type: "bool",
            default_value: "false",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "line_numbers",
            label: "Line Numbers",
            description: "Show line numbers in the gutter",
            category: "Editor",
            setting_type: "bool",
            default_value: "true",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "minimap",
            label: "Minimap",
            description: "Show minimap overview of the file",
            category: "Appearance",
            setting_type: "bool",
            default_value: "false",
            enum_options: [],
            platform: "desktop"
        ),
        SettingDescriptor(
            key: "auto_save",
            label: "Auto Save",
            description: "Automatically save files after changes",
            category: "Files",
            setting_type: "bool",
            default_value: "false",
            enum_options: [],
            platform: "all"
        ),
        SettingDescriptor(
            key: "auto_save_delay_ms",
            label: "Auto Save Delay",
            description: "Delay in milliseconds before auto-save triggers",
            category: "Files",
            setting_type: "i64",
            default_value: "30000",
            enum_options: [],
            platform: "all"
        )
    ]

