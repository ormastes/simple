# Editor Configuration
#
# Layered config: defaults -> user (~/.simple-editor/settings.sdn) -> workspace.
# All config stored in SDN format.

use std.io_runtime.{file_read, file_write}

struct EditorConfig:
    theme: text
    font_size: i64
    tab_size: i64
    insert_spaces: bool
    word_wrap: bool
    line_numbers: bool
    minimap: bool
    auto_save: bool
    auto_save_delay_ms: i64
    hover_delay_ms: i64

fn editor_config_default() -> EditorConfig:
    EditorConfig(
        theme: "dark",
        font_size: 14,
        tab_size: 4,
        insert_spaces: true,
        word_wrap: false,
        line_numbers: true,
        minimap: false,
        auto_save: false,
        auto_save_delay_ms: 30000,
        hover_delay_ms: 300
    )

fn editor_config_load(user_path: text, workspace_path: text) -> EditorConfig:
    var config = editor_config_default()
    val user_content = file_read(user_path) ?? ""
    if user_content != "":
        config = _ec_apply_sdn(config, user_content)
    val ws_content = file_read(workspace_path) ?? ""
    if ws_content != "":
        config = _ec_apply_sdn(config, ws_content)
    config

fn _ec_apply_sdn(config: EditorConfig, content: text) -> EditorConfig:
    var result = config
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            val line = content.slice(start, i).trim()
            result = _ec_apply_line(result, line)
            start = i + 1
        i = i + 1
    if start < content.len():
        result = _ec_apply_line(result, content.slice(start, content.len()).trim())
    result

fn _ec_apply_line(config: EditorConfig, line: text) -> EditorConfig:
    if line == "" or line.starts_with("#"):
        return config
    val eq = _ec_find_char(line, ":")
    if eq < 0:
        return config
    val key = line.slice(0, eq).trim()
    val value = line.slice(eq + 1, line.len()).trim()
    if key == "theme":
        return EditorConfig(theme: value, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "font_size":
        val n = _ec_parse_int(value)
        if n > 0:
            return EditorConfig(theme: config.theme, font_size: n, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "tab_size":
        val n = _ec_parse_int(value)
        if n > 0:
            return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: n, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "insert_spaces":
        return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: value == "true", word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "word_wrap":
        return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: value == "true", line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "line_numbers":
        return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: value == "true", minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "minimap":
        return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: value == "true", auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "auto_save":
        return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: value == "true", auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: config.hover_delay_ms)
    if key == "auto_save_delay_ms":
        val n = _ec_parse_int(value)
        if n > 0:
            return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: n, hover_delay_ms: config.hover_delay_ms)
    if key == "hover_delay_ms":
        val n = _ec_parse_int(value)
        if n >= 0:
            return EditorConfig(theme: config.theme, font_size: config.font_size, tab_size: config.tab_size, insert_spaces: config.insert_spaces, word_wrap: config.word_wrap, line_numbers: config.line_numbers, minimap: config.minimap, auto_save: config.auto_save, auto_save_delay_ms: config.auto_save_delay_ms, hover_delay_ms: n)
    config

fn _ec_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.char_at(i) == ch:
            return i
        i = i + 1
    -1

fn _ec_parse_int(s: text) -> i64:
    var result = 0
    var i = 0
    while i < s.len():
        val code = s.char_code_at(i)
        if code >= 48 and code <= 57:
            result = result * 10 + (code - 48)
        i = i + 1
    result

fn editor_config_get_by_key(config: EditorConfig, key: text) -> text:
    if key == "theme":
        return config.theme
    if key == "font_size":
        return _ec_int_to_text(config.font_size)
    if key == "tab_size":
        return _ec_int_to_text(config.tab_size)
    if key == "insert_spaces":
        return _ec_bool_to_text(config.insert_spaces)
    if key == "word_wrap":
        return _ec_bool_to_text(config.word_wrap)
    if key == "line_numbers":
        return _ec_bool_to_text(config.line_numbers)
    if key == "minimap":
        return _ec_bool_to_text(config.minimap)
    if key == "auto_save":
        return _ec_bool_to_text(config.auto_save)
    if key == "auto_save_delay_ms":
        return _ec_int_to_text(config.auto_save_delay_ms)
    if key == "hover_delay_ms":
        return _ec_int_to_text(config.hover_delay_ms)
    ""

fn editor_config_set_by_key(config: EditorConfig, key: text, value: text) -> EditorConfig:
    _ec_apply_line(config, key + ": " + value)

fn editor_config_save(config: EditorConfig, path: text) -> bool:
    val content = "theme: " + config.theme + "\n" +
        "font_size: " + _ec_int_to_text(config.font_size) + "\n" +
        "tab_size: " + _ec_int_to_text(config.tab_size) + "\n" +
        "insert_spaces: " + _ec_bool_to_text(config.insert_spaces) + "\n" +
        "word_wrap: " + _ec_bool_to_text(config.word_wrap) + "\n" +
        "line_numbers: " + _ec_bool_to_text(config.line_numbers) + "\n" +
        "minimap: " + _ec_bool_to_text(config.minimap) + "\n" +
        "auto_save: " + _ec_bool_to_text(config.auto_save) + "\n" +
        "auto_save_delay_ms: " + _ec_int_to_text(config.auto_save_delay_ms) + "\n" +
        "hover_delay_ms: " + _ec_int_to_text(config.hover_delay_ms) + "\n"
    file_write(path, content)

fn _ec_bool_to_text(b: bool) -> text:
    if b:
        return "true"
    "false"

fn _ec_int_to_text(n: i64) -> text:
    if n == 0:
        return "0"
    var result = ""
    var remaining = n
    while remaining > 0:
        val digit = remaining - (remaining / 10) * 10
        result = _ec_digit_char(digit) + result
        remaining = remaining / 10
    result

fn _ec_digit_char(d: i64) -> text:
    if d == 0: return "0"
    if d == 1: return "1"
    if d == 2: return "2"
    if d == 3: return "3"
    if d == 4: return "4"
    if d == 5: return "5"
    if d == 6: return "6"
    if d == 7: return "7"
    if d == 8: return "8"
    "9"
