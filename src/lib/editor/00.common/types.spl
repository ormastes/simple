# Editor Common Types
#
# Core types shared across the editor platform.

class EditorBufferId:
    value: i64

class EditorDocumentId:
    value: i64

    fn int_value() -> i64:
        me.value

enum EditorMode:
    Normal
    Insert
    Command

fn editor_mode_normal() -> EditorMode:
    EditorMode.Normal

fn editor_mode_insert() -> EditorMode:
    EditorMode.Insert

fn editor_mode_command() -> EditorMode:
    EditorMode.Command

fn editor_mode_is_normal(mode: EditorMode) -> bool:
    match mode:
        EditorMode.Normal => true
        _ => false

fn editor_mode_is_insert(mode: EditorMode) -> bool:
    match mode:
        EditorMode.Insert => true
        _ => false

fn editor_mode_is_command(mode: EditorMode) -> bool:
    match mode:
        EditorMode.Command => true
        _ => false

fn editor_mode_name(mode: EditorMode) -> text:
    match mode:
        EditorMode.Normal => "NORMAL"
        EditorMode.Insert => "INSERT"
        EditorMode.Command => "COMMAND"

struct EditorCursor:
    row: i64
    col: i64

struct EditorViewport:
    top_row: i64
    left_col: i64
    width: i64
    height: i64

struct EditCommand:
    name: text
    payload: text
    count: i64

struct EditResult:
    ok: bool
    message: text
    quit: bool

fn edit_ok(message: text) -> EditResult:
    EditResult(ok: true, message: message, quit: false)

fn edit_fail(message: text) -> EditResult:
    EditResult(ok: false, message: message, quit: false)

fn edit_quit() -> EditResult:
    EditResult(ok: true, message: "quit", quit: true)

fn editor_clamp(value: i64, low: i64, high: i64) -> i64:
    if value < low:
        return low
    if value > high:
        return high
    value
