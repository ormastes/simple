# GUI Backend
#
# Integrates editor with UISession and Surface system for GUI rendering.
# Markdown blocks render as HTML in GUI mode.
# Provides render functions for tab bar, file tree, editor area.

struct GuiBackendConfig:
    window_title: text
    initial_width: i64
    initial_height: i64
    theme: text

fn gui_backend_default_config() -> GuiBackendConfig:
    GuiBackendConfig(
        window_title: "Simple Editor",
        initial_width: 1200,
        initial_height: 800,
        theme: "dark"
    )

struct GuiRenderBlock:
    block_id: i64
    kind: text
    html: text
    from_line: i64
    to_line: i64

fn gui_render_markdown_block(block: RenderBlock) -> GuiRenderBlock:
    var html = ""
    val escaped_content = _gui_escape_html(block.content)
    match block.kind:
        "heading":
            val level = _gui_heading_level(block.content)
            val text_content = _gui_strip_heading(block.content)
            val escaped_heading = _gui_escape_html(text_content)
            val lv = str(level)
            html = "<h" + lv + ">" + escaped_heading + "</h" + lv + ">"
        "code":
            html = "<pre><code>" + escaped_content + "</code></pre>"
        "paragraph":
            html = "<p>" + escaped_content + "</p>"
        "list":
            html = "<ul>"
            for line in block.rendered_lines:
                val item = line.trim()
                if item.starts_with("- ") or item.starts_with("* "):
                    val li_text = _gui_escape_html(item.slice(2, item.len()))
                    html = html + "<li>" + li_text + "</li>"
                else:
                    val li_text = _gui_escape_html(item)
                    html = html + "<li>" + li_text + "</li>"
            html = html + "</ul>"
        "table":
            html = "<table>" + escaped_content + "</table>"
        _:
            html = "<div>" + escaped_content + "</div>"
    GuiRenderBlock(block_id: block.id, kind: block.kind, html: html, from_line: block.from_line, to_line: block.to_line)

fn gui_render_editor_area(buffer: EditorBuffer, language_id: text, viewport: EditorViewport) -> text:
    val escaped_language = _gui_escape_html(language_id)
    var html = "<div class=\"editor-area gui-editor-source\" role=\"textbox\" contenteditable=\"true\" spellcheck=\"false\" data-language=\"" + escaped_language + "\">"
    var row = 0
    while row < viewport.height:
        val file_row = viewport.top_row + row
        if file_row < buffer.line_count():
            val line_content = buffer.line_at(file_row)
            val line_num = str(file_row + 1)
            val active_class = if file_row == buffer.cursor_row then " active-line" else: ""
            val active_attr = if file_row == buffer.cursor_row then "true" else: "false"
            var rendered_content = _gui_escape_html(line_content)
            if file_row == buffer.cursor_row:
                rendered_content = _gui_render_line_with_cursor(line_content, buffer.cursor_col)
            html = html + "<div class=\"line" + active_class + "\" data-line=\"" + str(file_row) + "\" data-active=\"" + active_attr + "\"><span class=\"line-num\">" + line_num + "</span><span class=\"content\">" + rendered_content + "</span></div>"
        row = row + 1
    html = html + "</div>"
    html

fn gui_render_tab_bar_html(session: EditSession) -> text:
    var html = "<div class=\"tab-bar\">"
    val group_idx = session.layout.active_group_index
    if group_idx >= 0 and group_idx < session.layout.groups.len():
        val group = session.layout.groups[group_idx]
        var t = 0
        while t < group.tabs.len():
            val tab = group.tabs[t]
            val label = _gui_escape_html(tab.label)
            val active_class = if t == group.active_tab_index then " active" else: ""
            html = html + "<div class=\"tab" + active_class + "\">" + label + "</div>"
            t = t + 1
    html = html + "</div>"
    html

fn gui_render_file_tree_html(file_tree: FileTreeState) -> text:
    var html = "<div class=\"file-tree\">"
    val visible = file_tree.visible_nodes()
    var i = 0
    while i < visible.len():
        val node = visible[i]
        val name = _gui_escape_html(node.name)
        val selected_class = if i == file_tree.selected_index then " selected" else: ""
        val icon = if node.is_dir then "folder" else: "file"
        html = html + "<div class=\"tree-node " + icon + selected_class + "\">" + name + "</div>"
        i = i + 1
    html = html + "</div>"
    html


fn gui_render_settings_html(view: SettingsViewState, config: EditorConfig) -> text:
    var html = "<div class=\"settings-panel\">"
    html = html + "<input type=\"text\" class=\"settings-search\" placeholder=\"Search settings...\" value=\"" + _gui_escape_html(view.search_query) + "\">"
    html = html + "<div class=\"settings-categories\">"
    var ci = 0
    while ci < view.categories.len():
        val cat = view.categories[ci]
        val active_class = if ci == view.category_index then " active" else: ""
        html = html + "<button class=\"category-tab" + active_class + "\">" + _gui_escape_html(cat) + "</button>"
        ci = ci + 1
    html = html + "</div>"
    html = html + "<div class=\"settings-list\">"
    var si = 0
    while si < view.filtered.len():
        val setting = view.filtered[si]
        val current_value = editor_config_get_by_key(config, setting.key)
        val selected_class = if si == view.selected_index then " selected" else: ""
        html = html + "<div class=\"setting-item" + selected_class + "\">"
        html = html + "<div class=\"setting-label\">" + _gui_escape_html(setting.label) + "</div>"
        html = html + "<div class=\"setting-description\">" + _gui_escape_html(setting.description) + "</div>"
        if setting.setting_type == "bool":
            val checked = if current_value == "true" then " checked" else: ""
            html = html + "<input type=\"checkbox\"" + checked + " data-key=\"" + _gui_escape_html(setting.key) + "\">"
        elif setting.setting_type == "i64":
            html = html + "<input type=\"number\" value=\"" + _gui_escape_html(current_value) + "\" data-key=\"" + _gui_escape_html(setting.key) + "\">"
        elif setting.setting_type == "enum":
            html = html + "<select data-key=\"" + _gui_escape_html(setting.key) + "\">"
            var oi = 0
            while oi < setting.enum_options.len():
                val opt = setting.enum_options[oi]
                val selected_attr = if opt == current_value then " selected" else: ""
                html = html + "<option" + selected_attr + ">" + _gui_escape_html(opt) + "</option>"
                oi = oi + 1
            html = html + "</select>"
        else:
            html = html + "<input type=\"text\" value=\"" + _gui_escape_html(current_value) + "\" data-key=\"" + _gui_escape_html(setting.key) + "\">"
        html = html + "</div>"
        si = si + 1
    html = html + "</div>"
    html = html + "</div>"
    html

fn _gui_escape_html(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "<":
            result = result + "&lt;"
        elif ch == ">":
            result = result + "&gt;"
        elif ch == "&":
            result = result + "&amp;"
        elif ch == "\"":
            result = result + "&quot;"
        else:
            result = result + ch
        i = i + 1
    result

fn _gui_render_line_with_cursor(line: text, cursor_col: i64) -> text:
    var safe_col = cursor_col
    if safe_col < 0:
        safe_col = 0
    if safe_col > line.len():
        safe_col = line.len()
    val before = _gui_escape_html(line.slice(0, safe_col))
    val after = _gui_escape_html(line.slice(safe_col, line.len()))
    before + "<span class=\"cursor\" data-cursor=\"true\"></span>" + after

fn _gui_heading_level(content: text) -> i64:
    var level = 0
    while level < content.len() and content.char_at(level) == "#":
        level = level + 1
    if level > 6:
        level = 6
    if level == 0:
        level = 1
    level

fn _gui_strip_heading(content: text) -> text:
    val level = _gui_heading_level(content)
    content.slice(level, content.len()).trim()
