# GUI Backend
#
# Integrates editor with UISession and Surface system for GUI rendering.
# Markdown blocks render as HTML in GUI mode.

struct GuiBackendConfig:
    window_title: text
    initial_width: i64
    initial_height: i64
    theme: text

fn gui_backend_default_config() -> GuiBackendConfig:
    GuiBackendConfig(
        window_title: "Simple Editor",
        initial_width: 1200,
        initial_height: 800,
        theme: "dark"
    )

struct GuiRenderBlock:
    block_id: i64
    kind: text
    html: text
    from_line: i64
    to_line: i64

fn gui_render_markdown_block(block: RenderBlock) -> GuiRenderBlock:
    var html = ""
    match block.kind:
        "heading":
            val level = _gui_heading_level(block.content)
            val text_content = _gui_strip_heading(block.content)
            html = "<h{level}>{_gui_escape_html(text_content)}</h{level}>"
        "code":
            html = "<pre><code>{_gui_escape_html(block.content)}</code></pre>"
        "paragraph":
            html = "<p>{_gui_escape_html(block.content)}</p>"
        "list":
            html = "<ul>"
            for line in block.rendered_lines:
                val item = line.trim()
                if item.starts_with("- ") or item.starts_with("* "):
                    html = html + "<li>{_gui_escape_html(item.slice(2, item.len()))}</li>"
                else:
                    html = html + "<li>{_gui_escape_html(item)}</li>"
            html = html + "</ul>"
        "table":
            html = "<table>{_gui_escape_html(block.content)}</table>"
        _:
            html = "<div>{_gui_escape_html(block.content)}</div>"
    GuiRenderBlock(block_id: block.id, kind: block.kind, html: html, from_line: block.from_line, to_line: block.to_line)

fn _gui_escape_html(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "<":
            result = result + "&lt;"
        elif ch == ">":
            result = result + "&gt;"
        elif ch == "&":
            result = result + "&amp;"
        elif ch == "\"":
            result = result + "&quot;"
        else:
            result = result + ch
        i = i + 1
    result

fn _gui_heading_level(content: text) -> i64:
    var level = 0
    while level < content.len() and content.char_at(level) == "#":
        level = level + 1
    if level > 6:
        level = 6
    if level == 0:
        level = 1
    level

fn _gui_strip_heading(content: text) -> text:
    val level = _gui_heading_level(content)
    content.slice(level, content.len()).trim()
