# Headless Backend
#
# Non-interactive backend for snapshot testing and CI.
# Captures rendered output as text without terminal I/O.

struct HeadlessFrame:
    lines: [text]
    status_line: text
    cursor_row: i64
    cursor_col: i64
    mode: text

class HeadlessBackend:
    frames: [HeadlessFrame]
    width: i64
    height: i64

impl HeadlessBackend:

    static fn new(width: i64, height: i64) -> HeadlessBackend:
        HeadlessBackend(frames: [], width: width, height: height)

    me capture_frame(buffer: EditorBuffer, mode: text, status_message: text):
        var lines: [text] = []
        val editor_height = self.height - 2
        var row = 0
        while row < editor_height:
            val file_row = buffer.viewport.top_row + row
            if file_row < buffer.line_count():
                lines.push(buffer.line_at(file_row))
            else:
                lines.push("~")
            row = row + 1
        val path_str = if buffer.path != "" then buffer.path else: "[No Name]"
        val dirty_str = if buffer.dirty then " [+]" else: ""
        val status = "{mode} | {path_str}{dirty_str} {buffer.cursor_row + 1},{buffer.cursor_col + 1}"
        self.frames.push(HeadlessFrame(
            lines: lines,
            status_line: status,
            cursor_row: buffer.cursor_row,
            cursor_col: buffer.cursor_col,
            mode: mode
        ))

    fn frame_count() -> i64:
        self.frames.len()

    fn last_frame() -> HeadlessFrame:
        if self.frames.len() == 0:
            return HeadlessFrame(lines: [], status_line: "", cursor_row: 0, cursor_col: 0, mode: "")
        self.frames[self.frames.len() - 1]

    fn frame_at(index: i64) -> HeadlessFrame:
        if index < 0 or index >= self.frames.len():
            return HeadlessFrame(lines: [], status_line: "", cursor_row: 0, cursor_col: 0, mode: "")
        self.frames[index]
