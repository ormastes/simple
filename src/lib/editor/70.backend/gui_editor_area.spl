# Lightweight editor-area GUI renderer for embeddable examples and smoke tests.

use std.editor.buffer.buffer.{EditorBuffer}
use std.editor.common.types.{EditorViewport}

fn gui_render_editor_area_basic(buffer: EditorBuffer, language_id: text, viewport: EditorViewport) -> text:
    var html = "<div class=\"editor-area gui-editor-source\" data-language=\"" + language_id + "\">"
    var row = 0
    while row < viewport.height:
        val file_row = buffer.visible_line_at(row)
        if file_row >= 0 and file_row < buffer.line_count():
            html = html + "<div class=\"line\"><span class=\"content\">" + buffer.line_at(file_row) + "</span></div>"
        row = row + 1
    return html + "</div>"
