# Editor Workspace — reusable workspace folders and settings model.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

struct WorkspaceFolder:
    path: text
    name: text

struct WorkspaceSetting:
    key: text
    value: text

struct WorkspaceConfig:
    root_path: text
    folders: [WorkspaceFolder]
    settings: [WorkspaceSetting]
    storage_path: text

fn workspace_new(root_path: text) -> WorkspaceConfig:
    WorkspaceConfig(
        root_path: root_path,
        folders: [WorkspaceFolder(path: root_path, name: _workspace_basename(root_path))],
        settings: [],
        storage_path: root_path + "/.simple-editor/workspace.sdn"
    )

fn workspace_load(root_path: text) -> WorkspaceConfig:
    val config = workspace_new(root_path)
    val content = rt_file_read_text(config.storage_path)
    if content == "":
        return config
    workspace_parse_settings(config, content)

fn workspace_save(config: WorkspaceConfig) -> bool:
    rt_file_write_text(config.storage_path, workspace_to_sdn(config))

fn workspace_get_setting(config: WorkspaceConfig, key: text, default_value: text) -> text:
    for setting in config.settings:
        if setting.key == key:
            return setting.value
    default_value

fn workspace_set_setting(config: WorkspaceConfig, key: text, value: text) -> WorkspaceConfig:
    var settings: [WorkspaceSetting] = []
    var replaced = false
    for setting in config.settings:
        if setting.key == key:
            settings.push(WorkspaceSetting(key: key, value: value))
            replaced = true
        else:
            settings.push(setting)
    if not replaced:
        settings.push(WorkspaceSetting(key: key, value: value))
    WorkspaceConfig(
        root_path: config.root_path,
        folders: config.folders,
        settings: settings,
        storage_path: config.storage_path
    )

fn workspace_parse_settings(config: WorkspaceConfig, content: text) -> WorkspaceConfig:
    var parsed = config
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        val idx = trimmed.index_of("=")
        if idx > 0:
            val key = trimmed.slice(0, idx).trim()
            val value = trimmed.slice(idx + 1, trimmed.len()).trim()
            parsed = workspace_set_setting(parsed, key, value)
    parsed

fn workspace_to_sdn(config: WorkspaceConfig) -> text:
    var out = "workspace \"" + config.root_path + "\"\n"
    for setting in config.settings:
        out = out + setting.key + " = " + setting.value + "\n"
    out

fn _workspace_basename(path: text) -> text:
    val idx = path.last_index_of("/")
    if idx >= 0 and idx + 1 < path.len():
        return path.slice(idx + 1, path.len())
    path
