# Editor launch contract.
#
# Pure launch-option parsing shared by editor, IDE, examples, and embedded
# entrypoints. Runtime-specific argv access stays in app adapters.

struct EditorLaunchOptions:
    mode: text
    files: [text]
    unknown_option: text

fn editor_launch_parse(args: [text]) -> EditorLaunchOptions:
    var mode = "tui"
    var files: [text] = []
    var unknown = ""
    for arg in args:
        if arg == "--gui-sdl":
            mode = "gui-sdl"
        elif arg == "--gui":
            mode = "gui"
        elif arg == "--tui":
            mode = "tui"
        elif arg.starts_with("-"):
            if unknown == "":
                unknown = arg
        else:
            files.push(arg)
    EditorLaunchOptions(mode: mode, files: files, unknown_option: unknown)

fn editor_launch_mode(args: [text]) -> text:
    editor_launch_parse(args).mode

fn editor_launch_file_count(args: [text]) -> i64:
    editor_launch_parse(args).files.len()

fn editor_launch_has_unknown_option(args: [text]) -> bool:
    editor_launch_parse(args).unknown_option != ""

fn editor_launch_first_unknown_option(args: [text]) -> text:
    editor_launch_parse(args).unknown_option

fn editor_launch_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--stdout" or arg == "--quiet" or arg == "--verbose" or
        arg == "--dots" or arg == "--count" or arg == "--no-progress" or
        arg == "--log-mode" or arg == "--surface" or arg == "--progress" or
        arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or
        arg.starts_with("--progress=")

fn editor_launch_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if editor_launch_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn editor_launch_file_args_after_command(raw: [text], commands: [text]) -> [text]:
    var files: [text] = []
    var seen_command = false
    for arg in raw:
        if not seen_command:
            if _editor_launch_is_command(arg, commands):
                seen_command = true
            continue
        val parsed = editor_launch_parse([arg])
        if parsed.unknown_option == "" and parsed.files.len() > 0:
            files.push(arg)
    files

fn _editor_launch_is_command(arg: text, commands: [text]) -> bool:
    for command in commands:
        if arg == command:
            return true
    false
