# Editor Session DB — file-backed session persistence over the editor WAL.

use std.editor.core.wal.*

struct SessionTabEntry:
    doc_id: i64
    path: text
    cursor_row: i64
    cursor_col: i64
    folds: text

struct SessionEditorState:
    active_doc_id: i64
    mode: text
    group_count: i64

class SessionDb:
    db_path: text
    wal: WalWriter

    static fn new(db_path: text, wal_path: text) -> SessionDb:
        SessionDb(db_path: db_path, wal: WalWriter.new(wal_path, db_path))

    me save_open_tab(doc_id: i64, path: text, cursor_row: i64, cursor_col: i64):
        me.save_open_tab_with_folds(doc_id, path, cursor_row, cursor_col, "")

    me save_open_tab_with_folds(doc_id: i64, path: text, cursor_row: i64, cursor_col: i64, folds: text):
        val data = "doc_id=" + doc_id.to_text() + ";path=" + path + ";cursor_row=" + cursor_row.to_text() + ";cursor_col=" + cursor_col.to_text() + ";folds=" + folds
        me.wal.append_set("tabs", doc_id.to_text(), data)

    me save_editor_state(active_doc_id: i64, mode: text, group_count: i64):
        val data = "active_doc_id=" + active_doc_id.to_text() + ";mode=" + mode + ";group_count=" + group_count.to_text()
        me.wal.append_set("state", "editor", data)

    fn load_tabs() -> [SessionTabEntry]:
        var tabs: [SessionTabEntry] = []
        tabs

    fn load_editor_state() -> SessionEditorState:
        SessionEditorState(active_doc_id: 0, mode: "normal", group_count: 1)

    me checkpoint() -> bool:
        me.wal.checkpoint()

fn session_tab_folds(tab: SessionTabEntry) -> text:
    tab.folds
