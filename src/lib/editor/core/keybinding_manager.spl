# Editor Keybinding Manager
#
# Runtime keybinding resolution: maps key sequences to commands
# with mode awareness and user overrides.

use std.editor.common.keybindings.*

struct KeybindingManager:
    config: KeybindingConfig
    overrides: [KeyBinding]

fn keybinding_manager_new() -> KeybindingManager:
    KeybindingManager(config: default_keybindings(), overrides: [])

fn keybinding_manager_from_config(config: KeybindingConfig) -> KeybindingManager:
    KeybindingManager(config: config, overrides: [])

fn keybinding_manager_add_override(manager: KeybindingManager, binding: KeyBinding) -> KeybindingManager:
    var overrides = manager.overrides
    overrides.push(binding)
    KeybindingManager(config: manager.config, overrides: overrides)

fn keybinding_manager_resolve(manager: KeybindingManager, key: text, mode: text) -> text:
    for b in manager.overrides:
        if b.key == key and (b.mode == mode or b.mode == ""):
            return b.command
    for b in manager.config.bindings:
        if b.key == key and (b.mode == mode or b.mode == ""):
            return b.command
    ""

fn keybinding_manager_all_for_mode(manager: KeybindingManager, mode: text) -> [KeyBinding]:
    var result: [KeyBinding] = []
    for b in manager.overrides:
        if b.mode == mode or b.mode == "":
            result.push(b)
    for b in manager.config.bindings:
        if b.mode == mode or b.mode == "":
            result.push(b)
    result
