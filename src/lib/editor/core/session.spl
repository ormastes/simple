# Editor Session — top-level editor state: open documents, layout, buffers.
#
# Provides: EditSession.

use std.editor.buffer.buffer.{EditorBuffer}
use std.editor.core.document.{EditorDocument}
use std.editor.view.layout.{EditorLayout, layout_new}

class EditSession:
    documents: [EditorDocument]
    buffers: [EditorBuffer]
    active_index: i64
    layout: EditorLayout

    static fn new() -> EditSession:
        EditSession(
            documents: [],
            buffers: [],
            active_index: -1,
            layout: layout_new()
        )

    me open_file(path: text):
        val doc = EditorDocument.from_path(path)
        val buf = EditorBuffer.from_text(doc.content)
        me.documents.push(doc)
        me.buffers.push(buf)
        me.active_index = me.documents.len() - 1

    me switch_tab(delta: i64):
        if me.documents.len() == 0:
            return
        val n = me.documents.len()
        me.active_index = (me.active_index + delta + n) % n

    me close_tab():
        if me.active_index < 0 or me.documents.len() == 0:
            return
        var new_docs: [EditorDocument] = []
        var new_bufs: [EditorBuffer] = []
        var i = 0
        while i < me.documents.len():
            if i != me.active_index:
                new_docs.push(me.documents[i])
                new_bufs.push(me.buffers[i])
            i = i + 1
        me.documents = new_docs
        me.buffers = new_bufs
        if me.active_index >= me.documents.len():
            me.active_index = me.documents.len() - 1

    me split_editor():
        pass_do_nothing

    me split_editor_horizontal():
        pass_do_nothing

    me close_other_groups():
        pass_do_nothing

    me focus_next_group():
        pass_do_nothing

    me focus_prev_group():
        pass_do_nothing

    fn save_active() -> bool:
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return false
        val doc = me.documents[me.active_index]
        val buf = me.buffers[me.active_index]
        doc.save(buf.full_text())

    fn active_buffer() -> EditorBuffer:
        if me.active_index < 0 or me.active_index >= me.buffers.len():
            return EditorBuffer.new()
        me.buffers[me.active_index]

    fn active_document() -> EditorDocument:
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return EditorDocument.empty()
        me.documents[me.active_index]
