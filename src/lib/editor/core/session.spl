# Editor Session — top-level editor state: open documents, layout, buffers.
#
# Provides: EditSession.

use std.editor.buffer.buffer.*
use std.editor.buffer.piece_table.*
use std.editor.core.document.*
use std.editor.core.session_db.*
use std.editor.view.layout.*
use std.editor.view.split_tree.*
use std.editor.view.dock_zone.*
use std.editor.common.types.*

# Pane — maps a pane_id to a buffer index.
class Pane:
    pane_id: i64
    buffer_index: i64

class EditSession:
    documents: [EditorDocument]
    buffers: [EditorBuffer]
    active_index: i64
    layout: EditorLayout
    split: SplitTree
    panes: [Pane]
    next_pane_id: i64
    mode: EditorMode
    dock_layout: DockLayout
    status_message: text

    static fn new() -> EditSession:
        val initial_pane = Pane(pane_id: 1, buffer_index: -1)
        EditSession(
            documents: [],
            buffers: [],
            active_index: -1,
            layout: layout_new(),
            split: split_tree_leaf(1),
            panes: [initial_pane],
            next_pane_id: 2,
            mode: editor_mode_normal(),
            dock_layout: DockLayout.new(),
            status_message: ""
        )

    me open_file(path: text) -> EditorDocumentId:
        for existing_doc in me.documents:
            if existing_doc.path() == path:
                me.switch_to_index(existing_doc.doc_id().value)
                return existing_doc.doc_id()
        val doc = EditorDocument.from_path(path)
        val doc_id = EditorDocumentId(value: me.documents.len())
        doc.id = doc_id
        val buf = EditorBuffer(
            table: PieceTable.new(doc.content),
            id: EditorBufferId(value: me.documents.len()),
            path: path,
            cursor_row: 0,
            cursor_col: 0,
            dirty: false,
            viewport: EditorViewport(top_row: 0, left_col: 0, width: 80, height: 24),
            semantic_tokens: [],
            inlay_hints: [],
            code_lenses: [],
            selection_range: SelectionRangeState(active: false, start_row: 0, start_col: 0, end_row: 0, end_col: 0),
            selection_ranges: [],
            fold_ranges: [],
            folded_ranges: [],
            undo_text: "",
            undo_cursor_row: 0,
            undo_cursor_col: 0,
            undo_available: false
        )
        me.documents.push(doc)
        me.buffers.push(buf)
        me.active_index = me.documents.len() - 1
        me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, me.active_index)
        doc_id

    me open_empty() -> EditorDocumentId:
        val doc = EditorDocument.empty()
        val buf = EditorBuffer.new()
        val doc_id = EditorDocumentId(value: me.documents.len())
        doc.id = doc_id
        me.documents.push(doc)
        me.buffers.push(buf)
        me.active_index = me.documents.len() - 1
        me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, me.active_index)
        doc_id

    me switch_tab(delta: i64):
        if me.documents.len() == 0:
            return
        val n = me.documents.len()
        me.active_index = (me.active_index + delta + n) % n
        me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, me.active_index)

    me switch_to_index(index: i64):
        if index < 0 or index >= me.documents.len():
            return
        me.active_index = index
        me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, me.active_index)

    me switch_to_name(name: text) -> bool:
        """Switch to the buffer whose path contains the given name. Returns true if found."""
        var i = 0
        while i < me.documents.len():
            val doc_path = me.documents[i].path()
            if doc_path == name or doc_path.ends_with(name):
                me.active_index = i
                me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, i)
                return true
            i = i + 1
        false

    me close_tab():
        if me.active_index < 0 or me.documents.len() == 0:
            return
        var new_docs: [EditorDocument] = []
        var new_bufs: [EditorBuffer] = []
        var i = 0
        while i < me.documents.len():
            if i != me.active_index:
                new_docs.push(me.documents[i])
                new_bufs.push(me.buffers[i])
            i = i + 1
        me.documents = new_docs
        me.buffers = new_bufs
        if me.active_index >= me.documents.len():
            me.active_index = me.documents.len() - 1
        me.panes = editor_session_bind_panes(me.panes, me.split.active_pane_id, me.active_index)

    me split_editor():
        """Vertical split — add a new pane to the right of the active pane."""
        val new_id = me.next_pane_id
        me.next_pane_id = me.next_pane_id + 1
        val new_pane = Pane(pane_id: new_id, buffer_index: me.active_index)
        me.panes.push(new_pane)
        me.split = split_tree_split(me.split, me.split.active_pane_id, new_id, SplitDirection.Vertical)

    me split_editor_horizontal():
        """Horizontal split — add a new pane below the active pane."""
        val new_id = me.next_pane_id
        me.next_pane_id = me.next_pane_id + 1
        val new_pane = Pane(pane_id: new_id, buffer_index: me.active_index)
        me.panes.push(new_pane)
        me.split = split_tree_split(me.split, me.split.active_pane_id, new_id, SplitDirection.Horizontal)

    me close_other_groups():
        """Close all panes except the active one."""
        val active_id = me.split.active_pane_id
        var kept: [Pane] = []
        var i = 0
        while i < me.panes.len():
            if me.panes[i].pane_id == active_id:
                kept.push(me.panes[i])
            i = i + 1
        me.panes = kept
        me.split = split_tree_leaf(active_id)

    me close_active_group():
        """Close the active pane; keep at least one pane alive."""
        if me.panes.len() <= 1:
            return
        val active_id = me.split.active_pane_id
        var kept: [Pane] = []
        for pane in me.panes:
            if pane.pane_id != active_id:
                kept.push(pane)
        me.panes = kept
        me.split = split_tree_leaf(me.panes[0].pane_id)
        me._sync_active_from_pane()

    me focus_next_group():
        """Move focus to the next pane in the pane list."""
        val ids = me._pane_ids()
        val cur = me.split.active_pane_id
        var idx = 0
        var i = 0
        while i < ids.len():
            if ids[i] == cur:
                idx = i
            i = i + 1
        idx = (idx + 1) % ids.len()
        me.split.active_pane_id = ids[idx]
        me._sync_active_from_pane()

    me focus_prev_group():
        """Move focus to the previous pane in the pane list."""
        val ids = me._pane_ids()
        val cur = me.split.active_pane_id
        var idx = 0
        var i = 0
        while i < ids.len():
            if ids[i] == cur:
                idx = i
            i = i + 1
        idx = (idx - 1 + ids.len()) % ids.len()
        me.split.active_pane_id = ids[idx]
        me._sync_active_from_pane()

    me focus_direction(direction: text, ids: [i64]):
        """Focus pane in given direction (left/right/up/down). Uses next/prev as approximation."""
        if direction == "left" or direction == "up":
            me.focus_prev_group()
        else:
            me.focus_next_group()

    fn document_count() -> i64:
        me.documents.len()

    fn pane_count() -> i64:
        me.panes.len()

    fn active_pane_id() -> i64:
        me.split.active_pane_id

    fn active_pane_index() -> i64:
        """Return 0-based index of active pane in pane list."""
        val target = me.split.active_pane_id
        var i = 0
        while i < me.panes.len():
            if me.panes[i].pane_id == target:
                return i
            i = i + 1
        0

    fn save_active() -> bool:
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return false
        val doc = me.documents[me.active_index]
        val buf = me.buffers[me.active_index]
        doc.save(buf.full_text())

    fn active_buffer() -> EditorBuffer:
        if me.active_index < 0 or me.active_index >= me.buffers.len():
            return EditorBuffer.new()
        val raw = me.buffers[me.active_index]
        EditorBuffer(
            table: raw.table,
            id: raw.id,
            path: raw.path,
            cursor_row: raw.cursor_row,
            cursor_col: raw.cursor_col,
            dirty: raw.dirty,
            viewport: raw.viewport,
            semantic_tokens: raw.semantic_tokens,
            inlay_hints: raw.inlay_hints,
            code_lenses: raw.code_lenses,
            selection_range: raw.selection_range,
            selection_ranges: raw.selection_ranges,
            fold_ranges: raw.fold_ranges,
            folded_ranges: raw.folded_ranges,
            undo_text: raw.undo_text,
            undo_cursor_row: raw.undo_cursor_row,
            undo_cursor_col: raw.undo_cursor_col,
            undo_available: raw.undo_available
        )

    fn active_document() -> EditorDocument:
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return EditorDocument.empty()
        val raw = me.documents[me.active_index]
        EditorDocument(
            id: raw.id,
            _path: raw._path,
            language_id: raw.language_id,
            content: raw.content,
            cached_md_stats: raw.cached_md_stats,
            modified: raw.modified,
            buffer: raw.buffer,
            md_state: raw.md_state
        )

    fn active_doc_id() -> EditorDocumentId:
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return EditorDocumentId(value: 0)
        me.documents[me.active_index].doc_id()

    # Replace the active buffer in place (used after LSP/format edits).
    me update_active_buffer(buffer: EditorBuffer):
        if me.active_index < 0 or me.active_index >= me.buffers.len():
            return
        me.buffers[me.active_index] = buffer

    # Replace the active document in place (used after markdown/state edits).
    me update_active_document(doc: EditorDocument):
        if me.active_index < 0 or me.active_index >= me.documents.len():
            return
        me.documents[me.active_index] = doc

    fn split_tree() -> SplitTree:
        me.split

    me save_to_db(session_db: SessionDb):
        for doc in me.documents:
            val buffer = doc.buffer
            session_db.save_open_tab_with_folds(doc.doc_id().value, doc.path(), buffer.cursor_row, buffer.cursor_col, buffer.fold_state())
        session_db.save_editor_state(me.active_doc_id().value, "normal", me.panes.len())

    me restore_from_db(session_db: SessionDb):
        val tabs = session_db.load_tabs()
        for tab in tabs:
            me.open_file(tab.path)
            var doc = me.active_document()
            doc.buffer.restore_fold_state(session_tab_folds(tab))
            me.update_active_document(doc)

    # --- private helpers ---

    me _bind_active_pane(buf_index: i64):
        """Bind the currently active pane to a buffer index."""
        val target = me.split.active_pane_id
        var panes: [Pane] = []
        var i = 0
        while i < me.panes.len():
            if me.panes[i].pane_id == target:
                panes.push(Pane(pane_id: me.panes[i].pane_id, buffer_index: buf_index))
            else:
                panes.push(me.panes[i])
            i = i + 1
        me.panes = panes

    me _sync_active_from_pane():
        """Set active_index from the buffer bound to the active pane."""
        val target = me.split.active_pane_id
        var i = 0
        while i < me.panes.len():
            if me.panes[i].pane_id == target:
                if me.panes[i].buffer_index >= 0:
                    me.active_index = me.panes[i].buffer_index
                return
            i = i + 1

    fn _pane_ids() -> [i64]:
        """Collect all pane IDs in order."""
        var ids: [i64] = []
        var i = 0
        while i < me.panes.len():
            ids.push(me.panes[i].pane_id)
            i = i + 1
        ids

fn editor_session_bind_panes(panes_in: [Pane], active_pane_id: i64, buf_index: i64) -> [Pane]:
    var panes: [Pane] = []
    var i = 0
    while i < panes_in.len():
        if panes_in[i].pane_id == active_pane_id:
            panes.push(Pane(pane_id: panes_in[i].pane_id, buffer_index: buf_index))
        else:
            panes.push(panes_in[i])
        i = i + 1
    panes
