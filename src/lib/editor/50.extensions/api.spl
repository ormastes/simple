# Extension API
#
# Public API surface for editor extensions.
# ExtensionContext provides workspace info and command registration.

struct ExtensionContext:
    workspace_path: text
    extension_name: text
    commands: [text]
    subscriptions: [text]
    workspace_state: [ExtensionStateValue]

struct ExtensionStateValue:
    key: text
    value: text

fn extension_context_new(workspace_path: text, extension_name: text) -> ExtensionContext:
    ExtensionContext(
        workspace_path: workspace_path,
        extension_name: extension_name,
        commands: [],
        subscriptions: [],
        workspace_state: []
    )

fn extension_context_register_command(ctx: ExtensionContext, command_id: text) -> ExtensionContext:
    var commands = ctx.commands
    commands.push(command_id)
    ExtensionContext(
        workspace_path: ctx.workspace_path,
        extension_name: ctx.extension_name,
        commands: commands,
        subscriptions: ctx.subscriptions,
        workspace_state: ctx.workspace_state
    )

fn extension_context_subscribe(ctx: ExtensionContext, event: text) -> ExtensionContext:
    var subs = ctx.subscriptions
    subs.push(event)
    ExtensionContext(
        workspace_path: ctx.workspace_path,
        extension_name: ctx.extension_name,
        commands: ctx.commands,
        subscriptions: subs,
        workspace_state: ctx.workspace_state
    )

fn extension_context_is_subscribed(ctx: ExtensionContext, event: text) -> bool:
    for sub in ctx.subscriptions:
        if sub == event or sub == "*":
            return true
    false

fn extension_context_set_state(ctx: ExtensionContext, key: text, value: text) -> ExtensionContext:
    var values: [ExtensionStateValue] = []
    var replaced = false
    for entry in ctx.workspace_state:
        if entry.key == key:
            values.push(ExtensionStateValue(key: key, value: value))
            replaced = true
        else:
            values.push(entry)
    if not replaced:
        values.push(ExtensionStateValue(key: key, value: value))
    ExtensionContext(
        workspace_path: ctx.workspace_path,
        extension_name: ctx.extension_name,
        commands: ctx.commands,
        subscriptions: ctx.subscriptions,
        workspace_state: values
    )

fn extension_context_get_state(ctx: ExtensionContext, key: text) -> text:
    for entry in ctx.workspace_state:
        if entry.key == key:
            return entry.value
    ""
