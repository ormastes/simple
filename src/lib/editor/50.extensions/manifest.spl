# Extension Manifest
#
# Parses extension.sdn manifests for the editor plugin system.
# Each extension declares name, version, activation events, and contributions.

extern fn rt_file_read_text(path: text) -> text

struct ExtensionManifest:
    name: text
    version: text
    main: text
    activation_events: [text]
    contributes_commands: [ExtensionCommand]
    contributes_languages: [ExtensionLanguage]
    contributes_debug_adapters: [ExtensionDebugAdapter]
    contributes_themes: [text]
    contributes_keybindings: [ExtensionKeybinding]

struct ExtensionCommand:
    id: text
    title: text

struct ExtensionLanguage:
    id: text
    extensions: [text]

struct ExtensionDebugAdapter:
    id: text
    label: text
    program: text

struct ExtensionKeybinding:
    key: text
    command: text

fn extension_manifest_parse(content: text) -> ExtensionManifest:
    var manifest = ExtensionManifest(
        name: "", version: "", main: "",
        activation_events: [],
        contributes_commands: [],
        contributes_languages: [],
        contributes_debug_adapters: [],
        contributes_themes: [],
        contributes_keybindings: []
    )
    val lines = _em_split_lines(content)
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("name:"):
            manifest.name = trimmed.slice(5, trimmed.len()).trim()
        elif trimmed.starts_with("version:"):
            manifest.version = trimmed.slice(8, trimmed.len()).trim()
        elif trimmed.starts_with("main:"):
            manifest.main = trimmed.slice(5, trimmed.len()).trim()
        elif trimmed.starts_with("activation:"):
            manifest.activation_events.push(trimmed.slice(11, trimmed.len()).trim())
        elif trimmed.starts_with("command:"):
            val rest = trimmed.slice(8, trimmed.len()).trim()
            val sep = _em_find_char(rest, "|")
            if sep > 0:
                manifest.contributes_commands.push(ExtensionCommand(
                    id: rest.slice(0, sep).trim(),
                    title: rest.slice(sep + 1, rest.len()).trim()
                ))
        elif trimmed.starts_with("language:"):
            val rest = trimmed.slice(9, trimmed.len()).trim()
            val sep = _em_find_char(rest, "|")
            if sep > 0:
                val exts = _em_split_comma(rest.slice(sep + 1, rest.len()).trim())
                manifest.contributes_languages.push(ExtensionLanguage(
                    id: rest.slice(0, sep).trim(),
                    extensions: exts
                ))
        elif trimmed.starts_with("debugAdapter:"):
            val rest = trimmed.slice(13, trimmed.len()).trim()
            val first = _em_find_char(rest, "|")
            if first > 0:
                val remaining = rest.slice(first + 1, rest.len()).trim()
                val second = _em_find_char(remaining, "|")
                if second > 0:
                    manifest.contributes_debug_adapters.push(ExtensionDebugAdapter(
                        id: rest.slice(0, first).trim(),
                        label: remaining.slice(0, second).trim(),
                        program: remaining.slice(second + 1, remaining.len()).trim()
                    ))
        elif trimmed.starts_with("theme:"):
            manifest.contributes_themes.push(trimmed.slice(6, trimmed.len()).trim())
        elif trimmed.starts_with("keybinding:"):
            val rest = trimmed.slice(11, trimmed.len()).trim()
            val sep = _em_find_char(rest, "|")
            if sep > 0:
                manifest.contributes_keybindings.push(ExtensionKeybinding(
                    key: rest.slice(0, sep).trim(),
                    command: rest.slice(sep + 1, rest.len()).trim()
                ))
    manifest

fn extension_manifest_load(path: text) -> ExtensionManifest:
    val content = rt_file_read_text(path) ?? ""
    extension_manifest_parse(content)

fn _em_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines

fn _em_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.char_at(i) == ch:
            return i
        i = i + 1
    -1

fn _em_split_comma(s: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    while i < s.len():
        if s.char_at(i) == ",":
            val part = s.slice(start, i).trim()
            if part != "":
                parts.push(part)
            start = i + 1
        i = i + 1
    val last = s.slice(start, s.len()).trim()
    if last != "":
        parts.push(last)
    parts
