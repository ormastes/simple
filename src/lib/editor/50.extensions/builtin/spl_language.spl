# Built-in Simple Language Extension
#
# Provides Simple language support: file association, syntax highlighting,
# comment toggling, bracket matching.

fn spl_language_manifest() -> ExtensionManifest:
    ExtensionManifest(
        name: "simple-language",
        version: "1.0.0",
        main: "",
        activation_events: ["onLanguage:simple"],
        contributes_commands: [
            ExtensionCommand(id: "simple.toggleComment", title: "Toggle Line Comment")
        ],
        contributes_languages: [
            ExtensionLanguage(id: "simple", extensions: [".spl", ".shs"])
        ],
        contributes_themes: [],
        contributes_keybindings: [
            ExtensionKeybinding(key: "ctrl+/", command: "simple.toggleComment")
        ]
    )

fn spl_language_id() -> text:
    "simple"

fn spl_file_extensions() -> [text]:
    [".spl", ".shs"]

fn spl_comment_prefix() -> text:
    "# "

fn spl_bracket_pairs() -> [text]:
    ["()", "[]", "{}"]
