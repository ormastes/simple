# Markdown Folding Extension
#
# Convenience wrapper: parses markdown content and returns folding ranges.
# Delegates to the common markdown library (parse_blocks_with_ranges +
# compute_folding_ranges).

fn md_folding_ranges(content: text) -> [FoldRange]:
    val lines = split_lines(content)
    val ranged_ast = parse_blocks_with_ranges(lines)
    compute_folding_ranges(ranged_ast)
