fn md_commands_keybindings() -> [KeyBinding]:
    [
        KeyBinding(
            key: "ctrl+shift+v",
            command: "markdown.togglePreview",
            mode: "normal",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+shift+o",
            command: "markdown.toggleOutline",
            mode: "normal",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+b",
            command: "markdown.formatBold",
            mode: "insert",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+i",
            command: "markdown.formatItalic",
            mode: "insert",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+shift+x",
            command: "markdown.formatStrikethrough",
            mode: "insert",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+shift+c",
            command: "markdown.insertCodeBlock",
            mode: "insert",
            args: ""
        ),
        KeyBinding(
            key: "ctrl+k",
            command: "markdown.insertLink",
            mode: "insert",
            args: ""
        )
    ]

fn md_dock_panels() -> [DockPanel]:
    [
        DockPanel(
            id: "md-outline",
            label: "Outline",
            zone: DOCK_RIGHT,
            icon: "list-tree",
            visible: false
        ),
        DockPanel(
            id: "md-preview",
            label: "Preview",
            zone: DOCK_RIGHT,
            icon: "eye",
            visible: false
        )
    ]

fn _md_result_no_change(state: MdEditorState, msg: text) -> MdCommandResult:
    MdCommandResult(
        state: state,
        insert_text: "",
        replace_line: "",
        cursor_delta_line: 0,
        cursor_delta_col: 0,
        status_message: msg
    )

fn _md_result_insert(state: MdEditorState, text_to_insert: text, col_delta: i64) -> MdCommandResult:
    MdCommandResult(
        state: state,
        insert_text: text_to_insert,
        replace_line: "",
        cursor_delta_line: 0,
        cursor_delta_col: col_delta,
        status_message: ""
    )

fn _md_result_replace(state: MdEditorState, replacement: text, msg: text) -> MdCommandResult:
    MdCommandResult(
        state: state,
        insert_text: "",
        replace_line: replacement,
        cursor_delta_line: 0,
        cursor_delta_col: 0,
        status_message: msg
    )

fn _md_cmd_toggle_preview(state: MdEditorState, content: text) -> MdCommandResult:
    val new_visible = not state.preview_visible
    var new_preview = state.preview
    if new_visible:
        new_preview = preview_pane_update(state.preview, content)
    val new_state = MdEditorState(
        preview: new_preview,
        outline: state.outline,
        preview_visible: new_visible,
        outline_visible: state.outline_visible
    )
    var msg = "Preview hidden"
    if new_visible:
        msg = "Preview shown"
    _md_result_no_change(new_state, msg)

fn _md_cmd_toggle_outline(state: MdEditorState, content: text) -> MdCommandResult:
    val new_visible = not state.outline_visible
    var new_outline = state.outline
    if new_visible:
        new_outline = outline_panel_update(state.outline, content)
    else:
        new_outline = outline_panel_toggle(state.outline)
    val new_state = MdEditorState(
        preview: state.preview,
        outline: new_outline,
        preview_visible: state.preview_visible,
        outline_visible: new_visible
    )
    var msg = "Outline hidden"
    if new_visible:
        msg = "Outline shown"
    _md_result_no_change(new_state, msg)

fn _md_cmd_toggle_task(state: MdEditorState, current_line: text) -> MdCommandResult:
    val toggled = md_assist_toggle_task(current_line)
    _md_result_replace(state, toggled, "")

fn _md_cmd_increase_heading(state: MdEditorState, current_line: text) -> MdCommandResult:
    val updated = md_assist_change_heading(current_line, 1)
    _md_result_replace(state, updated, "")

fn _md_cmd_decrease_heading(state: MdEditorState, current_line: text) -> MdCommandResult:
    val updated = md_assist_change_heading(current_line, -1)
    _md_result_replace(state, updated, "")

fn _md_cmd_insert_table(state: MdEditorState) -> MdCommandResult:
    val table = "| Header 1 | Header 2 | Header 3 |\n| --- | --- | --- |\n| Cell 1 | Cell 2 | Cell 3 |"
    _md_result_insert(state, table, 0)

fn _md_cmd_insert_link(state: MdEditorState) -> MdCommandResult:
    val link = "[text](url)"
    _md_result_insert(state, link, 1)

fn _md_cmd_insert_image(state: MdEditorState) -> MdCommandResult:
    val image = "![alt](url)"
    _md_result_insert(state, image, 2)

fn _md_cmd_insert_code_block(state: MdEditorState) -> MdCommandResult:
    val block = "```\n\n```"
    MdCommandResult(
        state: state,
        insert_text: block,
        replace_line: "",
        cursor_delta_line: 1,
        cursor_delta_col: 0,
        status_message: ""
    )

fn _md_cmd_format_bold(state: MdEditorState) -> MdCommandResult:
    _md_result_insert(state, "****", 2)

fn _md_cmd_format_italic(state: MdEditorState) -> MdCommandResult:
    _md_result_insert(state, "**", 1)

fn _md_cmd_format_strikethrough(state: MdEditorState) -> MdCommandResult:
    _md_result_insert(state, "~~~~", 2)

fn _md_cmd_document_stats(state: MdEditorState, content: text) -> MdCommandResult:
    val lines = content.split("\n")
    val line_count = lines.len()
    val words = content.split(" ")
    val word_count = words.len()
    val lc_text = _md_i64_to_text(line_count)
    val wc_text = _md_i64_to_text(word_count)
    val msg = "Lines: " + lc_text + "  Words: ~" + wc_text
    _md_result_no_change(state, msg)

fn _md_cmd_fold_all(state: MdEditorState) -> MdCommandResult:
    _md_result_no_change(state, "Fold all — handled by fold system")

fn _md_cmd_unfold_all(state: MdEditorState) -> MdCommandResult:
    _md_result_no_change(state, "Unfold all — handled by fold system")

fn _md_cmd_goto_heading(state: MdEditorState) -> MdCommandResult:
    _md_result_no_change(state, "Open the Outline panel (ctrl+shift+o) to navigate headings")

# Convert a non-negative i64 to text for status messages.
fn _md_i64_to_text(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var remaining = n
    while remaining > 0:
        val d = remaining - (remaining / 10) * 10
        if d == 0:
            digits.push("0")
        elif d == 1:
            digits.push("1")
        elif d == 2:
            digits.push("2")
        elif d == 3:
            digits.push("3")
        elif d == 4:
            digits.push("4")
        elif d == 5:
            digits.push("5")
        elif d == 6:
            digits.push("6")
        elif d == 7:
            digits.push("7")
        elif d == 8:
            digits.push("8")
        else:
            digits.push("9")
        remaining = remaining / 10
    var result = ""
    var i = digits.len() - 1
    while i >= 0:
        result = result + digits[i]
        i = i - 1
    result

fn _md_get_line(content: text, line_idx: i64) -> text:
    var start = 0
    var current_line = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            if current_line == line_idx:
                return content.slice(start, i)
            current_line = current_line + 1
            start = i + 1
        i = i + 1
    if current_line == line_idx:
        return content.slice(start, content.len())
    ""

fn md_commands_dispatch(command: text, state: MdEditorState, content: text, cursor_line: i64, cursor_col: i64) -> MdCommandResult:
    val current_line = _md_get_line(content, cursor_line)
    if command == "markdown.togglePreview":
        return _md_cmd_toggle_preview(state, content)
    if command == "markdown.toggleOutline":
        return _md_cmd_toggle_outline(state, content)
    if command == "markdown.toggleTask":
        return _md_cmd_toggle_task(state, current_line)
    if command == "markdown.increaseHeading":
        return _md_cmd_increase_heading(state, current_line)
    if command == "markdown.decreaseHeading":
        return _md_cmd_decrease_heading(state, current_line)
    if command == "markdown.insertTable":
        return _md_cmd_insert_table(state)
    if command == "markdown.insertLink":
        return _md_cmd_insert_link(state)
    if command == "markdown.insertImage":
        return _md_cmd_insert_image(state)
    if command == "markdown.insertCodeBlock":
        return _md_cmd_insert_code_block(state)
    if command == "markdown.formatBold":
        return _md_cmd_format_bold(state)
    if command == "markdown.formatItalic":
        return _md_cmd_format_italic(state)
    if command == "markdown.formatStrikethrough":
        return _md_cmd_format_strikethrough(state)
    if command == "markdown.documentStats":
        return _md_cmd_document_stats(state, content)
    if command == "markdown.foldAll":
        return _md_cmd_fold_all(state)
    if command == "markdown.unfoldAll":
        return _md_cmd_unfold_all(state)
    if command == "markdown.gotoHeading":
        return _md_cmd_goto_heading(state)
    _md_result_no_change(state, "Unknown command: " + command)
