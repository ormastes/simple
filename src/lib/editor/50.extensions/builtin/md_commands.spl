# Markdown Command Dispatch
#
# Registers all markdown commands for the command palette, provides a
# command dispatch function, and defines markdown-specific keybindings.
# Depends on: command_palette, keybindings, dock_zone, preview_pane,
#             outline_panel, md_edit_assist.

struct MdEditorState:
    preview: PreviewPane
    outline: OutlinePanel
    preview_visible: bool
    outline_visible: bool

struct MdCommandResult:
    state: MdEditorState
    insert_text: text
    replace_line: text
    cursor_delta_line: i64
    cursor_delta_col: i64
    status_message: text

fn md_editor_state_new() -> MdEditorState:
    val preview = preview_pane_create(0)
    val outline = outline_panel_new()
    MdEditorState(
        preview: preview,
        outline: outline,
        preview_visible: false,
        outline_visible: false
    )

