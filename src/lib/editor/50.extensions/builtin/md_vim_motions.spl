# Vim-style Markdown Navigation Motions
#
# Provides vim-style motions for navigating markdown structure:
#   ]] / [[  next/prev heading
#   ]h / [h  next/prev sibling heading (same level)
#   [p       parent heading (one level up)
#   ]l / [l  next/prev link
#   ]c / [c  next/prev code fence
#   gx       open/extract link under cursor
#   za       fold range for heading section
#   viH      visual inner heading section
#   vip      paragraph text object

struct MdMotionResult:
    line: i64
    col: i64
    found: bool

# Split content into lines
fn _md_vim_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines

# Return heading level (number of leading #), 0 if not a heading
fn _md_vim_heading_level(line: text) -> i64:
    val trimmed = line.trim()
    if not trimmed.starts_with("#"):
        return 0
    var count = 0
    var i = 0
    while i < trimmed.len():
        if trimmed.char_at(i) == "#":
            count = count + 1
        else:
            i = trimmed.len()
        i = i + 1
    # Must have a space after hashes to be a valid heading
    if count >= trimmed.len():
        return 0
    if trimmed.char_at(count) != " ":
        return 0
    count

# ]] motion: jump to next heading (line starting with #)
fn md_vim_next_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var i = cursor_line + 1
    while i < lines.len():
        val level = _md_vim_heading_level(lines[i])
        if level > 0:
            return MdMotionResult(line: i, col: 0, found: true)
        i = i + 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# [[ motion: jump to previous heading
fn md_vim_prev_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var i = cursor_line - 1
    while i >= 0:
        val level = _md_vim_heading_level(lines[i])
        if level > 0:
            return MdMotionResult(line: i, col: 0, found: true)
        i = i - 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# ]h motion: jump to next heading at same level
fn md_vim_next_sibling_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    # Find current heading level by scanning at or before cursor_line
    var current_level = _md_vim_heading_level(lines[cursor_line])
    if current_level == 0:
        # Scan backward to find enclosing heading
        var k = cursor_line - 1
        while k >= 0:
            val lv = _md_vim_heading_level(lines[k])
            if lv > 0:
                current_level = lv
                k = -1
            k = k - 1
    if current_level == 0:
        return MdMotionResult(line: cursor_line, col: 0, found: false)
    var i = cursor_line + 1
    while i < lines.len():
        val level = _md_vim_heading_level(lines[i])
        if level == current_level:
            return MdMotionResult(line: i, col: 0, found: true)
        if level > 0 and level < current_level:
            i = lines.len()
        i = i + 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# [h motion: jump to previous heading at same level
fn md_vim_prev_sibling_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var current_level = _md_vim_heading_level(lines[cursor_line])
    if current_level == 0:
        var k = cursor_line - 1
        while k >= 0:
            val lv = _md_vim_heading_level(lines[k])
            if lv > 0:
                current_level = lv
                k = -1
            k = k - 1
    if current_level == 0:
        return MdMotionResult(line: cursor_line, col: 0, found: false)
    var i = cursor_line - 1
    while i >= 0:
        val level = _md_vim_heading_level(lines[i])
        if level == current_level:
            return MdMotionResult(line: i, col: 0, found: true)
        if level > 0 and level < current_level:
            i = -1
        i = i - 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# [p motion: jump to parent heading (one level up)
fn md_vim_parent_heading(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var current_level = _md_vim_heading_level(lines[cursor_line])
    if current_level == 0:
        # Scan backward to find enclosing heading first
        var k = cursor_line - 1
        while k >= 0:
            val lv = _md_vim_heading_level(lines[k])
            if lv > 0:
                current_level = lv
                k = -1
            k = k - 1
    if current_level <= 1:
        return MdMotionResult(line: cursor_line, col: 0, found: false)
    val parent_level = current_level - 1
    var i = cursor_line - 1
    while i >= 0:
        val level = _md_vim_heading_level(lines[i])
        if level == parent_level:
            return MdMotionResult(line: i, col: 0, found: true)
        i = i - 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# Check if a character at position in line starts a markdown link ([ not preceded by !)
fn _md_vim_is_link_start(line: text, pos: i64) -> bool:
    if line.char_at(pos) != "[":
        return false
    if pos > 0:
        if line.char_at(pos - 1) == "!":
            return false
    true

# ]l motion: jump to next link [text](url) or [[wikilink]]
fn md_vim_next_link(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var ln = cursor_line
    var start_col = cursor_col + 1
    while ln < lines.len():
        val line = lines[ln]
        var col = start_col
        while col < line.len():
            if _md_vim_is_link_start(line, col):
                return MdMotionResult(line: ln, col: col, found: true)
            col = col + 1
        ln = ln + 1
        start_col = 0
    MdMotionResult(line: cursor_line, col: cursor_col, found: false)

# [l motion: jump to previous link
fn md_vim_prev_link(content: text, cursor_line: i64, cursor_col: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var ln = cursor_line
    var end_col = cursor_col - 1
    while ln >= 0:
        val line = lines[ln]
        var col = end_col
        if col >= line.len():
            col = line.len() - 1
        while col >= 0:
            if _md_vim_is_link_start(line, col):
                return MdMotionResult(line: ln, col: col, found: true)
            col = col - 1
        ln = ln - 1
        if ln >= 0:
            end_col = lines[ln].len() - 1
    MdMotionResult(line: cursor_line, col: cursor_col, found: false)

# Check if line is a code fence (``` or ~~~)
fn _md_vim_is_code_fence(line: text) -> bool:
    val trimmed = line.trim()
    if trimmed.starts_with("```"):
        return true
    if trimmed.starts_with("~~~"):
        return true
    false

# ]c motion: jump to next code fence
fn md_vim_next_code_block(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var i = cursor_line + 1
    while i < lines.len():
        if _md_vim_is_code_fence(lines[i]):
            return MdMotionResult(line: i, col: 0, found: true)
        i = i + 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# [c motion: jump to previous code fence
fn md_vim_prev_code_block(content: text, cursor_line: i64) -> MdMotionResult:
    val lines = _md_vim_split_lines(content)
    var i = cursor_line - 1
    while i >= 0:
        if _md_vim_is_code_fence(lines[i]):
            return MdMotionResult(line: i, col: 0, found: true)
        i = i - 1
    MdMotionResult(line: cursor_line, col: 0, found: false)

# gx motion: extract URL from link under cursor
# Returns "" if no link found at cursor position
fn md_vim_open_link_under_cursor(content: text, cursor_line: i64, cursor_col: i64) -> text:
    val lines = _md_vim_split_lines(content)
    if cursor_line < 0 or cursor_line >= lines.len():
        return ""
    val line = lines[cursor_line]
    # Try [[wikilink]] pattern first
    var i = 0
    while i < line.len():
        if line.char_at(i) == "[":
            if i + 1 < line.len():
                if line.char_at(i + 1) == "[":
                    # Find closing ]]
                    var j = i + 2
                    while j < line.len():
                        if line.char_at(j) == "]":
                            if j + 1 < line.len():
                                if line.char_at(j + 1) == "]":
                                    if cursor_col >= i and cursor_col <= j + 1:
                                        return line.slice(i + 2, j)
                                    j = line.len()
                        j = j + 1
        i = i + 1
    # Try [text](url) pattern
    i = 0
    while i < line.len():
        if _md_vim_is_link_start(line, i):
            # Find closing ]
            var j = i + 1
            while j < line.len():
                if line.char_at(j) == "]":
                    if j + 1 < line.len():
                        if line.char_at(j + 1) == "(":
                            # Find closing )
                            var k = j + 2
                            while k < line.len():
                                if line.char_at(k) == ")":
                                    if cursor_col >= i and cursor_col <= k:
                                        return line.slice(j + 2, k)
                                    k = line.len()
                                k = k + 1
                    j = line.len()
                j = j + 1
        i = i + 1
    # Try raw URL (http:// or https://)
    i = 0
    while i < line.len():
        val remaining = line.slice(i, line.len())
        if remaining.starts_with("http://") or remaining.starts_with("https://"):
            # Find end of URL (space, ), >, or end of line)
            var j = i
            while j < line.len():
                val ch = line.char_at(j)
                if ch == " " or ch == ")" or ch == ">" or ch == "\"":
                    j = line.len() + 1
                j = j + 1
            var url_end = j
            if url_end > line.len():
                url_end = line.len()
            if cursor_col >= i and cursor_col < url_end:
                return line.slice(i, url_end)
        i = i + 1
    ""

# za motion: return (from_line, to_line) range of heading section at cursor
# Returns the range from heading line to the line before the next same-or-higher-level heading
fn md_vim_toggle_fold_heading(content: text, cursor_line: i64) -> (i64, i64):
    val lines = _md_vim_split_lines(content)
    # Find the heading at or before cursor
    var heading_line = cursor_line
    var heading_level = _md_vim_heading_level(lines[cursor_line])
    if heading_level == 0:
        var k = cursor_line - 1
        while k >= 0:
            val lv = _md_vim_heading_level(lines[k])
            if lv > 0:
                heading_line = k
                heading_level = lv
                k = -1
            k = k - 1
    if heading_level == 0:
        return (cursor_line, cursor_line)
    # Scan forward for next heading at same or higher level (lower number)
    var end_line = lines.len() - 1
    var i = heading_line + 1
    while i < lines.len():
        val lv = _md_vim_heading_level(lines[i])
        if lv > 0 and lv <= heading_level:
            end_line = i - 1
            i = lines.len()
        i = i + 1
    (heading_line, end_line)

# viH motion: select entire heading section content (excluding heading line)
# Returns (start_line, end_line) of section body
fn md_vim_select_heading_section(content: text, cursor_line: i64) -> (i64, i64):
    val range = md_vim_toggle_fold_heading(content, cursor_line)
    val from_line = range.0
    val to_line = range.1
    if from_line >= to_line:
        return (from_line, from_line)
    (from_line + 1, to_line)

# vip for markdown: select paragraph block (between blank lines or block boundaries)
# Respects markdown block boundaries (headings, code fences, lists)
fn md_vim_markdown_text_object_paragraph(content: text, cursor_line: i64) -> (i64, i64):
    val lines = _md_vim_split_lines(content)
    if cursor_line < 0 or cursor_line >= lines.len():
        return (cursor_line, cursor_line)
    # Check if cursor is on a blank line — move to nearest non-blank
    var anchor = cursor_line
    if lines[anchor].trim() == "":
        # Try forward first
        var fwd = anchor + 1
        while fwd < lines.len():
            if lines[fwd].trim() != "":
                anchor = fwd
                fwd = lines.len()
            fwd = fwd + 1
    # If still blank, no paragraph
    if lines[anchor].trim() == "":
        return (cursor_line, cursor_line)
    # Extend upward until blank line or block boundary
    var start = anchor
    var i = anchor - 1
    while i >= 0:
        val trimmed = lines[i].trim()
        if trimmed == "":
            i = -1
        else:
            if _md_vim_heading_level(lines[i]) > 0:
                i = -1
            else:
                if _md_vim_is_code_fence(lines[i]):
                    i = -1
                else:
                    start = i
                    i = i - 1
    # Extend downward until blank line or block boundary
    var end_line = anchor
    var j = anchor + 1
    while j < lines.len():
        val trimmed = lines[j].trim()
        if trimmed == "":
            j = lines.len()
        else:
            if _md_vim_heading_level(lines[j]) > 0:
                j = lines.len()
            else:
                if _md_vim_is_code_fence(lines[j]):
                    j = lines.len()
                else:
                    end_line = j
                    j = j + 1
    (start, end_line)
