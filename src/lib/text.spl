# allow(star_import): shim module, delegates all symbols to common text implementation
# Shim: re-exports from lib/common/text.spl
# Allows `use std.text.{...}` to resolve at runtime
export use lib.common.text.*

# Standalone wrappers for built-in string methods
fn each(s: text, f: fn(text) -> void):
    for c in s:
        f(c)

fn each_with_index(s: text, f: fn(i64, text) -> void):
    var i = 0
    for c in s:
        f(i, c)
        i = i + 1

fn levenshtein_distance(a: text, b: text) -> i64:
    val m = a.len()
    val n = b.len()
    if m == 0:
        return n
    if n == 0:
        return m

    var prev: [i64] = []
    var i = 0
    while i <= n:
        prev.push(i)
        i = i + 1

    i = 1
    while i <= m:
        var curr: [i64] = [i]
        var j = 1
        while j <= n:
            val cost = if a[i - 1] == b[j - 1]: 0 else: 1
            val del = prev[j] + 1
            val ins = curr[j - 1] + 1
            val sub = prev[j - 1] + cost
            var min_val = del
            if ins < min_val:
                min_val = ins
            if sub < min_val:
                min_val = sub
            curr.push(min_val)
            j = j + 1
        prev = curr
        i = i + 1

    prev[n]

extern fn rt_string_ends_with(s: text, suffix: text) -> bool
extern fn rt_string_rfind(s: text, needle: text) -> i64?

# reason: positional text API
fn ends_with(s: text, suffix: text) -> bool:
    rt_string_ends_with(s, suffix)

# reason: positional text API — delegates to rt_string_rfind to avoid
# self-recursion (s.last_index_of would resolve back to this function)
fn last_index_of(s: text, needle: text) -> i64?:
    rt_string_rfind(s, needle)

# Re-export functions from common/text.spl
