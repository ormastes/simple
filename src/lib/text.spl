# reason: positional API (Tier A algorithmic library) + star_import for re-exported module symbols
@allow(unnamed_duplicate_typed_args, star_import) # reason: multi-param same-type API with submodule re-exports
# Shim: re-exports from lib/common/text.spl
# Allows `use std.text.{...}` to resolve at runtime
use lib.common.text.*

# Standalone wrappers for built-in string methods
fn each(s: text, f):
    for c in s:
        f(c)

fn each_with_index(s: text, f):
    var i = 0
    for c in s:
        f(i, c)
        i = i + 1

fn ends_with(s: text, suffix: text) -> bool:
    s.ends_with(suffix)

fn last_index_of(s: text, needle: text) -> i64?:
    s.last_index_of(needle)

# Re-export functions from common/text.spl
