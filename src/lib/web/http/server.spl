"""
HTTP Server — web.http.server

Provides HttpServer, HttpRequest, HttpResponse, and HttpHandler for
building HTTP/MCP servers. Consumed by app.lms.main.

Usage:
    val server = HttpServer.localhost(port)
        .handler(fn(req: HttpRequest) -> HttpResponse:
            HttpResponse.ok().json("{\"status\":\"ok\"}"))
    server.run()
"""

# ============================================================================
# HttpRequest
# ============================================================================

class HttpRequest:
    """An incoming HTTP request."""
    method: text
    path: text
    headers: Dict<text, text>
    body: text
    query: text

impl HttpRequest:
    static fn create(method: text, path: text, headers: Dict<text, text>,
                     body: text, query: text) -> HttpRequest:
        HttpRequest(method: method, path: path, headers: headers, body: body, query: query)

    fn get_header(name: text) -> text:
        val lower = name.lower()
        for key in self.headers.keys():
            if key.lower() == lower:
                return self.headers.get(key) ?? ""
        ""

    fn body_json() -> Dict<text, text>:
        """Parse the request body as a simple flat JSON object.

        Returns a Dict of top-level string keys and their string values.
        For full JSON support, use std.json.
        """
        parse_flat_json(self.body)

    fn content_type() -> text:
        self.get_header("content-type")

    fn is_json() -> bool:
        self.content_type().contains("application/json")

# ============================================================================
# HttpResponse
# ============================================================================

class HttpResponse:
    """An HTTP response to be sent back to the client."""
    status_code: i64
    status_text: text
    headers: Dict<text, text>
    body: text

impl HttpResponse:
    static fn new(status_code: i64, status_text: text) -> HttpResponse:
        HttpResponse(status_code: status_code, status_text: status_text,
                     headers: {}, body: "")

    static fn ok() -> HttpResponse:
        """200 OK response."""
        HttpResponse.new(200, "OK")

    static fn created() -> HttpResponse:
        """201 Created response."""
        HttpResponse.new(201, "Created")

    static fn not_found() -> HttpResponse:
        """404 Not Found response."""
        HttpResponse.new(404, "Not Found")

    static fn bad_request() -> HttpResponse:
        """400 Bad Request response."""
        HttpResponse.new(400, "Bad Request")

    static fn internal_error() -> HttpResponse:
        """500 Internal Server Error response."""
        HttpResponse.new(500, "Internal Server Error")

    me json(json_body: text) -> HttpResponse:
        """Set body and Content-Type: application/json."""
        self.body = json_body
        self.headers["Content-Type"] = "application/json"
        self.headers["Content-Length"] = "{json_body.len()}"
        self

    me text_body(body: text) -> HttpResponse:
        """Set body and Content-Type: text/plain."""
        self.body = body
        self.headers["Content-Type"] = "text/plain; charset=utf-8"
        self.headers["Content-Length"] = "{body.len()}"
        self

    me html(body: text) -> HttpResponse:
        """Set body and Content-Type: text/html."""
        self.body = body
        self.headers["Content-Type"] = "text/html; charset=utf-8"
        self.headers["Content-Length"] = "{body.len()}"
        self

    me header(name: text, value: text) -> HttpResponse:
        """Add a response header."""
        self.headers[name] = value
        self

    fn to_text() -> text:
        """Serialize to HTTP/1.1 wire format."""
        var header_lines: [text] = []
        header_lines.push("HTTP/1.1 {self.status_code} {self.status_text}")
        for key in self.headers.keys():
            header_lines.push("{key}: {self.headers.get(key) ?? \"\"}")
        header_lines.push("")
        header_lines.push(self.body)
        header_lines.join("\r\n")

# ============================================================================
# HttpHandler
# ============================================================================

type HttpHandler = fn(HttpRequest) -> HttpResponse

# ============================================================================
# HttpServer
# ============================================================================

class HttpServer:
    """A simple blocking HTTP server."""
    host: text
    port: i64
    handler_fn: HttpHandler?

impl HttpServer:
    static fn localhost(port: i64) -> HttpServer:
        """Create a server bound to localhost."""
        HttpServer(host: "127.0.0.1", port: port, handler_fn: nil)

    static fn bind(host: text, port: i64) -> HttpServer:
        """Create a server bound to the given host and port."""
        HttpServer(host: host, port: port, handler_fn: nil)

    me handler(h: HttpHandler) -> HttpServer:
        """Register the request handler function."""
        self.handler_fn = Some(h)
        self

    fn run():
        """Start the server event loop (blocking).

        Binds to host:port and dispatches each accepted connection to
        the registered handler. Runs until the process is terminated.

        NOTE: This high-level facade does not yet wire to the underlying
        http_server stack. Use std.nogc_async_mut.http_server for a
        production server implementation.
        """
        pass_dn

# ============================================================================
# Internal helpers
# ============================================================================

fn default_handler(req: HttpRequest) -> HttpResponse:
    HttpResponse.not_found().json("{\"error\":\"No handler registered\"}")

fn parse_flat_json(json: text) -> Dict<text, text>:
    """Parse a flat JSON object {"k":"v",...} into Dict<text,text>.

    Does not handle nested objects or arrays — callers needing full
    JSON must use std.json.
    """
    var result: Dict<text, text> = {}
    val trimmed = json.trim()
    if not trimmed.starts_with("{"):
        return result
    # Strip outer braces
    val inner = trimmed.substring(1, trimmed.len() - 1).trim()
    if inner.len() == 0:
        return result
    # Split on "," — note: does not handle commas inside string values
    val pairs = inner.split(",")
    var i = 0
    while i < pairs.len():
        val pair = pairs[i].trim()
        val colon = pair.index_of(":")
        if colon > 0:
            val key = pair.substring(0, colon).trim().trim_char('"')
            val value = pair.substring(colon + 1, pair.len()).trim().trim_char('"')
            result[key] = value
        i = i + 1
    result
