# Pure GUI SMF/dynlib hot-response perf contract.
#
# This module evaluates measured hot-path samples. It does not render pixels and
# does not load platform GUI runtimes; callers provide loader evidence and timing
# samples from the SMF/dynlib probe.

class GuiDynlibPerfStats:
    p50_us: i64
    p95_us: i64
    p99_us: i64
    max_us: i64
    sample_count: i32

class GuiDynlibPerfReport:
    artifact_path: text
    dynlib_path: text
    loader_mode: text
    symbol_name: text
    call_source: text
    symbol_resolved: bool
    fallback_used: bool
    warmup_count: i32
    stats: GuiDynlibPerfStats
    threshold_us: i64
    pass: bool
    error: text

fn _sort_i64(values: [i64]) -> [i64]:
    var out: [i64] = []
    for value in values:
        out.push(value)
    var i = 1
    while i < out.len():
        val key = out[i]
        var j = i - 1
        while j >= 0 and out[j] > key:
            out[j + 1] = out[j]
            j = j - 1
        out[j + 1] = key
        i = i + 1
    out

fn _percentile_nearest_rank(sorted: [i64], percentile: i32) -> i64:
    if sorted.len() == 0:
        return 0
    var rank = (sorted.len() * percentile + 99) / 100
    if rank <= 0:
        rank = 1
    val idx = rank - 1
    if idx >= sorted.len():
        return sorted[sorted.len() - 1]
    sorted[idx]

fn gui_dynlib_perf_stats(samples_us: [i64]) -> GuiDynlibPerfStats:
    val sorted = _sort_i64(samples_us)
    val max = if sorted.len() == 0: 0 else: sorted[sorted.len() - 1]
    GuiDynlibPerfStats(
        p50_us: _percentile_nearest_rank(sorted, 50),
        p95_us: _percentile_nearest_rank(sorted, 95),
        p99_us: _percentile_nearest_rank(sorted, 99),
        max_us: max,
        sample_count: samples_us.len()
    )

fn gui_dynlib_perf_error(artifact_path: text, loader_mode: text, call_source: text, symbol_resolved: bool, fallback_used: bool, samples_us: [i64], threshold_us: i64) -> text:
    if artifact_path == "":
        return "missing-artifact-path"
    if loader_mode != "smf_dynlib":
        return "not-smf-dynlib"
    if not symbol_resolved:
        return "symbol-not-resolved"
    if call_source != "dynlib_symbol_call":
        return "not-dynlib-hot-call"
    if fallback_used:
        return "fallback-used"
    if samples_us.len() == 0:
        return "missing-samples"
    val stats = gui_dynlib_perf_stats(samples_us)
    if stats.p99_us >= threshold_us:
        return "p99-over-threshold"
    ""

fn gui_dynlib_perf_report(artifact_path: text, dynlib_path: text, loader_mode: text, symbol_name: text, call_source: text, symbol_resolved: bool, fallback_used: bool, warmup_count: i32, samples_us: [i64], threshold_us: i64) -> GuiDynlibPerfReport:
    val stats = gui_dynlib_perf_stats(samples_us)
    val error = gui_dynlib_perf_error(artifact_path, loader_mode, call_source, symbol_resolved, fallback_used, samples_us, threshold_us)
    GuiDynlibPerfReport(
        artifact_path: artifact_path,
        dynlib_path: dynlib_path,
        loader_mode: loader_mode,
        symbol_name: symbol_name,
        call_source: call_source,
        symbol_resolved: symbol_resolved,
        fallback_used: fallback_used,
        warmup_count: warmup_count,
        stats: stats,
        threshold_us: threshold_us,
        pass: error == "",
        error: error
    )

fn gui_dynlib_perf_report_row(report: GuiDynlibPerfReport) -> text:
        "GUI_DYNLIB_PERF artifact=" + report.artifact_path +
        " dynlib_path=" + report.dynlib_path +
        " loader=" + report.loader_mode +
        " symbol=" + report.symbol_name +
        " call_source=" + report.call_source +
        " samples=" + report.stats.sample_count.to_text() +
        " warmup=" + report.warmup_count.to_text() +
        " p50_us=" + report.stats.p50_us.to_text() +
        " p95_us=" + report.stats.p95_us.to_text() +
        " p99_us=" + report.stats.p99_us.to_text() +
        " max_us=" + report.stats.max_us.to_text() +
        " threshold_us=" + report.threshold_us.to_text() +
        " pass=" + report.pass.to_text() +
        " error=" + report.error
