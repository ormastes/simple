# Pure GUI release-lane exports for SMF/dynlib loading.
#
# This module intentionally excludes BrowserWindow, WM, Simple Web, Skia, and
# native GUI runtime surfaces. The macOS/SMF release path should import this
# module or the two pure modules below directly.

use std.gui.pure_core.{GuiInputEvent, GuiCommand, GuiCommandBatch, GuiDirtyRegion, GuiPerfCounters, gui_pointer_event, gui_key_event, gui_empty_batch, gui_dispatch_events, gui_batch_meets_hot_response_target, gui_dynlib_hot_probe_tick}
use std.gui.pure_smf_dynlib_perf.{GuiDynlibPerfStats, GuiDynlibPerfReport, gui_dynlib_perf_stats, gui_dynlib_perf_error, gui_dynlib_perf_report, gui_dynlib_perf_report_row}
