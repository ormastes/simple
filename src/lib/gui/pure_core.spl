# Pure Simple GUI command boundary.
#
# This module is intentionally independent of WM, Simple Web, and native GUI
# runtime externs. It is the value-level ABI that can be emitted as SMF and
# called from a dynlib-loaded artifact.

class GuiInputEvent:
    kind: text
    target_id: text
    x: i32
    y: i32
    key: text
    text_value: text

class GuiCommand:
    kind: text
    target_id: text
    x: i32
    y: i32
    w: i32
    h: i32
    value: text

class GuiDirtyRegion:
    x: i32
    y: i32
    w: i32
    h: i32

class GuiPerfCounters:
    event_count: i32
    command_count: i32
    dirty_region_count: i32
    elapsed_us: i64

class GuiCommandBatch:
    commands: [GuiCommand]
    dirty_regions: [GuiDirtyRegion]
    counters: GuiPerfCounters

fn gui_pointer_event(kind: text, target_id: text, x: i32, y: i32) -> GuiInputEvent:
    GuiInputEvent(kind: kind, target_id: target_id, x: x, y: y, key: "", text_value: "")

fn gui_key_event(target_id: text, key: text, text_value: text) -> GuiInputEvent:
    GuiInputEvent(kind: "key", target_id: target_id, x: 0, y: 0, key: key, text_value: text_value)

fn gui_empty_batch() -> GuiCommandBatch:
    GuiCommandBatch(
        commands: [],
        dirty_regions: [],
        counters: GuiPerfCounters(event_count: 0, command_count: 0, dirty_region_count: 0, elapsed_us: 0)
    )

fn _command_for_event(ev: GuiInputEvent) -> GuiCommand:
    match ev.kind:
        "pointer_move":
            GuiCommand(kind: "hover", target_id: ev.target_id, x: ev.x, y: ev.y, w: 1, h: 1, value: "")
        "pointer_down":
            GuiCommand(kind: "activate", target_id: ev.target_id, x: ev.x, y: ev.y, w: 1, h: 1, value: "")
        "pointer_up":
            GuiCommand(kind: "commit", target_id: ev.target_id, x: ev.x, y: ev.y, w: 1, h: 1, value: "")
        "key":
            GuiCommand(kind: "text_input", target_id: ev.target_id, x: 0, y: 0, w: 0, h: 0, value: ev.text_value)
        _:
            GuiCommand(kind: "ignore", target_id: ev.target_id, x: ev.x, y: ev.y, w: 0, h: 0, value: "")

fn _dirty_for_command(cmd: GuiCommand) -> GuiDirtyRegion:
    val w = if cmd.w <= 0: 1 else: cmd.w
    val h = if cmd.h <= 0: 1 else: cmd.h
    GuiDirtyRegion(x: cmd.x, y: cmd.y, w: w, h: h)

fn gui_dispatch_events(events: [GuiInputEvent], elapsed_us: i64) -> GuiCommandBatch:
    var commands: [GuiCommand] = []
    var dirty: [GuiDirtyRegion] = []
    for ev in events:
        val cmd = _command_for_event(ev)
        if cmd.kind != "ignore":
            commands.push(cmd)
            dirty.push(_dirty_for_command(cmd))
    GuiCommandBatch(
        commands: commands,
        dirty_regions: dirty,
        counters: GuiPerfCounters(
            event_count: events.len(),
            command_count: commands.len(),
            dirty_region_count: dirty.len(),
            elapsed_us: elapsed_us
        )
    )

fn gui_batch_meets_hot_response_target(batch: GuiCommandBatch, threshold_us: i64) -> bool:
    batch.counters.elapsed_us < threshold_us

fn _hot_probe_emits_command(kind: text) -> i64:
    match kind:
        "pointer_move":
            1
        "pointer_down":
            1
        "pointer_up":
            1
        "key":
            1
        _:
            0

fn gui_representative_hot_probe_command_count(iteration: i64) -> i64:
    _hot_probe_emits_command("pointer_move") +
        _hot_probe_emits_command("pointer_down") +
        _hot_probe_emits_command("pointer_up") +
        _hot_probe_emits_command("key")

fn gui_dynlib_hot_probe_tick(iteration: i64) -> i64:
    gui_representative_hot_probe_command_count(iteration)
