# Menu and MenuItem: application menu model mirroring Electron's Menu API

enum MenuItemKind:
    Normal
    Separator
    Checkbox
    Radio
    Submenu

class MenuItem:
    id: i32
    label: text
    kind: MenuItemKind
    enabled: bool
    checked: bool
    accelerator: text
    submenu_id: i32

class Menu:
    id: i32
    items: [MenuItem]

    static fn new(id: i32) -> Menu:
        Menu(id: id, items: [MenuItem]())

    me append(item: MenuItem):
        me.items = me.items + [item]

    me item_count() -> i32:
        me.items.len().to_i32()
