# BrowserWindow: native window chrome + compositing target, mirroring Electron's BrowserWindow

use std.content.entity.web_contents.{WebContents}
use std.content.feature.render_widget_host_view.{RenderWidgetHostView}
use std.skia.entity.geometry.{SkRect, SkISize}
use std.skia.entity.color.{SkColor4f}

class WindowStyle:
    frame: bool
    transparent: bool
    title_bar_visible: bool
    resizable: bool
    background: SkColor4f

    static fn default() -> WindowStyle:
        WindowStyle(
            frame: true,
            transparent: false,
            title_bar_visible: true,
            resizable: true,
            background: SkColor4f(r: 1.0, g: 1.0, b: 1.0, a: 1.0)
        )

class BrowserWindow:
    id: i32
    title: text
    bounds: SkRect
    style: WindowStyle
    web_contents: WebContents
    view: RenderWidgetHostView
    device_scale_factor: f64
    is_visible: bool

    static fn new(id: i32, title: text, bounds: SkRect, web_contents: WebContents, view: RenderWidgetHostView) -> BrowserWindow:
        BrowserWindow(
            id: id,
            title: title,
            bounds: bounds,
            style: WindowStyle.default(),
            web_contents: web_contents,
            view: view,
            device_scale_factor: 1.0,
            is_visible: false
        )

    me show():
        me.is_visible = true

    me hide():
        me.is_visible = false

    me set_title(title: text):
        me.title = title

    me set_bounds(bounds: SkRect):
        me.bounds = bounds

    me set_device_scale_factor(dpi: f64):
        me.device_scale_factor = dpi
