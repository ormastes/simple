# Shim: std.debug → nogc_sync_mut.debugger
# Explicit re-export shim for interpreter-mode module resolution.
# Renamed from nogc_sync_mut.debug to nogc_sync_mut.debugger because the
# directory nogc_sync_mut/debug/ shadowed the file nogc_sync_mut/debug.spl,
# preventing resolution of file-level symbols. See:
#   doc/08_tracking/bug/loader_init_sibling_export_2026-04-28.md
# (lint: L:export_outside_init)
use nogc_sync_mut.debugger.{
    DebugLevel, StepMode, Breakpoint, StackFrame, Debugger,
    debugger_new, level_to_int, should_print, debug_print, handle_debug_command
}

export DebugLevel, StepMode, Breakpoint, StackFrame, Debugger
export debugger_new, level_to_int, should_print, debug_print, handle_debug_command
