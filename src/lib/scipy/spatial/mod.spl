use std.ndarray.*

fn squared_euclidean(left: NDArray, right: NDArray) -> Result<Float64, NdarrayError>:
    if left.dtype != DType.F64 or right.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if left.shape.dims.len() != 1 or right.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if left.len() != right.len():
        return Err(NdarrayError.ShapeMismatch)
    var total = 0.0
    var i = 0
    while i < left.len().value:
        val delta = left.flat_f64(i).value - right.flat_f64(i).value
        total = total + delta * delta
        i = i + 1
    Ok(Float64.new(total))

fn euclidean(left: NDArray, right: NDArray) -> Result<Float64, NdarrayError>:
    val squared = squared_euclidean(left, right)?
    Ok(Float64.new(sqrt_f64(squared.value)))

fn pairwise_squared_euclidean(left: NDArray, right: NDArray) -> Result<NDArray, NdarrayError>:
    if left.dtype != DType.F64 or right.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if left.shape.dims.len() != 2 or right.shape.dims.len() != 2:
        return Err(NdarrayError.InvalidShape)
    if left.cols() != right.cols():
        return Err(NdarrayError.ShapeMismatch)
    var out: [Float64] = []
    var left_row = 0
    while left_row < left.rows().value:
        var right_row = 0
        while right_row < right.rows().value:
            var total = 0.0
            var col = 0
            while col < left.cols().value:
                val delta = left.get_f64_at([Index.new(left_row), Index.new(col)]).value - right.get_f64_at([Index.new(right_row), Index.new(col)]).value
                total = total + delta * delta
                col = col + 1
            out.push(Float64.new(total))
            right_row = right_row + 1
        left_row = left_row + 1
    Ok(array(out).reshape(Shape.new([left.rows(), right.rows()])))

fn sqrt_f64(value: f64) -> f64:
    if value <= 0.0:
        return 0.0
    var estimate = value
    if estimate < 1.0:
        estimate = 1.0
    var i = 0
    while i < 20:
        estimate = 0.5 * (estimate + value / estimate)
        i = i + 1
    estimate
