use std.ndarray.*

fn erf_approx(x: Float64) -> Float64:
    if x.value == 0.0:
        return Float64.new(0.0)
    val sign = if x.value < 0.0: -1.0 else: 1.0
    var abs_x = x.value
    if abs_x < 0.0:
        abs_x = -abs_x
    val t = 1.0 / (1.0 + 0.3275911 * abs_x)
    val y = 1.0 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * exp_approx(-abs_x * abs_x)
    Float64.new(sign * y)

fn exp_approx(x: f64) -> f64:
    var term = 1.0
    var sum = 1.0
    var i = 1
    while i < 24:
        term = term * x / i
        sum = sum + term
        i = i + 1
    sum

fn factorial(n: Int64) -> Result<Int64, NdarrayError>:
    if n.value < 0:
        return Err(NdarrayError.InvalidShape)
    var out = 1
    var i = 2
    while i <= n.value:
        out = out * i
        i = i + 1
    Ok(Int64.new(out))

fn comb(n: Int64, k: Int64) -> Result<Int64, NdarrayError>:
    if n.value < 0 or k.value < 0 or k.value > n.value:
        return Err(NdarrayError.InvalidShape)
    var kk = k.value
    if kk > n.value - kk:
        kk = n.value - kk
    var result = 1
    var i = 1
    while i <= kk:
        result = (result * (n.value - kk + i)) / i
        i = i + 1
    Ok(Int64.new(result))
