use std.ndarray.*

fn convolve_full(values: NDArray, weights: NDArray) -> Result<NDArray, NdarrayError>:
    if values.dtype != DType.F64 or weights.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if values.shape.dims.len() != 1 or weights.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if values.len().value == 0 or weights.len().value == 0:
        return Err(NdarrayError.InvalidShape)
    val out_len = values.len().value + weights.len().value - 1
    var out: [Float64] = []
    var i = 0
    while i < out_len:
        var total = 0.0
        var k = 0
        while k < weights.len().value:
            val input_index = i - k
            if input_index >= 0 and input_index < values.len().value:
                total = total + values.flat_f64(input_index).value * weights.flat_f64(k).value
            k = k + 1
        out.push(Float64.new(total))
        i = i + 1
    Ok(array(out))

fn correlate_full(left: NDArray, right: NDArray) -> Result<NDArray, NdarrayError>:
    if left.dtype != DType.F64 or right.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if left.shape.dims.len() != 1 or right.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if left.len().value == 0 or right.len().value == 0:
        return Err(NdarrayError.InvalidShape)
    val out_len = left.len().value + right.len().value - 1
    val min_lag = 1 - right.len().value
    var out: [Float64] = []
    var offset = 0
    while offset < out_len:
        val lag = min_lag + offset
        var total = 0.0
        var i = 0
        while i < left.len().value:
            val j = i - lag
            if j >= 0 and j < right.len().value:
                total = total + left.flat_f64(i).value * right.flat_f64(j).value
            i = i + 1
        out.push(Float64.new(total))
        offset = offset + 1
    Ok(array(out))

fn moving_average(values: NDArray, window: Index) -> Result<NDArray, NdarrayError>:
    if values.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if values.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if window.value <= 0 or window.value > values.len().value:
        return Err(NdarrayError.InvalidShape)
    var out: [Float64] = []
    var start = 0
    while start <= values.len().value - window.value:
        var total = 0.0
        var i = 0
        while i < window.value:
            total = total + values.flat_f64(start + i).value
            i = i + 1
        out.push(Float64.new(total / window.value))
        start = start + 1
    Ok(array(out))

fn first_difference(values: NDArray) -> Result<NDArray, NdarrayError>:
    if values.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if values.shape.dims.len() != 1 or values.len().value < 2:
        return Err(NdarrayError.InvalidShape)
    var out: [Float64] = []
    var i = 1
    while i < values.len().value:
        val delta = values.flat_f64(i).value - values.flat_f64(i - 1).value
        out.push(Float64.new(delta))
        i = i + 1
    Ok(array(out))
