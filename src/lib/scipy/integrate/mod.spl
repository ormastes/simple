use std.ndarray.*

fn trapezoid(y: NDArray, x: NDArray) -> Result<Float64, NdarrayError>:
    if y.dtype != DType.F64 or x.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if y.shape.dims.len() != 1 or x.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if y.len() != x.len() or y.len().value < 2:
        return Err(NdarrayError.ShapeMismatch)
    var total = 0.0
    var i = 0
    while i < y.len().value - 1:
        val width = x.flat_f64(i + 1).value - x.flat_f64(i).value
        val height = (y.flat_f64(i).value + y.flat_f64(i + 1).value) * 0.5
        total = total + width * height
        i = i + 1
    Ok(Float64.new(total))

fn cumulative_trapezoid(y: NDArray, x: NDArray) -> Result<NDArray, NdarrayError>:
    if y.dtype != DType.F64 or x.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if y.shape.dims.len() != 1 or x.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if y.len() != x.len() or y.len().value < 2:
        return Err(NdarrayError.ShapeMismatch)
    var out: [Float64] = [Float64.new(0.0)]
    var total = 0.0
    var i = 0
    while i < y.len().value - 1:
        val width = x.flat_f64(i + 1).value - x.flat_f64(i).value
        val height = (y.flat_f64(i).value + y.flat_f64(i + 1).value) * 0.5
        total = total + width * height
        out.push(Float64.new(total))
        i = i + 1
    Ok(array(out))
