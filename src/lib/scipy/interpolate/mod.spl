use std.ndarray.*

fn interp1d_linear(x: NDArray, y: NDArray, query: Float64) -> Result<Float64, NdarrayError>:
    if x.dtype != DType.F64 or y.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if x.shape.dims.len() != 1 or y.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if x.len() != y.len() or x.len().value < 2:
        return Err(NdarrayError.ShapeMismatch)
    var i = 0
    while i < x.len().value - 1:
        val left_x = x.flat_f64(i).value
        val right_x = x.flat_f64(i + 1).value
        if query.value >= left_x and query.value <= right_x:
            val span = right_x - left_x
            if span == 0.0:
                return Err(NdarrayError.InvalidShape)
            val t = (query.value - left_x) / span
            val left_y = y.flat_f64(i).value
            val right_y = y.flat_f64(i + 1).value
            return Ok(Float64.new(left_y + t * (right_y - left_y)))
        i = i + 1
    Err(NdarrayError.IndexOutOfBounds)

fn interp1d_linear_array(x: NDArray, y: NDArray, queries: NDArray) -> Result<NDArray, NdarrayError>:
    if queries.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if queries.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    var out: [Float64] = []
    var i = 0
    while i < queries.len().value:
        out.push(interp1d_linear(x, y, queries.flat_f64(i))?)
        i = i + 1
    Ok(array(out))
