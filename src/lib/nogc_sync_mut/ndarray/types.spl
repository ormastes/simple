# Scilib NDArray — typed wrappers (no-primitive boundary)
#
# T-NDARRAY-01. Defines the public typed-wrapper structs used across
# std.ndarray, std.linalg, std.df, std.ml. The construction
# `Float64(x: f64) -> Float64` is the ONE place a primitive crosses the
# boundary; every other public surface stays primitive-free.
#
# DType and Device are RE-EXPORTED from std.nogc_sync_mut.tensor (per
# T-NDARRAY-02 and arch §3) — they are NOT redefined here.
#
# Performance notes: the wrapper is a single-field struct. A future
# compiler newtype-optimization (PERF-SUGAR-011) is expected to make
# `Float64(x)` zero-cost; until then it allocates a small object per
# wrap. Architecture §3 acknowledges this as a "purity tax" v1 caveat;
# impl agents must measure and escalate if it exceeds 2× cost.

use std.nogc_sync_mut.tensor.{DType, Device}


# ============================================================================
# Float wrappers
# ============================================================================

struct Float64:
    """Typed wrapper around f64. Boundary point for primitive→wrapper.

    Construction is the one place a primitive enters the public API;
    all subsequent operations on Float64 stay typed.
    """
    _v: f64

    fn raw(self) -> f64:
        """Internal accessor — used by FFI Layer B only."""
        self._v


struct Float32:
    """Typed wrapper around f32."""
    _v: f32

    fn raw(self) -> f32:
        self._v


# ============================================================================
# Integer wrappers
# ============================================================================

struct Int64:
    """Typed wrapper around i64. Distinct from Index (which is for
    array indexing / dimensions) by intent: Int64 is general data,
    Index is structural."""
    _v: i64

    fn raw(self) -> i64:
        self._v


struct Int32:
    """Typed wrapper around i32."""
    _v: i32

    fn raw(self) -> i32:
        self._v


# ============================================================================
# Index / Shape / Stride — structural types
# ============================================================================

struct Index:
    """A position or dimension count. Distinct from Int64 by intent.

    Negative values are permitted and interpreted as count-from-end
    (NumPy parity) by the consumer (e.g. NDArray.get(Index(-1))).
    """
    _v: i64

    fn raw(self) -> i64:
        self._v


struct Shape:
    """N-dim shape: ordered list of Index values.

    Construction is variadic at the constructor level (Shape(3, 4)
    becomes Shape(_dims=[Index(3), Index(4)])); rank-0 is Shape().
    The variadic constructor is provided as a separate factory `shape(...)`
    helper because Simple struct ctors take a fixed positional shape.
    """
    _dims: [Index]

    fn rank(self) -> Index:
        Index(self._dims.len())

    fn dim_at(self, i: Index) -> Index:
        self._dims[i.raw()]


struct Stride:
    """N-dim stride: byte-or-element offset per axis. Index-typed."""
    _vals: [Index]

    fn rank(self) -> Index:
        Index(self._vals.len())


# ============================================================================
# numel — free function (T-NDARRAY-08)
# ============================================================================
#
# Computes the total element count of a Shape. Pure function, no
# allocation. Returns Index — never a primitive. Used by factories
# to size buffer allocations and by NDArray.len() under the hood.

fn numel(shape: Shape) -> Index:
    """Total element count = product of all dim values.

    Rank-0 shape (`Shape()`) returns Index(1) — a scalar holds one
    element. Negative dims propagate through the product (callers
    catch them via `try_*` ctors that pre-validate Shape).
    """
    var n: i64 = 1
    for d in shape._dims:
        n = n * d.raw()
    Index(n)


# ============================================================================
# NDArray<T> — stub
# ============================================================================

struct NDArray<T>:
    """N-dimensional typed array — supersedes existing Tensor<T, N>.

    Public API uses typed wrappers throughout; internal fields are
    underscore-prefixed and accessed only by methods on this struct
    (or its sibling impl files in std.ndarray).

    The `_backend` field holds an opaque backend handle (libtorch handle
    for v1 compatibility; cuBLAS/OpenBLAS-allocated buffer pointer for
    new code). `StorageBackend` selection is dynamic per arch §4.
    """
    _backend: i64           # opaque backend handle (libtorch / cublas / cpu-buffer)
    _shape: Shape
    _strides: Stride
    _dtype: DType
    _device: Device
    _offset: Index

    fn shape(self) -> Shape:
        self._shape

    fn strides(self) -> Stride:
        self._strides

    fn dtype(self) -> DType:
        self._dtype

    fn device(self) -> Device:
        self._device

    fn ndim(self) -> Index:
        self._shape.rank()

    fn len(self) -> Index:
        # Total element count = numel(shape). Delegates to the free
        # function (T-NDARRAY-08) so factories can size buffers without
        # constructing an NDArray first.
        numel(self._shape)

    fn numel(self) -> Index:
        """Alias for `.len()` — matches NumPy `ndarray.size`."""
        numel(self._shape)

    fn is_contiguous(self) -> bool:
        """v1 invariant: ndarrays are always C-contiguous. Strided
        views land in v1.1 (T-NDARRAY-24, gated on PERF-SUGAR-005);
        until then this is unconditionally true."""
        true


# ============================================================================
# Tensor type alias (one-cycle backward compatibility per OQ-B)
# ============================================================================

# `Tensor<T,N>` was the prior name; the alias is a transitional bridge
# for callers in `std.gpu`, `std.ml` (loss/norm), and `std.units` until
# v1.1, when the alias is removed. New code SHOULD use `NDArray<T>`.
#
# Note: Simple's `<T,N>` alias targeting `<T>` requires the rank
# parameter to be erased — done by the impl in `compat.spl` (T-NDARRAY-23).
