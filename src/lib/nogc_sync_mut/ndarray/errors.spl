# Scilib NDArray — error type
#
# T-NDARRAY-06. NdarrayError enum carries diagnostic context for
# fallible NDArray operations. Returned via Result<T, NdarrayError>
# from public `try_*` constructors and accessors (per language rule:
# Result + ? — no exceptions).

use std.nogc_sync_mut.ndarray.types.{Index, Shape}


enum NdarrayError:
    """Public diagnostic surface for ndarray construction and access errors.

    Variants are payload-bearing where the payload is meaningful:
    `NegativeShape(d: Index)` carries the offending dim, `OutOfRange`
    carries the requested + actual extent.
    """
    NegativeShape(dim: Index)
    NegativeIndex(idx: Index)
    OutOfRange(requested: Index, actual: Index)
    ShapeMismatch(left: Shape, right: Shape)
    RankMismatch(left: Index, right: Index)
    InvalidStep(step: Index)
    SeqLengthMismatch(seq_len: Index, shape_numel: Index)
    BackendUnavailable(name: text)

    fn to_string(self) -> text:
        match self:
            case NegativeShape(d): "NegativeShape(dim={d.raw()})"
            case NegativeIndex(i): "NegativeIndex(idx={i.raw()})"
            case OutOfRange(r, a): "OutOfRange(requested={r.raw()}, actual={a.raw()})"
            case ShapeMismatch(_, _): "ShapeMismatch"
            case RankMismatch(l, r): "RankMismatch(left={l.raw()}, right={r.raw()})"
            case InvalidStep(s): "InvalidStep(step={s.raw()})"
            case SeqLengthMismatch(s, n): "SeqLengthMismatch(seq_len={s.raw()}, shape_numel={n.raw()})"
            case BackendUnavailable(n): "BackendUnavailable({n})"
