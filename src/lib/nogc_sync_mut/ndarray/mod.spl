# std.ndarray module — typed-array substrate for std.linalg / std.df / std.ml
#
# v1 module surface. T-NDARRAY-01 establishes the public namespace.
# T-NDARRAY-09..23 land subsequent factories, ops, broadcasting, and
# slicing into sibling files (factory.spl, ops.spl, broadcast.spl,
# slice.spl) which are imported here as they are added.
#
# Naming harmony rule: this module composes with std.nogc_sync_mut.tensor
# (DType/Device re-export) but does NOT redefine its enums. See
# doc/01_research/scilib_fortran_port/04_naming_harmony.md.

use std.nogc_sync_mut.ndarray.types.{
    Float64,
    Float32,
    Int64,
    Int32,
    Index,
    Shape,
    Stride,
    NDArray,
    numel,
}

use std.nogc_sync_mut.ndarray.errors.{NdarrayError}

use std.nogc_sync_mut.ndarray.storage.{StorageBackend, default_backend}

# Re-export DType and Device so callers can `use std.nogc_sync_mut.ndarray`
# and get the full surface without a separate `use` for tensor.
use std.nogc_sync_mut.tensor.{DType, Device}
