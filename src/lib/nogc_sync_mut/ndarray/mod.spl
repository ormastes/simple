enum DType:
    F64
    I64
    Bool

struct Float64:
    value: f64

    static fn new(value: f64) -> Float64:
        Float64(value: value)

struct Int64:
    value: i64

    static fn new(value: i64) -> Int64:
        Int64(value: value)

struct Bool:
    value: bool

    static fn new(value: bool) -> Bool:
        Bool(value: value)

struct Index:
    value: i64

    static fn new(value: i64) -> Index:
        Index(value: value)

struct Shape:
    dims: [Index]

    static fn new(dims: [Index]) -> Shape:
        Shape(dims: dims)

    fn numel(self) -> Index:
        var total = 1
        var i = 0
        while i < self.dims.len():
            total = total * self.dims[i].value
            i = i + 1
        Index.new(total)

struct Slice:
    start: Index
    stop: Index
    step: Index

    static fn new(start: Index, stop: Index, step: Index) -> Slice:
        Slice(start: start, stop: stop, step: step)

struct SliceBounds:
    start: i64
    stop: i64
    step: i64

enum NdarrayError:
    InvalidShape
    InvalidStep
    InvalidLinspace
    ShapeMismatch
    IndexOutOfBounds

struct DTypeArray:
    data: [DType]

    fn len(self) -> Index:
        Index.new(self.data.len())

    fn dtype_at(self, index: Index) -> DType:
        self.data[index.value]

struct NDArray:
    data_f64: [Float64]
    data_i64: [Int64]
    data_bool: [Bool]
    shape: Shape
    dtype: DType

    fn len(self) -> Index:
        self.shape.numel()

    fn rows(self) -> Index:
        if self.shape.dims.len() == 0:
            return Index.new(0)
        self.shape.dims[0]

    fn cols(self) -> Index:
        if self.shape.dims.len() < 2:
            return Index.new(0)
        self.shape.dims[1]

    fn ndim(self) -> i64:
        self.shape.dims.len()

    fn reshape(self, shape: Shape) -> NDArray:
        NDArray(
            data_f64: self.data_f64,
            data_i64: self.data_i64,
            data_bool: self.data_bool,
            shape: shape,
            dtype: self.dtype
        )

    fn get(self, index: Index) -> Any:
        var pos = index.value
        val size = self.raw_len()
        if pos < 0:
            pos = size + pos
        self.raw_get(pos)

    fn try_get(self, index: Index) -> Result<Any, NdarrayError>:
        if index.value < 0 or index.value >= self.raw_len():
            return Err(NdarrayError.IndexOutOfBounds)
        Ok(self.raw_get(index.value))

    fn get_at(self, indices: [Index]) -> Any:
        self.raw_get(flat_index(self.shape, indices))

    fn get_f64(self, index: Index) -> Float64:
        var pos = index.value
        if pos < 0:
            pos = self.raw_len() + pos
        self.data_f64[pos]

    fn get_f64_at(self, indices: [Index]) -> Float64:
        self.data_f64[flat_index(self.shape, indices)]

    fn to_f64_values(self) -> [Float64]:
        self.data_f64

    fn try_get_at(self, indices: [Index]) -> Result<Any, NdarrayError>:
        val pos = try_flat_index(self.shape, indices)
        match pos:
            case Ok(index_value):
                Ok(self.raw_get(index_value))
            case Err(e):
                Err(e)

    fn slice(self, range: Slice) -> NDArray:
        self.try_slice(range).unwrap()

    fn try_slice(self, range: Slice) -> Result<NDArray, NdarrayError>:
        if range.step.value == 0:
            return Err(NdarrayError.InvalidStep)
        var start = range.start.value
        var stop = range.stop.value
        val step = range.step.value
        val size = self.len().value
        if start < 0:
            start = size + start
        if stop < 0:
            stop = size + stop
        if start < 0 or start > size:
            return Err(NdarrayError.IndexOutOfBounds)
        if stop < 0 or stop > size:
            return Err(NdarrayError.IndexOutOfBounds)
        var out_f64: [Float64] = []
        var out_i64: [Int64] = []
        var out_bool: [Bool] = []
        var i = start
        if step > 0:
            while i < stop:
                match self.dtype:
                    case DType.F64:
                        out_f64.push(self.get_f64(Index.new(i)))
                    case DType.I64:
                        out_i64.push(self.data_i64[i])
                    case DType.Bool:
                        out_bool.push(self.data_bool[i])
                i = i + step
        else:
            while i > stop:
                match self.dtype:
                    case DType.F64:
                        out_f64.push(self.get_f64(Index.new(i)))
                    case DType.I64:
                        out_i64.push(self.data_i64[i])
                    case DType.Bool:
                        out_bool.push(self.data_bool[i])
                i = i + step
        Ok(make_array(out_f64, out_i64, out_bool, Shape.new([Index.new(raw_array_len(self.dtype, out_f64, out_i64, out_bool))]), self.dtype))

    fn slice_2d(self, rows: Slice, cols: Slice) -> NDArray:
        var out_f64: [Float64] = []
        var out_i64: [Int64] = []
        var out_bool: [Bool] = []
        var row = rows.start.value
        while row < rows.stop.value:
            var col = cols.start.value
            while col < cols.stop.value:
                val pos = flat_index(self.shape, [Index.new(row), Index.new(col)])
                match self.dtype:
                    case DType.F64:
                        out_f64.push(self.data_f64[pos])
                    case DType.I64:
                        out_i64.push(self.data_i64[pos])
                    case DType.Bool:
                        out_bool.push(self.data_bool[pos])
                col = col + cols.step.value
            row = row + rows.step.value
        val row_count = (rows.stop.value - rows.start.value) / rows.step.value
        val col_count = (cols.stop.value - cols.start.value) / cols.step.value
        make_array(out_f64, out_i64, out_bool, Shape.new([Index.new(row_count), Index.new(col_count)]), self.dtype)

    fn gather(self, idx: NDArray) -> NDArray:
        self.try_gather(idx).unwrap()

    fn try_gather(self, idx: NDArray) -> Result<NDArray, NdarrayError>:
        var out_f64: [Float64] = []
        var out_i64: [Int64] = []
        var out_bool: [Bool] = []
        var i = 0
        while i < idx.data_i64.len():
            val pos = idx.data_i64[i].value
            if pos < 0 or pos >= self.raw_len():
                return Err(NdarrayError.IndexOutOfBounds)
            match self.dtype:
                case DType.F64:
                    out_f64.push(self.data_f64[pos])
                case DType.I64:
                    out_i64.push(self.data_i64[pos])
                case DType.Bool:
                    out_bool.push(self.data_bool[pos])
            i = i + 1
        Ok(make_array(out_f64, out_i64, out_bool, Shape.new([Index.new(raw_array_len(self.dtype, out_f64, out_i64, out_bool))]), self.dtype))

    fn mask(self, mask_values: NDArray) -> NDArray:
        self.try_mask(mask_values).unwrap()

    fn try_mask(self, mask_values: NDArray) -> Result<NDArray, NdarrayError>:
        if mask_values.raw_len() != self.raw_len():
            return Err(NdarrayError.ShapeMismatch)
        var out_f64: [Float64] = []
        var out_i64: [Int64] = []
        var out_bool: [Bool] = []
        var i = 0
        while i < self.raw_len():
            if mask_values.data_bool[i].value:
                match self.dtype:
                    case DType.F64:
                        out_f64.push(self.data_f64[i])
                    case DType.I64:
                        out_i64.push(self.data_i64[i])
                    case DType.Bool:
                        out_bool.push(self.data_bool[i])
            i = i + 1
        Ok(make_array(out_f64, out_i64, out_bool, Shape.new([Index.new(raw_array_len(self.dtype, out_f64, out_i64, out_bool))]), self.dtype))

    fn add(self, other: NDArray) -> NDArray:
        add_impl(self, other)

    fn try_add(self, other: NDArray) -> Result<NDArray, NdarrayError>:
        val shape_result = broadcast_shapes(self.shape, other.shape)
        match shape_result:
            case Err(e):
                return Err(e)
            case Ok(_):
                pass
        val result = self.add(other)
        Ok(result)

    fn add_scalar(self, scalar: Float64) -> NDArray:
        add_scalar_impl(self, scalar)

    fn mul_scalar(self, scalar: Float64) -> NDArray:
        mul_scalar_impl(self, scalar)

    fn f64_at_broadcast(self, indices: [Index]) -> Float64:
        f64_at_broadcast_impl(self, indices)

    fn raw_len(self) -> i64:
        match self.dtype:
            case DType.F64:
                self.data_f64.len()
            case DType.I64:
                self.data_i64.len()
            case DType.Bool:
                self.data_bool.len()

    fn raw_get(self, pos: i64) -> Any:
        match self.dtype:
            case DType.F64:
                self.data_f64[pos]
            case DType.I64:
                self.data_i64[pos]
            case DType.Bool:
                self.data_bool[pos]

fn make_array(data_f64: [Float64], data_i64: [Int64], data_bool: [Bool], shape: Shape, dtype: DType) -> NDArray:
    NDArray(data_f64: data_f64, data_i64: data_i64, data_bool: data_bool, shape: shape, dtype: dtype)

fn make_f64_array(data: [Float64], shape: Shape) -> NDArray:
    NDArray(data_f64: data, data_i64: [], data_bool: [], shape: shape, dtype: DType.F64)

fn make_i64_array(data: [Int64], shape: Shape) -> NDArray:
    NDArray(data_f64: [], data_i64: data, data_bool: [], shape: shape, dtype: DType.I64)

fn make_bool_array(data: [Bool], shape: Shape) -> NDArray:
    NDArray(data_f64: [], data_i64: [], data_bool: data, shape: shape, dtype: DType.Bool)

fn add_impl(left: NDArray, right: NDArray) -> NDArray:
    val out_shape = broadcast_shapes(left.shape, right.shape).unwrap()
    val total = out_shape.numel().value
    var out: [Float64] = []
    var i = 0
    while i < total:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < total:
        val indices = unravel_index(i, out_shape)
        val lhs = f64_at_broadcast_impl(left, indices)
        val rhs = f64_at_broadcast_impl(right, indices)
        out[i] = Float64.new(lhs.value + rhs.value)
        i = i + 1
    make_f64_array(out, out_shape)

fn add_scalar_impl(array_value: NDArray, scalar: Float64) -> NDArray:
    val shape = clone_shape(array_value.shape)
    var out: [Float64] = []
    var i = 0
    while i < array_value.len().value:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < array_value.len().value:
        out[i] = Float64.new(array_value.get_f64(Index.new(i)).value + scalar.value)
        i = i + 1
    make_f64_array(out, shape)

fn mul_scalar_impl(array_value: NDArray, scalar: Float64) -> NDArray:
    val shape = clone_shape(array_value.shape)
    var out: [Float64] = []
    var i = 0
    while i < array_value.len().value:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < array_value.len().value:
        out[i] = Float64.new(array_value.get_f64(Index.new(i)).value * scalar.value)
        i = i + 1
    make_f64_array(out, shape)

fn f64_at_broadcast_impl(array_value: NDArray, indices: [Index]) -> Float64:
    val delta = indices.len() - array_value.shape.dims.len()
    var actual: [Index] = []
    var i = 0
    while i < array_value.shape.dims.len():
        actual.push(Index.new(0))
        i = i + 1
    i = 0
    while i < array_value.shape.dims.len():
        if array_value.shape.dims[i].value == 1:
            actual[i] = Index.new(0)
        else:
            actual[i] = indices[i + delta]
        i = i + 1
    array_value.get_f64_at(actual)

fn raw_array_len(dtype: DType, data_f64: [Float64], data_i64: [Int64], data_bool: [Bool]) -> i64:
    match dtype:
        case DType.F64:
            data_f64.len()
        case DType.I64:
            data_i64.len()
        case DType.Bool:
            data_bool.len()

fn array(values: [Float64]) -> NDArray:
    val len = values.len()
    make_f64_array(values, Shape.new([Index.new(len)]))

fn array_i64(values: [Int64]) -> NDArray:
    val len = values.len()
    make_i64_array(values, Shape.new([Index.new(len)]))

fn array_bool(values: [Bool]) -> NDArray:
    val len = values.len()
    make_bool_array(values, Shape.new([Index.new(len)]))

fn filled_array(shape: Shape, fill: Float64) -> NDArray:
    var out: [Float64] = []
    var i = 0
    while i < shape.numel().value:
        out.push(fill)
        i = i + 1
    make_f64_array(out, shape)

fn clone_shape(shape: Shape) -> Shape:
    var dims: [Index] = []
    var i = 0
    while i < shape.dims.len():
        dims.push(shape.dims[i])
        i = i + 1
    Shape.new(dims)

fn zeros(shape: Shape) -> NDArray:
    try_zeros(shape).unwrap()

fn try_zeros(shape: Shape) -> Result<NDArray, NdarrayError>:
    var i = 0
    while i < shape.dims.len():
        if shape.dims[i].value < 0:
            return Err(NdarrayError.InvalidShape)
        i = i + 1
    Ok(filled_array(shape, Float64.new(0.0)))

fn ones(shape: Shape) -> NDArray:
    filled_array(shape, Float64.new(1.0))

fn full(shape: Shape, fill: Float64) -> NDArray:
    filled_array(shape, fill)

fn empty(shape: Shape) -> NDArray:
    zeros(shape)

fn eye(size: Index) -> NDArray:
    var out: [Float64] = []
    var row = 0
    while row < size.value:
        var col = 0
        while col < size.value:
            if row == col:
                out.push(Float64.new(1.0))
            else:
                out.push(Float64.new(0.0))
            col = col + 1
        row = row + 1
    make_f64_array(out, Shape.new([size, size]))

fn arange(start: Float64, stop: Float64, step: Float64) -> NDArray:
    try_arange(start, stop, step).unwrap()

fn try_arange(start: Float64, stop: Float64, step: Float64) -> Result<NDArray, NdarrayError>:
    if step.value == 0.0:
        return Err(NdarrayError.InvalidStep)
    var out: [Float64] = []
    var current = start.value
    while current < stop.value:
        out.push(Float64.new(current))
        current = current + step.value
    Ok(make_f64_array(out, Shape.new([Index.new(out.len())])))

fn linspace(start: Float64, stop: Float64, count: Index) -> NDArray:
    try_linspace(start, stop, count).unwrap()

fn try_linspace(start: Float64, stop: Float64, count: Index) -> Result<NDArray, NdarrayError>:
    if count.value <= 0:
        return Err(NdarrayError.InvalidLinspace)
    if count.value == 1:
        return Ok(array([start]))
    val step = (stop.value - start.value) / (count.value - 1) as f64
    var out: [Float64] = []
    var i = 0
    while i < count.value:
        out.push(Float64.new(start.value + step * i as f64))
        i = i + 1
    Ok(make_f64_array(out, Shape.new([count])))

fn broadcast_shapes(left: Shape, right: Shape) -> Result<Shape, NdarrayError>:
    var result_rev: [Index] = []
    var li = left.dims.len() - 1
    var ri = right.dims.len() - 1
    while li >= 0 or ri >= 0:
        var ldim = 1
        var rdim = 1
        if li >= 0:
            ldim = left.dims[li].value
        if ri >= 0:
            rdim = right.dims[ri].value
        if ldim != rdim and ldim != 1 and rdim != 1:
            return Err(NdarrayError.ShapeMismatch)
        if ldim > rdim:
            result_rev.push(Index.new(ldim))
        else:
            result_rev.push(Index.new(rdim))
        li = li - 1
        ri = ri - 1
    var result: [Index] = []
    var i = result_rev.len() - 1
    while i >= 0:
        result.push(result_rev[i])
        i = i - 1
    Ok(Shape.new(result))

fn flat_index(shape: Shape, indices: [Index]) -> i64:
    var offset = 0
    var stride = 1
    var dim = shape.dims.len() - 1
    while dim >= 0:
        offset = offset + indices[dim].value * stride
        stride = stride * shape.dims[dim].value
        dim = dim - 1
    offset

fn try_flat_index(shape: Shape, indices: [Index]) -> Result<i64, NdarrayError>:
    if indices.len() != shape.dims.len():
        return Err(NdarrayError.IndexOutOfBounds)
    var offset = 0
    var stride = 1
    var dim = shape.dims.len() - 1
    while dim >= 0:
        if indices[dim].value < 0 or indices[dim].value >= shape.dims[dim].value:
            return Err(NdarrayError.IndexOutOfBounds)
        offset = offset + indices[dim].value * stride
        stride = stride * shape.dims[dim].value
        dim = dim - 1
    Ok(offset)

fn unravel_index(flat: i64, shape: Shape) -> [Index]:
    if shape.dims.len() == 0:
        return []
    var rem = flat
    var rev: [Index] = []
    var i = shape.dims.len() - 1
    while i >= 0:
        rev.push(Index.new(0))
        i = i - 1
    i = shape.dims.len() - 1
    while i >= 0:
        val dim = shape.dims[i].value
        rev[shape.dims.len() - 1 - i] = Index.new(rem % dim)
        rem = rem / dim
        i = i - 1
    var out: [Index] = []
    i = rev.len() - 1
    while i >= 0:
        out.push(Index.new(0))
        i = i - 1
    i = rev.len() - 1
    while i >= 0:
        out[rev.len() - 1 - i] = rev[i]
        i = i - 1
    out

fn normalize_slice(range: Slice, length: i64) -> Result<SliceBounds, NdarrayError>:
    if range.step.value == 0:
        return Err(NdarrayError.InvalidStep)
    var start = range.start.value
    var stop = range.stop.value
    val step = range.step.value
    if start < 0:
        start = length + start
    if stop < 0:
        stop = length + stop
    if step > 0:
        if start < 0:
            start = 0
        if stop > length:
            stop = length
        if start > length:
            return Err(NdarrayError.IndexOutOfBounds)
        if stop > length:
            return Err(NdarrayError.IndexOutOfBounds)
    else:
        if start >= length:
            start = length - 1
        if stop < -1:
            stop = -1
        if start < -1 or start >= length:
            return Err(NdarrayError.IndexOutOfBounds)
    Ok(SliceBounds(start: start, stop: stop, step: step))

fn add(left: NDArray, right: NDArray) -> NDArray:
    left.add(right)
