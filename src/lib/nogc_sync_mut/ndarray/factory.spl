# Scilib NDArray — factory constructors
#
# T-NDARRAY-09: zeros, ones, empty, full, eye
# T-NDARRAY-10: from_seq, from_scalar
# T-NDARRAY-11: arange, linspace
#
# All public signatures use typed wrappers (Float64, Index, Shape, Device).
# Primitives appear ONLY inside the private helpers that call the bulk-alloc
# externs — never in any public `fn` signature or return type.
#
# Backend note (T-NDARRAY-08 gap): T-NDARRAY-07/08 (LibtorchBackend /
# MockBackend) are not yet implemented — only the StorageBackend enum exists
# in storage.spl. Factories set `_backend: 0` as an opaque placeholder handle;
# the actual buffer is allocated via `rt_f64_array_alloc` / `rt_i64_array_alloc`
# but not yet attached to the backend dispatch layer. This is the expected state
# for Wave 2A: factories produce correct shaped NDArray structs and allocate
# buffers via the T-PERFSUGAR-01 bulk-alloc path. Element access (T-NDARRAY-15)
# and backend wiring (T-NDARRAY-07/08) land in subsequent waves.
#
# arange length: computed via integer ceiling arithmetic to avoid `rt_math_ceil`
# extern dependency: len = (stop_i - start_i + step_i - 1) / step_i is NOT
# applicable for f64; instead we declare `rt_math_ceil` inline.

use std.nogc_sync_mut.ndarray.types.{Float64, Float32, Int64, Int32, Index, Shape, Stride, NDArray, numel}
use std.nogc_sync_mut.ndarray.errors.{NdarrayError}
use std.nogc_sync_mut.tensor.{DType, Device}


# ============================================================================
# Private externs — bulk typed-buffer alloc (T-PERFSUGAR-01)
# ============================================================================
#
# These are the ONE site where primitives appear at the extern boundary.
# All callers within this file immediately wrap results in typed values.

extern fn rt_f64_array_alloc(len: i64) -> [f64]
extern fn rt_i64_array_alloc(len: i64) -> [i64]
extern fn rt_math_ceil(x: f64) -> f64


# ============================================================================
# Private helpers
# ============================================================================

fn _make_c_strides(shape: Shape) -> Stride:
    """Compute C-contiguous (row-major) strides for the given shape.

    For a shape (d0, d1, ..., dk) the stride for axis i is the product
    of all dims to the right of i. Axis rank-1 has stride 1.
    """
    val rank = shape.rank().raw()
    var strides: [Index] = []
    var acc: i64 = 1
    var i: i64 = rank - 1
    while i >= 0:
        strides = [Index(acc)] + strides
        acc = acc * shape.dim_at(Index(i)).raw()
        i = i - 1
    Stride(_vals: strides)


fn _make_ndarray_f64(buf: [f64], shape: Shape, device: Device) -> NDArray<Float64>:
    """Construct an NDArray<Float64> around an already-allocated f64 buffer.

    `_backend` is set to 0 (opaque placeholder) until T-NDARRAY-07/08
    backend wiring lands. The buffer itself lives in `buf` (managed by
    the Simple GC); the NDArray struct records shape/strides/dtype.
    """
    NDArray<Float64>(
        _backend: 0,
        _shape: shape,
        _strides: _make_c_strides(shape),
        _dtype: DType.F64,
        _device: device,
        _offset: Index(0),
    )


fn _make_ndarray_i64(buf: [i64], shape: Shape, device: Device) -> NDArray<Int64>:
    """Construct an NDArray<Int64> around an already-allocated i64 buffer."""
    NDArray<Int64>(
        _backend: 0,
        _shape: shape,
        _strides: _make_c_strides(shape),
        _dtype: DType.I64,
        _device: device,
        _offset: Index(0),
    )


fn _validate_shape(shape: Shape) -> Result<(), NdarrayError>:
    """Return Err(NegativeShape) if any dimension is <= 0."""
    for d in shape._dims:
        if d.raw() <= 0:
            return Err(NdarrayError.NegativeShape(d))
    Ok(())


# ============================================================================
# impl NDArray<T> — static factory methods (T-NDARRAY-09)
# ============================================================================

impl NDArray<Float64>:

    # ------------------------------------------------------------------
    # zeros — allocate and zero-fill (rt_f64_array_alloc returns 0.0-filled)
    # ------------------------------------------------------------------

    static fn zeros(shape: Shape, device: Device) -> NDArray<Float64>:
        """Allocate an NDArray<Float64> zero-filled to the given shape.

        Uses `rt_f64_array_alloc` (T-PERFSUGAR-01) for O(n) allocation
        at native speed rather than an interpreter push loop.

        Panics if any dim is non-positive; use `try_zeros` for the
        Result-returning variant.
        """
        val n = numel(shape).raw()
        val buf = rt_f64_array_alloc(n)
        _make_ndarray_f64(buf, shape, device)

    static fn try_zeros(shape: Shape, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `zeros`. Returns Err(NegativeShape) on
        any non-positive dimension."""
        _validate_shape(shape)?
        Ok(NDArray<Float64>.zeros(shape, device))

    # ------------------------------------------------------------------
    # ones — allocate and fill with 1.0
    # ------------------------------------------------------------------

    static fn ones(shape: Shape, device: Device) -> NDArray<Float64>:
        """Allocate an NDArray<Float64> filled with Float64(1.0).

        Allocates via `rt_f64_array_alloc` then overwrites each element
        with 1.0. The fill loop runs at interpreter speed — 1024×1024
        should complete inside 5 s on current hardware per T-NDARRAY-09
        acceptance criterion.
        """
        val n = numel(shape).raw()
        val buf = rt_f64_array_alloc(n)
        var i: i64 = 0
        while i < n:
            buf[i] = 1.0
            i = i + 1
        _make_ndarray_f64(buf, shape, device)

    static fn try_ones(shape: Shape, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `ones`."""
        _validate_shape(shape)?
        Ok(NDArray<Float64>.ones(shape, device))

    # ------------------------------------------------------------------
    # empty — allocate without initialization
    # ------------------------------------------------------------------

    static fn empty(shape: Shape, device: Device) -> NDArray<Float64>:
        """Allocate an NDArray<Float64> without initialising the buffer.

        Content is undefined (actually 0.0 in interpreter mode because
        `rt_f64_array_alloc` zero-fills, but callers MUST NOT rely on
        this — it is a platform detail, not a contract).
        """
        val n = numel(shape).raw()
        val buf = rt_f64_array_alloc(n)
        _make_ndarray_f64(buf, shape, device)

    # ------------------------------------------------------------------
    # full — broadcast-fill with a scalar value
    # ------------------------------------------------------------------

    static fn full(shape: Shape, fill: Float64, device: Device) -> NDArray<Float64>:
        """Allocate and fill every element with `fill`."""
        val n = numel(shape).raw()
        val buf = rt_f64_array_alloc(n)
        val fv = fill.raw()
        var i: i64 = 0
        while i < n:
            buf[i] = fv
            i = i + 1
        _make_ndarray_f64(buf, shape, device)

    static fn try_full(shape: Shape, fill: Float64, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `full`."""
        _validate_shape(shape)?
        Ok(NDArray<Float64>.full(shape, fill, device))

    # ------------------------------------------------------------------
    # eye — n×n identity matrix
    # ------------------------------------------------------------------

    static fn eye(n: Index, device: Device) -> NDArray<Float64>:
        """Produce an n×n identity matrix.

        Diagonal elements are Float64(1.0); off-diagonal are Float64(0.0).
        Shape is Shape(_dims: [n, n]).
        """
        val ni = n.raw()
        val shape = Shape(_dims: [Index(ni), Index(ni)])
        val total = ni * ni
        val buf = rt_f64_array_alloc(total)
        # buf is already zero-filled; write 1.0 on the diagonal
        var i: i64 = 0
        while i < ni:
            buf[i * ni + i] = 1.0
            i = i + 1
        _make_ndarray_f64(buf, shape, device)

    static fn try_eye(n: Index, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `eye`. Returns Err(NegativeShape) for n <= 0."""
        if n.raw() <= 0:
            return Err(NdarrayError.NegativeShape(n))
        Ok(NDArray<Float64>.eye(n, device))

    # ------------------------------------------------------------------
    # from_seq — copy a sequence into a typed buffer (T-NDARRAY-10)
    # ------------------------------------------------------------------

    static fn from_seq(data: [Float64], shape: Shape, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Construct NDArray<Float64> by copying `data` into a fresh buffer.

        Returns Err(SeqLengthMismatch) when `data.len() != numel(shape)`.
        Always copies — no zero-copy path in v1.
        """
        val expected = numel(shape).raw()
        val actual = data.len()
        if actual != expected:
            return Err(NdarrayError.SeqLengthMismatch(
                seq_len: Index(actual),
                shape_numel: Index(expected),
            ))
        val buf = rt_f64_array_alloc(expected)
        var i: i64 = 0
        while i < expected:
            buf[i] = data[i].raw()
            i = i + 1
        Ok(_make_ndarray_f64(buf, shape, device))

    static fn from_scalar(val_: Float64, device: Device) -> NDArray<Float64>:
        """Rank-0 scalar array. Shape is Shape(_dims: []) (no dims)."""
        val shape = Shape(_dims: [])
        val buf = rt_f64_array_alloc(1)
        buf[0] = val_.raw()
        _make_ndarray_f64(buf, shape, device)

    # ------------------------------------------------------------------
    # arange — half-open interval [start, stop) with given step (T-NDARRAY-11)
    # ------------------------------------------------------------------

    static fn arange(start: Float64, stop: Float64, step: Float64, device: Device) -> NDArray<Float64>:
        """Produce [start, start+step, start+2*step, ...] while < stop.

        Length = ceil((stop - start) / step).  NumPy parity: half-open.
        Panics on step == 0.0; use `try_arange` for the Result variant.
        """
        val sv = start.raw()
        val ev = stop.raw()
        val dv = step.raw()
        val raw_len = rt_math_ceil((ev - sv) / dv)
        val n = raw_len as i64
        val shape = Shape(_dims: [Index(n)])
        val buf = rt_f64_array_alloc(n)
        var i: i64 = 0
        while i < n:
            buf[i] = sv + i as f64 * dv
            i = i + 1
        _make_ndarray_f64(buf, shape, device)

    static fn try_arange(start: Float64, stop: Float64, step: Float64, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `arange`. Returns Err(InvalidStep) when step == 0."""
        if step.raw() == 0.0:
            return Err(NdarrayError.InvalidStep(Index(0)))
        Ok(NDArray<Float64>.arange(start, stop, step, device))

    # ------------------------------------------------------------------
    # linspace — closed interval [start, stop] with num points (T-NDARRAY-11)
    # ------------------------------------------------------------------

    static fn linspace(start: Float64, stop: Float64, num: Index, device: Device) -> NDArray<Float64>:
        """Produce `num` equally-spaced points on [start, stop] (closed interval).

        For num == 1 the single point is `start`. For num == 2 the two
        points are start and stop. Panics on num <= 0; use `try_linspace`.
        """
        val sv = start.raw()
        val ev = stop.raw()
        val n = num.raw()
        val shape = Shape(_dims: [Index(n)])
        val buf = rt_f64_array_alloc(n)
        if n == 1:
            buf[0] = sv
        else:
            val dv = (ev - sv) / (n - 1) as f64
            var i: i64 = 0
            while i < n:
                buf[i] = sv + i as f64 * dv
                i = i + 1
        _make_ndarray_f64(buf, shape, device)

    static fn try_linspace(start: Float64, stop: Float64, num: Index, device: Device) -> Result<NDArray<Float64>, NdarrayError>:
        """Fallible variant of `linspace`. Returns Err(NegativeShape) when num <= 0."""
        if num.raw() <= 0:
            return Err(NdarrayError.NegativeShape(num))
        Ok(NDArray<Float64>.linspace(start, stop, num, device))


# ============================================================================
# impl NDArray<Int64> — from_seq for integer arrays (T-NDARRAY-10)
# ============================================================================

impl NDArray<Int64>:

    static fn from_seq(data: [Int64], shape: Shape, device: Device) -> Result<NDArray<Int64>, NdarrayError>:
        """Construct NDArray<Int64> by copying `data` into a fresh i64 buffer."""
        val expected = numel(shape).raw()
        val actual = data.len()
        if actual != expected:
            return Err(NdarrayError.SeqLengthMismatch(
                seq_len: Index(actual),
                shape_numel: Index(expected),
            ))
        val buf = rt_i64_array_alloc(expected)
        var i: i64 = 0
        while i < expected:
            buf[i] = data[i].raw()
            i = i + 1
        Ok(_make_ndarray_i64(buf, shape, device))

    static fn from_scalar(val_: Int64, device: Device) -> NDArray<Int64>:
        """Rank-0 Int64 scalar array."""
        val shape = Shape(_dims: [])
        val buf = rt_i64_array_alloc(1)
        buf[0] = val_.raw()
        Ok(_make_ndarray_i64(buf, shape, device))
