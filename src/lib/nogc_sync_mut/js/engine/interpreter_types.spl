# JS Interpreter Types
# Environment, scope chain, call frames, and JS value coercion utilities.

use std.js.types.js_types.{JsValue, JsObject, JsProperty}
use std.js.types.ast_types.{JsStatement, JsExpression}

val RETURN_SIGNAL = "__return__"

class Environment:
    bindings: Dict<text, JsValue>
    is_strict: bool

fn env_new() -> Environment:
    Environment(bindings: {}, is_strict: false)

class EnvironmentStack:
    frames: [Environment]

fn env_stack_new() -> EnvironmentStack:
    EnvironmentStack(frames: [env_new()])

class CallFrame:
    function_name: text
    return_value: JsValue
    has_return: bool

fn call_frame_new(name: text) -> CallFrame:
    CallFrame(function_name: name, return_value: JsValue.Undefined, has_return: false)

class JsFunction:
    name: text
    params: [text]
    body: [JsStatement]
    closure_env: EnvironmentStack
    is_arrow: bool

fn to_number(v: JsValue) -> f64:
    match v:
        JsValue.Undefined: 0.0 / 0.0
        JsValue.Null: 0.0
        JsValue.Boolean(b): if b: 1.0 else: 0.0
        JsValue.Number(n): n
        JsValue.String(s): s.parse_f64() ?? (0.0 / 0.0)
        JsValue.Object(_): 0.0 / 0.0
        JsValue.Array(_): 0.0
        JsValue.Function(_): 0.0 / 0.0

fn js_to_string(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n): if n != n: "NaN" else: "{n}"
        JsValue.String(s): s
        JsValue.Object(_): "[object Object]"
        JsValue.Array(_): ""
        JsValue.Function(_): "function() {}"

fn to_boolean(v: JsValue) -> bool:
    match v:
        JsValue.Undefined: false
        JsValue.Null: false
        JsValue.Boolean(b): b
        JsValue.Number(n): n != 0.0 and n == n
        JsValue.String(s): s.len() > 0
        JsValue.Object(_): true
        JsValue.Array(_): true
        JsValue.Function(_): true

fn is_truthy(v: JsValue) -> bool:
    to_boolean(v)

fn typeof_value(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "object"
        JsValue.Boolean(_): "boolean"
        JsValue.Number(_): "number"
        JsValue.String(_): "string"
        JsValue.Object(_): "object"
        JsValue.Array(_): "object"
        JsValue.Function(_): "function"

fn strict_equals(a: JsValue, b: JsValue) -> bool:
    match a:
        JsValue.Undefined:
            match b:
                JsValue.Undefined: true
                _: false
        JsValue.Null:
            match b:
                JsValue.Null: true
                _: false
        JsValue.Boolean(av):
            match b:
                JsValue.Boolean(bv): av == bv
                _: false
        JsValue.Number(an):
            match b:
                JsValue.Number(bn): an == bn
                _: false
        JsValue.String(as):
            match b:
                JsValue.String(bs): as == bs
                _: false
        JsValue.Object(ai):
            match b:
                JsValue.Object(bi): ai == bi
                _: false
        JsValue.Array(ai):
            match b:
                JsValue.Array(bi): ai == bi
                _: false
        JsValue.Function(ai):
            match b:
                JsValue.Function(bi): ai == bi
                _: false

fn abstract_equals(a: JsValue, b: JsValue) -> bool:
    strict_equals(a, b)

fn _is_array_method(name: text) -> bool:
    name == "push" or name == "pop" or name == "shift" or name == "unshift" or
    name == "splice" or name == "slice" or name == "concat" or name == "join" or
    name == "indexOf" or name == "lastIndexOf" or name == "includes" or
    name == "map" or name == "filter" or name == "reduce" or name == "forEach" or
    name == "find" or name == "findIndex" or name == "some" or name == "every" or
    name == "sort" or name == "reverse" or name == "fill" or name == "flat" or
    name == "flatMap" or name == "entries" or name == "keys" or name == "values" or
    name == "length" or name == "from" or name == "isArray"

fn _is_string_method(name: text) -> bool:
    name == "length" or name == "charAt" or name == "charCodeAt" or
    name == "indexOf" or name == "lastIndexOf" or name == "includes" or
    name == "startsWith" or name == "endsWith" or name == "slice" or
    name == "substring" or name == "toUpperCase" or name == "toLowerCase" or
    name == "trim" or name == "trimStart" or name == "trimEnd" or
    name == "split" or name == "replace" or name == "replaceAll" or
    name == "match" or name == "search" or name == "padStart" or name == "padEnd" or
    name == "repeat" or name == "concat" or name == "fromCharCode"

fn _get_obj_id(v: JsValue) -> i64:
    match v:
        JsValue.Object(id): id
        JsValue.Array(id): id
        JsValue.Function(id): id
        _: -1

fn _get_fn_id(v: JsValue) -> i64:
    match v:
        JsValue.Function(id): id
        _: -1

fn f64_to_i64(n: f64) -> i64:
    n.to_i64()

fn _digit_val(ch: i64) -> i64:
    if ch >= 48 and ch <= 57:
        return ch - 48
    if ch >= 65 and ch <= 90:
        return ch - 55
    if ch >= 97 and ch <= 122:
        return ch - 87
    -1
