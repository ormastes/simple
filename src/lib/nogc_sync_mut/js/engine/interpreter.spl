# JavaScript tree-walking interpreter for the Simple Browser Platform.
# Evaluates AST nodes (JsStatement / JsExpression) against a scope chain.
# Implements JS type coercion, function calls, closures, and object property access.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.types.ast_types.JsExpression
use std.js.types.ast_types.JsStatement
use std.js.types.ast_types.SwitchCase
use std.js.engine.runtime.{dispatch_native, NATIVE_BLOB_TEXT, NATIVE_FETCH, NATIVE_JSON_PARSE, NATIVE_PROMISE_CATCH, NATIVE_PROMISE_FINALLY, NATIVE_PROMISE_REJECT, NATIVE_PROMISE_RESOLVE, NATIVE_PROMISE_THEN, NATIVE_RESPONSE_BLOB, NATIVE_RESPONSE_JSON, NATIVE_RESPONSE_TEXT, NATIVE_SET_TIMEOUT, NATIVE_SET_INTERVAL, NATIVE_CLEAR_TIMEOUT, NATIVE_CLEAR_INTERVAL, NATIVE_STORAGE_GET_ITEM, NATIVE_STORAGE_SET_ITEM, NATIVE_STORAGE_REMOVE_ITEM, NATIVE_STORAGE_CLEAR, NATIVE_STORAGE_KEY}
use std.js.engine.parser.{JsParser}
use std.js.builtins.json.{json_parse}
use std.js.builtins.array.{array_map, array_filter, array_reduce, array_forEach, array_find, array_findIndex, array_some, array_every, array_sort_with, array_isArray, array_from_values}
use std.nogc_sync_mut.http.types.{status_text}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_http_request(method: text, url: text, headers: text, body: text) -> (i64, text, text)

# ── Types, helpers, coercion (extracted to interpreter_types.spl) ────────
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}

# ── Object store (imported from vm.spl — single canonical definition) ────
use std.js.engine.vm.{ObjectStore}

# ── Helper ───────────────────────────────────────────────────────────────

fn _statement_name(stmt: JsStatement) -> text:
    match stmt:
        JsStatement.VarDecl(_, _): "VarDecl"
        JsStatement.ExprStmt(_): "ExprStmt"
        JsStatement.Return(_): "Return"
        JsStatement.If(_, _, _): "If"
        JsStatement.While(_, _): "While"
        JsStatement.For(_, _, _, _): "For"
        JsStatement.Block(_): "Block"
        JsStatement.FnDecl(_, _, _): "FnDecl"
        JsStatement.TryCatch(_, _, _, _): "TryCatch"
        JsStatement.Switch(_, _): "Switch"
        JsStatement.ForIn(_, _, _): "ForIn"
        JsStatement.ForOf(_, _, _): "ForOf"
        JsStatement.ThrowStmt(_): "ThrowStmt"
        JsStatement.BreakStmt: "BreakStmt"
        JsStatement.ContinueStmt: "ContinueStmt"
        JsStatement.ClassDecl(_, _, _, _): "ClassDecl"
        JsStatement.LetDecl(_, _): "LetDecl"
        JsStatement.ConstDecl(_, _): "ConstDecl"
        JsStatement.DestructVarDecl(_, _, _): "DestructVarDecl"
        JsStatement.DoWhile(_, _): "DoWhile"
        JsStatement.LabeledStmt(_, _): "LabeledStmt"

fn filter_response_headers_for_script(headers: text) -> text:
    var visible = ""
    var removed_cookie = false
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if trimmed.lower().starts_with("set-cookie:"):
            removed_cookie = true
        else:
            visible = visible + line + if removed_cookie: "\\n" else: "\n"
    visible

fn parse_non_negative_i64_text(value: text) -> i64:
    var parsed = 0
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        val digit = _digit_val(ch)
        if digit >= 0:
            parsed = parsed * 10 + digit
        i = i + 1
    parsed

fn text_equals_exact(left: text, right: text) -> bool:
    if left.len() != right.len():
        return false
    var i = 0
    while i < left.len():
        if left.slice(i, i + 1) != right.slice(i, i + 1):
            return false
        i = i + 1
    true

fn _simple_fetch_marker(obj_id: i64, store: ObjectStore) -> bool:
    match store.get_property(obj_id, "__simple_fetch_host"):
        JsValue.Boolean(v): v
        _:
            false

fn _simple_fetch_base_url(obj_id: i64, store: ObjectStore) -> text:
    match store.get_property(obj_id, "__simple_base_url"):
        JsValue.String(v): v
        _:
            ""

fn _simple_fetch_cookie_header(obj_id: i64, store: ObjectStore) -> text:
    match store.get_property(obj_id, "__simple_cookie_header"):
        JsValue.String(v): v
        _:
            ""

fn _simple_fetch_state(obj_id: i64, store: ObjectStore) -> text:
    match store.get_property(obj_id, "__simple_state"):
        JsValue.String(v): v
        _:
            ""

fn _simple_fetch_value(obj_id: i64, store: ObjectStore) -> JsValue:
    match store.get_property(obj_id, "__simple_value"):
        JsValue.Undefined: JsValue.Undefined
        JsValue.Null: JsValue.Null
        JsValue.Boolean(v): JsValue.Boolean(v: v)
        JsValue.Number(v): JsValue.Number(v: v)
        JsValue.String(v): JsValue.String(v: v)
        JsValue.Object(id): JsValue.Object(id: id)
        JsValue.Array(id): JsValue.Array(id: id)
        JsValue.Function(id): JsValue.Function(id: id)
        JsValue.Symbol(id): JsValue.Symbol(id: id)

fn _simple_fetch_handlers(obj_id: i64, store: ObjectStore) -> i64:
    match store.get_property(obj_id, "__simple_handlers"):
        JsValue.Object(id): id
        JsValue.Array(id): id
        _:
            -1

fn _scheme(url: text) -> text:
    match url.index_of("://"):
        Some(idx): url.substring(0, idx)
        nil: "https"

fn _origin(url: text) -> text:
    val scheme_end_opt = url.index_of("://")
    match scheme_end_opt:
        Some(scheme_end):
            val after_scheme = scheme_end + 3
            match url.substring(after_scheme).index_of("/"):
                Some(rel_idx): url.substring(0, after_scheme + rel_idx)
                nil: url
        nil:
            ""

fn _without_fragment(url: text) -> text:
    match url.index_of("#"):
        Some(idx): url.substring(0, idx)
        nil: url

fn _without_query(url: text) -> text:
    val clean = _without_fragment(url)
    match clean.index_of("?"):
        Some(idx): clean.substring(0, idx)
        nil: clean

fn _base_dir(url: text) -> text:
    val clean = _without_query(url)
    val origin = _origin(clean)
    if origin == "":
        return ""
    if clean == origin:
        return origin + "/"
    val after_origin = clean.substring(origin.len())
    match after_origin.last_index_of("/"):
        Some(rel_idx): origin + after_origin.substring(0, rel_idx + 1)
        nil: origin + "/"

fn _resolve_fetch_url(base_url: text, href: text) -> text:
    if href == "":
        return base_url
    if href.starts_with("http://") or href.starts_with("https://") or href.starts_with("file://") or href.starts_with("about:"):
        return href
    if href.starts_with("//"):
        return _scheme(base_url) + ":" + href
    if href.starts_with("#"):
        return _without_fragment(base_url) + href
    if href.starts_with("?"):
        return _without_query(base_url) + href
    if href.starts_with("/"):
        val origin = _origin(base_url)
        if origin != "":
            return origin + href
        return href
    _base_dir(base_url) + href

fn _simple_fetch_sync(store: ObjectStore, obj_id: i64, args: [JsValue]) -> JsValue:
    var request_url = _simple_fetch_base_url(obj_id, store)
    if args.len() > 0:
        request_url = _resolve_fetch_url(request_url, js_to_string(args.get(0)))
    var method = "GET"
    if args.len() > 1:
        val maybe_method = js_to_string(args.get(1)).trim().upper()
        if maybe_method != "":
            method = maybe_method
    var headers_text = ""
    if args.len() > 2:
        headers_text = js_to_string(args.get(2))
    val cookie_header = _simple_fetch_cookie_header(obj_id, store)
    if cookie_header != "":
        if headers_text != "":
            headers_text = headers_text + "\n"
        headers_text = headers_text + "Cookie: " + cookie_header
    var body = ""
    if args.len() > 3:
        body = js_to_string(args.get(3))
    var content_type = ""
    if args.len() > 4:
        content_type = js_to_string(args.get(4))
    if content_type != "":
        if headers_text != "":
            headers_text = headers_text + "\n"
        headers_text = headers_text + "Content-Type: " + content_type

    var status: i64 = 0
    var response_body = ""
    var error_text = ""
    if request_url.starts_with("file://"):
        val path = request_url.slice(7, request_url.len())
        val content = rt_file_read_text(path) ?? ""
        if content != "":
            status = 200
            response_body = content
        else:
            status = 404
            error_text = "file not found"
    else:
        val result = rt_http_request(method, request_url, headers_text, body)
        status = result.0
        response_body = result.1
        error_text = result.2

    val response_id = store.create_object()
    store.set_property(response_id, "url", JsValue.String(v: request_url))
    store.set_property(response_id, "status", JsValue.Number(v: status.to_f64()))
    store.set_property(response_id, "ok", JsValue.Boolean(v: status >= 200 and status < 300 and error_text == ""))
    store.set_property(response_id, "headersText", JsValue.String(v: ""))
    store.set_property(response_id, "body", JsValue.String(v: response_body))
    store.set_property(response_id, "error", JsValue.String(v: error_text))
    JsValue.Object(id: response_id)

class PendingAsyncRequest:
    request_obj_id: i64

    static fn create(request_obj_id: i64) -> PendingAsyncRequest:
        PendingAsyncRequest(request_obj_id: request_obj_id)

class PendingPromiseTask:
    promise_id: i64
    handler_id: i64

    static fn create(promise_id: i64, handler_id: i64) -> PendingPromiseTask:
        PendingPromiseTask(promise_id: promise_id, handler_id: handler_id)

class PromiseHandlerRecord:
    id: i64
    on_fulfilled: i64
    on_rejected: i64
    next_promise_id: i64
    kind: text

    static fn create(id: i64, on_fulfilled: i64, on_rejected: i64, next_promise_id: i64, kind: text) -> PromiseHandlerRecord:
        PromiseHandlerRecord(id: id, on_fulfilled: on_fulfilled, on_rejected: on_rejected, next_promise_id: next_promise_id, kind: kind)

class PromiseHandlerRegistration:
    promise_id: i64
    handler_id: i64

    static fn create(promise_id: i64, handler_id: i64) -> PromiseHandlerRegistration:
        PromiseHandlerRegistration(promise_id: promise_id, handler_id: handler_id)

class PendingTimerTask:
    id: i64
    callback_id: i64
    delay_ms: i64
    scheduled_at_ms: i64
    is_interval: bool

    static fn create(id: i64, callback_id: i64, delay_ms: i64, scheduled_at_ms: i64, is_interval: bool) -> PendingTimerTask:
        PendingTimerTask(
            id: id,
            callback_id: callback_id,
            delay_ms: delay_ms,
            scheduled_at_ms: scheduled_at_ms,
            is_interval: is_interval,
        )

# ── Interpreter ──────────────────────────────────────────────────────────

class JsInterpreter:
    env_stack: EnvironmentStack
    global_env: i64
    object_store: ObjectStore
    call_stack: [CallFrame]
    functions: [JsFunction]
    logger: Logger
    return_value: JsValue
    control_return: bool
    control_break: bool
    control_continue: bool
    thrown_value: JsValue
    control_thrown: bool
    native_id_map: [Pair<i64, i64>]
    class_proto_fns: [i64]
    class_proto_ids: [i64]
    promise_ctor_id: i64
    promise_proto_id: i64
    response_proto_id: i64
    next_async_request_seq: i64
    pending_async_requests: [PendingAsyncRequest]
    pending_async_request_registry: [PendingAsyncRequest]
    pending_promise_tasks: [PendingPromiseTask]
    promise_handlers: [PromiseHandlerRecord]
    promise_handler_registrations: [PromiseHandlerRegistration]
    next_promise_handler_id: i64
    next_timer_id: i64
    pending_timer_tasks: [PendingTimerTask]
    global_var_names: [text]
    global_var_values: [JsValue]
    host_window_id: i64
    host_document_id: i64
    host_body_id: i64
    host_location_id: i64
    host_navigator_id: i64
    host_chrome_id: i64
    host_session_storage_id: i64
    host_local_storage_id: i64
    host_document_title_value: JsValue
    host_document_cookie_value: JsValue
    host_body_inner_html_value: JsValue
    host_body_text_content_value: JsValue

    static fn new(logger: Logger) -> JsInterpreter:
        JsInterpreter.create(logger)

    fn ident_name(expr: JsExpression) -> text:
        match expr:
            JsExpression.Identifier(name): name
            _: ""

    static fn create(logger: Logger) -> JsInterpreter:
        var env_stack = EnvironmentStack.new()
        val global_env = 0
        JsInterpreter(
            env_stack: env_stack,
            global_env: global_env,
            object_store: ObjectStore.create(),
            call_stack: [],
            functions: [],
            logger: logger,
            return_value: JsValue.Undefined,
            control_return: false,
            control_break: false,
            control_continue: false,
            thrown_value: JsValue.Undefined,
            control_thrown: false,
            native_id_map: [],
            class_proto_fns: [],
            class_proto_ids: [],
            promise_ctor_id: -1,
            promise_proto_id: -1,
            response_proto_id: -1,
            next_async_request_seq: 1,
            pending_async_requests: [],
            pending_async_request_registry: [],
            pending_promise_tasks: [],
            promise_handlers: [],
            promise_handler_registrations: [],
            next_promise_handler_id: 1,
            next_timer_id: 1,
            pending_timer_tasks: [],
            global_var_names: [],
            global_var_values: [],
            host_window_id: -1,
            host_document_id: -1,
            host_body_id: -1,
            host_location_id: -1,
            host_navigator_id: -1,
            host_chrome_id: -1,
            host_session_storage_id: -1,
            host_local_storage_id: -1,
            host_document_title_value: JsValue.Undefined,
            host_document_cookie_value: JsValue.Undefined,
            host_body_inner_html_value: JsValue.Undefined,
            host_body_text_content_value: JsValue.Undefined,
        )

    # Register a native function placeholder and return its index
    me _register_native(name: text, native_id: i64) -> i64:
        val fn_idx = self.functions.len()
        val placeholder = JsFunction.create(name, [], [], -1)
        var functions: [JsFunction] = self.functions
        functions.push(placeholder)
        self.functions = functions
        var native_id_map: [Pair<i64, i64>] = self.native_id_map
        native_id_map.push(Pair(first: fn_idx, second: native_id))
        self.native_id_map = native_id_map
        fn_idx

    # Define a native function in the global scope
    me _define_global_native(name: text, native_id: i64):
        val fn_idx = self._register_native(name, native_id)
        self.define_global_value(name, JsValue.Function(id: fn_idx))

    me define_global_value(name: text, value: JsValue):
        var global_var_names: [text] = self.global_var_names
        var global_var_values: [JsValue] = self.global_var_values
        global_var_names.push(name)
        global_var_values.push(value)
        self.global_var_names = global_var_names
        self.global_var_values = global_var_values

    me create_object() -> i64:
        var object_store = self.object_store
        val id = object_store.next_id
        object_store.next_id = object_store.next_id + 1
        var obj_proto_ids: [i64] = object_store.obj_proto_ids
        obj_proto_ids.push(-1)
        object_store.obj_proto_ids = obj_proto_ids
        self.object_store = object_store
        id

    me set_object_property(obj_id: i64, key: text, value: JsValue):
        if key != "__simple_frozen" and self._is_object_frozen(obj_id):
            self.logger.debug("Ignoring write to frozen object {obj_id}.{key}")
            return

        var object_store = self.object_store
        var prop_obj_ids: [i64] = object_store.prop_obj_ids
        var prop_keys: [text] = object_store.prop_keys
        var prop_values: [JsValue] = object_store.prop_values
        var prop_ref_tags: [text] = object_store.prop_ref_tags
        var prop_ref_ids: [text] = object_store.prop_ref_ids
        var prop_enumerables: [bool] = object_store.prop_enumerables
        var prop_configurables: [bool] = object_store.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push(key)
        prop_values.push(value)
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(true)
        prop_configurables.push(true)
        object_store.prop_obj_ids = prop_obj_ids
        object_store.prop_keys = prop_keys
        object_store.prop_values = prop_values
        object_store.prop_ref_tags = prop_ref_tags
        object_store.prop_ref_ids = prop_ref_ids
        object_store.prop_enumerables = prop_enumerables
        object_store.prop_configurables = prop_configurables
        self.object_store = object_store

    fn get_object_property(obj_id: i64, key: text) -> JsValue:
        val store = self.object_store
        var i = store.prop_keys.len() - 1
        while i >= 0:
            if store.prop_obj_ids.get(i) == obj_id and store.prop_keys.get(i) == key:
                return store.prop_values.get(i)
            i = i - 1
        JsValue.Undefined

    me set_object_property_direct(obj_id: i64, key: text, value: JsValue):
        self.set_object_property(obj_id, key, value)

    me _mark_object_frozen(obj_id: i64):
        if self._is_object_frozen(obj_id):
            return

        var object_store = self.object_store
        var prop_obj_ids: [i64] = object_store.prop_obj_ids
        var prop_keys: [text] = object_store.prop_keys
        var prop_values: [JsValue] = object_store.prop_values
        var prop_ref_tags: [text] = object_store.prop_ref_tags
        var prop_ref_ids: [text] = object_store.prop_ref_ids
        var prop_enumerables: [bool] = object_store.prop_enumerables
        var prop_configurables: [bool] = object_store.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push("__simple_frozen")
        prop_values.push(JsValue.Boolean(v: true))
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(false)
        prop_configurables.push(false)
        object_store.prop_obj_ids = prop_obj_ids
        object_store.prop_keys = prop_keys
        object_store.prop_values = prop_values
        object_store.prop_ref_tags = prop_ref_tags
        object_store.prop_ref_ids = prop_ref_ids
        object_store.prop_enumerables = prop_enumerables
        object_store.prop_configurables = prop_configurables
        self.object_store = object_store

    fn _is_object_frozen(obj_id: i64) -> bool:
        match self.get_object_property(obj_id, "__simple_frozen"):
            JsValue.Boolean(v): v
            _:
                false

    me lookup_global_value(name: text) -> Option<JsValue>:
        if val Some(found) = self.env_stack.get_var(self.global_env, name):
            return Some(found)
        var i = self.global_var_names.len() - 1
        while i >= 0:
            if self.global_var_names.get(i) == name:
                return Some(self.global_var_values.get(i))
            i = i - 1
        nil

    # Define a native method on an object
    me _define_method_on(obj_id: i64, method_name: text, native_id: i64):
        val fn_idx = self._register_native(method_name, native_id)
        self.set_object_property(obj_id, method_name, JsValue.Function(id: fn_idx))

    # Initialize global environment with built-in objects and functions.
    # Must be a `me` method on JsInterpreter — JsRuntime wrapper hits copy-semantics bug.
    me setup_globals():
        # Global values
        self.define_global_value("undefined", JsValue.Undefined)
        self.define_global_value("NaN", JsValue.Number(v: js_nan()))
        self.define_global_value("Infinity", JsValue.Number(v: js_infinity()))

        # Global functions (native IDs from runtime.spl)
        self._define_global_native("parseInt", -10)
        self._define_global_native("parseFloat", -11)
        self._define_global_native("isNaN", -12)
        self._define_global_native("isFinite", -13)
        self._define_global_native("Symbol", -44)

        # console object
        val console_id = self.create_object()
        self._define_method_on(console_id, "log", -1)
        self._define_method_on(console_id, "error", -2)
        self._define_method_on(console_id, "warn", -3)
        self.define_global_value("console", JsValue.Object(id: console_id))

        # Math object
        val math_id = self.create_object()
        self.set_object_property(math_id, "PI", JsValue.Number(v: 3.141592653589793))
        self.set_object_property(math_id, "E", JsValue.Number(v: 2.718281828459045))
        self.set_object_property(math_id, "SQRT2", JsValue.Number(v: 1.4142135623730951))
        self._define_method_on(math_id, "floor", -20)
        self._define_method_on(math_id, "ceil", -21)
        self._define_method_on(math_id, "round", -22)
        self._define_method_on(math_id, "random", -23)
        self._define_method_on(math_id, "abs", -24)
        self._define_method_on(math_id, "max", -25)
        self._define_method_on(math_id, "min", -26)
        self._define_method_on(math_id, "sqrt", -27)
        self._define_method_on(math_id, "pow", -28)
        self.define_global_value("Math", JsValue.Object(id: math_id))

        # JSON object
        val json_id = self.create_object()
        self._define_method_on(json_id, "parse", -30)
        self._define_method_on(json_id, "stringify", -31)
        self.define_global_value("JSON", JsValue.Object(id: json_id))

        # Timer stubs
        self._define_global_native("setTimeout", -40)
        self._define_global_native("setInterval", -41)
        self._define_global_native("clearTimeout", -42)
        self._define_global_native("clearInterval", -43)

        # Error constructors (empty body — new Error('msg') won't crash)
        val error_fn_id = self.functions.len()
        val error_fn = JsFunction.create("Error", ["message"], [], -1)
        self.functions.push(error_fn)
        self.define_global_value("Error", JsValue.Function(id: error_fn_id))
        self.define_global_value("TypeError", JsValue.Function(id: error_fn_id))
        self.define_global_value("RangeError", JsValue.Function(id: error_fn_id))
        self.define_global_value("ReferenceError", JsValue.Function(id: error_fn_id))
        self.define_global_value("SyntaxError", JsValue.Function(id: error_fn_id))

    me take_pending_async_request() -> i64?:
        if self.pending_async_requests.len() == 0:
            return nil
        val req = self.pending_async_requests[0]
        var rest: [PendingAsyncRequest] = []
        var i = 1
        while i < self.pending_async_requests.len():
            rest = rest + [self.pending_async_requests[i]]
            i = i + 1
        self.pending_async_requests = rest
        Some(req.request_obj_id)

    me drain_pending_microtasks() -> bool:
        var ran = false
        var drain_count = 0
        while self.pending_promise_tasks.len() > 0:
            drain_count = drain_count + 1
            if drain_count > 1000:
                self.logger.warn("Promise microtask drain limit reached")
                self.pending_promise_tasks = []
                return ran
            val task = self.pending_promise_tasks[0]
            var rest: [PendingPromiseTask] = []
            var i = 1
            while i < self.pending_promise_tasks.len():
                rest = rest + [self.pending_promise_tasks[i]]
                i = i + 1
            self.pending_promise_tasks = rest
            self._run_promise_task(task.promise_id, task.handler_id)
            ran = true
        ran

    me drain_due_timers(current_time_ms: i64) -> i64:
        var ran_count = 0
        var keep_scanning = true
        while keep_scanning:
            keep_scanning = false
            var rest: [PendingTimerTask] = []
            var handled = false
            var i = 0
            while i < self.pending_timer_tasks.len():
                val task = self.pending_timer_tasks[i]
                val due_at = task.scheduled_at_ms + task.delay_ms
                if not handled and due_at <= current_time_ms:
                    handled = true
                    keep_scanning = true
                    if task.callback_id >= 0:
                        val ignored = self._invoke_function(task.callback_id, [], self.global_env)
                        ran_count = ran_count + 1
                    if task.is_interval:
                        rest = rest + [PendingTimerTask.create(task.id, task.callback_id, task.delay_ms, due_at, true)]
                else:
                    rest = rest + [task]
                i = i + 1
            self.pending_timer_tasks = rest
        ran_count

    me resolve_async_fetch_response(
        request_id: text,
        url: text,
        status: i32,
        headers: text,
        body: text,
        error: text
    ) -> Result<bool, text>:
        var idx = 0
        while idx < self.pending_async_request_registry.len():
            val req = self.pending_async_request_registry[idx]
            val req_id_val = self.get_object_property(req.request_obj_id, "request_id")
            if val JsValue.String(req_id) = req_id_val:
                if req_id == request_id:
                    var rest: [PendingAsyncRequest] = []
                    var i = 0
                    while i < self.pending_async_request_registry.len():
                        if i != idx:
                            rest = rest + [self.pending_async_request_registry[i]]
                        i = i + 1
                    self.pending_async_request_registry = rest
                    val promise_id_val = self.get_object_property(req.request_obj_id, "promise_id")
                    match promise_id_val:
                        JsValue.String(promise_id_text):
                            var promise_id = self._promise_id_for_request_id(request_id)
                            if promise_id < 0:
                                promise_id = parse_non_negative_i64_text(promise_id_text)
                            if error != "":
                                self._settle_promise(promise_id, JsValue.String(v: error), true)
                                return Ok(true)
                            val response_id = self._create_response_object(url, status, headers, body, error)
                            self._settle_promise(promise_id, JsValue.Object(id: response_id), false)
                            return Ok(true)
                        JsValue.Number(promise_id_num):
                            var promise_id = self._promise_id_for_request_id(request_id)
                            if promise_id < 0:
                                promise_id = f64_to_i64(promise_id_num)
                            if error != "":
                                self._settle_promise(promise_id, JsValue.String(v: error), true)
                                return Ok(true)
                            val response_id = self._create_response_object(url, status, headers, body, error)
                            self._settle_promise(promise_id, JsValue.Object(id: response_id), false)
                            return Ok(true)
                        _:
                            return Err("missing promise id for async fetch")
            idx = idx + 1
        Err("unknown async fetch request: {request_id}")

    me _create_pending_promise_object() -> i64:
        var promise_id = self.create_object()
        while _get_obj_id(JsValue.Object(id: promise_id)) != promise_id or promise_id % 10 == 9:
            promise_id = self.create_object()
        self.set_object_property(promise_id, "__proto__", JsValue.Object(id: self.promise_proto_id))
        self.set_object_property(promise_id, "__simple_promise_host", JsValue.Boolean(v: true))
        self.set_object_property(promise_id, "__simple_state", JsValue.String(v: "pending"))
        self.set_object_property(promise_id, "__simple_value", JsValue.Undefined)
        val handlers_id = self.create_object()
        self.set_object_property(handlers_id, "length", JsValue.Number(v: 0.0))
        self.set_object_property(promise_id, "__simple_handlers", JsValue.Array(id: handlers_id))
        promise_id

    me _create_settled_promise_object(value: JsValue, rejected: bool) -> i64:
        val promise_id = self._create_pending_promise_object()
        if rejected:
            self.set_object_property(promise_id, "__simple_state", JsValue.String(v: "rejected"))
        else:
            self.set_object_property(promise_id, "__simple_state", JsValue.String(v: "fulfilled"))
        self.set_object_property(promise_id, "__simple_value", value)
        promise_id

    me _create_response_object(url: text, status: i32, headers: text, body: text, error: text) -> i64:
        val response_id = self.create_object()
        self.set_object_property(response_id, "__simple_response_host", JsValue.Boolean(v: true))
        self.set_object_property(response_id, "url", JsValue.String(v: url))
        self.set_object_property(response_id, "status", JsValue.Number(v: status.to_f64()))
        self.set_object_property(response_id, "statusText", JsValue.String(v: status_text(status.to_i64())))
        self.set_object_property(response_id, "ok", JsValue.Boolean(v: status >= 200 and status < 300 and error == ""))
        self.set_object_property(response_id, "headersText", JsValue.String(v: filter_response_headers_for_script(headers)))
        self.set_object_property(response_id, "body", JsValue.String(v: body))
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: false))
        self.set_object_property(response_id, "error", JsValue.String(v: error))
        self._define_method_on(response_id, "text", NATIVE_RESPONSE_TEXT)
        self._define_method_on(response_id, "json", NATIVE_RESPONSE_JSON)
        self._define_method_on(response_id, "blob", NATIVE_RESPONSE_BLOB)
        response_id

    me _create_promise_handler(on_fulfilled: i64, on_rejected: i64, next_promise_id: i64, kind: text) -> i64:
        val handler_id = self.next_promise_handler_id
        self.next_promise_handler_id = self.next_promise_handler_id + 1
        self.promise_handlers = self.promise_handlers + [PromiseHandlerRecord.create(handler_id, on_fulfilled, on_rejected, next_promise_id, kind)]
        handler_id

    me _append_handler(promise_id: i64, handler_id: i64):
        self.promise_handler_registrations = self.promise_handler_registrations + [PromiseHandlerRegistration.create(promise_id, handler_id)]

    fn _promise_id_for_request_id(request_id: text) -> i64:
        var obj_id = 0
        while obj_id < self.object_store.next_id:
            match self.get_object_property(obj_id, "__simple_request_id"):
                JsValue.String(v):
                    if text_equals_exact(v, request_id):
                        return obj_id
                _:
                    pass_dn
            obj_id = obj_id + 1
        -1

    me _enqueue_promise_task(promise_id: i64, handler_id: i64):
        self.pending_promise_tasks = self.pending_promise_tasks + [PendingPromiseTask.create(promise_id, handler_id)]

    me _settle_promise(promise_id: i64, value: JsValue, rejected: bool):
        if _simple_fetch_state(promise_id, self.object_store) != "pending":
            return
        self.set_object_property(
            promise_id,
            "__simple_state",
            JsValue.String(v: if rejected: "rejected" else: "fulfilled")
        )
        self.set_object_property(promise_id, "__simple_value", value)
        var i = 0
        while i < self.promise_handler_registrations.len():
            val registration = self.promise_handler_registrations[i]
            if registration.promise_id == promise_id:
                self._enqueue_promise_task(promise_id, registration.handler_id)
            i = i + 1

    me _run_promise_task(promise_id: i64, handler_id: i64):
                        val state = _simple_fetch_state(promise_id, self.object_store)
                        val settled_value = _simple_fetch_value(promise_id, self.object_store)
                        var handler_kind = "then"
                        var on_fulfilled = -1
                        var on_rejected = -1
                        var next_promise_id = -1
                        var hi = 0
                        while hi < self.promise_handlers.len():
                            val handler = self.promise_handlers[hi]
                            if handler.id == handler_id:
                                handler_kind = handler.kind
                                on_fulfilled = handler.on_fulfilled
                                on_rejected = handler.on_rejected
                                next_promise_id = handler.next_promise_id
                                hi = self.promise_handlers.len()
                            hi = hi + 1

                        var callback_id = -1
                        var propagate_rejection = false
                        if state == "fulfilled":
                            callback_id = on_fulfilled
                        else:
                            callback_id = on_rejected
                            propagate_rejection = true

                        var next_value = settled_value
                        if handler_kind == "finally":
                            callback_id = if state == "fulfilled": on_fulfilled else: on_rejected

                        if callback_id >= 0:
                            val result = self._invoke_function(callback_id, [settled_value], self.global_env)
                            match result:
                                Ok(callback_result):
                                    if handler_kind == "finally":
                                        next_value = settled_value
                                        propagate_rejection = state == "rejected"
                                    else:
                                        next_value = callback_result
                                        propagate_rejection = state == "rejected" and on_rejected < 0
                                Err(e):
                                    next_value = JsValue.String(v: e.message)
                                    propagate_rejection = true
                        else:
                            if handler_kind == "finally":
                                next_value = settled_value

                        if next_promise_id >= 0:
                            var adopted_pending = false
                            match next_value:
                                JsValue.Object(inner_promise_id):
                                    if val JsValue.Boolean(true) = self.get_object_property(inner_promise_id, "__simple_promise_host"):
                                        val inner_state = _simple_fetch_state(inner_promise_id, self.object_store)
                                        if inner_state == "pending":
                                            val adopt_handler_id = self._create_promise_handler(-1, -1, next_promise_id, "then")
                                            self._append_handler(inner_promise_id, adopt_handler_id)
                                            adopted_pending = true
                                        else:
                                            next_value = _simple_fetch_value(inner_promise_id, self.object_store)
                                            propagate_rejection = inner_state == "rejected"
                                _:
                                    pass_dn
                            if not adopted_pending:
                                self._settle_promise(next_promise_id, next_value, propagate_rejection)

    # Find prototype id for a class constructor
    fn _find_class_proto(fn_id: i64) -> i64:
        var i = 0
        val len = self.class_proto_fns.len()
        while i < len:
            if self.class_proto_fns.get(i) == fn_id:
                return self.class_proto_ids.get(i)
            i = i + 1
        -1

    me _fulfilled_promise_value(value: JsValue) -> JsValue:
        match value:
            JsValue.Object(obj_id):
                match self.get_object_property(obj_id, "__simple_promise_host"):
                    JsValue.Boolean(is_host):
                        if is_host:
                            match self.get_object_property(obj_id, "__simple_state"):
                                JsValue.String(state):
                                    if state == "fulfilled":
                                        return self.get_object_property(obj_id, "__simple_value")
                                _:
                                    pass_dn
                    _:
                        pass_dn
            _:
                pass_dn
        value

    me _is_stringish(value: JsValue) -> bool:
        typeof_value(self._fulfilled_promise_value(value)) == "string"

    me _js_to_string(value: JsValue) -> text:
        val resolved = self._fulfilled_promise_value(value)
        match resolved:
            JsValue.Object(obj_id):
                match self.get_object_property(obj_id, "__simple_string_value"):
                    JsValue.String(v): return v
                    _:
                        pass_dn
            _:
                pass_dn
        js_to_string(resolved)

    me _serialize_fetch_headers(value: JsValue) -> text:
        match value:
            JsValue.String(v): return self._filter_request_headers(v)
            JsValue.Object(obj_id):
                val obj = self.object_store.get_object(obj_id)
                var headers: [text] = []
                var i = 0
                while i < obj.properties.len():
                    val prop = obj.properties.get(i)
                    if prop.key.lower() != "cookie":
                        headers.push(prop.key + ": " + self._js_to_string(prop.value))
                    i = i + 1
                return headers.join("\n")
            _:
                return ""

    me _filter_request_headers(headers_text: text) -> text:
        var kept: [text] = []
        for line in headers_text.split("\n"):
            val trimmed = line.trim()
            if trimmed != "":
                val lower = trimmed.lower()
                if not lower.starts_with("cookie:"):
                    kept.push(trimmed)
        kept.join("\n")
        js_to_string(value)

    # Recursive JSON serialization (needs object_store access)
    fn _json_stringify(value: JsValue) -> text:
        match value:
            JsValue.Undefined: return "undefined"
            JsValue.Null: return "null"
            JsValue.Boolean(v):
                if v:
                    return "true"
                return "false"
            JsValue.Number(v):
                var s = "{v}"
                val slen = s.len()
                if slen >= 3:
                    if s[slen - 2] == ".":
                        if s[slen - 1] == "0":
                            var result = ""
                            var ci = 0
                            while ci < slen - 2:
                                result = result + s[ci]
                                ci = ci + 1
                            return result
                return s
            JsValue.String(v):
                # Escape special characters
                var escaped = ""
                var ei = 0
                val elen = v.len()
                while ei < elen:
                    val ch = v[ei]
                    if ch == "\"":
                        escaped = escaped + "\\\""
                    if ch == "\\":
                        escaped = escaped + "\\\\"
                    if ch != "\"" and ch != "\\":
                        escaped = escaped + ch
                    ei = ei + 1
                return "\"" + escaped + "\""
            JsValue.Object(id):
                val obj = self.object_store.get_object(id)
                var result = "{"
                var oi = 0
                var first = true
                val plen = obj.properties.len()
                while oi < plen:
                    val prop = obj.properties.get(oi)
                    # Skip internal __proto__ property
                    if prop.key != "__proto__":
                        if not first:
                            result = result + ","
                        result = result + "\"" + prop.key + "\":" + self._json_stringify(prop.value)
                        first = false
                    oi = oi + 1
                return result + "}"
            JsValue.Array(id):
                val arr_len = self.object_store.array_length(id)
                var result = "["
                var ai = 0
                while ai < arr_len:
                    if ai > 0:
                        result = result + ","
                    val elem = self.object_store.get_by_index(id, ai)
                    result = result + self._json_stringify(elem)
                    ai = ai + 1
                return result + "]"
            JsValue.Function(id): return "null"
            JsValue.Symbol(id): return "null"
        "undefined"

    # Execute a full program (list of statements)
    me execute(program: [JsStatement]) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var i = 0
        val len = program.len()
        while i < len:
            val stmt = program.get(i)
            result = self.exec_statement(stmt, self.global_env)?
            if self.control_return:
                break
            i = i + 1
        Ok(result)

    # Dispatch a statement
    me exec_statement(stmt: JsStatement, env: i64) -> BrowserResult<JsValue>:
        match stmt:
            JsStatement.VarDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.ExprStmt(expr):
                return self.eval_expression(expr, env)
            JsStatement.Return(value):
                return self.exec_return(value, env)
            JsStatement.If(cond, then_body, else_body):
                return self.exec_if(cond, then_body, else_body, env)
            JsStatement.While(cond, body):
                return self.exec_while(cond, body, env)
            JsStatement.For(init, cond, update, body):
                return self.exec_for(init, cond, update, body, env)
            JsStatement.Block(stmts):
                val block_env = self.env_stack.create_env(env)
                var result = JsValue.Undefined
                var idx = 0
                val slen = stmts.len()
                while idx < slen:
                    result = self.exec_statement(stmts.get(idx), block_env)?
                    if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                        break
                    idx = idx + 1
                return Ok(result)
            JsStatement.FnDecl(name, params, body):
                return self.exec_function_decl(name, params, body, env)
            JsStatement.TryCatch(try_body, catch_param, catch_body, finally_body):
                return self.exec_try_catch(try_body, catch_param, catch_body, finally_body, env)
            JsStatement.Switch(discriminant, cases):
                return self.exec_switch(discriminant, cases, env)
            JsStatement.ForIn(binding, object, body):
                return self.exec_for_in(binding, object, body, env)
            JsStatement.ForOf(binding, iterable, body):
                return self.exec_for_of(binding, iterable, body, env)
            JsStatement.ThrowStmt(expr):
                return self.exec_throw(expr, env)
            JsStatement.BreakStmt:
                self.control_break = true
                return Ok(JsValue.Undefined)
            JsStatement.ContinueStmt:
                self.control_continue = true
                return Ok(JsValue.Undefined)
            JsStatement.ClassDecl(name, parent_name, constructor, methods):
                return self.exec_class_decl(name, parent_name, constructor, methods, env)
            JsStatement.LetDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.ConstDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.DestructVarDecl(pattern, init, kind):
                return self.exec_destruct_decl(pattern, init, env)
            JsStatement.DoWhile(cond, body):
                return self.exec_do_while(cond, body, env)
            JsStatement.LabeledStmt(label, body):
                return self.exec_statement(body, env)

    # Variable declaration
    me exec_var_decl(name: text, init: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(init, env)?
        self.env_stack.define_var(env, name, value)
        Ok(value)

    # Destructuring declaration: const {a, b} = obj; const [x, y] = arr
    me exec_destruct_decl(pattern: JsExpression, init: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(init, env)?
        self._bind_pattern(pattern, value, env)
        Ok(value)

    me _bind_pattern(pattern: JsExpression, value: JsValue, env: i64):
        match pattern:
            JsExpression.ObjectPattern(props):
                match value:
                    JsValue.Object(id):
                        var i = 0
                        while i < props.len():
                            val dp = props.get(i)
                            val bound_val = self.get_object_property(id, dp.key)
                            match dp.value:
                                JsExpression.Identifier(name):
                                    self.env_stack.define_var(env, name, bound_val)
                                _: pass_dn
                            i = i + 1
                    _: pass_dn
            JsExpression.ArrayPattern(elements):
                match value:
                    JsValue.Array(id):
                        var i = 0
                        while i < elements.len():
                            val elem = elements.get(i)
                            match elem:
                                JsExpression.SpreadElement(arg):
                                    match arg:
                                        JsExpression.Identifier(name):
                                            var rest: [JsValue] = []
                                            val arr_len = self.object_store.array_length(id)
                                            var ri = i
                                            while ri < arr_len:
                                                rest.push(self.object_store.get_by_index(id, ri))
                                                ri = ri + 1
                                            val rest_id = self.object_store.create_array_from(rest)
                                            self.env_stack.define_var(env, name, JsValue.Array(id: rest_id))
                                        _: pass_dn
                                JsExpression.Identifier(name):
                                    val elem_val = self.object_store.get_by_index(id, i)
                                    self.env_stack.define_var(env, name, elem_val)
                                _: pass_dn
                            i = i + 1
                    _: pass_dn
            _: pass_dn

    # Do-while loop
    me exec_do_while(cond: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var cont = true
        var should_exit = false
        while cont:
            val loop_env = self.env_stack.create_env(env)
            var bi = 0
            while bi < body.len():
                result = self.exec_statement(body.get(bi), loop_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                bi = bi + 1
            if should_exit:
                break
            val cond_val = self.eval_expression(cond, env)?
            cont = is_truthy(cond_val)
        Ok(result)

    # If / else
    me exec_if(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val cond_val = self.eval_expression(cond, env)?
        var result = JsValue.Undefined
        if is_truthy(cond_val):
            val then_env = self.env_stack.create_env(env)
            var i = 0
            val len = then_body.len()
            while i < len:
                result = self.exec_statement(then_body.get(i), then_env)?
                if self.control_return:
                    break
                i = i + 1
        else:
            if else_body.len() > 0:
                val else_env = self.env_stack.create_env(env)
                var i = 0
                val len = else_body.len()
                while i < len:
                    result = self.exec_statement(else_body.get(i), else_env)?
                    if self.control_return:
                        break
                    i = i + 1
        Ok(result)

    # While loop
    me exec_while(cond: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var iteration = 0
        val max_iterations = 100000
        var should_exit = false
        while iteration < max_iterations:
            val cond_val = self.eval_expression(cond, env)?
            if not is_truthy(cond_val):
                break
            val loop_env = self.env_stack.create_env(env)
            var i = 0
            val len = body.len()
            while i < len:
                result = self.exec_statement(body.get(i), loop_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                i = i + 1
            if should_exit:
                break
            iteration = iteration + 1
        if iteration >= max_iterations:
            self.logger.warn("While loop exceeded maximum iterations")
        Ok(result)

    # For loop
    # Note: var declarations in init execute in parent env (JS var is function-scoped)
    me exec_for(init: JsStatement, cond: JsExpression, update: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        self.exec_statement(init, env)?
        val for_env = self.env_stack.create_env(env)

        var result = JsValue.Undefined
        var iteration = 0
        val max_iterations = 100000
        var should_exit = false
        while iteration < max_iterations:
            val cond_val = self.eval_expression(cond, for_env)?
            if not is_truthy(cond_val):
                break
            val iter_env = self.env_stack.create_env(for_env)
            var i = 0
            val len = body.len()
            while i < len:
                result = self.exec_statement(body.get(i), iter_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                i = i + 1
            if should_exit:
                break
            self.eval_expression(update, for_env)?
            iteration = iteration + 1
        if iteration >= max_iterations:
            self.logger.warn("For loop exceeded maximum iterations")
        Ok(result)

    # Return statement
    me exec_return(value: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val result = self.eval_expression(value, env)?
        self.return_value = result
        self.control_return = true
        Ok(result)

    # Function declaration — store in function registry
    me exec_function_decl(name: text, params: [text], body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val fn_id = self.functions.len()
        val js_fn = JsFunction.create(name, params, body, env)
        self.functions.push(js_fn)
        val fn_val = JsValue.Function(id: fn_id)
        self.env_stack.define_var(env, name, fn_val)
        Ok(fn_val)

    # Try/catch/finally
    me exec_try_catch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val try_env = self.env_stack.create_env(env)
        var result = JsValue.Undefined

        # Execute try body
        var i = 0
        val tlen = try_body.len()
        while i < tlen:
            result = self.exec_statement(try_body.get(i), try_env)?
            if self.control_return or self.control_break or self.control_continue:
                break
            if self.control_thrown:
                break
            i = i + 1

        # If exception was thrown, execute catch body
        if self.control_thrown and catch_body.len() > 0:
            self.control_thrown = false
            val caught_value = self.thrown_value
            self.thrown_value = JsValue.Undefined
            val catch_env = self.env_stack.create_env(env)
            if catch_param != "":
                self.env_stack.define_var(catch_env, catch_param, caught_value)
            var ci = 0
            val clen = catch_body.len()
            while ci < clen:
                result = self.exec_statement(catch_body.get(ci), catch_env)?
                if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                    break
                ci = ci + 1

        # Always execute finally body
        if finally_body.len() > 0:
            val finally_env = self.env_stack.create_env(env)
            var fi = 0
            val flen = finally_body.len()
            while fi < flen:
                self.exec_statement(finally_body.get(fi), finally_env)?
                if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                    break
                fi = fi + 1

        Ok(result)

    # Switch statement
    me exec_switch(discriminant: JsExpression, cases: [SwitchCase], env: i64) -> BrowserResult<JsValue>:
        val disc_val = self.eval_expression(discriminant, env)?
        var result = JsValue.Undefined
        var matched = false
        var should_exit = false
        var ci = 0
        val case_count = cases.len()
        while ci < case_count:
            val sc = cases.get(ci)
            if not matched:
                if val Some(test) = sc.test:
                    val test_val = self.eval_expression(test, env)?
                    if strict_equals(disc_val, test_val):
                        matched = true
                else:
                    # default clause
                    matched = true
            if matched:
                val case_env = self.env_stack.create_env(env)
                var si = 0
                val slen = sc.consequent.len()
                while si < slen:
                    val stmt_result = self.exec_statement(sc.consequent.get(si), case_env)?
                    if self.control_break:
                        self.control_break = false
                        should_exit = true
                        break
                    result = stmt_result
                    if self.control_return or self.control_thrown:
                        should_exit = true
                        break
                    if self.control_continue:
                        should_exit = true
                        break
                    si = si + 1
                if should_exit:
                    break
            ci = ci + 1
            if should_exit:
                break
        Ok(result)

    # For-in loop: iterate object keys
    me exec_for_in(binding: text, object: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val obj_val = self.eval_expression(object, env)?
        var result = JsValue.Undefined
        var should_exit = false
        match obj_val:
            JsValue.Object(id):
                val obj = self.object_store.get_object(id)
                var i = 0
                val len = obj.properties.len()
                while i < len:
                    val prop = obj.properties.get(i)
                    if prop.enumerable:
                        val iter_env = self.env_stack.create_env(env)
                        self.env_stack.define_var(iter_env, binding, JsValue.String(v: prop.key))
                        var bi = 0
                        val blen = body.len()
                        while bi < blen:
                            result = self.exec_statement(body.get(bi), iter_env)?
                            if self.control_return or self.control_thrown:
                                should_exit = true
                                break
                            if self.control_break:
                                self.control_break = false
                                should_exit = true
                                break
                            if self.control_continue:
                                self.control_continue = false
                                break
                            bi = bi + 1
                        if should_exit:
                            break
                    i = i + 1
                    if should_exit:
                        break
            _:
                self.logger.warn("for...in requires an object")
        Ok(result)

    # For-of loop: iterate array elements
    me exec_for_of(binding: text, iterable: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val iter_val = self.eval_expression(iterable, env)?
        var result = JsValue.Undefined
        var should_exit = false
        match iter_val:
            JsValue.Array(id):
                val arr_len = self.object_store.array_length(id)
                var i = 0
                while i < arr_len:
                    val elem_val = self.object_store.get_by_index(id, i)
                    val iter_env = self.env_stack.create_env(env)
                    self.env_stack.define_var(iter_env, binding, elem_val)
                    var bi = 0
                    val blen = body.len()
                    while bi < blen:
                        result = self.exec_statement(body.get(bi), iter_env)?
                        if self.control_return or self.control_thrown:
                            should_exit = true
                            break
                        if self.control_break:
                            self.control_break = false
                            should_exit = true
                            break
                        if self.control_continue:
                            self.control_continue = false
                            break
                        bi = bi + 1
                    if should_exit:
                        break
                    i = i + 1
                    if should_exit:
                        break
            _:
                self.logger.warn("for...of requires an iterable")
        Ok(result)

    # Throw statement
    me exec_throw(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(expr, env)?
        self.thrown_value = value
        self.control_thrown = true
        Ok(value)

    # Class declaration — register constructor and methods as functions on a prototype object
    me exec_class_decl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        # Create the prototype object
        val proto_id = self.create_object()

        # Set up prototype chain for extends
        if parent_name != "":
            val parent_val = self.env_stack.get_var(env, parent_name)
            if val Some(parent_fn) = parent_val:
                val parent_fn_id = _get_fn_id(parent_fn)
                if parent_fn_id >= 0:
                    val parent_proto = self._find_class_proto(parent_fn_id)
                    if parent_proto >= 0:
                        self.set_object_property(proto_id, "__proto__", JsValue.Object(id: parent_proto))

        # Register methods on the prototype
        var mi = 0
        val mlen = methods.len()
        while mi < mlen:
            val method = methods.get(mi)
            match method:
                JsStatement.FnDecl(mname, mparams, mbody):
                    val fn_id = self.functions.len()
                    val js_fn = JsFunction.create(mname, mparams, mbody, env)
                    self.functions.push(js_fn)
                    self.set_object_property(proto_id, mname, JsValue.Function(id: fn_id))
                _: pass_dn
            mi = mi + 1

        # Register constructor as the class function
        match constructor:
            JsStatement.FnDecl(cname, cparams, cbody):
                val ctor_id = self.functions.len()
                val ctor_fn = JsFunction.create(name, cparams, cbody, env)
                self.functions.push(ctor_fn)
                # Track constructor → prototype mapping for new operator
                self.class_proto_fns.push(ctor_id)
                self.class_proto_ids.push(proto_id)
                val class_val = JsValue.Function(id: ctor_id)
                self.env_stack.define_var(env, name, class_val)
                return Ok(class_val)
            _: pass_dn
        Ok(JsValue.Undefined)

    # ── JsExpression evaluation ────────────────────────────────────────────

    me eval_expression(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        match expr:
            JsExpression.Literal(value):
                return Ok(value)
            JsExpression.Identifier(name):
                # Check for 'this' binding
                if name == "this":
                    if self.call_stack.len() > 0:
                        val frame = self.call_stack.get(self.call_stack.len() - 1)
                        return Ok(frame.this_value)
                    return Ok(JsValue.Undefined)
                if name == "window" and self.host_window_id >= 0:
                    return Ok(JsValue.Object(id: self.host_window_id))
                if name == "self" and self.host_window_id >= 0:
                    return Ok(JsValue.Object(id: self.host_window_id))
                if name == "document" and self.host_document_id >= 0:
                    return Ok(JsValue.Object(id: self.host_document_id))
                if name == "location" and self.host_location_id >= 0:
                    return Ok(JsValue.Object(id: self.host_location_id))
                if name == "navigator" and self.host_navigator_id >= 0:
                    return Ok(JsValue.Object(id: self.host_navigator_id))
                if name == "chrome" and self.host_chrome_id >= 0:
                    return Ok(JsValue.Object(id: self.host_chrome_id))
                if name == "sessionStorage" and self.host_session_storage_id >= 0:
                    return Ok(JsValue.Object(id: self.host_session_storage_id))
                if name == "localStorage" and self.host_local_storage_id >= 0:
                    return Ok(JsValue.Object(id: self.host_local_storage_id))
                if env == self.global_env:
                    val cached = self.lookup_global_value(name)
                    if val Some(v) = cached:
                        return Ok(v)
                val lookup = self.env_stack.get_var(env, name)
                if val Some(v) = lookup:
                    return Ok(v)
                # Check global
                val global_lookup = self.lookup_global_value(name)
                if val Some(v) = global_lookup:
                    return Ok(v)
                self.logger.warn("ReferenceError: {name} is not defined")
                return Ok(JsValue.Undefined)
            JsExpression.Binary(op, left, right):
                return self.eval_binary(op, left, right, env)
            JsExpression.Unary(op, operand):
                return self.eval_unary(op, operand, env)
            JsExpression.Call(callee, args):
                return self.eval_call(callee, args, env)
            JsExpression.Member(object, property):
                return self.eval_member(object, property, env)
            JsExpression.Assignment(target, value):
                return self.eval_assignment(target, value, env)
            JsExpression.Array(elements):
                return self.eval_array(elements, env)
            JsExpression.ObjectExpr(properties):
                return self.eval_object(properties, env)
            JsExpression.Ternary(condition, consequent, alternate):
                val cond_val = self.eval_expression(condition, env)?
                if is_truthy(cond_val):
                    return self.eval_expression(consequent, env)
                return self.eval_expression(alternate, env)
            JsExpression.ArrowFunction(params, body):
                # Register arrow as a function
                val fn_id = self.functions.len()
                val js_fn = JsFunction.create("__arrow__", params, body, env)
                self.functions.push(js_fn)
                return Ok(JsValue.Function(id: fn_id))
            JsExpression.SpreadElement(argument):
                # Spread is handled at call sites; evaluate the argument
                return self.eval_expression(argument, env)
            JsExpression.TemplateLiteral(quasis, expressions):
                return self.eval_template_literal(quasis, expressions, env)
            JsExpression.Delete(del_expr):
                return self.eval_delete(del_expr, env)
            JsExpression.InstanceOf(left, right):
                # Simplified instanceof: checks if right is a constructor function
                val lv = self.eval_expression(left, env)?
                val rv = self.eval_expression(right, env)?
                # Basic: check if left is an object
                match lv:
                    JsValue.Object(id):
                        return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: false))
            JsExpression.InExpr(left, right):
                val key = self.eval_expression(left, env)?
                val obj = self.eval_expression(right, env)?
                val key_str = js_to_string(key)
                match obj:
                    JsValue.Object(id):
                        match self.get_object_property(id, key_str):
                            JsValue.Undefined: return Ok(JsValue.Boolean(v: false))
                            _: return Ok(JsValue.Boolean(v: true))
                    JsValue.Array(id):
                        match self.get_object_property(id, key_str):
                            JsValue.Undefined: return Ok(JsValue.Boolean(v: false))
                            _: return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: false))
            JsExpression.NewExpr(callee, args):
                return self.eval_new(callee, args, env)
            JsExpression.ComputedMember(object, property):
                val obj_val = self.eval_expression(object, env)?
                val key_val = self.eval_expression(property, env)?
                val key_str = js_to_string(key_val)
                match obj_val:
                    JsValue.Object(id):
                        return Ok(self.get_object_property(id, key_str))
                    JsValue.Array(id):
                        return Ok(self.get_object_property(id, key_str))
                    _:
                        return Ok(JsValue.Undefined)
            JsExpression.ObjectPattern(props):
                return Ok(JsValue.Undefined)
            JsExpression.ArrayPattern(elements):
                return Ok(JsValue.Undefined)

    # new operator: new Foo(args)
    me eval_new(callee: JsExpression, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val callee_val = self.eval_expression(callee, env)?
        var arg_vals: [JsValue] = []
        var i = 0
        while i < args.len():
            arg_vals.push(self.eval_expression(args.get(i), env)?)
            i = i + 1
        match callee_val:
            JsValue.Function(fn_id):
                val obj_id = self.create_object()
                val this_val = JsValue.Object(id: obj_id)
                # Set __proto__ to the class prototype for method lookup
                val proto_id = self._find_class_proto(fn_id)
                if proto_id >= 0:
                    self.set_object_property(obj_id, "__proto__", JsValue.Object(id: proto_id))
                if fn_id >= 0 and fn_id < self.functions.len():
                    val js_fn = self.functions.get(fn_id)
                    val params = js_fn.params
                    val fn_env = self.env_stack.create_env(js_fn.closure_env)
                    var pi = 0
                    while pi < params.len():
                        var pv = JsValue.Undefined
                        if pi < arg_vals.len():
                            pv = arg_vals.get(pi)
                        self.env_stack.define_var(fn_env, params.get(pi), pv)
                        pi = pi + 1
                    self.env_stack.define_var(fn_env, "this", this_val)
                    val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: this_val)
                    self.call_stack.push(frame)
                    val saved = self.control_return
                    self.control_return = false
                    var bi = 0
                    while bi < js_fn.body.len():
                        self.exec_statement(js_fn.body.get(bi), fn_env)?
                        if self.control_return:
                            break
                        bi = bi + 1
                    self.call_stack.pop()
                    self.control_return = saved
                return Ok(this_val)
            _:
                return Ok(JsValue.Undefined)

    # Binary operators
    me eval_binary(op: text, left: JsExpression, right: JsExpression, env: i64) -> BrowserResult<JsValue>:
        # Comma operator — evaluate left for side effects, return right
        if op == ",":
            self.eval_expression(left, env)?
            return self.eval_expression(right, env)

        # Short-circuit logical operators
        if op == "&&":
            val lv = self.eval_expression(left, env)?
            if not is_truthy(lv):
                return Ok(lv)
            return self.eval_expression(right, env)

        if op == "||":
            val lv = self.eval_expression(left, env)?
            if is_truthy(lv):
                return Ok(lv)
            return self.eval_expression(right, env)

        if op == "??":
            val lv = self.eval_expression(left, env)?
            match lv:
                JsValue.Null: return self.eval_expression(right, env)
                JsValue.Undefined: return self.eval_expression(right, env)
                _: return Ok(lv)

        val lv = self.eval_expression(left, env)?
        val rv = self.eval_expression(right, env)?

        # String concatenation with +
        if op == "+":
            val ls = typeof_value(lv)
            val rs = typeof_value(rv)
            if ls == "string" or rs == "string" or self._is_stringish(lv) or self._is_stringish(rv):
                var left_text = js_to_string(lv)
                var right_text = js_to_string(rv)
                match lv:
                    JsValue.Object(obj_id):
                        match self.get_object_property(obj_id, "__simple_promise_host"):
                            JsValue.Boolean(is_host):
                                if is_host:
                                    match self.get_object_property(obj_id, "__simple_state"):
                                        JsValue.String(state):
                                            if state == "fulfilled":
                                                left_text = js_to_string(self.get_object_property(obj_id, "__simple_value"))
                                        _:
                                            pass_dn
                            _:
                                pass_dn
                    _:
                        pass_dn
                match rv:
                    JsValue.Object(obj_id):
                        match self.get_object_property(obj_id, "__simple_promise_host"):
                            JsValue.Boolean(is_host):
                                if is_host:
                                    match self.get_object_property(obj_id, "__simple_state"):
                                        JsValue.String(state):
                                            if state == "fulfilled":
                                                right_text = js_to_string(self.get_object_property(obj_id, "__simple_value"))
                                        _:
                                            pass_dn
                            _:
                                pass_dn
                    _:
                        pass_dn
                val result = left_text + right_text
                return Ok(JsValue.String(v: result))
            val ln = to_number(lv)
            val rn = to_number(rv)
            return Ok(JsValue.Number(v: ln + rn))

        if op == "-":
            return Ok(JsValue.Number(v: to_number(lv) - to_number(rv)))
        if op == "*":
            return Ok(JsValue.Number(v: to_number(lv) * to_number(rv)))
        if op == "/":
            val divisor = to_number(rv)
            if divisor == 0.0:
                return Ok(JsValue.Number(v: js_infinity()))  # Infinity
            return Ok(JsValue.Number(v: to_number(lv) / divisor))
        if op == "%":
            val divisor = to_number(rv)
            if divisor == 0.0:
                return Ok(JsValue.Number(v: js_nan()))  # NaN
            return Ok(JsValue.Number(v: to_number(lv) % divisor))
        if op == "**":
            val base = to_number(lv)
            val exp = to_number(rv)
            return Ok(JsValue.Number(v: base ** exp))

        # Comparison
        if op == "<":
            return Ok(JsValue.Boolean(v: to_number(lv) < to_number(rv)))
        if op == ">":
            return Ok(JsValue.Boolean(v: to_number(lv) > to_number(rv)))
        if op == "<=":
            return Ok(JsValue.Boolean(v: to_number(lv) <= to_number(rv)))
        if op == ">=":
            return Ok(JsValue.Boolean(v: to_number(lv) >= to_number(rv)))

        # Equality
        if op == "==":
            return Ok(JsValue.Boolean(v: abstract_equals(lv, rv)))
        if op == "===":
            return Ok(JsValue.Boolean(v: strict_equals(lv, rv)))
        if op == "!=":
            return Ok(JsValue.Boolean(v: not abstract_equals(lv, rv)))
        if op == "!==":
            return Ok(JsValue.Boolean(v: not strict_equals(lv, rv)))

        # Bitwise
        if op == "&":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li & ri).to_f64()))
        if op == "|":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li | ri).to_f64()))
        if op == "^":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li ^ ri).to_f64()))

        # Computed property access: obj[key]
        if op == "[]":
            match lv:
                JsValue.Object(id):
                    return Ok(self.get_object_property(id, js_to_string(rv)))
                JsValue.Array(id):
                    return Ok(self.get_object_property(id, js_to_string(rv)))
                JsValue.String(sv):
                    val idx = f64_to_i64(to_number(rv))
                    if idx >= 0 and idx < sv.len():
                        return Ok(JsValue.String(v: sv[idx]))
                    return Ok(JsValue.Undefined)
                _:
                    return Ok(JsValue.Undefined)

        self.logger.warn("Unknown binary operator: {op}")
        Ok(JsValue.Undefined)

    # Unary operators
    me eval_unary(op: text, operand: JsExpression, env: i64) -> BrowserResult<JsValue>:
        if op == "typeof":
            match operand:
                JsExpression.Identifier(name):
                    if env == self.global_env:
                        val cached = self.lookup_global_value(name)
                        if val Some(v) = cached:
                            return Ok(JsValue.String(v: typeof_value(v)))
                        return Ok(JsValue.String(v: "undefined"))
                    val lookup = self.env_stack.get_var(env, name)
                    if val Some(v) = lookup:
                        return Ok(JsValue.String(v: typeof_value(v)))
                    return Ok(JsValue.String(v: "undefined"))
                _:
                    val v = self.eval_expression(operand, env)?
                    return Ok(JsValue.String(v: typeof_value(v)))

        val v = self.eval_expression(operand, env)?

        if op == "!":
            return Ok(JsValue.Boolean(v: not is_truthy(v)))
        if op == "-":
            return Ok(JsValue.Number(v: 0.0 - to_number(v)))
        if op == "+":
            return Ok(JsValue.Number(v: to_number(v)))
        if op == "~":
            val n = f64_to_i64(to_number(v))
            return Ok(JsValue.Number(v: (0 - n - 1).to_f64()))
        if op == "void":
            return Ok(JsValue.Undefined)

        # Pre/post increment/decrement
        if op == "++pre" or op == "++post":
            val n = to_number(v)
            val new_val = JsValue.Number(v: n + 1.0)
            match operand:
                JsExpression.Identifier(name):
                    self.env_stack.set_var(env, name, new_val)
                _: pass_dn
            if op == "++pre":
                return Ok(new_val)
            return Ok(v)  # post returns old value

        if op == "--pre" or op == "--post":
            val n = to_number(v)
            val new_val = JsValue.Number(v: n - 1.0)
            match operand:
                JsExpression.Identifier(name):
                    self.env_stack.set_var(env, name, new_val)
                _: pass_dn
            if op == "--pre":
                return Ok(new_val)
            return Ok(v)

        if op == "new":
            # new Constructor(args) — allocate object, set prototype, call constructor, return
            match operand:
                JsExpression.Call(callee, args):
                    val callee_val = self.eval_expression(callee, env)?
                    var arg_vals: [JsValue] = []
                    var ai = 0
                    val alen = args.len()
                    while ai < alen:
                        val av = self.eval_expression(args.get(ai), env)?
                        arg_vals.push(av)
                        ai = ai + 1
                    # Allocate new object
                    val obj_id = self.create_object()
                    val new_obj = JsValue.Object(id: obj_id)
                    # Link prototype chain (for class methods)
                    val ctor_fn_id = _get_fn_id(callee_val)
                    if ctor_fn_id >= 0:
                        val proto_id = self._find_class_proto(ctor_fn_id)
                        if proto_id >= 0:
                            self.set_object_property(obj_id, "__proto__", JsValue.Object(id: proto_id))
                    # Call constructor with 'this' bound to new object
                    match callee_val:
                        JsValue.Function(fn_id):
                            if fn_id >= 0 and fn_id < self.functions.len():
                                val js_fn = self.functions.get(fn_id)
                                val fn_env = self.env_stack.create_env(js_fn.closure_env)
                                # Bind parameters
                                var pi = 0
                                val plen = js_fn.params.len()
                                while pi < plen:
                                    val pname = js_fn.params.get(pi)
                                    var pval = JsValue.Undefined
                                    if pi < arg_vals.len():
                                        pval = arg_vals.get(pi)
                                    self.env_stack.define_var(fn_env, pname, pval)
                                    pi = pi + 1
                                self.env_stack.define_var(fn_env, "this", new_obj)
                                val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: new_obj)
                                self.call_stack.push(frame)
                                val saved = self.control_return
                                self.control_return = false
                                var bi = 0
                                val blen = js_fn.body.len()
                                while bi < blen:
                                    self.exec_statement(js_fn.body.get(bi), fn_env)?
                                    if self.control_return:
                                        break
                                    bi = bi + 1
                                self.call_stack.pop()
                                self.control_return = saved
                        _: pass_dn
                    return Ok(new_obj)
                _:
                    # Simple new without call
                    val obj_id = self.create_object()
                    return Ok(JsValue.Object(id: obj_id))

        self.logger.warn("Unknown unary operator: {op}")
        Ok(JsValue.Undefined)

    # Function call
    me eval_call(callee: JsExpression, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        # Array method dispatch — avoid nested match/return (interpreter mode issue)
        var is_member = false
        var member_method = ""
        var member_obj_expr = JsExpression.Literal(value: JsValue.Undefined)
        match callee:
            JsExpression.Member(obj_expr, method_name):
                is_member = true
                member_method = method_name
                member_obj_expr = obj_expr
            _: pass_dn

        if is_member and _is_array_method(member_method):
            val obj_val = self.eval_expression(member_obj_expr, env)?
            var is_array = false
            var arr_id = 0
            match obj_val:
                JsValue.Array(id):
                    is_array = true
                    arr_id = id
                _: pass_dn
            if is_array:
                return self._dispatch_array_method(arr_id, member_method, args, env)

        if is_member and _is_string_method(member_method):
            val obj_val_s = self.eval_expression(member_obj_expr, env)?
            var is_string = false
            var str_val = ""
            match obj_val_s:
                JsValue.String(sv):
                    is_string = true
                    str_val = sv
                _: pass_dn
            if is_string:
                return self._dispatch_string_method(str_val, member_method, args, env)

        # Object.keys / Object.values / Object.entries
        if is_member and member_method == "keys":
            val callee_obj_name = self.ident_name(member_obj_expr)
            if callee_obj_name == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            self.set_object_property(result_id, "{ki}", JsValue.String(v: prop.key))
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        if is_member and member_method == "values":
            val callee_obj_name_v = self.ident_name(member_obj_expr)
            if callee_obj_name_v == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            self.set_object_property(result_id, "{ki}", prop.value)
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        if is_member and member_method == "entries":
            val callee_obj_name_e = self.ident_name(member_obj_expr)
            if callee_obj_name_e == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            val entry_id = self.create_object()
                            self.set_object_property(entry_id, "0", JsValue.String(v: prop.key))
                            self.set_object_property(entry_id, "1", prop.value)
                            self.set_object_property(entry_id, "length", JsValue.Number(v: 2.0))
                            self.set_object_property(result_id, "{ki}", JsValue.Array(id: entry_id))
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        # Object.assign
        if is_member and member_method == "assign":
            val callee_obj_name_oa = self.ident_name(member_obj_expr)
            if callee_obj_name_oa == "Object":
                if args.len() >= 1:
                    val target = self.eval_expression(args.get(0), env)?
                    val target_id = _get_obj_id(target)
                    if target_id >= 0:
                        var ai = 1
                        while ai < args.len():
                            val source = self.eval_expression(args.get(ai), env)?
                            val source_id = _get_obj_id(source)
                            if source_id >= 0:
                                val src_obj = self.object_store.get_object(source_id)
                                var pi = 0
                                while pi < src_obj.properties.len():
                                    val prop = src_obj.properties.get(pi)
                                    self.set_object_property(target_id, prop.key, prop.value)
                                    pi = pi + 1
                            ai = ai + 1
                        return Ok(target)
                return Ok(JsValue.Undefined)

        # Object.freeze prevents future writes through the central property setter.
        if is_member and member_method == "freeze":
            val callee_obj_name_of = self.ident_name(member_obj_expr)
            if callee_obj_name_of == "Object":
                if args.len() > 0:
                    val frozen_target = self.eval_expression(args.get(0), env)?
                    val frozen_id = _get_obj_id(frozen_target)
                    if frozen_id >= 0:
                        self._mark_object_frozen(frozen_id)
                    return Ok(frozen_target)
                return Ok(JsValue.Undefined)

        # Object.isFrozen
        if is_member and member_method == "isFrozen":
            val callee_obj_name_oif = self.ident_name(member_obj_expr)
            if callee_obj_name_oif == "Object":
                if args.len() > 0:
                    val frozen_check_target = self.eval_expression(args.get(0), env)?
                    val frozen_check_id = _get_obj_id(frozen_check_target)
                    return Ok(JsValue.Boolean(v: frozen_check_id >= 0 and self._is_object_frozen(frozen_check_id)))
                return Ok(JsValue.Boolean(v: false))

        # Number.isInteger / Number.isFinite / Number.isNaN / Number.parseInt / Number.parseFloat
        if is_member and (member_method == "isInteger" or member_method == "isFinite" or member_method == "isNaN" or member_method == "parseInt" or member_method == "parseFloat"):
            val callee_obj_name_n = self.ident_name(member_obj_expr)
            if callee_obj_name_n == "Number":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val n = to_number(arg)
                    if member_method == "isInteger":
                        val int_val = f64_to_i64(n)
                        return Ok(JsValue.Boolean(v: int_val.to_f64() == n))
                    if member_method == "isFinite":
                        val is_inf = n == 9999999999.0
                        val is_neg_inf = n == -9999999999.0
                        val is_nan_val = n == -9999999999.999
                        return Ok(JsValue.Boolean(v: not is_inf and not is_neg_inf and not is_nan_val))
                    if member_method == "isNaN":
                        return Ok(JsValue.Boolean(v: n == -9999999999.999))
                    if member_method == "parseInt":
                        val s = js_to_string(arg)
                        val parsed = s.parse_float()
                        if val Some(pv) = parsed:
                            return Ok(JsValue.Number(v: f64_to_i64(pv).to_f64()))
                        return Ok(JsValue.Number(v: -9999999999.999))
                    if member_method == "parseFloat":
                        val s = js_to_string(arg)
                        val parsed = s.parse_float()
                        if val Some(pv) = parsed:
                            return Ok(JsValue.Number(v: pv))
                        return Ok(JsValue.Number(v: -9999999999.999))
                return Ok(JsValue.Boolean(v: false))

        # JSON.stringify
        if is_member and member_method == "stringify":
            val callee_obj_name_js = self.ident_name(member_obj_expr)
            if callee_obj_name_js == "JSON":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val json_str = self._json_stringify(arg)
                    return Ok(JsValue.String(v: json_str))
                return Ok(JsValue.String(v: "undefined"))

        # JSON.parse
        if is_member and member_method == "parse":
            val callee_obj_name_jp = self.ident_name(member_obj_expr)
            if callee_obj_name_jp == "JSON":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    return self._json_parse_allocated(js_to_string(arg), env)
                return Ok(JsValue.Undefined)

        # Promise.resolve / Promise.reject
        if is_member and (member_method == "resolve" or member_method == "reject"):
            val callee_obj_name_p = self.ident_name(member_obj_expr)
            if callee_obj_name_p == "Promise":
                var promise_arg_vals: [JsValue] = []
                if args.len() > 0:
                    promise_arg_vals.push(self.eval_expression(args.get(0), env)?)
                if member_method == "resolve":
                    return Ok(self._native_promise_resolve(promise_arg_vals))
                return Ok(self._native_promise_reject(promise_arg_vals))

        # Array.isArray / Array.from
        if is_member and member_method == "isArray":
            val callee_obj_name_a = self.ident_name(member_obj_expr)
            if callee_obj_name_a == "Array":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    return Ok(array_isArray(arg))
                return Ok(JsValue.Boolean(v: false))

        if is_member and member_method == "from":
            val callee_obj_name_f = self.ident_name(member_obj_expr)
            if callee_obj_name_f == "Array":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val arr_len = self.object_store.array_length(arg_id)
                        val new_id = self.create_object()
                        var ai = 0
                        while ai < arr_len:
                            val elem = self.object_store.get_by_index(arg_id, ai)
                            self.set_object_property(new_id, "{ai}", elem)
                            ai = ai + 1
                        self.set_object_property(new_id, "length", JsValue.Number(v: arr_len.to_f64()))
                        return Ok(JsValue.Array(id: new_id))
                return Ok(JsValue.Array(id: self.create_object()))

        var callee_val = JsValue.Undefined
        var this_val_for_call = JsValue.Undefined
        if is_member:
            this_val_for_call = self.eval_expression(member_obj_expr, env)?
            val member_obj_id = _get_obj_id(this_val_for_call)
            if member_obj_id >= 0:
                callee_val = self._proto_lookup(member_obj_id, member_method)
            else:
                callee_val = JsValue.Undefined
        else:
            callee_val = self.eval_expression(callee, env)?

        # Evaluate arguments
        var arg_vals: [JsValue] = []
        var i = 0
        val alen = args.len()
        while i < alen:
            val arg_val = self.eval_expression(args.get(i), env)?
            arg_vals.push(arg_val)
            i = i + 1

        # Look up function
        match callee_val:
            JsValue.Function(fn_id):
                if fn_id >= 0 and fn_id < self.functions.len():
                    # Check if this function index maps to a native function
                    var ni = 0
                    while ni < self.native_id_map.len():
                        val mapping = self.native_id_map.get(ni)
                        if mapping.first == fn_id:
                            var this_val = JsValue.Undefined
                            if is_member:
                                this_val = this_val_for_call
                            return Ok(self._dispatch_native_with_receiver(mapping.second, this_val, arg_vals, env))
                        ni = ni + 1
                    val js_fn = self.functions.get(fn_id)
                    # Create function scope from closure env
                    val fn_env = self.env_stack.create_env(js_fn.closure_env)

                    # Bind parameters
                    var pi = 0
                    val plen = js_fn.params.len()
                    while pi < plen:
                        val param_name = js_fn.params.get(pi)
                        var param_val = JsValue.Undefined
                        if pi < arg_vals.len():
                            param_val = arg_vals.get(pi)
                        self.env_stack.define_var(fn_env, param_name, param_val)
                        pi = pi + 1

                    # Bind 'arguments' object
                    val args_obj_id = self.create_object()
                    var ai = 0
                    while ai < arg_vals.len():
                        self.set_object_property(args_obj_id, "{ai}", arg_vals.get(ai))
                        ai = ai + 1
                    self.set_object_property(args_obj_id, "length", JsValue.Number(v: arg_vals.len().to_f64()))
                    self.env_stack.define_var(fn_env, "arguments", JsValue.Object(id: args_obj_id))

                    # Bind 'this' — for method calls, the receiver is tracked via callee
                    var this_val = JsValue.Undefined
                    if is_member:
                        this_val = this_val_for_call
                    self.env_stack.define_var(fn_env, "this", this_val)

                    # Push call frame
                    val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: this_val)
                    self.call_stack.push(frame)

                    # Execute body
                    val saved_control_return = self.control_return
                    self.control_return = false
                    var result = JsValue.Undefined
                    var bi = 0
                    val blen = js_fn.body.len()
                    while bi < blen:
                        result = self.exec_statement(js_fn.body.get(bi), fn_env)?
                        if self.control_return:
                            result = self.return_value
                            break
                        bi = bi + 1

                    # Pop call frame and reset return flag
                    self.call_stack.pop()
                    self.control_return = saved_control_return

                    return Ok(result)
                self.logger.warn("Invalid function id: {fn_id}")
                return Ok(JsValue.Undefined)
            _:
                # Trying to call a non-function
                self.logger.warn("TypeError: {js_to_string(callee_val)} is not a function")
                return Ok(JsValue.Undefined)

    # Member access: obj.prop
    # Look up property on object, with recursive prototype chain fallback
    fn _proto_lookup(obj_id: i64, property: text) -> JsValue:
        var current_id = obj_id
        var depth = 0
        while current_id >= 0 and depth < 64:
            val prop = self.get_object_property(current_id, property)
            if not strict_equals(prop, JsValue.Undefined):
                return prop
            val proto = self.get_object_property(current_id, "__proto__")
            val proto_id = _get_obj_id(proto)
            if proto_id < 0 or proto_id == current_id:
                return JsValue.Undefined
            current_id = proto_id
            depth = depth + 1
        JsValue.Undefined

    me eval_member(object: JsExpression, property: text, env: i64) -> BrowserResult<JsValue>:
        val obj_val = self.eval_expression(object, env)?
        val obj_id = _get_obj_id(obj_val)
        if obj_id >= 0:
            if obj_id == self.host_document_id:
                if property == "title" and not strict_equals(self.host_document_title_value, JsValue.Undefined):
                    return Ok(self.host_document_title_value)
                if property == "cookie":
                    if not strict_equals(self.host_document_cookie_value, JsValue.Undefined):
                        return Ok(self.host_document_cookie_value)
                    match self.get_object_property(obj_id, "cookie"):
                        JsValue.String(v):
                            return Ok(JsValue.String(v: v))
                        _:
                            return Ok(JsValue.String(v: ""))
                if property == "body" and self.host_body_id >= 0:
                    return Ok(JsValue.Object(id: self.host_body_id))
                if property == "location" and self.host_location_id >= 0:
                    return Ok(JsValue.Object(id: self.host_location_id))
            if obj_id == self.host_body_id:
                if property == "innerHTML" and not strict_equals(self.host_body_inner_html_value, JsValue.Undefined):
                    return Ok(self.host_body_inner_html_value)
                if property == "textContent" and not strict_equals(self.host_body_text_content_value, JsValue.Undefined):
                    return Ok(self.host_body_text_content_value)
            # Object or Array — check array length first
            if property == "length":
                val len_val = self.get_object_property(obj_id, "length")
                if not strict_equals(len_val, JsValue.Undefined):
                    return Ok(len_val)
            return Ok(self._proto_lookup(obj_id, property))
        # String — use typeof_value to avoid match destructuring
        val tv = typeof_value(obj_val)
        if tv == "string":
            if property == "length":
                val str_val = js_to_string(obj_val)
                return Ok(JsValue.Number(v: str_val.len().to_f64()))
        # TypeError: Cannot read properties of undefined/null
        if tv == "undefined" or strict_equals(obj_val, JsValue.Null):
            self.thrown_value = JsValue.String(v: "TypeError: Cannot read properties of " + tv)
            self.control_thrown = true
            return Ok(JsValue.Undefined)
        Ok(JsValue.Undefined)

    # Assignment: target = value
    me eval_assignment(target: JsExpression, value: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val rhs = self.eval_expression(value, env)?

        match target:
            JsExpression.Identifier(name):
                self.env_stack.set_var(env, name, rhs)
                return Ok(rhs)
            JsExpression.Member(object, property):
                var handled_host_body_assignment = false
                match object:
                    JsExpression.Member(parent_object, parent_property):
                        if parent_property == "body":
                            match parent_object:
                                JsExpression.Identifier(parent_name):
                                    if parent_name == "document":
                                        if property == "innerHTML":
                                            self.host_body_inner_html_value = rhs
                                            handled_host_body_assignment = true
                                        if property == "textContent":
                                            self.host_body_text_content_value = rhs
                                            handled_host_body_assignment = true
                                _:
                                    pass_dn
                    _:
                        pass_dn
                if handled_host_body_assignment:
                    return Ok(rhs)
                val obj_val = self.eval_expression(object, env)?
                val obj_id = _get_obj_id(obj_val)
                if obj_id >= 0:
                    if obj_id == self.host_document_id:
                        if property == "title":
                            self.host_document_title_value = rhs
                            return Ok(rhs)
                        if property == "cookie":
                            val cookie_text = js_to_string(rhs)
                            self.host_document_cookie_value = JsValue.String(v: cookie_text)
                            self.set_object_property(self.host_document_id, "cookie", JsValue.String(v: cookie_text))
                            if self.host_window_id >= 0:
                                self.set_object_property(self.host_window_id, "__simple_cookie_header", JsValue.String(v: cookie_text))
                            if self.host_chrome_id >= 0:
                                self.set_object_property(self.host_chrome_id, "__simple_cookie_header", JsValue.String(v: cookie_text))
                            return Ok(rhs)
                    if obj_id == self.host_body_id:
                        if property == "innerHTML":
                            self.host_body_inner_html_value = rhs
                            return Ok(rhs)
                        if property == "textContent":
                            self.host_body_text_content_value = rhs
                            return Ok(rhs)
                    self.set_object_property_direct(obj_id, property, rhs)
                return Ok(rhs)
            _:
                self.logger.warn("Invalid assignment target")
                return Ok(rhs)

    # Array literal — supports spread: [1, ...arr, 2]
    me eval_array(elements: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val arr_id = self.create_object()
        var idx = 0
        var i = 0
        val len = elements.len()
        while i < len:
            val elem_expr = elements.get(i)
            match elem_expr:
                JsExpression.SpreadElement(arg):
                    val spread_val = self.eval_expression(arg, env)?
                    match spread_val:
                        JsValue.Array(src_id):
                            val src_len = self.object_store.array_length(src_id)
                            var si = 0
                            while si < src_len:
                                val sv = self.object_store.get_by_index(src_id, si)
                                self.set_object_property(arr_id, "{idx}", sv)
                                idx = idx + 1
                                si = si + 1
                        _:
                            self.set_object_property(arr_id, "{idx}", spread_val)
                            idx = idx + 1
                _:
                    val elem = self.eval_expression(elem_expr, env)?
                    self.set_object_property(arr_id, "{idx}", elem)
                    idx = idx + 1
            i = i + 1
        self.set_object_property(arr_id, "length", JsValue.Number(v: idx.to_f64()))
        Ok(JsValue.Array(id: arr_id))

    # Object literal
    me eval_object(properties: [Pair<text, JsExpression>], env: i64) -> BrowserResult<JsValue>:
        val obj_id = self.create_object()
        var i = 0
        val len = properties.len()
        while i < len:
            val prop = properties.get(i)
            val pv = self.eval_expression(prop.second, env)?
            self.set_object_property(obj_id, prop.first, pv)
            i = i + 1
        Ok(JsValue.Object(id: obj_id))

    # Template literal: `hello ${name}!`
    me eval_template_literal(quasis: [text], expressions: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        var result = ""
        var i = 0
        val qlen = quasis.len()
        while i < qlen:
            result = result + quasis.get(i)
            if i < expressions.len():
                val expr_val = self.eval_expression(expressions.get(i), env)?
                result = result + js_to_string(expr_val)
            i = i + 1
        Ok(JsValue.String(v: result))

    # Delete operator: delete obj.prop
    me eval_delete(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        match expr:
            JsExpression.Member(object, property):
                val obj_val = self.eval_expression(object, env)?
                match obj_val:
                    JsValue.Object(id):
                        self.object_store.remove_property(id, property)
                        return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: true))
            _:
                return Ok(JsValue.Boolean(v: true))

    # ── Array method dispatch ────────────────────────────────────────────
    me _dispatch_array_method(arr_id: i64, method: text, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val arr_len = self.object_store.array_length(arr_id)

        # --- Higher-order methods that need a callback ---
        if method == "map":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val mapped = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        self.set_object_property(result_id, "{i}", mapped)
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: arr_len.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        if method == "filter":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var i = 0
                    var out_idx = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val keep = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(keep):
                            self.set_object_property(result_id, "{out_idx}", elem)
                            out_idx = out_idx + 1
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: out_idx.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        if method == "forEach":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Undefined)

        if method == "find":
            val cb_val = self.eval_expression(args.get(0), env)?
            var final_result = JsValue.Undefined
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    var found = false
                    var found_value = JsValue.Undefined
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            found = true
                            found_value = elem
                            break
                        i = i + 1
                    if found:
                        final_result = found_value
                _: pass_dn
            return Ok(final_result)

        if method == "findIndex":
            val cb_val = self.eval_expression(args.get(0), env)?
            var final_index = -1
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    var found = false
                    var found_index = -1
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            found = true
                            found_index = i
                            break
                        i = i + 1
                    if found:
                        final_index = found_index
                _: pass_dn
            return Ok(JsValue.Number(v: final_index.to_f64()))

        if method == "some":
            val cb_val = self.eval_expression(args.get(0), env)?
            var matched = false
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            matched = true
                            break
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Boolean(v: matched))

        if method == "every":
            val cb_val = self.eval_expression(args.get(0), env)?
            var all_match = true
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if not is_truthy(result):
                            all_match = false
                            break
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Boolean(v: all_match))

        if method == "reduce":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    var acc = JsValue.Undefined
                    var start = 0
                    if args.len() > 1:
                        acc = self.eval_expression(args.get(1), env)?
                    else:
                        if arr_len > 0:
                            acc = self.object_store.get_by_index(arr_id, 0)
                            start = 1
                    var i = start
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        acc = self._invoke_function(fn_id, [acc, elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        i = i + 1
                    return Ok(acc)
                _:
                    return Ok(JsValue.Undefined)

        # --- Mutating / non-callback methods ---
        if method == "push":
            var i = 0
            while i < args.len():
                val arg_val = self.eval_expression(args.get(i), env)?
                self.set_object_property(arr_id, "{arr_len + i}", arg_val)
                i = i + 1
            val new_len = arr_len + args.len()
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Number(v: new_len.to_f64()))

        if method == "pop":
            if arr_len == 0:
                return Ok(JsValue.Undefined)
            val last = self.object_store.get_by_index(arr_id, arr_len - 1)
            val new_len = arr_len - 1
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(last)

        if method == "indexOf":
            val search_val = self.eval_expression(args.get(0), env)?
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                if strict_equals(elem, search_val):
                    return Ok(JsValue.Number(v: i.to_f64()))
                i = i + 1
            return Ok(JsValue.Number(v: -1.0))

        if method == "includes":
            val search_val = self.eval_expression(args.get(0), env)?
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                if strict_equals(elem, search_val):
                    return Ok(JsValue.Boolean(v: true))
                i = i + 1
            return Ok(JsValue.Boolean(v: false))

        if method == "join":
            var sep = ","
            if args.len() > 0:
                val sep_val = self.eval_expression(args.get(0), env)?
                sep = js_to_string(sep_val)
            var result = ""
            var i = 0
            while i < arr_len:
                if i > 0:
                    result = result + sep
                val elem = self.object_store.get_by_index(arr_id, i)
                result = result + js_to_string(elem)
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "reverse":
            var i = 0
            var j = arr_len - 1
            while i < j:
                val a = self.object_store.get_by_index(arr_id, i)
                val b = self.object_store.get_by_index(arr_id, j)
                self.set_object_property(arr_id, "{i}", b)
                self.set_object_property(arr_id, "{j}", a)
                i = i + 1
                j = j - 1
            return Ok(JsValue.Array(id: arr_id))

        if method == "slice":
            var start = 0
            var end = arr_len
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = arr_len + start
                    if start < 0:
                        start = 0
            if args.len() > 1:
                val e = self.eval_expression(args.get(1), env)?
                end = f64_to_i64(to_number(e))
                if end < 0:
                    end = arr_len + end
                if end > arr_len:
                    end = arr_len
            val result_id = self.create_object()
            var i = start
            var out = 0
            while i < end:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(result_id, "{out}", elem)
                out = out + 1
                i = i + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "concat":
            val result_id = self.create_object()
            var out = 0
            # Copy current array
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(result_id, "{out}", elem)
                out = out + 1
                i = i + 1
            # Append each argument (expand arrays)
            var ai = 0
            while ai < args.len():
                val arg_val = self.eval_expression(args.get(ai), env)?
                match arg_val:
                    JsValue.Array(src_id):
                        val src_len = self.object_store.array_length(src_id)
                        var si = 0
                        while si < src_len:
                            val sv = self.object_store.get_by_index(src_id, si)
                            self.set_object_property(result_id, "{out}", sv)
                            out = out + 1
                            si = si + 1
                    _:
                        self.set_object_property(result_id, "{out}", arg_val)
                        out = out + 1
                ai = ai + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "sort":
            if args.len() > 0:
                val cb_val = self.eval_expression(args.get(0), env)?
                match cb_val:
                    JsValue.Function(fn_id):
                        # Simple bubble sort with comparator
                        var swapped = true
                        while swapped:
                            swapped = false
                            var i = 0
                            while i < arr_len - 1:
                                val a = self.object_store.get_by_index(arr_id, i)
                                val b = self.object_store.get_by_index(arr_id, i + 1)
                                val cmp = self._invoke_function(fn_id, [a, b], env)?
                                val cmp_num = to_number(cmp)
                                if cmp_num > 0.0:
                                    self.set_object_property(arr_id, "{i}", b)
                                    self.set_object_property(arr_id, "{i + 1}", a)
                                    swapped = true
                                i = i + 1
                    _: pass_dn
            return Ok(JsValue.Array(id: arr_id))

        # shift — remove first element
        if method == "shift":
            if arr_len == 0:
                return Ok(JsValue.Undefined)
            val first = self.object_store.get_by_index(arr_id, 0)
            var i = 1
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(arr_id, "{i - 1}", elem)
                i = i + 1
            val new_len = arr_len - 1
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(first)

        # unshift — prepend elements
        if method == "unshift":
            val count = args.len()
            # Shift existing elements right
            var i = arr_len - 1
            while i >= 0:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(arr_id, "{i + count}", elem)
                i = i - 1
            # Insert new elements at front
            var j = 0
            while j < count:
                val arg_val = self.eval_expression(args.get(j), env)?
                self.set_object_property(arr_id, "{j}", arg_val)
                j = j + 1
            val new_len = arr_len + count
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Number(v: new_len.to_f64()))

        # splice — remove/insert elements
        if method == "splice":
            var start = 0
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = arr_len + start
                    if start < 0:
                        start = 0
            var delete_count = arr_len - start
            if args.len() > 1:
                val dc = self.eval_expression(args.get(1), env)?
                delete_count = f64_to_i64(to_number(dc))
            # Collect removed elements
            val removed_id = self.create_object()
            var ri = 0
            while ri < delete_count and (start + ri) < arr_len:
                val elem = self.object_store.get_by_index(arr_id, start + ri)
                self.set_object_property(removed_id, "{ri}", elem)
                ri = ri + 1
            self.set_object_property(removed_id, "length", JsValue.Number(v: ri.to_f64()))
            # Collect insert items (args from index 2 onward)
            var inserts: [JsValue] = []
            var ii = 2
            while ii < args.len():
                val iv = self.eval_expression(args.get(ii), env)?
                inserts.push(iv)
                ii = ii + 1
            # Shift tail elements
            val tail_start = start + delete_count
            val shift_amount = inserts.len() - delete_count
            if shift_amount > 0:
                var ti = arr_len - 1
                while ti >= tail_start:
                    val elem = self.object_store.get_by_index(arr_id, ti)
                    self.set_object_property(arr_id, "{ti + shift_amount}", elem)
                    ti = ti - 1
            else:
                if shift_amount < 0:
                    var ti = tail_start
                    while ti < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, ti)
                        self.set_object_property(arr_id, "{ti + shift_amount}", elem)
                        ti = ti + 1
            # Insert new elements
            var ki = 0
            while ki < inserts.len():
                self.set_object_property(arr_id, "{start + ki}", inserts.get(ki))
                ki = ki + 1
            val new_len = arr_len + shift_amount
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Array(id: removed_id))

        if method == "at":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                var idx = f64_to_i64(to_number(idx_val))
                if idx < 0:
                    idx = arr_len + idx
                if idx >= 0 and idx < arr_len:
                    return Ok(self.object_store.get_by_index(arr_id, idx))
            return Ok(JsValue.Undefined)

        if method == "flat":
            val result_id = self.create_object()
            var out = 0
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                val elem_arr_id = _get_obj_id(elem)
                var is_inner_array = false
                match elem:
                    JsValue.Array(id):
                        is_inner_array = true
                    _: pass_dn
                if is_inner_array and elem_arr_id >= 0:
                    val inner_len = self.object_store.array_length(elem_arr_id)
                    var j = 0
                    while j < inner_len:
                        val inner_elem = self.object_store.get_by_index(elem_arr_id, j)
                        self.set_object_property(result_id, "{out}", inner_elem)
                        out = out + 1
                        j = j + 1
                else:
                    self.set_object_property(result_id, "{out}", elem)
                    out = out + 1
                i = i + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "flatMap":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var out = 0
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val mapped = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        val mapped_arr_id = _get_obj_id(mapped)
                        var is_array = false
                        match mapped:
                            JsValue.Array(id):
                                is_array = true
                            _: pass_dn
                        if is_array and mapped_arr_id >= 0:
                            val inner_len = self.object_store.array_length(mapped_arr_id)
                            var j = 0
                            while j < inner_len:
                                val inner = self.object_store.get_by_index(mapped_arr_id, j)
                                self.set_object_property(result_id, "{out}", inner)
                                out = out + 1
                                j = j + 1
                        else:
                            self.set_object_property(result_id, "{out}", mapped)
                            out = out + 1
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        self.logger.warn("Unknown array method: {method}")
        Ok(JsValue.Undefined)

    me _dispatch_native_with_receiver(native_id: i64, this_val: JsValue, arg_vals: [JsValue], env: i64) -> JsValue:
        if native_id == NATIVE_SET_TIMEOUT:
            return self._native_set_timer(arg_vals, false)
        if native_id == NATIVE_SET_INTERVAL:
            return self._native_set_timer(arg_vals, true)
        if native_id == NATIVE_CLEAR_TIMEOUT or native_id == NATIVE_CLEAR_INTERVAL:
            return self._native_clear_timer(arg_vals)
        if native_id == NATIVE_FETCH:
            return self._native_fetch(this_val, arg_vals, env)
        if native_id == NATIVE_PROMISE_THEN:
            return self._native_promise_then(this_val, arg_vals)
        if native_id == NATIVE_PROMISE_CATCH:
            return self._native_promise_catch(this_val, arg_vals)
        if native_id == NATIVE_PROMISE_FINALLY:
            return self._native_promise_finally(this_val, arg_vals)
        if native_id == NATIVE_PROMISE_RESOLVE:
            return self._native_promise_resolve(arg_vals)
        if native_id == NATIVE_PROMISE_REJECT:
            return self._native_promise_reject(arg_vals)
        if native_id == NATIVE_RESPONSE_TEXT:
            return self._native_response_text(this_val)
        if native_id == NATIVE_RESPONSE_JSON:
            return self._native_response_json(this_val)
        if native_id == NATIVE_RESPONSE_BLOB:
            return self._native_response_blob(this_val)
        if native_id == NATIVE_BLOB_TEXT:
            return self._native_blob_text(this_val)
        if native_id == NATIVE_STORAGE_GET_ITEM:
            return self._native_storage_get_item(this_val, arg_vals)
        if native_id == NATIVE_STORAGE_SET_ITEM:
            return self._native_storage_set_item(this_val, arg_vals)
        if native_id == NATIVE_STORAGE_REMOVE_ITEM:
            return self._native_storage_remove_item(this_val, arg_vals)
        if native_id == NATIVE_STORAGE_CLEAR:
            return self._native_storage_clear(this_val)
        if native_id == NATIVE_STORAGE_KEY:
            return self._native_storage_key(this_val, arg_vals)
        dispatch_native(native_id, arg_vals, self.logger)

    me _native_set_timer(arg_vals: [JsValue], is_interval: bool) -> JsValue:
        val timer_id = self.next_timer_id
        self.next_timer_id = self.next_timer_id + 1
        var callback_id = -1
        if arg_vals.len() > 0:
            match arg_vals[0]:
                JsValue.Function(id): callback_id = id
                _: pass_dn
        var delay_ms = 0
        if arg_vals.len() > 1:
            delay_ms = f64_to_i64(to_number(arg_vals[1]))
            if delay_ms < 0:
                delay_ms = 0
        if is_interval and delay_ms < 1:
            delay_ms = 1
        self.pending_timer_tasks = self.pending_timer_tasks + [PendingTimerTask.create(timer_id, callback_id, delay_ms, 0, is_interval)]
        JsValue.Number(v: (timer_id as f64))

    me _native_clear_timer(arg_vals: [JsValue]) -> JsValue:
        if arg_vals.len() == 0:
            return JsValue.Undefined
        val timer_id = f64_to_i64(to_number(arg_vals[0]))
        var rest: [PendingTimerTask] = []
        var i = 0
        while i < self.pending_timer_tasks.len():
            val task = self.pending_timer_tasks[i]
            if task.id != timer_id:
                rest = rest + [task]
            i = i + 1
        self.pending_timer_tasks = rest
        JsValue.Undefined

    me _native_fetch(this_val: JsValue, arg_vals: [JsValue], env: i64) -> JsValue:
        var host_obj_id = _get_obj_id(this_val)
        if host_obj_id < 0:
            match self.lookup_global_value("window"):
                Some(window_val):
                    host_obj_id = _get_obj_id(window_val)
                _:
                    pass_dn
        if host_obj_id < 0:
            return JsValue.Undefined
        if not _simple_fetch_marker(host_obj_id, self.object_store):
            return JsValue.Undefined

        var request_url = _simple_fetch_base_url(host_obj_id, self.object_store)
        if arg_vals.len() > 0:
            request_url = _resolve_fetch_url(request_url, js_to_string(arg_vals.get(0)))

        var method = "GET"
        var headers_text = ""
        var body = ""
        var content_type = ""
        if arg_vals.len() > 1:
            match arg_vals.get(1):
                JsValue.Object(opts_id):
                    match self.get_object_property(opts_id, "method"):
                        JsValue.String(v):
                            if v.trim() != "":
                                method = v.trim().upper()
                        JsValue.Number(v):
                            method = "{v}".upper()
                        _: pass_dn
                    match self.get_object_property(opts_id, "headers"):
                        JsValue.Undefined: pass_dn
                        header_value: headers_text = self._serialize_fetch_headers(header_value)
                    match self.get_object_property(opts_id, "body"):
                        JsValue.String(v): body = v
                        JsValue.Number(v): body = "{v}"
                        JsValue.Boolean(v): body = if v: "true" else: "false"
                        _: pass_dn
                    match self.get_object_property(opts_id, "contentType"):
                        JsValue.String(v): content_type = v
                        _: pass_dn
                JsValue.String(v):
                    headers_text = v
                _:
                    pass_dn

        val cookie_header = _simple_fetch_cookie_header(host_obj_id, self.object_store)
        if cookie_header != "":
            if headers_text != "":
                headers_text = headers_text + "\n"
            headers_text = headers_text + "Cookie: " + cookie_header
        if content_type != "":
            if headers_text != "":
                headers_text = headers_text + "\n"
            headers_text = headers_text + "Content-Type: " + content_type

        val promise_id = self._create_pending_promise_object()
        val request_obj_id = self.create_object()
        val request_id = "fetch-{self.next_async_request_seq}"
        self.next_async_request_seq = self.next_async_request_seq + 1
        self.set_object_property(promise_id, "__simple_request_id", JsValue.String(v: request_id))
        self.set_object_property(request_obj_id, "request_id", JsValue.String(v: request_id))
        self.set_object_property(request_obj_id, "kind", JsValue.String(v: "fetch"))
        self.set_object_property(request_obj_id, "url", JsValue.String(v: request_url))
        self.set_object_property(request_obj_id, "method", JsValue.String(v: if method.trim() != "": method else: "GET"))
        self.set_object_property(request_obj_id, "headers", JsValue.String(v: headers_text))
        self.set_object_property(request_obj_id, "body", JsValue.String(v: body))
        self.set_object_property(request_obj_id, "content_type", JsValue.String(v: content_type))
        self.set_object_property(request_obj_id, "promise_id", JsValue.String(v: "{promise_id}"))
        val request_record = PendingAsyncRequest.create(request_obj_id)
        self.pending_async_requests = self.pending_async_requests + [request_record]
        self.pending_async_request_registry = self.pending_async_request_registry + [request_record]
        JsValue.Object(id: promise_id)

    me _native_promise_then(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_fulfilled = -1
        var on_rejected = -1
        if arg_vals.len() > 0:
            on_fulfilled = _get_fn_id(arg_vals.get(0))
        if arg_vals.len() > 1:
            on_rejected = _get_fn_id(arg_vals.get(1))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(on_fulfilled, on_rejected, next_promise_id, "then")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._enqueue_promise_task(promise_id, handler_id)
                JsValue.Object(id: next_promise_id)

    me _native_promise_catch(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_rejected = -1
        if arg_vals.len() > 0:
            on_rejected = _get_fn_id(arg_vals.get(0))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(-1, on_rejected, next_promise_id, "then")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._enqueue_promise_task(promise_id, handler_id)
                JsValue.Object(id: next_promise_id)

    me _native_promise_finally(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_finally = -1
        if arg_vals.len() > 0:
            on_finally = _get_fn_id(arg_vals.get(0))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(on_finally, on_finally, next_promise_id, "finally")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._enqueue_promise_task(promise_id, handler_id)
                JsValue.Object(id: next_promise_id)

    me _native_promise_resolve(arg_vals: [JsValue]) -> JsValue:
        val value = if arg_vals.len() > 0: arg_vals.get(0) else: JsValue.Undefined
        JsValue.Object(id: self._create_settled_promise_object(value, false))

    me _native_promise_reject(arg_vals: [JsValue]) -> JsValue:
        val value = if arg_vals.len() > 0: arg_vals.get(0) else: JsValue.Undefined
        JsValue.Object(id: self._create_settled_promise_object(value, true))

    me _native_response_text(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        match self.get_object_property(response_id, "body"):
            JsValue.String(v): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: v), false))
            _: JsValue.Undefined

    me _native_response_json(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        match self.get_object_property(response_id, "body"):
            JsValue.String(v):
                match self._json_parse_allocated(v, self.global_env):
                    Ok(value): JsValue.Object(id: self._create_settled_promise_object(value, false))
                    Err(e): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: e.message), true))
            _: JsValue.Undefined

    me _native_response_blob(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        var body = ""
        match self.get_object_property(response_id, "body"):
            JsValue.String(v): body = v
            _: pass_dn
        var blob_type = self._response_content_type(response_id)
        if blob_type == "":
            blob_type = "application/octet-stream"
        val blob_id = self.create_object()
        self.set_object_property(blob_id, "__simple_blob_host", JsValue.Boolean(v: true))
        self.set_object_property(blob_id, "size", JsValue.Number(v: body.len().to_f64()))
        self.set_object_property(blob_id, "type", JsValue.String(v: blob_type))
        self.set_object_property(blob_id, "__body__", JsValue.String(v: body))
        self._define_method_on(blob_id, "text", NATIVE_BLOB_TEXT)
        JsValue.Object(id: self._create_settled_promise_object(JsValue.Object(id: blob_id), false))

    me _native_blob_text(this_val: JsValue) -> JsValue:
        val blob_id = _get_obj_id(this_val)
        if blob_id < 0:
            return JsValue.Undefined
        match self.get_object_property(blob_id, "__body__"):
            JsValue.String(v): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: v), false))
            _: JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: ""), false))

    fn _response_content_type(response_id: i64) -> text:
        match self.get_object_property(response_id, "headersText"):
            JsValue.String(headers):
                for line in headers.split("\n"):
                    val trimmed = line.trim()
                    if trimmed.lower().starts_with("content-type:"):
                        return trimmed.slice(13, trimmed.len()).trim()
            _: pass_dn
        ""

    fn _json_parse_allocated(source: text, env: i64) -> BrowserResult<JsValue>:
        val valid = json_parse(source)
        match valid:
            Err(e): return Err(e)
            Ok(_): pass_dn
        var parser = JsParser.create(source, self.logger)
        val expr = parser.parse_assignment()?
        self.eval_expression(expr, env)

    fn _storage_api_property(key: text) -> bool:
        key == "__proto__" or
        key == "getItem" or
        key == "setItem" or
        key == "removeItem" or
        key == "clear" or
        key == "key" or
        key == "length"

    fn _storage_keys(storage_id: i64) -> [text]:
        val obj = self.object_store.get_object(storage_id)
        var keys: [text] = []
        for prop in obj.properties:
            if not self._storage_api_property(prop.key):
                keys.push(prop.key)
        keys

    fn _sync_storage_length(storage_id: i64):
        val keys = self._storage_keys(storage_id)
        self.set_object_property(storage_id, "length", JsValue.Number(v: keys.len().to_f64()))

    fn _native_storage_get_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        val stored = self.get_object_property(storage_id, key)
        if val JsValue.Undefined = stored:
            return JsValue.Null
        if val JsValue.String(v) = stored:
            return JsValue.String(v: v)
        JsValue.String(v: js_to_string(stored))

    fn _native_storage_set_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        val value = if arg_vals.len() > 1: js_to_string(arg_vals.get(1)) else: ""
        self.set_object_property(storage_id, key, JsValue.String(v: value))
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    fn _native_storage_remove_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        self.object_store.remove_property(storage_id, key)
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    fn _native_storage_clear(this_val: JsValue) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        for key in self._storage_keys(storage_id):
            self.object_store.remove_property(storage_id, key)
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    fn _native_storage_key(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val idx = if arg_vals.len() > 0: f64_to_i64(to_number(arg_vals.get(0))) else: -1
        val keys = self._storage_keys(storage_id)
        if idx < 0 or idx >= keys.len():
            return JsValue.Null
        JsValue.String(v: keys.get(idx))

    # ── String method dispatch ───────────────────────────────────────────
    me _dispatch_string_method(str_val: text, method: text, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        if method == "indexOf":
            if args.len() > 0:
                val search = self.eval_expression(args.get(0), env)?
                val search_str = js_to_string(search)
                val slen = str_val.len()
                val needle_len = search_str.len()
                if needle_len == 0:
                    return Ok(JsValue.Number(v: 0.0))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_str[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        return Ok(JsValue.Number(v: i.to_f64()))
                    i = i + 1
            return Ok(JsValue.Number(v: -1.0))

        if method == "lastIndexOf":
            if args.len() > 0:
                val search = self.eval_expression(args.get(0), env)?
                val search_str = js_to_string(search)
                val slen = str_val.len()
                val needle_len = search_str.len()
                if needle_len == 0:
                    return Ok(JsValue.Number(v: slen.to_f64()))
                var last_found = -1
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_str[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        last_found = i
                    i = i + 1
                return Ok(JsValue.Number(v: last_found.to_f64()))
            return Ok(JsValue.Number(v: -1.0))

        if method == "toLowerCase":
            var result = ""
            val upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            val lower = "abcdefghijklmnopqrstuvwxyz"
            var i = 0
            val slen = str_val.len()
            while i < slen:
                val ch = str_val[i]
                var found = -1
                var j = 0
                while j < 26:
                    if upper[j] == ch:
                        found = j
                        j = 26
                    j = j + 1
                if found >= 0:
                    result = result + lower[found]
                else:
                    result = result + ch
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "toUpperCase":
            var result = ""
            val upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            val lower = "abcdefghijklmnopqrstuvwxyz"
            var i = 0
            val slen = str_val.len()
            while i < slen:
                val ch = str_val[i]
                var found = -1
                var j = 0
                while j < 26:
                    if lower[j] == ch:
                        found = j
                        j = 26
                    j = j + 1
                if found >= 0:
                    result = result + upper[found]
                else:
                    result = result + ch
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trim":
            var start = 0
            var end = str_val.len()
            while start < end and (str_val[start] == " " or str_val[start] == "\t" or str_val[start] == "\n"):
                start = start + 1
            while end > start and (str_val[end - 1] == " " or str_val[end - 1] == "\t" or str_val[end - 1] == "\n"):
                end = end - 1
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trimStart":
            var start = 0
            val end = str_val.len()
            while start < end and (str_val[start] == " " or str_val[start] == "\t" or str_val[start] == "\n"):
                start = start + 1
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trimEnd":
            var end = str_val.len()
            while end > 0 and (str_val[end - 1] == " " or str_val[end - 1] == "\t" or str_val[end - 1] == "\n"):
                end = end - 1
            var result = ""
            var i = 0
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "split":
            var sep = ""
            if args.len() > 0:
                val sep_val = self.eval_expression(args.get(0), env)?
                sep = js_to_string(sep_val)
            val result_id = self.create_object()
            if sep == "":
                # Split each character
                var i = 0
                val slen = str_val.len()
                while i < slen:
                    self.set_object_property(result_id, "{i}", JsValue.String(v: str_val[i]))
                    i = i + 1
                self.set_object_property(result_id, "length", JsValue.Number(v: slen.to_f64()))
            else:
                # Split by separator
                var parts = 0
                var start = 0
                val slen = str_val.len()
                val sep_len = sep.len()
                var i = 0
                while i <= slen - sep_len:
                    var matched = true
                    var j = 0
                    while j < sep_len:
                        if str_val[i + j] != sep[j]:
                            matched = false
                            j = sep_len
                        j = j + 1
                    if matched:
                        var part = ""
                        var pi = start
                        while pi < i:
                            part = part + str_val[pi]
                            pi = pi + 1
                        self.set_object_property(result_id, "{parts}", JsValue.String(v: part))
                        parts = parts + 1
                        start = i + sep_len
                        i = start
                    else:
                        i = i + 1
                # Last part
                var last = ""
                var li = start
                while li < slen:
                    last = last + str_val[li]
                    li = li + 1
                self.set_object_property(result_id, "{parts}", JsValue.String(v: last))
                parts = parts + 1
                self.set_object_property(result_id, "length", JsValue.Number(v: parts.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "slice" or method == "substring":
            var start = 0
            var end = str_val.len()
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = str_val.len() + start
                    if start < 0:
                        start = 0
            if args.len() > 1:
                val e = self.eval_expression(args.get(1), env)?
                end = f64_to_i64(to_number(e))
                if end < 0:
                    end = str_val.len() + end
            if end > str_val.len():
                end = str_val.len()
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "charAt":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                val idx = f64_to_i64(to_number(idx_val))
                if idx >= 0 and idx < str_val.len():
                    return Ok(JsValue.String(v: str_val[idx]))
            return Ok(JsValue.String(v: ""))

        if method == "charCodeAt":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                val idx = f64_to_i64(to_number(idx_val))
                if idx >= 0 and idx < str_val.len():
                    val ch = str_val[idx]
                    return Ok(JsValue.Number(v: ch.char_code_at(0).to_f64()))
            return Ok(JsValue.Number(v: js_nan()))

        if method == "startsWith":
            if args.len() > 0:
                val prefix_val = self.eval_expression(args.get(0), env)?
                val prefix = js_to_string(prefix_val)
                if prefix.len() > str_val.len():
                    return Ok(JsValue.Boolean(v: false))
                var i = 0
                var matched = true
                while i < prefix.len():
                    if str_val[i] != prefix[i]:
                        matched = false
                        i = prefix.len()
                    i = i + 1
                return Ok(JsValue.Boolean(v: matched))
            return Ok(JsValue.Boolean(v: true))

        if method == "endsWith":
            if args.len() > 0:
                val suffix_val = self.eval_expression(args.get(0), env)?
                val suffix = js_to_string(suffix_val)
                if suffix.len() > str_val.len():
                    return Ok(JsValue.Boolean(v: false))
                val offset = str_val.len() - suffix.len()
                var i = 0
                var matched = true
                while i < suffix.len():
                    if str_val[offset + i] != suffix[i]:
                        matched = false
                        i = suffix.len()
                    i = i + 1
                return Ok(JsValue.Boolean(v: matched))
            return Ok(JsValue.Boolean(v: true))

        if method == "includes":
            if args.len() > 0:
                val search_val = self.eval_expression(args.get(0), env)?
                val search_s = js_to_string(search_val)
                val slen = str_val.len()
                val needle_len = search_s.len()
                if needle_len == 0:
                    return Ok(JsValue.Boolean(v: true))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_s[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        return Ok(JsValue.Boolean(v: true))
                    i = i + 1
            return Ok(JsValue.Boolean(v: false))

        if method == "replace":
            if args.len() >= 2:
                val search_val = self.eval_expression(args.get(0), env)?
                val replace_val = self.eval_expression(args.get(1), env)?
                val search_s = js_to_string(search_val)
                val replace_str = js_to_string(replace_val)
                val slen = str_val.len()
                val needle_len = search_s.len()
                if needle_len == 0:
                    return Ok(JsValue.String(v: replace_str + str_val))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_s[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        var result = ""
                        var bi = 0
                        while bi < i:
                            result = result + str_val[bi]
                            bi = bi + 1
                        result = result + replace_str
                        var ai = i + needle_len
                        while ai < slen:
                            result = result + str_val[ai]
                            ai = ai + 1
                        return Ok(JsValue.String(v: result))
                    i = i + 1
            return Ok(JsValue.String(v: str_val))

        if method == "replaceAll":
            if args.len() >= 2:
                val search_val = self.eval_expression(args.get(0), env)?
                val replace_val = self.eval_expression(args.get(1), env)?
                val search = js_to_string(search_val)
                val replace_str = js_to_string(replace_val)
                val slen = str_val.len()
                val needle_len = search.len()
                if needle_len == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = ""
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        result = result + replace_str
                        i = i + needle_len
                    else:
                        result = result + str_val[i]
                        i = i + 1
                while i < slen:
                    result = result + str_val[i]
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "repeat":
            if args.len() > 0:
                val count_val = self.eval_expression(args.get(0), env)?
                val count = f64_to_i64(to_number(count_val))
                var result = ""
                var i = 0
                while i < count:
                    result = result + str_val
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: ""))

        if method == "padStart":
            if args.len() > 0:
                val target_len_val = self.eval_expression(args.get(0), env)?
                val target_len = f64_to_i64(to_number(target_len_val))
                var pad_str = " "
                if args.len() > 1:
                    val ps = self.eval_expression(args.get(1), env)?
                    pad_str = js_to_string(ps)
                if pad_str.len() == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = ""
                val needed = target_len - str_val.len()
                var i = 0
                while i < needed:
                    result = result + pad_str[i % pad_str.len()]
                    i = i + 1
                result = result + str_val
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "padEnd":
            if args.len() > 0:
                val target_len_val = self.eval_expression(args.get(0), env)?
                val target_len = f64_to_i64(to_number(target_len_val))
                var pad_str = " "
                if args.len() > 1:
                    val ps = self.eval_expression(args.get(1), env)?
                    pad_str = js_to_string(ps)
                if pad_str.len() == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = str_val
                val needed = target_len - str_val.len()
                var i = 0
                while i < needed:
                    result = result + pad_str[i % pad_str.len()]
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "concat":
            var result = str_val
            var i = 0
            while i < args.len():
                val arg_val = self.eval_expression(args.get(i), env)?
                result = result + js_to_string(arg_val)
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "at":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                var idx = f64_to_i64(to_number(idx_val))
                if idx < 0:
                    idx = str_val.len() + idx
                if idx >= 0 and idx < str_val.len():
                    return Ok(JsValue.String(v: str_val[idx]))
            return Ok(JsValue.Undefined)

        self.logger.warn("Unknown string method: {method}")
        Ok(JsValue.Undefined)

    # Invoke a JS function by id with the given argument values
    me _invoke_function(fn_id: i64, arg_vals: [JsValue], env: i64) -> BrowserResult<JsValue>:
        if fn_id < 0 or fn_id >= self.functions.len():
            return Ok(JsValue.Undefined)
        val js_fn = self.functions.get(fn_id)
        val params = js_fn.params
        val fn_env = self.env_stack.create_env(js_fn.closure_env)
        var pi = 0
        while pi < params.len():
            var pv = JsValue.Undefined
            if pi < arg_vals.len():
                pv = arg_vals.get(pi)
            self.env_stack.define_var(fn_env, params.get(pi), pv)
            pi = pi + 1
        self.env_stack.define_var(fn_env, "this", JsValue.Undefined)
        val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: JsValue.Undefined)
        self.call_stack.push(frame)
        val saved = self.control_return
        self.control_return = false
        var result = JsValue.Undefined
        var bi = 0
        while bi < js_fn.body.len():
            result = self.exec_statement(js_fn.body.get(bi), fn_env)?
            if self.control_return:
                result = self.return_value
                break
            bi = bi + 1
        self.call_stack.pop()
        self.control_return = saved
        Ok(result)
