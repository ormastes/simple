# JsInterpreter — statement execution methods (execute, exec_*).

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.types.ast_types.JsExpression
use std.js.types.ast_types.JsStatement
use std.js.types.ast_types.SwitchCase
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm.{ObjectStore}
use std.nogc_sync_mut.js.engine.interpreter.{JsInterpreter}

impl JsInterpreter:
    # Execute a full program (list of statements)
    me execute(program: [JsStatement]) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var i = 0
        val len = program.len()
        while i < len:
            val stmt = program.get(i)
            result = self.exec_statement(stmt, self.global_env)?
            if self.control_return:
                break
            i = i + 1
        Ok(result)

    # Dispatch a statement
    me exec_statement(stmt: JsStatement, env: i64) -> BrowserResult<JsValue>:
        match stmt:
            JsStatement.VarDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.ExprStmt(expr):
                return self.eval_expression(expr, env)
            JsStatement.Return(value):
                return self.exec_return(value, env)
            JsStatement.If(cond, then_body, else_body):
                return self.exec_if(cond, then_body, else_body, env)
            JsStatement.While(cond, body):
                return self.exec_while(cond, body, env)
            JsStatement.For(init, cond, update, body):
                return self.exec_for(init, cond, update, body, env)
            JsStatement.Block(stmts):
                val block_env = self.env_stack.create_env(env)
                var result = JsValue.Undefined
                var idx = 0
                val slen = stmts.len()
                while idx < slen:
                    result = self.exec_statement(stmts.get(idx), block_env)?
                    if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                        break
                    idx = idx + 1
                return Ok(result)
            JsStatement.FnDecl(name, params, body):
                return self.exec_function_decl(name, params, body, env)
            JsStatement.TryCatch(try_body, catch_param, catch_body, finally_body):
                return self.exec_try_catch(try_body, catch_param, catch_body, finally_body, env)
            JsStatement.Switch(discriminant, cases):
                return self.exec_switch(discriminant, cases, env)
            JsStatement.ForIn(binding, object, body):
                return self.exec_for_in(binding, object, body, env)
            JsStatement.ForOf(binding, iterable, body):
                return self.exec_for_of(binding, iterable, body, env)
            JsStatement.ThrowStmt(expr):
                return self.exec_throw(expr, env)
            JsStatement.BreakStmt:
                self.control_break = true
                return Ok(JsValue.Undefined)
            JsStatement.ContinueStmt:
                self.control_continue = true
                return Ok(JsValue.Undefined)
            JsStatement.ClassDecl(name, parent_name, constructor, methods):
                return self.exec_class_decl(name, parent_name, constructor, methods, env)
            JsStatement.LetDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.ConstDecl(name, init):
                return self.exec_var_decl(name, init, env)
            JsStatement.DestructVarDecl(pattern, init, kind):
                return self.exec_destruct_decl(pattern, init, env)
            JsStatement.DoWhile(cond, body):
                return self.exec_do_while(cond, body, env)
            JsStatement.LabeledStmt(label, body):
                return self.exec_statement(body, env)

    # Variable declaration
    me exec_var_decl(name: text, init: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(init, env)?
        self.env_stack.define_var(env, name, value)
        Ok(value)

    # Destructuring declaration: const {a, b} = obj; const [x, y] = arr
    me exec_destruct_decl(pattern: JsExpression, init: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(init, env)?
        self._bind_pattern(pattern, value, env)
        Ok(value)

    me _bind_pattern(pattern: JsExpression, value: JsValue, env: i64):
        match pattern:
            JsExpression.ObjectPattern(props):
                match value:
                    JsValue.Object(id):
                        var i = 0
                        while i < props.len():
                            val dp = props.get(i)
                            val bound_val = self.get_object_property(id, dp.key)
                            match dp.value:
                                JsExpression.Identifier(name):
                                    self.env_stack.define_var(env, name, bound_val)
                                _: pass_dn
                            i = i + 1
                    _: pass_dn
            JsExpression.ArrayPattern(elements):
                match value:
                    JsValue.Array(id):
                        var i = 0
                        while i < elements.len():
                            val elem = elements.get(i)
                            match elem:
                                JsExpression.SpreadElement(arg):
                                    match arg:
                                        JsExpression.Identifier(name):
                                            var rest: [JsValue] = []
                                            val arr_len = self.object_store.array_length(id)
                                            var ri = i
                                            while ri < arr_len:
                                                rest.push(self.object_store.get_by_index(id, ri))
                                                ri = ri + 1
                                            val rest_id = self.object_store.create_array_from(rest)
                                            self.env_stack.define_var(env, name, JsValue.Array(id: rest_id))
                                        _: pass_dn
                                JsExpression.Identifier(name):
                                    val elem_val = self.object_store.get_by_index(id, i)
                                    self.env_stack.define_var(env, name, elem_val)
                                _: pass_dn
                            i = i + 1
                    _: pass_dn
            _: pass_dn

    # Do-while loop
    me exec_do_while(cond: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var cont = true
        var should_exit = false
        while cont:
            val loop_env = self.env_stack.create_env(env)
            var bi = 0
            while bi < body.len():
                result = self.exec_statement(body.get(bi), loop_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                bi = bi + 1
            if should_exit:
                break
            val cond_val = self.eval_expression(cond, env)?
            cont = is_truthy(cond_val)
        Ok(result)

    # If / else
    me exec_if(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val cond_val = self.eval_expression(cond, env)?
        var result = JsValue.Undefined
        if is_truthy(cond_val):
            val then_env = self.env_stack.create_env(env)
            var i = 0
            val len = then_body.len()
            while i < len:
                result = self.exec_statement(then_body.get(i), then_env)?
                if self.control_return:
                    break
                i = i + 1
        else:
            if else_body.len() > 0:
                val else_env = self.env_stack.create_env(env)
                var i = 0
                val len = else_body.len()
                while i < len:
                    result = self.exec_statement(else_body.get(i), else_env)?
                    if self.control_return:
                        break
                    i = i + 1
        Ok(result)

    # While loop
    me exec_while(cond: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        var result = JsValue.Undefined
        var iteration = 0
        val max_iterations = 100000
        var should_exit = false
        while iteration < max_iterations:
            val cond_val = self.eval_expression(cond, env)?
            if not is_truthy(cond_val):
                break
            val loop_env = self.env_stack.create_env(env)
            var i = 0
            val len = body.len()
            while i < len:
                result = self.exec_statement(body.get(i), loop_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                i = i + 1
            if should_exit:
                break
            iteration = iteration + 1
        if iteration >= max_iterations:
            self.logger.warn("While loop exceeded maximum iterations")
        Ok(result)

    # For loop
    # Note: var declarations in init execute in parent env (JS var is function-scoped)
    me exec_for(init: JsStatement, cond: JsExpression, update: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        self.exec_statement(init, env)?
        val for_env = self.env_stack.create_env(env)

        var result = JsValue.Undefined
        var iteration = 0
        val max_iterations = 100000
        var should_exit = false
        while iteration < max_iterations:
            val cond_val = self.eval_expression(cond, for_env)?
            if not is_truthy(cond_val):
                break
            val iter_env = self.env_stack.create_env(for_env)
            var i = 0
            val len = body.len()
            while i < len:
                result = self.exec_statement(body.get(i), iter_env)?
                if self.control_return or self.control_thrown:
                    should_exit = true
                    break
                if self.control_break:
                    self.control_break = false
                    should_exit = true
                    break
                if self.control_continue:
                    self.control_continue = false
                    break
                i = i + 1
            if should_exit:
                break
            self.eval_expression(update, for_env)?
            iteration = iteration + 1
        if iteration >= max_iterations:
            self.logger.warn("For loop exceeded maximum iterations")
        Ok(result)

    # Return statement
    me exec_return(value: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val result = self.eval_expression(value, env)?
        self.return_value = result
        self.control_return = true
        Ok(result)

    # Function declaration — store in function registry
    me exec_function_decl(name: text, params: [text], body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val fn_id = self.functions.len()
        val js_fn = JsFunction.create(name, params, body, env)
        self.functions.push(js_fn)
        val fn_val = JsValue.Function(id: fn_id)
        self.env_stack.define_var(env, name, fn_val)
        Ok(fn_val)

    # Try/catch/finally
    me exec_try_catch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val try_env = self.env_stack.create_env(env)
        var result = JsValue.Undefined

        # Execute try body
        var i = 0
        val tlen = try_body.len()
        while i < tlen:
            result = self.exec_statement(try_body.get(i), try_env)?
            if self.control_return or self.control_break or self.control_continue:
                break
            if self.control_thrown:
                break
            i = i + 1

        # If exception was thrown, execute catch body
        if self.control_thrown and catch_body.len() > 0:
            self.control_thrown = false
            val caught_value = self.thrown_value
            self.thrown_value = JsValue.Undefined
            val catch_env = self.env_stack.create_env(env)
            if catch_param != "":
                self.env_stack.define_var(catch_env, catch_param, caught_value)
            var ci = 0
            val clen = catch_body.len()
            while ci < clen:
                result = self.exec_statement(catch_body.get(ci), catch_env)?
                if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                    break
                ci = ci + 1

        # Always execute finally body
        if finally_body.len() > 0:
            val finally_env = self.env_stack.create_env(env)
            var fi = 0
            val flen = finally_body.len()
            while fi < flen:
                self.exec_statement(finally_body.get(fi), finally_env)?
                if self.control_return or self.control_break or self.control_continue or self.control_thrown:
                    break
                fi = fi + 1

        Ok(result)

    # Switch statement
    me exec_switch(discriminant: JsExpression, cases: [SwitchCase], env: i64) -> BrowserResult<JsValue>:
        val disc_val = self.eval_expression(discriminant, env)?
        var result = JsValue.Undefined
        var matched = false
        var should_exit = false
        var ci = 0
        val case_count = cases.len()
        while ci < case_count:
            val sc = cases.get(ci)
            if not matched:
                if val Some(test) = sc.test:
                    val test_val = self.eval_expression(test, env)?
                    if strict_equals(disc_val, test_val):
                        matched = true
                else:
                    # default clause
                    matched = true
            if matched:
                val case_env = self.env_stack.create_env(env)
                var si = 0
                val slen = sc.consequent.len()
                while si < slen:
                    val stmt_result = self.exec_statement(sc.consequent.get(si), case_env)?
                    if self.control_break:
                        self.control_break = false
                        should_exit = true
                        break
                    result = stmt_result
                    if self.control_return or self.control_thrown:
                        should_exit = true
                        break
                    if self.control_continue:
                        should_exit = true
                        break
                    si = si + 1
                if should_exit:
                    break
            ci = ci + 1
            if should_exit:
                break
        Ok(result)

    # For-in loop: iterate object keys
    me exec_for_in(binding: text, object: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val obj_val = self.eval_expression(object, env)?
        var result = JsValue.Undefined
        var should_exit = false
        match obj_val:
            JsValue.Object(id):
                val obj = self.object_store.get_object(id)
                var i = 0
                val len = obj.properties.len()
                while i < len:
                    val prop = obj.properties.get(i)
                    if prop.enumerable:
                        val iter_env = self.env_stack.create_env(env)
                        self.env_stack.define_var(iter_env, binding, JsValue.String(v: prop.key))
                        var bi = 0
                        val blen = body.len()
                        while bi < blen:
                            result = self.exec_statement(body.get(bi), iter_env)?
                            if self.control_return or self.control_thrown:
                                should_exit = true
                                break
                            if self.control_break:
                                self.control_break = false
                                should_exit = true
                                break
                            if self.control_continue:
                                self.control_continue = false
                                break
                            bi = bi + 1
                        if should_exit:
                            break
                    i = i + 1
                    if should_exit:
                        break
            _:
                self.logger.warn("for...in requires an object")
        Ok(result)

    # For-of loop: iterate array elements
    me exec_for_of(binding: text, iterable: JsExpression, body: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        val iter_val = self.eval_expression(iterable, env)?
        var result = JsValue.Undefined
        var should_exit = false
        match iter_val:
            JsValue.Array(id):
                val arr_len = self.object_store.array_length(id)
                var i = 0
                while i < arr_len:
                    val elem_val = self.object_store.get_by_index(id, i)
                    val iter_env = self.env_stack.create_env(env)
                    self.env_stack.define_var(iter_env, binding, elem_val)
                    var bi = 0
                    val blen = body.len()
                    while bi < blen:
                        result = self.exec_statement(body.get(bi), iter_env)?
                        if self.control_return or self.control_thrown:
                            should_exit = true
                            break
                        if self.control_break:
                            self.control_break = false
                            should_exit = true
                            break
                        if self.control_continue:
                            self.control_continue = false
                            break
                        bi = bi + 1
                    if should_exit:
                        break
                    i = i + 1
                    if should_exit:
                        break
            _:
                self.logger.warn("for...of requires an iterable")
        Ok(result)

    # Throw statement
    me exec_throw(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        val value = self.eval_expression(expr, env)?
        self.thrown_value = value
        self.control_thrown = true
        Ok(value)

    # Class declaration — register constructor and methods as functions on a prototype object
    me exec_class_decl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement], env: i64) -> BrowserResult<JsValue>:
        # Create the prototype object
        val proto_id = self.create_object()

        # Set up prototype chain for extends
        if parent_name != "":
            val parent_val = self.env_stack.get_var(env, parent_name)
            if val Some(parent_fn) = parent_val:
                val parent_fn_id = _get_fn_id(parent_fn)
                if parent_fn_id >= 0:
                    val parent_proto = self._find_class_proto(parent_fn_id)
                    if parent_proto >= 0:
                        self.set_object_property(proto_id, "__proto__", JsValue.Object(id: parent_proto))

        # Register methods on the prototype
        var mi = 0
        val mlen = methods.len()
        while mi < mlen:
            val method = methods.get(mi)
            match method:
                JsStatement.FnDecl(mname, mparams, mbody):
                    val fn_id = self.functions.len()
                    val js_fn = JsFunction.create(mname, mparams, mbody, env)
                    self.functions.push(js_fn)
                    self.set_object_property(proto_id, mname, JsValue.Function(id: fn_id))
                _: pass_dn
            mi = mi + 1

        # Register constructor as the class function
        match constructor:
            JsStatement.FnDecl(cname, cparams, cbody):
                val ctor_id = self.functions.len()
                val ctor_fn = JsFunction.create(name, cparams, cbody, env)
                self.functions.push(ctor_fn)
                # Track constructor → prototype mapping for new operator
                self.class_proto_fns.push(ctor_id)
                self.class_proto_ids.push(proto_id)
                val class_val = JsValue.Function(id: ctor_id)
                self.env_stack.define_var(env, name, class_val)
                return Ok(class_val)
            _: pass_dn
        Ok(JsValue.Undefined)
