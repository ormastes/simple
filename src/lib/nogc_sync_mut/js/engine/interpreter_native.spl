                var body_module_ids = self.wasm_export_body_module_ids
                var body_indices = self.wasm_export_body_indices
                body_fn_ids.push(fn_id)
                body_module_ids.push(module_id)
                body_indices.push(index)
                self.wasm_export_body_fn_ids = body_fn_ids
                self.wasm_export_body_module_ids = body_module_ids
                self.wasm_export_body_indices = body_indices
