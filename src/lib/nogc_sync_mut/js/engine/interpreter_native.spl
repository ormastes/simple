                        break
                    _:
                        val statement_result = self.exec_statement(stmt, import_env)
                        match statement_result:
                            Ok(v):
                                result = v
                            Err(e):
                                self.call_stack.pop()
                                self.control_return = saved_return
                                return JsValue.String(v: e.message)
                if self.control_return:
                    result = self.return_value
                    break
                bi = bi + 1
            self.call_stack.pop()
            self.control_return = saved_return
            return result
        if lookup_fn_id >= 0:
