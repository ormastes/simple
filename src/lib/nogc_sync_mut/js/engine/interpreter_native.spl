        if self.node_require_last_cache_key == cache_key:
            return self.node_require_last_cache_value
        var i = self.node_require_cache_names.len() - 1
        while i >= 0:
            if self.node_require_cache_names.get(i) == cache_key:
                val cached_value = self.node_require_cache_values.get(i)
                self.node_require_last_cache_key = cache_key
                self.node_require_last_cache_value = cached_value
                return cached_value
            i = i - 1
        if canonical == "":
            val module_cache_key = "module:" + specifier
            if self.node_require_last_cache_key == module_cache_key:
                return self.node_require_last_cache_value
            i = self.node_require_cache_names.len() - 1
            while i >= 0:
                if self.node_require_cache_names.get(i) == module_cache_key:
                    val cached_value = self.node_require_cache_values.get(i)
                    self.node_require_last_cache_key = module_cache_key
                    self.node_require_last_cache_value = cached_value
                    return cached_value
                i = i - 1
