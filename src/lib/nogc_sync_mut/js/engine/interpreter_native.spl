                self.env_stack.define_var(import_env, import_fn.params.get(pi), pv)
                pi = pi + 1
            self.env_stack.define_var(import_env, "this", JsValue.Undefined)
            val frame = CallFrame(function_name: import_fn.name, env_id: import_env, line: 0, this_value: JsValue.Undefined)
            self.call_stack.push(frame)
            val saved_return = self.control_return
            self.control_return = false
            var result = JsValue.Undefined
            var bi = 0
            while bi < import_fn.body.len():
                val stmt = import_fn.body.get(bi)
                match stmt:
                    JsStatement.Return(value):
