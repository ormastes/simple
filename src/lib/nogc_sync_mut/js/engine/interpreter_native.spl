    me _native_node_parent_dir(path: text) -> text:
        var last_slash = -1
        var i = 0
        while i < path.len():
            if path.substring(i, i + 1) == "/":
                last_slash = i
            i = i + 1
        if last_slash <= 0:
            return "/"
        path.substring(0, last_slash)

    me _native_node_basename(path: text) -> text:
        var last_slash = -1
        var i = 0
        while i < path.len():
            if path.substring(i, i + 1) == "/":
                last_slash = i
            i = i + 1
        if last_slash < 0:
            return path
        if last_slash + 1 >= path.len():
            return ""
        path.substring(last_slash + 1, path.len())

    me _native_node_dir_key(prefix: text, path: text) -> text:
        var key = prefix
        var i = 0
        while i < path.len():
            val ch = path.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
            else:
                key = key + "_"
            i = i + 1
        key

