        var index = 0
        while index < global_count:
            if self._native_webassembly_global_i32_mutability_at(hex, index) == 1:
                return true
            index = index + 1
        false

    me _native_webassembly_memory(arg_vals: [JsValue]) -> JsValue:
        var initial = 0
        var maximum = -1
        if arg_vals.len() > 0:
            val options_id = _get_obj_id(arg_vals[0])
            if options_id >= 0:
                match self.get_object_property(options_id, "initial"):
                    JsValue.Number(v): initial = f64_to_i64(v)
                    _: pass_dn
                match self.get_object_property(options_id, "maximum"):
                    JsValue.Number(v): maximum = f64_to_i64(v)
                    _: pass_dn
        self._native_webassembly_memory_from_pages(initial, maximum)

    me _native_webassembly_memory_from_pages(initial: i64, maximum: i64) -> JsValue:
        var pages = initial
        if pages < 0:
            pages = 0
        val memory_id = self.create_object()
        val buffer_id = self.create_object()
        val byte_length = pages * 65536
        self.set_object_property(buffer_id, "__simple_array_buffer", JsValue.Boolean(v: true))
        self.set_object_property(buffer_id, "byteLength", JsValue.Number(v: byte_length.to_f64()))
        self.set_object_property(memory_id, "__simple_wasm_memory", JsValue.Boolean(v: true))
        self.set_object_property(memory_id, "initial", JsValue.Number(v: pages.to_f64()))
        self.set_object_property(memory_id, "pages", JsValue.Number(v: pages.to_f64()))
        if maximum >= 0:
            self.set_object_property(memory_id, "maximum", JsValue.Number(v: maximum.to_f64()))
        else:
            self.set_object_property(memory_id, "maximum", JsValue.Undefined)
        self.set_object_property(memory_id, "byteLength", JsValue.Number(v: byte_length.to_f64()))
        self.set_object_property(memory_id, "pageSize", JsValue.Number(v: 65536.0))
        self.set_object_property(memory_id, "buffer", JsValue.Object(id: buffer_id))
        self._define_method_on(memory_id, "grow", NATIVE_WEBASSEMBLY_MEMORY_GROW)
        JsValue.Object(id: memory_id)

    me _native_webassembly_memory_grow(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val memory_id = _get_obj_id(this_val)
        if memory_id < 0:
            return JsValue.Number(v: -1.0)
        var delta = 0
        if arg_vals.len() > 0:
            delta = f64_to_i64(to_number(arg_vals[0]))
        if delta < 0:
            return JsValue.Number(v: -1.0)
        var pages = 0
        var maximum = -1
        match self.get_object_property(memory_id, "pages"):
            JsValue.Number(v): pages = f64_to_i64(v)
            _: pass_dn
        match self.get_object_property(memory_id, "maximum"):
            JsValue.Number(v): maximum = f64_to_i64(v)
            _: pass_dn
        val new_pages = pages + delta
        if maximum >= 0 and new_pages > maximum:
            return JsValue.Number(v: -1.0)
        val byte_length = new_pages * 65536
        self.set_object_property(memory_id, "pages", JsValue.Number(v: new_pages.to_f64()))
        self.set_object_property(memory_id, "byteLength", JsValue.Number(v: byte_length.to_f64()))
        match self.get_object_property(memory_id, "buffer"):
            JsValue.Object(buffer_id):
                self.set_object_property(buffer_id, "byteLength", JsValue.Number(v: byte_length.to_f64()))
            _:
                pass_dn
        JsValue.Number(v: pages.to_f64())

    me _native_webassembly_create_module_object(payload_hex: text) -> i64:
        val has_valid_header = self._native_webassembly_valid_header(payload_hex)
        var sections_valid = false
        if has_valid_header:
            sections_valid = self._native_webassembly_sections_valid(payload_hex)
        var validated = false
        if has_valid_header and sections_valid:
            validated = true
        val module_id = self.create_object()
        self.set_object_property(module_id, "__simple_wasm_module", JsValue.Boolean(v: validated))
        self.set_object_property(module_id, "target", JsValue.String(v: "wasm32"))
        self.set_object_property(module_id, "validated", JsValue.Boolean(v: validated))
        self.set_object_property(module_id, "byteLength", JsValue.Number(v: ((payload_hex.len() / 2) as f64)))
        self._native_webassembly_attach_section_metadata(module_id, payload_hex, validated)
        if not validated:
            if has_valid_header:
                self.set_object_property(module_id, "error", JsValue.String(v: "invalid-wasm-section"))
            else:
                self.set_object_property(module_id, "error", JsValue.String(v: "invalid-wasm-header"))
        module_id

    me _native_webassembly_payload_hex(arg_vals: [JsValue]) -> text:
        if arg_vals.len() == 0:
            return ""
        match arg_vals[0]:
            JsValue.String(v): self._native_webassembly_normalize_hex(v)
            JsValue.Array(id): self._native_webassembly_payload_hex_from_indexed(id)
            JsValue.Object(id): self._native_webassembly_payload_hex_from_indexed(id)
            _: ""

    me _native_webassembly_payload_hex_from_indexed(obj_id: i64) -> text:
        var length = self.object_store.array_length(obj_id)
        match self.get_object_property(obj_id, "byteLength"):
            JsValue.Number(v):
                length = f64_to_i64(v)
            _:
                match self.get_object_property(obj_id, "length"):
                    JsValue.Number(v2):
                        length = f64_to_i64(v2)
                    _:
                        pass_dn
        if length <= 0:
            return ""
        var out = ""
        var i = 0
        while i < length:
            val item = self.get_object_property(obj_id, "{i}")
            match item:
                JsValue.Number(v):
                    val byte = f64_to_i64(v)
                    if byte < 0 or byte > 255:
                        return ""
                    out = out + self._native_webassembly_byte_to_hex(byte)
                _:
                    return ""
            i = i + 1
        out

    me _native_webassembly_byte_to_hex(byte: i64) -> text:
        self._native_webassembly_nibble_to_hex(byte / 16) + self._native_webassembly_nibble_to_hex(byte % 16)

    me _native_webassembly_nibble_to_hex(n: i64) -> text:
        if n == 0:
            return "0"
        if n == 1:
            return "1"
        if n == 2:
            return "2"
        if n == 3:
            return "3"
        if n == 4:
            return "4"
        if n == 5:
            return "5"
        if n == 6:
            return "6"
        if n == 7:
            return "7"
        if n == 8:
            return "8"
        if n == 9:
            return "9"
        if n == 10:
            return "a"
        if n == 11:
            return "b"
        if n == 12:
            return "c"
        if n == 13:
            return "d"
        if n == 14:
            return "e"
        "f"

    me _native_webassembly_normalize_hex(raw: text) -> text:
        var s = raw.trim().lower()
        if s.starts_with("0x"):
            s = s.substring(2)
        var out = ""
        var i = 0
        while i < s.len():
            val ch = s.substring(i, i + 1)
            if ch == " " or ch == "\n" or ch == "\r" or ch == "\t" or ch == "_":
                i = i + 1
                continue
            if not self._native_webassembly_is_hex_digit(ch):
                return ""
            out = out + ch
            i = i + 1
        out

    me _native_webassembly_is_hex_digit(ch: text) -> bool:
        (ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "f")

    me _native_webassembly_valid_hex_payload(arg_vals: [JsValue]) -> bool:
        val hex = self._native_webassembly_payload_hex(arg_vals)
        if not self._native_webassembly_valid_header(hex):
            return false
        self._native_webassembly_sections_valid(hex)

    me _native_webassembly_valid_header(hex: text) -> bool:
        if hex.len() < 16:
            return false
        if (hex.len() % 2) != 0:
            return false
        if not hex.starts_with("0061736d01000000"):
            return false
        true

    me _native_webassembly_attach_section_metadata(module_id: i64, hex: text, validated: bool):
        self.set_object_property(module_id, "sectionCount", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "hasTypeSection", JsValue.Boolean(v: false))
        self.set_object_property(module_id, "hasImportSection", JsValue.Boolean(v: false))
        self.set_object_property(module_id, "hasMemorySection", JsValue.Boolean(v: false))
        self.set_object_property(module_id, "hasExportSection", JsValue.Boolean(v: false))
        self.set_object_property(module_id, "importCount", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "firstImportModuleName", JsValue.String(v: ""))
        self.set_object_property(module_id, "firstImportFieldName", JsValue.String(v: ""))
        self.set_object_property(module_id, "firstImportKind", JsValue.String(v: ""))
        self.set_object_property(module_id, "memoryMinPages", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "memoryMaxPages", JsValue.Number(v: -1.0))
        self.set_object_property(module_id, "tableMinElements", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "exportCount", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "firstExportName", JsValue.String(v: ""))
        self.set_object_property(module_id, "firstExportKind", JsValue.String(v: ""))
        self.set_object_property(module_id, "memoryExportName", JsValue.String(v: ""))
        self.set_object_property(module_id, "functionExportName", JsValue.String(v: ""))
        self.set_object_property(module_id, "functionExportCount", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "tableExportName", JsValue.String(v: ""))
        self.set_object_property(module_id, "tableExportCount", JsValue.Number(v: 0.0))
        self.set_object_property(module_id, "globalExportName", JsValue.String(v: ""))
        self.set_object_property(module_id, "globalExportCount", JsValue.Number(v: 0.0))
