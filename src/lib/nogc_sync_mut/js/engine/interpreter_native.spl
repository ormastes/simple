    me _native_text_decoder_decode(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        if arg_vals.len() == 0:
            return JsValue.String(v: "")
        JsValue.String(v: self._native_utf8_decode(self._native_indexed_bytes(arg_vals[0])))

    me _native_indexed_bytes(value: JsValue) -> [i64]:
        var out: [i64] = []
        val obj_id = _get_obj_id(value)
        if obj_id < 0:
            return out
        match self.get_object_property(obj_id, "__simple_node_buffer_hex"):
            JsValue.String(hex):
                val buffer = NodeBuffer.from_text(hex, "hex")
                var bi = 0
                while bi < buffer.bytes.len():
                    out.push(buffer.bytes[bi] as i64)
                    bi = bi + 1
                return out
            _:
                pass_dn
        var length = self.object_store.array_length(obj_id)
        match self.get_object_property(obj_id, "byteLength"):
            JsValue.Number(v):
                length = f64_to_i64(v)
            _:
                pass_dn
        var i = 0
        while i < length:
            var byte = 0
            match self.get_object_property(obj_id, "{i}"):
                JsValue.Number(v):
                    byte = f64_to_i64(v)
                _:
                    pass_dn
            byte = byte & 255
            out.push(byte)
            i = i + 1
        out

    me _native_utf8_decode(bytes: [i64]) -> text:
        var out = ""
        var i = 0
        while i < bytes.len():
            val b0 = bytes[i]
            if b0 < 128:
                out = out + b0.chr()
                i = i + 1
            else:
                if b0 >= 194 and b0 < 224 and i + 1 < bytes.len() and self._native_utf8_is_continuation(bytes[i + 1]):
                    val b1 = bytes[i + 1]
                    out = out + (((b0 & 31) << 6) | (b1 & 63)).chr()
                    i = i + 2
                else:
                    if b0 >= 224 and b0 < 240 and i + 2 < bytes.len() and self._native_utf8_is_continuation(bytes[i + 1]) and self._native_utf8_is_continuation(bytes[i + 2]) and self._native_utf8_three_byte_allowed(b0, bytes[i + 1]):
                        val b1 = bytes[i + 1]
                        val b2 = bytes[i + 2]
                        out = out + (((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63)).chr()
                        i = i + 3
                    else:
                        if b0 >= 240 and b0 < 245 and i + 3 < bytes.len() and self._native_utf8_is_continuation(bytes[i + 1]) and self._native_utf8_is_continuation(bytes[i + 2]) and self._native_utf8_is_continuation(bytes[i + 3]) and self._native_utf8_four_byte_allowed(b0, bytes[i + 1]):
                            val b1 = bytes[i + 1]
                            val b2 = bytes[i + 2]
                            val b3 = bytes[i + 3]
                            out = out + (((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63)).chr()
                            i = i + 4
                        else:
                            out = out + 65533.chr()
                            i = i + 1
        out

    me _native_utf8_is_continuation(byte: i64) -> bool:
        byte >= 128 and byte < 192

    me _native_utf8_three_byte_allowed(lead: i64, cont: i64) -> bool:
        if lead == 224:
            return cont >= 160
        if lead == 237:
            return cont < 160
        true

    me _native_utf8_four_byte_allowed(lead: i64, cont: i64) -> bool:
        if lead == 240:
            return cont >= 144
        if lead == 244:
            return cont < 144
        true

    me _native_copy_indexed_bytes(src_id: i64, dst_id: i64, length: i64):
        var i = 0
        while i < length:
            var byte = 0
            match self.get_object_property(src_id, "{i}"):
                JsValue.Number(v):
                    byte = f64_to_i64(v)
                _:
                    byte = 0
            byte = byte & 255
            self.set_object_property(dst_id, "{i}", JsValue.Number(v: byte.to_f64()))
            i = i + 1

    me _native_webassembly_validate(arg_vals: [JsValue]) -> JsValue:
        JsValue.Boolean(v: self._native_webassembly_valid_hex_payload(arg_vals))

    me _native_webassembly_module(arg_vals: [JsValue]) -> JsValue:
        val payload_hex = self._native_webassembly_payload_hex(arg_vals)
        val module_id = self._native_webassembly_create_module_object(payload_hex)
        JsValue.Object(id: module_id)

    me _native_webassembly_compile(arg_vals: [JsValue]) -> JsValue:
        val payload_hex = self._native_webassembly_payload_hex(arg_vals)
        val result_id = self.create_object()
        self._define_method_on(result_id, "then", NATIVE_WEBASSEMBLY_COMPILE_THEN)
        self._define_method_on(result_id, "catch", NATIVE_WEBASSEMBLY_COMPILE_CATCH)
        val module_id = self._native_webassembly_create_module_object(payload_hex)
        var validated = false
        match self.get_object_property(module_id, "validated"):
            JsValue.Boolean(v):
                validated = v
            _:
                pass_dn
        self.set_object_property(result_id, "module", JsValue.Object(id: module_id))
        if validated:
            self.set_object_property(result_id, "status", JsValue.String(v: "compiled"))
        else:
            self.set_object_property(result_id, "status", JsValue.String(v: "invalid"))
            match self.get_object_property(module_id, "error"):
                JsValue.String(v):
                    self.set_object_property(result_id, "error", JsValue.String(v: v))
                _:
                    self.set_object_property(result_id, "error", JsValue.String(v: "invalid-wasm-header"))
        JsValue.Object(id: result_id)

    me _native_webassembly_instance(arg_vals: [JsValue]) -> JsValue:
        val instance_id = self.create_object()
        var exports_id = self.create_object()
        var valid_module = false
        var module_id = -1
        if arg_vals.len() > 0:
            match arg_vals.get(0):
                JsValue.Object(id):
                    module_id = id
                    match self.get_object_property(id, "__simple_wasm_module"):
                        JsValue.Boolean(v):
                            valid_module = v
                        _:
                            pass_dn
                _:
                    pass_dn
        val imports_value = if arg_vals.len() > 1: arg_vals.get(1) else: JsValue.Undefined
        val imports_satisfied = valid_module and module_id >= 0 and self._native_webassembly_imports_satisfied(module_id, imports_value)
        if valid_module and module_id >= 0:
            if imports_satisfied:
                exports_id = self._native_webassembly_create_exports_object(module_id, imports_value)
        self.set_object_property(instance_id, "exports", JsValue.Object(id: exports_id))
        val instantiated = valid_module and module_id >= 0 and imports_satisfied
        self.set_object_property(instance_id, "status", JsValue.String(v: if instantiated: "instantiated" else: "invalid"))
        self.set_object_property(instance_id, "moduleValid", JsValue.Boolean(v: valid_module))
        if valid_module and not imports_satisfied:
            self.set_object_property(instance_id, "error", JsValue.String(v: "unsupported-wasm-imports"))
        else:
            if not valid_module:
                self.set_object_property(instance_id, "error", JsValue.String(v: "invalid-wasm-module"))
        JsValue.Object(id: instance_id)

    me _native_webassembly_requires_imports(module_id: i64) -> bool:
        if module_id < 0:
            return false
        match self.get_object_property(module_id, "hasImportSection"):
            JsValue.Boolean(v): v
            _: false

    me _native_webassembly_imports_satisfied(module_id: i64, imports_value: JsValue) -> bool:
        if not self._native_webassembly_requires_imports(module_id):
            return true
        var import_count = 0
        match self.get_object_property(module_id, "importCount"):
            JsValue.Number(v): import_count = f64_to_i64(v)
            _: pass_dn
        if import_count != 1:
            return false
        var import_kind = ""
        var module_name = ""
        var field_name = ""
        match self.get_object_property(module_id, "firstImportKind"):
            JsValue.String(v): import_kind = v
            _: pass_dn
        match self.get_object_property(module_id, "firstImportModuleName"):
            JsValue.String(v): module_name = v
            _: pass_dn
        match self.get_object_property(module_id, "firstImportFieldName"):
            JsValue.String(v): field_name = v
            _: pass_dn
        if import_kind != "function" or module_name == "" or field_name == "":
            return false
        match self._native_webassembly_bound_import_function(imports_value, module_name, field_name):
            JsValue.Function(id): true
            _: false

    me _native_webassembly_bound_single_import_function(module_id: i64, imports_value: JsValue) -> JsValue:
        var module_name = ""
        var field_name = ""
        match self.get_object_property(module_id, "firstImportModuleName"):
            JsValue.String(v): module_name = v
            _: pass_dn
        match self.get_object_property(module_id, "firstImportFieldName"):
            JsValue.String(v): field_name = v
            _: pass_dn
        if module_name == "" or field_name == "":
            return JsValue.Undefined
        self._native_webassembly_bound_import_function(imports_value, module_name, field_name)

    me _native_webassembly_bound_import_function(imports_value: JsValue, module_name: text, field_name: text) -> JsValue:
        val imports_id = _get_obj_id(imports_value)
        if imports_id < 0:
            return JsValue.Undefined
        val module_key = "" + module_name
        val field_key = "" + field_name
        val import_module_id = _get_obj_id(self.get_object_property(imports_id, module_key))
        if import_module_id >= 0:
            val bound_value = self.get_object_property(import_module_id, field_key)
            val fn_id = _get_fn_id(bound_value)
            if fn_id >= 0:
                return JsValue.Function(id: fn_id)
        JsValue.Undefined

    me _native_webassembly_instantiate(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val payload_hex = self._native_webassembly_payload_hex(arg_vals)
        val result_id = self.create_object()
        self._define_method_on(result_id, "then", NATIVE_WEBASSEMBLY_INSTANTIATE_THEN)
        self._define_method_on(result_id, "catch", NATIVE_WEBASSEMBLY_INSTANTIATE_CATCH)
        val module_id = self._native_webassembly_create_module_object(payload_hex)
        val instance_id = self.create_object()
        var exports_id = self.create_object()
        var validated = false
        match self.get_object_property(module_id, "validated"):
            JsValue.Boolean(v):
                validated = v
            _:
                pass_dn
        self.set_object_property(result_id, "module", JsValue.Object(id: module_id))
        val imports_value = if arg_vals.len() > 1: arg_vals.get(1) else: JsValue.Undefined
        val imports_satisfied = validated and self._native_webassembly_imports_satisfied(module_id, imports_value)
        val unsupported_imports = validated and not imports_satisfied
        if validated and imports_satisfied:
            exports_id = self._native_webassembly_create_exports_object(module_id, imports_value)
            self.set_object_property(instance_id, "exports", JsValue.Object(id: exports_id))
            self.set_object_property(instance_id, "status", JsValue.String(v: "instantiated"))
            self.set_object_property(instance_id, "moduleValid", JsValue.Boolean(v: true))
            self.set_object_property(result_id, "instance", JsValue.Object(id: instance_id))
            self.set_object_property(result_id, "status", JsValue.String(v: "instantiated"))
        else:
            self.set_object_property(result_id, "instance", JsValue.Null)
            self.set_object_property(result_id, "status", JsValue.String(v: "invalid"))
            if unsupported_imports:
                self.set_object_property(result_id, "error", JsValue.String(v: "unsupported-wasm-imports"))
            else:
                match self.get_object_property(module_id, "error"):
                    JsValue.String(v):
                        self.set_object_property(result_id, "error", JsValue.String(v: v))
                    _:
                        self.set_object_property(result_id, "error", JsValue.String(v: "invalid-wasm-header"))
        JsValue.Object(id: result_id)

