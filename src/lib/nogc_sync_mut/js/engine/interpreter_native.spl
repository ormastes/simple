    me _native_node_fs_readdir_result(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val result_id = self.create_object()
        var path = ""
        if arg_vals.len() > 0:
            path = js_to_string(arg_vals[0])
        val reason = self._native_node_file_denial_reason_for_module(this_val, path)
        if reason == "":
            var first_entry = ""
            var entry_count = 0
            val module_id = _get_obj_id(this_val)
            if module_id >= 0:
                val first_key = self._native_node_dir_key("__simple_node_dir_first_", path)
                match self.get_object_property(module_id, first_key):
                    JsValue.String(v):
                        first_entry = v
                    _:
                        pass_dn
                val count_key = self._native_node_dir_key("__simple_node_dir_count_", path)
                match self.get_object_property(module_id, count_key):
                    JsValue.Number(v):
                        entry_count = f64_to_i64(v)
                    _:
                        pass_dn
            if first_entry == "":
                val first_key = self._native_node_dir_key("__simple_node_dir_first_", path)
                if val Some(value) = self.lookup_global_value(first_key):
                    match value:
                        JsValue.String(v):
                            first_entry = v
                        _:
                            pass_dn
            if entry_count == 0:
                val count_key = self._native_node_dir_key("__simple_node_dir_count_", path)
                if val Some(value) = self.lookup_global_value(count_key):
                    match value:
                        JsValue.Number(v):
                            entry_count = f64_to_i64(v)
                        _:
                            pass_dn
            self.set_object_property(result_id, "status", JsValue.String(v: "allowed"))
            self.set_object_property(result_id, "error", JsValue.String(v: ""))
            self.set_object_property(result_id, "entryCount", JsValue.Number(v: entry_count.to_f64()))
            self.set_object_property(result_id, "firstEntry", JsValue.String(v: first_entry))
            self.set_object_property(result_id, "length", JsValue.Number(v: entry_count.to_f64()))
            if entry_count > 0:
                self.set_object_property(result_id, "0", JsValue.String(v: first_entry))
            self.set_object_property(result_id, "operation", JsValue.String(v: "readdirSync"))
            self.set_object_property(result_id, "path", JsValue.String(v: path))
