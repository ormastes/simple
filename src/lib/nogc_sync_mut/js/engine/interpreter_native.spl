        self._native_webassembly_global_i32_const_value_at(hex, 0)

    me _native_webassembly_missing_i32_const() -> i64:
        -2147483649

    me _native_webassembly_global_count(hex: text) -> i64:
        val start = self._native_webassembly_section_payload_start(hex, 6)
        if start < 0:
