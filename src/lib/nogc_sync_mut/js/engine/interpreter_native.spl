            normalized = normalized + 4294967296
        while normalized >= 4294967296:
            normalized = normalized - 4294967296
        normalized

    me _native_webassembly_i32_signed(value: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        if normalized >= 2147483648:
            return normalized - 4294967296
        normalized

    me _native_webassembly_i32_clz(value: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        if normalized == 0:
            return 32
        var count = 0
        var bit = 31
        while bit >= 0:
            val mask = self._native_webassembly_pow2(bit)
            if (normalized & mask) != 0:
                return count
            count = count + 1
            bit = bit - 1
        count

    me _native_webassembly_i32_ctz(value: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        if normalized == 0:
            return 32
        var count = 0
        var bit = 0
        while bit < 32:
            val mask = self._native_webassembly_pow2(bit)
            if (normalized & mask) != 0:
                return count
            count = count + 1
            bit = bit + 1
        count

    me _native_webassembly_i32_popcnt(value: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        var count = 0
        var bit = 0
        while bit < 32:
            val mask = self._native_webassembly_pow2(bit)
            if (normalized & mask) != 0:
                count = count + 1
            bit = bit + 1
        count

    me _native_webassembly_i32_rotl(value: i64, amount: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        val shift = amount & 31
        if shift == 0:
            return self._native_webassembly_i32_signed(normalized)
        val width = 4294967296
        val left = (normalized * self._native_webassembly_pow2(shift)) % width
        val right = normalized / self._native_webassembly_pow2(32 - shift)
        self._native_webassembly_i32_signed(left | right)

    me _native_webassembly_i32_rotr(value: i64, amount: i64) -> i64:
        val normalized = self._native_webassembly_i32_unsigned(value)
        val shift = amount & 31
        if shift == 0:
            return self._native_webassembly_i32_signed(normalized)
        val low_mask = self._native_webassembly_pow2(shift)
        val left = (normalized % low_mask) * self._native_webassembly_pow2(32 - shift)
        val right = normalized / low_mask
        self._native_webassembly_i32_signed(left | right)

    me _native_webassembly_hex_byte_at(hex: text, byte_index: i64) -> i64:
        val char_index = byte_index * 2
        if char_index < 0 or char_index + 2 > hex.len():
            return -1
        val hi = self._native_webassembly_hex_value(hex.slice(char_index, char_index + 1))
        val lo = self._native_webassembly_hex_value(hex.slice(char_index + 1, char_index + 2))
        if hi < 0 or lo < 0:
            return -1
        hi * 16 + lo

    me _native_webassembly_hex_value(ch: text) -> i64:
        if ch == "0":
            return 0
        if ch == "1":
            return 1
        if ch == "2":
            return 2
        if ch == "3":
            return 3
        if ch == "4":
            return 4
        if ch == "5":
            return 5
        if ch == "6":
            return 6
        if ch == "7":
            return 7
        if ch == "8":
            return 8
        if ch == "9":
            return 9
        if ch == "a":
            return 10
        if ch == "b":
            return 11
        if ch == "c":
            return 12
        if ch == "d":
            return 13
        if ch == "e":
            return 14
        if ch == "f":
            return 15
        -1

    me _timer_id_from_value(value: JsValue) -> i64:
        match value:
            JsValue.Number(v): return f64_to_i64(v)
            JsValue.Object(id):
                match self.get_object_property(id, "__simple_timer_id"):
                    JsValue.Number(v): return f64_to_i64(v)
                    _:
                        pass_dn
                match self.get_object_property(id, "id"):
                    JsValue.Number(v): return f64_to_i64(v)
                    _:
                        pass_dn
            _:
                pass_dn
        -1

    me _cancel_timer_id(timer_id: i64):
        if timer_id < 0:
            return
        var already_canceled = false
        var cancel_i = 0
        while cancel_i < self.canceled_timer_ids.len():
            if self.canceled_timer_ids[cancel_i] == timer_id:
                already_canceled = true
            cancel_i = cancel_i + 1
        if not already_canceled:
            self.canceled_timer_ids.push(timer_id)
        var rest: [PendingTimerTask] = []
        var i = 0
        while i < self.pending_timer_tasks.len():
            val task = self.pending_timer_tasks[i]
            if task.id != timer_id:
                rest.push(task)
            i = i + 1
        self.pending_timer_tasks = rest

    me _native_set_timer(arg_vals: [JsValue], is_interval: bool) -> JsValue:
        val timer_id = self.next_timer_id
        self.next_timer_id = self.next_timer_id + 1
        var callback_id = -1
        if arg_vals.len() > 0:
            match arg_vals[0]:
                JsValue.Function(id): callback_id = id
                _: pass_dn
        var delay_ms = 0
        if arg_vals.len() > 1:
            delay_ms = f64_to_i64(to_number(arg_vals[1]))
            if delay_ms < 0:
                delay_ms = 0
        if is_interval and delay_ms < 1:
            delay_ms = 1
        self.pending_timer_tasks.push(PendingTimerTask.create(timer_id, callback_id, delay_ms, 0, is_interval))
        val handle_id = self.create_object()
        self.set_object_property(handle_id, "__simple_timer_id", JsValue.Number(v: timer_id.to_f64()))
        self.set_object_property(handle_id, "id", JsValue.Number(v: timer_id.to_f64()))
        self.set_object_property(handle_id, "delay", JsValue.Number(v: delay_ms.to_f64()))
        self.set_object_property(handle_id, "repeat", JsValue.Boolean(v: is_interval))
        self.set_object_property(handle_id, "__simple_timer_refed", JsValue.Boolean(v: true))
        self._define_method_on(handle_id, "ref", NATIVE_NODE_TIMER_REF)
        self._define_method_on(handle_id, "unref", NATIVE_NODE_TIMER_UNREF)
        self._define_method_on(handle_id, "hasRef", NATIVE_NODE_TIMER_HAS_REF)
        self._define_method_on(handle_id, "close", NATIVE_NODE_TIMER_CLOSE)
        JsValue.Object(id: handle_id)

    me _native_clear_timer(arg_vals: [JsValue]) -> JsValue:
        if arg_vals.len() == 0:
            return JsValue.Undefined
        val timer_id = self._timer_id_from_value(arg_vals[0])
        if timer_id < 0:
            return JsValue.Undefined
        self._cancel_timer_id(timer_id)
        JsValue.Undefined

    me _native_timer_ref(this_val: JsValue) -> JsValue:
        val handle_id = _get_obj_id(this_val)
        if handle_id < 0:
            return this_val
        self.set_object_property(handle_id, "__simple_timer_refed", JsValue.Boolean(v: true))
        this_val

    me _native_timer_unref(this_val: JsValue) -> JsValue:
        val handle_id = _get_obj_id(this_val)
        if handle_id < 0:
            return this_val
        self.set_object_property(handle_id, "__simple_timer_refed", JsValue.Boolean(v: false))
        this_val

    me _native_timer_has_ref(this_val: JsValue) -> JsValue:
        val handle_id = _get_obj_id(this_val)
        if handle_id < 0:
            return JsValue.Boolean(v: false)
        match self.get_object_property(handle_id, "__simple_timer_refed"):
            JsValue.Boolean(v): return JsValue.Boolean(v: v)
            _:
                pass_dn
        JsValue.Boolean(v: false)

    me _native_timer_close(this_val: JsValue) -> JsValue:
        val timer_id = self._timer_id_from_value(this_val)
        self._cancel_timer_id(timer_id)
        val handle_id = _get_obj_id(this_val)
        if handle_id >= 0:
            self.set_object_property(handle_id, "closed", JsValue.Boolean(v: true))
        this_val

    me _native_node_process_next_tick(arg_vals: [JsValue]) -> JsValue:
        if arg_vals.len() == 0:
            return JsValue.Undefined
        val callback_id = _get_fn_id(arg_vals[0])
        if callback_id < 0:
            return JsValue.Undefined
        val timer_id = self.next_timer_id
        self.next_timer_id = self.next_timer_id + 1
        self.pending_timer_tasks.push(PendingTimerTask.create(timer_id, callback_id, 0, 0, false))
        JsValue.Undefined

    me _native_fetch(this_val: JsValue, arg_vals: [JsValue], env: i64) -> JsValue:
        var host_obj_id = _get_obj_id(this_val)
        if host_obj_id < 0:
            match self.lookup_global_value("window"):
                Some(window_val):
                    host_obj_id = _get_obj_id(window_val)
                _:
                    pass_dn
        if host_obj_id < 0:
            return JsValue.Undefined
        if not _simple_fetch_marker(host_obj_id, self.object_store):
            return JsValue.Undefined

        var request_url = _simple_fetch_base_url(host_obj_id, self.object_store)
        if arg_vals.len() > 0:
            request_url = _resolve_fetch_url(request_url, js_to_string(arg_vals.get(0)))

        var method = "GET"
        var headers_text = ""
        var body = ""
        var content_type = ""
        if arg_vals.len() > 1:
            match arg_vals.get(1):
                JsValue.Object(opts_id):
                    match self.get_object_property(opts_id, "method"):
                        JsValue.String(v):
                            if v.trim() != "":
                                method = v.trim().upper()
                        JsValue.Number(v):
                            method = "{v}".upper()
                        _: pass_dn
                    match self.get_object_property(opts_id, "headers"):
                        JsValue.Undefined: pass_dn
                        header_value: headers_text = self._serialize_fetch_headers(header_value)
                    match self.get_object_property(opts_id, "body"):
                        JsValue.String(v): body = v
                        JsValue.Number(v): body = "{v}"
                        JsValue.Boolean(v): body = if v: "true" else: "false"
                        _: pass_dn
                    match self.get_object_property(opts_id, "contentType"):
                        JsValue.String(v): content_type = v
                        _: pass_dn
                JsValue.String(v):
                    headers_text = v
                _:
                    pass_dn

        val cookie_header = _simple_fetch_cookie_header(host_obj_id, self.object_store)
        if cookie_header != "":
            if headers_text != "":
                headers_text = headers_text + "\n"
            headers_text = headers_text + "Cookie: " + cookie_header
        if content_type != "":
            if headers_text != "":
                headers_text = headers_text + "\n"
            headers_text = headers_text + "Content-Type: " + content_type

        val promise_id = self._create_pending_promise_object()
        val request_obj_id = self.create_object()
        val request_id = "fetch-{self.next_async_request_seq}"
        self.next_async_request_seq = self.next_async_request_seq + 1
        self.set_object_property(promise_id, "__simple_request_id", JsValue.String(v: request_id))
        self.set_object_property(request_obj_id, "request_id", JsValue.String(v: request_id))
        self.set_object_property(request_obj_id, "kind", JsValue.String(v: "fetch"))
        self.set_object_property(request_obj_id, "url", JsValue.String(v: request_url))
        self.set_object_property(request_obj_id, "method", JsValue.String(v: if method.trim() != "": method else: "GET"))
        self.set_object_property(request_obj_id, "headers", JsValue.String(v: headers_text))
        self.set_object_property(request_obj_id, "body", JsValue.String(v: body))
        self.set_object_property(request_obj_id, "content_type", JsValue.String(v: content_type))
        self.set_object_property(request_obj_id, "promise_id", JsValue.String(v: "{promise_id}"))
        val request_record = PendingAsyncRequest.create(request_obj_id)
        self.pending_async_requests.push(request_record)
        self.pending_async_request_registry.push(request_record)
        JsValue.Object(id: promise_id)

    me _native_promise_then(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_fulfilled = -1
        var on_rejected = -1
        if arg_vals.len() > 0:
            on_fulfilled = _get_fn_id(arg_vals.get(0))
        if arg_vals.len() > 1:
            on_rejected = _get_fn_id(arg_vals.get(1))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(on_fulfilled, on_rejected, next_promise_id, "then")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._settle_already_settled_promise_then(promise_id, on_fulfilled, on_rejected, next_promise_id)
                JsValue.Object(id: next_promise_id)

    me _settle_already_settled_promise_then(promise_id: i64, on_fulfilled: i64, on_rejected: i64, next_promise_id: i64):
        val state = _simple_fetch_state(promise_id, self.object_store)
        var settled_value = _simple_fetch_value(promise_id, self.object_store)
        match settled_value:
            JsValue.Object(id: settled_obj_id):
                match self.get_object_property(settled_obj_id, "__simple_promise_host"):
                    JsValue.Boolean(is_host):
                        if is_host and _simple_fetch_state(settled_obj_id, self.object_store) == "fulfilled":
                            settled_value = _simple_fetch_value(settled_obj_id, self.object_store)
                    _:
                        pass_dn
            _:
                pass_dn
        var callback_id = if state == "fulfilled": on_fulfilled else: on_rejected
        var propagate_rejection = state == "rejected"
        var next_value = settled_value
        if callback_id >= 0:
            val result = self._invoke_promise_callback(callback_id, [settled_value])
            match result:
                Ok(callback_result):
                    next_value = callback_result
                    propagate_rejection = state == "rejected" and on_rejected < 0
                Err(e):
                    next_value = JsValue.String(v: e.message)
                    propagate_rejection = true
        val _ = self._resolve_promise_from_callback_result(next_promise_id, next_value, propagate_rejection)

    me _native_promise_catch(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_rejected = -1
        if arg_vals.len() > 0:
            on_rejected = _get_fn_id(arg_vals.get(0))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(-1, on_rejected, next_promise_id, "then")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._run_promise_task(promise_id, handler_id)
                JsValue.Object(id: next_promise_id)

    me _native_promise_finally(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val promise_id = _get_obj_id(this_val)
        if promise_id < 0:
            return JsValue.Undefined
        var on_finally = -1
        if arg_vals.len() > 0:
            on_finally = _get_fn_id(arg_vals.get(0))
        val next_promise_id = self._create_pending_promise_object()
        val handler_id = self._create_promise_handler(on_finally, on_finally, next_promise_id, "finally")
        self._append_handler(promise_id, handler_id)
        match _simple_fetch_state(promise_id, self.object_store):
            "pending": JsValue.Object(id: next_promise_id)
            _:
                self._run_promise_task(promise_id, handler_id)
                JsValue.Object(id: next_promise_id)

    me _native_promise_resolve(arg_vals: [JsValue]) -> JsValue:
        val value = if arg_vals.len() > 0: arg_vals.get(0) else: JsValue.Undefined
        match value:
            JsValue.Object(id: obj_id):
                match self.get_object_property(obj_id, "__simple_promise_host"):
                    JsValue.Boolean(is_host):
                        if is_host:
                            return value
                    _:
                        pass_dn
            _:
                pass_dn
        JsValue.Object(id: self._create_settled_promise_object(value, false))

    me _native_promise_reject(arg_vals: [JsValue]) -> JsValue:
        val value = if arg_vals.len() > 0: arg_vals.get(0) else: JsValue.Undefined
        JsValue.Object(id: self._create_settled_promise_object(value, true))

    me _native_response_text(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        match self.get_object_property(response_id, "body"):
            JsValue.String(v): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: v), false))
            _: JsValue.Undefined

    me _native_response_json(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        match self.get_object_property(response_id, "body"):
            JsValue.String(v):
                match self._json_parse_allocated(v, self.global_env):
                    Ok(value): JsValue.Object(id: self._create_settled_promise_object(value, false))
                    Err(e): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: e.message), true))
            _: JsValue.Undefined

    me _native_response_blob(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        var body = ""
        match self.get_object_property(response_id, "body"):
            JsValue.String(v): body = v
            _: pass_dn
        var blob_type = self._response_content_type(response_id)
        if blob_type == "":
            blob_type = "application/octet-stream"
        val blob_id = self.create_object()
        self.set_object_property(blob_id, "__simple_blob_host", JsValue.Boolean(v: true))
        self.set_object_property(blob_id, "size", JsValue.Number(v: body.len().to_f64()))
        self.set_object_property(blob_id, "type", JsValue.String(v: blob_type))
        self.set_object_property(blob_id, "__body__", JsValue.String(v: body))
        self._define_method_on(blob_id, "text", NATIVE_BLOB_TEXT)
        JsValue.Object(id: self._create_settled_promise_object(JsValue.Object(id: blob_id), false))

    me _native_response_array_buffer(this_val: JsValue) -> JsValue:
        val response_id = _get_obj_id(this_val)
        if response_id < 0:
            return JsValue.Undefined
        self.set_object_property(response_id, "bodyUsed", JsValue.Boolean(v: true))
        var body = ""
        match self.get_object_property(response_id, "body"):
            JsValue.String(v): body = v
            _: pass_dn
        val body_hex = self._native_webassembly_normalize_hex(body)
        val use_hex_body = self._native_webassembly_valid_header(body_hex)
        val byte_len = if use_hex_body: body_hex.len() / 2 else: body.bytes().len()
        val buffer = self._native_array_buffer([JsValue.Number(v: byte_len.to_f64())])
        val buffer_id = _get_obj_id(buffer)
        if buffer_id >= 0:
            var i = 0
            if use_hex_body:
                while i < byte_len:
                    val byte = self._native_webassembly_hex_byte_at(body_hex, i)
                    self.set_object_property(buffer_id, i.to_text(), JsValue.Number(v: byte.to_f64()))
                    i = i + 1
            else:
                val bytes = body.bytes()
                while i < bytes.len():
                    self.set_object_property(buffer_id, i.to_text(), JsValue.Number(v: (bytes[i] as i64).to_f64()))
                    i = i + 1
        JsValue.Object(id: self._create_settled_promise_object(buffer, false))

    me _native_blob_text(this_val: JsValue) -> JsValue:
        val blob_id = _get_obj_id(this_val)
        if blob_id < 0:
            return JsValue.Undefined
        match self.get_object_property(blob_id, "__body__"):
            JsValue.String(v): JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: v), false))
            _: JsValue.Object(id: self._create_settled_promise_object(JsValue.String(v: ""), false))

    me _native_navigator_gpu_request_adapter(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val gpu_id = _get_obj_id(this_val)
        if gpu_id < 0:
            return JsValue.Object(id: self._create_settled_promise_object(JsValue.Null, false))
        match self.get_object_property(gpu_id, "__simple_webgpu_host"):
            JsValue.Boolean(is_host):
                if not is_host:
                    return JsValue.Object(id: self._create_settled_promise_object(JsValue.Null, false))
            _:
                return JsValue.Object(id: self._create_settled_promise_object(JsValue.Null, false))

        val adapter_id = self.create_object()
        self.set_object_property(adapter_id, "__simple_webgpu_adapter_host", JsValue.Boolean(v: true))
        self.set_object_property(adapter_id, "name", JsValue.String(v: "Simple WebGPU Software Adapter"))
        self.set_object_property(adapter_id, "requestAdapterStatus", JsValue.String(v: "available"))
        self.set_object_property(adapter_id, "isFallbackAdapter", JsValue.Boolean(v: true))
        self.set_object_property(adapter_id, "features", JsValue.String(v: "texture-compression-bc,timestamp-query"))
        self.set_object_property(adapter_id, "limitsProfile", JsValue.String(v: "mvp"))
        JsValue.Object(id: self._create_settled_promise_object(JsValue.Object(id: adapter_id), false))

    me _response_content_type(response_id: i64) -> text:
        match self.get_object_property(response_id, "headersText"):
            JsValue.String(headers):
                for line in headers.split("\n"):
                    val trimmed = line.trim()
                    if trimmed.lower().starts_with("content-type:"):
                        return trimmed.slice(13, trimmed.len()).trim()
            _: pass_dn
        ""

    me _json_parse_allocated(source: text, env: i64) -> BrowserResult<JsValue>:
        if not json_is_valid(source):
            return Err(script_error("invalid-json"))
        var parser = JsParser.create(source, self.logger)
        val expr = parser.parse_assignment()?
        self.eval_expression(expr, env)

    me _storage_api_property(key: text) -> bool:
        key == "__proto__" or
        key == "getItem" or
        key == "setItem" or
        key == "removeItem" or
        key == "clear" or
        key == "key" or
        key == "length"

    me _storage_internal_prefix() -> text:
        "__simple_storage_data:"

    me _storage_internal_key(key: text) -> text:
        self._storage_internal_prefix() + key

    me _storage_public_key_from_internal(key: text) -> text:
        val prefix = self._storage_internal_prefix()
        if key.starts_with(prefix):
            return key.slice(prefix.len(), key.len())
        key

    me _storage_property_key(key: text) -> text:
        if self._storage_api_property(key):
            return self._storage_internal_key(key)
        key

    me _storage_keys(storage_id: i64) -> [text]:
        val obj = self.object_store.get_object(storage_id)
        var keys: [text] = []
        for prop in obj.properties:
            if prop.key.starts_with(self._storage_internal_prefix()):
                keys.push(self._storage_public_key_from_internal(prop.key))
            else if not self._storage_api_property(prop.key):
                keys.push(prop.key)
        keys

    me _sync_storage_length(storage_id: i64):
        val keys = self._storage_keys(storage_id)
        self.set_object_property(storage_id, "length", JsValue.Number(v: keys.len().to_f64()))

    me _native_storage_get_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        val stored = self.get_object_property(storage_id, self._storage_property_key(key))
        if val JsValue.Undefined = stored:
            return JsValue.Null
        if val JsValue.String(v) = stored:
            return JsValue.String(v: v)
        JsValue.String(v: js_to_string(stored))

    me _native_storage_set_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        val value = if arg_vals.len() > 1: js_to_string(arg_vals.get(1)) else: ""
        self.set_object_property(storage_id, self._storage_property_key(key), JsValue.String(v: value))
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    me _native_storage_remove_item(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val key = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""
        self.object_store.remove_property(storage_id, self._storage_property_key(key))
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    me _native_storage_clear(this_val: JsValue) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        for key in self._storage_keys(storage_id):
            self.object_store.remove_property(storage_id, self._storage_property_key(key))
        self._sync_storage_length(storage_id)
        JsValue.Undefined

    me _native_storage_key(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val storage_id = _get_obj_id(this_val)
        if storage_id < 0:
            return JsValue.Undefined
        val idx = if arg_vals.len() > 0: f64_to_i64(to_number(arg_vals.get(0))) else: -1
        val keys = self._storage_keys(storage_id)
        if idx < 0 or idx >= keys.len():
            return JsValue.Null
        JsValue.String(v: keys.get(idx))
