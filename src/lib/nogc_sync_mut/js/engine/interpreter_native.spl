    me _native_node_execute_granted_module_source(specifier: text, source: text) -> JsValue:
        val exports_id = self.create_object()
        val module_id = self.create_object()
        self.set_object_property(module_id, "exports", JsValue.Object(id: exports_id))
        self.set_object_property(module_id, "id", JsValue.String(v: specifier))
        self.set_object_property(module_id, "filename", JsValue.String(v: specifier))
        val module_env = self.env_stack.create_env(self.global_env)
        self.env_stack.define_var(module_env, "exports", JsValue.Object(id: exports_id))
        self.env_stack.define_var(module_env, "module", JsValue.Object(id: module_id))
        self.env_stack.define_var(module_env, "require", self._native_node_require_function())
        self.env_stack.define_var(module_env, "__filename", JsValue.String(v: specifier))
        self.env_stack.define_var(module_env, "__dirname", JsValue.String(v: self._native_node_parent_dir(specifier)))
