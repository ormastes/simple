    me _native_node_http_request_add_header_name(request_id: i64, name: text):
        var names = ""
        match self.get_object_property(request_id, "headerNames"):
            JsValue.String(v): names = v
            _:
                pass_dn
        if names == "":
            self.set_object_property(request_id, "headerNames", JsValue.String(v: name))
            return
        for existing in names.split(","):
            if existing == name:
                return
        self.set_object_property(request_id, "headerNames", JsValue.String(v: names + "," + name))

    me _native_node_http_request_remove_header_name(request_id: i64, name: text):
        var names = ""
        match self.get_object_property(request_id, "headerNames"):
            JsValue.String(v): names = v
            _:
                pass_dn
        if names == "":
            return
        var kept: [text] = []
        for existing in names.split(","):
            if existing != "" and existing != name:
                kept.push(existing)
        self.set_object_property(request_id, "headerNames", JsValue.String(v: kept.join(",")))

    me _native_node_network_marker_key(endpoint: text) -> text:
        var key = "__simple_node_network_grant_"
        var i = 0
        while i < endpoint.len():
            val ch = endpoint.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
            else:
                key = key + "_"
            i = i + 1
        key

    me _native_node_network_allowed(endpoint: text) -> bool:
        val marker_key = self._native_node_network_marker_key(endpoint)
        if val Some(marker) = self.lookup_global_value(marker_key):
            match marker:
                JsValue.Boolean(v): return v
                _:
                    pass_dn
        if endpoint == "tcp://example.com:80":
            if val Some(marker) = self.lookup_global_value("__simple_node_network_grant_tcp___example_com_80"):
                match marker:
                    JsValue.Boolean(v): return v
                    _:
                        pass_dn
        if endpoint == "http://example.com:80":
            if val Some(marker) = self.lookup_global_value("__simple_node_network_grant_http___example_com_80"):
                match marker:
                    JsValue.Boolean(v): return v
                    _:
                        pass_dn
        if endpoint == "https://example.com:443":
            if val Some(marker) = self.lookup_global_value("__simple_node_network_grant_https___example_com_443"):
                match marker:
                    JsValue.Boolean(v): return v
                    _:
                        pass_dn
        false

