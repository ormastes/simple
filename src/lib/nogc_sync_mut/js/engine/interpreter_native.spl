    me _native_webassembly_function_body_i32_result_with_args_for_module(hex: text, wanted_body_index: i64, arg_vals: [JsValue], module_id: i64) -> i64:
        val start = self._native_webassembly_section_payload_start(hex, 10)
        val end = self._native_webassembly_section_payload_end(hex, 10)
        if start < 0 or end <= start:
            return -1
        val count = self._native_webassembly_read_leb_value(hex, start)
        var pos = self._native_webassembly_read_leb_next(hex, start)
        if count < 0 or pos < 0:
            return -1
        var index = 0
        while index < count and pos < end:
            val body_size = self._native_webassembly_read_leb_value(hex, pos)
            val body_start = self._native_webassembly_read_leb_next(hex, pos)
            if body_size < 0 or body_start < 0:
                return -1
            val body_end = body_start + body_size
            if body_end > end:
                return -1
            if index == wanted_body_index:
                val local_decl_count = self._native_webassembly_read_leb_value(hex, body_start)
                var instr_start = self._native_webassembly_read_leb_next(hex, body_start)
                if local_decl_count < 0 or instr_start < 0:
                    return -1
                var local_vals: [i64] = []
                var arg_index = 0
                while arg_index < arg_vals.len():
                    match arg_vals.get(arg_index):
                        JsValue.Number(v):
                            local_vals.push(f64_to_i64(v))
                        _:
                            return -1
                    arg_index = arg_index + 1
                var local_decl_index = 0
                while local_decl_index < local_decl_count:
                    val declared_count = self._native_webassembly_read_leb_value(hex, instr_start)
                    val type_pos = self._native_webassembly_read_leb_next(hex, instr_start)
                    if declared_count < 0 or type_pos < 0 or type_pos >= body_end:
                        return -1
                    val value_type = self._native_webassembly_hex_byte_at(hex, type_pos)
                    if value_type != 127:
                        return -1
                    var declared_index = 0
                    while declared_index < declared_count:
                        local_vals.push(0)
                        declared_index = declared_index + 1
                    instr_start = type_pos + 1
                    local_decl_index = local_decl_index + 1
                if instr_start > body_end:
                    return -1
                var stack: [i64] = []
                var memory_page_count = self._native_webassembly_memory_min_pages(hex)
                val memory_max_pages = self._native_webassembly_memory_max_pages(hex)
                if module_id >= 0:
                    self.set_object_property(module_id, "lastWasmI32MinusOneValid", JsValue.Boolean(v: false))
                    match self.get_object_property(module_id, "runtimeMemoryPages"):
                        JsValue.Number(v): memory_page_count = f64_to_i64(v)
                        _:
                            self.set_object_property(module_id, "runtimeMemoryPages", JsValue.Number(v: memory_page_count.to_f64()))
                var memory_byte_len = memory_page_count * 65536
                var memory_addrs: [i64] = []
                var memory_bytes: [i64] = []
                var dropped_data_segments: [i64] = []
                var global_vals: [i64] = []
                var global_mutabilities: [i64] = []
                val global_count = self._native_webassembly_global_count(hex)
                var global_init_index = 0
                while global_init_index < global_count:
                    var global_init_value = self._native_webassembly_global_i32_const_value_at(hex, global_init_index)
                    val global_mutability = self._native_webassembly_global_i32_mutability_at(hex, global_init_index)
                    if global_init_value == self._native_webassembly_missing_i32_const() or global_mutability < 0:
                        return -1
                    if module_id >= 0:
                        match self.get_object_property(module_id, "runtimeGlobalValue{global_init_index}"):
                            JsValue.Number(v): global_init_value = f64_to_i64(v)
                            _:
                                self.set_object_property(module_id, "runtimeGlobalValue{global_init_index}", JsValue.Number(v: global_init_value.to_f64()))
                    global_vals.push(global_init_value)
                    global_mutabilities.push(global_mutability)
                    global_init_index = global_init_index + 1
                var control_kinds: [i64] = []
                var control_body_starts: [i64] = []
                var control_end_positions: [i64] = []
                var cursor = instr_start
                var step_count = 0
                while cursor < body_end:
                    step_count = step_count + 1
                    if step_count > 10000:
                        return -1
                    val opcode = self._native_webassembly_hex_byte_at(hex, cursor)
                    if opcode == 0:
                        return -3
                    if opcode == 2:
                        if cursor + 1 >= body_end:
                            return -1
                        val block_type = self._native_webassembly_hex_byte_at(hex, cursor + 1)
                        if block_type != 64 and block_type != 127:
                            return -1
                        val end_pos = self._native_webassembly_control_end_pos(hex, cursor + 2, body_end)
                        if end_pos < 0:
                            return -1
                        control_kinds.push(0)
                        control_body_starts.push(cursor + 2)
                        control_end_positions.push(end_pos)
                        cursor = cursor + 2
                        continue
                    if opcode == 3:
                        if cursor + 1 >= body_end:
                            return -1
                        val block_type = self._native_webassembly_hex_byte_at(hex, cursor + 1)
                        if block_type != 64 and block_type != 127:
                            return -1
                        val end_pos = self._native_webassembly_control_end_pos(hex, cursor + 2, body_end)
                        if end_pos < 0:
                            return -1
                        control_kinds.push(1)
                        control_body_starts.push(cursor + 2)
                        control_end_positions.push(end_pos)
                        cursor = cursor + 2
                        continue
                    if opcode == 4:
                        if stack.len() < 1 or cursor + 1 >= body_end:
                            return -1
                        val block_type = self._native_webassembly_hex_byte_at(hex, cursor + 1)
                        if block_type != 64 and block_type != 127:
                            return -1
                        val else_pos = self._native_webassembly_control_else_pos(hex, cursor + 2, body_end)
                        val end_pos = self._native_webassembly_control_end_pos(hex, cursor + 2, body_end)
                        if end_pos < 0:
                            return -1
                        val condition = stack.get(stack.len() - 1)
                        stack.pop()
                        control_kinds.push(0)
                        control_body_starts.push(cursor + 2)
                        control_end_positions.push(end_pos)
                        if condition != 0:
                            cursor = cursor + 2
                        else:
                            if else_pos >= 0:
                                cursor = else_pos + 1
                            else:
                                cursor = end_pos + 1
                        continue
                    if opcode == 5:
