            self.set_object_property(result_id, "reason", JsValue.String(v: reason))
            self.set_object_property(result_id, "entryCount", JsValue.Number(v: 0.0))
            self.set_object_property(result_id, "firstEntry", JsValue.String(v: ""))
        self.set_object_property(result_id, "operation", JsValue.String(v: "readdirSync"))
        self.set_object_property(result_id, "path", JsValue.String(v: path))
