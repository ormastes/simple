    me _native_node_fs_mkdir_recursive_option(arg_vals: [JsValue]) -> bool:
        if arg_vals.len() <= 1:
            return false
        val options_id = _get_obj_id(arg_vals.get(1))
        if options_id < 0:
            return false
        match self.get_object_property(options_id, "recursive"):
            JsValue.Boolean(v):
                return v
            _:
                pass_dn
        false

    me _native_node_mkdir_recursive_for_module(this_val: JsValue, path: text):
        var dirs: [text] = []
        var current = path
        while current != "" and current != "/":
            if self._native_node_file_denial_reason_for_module(this_val, current) != "":
                break
            dirs.push(current)
            val parent = self._native_node_parent_dir(current)
            if text_equals_exact(parent, current):
                break
            current = parent
        var i = dirs.len() - 1
        while i >= 0:
            val dir_path = dirs.get(i)
            val already_exists = self._native_node_dir_exists_for_module(this_val, dir_path)
            self._native_node_mark_dir_for_module(this_val, dir_path)
            if not already_exists:
                val parent = self._native_node_parent_dir(dir_path)
                if self._native_node_file_denial_reason_for_module(this_val, parent) == "":
                    val entry = self._native_node_basename(dir_path)
                    if entry != "":
                        self._native_node_record_dir_entry_for_module(this_val, parent, entry)
            i = i - 1

