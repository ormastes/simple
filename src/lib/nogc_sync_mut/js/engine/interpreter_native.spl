    me _native_node_module_marker_key(specifier: text) -> text:
        var key = "__simple_node_module_grant_"
        var i = 0
        while i < specifier.len():
            val ch = specifier.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
            else:
                key = key + "_"
            i = i + 1
        key

