    me _native_node_require(arg_vals: [JsValue]) -> JsValue:
        if arg_vals.len() == 0:
            return JsValue.Undefined
        var specifier = ""
        match arg_vals.get(0):
            JsValue.String(v):
                specifier = v
            _:
                return JsValue.Undefined
        if specifier == "path" or specifier == "node:path":
            return self._native_node_path_module()
        if specifier == "buffer" or specifier == "node:buffer":
            return self._native_node_buffer_module()
        if specifier == "process" or specifier == "node:process":
            return self._native_node_process_object()
        if specifier == "os" or specifier == "node:os":
            return self._native_node_os_module()
        if specifier == "crypto" or specifier == "node:crypto":
            return self._native_node_crypto_module()
        if specifier == "events" or specifier == "node:events":
            return self._native_node_events_module()
        if specifier == "child_process" or specifier == "node:child_process":
            return self._native_node_child_process_module()
        if specifier == "fs" or specifier == "node:fs":
            return self._native_node_fs_module()
        if specifier == "net" or specifier == "node:net":
            return self._native_node_net_module()
        if specifier == "http" or specifier == "node:http":
            return self._native_node_http_module(false)
        if specifier == "https" or specifier == "node:https":
            return self._native_node_http_module(true)
        if specifier == "readline" or specifier == "node:readline":
            return self._native_node_readline_module()
        self._native_node_denied_module(specifier)

