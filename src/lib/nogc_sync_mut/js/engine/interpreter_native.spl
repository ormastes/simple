                    if mapped_result == -4:
                        return JsValue.String(v: "wasm-trap:integer-overflow")
                    if mapped_result == -5:
                        return JsValue.String(v: "wasm-trap:out-of-bounds-memory-access")
                    return JsValue.Number(v: mapped_result.to_f64())
