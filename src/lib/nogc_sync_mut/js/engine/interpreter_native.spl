    me _native_node_require_canonical_specifier(specifier: text) -> text:
        if specifier.starts_with("node:"):
            return specifier.substring(5, specifier.len())
        if specifier == "path" or specifier == "buffer" or specifier == "process" or specifier == "os" or specifier == "crypto" or specifier == "events" or specifier == "child_process" or specifier == "fs" or specifier == "net" or specifier == "http" or specifier == "https" or specifier == "readline" or specifier == "stream" or specifier == "timers":
            return specifier
        ""

    me _native_node_require_cached(canonical: text, module_value: JsValue) -> JsValue:
        var names = self.node_require_cache_names
        var values = self.node_require_cache_values
        names.push(canonical)
        values.push(module_value)
        self.node_require_cache_names = names
        self.node_require_cache_values = values
        self.node_require_last_cache_key = canonical
        self.node_require_last_cache_value = module_value
        module_value

