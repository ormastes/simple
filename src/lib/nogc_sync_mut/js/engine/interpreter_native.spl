            return -1
        var type_index = 0
        while type_index < type_count and type_pos < type_end:
            val form = self._native_webassembly_hex_byte_at(hex, type_pos)
            if form != 96:
                return -1
            val param_count = self._native_webassembly_read_leb_value(hex, type_pos + 1)
            var param_pos = self._native_webassembly_read_leb_next(hex, type_pos + 1)
            if param_count < 0 or param_pos < 0 or param_pos > type_end:
                return -1
            var param_index = 0
            while param_index < param_count:
                if param_pos >= type_end or self._native_webassembly_hex_byte_at(hex, param_pos) != 127:
                    return -1
                param_pos = param_pos + 1
                param_index = param_index + 1
            val result_count = self._native_webassembly_read_leb_value(hex, param_pos)
            var result_pos = self._native_webassembly_read_leb_next(hex, param_pos)
            if result_count < 0 or result_pos < 0 or result_pos > type_end:
                return -1
            var result_index = 0
