        if flags < 0 or pos >= end:
            return -1
        val min_pages = self._native_webassembly_read_leb_value(hex, pos)
        pos = self._native_webassembly_read_leb_next(hex, pos)
        if min_pages < 0 or pos < 0:
            return -1
        if (flags & 1) == 0:
            return -1
        if pos >= end:
            return -1
        val max_pages = self._native_webassembly_read_leb_value(hex, pos)
        if max_pages < 0:
            return -1
        max_pages

