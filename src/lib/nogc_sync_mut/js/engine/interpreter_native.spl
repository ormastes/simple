    me _native_webassembly_sections_valid(hex: text) -> bool:
        if not self._native_webassembly_valid_header(hex):
            return false
        val byte_len = hex.len() / 2
        var pos = 8
        while pos < byte_len:
            val section_id = self._native_webassembly_hex_byte_at(hex, pos)
            if section_id < 0:
                return false
            pos = pos + 1
            val payload_len = self._native_webassembly_read_leb_value(hex, pos)
            val next_pos = self._native_webassembly_read_leb_next(hex, pos)
            if payload_len < 0 or next_pos < 0:
                return false
            if next_pos + payload_len > byte_len:
                return false
            pos = next_pos + payload_len
        pos == byte_len

    me _native_webassembly_section_count(hex: text) -> i64:
        if not self._native_webassembly_sections_valid(hex):
            return 0
        val byte_len = hex.len() / 2
        var pos = 8
        var count = 0
        while pos < byte_len:
            pos = pos + 1
            val payload_len = self._native_webassembly_read_leb_value(hex, pos)
            val next_pos = self._native_webassembly_read_leb_next(hex, pos)
            pos = next_pos + payload_len
            count = count + 1
        count

    me _native_webassembly_has_section(hex: text, wanted_id: i64) -> bool:
        if not self._native_webassembly_sections_valid(hex):
            return false
        val byte_len = hex.len() / 2
        var pos = 8
        while pos < byte_len:
            val section_id = self._native_webassembly_hex_byte_at(hex, pos)
            pos = pos + 1
            val payload_len = self._native_webassembly_read_leb_value(hex, pos)
            val next_pos = self._native_webassembly_read_leb_next(hex, pos)
            if section_id == wanted_id:
                return true
            pos = next_pos + payload_len
        false

    me _native_webassembly_section_payload_start(hex: text, wanted_id: i64) -> i64:
        if not self._native_webassembly_sections_valid(hex):
            return -1
        val byte_len = hex.len() / 2
        var pos = 8
        while pos < byte_len:
            val section_id = self._native_webassembly_hex_byte_at(hex, pos)
            pos = pos + 1
            val payload_len = self._native_webassembly_read_leb_value(hex, pos)
            val next_pos = self._native_webassembly_read_leb_next(hex, pos)
            if payload_len < 0 or next_pos < 0:
                return -1
            if section_id == wanted_id:
                return next_pos
            pos = next_pos + payload_len
        -1

    me _native_webassembly_section_payload_end(hex: text, wanted_id: i64) -> i64:
        if not self._native_webassembly_sections_valid(hex):
            return -1
        val byte_len = hex.len() / 2
        var pos = 8
        while pos < byte_len:
            val section_id = self._native_webassembly_hex_byte_at(hex, pos)
            pos = pos + 1
            val payload_len = self._native_webassembly_read_leb_value(hex, pos)
            val next_pos = self._native_webassembly_read_leb_next(hex, pos)
            if payload_len < 0 or next_pos < 0:
                return -1
            if section_id == wanted_id:
                return next_pos + payload_len
            pos = next_pos + payload_len
        -1

    me _native_webassembly_memory_min_pages(hex: text) -> i64:
        val start = self._native_webassembly_section_payload_start(hex, 5)
        val end = self._native_webassembly_section_payload_end(hex, 5)
        if start < 0 or end <= start:
            return 0
        val count = self._native_webassembly_read_leb_value(hex, start)
        var pos = self._native_webassembly_read_leb_next(hex, start)
        if count <= 0 or pos < 0 or pos >= end:
            return 0
        val flags = self._native_webassembly_hex_byte_at(hex, pos)
        pos = pos + 1
        if flags < 0 or pos >= end:
            return 0
        val min_pages = self._native_webassembly_read_leb_value(hex, pos)
        if min_pages < 0:
            return 0
        min_pages

    me _native_webassembly_memory_max_pages(hex: text) -> i64:
        val start = self._native_webassembly_section_payload_start(hex, 5)
        val end = self._native_webassembly_section_payload_end(hex, 5)
        if start < 0 or end <= start:
            return -1
        val count = self._native_webassembly_read_leb_value(hex, start)
        var pos = self._native_webassembly_read_leb_next(hex, start)
        if count <= 0 or pos < 0 or pos >= end:
            return -1
        val flags = self._native_webassembly_hex_byte_at(hex, pos)
