        self.set_object_property(table_id, "kind", JsValue.String(v: "table"))
        match self.get_object_property(module_id, "tableMinElements"):
            JsValue.Number(v): self.set_object_property(table_id, "length", JsValue.Number(v: v))
            _: self.set_object_property(table_id, "length", JsValue.Number(v: 0.0))
        JsValue.Object(id: table_id)

    me _native_webassembly_global_placeholder(module_id: i64) -> JsValue:
