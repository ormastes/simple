    me _native_node_network_endpoint(operation: text, scheme: text, arg_vals: [JsValue]) -> text:
        if operation == "net.createConnection":
            if arg_vals.len() > 0:
                match arg_vals.get(0):
                    JsValue.Object(obj_id):
                        var host = ""
                        var port = ""
                        match self.get_object_property(obj_id, "host"):
                            JsValue.String(v): host = v
                            _:
                                pass_dn
                        match self.get_object_property(obj_id, "port"):
                            JsValue.Number(v): port = f64_to_i64(v).to_text()
                            JsValue.String(v): port = v
                            _:
                                pass_dn
                        if host != "" and port != "":
                            return "tcp://" + host + ":" + port
                    JsValue.Number(port_value):
                        if arg_vals.len() > 1:
                            match arg_vals.get(1):
                                JsValue.String(host):
                                    return "tcp://" + host + ":" + f64_to_i64(port_value).to_text()
                                _:
                                    pass_dn
                    _:
                        pass_dn
        if operation == "http.request" or operation == "https.request":
            if arg_vals.len() > 0:
                var parsed_endpoint = ""
                match arg_vals.get(0):
                    JsValue.String(url):
                        parsed_endpoint = self._native_node_http_endpoint_from_url(scheme, url)
                    JsValue.Object(obj_id):
                        parsed_endpoint = self._native_node_http_endpoint_from_options(scheme, obj_id)
                    _:
                        pass_dn
                if parsed_endpoint != "":
                    return parsed_endpoint
        scheme + "://"

    me _native_node_http_endpoint_from_options(scheme: text, obj_id: i64) -> text:
        var host = ""
        match self.get_object_property(obj_id, "hostname"):
            JsValue.String(v): host = v
            _:
                pass_dn
        if host == "":
            match self.get_object_property(obj_id, "host"):
                JsValue.String(v): host = v
                _:
                    pass_dn
        var port = ""
        match self.get_object_property(obj_id, "port"):
            JsValue.Number(v): port = f64_to_i64(v).to_text()
            JsValue.String(v): port = v
            _:
                pass_dn
        if port == "":
            port = if scheme == "https": "443" else: "80"
        if host == "":
            return ""
        scheme + "://" + host + ":" + port

    me _native_node_http_endpoint_from_url(scheme: text, url: text) -> text:
        val prefix = scheme + "://"
        if not url.starts_with(prefix):
            return ""
        var rest = url.substring(prefix.len(), url.len())
        var slash_idx = rest.len()
        var i = 0
        while i < rest.len():
            if rest.substring(i, i + 1) == "/":
                slash_idx = i
                i = rest.len()
            else:
                i = i + 1
        rest = rest.substring(0, slash_idx)
        if rest == "":
            return ""
        var host = rest
        var port = if scheme == "https": "443" else: "80"
        i = 0
        while i < rest.len():
            if rest.substring(i, i + 1) == ":":
                host = rest.substring(0, i)
                port = rest.substring(i + 1, rest.len())
                i = rest.len()
            else:
                i = i + 1
        if host == "" or port == "":
            return ""
        scheme + "://" + host + ":" + port

    me _native_node_http_request_method(arg_vals: [JsValue]) -> text:
        var method = "GET"
        if arg_vals.len() > 0:
            match arg_vals.get(0):
                JsValue.Object(obj_id):
                    match self.get_object_property(obj_id, "method"):
                        JsValue.String(v):
                            if v != "":
                                method = v
                        _:
                            pass_dn
                _:
                    pass_dn
        method

    me _native_node_http_request_path(arg_vals: [JsValue]) -> text:
        var request_path = "/"
        if arg_vals.len() > 0:
            match arg_vals.get(0):
                JsValue.String(url):
                    val parsed_path = self._native_node_http_path_from_url(url)
                    if parsed_path != "":
                        request_path = parsed_path
                JsValue.Object(obj_id):
                    match self.get_object_property(obj_id, "path"):
                        JsValue.String(v):
                            if v != "":
                                request_path = v
                        _:
                            pass_dn
                _:
                    pass_dn
        request_path

    me _native_node_http_request_callback_id(arg_vals: [JsValue]) -> i64:
        var i = 0
        while i < arg_vals.len():
            val callback_id = _get_fn_id(arg_vals.get(i))
            if callback_id >= 0:
                return callback_id
            i = i + 1
        -1

    me _native_node_http_path_from_url(url: text) -> text:
        var start = -1
        var i = 0
        var slash_count = 0
        while i < url.len():
            if url.substring(i, i + 1) == "/":
                slash_count = slash_count + 1
                if slash_count == 3:
                    start = i
                    i = url.len()
                else:
                    i = i + 1
            else:
                i = i + 1
        if start < 0:
            return "/"
        val path = url.substring(start, url.len())
        if path == "":
            return "/"
        path

    me _native_node_http_request_write(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val request_id = _get_obj_id(this_val)
        val result_id = self.create_object()
        if request_id < 0:
            self.set_object_property(result_id, "status", JsValue.String(v: "denied"))
            self.set_object_property(result_id, "error", JsValue.String(v: "invalid-request"))
            return JsValue.Object(id: result_id)
        val bytes = if arg_vals.len() > 0: js_to_string(arg_vals.get(0)).len() else: 0
        var body_bytes = 0
        match self.get_object_property(request_id, "bodyBytes"):
            JsValue.Number(v): body_bytes = f64_to_i64(v)
            _:
                pass_dn
        var body_chunks = 0
        match self.get_object_property(request_id, "bodyChunks"):
            JsValue.Number(v): body_chunks = f64_to_i64(v)
            _:
                pass_dn
        body_bytes = body_bytes + bytes
        body_chunks = body_chunks + 1
        self.set_object_property(request_id, "bodyBytes", JsValue.Number(v: body_bytes.to_f64()))
        self.set_object_property(request_id, "bodyChunks", JsValue.Number(v: body_chunks.to_f64()))
        self.set_object_property(request_id, "lastBodyChunk", JsValue.String(v: if arg_vals.len() > 0: js_to_string(arg_vals.get(0)) else: ""))
        self.set_object_property(result_id, "status", JsValue.String(v: "ok"))
        self.set_object_property(result_id, "bytes", JsValue.Number(v: bytes.to_f64()))
        self.set_object_property(result_id, "chunks", JsValue.Number(v: body_chunks.to_f64()))
