            while mapped_body_i < self.wasm_export_body_fn_ids.len():
                if self.wasm_export_body_fn_ids.get(mapped_body_i) == lookup_fn_id:
                    val mapped_module_id = self.wasm_export_body_module_ids.get(mapped_body_i)
                    val mapped_body_index = self.wasm_export_body_indices.get(mapped_body_i)
                    val mapped_result = self._native_webassembly_module_function_export_i32_result_with_args_at(mapped_module_id, mapped_body_index, arg_vals)
