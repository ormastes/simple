        exports_id

    me _native_webassembly_export_function(this_val: JsValue, arg_vals: [JsValue], dispatched_fn_id: i64) -> JsValue:
        var bound_import = JsValue.Undefined
        val direct_fn_id = _get_fn_id(this_val)
        var lookup_fn_id = dispatched_fn_id
        if lookup_fn_id < 0:
            lookup_fn_id = direct_fn_id
        if lookup_fn_id >= 0:
            var wi = 0
            while wi < self.wasm_export_fn_ids.len():
                if self.wasm_export_fn_ids.get(wi) == lookup_fn_id:
                    bound_import = self.wasm_export_bound_imports.get(wi)
                    break
                wi = wi + 1
        var const_return = -1
        if lookup_fn_id >= 0:
            var ci = 0
            while ci < self.wasm_export_const_fn_ids.len():
                if self.wasm_export_const_fn_ids.get(ci) == lookup_fn_id:
