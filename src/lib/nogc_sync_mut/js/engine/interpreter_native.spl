    me _native_node_fs_mkdir_result(this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        val result_id = self.create_object()
        var path = ""
        if arg_vals.len() > 0:
            path = js_to_string(arg_vals[0])
        val reason = self._native_node_file_denial_reason_for_module(this_val, path)
        if reason == "":
            val recursive = self._native_node_fs_mkdir_recursive_option(arg_vals)
            if recursive:
                self._native_node_mkdir_recursive_for_module(this_val, path)
                self.set_object_property(result_id, "recursive", JsValue.Boolean(v: true))
            else:
                val already_exists = self._native_node_dir_exists_for_module(this_val, path)
                self._native_node_mark_dir_for_module(this_val, path)
                if not already_exists:
                    val parent = self._native_node_parent_dir(path)
                    val entry = self._native_node_basename(path)
                    if parent != "" and entry != "":
                        self._native_node_record_dir_entry_for_module(this_val, parent, entry)
                self.set_object_property(result_id, "recursive", JsValue.Boolean(v: false))
            self.set_object_property(result_id, "status", JsValue.String(v: "allowed"))
            self.set_object_property(result_id, "error", JsValue.String(v: ""))
        else:
            self.set_object_property(result_id, "status", JsValue.String(v: "denied"))
            self.set_object_property(result_id, "error", JsValue.String(v: "file-denied"))
            self.set_object_property(result_id, "reason", JsValue.String(v: reason))
        self.set_object_property(result_id, "operation", JsValue.String(v: "mkdirSync"))
        self.set_object_property(result_id, "path", JsValue.String(v: path))
