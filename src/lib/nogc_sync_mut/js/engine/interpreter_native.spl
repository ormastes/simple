    me grant_node_credential(handle: text, value: text):
        val env_key = self._node_env_key_for_credential(handle)
        if env_key == "":
            return
        var names = self.node_credential_grant_names
        var values = self.node_credential_grant_values
        names.push(env_key)
        values.push(value)
        self.node_credential_grant_names = names
        self.node_credential_grant_values = values

    me _node_env_key_for_credential(handle: text) -> text:
        val trimmed = handle.trim()
