# JS Module Loader
# Resolves and loads JS modules for the Simple Browser JS engine.

use std.js.types.ast_types.JsStatement

class JsModule:
    path: text
    source: text
    stmts: [JsStatement]
    loaded: bool

class JsModuleLoader:
    base_path: text
    cache: Dict<text, JsModule>

impl JsModuleLoader:
    static fn create(base_path: text) -> JsModuleLoader:
        JsModuleLoader(base_path: base_path, cache: {})

    fn load(path: text) -> Result<JsModule, text>:
        Err("module loading not implemented: {path}")

    fn resolve(base: text, specifier: text) -> text:
        if specifier.starts_with("/") or specifier.starts_with("http"):
            return specifier
        "{base}/{specifier}"
