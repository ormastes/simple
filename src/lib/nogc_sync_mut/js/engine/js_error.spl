# JS Engine Error Types
# JsError, Logger, BrowserResult and related types for the JS interpreter.

use std.js.types.js_types.JsValue

enum LogLevel:
    Debug
    Info
    Warn
    Error

class JsError:
    message: text
    name: text
    stack: text

class BrowserError:
    code: i64
    message: text

class BrowserResult:
    ok: bool
    value: JsValue
    error: BrowserError?

class Logger:
    level: LogLevel

fn script_error(msg: text) -> JsError:
    JsError(message: msg, name: "Error", stack: msg)

fn js_nan() -> f64:
    0.0 / 0.0

fn js_infinity() -> f64:
    1.0 / 0.0

fn js_neg_infinity() -> f64:
    -1.0 / 0.0

fn is_nan(v: f64) -> bool:
    v != v
