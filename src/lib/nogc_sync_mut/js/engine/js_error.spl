# JS Engine Error Types
# JsError, Logger, BrowserResult and related types for the JS interpreter.

use std.js.types.js_types.JsValue

enum LogLevel:
    Trace
    Debug
    Info
    Warn
    Error

class JsError:
    message: text
    name: text
    stack: text

class BrowserError:
    code: i64
    message: text

class BrowserResult:
    ok: bool
    value: JsValue
    error: BrowserError?

class Logger:
    name: text

    static fn new(name: text, level: LogLevel) -> Logger:
        Logger(name: name)

    fn level_tag(l: LogLevel) -> text:
        match l:
            LogLevel.Trace: "TRACE"
            LogLevel.Debug: "DEBUG"
            LogLevel.Info: "INFO"
            LogLevel.Warn: "WARN"
            LogLevel.Error: "ERROR"

    fn should_log(msg_level: LogLevel) -> bool:
        true

    me log(msg_level: LogLevel, msg: text):
        if self.should_log(msg_level):
            val tag = self.level_tag(msg_level)
            print "[{tag}] [{self.name}] {msg}"

    me trace(msg: text):
        self.log(LogLevel.Trace, msg)

    me debug(msg: text):
        self.log(LogLevel.Debug, msg)

    me info(msg: text):
        self.log(LogLevel.Info, msg)

    me warn(msg: text):
        self.log(LogLevel.Warn, msg)

    me error(msg: text):
        self.log(LogLevel.Error, msg)

fn script_error(msg: text) -> JsError:
    JsError(message: msg, name: "Error", stack: msg)

fn js_nan() -> f64:
    0.0 / 0.0

fn js_infinity() -> f64:
    1.0 / 0.0

fn js_neg_infinity() -> f64:
    -1.0 / 0.0

fn is_nan(v: f64) -> bool:
    v != v
