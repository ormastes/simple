    me _node_package_main_key(package_name: text) -> text:
        var key = "__simple_node_package_main_"
        var i = 0
        while i < package_name.len():
            val ch = package_name.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
