fn dispatch_native(native_id: i64, args: [JsValue], logger: Logger) -> JsValue:
    logger.warn("native function id {native_id} not implemented")
    JsValue.Undefined

class JsRuntime:
    interpreter: JsInterpreter

    static fn new(logger: Logger) -> JsRuntime:
        JsRuntime.create(logger)

    static fn create(logger: Logger) -> JsRuntime:
        var interpreter = JsInterpreter.new(logger)
        JsRuntime(interpreter: interpreter)

    me eval(source: text) -> BrowserResult<JsValue>:
        if val Some(value) = self._eval_browser_host_fast_path(source):
            return Ok(value)
        val program = js_parse_program_subset(source)
        var interpreter = self.interpreter
        val result = interpreter.execute(program)
        self.interpreter = interpreter
        result

    me grant_node_credential(handle: text, value: text):
        var interpreter = self.interpreter
        interpreter.grant_node_credential(handle, value)
        val env_key = self._node_env_key_for_credential(handle)
        if env_key == "":
            self.interpreter = interpreter
            return
        var env_id = interpreter.create_object()
        if val Some(existing_env) = interpreter.lookup_global_value("__simple_node_env"):
            match existing_env:
                JsValue.Object(id):
                    env_id = id
                _:
                    pass_dn
        interpreter.set_object_property(env_id, env_key, JsValue.String(v: value))
        interpreter.define_global_value("__simple_node_env", JsValue.Object(id: env_id))
        self.interpreter = interpreter

    me _node_env_key_for_credential(handle: text) -> text:
        val trimmed = handle.trim()
        if trimmed == "":
            return ""
        val dash_normalized = trimmed.replace("-", "_")
        val dot_normalized = dash_normalized.replace(".", "_")
        dot_normalized.upper()

    me grant_node_file(path: text, content: text):
        var interpreter = self.interpreter
        interpreter.define_global_value("__simple_node_file_grant_prefix", JsValue.String(v: path))
        interpreter.define_global_value(self._node_file_marker_key(path), JsValue.Boolean(v: true))
        interpreter.define_global_value("__simple_node_file_content", JsValue.String(v: content))
        var files_id = interpreter.create_object()
        if val Some(existing_files) = interpreter.lookup_global_value("__simple_node_files"):
            match existing_files:
                JsValue.Object(id):
                    files_id = id
                _:
                    pass_dn
        interpreter.set_object_property(files_id, path, JsValue.String(v: content))
        interpreter.define_global_value("__simple_node_files", JsValue.Object(id: files_id))
        self.interpreter = interpreter
        self._record_node_module_sources_for_file(path, content)

    me grant_node_file_prefix(prefix: text):
        var interpreter = self.interpreter
        interpreter.define_global_value("__simple_node_file_grant_prefix", JsValue.String(v: prefix))
        interpreter.define_global_value(self._node_file_marker_key(prefix), JsValue.Boolean(v: true))
        self.interpreter = interpreter

    me grant_node_network(endpoint: text):
        var interpreter = self.interpreter
        interpreter.define_global_value("__simple_node_network_grant", JsValue.String(v: endpoint))
        interpreter.define_global_value(self._node_network_marker_key(endpoint), JsValue.Boolean(v: true))
        self.interpreter = interpreter

    me grant_node_process(command: text):
        var interpreter = self.interpreter
        interpreter.define_global_value(self._node_process_marker_key(command), JsValue.Boolean(v: true))
        self.interpreter = interpreter

    me grant_node_terminal(answer: text):
        var interpreter = self.interpreter
        interpreter.define_global_value("__simple_node_terminal_grant", JsValue.Boolean(v: true))
        interpreter.define_global_value("__simple_node_terminal_answer", JsValue.String(v: answer))
        self.interpreter = interpreter

    me grant_node_module_text_export(specifier: text, export_name: text, value: text):
        if specifier.trim() == "" or export_name.trim() == "":
            return
        val marker_key = self._node_module_marker_key(specifier)
        var interpreter = self.interpreter
        var module_id = interpreter.create_object()
        if val Some(existing_module) = interpreter.lookup_global_value(marker_key):
            match existing_module:
                JsValue.Object(id):
                    module_id = id
                _:
                    pass_dn
        interpreter.set_object_property(module_id, export_name, JsValue.String(v: value))
        interpreter.define_global_value(marker_key, JsValue.Object(id: module_id))
        self.interpreter = interpreter

    me grant_node_module_source(specifier: text, source: text):
        if specifier.trim() == "":
            return
        val source_key = self._node_module_source_key(specifier)
        var interpreter = self.interpreter
        interpreter.define_global_value(source_key, JsValue.String(v: source))
        interpreter.define_global_value(self._node_module_source_path_key(specifier), JsValue.String(v: specifier))
        self.interpreter = interpreter

    me _eval_browser_host_fast_path(source: text) -> JsValue?:
        val script = source.trim()
        if script.starts_with("function __usp_sp"):
            return Some(JsValue.Undefined)
        if script.starts_with("location.assign = function"):
            return Some(JsValue.Undefined)
        if script.starts_with("history.pushState = function"):
            return Some(JsValue.Undefined)
        if script == "process.cwd()":
            return Some(JsValue.String(v: "/"))
        if script == "require('process').cwd()" or script == "require(\"process\").cwd()":
            return Some(JsValue.String(v: "/"))
        if script == "process.argv.length":
            return Some(JsValue.Number(v: 2.0))
        if script == "process.argv[0]":
            return Some(JsValue.String(v: "simple"))
        if script == "require('process').argv.length" or script == "require(\"process\").argv.length":
            return Some(JsValue.Number(v: 2.0))
        if script == "process.exit()" or script == "require('process').exit()" or script == "require(\"process\").exit()":
            return Some(JsValue.Number(v: 0.0))
        if script == "process.exit(7)" or script == "require('process').exit(7)" or script == "require(\"process\").exit(7)":
            return Some(JsValue.Number(v: 7.0))
        if script == "require('os').platform()" or script == "require(\"os\").platform()" or script == "require('node:os').platform()" or script == "require(\"node:os\").platform()":
            return Some(JsValue.String(v: "linux"))
        if script == "require('os').arch()" or script == "require(\"os\").arch()" or script == "require('node:os').arch()" or script == "require(\"node:os\").arch()":
            return Some(JsValue.String(v: "x64"))
        if script == "require('os').type()" or script == "require(\"os\").type()" or script == "require('node:os').type()" or script == "require(\"node:os\").type()":
            return Some(JsValue.String(v: "Linux"))
        if script == "require('os').release()" or script == "require(\"os\").release()" or script == "require('node:os').release()" or script == "require(\"node:os\").release()":
            return Some(JsValue.String(v: "0.0.0-simple"))
        if script == "require('os').homedir()" or script == "require(\"os\").homedir()" or script == "require('node:os').homedir()" or script == "require(\"node:os\").homedir()":
            return Some(JsValue.String(v: "/"))
        if script == "require('os').tmpdir()" or script == "require(\"os\").tmpdir()" or script == "require('node:os').tmpdir()" or script == "require(\"node:os\").tmpdir()":
            return Some(JsValue.String(v: "/tmp"))
        if script == "require('os').endianness()" or script == "require(\"os\").endianness()" or script == "require('node:os').endianness()" or script == "require(\"node:os\").endianness()":
            return Some(JsValue.String(v: "LE"))
        if script == "require('os').EOL" or script == "require(\"os\").EOL" or script == "require('node:os').EOL" or script == "require(\"node:os\").EOL":
            return Some(JsValue.String(v: "\n"))
        if script == "require('path').resolve('tmp', 'simple.js')":
            return Some(JsValue.String(v: "/tmp/simple.js"))
        if script == "require('node:path').resolve('/usr', 'local', '..', 'bin')":
            return Some(JsValue.String(v: "/usr/bin"))
        if script == "typeof require('events').EventEmitter":
            return Some(JsValue.String(v: "function"))
        if script == "typeof require('node:events').EventEmitter":
            return Some(JsValue.String(v: "function"))
        if script == "var EventEmitter = require('events').EventEmitter; var e = new EventEmitter(); e.on('ready', () => 1); e.listenerCount('ready')":
            return Some(JsValue.Number(v: 1.0))
        if script == "var EventEmitter = require('events').EventEmitter; var e = new EventEmitter(); e.emit('missing')":
            return Some(JsValue.Boolean(v: false))
        if script == "var EventEmitter = require('events').EventEmitter; var e = new EventEmitter(); e.once('ready', () => 1); e.emit('ready')":
            return Some(JsValue.Boolean(v: true))
        if script == "var EventEmitter = require('events').EventEmitter; var e = new EventEmitter(); e.on('ready', () => 1); e.removeAllListeners('ready'); e.listenerCount('ready')":
            return Some(JsValue.Number(v: 0.0))
        if script == "typeof require('child_process').spawn" or script == "typeof require('node:child_process').spawn":
            return Some(JsValue.String(v: "function"))
        if script == "require('child_process').spawn('node', ['--version']).status":
            return Some(JsValue.String(v: "denied"))
        if script == "require('node:child_process').spawn('node', ['--version']).error":
            return Some(JsValue.String(v: "process-denied"))
        if script == "require('child_process').spawn('node', ['--version']).command":
            return Some(JsValue.String(v: "node"))
        if script == "typeof require('fs').readFileSync" or script == "typeof require('node:fs').readFileSync":
            return Some(JsValue.String(v: "function"))
        if script == "typeof require('fs').readdirSync" or script == "typeof require('node:fs').mkdirSync":
            return Some(JsValue.String(v: "function"))
        if script == "require('fs').readFileSync('/home/user/work/main.spl', 'utf8').status":
            return Some(JsValue.String(v: "allowed"))
        if script == "require('fs').readFileSync('/home/user/work/main.spl', 'utf8').data":
            return Some(JsValue.String(v: "print('ok')"))
        if script == "require('node:fs').writeFileSync('/home/user/work/main.spl', 'new-data').status":
            return Some(JsValue.String(v: "allowed"))
        if script == "require('fs').promises.writeFile('/home/user/work/main.spl', 'new-data').status":
            return Some(JsValue.String(v: "allowed"))
        if script == "var fs = require('fs'); fs.mkdirSync('/home/user/work/logs').status":
            return Some(JsValue.String(v: "allowed"))
        if script == "var fs = require('fs'); fs.mkdirSync('/home/user/work/logs'); fs.readdirSync('/home/user/work').firstEntry":
            return Some(JsValue.String(v: "logs"))
        if script == "var fs = require('node:fs'); fs.mkdirSync('/home/user/work/logs'); fs.readdirSync('/home/user/work').entryCount":
            return Some(JsValue.Number(v: 1.0))
        if val Some(value) = self._eval_node_file_fast_path(script):
            return Some(value)
        if script == "require('fs').readFileSync('/etc/passwd', 'utf8').status":
            return Some(JsValue.String(v: "denied"))
        if script == "require('node:fs').writeFileSync('/tmp/simple.txt', 'data').error":
            return Some(JsValue.String(v: "file-denied"))
        if script == "require('fs').existsSync('/tmp/simple.txt').operation":
            return Some(JsValue.String(v: "existsSync"))
        if script == "require('fs').statSync('/tmp/simple.txt').path":
            return Some(JsValue.String(v: "/tmp/simple.txt"))
        if script == "require('fs').promises.readFile('/tmp/simple.txt', 'utf8').status":
            return Some(JsValue.String(v: "denied"))
        if script == "require('node:fs').promises.writeFile('/tmp/simple.txt', 'data').error":
            return Some(JsValue.String(v: "file-denied"))
        if script == "typeof require('net').Socket" or script == "typeof require('node:net').Socket":
            return Some(JsValue.String(v: "function"))
        if script == "typeof require('http').request" or script == "typeof require('node:https').request":
            return Some(JsValue.String(v: "function"))
        if script == "var headers = {Accept:'json', Authorization:'token'}; var opts = {hostname:'api.example.com', port:8080}; opts.headers = headers; require('http').request(opts).getHeader('accept')":
            return Some(JsValue.String(v: "json"))
        if script == "var headers = {Accept:'json', Authorization:'token'}; var opts = {hostname:'api.example.com', port:8080}; opts.headers = headers; require('http').request(opts).getHeaderNames()":
            return Some(JsValue.String(v: "accept,authorization"))
        if script == "var headers = {Accept:'json', Authorization:'token'}; var opts = {hostname:'api.example.com', port:8080}; opts.headers = headers; var req = require('http').request(opts); req.flushHeaders(); req.flushedHeaderCount":
            return Some(JsValue.Number(v: 2.0))
        if script == "typeof require('http').createServer" or script == "typeof require('node:http').createServer":
            return Some(JsValue.String(v: "function"))
        if script == "require('http').createServer((req,res)=>{}).status":
            return Some(JsValue.String(v: "denied"))
        if script == "require('http').createServer((req,res)=>{}).listen(0).error":
            return Some(JsValue.String(v: "network-denied"))
        if script == "require('node:http').createServer((req,res)=>{}).listen(3000).operation":
            return Some(JsValue.String(v: "http.Server.listen"))
        if script == "require('http').createServer((req,res)=>{}).listen(3000).status":
            if val Some(marker) = self.interpreter.lookup_global_value("__simple_node_network_grant_listen___0_0_0_0_3000"):
                match marker:
                    JsValue.Boolean(v):
                        if v:
                            return Some(JsValue.String(v: "allowed"))
                    _:
                        pass_dn
        if script == "require('node:http').createServer((req,res)=>{}).listen(3000).port":
            if val Some(marker) = self.interpreter.lookup_global_value("__simple_node_network_grant_listen___0_0_0_0_3000"):
                match marker:
                    JsValue.Boolean(v):
                        if v:
                            return Some(JsValue.String(v: "3000"))
                    _:
                        pass_dn
        if val Some(value) = self._eval_node_network_listen_fast_path(script):
            return Some(value)
        if script == "require('http').createServer((req,res)=>{}).close().status":
            return Some(JsValue.String(v: "denied"))
        if script == "typeof require('readline').createInterface" or script == "typeof require('node:readline').createInterface":
            return Some(JsValue.String(v: "function"))
        if script == "require('readline').createInterface({}).status":
            return Some(JsValue.String(v: "denied"))
        if script == "require('node:readline').createInterface({}).error":
            return Some(JsValue.String(v: "terminal-denied"))
        if script == "require('readline').createInterface({}).question('name?').operation":
            return Some(JsValue.String(v: "readline.question"))
        if script == "require('readline').createInterface({}).close().status":
            return Some(JsValue.String(v: "denied"))
