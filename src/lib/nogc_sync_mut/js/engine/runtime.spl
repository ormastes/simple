    me _eval_node_file_fast_path(script: text) -> JsValue?:
        if not script.starts_with("require('fs').") and not script.starts_with("require('node:fs').") and not script.starts_with("require(\"fs\").") and not script.starts_with("require(\"node:fs\")."):
            return nil
        var operation = ""
        var token = ""
        if script.contains(".readFileSync("):
            operation = "readFileSync"
            token = ".readFileSync("
        elif script.contains(".writeFileSync("):
            operation = "writeFileSync"
            token = ".writeFileSync("
        elif script.contains(".existsSync("):
            operation = "existsSync"
            token = ".existsSync("
        elif script.contains(".statSync("):
            operation = "statSync"
            token = ".statSync("
        elif script.contains(".readdirSync("):
            operation = "readdirSync"
            token = ".readdirSync("
        elif script.contains(".mkdirSync("):
            operation = "mkdirSync"
            token = ".mkdirSync("
        elif script.contains(".promises.readFile("):
            operation = "promises.readFile"
            token = ".promises.readFile("
        elif script.contains(".promises.writeFile("):
            operation = "promises.writeFile"
            token = ".promises.writeFile("
        else:
            return nil
        val path = self._node_file_arg_after(script, token)
        if path == "":
            return nil
        var prop = ""
        if script.ends_with(".status"):
            prop = "status"
        elif script.ends_with(".error"):
            prop = "error"
        elif script.ends_with(".reason"):
            prop = "reason"
        elif script.ends_with(".path"):
            prop = "path"
        elif script.ends_with(".operation"):
            prop = "operation"
        elif script.ends_with(".data"):
            prop = "data"
        elif script.ends_with(".entryCount"):
            prop = "entryCount"
        elif script.ends_with(".firstEntry"):
            prop = "firstEntry"
        else:
            return nil
        val reason = self._node_file_denial_reason(path)
        if operation == "readdirSync" and script.contains(".mkdirSync("):
            val mkdir_path = self._node_file_arg_after(script, ".mkdirSync(")
            if self._node_file_denial_reason(mkdir_path) == "":
                self._node_record_dir_for_created_path(mkdir_path)
        if prop == "operation":
            return Some(JsValue.String(v: operation))
        if prop == "path":
            return Some(JsValue.String(v: path))
        if reason != "":
            if prop == "status":
                return Some(JsValue.String(v: "denied"))
            if prop == "error":
                return Some(JsValue.String(v: "file-denied"))
            if prop == "reason":
                return Some(JsValue.String(v: reason))
            if prop == "data":
                return Some(JsValue.Undefined)
            if prop == "entryCount":
                return Some(JsValue.Number(v: 0.0))
            if prop == "firstEntry":
                return Some(JsValue.String(v: ""))
        else:
            if operation == "mkdirSync":
                self._node_record_dir_for_created_path(path)
            if prop == "status":
                return Some(JsValue.String(v: "allowed"))
            if prop == "error" or prop == "reason":
                return Some(JsValue.String(v: ""))
            if prop == "data":
                if val Some(content_value) = self.interpreter.lookup_global_value("__simple_node_file_content"):
                    match content_value:
                        JsValue.String(content):
                            return Some(JsValue.String(v: content))
                        _:
                            pass_dn
                return Some(JsValue.String(v: ""))
            if prop == "entryCount":
                return Some(JsValue.Number(v: self._node_dir_entry_count(path).to_f64()))
            if prop == "firstEntry":
                return Some(JsValue.String(v: self._node_dir_first_entry(path)))
        nil

    me _node_record_dir_for_created_path(path: text):
        val parent = self._node_parent_dir(path)
        val entry = self._node_basename(path)
        if parent == "" or entry == "":
            return
        var interpreter = self.interpreter
        if self._node_dir_first_entry(parent) == "":
            interpreter.define_global_value(self._node_dir_key("__simple_node_dir_first_", parent), JsValue.String(v: entry))
        val count = self._node_dir_entry_count(parent)
        interpreter.define_global_value(self._node_dir_key("__simple_node_dir_count_", parent), JsValue.Number(v: (count + 1).to_f64()))
        self.interpreter = interpreter

    me _node_dir_entry_count(path: text) -> i64:
        if val Some(value) = self.interpreter.lookup_global_value(self._node_dir_key("__simple_node_dir_count_", path)):
            match value:
                JsValue.Number(v):
                    return v.to_i64()
                _:
                    pass_dn
        0

    me _node_dir_first_entry(path: text) -> text:
        if val Some(value) = self.interpreter.lookup_global_value(self._node_dir_key("__simple_node_dir_first_", path)):
            match value:
                JsValue.String(v):
                    return v
                _:
                    pass_dn
        ""

    me _node_parent_dir(path: text) -> text:
        var last_slash = -1
        var i = 0
        while i < path.len():
            if path.substring(i, i + 1) == "/":
                last_slash = i
            i = i + 1
        if last_slash <= 0:
            return "/"
        path.substring(0, last_slash)

    me _node_basename(path: text) -> text:
        var last_slash = -1
        var i = 0
        while i < path.len():
            if path.substring(i, i + 1) == "/":
                last_slash = i
            i = i + 1
        if last_slash < 0:
            return path
        if last_slash + 1 >= path.len():
            return ""
        path.substring(last_slash + 1, path.len())

    me _node_dir_key(prefix: text, path: text) -> text:
        var key = prefix
        var i = 0
        while i < path.len():
            val ch = path.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
            else:
                key = key + "_"
            i = i + 1
        key

    me _node_file_marker_key(path: text) -> text:
        self._node_dir_key("__simple_node_file_grant_", path)

    me _node_file_arg_after(script: text, token: text) -> text:
        match script.index_of(token):
            Some(idx):
                var start = idx + token.len()
                if start >= script.len():
                    return ""
                val quote = script.substring(start, start + 1)
                if quote != "'" and quote != "\"":
                    return ""
                start = start + 1
                var end = start
                while end < script.len():
                    if script.substring(end, end + 1) == quote:
                        return script.substring(start, end)
                    end = end + 1
            nil:
                pass_dn
        ""

    me _node_file_denial_reason(path: text) -> text:
        if path == "" or not path.starts_with("/"):
            return "invalid-path"
        if self._node_file_path_allowed(path):
            return ""
        "file-grant-denied"

    me _node_file_path_allowed(path: text) -> bool:
        if val Some(grant_value) = self.interpreter.lookup_global_value("__simple_node_file_grant_prefix"):
            match grant_value:
                JsValue.String(grant):
                    if grant == "":
                        return false
                    if self._text_exact(path, grant):
                        return true
                    if path.len() > grant.len() and self._text_exact(path.substring(0, grant.len()), grant):
                        if grant.ends_with("/"):
                            return true
                        return path.substring(grant.len(), grant.len() + 1) == "/"
                _:
                    pass_dn
        false

    me _node_network_denial_reason_for_marker(endpoint: text, marker_key: text) -> text:
        if endpoint == "" or not endpoint.contains("://") or not endpoint.contains(":"):
            return "invalid-endpoint"
        if val Some(marker) = self.interpreter.lookup_global_value(marker_key):
            match marker:
                JsValue.Boolean(v):
                    if v:
                        return ""
                _:
                    pass_dn
        "network-grant-denied"

    me _eval_node_network_listen_fast_path(script: text) -> JsValue?:
        var endpoint = ""
        var marker_key = ""
        if script.starts_with("require('http').createServer((req,res)=>{}).listen(3000)") or script.starts_with("require(\"http\").createServer((req,res)=>{}).listen(3000)"):
            endpoint = "listen://0.0.0.0:3000"
            marker_key = "__simple_node_network_grant_listen___0_0_0_0_3000"
        elif script.starts_with("require('node:http').createServer((req,res)=>{}).listen(3000)") or script.starts_with("require(\"node:http\").createServer((req,res)=>{}).listen(3000)"):
            endpoint = "listen://0.0.0.0:3000"
            marker_key = "__simple_node_network_grant_listen___0_0_0_0_3000"
        elif script.starts_with("require('http').createServer((req,res)=>{}).listen(0)") or script.starts_with("require(\"http\").createServer((req,res)=>{}).listen(0)"):
            endpoint = "listen://0.0.0.0:0"
            marker_key = "__simple_node_network_grant_listen___0_0_0_0_0"
        else:
            return nil
        var prop = ""
        if script.ends_with(".status"):
            prop = "status"
        elif script.ends_with(".error"):
            prop = "error"
        elif script.ends_with(".reason"):
            prop = "reason"
        elif script.ends_with(".operation"):
            prop = "operation"
        elif script.ends_with(".port"):
            prop = "port"
        else:
            return nil
        val reason = self._node_network_denial_reason_for_marker(endpoint, marker_key)
        if prop == "operation":
            return Some(JsValue.String(v: "http.Server.listen"))
        if prop == "port":
            if endpoint.ends_with(":3000"):
                return Some(JsValue.String(v: "3000"))
            return Some(JsValue.String(v: "0"))
        if reason != "":
            if prop == "status":
                return Some(JsValue.String(v: "denied"))
            if prop == "error":
                return Some(JsValue.String(v: "network-denied"))
            if prop == "reason":
                return Some(JsValue.String(v: reason))
        else:
            if prop == "status":
                return Some(JsValue.String(v: "allowed"))
            if prop == "error" or prop == "reason":
                return Some(JsValue.String(v: ""))
        nil

    me _node_network_marker_key(endpoint: text) -> text:
        var key = "__simple_node_network_grant_"
        var i = 0
        while i < endpoint.len():
            val ch = endpoint.substring(i, i + 1)
            if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
                key = key + ch.lower()
            else:
                key = key + "_"
            i = i + 1
        key

