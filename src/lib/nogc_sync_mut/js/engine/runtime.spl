        if script == "new TextDecoder('utf8').encoding" or script == "new TextDecoder(\"utf8\").encoding":
            return Some(JsValue.String(v: "utf-8"))
        nil

    me create_host_object() -> i64:
        self.interpreter.create_object()

    me set_host_property(obj_id: i64, key: text, value: JsValue):
        self.interpreter.set_object_property(obj_id, key, value)

    me get_host_property(obj_id: i64, key: text) -> JsValue:
        self.interpreter.object_store.get_property(obj_id, key)

    me get_host_object(obj_id: i64) -> JsObject:
        self.interpreter.object_store.get_object(obj_id)

    me _define_method_on(obj_id: i64, method_name: text, native_id: i64):
        self.interpreter._define_method_on(obj_id, method_name, native_id)

    me _define_global_native(name: text, native_id: i64):
        self.interpreter._define_global_native(name, native_id)

    me drain_due_timers(current_time_ms: i64) -> i64:
        self.interpreter.drain_due_timers(current_time_ms)

    me drain_pending_microtasks() -> bool:
        self.interpreter.drain_pending_microtasks()
