    me _record_node_module_sources_for_file(path: text, content: text):
        var interpreter = self.interpreter
        interpreter.define_global_value(self._node_module_source_key(path), JsValue.String(v: content))
        interpreter.define_global_value(self._node_module_source_path_key(path), JsValue.String(v: path))
        val package_name = self._node_package_name_from_path(path)
        if package_name == "":
            self.interpreter = interpreter
            return
        val package_file = self._node_package_file_from_path(path)
        if package_file == "index.js":
            interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: content))
            interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: path))
            self.interpreter = interpreter
            return
        val main_key = self._node_package_main_key(package_name)
        if package_file == "package.json":
            val main_entry = self._node_package_json_main(content)
            if main_entry != "":
                interpreter.define_global_value(main_key, JsValue.String(v: main_entry))
                val main_path = "/node_modules/" + package_name + "/" + main_entry
                if val Some(files_value) = interpreter.lookup_global_value("__simple_node_files"):
                    match files_value:
                        JsValue.Object(files_id):
                            match interpreter.get_object_property_exact_key(files_id, main_path):
                                JsValue.String(main_content):
                                    interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: main_content))
                                    interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: main_path))
                                _:
                                    val main_js_path = main_path + ".js"
                                    match interpreter.get_object_property_exact_key(files_id, main_js_path):
                                        JsValue.String(main_js_content):
                                            interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: main_js_content))
                                            interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: main_js_path))
                                        _:
                                            pass_dn
                        _:
                            pass_dn
            self.interpreter = interpreter
            return
        var matched_main = false
        if val Some(main_value) = interpreter.lookup_global_value(main_key):
            match main_value:
                JsValue.String(main_entry):
                    if package_file == main_entry or (not main_entry.ends_with(".js") and package_file == main_entry + ".js"):
                        interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: content))
                        interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: path))
                        matched_main = true
                _:
                    pass_dn
        if not matched_main:
            val package_path = "/node_modules/" + package_name + "/package.json"
            if val Some(files_value) = interpreter.lookup_global_value("__simple_node_files"):
                match files_value:
                    JsValue.Object(files_id):
                        match interpreter.get_object_property_exact_key(files_id, package_path):
                            JsValue.String(package_json):
                                val main_entry = self._node_package_json_main(package_json)
                                if main_entry != "":
                                    if package_file == main_entry or (not main_entry.ends_with(".js") and package_file == main_entry + ".js"):
                                        interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: content))
                                        interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: path))
                                val quoted_package_file = "\"" + package_file + "\""
                                if package_json.contains(quoted_package_file):
                                    interpreter.define_global_value(self._node_module_source_key(package_name), JsValue.String(v: content))
                                    interpreter.define_global_value(self._node_module_source_path_key(package_name), JsValue.String(v: path))
                            _:
