# JsInterpreter — string method dispatch and function invocation.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.js_types.JsValue
use std.js.types.ast_types.JsExpression
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm_object_store.{ObjectStore}
use std.nogc_sync_mut.js.engine.interpreter.{JsInterpreter}
use std.nogc_sync_mut.js.engine.interpreter_object.{JsInterpreter}
use std.nogc_sync_mut.js.engine.interpreter_exec.{JsInterpreter}

impl JsInterpreter:
    # String method dispatch
    me _dispatch_string_method(str_val: text, method: text, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        if method == "indexOf":
            if args.len() > 0:
                val search = self.eval_expression(args.get(0), env)?
                val search_str = js_to_string(search)
                val slen = str_val.len()
                val needle_len = search_str.len()
                if needle_len == 0:
                    return Ok(JsValue.Number(v: 0.0))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_str[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        return Ok(JsValue.Number(v: i.to_f64()))
                    i = i + 1
            return Ok(JsValue.Number(v: -1.0))

        if method == "lastIndexOf":
            if args.len() > 0:
                val search = self.eval_expression(args.get(0), env)?
                val search_str = js_to_string(search)
                val slen = str_val.len()
                val needle_len = search_str.len()
                if needle_len == 0:
                    return Ok(JsValue.Number(v: slen.to_f64()))
                var last_found = -1
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_str[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        last_found = i
                    i = i + 1
                return Ok(JsValue.Number(v: last_found.to_f64()))
            return Ok(JsValue.Number(v: -1.0))

        if method == "toLowerCase":
            var result = ""
            val upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            val lower = "abcdefghijklmnopqrstuvwxyz"
            var i = 0
            val slen = str_val.len()
            while i < slen:
                val ch = str_val[i]
                var found = -1
                var j = 0
                while j < 26:
                    if upper[j] == ch:
                        found = j
                        j = 26
                    j = j + 1
                if found >= 0:
                    result = result + lower[found]
                else:
                    result = result + ch
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "toUpperCase":
            var result = ""
            val upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            val lower = "abcdefghijklmnopqrstuvwxyz"
            var i = 0
            val slen = str_val.len()
            while i < slen:
                val ch = str_val[i]
                var found = -1
                var j = 0
                while j < 26:
                    if lower[j] == ch:
                        found = j
                        j = 26
                    j = j + 1
                if found >= 0:
                    result = result + upper[found]
                else:
                    result = result + ch
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trim":
            var start = 0
            var end = str_val.len()
            while start < end and (str_val[start] == " " or str_val[start] == "\t" or str_val[start] == "\n"):
                start = start + 1
            while end > start and (str_val[end - 1] == " " or str_val[end - 1] == "\t" or str_val[end - 1] == "\n"):
                end = end - 1
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trimStart":
            var start = 0
            val end = str_val.len()
            while start < end and (str_val[start] == " " or str_val[start] == "\t" or str_val[start] == "\n"):
                start = start + 1
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "trimEnd":
            var end = str_val.len()
            while end > 0 and (str_val[end - 1] == " " or str_val[end - 1] == "\t" or str_val[end - 1] == "\n"):
                end = end - 1
            var result = ""
            var i = 0
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "split":
            var sep = ""
            if args.len() > 0:
                val sep_val = self.eval_expression(args.get(0), env)?
                sep = js_to_string(sep_val)
            val result_id = self.create_object()
            if sep == "":
                # Split each character
                var i = 0
                val slen = str_val.len()
                while i < slen:
                    self.set_object_property(result_id, "{i}", JsValue.String(v: str_val[i]))
                    i = i + 1
                self.set_object_property(result_id, "length", JsValue.Number(v: slen.to_f64()))
            else:
                # Split by separator
                var parts = 0
                var start = 0
                val slen = str_val.len()
                val sep_len = sep.len()
                var i = 0
                while i <= slen - sep_len:
                    var matched = true
                    var j = 0
                    while j < sep_len:
                        if str_val[i + j] != sep[j]:
                            matched = false
                            j = sep_len
                        j = j + 1
                    if matched:
                        var part = ""
                        var pi = start
                        while pi < i:
                            part = part + str_val[pi]
                            pi = pi + 1
                        self.set_object_property(result_id, "{parts}", JsValue.String(v: part))
                        parts = parts + 1
                        start = i + sep_len
                        i = start
                    else:
                        i = i + 1
                # Last part
                var last = ""
                var li = start
                while li < slen:
                    last = last + str_val[li]
                    li = li + 1
                self.set_object_property(result_id, "{parts}", JsValue.String(v: last))
                parts = parts + 1
                self.set_object_property(result_id, "length", JsValue.Number(v: parts.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "slice" or method == "substring":
            var start = 0
            var end = str_val.len()
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = str_val.len() + start
                    if start < 0:
                        start = 0
            if args.len() > 1:
                val e = self.eval_expression(args.get(1), env)?
                end = f64_to_i64(to_number(e))
                if end < 0:
                    end = str_val.len() + end
            if end > str_val.len():
                end = str_val.len()
            var result = ""
            var i = start
            while i < end:
                result = result + str_val[i]
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "charAt":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                val idx = f64_to_i64(to_number(idx_val))
                if idx >= 0 and idx < str_val.len():
                    return Ok(JsValue.String(v: str_val[idx]))
            return Ok(JsValue.String(v: ""))

        if method == "charCodeAt":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                val idx = f64_to_i64(to_number(idx_val))
                if idx >= 0 and idx < str_val.len():
                    val ch = str_val[idx]
                    return Ok(JsValue.Number(v: ch.char_code_at(0).to_f64()))
            return Ok(JsValue.Number(v: js_nan()))

        if method == "startsWith":
            if args.len() > 0:
                val prefix_val = self.eval_expression(args.get(0), env)?
                val prefix = js_to_string(prefix_val)
                if prefix.len() > str_val.len():
                    return Ok(JsValue.Boolean(v: false))
                var i = 0
                var matched = true
                while i < prefix.len():
                    if str_val[i] != prefix[i]:
                        matched = false
                        i = prefix.len()
                    i = i + 1
                return Ok(JsValue.Boolean(v: matched))
            return Ok(JsValue.Boolean(v: true))

        if method == "endsWith":
            if args.len() > 0:
                val suffix_val = self.eval_expression(args.get(0), env)?
                val suffix = js_to_string(suffix_val)
                if suffix.len() > str_val.len():
                    return Ok(JsValue.Boolean(v: false))
                val offset = str_val.len() - suffix.len()
                var i = 0
                var matched = true
                while i < suffix.len():
                    if str_val[offset + i] != suffix[i]:
                        matched = false
                        i = suffix.len()
                    i = i + 1
                return Ok(JsValue.Boolean(v: matched))
            return Ok(JsValue.Boolean(v: true))

        if method == "includes":
            if args.len() > 0:
                val search_val = self.eval_expression(args.get(0), env)?
                val search_s = js_to_string(search_val)
                val slen = str_val.len()
                val needle_len = search_s.len()
                if needle_len == 0:
                    return Ok(JsValue.Boolean(v: true))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_s[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        return Ok(JsValue.Boolean(v: true))
                    i = i + 1
            return Ok(JsValue.Boolean(v: false))

        if method == "replace":
            if args.len() >= 2:
                val search_val = self.eval_expression(args.get(0), env)?
                val replace_val = self.eval_expression(args.get(1), env)?
                val search_s = js_to_string(search_val)
                val replace_str = js_to_string(replace_val)
                val slen = str_val.len()
                val needle_len = search_s.len()
                if needle_len == 0:
                    return Ok(JsValue.String(v: replace_str + str_val))
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search_s[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        var result = ""
                        var bi = 0
                        while bi < i:
                            result = result + str_val[bi]
                            bi = bi + 1
                        result = result + replace_str
                        var ai = i + needle_len
                        while ai < slen:
                            result = result + str_val[ai]
                            ai = ai + 1
                        return Ok(JsValue.String(v: result))
                    i = i + 1
            return Ok(JsValue.String(v: str_val))

        if method == "replaceAll":
            if args.len() >= 2:
                val search_val = self.eval_expression(args.get(0), env)?
                val replace_val = self.eval_expression(args.get(1), env)?
                val search = js_to_string(search_val)
                val replace_str = js_to_string(replace_val)
                val slen = str_val.len()
                val needle_len = search.len()
                if needle_len == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = ""
                var i = 0
                while i <= slen - needle_len:
                    var matched = true
                    var j = 0
                    while j < needle_len:
                        if str_val[i + j] != search[j]:
                            matched = false
                            j = needle_len
                        j = j + 1
                    if matched:
                        result = result + replace_str
                        i = i + needle_len
                    else:
                        result = result + str_val[i]
                        i = i + 1
                while i < slen:
                    result = result + str_val[i]
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "repeat":
            if args.len() > 0:
                val count_val = self.eval_expression(args.get(0), env)?
                val count = f64_to_i64(to_number(count_val))
                var result = ""
                var i = 0
                while i < count:
                    result = result + str_val
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: ""))

        if method == "padStart":
            if args.len() > 0:
                val target_len_val = self.eval_expression(args.get(0), env)?
                val target_len = f64_to_i64(to_number(target_len_val))
                var pad_str = " "
                if args.len() > 1:
                    val ps = self.eval_expression(args.get(1), env)?
                    pad_str = js_to_string(ps)
                if pad_str.len() == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = ""
                val needed = target_len - str_val.len()
                var i = 0
                while i < needed:
                    result = result + pad_str[i % pad_str.len()]
                    i = i + 1
                result = result + str_val
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "padEnd":
            if args.len() > 0:
                val target_len_val = self.eval_expression(args.get(0), env)?
                val target_len = f64_to_i64(to_number(target_len_val))
                var pad_str = " "
                if args.len() > 1:
                    val ps = self.eval_expression(args.get(1), env)?
                    pad_str = js_to_string(ps)
                if pad_str.len() == 0:
                    return Ok(JsValue.String(v: str_val))
                var result = str_val
                val needed = target_len - str_val.len()
                var i = 0
                while i < needed:
                    result = result + pad_str[i % pad_str.len()]
                    i = i + 1
                return Ok(JsValue.String(v: result))
            return Ok(JsValue.String(v: str_val))

        if method == "concat":
            var result = str_val
            var i = 0
            while i < args.len():
                val arg_val = self.eval_expression(args.get(i), env)?
                result = result + js_to_string(arg_val)
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "at":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                var idx = f64_to_i64(to_number(idx_val))
                if idx < 0:
                    idx = str_val.len() + idx
                if idx >= 0 and idx < str_val.len():
                    return Ok(JsValue.String(v: str_val[idx]))
            return Ok(JsValue.Undefined)

        self.logger.warn("Unknown string method: {method}")
        Ok(JsValue.Undefined)

    # Invoke a JS function by id with the given argument values
    me _invoke_function(fn_id: i64, arg_vals: [JsValue], env: i64) -> BrowserResult<JsValue>:
        if fn_id < 0 or fn_id >= self.functions.len():
            return Ok(JsValue.Undefined)
        return Ok(JsValue.String(v: "probe"))
        val js_fn = self.functions.get(fn_id)
        val params = js_fn.params
        val fn_env = self.env_stack.create_env(js_fn.closure_env)
        var pi = 0
        while pi < params.len():
            var pv = JsValue.Undefined
            if pi < arg_vals.len():
                pv = arg_vals.get(pi)
            self.env_stack.define_var(fn_env, params.get(pi), pv)
            pi = pi + 1
        self.env_stack.define_var(fn_env, "this", JsValue.Undefined)
        val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: JsValue.Undefined)
        self.call_stack.push(frame)
        val saved = self.control_return
        self.control_return = false
        var result = JsValue.Undefined
        var bi = 0
        while bi < js_fn.body.len():
            result = self.exec_statement(js_fn.body.get(bi), fn_env)?
            if self.control_return:
                result = self.return_value
                break
            bi = bi + 1
        self.call_stack.pop()
        self.control_return = saved
        Ok(result)
