# JS Parser
# Parses JavaScript source code into an AST.

use std.js.types.ast_types.{DestructProp, JsStatement, JsExpression}
use std.js.engine.js_error.{JsError, Logger}
use std.js.engine.lexer.{JsLexer}
use std.js.types.js_types.{JsValue}
use std.js.types.pair.{Pair}

fn js_parse_program_subset(source: text) -> [JsStatement]:
    var statements: [JsStatement] = []
    val parts = _js_parser_split_top_level(source, ";")
    var i = 0
    while i < parts.len():
        val stmt = parts.get(i).trim()
        if stmt != "":
            statements.push(_js_parser_statement(stmt))
        i = i + 1
    statements

fn _js_parser_statement(stmt: text) -> JsStatement:
    if stmt.starts_with("var "):
        val body = stmt.slice(4, stmt.len()).trim()
        val eq = _js_parser_find_top_level(body, "=")
        if eq >= 0:
            return JsStatement.VarDecl(body.slice(0, eq).trim(), _js_parser_expression(body.slice(eq + 1, body.len())))
        return JsStatement.VarDecl(body, JsExpression.Literal(value: JsValue.Undefined))
    if stmt.starts_with("return "):
        return JsStatement.Return(value: _js_parser_expression(stmt.slice(7, stmt.len()).trim()))
    if stmt == "return":
        return JsStatement.Return(value: JsExpression.Literal(value: JsValue.Undefined))
    JsStatement.ExprStmt(_js_parser_expression(stmt))

fn _js_parser_expression(raw: text) -> JsExpression:
    val expr = _js_parser_strip_outer_parens(raw.trim())
    if val Some(regex_expr) = _js_parser_try_regex_literal(expr):
        return regex_expr
    if val Some(regex_chain_expr) = _js_parser_try_regex_literal_chain(expr):
        return regex_chain_expr
    val arrow = _js_parser_find_top_level(expr, "=>")
    if arrow >= 0:
        return _js_parser_arrow_expression(expr, arrow)
    val assign = _js_parser_find_top_level_assignment(expr)
    if assign >= 0:
        return JsExpression.Assignment(
            target: _js_parser_expression(expr.slice(0, assign)),
            value: _js_parser_expression(expr.slice(assign + 1, expr.len()))
        )
    if expr.starts_with("-") and expr.len() > 1:
        return JsExpression.Unary(op: "-", operand: _js_parser_expression(expr.slice(1, expr.len())))
    if expr.starts_with("!") and expr.len() > 1:
        return JsExpression.Unary(op: "!", operand: _js_parser_expression(expr.slice(1, expr.len())))
    val logical_or = _js_parser_find_binary_operator(expr, ["||", "??"])
    if logical_or.first >= 0:
        return JsExpression.Binary(
            op: logical_or.second,
            left: _js_parser_expression(expr.slice(0, logical_or.first)),
            right: _js_parser_expression(expr.slice(logical_or.first + logical_or.second.len(), expr.len()))
        )
    val logical_and = _js_parser_find_binary_operator(expr, ["&&"])
    if logical_and.first >= 0:
        return JsExpression.Binary(
            op: logical_and.second,
            left: _js_parser_expression(expr.slice(0, logical_and.first)),
            right: _js_parser_expression(expr.slice(logical_and.first + logical_and.second.len(), expr.len()))
        )
    val equality = _js_parser_find_binary_operator(expr, ["===", "!==", "==", "!="])
    if equality.first >= 0:
        return JsExpression.Binary(
            op: equality.second,
            left: _js_parser_expression(expr.slice(0, equality.first)),
            right: _js_parser_expression(expr.slice(equality.first + equality.second.len(), expr.len()))
        )
    val comparison = _js_parser_find_binary_operator(expr, ["<=", ">=", "<", ">"])
    if comparison.first >= 0:
        return JsExpression.Binary(
            op: comparison.second,
            left: _js_parser_expression(expr.slice(0, comparison.first)),
            right: _js_parser_expression(expr.slice(comparison.first + comparison.second.len(), expr.len()))
        )
    val additive = _js_parser_find_binary_operator(expr, ["+", "-"])
    if additive.first >= 0:
        return JsExpression.Binary(
            op: additive.second,
            left: _js_parser_expression(expr.slice(0, additive.first)),
            right: _js_parser_expression(expr.slice(additive.first + additive.second.len(), expr.len()))
        )
    val multiplicative = _js_parser_find_binary_operator(expr, ["*", "/", "%"])
    if multiplicative.first >= 0:
        return JsExpression.Binary(
            op: multiplicative.second,
            left: _js_parser_expression(expr.slice(0, multiplicative.first)),
            right: _js_parser_expression(expr.slice(multiplicative.first + multiplicative.second.len(), expr.len()))
        )
    val exponent = _js_parser_find_binary_operator(expr, ["**"])
    if exponent.first >= 0:
        return JsExpression.Binary(
            op: exponent.second,
            left: _js_parser_expression(expr.slice(0, exponent.first)),
            right: _js_parser_expression(expr.slice(exponent.first + exponent.second.len(), expr.len()))
        )
    if expr.starts_with("new "):
        return _js_parser_new_expression(expr.slice(4, expr.len()).trim())
    if expr.starts_with("typeof "):
        return JsExpression.Unary(op: "typeof", operand: _js_parser_expression(expr.slice(7, expr.len())))
    _js_parser_postfix(expr)

fn _js_parser_arrow_expression(expr: text, arrow: i64) -> JsExpression:
    var params_text = expr.slice(0, arrow).trim()
    if params_text.starts_with("(") and params_text.ends_with(")"):
        params_text = params_text.slice(1, params_text.len() - 1).trim()
    val param_parts = _js_parser_split_top_level(params_text, ",")
    var params: [text] = []
    var pi = 0
    while pi < param_parts.len():
        val p = param_parts.get(pi).trim()
        if p != "":
            params.push(p)
        pi = pi + 1
    val body_text = expr.slice(arrow + 2, expr.len()).trim()
    if body_text.starts_with("{"):
        val body_end = _js_parser_matching_brace(body_text, 0)
        if body_end >= 0:
            return JsExpression.ArrowFunction(params: params, body: js_parse_program_subset(body_text.slice(1, body_end)))
        return JsExpression.ArrowFunction(params: params, body: [])
    JsExpression.ArrowFunction(params: params, body: [JsStatement.Return(value: _js_parser_expression(body_text))])

fn _js_parser_postfix(expr: text) -> JsExpression:
    val current = _js_parser_primary_at(expr, 0)
    val pos = _js_parser_primary_end(expr, 0)
    _js_parser_postfix_continue(expr, current, pos).first

# Continues member/call/computed-member (postfix) parsing of `expr` starting
# at `start_pos` with `start_current` as the already-parsed left operand.
# Returns the resulting expression paired with the position where parsing
# stopped (== expr.len() iff the postfix chain consumed the whole string).
# Factored out of _js_parser_postfix so it can be resumed from a
# non-primary starting point in two places: an already-built expression such
# as a `new` expression's result (e.g. `.method(...)` in
# `new Ctor(args).method(args2)`), and a regex-literal primary
# (`/re/.test(x)`) resuming postfix parsing right after the literal instead
# of re-deriving the initial primary via _js_parser_primary_at.
fn _js_parser_postfix_continue(expr: text, start_current: JsExpression, start_pos: i64) -> Pair<JsExpression, i64>:
    var current = start_current
    var pos = start_pos
    while pos < expr.len():
        val skipped = _js_parser_skip_spaces(expr, pos)
        if skipped >= expr.len():
            pos = skipped
            break
        val ch = expr.slice(skipped, skipped + 1)
        if ch == ".":
            val start = _js_parser_skip_spaces(expr, skipped + 1)
            val end = _js_parser_identifier_end(expr, start)
            current = JsExpression.Member(object: current, property: expr.slice(start, end))
            pos = end
        else if ch == "(":
            val end = _js_parser_matching_paren(expr, skipped)
            val arg_text = if end > skipped: expr.slice(skipped + 1, end) else: ""
            val arg_parts = _js_parser_split_top_level(arg_text, ",")
            var args: [JsExpression] = []
            var ai = 0
            while ai < arg_parts.len():
                val arg = arg_parts.get(ai).trim()
                if arg != "":
                    args.push(_js_parser_expression(arg))
                ai = ai + 1
            current = JsExpression.Call(callee: current, args: args)
            pos = if end >= 0: end + 1 else: expr.len()
        else if ch == "[":
            val end = _js_parser_matching_bracket(expr, skipped)
            val key_text = if end > skipped: expr.slice(skipped + 1, end) else: ""
            current = JsExpression.ComputedMember(object: current, property: _js_parser_expression(key_text.trim()))
            pos = if end >= 0: end + 1 else: expr.len()
        else:
            pos = skipped
            break
    Pair(first: current, second: pos)

# Parses the target of a `new` expression per JS semantics: `new` binds only to
# the immediately-following member-access chain (`.`/`[...]`, no calls) plus at
# most one directly-adjacent argument list. Anything chained after that
# (`.method(...)`, further calls, more member access) applies to the
# constructed value instead — e.g. `new Ctor(args).method(args2)` parses as
# `(new Ctor(args)).method(args2)`, not `new (Ctor(args).method)(args2)`.
fn _js_parser_new_expression(expr: text) -> JsExpression:
    val chain = _js_parser_new_member_chain(expr, 0)
    val callee = chain.first
    var pos = _js_parser_skip_spaces(expr, chain.second)
    var args: [JsExpression] = []
    if pos < expr.len() and expr.slice(pos, pos + 1) == "(":
        val end = _js_parser_matching_paren(expr, pos)
        val arg_text = if end > pos: expr.slice(pos + 1, end) else: ""
        val arg_parts = _js_parser_split_top_level(arg_text, ",")
        var ai = 0
        while ai < arg_parts.len():
            val arg = arg_parts.get(ai).trim()
            if arg != "":
                args.push(_js_parser_expression(arg))
            ai = ai + 1
        pos = if end >= 0: end + 1 else: expr.len()
    val new_node = JsExpression.NewExpr(callee: callee, args: args)
    _js_parser_postfix_continue(expr, new_node, pos).first

# Member-access-only chain (`.` and `[...]`, but NOT `(...)`) for the callee of
# a `new` expression. Stops right before any `(` so the caller can decide
# whether that paren is the constructor's argument list. Returns the parsed
# expression along with the position it stopped at.
fn _js_parser_new_member_chain(expr: text, pos_in: i64) -> Pair<JsExpression, i64>:
    var current = _js_parser_primary_at(expr, pos_in)
    var pos = _js_parser_primary_end(expr, pos_in)
    while pos < expr.len():
        pos = _js_parser_skip_spaces(expr, pos)
        if pos >= expr.len():
            break
        val ch = expr.slice(pos, pos + 1)
        if ch == ".":
            val start = _js_parser_skip_spaces(expr, pos + 1)
            val end = _js_parser_identifier_end(expr, start)
            current = JsExpression.Member(object: current, property: expr.slice(start, end))
            pos = end
        else if ch == "[":
            val end = _js_parser_matching_bracket(expr, pos)
            val key_text = if end > pos: expr.slice(pos + 1, end) else: ""
            current = JsExpression.ComputedMember(object: current, property: _js_parser_expression(key_text.trim()))
            pos = if end >= 0: end + 1 else: expr.len()
        else:
            break
    Pair(first: current, second: pos)

fn _js_parser_primary_at(expr: text, pos_in: i64) -> JsExpression:
    val pos = _js_parser_skip_spaces(expr, pos_in)
    if pos >= expr.len():
        return JsExpression.Literal(value: JsValue.Undefined)
    val ch = expr.slice(pos, pos + 1)
    if ch == "'" or ch == "\"":
        val end = _js_parser_string_end(expr, pos)
        return JsExpression.Literal(value: JsValue.String(v: _js_parser_decode_string_literal(expr.slice(pos + 1, end))))
    if ch == "(":
        val end = _js_parser_matching_paren(expr, pos)
        if end > pos:
            return _js_parser_expression(expr.slice(pos + 1, end))
    if ch == "[":
        val end = _js_parser_matching_bracket(expr, pos)
        val elem_text = if end > pos: expr.slice(pos + 1, end) else: ""
        val elem_parts = _js_parser_split_top_level(elem_text, ",")
        var elements: [JsExpression] = []
        var ei = 0
        while ei < elem_parts.len():
            val elem = elem_parts.get(ei).trim()
            if elem != "":
                elements.push(_js_parser_expression(elem))
            ei = ei + 1
        return JsExpression.Array(elements: elements)
    if ch == "{":
        val end = _js_parser_matching_brace(expr, pos)
        val prop_text = if end > pos: expr.slice(pos + 1, end) else: ""
        val prop_parts = _js_parser_split_top_level(prop_text, ",")
        var props: [DestructProp] = []
        var pi = 0
        while pi < prop_parts.len():
            val prop = prop_parts.get(pi).trim()
            if prop != "":
                val colon = _js_parser_find_top_level(prop, ":")
                if colon > 0:
                    var key = prop.slice(0, colon).trim()
                    if (key.starts_with("\"") and key.ends_with("\"")) or (key.starts_with("'") and key.ends_with("'")):
                        key = key.slice(1, key.len() - 1).trim()
                    props.push(DestructProp(key: key, value: _js_parser_expression(prop.slice(colon + 1, prop.len()).trim())))
            pi = pi + 1
        return JsExpression.ObjectExpr(properties: props)
    if expr.slice(pos, expr.len()).starts_with("function"):
        return _js_parser_function_expression(expr, pos)
    val end = _js_parser_identifier_end(expr, pos)
    val token = expr.slice(pos, end)
    if token == "true":
        return JsExpression.Literal(value: JsValue.Boolean(v: true))
    if token == "false":
        return JsExpression.Literal(value: JsValue.Boolean(v: false))
    if token == "null":
        return JsExpression.Literal(value: JsValue.Null)
    if token == "undefined":
        return JsExpression.Literal(value: JsValue.Undefined)
    val parsed = token.parse_float()
    if val Some(n) = parsed:
        return JsExpression.Literal(value: JsValue.Number(v: n))
    JsExpression.Identifier(name: token)

fn _js_parser_primary_end(expr: text, pos_in: i64) -> i64:
    val pos = _js_parser_skip_spaces(expr, pos_in)
    if pos >= expr.len():
        return pos
    val ch = expr.slice(pos, pos + 1)
    if ch == "'" or ch == "\"":
        val end = _js_parser_string_end(expr, pos)
        return if end >= 0: end + 1 else: expr.len()
    if ch == "(":
        val end = _js_parser_matching_paren(expr, pos)
        return if end >= 0: end + 1 else: expr.len()
    if ch == "[":
        val end = _js_parser_matching_bracket(expr, pos)
        return if end >= 0: end + 1 else: expr.len()
    if ch == "{":
        val end = _js_parser_matching_brace(expr, pos)
        return if end >= 0: end + 1 else: expr.len()
    if expr.slice(pos, expr.len()).starts_with("function"):
        val body_start = _js_parser_find_function_body_start(expr, pos)
        if body_start >= 0:
            val end = _js_parser_matching_brace(expr, body_start)
            return if end >= 0: end + 1 else: expr.len()
    _js_parser_identifier_end(expr, pos)

fn _js_parser_find_function_body_start(expr: text, pos: i64) -> i64:
    val open = _js_parser_find_char_from(expr, "(", pos)
    if open < 0:
        return -1
    val close = _js_parser_matching_paren(expr, open)
    if close < 0:
        return -1
    val body_start = _js_parser_skip_spaces(expr, close + 1)
    if body_start < expr.len() and expr.slice(body_start, body_start + 1) == "{":
        return body_start
    -1

fn _js_parser_find_char_from(expr: text, needle: text, start: i64) -> i64:
    var i = start
    while i < expr.len():
        if expr.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn _js_parser_function_expression(expr: text, pos: i64) -> JsExpression:
    val open = _js_parser_find_char_from(expr, "(", pos)
    if open < 0:
        return JsExpression.Literal(value: JsValue.Undefined)
    val close = _js_parser_matching_paren(expr, open)
    if close < 0:
        return JsExpression.Literal(value: JsValue.Undefined)
    val params_text = expr.slice(open + 1, close)
    val param_parts = _js_parser_split_top_level(params_text, ",")
    var params: [text] = []
    var pi = 0
    while pi < param_parts.len():
        val p = param_parts.get(pi).trim()
        if p != "":
            params.push(p)
        pi = pi + 1
    val body_start = _js_parser_find_function_body_start(expr, pos)
    if body_start < 0:
        return JsExpression.ArrowFunction(params: params, body: [])
    val body_end = _js_parser_matching_brace(expr, body_start)
    if body_end < 0:
        return JsExpression.ArrowFunction(params: params, body: [])
    val body_text = expr.slice(body_start + 1, body_end)
    JsExpression.ArrowFunction(params: params, body: js_parse_program_subset(body_text))

fn _js_parser_identifier_end(expr: text, pos: i64) -> i64:
    var i = pos
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "$":
            i = i + 1
        else:
            break
    i

fn _js_parser_skip_spaces(expr: text, pos: i64) -> i64:
    var i = pos
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            i = i + 1
        else:
            break
    i

fn _js_parser_find_top_level(expr: text, needle: text) -> i64:
    var depth = 0
    var quote = ""
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(" or ch == "[" or ch == "{":
                depth = depth + 1
            else if ch == ")" or ch == "]" or ch == "}":
                depth = depth - 1
            else if depth == 0 and expr.slice(i, i + needle.len()) == needle:
                return i
        i = i + 1
    -1

fn _js_parser_find_top_level_right(expr: text, needle: text) -> i64:
    var depth = 0
    var quote = ""
    var found = -1
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(" or ch == "[" or ch == "{":
                depth = depth + 1
            else if ch == ")" or ch == "]" or ch == "}":
                depth = depth - 1
            else if depth == 0 and expr.slice(i, i + needle.len()) == needle:
                found = i
        i = i + 1
    found

fn _js_parser_find_binary_operator(expr: text, operators: [text]) -> Pair<i64, text>:
    var best_pos = -1
    var best_op = ""
    var oi = 0
    while oi < operators.len():
        val op = operators.get(oi)
        val pos = _js_parser_find_top_level_right_binary_operator(expr, op)
        if pos > best_pos and not _js_parser_binary_operator_is_unary(expr, pos, op):
            best_pos = pos
            best_op = op
        oi = oi + 1
    Pair(first: best_pos, second: best_op)

fn _js_parser_find_top_level_right_binary_operator(expr: text, needle: text) -> i64:
    var depth = 0
    var quote = ""
    var found = -1
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(" or ch == "[" or ch == "{":
                depth = depth + 1
            else if ch == ")" or ch == "]" or ch == "}":
                depth = depth - 1
            else if depth == 0 and expr.slice(i, i + needle.len()) == needle:
                if _js_parser_binary_operator_match_is_standalone(expr, i, needle):
                    found = i
        i = i + 1
    found

fn _js_parser_binary_operator_match_is_standalone(expr: text, pos: i64, op: text) -> bool:
    if op == "==":
        val prev = if pos > 0: expr.slice(pos - 1, pos) else: ""
        val next = if pos + 2 < expr.len(): expr.slice(pos + 2, pos + 3) else: ""
        return prev != "=" and prev != "!" and prev != "<" and prev != ">" and next != "="
    if op == "!=":
        val next_bang = if pos + 2 < expr.len(): expr.slice(pos + 2, pos + 3) else: ""
        return next_bang != "="
    true

fn _js_parser_binary_operator_is_unary(expr: text, pos: i64, op: text) -> bool:
    if op == "*" and ((pos > 0 and expr.slice(pos - 1, pos) == "*") or (pos + 1 < expr.len() and expr.slice(pos + 1, pos + 2) == "*")):
        return true
    if op != "-":
        return false
    if pos <= 0:
        return true
    var i = pos - 1
    while i >= 0:
        val ch = expr.slice(i, i + 1)
        if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            i = i - 1
            continue
        return ch == "(" or ch == "[" or ch == "{" or ch == "," or ch == ":" or ch == "=" or ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "%"
    true

fn _js_parser_find_top_level_assignment(expr: text) -> i64:
    var depth = 0
    var quote = ""
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(" or ch == "[" or ch == "{":
                depth = depth + 1
            else if ch == ")" or ch == "]" or ch == "}":
                depth = depth - 1
            else if depth == 0 and ch == "=":
                val prev = if i > 0: expr.slice(i - 1, i) else: ""
                val next = if i + 1 < expr.len(): expr.slice(i + 1, i + 2) else: ""
                if prev != "=" and prev != "!" and prev != "<" and prev != ">" and next != "=":
                    return i
        i = i + 1
    -1

fn _js_parser_split_top_level(expr: text, sep: text) -> [text]:
    var parts: [text] = []
    var depth = 0
    var quote = ""
    var start = 0
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(" or ch == "[" or ch == "{":
                depth = depth + 1
            else if ch == ")" or ch == "]" or ch == "}":
                depth = depth - 1
            else if depth == 0 and expr.slice(i, i + sep.len()) == sep:
                parts.push(expr.slice(start, i))
                start = i + sep.len()
                i = start - 1
        i = i + 1
    parts.push(expr.slice(start, expr.len()))
    parts

fn _js_parser_string_end(expr: text, start: i64) -> i64:
    val quote = expr.slice(start, start + 1)
    var i = start + 1
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if ch == "\\":
            i = i + 1
        else if ch == quote:
            return i
        i = i + 1
    expr.len()

fn _js_parser_hex_digit(ch: text) -> i64:
    if ch >= "0" and ch <= "9":
        return ch.char_at(0) as i64 - 48
    if ch >= "a" and ch <= "f":
        return ch.char_at(0) as i64 - 87
    if ch >= "A" and ch <= "F":
        return ch.char_at(0) as i64 - 55
    -1

fn _js_parser_decode_string_literal(raw: text) -> text:
    var out = ""
    var i = 0
    while i < raw.len():
        val ch = raw.slice(i, i + 1)
        if ch != "\\" or i + 1 >= raw.len():
            out = out + ch
            i = i + 1
            continue
        val esc = raw.slice(i + 1, i + 2)
        if esc == "n":
            out = out + "\n"
            i = i + 2
        else if esc == "r":
            out = out + "\r"
            i = i + 2
        else if esc == "t":
            out = out + "\t"
            i = i + 2
        else if esc == "0":
            out = out + 0.chr()
            i = i + 2
        else if esc == "\\" or esc == "'" or esc == "\"":
            out = out + esc
            i = i + 2
        else if esc == "u" and i + 5 < raw.len():
            val h0 = _js_parser_hex_digit(raw.slice(i + 2, i + 3))
            val h1 = _js_parser_hex_digit(raw.slice(i + 3, i + 4))
            val h2 = _js_parser_hex_digit(raw.slice(i + 4, i + 5))
            val h3 = _js_parser_hex_digit(raw.slice(i + 5, i + 6))
            if h0 >= 0 and h1 >= 0 and h2 >= 0 and h3 >= 0:
                out = out + ((h0 << 12) | (h1 << 8) | (h2 << 4) | h3).chr()
                i = i + 6
            else:
                out = out + esc
                i = i + 2
        else if esc == "x" and i + 3 < raw.len():
            val h0 = _js_parser_hex_digit(raw.slice(i + 2, i + 3))
            val h1 = _js_parser_hex_digit(raw.slice(i + 3, i + 4))
            if h0 >= 0 and h1 >= 0:
                out = out + ((h0 << 4) | h1).chr()
                i = i + 4
            else:
                out = out + esc
                i = i + 2
        else if esc == "b":
            out = out + 8.chr()
            i = i + 2
        else if esc == "f":
            out = out + 12.chr()
            i = i + 2
        else if esc == "v":
            out = out + 11.chr()
            i = i + 2
        else:
            out = out + esc
            i = i + 2
    out

fn _js_parser_matching_paren(expr: text, start: i64) -> i64:
    var depth = 0
    var quote = ""
    var i = start
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "(":
                depth = depth + 1
            else if ch == ")":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _js_parser_matching_bracket(expr: text, start: i64) -> i64:
    var depth = 0
    var quote = ""
    var i = start
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "[":
                depth = depth + 1
            else if ch == "]":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _js_parser_matching_brace(expr: text, start: i64) -> i64:
    var depth = 0
    var quote = ""
    var i = start
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if quote != "":
            if ch == "\\":
                i = i + 1
            else if ch == quote:
                quote = ""
        else:
            if ch == "'" or ch == "\"":
                quote = ch
            else if ch == "{":
                depth = depth + 1
            else if ch == "}":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _js_parser_strip_outer_parens(expr: text) -> text:
    var current = expr.trim()
    var changed = true
    while changed and current.starts_with("(") and current.ends_with(")"):
        changed = false
        val end = _js_parser_matching_paren(current, 0)
        if end == current.len() - 1:
            current = current.slice(1, current.len() - 1).trim()
            changed = true
    current

class JsParser:
    source: text
    lexer: JsLexer
    logger: Logger
    pos: i64

impl JsParser:
    static fn create(source: text, logger: Logger) -> JsParser:
        JsParser(source: source, lexer: JsLexer.create(source), logger: logger, pos: 0)

    static fn new(source: text, logger: Logger) -> JsParser:
        JsParser.create(source, logger)

    me parse_program() -> [JsStatement]:
        js_parse_program_subset(self.source)

    me parse_assignment() -> Result<JsExpression, JsError>:
        Ok(_js_parser_expression(self.source))

fn _js_bal_is_ident_char(c: text) -> bool:
    (c >= "a" and c <= "z") or (c >= "A" and c <= "Z") or (c >= "0" and c <= "9") or c == "_" or c == "$"

# Returns true if a `/` at the current position begins a regex literal rather
# than a division operator, based on the previous significant (non-space,
# non-comment) character `prev` and any trailing keyword captured in `prev_word`.
fn _js_regex_context(prev: text, prev_word: text) -> bool:
    if prev == "":
        return true
    # A regex may begin after an operator, an opening delimiter, or certain
    # punctuation — but not after a value (identifier, number, string, `)`, `]`).
    if (prev == "(" or prev == "," or prev == "=" or prev == ":" or prev == "["
        or prev == "!" or prev == "&" or prev == "|" or prev == "?"
        or prev == "{" or prev == "}" or prev == ";" or prev == "+"
        or prev == "-" or prev == "*" or prev == "%" or prev == "<"
        or prev == ">" or prev == "~" or prev == "^" or prev == "/"):
        return true
    # Keywords that expect an expression next (so `/` starts a regex).
    if (prev_word == "return" or prev_word == "typeof" or prev_word == "instanceof"
        or prev_word == "in" or prev_word == "of" or prev_word == "new"
        or prev_word == "delete" or prev_word == "void" or prev_word == "do"
        or prev_word == "else" or prev_word == "yield" or prev_word == "case"
        or prev_word == "throw"):
        return true
    false

# Returns the position of the unescaped closing `/` of a regex literal that
# starts at position 0 of `expr` (i.e. `expr[0] == "/"`), skipping over
# character classes `[...]` (where an unescaped `/` is not special), or -1 if
# `expr` doesn't start with `/` or the literal is unterminated. Shared by
# _js_parser_try_regex_literal (whole-expression regex) and
# _js_parser_try_regex_literal_chain (regex followed by a postfix chain).
fn _js_parser_regex_close_pos(expr: text) -> i64:
    if not expr.starts_with("/"):
        return -1
    val n = expr.len()
    var i = 1
    var in_class = false
    while i < n:
        val ch = expr.slice(i, i + 1)
        if ch == "\\":
            i = i + 2
            continue
        elif ch == "[":
            in_class = true
        elif ch == "]":
            in_class = false
        elif ch == "/" and not in_class:
            return i
        i = i + 1
    -1

# Returns the exclusive end position of the flags run (`[a-z]*`) immediately
# following the closing `/` at `close_pos`.
fn _js_parser_regex_flags_end(expr: text, close_pos: i64) -> i64:
    val n = expr.len()
    var fi = close_pos + 1
    while fi < n:
        val fc = expr.slice(fi, fi + 1)
        if fc >= "a" and fc <= "z":
            fi = fi + 1
        else:
            break
    fi

# Recognizes a bare regex literal `/pattern/flags` that spans the ENTIRE given
# expression text (nothing meaningful trails the flags) — e.g.
# `str.replace(/b/, 'X')` or `var re = /a+b/i;`. Returns nil (falls back to
# normal operator/primary parsing, e.g. division) when `expr` isn't a complete
# bare regex literal, including when a member/call chain trails the flags
# (`/re/.test(x)`) — that case is handled separately by
# _js_parser_try_regex_literal_chain.
fn _js_parser_try_regex_literal(expr: text) -> JsExpression?:
    val close_pos = _js_parser_regex_close_pos(expr)
    if close_pos < 0:
        return nil
    val flags_end = _js_parser_regex_flags_end(expr, close_pos)
    if flags_end != expr.len():
        return nil
    Some(JsExpression.RegexLiteral(pattern: expr.slice(1, close_pos), flags: expr.slice(close_pos + 1, flags_end)))

# Recognizes a regex literal at the START of `expr` immediately followed by a
# member/call/computed-member chain — e.g. `/re/.test(x)`, `/re/g.exec(s)[0]`.
# Needed because the operator-precedence scanners below (in particular the
# multiplicative `/` scan) would otherwise misparse the pattern's internal
# `/` characters as division operators before postfix parsing ever gets a
# chance to run. Conservative: only fires when the postfix chain consumes the
# ENTIRE remainder of `expr` — if something trails that the chain can't
# consume (e.g. `/re/.test(x) && y`), returns nil rather than silently
# dropping it, falling back to the (separately scoped, pre-existing)
# operator-scan behavior for that rarer composition.
fn _js_parser_try_regex_literal_chain(expr: text) -> JsExpression?:
    val close_pos = _js_parser_regex_close_pos(expr)
    if close_pos < 0:
        return nil
    val flags_end = _js_parser_regex_flags_end(expr, close_pos)
    if flags_end >= expr.len():
        return nil  # No trailing chain — _js_parser_try_regex_literal handles this.
    val regex_expr = JsExpression.RegexLiteral(pattern: expr.slice(1, close_pos), flags: expr.slice(close_pos + 1, flags_end))
    val chained = _js_parser_postfix_continue(expr, regex_expr, flags_end)
    if chained.second != expr.len():
        return nil
    Some(chained.first)

# Fail-fast structural gate for eval: the subset expression parser recurses on
# malformed input and unbalanced delimiters can make it effectively hang.
# Scans outside string literals ('..' ".." `..`), // and /* */ comments, and
# regex literals (/.../ — whose parens/brackets are not structural).
pub fn js_source_delimiters_balanced(source: text) -> bool:
    val n = source.len()
    var paren = 0
    var bracket = 0
    var brace = 0
    var i = 0
    # Previous significant character and, when it terminates an identifier, the
    # word itself (for keyword-preceded regex literals like `return /re/`).
    var prev = ""
    var prev_word = ""
    while i < n:
        val c = source[i]
        if c == "'" or c == "\"" or c == "`":
            val quote = c
            i = i + 1
            while i < n:
                if source[i] == "\\":
                    i = i + 2
                    continue
                if source[i] == quote:
                    break
                i = i + 1
            prev = quote
            prev_word = ""
            i = i + 1
            continue
        elif c == "/" and i + 1 < n and source[i + 1] == "/":
            while i < n and source[i] != "\n":
                i = i + 1
            continue
        elif c == "/" and i + 1 < n and source[i + 1] == "*":
            i = i + 2
            while i + 1 < n and not (source[i] == "*" and source[i + 1] == "/"):
                i = i + 1
            i = i + 2
            continue
        elif c == "/" and _js_regex_context(prev, prev_word):
            # Regex literal: skip to the unescaped closing `/`, treating `[...]`
            # character classes as regions where `/` does not close the literal.
            i = i + 1
            var in_class = false
            while i < n:
                val rc = source[i]
                if rc == "\\":
                    i = i + 2
                    continue
                if rc == "[":
                    in_class = true
                elif rc == "]":
                    in_class = false
                elif rc == "/" and not in_class:
                    break
                elif rc == "\n":
                    break  # Unterminated regex — stop regex scan.
                i = i + 1
            prev = "/"
            prev_word = ""
            i = i + 1
            continue
        elif c == " " or c == "\t" or c == "\n" or c == "\r":
            i = i + 1
            continue
        elif c == "(":
            paren = paren + 1
        elif c == ")":
            paren = paren - 1
        elif c == "[":
            bracket = bracket + 1
        elif c == "]":
            bracket = bracket - 1
        elif c == "{":
            brace = brace + 1
        elif c == "}":
            brace = brace - 1
        if paren < 0 or bracket < 0 or brace < 0:
            return false
        # Track the previous significant char / identifier word.
        prev = c
        if _js_bal_is_ident_char(c):
            prev_word = prev_word + c
        else:
            prev_word = ""
        i = i + 1
    paren == 0 and bracket == 0 and brace == 0
