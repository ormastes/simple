# JsInterpreter — expression evaluation: eval_expression, eval_new, eval_binary, eval_unary, eval_call.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.types.ast_types.JsExpression
use std.js.types.ast_types.JsStatement
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, NativeIdMapping, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm_object_store.{ObjectStore}
use std.js.engine.runtime.{NATIVE_SET_IMMEDIATE, NATIVE_CLEAR_IMMEDIATE, NATIVE_SET_TIMEOUT, NATIVE_CLEAR_TIMEOUT, NATIVE_WEBASSEMBLY_COMPILE_CATCH, NATIVE_WEBASSEMBLY_COMPILE_THEN, NATIVE_WEBASSEMBLY_EXPORT_FUNCTION, NATIVE_WEBASSEMBLY_INSTANTIATE_THEN}
use std.js.node.buffer_module.{buffer_byteLength}
use std.nogc_sync_mut.js.engine.interpreter.{JsInterpreter}
use std.nogc_sync_mut.js.engine.interpreter_object.{JsInterpreter}
use std.js.builtins.array.{array_isArray, array_from_values}

impl JsInterpreter:
    # ── JsExpression evaluation ────────────────────────────────────────────

    me eval_expression(expr: JsExpression, env: i64) -> BrowserResult<JsValue>:
        match expr:
            JsExpression.Literal(value):
                return Ok(value)
            JsExpression.Identifier(name):
                # Check for 'this' binding
                if name == "this":
                    if self.call_stack.len() > 0:
                        val frame = self.call_stack.get(self.call_stack.len() - 1)
                        return Ok(frame.this_value)
                    return Ok(JsValue.Undefined)
                if name == "window" and self.host_window_id >= 0:
                    return Ok(JsValue.Object(id: self.host_window_id))
                if name == "self" and self.host_window_id >= 0:
                    return Ok(JsValue.Object(id: self.host_window_id))
                if name == "document" and self.host_document_id >= 0:
                    return Ok(JsValue.Object(id: self.host_document_id))
                if name == "location" and self.host_location_id >= 0:
                    return Ok(JsValue.Object(id: self.host_location_id))
                if name == "navigator" and self.host_navigator_id >= 0:
                    return Ok(JsValue.Object(id: self.host_navigator_id))
                if name == "chrome" and self.host_chrome_id >= 0:
                    return Ok(JsValue.Object(id: self.host_chrome_id))
                if name == "sessionStorage" and self.host_session_storage_id >= 0:
                    return Ok(JsValue.Object(id: self.host_session_storage_id))
                if name == "localStorage" and self.host_local_storage_id >= 0:
                    return Ok(JsValue.Object(id: self.host_local_storage_id))
                if name == "Promise":
                    return Ok(self._promise_global_object())
                if name == "require":
                    return Ok(self._native_node_require_function())
                if name == "Buffer":
                    return Ok(self._native_node_buffer_global())
                if name == "process":
                    return Ok(self._native_node_process_object())
                if name == "setImmediate":
                    val immediate_fn = JsValue.Function(id: self._register_native("setImmediate", NATIVE_SET_IMMEDIATE))
                    self.define_global_value("setImmediate", immediate_fn)
                    return Ok(immediate_fn)
                if name == "clearImmediate":
                    val clear_immediate_fn = JsValue.Function(id: self._register_native("clearImmediate", NATIVE_CLEAR_IMMEDIATE))
                    self.define_global_value("clearImmediate", clear_immediate_fn)
                    return Ok(clear_immediate_fn)
                if name == "setTimeout":
                    val set_timeout_fn = JsValue.Function(id: self._register_native("setTimeout", NATIVE_SET_TIMEOUT))
                    self.define_global_value("setTimeout", set_timeout_fn)
                    return Ok(set_timeout_fn)
                if name == "clearTimeout":
                    val clear_timeout_fn = JsValue.Function(id: self._register_native("clearTimeout", NATIVE_CLEAR_TIMEOUT))
                    self.define_global_value("clearTimeout", clear_timeout_fn)
                    return Ok(clear_timeout_fn)
                if env == self.global_env:
                    val cached = self.lookup_global_value(name)
                    if val Some(v) = cached:
                        return Ok(v)
                val lookup = self.env_stack.get_var(env, name)
                if val Some(v) = lookup:
                    return Ok(v)
                # Check global
                val global_lookup = self.lookup_global_value(name)
                if val Some(v) = global_lookup:
                    return Ok(v)
                self.logger.warn("ReferenceError: {name} is not defined")
                return Ok(JsValue.Undefined)
            JsExpression.Binary(op, left, right):
                return self.eval_binary(op, left, right, env)
            JsExpression.Unary(op, operand):
                return self.eval_unary(op, operand, env)
            JsExpression.Call(callee, args):
                return self.eval_call(callee, args, env)
            JsExpression.Member(object, property):
                return self.eval_member(object, property, env)
            JsExpression.Assignment(target, value):
                return self.eval_assignment(target, value, env)
            JsExpression.Array(elements):
                return self.eval_array(elements, env)
            JsExpression.ObjectExpr(properties):
                return self.eval_object(properties, env)
            JsExpression.Ternary(condition, consequent, alternate):
                val cond_val = self.eval_expression(condition, env)?
                if is_truthy(cond_val):
                    return self.eval_expression(consequent, env)
                return self.eval_expression(alternate, env)
            JsExpression.ArrowFunction(params, body):
                # Register arrow as a function
                val fn_id = self.functions.len()
                val js_fn = JsFunction(name: "__arrow__", params: params, body: body, closure_env: env, is_arrow: false)
                self.functions.push(js_fn)
                return Ok(JsValue.Function(id: fn_id))
            JsExpression.SpreadElement(argument):
                # Spread is handled at call sites; evaluate the argument
                return self.eval_expression(argument, env)
            JsExpression.TemplateLiteral(quasis, expressions):
                return self.eval_template_literal(quasis, expressions, env)
            JsExpression.Delete(del_expr):
                return self.eval_delete(del_expr, env)
            JsExpression.InstanceOf(left, right):
                # Simplified instanceof: checks if right is a constructor function
                val lv = self.eval_expression(left, env)?
                val rv = self.eval_expression(right, env)?
                # Basic: check if left is an object
                match lv:
                    JsValue.Object(id):
                        return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: false))
            JsExpression.InExpr(left, right):
                val key = self.eval_expression(left, env)?
                val obj = self.eval_expression(right, env)?
                val key_str = js_to_string(key)
                match obj:
                    JsValue.Object(id):
                        match self.get_object_property(id, key_str):
                            JsValue.Undefined: return Ok(JsValue.Boolean(v: false))
                            _: return Ok(JsValue.Boolean(v: true))
                    JsValue.Array(id):
                        match self.get_object_property(id, key_str):
                            JsValue.Undefined: return Ok(JsValue.Boolean(v: false))
                            _: return Ok(JsValue.Boolean(v: true))
                    _:
                        return Ok(JsValue.Boolean(v: false))
            JsExpression.NewExpr(callee, args):
                return self.eval_new(callee, args, env)
            JsExpression.ComputedMember(object, property):
                val obj_val = self.eval_expression(object, env)?
                val key_val = self.eval_expression(property, env)?
                var key_str = js_to_string(key_val)
                match key_val:
                    JsValue.Number(n):
                        key_str = "{f64_to_i64(n)}"
                    _:
                        pass_dn
                match obj_val:
                    JsValue.Object(id):
                        return Ok(self.get_object_property(id, key_str))
                    JsValue.Array(id):
                        return Ok(self.get_object_property(id, key_str))
                    _:
                        return Ok(JsValue.Undefined)
            JsExpression.ObjectPattern(props):
                return Ok(JsValue.Undefined)
            JsExpression.ArrayPattern(elements):
                return Ok(JsValue.Undefined)
            JsExpression.RegexLiteral(pattern, flags):
                return Ok(self._create_regex_value(pattern, flags))

    # Regex literal /pattern/flags — materialized as a plain object carrying
    # source/flags/global/ignoreCase/multiline plus an internal marker so
    # callers (e.g. String.prototype.replace) can detect "this argument is a
    # regex" without a dedicated JsValue variant (which would ripple through
    # every exhaustive match on JsValue across the interpreter).
    me _create_regex_value(pattern: text, flags: text) -> JsValue:
        val obj_id = self.create_object()
        self.set_object_property(obj_id, "__simple_is_regexp", JsValue.Boolean(v: true))
        self.set_object_property(obj_id, "source", JsValue.String(v: pattern))
        self.set_object_property(obj_id, "flags", JsValue.String(v: flags))
        self.set_object_property(obj_id, "global", JsValue.Boolean(v: flags.contains("g")))
        self.set_object_property(obj_id, "ignoreCase", JsValue.Boolean(v: flags.contains("i")))
        self.set_object_property(obj_id, "multiline", JsValue.Boolean(v: flags.contains("m")))
        self.set_object_property(obj_id, "lastIndex", JsValue.Number(v: 0.0))
        JsValue.Object(id: obj_id)

    # new operator: new Foo(args)
    me eval_new(callee: JsExpression, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val callee_val = self.eval_expression(callee, env)?
        var arg_vals: [JsValue] = []
        var i = 0
        while i < args.len():
            arg_vals.push(self.eval_expression(args.get(i), env)?)
            i = i + 1
        match callee_val:
            JsValue.Function(fn_id):
                var ni = 0
                while ni < self.native_id_map.len():
                    val mapping = self.native_id_map.get(ni)
                    if mapping.first == fn_id:
                        return Ok(self._dispatch_native_with_receiver(mapping.second, JsValue.Undefined, arg_vals, env))
                    ni = ni + 1
                val obj_id = self.create_object()
                val this_val = JsValue.Object(id: obj_id)
                # Set __proto__ to the class prototype for method lookup
                val proto_id = self._find_class_proto(fn_id)
                if proto_id >= 0:
                    self.set_object_property(obj_id, "__proto__", JsValue.Object(id: proto_id))
                if fn_id >= 0 and fn_id < self.functions.len():
                    val js_fn = self.functions.get(fn_id)
                    val params = js_fn.params
                    val fn_env = self.env_stack.create_env(js_fn.closure_env)
                    var pi = 0
                    while pi < params.len():
                        var pv = JsValue.Undefined
                        if pi < arg_vals.len():
                            pv = arg_vals.get(pi)
                        self.env_stack.define_var(fn_env, params.get(pi), pv)
                        pi = pi + 1
                    self.env_stack.define_var(fn_env, "this", this_val)
                    val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: this_val)
                    self.call_stack.push(frame)
                    val saved = self.control_return
                    self.control_return = false
                    var bi = 0
                    while bi < js_fn.body.len():
                        self.exec_statement(js_fn.body.get(bi), fn_env)?
                        if self.control_return:
                            break
                        bi = bi + 1
                    self.call_stack.pop()
                    self.control_return = saved
                return Ok(this_val)
            _:
                return Ok(JsValue.Undefined)

    # Binary operators
    me eval_binary(op: text, left: JsExpression, right: JsExpression, env: i64) -> BrowserResult<JsValue>:
        # Comma operator — evaluate left for side effects, return right
        if op == ",":
            self.eval_expression(left, env)?
            return self.eval_expression(right, env)

        # Short-circuit logical operators
        if op == "&&":
            val lv = self.eval_expression(left, env)?
            if not is_truthy(lv):
                return Ok(lv)
            return self.eval_expression(right, env)

        if op == "||":
            val lv = self.eval_expression(left, env)?
            if is_truthy(lv):
                return Ok(lv)
            return self.eval_expression(right, env)

        if op == "??":
            val lv = self.eval_expression(left, env)?
            match lv:
                JsValue.Null: return self.eval_expression(right, env)
                JsValue.Undefined: return self.eval_expression(right, env)
                _: return Ok(lv)

        val lv = self.eval_expression(left, env)?
        val rv = self.eval_expression(right, env)?

        # String concatenation with +
        if op == "+":
            val ls = typeof_value(lv)
            val rs = typeof_value(rv)
            if ls == "string" or rs == "string" or self._is_stringish(lv) or self._is_stringish(rv):
                var left_text = js_to_string(lv)
                var right_text = js_to_string(rv)
                match lv:
                    JsValue.Object(obj_id):
                        match self.get_object_property(obj_id, "__simple_promise_host"):
                            JsValue.Boolean(is_host):
                                if is_host:
                                    match self.get_object_property(obj_id, "__simple_state"):
                                        JsValue.String(state):
                                            if state == "fulfilled":
                                                left_text = js_to_string(self.get_object_property(obj_id, "__simple_value"))
                                        _:
                                            pass_dn
                            _:
                                pass_dn
                    _:
                        pass_dn
                match rv:
                    JsValue.Object(obj_id):
                        match self.get_object_property(obj_id, "__simple_promise_host"):
                            JsValue.Boolean(is_host):
                                if is_host:
                                    match self.get_object_property(obj_id, "__simple_state"):
                                        JsValue.String(state):
                                            if state == "fulfilled":
                                                right_text = js_to_string(self.get_object_property(obj_id, "__simple_value"))
                                        _:
                                            pass_dn
                            _:
                                pass_dn
                    _:
                        pass_dn
                val result = left_text + right_text
                return Ok(JsValue.String(v: result))
            val ln = to_number(lv)
            val rn = to_number(rv)
            return Ok(JsValue.Number(v: ln + rn))

        if op == "-":
            return Ok(JsValue.Number(v: to_number(lv) - to_number(rv)))
        if op == "*":
            return Ok(JsValue.Number(v: to_number(lv) * to_number(rv)))
        if op == "/":
            val divisor = to_number(rv)
            if divisor == 0.0:
                return Ok(JsValue.Number(v: js_infinity()))  # Infinity
            return Ok(JsValue.Number(v: to_number(lv) / divisor))
        if op == "%":
            val divisor = to_number(rv)
            if divisor == 0.0:
                return Ok(JsValue.Number(v: js_nan()))  # NaN
            return Ok(JsValue.Number(v: to_number(lv) % divisor))
        if op == "**":
            val base = to_number(lv)
            val exp = to_number(rv)
            return Ok(JsValue.Number(v: base ** exp))

        # Comparison
        if op == "<":
            return Ok(JsValue.Boolean(v: to_number(lv) < to_number(rv)))
        if op == ">":
            return Ok(JsValue.Boolean(v: to_number(lv) > to_number(rv)))
        if op == "<=":
            return Ok(JsValue.Boolean(v: to_number(lv) <= to_number(rv)))
        if op == ">=":
            return Ok(JsValue.Boolean(v: to_number(lv) >= to_number(rv)))

        # Equality
        if op == "==":
            return Ok(JsValue.Boolean(v: abstract_equals(lv, rv)))
        if op == "===":
            return Ok(JsValue.Boolean(v: strict_equals(lv, rv)))
        if op == "!=":
            return Ok(JsValue.Boolean(v: not abstract_equals(lv, rv)))
        if op == "!==":
            return Ok(JsValue.Boolean(v: not strict_equals(lv, rv)))

        # Bitwise
        if op == "&":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li & ri).to_f64()))
        if op == "|":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li | ri).to_f64()))
        if op == "^":
            val li = f64_to_i64(to_number(lv))
            val ri = f64_to_i64(to_number(rv))
            return Ok(JsValue.Number(v: (li ^ ri).to_f64()))

        # Computed property access: obj[key]
        if op == "[]":
            match lv:
                JsValue.Object(id):
                    return Ok(self.get_object_property(id, js_to_string(rv)))
                JsValue.Array(id):
                    return Ok(self.get_object_property(id, js_to_string(rv)))
                JsValue.String(sv):
                    val idx = f64_to_i64(to_number(rv))
                    if idx >= 0 and idx < sv.len():
                        return Ok(JsValue.String(v: sv[idx]))
                    return Ok(JsValue.Undefined)
                _:
                    return Ok(JsValue.Undefined)

        self.logger.warn("Unknown binary operator: {op}")
        Ok(JsValue.Undefined)

    # Unary operators
    me eval_unary(op: text, operand: JsExpression, env: i64) -> BrowserResult<JsValue>:
        if op == "typeof":
            match operand:
                JsExpression.Identifier(name):
                    if env == self.global_env:
                        val cached = self.lookup_global_value(name)
                        if val Some(v) = cached:
                            return Ok(JsValue.String(v: typeof_value(v)))
                        if name == "setImmediate":
                            val immediate_fn = JsValue.Function(id: self._register_native("setImmediate", NATIVE_SET_IMMEDIATE))
                            self.define_global_value("setImmediate", immediate_fn)
                            return Ok(JsValue.String(v: typeof_value(immediate_fn)))
                        if name == "clearImmediate":
                            val clear_immediate_fn = JsValue.Function(id: self._register_native("clearImmediate", NATIVE_CLEAR_IMMEDIATE))
                            self.define_global_value("clearImmediate", clear_immediate_fn)
                            return Ok(JsValue.String(v: typeof_value(clear_immediate_fn)))
                        if name == "Promise":
                            # Promise is a constructor (callable), but this
                            # interpreter represents it internally as a plain
                            # Object carrying resolve/reject/prototype (see
                            # _promise_global_object) rather than a JsValue.Function,
                            # so typeof needs an explicit override here to match
                            # real JS: `typeof Promise === "function"`.
                            return Ok(JsValue.String(v: "function"))
                        # Fall through to eval_expression: it is the single source of
                        # truth for pseudo-globals (window, document, Promise, Buffer,
                        # process, require, setTimeout, clearTimeout, ...). Duplicating
                        # that name list here previously drifted out of sync and caused
                        # `typeof Promise` etc. to wrongly report "undefined" even
                        # though the identifier resolves fine outside of `typeof`.
                        val resolved = self.eval_expression(operand, env)?
                        return Ok(JsValue.String(v: typeof_value(resolved)))
                    val lookup = self.env_stack.get_var(env, name)
                    if val Some(v) = lookup:
                        return Ok(JsValue.String(v: typeof_value(v)))
                    val resolved_local = self.eval_expression(operand, env)?
                    return Ok(JsValue.String(v: typeof_value(resolved_local)))
                _:
                    val v = self.eval_expression(operand, env)?
                    return Ok(JsValue.String(v: typeof_value(v)))

        val v = self.eval_expression(operand, env)?

        if op == "!":
            return Ok(JsValue.Boolean(v: not is_truthy(v)))
        if op == "-":
            return Ok(JsValue.Number(v: 0.0 - to_number(v)))
        if op == "+":
            return Ok(JsValue.Number(v: to_number(v)))
        if op == "~":
            val n = f64_to_i64(to_number(v))
            return Ok(JsValue.Number(v: (0 - n - 1).to_f64()))
        if op == "void":
            return Ok(JsValue.Undefined)

        # Pre/post increment/decrement
        if op == "++pre" or op == "++post":
            val n = to_number(v)
            val new_val = JsValue.Number(v: n + 1.0)
            match operand:
                JsExpression.Identifier(name):
                    self.env_stack.set_var(env, name, new_val)
                _: pass_dn
            if op == "++pre":
                return Ok(new_val)
            return Ok(v)  # post returns old value

        if op == "--pre" or op == "--post":
            val n = to_number(v)
            val new_val = JsValue.Number(v: n - 1.0)
            match operand:
                JsExpression.Identifier(name):
                    self.env_stack.set_var(env, name, new_val)
                _: pass_dn
            if op == "--pre":
                return Ok(new_val)
            return Ok(v)

        if op == "new":
            # new Constructor(args) — allocate object, set prototype, call constructor, return
            match operand:
                JsExpression.Call(callee, args):
                    val callee_val = self.eval_expression(callee, env)?
                    var arg_vals: [JsValue] = []
                    var ai = 0
                    val alen = args.len()
                    while ai < alen:
                        val av = self.eval_expression(args.get(ai), env)?
                        arg_vals.push(av)
                        ai = ai + 1
                    # Allocate new object
                    val obj_id = self.create_object()
                    val new_obj = JsValue.Object(id: obj_id)
                    # Link prototype chain (for class methods)
                    val ctor_fn_id = _get_fn_id(callee_val)
                    if ctor_fn_id >= 0:
                        val proto_id = self._find_class_proto(ctor_fn_id)
                        if proto_id >= 0:
                            self.set_object_property(obj_id, "__proto__", JsValue.Object(id: proto_id))
                    # Call constructor with 'this' bound to new object
                    match callee_val:
                        JsValue.Function(fn_id):
                            if fn_id >= 0 and fn_id < self.functions.len():
                                val js_fn = self.functions.get(fn_id)
                                val fn_env = self.env_stack.create_env(js_fn.closure_env)
                                # Bind parameters
                                var pi = 0
                                val plen = js_fn.params.len()
                                while pi < plen:
                                    val pname = js_fn.params.get(pi)
                                    var pval = JsValue.Undefined
                                    if pi < arg_vals.len():
                                        pval = arg_vals.get(pi)
                                    self.env_stack.define_var(fn_env, pname, pval)
                                    pi = pi + 1
                                self.env_stack.define_var(fn_env, "this", new_obj)
                                val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: new_obj)
                                self.call_stack.push(frame)
                                val saved = self.control_return
                                self.control_return = false
                                var bi = 0
                                val blen = js_fn.body.len()
                                while bi < blen:
                                    self.exec_statement(js_fn.body.get(bi), fn_env)?
                                    if self.control_return:
                                        break
                                    bi = bi + 1
                                self.call_stack.pop()
                                self.control_return = saved
                        _: pass_dn
                    return Ok(new_obj)
                _:
                    # Simple new without call
                    val obj_id = self.create_object()
                    return Ok(JsValue.Object(id: obj_id))

        self.logger.warn("Unknown unary operator: {op}")
        Ok(JsValue.Undefined)

    # Function call
    me eval_call(callee: JsExpression, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        # Array method dispatch — avoid nested match/return (interpreter mode issue)
        var is_member = false
        var member_method = ""
        var member_obj_expr = JsExpression.Literal(value: JsValue.Undefined)
        match callee:
            JsExpression.Member(obj_expr, method_name):
                is_member = true
                member_method = method_name
                member_obj_expr = obj_expr
            JsExpression.ComputedMember(obj_expr, prop_expr):
                is_member = true
                match prop_expr:
                    JsExpression.Literal(value):
                        match value:
                            JsValue.String(v):
                                member_method = v
                            _:
                                member_method = js_to_string(value)
                    _:
                        member_method = js_to_string(self.eval_expression(prop_expr, env)?)
                member_obj_expr = obj_expr
            _: pass_dn

        if is_member and member_method == "cwd":
            match member_obj_expr:
                JsExpression.Identifier(obj_name):
                    if obj_name == "process":
                        return Ok(JsValue.String(v: "/"))
                _: pass_dn

        if is_member and member_method == "byteLength":
            var byte_length_global = false
            match member_obj_expr:
                JsExpression.Member(root_expr, root_prop):
                    if root_prop == "Buffer":
                        match root_expr:
                            JsExpression.Identifier(root_name):
                                if root_name == "globalThis":
                                    byte_length_global = true
                            _: pass_dn
                _: pass_dn
            if byte_length_global:
