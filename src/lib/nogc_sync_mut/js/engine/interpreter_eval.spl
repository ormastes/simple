                self.bound_function_arg_array_ids.push(bound_args_id)
                return Ok(JsValue.Function(id: bound_fn_id))

        # Object.keys / Object.values / Object.entries
        if is_member and member_method == "keys":
            val callee_obj_name = self.ident_name(member_obj_expr)
            if callee_obj_name == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            self.set_object_property(result_id, "{ki}", JsValue.String(v: prop.key))
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        if is_member and member_method == "values":
            val callee_obj_name_v = self.ident_name(member_obj_expr)
            if callee_obj_name_v == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            self.set_object_property(result_id, "{ki}", prop.value)
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        if is_member and member_method == "entries":
            val callee_obj_name_e = self.ident_name(member_obj_expr)
            if callee_obj_name_e == "Object":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val obj = self.object_store.get_object(arg_id)
                        val result_id = self.create_object()
                        var ki = 0
                        while ki < obj.properties.len():
                            val prop = obj.properties.get(ki)
                            val entry_id = self.create_object()
                            self.set_object_property(entry_id, "0", JsValue.String(v: prop.key))
                            self.set_object_property(entry_id, "1", prop.value)
                            self.set_object_property(entry_id, "length", JsValue.Number(v: 2.0))
                            self.set_object_property(result_id, "{ki}", JsValue.Array(id: entry_id))
                            ki = ki + 1
                        self.set_object_property(result_id, "length", JsValue.Number(v: ki.to_f64()))
                        return Ok(JsValue.Array(id: result_id))
                return Ok(JsValue.Array(id: self.create_object()))

        # Object.assign
        if is_member and member_method == "assign":
            val callee_obj_name_oa = self.ident_name(member_obj_expr)
            if callee_obj_name_oa == "Object":
                if args.len() >= 1:
                    val target = self.eval_expression(args.get(0), env)?
                    val target_id = _get_obj_id(target)
                    if target_id >= 0:
                        var ai = 1
                        while ai < args.len():
                            val source = self.eval_expression(args.get(ai), env)?
                            val source_id = _get_obj_id(source)
                            if source_id >= 0:
                                val src_obj = self.object_store.get_object(source_id)
                                var pi = 0
                                while pi < src_obj.properties.len():
                                    val prop = src_obj.properties.get(pi)
                                    self.set_object_property(target_id, prop.key, prop.value)
                                    pi = pi + 1
                            ai = ai + 1
                        return Ok(target)
                return Ok(JsValue.Undefined)

        # Object.freeze prevents future writes through the central property setter.
        if is_member and member_method == "freeze":
            val callee_obj_name_of = self.ident_name(member_obj_expr)
            if callee_obj_name_of == "Object":
                if args.len() > 0:
                    val frozen_target = self.eval_expression(args.get(0), env)?
                    val frozen_id = _get_obj_id(frozen_target)
                    if frozen_id >= 0:
                        self._mark_object_frozen(frozen_id)
                    return Ok(frozen_target)
                return Ok(JsValue.Undefined)

        # Object.isFrozen
        if is_member and member_method == "isFrozen":
            val callee_obj_name_oif = self.ident_name(member_obj_expr)
            if callee_obj_name_oif == "Object":
                if args.len() > 0:
                    val frozen_check_target = self.eval_expression(args.get(0), env)?
                    val frozen_check_id = _get_obj_id(frozen_check_target)
                    return Ok(JsValue.Boolean(v: frozen_check_id >= 0 and self._is_object_frozen(frozen_check_id)))
                return Ok(JsValue.Boolean(v: false))

        # Number.isInteger / Number.isFinite / Number.isNaN / Number.parseInt / Number.parseFloat
        if is_member and (member_method == "isInteger" or member_method == "isFinite" or member_method == "isNaN" or member_method == "parseInt" or member_method == "parseFloat"):
            val callee_obj_name_n = self.ident_name(member_obj_expr)
            if callee_obj_name_n == "Number":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val n = to_number(arg)
                    if member_method == "isInteger":
                        val int_val = f64_to_i64(n)
                        return Ok(JsValue.Boolean(v: int_val.to_f64() == n))
                    if member_method == "isFinite":
                        val is_inf = n == 9999999999.0
                        val is_neg_inf = n == -9999999999.0
                        val is_nan_val = n == -9999999999.999
                        return Ok(JsValue.Boolean(v: not is_inf and not is_neg_inf and not is_nan_val))
                    if member_method == "isNaN":
                        return Ok(JsValue.Boolean(v: n == -9999999999.999))
                    if member_method == "parseInt":
                        val s = js_to_string(arg)
                        val parsed = s.parse_float()
                        if val Some(pv) = parsed:
                            return Ok(JsValue.Number(v: f64_to_i64(pv).to_f64()))
                        return Ok(JsValue.Number(v: -9999999999.999))
                    if member_method == "parseFloat":
                        val s = js_to_string(arg)
                        val parsed = s.parse_float()
                        if val Some(pv) = parsed:
                            return Ok(JsValue.Number(v: pv))
                        return Ok(JsValue.Number(v: -9999999999.999))
                return Ok(JsValue.Boolean(v: false))

        # JSON.stringify
        if is_member and member_method == "stringify":
            val callee_obj_name_js = self.ident_name(member_obj_expr)
            if callee_obj_name_js == "JSON":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val json_str = self._json_stringify(arg)
                    return Ok(JsValue.String(v: json_str))
                return Ok(JsValue.String(v: "undefined"))

        # JSON.parse
        if is_member and member_method == "parse":
            val callee_obj_name_jp = self.ident_name(member_obj_expr)
            if callee_obj_name_jp == "JSON":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    return self._json_parse_allocated(js_to_string(arg), env)
                return Ok(JsValue.Undefined)

        # Promise.resolve / Promise.reject
        if is_member and (member_method == "resolve" or member_method == "reject"):
            val callee_obj_name_p = self.ident_name(member_obj_expr)
            if callee_obj_name_p == "Promise":
                var promise_arg_vals: [JsValue] = []
                if args.len() > 0:
                    promise_arg_vals.push(self.eval_expression(args.get(0), env)?)
                if member_method == "resolve":
                    return Ok(self._native_promise_resolve(promise_arg_vals))
                return Ok(self._native_promise_reject(promise_arg_vals))

        # Array.isArray / Array.from
        if is_member and member_method == "isArray":
            val callee_obj_name_a = self.ident_name(member_obj_expr)
            if callee_obj_name_a == "Array":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    return Ok(JsValue.Boolean(v: array_isArray(arg)))
                return Ok(JsValue.Boolean(v: false))

        if is_member and member_method == "isView":
            val callee_obj_name_ab = self.ident_name(member_obj_expr)
            if callee_obj_name_ab == "ArrayBuffer":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        var is_view = false
                        match self.get_object_property(arg_id, "__simple_typed_array"):
                            JsValue.Boolean(v):
                                if v:
                                    is_view = true
                            _:
                                pass_dn
                        match self.get_object_property(arg_id, "__simple_data_view"):
                            JsValue.Boolean(v):
                                if v:
                                    is_view = true
                            _:
                                pass_dn
                        if is_view:
                            return Ok(JsValue.Boolean(v: true))
                return Ok(JsValue.Boolean(v: false))

        if is_member and member_method == "from":
            val callee_obj_name_f = self.ident_name(member_obj_expr)
            if callee_obj_name_f == "Uint8Array":
                if args.len() > 0:
                    val source = self.eval_expression(args.get(0), env)?
                    val source_id = _get_obj_id(source)
                    if source_id >= 0:
                        val source_len = self._native_indexed_length(source_id)
                        var bytes: [u8] = []
                        var map_fn_id = -1
                        if args.len() > 1:
                            val map_fn = self.eval_expression(args.get(1), env)?
                            map_fn_id = _get_fn_id(map_fn)
                        var ui = 0
                        while ui < source_len:
                            var elem = self.get_object_property(source_id, ui.to_text())
                            if map_fn_id >= 0:
                                elem = self._invoke_function(map_fn_id, [elem, JsValue.Number(v: ui.to_f64())], env)?
                            bytes.push(self._native_uint8_array_normalized_byte(elem))
                            ui = ui + 1
                        return Ok(self._native_uint8_array_from_bytes(bytes))
                return Ok(self._native_uint8_array_from_bytes([]))
            if callee_obj_name_f == "Array":
                if args.len() > 0:
                    val arg = self.eval_expression(args.get(0), env)?
                    val arg_id = _get_obj_id(arg)
                    if arg_id >= 0:
                        val arr_len = self.object_store.array_length(arg_id)
                        val new_id = self.create_object()
                        var ai = 0
                        while ai < arr_len:
                            val elem = self.object_store.get_by_index(arg_id, ai)
                            self.set_object_property(new_id, "{ai}", elem)
                            ai = ai + 1
                        self.set_object_property(new_id, "length", JsValue.Number(v: arr_len.to_f64()))
                        return Ok(JsValue.Array(id: new_id))
                return Ok(JsValue.Array(id: self.create_object()))

        if is_member and member_method == "of":
            val callee_obj_name_o = self.ident_name(member_obj_expr)
            if callee_obj_name_o == "Uint8Array":
                var bytes: [u8] = []
                var oi = 0
                while oi < args.len():
                    val elem = self.eval_expression(args.get(oi), env)?
                    bytes.push(self._native_uint8_array_normalized_byte(elem))
                    oi = oi + 1
                return Ok(self._native_uint8_array_from_bytes(bytes))

        var callee_val = JsValue.Undefined
        var this_val_for_call = JsValue.Undefined
        if is_member:
            this_val_for_call = self.eval_expression(member_obj_expr, env)?
            val member_obj_id = _get_obj_id(this_val_for_call)
            if member_obj_id >= 0:
                callee_val = self._proto_lookup(member_obj_id, member_method)
            else:
                callee_val = JsValue.Undefined
        else:
            callee_val = self.eval_expression(callee, env)?

        # Evaluate arguments
        var arg_vals: [JsValue] = []
        var i = 0
        val alen = args.len()
        while i < alen:
            val arg_val = self.eval_expression(args.get(i), env)?
            arg_vals.push(arg_val)
            i = i + 1

        # Look up function
        match callee_val:
            JsValue.Function(fn_id):
                if fn_id >= 0 and fn_id < self.functions.len():
                    var bound_direct_i = 0
                    while bound_direct_i < self.bound_function_ids.len():
                        if self.bound_function_ids.get(bound_direct_i) == fn_id:
                            return self._invoke_function_with_this(fn_id, arg_vals, env, this_val_for_call)
                        bound_direct_i = bound_direct_i + 1
                    # Check if this function index maps to a native function
                    var ni = 0
                    while ni < self.native_id_map.len():
                        val mapping = self.native_id_map.get(ni)
                        if mapping.first == fn_id:
                            var this_val = JsValue.Undefined
                            if is_member:
                                this_val = this_val_for_call
                            if mapping.second == NATIVE_WEBASSEMBLY_INSTANTIATE_THEN:
                                var wasm_status = ""
                                val wasm_result_id = _get_obj_id(this_val)
                                if wasm_result_id >= 0:
                                    match self.get_object_property(wasm_result_id, "status"):
                                        JsValue.String(v): wasm_status = v
                                        _: pass_dn
                                var wasm_callback_id = -1
                                if wasm_status == "instantiated" and arg_vals.len() > 0:
                                    wasm_callback_id = _get_fn_id(arg_vals.get(0))
                                if wasm_status != "instantiated" and arg_vals.len() > 1:
                                    wasm_callback_id = _get_fn_id(arg_vals.get(1))
                                if wasm_callback_id >= 0 and wasm_callback_id < self.functions.len():
                                    val wasm_fn = self.functions.get(wasm_callback_id)
                                    val wasm_env = self.env_stack.create_env(wasm_fn.closure_env)
                                    var wpi = 0
                                    while wpi < wasm_fn.params.len():
                                        var wpv = JsValue.Undefined
                                        if wpi == 0:
                                            wpv = this_val
                                        self.env_stack.define_var(wasm_env, wasm_fn.params.get(wpi), wpv)
                                        wpi = wpi + 1
                                    self.env_stack.define_var(wasm_env, "this", JsValue.Undefined)
                                    val wasm_frame = CallFrame(function_name: wasm_fn.name, env_id: wasm_env, line: 0, this_value: JsValue.Undefined)
                                    self.call_stack.push(wasm_frame)
                                    val wasm_saved_return = self.control_return
                                    self.control_return = false
                                    var wasm_result = JsValue.Undefined
                                    var wbi = 0
                                    while wbi < wasm_fn.body.len():
                                        wasm_result = self.exec_statement(wasm_fn.body.get(wbi), wasm_env)?
                                        if self.control_return:
                                            wasm_result = self.return_value
                                            break
                                        wbi = wbi + 1
                                    self.call_stack.pop()
                                    self.control_return = wasm_saved_return
                                    return Ok(wasm_result)
                            if mapping.second == NATIVE_WEBASSEMBLY_COMPILE_THEN or mapping.second == NATIVE_WEBASSEMBLY_COMPILE_CATCH:
                                var compile_status = ""
                                val compile_result_id = _get_obj_id(this_val)
                                if compile_result_id >= 0:
                                    match self.get_object_property(compile_result_id, "status"):
                                        JsValue.String(v): compile_status = v
                                        _: pass_dn
                                var compile_callback_id = -1
                                if mapping.second == NATIVE_WEBASSEMBLY_COMPILE_THEN:
                                    if compile_status == "compiled" and arg_vals.len() > 0:
                                        compile_callback_id = _get_fn_id(arg_vals.get(0))
                                    if compile_status != "compiled" and arg_vals.len() > 1:
                                        compile_callback_id = _get_fn_id(arg_vals.get(1))
                                if mapping.second == NATIVE_WEBASSEMBLY_COMPILE_CATCH:
                                    if compile_status != "compiled" and arg_vals.len() > 0:
                                        compile_callback_id = _get_fn_id(arg_vals.get(0))
                                if compile_callback_id >= 0 and compile_callback_id < self.functions.len():
                                    val compile_fn = self.functions.get(compile_callback_id)
                                    val compile_env = self.env_stack.create_env(compile_fn.closure_env)
                                    var cpi = 0
                                    while cpi < compile_fn.params.len():
                                        var cpv = JsValue.Undefined
                                        if cpi == 0:
                                            if compile_status == "compiled":
                                                cpv = self.get_object_property(compile_result_id, "module")
                                            else:
                                                cpv = this_val
                                        self.env_stack.define_var(compile_env, compile_fn.params.get(cpi), cpv)
                                        cpi = cpi + 1
                                    self.env_stack.define_var(compile_env, "this", JsValue.Undefined)
                                    val compile_frame = CallFrame(function_name: compile_fn.name, env_id: compile_env, line: 0, this_value: JsValue.Undefined)
                                    self.call_stack.push(compile_frame)
                                    val compile_saved_return = self.control_return
                                    self.control_return = false
                                    var compile_result = JsValue.Undefined
                                    var cbi = 0
                                    while cbi < compile_fn.body.len():
                                        compile_result = self.exec_statement(compile_fn.body.get(cbi), compile_env)?
                                        if self.control_return:
                                            compile_result = self.return_value
                                            break
                                        cbi = cbi + 1
                                    self.call_stack.pop()
                                    self.control_return = compile_saved_return
                                    return Ok(compile_result)
                            if mapping.second == NATIVE_WEBASSEMBLY_EXPORT_FUNCTION:
                                return Ok(self._native_webassembly_export_function(this_val, arg_vals, fn_id))
                            if mapping.second == NATIVE_UINT8_ARRAY_SUBARRAY:
                                val native_fn = self.functions.get(fn_id)
                                if native_fn.name == "slice":
                                    var uint8_slice_args: [JsValue] = []
                                    var uint8_slice_i = 0
                                    while uint8_slice_i < arg_vals.len():
                                        uint8_slice_args.push(arg_vals.get(uint8_slice_i))
                                        uint8_slice_i = uint8_slice_i + 1
                                    uint8_slice_args.push(JsValue.String(v: "__simple_uint8_slice_copy"))
                                    return Ok(self._dispatch_native_with_receiver(mapping.second, this_val, uint8_slice_args, env))
                            return Ok(self._dispatch_native_with_receiver(mapping.second, this_val, arg_vals, env))
                        ni = ni + 1
                    val js_fn = self.functions.get(fn_id)
                    # Create function scope from closure env
                    val fn_env = self.env_stack.create_env(js_fn.closure_env)

                    # Bind parameters
                    var pi = 0
                    val plen = js_fn.params.len()
                    while pi < plen:
                        val param_name = js_fn.params.get(pi)
                        var param_val = JsValue.Undefined
                        if pi < arg_vals.len():
                            param_val = arg_vals.get(pi)
                        self.env_stack.define_var(fn_env, param_name, param_val)
                        pi = pi + 1

                    # Bind 'arguments' object
                    val args_obj_id = self.create_object()
                    var ai = 0
                    while ai < arg_vals.len():
                        self.set_object_property(args_obj_id, "{ai}", arg_vals.get(ai))
                        ai = ai + 1
                    self.set_object_property(args_obj_id, "length", JsValue.Number(v: arg_vals.len().to_f64()))
                    self.env_stack.define_var(fn_env, "arguments", JsValue.Object(id: args_obj_id))

                    # Bind 'this' — for method calls, the receiver is tracked via callee
                    var this_val = JsValue.Undefined
                    if is_member:
                        this_val = this_val_for_call
                    self.env_stack.define_var(fn_env, "this", this_val)

                    # Push call frame
                    val frame = CallFrame(function_name: js_fn.name, env_id: fn_env, line: 0, this_value: this_val)
                    self.call_stack.push(frame)

                    # Execute body
                    val saved_control_return = self.control_return
                    self.control_return = false
                    var result = JsValue.Undefined
                    var bi = 0
                    val blen = js_fn.body.len()
                    while bi < blen:
                        result = self.exec_statement(js_fn.body.get(bi), fn_env)?
                        if self.control_return:
                            result = self.return_value
                            break
                        bi = bi + 1

                    # Pop call frame and reset return flag
                    self.call_stack.pop()
                    self.control_return = saved_control_return

                    return Ok(result)
                self.logger.warn("Invalid function id: {fn_id}")
                return Ok(JsValue.Undefined)
            _:
                # Trying to call a non-function
                self.logger.warn("TypeError: {js_to_string(callee_val)} is not a function")
                return Ok(JsValue.Undefined)

    me _uint8_array_prototype_method_name(expr: JsExpression) -> text:
        var resolved_method = ""
        match expr:
            JsExpression.Member(obj_expr, method_name):
                match obj_expr:
                    JsExpression.Member(root_expr, proto_name):
                        if proto_name == "prototype":
                            match root_expr:
                                JsExpression.Identifier(root_name):
                                    if root_name == "Uint8Array":
                                        resolved_method = method_name
                                _:
                                    pass_dn
                    _:
                        pass_dn
            JsExpression.ComputedMember(obj_expr, prop_expr):
                var prop_name = ""
                match prop_expr:
                    JsExpression.Literal(value):
                        match value:
                            JsValue.String(v):
                                prop_name = v
                            _:
                                prop_name = js_to_string(value)
                    JsExpression.Member(symbol_expr, symbol_prop):
                        match symbol_expr:
                            JsExpression.Identifier(symbol_name):
                                if symbol_name == "Symbol" and symbol_prop == "iterator":
                                    prop_name = "Symbol.iterator"
                            _:
                                pass_dn
                    _:
                        pass_dn
                if prop_name != "":
                    match obj_expr:
                        JsExpression.Member(root_expr, proto_name):
                            if proto_name == "prototype":
                                match root_expr:
                                    JsExpression.Identifier(root_name):
                                        if root_name == "Uint8Array":
                                            resolved_method = prop_name
                                    _:
                                        pass_dn
                        _:
                            pass_dn
            _:
                pass_dn
        resolved_method

    me _indexed_arg_values(args_val: JsValue) -> [JsValue]:
        val args_id = _get_obj_id(args_val)
        var result: [JsValue] = []
        if args_id >= 0:
            var arg_len = self.object_store.array_length(args_id)
            match self.get_object_property(args_id, "length"):
                JsValue.Number(v):
                    arg_len = f64_to_i64(v)
                _:
                    pass_dn
            var ai = 0
            while ai < arg_len:
                result.push(self.get_object_property(args_id, ai.to_text()))
                ai = ai + 1
        result

    me _data_view_prototype_method_name(expr: JsExpression) -> text:
        var resolved_method = ""
        match expr:
            JsExpression.Member(obj_expr, method_name):
                match obj_expr:
                    JsExpression.Member(root_expr, proto_name):
                        if proto_name == "prototype":
                            match root_expr:
                                JsExpression.Identifier(root_name):
                                    if root_name == "DataView":
                                        resolved_method = method_name
                                _:
                                    pass_dn
                    _:
                        pass_dn
            _:
                pass_dn
        resolved_method

    me _array_buffer_prototype_method_name(expr: JsExpression) -> text:
        var resolved_method = ""
        match expr:
            JsExpression.Member(obj_expr, method_name):
                match obj_expr:
                    JsExpression.Member(root_expr, proto_name):
                        if proto_name == "prototype":
                            match root_expr:
                                JsExpression.Identifier(root_name):
                                    if root_name == "ArrayBuffer":
                                        resolved_method = method_name
                                _:
                                    pass_dn
                    _:
                        pass_dn
            _:
                pass_dn
        resolved_method

    me _dispatch_uint8_array_prototype_method(method_name: text, this_val: JsValue, arg_vals: [JsValue]) -> JsValue:
        if method_name == "set":
            return self._native_uint8_array_set(this_val, arg_vals)
