# Core JS runtime value types for the Simple Browser JS engine.
# JsValue is the tagged union of all JS values.
# JsProperty is the runtime property descriptor (key + evaluated value + flags).
# JsObject holds a flat list of properties for a single object.

# Runtime JS value — all variants that the interpreter can produce.
enum JsValue:
    Undefined
    Null
    Boolean(v: bool)
    Number(v: f64)
    String(v: text)
    Object(id: i64)
    Array(id: i64)
    Function(id: i64)

# A single runtime property on a JS object.
# `value` holds the evaluated JsValue (not an AST expression).
# `enumerable` controls visibility in for-in / Object.keys().
class JsProperty:
    key: text
    value: JsValue
    enumerable: bool

# A JS object represented as an ordered list of named properties.
# Lookups scan the list; the ObjectStore uses parallel arrays for storage,
# but get_object() returns a JsObject for read-only enumeration.
class JsObject:
    properties: [JsProperty]
