# Shared JIT Layout Planning

use std.nogc_sync_mut.jit.jit_types.{JitBinary, JitLayoutPlan}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap}
use std.nogc_sync_mut.debug.remote.types.{Architecture}

fn jit_halt_instruction_size(arch: Architecture) -> i64:
    match arch:
        Architecture.Arm32: 2
        _: 4

fn append_halt_trampoline_arm32(bytes_arg: [i32]) -> [i32]:
    # BKPT (Thumb) = 0xBE00, 2 bytes little-endian
    var bytes = bytes_arg
    val v: i64 = 0xBE00
    bytes.push((v & 0xFF) as i32)
    bytes.push(((v >> 8) & 0xFF) as i32)
    bytes

fn append_halt_trampoline_rv32(bytes_arg: [i32]) -> [i32]:
    # EBREAK = 0x00100073, 4 bytes little-endian
    var bytes = bytes_arg
    val v: i64 = 0x00100073
    bytes.push((v & 0xFF) as i32)
    bytes.push(((v >> 8) & 0xFF) as i32)
    bytes.push(((v >> 16) & 0xFF) as i32)
    bytes.push(((v >> 24) & 0xFF) as i32)
    bytes

fn plan_binary_layout_arm32(binary: JitBinary, limits: MemoryMap) -> Result<JitLayoutPlan, text>:
    val total = binary.size()
    if not limits.allow_expand and total > limits.code_capacity():
        return Err("binary too large for target code region: need {total}, capacity {limits.code_capacity()}")

    val code_base = limits.code_start
    val halt_addr = code_base + total - 2
    Ok(JitLayoutPlan(
        code_base: code_base,
        code_size: total,
        entry_point: code_base + binary.entry_offset,
        halt_addr: halt_addr,
        stack_top: limits.stack_top,
        can_expand: limits.allow_expand
    ))

fn plan_binary_layout_rv32(binary: JitBinary, limits: MemoryMap) -> Result<JitLayoutPlan, text>:
    plan_binary_layout(binary, limits, Architecture.RiscV32)

fn plan_binary_layout(binary: JitBinary, limits: MemoryMap, arch: Architecture) -> Result<JitLayoutPlan, text>:
    val total = binary.size()
    if not limits.allow_expand and total > limits.code_capacity():
        return Err("binary too large for target code region: need {total}, capacity {limits.code_capacity()}")

    val code_base = limits.code_start
    val halt_size = jit_halt_instruction_size(arch)
    val halt_addr = code_base + total - halt_size
    Ok(JitLayoutPlan(
        code_base: code_base,
        code_size: total,
        entry_point: code_base + binary.entry_offset,
        halt_addr: halt_addr,
        stack_top: limits.stack_top,
        can_expand: limits.allow_expand
    ))

fn jit_entry_pc_arm32(plan: JitLayoutPlan) -> i64:
    plan.entry_point + 1

fn jit_return_pc_arm32(plan: JitLayoutPlan) -> i64:
    plan.halt_addr + 1
