# Shared JIT Types

class JitBinary:
    name: text
    bytes: [i32]
    entry_offset: i64
    stack_bytes: i64

    fn size() -> i64:
        self.bytes.len()

class JitLayoutPlan:
    code_base: i64
    code_size: i64
    entry_point: i64
    halt_addr: i64
    stack_top: i64
    can_expand: bool

    fn end_addr() -> i64:
        self.code_base + self.code_size
