# Unified JIT Runner
#
# Single shared orchestration path for local and remote JIT execution.
# Replaces the duplicated runner branches that previously existed for
# each backend/target combination.
#
# Pipeline:
#   1. Validate binary against memory limits
#   2. Append halt trampoline
#   3. Plan binary placement via shared layout planner
#   4. Load binary bytes through backend operations
#   5. Optionally verify uploaded bytes
#   6. Prepare registers (PC, SP, LR/RA)
#   7. Resume execution
#   8. Wait for halt and collect result
#
# The runner does NOT know whether the backend is local, OpenOCD, GDB,
# or WLink. It calls the JitBackendOps contract and delegates all
# backend-specific behavior.

use std.nogc_sync_mut.jit.jit_types.{
    JitBackendKind, JitMemoryLimits, JitBinary, JitLayoutPlan, JitExecResult
}
use std.nogc_sync_mut.jit.jit_layout.{
    plan_binary_layout, append_halt_trampoline_arm32, append_halt_trampoline_rv32,
    jit_entry_pc_arm32, jit_return_pc_arm32
}
use std.nogc_sync_mut.jit.jit_backend.{JitBackendOps, DisconnectedBackendOps}
use std.nogc_sync_mut.debug.remote.types.{Architecture}
use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap,
    pc_register_index, sp_register_index, return_register_index, link_register_index
}

# ============================================================================
# Runner Configuration
# ============================================================================

class JitRunnerConfig:
    """Configuration for a JIT runner session."""
    verify_upload: bool
    timeout_ms: i64
    verbose: bool

    static fn default() -> JitRunnerConfig:
        JitRunnerConfig(verify_upload: false, timeout_ms: 5000, verbose: false)

    static fn with_verify() -> JitRunnerConfig:
        JitRunnerConfig(verify_upload: true, timeout_ms: 5000, verbose: false)

# ============================================================================
# Pipeline Steps (stateless, reusable)
# ============================================================================

fn _limits_to_memory_map(limits: JitMemoryLimits) -> MemoryMap:
    """Convert JitMemoryLimits to the MemoryMap type used by layout planner."""
    MemoryMap(
        code_start: limits.code_start,
        code_end: limits.code_end(),
        data_start: limits.data_start,
        data_end: limits.data_end(),
        stack_top: limits.stack_top,
        allow_expand: limits.allow_expand
    )

fn validate_binary(binary: JitBinary, limits: JitMemoryLimits) -> Result<text, text>:
    """Step 1: Validate binary fits in target memory.

    Remote targets fail early and clearly if the binary is too large.
    Local targets with allow_expand skip this check.
    """
    if limits.allow_expand:
        return Ok("ok")
    if binary.size() > limits.code_capacity:
        return Err("binary '{binary.name}' is {binary.size()} bytes but target code region is {limits.code_capacity} bytes")
    Ok("ok")

fn plan_layout(binary: JitBinary, limits: JitMemoryLimits) -> Result<JitLayoutPlan, text>:
    """Step 2: Plan binary placement in target memory.

    Uses the shared layout planner with architecture-aware halt instruction
    sizing and entry-point adjustment.
    """
    val mem_map = _limits_to_memory_map(limits)
    plan_binary_layout(binary, mem_map, binary.arch)

fn append_halt_trampoline(binary: JitBinary) -> JitBinary:
    """Append architecture-specific halt trampoline to binary bytes."""
    var new_bytes = binary.bytes
    match binary.arch:
        Architecture.Arm32:
            new_bytes = append_halt_trampoline_arm32(new_bytes)
        Architecture.RiscV32:
            new_bytes = append_halt_trampoline_rv32(new_bytes)
        _:
            new_bytes = append_halt_trampoline_rv32(new_bytes)

    JitBinary(
        name: binary.name,
        bytes: new_bytes,
        entry_offset: binary.entry_offset,
        stack_bytes: binary.stack_bytes,
        arch: binary.arch
    )

fn _compute_entry_pc(plan: JitLayoutPlan, arch: Architecture) -> i64:
    """Compute the entry PC value, Thumb-adjusted for ARM32."""
    if arch == Architecture.Arm32:
        return jit_entry_pc_arm32(plan)
    plan.entry_point

fn _compute_halt_pc(plan: JitLayoutPlan, arch: Architecture) -> i64:
    """Compute the halt/return PC value, Thumb-adjusted for ARM32."""
    if arch == Architecture.Arm32:
        return jit_return_pc_arm32(plan)
    plan.halt_addr

# ============================================================================
# Full Pipeline (with JitBackendOps)
# ============================================================================

fn jit_run(backend: JitBackendOps, binary: JitBinary, config: JitRunnerConfig) -> JitExecResult:
    """Execute the full unified JIT pipeline.

    This is the single entry point that replaces all per-backend runner
    branches. The pipeline is:
      1. Validate binary against memory limits
      2. Append halt trampoline
      3. Plan binary layout
      4. Load binary through backend
      5. Optionally verify upload
      6. Setup registers (PC, SP, LR)
      7. Resume and wait for halt
      8. Collect and return result
    """
    val limits = backend.limits
    val arch = backend.arch

    # Step 1: Validate
    val validate_result = validate_binary(binary, limits)
    if validate_result.is_err():
        return JitExecResult.failure(validate_result.unwrap_err())

    # Step 2: Append halt trampoline
    val binary_with_halt = append_halt_trampoline(binary)

    # Step 3: Plan layout
    val plan_result = plan_layout(binary_with_halt, limits)
    if plan_result.is_err():
        return JitExecResult.failure(plan_result.unwrap_err())
    val plan = plan_result.unwrap()

    # Step 4: Load binary
    val load_result = backend.load_binary(plan.code_base, binary_with_halt.bytes)
    if load_result.is_err():
        return JitExecResult.failure("load failed: {load_result.unwrap_err()}")

    # Step 5: Verify (optional)
    if config.verify_upload:
        val verify_result = backend.verify_binary(plan.code_base, binary_with_halt.bytes)
        if verify_result.is_err():
            return JitExecResult.failure("verify failed: {verify_result.unwrap_err()}")
        val verified = verify_result.unwrap()
        if not verified:
            return JitExecResult.failure("binary verification mismatch at {plan.code_base}")

    # Step 6: Setup registers
    val pc_idx = pc_register_index(arch)
    val sp_idx = sp_register_index(arch)
    val lr_idx = link_register_index(arch)

    val entry_pc = _compute_entry_pc(plan, arch)
    val pc_result = backend.write_register(pc_idx, entry_pc)
    if pc_result.is_err():
        return JitExecResult.failure("failed to set PC: {pc_result.unwrap_err()}")

    val sp_result = backend.write_register(sp_idx, plan.stack_top)
    if sp_result.is_err():
        return JitExecResult.failure("failed to set SP: {sp_result.unwrap_err()}")

    val halt_pc = _compute_halt_pc(plan, arch)
    val lr_result = backend.write_register(lr_idx, halt_pc)
    if lr_result.is_err():
        return JitExecResult.failure("failed to set LR: {lr_result.unwrap_err()}")

    # Step 7: Resume and wait
    val resume_result = backend.resume()
    if resume_result.is_err():
        return JitExecResult.failure("failed to resume: {resume_result.unwrap_err()}")

    val halt_result = backend.wait_halt(config.timeout_ms)
    if halt_result.is_err():
        return JitExecResult.failure("execution failed: {halt_result.unwrap_err()}")
    val halt_reason = halt_result.unwrap()

    # Step 8: Collect result
    val ret_idx = return_register_index(arch)
    val ret_result = backend.read_register(ret_idx)
    if ret_result.is_err():
        return JitExecResult.failure("failed to read return register: {ret_result.unwrap_err()}")

    val return_value = ret_result.unwrap()
    JitExecResult.success(return_value, 0, halt_reason)

fn jit_run_simple(backend: JitBackendOps, binary: JitBinary) -> JitExecResult:
    """Convenience: run with default config (no verify, 5s timeout)."""
    jit_run(backend, binary, JitRunnerConfig.default())

# ============================================================================
# Full Pipeline (with DisconnectedBackendOps -- error testing)
# ============================================================================

fn jit_run_disconnected(backend: DisconnectedBackendOps, binary: JitBinary, config: JitRunnerConfig) -> JitExecResult:
    """Execute the pipeline against a disconnected backend (always fails at load).

    Used for testing error handling in the orchestration layer.
    """
    val limits = backend.limits

    # Step 1: Validate
    val validate_result = validate_binary(binary, limits)
    if validate_result.is_err():
        return JitExecResult.failure(validate_result.unwrap_err())

    # Step 2: Append halt trampoline
    val binary_with_halt = append_halt_trampoline(binary)

    # Step 3: Plan layout
    val plan_result = plan_layout(binary_with_halt, limits)
    if plan_result.is_err():
        return JitExecResult.failure(plan_result.unwrap_err())
    val plan = plan_result.unwrap()

    # Step 4: Load binary (will fail)
    val load_result = backend.load_binary(plan.code_base, binary_with_halt.bytes)
    if load_result.is_err():
        return JitExecResult.failure("load failed: {load_result.unwrap_err()}")

    # Should not reach here for disconnected backend
    JitExecResult.failure("unexpected: disconnected backend did not fail")
