# SPipe codebase-mcp / RepoMix ingest helpers.

use std.nogc_sync_mut.spipe.tree_context.{ContextStore, spipe_context_get, spipe_context_put, spipe_context_search, spipe_render_tree, spipe_source_blob}

fn spipe_codebase_simple_include_profile() -> text:
    "MCP.md,.mcp.json,config/mcp/**,src/app/mcp/**,src/app/simple_lsp_mcp/**,src/lib/nogc_sync_mut/mcp_sdk/**,examples/10_tooling/minimal_mcp/**,tools/mcp-registry/**,tools/lsp-mcp-registry/**,.codex/**,.claude/**,.gemini/**"

fn spipe_codebase_simple_ignore_profile() -> text:
    ".git/**,.cache/**,target/**,release/**,var/**,gh-cli-cache/**,build/**"

fn spipe_codebase_validate_patterns(patterns: text) -> text:
    val bad = [";", "|", "&&", "`", "$(", ">", "<"]
    for item in bad:
        if patterns.contains(item):
            return "invalid: shell metacharacter " + item
    "ok"

fn spipe_codebase_pack_args(root: text, include_patterns: text, ignore_patterns: text, remote: bool) -> [text]:
    if remote:
        return ["-y", "repomix", "--remote", root, "--stdout", "--style", "markdown", "--include", include_patterns, "--ignore", ignore_patterns]
    ["-y", "repomix", root, "--stdout", "--style", "markdown", "--include", include_patterns, "--ignore", ignore_patterns]

fn spipe_codebase_ingest(store: ContextStore, source_id: text, packed_text: text) -> ContextStore:
    spipe_context_put(store, spipe_source_blob(source_id, "repomix", "codebase ingest", packed_text))

fn spipe_codebase_get(store: ContextStore, source_id: text) -> text:
    spipe_context_get(store, source_id)

fn spipe_codebase_search(store: ContextStore, query: text) -> text:
    spipe_context_search(store, query)

fn spipe_codebase_profile() -> text:
    "@codebase_profile v=1 name=simple-mcp-focused\n@include " + spipe_codebase_simple_include_profile() + "\n@ignore " + spipe_codebase_simple_ignore_profile()

fn spipe_codebase_save_text(source_id: text, packed_text: text) -> text:
    # Text-only helper: the app layer owns filesystem writes through its facade.
    "@codebase_save v=1 source_id=\"{source_id}\" bytes={packed_text.len()}"
