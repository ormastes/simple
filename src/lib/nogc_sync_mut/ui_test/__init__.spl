# UI Test Client Module
#
# Foundation library for UI testing via HTTP-based test protocol.
# Provides types, HTTP helpers, and JSON parsing for inspecting
# and interacting with UI applications under test.
#
# Components:
#   - types: ElementInfo, UIStateInfo data classes
#   - http: Raw TCP HTTP GET/POST helpers
#   - parse: JSON response parsing into typed objects
#
# Public API:
#   - use std.ui_test.types.{ElementInfo, UIStateInfo}
#   - use std.ui_test.http.{test_get, test_post}
#   - use std.ui_test.parse.{parse_element_info, parse_elements_list, parse_state_info}
#
# Example:
#   use std.ui_test.*
#
#   val body = test_get("127.0.0.1", 8080, "/api/elements")?
#   val elements = parse_elements_list(body)?

# Re-exported from types.spl
export ElementInfo, UIStateInfo

# Re-exported from http.spl
export test_get, test_post

# Re-exported from parse.spl
export extract_field, extract_bool_field, parse_props
export parse_element_info, parse_elements_list, parse_state_info
export use nogc_sync_mut.ui_test.sgtti.{SgttiTestDriver, SgttiParityResult, UI_TEST_TARGET_TUI, UI_TEST_TARGET_GUI, UI_TEST_TARGET_BOTH, ui_test_targets, sgtti_parity_check, sgtti_snapshot_from_tui_state, sgtti_snapshot_from_draw_ir_batch, sgtti_snapshot_from_draw_ir_composition, gui_test_snapshot, gui_test_snapshot_default}
