# UI Test Client Types
#
# Data types for UI test results and state inspection.
#
# Components:
#   - ElementInfo: UI element properties (id, kind, visibility, focus, props)
#   - UIStateInfo: Application state snapshot (mode, focus, title, theme)
#
# Usage:
#   use std.ui_test.types.{ElementInfo, UIStateInfo}
#
#   val elem = ElementInfo(id: "btn1", kind: "button", visible: true, focused: false, enabled: true, selected: false, text_content: "", props: [])
#   val state = UIStateInfo(mode: "NORMAL", focused_id: "btn1", title: "App", theme: "dark", element_count: 5, protocol_version: 1)

# ============================================================================
# ElementInfo - UI Element Properties
# ============================================================================

class ElementInfo:
    """Represents a single UI element with its properties.

    Args:
        id: Unique element identifier
        kind: Element type (button, text_field, label, panel, etc.)
        visible: Whether the element is currently visible
        focused: Whether the element currently has focus
        props: Key-value pairs of additional properties
    """
    id: text
    kind: text
    visible: bool
    focused: bool
    enabled: bool
    selected: bool
    text_content: text
    props: [(text, text)]

    static fn create(id: text, kind: text, visible: bool, focused: bool, enabled: bool, selected: bool, text_content: text, props: [(text, text)]) -> ElementInfo:
        """Create a new ElementInfo with all fields.

        Args:
            id: Element identifier
            kind: Element type
            visible: Visibility flag
            focused: Focus flag
            enabled: Enabled flag
            selected: Selected flag
            text_content: Primary text content
            props: Additional properties

        Returns:
            New ElementInfo instance
        """
        ElementInfo(id: id, kind: kind, visible: visible, focused: focused, enabled: enabled, selected: selected, text_content: text_content, props: props)

    static fn simple(id: text, kind: text) -> ElementInfo:
        """Create a minimal ElementInfo with defaults.

        Args:
            id: Element identifier
            kind: Element type

        Returns:
            ElementInfo with visible=true, focused=false, enabled=true, selected=false, empty text, empty props
        """
        ElementInfo(id: id, kind: kind, visible: true, focused: false, enabled: true, selected: false, text_content: "", props: [])

    fn get_id() -> text:
        """Get element identifier."""
        self.id

    fn get_kind() -> text:
        """Get element type."""
        self.kind

    fn is_visible() -> bool:
        """Check if element is visible."""
        self.visible

    fn is_focused() -> bool:
        """Check if element has focus."""
        self.focused

    fn is_enabled() -> bool:
        """Check if element is enabled."""
        self.enabled

    fn is_selected() -> bool:
        """Check if element is in selected state."""
        self.selected

    fn get_text() -> text:
        """Get primary text content."""
        self.text_content

    fn get_props() -> [(text, text)]:
        """Get all properties."""
        self.props

    fn get_prop(name: text) -> text?:
        """Get a property value by name.

        Args:
            name: Property name to look up

        Returns:
            Some(value) if found, nil otherwise
        """
        var i = 0
        while i < self.props.length():
            var pair = self.props[i]
            var key = pair.0
            if key == name:
                return pair.1
            i = i + 1
        nil

    fn has_prop(name: text) -> bool:
        """Check if a property exists.

        Args:
            name: Property name

        Returns:
            true if property exists
        """
        var result = self.get_prop(name)
        result != nil

# ============================================================================
# UIStateInfo - Application State Snapshot
# ============================================================================

class UIStateInfo:
    """Represents the current UI application state.

    Args:
        mode: Current mode (NORMAL, INSERT, COMMAND, etc.)
        focused_id: ID of the currently focused element
        title: Application window title
        theme: Current theme name
        element_count: Number of elements in the UI
        protocol_version: UI test protocol version
    """
    mode: text
    focused_id: text
    title: text
    theme: text
    element_count: i32
    protocol_version: i32

    static fn create(mode: text, focused_id: text, title: text, theme: text, element_count: i32, protocol_version: i32) -> UIStateInfo:
        """Create a new UIStateInfo with all fields.

        Args:
            mode: Application mode
            focused_id: Focused element ID
            title: Window title
            theme: Theme name
            element_count: Number of elements in the UI
            protocol_version: UI test protocol version

        Returns:
            New UIStateInfo instance
        """
        UIStateInfo(mode: mode, focused_id: focused_id, title: title, theme: theme, element_count: element_count, protocol_version: protocol_version)

    static fn default_state() -> UIStateInfo:
        """Create a default UIStateInfo.

        Returns:
            UIStateInfo with NORMAL mode, empty focus, empty title, default theme
        """
        UIStateInfo(mode: "NORMAL", focused_id: "", title: "", theme: "default", element_count: 0, protocol_version: 1)

    fn get_mode() -> text:
        """Get current mode."""
        self.mode

    fn get_focused_id() -> text:
        """Get focused element ID."""
        self.focused_id

    fn get_title() -> text:
        """Get window title."""
        self.title

    fn get_theme() -> text:
        """Get current theme."""
        self.theme

# ============================================================================
# Exports
# ============================================================================

export ElementInfo, UIStateInfo
