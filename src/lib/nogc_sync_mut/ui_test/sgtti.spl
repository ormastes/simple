# SGTTI UI Test Driver
#
# In-process sibling to UITestClient. It mirrors the common UI-test
# query/check/action vocabulary over a WinTextSnapshot without an HTTP server.

use common.ui.access.{ui_access_snapshot_from_state}
use common.ui.access_types.{UiAccessNode, UiAccessProp, UiAccessSurface}
use common.ui.draw_ir.{DrawIrBatch, DrawIrComposition, DrawIrCommand, DrawIrRect}
use common.ui.widget.{UIState}
use common.ui.win_text_access.{
    WinTextSnapshot,
    WinTextActionRequest,
    win_text_find_nodes,
    win_text_route_action,
    win_text_simple_ui_snapshot,
    win_text_snapshot_from_parts,
    win_text_source
}
use os.compositor.compositor.{Compositor}
use os.compositor.gtti.{gtti_snapshot_from_compositor}
use os.compositor.host_compositor_entry.{HeadlessHostCompositorBackend}
use os.compositor.wm_core.{WM_MODE_HIDDEN}

val UI_TEST_TARGET_TUI: text = "tui"
val UI_TEST_TARGET_GUI: text = "gui"
val UI_TEST_TARGET_BOTH: text = "both"

pub struct SgttiParityResult:
    ok: bool
    id: text
    message: text
    tui_found: bool
    gui_found: bool
    visible_match: bool
    focused_match: bool
    enabled_match: bool
    selected_match: bool

fn ui_test_targets(target: text) -> [text]:
    if target == UI_TEST_TARGET_TUI:
        return [UI_TEST_TARGET_TUI]
    if target == UI_TEST_TARGET_GUI:
        return [UI_TEST_TARGET_GUI]
    if target == UI_TEST_TARGET_BOTH:
        return [UI_TEST_TARGET_TUI, UI_TEST_TARGET_GUI]
    []

fn _sgtti_parity_result(ok: bool, id: text, message: text, tui_found: bool, gui_found: bool, visible_match: bool, focused_match: bool, enabled_match: bool, selected_match: bool) -> SgttiParityResult:
    SgttiParityResult(
        ok: ok,
        id: id,
        message: message,
        tui_found: tui_found,
        gui_found: gui_found,
        visible_match: visible_match,
        focused_match: focused_match,
        enabled_match: enabled_match,
        selected_match: selected_match
    )

fn sgtti_snapshot_from_tui_state(state: UIState, captured_at_ms: i64, max_age_ms: i64, now_ms: i64) -> WinTextSnapshot:
    win_text_simple_ui_snapshot(ui_access_snapshot_from_state(state, []), captured_at_ms, max_age_ms, now_ms)

fn gui_test_snapshot(title: text, x: i32, y: i32, width: i32, height: i32, captured_at_ms: i64, now_ms: i64) -> WinTextSnapshot:
    var comp = Compositor.with_backends(HeadlessHostCompositorBackend.new(width, height), nil, width, height)
    comp.create_window(title, x, y, width, height)
    gtti_snapshot_from_compositor(comp, WM_MODE_HIDDEN, captured_at_ms, now_ms)

fn gui_test_snapshot_default(title: text) -> WinTextSnapshot:
    gui_test_snapshot(title, 0, 0, 640, 480, 1000, 1000)

fn sgtti_snapshot_from_draw_ir_batch(batch: DrawIrBatch, captured_at_ms: i64, max_age_ms: i64, now_ms: i64) -> WinTextSnapshot:
    val surface_id = "draw_ir:{batch.batch_id}"
    val surface = UiAccessSurface(
        surface_id: surface_id,
        title: batch.batch_id,
        active: true,
        window_id: batch.embedding.component_id,
        app_id: "draw_ir",
        root_canonical_id: "{surface_id}#root"
    )
    val source = win_text_source(
        source_id: "draw_ir",
        source_kind: "in_process_semantic",
        confidence: "high",
        capabilities: ["query_text", "layout_read"],
        captured_at_ms: captured_at_ms,
        max_age_ms: max_age_ms,
        now_ms: now_ms
    )
    win_text_snapshot_from_parts(
        mode: "draw_ir",
        active_surface: surface_id,
        surfaces: [surface],
        nodes: _sgtti_draw_ir_batch_nodes(surface_id, batch),
        sources: [source]
    )

fn sgtti_snapshot_from_draw_ir_composition(composition: DrawIrComposition, captured_at_ms: i64, max_age_ms: i64, now_ms: i64) -> WinTextSnapshot:
    val surface_id = "draw_ir:{composition.composition_id}"
    val surface = UiAccessSurface(
        surface_id: surface_id,
        title: composition.scene_key,
        active: true,
        window_id: composition.scene_key,
        app_id: "draw_ir",
        root_canonical_id: "{surface_id}#root"
    )
    val source = win_text_source(
        source_id: "draw_ir",
        source_kind: "in_process_semantic",
        confidence: "high",
        capabilities: ["query_text", "layout_read"],
        captured_at_ms: captured_at_ms,
        max_age_ms: max_age_ms,
        now_ms: now_ms
    )
    var nodes: [UiAccessNode] = []
    for batch in composition.batches:
        for node in _sgtti_draw_ir_batch_nodes(surface_id, batch):
            nodes = nodes.push(node)
    win_text_snapshot_from_parts(
        mode: "draw_ir",
        active_surface: surface_id,
        surfaces: [surface],
        nodes: nodes,
        sources: [source]
    )

fn _sgtti_draw_ir_batch_nodes(surface_id: text, batch: DrawIrBatch) -> [UiAccessNode]:
    var nodes: [UiAccessNode] = []
    for command in batch.commands:
        nodes = nodes.push(_sgtti_draw_ir_node(surface_id, batch.batch_id, command))
    nodes

fn _sgtti_draw_ir_node(surface_id: text, batch_id: text, command: DrawIrCommand) -> UiAccessNode:
    UiAccessNode(
        canonical_id: "{surface_id}#{command.component_id}",
        surface_id: surface_id,
        widget_id: command.component_id,
        kind: command.kind,
        visible: true,
        focused: false,
        enabled: true,
        selected: false,
        text_value: command.text_value,
        props: [
            UiAccessProp(key: "source", value: "draw_ir"),
            UiAccessProp(key: "batch_id", value: batch_id),
            UiAccessProp(key: "parent", value: command.parent_id),
            UiAccessProp(key: "x", value: "{command.x}"),
            UiAccessProp(key: "y", value: "{command.y}"),
            UiAccessProp(key: "width", value: "{command.width}"),
            UiAccessProp(key: "height", value: "{command.height}"),
            UiAccessProp(key: "border_rect", value: _sgtti_draw_ir_rect_value(command.border_rect)),
            UiAccessProp(key: "content_rect", value: _sgtti_draw_ir_rect_value(command.content_rect)),
            UiAccessProp(key: "hit_rect", value: _sgtti_draw_ir_rect_value(command.hit_rect)),
            UiAccessProp(key: "clip_rect", value: _sgtti_draw_ir_rect_value(command.clip_rect))
        ] + _sgtti_draw_ir_style_props(command),
        child_ids: [],
        action_names: []
    )

fn _sgtti_draw_ir_rect_value(rect: DrawIrRect) -> text:
    if not rect.present:
        return ""
    "{rect.x},{rect.y},{rect.width},{rect.height}"

fn _sgtti_draw_ir_style_props(command: DrawIrCommand) -> [UiAccessProp]:
    var props: [UiAccessProp] = []
    for style in command.computed_style:
        props = props.push(UiAccessProp(key: "css:{style.key}", value: style.value))
    props

pub class SgttiTestDriver:
    snapshot: WinTextSnapshot

    static fn new(snapshot: WinTextSnapshot) -> SgttiTestDriver:
        SgttiTestDriver(snapshot: snapshot)

    static fn from_snapshot(source_snapshot: WinTextSnapshot) -> SgttiTestDriver:
        SgttiTestDriver.new(source_snapshot)

    static fn from_tui_state(state: UIState, captured_at_ms: i64, max_age_ms: i64, now_ms: i64) -> SgttiTestDriver:
        SgttiTestDriver.new(sgtti_snapshot_from_tui_state(state, captured_at_ms, max_age_ms, now_ms))

    fn get_element(id: text) -> Result<UiAccessNode, text>:
        val node = self._find_node(id)
        if node == nil:
            return Err("element not found: {id}")
        Ok(node)

    fn get_elements() -> Result<[UiAccessNode], text>:
        Ok(self.snapshot.access.nodes)

    fn find_nodes(surface_id: text, kind: text, text_query: text, limit: i32) -> Result<[UiAccessNode], text>:
        Ok(win_text_find_nodes(self.snapshot, surface_id, kind, text_query, limit))

    fn click(id: text) -> Result<bool, text>:
        self._route_action(id, "click", "")

    fn type_text(id: text, content: text) -> Result<bool, text>:
        self._route_action(id, "type_text", content)

    fn check_exists(id: text) -> Result<bool, text>:
        Ok(self._find_node(id) != nil)

    fn check_visible(id: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        Ok(node.visible)

    fn check_focused(id: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        Ok(node.focused)

    fn check_enabled(id: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        Ok(node.enabled)

    fn check_selected(id: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        Ok(node.selected)

    fn check_text(id: text, expected: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        if node.text_value.contains(expected):
            return Ok(true)
        for prop in node.props:
            if prop.value.contains(expected):
                return Ok(true)
        Ok(false)

    fn expect_draw(id: text, assertion: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        _sgtti_expect_draw_node(node, assertion)

    fn _route_action(id: text, action: text, text_value: text) -> Result<bool, text>:
        val node = self.get_element(id)?
        val result = win_text_route_action(self.snapshot, WinTextActionRequest(
            target_id: node.canonical_id,
            action: action,
            text_value: text_value,
            x: 0,
            y: 0
        ))
        if result.ok:
            return Ok(true)
        Err(result.message)

    fn _find_node(id: text) -> UiAccessNode?:
        for node in self.snapshot.access.nodes:
            if node.canonical_id == id:
                return node
        for node in self.snapshot.access.nodes:
            if node.widget_id == id:
                return node
        nil

    fn find_element(id: text) -> UiAccessNode?:
        self._find_node(id)

fn expect_draw(driver: SgttiTestDriver, id: text, assertion: text) -> Result<bool, text>:
    driver.expect_draw(id, assertion)

fn _sgtti_expect_draw_node(node: UiAccessNode, assertion: text) -> Result<bool, text>:
    val parts = _sgtti_words(assertion)
    if parts.len() == 0:
        return Err("empty draw assertion")
    val command = parts[0]
    if command == "visible":
        return Ok(node.visible)
    if command == "kind":
        if parts.len() < 2:
            return Err("kind assertion requires a value")
        val expected = parts[1]
        return Ok(node.kind == expected or _sgtti_prop_value(node, "css:kind") == expected)
    if command == "role":
        if parts.len() < 2:
            return Err("role assertion requires a value")
        return Ok(_sgtti_prop_value(node, "css:role") == parts[1])
    if command == "parent":
        if parts.len() < 2:
            return Err("parent assertion requires an id")
        return Ok(_sgtti_prop_value(node, "parent") == parts[1])
    if command == "css":
        if parts.len() < 3:
            return Err("css assertion requires property and value")
        return Ok(_sgtti_prop_value(node, "css:{parts[1]}") == parts[2])
    if command == "geometry":
        return _sgtti_expect_geometry(node, parts)
    if command == "hit_rect":
        return _sgtti_expect_hit_rect(node, parts)
    Err("unknown draw assertion: {assertion}")

fn _sgtti_expect_geometry(node: UiAccessNode, parts: [text]) -> Result<bool, text>:
    if parts.len() < 5:
        return Err("geometry assertion requires x y width height")
    var tolerance = 0
    if parts.len() >= 7 and parts[5] == "tolerance":
        tolerance = parts[6].to_i32()
    val x_ok = _sgtti_i32_close(_sgtti_prop_value(node, "x").to_i32(), parts[1].to_i32(), tolerance)
    val y_ok = _sgtti_i32_close(_sgtti_prop_value(node, "y").to_i32(), parts[2].to_i32(), tolerance)
    val w_ok = _sgtti_i32_close(_sgtti_prop_value(node, "width").to_i32(), parts[3].to_i32(), tolerance)
    val h_ok = _sgtti_i32_close(_sgtti_prop_value(node, "height").to_i32(), parts[4].to_i32(), tolerance)
    Ok(x_ok and y_ok and w_ok and h_ok)

fn _sgtti_expect_hit_rect(node: UiAccessNode, parts: [text]) -> Result<bool, text>:
    if parts.len() < 4 or parts[1] != "contains":
        return Err("hit_rect assertion requires: hit_rect contains x y")
    val rect = _sgtti_rect_parts(_sgtti_prop_value(node, "hit_rect"))
    if rect.len() < 4:
        return Ok(false)
    val x = parts[2].to_i32()
    val y = parts[3].to_i32()
    val rx = rect[0].to_i32()
    val ry = rect[1].to_i32()
    val rw = rect[2].to_i32()
    val rh = rect[3].to_i32()
    Ok(x >= rx and y >= ry and x <= rx + rw and y <= ry + rh)

fn _sgtti_i32_close(actual: i32, expected: i32, tolerance: i32) -> bool:
    val delta = actual - expected
    if delta < 0:
        return -delta <= tolerance
    delta <= tolerance

fn _sgtti_prop_value(node: UiAccessNode, key: text) -> text:
    for prop in node.props:
        if prop.key == key:
            return prop.value
    ""

fn _sgtti_words(source: text) -> [text]:
    var out: [text] = []
    for part in source.split(" "):
        if part != "":
            out = out.push(part)
    out

fn _sgtti_rect_parts(source: text) -> [text]:
    if source == "":
        return []
    source.split(",")

fn sgtti_parity_check(tui: SgttiTestDriver, gui: SgttiTestDriver, id: text) -> SgttiParityResult:
    val tui_node = tui.find_element(id)
    val gui_node = gui.find_element(id)
    if tui_node == nil and gui_node == nil:
        return _sgtti_parity_result(false, id, "missing from tui and gui: {id}", false, false, false, false, false, false)
    if tui_node == nil:
        return _sgtti_parity_result(false, id, "missing from tui: {id}", false, true, false, false, false, false)
    if gui_node == nil:
        return _sgtti_parity_result(false, id, "missing from gui: {id}", true, false, false, false, false, false)
    val visible_match = tui_node.visible == gui_node.visible
    val focused_match = tui_node.focused == gui_node.focused
    val enabled_match = tui_node.enabled == gui_node.enabled
    val selected_match = tui_node.selected == gui_node.selected
    val ok = visible_match and focused_match and enabled_match and selected_match
    val message = if ok: "parity ok: {id}" else: "parity mismatch: {id}"
    _sgtti_parity_result(ok, id, message, true, true, visible_match, focused_match, enabled_match, selected_match)
