# spostgre_if.types — opaque aliases for the DB trait surface.
#
# All DB-internal identifiers. Kept as newtype-style structs so compiler
# enforces "no passing a BlkNo where Lsn is required" at the trait boundary.

struct Rel:
    """Relation identifier (tableoid-equivalent)."""
    id: i64

    static fn null() -> Rel:
        Rel(id: -1)

    fn is_null(self) -> bool:
        self.id < 0

struct BlkNo:
    """Logical block / page number within a fork of a relation."""
    n: i64

    static fn first() -> BlkNo:
        BlkNo(n: 0)

struct Lsn:
    """Log Sequence Number for WAL position."""
    value: i64

    static fn zero() -> Lsn:
        Lsn(value: 0)

    fn precedes(self, other: Lsn) -> bool:
        self.value < other.value

struct TxnId:
    """Transaction identifier."""
    id: i64

    static fn null() -> TxnId:
        TxnId(id: 0)

struct PhysPtr:
    """Physical pointer (arena_id + offset) into NVFS storage."""
    arena_id: i64
    offset: i64

    static fn null() -> PhysPtr:
        PhysPtr(arena_id: -1, offset: 0)

    fn is_null(self) -> bool:
        self.arena_id < 0
