# Windows MSVC Platform Path Configuration
# Uses native Windows backslash separators
# Import directly for testing: use std.path_platform.windows_msvc.{...}

fn platform_name() -> text: "windows_msvc"
fn platform_sep() -> text: "\\"
fn platform_path_sep() -> text: ";"
fn platform_exe_ext() -> text: ".exe"
fn platform_lib_ext() -> text: ".dll"

fn platform_is_absolute(path: text) -> bool:
    if path.starts_with("/"):
        return true
    # Windows drive letter: C:\ or C:/
    if path.len() >= 3:
        val second = path[1:2]
        val third = path[2:3]
        if second == ":" and (third == "\\" or third == "/"):
            val first = path[0:1]
            if (first >= "A" and first <= "Z") or (first >= "a" and first <= "z"):
                return true
    false

fn platform_normalize_sep(path: text) -> text:
    # MSVC normalizes forward slashes to backslashes
    path.replace("/", "\\")

# MSVC-specific: linker flag format
fn platform_lib_prefix() -> text: ""
fn platform_obj_ext() -> text: ".obj"
fn platform_whole_archive_flag() -> text: "/WHOLEARCHIVE"
