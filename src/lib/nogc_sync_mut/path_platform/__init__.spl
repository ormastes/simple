# Platform Path Configuration - Compile-Time Selection
#
# Usage (automatic platform selection):
#   use std.path_platform.{platform_sep, platform_is_absolute}
#
# Usage (direct platform import for testing):
#   use std.path_platform.unix.{platform_sep as unix_sep}
#   use std.path_platform.windows_msvc.{platform_sep as msvc_sep}

@when(windows and msvc):
    use nogc_sync_mut.path_platform.windows_msvc.*
@elif(windows and mingw):
    use nogc_sync_mut.path_platform.windows_mingw.*
@elif(windows):
    use nogc_sync_mut.path_platform.windows_msvc.*
@elif(macos):
    use nogc_sync_mut.path_platform.macos.*
@else:
    use nogc_sync_mut.path_platform.unix.*
@end
