# macOS Platform Path Configuration
# Import directly for testing: use std.path_platform.macos.{...}

fn platform_name() -> text: "macos"
fn platform_sep() -> text: "/"
fn platform_path_sep() -> text: ":"
fn platform_exe_ext() -> text: ""
fn platform_lib_ext() -> text: ".dylib"

fn platform_is_absolute(path: text) -> bool:
    path.starts_with("/")

fn platform_normalize_sep(path: text) -> text:
    path.replace("\\", "/")
