# Shell Module - Shell utilities facade
#
# Module index for shell/ subdirectory

# Import env module functions
use env.{get, set, cwd}

# Import file module functions
use file.{exist, write_text, read_text, remove, copy, append_text, rename}

# Import dir module functions
use dir.{exist as dir_exist, create, create_recursive, remove as dir_remove_fn, remove_recursive, list as dir_list_fn}

# Create env namespace with functions
val env = {
    "get": get,
    "set": set,
    "cwd": cwd
}

# Create file namespace with operations
val file = {
    "exist": exist,
    "write_text": write_text,
    "read_text": read_text,
    "remove": remove,
    "copy": copy,
    "append_text": append_text,
    "rename": rename
}

# Create dir namespace with operations
val dir = {
    "exist": dir_exist,
    "create": create,
    "create_recursive": create_recursive,
    "remove": dir_remove_fn,
    "remove_recursive": remove_recursive,
    "list": dir_list_fn
}

