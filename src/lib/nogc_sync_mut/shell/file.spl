# Shell File Module - File operations namespace
#
# Provides a `file` namespace object with common file operations.
# Backed by io_runtime extern fn wrappers.
#
# Usage (via mod.spl):
#   use std.shell.{file}
#   file.exist(path)      -> bool
#   file.write_text(...)  -> bool
#   file.read_text(...)   -> text
#   file.remove(...)      -> bool
#   file.copy(...)        -> bool
#   file.rename(...)      -> bool
#   file.append_text(...) -> bool

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_copy(src: text, dst: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_rename(src: text, dst: text) -> bool

fn exist(path: text) -> bool:
    rt_file_exists(path)

fn write_text(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn read_text(path: text) -> text:
    val result = rt_file_read_text(path)
    if result == nil:
        ""
    else:
        result

fn remove(path: text) -> bool:
    rt_file_delete(path)

fn copy(src: text, dst: text) -> bool:
    rt_file_copy(src, dst)

fn append_text(path: text, content: text) -> bool:
    rt_file_append_text(path, content)

fn rename(src: text, dst: text) -> bool:
    rt_file_rename(src, dst)
