enum MimallocCompatibilityRole:
    PublicAllocatorStructs
    AllocatorClass
    HeapInitialization
    HeapSpecificApis
    OsPageProvider
    BasicAllocation
    CountAndZeroingApis
    SizeQueryApis
    SizedAndAlignedApis
    StatsAndOptionsApis
    RawKernelApi
    SimpleOsKernelHeap
    UpstreamAbiParity
    ThreadLocalHeaps
    PageCommitPolicy
    SecureAllocationMode

impl MimallocCompatibilityRole:
    fn to_string() -> text:
        match self:
            case PublicAllocatorStructs: "public-allocator-structs"
            case AllocatorClass: "allocator-class"
            case HeapInitialization: "heap-initialization"
            case HeapSpecificApis: "heap-specific-apis"
            case OsPageProvider: "os-page-provider"
            case BasicAllocation: "basic-allocation"
            case CountAndZeroingApis: "count-and-zeroing-apis"
            case SizeQueryApis: "size-query-apis"
            case SizedAndAlignedApis: "sized-and-aligned-apis"
            case StatsAndOptionsApis: "stats-and-options-apis"
            case RawKernelApi: "raw-kernel-api"
            case SimpleOsKernelHeap: "simpleos-kernel-heap"
            case UpstreamAbiParity: "upstream-abi-parity"
            case ThreadLocalHeaps: "thread-local-heaps"
            case PageCommitPolicy: "page-commit-policy"
            case SecureAllocationMode: "secure-allocation-mode"

struct MimallocCompatibilityFeature:
    """Documented mimalloc compatibility feature exposed to tests and docs."""
    role: MimallocCompatibilityRole
    artifact: text
    status: text
    note: text

fn mimalloc_compatibility_features() -> [MimallocCompatibilityFeature]:
    """Return the current mimalloc role/feature compatibility surface."""
    [
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.PublicAllocatorStructs,
            artifact: "MiBlock/MiPage/MiSegment/MiHeap/MiStats/MiOption",
            status: "implemented",
            note: "Structural Simple model for pages, segments, heaps, stats, and options."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.AllocatorClass,
            artifact: "MimallocAllocator",
            status: "implemented",
            note: "Implements the repo-local Allocator trait over the global compatibility heap."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.HeapInitialization,
            artifact: "mimalloc_init/mi_heap_new/mi_heap_delete",
            status: "implemented",
            note: "Initializes one global heap and structural heap handles."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.HeapSpecificApis,
            artifact: "mi_heap_malloc/mi_heap_zalloc/mi_heap_calloc/mi_heap_realloc/mi_heap_free",
            status: "partial",
            note: "Heap APIs delegate to the current single global heap; upstream per-heap ownership is missing."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.OsPageProvider,
            artifact: "mimalloc_set_os_page_alloc",
            status: "implemented",
            note: "SimpleOS can inject a kernel page provider for raw allocations."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.BasicAllocation,
            artifact: "mi_malloc/mi_free/mi_realloc",
            status: "implemented",
            note: "Modeled for the Simple byte-array pointer representation."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.CountAndZeroingApis,
            artifact: "mi_zalloc/mi_mallocn/mi_calloc/mi_rezalloc",
            status: "partial",
            note: "Basic zeroing and count APIs exist; upstream small/count realloc aliases are missing from the current source."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.SizeQueryApis,
            artifact: "mi_good_size/mi_usable_size",
            status: "partial",
            note: "Reports size classes and mock pointer usable lengths; raw provider sizing helper is missing from current source."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.SizedAndAlignedApis,
            artifact: "mi_malloc_aligned/mi_zalloc_aligned/mi_calloc_aligned/mi_realloc_aligned/mi_free_size",
            status: "partial",
            note: "Validates alignment contracts, but byte-array pointers cannot prove address alignment."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.StatsAndOptionsApis,
            artifact: "MiStats/MiOption/mi_stats_current/mi_stats_reset/mi_collect/mi_option_*",
            status: "implemented",
            note: "Tracks modeled allocation counters and option booleans; collect hooks are no-ops."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.RawKernelApi,
            artifact: "mi_malloc_raw/mi_free_raw/mi_raw_allocated",
            status: "implemented",
            note: "Provides address-returning kernel allocation through the injected page provider."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.SimpleOsKernelHeap,
            artifact: "src/os/kernel/memory/heap.spl",
            status: "implemented",
            note: "SimpleOS heap routes allocation and sized free through the mimalloc raw API."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.UpstreamAbiParity,
            artifact: "mimalloc C ABI/file layout",
            status: "missing",
            note: "No upstream ABI or file/class/struct layout parity exists yet."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.ThreadLocalHeaps,
            artifact: "TLS heaps and xthread free",
            status: "missing",
            note: "Current nogc_sync_mut port is single-threaded with one global heap."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.PageCommitPolicy,
            artifact: "commit/decommit/abandon policy",
            status: "missing",
            note: "No segment abandon, page commit, or decommit policy is implemented."
        ),
        MimallocCompatibilityFeature(
            role: MimallocCompatibilityRole.SecureAllocationMode,
            artifact: "secure/guarded allocation mode",
            status: "missing",
            note: "MiOption.Secure is modeled as an option flag only."
        )
    ]

fn mimalloc_is_upstream_compatible_complete() -> bool:
    """Return whether this module is a complete upstream-compatible mimalloc port."""
    false

export MimallocCompatibilityRole
export MimallocCompatibilityFeature
export mimalloc_compatibility_features
export mimalloc_is_upstream_compatible_complete
