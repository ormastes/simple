@allow(star_import) # facade aggregator: imports submodule symbols for re-export
# Fail-Safe Framework Core
# Pure Simple implementation - no FFI dependencies

use compiler.core.*

type Count = i64
type GaugeValue = f64

# ============================================================================
# ERROR TYPES
# ============================================================================

pub enum ErrorSeverity:
    Debug
    Info
    Warning
    Error
    Critical
    Fatal

    fn to_string() -> text:
        match self:
            case Debug: "debug"
            case Info: "info"
            case Warning: "warning"
            case Error: "error"
            case Critical: "critical"
            case Fatal: "fatal"

    fn to_level() -> i64:
        match self:
            case Debug: 0
            case Info: 1
            case Warning: 2
            case Error: 3
            case Critical: 4
            case Fatal: 5

pub enum ErrorCategory:
    Network
    Timeout
    Validation
    Internal
    RateLimit
    TooManyRequests
    Panic
    Overflow
    DivisionByZero
    ResourceExhausted
    Exhausted

    fn to_string() -> text:
        match self:
            case Network: "network"
            case Timeout: "timeout"
            case Validation: "validation"
            case Internal: "internal"
            case RateLimit: "rate_limit"
            case TooManyRequests: "too_many_requests"
            case Panic: "panic"
            case Overflow: "overflow"
            case DivisionByZero: "division_by_zero"
            case ResourceExhausted: "resource_exhausted"
            case Exhausted: "exhausted"

    fn is_recoverable() -> bool:
        match self:
            case Network: true
            case Timeout: true
            case RateLimit: true
            case TooManyRequests: true
            case Panic: false
            case Internal: false
            case _: true

# ============================================================================
# FAIL-SAFE ERROR
# ============================================================================

pub class FailSafeError:
    category: ErrorCategory
    severity: ErrorSeverity
    message: text
    recoverable: bool
    retry_after_ms: i64

    static fn new(category: ErrorCategory, message: text) -> FailSafeError:
        return FailSafeError(
            category,
            ErrorSeverity.Error,
            message,
            category.is_recoverable(),
            0
        )

    fn with_severity(severity: ErrorSeverity) -> FailSafeError:
        return FailSafeError(
            self.category,
            severity,
            self.message,
            self.recoverable,
            self.retry_after_ms
        )

    fn with_retry(retry_after_ms: i64) -> FailSafeError:
        return FailSafeError(
            self.category,
            self.severity,
            self.message,
            true,
            retry_after_ms
        )

    fn as_unrecoverable() -> FailSafeError:
        return FailSafeError(
            self.category,
            self.severity,
            self.message,
            false,
            0
        )

    fn to_string() -> text:
        return "[{self.severity.to_string()}] {self.category.to_string()}: {self.message}"

# ============================================================================
# FAIL-SAFE RESULT
# ============================================================================

pub enum FailSafeResult<T>:
    Ok(T)
    Err(FailSafeError)

    fn is_ok() -> bool:
        match self:
            case Ok(_): true
            case Err(_): false

    fn is_err() -> bool:
        return not self.is_ok()

    fn unwrap() -> T:
        match self:
            case Ok(v): v
            case Err(e): panic("unwrap on Err: {e.message}")

    fn unwrap_or(default: T) -> T:
        match self:
            case Ok(v): v
            case Err(_): default

# ============================================================================
# HEALTH STATUS
# ============================================================================

pub enum HealthStatus:
    Healthy
    Degraded
    Unhealthy

    fn to_string() -> text:
        match self:
            case Healthy: "healthy"
            case Degraded: "degraded"
            case Unhealthy: "unhealthy"

    fn is_healthy() -> bool:
        match self:
            case Healthy: true
            case _: false

# ============================================================================
# METRICS
# ============================================================================

pub class Counter:
    name: text
    value: Count

    static fn new(name: text) -> Counter:
        return Counter(name, 0)

    me inc():
        self.value = self.value + 1

    me add(n: i64):
        self.value = self.value + n

    me reset():
        self.value = 0

pub class Gauge:
    name: text
    value: GaugeValue

    static fn new(name: text) -> Gauge:
        return Gauge(name, 0.0)

    me set(v: f64):
        self.value = v

    me inc():
        self.value = self.value + 1.0

    me dec():
        self.value = self.value - 1.0

    me add(n: f64):
        self.value = self.value + n

    me sub(n: f64):
        self.value = self.value - n

pub class MetricsRegistry:
    counters: Dict<text, Counter>
    gauges: Dict<text, Gauge>

    static fn new() -> MetricsRegistry:
        return MetricsRegistry({}, {})

    me get_counter(name: text) -> Counter:
        match self.counters.get(name):
            case Some(c): return c
            case nil:
                val c = Counter.new(name)
                self.counters.set(name, c)
                return c

    me get_gauge(name: text) -> Gauge:
        match self.gauges.get(name):
            case Some(g): return g
            case nil:
                val g = Gauge.new(name)
                self.gauges.set(name, g)
                return g

# ============================================================================
# LOGGING
# ============================================================================

pub enum LogLevel:
    Debug
    Info
    Warn
    Error

    fn to_string() -> text:
        match self:
            case Debug: "DEBUG"
            case Info: "INFO"
            case Warn: "WARN"
            case Error: "ERROR"

    fn to_i64() -> i64:
        match self:
            case Debug: 0
            case Info: 1
            case Warn: 2
            case Error: 3

pub class ConsoleLogger:
    min_level: LogLevel

    static fn new(min_level: LogLevel) -> ConsoleLogger:
        return ConsoleLogger(min_level)

    fn is_enabled(level: LogLevel) -> bool:
        return level.to_i64() >= self.min_level.to_i64()

    fn log(level: LogLevel, message: text):
        if self.is_enabled(level):
            print "[{level.to_string()}] {message}"
