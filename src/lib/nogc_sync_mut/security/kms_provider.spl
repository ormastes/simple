"""
# Hosted KMS/HSM Key Provider

Generic JSON-over-HTTPS KMS contract for remote SecurityContext token signing
and verification. The provider stores opaque key handles and transport config,
never raw signing keys.
"""

use std.security.types.{RemoteSecurityKeyRolloutProvider, remote_security_token_with_external_signature}

struct HostedKmsHttpConfig:
    vendor: text
    endpoint: text
    auth_mode: text
    bearer_token: text
    tls_profile: text
    timeout_ms: i64

struct HostedKmsHttpRequest:
    method: text
    url: text
    headers: Dict<text, text>
    body: text
    timeout_ms: i64
    tls_profile: text

struct HostedKmsHttpResponse:
    status_code: i64
    body: text
    error: text

class HostedKmsKeyProvider:
    """Opaque hosted KMS/HSM adapter.

    `simulated_responses` is intentionally a transport seam for tests and
    hosted integration adapters. Request handlers still receive only tokens and
    call the existing external-signature validation seam.
    """
    config: HostedKmsHttpConfig
    active_key_id: text
    key_handles: Dict<text, text>
    simulated_responses: Dict<text, HostedKmsHttpResponse>

    static fn new(config: HostedKmsHttpConfig) -> HostedKmsKeyProvider:
        val handles: Dict<text, text> = {}
        val responses: Dict<text, HostedKmsHttpResponse> = {}
        HostedKmsKeyProvider(config: config, active_key_id: "", key_handles: handles, simulated_responses: responses)

    static fn with_active_key(config: HostedKmsHttpConfig, key_id: text, key_handle: text) -> HostedKmsKeyProvider:
        var provider = HostedKmsKeyProvider.new(config)
        provider.add_key(key_id, key_handle)
        provider.active_key_id = key_id
        provider

impl HostedKmsKeyProvider:
    me add_key(key_id: text, key_handle: text):
        self.key_handles = self.key_handles.set(key_id, key_handle)

    me rotate_key(key_id: text, key_handle: text):
        self.add_key(key_id, key_handle)
        self.active_key_id = key_id

    me retire_key(key_id: text):
        if self.key_handles.has(key_id):
            self.key_handles = self.key_handles.set(key_id, "")
        if self.active_key_id == key_id:
            self.active_key_id = ""

    fn key_handle_for(key_id: text) -> text:
        if self.key_handles.has(key_id):
            return self.key_handles[key_id]
        ""

    me register_response(request: HostedKmsHttpRequest, response: HostedKmsHttpResponse):
        self.simulated_responses = self.simulated_responses.set(hosted_kms_request_key(request), response)

    fn sign_request(key_id: text, payload: text) -> HostedKmsHttpRequest:
        hosted_kms_build_request(self.config, "sign", key_id, self.key_handle_for(key_id), payload, "")

    fn verify_request(key_id: text, payload: text, signature: text) -> HostedKmsHttpRequest:
        hosted_kms_build_request(self.config, "verify", key_id, self.key_handle_for(key_id), payload, signature)

    fn execute(request: HostedKmsHttpRequest) -> HostedKmsHttpResponse:
        val key = hosted_kms_request_key(request)
        if self.simulated_responses.has(key):
            return self.simulated_responses[key]
        HostedKmsHttpResponse(status_code: 599, body: "", error: "kms transport unavailable")

    fn sign_payload(key_id: text, payload: text) -> text:
        if self.key_handle_for(key_id) == "":
            return ""
        val response = self.execute(self.sign_request(key_id, payload))
        hosted_kms_signature_from_response(response)

    fn verify_external_signature(key_id: text, payload: text, signature: text) -> bool:
        if self.key_handle_for(key_id) == "" or signature == "":
            return false
        val response = self.execute(self.verify_request(key_id, payload, signature))
        hosted_kms_valid_from_response(response)

    fn rollout_provider_for_verified_signature(key_id: text, payload: text, signature: text) -> RemoteSecurityKeyRolloutProvider:
        var provider = RemoteSecurityKeyRolloutProvider.with_active_key(key_id, self.key_handle_for(key_id))
        if self.verify_external_signature(key_id, payload, signature):
            provider.allow_external_signature(key_id, payload, signature)
        provider

    fn token_with_kms_signature(key_id: text, session_id: text, user_id: text, expires_at_ms: i64, capabilities: List<text>) -> text:
        val payload = "{key_id}|{session_id}|{user_id}|{expires_at_ms}|{capabilities.join(\",\")}"
        val signature = self.sign_payload(key_id, payload)
        if signature == "":
            return ""
        remote_security_token_with_external_signature(key_id, session_id, user_id, expires_at_ms, capabilities, signature)

    fn export_sdn() -> text:
        var lines: [text] = [
            "hosted_kms_key_provider:",
            "  vendor: {self.config.vendor}",
            "  endpoint: {self.config.endpoint}",
            "  auth_mode: {self.config.auth_mode}",
            "  tls_profile: {self.config.tls_profile}",
            "  timeout_ms: {self.config.timeout_ms}",
            "  active: {self.active_key_id}"
        ]
        for key_id in self.key_handles.keys():
            lines.push("  key_handle|{key_id}|{self.key_handles[key_id]}")
        lines.join("\n")

fn hosted_kms_default_config(endpoint: text) -> HostedKmsHttpConfig:
    HostedKmsHttpConfig(
        vendor: "generic-http-kms",
        endpoint: endpoint,
        auth_mode: "bearer",
        bearer_token: "",
        tls_profile: "system",
        timeout_ms: 3000
    )

fn hosted_kms_build_request(config: HostedKmsHttpConfig, operation: text, key_id: text, key_handle: text, payload: text, signature: text) -> HostedKmsHttpRequest:
    val headers: Dict<text, text> = {
        "content-type": "application/json",
        "x-simple-kms-vendor": config.vendor
    }
    var all_headers = headers
    if config.auth_mode == "bearer" and config.bearer_token != "":
        all_headers = all_headers.set("authorization", "Bearer {config.bearer_token}")
    val body = hosted_kms_json_body(operation, key_id, key_handle, payload, signature)
    HostedKmsHttpRequest(
        method: "POST",
        url: "{config.endpoint}/{operation}",
        headers: all_headers,
        body: body,
        timeout_ms: config.timeout_ms,
        tls_profile: config.tls_profile
    )

fn hosted_kms_json_body(operation: text, key_id: text, key_handle: text, payload: text, signature: text) -> text:
    "{\"operation\":\"{operation}\",\"key_id\":\"{key_id}\",\"key_handle\":\"{key_handle}\",\"payload\":\"{payload}\",\"signature\":\"{signature}\"}"

fn hosted_kms_request_key(request: HostedKmsHttpRequest) -> text:
    "{request.method} {request.url} {request.body}"

fn hosted_kms_signature_from_response(response: HostedKmsHttpResponse) -> text:
    if response.error != "" or response.status_code < 200 or response.status_code >= 300:
        return ""
    hosted_kms_json_string_field(response.body, "signature")

fn hosted_kms_valid_from_response(response: HostedKmsHttpResponse) -> bool:
    if response.error != "" or response.status_code < 200 or response.status_code >= 300:
        return false
    hosted_kms_json_bool_field(response.body, "valid")

fn hosted_kms_json_string_field(body: text, field: text) -> text:
    val marker = "\"{field}\":\""
    val start = body.index_of(marker)
    if start < 0:
        return ""
    val after = body.substring(start + marker.len(), body.len())
    val end = after.index_of("\"")
    if end < 0:
        return ""
    after.substring(0, end)

fn hosted_kms_json_bool_field(body: text, field: text) -> bool:
    val true_marker = "\"{field}\":true"
    body.contains(true_marker)
