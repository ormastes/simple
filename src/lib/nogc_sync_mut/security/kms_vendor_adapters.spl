"""
# Vendor KMS/HSM Transport Adapters

Request builders for common hosted KMS/HSM transports. They produce
`HostedKmsHttpRequest` values for the generic hosted KMS provider seam and
carry only opaque key handles, algorithms, transport auth metadata, and TLS
profile names.
"""

use std.security.kms_provider.{HostedKmsHttpRequest}
use std.nogc_sync_mut.aws_sigv4.{SigV4Header, sigv4_sha256_hex, sigv4_authorization_header}
use std.security.auth.credential_store.{CredentialStore, credential_store_aws_sigv4_authorization, credential_store_aws_sigv4_authorization_with_session_token, credential_store_bearer_authorization}

fn kms_vendor_headers(vendor: text, auth_header: text) -> Dict<text, text>:
    var headers: Dict<text, text> = {
        "content-type": "application/json",
        "x-simple-kms-vendor": vendor
    }
    if auth_header != "":
        return headers.set("authorization", auth_header)
    headers

fn aws_kms_sign_request(endpoint: text, key_handle: text, payload: text, signing_algorithm: text, auth_header: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
    var headers = kms_vendor_headers("aws-kms", auth_header)
    headers = headers.set("x-amz-target", "TrentService.Sign")
    headers = headers.set("content-type", "application/x-amz-json-1.1")
    HostedKmsHttpRequest(
        method: "POST",
        url: endpoint,
        headers: headers,
        body: "{\"KeyId\":\"{key_handle}\",\"Message\":\"{payload}\",\"MessageType\":\"RAW\",\"SigningAlgorithm\":\"{signing_algorithm}\"}",
        timeout_ms: timeout_ms,
        tls_profile: tls_profile
    )

fn aws_kms_verify_request(endpoint: text, key_handle: text, payload: text, signature: text, signing_algorithm: text, auth_header: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
    var headers = kms_vendor_headers("aws-kms", auth_header)
    headers = headers.set("x-amz-target", "TrentService.Verify")
    headers = headers.set("content-type", "application/x-amz-json-1.1")
    HostedKmsHttpRequest(
        method: "POST",
        url: endpoint,
        headers: headers,
        body: "{\"KeyId\":\"{key_handle}\",\"Message\":\"{payload}\",\"MessageType\":\"RAW\",\"Signature\":\"{signature}\",\"SigningAlgorithm\":\"{signing_algorithm}\"}",
        timeout_ms: timeout_ms,
        tls_profile: tls_profile
    )

fn aws_kms_host_from_endpoint(endpoint: text) -> text:
    var rest = endpoint
    val scheme_end = rest.find("://").unwrap_or(-1)
    if scheme_end >= 0:
        rest = rest[scheme_end + 3:]
    val slash = rest.find("/").unwrap_or(-1)
    if slash >= 0:
        return rest[0:slash]
    rest

fn aws_kms_canonical_uri_from_endpoint(endpoint: text) -> text:
    var rest = endpoint
    val scheme_end = rest.find("://").unwrap_or(-1)
    if scheme_end >= 0:
        rest = rest[scheme_end + 3:]
    val slash = rest.find("/").unwrap_or(-1)
    if slash >= 0:
        return rest[slash:]
    "/"

fn aws_kms_sigv4_headers(endpoint: text, target: text, body: text, access_key: text, secret_key: text, region: text, amz_datetime: text) -> Dict<text, text>:
    val host = aws_kms_host_from_endpoint(endpoint)
    val payload_hash = sigv4_sha256_hex(body)
    var signed: [SigV4Header] = []
    signed = signed + [SigV4Header(name: "content-type", value: "application/x-amz-json-1.1")]
    signed = signed + [SigV4Header(name: "host", value: host)]
    signed = signed + [SigV4Header(name: "x-amz-content-sha256", value: payload_hash)]
    signed = signed + [SigV4Header(name: "x-amz-date", value: amz_datetime)]
    signed = signed + [SigV4Header(name: "x-amz-target", value: target)]
    val auth = sigv4_authorization_header(
        "POST",
        aws_kms_canonical_uri_from_endpoint(endpoint),
        "",
        signed,
        payload_hash,
        access_key,
        secret_key,
        region,
        "kms",
        amz_datetime
    )
    {
        "authorization": auth,
        "content-type": "application/x-amz-json-1.1",
        "host": host,
        "x-amz-content-sha256": payload_hash,
        "x-amz-date": amz_datetime,
        "x-amz-target": target,
        "x-simple-kms-vendor": "aws-kms"
    }

fn aws_kms_sigv4_headers_with_session_token(endpoint: text, target: text, body: text, access_key: text, secret_key: text, session_token: text, region: text, amz_datetime: text) -> Dict<text, text>:
    val host = aws_kms_host_from_endpoint(endpoint)
    val payload_hash = sigv4_sha256_hex(body)
    var signed: [SigV4Header] = []
    signed = signed + [SigV4Header(name: "content-type", value: "application/x-amz-json-1.1")]
    signed = signed + [SigV4Header(name: "host", value: host)]
    signed = signed + [SigV4Header(name: "x-amz-content-sha256", value: payload_hash)]
    signed = signed + [SigV4Header(name: "x-amz-date", value: amz_datetime)]
    signed = signed + [SigV4Header(name: "x-amz-security-token", value: session_token)]
    signed = signed + [SigV4Header(name: "x-amz-target", value: target)]
    val auth = sigv4_authorization_header(
        "POST",
        aws_kms_canonical_uri_from_endpoint(endpoint),
        "",
        signed,
        payload_hash,
        access_key,
        secret_key,
        region,
        "kms",
        amz_datetime
    )
    {
        "authorization": auth,
        "content-type": "application/x-amz-json-1.1",
        "host": host,
        "x-amz-content-sha256": payload_hash,
        "x-amz-date": amz_datetime,
        "x-amz-security-token": session_token,
        "x-amz-target": target,
        "x-simple-kms-vendor": "aws-kms"
    }

fn aws_kms_sigv4_headers_from_credentials(endpoint: text, target: text, body: text, store: CredentialStore, access_key_name: text, secret_key_name: text, region: text, amz_datetime: text) -> Dict<text, text>:
    val host = aws_kms_host_from_endpoint(endpoint)
    val payload_hash = sigv4_sha256_hex(body)
    var signed: [SigV4Header] = []
    signed = signed + [SigV4Header(name: "content-type", value: "application/x-amz-json-1.1")]
    signed = signed + [SigV4Header(name: "host", value: host)]
    signed = signed + [SigV4Header(name: "x-amz-content-sha256", value: payload_hash)]
    signed = signed + [SigV4Header(name: "x-amz-date", value: amz_datetime)]
    signed = signed + [SigV4Header(name: "x-amz-target", value: target)]
    val auth = credential_store_aws_sigv4_authorization(
        store,
        access_key_name,
        secret_key_name,
        "POST",
        aws_kms_canonical_uri_from_endpoint(endpoint),
        "",
        signed,
        payload_hash,
        region,
        "kms",
        amz_datetime
    )
    var headers: Dict<text, text> = {
        "content-type": "application/x-amz-json-1.1",
        "host": host,
        "x-amz-content-sha256": payload_hash,
        "x-amz-date": amz_datetime,
        "x-amz-target": target,
        "x-simple-kms-vendor": "aws-kms"
    }
    if auth != "":
        headers = headers.set("authorization", auth)
    headers

fn aws_kms_sigv4_headers_from_temporary_credentials(endpoint: text, target: text, body: text, store: CredentialStore, access_key_name: text, secret_key_name: text, session_token_name: text, region: text, amz_datetime: text) -> Dict<text, text>:
    val host = aws_kms_host_from_endpoint(endpoint)
    val payload_hash = sigv4_sha256_hex(body)
    var session_token = ""
    val session_handle = store.resolve(session_token_name)
    match session_handle:
        Some(handle):
            store.apply(handle, fn(token):
                session_token = token
            )
        nil:
            pass_do_nothing("temporary credentials did not include a session token")
    var signed: [SigV4Header] = []
    signed = signed + [SigV4Header(name: "content-type", value: "application/x-amz-json-1.1")]
    signed = signed + [SigV4Header(name: "host", value: host)]
    signed = signed + [SigV4Header(name: "x-amz-content-sha256", value: payload_hash)]
    signed = signed + [SigV4Header(name: "x-amz-date", value: amz_datetime)]
    signed = signed + [SigV4Header(name: "x-amz-security-token", value: session_token)]
    signed = signed + [SigV4Header(name: "x-amz-target", value: target)]
    val auth = credential_store_aws_sigv4_authorization_with_session_token(
        store,
        access_key_name,
        secret_key_name,
        session_token_name,
        "POST",
        aws_kms_canonical_uri_from_endpoint(endpoint),
        "",
        signed,
        payload_hash,
        region,
        "kms",
        amz_datetime
    )
    var headers: Dict<text, text> = {
        "content-type": "application/x-amz-json-1.1",
        "host": host,
        "x-amz-content-sha256": payload_hash,
        "x-amz-date": amz_datetime,
        "x-amz-security-token": session_token,
        "x-amz-target": target,
        "x-simple-kms-vendor": "aws-kms"
    }
    if auth != "":
        headers = headers.set("authorization", auth)
    headers

fn aws_kms_sigv4_sign_request(endpoint: text, key_handle: text, payload: text, signing_algorithm: text, access_key: text, secret_key: text, region: text, amz_datetime: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
    val body = "{\"KeyId\":\"{key_handle}\",\"Message\":\"{payload}\",\"MessageType\":\"RAW\",\"SigningAlgorithm\":\"{signing_algorithm}\"}"
    HostedKmsHttpRequest(
        method: "POST",
        url: endpoint,
        headers: aws_kms_sigv4_headers(endpoint, "TrentService.Sign", body, access_key, secret_key, region, amz_datetime),
        body: body,
        timeout_ms: timeout_ms,
        tls_profile: tls_profile
    )

fn aws_kms_sigv4_sign_request_with_session_token(endpoint: text, key_handle: text, payload: text, signing_algorithm: text, access_key: text, secret_key: text, session_token: text, region: text, amz_datetime: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
    val body = "{\"KeyId\":\"{key_handle}\",\"Message\":\"{payload}\",\"MessageType\":\"RAW\",\"SigningAlgorithm\":\"{signing_algorithm}\"}"
    HostedKmsHttpRequest(
        method: "POST",
        url: endpoint,
        headers: aws_kms_sigv4_headers_with_session_token(endpoint, "TrentService.Sign", body, access_key, secret_key, session_token, region, amz_datetime),
        body: body,
        timeout_ms: timeout_ms,
        tls_profile: tls_profile
    )

fn aws_kms_sigv4_sign_request_from_credentials(endpoint: text, key_handle: text, payload: text, signing_algorithm: text, store: CredentialStore, access_key_name: text, secret_key_name: text, region: text, amz_datetime: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
    val body = "{\"KeyId\":\"{key_handle}\",\"Message\":\"{payload}\",\"MessageType\":\"RAW\",\"SigningAlgorithm\":\"{signing_algorithm}\"}"
    HostedKmsHttpRequest(
        method: "POST",
