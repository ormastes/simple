fn aws_kms_sigv4_verify_request_from_temporary_credentials(endpoint: text, key_handle: text, payload: text, signature: text, signing_algorithm: text, store: CredentialStore, access_key_name: text, secret_key_name: text, session_token_name: text, region: text, amz_datetime: text, timeout_ms: i64, tls_profile: text) -> HostedKmsHttpRequest:
