"""
# Remote Security Quorum Session Store

N-of-M quorum wrapper for remote `SecurityContext` session adapters.
"""

use std.security.types.{RemoteSecuritySession, RemoteSecuritySessionStoreAdapter}

class RemoteSecurityQuorumSessionStore:
    """Quorum store over replicated remote session adapters.

    Reads merge the visible replicas with revocation-wins and later-expiry-wins
    semantics. Writes succeed only when the configured write quorum is reached.
    """
    replicas: [RemoteSecuritySessionStoreAdapter]
    read_quorum: i64
    write_quorum: i64

    static fn new(replicas: [RemoteSecuritySessionStoreAdapter], read_quorum: i64, write_quorum: i64) -> RemoteSecurityQuorumSessionStore:
        RemoteSecurityQuorumSessionStore(
            replicas: replicas,
            read_quorum: read_quorum,
            write_quorum: write_quorum
        )

impl RemoteSecurityQuorumSessionStore:
    fn replica_count() -> i64:
        self.replicas.len()

    fn effective_read_quorum() -> i64:
        remote_security_quorum_clamp(self.read_quorum, self.replica_count())

    fn effective_write_quorum() -> i64:
        remote_security_quorum_clamp(self.write_quorum, self.replica_count())

    me save_session(session: RemoteSecuritySession) -> bool:
        var successes = 0
        var updated: [RemoteSecuritySessionStoreAdapter] = []
        for replica in self.replicas:
            var writable = replica
            writable.save_session(session)
            updated = updated.push(writable)
            if writable.lookup_session(session.session_id).?:
                successes = successes + 1
        self.replicas = updated
        successes >= self.effective_write_quorum()

    me create_session(session_id: text, user_id: text, capabilities: List<text>, expires_at_ms: i64) -> bool:
        self.save_session(RemoteSecuritySession(
            session_id: session_id,
            user_id: user_id,
            capabilities: capabilities,
            expires_at_ms: expires_at_ms,
            revoked: false
        ))

    fn lookup_session(session_id: text) -> RemoteSecuritySession?:
        var found = 0
        var winner: RemoteSecuritySession? = nil
        for replica in self.replicas:
            val session = replica.lookup_session(session_id)
            if session.?:
                found = found + 1
                val loaded: RemoteSecuritySession = match session:
                    Some(value): value
                    None: continue
                winner = remote_security_quorum_pick(winner, loaded)
        if found < self.effective_read_quorum():
            return nil
        winner

    me lookup_and_repair_session(session_id: text) -> RemoteSecuritySession?:
        val winner = self.lookup_session(session_id)
        if winner.?:
            match winner:
                Some(value):
                    self.save_session(value)
                None:
                    pass
        winner

    fn lookup_active_session(session_id: text, now_ms: i64) -> RemoteSecuritySession?:
        val session = self.lookup_session(session_id)
        if session.?:
            val loaded: RemoteSecuritySession = match session:
                Some(value): value
                None: return nil
            if loaded.is_active(now_ms):
                return Some(loaded)
        nil

    me refresh_session(session_id: text, expires_at_ms: i64) -> bool:
        val session = self.lookup_session(session_id)
        if not session.?:
            return false
        val loaded: RemoteSecuritySession = match session:
            Some(value): value
            None: return false
        if loaded.revoked:
            return false
        self.save_session(loaded.refreshed(expires_at_ms))

    me revoke_session(session_id: text) -> bool:
        val session = self.lookup_session(session_id)
        if not session.?:
            return false
        val loaded: RemoteSecuritySession = match session:
            Some(value): value
            None: return false
        self.save_session(RemoteSecuritySession(
            session_id: loaded.session_id,
            user_id: loaded.user_id,
            capabilities: loaded.capabilities,
            expires_at_ms: loaded.expires_at_ms,
            revoked: true
        ))

    fn export_sdn() -> text:
        var lines: List<text> = [
            "remote_security_quorum_session_store:",
            "  replicas: {self.replica_count()}",
            "  read_quorum: {self.effective_read_quorum()}",
            "  write_quorum: {self.effective_write_quorum()}"
        ]
        var index = 0
        for replica in self.replicas:
            lines = lines.push("  replica|{index}|{replica.backend}|{replica.store_namespace}")
            index = index + 1
        lines.join("\n")

fn remote_security_quorum_clamp(required: i64, replica_count: i64) -> i64:
    if replica_count <= 0:
        return 1
    if required <= 0:
        return 1
    if required > replica_count:
        return replica_count
    required

fn remote_security_quorum_pick(current: RemoteSecuritySession?, incoming: RemoteSecuritySession) -> RemoteSecuritySession?:
    if not current.?:
        return Some(incoming)
    val local: RemoteSecuritySession = match current:
        Some(value): value
        None: return Some(incoming)
    if incoming.revoked and not local.revoked:
        return Some(incoming)
    if local.revoked:
        return Some(local)
    if incoming.expires_at_ms > local.expires_at_ms:
        return Some(incoming)
    Some(local)
