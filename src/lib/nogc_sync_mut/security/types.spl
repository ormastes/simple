# Security core types for audit logging, events, and security context.

use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.crypto.hmac.{hmac_sha256_bytes}
use std.common.crypto.constant_time.{constant_time_compare}
use std.common.crypto.types.{bytes_to_hex, text_to_bytes}

extern fn rt_random_hex(length: i64) -> text

## Security event types for audit logging.
enum SecurityEvent:
    AuthSuccess(user: text, peer: text)
    AuthFailure(user: text, peer: text, reason: text)
    AccessDenied(resource: text, capability: text, peer: text)
    CsrfViolation(peer: text, path: text)
    RateLimitHit(peer: text, path: text)
    InputSanitized(field: text, original_len: i64)
    SessionCreated(session_id: text, peer: text)
    SessionExpired(session_id: text)
    CapabilityDenied(capability: text, window_id: text)
    RequestProcessed(path: text, duration_ms: i64, status: i64)

## Severity levels for security events.
enum SecuritySeverity:
    Info
    Warning
    Critical

## A single structured audit log entry.
##
## Hash-chain fields (`seq`, `prev_hash`, `entry_hash`) are populated by
## `audit_chain_append` (see `src/lib/common/security/audit_chain.spl`).
## `AuditEntry.new(...)` leaves them at zero defaults — direct callers of
## `log_security_event` (non-chained path) will see seq=0 / zero hashes.
class AuditEntry:
    timestamp_ms: i64
    event: SecurityEvent
    correlation_id: text
    module_path: text
    severity: SecuritySeverity
    seq: i64                  # NEW — monotonic 1-based; 0 means "not chained"
    prev_hash: [u8]           # NEW — sha256 of previous entry's entry_hash; 32 bytes
    entry_hash: [u8]          # NEW — sha256(seq_be || ts_be || sev || event_json || prev_hash)

    static fn new(event: SecurityEvent, correlation_id: text, module_path: text) -> AuditEntry:
        AuditEntry(
            timestamp_ms: time_now_ms(),
            event: event,
            correlation_id: correlation_id,
            module_path: module_path,
            severity: severity_for_event(event),
            seq: 0,
            prev_hash: _zero_hash_32(),
            entry_hash: _zero_hash_32()
        )

## Returns a 32-byte zero list — used as the genesis prev_hash and as the
## default for non-chained AuditEntry construction.
fn _zero_hash_32() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(0)
        i = i + 1
    out

## Security context carried through a request/session lifecycle.
class SecurityContext:
    peer_addr: text
    session_id: text
    user_id: text
    correlation_id: text
    capabilities: List<text>

    static fn anonymous(peer_addr: text) -> SecurityContext:
        SecurityContext(
            peer_addr: peer_addr,
            session_id: "",
            user_id: "",
            correlation_id: generate_correlation_id(),
            capabilities: []
        )

    fn is_authenticated() -> bool:
        self.user_id != ""

    fn has_capability(cap: text) -> bool:
        self.capabilities.contains(cap)

## Display-only permission snapshot sent to remote UI clients.
##
## This is never an authorization token. Clients may use it to hide or disable
## UI, but every privileged action must still call a server-side gate that
## reconstructs and checks a SecurityContext.
class PermissionSnapshot:
    subject: text
    scopes: List<text>
    ui_hints: Dict<text, bool>
    policy_version: i64
    expires_at_ms: i64
    authority: text
    server_gate_required: bool

    static fn display_only(subject: text, scopes: List<text>, ui_hints: Dict<text, bool>, policy_version: i64, expires_at_ms: i64) -> PermissionSnapshot:
        PermissionSnapshot(
            subject: subject,
            scopes: scopes,
            ui_hints: ui_hints,
            policy_version: policy_version,
            expires_at_ms: expires_at_ms,
            authority: "display_only",
            server_gate_required: true
        )

    fn is_display_only() -> bool:
        self.authority == "display_only" and self.server_gate_required

    fn is_expired(now_ms: i64) -> bool:
        self.expires_at_ms <= now_ms

    fn has_scope(scope: text) -> bool:
        self.scopes.contains(scope)

    fn can_show(key: text) -> bool:
        val maybe_allowed = self.ui_hints.get(key)
        if val allowed = maybe_allowed:
            allowed
        else:
            false

## Remote request headers that are safe to propagate into context assembly.
##
## Raw authorization remains an input to server-side reconstruction; baggage is
## limited to non-authoritative metadata and must not contain roles or secrets.
class RemoteSecurityContextHeaders:
    authorization: text
    traceparent: text
    tenant_id: text
    policy_version: text
    request_class: text

    static fn empty() -> RemoteSecurityContextHeaders:
        RemoteSecurityContextHeaders(
            authorization: "",
            traceparent: "",
            tenant_id: "",
            policy_version: "",
            request_class: ""
        )

    fn has_authorization() -> bool:
        self.authorization != ""

    fn safe_baggage() -> Dict<text, text>:
        {
            "tenant_id": self.tenant_id,
            "policy_version": self.policy_version,
            "request_class": self.request_class
        }

fn remote_security_headers_from_pairs(headers: [(text, text)]) -> RemoteSecurityContextHeaders:
    var authorization = ""
    var traceparent = ""
    var tenant_id = ""
    var policy_version = ""
    var request_class = ""

    for pair in headers:
        val name = pair.0.lower()
        val value = pair.1
        if name == "authorization":
            authorization = value
        elif name == "traceparent":
            traceparent = value
        elif name == "x-simple-tenant-id":
            tenant_id = value
        elif name == "x-simple-policy-version":
            policy_version = value
        elif name == "x-simple-request-class":
            request_class = value

    RemoteSecurityContextHeaders(
        authorization: authorization,
        traceparent: traceparent,
        tenant_id: tenant_id,
        policy_version: policy_version,
        request_class: request_class
    )

fn remote_security_session_id_from_pairs(headers: [(text, text)]) -> text:
    for pair in headers:
        if pair.0.lower() == "x-simple-session-id":
            return pair.1
    return ""

fn anonymous_remote_security_context(headers: RemoteSecurityContextHeaders, peer_addr: text) -> SecurityContext:
    reconstruct_remote_security_context(headers, peer_addr, "", "", [])

## Validated identity extracted from a server-signed remote token.
class RemoteSecurityValidatedIdentity:
    session_id: text
    user_id: text
    capabilities: List<text>
    expires_at_ms: i64

    fn is_expired(now_ms: i64) -> bool:
        self.expires_at_ms <= now_ms

fn remote_security_bearer_token(headers: RemoteSecurityContextHeaders) -> text:
    val authorization = headers.authorization.trim()
    if authorization.starts_with("Bearer "):
        return authorization[7:].trim()
    return ""

fn remote_security_token_payload(session_id: text, user_id: text, expires_at_ms: i64, capabilities: List<text>) -> text:
    val scopes = capabilities.join(",")
    "{session_id}|{user_id}|{expires_at_ms}|{scopes}"

fn remote_security_hmac_sha256_hex(signing_key: text, payload: text) -> text:
    bytes_to_hex(hmac_sha256_bytes(text_to_bytes(signing_key), text_to_bytes(payload)))

fn sign_remote_security_token(signing_key: text,
                              session_id: text,
                              user_id: text,
                              expires_at_ms: i64,
                              capabilities: List<text>) -> text:
    val payload = remote_security_token_payload(session_id, user_id, expires_at_ms, capabilities)
    val signature = remote_security_hmac_sha256_hex(signing_key, payload)
    "simple-v1|{payload}|{signature}"

fn validate_remote_security_token(headers: RemoteSecurityContextHeaders,
                                  session_id: text,
                                  signing_key: text,
                                  now_ms: i64) -> RemoteSecurityValidatedIdentity?:
    if signing_key == "":
        return nil
    val bearer = remote_security_bearer_token(headers)
    if bearer == "":
        return nil
    val parts = bearer.split("|")
    if parts.len() != 6:
        return nil
    if parts[0] != "simple-v1":
        return nil
    val token_session_id = parts[1]
    val user_id = parts[2]
    val expires_at_ms = parts[3].to_i64() ?? 0
    val scopes = parts[4]
    val signature = parts[5]
    if token_session_id == "" or user_id == "":
        return nil
    if session_id != "" and session_id != token_session_id:
        return nil
    val capabilities = if scopes == "": [] else: scopes.split(",")
    val payload = remote_security_token_payload(token_session_id, user_id, expires_at_ms, capabilities)
    val expected = remote_security_hmac_sha256_hex(signing_key, payload)
    if not constant_time_compare(expected, signature):
        return nil
    val identity = RemoteSecurityValidatedIdentity(
        session_id: token_session_id,
        user_id: user_id,
        capabilities: capabilities,
        expires_at_ms: expires_at_ms
    )
    if identity.is_expired(now_ms):
        return nil
    identity

## Validate a remote bearer token against the server signing key. Invalid,
## missing, expired, tampered, or session-mismatched tokens reconstruct an
## anonymous context while preserving peer/session transport metadata.
fn validate_remote_security_context(headers: RemoteSecurityContextHeaders,
                                    peer_addr: text,
                                    session_id: text,
                                    signing_key: text,
                                    now_ms: i64) -> SecurityContext:
    if val identity = validate_remote_security_token(headers, session_id, signing_key, now_ms):
        return reconstruct_remote_security_context(headers, peer_addr, identity.session_id, identity.user_id, identity.capabilities)

    reconstruct_remote_security_context(headers, peer_addr, session_id, "", [])

## Reconstructed remote context plus its display-only client snapshot.
class RemoteSecurityContext:
    ctx: SecurityContext
    headers: RemoteSecurityContextHeaders
    snapshot: PermissionSnapshot

    fn server_authoritative() -> bool:
        self.snapshot.is_display_only()

## Reconstruct a server SecurityContext from already-validated identity data.
##
## The client snapshot is deliberately not used as an authority source.
fn reconstruct_remote_security_context(headers: RemoteSecurityContextHeaders, peer_addr: text, session_id: text, user_id: text, capabilities: List<text>) -> SecurityContext:
    if user_id == "":
        return SecurityContext(
            peer_addr: peer_addr,
            session_id: session_id,
            user_id: "",
            correlation_id: generate_correlation_id(),
            capabilities: []
        )

    SecurityContext(
        peer_addr: peer_addr,
        session_id: session_id,
        user_id: user_id,
        correlation_id: generate_correlation_id(),
        capabilities: capabilities
    )

## Configuration for audit logging behavior.
class AuditConfig:
    enabled: bool
    log_file: text
    log_to_stdout: bool
    min_severity: SecuritySeverity
    mask_secrets: bool

    static fn default() -> AuditConfig:
        AuditConfig(
            enabled: true,
            log_file: "security_audit.log",
            log_to_stdout: false,
            min_severity: SecuritySeverity.Info,
            mask_secrets: true
        )

## Determine severity from event type.
fn severity_for_event(event: SecurityEvent) -> SecuritySeverity:
    """
    Maps security events to their severity level.

    sdoctest:
        val e1 = SecurityEvent.AuthSuccess(user: "u", peer: "p")
        expect(severity_for_event(e1)).to_equal(SecuritySeverity.Info)
        val e2 = SecurityEvent.CsrfViolation(peer: "p", path: "/")
        expect(severity_for_event(e2)).to_equal(SecuritySeverity.Critical)
    """
    match event:
        AuthFailure(_, _, _): SecuritySeverity.Warning
        AccessDenied(_, _, _): SecuritySeverity.Warning
        CsrfViolation(_, _): SecuritySeverity.Critical
        CapabilityDenied(_, _): SecuritySeverity.Warning
        _: SecuritySeverity.Info

## Generate a unique correlation ID for request tracing.
fn generate_correlation_id() -> text:
    val ts = time_now_ms()
    val rand = random_hex(8)
    "{ts}-{rand}"

## Time helper (delegates to runtime).
fn time_now_ms() -> i64:
    current_time_ms()

## Random hex helper (delegates to crypto SFFI).
fn random_hex(bytes: i64) -> text:
    rt_random_hex(bytes)
