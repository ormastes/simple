# ============================================================================
# game_net/virtual_clock.spl — deterministic virtual clock (no wall time)
#
# Netcode plan P4: the loopback harness never reads the OS clock. Tests
# advance a `VirtualClock` by an explicit number of milliseconds each tick,
# which is what makes latency/jitter/reorder scheduling reproducible byte-
# for-byte across runs.
# ============================================================================

class VirtualClock:
    now_ms: u64

impl VirtualClock:
    static fn new() -> VirtualClock:
        VirtualClock(now_ms: 0u64)

    me advance(ms: u64):
        self.now_ms = self.now_ms + ms

    fn now() -> u64:
        self.now_ms

export VirtualClock
