# ============================================================================
# game_net/interpolator.spl — remote (non-owned) entity interpolation
#
# Netcode plan P2: remote entities are never predicted, only interpolated
# between the last two acked snapshots by `interpolation_factor` (0.0 = the
# older snapshot, 1.0 = the newer one). At t=1.0 the lerp is exact (equals
# the newer snapshot's values), which the two-client convergence BDD leans
# on: a converged world hash needs the *authoritative* remote value, not a
# render-smoothed one.
# ============================================================================

use std.nogc_sync_mut.game_net.wire.{EntityState}

class Interpolator:
    prev: EntityState?
    next: EntityState?

impl Interpolator:
    static fn new() -> Interpolator:
        Interpolator(prev: nil, next: nil)

    me push_snapshot(e: EntityState):
        """Slide the 2-snapshot buffer: previous `next` becomes `prev`."""
        self.prev = self.next
        self.next = e

    fn lerp(t: f32) -> EntityState?:
        if val n = self.next:
            if val p = self.prev:
                return EntityState(
                    entity_id: n.entity_id,
                    pos_x: p.pos_x + (n.pos_x - p.pos_x) * t,
                    pos_y: p.pos_y + (n.pos_y - p.pos_y) * t,
                    vel_x: n.vel_x, vel_y: n.vel_y
                )
            return n
        nil

export Interpolator
