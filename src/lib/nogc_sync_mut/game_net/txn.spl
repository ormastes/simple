# ============================================================================
# game_net/txn.spl — transactional op layer (accept/reject/cancel)
#
# Netcode plan P3. Concrete demo domain: a `Wallet{gold}` inventory balance
# (kept intentionally tiny — the mechanism, not the domain, is the point of
# this slice). Client: `begin_spend` serializes the pre-op wallet to bytes
# via ByteWriter, applies the spend optimistically, and marks the op
# pending. Server: `validate_spend` checks the authoritative balance.
# Client on accept: drop the pre-op snapshot (commit stands). Client on
# reject/cancel: `ByteReader`-restore the pre-op snapshot — byte-identical
# to before the op, by construction (same bytes, decoded back).
# ============================================================================

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.nogc_sync_mut.game_net.wire.{TxnMsg, TXN_BEGIN}

struct Wallet:
    gold: i32

fn wallet_to_bytes(w: Wallet) -> [u8]:
    var bw = ByteWriter.new()
    bw.write_u32(w.gold.to_u32())
    bw.to_bytes()

fn wallet_from_bytes(bytes: [u8]) -> Result<Wallet, text>:
    var r = ByteReader.new(bytes)
    val v = r.read_u32()?
    Ok(Wallet(gold: v.to_i32()))

fn validate_spend(gold: i32, cost: i32) -> bool:
    """Server-side authority check: can this wallet afford the op?"""
    gold >= cost

struct PendingOp:
    op_seq: u32
    pre_bytes: [u8]

class TxnClient:
    seq_counter: u32
    pending: [PendingOp]

impl TxnClient:
    static fn new() -> TxnClient:
        TxnClient(seq_counter: 0u32, pending: [])

    me begin_spend(wallet: Wallet, cost: i32) -> (TxnMsg, Wallet):
        """Optimistic apply: snapshot pre-op state, deduct immediately,
        mark pending(op_seq)."""
        self.seq_counter = self.seq_counter + 1u32
        val pre_bytes = wallet_to_bytes(wallet)
        self.pending.push(PendingOp(op_seq: self.seq_counter, pre_bytes: pre_bytes))
        val new_wallet = Wallet(gold: wallet.gold - cost)
        var payload_w = ByteWriter.new()
        payload_w.write_u32(cost.to_u32())
        val msg = TxnMsg(op_seq: self.seq_counter, kind: TXN_BEGIN, payload: payload_w.to_bytes())
        (msg, new_wallet)

    me accept(op_seq: u32):
        """Server accepted: drop the pre-op snapshot, the optimistic apply stands."""
        self.drop(op_seq)

    me reject(op_seq: u32) -> Wallet?:
        """Server rejected: restore the pre-op snapshot, byte-identical to
        before the op."""
        self.restore(op_seq)

    me cancel(op_seq: u32) -> Wallet?:
        """Client cancels before any server ack: same byte-identical restore."""
        self.restore(op_seq)

    me pre_op_bytes(op_seq: u32) -> [u8]?:
        var i: u64 = 0
        while i < self.pending.len().to_u64():
            if self.pending[i].op_seq == op_seq:
                return self.pending[i].pre_bytes
            i = i + 1
        nil

    me restore(op_seq: u32) -> Wallet?:
        var i: u64 = 0
        while i < self.pending.len().to_u64():
            if self.pending[i].op_seq == op_seq:
                val bytes = self.pending[i].pre_bytes
                self.drop(op_seq)
                match wallet_from_bytes(bytes):
                    case Ok(w): return w
                    case Err(_): return nil
            i = i + 1
        nil

    me drop(op_seq: u32):
        var kept: [PendingOp] = []
        var i: u64 = 0
        while i < self.pending.len().to_u64():
            if self.pending[i].op_seq != op_seq:
                kept.push(self.pending[i])
            i = i + 1
        self.pending = kept

    fn pending_count() -> u64:
        self.pending.len().to_u64()

export Wallet
export wallet_to_bytes, wallet_from_bytes, validate_spend
export TxnClient
