# ============================================================================
# game_net/wire.spl — versioned wire frame codecs on ByteReader/ByteWriter
#
# Netcode plan P1 (doc/03_plan/app/game_engine/netcode_prediction_plan.md).
# Every frame starts with a common header: proto_ver:u16 + msg_kind:u8. Big
# endian throughout (matches src/lib/common/net/byte_cursor.spl). f32 fields
# ride the existing bitcast helpers in std.nogc_sync_mut.binary_io (reused,
# not reimplemented) since byte_cursor has no native f32 accessor.
#
# Snapshot supports two wire modes:
#   mode 0 (full)  — every EntityState field is written.
#   mode 1 (delta) — only fields that changed vs a caller-supplied baseline
#                    are written, gated by a per-entity dirty bitmask.
# decode_snapshot takes the same baseline so delta frames reconstruct the
# full EntityState by merging dirty fields onto the last-known value.
#
# Interest management (game_net/interest.spl) rides the existing delta
# scheme with no PROTO_VER bump: an entity ENTERING a client's interest set
# is simply absent from that client's baseline, so `_dirty_mask` already
# returns DIRTY_ALL for it (same as any never-before-seen entity) — full
# fields go out for free. An entity LEAVING interest has no natural
# representation on the wire (it just stops appearing), so
# `encode_snapshot_delta` gained one additive optional param, `removed_ids`,
# written per id as `entity_id:u32 + mask:u8(DIRTY_REMOVE)` with no field
# payload. `DIRTY_REMOVE` (16) sits outside the existing 0..15 dirty-bit
# range so it can never collide with a real field combination. Every
# existing call site omits `removed_ids` (defaults to `[]`), so their output
# is byte-identical to before — additive, not a layout change, hence no
# version bump.
# ============================================================================

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.nogc_sync_mut.binary_io.{f32_to_bits, f32_from_bits}

val PROTO_VER: u16 = 1u16

val MSG_INPUT: u8 = 0u8
val MSG_SNAPSHOT: u8 = 1u8
val MSG_TXN: u8 = 2u8
val MSG_ACK: u8 = 3u8

val SNAPSHOT_MODE_FULL: u8 = 0u8
val SNAPSHOT_MODE_DELTA: u8 = 1u8

val TXN_BEGIN: u8 = 0u8
val TXN_ACCEPT: u8 = 1u8
val TXN_REJECT: u8 = 2u8
val TXN_CANCEL: u8 = 3u8

val DIRTY_POS_X: u8 = 1u8
val DIRTY_POS_Y: u8 = 2u8
val DIRTY_VEL_X: u8 = 4u8
val DIRTY_VEL_Y: u8 = 8u8
val DIRTY_ALL: u8 = 15u8
val DIRTY_REMOVE: u8 = 16u8

struct InputFrame:
    """Client input for one fixed-step tick."""
    seq: u32
    tick: u32
    move_x: f32
    move_y: f32

struct EntityState:
    """One entity's authoritative or predicted state."""
    entity_id: u32
    pos_x: f32
    pos_y: f32
    vel_x: f32
    vel_y: f32

struct Snapshot:
    """Server broadcast: authoritative tick + per-client input ack + entities."""
    tick: u32
    ack_input_seq: u32
    entities: [EntityState]

struct TxnMsg:
    op_seq: u32
    kind: u8
    payload: [u8]

struct Ack:
    last_seq: u32

fn _write_f32(w: ByteWriter, v: f32):
    w.write_u32(f32_to_bits(v))

# NOTE: no `_read_f32(r: ByteReader) -> ...` helper — ByteReader.pos is a
# scalar field, so passing `r` into a plain function (not calling `.read_*()`
# directly on the caller's own `r`) copies it by value and the position
# advance is silently lost on return (same class as
# BUG byvalue_reader_cursor_no_advance_cross_module_2026-06-15, which applies
# to any function boundary, not only cross-module). Every f32 read below is
# inlined as `f32_from_bits(r.read_u32()?)` directly against the local `r`.

# ---------------------------------------------------------------------------
# InputFrame
# ---------------------------------------------------------------------------

fn encode_input_frame(f: InputFrame) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(PROTO_VER)
    w.write_u8(MSG_INPUT)
    w.write_u32(f.seq)
    w.write_u32(f.tick)
    _write_f32(w, f.move_x)
    _write_f32(w, f.move_y)
    w.to_bytes()

fn decode_input_frame(bytes: [u8]) -> Result<InputFrame, text>:
    var r = ByteReader.new(bytes)
    val ver = r.read_u16()?
    if ver != PROTO_VER:
        return Err("wire: InputFrame bad proto_ver {ver}")
    val kind = r.read_u8()?
    if kind != MSG_INPUT:
        return Err("wire: expected MSG_INPUT, got {kind}")
    val seq = r.read_u32()?
    val tick = r.read_u32()?
    val mx = f32_from_bits(r.read_u32()?)
    val my = f32_from_bits(r.read_u32()?)
    Ok(InputFrame(seq: seq, tick: tick, move_x: mx, move_y: my))

# ---------------------------------------------------------------------------
# EntityState (helpers shared by Snapshot full/delta encode-decode)
# ---------------------------------------------------------------------------

fn _find_baseline(entity_id: u32, baseline: [EntityState]) -> EntityState?:
    var i: u64 = 0
    while i < baseline.len().to_u64():
        val e = baseline[i]
        if e.entity_id == entity_id:
            return e
        i = i + 1
    nil

fn _dirty_mask(cur: EntityState, base: EntityState?) -> u8:
    # NOTE: `if val b = base:` misdetects a genuinely-nil `base` as present
    # under the interpreter fallback path (tracked:
    # doc/08_tracking/bug/interpreter_if_val_nil_mismatch_option_2026-07-03.md
    # and interp_if_val_option_binding_enters_body_on_nil_2026-07-02.md) —
    # this matters here because an entity ENTERING a client's interest set
    # (game_net/interest.spl) has no baseline entry yet, i.e. `base == nil`
    # is the common case, not an edge case. `base != nil` + direct field
    # access on `base` is the documented-safe idiom instead.
    if base != nil:
        var mask: u8 = 0u8
        if cur.pos_x != base.pos_x:
            mask = mask | DIRTY_POS_X
        if cur.pos_y != base.pos_y:
            mask = mask | DIRTY_POS_Y
        if cur.vel_x != base.vel_x:
            mask = mask | DIRTY_VEL_X
        if cur.vel_y != base.vel_y:
            mask = mask | DIRTY_VEL_Y
        mask
    else:
        DIRTY_ALL

# ---------------------------------------------------------------------------
# Snapshot
# ---------------------------------------------------------------------------

fn encode_snapshot_full(s: Snapshot) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(PROTO_VER)
    w.write_u8(MSG_SNAPSHOT)
    w.write_u8(SNAPSHOT_MODE_FULL)
    w.write_u32(s.tick)
    w.write_u32(s.ack_input_seq)
    w.write_u16(s.entities.len().to_u16())
    var i: u64 = 0
    while i < s.entities.len().to_u64():
        val e = s.entities[i]
        w.write_u32(e.entity_id)
        _write_f32(w, e.pos_x)
        _write_f32(w, e.pos_y)
        _write_f32(w, e.vel_x)
        _write_f32(w, e.vel_y)
        i = i + 1
    w.to_bytes()

fn encode_snapshot_delta(s: Snapshot, baseline: [EntityState], removed_ids: [u32] = []) -> [u8]:
    """`removed_ids` (game_net/interest.spl leave-tracking) are entities the
    receiving client must drop — each is written as `entity_id + DIRTY_REMOVE`
    with no field payload. Omitting it (every pre-interest call site) is
    byte-identical to before."""
    var w = ByteWriter.new()
    w.write_u16(PROTO_VER)
    w.write_u8(MSG_SNAPSHOT)
    w.write_u8(SNAPSHOT_MODE_DELTA)
    w.write_u32(s.tick)
    w.write_u32(s.ack_input_seq)
    w.write_u16((s.entities.len().to_u64() + removed_ids.len().to_u64()).to_u16())
    var i: u64 = 0
    while i < s.entities.len().to_u64():
        val e = s.entities[i]
        val base = _find_baseline(e.entity_id, baseline)
        val mask = _dirty_mask(e, base)
        w.write_u32(e.entity_id)
        w.write_u8(mask)
        if (mask & DIRTY_POS_X) != 0u8:
            _write_f32(w, e.pos_x)
        if (mask & DIRTY_POS_Y) != 0u8:
            _write_f32(w, e.pos_y)
        if (mask & DIRTY_VEL_X) != 0u8:
            _write_f32(w, e.vel_x)
        if (mask & DIRTY_VEL_Y) != 0u8:
            _write_f32(w, e.vel_y)
        i = i + 1
    i = 0
    while i < removed_ids.len().to_u64():
        w.write_u32(removed_ids[i])
        w.write_u8(DIRTY_REMOVE)
        i = i + 1
    w.to_bytes()

fn decode_snapshot(bytes: [u8], baseline: [EntityState]) -> Result<Snapshot, text>:
    var r = ByteReader.new(bytes)
    val ver = r.read_u16()?
    if ver != PROTO_VER:
        return Err("wire: Snapshot bad proto_ver {ver}")
    val kind = r.read_u8()?
    if kind != MSG_SNAPSHOT:
        return Err("wire: expected MSG_SNAPSHOT, got {kind}")
    val mode = r.read_u8()?
    val tick = r.read_u32()?
    val ack_input_seq = r.read_u32()?
    val count = r.read_u16()?
    var entities: [EntityState] = []
    var i: u16 = 0u16
    while i < count:
        val entity_id = r.read_u32()?
        if mode == SNAPSHOT_MODE_FULL:
            val px = f32_from_bits(r.read_u32()?)
            val py = f32_from_bits(r.read_u32()?)
            val vx = f32_from_bits(r.read_u32()?)
            val vy = f32_from_bits(r.read_u32()?)
            entities.push(EntityState(entity_id: entity_id, pos_x: px, pos_y: py, vel_x: vx, vel_y: vy))
        elif mode == SNAPSHOT_MODE_DELTA:
            val mask = r.read_u8()?
            if mask == DIRTY_REMOVE:
                pass_dn   # entity left the client's interest set: drop it, no payload follows
            else:
                val base = _find_baseline(entity_id, baseline)
                var px: f32 = 0.0
                var py: f32 = 0.0
                var vx: f32 = 0.0
                var vy: f32 = 0.0
                # same `base != nil` workaround as `_dirty_mask` above.
                if base != nil:
                    px = base.pos_x
                    py = base.pos_y
                    vx = base.vel_x
                    vy = base.vel_y
                if (mask & DIRTY_POS_X) != 0u8:
                    px = f32_from_bits(r.read_u32()?)
                if (mask & DIRTY_POS_Y) != 0u8:
                    py = f32_from_bits(r.read_u32()?)
                if (mask & DIRTY_VEL_X) != 0u8:
                    vx = f32_from_bits(r.read_u32()?)
                if (mask & DIRTY_VEL_Y) != 0u8:
                    vy = f32_from_bits(r.read_u32()?)
                entities.push(EntityState(entity_id: entity_id, pos_x: px, pos_y: py, vel_x: vx, vel_y: vy))
        else:
            return Err("wire: Snapshot bad mode {mode}")
        i = i + 1u16
    Ok(Snapshot(tick: tick, ack_input_seq: ack_input_seq, entities: entities))

# ---------------------------------------------------------------------------
# TxnMsg
# ---------------------------------------------------------------------------

fn encode_txn_msg(t: TxnMsg) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(PROTO_VER)
    w.write_u8(MSG_TXN)
    w.write_u32(t.op_seq)
    w.write_u8(t.kind)
    w.write_u16(t.payload.len().to_u16())
    w.write_bytes(t.payload)
    w.to_bytes()

fn decode_txn_msg(bytes: [u8]) -> Result<TxnMsg, text>:
    var r = ByteReader.new(bytes)
    val ver = r.read_u16()?
    if ver != PROTO_VER:
        return Err("wire: TxnMsg bad proto_ver {ver}")
    val kind_hdr = r.read_u8()?
    if kind_hdr != MSG_TXN:
        return Err("wire: expected MSG_TXN, got {kind_hdr}")
    val op_seq = r.read_u32()?
    val kind = r.read_u8()?
    val payload_len = r.read_u16()?
    val payload = r.read_bytes(payload_len.to_u64())?
    Ok(TxnMsg(op_seq: op_seq, kind: kind, payload: payload))

# ---------------------------------------------------------------------------
# Ack
# ---------------------------------------------------------------------------

fn encode_ack(a: Ack) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(PROTO_VER)
    w.write_u8(MSG_ACK)
    w.write_u32(a.last_seq)
    w.to_bytes()

fn decode_ack(bytes: [u8]) -> Result<Ack, text>:
    var r = ByteReader.new(bytes)
    val ver = r.read_u16()?
    if ver != PROTO_VER:
        return Err("wire: Ack bad proto_ver {ver}")
    val kind = r.read_u8()?
    if kind != MSG_ACK:
        return Err("wire: expected MSG_ACK, got {kind}")
    val last_seq = r.read_u32()?
    Ok(Ack(last_seq: last_seq))

export InputFrame, EntityState, Snapshot, TxnMsg, Ack
export PROTO_VER, MSG_INPUT, MSG_SNAPSHOT, MSG_TXN, MSG_ACK
export SNAPSHOT_MODE_FULL, SNAPSHOT_MODE_DELTA
export DIRTY_POS_X, DIRTY_POS_Y, DIRTY_VEL_X, DIRTY_VEL_Y, DIRTY_ALL, DIRTY_REMOVE
export TXN_BEGIN, TXN_ACCEPT, TXN_REJECT, TXN_CANCEL
export encode_input_frame, decode_input_frame
export encode_snapshot_full, encode_snapshot_delta, decode_snapshot
export encode_txn_msg, decode_txn_msg
export encode_ack, decode_ack
