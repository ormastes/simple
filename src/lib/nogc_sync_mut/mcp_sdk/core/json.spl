# MCP SDK - JSON Building and Parsing Helpers
#
# Provides battle-tested JSON construction and extraction functions.
# Extracted from app.mcp.helpers for SDK reuse.

use std.common.string_core.{char_from_code}

extern fn rt_string_bytes(value: text) -> [i64]

# Local definitions (runtime can't re-export imported symbols)
fn LB() -> text:
    char_from_code(123)

fn RB() -> text:
    char_from_code(125)

fn Q() -> text:
    "\""

fn escape_json(s: text) -> text:
    var result = s
    result = result.replace(r"\", r"\\")
    result = result.replace(Q(), r"\" + Q())
    result = result.replace("\n", r"\n")
    result = result.replace("\r", r"\r")
    result = result.replace("\t", r"\t")
    result

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

# Build JSON object with 1 pair
fn jo1(pair: String) -> String:
    LB() + pair + RB()

# Build JSON object with 2 pairs
fn jo2(p1: String, p2: String) -> String:
    LB() + p1 + "," + p2 + RB()

# Build JSON object with 3 pairs
fn jo3(p1: String, p2: String, p3: String) -> String:
    LB() + p1 + "," + p2 + "," + p3 + RB()

# Build JSON object with 4 pairs
fn jo4(p1: String, p2: String, p3: String, p4: String) -> String:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + RB()

# Build JSON object with 5 pairs
fn jo5(p1: String, p2: String, p3: String, p4: String, p5: String) -> String:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + "," + p5 + RB()

# Build JSON array from list of strings
fn ja(items: [String]) -> String:
    "[" + items.join(",") + "]"

fn unwrap_idx(opt_idx: i64) -> i64:
    opt_idx

# --- JSON parsing helpers ---

# Extract a string value for a given key from JSON
fn extract_json_string(json: String, key: String) -> String:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx = find_sub(json, search)
    if idx < 0:
        return ""

    val slen = search.len()
    val start = idx + slen
    val after = json.substring(start)
    val trimmed = after.trim()

    if trimmed.starts_with(quote):
        val rest = trimmed.substring(1)
        val end = find_sub(rest, quote)
        if end >= 0:
            return rest.substring(0, end)
    ""

# Extract a raw value (number, boolean, null) for a given key
fn extract_json_value(json: String, key: String) -> String:
    val search = Q() + key + Q() + ":"
    val idx = find_sub(json, search)
    if idx < 0:
        return "null"
    val slen = search.len()
    val start = idx + slen
    val after = json.substring(start)
    val trimmed = after.trim()
    var end = 0
    for ch in trimmed:
        if ch == "," or ch == RB() or ch == "]":
            break
        end = end + 1
    trimmed.substring(0, end).trim()

# Extract a string from a nested JSON object
fn extract_nested_string(json: String, outer_key: String, inner_key: String) -> String:
    val search = Q() + outer_key + Q() + ":"
    val idx = find_sub(json, search)
    if idx < 0:
        return ""
    val slen = search.len()
    val start = idx + slen
    val after = json.substring(start)
    extract_json_string(json=after, key=inner_key)

# Extract arguments dict from MCP request body
fn extract_arguments_dict(body: String) -> String:
    val params_search = Q() + "params" + Q() + ":"
    val params_idx = find_sub(body, params_search)
    if params_idx < 0:
        return ""

    val params_start = params_idx + params_search.len()
    val params_section = body.substring(params_start)

    val args_search = Q() + "arguments" + Q() + ":"
    val args_idx = find_sub(params_section, args_search)
    if args_idx < 0:
        return ""

    val args_start = args_idx + args_search.len()
    val after_args = params_section.substring(args_start)
    val trimmed = after_args.trim()

    if not trimmed.starts_with(LB()):
        return ""

    # Find matching closing brace
    var brace_count = 0
    var idx2 = 0
    var args_content = ""

    for ch in trimmed:
        if ch == LB():
            brace_count = brace_count + 1
        elif ch == RB():
            brace_count = brace_count - 1
            if brace_count == 0:
                args_content = trimmed.substring(0, idx2 + 1)
                break
        idx2 = idx2 + 1

    args_content

# Extract a boolean value for a given key
fn extract_json_bool(json: String, key: String) -> bool:
    val raw = extract_json_value(json=json, key=key)
    raw == "true"

# Extract an integer value for a given key
fn extract_json_int(json: String, key: String) -> i64:
    val raw = extract_json_value(json=json, key=key)
    if raw == "null" or raw == "":
        return 0
    int(raw)

# --- Square bracket helpers ---

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

# --- Robust JSON parsing helpers ---

# Manual substring search. `text.index_of(needle)` returns -1 even when the
# needle is present (`contains` returns true) once this module is compiled
# inside the full MCP server module graph — the method-on-var-receiver folds.
# A literal scan with slice comparison stays correct (same pattern app_find
# relies on in mcp_sdk/server/app.spl), so all callers go through this.
fn find_sub(haystack: text, needle: text) -> i64:
    if not haystack.contains(needle):
        return -1
    # O(n) byte scan: the literal slice compare `haystack[i:i+nlen]` was O(i)
    # per position (UTF-8 slice), i.e. O(n^2) — slow for keys late in a large
    # body. Byte access is O(1). Returns a CHAR index (callers substring by
    # char): ci counts char-start bytes; ASCII keys' first byte never collides
    # with UTF-8 multibyte bytes (all >= 0x80).
    val hb = rt_string_bytes(haystack)
    val nb = rt_string_bytes(needle)
    val nlen = nb.len()
    val hlen = hb.len()
    if nlen == 0:
        return 0
    val first = nb[0].to_i64()
    var i = 0
    var ci = -1
    while i <= hlen - nlen:
        val v = hb[i].to_i64()
        if v < 128 or v >= 192:
            ci = ci + 1
        if v == first:
            var j = 1
            var matched = true
            while j < nlen:
                if hb[i + j].to_i64() != nb[j].to_i64():
                    matched = false
                    break
                j = j + 1
            if matched:
                return ci
        i = i + 1
    -1

fn char_at(s: text, index: i64) -> text:
    s.substring(index, index + 1)

fn skip_ws(s: text, start: i64) -> i64:
    var i = start
    while i < s.len():
        val ch = char_at(s, i)
        if ch != " " and ch != "\t" and ch != "\r" and ch != "\n":
            return i
        i = i + 1
    return i

fn read_string_end(s: text, start_quote: i64) -> i64:
    # O(n) byte scan. Indexed char_at()/text-array cs[i]/`for ch in s` are all
    # O(n) per step in the interpreter, making this O(n^2) and dominating MCP
    # handshake/tools-list latency. Byte indexing is O(1). Returns a CHAR index
    # (callers substring by char): UTF-8 multibyte bytes are all >= 0x80 and
    # never collide with the ASCII structural bytes, so `ci` counts char-start
    # bytes to recover the char index. See test/05_perf/mcp_json_perf_spec.spl.
    val b = rt_string_bytes(s)
    var i = 0
    var ci = -1
    var escaped = false
    while i < b.len():
        val v = b[i].to_i64()
        if v < 128 or v >= 192:
            ci = ci + 1
        if ci > start_quote:
            if escaped:
                escaped = false
            elif v == 92:
                escaped = true
            elif v == 34:
                return ci
        i = i + 1
    return -1

fn read_nested_end(s: text, start_index: i64) -> i64:
    # O(n) byte scan. Indexed char_at()/text-array cs[i]/`for ch in s` are all
    # O(n) per step in the interpreter, so this was O(n^2):
    # extract_field_raw('result') over a ~2KB tools/list response took ~6.9ms/
    # call and grew quadratically with the 151-tool response size, dominating
    # handshake latency (codex timeout). Byte indexing is O(1). Returns a CHAR
    # index (callers substring by char): UTF-8 multibyte bytes are all >= 0x80
    # and never collide with the ASCII structural bytes ({ } [ ] " \), so `ci`
    # counts char-start bytes to recover the char index.
    # See test/05_perf/mcp_json_perf_spec.spl.
    val b = rt_string_bytes(s)
    var i = 0
    var ci = -1
    var depth = 0
    var in_string = false
    var escaped = false
    while i < b.len():
        val v = b[i].to_i64()
        if v < 128 or v >= 192:
            ci = ci + 1
        if ci >= start_index:
            if in_string:
                if escaped:
                    escaped = false
                elif v == 92:
                    escaped = true
                elif v == 34:
                    in_string = false
            else:
                if v == 34:
                    in_string = true
                elif v == 123 or v == 91:
                    depth = depth + 1
                elif v == 125 or v == 93:
                    depth = depth - 1
                    if depth == 0:
                        return ci
        i = i + 1
    return -1

fn find_text(haystack: text, needle: text) -> i64:
    # `index_of` folds to -1 in the full MCP module graph (see find_sub); use the
    # literal slice scan so callers get correct offsets.
    find_sub(haystack, needle)

fn unescape_json_string(s: text) -> text:
    var out = s
    out = out.replace("\\\\", "__MCP_SDK_JSON_BS__")
    out = out.replace("\\\"", "\"")
    out = out.replace("\\n", "\n")
    out = out.replace("\\r", "\r")
    out = out.replace("\\t", "\t")
    out = out.replace("__MCP_SDK_JSON_BS__", "\\")
    out

# Extract raw JSON value for a given key (handles whitespace around colon, nested objects, escape sequences)
fn extract_field_raw(json: text, key: text) -> text:
    val search = Q() + key + Q()
    val idx = find_sub(json, search)
    if idx < 0:
        return "null"
    if idx < 0:
        return "null"
    var start = idx + search.len()
    start = skip_ws(json, start)
    if start >= json.len() or char_at(json, start) != ":":
        return "null"
    start = skip_ws(json, start + 1)
    if start >= json.len():
        return "null"
    var rest = json.substring(start)
    rest = rest.trim()
    if rest == "":
        return "null"
    if rest.starts_with(Q()):
        val end_idx = read_string_end(rest, 0)
        if end_idx < 0:
            return "null"
        return rest[0:end_idx + 1]
    if rest.starts_with(LB()) or rest.starts_with(SB_L()):
        val end_idx = read_nested_end(rest, 0)
        if end_idx < 0:
            return "null"
        return rest[0:end_idx + 1]
    var parts: [text] = []
    for ch in rest:
        if ch == "," or ch == RB() or ch == SB_R() or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        parts.push(ch)
    val raw = parts.join("")
    if raw == "":
        return "null"
    raw

# Extract and unquote a string field value
fn extract_field(json: text, key: text) -> text:
    val raw = extract_field_raw(json=json, key=key)
    if raw == "null":
        return ""
    if raw.len() >= 2 and raw.starts_with(Q()) and raw.ends_with(Q()):
        return unescape_json_string(raw[1:raw.len() - 1])
    return raw

# Extract JSON-RPC id (string or number, returned raw)
fn extract_id(json: text) -> text:
    extract_field_raw(json=json, key="id")

# Extract a field from the nested "params" object
fn extract_nested(json: text, key: text) -> text:
    val params = extract_field_raw(json=json, key="params")
    if params == "null":
        return ""
    extract_field(json=params, key=key)

# Extract a raw field from the nested "params" object
fn extract_nested_raw(json: text, key: text) -> text:
    val params = extract_field_raw(json=json, key="params")
    if params == "null":
        return "null"
    extract_field_raw(json=params, key=key)

# --- Exports ---
export unwrap_idx
