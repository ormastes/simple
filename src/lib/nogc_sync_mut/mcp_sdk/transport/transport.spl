# MCP SDK - Pluggable Transport Trait
#
# Defines the Transport trait for pluggable MCP transports and provides:
#   - StdioTransport: delegates to the existing stdio framing functions
#                     (no framing logic duplication, no new externs)
#   - BufferTransport: in-memory scripted inbound + captured outbound queue
#                      for tests and golden transcripts (A4 spec harness)
#
# Design rule D3: reads block forever — NO timeout parameters anywhere.
#
# NOTE on StdioTransport: read_message() delegates to read_stdin_message()
# which uses stdin_read_char() internally.  That extern only resolves in
# compiled mode when declared in std.* modules.  Do NOT call
# StdioTransport.read_message() in interpreter-mode specs — the process will
# hang.  Use BufferTransport for all interpreter-mode testing.

use std.mcp_sdk.transport.stdio.{
    read_stdin_message,
    write_stdout_message,
    set_json_lines_mode
}

# ============================================================================
# Transport trait
# ============================================================================

trait Transport:
    """Pluggable message transport for MCP servers.

    Implementations handle framing, encoding, and I/O.
    read_message() blocks until a message arrives (design rule D3 — no timeouts).
    Returns nil when the connection is closed / EOF reached.
    """

    fn read_message() -> text?
        # Block until a message is available.  Returns nil on EOF / closed.

    fn write_message(msg: text)
        # Send one message.  Must not return until the message is written.

    fn close()
        # Release any resources held by this transport.
        # After close(), read_message() must return nil and write_message() is a no-op.

# ============================================================================
# StdioTransport
# ============================================================================

class StdioTransport with Transport:
    """Transport adapter over the existing stdio framing module.

    Delegates entirely to read_stdin_message / write_stdout_message.
    No framing logic is duplicated here.

    Caveat: read_message() hangs in interpreter mode when this class is
    imported from a std.* module (stdin_read_char extern not resolved by
    the interpreter for std modules).  Only use in compiled mode or through
    BufferTransport in specs.
    """
    closed: bool

    static fn new() -> StdioTransport:
        StdioTransport(closed: false)

    static fn json_lines() -> StdioTransport:
        """Create a transport pre-configured for JSON Lines framing."""
        set_json_lines_mode(true)
        StdioTransport(closed: false)

    fn read_message() -> text?:
        if self.closed:
            return nil
        var msg = read_stdin_message()
        if msg == "":
            return nil
        Some(msg)

    fn write_message(msg: text):
        if not self.closed:
            write_stdout_message(msg)

    me close():
        self.closed = true

# ============================================================================
# BufferTransport
# ============================================================================

class BufferTransport with Transport:
    """In-memory transport for tests and golden transcripts.

    Inbound messages are scripted at construction time (or pushed via
    push_inbound()).  Outbound messages captured in the sent queue are
    available via pop_sent() / all_sent().

    Safe in interpreter mode — no externs, no stdin.
    """
    inbound: [text]
    sent: [text]
    closed: bool

    static fn new() -> BufferTransport:
        BufferTransport(inbound: [], sent: [], closed: false)

    static fn with_messages(messages: [text]) -> BufferTransport:
        """Pre-load inbound messages (oldest first — index 0 is read first)."""
        BufferTransport(inbound: messages, sent: [], closed: false)

    me push_inbound(msg: text):
        """Append one message to the inbound queue."""
        self.inbound.push(msg)

    me read_message() -> text?:
        if self.closed:
            return nil
        if self.inbound.length() == 0:
            return nil
        var first = self.inbound[0]
        var rest: [text] = []
        var i = 1
        while i < self.inbound.length():
            rest.push(self.inbound[i])
            i = i + 1
        self.inbound = rest
        Some(first)

    me write_message(msg: text):
        if not self.closed:
            self.sent.push(msg)

    me close():
        self.closed = true

    fn all_sent() -> [text]:
        """Return a copy of all sent messages (oldest first)."""
        self.sent

    me pop_sent() -> text?:
        """Remove and return the oldest sent message, or nil if empty."""
        if self.sent.length() == 0:
            return nil
        var first = self.sent[0]
        var rest: [text] = []
        var i = 1
        while i < self.sent.length():
            rest.push(self.sent[i])
            i = i + 1
        self.sent = rest
        Some(first)

    fn sent_count() -> i64:
        self.sent.length()

    fn inbound_count() -> i64:
        self.inbound.length()

# ============================================================================
# Helper: send a message through any Transport
# ============================================================================

fn transport_send(t: Transport, msg: text):
    """Send a message via a Transport trait object (tests dispatch)."""
    t.write_message(msg)

# ============================================================================
# Exports
# ============================================================================
export Transport
export StdioTransport
export BufferTransport
export transport_send
