#![allow(unnamed_duplicate_typed_args)]
# Tmux API Module
#
# Read/write interface for tmux terminal multiplexer.
# Uses shell commands to interact with tmux sessions, windows, and panes.

use std.io_runtime.{shell, shell_output_trimmed, shell_bool}
use std.text.{to_int_or}

# =========================================================================
# Data Types
# =========================================================================

struct TmuxSession:
    name: text
    windows: i64
    attached: bool
    created: text

struct TmuxWindow:
    session: text
    index: i64
    name: text
    active: bool
    panes: i64

struct TmuxPane:
    session: text
    window_index: i64
    pane_index: i64
    active: bool
    width: i64
    height: i64
    current_command: text
    pid: i64

struct TmuxCaptureResult:
    content: text
    pane_id: text
    rows: i64

# =========================================================================
# Availability Check
# =========================================================================

fn tmux_available() -> bool:
    shell_bool("command -v tmux >/dev/null 2>&1")

fn tmux_server_running() -> bool:
    shell_bool("tmux list-sessions >/dev/null 2>&1")

# =========================================================================
# Session Operations
# =========================================================================

fn tmux_list_sessions() -> [TmuxSession]:
    var sessions: [TmuxSession] = []
    if not tmux_server_running():
        return sessions

    val output = shell_output_trimmed(
        "tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_created}'",
        ""
    )
    if output == "":
        return sessions

    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 4:
            sessions.push(TmuxSession(
                name: parts[0],
                windows: to_int_or(parts[1], 0),
                attached: parts[2] == "1",
                created: parts[3]
            ))
    return sessions

fn tmux_has_session(name: text) -> bool:
    shell_bool("tmux has-session -t '{name}' 2>/dev/null")

fn tmux_new_session(name: text) -> Result<text, text>:
    if tmux_has_session(name):
        return Err("Session '{name}' already exists")
    val result = shell("tmux new-session -d -s '{name}'")
    if result.exit_code == 0:
        Ok(name)
    else:
        Err("Failed to create session: {result.stderr}")

fn tmux_kill_session(name: text) -> Result<text, text>:
    val result = shell("tmux kill-session -t '{name}'")
    if result.exit_code == 0:
        Ok("Session '{name}' killed")
    else:
        Err("Failed to kill session: {result.stderr}")

# =========================================================================
# Window Operations
# =========================================================================

fn tmux_list_windows(session: text) -> [TmuxWindow]:
    var windows: [TmuxWindow] = []
    val output = shell_output_trimmed(
        "tmux list-windows -t '{session}' -F '#{window_index}|#{window_name}|#{window_active}|#{window_panes}' 2>/dev/null",
        ""
    )
    if output == "":
        return windows

    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 4:
            windows.push(TmuxWindow(
                session: session,
                index: to_int_or(parts[0], 0),
                name: parts[1],
                active: parts[2] == "1",
                panes: to_int_or(parts[3], 1)
            ))
    return windows

fn tmux_new_window(session: text, name: text) -> Result<i64, text>:
    val result = shell("tmux new-window -t '{session}' -n '{name}'")
    if result.exit_code == 0:
        val idx = shell_output_trimmed(
            "tmux display-message -t '{session}' -p '#{window_index}'", "0"
        )
        Ok(to_int_or(idx, 0))
    else:
        Err("Failed to create window: {result.stderr}")

# =========================================================================
# Pane Operations
# =========================================================================

fn tmux_list_panes(session: text, window_index: i64) -> [TmuxPane]:
    var panes: [TmuxPane] = []
    val target = "{session}:{window_index}"
    val output = shell_output_trimmed(
        "tmux list-panes -t '{target}' -F '#{pane_index}|#{pane_active}|#{pane_width}|#{pane_height}|#{pane_current_command}|#{pane_pid}' 2>/dev/null",
        ""
    )
    if output == "":
        return panes

    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 6:
            panes.push(TmuxPane(
                session: session,
                window_index: window_index,
                pane_index: to_int_or(parts[0], 0),
                active: parts[1] == "1",
                width: to_int_or(parts[2], 80),
                height: to_int_or(parts[3], 24),
                current_command: parts[4],
                pid: to_int_or(parts[5], 0)
            ))
    return panes

fn tmux_split_pane(session: text, window_index: i64, horizontal: bool) -> Result<i64, text>:
    val target = "{session}:{window_index}"
    val flag = if horizontal: "-h" else: "-v"
    val result = shell("tmux split-window {flag} -t '{target}'")
    if result.exit_code == 0:
        val idx = shell_output_trimmed(
            "tmux display-message -t '{target}' -p '#{pane_index}'", "0"
        )
        Ok(to_int_or(idx, 0))
    else:
        Err("Failed to split pane: {result.stderr}")

# =========================================================================
# Capture & Send (Core Read/Write API)
# =========================================================================

fn tmux_capture_pane(session: text, window_index: i64, pane_index: i64) -> TmuxCaptureResult:
    val target = "{session}:{window_index}.{pane_index}"
    val content = shell_output_trimmed(
        "tmux capture-pane -t '{target}' -p -e 2>/dev/null",
        ""
    )
    val rows_str = shell_output_trimmed(
        "tmux display-message -t '{target}' -p '#{pane_height}' 2>/dev/null",
        "24"
    )
    TmuxCaptureResult(
        content: content,
        pane_id: target,
        rows: to_int_or(rows_str, 24)
    )

fn tmux_capture_pane_with_history(session: text, window_index: i64, pane_index: i64, history_lines: i64) -> TmuxCaptureResult:
    val target = "{session}:{window_index}.{pane_index}"
    val start = 0 - history_lines
    val content = shell_output_trimmed(
        "tmux capture-pane -t '{target}' -p -e -S {start} 2>/dev/null",
        ""
    )
    TmuxCaptureResult(
        content: content,
        pane_id: target,
        rows: history_lines
    )

fn tmux_send_keys(session: text, window_index: i64, pane_index: i64, keys: text) -> Result<text, text>:
    val target = "{session}:{window_index}.{pane_index}"
    val escaped = keys.replace("'", "'\\''")
    val result = shell("tmux send-keys -t '{target}' '{escaped}'")
    if result.exit_code == 0:
        Ok("Keys sent to {target}")
    else:
        Err("Failed to send keys: {result.stderr}")

fn tmux_send_text(session: text, window_index: i64, pane_index: i64, text_input: text) -> Result<text, text>:
    val target = "{session}:{window_index}.{pane_index}"
    val escaped = text_input.replace("'", "'\\''")
    val result = shell("tmux send-keys -t '{target}' -l '{escaped}'")
    if result.exit_code == 0:
        Ok("Text sent to {target}")
    else:
        Err("Failed to send text: {result.stderr}")

fn tmux_send_enter(session: text, window_index: i64, pane_index: i64) -> Result<text, text>:
    tmux_send_keys(session, window_index, pane_index, "Enter")

fn tmux_send_command(session: text, window_index: i64, pane_index: i64, command: text) -> Result<text, text>:
    val r1 = tmux_send_text(session, window_index, pane_index, command)
    match r1:
        Err(e) => return Err(e)
        Ok(_) => pass_dn
    tmux_send_enter(session, window_index, pane_index)

# =========================================================================
# Resize
# =========================================================================

fn tmux_resize_pane(session: text, window_index: i64, pane_index: i64, width: i64, height: i64) -> Result<text, text>:
    val target = "{session}:{window_index}.{pane_index}"
    val result = shell("tmux resize-pane -t '{target}' -x {width} -y {height}")
    if result.exit_code == 0:
        Ok("Pane resized to {width}x{height}")
    else:
        Err("Failed to resize: {result.stderr}")

# =========================================================================
# Convenience
# =========================================================================

fn tmux_active_pane_target() -> text:
    shell_output_trimmed(
        "tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null",
        ""
    )

fn tmux_run_in_new_pane(session: text, window_index: i64, command: text) -> Result<i64, text>:
    val target = "{session}:{window_index}"
    val escaped = command.replace("'", "'\\''")
    val result = shell("tmux split-window -t '{target}' '{escaped}'")
    if result.exit_code == 0:
        val idx = shell_output_trimmed(
            "tmux display-message -t '{target}' -p '#{pane_index}'", "0"
        )
        Ok(to_int_or(idx, 0))
    else:
        Err("Failed to run command in new pane: {result.stderr}")
