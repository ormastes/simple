# TMux Integration Module
#
# Programmatic control of tmux sessions, windows, and panes.
# Wraps tmux CLI via shell commands — no native bindings needed.
#
# Usage:
#   use std.tmux.{tmux_new_session, tmux_send_command, TmuxSession}
#
# Re-exported from mod.spl
export TmuxSession, TmuxWindow, TmuxPane, TmuxCaptureResult
export tmux_available, tmux_server_running
export tmux_list_sessions, tmux_has_session, tmux_new_session, tmux_kill_session
export tmux_list_windows, tmux_new_window
export tmux_list_panes, tmux_split_pane
export tmux_capture_pane, tmux_capture_pane_with_history
export tmux_send_keys, tmux_send_text, tmux_send_enter, tmux_send_command
export tmux_resize_pane
export tmux_active_pane_target, tmux_run_in_new_pane
