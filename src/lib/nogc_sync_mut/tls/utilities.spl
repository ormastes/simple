# TLS Utilities Module
#
# Provides utility functions for byte operations, random generation,
# cryptographic hashing (SHA-256, SHA-384), and string operations.
#
# Hex-safe wire encoding: all wire data is represented as hex-encoded text
# (e.g., "160301" for 3 bytes). This avoids NUL-byte truncation in text (C char*).

# Note: rt_wire_to_hex / rt_hex_to_wire externs exist in the C runtime for
# I/O boundary conversion. They are NOT declared here because internal helpers
# must stay NUL-safe (operating on byte lists or hex text, never raw wire text
# containing 0x00). Declare them at the socket/file I/O layer instead.

# =============================================================================
# HEX ENCODING HELPERS
# =============================================================================

# Convert a byte value (0-255) to a 2-character lowercase hex string
# Parameters:
#   v: Byte value (0-255)
# Returns: 2-character hex string, e.g. 42 -> "2a"

# Split from src/lib/nogc_sync_mut/tls/utilities.spl to keep module cohesion under the 800-line source limit.
export use lib.nogc_sync_mut.tls.utilities_part1.{i64_to_hex_byte, hex_to_i64, hex_nibble, concat_hex, hex_byte_at, hex_slice, hex_len, u16_be_hex, u24_be_hex, bytes_to_hex, hex_to_bytes, generate_random_hex, sha256_hex, sha384_hex, constant_time_compare_hex, generate_random, constant_time_compare, format_hex, byte_to_hex, pad_to_length, xor_with_byte, concat_bytes, byte_at, slice, to_bytes, sha256}
export use lib.nogc_sync_mut.tls.utilities_part2.{sha384, xor, or, char_at, starts_with, contains, len, append}
