"""
# Service Base — UDS Extern Declarations

Declares the five server-side Unix-domain socket externs (SJ-UDS-001, D-4).
Only uds_server.spl imports this file. All other capsules use uds_server.spl's
public API instead.
"""

# UDS server-side externs (SJ-UDS-001 / D-4)
extern fn rt_unix_socket_listen(path: text, backlog: i32) -> i64
extern fn rt_unix_socket_accept(fd: i64) -> i64
extern fn rt_unix_socket_send(fd: i64, data: [u8]) -> i64
extern fn rt_unix_socket_recv(fd: i64, max_len: i64) -> [u8]
extern fn rt_unix_socket_close(fd: i64) -> i32
# UDS client-side extern (also used by qmp_client; declared here so service
# tests can self-contain a roundtrip without depending on std.qemu).
extern fn rt_unix_socket_connect(path: text) -> i64

# Re-used process/signal externs
extern fn rt_getpid() -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_sleep_ms(ms: i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
