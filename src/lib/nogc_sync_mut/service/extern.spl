"""
# Service Externs — UDS (Unix Domain Socket) FFI declarations
#
# Declares the runtime externs for UDS server/client operations.
# Client-side rt_unix_socket_connect already exists in qmp_client.
# Server-side externs are new.
"""

use std.io_runtime

# --- UDS externs ---
# Client-side (already in runtime via qmp_client)
extern fn rt_unix_socket_connect(path: text) -> i64

# Server-side (new — require runtime implementation)
extern fn rt_unix_socket_listen(path: text, backlog: i64) -> i64
extern fn rt_unix_socket_accept(fd: i64) -> i64
extern fn rt_unix_socket_send(fd: i64, data: text) -> i64
extern fn rt_unix_socket_recv(fd: i64, max_bytes: i64) -> text
extern fn rt_unix_socket_close(fd: i64) -> bool
