"""
# Service Base — Shared Traits

Traits shared across service capsules. Use `impl Trait for X { ... }` blocks,
never header-form `class X: Trait` (per feedback_class_trait_header_form_also_fails.md).
"""

use std.io_runtime

# Handler trait: I-B's simple_vcs_daemon implements this.
trait RequestHandler:
    fn handle(self, req: text) -> text

# Drainable: anything with a shutdown-drain contract.
trait Drainable:
    fn drain(self) -> bool
