"""
# Service Base — UDS Server Capsule

Provides a Unix-domain socket server: listen, accept, JSON-framed
request/response (newline-delimited), multi-client support (AC-1, D-4).

Public API:
  uds_server_new(path: text) -> UdsServer
  uds_server_listen(server: UdsServer) -> bool
  uds_server_accept(server: UdsServer) -> i64
  uds_server_recv_line(fd: i64) -> text
  uds_server_send(fd: i64, data: text) -> bool
  uds_server_close_client(fd: i64) -> bool
  uds_server_close(server: UdsServer) -> bool
"""

use std.io_runtime

extern fn rt_unix_socket_listen(path: text, backlog: i32) -> i64
extern fn rt_unix_socket_accept(fd: i64) -> i64
extern fn rt_unix_socket_send(fd: i64, data: [u8]) -> i64
extern fn rt_unix_socket_recv(fd: i64, max_len: i64) -> [u8]
extern fn rt_unix_socket_close(fd: i64) -> i32

struct UdsServer:
    path: text
    server_fd: i64
    backlog: i64

fn uds_server_new(path: text) -> UdsServer:
    UdsServer(path: path, server_fd: -1i64, backlog: 128i64)

fn uds_server_listen(server: UdsServer) -> bool:
    val fd = rt_unix_socket_listen(server.path, 128i32)
    if fd < 0i64:
        return false
    server.server_fd = fd
    true

fn uds_server_accept(server: UdsServer) -> i64:
    rt_unix_socket_accept(server.server_fd)

fn uds_server_send(fd: i64, data: text) -> bool:
    val bytes = data.to_bytes()
    val n = rt_unix_socket_send(fd, bytes)
    n >= 0i64

fn uds_server_recv_raw(fd: i64, max_len: i64) -> [u8]:
    rt_unix_socket_recv(fd, max_len)

fn uds_server_close_client(fd: i64) -> bool:
    rt_unix_socket_close(fd) == 0i32

fn uds_server_close(server: UdsServer) -> bool:
    rt_unix_socket_close(server.server_fd) == 0i32

fn uds_server_is_listening(server: UdsServer) -> bool:
    server.server_fd >= 0i64

fn uds_server_backlog(server: UdsServer) -> i64:
    server.backlog

fn validate_request_shape(request: text) -> bool:
    request.contains("\"id\"") and request.contains("\"method\"")
