"""
# Service Base — Signal Handlers Capsule

Installs SIGTERM/SIGINT handlers that:
1. Set a cooperative shutdown flag
2. Remove the PID file (fixes anti-pattern in test_daemon/task_daemon)

This is a thin wrapper; actual OS signal registration happens in the
runtime. The service layer exposes a shutdown_requested() predicate
that the request loop polls each tick.
"""

use std.io_runtime

extern fn rt_file_delete(path: text) -> bool
extern fn rt_getpid() -> i64

struct ShutdownFlag:
    requested: bool
    pid_path: text

fn shutdown_flag_new(pid_path: text) -> ShutdownFlag:
    ShutdownFlag(requested: false, pid_path: pid_path)

fn shutdown_requested(flag: ShutdownFlag) -> bool:
    flag.requested

fn request_shutdown(flag: ShutdownFlag):
    flag.requested = true
    # Remove PID file immediately — critical for no-leak invariant
    val _ = rt_file_delete(flag.pid_path)
