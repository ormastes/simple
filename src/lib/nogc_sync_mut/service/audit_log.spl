"""
# Service Base — Audit Log Capsule

Append-only NDJSON audit log of every request, lease grant/release/reclaim,
max-hold kill (AC-6).

Public API:
  audit_log_new(path: text) -> AuditLog
  audit_write(log: AuditLog, event: text, details: text) -> bool
"""

use std.io_runtime

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_getpid() -> i64

struct AuditLog:
    path: text

fn audit_log_new(path: text) -> AuditLog:
    AuditLog(path: path)

fn audit_write(log: AuditLog, event: text, details: text) -> bool:
    val ts = rt_time_now_unix_micros()
    val pid = rt_getpid()
    val line = "{\"ts\":{ts},\"pid\":{pid},\"event\":\"{event}\",\"details\":\"{details}\"}\n"
    val existing = if rt_file_exists(log.path):
        rt_file_read_text(log.path)
    else:
        ""
    rt_file_write_text(log.path, existing + line)
