"""
# Service Base — Request Queue Capsule

FIFO queue with priority lanes (AC-1).
Priority order: Control > ReadShared > Mutating.
Supports cooperative shutdown drain.

Public API:
  request_queue_new() -> RequestQueue
  enqueue(queue: RequestQueue, entry: QueueEntry) -> bool
  dequeue(queue: RequestQueue) -> Option<QueueEntry>
  queue_len(queue: RequestQueue) -> i64
  begin_shutdown(queue: RequestQueue)
  is_shutdown(queue: RequestQueue) -> bool
  drain_done(queue: RequestQueue) -> bool

Lane constants:
  LANE_CONTROL   = 0
  LANE_READ      = 1
  LANE_MUTATING  = 2
"""

use std.io_runtime

val LANE_CONTROL: i64 = 0i64
val LANE_READ: i64 = 1i64
val LANE_MUTATING: i64 = 2i64

struct QueueEntry:
    id: text
    lane: i64
    payload: text

struct RequestQueue:
    control_entries: [QueueEntry]
    read_entries: [QueueEntry]
    mutating_entries: [QueueEntry]
    shutdown: bool

fn request_queue_new() -> RequestQueue:
    RequestQueue(
        control_entries: [],
        read_entries: [],
        mutating_entries: [],
        shutdown: false
    )

fn enqueue(queue: RequestQueue, entry: QueueEntry) -> bool:
    if queue.shutdown:
        return false
    if entry.lane == LANE_CONTROL:
        queue.control_entries.push(entry)
    else if entry.lane == LANE_READ:
        queue.read_entries.push(entry)
    else:
        queue.mutating_entries.push(entry)
    true

fn dequeue(queue: RequestQueue) -> Option<QueueEntry>:
    if queue.control_entries.len() > 0i64:
        val entry = queue.control_entries[0i64]
        val _ = queue.control_entries.remove(0i64)
        return Option.some(entry)
    if queue.read_entries.len() > 0i64:
        val entry = queue.read_entries[0i64]
        val _ = queue.read_entries.remove(0i64)
        return Option.some(entry)
    if queue.mutating_entries.len() > 0i64:
        val entry = queue.mutating_entries[0i64]
        val _ = queue.mutating_entries.remove(0i64)
        return Option.some(entry)
    Option.none()

fn queue_len(queue: RequestQueue) -> i64:
    queue.control_entries.len() + queue.read_entries.len() + queue.mutating_entries.len()

fn begin_shutdown(queue: RequestQueue):
    queue.shutdown = true

fn is_shutdown(queue: RequestQueue) -> bool:
    queue.shutdown

fn drain_done(queue: RequestQueue) -> bool:
    queue_len(queue) == 0i64

fn queue_entry_new(id: text, lane: i64, payload: text) -> QueueEntry:
    QueueEntry(id: id, lane: lane, payload: payload)
