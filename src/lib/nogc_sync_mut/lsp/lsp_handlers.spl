#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# LSP Server - Request handlers
# Uses lightweight lsp_query.spl for fast code analysis (no full compiler load).
# Only falls back to full query.spl for heavy operations (check/diagnostics).

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# REQ-LSPVIS-008: Track whether client supports structured visibility metadata.
# Set during initialize from client capabilities.experimental.simpleVisibility.
var CLIENT_SUPPORTS_VISIBILITY = false

fn client_supports_visibility() -> bool:
    CLIENT_SUPPORTS_VISIBILITY

fn _find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    if rt_file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if rt_file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    val os_env = rt_env_get("OS") ?? ""
    if os_env.contains("Windows"):
        if rt_file_exists("src/compiler_rust/target/release/simple.exe"):
            return "src/compiler_rust/target/release/simple.exe"
        if rt_file_exists("src/compiler_rust/target/bootstrap/simple.exe"):
            return "src/compiler_rust/target/bootstrap/simple.exe"
        if rt_file_exists("bin/simple.exe"):
            return "bin/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-msvc/simple.exe"):
            return "bin/release/x86_64-pc-windows-msvc/simple.exe"
        if rt_file_exists("bin/release/x86_64-pc-windows-gnu/simple.exe"):
            return "bin/release/x86_64-pc-windows-gnu/simple.exe"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if rt_file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if rt_file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if rt_file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    "bin/simple"

fn _fast_query_cmd(subcmd: text) -> text:
    # Lightweight query — only imports query_engine (no compiler). Fast startup.
    val bin = _find_simple_binary()
    "timeout 30 " + bin + " src/app/lsp/lsp_query.spl " + subcmd

fn _heavy_query_cmd(subcmd: text) -> text:
    # Full query — imports compiler for check/diagnostics. Slow startup.
    val bin = _find_simple_binary()
    "timeout 60 " + bin + " src/app/cli/query.spl " + subcmd

fn _visibility_query_cmd(subcmd: text) -> text:
    val bin = _find_simple_binary()
    "timeout 60 " + bin + " src/app/cli/query_visibility.spl " + subcmd

fn _shell_cmd(command: text) -> (text, i64):
    var stdout = ""
    var stderr = ""
    var code: i64 = 0
    (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", "export NO_COLOR=1 TERM=dumb; " + command])
    (stdout, code)

fn _extract_uri(body: text) -> text:
    val td_search = Q() + "textDocument" + Q() + ":"
    val td_idx_result = body.index_of(td_search)
    var td_idx = -1
    match td_idx_result:
        Some(i): td_idx = i
        nil: return ""
    if td_idx < 0:
        return ""
    val td_start = td_idx + td_search.len()
    val td_rest = body.substring(td_start)
    extract_field(td_rest, "uri")

fn _uri_to_path(uri: text) -> text:
    if uri.starts_with("file://"):
        return uri.substring(7)
    uri

fn _extract_line(body: text) -> text:
    val pos_search = Q() + "position" + Q() + ":"
    val pos_idx_result = body.index_of(pos_search)
    var pos_idx = -1
    match pos_idx_result:
        Some(i): pos_idx = i
        nil: return "0"
    if pos_idx < 0:
        return "0"
    val pos_start = pos_idx + pos_search.len()
    val pos_rest = body.substring(pos_start)
    val line_str = extract_field(pos_rest, "line")
    if line_str == "":
        return "0"
    line_str

fn _extract_character(body: text) -> text:
    val pos_search = Q() + "position" + Q() + ":"
    val pos_idx_result = body.index_of(pos_search)
    var pos_idx = -1
    match pos_idx_result:
        Some(i): pos_idx = i
        nil: return "0"
    if pos_idx < 0:
        return "0"
    val pos_start = pos_idx + pos_search.len()
    val pos_rest = body.substring(pos_start)
    val char_str = extract_field(pos_rest, "character")
    if char_str == "":
        return "0"
    char_str

# --- Initialize ---

fn lsp_handle_initialize(id: text) -> text:
    lsp_handle_initialize_with_body(id, "")

fn lsp_handle_initialize_with_body(id: text, body: text) -> text:
    # REQ-LSPVIS-008: Read client experimental.simpleVisibility capability
    if body != "":
        val experimental_raw = extract_nested(body, "experimental")
        if experimental_raw != "" and experimental_raw.contains("simpleVisibility"):
            CLIENT_SUPPORTS_VISIBILITY = true
    val completion_provider = jo1(jp("triggerCharacters", SB_L() + js(".") + "," + js(":") + "," + js("&") + SB_R()))
    var caps: [text] = []
    val sync_opts = jo3(jp("openClose", "true"), jp("change", "1"), jp("save", jo1(jp("includeText", "false"))))
    val token_types = SB_L() + js("namespace") + "," + js("type") + "," + js("class") + "," + js("enum") + "," + js("struct") + "," + js("function") + "," + js("method") + "," + js("property") + "," + js("variable") + "," + js("parameter") + "," + js("enumMember") + "," + js("keyword") + "," + js("comment") + "," + js("string") + "," + js("number") + "," + js("operator") + SB_R()
    val token_mods = SB_L() + js("declaration") + "," + js("definition") + "," + js("readonly") + "," + js("static") + "," + js("deprecated") + "," + js("abstract") + "," + js("async") + "," + js("modification") + "," + js("documentation") + "," + js("visibilityPublic") + "," + js("visibilityBoundary") + "," + js("visibilityPrivate") + SB_R()
    val semantic_provider = jo3(jp("legend", jo2(jp("tokenTypes", token_types), jp("tokenModifiers", token_mods))), jp("range", "true"), jp("full", "true"))
    caps.push(jp("textDocumentSync", sync_opts))
    caps.push(jp("completionProvider", completion_provider))
    caps.push(jp("hoverProvider", "true"))
    caps.push(jp("definitionProvider", "true"))
    caps.push(jp("referencesProvider", "true"))
    caps.push(jp("documentSymbolProvider", "true"))
    caps.push(jp("semanticTokensProvider", semantic_provider))
    caps.push(jp("implementationProvider", "true"))
    caps.push(jp("workspaceSymbolProvider", "true"))
    caps.push(jp("callHierarchyProvider", "true"))
    caps.push(jp("inlayHintProvider", "true"))
    val code_action_kinds = SB_L() + js("quickfix") + "," + js("refactor") + SB_R()
    caps.push(jp("codeActionProvider", jo1(jp("codeActionKinds", code_action_kinds))))
    val diag_provider = jo2(jp("interFileDependencies", "false"), jp("workspaceDiagnostics", "false"))
    caps.push(jp("diagnosticProvider", diag_provider))
    val capabilities_obj = LB() + caps.join(",") + RB()
    val server_info = jo2(jp("name", js("simple-lsp")), jp("version", js("0.1.0")))
    val experimental = jo1(jp("simpleVisibilityProvider", "true"))
    val result = jo3(jp("capabilities", capabilities_obj), jp("serverInfo", server_info), jp("experimental", experimental))
    make_json_result(id, result)

# --- Document sync ---

fn lsp_handle_did_open(body: text):
    # Diagnostics require full compiler (slow) — run async in background
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if uri != "" and file_path != "":
        _publish_diagnostics(uri, file_path)

fn lsp_handle_did_change(body: text):
    val _x = 0

fn lsp_handle_did_close(body: text):
    val uri = _extract_uri(body)
    if uri != "":
        val params = jo2(jp("uri", js(uri)), jp("diagnostics", SB_L() + SB_R()))
        lsp_write_notification("textDocument/publishDiagnostics", params)

fn lsp_handle_did_save(body: text):
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if uri != "" and file_path != "":
        _publish_diagnostics(uri, file_path)

# --- Diagnostics (heavy — uses full query.spl with compiler) ---

fn _publish_diagnostics(uri: text, file_path: text):
    val diags = _collect_diagnostics(file_path)
    val diags_str = SB_L() + diags.join(",") + SB_R()
    val params = jo2(jp("uri", js(uri)), jp("diagnostics", diags_str))
    lsp_write_notification("textDocument/publishDiagnostics", params)

fn _collect_diagnostics(file_path: text) -> [text]:
    var diags: [text] = []
    # Try structured JSON format first
    var cmd_json = _heavy_query_cmd("check " + file_path + " --format=json")
    var out_json = ""
    var exit_json: i64 = 0
    (out_json, exit_json) = _shell_cmd(cmd_json)
    if out_json.trim() != "":
        val lines = out_json.split("\n")
        for line in lines:
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val diag = _parse_diagnostic_line(trimmed, file_path)
            if diag != "":
                diags.push(diag)
        return diags
    # Fallback to plain text format
    var cmd = _heavy_query_cmd("check " + file_path)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 and out != "":
        val lines = out.split("\n")
        for line in lines:
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val diag = _parse_diagnostic_line(trimmed, file_path)
            if diag != "":
                diags.push(diag)
    diags

fn _parse_diagnostic_line(line: text, file_path: text) -> text:
    # JSON structured format: line starts with "{"
    if line.starts_with("{"):
        return _parse_json_diagnostic(line)
    # Fallback: plain text format (file:line:col: severity: message)
    _parse_text_diagnostic(line, file_path)

fn _parse_json_diagnostic(line: text) -> text:
    val msg = extract_field(line, "message")
    val sev_str = extract_field(line, "severity")
    val code = extract_field(line, "code")
    val source = extract_field(line, "source")
    val line_str = extract_field(line, "line")
    val col_str = extract_field(line, "col")
    val tags_raw = extract_field(line, "tags")
    var diag_line = 0
    var diag_col = 0
    if line_str != "":
        val ln = int(line_str)
        if ln > 0:
            diag_line = ln - 1
    if col_str != "":
        val cn = int(col_str)
        if cn > 0:
            diag_col = cn - 1
    var severity = 1
    if sev_str == "error" or sev_str == "1":
        severity = 1
    elif sev_str == "warning" or sev_str == "2":
        severity = 2
    elif sev_str == "information" or sev_str == "info" or sev_str == "3":
        severity = 3
    elif sev_str == "hint" or sev_str == "4":
        severity = 4
    val range = jo2(
        jp("start", jo2(jp("line", str(diag_line)), jp("character", str(diag_col)))),
        jp("end", jo2(jp("line", str(diag_line)), jp("character", str(diag_col + 1))))
    )
    var parts: [text] = []
    parts.push(jp("range", range))
    parts.push(jp("severity", str(severity)))
    parts.push(jp("message", js(msg)))
    if source != "":
        parts.push(jp("source", js(source)))
    elif source == "":
        parts.push(jp("source", js("simple")))
    if code != "":
        parts.push(jp("code", js(code)))
    # Parse tags (Unnecessary=1, Deprecated=2)
    var tag_items: [text] = []
    if tags_raw != "":
        if tags_raw.contains("Unnecessary") or tags_raw.contains("unnecessary"):
            tag_items.push("1")
        if tags_raw.contains("Deprecated") or tags_raw.contains("deprecated"):
            tag_items.push("2")
    if tag_items.len() > 0:
        parts.push(jp("tags", SB_L() + tag_items.join(",") + SB_R()))
    # Parse relatedInformation if present
    val related_raw = extract_field(line, "relatedFile")
    val related_msg = extract_field(line, "relatedMessage")
    if related_raw != "" and related_msg != "":
        val related_loc = jo2(
            jp("uri", js("file://" + related_raw)),
            jp("range", jo2(
                jp("start", jo2(jp("line", "0"), jp("character", "0"))),
                jp("end", jo2(jp("line", "0"), jp("character", "0")))
            ))
        )
        val related_info = jo2(jp("location", related_loc), jp("message", js(related_msg)))
        parts.push(jp("relatedInformation", SB_L() + related_info + SB_R()))
    LB() + parts.join(",") + RB()

fn _parse_text_diagnostic(line: text, file_path: text) -> text:
    var diag_line = 0
    var diag_col = 0
    var diag_msg = line
    var severity = 1
    val colon_idx = line.index_of(":")
    match colon_idx:
        Some(ci):
            val after = line.substring(ci + 1)
            val second_colon = after.index_of(":")
            match second_colon:
                Some(ci2):
                    val line_str = after.substring(0, ci2).trim()
                    val line_num = int(line_str)
                    if line_num > 0:
                        diag_line = line_num - 1
                        val after2 = after.substring(ci2 + 1)
                        val third_colon = after2.index_of(":")
                        match third_colon:
                            Some(ci3):
                                val col_str = after2.substring(0, ci3).trim()
                                val col_num = int(col_str)
                                if col_num > 0:
                                    diag_col = col_num - 1
                                diag_msg = after2.substring(ci3 + 1).trim()
                            nil:
                                diag_msg = after2.trim()
                nil:
                    val _x = 0
        nil:
            val _x = 0
    if diag_msg.starts_with("warning"):
        severity = 2
        diag_msg = diag_msg.replace("warning:", "").trim()
    elif diag_msg.starts_with("error"):
        severity = 1
        diag_msg = diag_msg.replace("error:", "").trim()
    val range = jo2(
        jp("start", jo2(jp("line", str(diag_line)), jp("character", str(diag_col)))),
        jp("end", jo2(jp("line", str(diag_line)), jp("character", str(diag_col + 1))))
    )
    jo3(jp("range", range), jp("severity", str(severity)), jp("message", js(diag_msg)))

# --- Definition (fast path) ---

fn lsp_handle_definition(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _fast_query_cmd("definition " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, "null")
    val result = _parse_location(out.trim())
    make_json_result(id, result)

fn _parse_location(output: text) -> text:
    val lines = output.split("\n")
    if lines.len() == 0:
        return "null"
    val first = lines[0].trim()
    if first == "" or first == "null" or first.starts_with("No ") or first.starts_with("Error"):
        return "null"
    var parts = first.split(":")
    if parts.len() >= 3:
        val file = parts[0]
        val line_num = int(parts[1]) - 1
        var col_num = 0
        if parts.len() >= 3:
            col_num = int(parts[2])
        if line_num < 0:
            line_num = 0
        val loc_uri = "file://" + file
        val range = jo2(
            jp("start", jo2(jp("line", str(line_num)), jp("character", str(col_num)))),
            jp("end", jo2(jp("line", str(line_num)), jp("character", str(col_num))))
        )
        return jo2(jp("uri", js(loc_uri)), jp("range", range))
    "null"

# --- References (fast path) ---

fn lsp_handle_references(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _fast_query_cmd("references " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val lines = out.split("\n")
    var locs: [text] = []
    for loc_line in lines:
        val trimmed = loc_line.trim()
        if trimmed == "" or trimmed.starts_with("No ") or trimmed.starts_with("Error"):
            continue
        val loc = _parse_location(trimmed)
        if loc != "null":
            locs.push(loc)
    make_json_result(id, SB_L() + locs.join(",") + SB_R())

# --- Hover (fast path) ---

fn lsp_handle_hover(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _visibility_query_cmd("hover " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, "null")
    make_json_result(id, out.trim())

# --- Completion (fast path) ---

fn lsp_handle_completion(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _visibility_query_cmd("completions " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    make_json_result(id, out.trim())

# --- Document Symbol (fast path) ---

fn lsp_handle_document_symbol(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        return make_json_result(id, SB_L() + SB_R())
    var cmd = _visibility_query_cmd("symbols " + file_path + " --requester " + file_path)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    make_json_result(id, out.trim())

fn _symbol_kind_number(kind_str: text) -> i64:
    if kind_str == "fn" or kind_str == "function" or kind_str == "extern_fn":
        return 12
    elif kind_str == "method" or kind_str == "static_method":
        return 6
    elif kind_str == "class":
        return 5
    elif kind_str == "struct":
        return 23
    elif kind_str == "enum":
        return 10
    elif kind_str == "trait" or kind_str == "impl":
        return 11
    elif kind_str == "var" or kind_str == "val":
        return 13
    12

# --- Implementation (fast path) ---

fn lsp_handle_implementation(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _fast_query_cmd("implementation " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val lines = out.split("\n")
    var locs: [text] = []
    for loc_line in lines:
        val trimmed = loc_line.trim()
        if trimmed == "":
            continue
        val loc = _parse_location(trimmed)
        if loc != "null":
            locs.push(loc)
    make_json_result(id, SB_L() + locs.join(",") + SB_R())

# --- Workspace Symbol (fast path) ---

fn lsp_handle_workspace_symbol(id: text, body: text) -> text:
    val query = extract_nested(body, "query")
    var cmd = _visibility_query_cmd("workspace-symbols --query " + query + " --requester src/")
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    make_json_result(id, out.trim())

fn lsp_handle_folding_range(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        return make_json_result(id, SB_L() + SB_R())
    var cmd = _fast_query_cmd("folding-range " + file_path)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val lines = out.split("\n")
    var ranges: [text] = []
    for raw_line in lines:
        val line = raw_line.trim()
        if line == "" or line.starts_with("No ") or line.starts_with("Error"):
            continue
        val parts = line.split(":")
        if parts.len() < 2:
            continue
        var start_line = int(parts[0]) - 1
        var end_line = int(parts[1]) - 1
        if start_line < 0:
            start_line = 0
        if end_line < start_line:
            continue
        var range_parts: [text] = []
        range_parts.push(jp("startLine", str(start_line)))
        range_parts.push(jp("endLine", str(end_line)))
        if parts.len() >= 3 and parts[2].trim() != "":
            range_parts.push(jp("kind", js(parts[2].trim())))
        ranges.push(LB() + range_parts.join(",") + RB())
    make_json_result(id, SB_L() + ranges.join(",") + SB_R())

fn lsp_handle_semantic_tokens_full(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        return make_json_result(id, "{\"data\":[]}")
    var cmd = _visibility_query_cmd("semantic-tokens " + file_path)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, "{\"data\":[]}")
    make_json_result(id, out.trim())

fn lsp_handle_semantic_tokens_range(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        return make_json_result(id, "{\"data\":[]}")
    val range_raw = extract_nested(body, "range")
    val start_line = extract_field(range_raw, "line")
    val end_idx = range_raw.last_index_of("\"line\"")
    var end_line = start_line
    match end_idx:
        Some(i):
            val tail = range_raw.substring(i)
            val maybe_end = extract_field(tail, "line")
            if maybe_end != "":
                end_line = maybe_end
        nil:
            val _x = 0
    var cmd = _visibility_query_cmd("semantic-tokens " + file_path + " --start-line " + start_line + " --end-line " + end_line)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, "{\"data\":[]}")
    make_json_result(id, out.trim())

# --- Call Hierarchy (fast path) ---

fn lsp_handle_prepare_call_hierarchy(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val line = _extract_line(body)
    val col = _extract_character(body)
    val file_path = _uri_to_path(uri)
    val query_line = str(int(line) + 1)
    val query_col = str(int(col) + 1)
    var cmd = _fast_query_cmd("hover " + file_path + " " + query_line + " " + query_col)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val first_line = out.split("\n")[0].trim()
    if first_line == "":
        return make_json_result(id, SB_L() + SB_R())
    val lsp_line = str(int(line))
    val range = jo2(
        jp("start", jo2(jp("line", lsp_line), jp("character", col))),
        jp("end", jo2(jp("line", lsp_line), jp("character", col)))
    )
    val item = jo4(jp("name", js(first_line)), jp("kind", "12"), jp("uri", js(uri)), jp("range", range)) + "," + jp("selectionRange", range)
    val item_obj = LB() + item + RB()
    make_json_result(id, SB_L() + item_obj + SB_R())

fn lsp_handle_incoming_calls(id: text, body: text) -> text:
    make_json_result(id, SB_L() + SB_R())

fn lsp_handle_outgoing_calls(id: text, body: text) -> text:
    make_json_result(id, SB_L() + SB_R())

# --- Inlay Hints (heavy — calls query engine) ---

fn lsp_handle_inlay_hint(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        return make_json_result(id, SB_L() + SB_R())
    var cmd = _heavy_query_cmd("inlay-hints " + file_path)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val lines = out.split("\n")
    var hints: [text] = []
    for hint_line in lines:
        val trimmed = hint_line.trim()
        if trimmed == "":
            continue
        val hint = _parse_inlay_hint(trimmed)
        if hint != "":
            hints.push(hint)
    make_json_result(id, SB_L() + hints.join(",") + SB_R())

fn _parse_inlay_hint(line: text) -> text:
    # JSON format: {"line":N,"character":N,"label":"text","kind":1|2}
    if line.starts_with("{"):
        val hint_line = extract_field(line, "line")
        val hint_char = extract_field(line, "character")
        val hint_label = extract_field(line, "label")
        val hint_kind = extract_field(line, "kind")
        if hint_label == "":
            return ""
        var ln = 0
        var ch = 0
        if hint_line != "":
            val ln_val = int(hint_line)
            if ln_val > 0:
                ln = ln_val - 1
        if hint_char != "":
            ch = int(hint_char)
        var kind_num = 1
        if hint_kind == "2" or hint_kind == "parameter":
            kind_num = 2
        val pos = jo2(jp("line", str(ln)), jp("character", str(ch)))
        return jo3(jp("position", pos), jp("label", js(hint_label)), jp("kind", str(kind_num)))
    # Text format: line:col:label:kind
    val parts = line.split(":")
    if parts.len() < 3:
        return ""
    var ln = 0
    val ln_val = int(parts[0])
    if ln_val > 0:
        ln = ln_val - 1
    val ch = int(parts[1])
    val label = parts[2]
    var kind_num = 1
    if parts.len() >= 4:
        if parts[3].trim() == "2" or parts[3].trim() == "parameter":
            kind_num = 2
    val pos = jo2(jp("line", str(ln)), jp("character", str(ch)))
    jo3(jp("position", pos), jp("label", js(label)), jp("kind", str(kind_num)))

# --- Code Action (heavy — calls query engine) ---

fn lsp_handle_code_action(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    val line = _extract_line(body)
    val query_line = str(int(line) + 1)
    if file_path == "":
        return make_json_result(id, SB_L() + SB_R())
    var cmd = _heavy_query_cmd("code-actions " + file_path + " " + query_line)
    var out = ""
    var exit_code: i64 = 0
    (out, exit_code) = _shell_cmd(cmd)
    if exit_code != 0 or out.trim() == "":
        return make_json_result(id, SB_L() + SB_R())
    val lines = out.split("\n")
    var actions: [text] = []
    for action_line in lines:
        val trimmed = action_line.trim()
        if trimmed == "":
            continue
        val action = _parse_code_action(trimmed, uri)
        if action != "":
            actions.push(action)
    make_json_result(id, SB_L() + actions.join(",") + SB_R())

fn _parse_code_action(line: text, uri: text) -> text:
    # JSON format: {"title":"...","kind":"quickfix|refactor","edit":{...}}
    if line.starts_with("{"):
        val title = extract_field(line, "title")
        val kind = extract_field(line, "kind")
        val new_text = extract_field(line, "newText")
        val edit_line = extract_field(line, "editLine")
        val edit_col = extract_field(line, "editCol")
        val edit_end_line = extract_field(line, "editEndLine")
        val edit_end_col = extract_field(line, "editEndCol")
        if title == "":
            return ""
        var action_kind = "quickfix"
        if kind != "":
            action_kind = kind
        # Build workspace edit if edit details are present
        if new_text != "" and edit_line != "":
            var start_ln = 0
            val sln = int(edit_line)
            if sln > 0:
                start_ln = sln - 1
            var start_col = 0
            if edit_col != "":
                start_col = int(edit_col)
            var end_ln = start_ln
            if edit_end_line != "":
                val eln = int(edit_end_line)
                if eln > 0:
                    end_ln = eln - 1
            var end_col = start_col
            if edit_end_col != "":
                end_col = int(edit_end_col)
            val edit_range = jo2(
                jp("start", jo2(jp("line", str(start_ln)), jp("character", str(start_col)))),
                jp("end", jo2(jp("line", str(end_ln)), jp("character", str(end_col))))
            )
            val text_edit = jo2(jp("range", edit_range), jp("newText", js(new_text)))
            val doc_changes = jo2(jp("textDocument", jo2(jp("uri", js(uri)), jp("version", "null"))), jp("edits", SB_L() + text_edit + SB_R()))
            val workspace_edit = jo1(jp("documentChanges", SB_L() + doc_changes + SB_R()))
            return jo3(jp("title", js(title)), jp("kind", js(action_kind)), jp("edit", workspace_edit))
        return jo2(jp("title", js(title)), jp("kind", js(action_kind)))
    # Text format: title\tkind
    val tab_idx = line.index_of("\t")
    var title = line
    var action_kind = "quickfix"
    match tab_idx:
        Some(ti):
            title = line.substring(0, ti)
            action_kind = line.substring(ti + 1).trim()
        nil:
            val _x = 0
    jo2(jp("title", js(title)), jp("kind", js(action_kind)))

# --- Pull Diagnostics (LSP 3.17 — textDocument/diagnostic) ---

fn lsp_handle_pull_diagnostic(id: text, body: text) -> text:
    val uri = _extract_uri(body)
    val file_path = _uri_to_path(uri)
    if file_path == "":
        val empty_result = jo2(jp("kind", js("full")), jp("items", SB_L() + SB_R()))
        return make_json_result(id, empty_result)
    val diags = _collect_diagnostics(file_path)
    val diags_str = SB_L() + diags.join(",") + SB_R()
    val result = jo2(jp("kind", js("full")), jp("items", diags_str))
    make_json_result(id, result)
