# LSP Query Runner - Lightweight query script for LSP internal use
# Only imports query_engine + query_sanitize — NO compiler imports.
# Startup: <1s vs 30s+ for full query.spl
#
# Usage: simple lsp_query.spl <subcmd> <file> [line] [col]
# Subcommands: definition, references, hover, completions, symbols,
#              type-at, signature-help, document-highlight, type-definition,
#              implementation, folding-range

extern fn rt_cli_get_args() -> [text]

use app.cli.query_engine.{engine_find_definition, engine_find_references, engine_hover, engine_completions, engine_type_at, engine_signature_help, engine_document_symbols}
use app.cli.query_sanitize.{sanitize_path, sanitize_symbol}
use app.cli.query_lsp_extras.{query_document_highlight, query_type_definition, query_implementation, query_folding_range}

fn extract_symbol_at(file: text, line_num: i64, col: i64) -> text:
    extern fn rt_file_read_text(path: text) -> text
    val content = rt_file_read_text(file) ?? ""
    if content == "":
        return ""
    val lines = content.split("\n")
    if line_num < 1 or line_num > lines.len():
        return ""
    val target_line = lines[line_num - 1]
    if target_line.trim() == "":
        return ""
    if col > 0 and col <= target_line.len():
        var start = col - 1
        var end_pos = col - 1
        for _i in range(0, col):
            if start <= 0:
                break
            val ch = target_line.substring(start - 1, start)
            val is_word = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
            if not is_word:
                break
            start = start - 1
        for _i in range(0, 200):
            if end_pos >= target_line.len():
                break
            val ch = target_line.substring(end_pos, end_pos + 1)
            val is_word = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
            if not is_word:
                break
            end_pos = end_pos + 1
        if end_pos > start:
            return target_line.substring(start, end_pos)
    val trimmed = target_line.trim()
    var rest = trimmed
    if rest.starts_with("fn "):
        rest = rest.substring(3)
    elif rest.starts_with("val "):
        rest = rest.substring(4)
    elif rest.starts_with("var "):
        rest = rest.substring(4)
    elif rest.starts_with("class "):
        rest = rest.substring(6)
    elif rest.starts_with("struct "):
        rest = rest.substring(7)
    elif rest.starts_with("enum "):
        rest = rest.substring(5)
    elif rest.starts_with("me "):
        rest = rest.substring(3)
    elif rest.starts_with("static fn "):
        rest = rest.substring(10)
    var parts: [text] = []
    for ch in rest:
        val is_word = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
        if not is_word:
            break
        parts.push(ch)
    parts.join("")

fn lsp_query_main() -> i64:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var i = 0
    for arg in all_args:
        if i >= 2:
            args.push(arg)
        i = i + 1

    if args.len() == 0:
        print "Usage: lsp_query.spl <subcmd> <file> [line] [col]"
        return 1

    val subcmd = args[0]

    # File-only subcommands
    if subcmd == "symbols" and args.len() >= 2:
        val file = sanitize_path(args[1])
        if file == "":
            return 1
        return engine_document_symbols(file)
    if subcmd == "folding-range" and args.len() >= 2:
        val file = sanitize_path(args[1])
        if file == "":
            return 1
        return query_folding_range(file)

    # Subcommands needing file + line + optional col
    if args.len() < 3:
        print "Error: {subcmd} requires <file> <line> [col]"
        return 1

    val file = sanitize_path(args[1])
    if file == "":
        return 1
    val line_num = args[2].to_int()
    var col = 0
    if args.len() > 3 and not args[3].starts_with("--"):
        col = args[3].to_int()

    val symbol = extract_symbol_at(file, line_num, col)
    if symbol == "":
        print "No symbol found at {file}:{line_num}"
        return 1

    val clean_sym = sanitize_symbol(symbol)
    if clean_sym == "":
        return 1

    if subcmd == "definition":
        return engine_find_definition(file, clean_sym)
    elif subcmd == "references":
        return engine_find_references(file, clean_sym)
    elif subcmd == "hover":
        return engine_hover(file, line_num, clean_sym)
    elif subcmd == "completions":
        return engine_completions(file, 0, clean_sym)
    elif subcmd == "type-at":
        return engine_type_at(file, line_num, clean_sym)
    elif subcmd == "signature-help":
        return engine_signature_help(file, line_num, col, clean_sym)
    elif subcmd == "document-highlight":
        return query_document_highlight(file, line_num, col)
    elif subcmd == "type-definition":
        return query_type_definition(file, line_num, col)
    elif subcmd == "implementation":
        return query_implementation(file, line_num, col)
    else:
        print "Unknown subcmd: {subcmd}"
        return 1

lsp_query_main()
