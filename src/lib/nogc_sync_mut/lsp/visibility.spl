@allow(unnamed_duplicate_typed_args)
# LSP Visibility Support
#
# Shared types and helpers for visibility metadata in LSP responses.
# Provides structured visibility payload for hover, completion, document
# symbols, workspace symbols, and semantic tokens.
#
# The live LSP handlers delegate visibility computation to
# src/app/cli/query_visibility.spl which resolves visibility from
# file/module boundaries and manifest exports. This module provides
# the shared type definitions and serialization helpers consumed by
# both the live LSP path and the unit test surface.

# --- Visibility display levels ---

fn visibility_level_public() -> text:
    "public"

fn visibility_level_boundary() -> text:
    "boundary"

fn visibility_level_private() -> text:
    "private"

# --- Declared visibility levels (richer compiler data) ---

fn declared_public() -> text:
    "public"

fn declared_internal() -> text:
    "internal"

fn declared_package() -> text:
    "package"

fn declared_private() -> text:
    "private"

# --- Boundary kinds ---

fn boundary_kind_open() -> text:
    "open"

fn boundary_kind_boundary() -> text:
    "boundary"

fn boundary_kind_bypass() -> text:
    "bypass"

# --- Visibility ranking for workspace symbol ordering ---

fn visibility_rank(display: text) -> i64:
    if display == "public":
        return 0
    if display == "boundary":
        return 10
    20

# --- Reachability check ---

fn is_reachable(display: text) -> bool:
    display != "private"

# --- Completion filtering ---
# REQ-LSPVIS-004: Filter inaccessible symbols from primary results

fn should_include_in_completion(display: text, reachable: bool) -> bool:
    reachable

fn should_include_in_workspace(display: text, reachable: bool) -> bool:
    reachable

# --- Detail string formatting ---
# REQ-LSPVIS-008: Readable text for clients without structured support

fn format_visibility_detail(symbol_name: text, display: text, boundary_module: text, exported_by: text) -> text:
    if exported_by != "":
        return display + " (exported from " + boundary_module + ")"
    if display == "boundary" and boundary_module != "":
        return display + " (boundary: " + boundary_module + ")"
    display

# --- Hover prose ---
# REQ-LSPVIS-005: Always show visibility in hover, even for unreachable targets

fn format_hover_visibility(display: text, boundary_module: text, boundary_kind: text, exported_by: text) -> text:
    var lines: [text] = []
    lines = lines.push("Visibility: **" + display + "**")
    if boundary_module != "":
        lines = lines.push("Boundary: `" + boundary_module + "` (" + boundary_kind + ")")
    if exported_by != "":
        lines = lines.push("Exported by: `" + exported_by + "`")
    lines.join("\n")

# --- Semantic token modifier bitmasks ---
# REQ-LSPVIS-006: Emit visibility modifiers for editor styling
#
# The modifier legend in lsp_handle_initialize maps:
#   index 9  -> visibilityPublic   -> bitmask 512
#   index 10 -> visibilityBoundary -> bitmask 1024
#   index 11 -> visibilityPrivate  -> bitmask 2048

fn visibility_modifier_public() -> i64:
    512

fn visibility_modifier_boundary() -> i64:
    1024

fn visibility_modifier_private() -> i64:
    2048

fn visibility_modifier_for_display(display: text) -> i64:
    if display == "public":
        return 512
    if display == "boundary":
        return 1024
    2048

# --- Capability negotiation ---
# REQ-LSPVIS-008: Negotiate structured visibility metadata

fn client_supports_visibility(experimental_field: text) -> bool:
    if experimental_field == "":
        return false
    experimental_field.contains("simpleVisibility")

fn server_capability_experimental() -> text:
    "\"simpleVisibilityProvider\":true"
