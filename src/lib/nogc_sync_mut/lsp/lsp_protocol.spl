@allow(unnamed_duplicate_typed_args)
# LSP Server - Protocol I/O
# Uses Content-Length framing for editor/plugin clients and accepts a raw JSON
# line as a fallback for ad-hoc local testing.

extern fn stdin_read_char() -> text

fn lsp_read_line_chars() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            if result == "":
                return ""
            return result
        result = result + ch
        if ch == "\n":
            return result

fn lsp_read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn lsp_read_message() -> text:
    var content_length = 0
    while true:
        var line = lsp_read_line_chars()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        if line.ends_with("\r\n"):
            line = line.substring(0, line.len() - 2)
        elif line.ends_with("\n"):
            line = line.substring(0, line.len() - 1)
        elif line.ends_with("\r"):
            line = line.substring(0, line.len() - 1)

        # Fallback mode for local debugging.
        if line.starts_with("{"):
            return line

        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = int(len_str)
    if content_length <= 0:
        return ""
    lsp_read_chars(content_length)

fn lsp_write_message(body: text):
    if body == "":
        return
    val byte_count = text_byte_len(body)
    var header = "Content-Length: " + str(byte_count) + "\r\n\r\n"
    print_raw(header)
    print_raw(body)

fn lsp_is_json_lines_mode() -> bool:
    false

fn lsp_set_json_lines_mode(use_json_lines: bool):
    val _ignored = use_json_lines

fn lsp_write_notification(method: text, params: text):
    val msg = jo3(jp("jsonrpc", js("2.0")), jp("method", js(method)), jp("params", params))
    lsp_write_message(msg)

fn lsp_log(message: text):
    extern fn rt_env_get(name: text) -> text
    val debug = rt_env_get("SIMPLE_LSP_DEBUG") ?? ""
    if debug != "":
        # Write to stderr via notification
        lsp_write_notification("window/logMessage", jo2(jp("type", "4"), jp("message", js(message))))
