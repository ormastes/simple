# LSP Server - Protocol I/O
# Content-Length framed JSON-RPC over stdin/stdout

val NL = "\n"

fn lsp_read_message() -> text:
    var line = input()
    if line == "":
        return ""
    if line.ends_with("\r"):
        line = line.substring(0, line.len() - 1)
    # LSP always uses Content-Length framing
    if line.starts_with("Content-Length:"):
        var len_str = line.replace("Content-Length:", "")
        len_str = len_str.trim()
        val content_length = int(len_str)
        if content_length == 0:
            return ""
        # Read until empty line (skip headers)
        var header_line = input()
        while header_line != "" and header_line != "\r":
            if header_line.ends_with("\r"):
                header_line = header_line.substring(0, header_line.len() - 1)
            if header_line == "":
                break
            header_line = input()
        # Read body
        var body = input()
        return body
    # Fallback: if it starts with { treat as raw JSON
    if line.starts_with("{"):
        return line
    ""

fn lsp_write_message(body: text):
    if body == "":
        return
    val byte_count = text_byte_len(body)
    var header = "Content-Length: " + str(byte_count) + "\r" + NL + "\r" + NL
    print_raw(header)
    print_raw(body)

fn lsp_write_notification(method: text, params: text):
    val msg = jo3(jp("jsonrpc", js("2.0")), jp("method", js(method)), jp("params", params))
    lsp_write_message(msg)

fn lsp_log(message: text):
    extern fn rt_env_get(name: text) -> text
    val debug = rt_env_get("SIMPLE_LSP_DEBUG") ?? ""
    if debug != "":
        # Write to stderr via notification
        lsp_write_notification("window/logMessage", jo2(jp("type", "4"), jp("message", js(message))))
