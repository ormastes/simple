# SMTP/S port constants per RFC 8314 and RFC 3207.
#
# RFC 8314 §4 — Use of TLS for Email Submission and Access (port 465 SMTPS)
# RFC 3207    — STARTTLS extension for SMTP (port 587)
# RFC 5321 §2.1 — Traditional SMTP MX (port 25)

fn smtps_default_port() -> i64: 465
fn smtp_starttls_port() -> i64: 587
fn smtp_cleartext_port() -> i64: 25
