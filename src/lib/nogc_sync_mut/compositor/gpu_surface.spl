#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# GPU surface management — abstraction over platform render targets.
# Manages allocation, resizing, destruction, and swapchain presentation
# of GPU-backed surfaces used for compositing and rasterization.
#
# Generic compositor module — no browser-specific dependencies.
#
# TODO: [gpu][P3] Add graphics module — a 2D game rendering engine abstraction that
# unifies Canvas 2D, SVG, and CSS paint onto a shared GPU pipeline.
# The graphics module should provide: sprite batching, texture atlasing,
# draw call sorting, and a retained-mode scene graph backed by the
# surface pool + texture cache. This replaces per-subsystem software raster
# with a single hardware-accelerated 2D renderer (reuse std.gpu + Vulkan FFI).

use core.collections.{List}

# ---------------------------------------------------------------------------
# SurfaceFormat — pixel format for GPU surfaces.
# ---------------------------------------------------------------------------

enum SurfaceFormat:
    BGRA8
    RGBA8
    RGB565

# Return bytes per pixel for a given surface format.
fn bytes_per_pixel(format: SurfaceFormat) -> i64:
    match format:
        SurfaceFormat.BGRA8: 4
        SurfaceFormat.RGBA8: 4
        SurfaceFormat.RGB565: 2

# ---------------------------------------------------------------------------
# GpuSurface — a single GPU-backed render target.
# ---------------------------------------------------------------------------

class GpuSurface:
    id: i64
    width: i64
    height: i64
    format: SurfaceFormat
    texture_id: i64
    is_valid: bool
    generation: i64
    pixels: List<i64>

    static fn create(id: i64, width: i64, height: i64, format: SurfaceFormat) -> GpuSurface:
        val size = width * height
        var px = List<i64>()
        var i = 0
        while i < size:
            px.push(0)
            i = i + 1
        GpuSurface(
            id: id,
            width: width,
            height: height,
            format: format,
            texture_id: id,
            is_valid: true,
            generation: 0,
            pixels: px
        )

impl GpuSurface:
    me set_pixel(x: i64, y: i64, packed: i64):
        if x >= 0 and x < self.width and y >= 0 and y < self.height:
            self.pixels[y * self.width + x] = packed

    fn get_pixel(x: i64, y: i64) -> i64:
        if x >= 0 and x < self.width and y >= 0 and y < self.height:
            return self.pixels[y * self.width + x]
        0

    me fill(packed: i64):
        var i = 0
        val size = self.width * self.height
        while i < size:
            self.pixels[i] = packed
            i = i + 1

# Calculate memory usage of a single surface in bytes.
fn surface_memory_bytes(surface: GpuSurface) -> i64:
    val bpp = bytes_per_pixel(surface.format)
    surface.width * surface.height * bpp

# ---------------------------------------------------------------------------
# SurfacePool — manages a collection of GPU surfaces.
# ---------------------------------------------------------------------------

class SurfacePool:
    surfaces: List<GpuSurface>
    next_id: i64
    max_surfaces: i64

    static fn new(max_surfaces: i64) -> SurfacePool:
        SurfacePool(
            surfaces: List<GpuSurface>(),
            next_id: 1,
            max_surfaces: max_surfaces
        )

    # Create a new GPU surface with the given dimensions and format.
    # Returns nil if pool is exhausted or dimensions are invalid.
    me create_surface(width: i64, height: i64, format: SurfaceFormat) -> GpuSurface?:
        if self.surfaces.len() >= self.max_surfaces:
            return nil

        if width <= 0 or height <= 0:
            return nil

        val id = self.next_id
        self.next_id = self.next_id + 1

        val surface = GpuSurface.create(id, width, height, format)
        self.surfaces.push(surface)
        surface

    # Resize an existing surface by ID. Invalidates old content.
    # Returns true on success, false if surface not found or invalid dimensions.
    me resize_surface(surface_id: i64, width: i64, height: i64) -> bool:
        if width <= 0 or height <= 0:
            return false

        for surface in self.surfaces:
            if surface.id == surface_id:
                surface.width = width
                surface.height = height
                surface.generation = surface.generation + 1
                # Reallocate pixel buffer for new dimensions
                val size = width * height
                var px = List<i64>()
                var i = 0
                while i < size:
                    px.push(0)
                    i = i + 1
                surface.pixels = px
                return true

        false

    # Destroy a surface by ID and remove it from the pool.
    me destroy_surface(surface_id: i64):
        var new_surfaces = List<GpuSurface>()
        for surface in self.surfaces:
            if surface.id == surface_id:
                surface.is_valid = false
            else:
                new_surfaces.push(surface)
        self.surfaces = new_surfaces

    # Look up a surface by ID.
    fn get_surface(surface_id: i64) -> GpuSurface?:
        for surface in self.surfaces:
            if surface.id == surface_id:
                if surface.is_valid:
                    return surface
        nil

    # Reclaim surfaces that are no longer valid.
    me reclaim_unused():
        var kept = List<GpuSurface>()
        for surface in self.surfaces:
            if surface.is_valid:
                kept.push(surface)
        self.surfaces = kept

    # Calculate total memory usage of all surfaces in the pool.
    fn total_memory_usage() -> i64:
        var total = 0
        for surface in self.surfaces:
            if surface.is_valid:
                total = total + surface_memory_bytes(surface)
        total

    # Present a swapchain by swapping front and back buffers.
    # Returns true on success, false if a surface is missing.
    me present(swapchain: Swapchain) -> bool:
        val front_surface = self.get_surface(swapchain.front)
        if not front_surface.?:
            return false

        val back_surface = self.get_surface(swapchain.back)
        if not back_surface.?:
            return false

        # Swap front and back buffer IDs
        val old_front = swapchain.front
        swapchain.front = swapchain.back
        swapchain.back = old_front
        true

    # Create a new swapchain with front and back surfaces.
    # Returns nil if surface creation fails.
    me create_swapchain(width: i64, height: i64) -> Swapchain?:
        val front = self.create_surface(width, height, SurfaceFormat.BGRA8)
        if not front.?:
            return nil
        val back = self.create_surface(width, height, SurfaceFormat.BGRA8)
        if not back.?:
            return nil

        if val f = front:
            if val b = back:
                val sc = Swapchain(
                    front: f.id,
                    back: b.id,
                    width: width,
                    height: height
                )
                return sc
        nil

# ---------------------------------------------------------------------------
# Swapchain — double-buffered presentation surface.
# ---------------------------------------------------------------------------

class Swapchain:
    front: i64
    back: i64
    width: i64
    height: i64

    static fn create(front: i64, back: i64, width: i64, height: i64) -> Swapchain:
        Swapchain(front: front, back: back, width: width, height: height)

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

# Calculate total memory for a given dimension and format.
fn calculate_surface_memory(width: i64, height: i64, format: SurfaceFormat) -> i64:
    width * height * bytes_per_pixel(format)

# Check if a surface fits within a maximum memory budget (in bytes).
fn surface_fits_budget(width: i64, height: i64, format: SurfaceFormat, budget_bytes: i64) -> bool:
    val needed = calculate_surface_memory(width, height, format)
    needed <= budget_bytes

# Format a surface description as text.
fn describe_surface(surface: GpuSurface) -> text:
    val fmt_name = match surface.format:
        SurfaceFormat.BGRA8: "BGRA8"
        SurfaceFormat.RGBA8: "RGBA8"
        SurfaceFormat.RGB565: "RGB565"
    val mem = surface_memory_bytes(surface)
    "Surface(id={surface.id}, {surface.width}x{surface.height}, {fmt_name}, {mem} bytes, gen={surface.generation})"

# Format memory size in human-readable form.
fn format_memory(bytes: i64) -> text:
    if bytes >= 1048576:
        val mb = bytes / 1048576
        return "{mb} MB"
    if bytes >= 1024:
        val kb = bytes / 1024
        return "{kb} KB"
    "{bytes} B"
