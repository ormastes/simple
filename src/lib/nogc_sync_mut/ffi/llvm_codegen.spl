# LLVM FFI — Builder, Basic Blocks, and all Instruction categories.

use std.nogc_sync_mut.ffi.llvm_loader.{
    _lc1, _lc2, _lc3, _lc4, _lcn,
    llvm_make_array, llvm_free_array
}

# ============================================================================
# 5. Builder & Basic Blocks
# ============================================================================

fn llvm_create_builder_in_context(ctx: i64) -> i64:
    _lc1("LLVMCreateBuilderInContext", ctx)

fn llvm_dispose_builder(builder: i64):
    _lc1("LLVMDisposeBuilder", builder)

# reason: positional ffi llvm API
fn llvm_append_basic_block_in_context(ctx: i64, func: i64, name: text) -> i64:
    _lc3("LLVMAppendBasicBlockInContext", ctx, func, name.ptr())

# reason: positional ffi llvm API
fn llvm_position_builder_at_end(builder: i64, block: i64):
    _lc2("LLVMPositionBuilderAtEnd", builder, block)

fn llvm_get_insert_block(builder: i64) -> i64:
    _lc1("LLVMGetInsertBlock", builder)

