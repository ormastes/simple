# 6. Instructions — Control Flow
# ============================================================================

# reason: positional ffi llvm API
fn llvm_build_ret(b: i64, value: i64) -> i64:
    _lc2("LLVMBuildRet", b, value)

fn llvm_build_ret_void(b: i64) -> i64:
    _lc1("LLVMBuildRetVoid", b)

# reason: positional ffi llvm API
fn llvm_build_br(b: i64, dest: i64) -> i64:
    _lc2("LLVMBuildBr", b, dest)

# reason: positional ffi llvm API
fn llvm_build_cond_br(b: i64, cond: i64, then_bb: i64, else_bb: i64) -> i64:
    val args: [i64] = [b, cond, then_bb, else_bb]
    _lcn("LLVMBuildCondBr", args)

# reason: positional ffi llvm API
fn llvm_build_switch(b: i64, value: i64, else_bb: i64, num_cases: i64) -> i64:
    _lc4("LLVMBuildSwitch", b, value, else_bb, num_cases)

# reason: positional ffi llvm API
fn llvm_add_case(switch_inst: i64, on_val: i64, dest: i64):
    _lc3("LLVMAddCase", switch_inst, on_val, dest)

fn llvm_build_unreachable(b: i64) -> i64:
    _lc1("LLVMBuildUnreachable", b)

# reason: positional ffi llvm API
fn llvm_build_phi(b: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMBuildPhi", b, ty, name.ptr())

# reason: positional ffi llvm API
fn llvm_add_incoming(phi: i64, values: [i64], blocks: [i64]):
    val n = values.len()
    val val_arr = llvm_make_array(values)
    val blk_arr = llvm_make_array(blocks)
    _lc4("LLVMAddIncoming", phi, val_arr, blk_arr, n)
    llvm_free_array(val_arr)
    llvm_free_array(blk_arr)

# ============================================================================
# 6. Instructions — Call
# ============================================================================

# reason: positional ffi llvm API
fn llvm_build_call2(b: i64, fn_ty: i64, func: i64, args: [i64], name: text) -> i64:
    val n = args.len()
    val arr = llvm_make_array(args)
    var call_args: [i64] = []
    call_args.push(b)
    call_args.push(fn_ty)
    call_args.push(func)
    call_args.push(arr)
    call_args.push(n)
    # NUL-terminate: LLVMBuildCall2's Name is a C string (strlen'd via Twine).
    # text.ptr() on an EMPTY Simple text returns a dangling (non-dereferenceable)
    # pointer, not merely an unterminated buffer -- strlen on it segfaults
    # immediately. Same hazard class as the LLVMSetDataLayout NUL-termination
    # fix; apply it here too since translate_call/translate_call_indirect/
    # translate_intrinsic all pass name="" for void/no-dest calls.
    call_args.push((name + "\0").ptr())
    val result = _lcn("LLVMBuildCall2", call_args)
    llvm_free_array(arr)
    result

# ============================================================================
# 6. Instructions — Select
# ============================================================================

# reason: positional ffi llvm API
fn llvm_build_select(b: i64, cond: i64, then_val: i64, else_val: i64, name: text) -> i64:
    var args: [i64] = []
    args.push(b)
    args.push(cond)
    args.push(then_val)
    args.push(else_val)
    args.push(name.ptr())
    _lcn("LLVMBuildSelect", args)
