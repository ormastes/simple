# ============================================================================
# 6. Instructions — Comparison
# ============================================================================

fn llvm_build_icmp(b: i64, pred: i64, lhs: i64, rhs: i64, name: text) -> i64:
    var args: [i64] = []
    args.push(b)
    args.push(pred)
    args.push(lhs)
    args.push(rhs)
    args.push(name.ptr())
    _lcn("LLVMBuildICmp", args)

fn llvm_build_fcmp(b: i64, pred: i64, lhs: i64, rhs: i64, name: text) -> i64:
    var args: [i64] = []
    args.push(b)
    args.push(pred)
    args.push(lhs)
    args.push(rhs)
    args.push(name.ptr())
    _lcn("LLVMBuildFCmp", args)

# ============================================================================
# 6. Instructions — Memory
# ============================================================================

fn llvm_build_alloca(b: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMBuildAlloca", b, ty, name.ptr())

fn llvm_build_load2(b: i64, ty: i64, ptr: i64, name: text) -> i64:
    _lc4("LLVMBuildLoad2", b, ty, ptr, name.ptr())

fn llvm_build_store(b: i64, val: i64, ptr: i64) -> i64:
    _lc3("LLVMBuildStore", b, val, ptr)

fn llvm_build_gep2(b: i64, ty: i64, ptr: i64, indices: [i64], name: text) -> i64:
    val n = indices.len()
    val arr = llvm_make_array(indices)
    var args: [i64] = []
    args.push(b)
    args.push(ty)
    args.push(ptr)
    args.push(arr)
    args.push(n)
    args.push(name.ptr())
    val result = _lcn("LLVMBuildGEP2", args)
    llvm_free_array(arr)
    result

fn llvm_build_in_bounds_gep2(b: i64, ty: i64, ptr: i64, indices: [i64], name: text) -> i64:
    val n = indices.len()
    val arr = llvm_make_array(indices)
    var args: [i64] = []
    args.push(b)
    args.push(ty)
    args.push(ptr)
    args.push(arr)
    args.push(n)
    args.push(name.ptr())
    val result = _lcn("LLVMBuildInBoundsGEP2", args)
    llvm_free_array(arr)
    result

