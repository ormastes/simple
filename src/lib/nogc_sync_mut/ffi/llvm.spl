fn llvm_add_global(mod_: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMAddGlobal", mod_, ty, name.ptr())

fn llvm_set_initializer(global: i64, const_val: i64):
    _lc2("LLVMSetInitializer", global, const_val)

fn llvm_set_global_constant(global: i64, is_const: bool):
    val ic = if is_const: 1 else: 0
    _lc2("LLVMSetGlobalConstant", global, ic)

fn llvm_set_unnamed_addr(global: i64, has_unnamed_addr: bool):
    val hua = if has_unnamed_addr: 1 else: 0
