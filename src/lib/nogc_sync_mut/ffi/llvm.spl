    _lc4("LLVMBuildAdd", b, lhs, rhs, name.ptr())

fn llvm_build_nsw_add(b: i64, lhs: i64, rhs: i64, name: text) -> i64:
    _lc4("LLVMBuildNSWAdd", b, lhs, rhs, name.ptr())

