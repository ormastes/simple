    _lc3("LLVMAddFunction", mod_, name.ptr(), fn_ty)

fn llvm_get_named_function(mod_: i64, name: text) -> i64:
    _lc2("LLVMGetNamedFunction", mod_, name.ptr())

fn llvm_get_param(func: i64, index: i64) -> i64:
    _lc2("LLVMGetParam", func, index)

fn llvm_set_linkage(global: i64, linkage: i64):
