fn llvm_build_neg(b: i64, val: i64, name: text) -> i64:
    _lc3("LLVMBuildNeg", b, val, name.ptr())

# Float arithmetic
fn llvm_build_fadd(b: i64, lhs: i64, rhs: i64, name: text) -> i64:
