# LLVM C API FFI Bindings via DynLib
#
# Provides runtime dynamic loading of libLLVM.so and wraps ~120 LLVM C API
# functions for in-process IR generation and object code emission.
#
# Pattern: All LLVM handles are opaque i64 (LLVMContextRef, LLVMModuleRef, etc.)
# Strings are passed via text.ptr() (null-terminated).
# Array arguments use rt_alloc + rt_ptr_write_i64 to build contiguous buffers.
#
# Usage:
#   if llvm_load():
#       val ctx = llvm_context_create()
#       val mod = llvm_module_create_with_name_in_context("test", ctx)
#       ...
#       llvm_context_dispose(ctx)

use std.ffi.dynamic.{DynLib}

# ============================================================================
# Memory helpers for C API interop
# ============================================================================

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64)
extern fn rt_memset(dest: i64, val: i64, len: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_memcpy(dest: i64, src: i64, len: i64)
extern fn rt_bytes_from_raw(ptr: i64, len: i64) -> [u8]

# FFI primitives for cached calls
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64

# ============================================================================
# Module state
# ============================================================================

var _llvm_lib: DynLib? = nil
var _llvm_initialized: bool = false
var _targets_initialized: bool = false
var _fptr_cache: {text: i64} = {}

# ============================================================================
# Library loading
# ============================================================================

extern fn rt_env_get(key: text) -> text

fn llvm_load() -> bool:
    if _llvm_initialized:
        return _llvm_lib.?
    _llvm_initialized = true

    # Check SIMPLE_LLVM_PATH env var first (all platforms)
    val env_path = rt_env_get("SIMPLE_LLVM_PATH")
    if env_path != nil and env_path != "":
        val lib = DynLib.load(env_path)
        if lib.?:
            _llvm_lib = lib
            return true

    val paths = [
        # Windows: MSVC distribution (LLVM-C.dll is the C API DLL)
        "LLVM-C.dll",
        # Windows: MinGW distribution (libLLVM-NN.dll)
        "libLLVM-18.dll", "libLLVM-17.dll", "libLLVM-19.dll",
        "libLLVM.dll", "LLVM.dll",
        # Linux system paths (dlopen searches ld.so.conf paths)
        "libLLVM-18.so", "libLLVM-18.so.1",
        "libLLVM-17.so", "libLLVM-17.so.1",
        "libLLVM-19.so", "libLLVM-19.so.1",
        "libLLVM.so",
        # macOS: short names (works if DYLD_LIBRARY_PATH is set)
        "libLLVM-18.dylib", "libLLVM-17.dylib", "libLLVM.dylib",
        # macOS Homebrew: Apple Silicon (arm64)
        "/opt/homebrew/opt/llvm/lib/libLLVM.dylib",
        "/opt/homebrew/opt/llvm@18/lib/libLLVM.dylib",
        "/opt/homebrew/opt/llvm@17/lib/libLLVM.dylib",
        # macOS Homebrew: Intel (x86_64)
        "/usr/local/opt/llvm/lib/libLLVM.dylib",
        "/usr/local/opt/llvm@18/lib/libLLVM.dylib",
        "/usr/local/opt/llvm@17/lib/libLLVM.dylib"
    ]
    for path in paths:
        val lib = DynLib.load(path)
        if lib.?:
            _llvm_lib = lib
            return true
    false

fn llvm_available() -> bool:
    llvm_load()

fn llvm_lib() -> DynLib:
    _llvm_lib.unwrap()

# ============================================================================
# Cached FFI calls — dlsym results cached in _fptr_cache dict
# ============================================================================

fn _llvm_resolve(name: text) -> i64:
    val cached = _fptr_cache[name]
    if cached != nil:
        return cached
    val fptr = spl_dlsym(_llvm_lib.unwrap().handle, name)
    _fptr_cache[name] = fptr
    fptr

fn _lc0(name: text) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), [], 0)

fn _lc1(name: text, a0: i64) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), [a0], 1)

fn _lc2(name: text, a0: i64, a1: i64) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), [a0, a1], 2)

fn _lc3(name: text, a0: i64, a1: i64, a2: i64) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), [a0, a1, a2], 3)

fn _lc4(name: text, a0: i64, a1: i64, a2: i64, a3: i64) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), [a0, a1, a2, a3], 4)

fn _lcn(name: text, args: [i64]) -> i64:
    spl_wffi_call_i64(_llvm_resolve(name), args, args.len())

# ============================================================================
# Helper: build contiguous i64 array for C API
# ============================================================================

# Scratch buffer for small arrays (avoids alloc/free for <= 8 elements)
var _scratch_buf: i64 = 0

fn _ensure_scratch() -> i64:
    if _scratch_buf == 0:
        _scratch_buf = rt_alloc(64)
    _scratch_buf

fn llvm_make_array(values: [i64]) -> i64:
    val n = values.len()
    if n == 0:
        return 0
    # Use scratch buffer for small arrays (up to 8 elements)
    if n <= 8:
        val buf = _ensure_scratch()
        for i in 0..n:
            rt_ptr_write_i64(buf, i * 8, values[i])
        return buf
    val ptr = rt_alloc(n * 8)
    for i in 0..n:
        rt_ptr_write_i64(ptr, i * 8, values[i])
    ptr

fn llvm_free_array(ptr: i64):
    if ptr != 0 and ptr != _scratch_buf:
        rt_free(ptr)

# ============================================================================
# LLVM Enum Constants
# ============================================================================

# IntPredicate
val LLVM_INT_EQ = 32
val LLVM_INT_NE = 33
val LLVM_INT_UGT = 34
val LLVM_INT_UGE = 35
val LLVM_INT_ULT = 36
val LLVM_INT_ULE = 37
val LLVM_INT_SGT = 38
val LLVM_INT_SGE = 39
val LLVM_INT_SLT = 40
val LLVM_INT_SLE = 41

# RealPredicate
val LLVM_REAL_OEQ = 1
val LLVM_REAL_OGT = 2
val LLVM_REAL_OGE = 3
val LLVM_REAL_OLT = 4
val LLVM_REAL_OLE = 5
val LLVM_REAL_ONE = 6
val LLVM_REAL_ORD = 7
val LLVM_REAL_UNO = 8

# Linkage
val LLVM_EXTERNAL_LINKAGE = 0
val LLVM_INTERNAL_LINKAGE = 8
val LLVM_PRIVATE_LINKAGE = 9

# CodeGenOptLevel
val LLVM_CODE_GEN_LEVEL_NONE = 0
val LLVM_CODE_GEN_LEVEL_LESS = 1
val LLVM_CODE_GEN_LEVEL_DEFAULT = 2
val LLVM_CODE_GEN_LEVEL_AGGRESSIVE = 3

# RelocMode
val LLVM_RELOC_DEFAULT = 0
val LLVM_RELOC_STATIC = 1
val LLVM_RELOC_PIC = 2

# CodeModel
val LLVM_CODE_MODEL_DEFAULT = 0
val LLVM_CODE_MODEL_SMALL = 2
val LLVM_CODE_MODEL_LARGE = 4

# CodeGenFileType
val LLVM_ASSEMBLY_FILE = 0
val LLVM_OBJECT_FILE = 1

# ============================================================================
# 1. Context & Module
# ============================================================================

fn llvm_context_create() -> i64:
    _lc0("LLVMContextCreate")

fn llvm_context_dispose(ctx: i64):
    _lc1("LLVMContextDispose", ctx)

fn llvm_module_create_with_name_in_context(name: text, ctx: i64) -> i64:
    _lc2("LLVMModuleCreateWithNameInContext", name.ptr(), ctx)

fn llvm_dispose_module(mod_: i64):
    _lc1("LLVMDisposeModule", mod_)

fn llvm_set_target(mod_: i64, triple: text):
    _lc2("LLVMSetTarget", mod_, triple.ptr())

fn llvm_set_data_layout(mod_: i64, layout: text):
    _lc2("LLVMSetDataLayout", mod_, layout.ptr())

fn llvm_set_source_file_name(mod_: i64, name: text):
    _lc3("LLVMSetSourceFileName", mod_, name.ptr(), name.len())

fn llvm_verify_module(mod_: i64) -> bool:
    # LLVMVerifyModule(M, Action, OutMessage) — Action=0=AbortProcess, 1=PrintMessage, 2=ReturnStatus
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    args.push(mod_)
    args.push(2)
    args.push(err_ptr)
    val result = _lcn("LLVMVerifyModule", args)
    rt_free(err_ptr)
    result == 0

fn llvm_print_module_to_string(mod_: i64) -> i64:
    _lc1("LLVMPrintModuleToString", mod_)

fn llvm_dispose_message(msg: i64):
    _lc1("LLVMDisposeMessage", msg)

# ============================================================================
# 2. Types
# ============================================================================

fn llvm_void_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMVoidTypeInContext", ctx)

fn llvm_int1_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt1TypeInContext", ctx)

fn llvm_int8_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt8TypeInContext", ctx)

fn llvm_int16_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt16TypeInContext", ctx)

fn llvm_int32_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt32TypeInContext", ctx)

fn llvm_int64_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMInt64TypeInContext", ctx)

fn llvm_float_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMFloatTypeInContext", ctx)

fn llvm_double_type_in_context(ctx: i64) -> i64:
    _lc1("LLVMDoubleTypeInContext", ctx)

fn llvm_pointer_type(elem_ty: i64, addr_space: i64) -> i64:
    _lc2("LLVMPointerType", elem_ty, addr_space)

fn llvm_function_type(ret_ty: i64, param_types: [i64], is_var_arg: bool) -> i64:
    val n = param_types.len()
    val arr = llvm_make_array(param_types)
    val va = if is_var_arg: 1 else: 0
    val result = _lc4("LLVMFunctionType", ret_ty, arr, n, va)
    llvm_free_array(arr)
    result

fn llvm_struct_type_in_context(ctx: i64, elem_types: [i64], packed: bool) -> i64:
    val n = elem_types.len()
    val arr = llvm_make_array(elem_types)
    val pk = if packed: 1 else: 0
    val result = _lc4("LLVMStructTypeInContext", ctx, arr, n, pk)
    llvm_free_array(arr)
    result

fn llvm_array_type2(elem_ty: i64, count: i64) -> i64:
    _lc2("LLVMArrayType2", elem_ty, count)

fn llvm_get_type_kind(ty: i64) -> i64:
    _lc1("LLVMGetTypeKind", ty)

# ============================================================================
# 3. Constants
# ============================================================================

fn llvm_const_int(ty: i64, value: i64, sign_extend: bool) -> i64:
    val se = if sign_extend: 1 else: 0
    _lc3("LLVMConstInt", ty, value, se)

fn llvm_const_real_of_string(ty: i64, value: text) -> i64:
    _lc2("LLVMConstRealOfString", ty, value.ptr())

fn llvm_const_string_in_context(ctx: i64, str: text, dont_null_terminate: bool) -> i64:
    val dnt = if dont_null_terminate: 1 else: 0
    _lc4("LLVMConstStringInContext", ctx, str.ptr(), str.len(), dnt)

fn llvm_const_null(ty: i64) -> i64:
    _lc1("LLVMConstNull", ty)

fn llvm_get_undef(ty: i64) -> i64:
    _lc1("LLVMGetUndef", ty)

fn llvm_const_array(elem_ty: i64, values: [i64]) -> i64:
    val n = values.len()
    val arr = llvm_make_array(values)
    val result = _lc3("LLVMConstArray", elem_ty, arr, n)
    llvm_free_array(arr)
    result

fn llvm_const_struct_in_context(ctx: i64, values: [i64], packed: bool) -> i64:
    val n = values.len()
    val arr = llvm_make_array(values)
    val pk = if packed: 1 else: 0
    val result = _lc4("LLVMConstStructInContext", ctx, arr, n, pk)
    llvm_free_array(arr)
    result

fn llvm_const_pointer_null(ty: i64) -> i64:
    _lc1("LLVMConstPointerNull", ty)

