    _lc4("LLVMBuildSub", b, lhs, rhs, name.ptr())

fn llvm_build_nsw_sub(b: i64, lhs: i64, rhs: i64, name: text) -> i64:
    _lc4("LLVMBuildNSWSub", b, lhs, rhs, name.ptr())

fn llvm_build_mul(b: i64, lhs: i64, rhs: i64, name: text) -> i64:
