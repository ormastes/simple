    _lc4("LLVMBuildBitCast", b, val, dest_ty, name.ptr())

# ============================================================================
# 6. Instructions — Control Flow
# ============================================================================

fn llvm_build_ret(b: i64, val: i64) -> i64:
    _lc2("LLVMBuildRet", b, val)

fn llvm_build_ret_void(b: i64) -> i64:
    _lc1("LLVMBuildRetVoid", b)

fn llvm_build_br(b: i64, dest: i64) -> i64:
    _lc2("LLVMBuildBr", b, dest)

fn llvm_build_cond_br(b: i64, cond: i64, then_bb: i64, else_bb: i64) -> i64:
    _lc4("LLVMBuildCondBr", b, cond, then_bb, else_bb)

fn llvm_build_switch(b: i64, val: i64, else_bb: i64, num_cases: i64) -> i64:
    _lc4("LLVMBuildSwitch", b, val, else_bb, num_cases)

fn llvm_add_case(switch_inst: i64, on_val: i64, dest: i64):
    _lc3("LLVMAddCase", switch_inst, on_val, dest)

fn llvm_build_unreachable(b: i64) -> i64:
    _lc1("LLVMBuildUnreachable", b)

fn llvm_build_phi(b: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMBuildPhi", b, ty, name.ptr())

fn llvm_add_incoming(phi: i64, values: [i64], blocks: [i64]):
    val n = values.len()
    val val_arr = llvm_make_array(values)
    val blk_arr = llvm_make_array(blocks)
    _lc4("LLVMAddIncoming", phi, val_arr, blk_arr, n)
    llvm_free_array(val_arr)
    llvm_free_array(blk_arr)

# ============================================================================
# 6. Instructions — Call
# ============================================================================

fn llvm_build_call2(b: i64, fn_ty: i64, func: i64, args: [i64], name: text) -> i64:
    val n = args.len()
    val arr = llvm_make_array(args)
    var call_args: [i64] = []
    call_args.push(b)
    call_args.push(fn_ty)
    call_args.push(func)
    call_args.push(arr)
    call_args.push(n)
    call_args.push(name.ptr())
    val result = _lcn("LLVMBuildCall2", call_args)
    llvm_free_array(arr)
    result

# ============================================================================
# 6. Instructions — Select
# ============================================================================

fn llvm_build_select(b: i64, cond: i64, then_val: i64, else_val: i64, name: text) -> i64:
    var args: [i64] = []
    args.push(b)
    args.push(cond)
    args.push(then_val)
    args.push(else_val)
    args.push(name.ptr())
    _lcn("LLVMBuildSelect", args)

# ============================================================================
# 7. Target Machine
# ============================================================================

fn llvm_initialize_all_target_infos():
    _lc0("LLVMInitializeAllTargetInfos")

fn llvm_initialize_all_targets():
    _lc0("LLVMInitializeAllTargets")

fn llvm_initialize_all_target_mcs():
    _lc0("LLVMInitializeAllTargetMCs")

fn llvm_initialize_all_asm_printers():
    _lc0("LLVMInitializeAllAsmPrinters")

fn llvm_initialize_all_asm_parsers():
    _lc0("LLVMInitializeAllAsmParsers")

fn llvm_initialize_targets():
    if _targets_initialized:
        return
    _targets_initialized = true
    llvm_initialize_all_target_infos()
    llvm_initialize_all_targets()
    llvm_initialize_all_target_mcs()
    llvm_initialize_all_asm_printers()
    llvm_initialize_all_asm_parsers()

fn llvm_get_target_from_triple(triple: text) -> i64:
    # LLVMGetTargetFromTriple(Triple, &Target, &ErrorMessage) -> LLVMBool
    # Returns 0 on success, writes Target to output param
    val target_ptr = rt_alloc(8)
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(target_ptr, 0, 0)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    args.push(triple.ptr())
    args.push(target_ptr)
    args.push(err_ptr)
    val result = _lcn("LLVMGetTargetFromTriple", args)
    var target = 0
    if result == 0:
        target = rt_ptr_read_i64(target_ptr, 0)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(target_ptr)
    rt_free(err_ptr)
    target

fn llvm_create_target_machine(target: i64, triple: text, cpu: text, features: text, opt_level: i64, reloc: i64, code_model: i64) -> i64:
    var args: [i64] = []
    args.push(target)
    args.push(triple.ptr())
    args.push(cpu.ptr())
    args.push(features.ptr())
    args.push(opt_level)
    args.push(reloc)
    args.push(code_model)
    _lcn("LLVMCreateTargetMachine", args)

fn llvm_dispose_target_machine(tm: i64):
    _lc1("LLVMDisposeTargetMachine", tm)

fn llvm_target_machine_emit_to_file(tm: i64, mod_: i64, filename: text, file_type: i64) -> bool:
    # LLVMTargetMachineEmitToFile(TM, M, Filename, FileType, &ErrorMessage) -> LLVMBool
    val err_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    var args: [i64] = []
    args.push(tm)
    args.push(mod_)
    args.push(filename.ptr())
    args.push(file_type)
    args.push(err_ptr)
    val result = _lcn("LLVMTargetMachineEmitToFile", args)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(err_ptr)
    result == 0

fn llvm_get_default_target_triple() -> i64:
    _lc0("LLVMGetDefaultTargetTriple")

fn llvm_create_target_data_layout(tm: i64) -> i64:
    _lc1("LLVMCreateTargetDataLayout", tm)

# ============================================================================
# 8. Pass Manager (New Pass Manager API)
# ============================================================================

fn llvm_run_passes(mod_: i64, passes: text, tm: i64, options: i64) -> i64:
    # LLVMRunPasses(Module, Passes, TM, Options) -> LLVMErrorRef (0=success)
    _lc4("LLVMRunPasses", mod_, passes.ptr(), tm, options)

fn llvm_create_pass_builder_options() -> i64:
    _lc0("LLVMCreatePassBuilderOptions")

fn llvm_dispose_pass_builder_options(options: i64):
    _lc1("LLVMDisposePassBuilderOptions", options)

fn llvm_pass_builder_options_set_verify_each(options: i64, verify: bool):
    val v = if verify: 1 else: 0
    _lc2("LLVMPassBuilderOptionsSetVerifyEach", options, v)

# ============================================================================
# 9. Memory Buffer (for reading emitted object code)
# ============================================================================

fn llvm_get_buffer_start(buf: i64) -> i64:
    _lc1("LLVMGetBufferStart", buf)

fn llvm_get_buffer_size(buf: i64) -> i64:
    _lc1("LLVMGetBufferSize", buf)

fn llvm_dispose_memory_buffer(buf: i64):
    _lc1("LLVMDisposeMemoryBuffer", buf)

fn llvm_target_machine_emit_to_memory_buffer(tm: i64, mod_: i64, file_type: i64) -> i64:
    # LLVMTargetMachineEmitToMemoryBuffer(TM, M, FileType, &ErrorMessage, &OutMemBuf) -> LLVMBool
    val err_ptr = rt_alloc(8)
    val buf_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    rt_ptr_write_i64(buf_ptr, 0, 0)
    var args: [i64] = []
    args.push(tm)
    args.push(mod_)
    args.push(file_type)
    args.push(err_ptr)
    args.push(buf_ptr)
    val result = _lcn("LLVMTargetMachineEmitToMemoryBuffer", args)
    var buffer = 0
    if result == 0:
        buffer = rt_ptr_read_i64(buf_ptr, 0)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(err_ptr)
    rt_free(buf_ptr)
    buffer

# ============================================================================
# 10. Type queries
# ============================================================================

fn llvm_type_of(val: i64) -> i64:
    _lc1("LLVMTypeOf", val)

fn llvm_get_element_type(ty: i64) -> i64:
    _lc1("LLVMGetElementType", ty)

fn llvm_count_struct_element_types(ty: i64) -> i64:
    _lc1("LLVMCountStructElementTypes", ty)

fn llvm_get_return_type(fn_ty: i64) -> i64:
    _lc1("LLVMGetReturnType", fn_ty)

fn llvm_get_int_type_width(ty: i64) -> i64:
    _lc1("LLVMGetIntTypeWidth", ty)

fn llvm_global_get_value_type(global: i64) -> i64:
    _lc1("LLVMGlobalGetValueType", global)

