fn llvm_run_passes(mod_: i64, passes: text, tm: i64, options: i64) -> i64:
    # LLVMRunPasses(Module, Passes, TM, Options) -> LLVMErrorRef (0=success)
    _lc4("LLVMRunPasses", mod_, passes.ptr(), tm, options)

fn llvm_create_pass_builder_options() -> i64:
    _lc0("LLVMCreatePassBuilderOptions")

fn llvm_dispose_pass_builder_options(options: i64):
    _lc1("LLVMDisposePassBuilderOptions", options)

fn llvm_pass_builder_options_set_verify_each(options: i64, verify: bool):
    val v = if verify: 1 else: 0
    _lc2("LLVMPassBuilderOptionsSetVerifyEach", options, v)

# ============================================================================
# 9. Memory Buffer (for reading emitted object code)
# ============================================================================

fn llvm_get_buffer_start(buf: i64) -> i64:
    _lc1("LLVMGetBufferStart", buf)

fn llvm_get_buffer_size(buf: i64) -> i64:
    _lc1("LLVMGetBufferSize", buf)

fn llvm_dispose_memory_buffer(buf: i64):
    _lc1("LLVMDisposeMemoryBuffer", buf)

fn llvm_target_machine_emit_to_memory_buffer(tm: i64, mod_: i64, file_type: i64) -> i64:
    # LLVMTargetMachineEmitToMemoryBuffer(TM, M, FileType, &ErrorMessage, &OutMemBuf) -> LLVMBool
    val err_ptr = rt_alloc(8)
    val buf_ptr = rt_alloc(8)
    rt_ptr_write_i64(err_ptr, 0, 0)
    rt_ptr_write_i64(buf_ptr, 0, 0)
    var args: [i64] = []
    args.push(tm)
    args.push(mod_)
    args.push(file_type)
    args.push(err_ptr)
    args.push(buf_ptr)
    val result = _lcn("LLVMTargetMachineEmitToMemoryBuffer", args)
    var buffer = 0
    if result == 0:
        buffer = rt_ptr_read_i64(buf_ptr, 0)
    val err_msg = rt_ptr_read_i64(err_ptr, 0)
    if err_msg != 0:
        llvm_dispose_message(err_msg)
    rt_free(err_ptr)
    rt_free(buf_ptr)
    buffer

