#![allow(unnamed_duplicate_typed_args)]
# LLVM C API FFI — Instructions, Builder, Target Machine
#
# Split from llvm.spl. Contains instruction emission, builder, target, and pass manager functions.

use std.nogc_sync_mut.ffi.llvm_loader.{
    _lc0, _lc1, _lc2, _lc3, _lc4, _lcn,
    llvm_make_array, llvm_free_array,
    rt_alloc, rt_free, rt_ptr_write_i64, rt_ptr_read_i64
}
use std.nogc_sync_mut.ffi.llvm_types.{llvm_dispose_message}

# ============================================================================
# 4. Functions & Globals
# ============================================================================

fn llvm_add_function(mod_: i64, name: text, fn_ty: i64) -> i64:
    _lc3("LLVMAddFunction", mod_, (name + "\0").ptr(), fn_ty)

fn llvm_get_named_function(mod_: i64, name: text) -> i64:
    _lc2("LLVMGetNamedFunction", mod_, (name + "\0").ptr())

fn llvm_get_param(func: i64, index: i64) -> i64:
    _lc2("LLVMGetParam", func, index)

fn llvm_set_linkage(global: i64, linkage: i64):
    _lc2("LLVMSetLinkage", global, linkage)

fn llvm_add_global(mod_: i64, ty: i64, name: text) -> i64:
    _lc3("LLVMAddGlobal", mod_, ty, name.ptr())

fn llvm_set_initializer(global: i64, const_val: i64):
    _lc2("LLVMSetInitializer", global, const_val)

fn llvm_set_global_constant(global: i64, is_const: bool):
    val ic = if is_const: 1 else: 0
    _lc2("LLVMSetGlobalConstant", global, ic)

fn llvm_set_unnamed_addr(global: i64, has_unnamed_addr: bool):
    val hua = if has_unnamed_addr: 1 else: 0
    _lc2("LLVMSetUnnamedAddr", global, hua)

fn llvm_count_params(func: i64) -> i64:
    _lc1("LLVMCountParams", func)

fn llvm_set_function_call_conv(func: i64, cc: i64):
    _lc2("LLVMSetFunctionCallConv", func, cc)

fn llvm_add_attribute_at_index(func: i64, idx: i64, attr: i64):
    _lc3("LLVMAddAttributeAtIndex", func, idx, attr)

fn llvm_create_enum_attribute(ctx: i64, kind_id: i64, attr_value: i64) -> i64:
    _lc3("LLVMCreateEnumAttribute", ctx, kind_id, attr_value)

fn llvm_get_enum_attribute_kind_for_name(name: text) -> i64:
    _lc2("LLVMGetEnumAttributeKindForName", name.ptr(), name.len())

