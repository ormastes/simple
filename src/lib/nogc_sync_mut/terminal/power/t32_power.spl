#![allow(star_import)]
# T32 Power Control - TRACE32 probe power via PRACTICE commands
#
# Controls target power state through TRACE32 RCL protocol using t32rem.
# Supports discrete on/off/reset and state query. Toggle is NOT supported
# (T32 uses discrete SYStem.Up / SYStem.Down commands).
#
# Used by: power/controller.spl dispatch layer

use std.terminal.types.{PowerConfig, PowerState, POWER_STATE_ON, POWER_STATE_OFF, POWER_STATE_UNKNOWN, make_power_state}
use std.debug.remote.protocol.trace32.{Trace32Client}
use app.debug.remote.types.{DebugConfig}

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# T32 Power Operations
# ============================================================================

fn t32_power_on(config: PowerConfig) -> PowerState:
    """Power on target via TRACE32 SYStem.Up command.

    Connects to T32 API, executes SYStem.Up to bring the target online,
    then disconnects.

    Args:
        config: PowerConfig with kind="t32", t32_host and t32_port set

    Returns:
        PowerState with POWER_STATE_ON on success, POWER_STATE_UNKNOWN on failure
    """
    val timestamp = rt_time_now_unix_micros()
    val debug_config = DebugConfig(
        host: config.t32_host,
        port: config.t32_port,
        program: "",
        args: [],
        debugger: "t32",
        remote: true
    )
    val result = Trace32Client.connect(debug_config)
    match result:
        Ok(client):
            val cmd_result = client.run_command("SYStem.Up")
            client.disconnect()
            match cmd_result:
                Ok(_):
                    make_power_state(POWER_STATE_ON, timestamp)
                Err(_):
                    make_power_state(POWER_STATE_UNKNOWN, timestamp)
        Err(_):
            make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn t32_power_off(config: PowerConfig) -> PowerState:
    """Power off target via TRACE32 SYStem.Down command.

    Connects to T32 API, executes SYStem.Down to shut down the target,
    then disconnects.

    Args:
        config: PowerConfig with kind="t32", t32_host and t32_port set

    Returns:
        PowerState with POWER_STATE_OFF on success, POWER_STATE_UNKNOWN on failure
    """
    val timestamp = rt_time_now_unix_micros()
    val debug_config = DebugConfig(
        host: config.t32_host,
        port: config.t32_port,
        program: "",
        args: [],
        debugger: "t32",
        remote: true
    )
    val result = Trace32Client.connect(debug_config)
    match result:
        Ok(client):
            val cmd_result = client.run_command("SYStem.Down")
            client.disconnect()
            match cmd_result:
                Ok(_):
                    make_power_state(POWER_STATE_OFF, timestamp)
                Err(_):
                    make_power_state(POWER_STATE_UNKNOWN, timestamp)
        Err(_):
            make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn t32_power_reset(config: PowerConfig) -> PowerState:
    """Reset target via TRACE32 SYStem.RESetTarget command.

    Connects to T32 API, executes SYStem.RESetTarget to perform a
    hardware reset, then disconnects. Target is ON after reset.

    Args:
        config: PowerConfig with kind="t32", t32_host and t32_port set

    Returns:
        PowerState with POWER_STATE_ON on success, POWER_STATE_UNKNOWN on failure
    """
    val timestamp = rt_time_now_unix_micros()
    val debug_config = DebugConfig(
        host: config.t32_host,
        port: config.t32_port,
        program: "",
        args: [],
        debugger: "t32",
        remote: true
    )
    val result = Trace32Client.connect(debug_config)
    match result:
        Ok(client):
            val cmd_result = client.run_command("SYStem.RESetTarget")
            client.disconnect()
            match cmd_result:
                Ok(_):
                    make_power_state(POWER_STATE_ON, timestamp)
                Err(_):
                    make_power_state(POWER_STATE_UNKNOWN, timestamp)
        Err(_):
            make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn t32_power_state(config: PowerConfig) -> PowerState:
    """Query target power state via TRACE32 EVAL STATE.RUN().

    Connects to T32 API, evaluates STATE.RUN() to determine if the
    target CPU is running. "TRUE" means on (running), "FALSE" means off (stopped).

    Args:
        config: PowerConfig with kind="t32", t32_host and t32_port set

    Returns:
        PowerState with detected state, or POWER_STATE_UNKNOWN on failure
    """
    val timestamp = rt_time_now_unix_micros()
    val debug_config = DebugConfig(
        host: config.t32_host,
        port: config.t32_port,
        program: "",
        args: [],
        debugger: "t32",
        remote: true
    )
    val result = Trace32Client.connect(debug_config)
    match result:
        Ok(client):
            val cmd_result = client.run_command("EVAL STATE.RUN()")
            client.disconnect()
            match cmd_result:
                Ok(output):
                    val trimmed = output.trim()
                    if trimmed == "TRUE":
                        make_power_state(POWER_STATE_ON, timestamp)
                    elif trimmed == "FALSE":
                        make_power_state(POWER_STATE_OFF, timestamp)
                    else:
                        make_power_state(POWER_STATE_UNKNOWN, timestamp)
                Err(_):
                    make_power_state(POWER_STATE_UNKNOWN, timestamp)
        Err(_):
            make_power_state(POWER_STATE_UNKNOWN, timestamp)
