#![allow(unnamed_duplicate_typed_args)]
@allow(star_import)
# Relay Terminal - Script-based relay/sensor terminal
#
# Provides terminal operations backed by .shs shell scripts. Each operation
# invokes the script specified in config.script_path with appropriate arguments.
# Not a persistent connection -- each operation is a separate script invocation.
#
# Script contract:
#   - Arguments passed as positional parameters ($1, $2, ...)
#   - Exit code 0 = success, non-zero = failure
#   - stdout = result data
#   - stderr = error messages
#   - Scripts must use `set -eu` for safety
#
# Depends on:
#   - std.terminal.types (TerminalConfig, TerminalConnection, TerminalExecResult)

use std.nogc_sync_mut.terminal.types.*

# ============================================================================
# FFI - Shell Execution and Timing
# ============================================================================

extern fn rt_shell_exec(cmd: text) -> (text, text, i64)  # (stdout, stderr, exit_code)
extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Connection ID Counter
# ============================================================================

var relay_conn_id_counter: i64 = 0

# ============================================================================
# Internal Helpers
# ============================================================================

fn relay_run_script(script_path: text, args: text) -> (text, text, i64):
    """Execute a relay script with arguments.

    Builds the command as: script_path + " " + args
    Returns (stdout, stderr, exit_code) tuple.

    Args:
        script_path: Path to .shs relay script
        args: Arguments to pass to the script

    Returns:
        Tuple of (stdout, stderr, exit_code)
    """
    var cmd = script_path
    if args.length() > 0:
        cmd = "{script_path} {args}"
    rt_shell_exec(cmd)

# ============================================================================
# Relay Terminal Operations
# ============================================================================

fn relay_terminal_connect(config: TerminalConfig) -> TerminalConnection:
    """Connect a relay terminal.

    Relay terminals are not persistent connections. This simply marks
    the connection as active and validates that a script_path is configured.

    Args:
        config: TerminalConfig with kind == TERM_KIND_RELAY.
                Uses config.script_path for all operations.

    Returns:
        TerminalConnection with connected=true if script_path is non-empty

    Example:
        val cfg = make_relay_config("power_relay", "scripts/relay.shs")
        val conn = relay_terminal_connect(cfg)
    """
    relay_conn_id_counter = relay_conn_id_counter + 1
    val id = relay_conn_id_counter

    # Validate that a script path is configured
    if config.script_path.length() == 0:
        return TerminalConnection(
            id: id,
            kind: TERM_KIND_RELAY,
            config: config,
            connected: false,
            session_handle: 0,
            channel_handle: 0
        )

    TerminalConnection(
        id: id,
        kind: TERM_KIND_RELAY,
        config: config,
        connected: true,
        session_handle: 0,
        channel_handle: 0
    )

fn relay_terminal_execute(conn: TerminalConnection, command: text) -> TerminalExecResult:
    """Execute a command via the relay script.

    Invokes: config.script_path + " " + command

    Args:
        conn: Active relay TerminalConnection
        command: Command string passed as argument to the relay script

    Returns:
        TerminalExecResult with script stdout/stderr and exit code
    """
    if not conn.connected:
        return make_exec_result(-1, "", "not connected", 0)

    val start_us = rt_time_now_unix_micros()
    val result = relay_run_script(conn.config.script_path, command)
    val end_us = rt_time_now_unix_micros()
    val duration_ms = (end_us - start_us) / 1000

    make_exec_result(result.2, result.0, result.1, duration_ms)

fn relay_terminal_send(conn: TerminalConnection, data: text) -> bool:
    """Send data via the relay script.

    Invokes: config.script_path + " send " + data

    Args:
        conn: Active relay TerminalConnection
        data: Data to send

    Returns:
        true if script exited with code 0
    """
    if not conn.connected:
        return false

    val result = relay_run_script(conn.config.script_path, "send {data}")
    result.2 == 0

fn relay_terminal_receive(conn: TerminalConnection, timeout_ms: i64) -> text:
    """Receive data via the relay script.

    Invokes: config.script_path + " read"
    The timeout_ms is not directly enforced; the script itself should handle timing.

    Args:
        conn: Active relay TerminalConnection
        timeout_ms: Timeout hint (script should handle its own timing)

    Returns:
        stdout from the read script, or empty on failure
    """
    if not conn.connected:
        return ""

    val result = relay_run_script(conn.config.script_path, "read")
    if result.2 == 0:
        return result.0
    ""

fn relay_terminal_close(conn: TerminalConnection) -> bool:
    """Close a relay terminal connection.

    Marks the connection as disconnected. Since relay terminals are not
    persistent, no cleanup is needed.

    Args:
        conn: Relay TerminalConnection to close

    Returns:
        true (always succeeds for relay terminals)
    """
    if not conn.connected:
        return false
    true
