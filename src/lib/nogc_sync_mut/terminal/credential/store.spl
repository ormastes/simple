#![allow(star_import)]
# Credential Store - Encrypt/Decrypt Credentials for Terminal Configs
#
# Provides transparent credential encryption using AES-256-CBC with keys
# derived from a master passphrase via BCrypt KDF. Encrypted credentials
# are stored as "encrypted:<base64>" strings in SDN config files.
#
# Key storage: ~/.simple/credential_key (base64-encoded 32-byte AES key)
#
# Depends on:
#   - std.common.aes.modes (AES-CBC encrypt/decrypt)
#   - std.common.aes.utilities (byte/text conversions, key preparation)
#   - std.common.bcrypt.key_derivation (Eksblowfish key setup)
#   - std.common.base_encoding.base64 (base64 encode/decode)

use std.common.aes.modes.{aes_cbc_encrypt, aes_cbc_decrypt}
use std.common.aes.utilities.{text_to_bytes, bytes_to_text, prepare_key, generate_iv_from_seed, bytes_to_hex, hex_to_bytes}
use std.common.bcrypt.key_derivation.{eksblowfish_setup, blowfish_encrypt_block}
use std.common.base_encoding.base64.{base64_encode, base64_decode}

# ============================================================================
# FFI Declarations - File I/O
# ============================================================================

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

# ============================================================================
# Constants
# ============================================================================

val CREDENTIAL_PREFIX: text = "encrypted:"
val CREDENTIAL_KEY_FILENAME: text = "credential_key"
val CREDENTIAL_KEY_DIR: text = ".simple"
val BCRYPT_COST: i64 = 10          # 2^10 = 1024 rounds
val AES_KEY_SIZE: i64 = 32         # AES-256
val AES_IV_SIZE: i64 = 16          # 128-bit IV

# Fixed salt for BCrypt KDF (16 bytes as integers)
# In production, this should be randomly generated and stored alongside the key
val KDF_SALT: list[i64] = [83, 105, 109, 112, 108, 101, 75, 101, 121, 83, 97, 108, 116, 49, 50, 51]

# ============================================================================
# Key Path Resolution
# ============================================================================

fn credential_key_default_path() -> text:
    """Get the default credential key file path.

    Returns:
        Path to ~/.simple/credential_key

    Note: Uses $HOME environment variable to resolve home directory.
    """
    # Use extern to get home directory
    val home = rt_env_get_home()
    "{home}/{CREDENTIAL_KEY_DIR}/{CREDENTIAL_KEY_FILENAME}"

fn credential_key_resolve_path(key_path: text) -> text:
    """Resolve the credential key file path.

    If key_path is empty, returns the default path (~/.simple/credential_key).
    Otherwise returns key_path as-is.

    Args:
        key_path: Explicit key path or empty string for default

    Returns:
        Resolved key file path
    """
    if key_path == "":
        return credential_key_default_path()
    key_path

# ============================================================================
# Home directory helper (FFI)
# ============================================================================

extern fn rt_env_get_home() -> text

# ============================================================================
# Key Management
# ============================================================================

fn credential_key_exists(key_path: text) -> bool:
    """Check if a credential key file exists.

    Args:
        key_path: Path to key file, or empty for default (~/.simple/credential_key)

    Returns:
        true if the key file exists
    """
    val path = credential_key_resolve_path(key_path)
    rt_file_exists(path)

fn credential_key_generate(passphrase: text, key_path: text) -> bool:
    """Generate a credential key file from a passphrase.

    Derives a 256-bit AES key from the passphrase using BCrypt KDF
    (Eksblowfish with configurable cost), then stores the key as
    base64 in the key file.

    Args:
        passphrase: Master passphrase for key derivation
        key_path: Path to write key file, or empty for default

    Returns:
        true if key was generated and written successfully

    Example:
        if credential_key_generate("my_strong_passphrase", ""):
            print "Key generated at ~/.simple/credential_key"
    """
    if passphrase.length() == 0:
        return false

    val path = credential_key_resolve_path(key_path)

    # Derive key using BCrypt KDF (Eksblowfish)
    val state = eksblowfish_setup(passphrase, KDF_SALT, BCRYPT_COST)

    # Extract 32 bytes from the Blowfish state for AES-256 key
    # Encrypt the bcrypt magic string "OrpheanBeholderScryDoubt" (24 bytes = 3 blocks)
    val magic_words: list[list[i64]] = [[0x4F727068, 0x65616E42], [0x65686F6C, 0x64657253], [0x63727944, 0x6F756274]]

    var key_bytes: list[i64] = []
    var block_idx = 0
    while block_idx < 3:
        var left = magic_words[block_idx][0]
        var right = magic_words[block_idx][1]

        # Encrypt 64 times (standard bcrypt)
        var round = 0
        while round < 64:
            val encrypted = blowfish_encrypt_block(left, right, state)
            left = encrypted[0]
            right = encrypted[1]
            round = round + 1

        # Extract 8 bytes from this block (4 from left, 4 from right)
        key_bytes.push((left / 16777216) % 256)
        key_bytes.push((left / 65536) % 256)
        key_bytes.push((left / 256) % 256)
        key_bytes.push(left % 256)
        key_bytes.push((right / 16777216) % 256)
        key_bytes.push((right / 65536) % 256)
        key_bytes.push((right / 256) % 256)
        key_bytes.push(right % 256)

        block_idx = block_idx + 1

    # Take first 32 bytes for AES-256 key
    var aes_key: list[i64] = []
    var i = 0
    while i < AES_KEY_SIZE:
        if i < key_bytes.length():
            aes_key.push(key_bytes[i])
        else:
            aes_key.push(0)
        i = i + 1

    # Encode key as hex and write to file
    val key_hex = bytes_to_hex(aes_key)

    # Ensure directory exists (best-effort)
    val home = rt_env_get_home()
    val dir_path = "{home}/{CREDENTIAL_KEY_DIR}"
    rt_ensure_dir(dir_path)

    rt_file_write_text(path, key_hex)

extern fn rt_ensure_dir(path: text) -> bool

# ============================================================================
# Key Loading
# ============================================================================

fn credential_load_key(key_path: text) -> list[i64]:
    """Load AES key bytes from a credential key file.

    Args:
        key_path: Path to key file, or empty for default

    Returns:
        32-byte key as list of integers, or empty list on failure
    """
    val path = credential_key_resolve_path(key_path)
    if not rt_file_exists(path):
        return []

    val key_hex = rt_file_read_text(path)
    val trimmed = key_hex.trim()
    if trimmed.length() == 0:
        return []

    hex_to_bytes(trimmed)

# ============================================================================
# Encrypt / Decrypt
# ============================================================================

fn credential_encrypt(plaintext: text, key_path: text) -> text:
    """Encrypt a credential string for secure storage.

    Encrypts the plaintext using AES-256-CBC and returns a string in
    the format "encrypted:<hex_iv><hex_ciphertext>".

    Args:
        plaintext: Credential value to encrypt (e.g., password)
        key_path: Path to credential key file, or empty for default

    Returns:
        Encrypted string with "encrypted:" prefix, or empty on failure

    Example:
        val encrypted = credential_encrypt("my_password", "")
        # Returns: "encrypted:a1b2c3d4..."
    """
    if plaintext.length() == 0:
        return ""

    val key = credential_load_key(key_path)
    if key.length() == 0:
        return ""

    # Generate deterministic IV from plaintext hash (for reproducibility)
    # In production, use a random IV and prepend it to ciphertext
    var seed: i64 = 0
    val pt_bytes = text_to_bytes(plaintext)
    var i = 0
    while i < pt_bytes.length():
        seed = seed + pt_bytes[i] * (i + 1)
        i = i + 1
    val iv = generate_iv_from_seed(seed)

    # Encrypt with AES-256-CBC
    val ciphertext = aes_cbc_encrypt(pt_bytes, key, iv)

    # Encode: IV (hex) + ciphertext (hex)
    val iv_hex = bytes_to_hex(iv)
    val ct_hex = bytes_to_hex(ciphertext)

    "{CREDENTIAL_PREFIX}{iv_hex}{ct_hex}"

fn credential_decrypt(encrypted: text, key_path: text) -> text:
    """Decrypt an encrypted credential string.

    Expects input in format "encrypted:<hex_iv><hex_ciphertext>" as
    produced by credential_encrypt().

    Args:
        encrypted: Encrypted credential string with "encrypted:" prefix
        key_path: Path to credential key file, or empty for default

    Returns:
        Decrypted plaintext string, or empty on failure

    Example:
        val password = credential_decrypt("encrypted:a1b2c3d4...", "")
    """
    if not encrypted.starts_with(CREDENTIAL_PREFIX):
        return ""

    val key = credential_load_key(key_path)
    if key.length() == 0:
        return ""

    # Strip prefix
    val payload = encrypted[CREDENTIAL_PREFIX.length()..]

    if payload.length() < (AES_IV_SIZE * 2 + 2):
        return ""

    # Extract IV (first 32 hex chars = 16 bytes)
    val iv_hex_len = AES_IV_SIZE * 2
    val iv_hex = payload[0..iv_hex_len]
    val ct_hex = payload[iv_hex_len..]

    val iv = hex_to_bytes(iv_hex)
    val ciphertext = hex_to_bytes(ct_hex)

    if iv.length() != AES_IV_SIZE:
        return ""
    if ciphertext.length() == 0:
        return ""

    # Decrypt with AES-256-CBC
    val plaintext_bytes = aes_cbc_decrypt(ciphertext, key, iv)

    bytes_to_text(plaintext_bytes)

# ============================================================================
# Transparent Resolution
# ============================================================================

fn credential_resolve(value: text) -> text:
    """Resolve a credential value, decrypting if necessary.

    If the value starts with "encrypted:", it is decrypted using the
    default credential key. Otherwise the value is returned as-is.

    This allows config files to contain either plaintext or encrypted
    credentials transparently.

    Args:
        value: Credential value (plaintext or "encrypted:..." format)

    Returns:
        Resolved plaintext credential

    Example:
        # Works with both forms:
        credential_resolve("plaintext_password")       # Returns: "plaintext_password"
        credential_resolve("encrypted:a1b2c3...")       # Returns: decrypted value
    """
    if value.starts_with(CREDENTIAL_PREFIX):
        return credential_decrypt(value, "")
    value

fn credential_is_encrypted(value: text) -> bool:
    """Check if a credential value is in encrypted format.

    Args:
        value: Credential string to check

    Returns:
        true if value starts with "encrypted:" prefix
    """
    value.starts_with(CREDENTIAL_PREFIX)
