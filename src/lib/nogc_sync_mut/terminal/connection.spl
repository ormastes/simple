#![allow(star_import)]
# Terminal Connection Dispatch Layer
#
# Routes terminal operations to the correct implementation based on
# the connection's kind field (TERM_KIND_SSH, TERM_KIND_TELNET,
# TERM_KIND_T32_SWD, TERM_KIND_RELAY).
#
# This is the primary API for terminal consumers. Callers use these
# functions instead of the per-implementation modules directly.
#
# Depends on:
#   - std.terminal.types (TerminalConfig, TerminalConnection, TerminalExecResult, kind constants)
#   - std.terminal.ssh_terminal (SSH implementation)
#   - std.terminal.telnet_terminal (Telnet implementation)
#   - std.terminal.t32_swd_terminal (T32 SWD serial implementation)
#   - std.terminal.relay_terminal (Relay script implementation)

use std.nogc_sync_mut.terminal.types.*
use std.nogc_sync_mut.terminal.ssh_terminal.*
use std.nogc_sync_mut.terminal.telnet_terminal.*
use std.nogc_sync_mut.terminal.t32_swd_terminal.*
use std.nogc_sync_mut.terminal.relay_terminal.*

# ============================================================================
# Dispatch: Connect
# ============================================================================

fn terminal_connect(config: TerminalConfig) -> TerminalConnection:
    """Connect to a terminal using the appropriate implementation.

    Dispatches by config.kind to the correct backend:
    - TERM_KIND_SSH (0): SSH2 protocol
    - TERM_KIND_TELNET (1): RFC 854 telnet
    - TERM_KIND_T32_SWD (2): TRACE32 SWD serial TERM window
    - TERM_KIND_RELAY (3): Script-based relay

    Args:
        config: Terminal configuration specifying kind and connection params

    Returns:
        TerminalConnection (check connected field for success)

    Example:
        val cfg = make_ssh_config("host1", "192.168.1.100", 22, "admin", "password", "secret")
        val conn = terminal_connect(cfg)
        if conn.connected:
            val result = terminal_execute(conn, "uname -a")
            print result.stdout
            terminal_close(conn)
    """
    if config.kind == TERM_KIND_SSH:
        return ssh_terminal_connect(config)

    if config.kind == TERM_KIND_TELNET:
        return telnet_terminal_connect(config)

    if config.kind == TERM_KIND_T32_SWD:
        return t32_swd_connect(config)

    if config.kind == TERM_KIND_RELAY:
        return relay_terminal_connect(config)

    # Unknown kind -- return disconnected
    TerminalConnection(
        id: 0,
        kind: config.kind,
        config: config,
        connected: false,
        session_handle: 0,
        channel_handle: 0
    )

# ============================================================================
# Dispatch: Execute
# ============================================================================

fn terminal_execute(conn: TerminalConnection, command: text) -> TerminalExecResult:
    """Execute a command on the terminal.

    Dispatches to the correct implementation based on conn.kind.
    Returns structured results with exit_code, stdout, stderr, and duration.

    Args:
        conn: Active TerminalConnection
        command: Command to execute

    Returns:
        TerminalExecResult with execution output and timing
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_execute(conn, command)

    if conn.kind == TERM_KIND_TELNET:
        return telnet_terminal_execute(conn, command)

    if conn.kind == TERM_KIND_T32_SWD:
        return t32_swd_execute(conn, command)

    if conn.kind == TERM_KIND_RELAY:
        return relay_terminal_execute(conn, command)

    make_exec_result(-1, "", "unknown terminal kind: {conn.kind}", 0)

# ============================================================================
# Dispatch: Send
# ============================================================================

fn terminal_send(conn: TerminalConnection, data: text) -> bool:
    """Send data to the terminal.

    For SSH: writes to the interactive shell channel.
    For Telnet: sends text with CR+LF.
    For T32 SWD: sends via TERM.Out PRACTICE command.
    For Relay: invokes script with "send" argument.

    Args:
        conn: Active TerminalConnection
        data: Text data to send

    Returns:
        true if send was successful
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_send(conn, data)

    if conn.kind == TERM_KIND_TELNET:
        return telnet_terminal_send(conn, data)

    if conn.kind == TERM_KIND_T32_SWD:
        return t32_swd_send(conn, data)

    if conn.kind == TERM_KIND_RELAY:
        return relay_terminal_send(conn, data)

    false

# ============================================================================
# Dispatch: Receive
# ============================================================================

fn terminal_receive(conn: TerminalConnection, timeout_ms: i64) -> text:
    """Receive data from the terminal.

    For SSH: reads from the interactive shell channel.
    For Telnet: reads with IAC stripping.
    For T32 SWD: captures TERM window text via WinPrint.
    For Relay: invokes script with "read" argument.

    Args:
        conn: Active TerminalConnection
        timeout_ms: Read timeout in milliseconds

    Returns:
        Received text, or empty string on timeout/error
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_receive(conn, timeout_ms)

    if conn.kind == TERM_KIND_TELNET:
        return telnet_terminal_receive(conn, timeout_ms)

    if conn.kind == TERM_KIND_T32_SWD:
        return t32_swd_receive(conn, timeout_ms)

    if conn.kind == TERM_KIND_RELAY:
        return relay_terminal_receive(conn, timeout_ms)

    ""

# ============================================================================
# Dispatch: Close
# ============================================================================

fn terminal_close(conn: TerminalConnection) -> bool:
    """Close a terminal connection.

    Disconnects and releases resources for the terminal connection.

    Args:
        conn: TerminalConnection to close

    Returns:
        true if connection was closed successfully
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_close(conn)

    if conn.kind == TERM_KIND_TELNET:
        return telnet_terminal_close(conn)

    if conn.kind == TERM_KIND_T32_SWD:
        return t32_swd_close(conn)

    if conn.kind == TERM_KIND_RELAY:
        return relay_terminal_close(conn)

    false

# ============================================================================
# Utility: Is Connected
# ============================================================================

fn terminal_is_connected(conn: TerminalConnection) -> bool:
    """Check if a terminal connection is currently active.

    Args:
        conn: TerminalConnection to check

    Returns:
        true if the connection is marked as connected
    """
    conn.connected

# ============================================================================
# Dispatch: Upload (SSH only)
# ============================================================================

fn terminal_upload(conn: TerminalConnection, local_path: text, remote_path: text) -> bool:
    """Upload a file to the remote terminal host.

    Only supported for SSH terminals (uses SFTP). Returns false for all
    other terminal kinds.

    Args:
        conn: Active TerminalConnection (must be SSH)
        local_path: Local file path to upload
        remote_path: Destination path on remote host

    Returns:
        true if upload was successful, false if unsupported or failed
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_upload(conn, local_path, remote_path)

    # Upload not supported for non-SSH terminals
    false

# ============================================================================
# Dispatch: Download (SSH only)
# ============================================================================

fn terminal_download(conn: TerminalConnection, remote_path: text, local_path: text) -> bool:
    """Download a file from the remote terminal host.

    Only supported for SSH terminals (uses SFTP). Returns false for all
    other terminal kinds.

    Args:
        conn: Active TerminalConnection (must be SSH)
        remote_path: Remote file path to download
        local_path: Local destination path

    Returns:
        true if download was successful, false if unsupported or failed
    """
    if conn.kind == TERM_KIND_SSH:
        return ssh_terminal_download(conn, remote_path, local_path)

    # Download not supported for non-SSH terminals
    false
