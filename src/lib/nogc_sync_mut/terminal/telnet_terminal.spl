#![allow(star_import)]
# Telnet Terminal - Wraps net/telnet.spl for the unified terminal abstraction
#
# Provides telnet terminal operations (connect, execute, send, receive, close)
# using the TelnetConnection type from net/telnet.spl.
# Authentication via telnet_login() prompt detection when username/password provided.
#
# Depends on:
#   - std.net.telnet (RFC 854 telnet client)
#   - std.terminal.types (TerminalConfig, TerminalConnection, TerminalExecResult)
#   - std.terminal.credential.store (credential_resolve for encrypted passwords)

use std.net.telnet.*
use std.nogc_sync_mut.terminal.types.*
use std.nogc_sync_mut.terminal.credential.store.{credential_resolve}

# ============================================================================
# FFI - Timing
# ============================================================================

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Connection State
# ============================================================================

# We store the underlying TelnetConnection handles mapped by terminal connection ID.
# Since Simple does not have global mutable maps easily, we use parallel arrays.

var telnet_conn_ids: [i64] = []
var telnet_conn_handles: [TelnetConnection] = []
var telnet_conn_id_counter: i64 = 0

val TELNET_DEFAULT_TIMEOUT_MS: i64 = 5000

# ============================================================================
# Internal Helpers
# ============================================================================

fn telnet_store_handle(id: i64, tc: TelnetConnection):
    """Store a TelnetConnection handle associated with a terminal connection ID."""
    telnet_conn_ids.push(id)
    telnet_conn_handles.push(tc)

fn telnet_find_handle(id: i64) -> TelnetConnection:
    """Find the TelnetConnection handle for a given terminal connection ID.

    Returns the matching TelnetConnection, or a disconnected placeholder on not-found.
    """
    var i = 0
    while i < telnet_conn_ids.length():
        if telnet_conn_ids[i] == id:
            return telnet_conn_handles[i]
        i = i + 1
    # Return a disconnected placeholder — caller checks connected field
    TelnetConnection(
        stream: TcpStream(handle: 0, connected: false),
        connected: false,
        echo_enabled: false,
        sga_enabled: false
    )

# ============================================================================
# Telnet Terminal Operations
# ============================================================================

fn telnet_terminal_connect(config: TerminalConfig) -> TerminalConnection:
    """Connect to a telnet server and optionally authenticate.

    If config.username and config.credential are non-empty, performs telnet_login()
    with prompt-based username/password detection.

    Args:
        config: TerminalConfig with kind == TERM_KIND_TELNET

    Returns:
        TerminalConnection with connected=true on success, connected=false on failure

    Example:
        val cfg = make_telnet_config("switch", "192.168.1.200", 23)
        val conn = telnet_terminal_connect(cfg)
    """
    telnet_conn_id_counter = telnet_conn_id_counter + 1
    val id = telnet_conn_id_counter

    val result = telnet_connect(config.host, config.port, TELNET_DEFAULT_TIMEOUT_MS)
    match result:
        Err(e):
            return TerminalConnection(
                id: id,
                kind: TERM_KIND_TELNET,
                config: config,
                connected: false,
                session_handle: 0,
                channel_handle: 0
            )
        Ok(tc):
            # Authenticate if credentials provided
            if config.username.length() > 0 and config.credential.length() > 0:
                val password = credential_resolve(config.credential)
                val login_ok = telnet_login(tc, config.username, password, TELNET_DEFAULT_TIMEOUT_MS)
                if not login_ok:
                    telnet_close(tc)
                    return TerminalConnection(
                        id: id,
                        kind: TERM_KIND_TELNET,
                        config: config,
                        connected: false,
                        session_handle: 0,
                        channel_handle: 0
                    )

            # Store the TelnetConnection handle for later retrieval
            telnet_store_handle(id, tc)

            TerminalConnection(
                id: id,
                kind: TERM_KIND_TELNET,
                config: config,
                connected: true,
                session_handle: id,
                channel_handle: 0
            )

fn telnet_terminal_execute(conn: TerminalConnection, command: text) -> TerminalExecResult:
    """Execute a command on the telnet server.

    Sends the command and waits for a shell prompt to indicate completion.
    Since telnet has no structured exit code, exit_code is always 0 on success.

    Args:
        conn: Active telnet TerminalConnection
        command: Command to execute

    Returns:
        TerminalExecResult with stdout from command output
    """
    if not conn.connected:
        return make_exec_result(-1, "", "not connected", 0)

    val tc = telnet_find_handle(conn.id)
    if not tc.connected:
        return make_exec_result(-1, "", "telnet handle not found", 0)

    val start_us = rt_time_now_unix_micros()
    val output = telnet_command(tc, command, TELNET_DEFAULT_TIMEOUT_MS)
    val end_us = rt_time_now_unix_micros()
    val duration_ms = (end_us - start_us) / 1000

    make_exec_result(0, output, "", duration_ms)

fn telnet_terminal_send(conn: TerminalConnection, data: text) -> bool:
    """Send raw text data to the telnet server.

    Args:
        conn: Active telnet TerminalConnection
        data: Text data to send (CR+LF appended automatically by telnet_send)

    Returns:
        true if send was successful
    """
    if not conn.connected:
        return false

    val tc = telnet_find_handle(conn.id)
    if not tc.connected:
        return false

    telnet_send(tc, data)

fn telnet_terminal_receive(conn: TerminalConnection, timeout_ms: i64) -> text:
    """Receive data from the telnet server.

    Args:
        conn: Active telnet TerminalConnection
        timeout_ms: Read timeout in milliseconds

    Returns:
        Received text with IAC sequences stripped, or empty on timeout
    """
    if not conn.connected:
        return ""

    val tc = telnet_find_handle(conn.id)
    if not tc.connected:
        return ""

    telnet_receive(tc, timeout_ms)

fn telnet_terminal_close(conn: TerminalConnection) -> bool:
    """Close a telnet terminal connection.

    Args:
        conn: Telnet TerminalConnection to close

    Returns:
        true if connection was closed successfully
    """
    if not conn.connected:
        return false

    val tc = telnet_find_handle(conn.id)
    if not tc.connected:
        return false

    telnet_close(tc)
