# LDAP (RFC 4511) typed structures + wire-dispatch integer constants.
#
# MDSOC: feature dimension, network application layer (email/directory).
# LDAP rides ASN.1 BER over TCP. The BER primitives live in
# std.common.net.ber; this module adds the LDAP-specific APPLICATION /
# CONTEXT class tags and the protocol-operation structs.
#
# DESIGN: operation tags, result codes, scope, deref and filter kinds are
# INTEGER CONSTANTS, never payload-carrying enums.  Carrying these as enum
# payloads miscompiles under the JIT (known integer-constant-dispatch bug),
# so dispatch is always over plain i64 constants and the Filter type holds an
# i64 `kind` tag rather than a variant.
#
# BUG(cross_module_match_arm_array_mutation_no_propagate): helpers that push
# into a [u8] arg do not propagate across a cross-module call.  All byte
# builders here are RETURN-STYLE (out = helper(out)).
# BUG(cross_module_struct_literal_push_array_nil): Type(field: push_built_arr)
# yields nil arrays cross-module; use Type.new(...) positional constructors.

use std.common.net.oid.{Oid}

# =============================================================================
# Wire tag bytes — RFC 4511 §4 (APPLICATION class, constructed unless noted)
# =============================================================================

val LDAP_TAG_BIND_REQUEST: u8 = 0x60       # [APPLICATION 0] constructed
val LDAP_TAG_BIND_RESPONSE: u8 = 0x61      # [APPLICATION 1] constructed
val LDAP_TAG_UNBIND_REQUEST: u8 = 0x42     # [APPLICATION 2] primitive (NULL)
val LDAP_TAG_SEARCH_REQUEST: u8 = 0x63     # [APPLICATION 3] constructed
val LDAP_TAG_SEARCH_RES_ENTRY: u8 = 0x64   # [APPLICATION 4] constructed
val LDAP_TAG_SEARCH_RES_DONE: u8 = 0x65    # [APPLICATION 5] constructed

# AuthenticationChoice — [0] simple password (primitive context tag)
val LDAP_TAG_AUTH_SIMPLE: u8 = 0x80        # [CONTEXT 0] primitive

# Filter context tags — RFC 4511 §4.5.1
val LDAP_FILTER_TAG_AND: u8 = 0xA0          # [CONTEXT 0] constructed
val LDAP_FILTER_TAG_OR: u8 = 0xA1           # [CONTEXT 1] constructed
val LDAP_FILTER_TAG_NOT: u8 = 0xA2          # [CONTEXT 2] constructed
val LDAP_FILTER_TAG_EQUALITY: u8 = 0xA3     # [CONTEXT 3] constructed (AVA)
val LDAP_FILTER_TAG_PRESENT: u8 = 0x87      # [CONTEXT 7] primitive

# ENUMERATED universal tag (scope / derefAliases / resultCode use this, NOT INTEGER)
val LDAP_TAG_ENUMERATED: u8 = 0x0A

# =============================================================================
# Integer constants — operation kind (mirror of the tag set, for dispatch)
# =============================================================================

val LDAP_OP_BIND_REQUEST: i64 = 0
val LDAP_OP_BIND_RESPONSE: i64 = 1
val LDAP_OP_UNBIND_REQUEST: i64 = 2
val LDAP_OP_SEARCH_REQUEST: i64 = 3
val LDAP_OP_SEARCH_RES_ENTRY: i64 = 4
val LDAP_OP_SEARCH_RES_DONE: i64 = 5
val LDAP_OP_UNKNOWN: i64 = -1

# =============================================================================
# Result codes — RFC 4511 §4.1.9 (subset)
# =============================================================================

val LDAP_RESULT_SUCCESS: i64 = 0
val LDAP_RESULT_OPERATIONS_ERROR: i64 = 1
val LDAP_RESULT_PROTOCOL_ERROR: i64 = 2
val LDAP_RESULT_TIME_LIMIT_EXCEEDED: i64 = 3
val LDAP_RESULT_SIZE_LIMIT_EXCEEDED: i64 = 4
val LDAP_RESULT_COMPARE_FALSE: i64 = 5
val LDAP_RESULT_COMPARE_TRUE: i64 = 6
val LDAP_RESULT_AUTH_METHOD_NOT_SUPPORTED: i64 = 7
val LDAP_RESULT_STRONGER_AUTH_REQUIRED: i64 = 8
val LDAP_RESULT_NO_SUCH_ATTRIBUTE: i64 = 16
val LDAP_RESULT_UNDEFINED_ATTRIBUTE_TYPE: i64 = 17
val LDAP_RESULT_INVALID_ATTRIBUTE_SYNTAX: i64 = 21
val LDAP_RESULT_NO_SUCH_OBJECT: i64 = 32
val LDAP_RESULT_INVALID_DN_SYNTAX: i64 = 34
val LDAP_RESULT_INVALID_CREDENTIALS: i64 = 49
val LDAP_RESULT_INSUFFICIENT_ACCESS_RIGHTS: i64 = 50
val LDAP_RESULT_BUSY: i64 = 51
val LDAP_RESULT_UNAVAILABLE: i64 = 52
val LDAP_RESULT_ENTRY_ALREADY_EXISTS: i64 = 68
val LDAP_RESULT_OTHER: i64 = 80

# =============================================================================
# Scope — RFC 4511 §4.5.1 (ENUMERATED)
# =============================================================================

val LDAP_SCOPE_BASE_OBJECT: i64 = 0
val LDAP_SCOPE_SINGLE_LEVEL: i64 = 1
val LDAP_SCOPE_WHOLE_SUBTREE: i64 = 2

# =============================================================================
# DerefAliases — RFC 4511 §4.5.1 (ENUMERATED)
# =============================================================================

val LDAP_DEREF_NEVER: i64 = 0
val LDAP_DEREF_IN_SEARCHING: i64 = 1
val LDAP_DEREF_FINDING_BASE_OBJ: i64 = 2
val LDAP_DEREF_ALWAYS: i64 = 3

# =============================================================================
# Filter kind — INTEGER tags (struct field, not enum payload)
# =============================================================================

val LDAP_FILTER_AND: i64 = 0
val LDAP_FILTER_OR: i64 = 1
val LDAP_FILTER_NOT: i64 = 2
val LDAP_FILTER_EQUALITY: i64 = 3
val LDAP_FILTER_PRESENT: i64 = 7

# =============================================================================
# Auth method — INTEGER tag
# =============================================================================

val LDAP_AUTH_SIMPLE: i64 = 0
val LDAP_AUTH_SASL: i64 = 3

# =============================================================================
# Structs
# =============================================================================

struct LdapDn:
    """Distinguished Name string (RFC 4514)."""
    value: text

impl LdapDn:
    static fn new(v: text) -> LdapDn:
        LdapDn(value: v)

struct LdapAttribute:
    """An attribute type with its raw byte values."""
    attr_type: text
    values: [[u8]]

impl LdapAttribute:
    static fn new(attr_type: text, values: [[u8]]) -> LdapAttribute:
        LdapAttribute(attr_type: attr_type, values: values)

struct LdapEntry:
    """A SearchResultEntry: a DN plus its attributes."""
    dn: LdapDn
    attributes: [LdapAttribute]

impl LdapEntry:
    static fn new(dn: LdapDn, attributes: [LdapAttribute]) -> LdapEntry:
        LdapEntry(dn: dn, attributes: attributes)

# Filter is a recursive tree.  `kind` is an i64 constant (LDAP_FILTER_*).
# Leaf types (equality, present) use `attribute` / `value`.
# Compound types (and/or/not) use `children`.
struct LdapFilter:
    kind: i64
    attribute: text
    value: [u8]
    children: [LdapFilter]

impl LdapFilter:
    static fn new(kind: i64, attribute: text, value: [u8], children: [LdapFilter]) -> LdapFilter:
        LdapFilter(kind: kind, attribute: attribute, value: value, children: children)

    static fn equality(attribute: text, value: [u8]) -> LdapFilter:
        LdapFilter(kind: LDAP_FILTER_EQUALITY, attribute: attribute, value: value, children: [])

    static fn present(attribute: text) -> LdapFilter:
        LdapFilter(kind: LDAP_FILTER_PRESENT, attribute: attribute, value: [], children: [])

    static fn and_of(children: [LdapFilter]) -> LdapFilter:
        LdapFilter(kind: LDAP_FILTER_AND, attribute: "", value: [], children: children)

    static fn or_of(children: [LdapFilter]) -> LdapFilter:
        LdapFilter(kind: LDAP_FILTER_OR, attribute: "", value: [], children: children)

    static fn not_of(child: LdapFilter) -> LdapFilter:
        LdapFilter(kind: LDAP_FILTER_NOT, attribute: "", value: [], children: [child])

struct LdapResult:
    """Common result fields shared by Bind/Search-Done responses."""
    code: i64
    matched_dn: LdapDn
    diagnostic_message: text

impl LdapResult:
    static fn new(code: i64, matched_dn: LdapDn, diagnostic_message: text) -> LdapResult:
        LdapResult(code: code, matched_dn: matched_dn, diagnostic_message: diagnostic_message)

struct LdapBindRequest:
    version: i64          # must be 3
    name: LdapDn
    auth_method: i64      # LDAP_AUTH_SIMPLE
    password: [u8]        # simple-auth password bytes

impl LdapBindRequest:
    static fn new(version: i64, name: LdapDn, auth_method: i64, password: [u8]) -> LdapBindRequest:
        LdapBindRequest(version: version, name: name, auth_method: auth_method, password: password)

    static fn simple(name: text, password: [u8]) -> LdapBindRequest:
        LdapBindRequest(version: 3, name: LdapDn.new(name), auth_method: LDAP_AUTH_SIMPLE, password: password)

struct LdapBindResponse:
    result: LdapResult

impl LdapBindResponse:
    static fn new(result: LdapResult) -> LdapBindResponse:
        LdapBindResponse(result: result)

struct LdapSearchRequest:
    base_dn: LdapDn
    scope: i64
    deref_aliases: i64
    size_limit: i64
    time_limit: i64
    types_only: bool
    filter: LdapFilter
    attributes: [text]

impl LdapSearchRequest:
    static fn new(base_dn: LdapDn, scope: i64, deref_aliases: i64, size_limit: i64, time_limit: i64, types_only: bool, filter: LdapFilter, attributes: [text]) -> LdapSearchRequest:
        LdapSearchRequest(base_dn: base_dn, scope: scope, deref_aliases: deref_aliases, size_limit: size_limit, time_limit: time_limit, types_only: types_only, filter: filter, attributes: attributes)

struct LdapSearchResultDone:
    result: LdapResult

impl LdapSearchResultDone:
    static fn new(result: LdapResult) -> LdapSearchResultDone:
        LdapSearchResultDone(result: result)

struct LdapUnbindRequest:
    """UnbindRequest carries no fields ([APPLICATION 2] NULL)."""
    placeholder: i64

impl LdapUnbindRequest:
    static fn new() -> LdapUnbindRequest:
        LdapUnbindRequest(placeholder: 0)

struct LdapControl:
    oid: Oid
    criticality: bool
    value: [u8]

impl LdapControl:
    static fn new(oid: Oid, criticality: bool, value: [u8]) -> LdapControl:
        LdapControl(oid: oid, criticality: criticality, value: value)

# LDAPMessage envelope: message_id + a protocol-op identified by op_tag.
# `protocol_op` holds the raw BER bytes of the op (tag+length+content), so the
# envelope decode never has to know the full op grammar.  `controls` optional.
struct LdapMessage:
    message_id: i64
    op_kind: i64          # LDAP_OP_* constant
    protocol_op: [u8]     # raw TLV bytes of the operation
    controls: [LdapControl]

impl LdapMessage:
    static fn new(message_id: i64, op_kind: i64, protocol_op: [u8], controls: [LdapControl]) -> LdapMessage:
        LdapMessage(message_id: message_id, op_kind: op_kind, protocol_op: protocol_op, controls: controls)

struct LdapSession:
    server_host: text
    server_port: i64
    next_message_id: i64
    bound_dn: LdapDn

impl LdapSession:
    static fn new(server_host: text, server_port: i64) -> LdapSession:
        LdapSession(server_host: server_host, server_port: server_port, next_message_id: 1, bound_dn: LdapDn.new(""))

# Map an APPLICATION tag byte to its op-kind constant.
fn ldap_op_kind_of_tag(tag_byte: u8) -> i64:
    if tag_byte == LDAP_TAG_BIND_REQUEST:
        return LDAP_OP_BIND_REQUEST
    elif tag_byte == LDAP_TAG_BIND_RESPONSE:
        return LDAP_OP_BIND_RESPONSE
    elif tag_byte == LDAP_TAG_UNBIND_REQUEST:
        return LDAP_OP_UNBIND_REQUEST
    elif tag_byte == LDAP_TAG_SEARCH_REQUEST:
        return LDAP_OP_SEARCH_REQUEST
    elif tag_byte == LDAP_TAG_SEARCH_RES_ENTRY:
        return LDAP_OP_SEARCH_RES_ENTRY
    elif tag_byte == LDAP_TAG_SEARCH_RES_DONE:
        return LDAP_OP_SEARCH_RES_DONE
    else:
        return LDAP_OP_UNKNOWN

export LDAP_TAG_BIND_REQUEST
export LDAP_TAG_BIND_RESPONSE
export LDAP_TAG_UNBIND_REQUEST
export LDAP_TAG_SEARCH_REQUEST
export LDAP_TAG_SEARCH_RES_ENTRY
export LDAP_TAG_SEARCH_RES_DONE
export LDAP_TAG_AUTH_SIMPLE
export LDAP_FILTER_TAG_AND
export LDAP_FILTER_TAG_OR
export LDAP_FILTER_TAG_NOT
export LDAP_FILTER_TAG_EQUALITY
export LDAP_FILTER_TAG_PRESENT
export LDAP_TAG_ENUMERATED
export LDAP_OP_BIND_REQUEST
export LDAP_OP_BIND_RESPONSE
export LDAP_OP_UNBIND_REQUEST
export LDAP_OP_SEARCH_REQUEST
export LDAP_OP_SEARCH_RES_ENTRY
export LDAP_OP_SEARCH_RES_DONE
export LDAP_OP_UNKNOWN
export LDAP_RESULT_SUCCESS
export LDAP_RESULT_OPERATIONS_ERROR
export LDAP_RESULT_PROTOCOL_ERROR
export LDAP_RESULT_TIME_LIMIT_EXCEEDED
export LDAP_RESULT_SIZE_LIMIT_EXCEEDED
export LDAP_RESULT_COMPARE_FALSE
export LDAP_RESULT_COMPARE_TRUE
export LDAP_RESULT_AUTH_METHOD_NOT_SUPPORTED
export LDAP_RESULT_STRONGER_AUTH_REQUIRED
export LDAP_RESULT_NO_SUCH_ATTRIBUTE
export LDAP_RESULT_UNDEFINED_ATTRIBUTE_TYPE
export LDAP_RESULT_INVALID_ATTRIBUTE_SYNTAX
export LDAP_RESULT_NO_SUCH_OBJECT
export LDAP_RESULT_INVALID_DN_SYNTAX
export LDAP_RESULT_INVALID_CREDENTIALS
export LDAP_RESULT_INSUFFICIENT_ACCESS_RIGHTS
export LDAP_RESULT_BUSY
export LDAP_RESULT_UNAVAILABLE
export LDAP_RESULT_ENTRY_ALREADY_EXISTS
export LDAP_RESULT_OTHER
export LDAP_SCOPE_BASE_OBJECT
export LDAP_SCOPE_SINGLE_LEVEL
export LDAP_SCOPE_WHOLE_SUBTREE
export LDAP_DEREF_NEVER
export LDAP_DEREF_IN_SEARCHING
export LDAP_DEREF_FINDING_BASE_OBJ
export LDAP_DEREF_ALWAYS
export LDAP_FILTER_AND
export LDAP_FILTER_OR
export LDAP_FILTER_NOT
export LDAP_FILTER_EQUALITY
export LDAP_FILTER_PRESENT
export LDAP_AUTH_SIMPLE
export LDAP_AUTH_SASL
