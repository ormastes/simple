# LDAPS — thin secure wrapper over LDAP + TLS.
# RFC 4511 §4.14 (StartTLS extended operation), implicit TLS on port 636.
#
# NOTE: TlsSessionHandle is a placeholder (fd-based) matching the other secure
# wrappers (see imap/secure.spl).  The TLS module (src/lib/nogc_sync_mut/tls/)
# is currently stateless hex-string functions with no wire session type, so
# this wrapper only establishes the composition shape — it introduces ZERO new
# wire types, exactly as the design note requires.
#
# FINDING: tls_session_type_missing_2026-06-15 — see doc/08_tracking/bug/

use std.nogc_sync_mut.ldap.types.{LdapSession, LdapDn}

val LDAPS_DEFAULT_PORT: i64 = 636
val LDAP_DEFAULT_PORT: i64 = 389
val LDAP_STARTTLS_OID: text = "1.3.6.1.4.1.1466.20037"

export LDAPS_DEFAULT_PORT
export LDAP_DEFAULT_PORT
export LDAP_STARTTLS_OID

fn ldaps_default_port() -> i64: LDAPS_DEFAULT_PORT
fn ldap_default_port() -> i64: LDAP_DEFAULT_PORT
fn ldap_starttls_oid() -> text: LDAP_STARTTLS_OID

# Placeholder TLS session handle (opaque, fd-based).
struct TlsSessionHandle:
    fd: i64

impl TlsSessionHandle:
    static fn new(fd: i64) -> TlsSessionHandle:
        TlsSessionHandle(fd: fd)

# LdapsSession — composition of TLS handle + LDAP cleartext session.
struct LdapsSession:
    tls: TlsSessionHandle
    ldap: LdapSession
    starttls_pending: bool   # true = StartTLS upgrade not yet completed

impl LdapsSession:
    # Implicit-TLS session (port 636): secure from the first byte.
    static fn new(fd: i64, host: text) -> LdapsSession:
        val handle = TlsSessionHandle.new(fd)
        val session = LdapSession.new(host, LDAPS_DEFAULT_PORT)
        LdapsSession(tls: handle, ldap: session, starttls_pending: false)

    # StartTLS session (port 389): cleartext until the StartTLS exop completes.
    static fn new_starttls(fd: i64, host: text) -> LdapsSession:
        val handle = TlsSessionHandle.new(fd)
        val session = LdapSession.new(host, LDAP_DEFAULT_PORT)
        LdapsSession(tls: handle, ldap: session, starttls_pending: true)

    fn ldap_session() -> LdapSession:
        self.ldap

    fn is_secure() -> bool:
        not self.starttls_pending
