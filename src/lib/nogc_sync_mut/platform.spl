# Platform Abstraction Layer
#
# Provides convenient platform-agnostic functions for:
# - Platform detection (Windows/Unix/macOS/Linux)
# - Path handling (separators, normalization) - delegates to std.path
# - Command resolution (executable extensions)
#
# Pure Simple implementation using shell commands (uname) for platform detection.
# Uses direct extern fn calls to avoid bootstrap runtime import issues.

extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

# Import the canonical path module as an owner, not function aliases. Native
# entry-closure lowering must retain the concrete module-qualified definitions;
# aliased imports were emitted as unresolved globals such as
# `_path_normalize_path` and silently weak-stubbed in hosted applications.
use nogc_sync_mut.path
use nogc_sync_mut.target_ext.{target_lib_ext, target_exe_ext}

# Re-export path operations from std.path

# ===========================================================================
# Platform Detection - Pure Simple Implementation
# ===========================================================================

fn shell_output_trim(command: text) -> text:
    """Run shell command and return trimmed stdout."""
    val result = rt_process_run("/bin/sh", ["-c", command])
    val stdout = result[0]
    val code = result[2]
    if code == 0:
        stdout.trim()
    else:
        ""

fn is_windows_env() -> bool:
    """Check if running on Windows by checking OS environment variable."""
    val os_env = rt_env_get("OS")
    if os_env == nil:
        false  # Default to Unix/Linux
    else:
        val os_lower = os_env.lower()
        os_lower.contains("windows")

pub fn host_os() -> text:
    """Internal helper to get host OS using Pure Simple implementation."""
    if is_windows_env():
        "windows"
    else:
        # Unix: Use uname -s
        val os = shell_output_trim("uname -s")
        if os.len() == 0:
            "linux"  # Default
        else:
            match os:
                case "Linux": "linux"
                case "Darwin": "macos"
                case "FreeBSD": "freebsd"
                case "OpenBSD": "openbsd"
                case "NetBSD": "netbsd"
                case _: os.lower()

pub fn host_arch() -> text:
    """Get host CPU architecture using Pure Simple implementation."""
    if is_windows_env():
        # Windows: Use PROCESSOR_ARCHITECTURE env var
        val arch_env = rt_env_get("PROCESSOR_ARCHITECTURE")
        if arch_env == nil:
            "x86_64"  # Default
        else:
            match arch_env:
                case "AMD64": "x86_64"
                case "ARM64": "aarch64"
                case "x86": "i686"
                case _: arch_env.lower()
    else:
        # Unix: Use uname -m
        val arch = shell_output_trim("uname -m")
        if arch.len() == 0:
            "x86_64"  # Default
        else:
            match arch:
                case "x86_64": "x86_64"
                case "amd64": "x86_64"
                case "arm64": "aarch64"
                case "aarch64": "aarch64"
                case "riscv64": "riscv64"
                case "i686": "i686"
                case "i386": "i686"
                case _: arch

# Deprecated: use host_os instead
pub fn get_host_os() -> text:
    host_os()
# Deprecated: use host_arch instead
pub fn get_host_arch() -> text:
    host_arch()

pub fn is_windows() -> bool:
    """Returns true if running on Windows."""
    host_os() == "windows"

pub fn is_unix() -> bool:
    """Returns true if running on Unix-like system (Linux, macOS, BSD)."""
    val os = host_os()
    os == "linux" or os == "macos" or os == "freebsd" or os == "openbsd" or os == "netbsd"

pub fn is_macos() -> bool:
    """Returns true if running on macOS."""
    host_os() == "macos"

pub fn is_linux() -> bool:
    """Returns true if running on Linux."""
    host_os() == "linux"

# ===========================================================================
# Path Separators - Pure Simple Implementation
# ===========================================================================

pub fn dir_sep() -> text:
    """Returns the directory separator for the current platform."""
    if is_windows():
        "\\"
    else:
        "/"

pub fn path_sep() -> text:
    """Returns the PATH environment variable separator."""
    if is_windows():
        ";"
    else:
        ":"

pub fn exe_ext() -> text:
    """Returns the executable extension for the build target.

    Delegates to the target_ext seam so the variants/ platform overlay can bake
    a fixed extension for an explicit build target; default/auto = host.
    """
    target_exe_ext()

pub fn lib_ext() -> text:
    """Returns the dynamic library extension for the build target.

    Delegates to the target_ext seam so the variants/ platform overlay can bake
    a fixed extension for an explicit build target; default/auto = host.
    """
    target_lib_ext()

# ===========================================================================
# Path Normalization (delegates to std.path)
# ===========================================================================

pub fn normalize_path(input_path: text) -> text:
    path.normalize_path(input_path)

pub fn is_absolute_path(input_path: text) -> bool:
    path.is_absolute_path(input_path)

# @tag(base=base, child=child)
pub fn join_path(base: text, child: text) -> text:
    path.join_path(base, child)

# ===========================================================================
# Command Resolution
# ===========================================================================

pub fn resolve_command(cmd: text) -> text:
    if not is_windows():
        return cmd  # Unix: use PATH directly

    # Windows: add .exe if missing, search in PATH
    var resolved = cmd
    if not cmd.ends_with(".exe") and not cmd.ends_with(".bat") and not cmd.ends_with(".cmd"):
        resolved = "{cmd}.exe"

    # Check if absolute path
    if is_absolute_path(resolved):
        return resolved

    # Search in PATH
    extern fn rt_env_get(key: text) -> text
    val path_env = rt_env_get("PATH")
    val paths = path_env.split(path_sep())

    for dir in paths:
        val candidate = join_path(dir, resolved)
        if rt_file_exists(candidate):
            return candidate

    cmd  # Return original if not found

# Alias: is_absolute is the canonical name used by fs/path.spl
fn is_absolute(path: text) -> bool:
    is_absolute_path(path)

# home_dir — returns the user's home directory
extern fn rt_env_home() -> text
fn home_dir() -> text:
    rt_env_home()

export is_absolute, home_dir
export host_os, host_arch, get_host_os, get_host_arch
export is_windows, is_unix, is_macos, is_linux
export dir_sep, path_sep, exe_ext, lib_ext
export normalize_path, is_absolute_path, join_path, resolve_command
