# SFM authorization — AOP Around interceptor + security-level gating (AC-4/5).
#
# Layer access is guarded by the module's security level. The gate rule:
#   deny  iff  level == Trusted  AND  layer.privileged  AND  not ctx.granted_trusted
# An `Ordinary` module never gates (AC-5: it lacks the marker, so a privileged
# claim under Ordinary is ungated). Enforcement is a direct `authorize()` call
# inside `resolve_layer` (di_bridge.spl) — the AOP weaver's Around advice is a
# pre-hook only and cannot block, so it is used as the named aspect marker while
# `authorize` does the real allow/deny.

use std.sfm.manifest.{LayerDescriptor, SfmSecurityLevel}
use std.nogc_sync_mut.src.aop.{Aspect, Advice, AdviceKind, Pointcut, JoinPoint, AdviceContext}

# Caller identity for an access attempt.
struct AuthzContext:
    principal: text
    granted_trusted: bool

# AC-4/5: allow / deny a layer access under a security level.
fn authorize(level: SfmSecurityLevel, layer: LayerDescriptor, ctx: AuthzContext) -> Result<(), text>:
    var trusted: bool = false
    match level:
        Trusted:  trusted = true
        Ordinary: trusted = false
    # Ordinary modules cannot gate — no marker.
    if not trusted:
        return Ok(())
    # Trusted module: only privileged layers are gated.
    if not layer.privileged:
        return Ok(())
    if ctx.granted_trusted:
        return Ok(())
    return Err("sfm authz: denied access to privileged layer '" + layer.role + "' for principal '" + ctx.principal + "'")

# The Around advice handler — a pre-hook used as the named gate marker. The real
# allow/deny is `authorize()`; this exists so the aspect can be registered and
# its name inspected (AC-5 spec checks `aspect.name` contains "authz").
fn _authz_advice(ctx: AdviceContext) -> Result<(), text>:
    return Ok(())

# AC-4/5: build the authorization Around aspect bound to a security level.
fn make_authz_aspect(level: SfmSecurityLevel) -> Aspect:
    var suffix: text = "ordinary"
    match level:
        Trusted:  suffix = "trusted"
        Ordinary: suffix = "ordinary"
    return Aspect(
        name: "sfm.authz." + suffix,
        pointcut: Pointcut(kind: JoinPoint.All, pattern: Some("*")),
        advice: Advice(kind: AdviceKind.Around, handler: _authz_advice),
        enabled: true,
        priority: 100
    )
