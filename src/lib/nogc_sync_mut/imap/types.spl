# IMAP Types and Constants
# RFC 3501 — Internet Message Access Protocol

# =============================================================================
# IMAP State Constants (integer dispatch — avoids JIT enum bug)
# =============================================================================

val IMAP_STATE_NOT_AUTHENTICATED = 0
val IMAP_STATE_AUTHENTICATED     = 1
val IMAP_STATE_SELECTED          = 2
val IMAP_STATE_LOGOUT            = 3

# =============================================================================
# IMAP Response Status Constants
# =============================================================================

val IMAP_STATUS_OK  = 0
val IMAP_STATUS_NO  = 1
val IMAP_STATUS_BAD = 2

# =============================================================================
# IMAP Command Verb Constants
# =============================================================================

val IMAP_CMD_CAPABILITY = 0
val IMAP_CMD_LOGIN      = 1
val IMAP_CMD_SELECT     = 2
val IMAP_CMD_FETCH      = 3
val IMAP_CMD_LOGOUT     = 4
val IMAP_CMD_NOOP       = 5
val IMAP_CMD_STARTTLS   = 6
val IMAP_CMD_LIST       = 7
val IMAP_CMD_STORE      = 8
val IMAP_CMD_SEARCH     = 9

# =============================================================================
# Session
# =============================================================================

struct ImapSession:
    state: i64      # IMAP_STATE_* constant
    tag_seq: i64    # monotonic tag counter

fn imap_session_new() -> ImapSession:
    ImapSession(state: IMAP_STATE_NOT_AUTHENTICATED, tag_seq: 1)

fn imap_session_state(session: ImapSession) -> i64:
    session.state

fn imap_session_is_authenticated(session: ImapSession) -> bool:
    session.state == IMAP_STATE_AUTHENTICATED or session.state == IMAP_STATE_SELECTED

# =============================================================================
# Tag
# =============================================================================

struct ImapTag:
    seq: i64

fn imap_tag_to_text(tag: ImapTag) -> text:
    "A{tag.seq}"

fn imap_next_tag(session: ImapSession) -> ImapTag:
    ImapTag(seq: session.tag_seq)

# =============================================================================
# Command
# =============================================================================

struct ImapCommand:
    tag: ImapTag
    verb: i64       # IMAP_CMD_* constant
    args: [text]    # positional arguments

fn imap_command(tag: ImapTag, verb: i64, args: [text]) -> ImapCommand:
    ImapCommand(tag: tag, verb: verb, args: args)

# =============================================================================
# Response
# =============================================================================

# Tagged response: tag + OK/NO/BAD + human text
struct ImapTaggedResponse:
    tag: text
    status: i64     # IMAP_STATUS_*
    message: text

# Untagged response line (e.g., "* 3 EXISTS", "* CAPABILITY IMAP4rev1")
struct ImapUntaggedResponse:
    data: text

fn imap_tagged_response(tag: text, status: i64, message: text) -> ImapTaggedResponse:
    ImapTaggedResponse(tag: tag, status: status, message: message)

fn imap_untagged_response(data: text) -> ImapUntaggedResponse:
    ImapUntaggedResponse(data: data)

fn imap_status_ok() -> i64:  IMAP_STATUS_OK
fn imap_status_no() -> i64:  IMAP_STATUS_NO
fn imap_status_bad() -> i64: IMAP_STATUS_BAD

fn imap_status_is_ok(status: i64) -> bool:
    status == IMAP_STATUS_OK

fn imap_status_name(status: i64) -> text:
    if status == IMAP_STATUS_OK:
        return "OK"
    if status == IMAP_STATUS_NO:
        return "NO"
    if status == IMAP_STATUS_BAD:
        return "BAD"
    return "UNKNOWN"

export IMAP_STATE_NOT_AUTHENTICATED
export IMAP_STATE_AUTHENTICATED
export IMAP_STATE_SELECTED
export IMAP_STATE_LOGOUT
export IMAP_STATUS_OK
export IMAP_STATUS_NO
export IMAP_STATUS_BAD
export IMAP_CMD_CAPABILITY
export IMAP_CMD_LOGIN
export IMAP_CMD_LOGOUT
export IMAP_CMD_NOOP
export IMAP_CMD_STARTTLS
export IMAP_CMD_LIST
export IMAP_CMD_SELECT
export IMAP_CMD_FETCH
export IMAP_CMD_STORE
export IMAP_CMD_SEARCH
