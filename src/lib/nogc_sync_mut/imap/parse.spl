# IMAP Response Parser
# RFC 3501 — line-based framing, no cursor-by-value (known bug avoidance)

use std.nogc_sync_mut.imap.types.{
    ImapTaggedResponse, ImapUntaggedResponse,
    IMAP_STATUS_OK, IMAP_STATUS_NO, IMAP_STATUS_BAD,
    imap_tagged_response, imap_untagged_response
}

# =============================================================================
# Helpers
# =============================================================================

# Split a line at first space; returns [prefix, rest] or [line] if no space.
# Uses offset loop to avoid cursor-by-value bug.
fn imap_split_at_first_space(line: text) -> [text]:
    val len = line.length()
    var i = 0
    var found = false
    var pos = 0
    while i < len and not found:
        val ch = line.char_at(i)
        if ch == " ":
            found = true
            pos = i
        i = i + 1
    if not found:
        return [line]
    val left = line.substring(0, pos)
    val right = line.substring(pos + 1, len)
    return [left, right]

fn imap_parse_status_word(word: text) -> i64:
    if word == "OK":
        return IMAP_STATUS_OK
    if word == "NO":
        return IMAP_STATUS_NO
    if word == "BAD":
        return IMAP_STATUS_BAD
    return IMAP_STATUS_BAD

# =============================================================================
# Parse a single IMAP response line.
#
# Tagged:   "A1 OK Logged in\r\n"  -> ImapTaggedResponse
# Untagged: "* 3 EXISTS\r\n"       -> ImapUntaggedResponse
#
# Returns the tagged response; use imap_line_is_tagged to distinguish.
# =============================================================================

fn imap_line_is_tagged(line: text) -> bool:
    val len = line.length()
    if len == 0:
        return false
    val first = line.char_at(0)
    # Untagged lines start with '*' or '+' (continuation)
    if first == "*":
        return false
    if first == "+":
        return false
    return true

fn imap_line_is_continuation(line: text) -> bool:
    val len = line.length()
    if len == 0:
        return false
    return line.char_at(0) == "+"

# Strip trailing CRLF from a line
fn imap_strip_crlf(line: text) -> text:
    val len = line.length()
    if len >= 2:
        val last1 = line.char_at(len - 1)
        val last2 = line.char_at(len - 2)
        if last2 == "\r" and last1 == "\n":
            return line.substring(0, len - 2)
    if len >= 1 and line.char_at(len - 1) == "\n":
        return line.substring(0, len - 1)
    return line

fn imap_parse_tagged_response(line: text) -> ImapTaggedResponse:
    val stripped = imap_strip_crlf(line)
    # Format: "<tag> <STATUS> <message...>"
    val parts1 = imap_split_at_first_space(stripped)
    if parts1.len() < 2:
        return imap_tagged_response(stripped, IMAP_STATUS_BAD, "")
    val tag = parts1[0]
    val rest = parts1[1]
    val parts2 = imap_split_at_first_space(rest)
    if parts2.len() < 2:
        val status = imap_parse_status_word(rest)
        return imap_tagged_response(tag, status, "")
    val status_word = parts2[0]
    val message = parts2[1]
    val status = imap_parse_status_word(status_word)
    return imap_tagged_response(tag, status, message)

fn imap_parse_untagged_response(line: text) -> ImapUntaggedResponse:
    val stripped = imap_strip_crlf(line)
    # Strip leading "* "
    val len = stripped.length()
    if len >= 2 and stripped.char_at(0) == "*" and stripped.char_at(1) == " ":
        val data = stripped.substring(2, len)
        return imap_untagged_response(data)
    return imap_untagged_response(stripped)

# Parse a CAPABILITY response data line (untagged data portion)
# e.g. "CAPABILITY IMAP4rev1 STARTTLS AUTH=PLAIN"
# Returns list of capability tokens
fn imap_parse_capability_tokens(data: text) -> [text]:
    val len = data.length()
    var tokens: [text] = []
    var start = 0
    var i = 0
    while i <= len:
        var is_sep = false
        if i == len:
            is_sep = true
        else:
            val ch = data.char_at(i)
            if ch == " ":
                is_sep = true
        if is_sep and i > start:
            val tok = data.substring(start, i)
            tokens.push(tok)
            start = i + 1
        i = i + 1
    return tokens
