# IMAPS — thin secure wrapper over IMAP + TLS
# RFC 3501 §6.2.1 (STARTTLS), RFC 8314 (implicit TLS on port 993)
#
# NOTE: TlsSession is a placeholder struct; the TLS module (src/lib/nogc_sync_mut/tls/)
# is currently stateless hex-string functions with no wire session type.
# This wrapper establishes the composition shape so it compiles correctly
# once a real TLS session handle is defined.
#
# FINDING: tls_session_type_missing_2026-06-15 — see doc/08_tracking/bug/

use std.nogc_sync_mut.imap.types.{ImapSession, imap_session_new}

# =============================================================================
# IMAPS default port constant
# =============================================================================

val IMAPS_DEFAULT_PORT = 993
val IMAP_STARTTLS_PORT = 143

fn imaps_default_port() -> i64: IMAPS_DEFAULT_PORT
fn imap_starttls_port() -> i64: IMAP_STARTTLS_PORT

# =============================================================================
# Placeholder TLS session handle (opaque)
# Remove once tls/ gains a real session type.
# =============================================================================

struct TlsSessionHandle:
    fd: i64     # raw socket file descriptor placeholder

fn tls_session_handle_new(fd: i64) -> TlsSessionHandle:
    TlsSessionHandle(fd: fd)

# =============================================================================
# ImapsSession — composition of TLS + IMAP cleartext session
# =============================================================================

struct ImapsSession:
    tls: TlsSessionHandle
    imap: ImapSession
    starttls_pending: bool   # true = STARTTLS upgrade not yet completed

fn imaps_session_new(fd: i64) -> ImapsSession:
    val handle = tls_session_handle_new(fd)
    val session = imap_session_new()
    ImapsSession(tls: handle, imap: session, starttls_pending: false)

fn imaps_session_imap(s: ImapsSession) -> ImapSession:
    s.imap

fn imaps_session_is_secure(s: ImapsSession) -> bool:
    not s.starttls_pending
