# IMAP Command Builder
# RFC 3501 — produces wire-ready text lines (CRLF-terminated)

use std.nogc_sync_mut.imap.types.{
    ImapCommand, ImapTag,
    IMAP_CMD_CAPABILITY, IMAP_CMD_LOGIN, IMAP_CMD_SELECT,
    IMAP_CMD_FETCH, IMAP_CMD_LOGOUT, IMAP_CMD_NOOP,
    IMAP_CMD_STARTTLS, IMAP_CMD_LIST, IMAP_CMD_STORE, IMAP_CMD_SEARCH,
    imap_tag_to_text
}

# =============================================================================
# Low-level verb → wire-text mapping
# =============================================================================

fn imap_verb_name(verb: i64) -> text:
    if verb == IMAP_CMD_CAPABILITY: return "CAPABILITY"
    if verb == IMAP_CMD_LOGIN:      return "LOGIN"
    if verb == IMAP_CMD_SELECT:     return "SELECT"
    if verb == IMAP_CMD_FETCH:      return "FETCH"
    if verb == IMAP_CMD_LOGOUT:     return "LOGOUT"
    if verb == IMAP_CMD_NOOP:       return "NOOP"
    if verb == IMAP_CMD_STARTTLS:   return "STARTTLS"
    if verb == IMAP_CMD_LIST:       return "LIST"
    if verb == IMAP_CMD_STORE:      return "STORE"
    if verb == IMAP_CMD_SEARCH:     return "SEARCH"
    return "NOOP"

# Build the wire line for any ImapCommand.
# Format: "<tag> <VERB> [<arg1> <arg2> ...]\r\n"
fn imap_build_command(cmd: ImapCommand) -> text:
    val tag_text = imap_tag_to_text(cmd.tag)
    val verb = imap_verb_name(cmd.verb)
    val args = cmd.args
    val nargs = args.len()
    if nargs == 0:
        return "{tag_text} {verb}\r\n"
    # Join args with spaces
    var arg_str = args[0]
    var i = 1
    while i < nargs:
        arg_str = "{arg_str} {args[i]}"
        i = i + 1
    return "{tag_text} {verb} {arg_str}\r\n"

# =============================================================================
# Convenience builders
# =============================================================================

fn imap_build_capability(tag: ImapTag) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} CAPABILITY\r\n"

fn imap_build_login(tag: ImapTag, username: text, password: text) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} LOGIN {username} {password}\r\n"

fn imap_build_select(tag: ImapTag, mailbox: text) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} SELECT {mailbox}\r\n"

fn imap_build_fetch(tag: ImapTag, sequence_set: text, items: text) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} FETCH {sequence_set} {items}\r\n"

fn imap_build_logout(tag: ImapTag) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} LOGOUT\r\n"

fn imap_build_noop(tag: ImapTag) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} NOOP\r\n"

fn imap_build_starttls(tag: ImapTag) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} STARTTLS\r\n"

fn imap_build_list(tag: ImapTag, reference: text, mailbox_pattern: text) -> text:
    val tag_text = imap_tag_to_text(tag)
    return "{tag_text} LIST {reference} {mailbox_pattern}\r\n"
