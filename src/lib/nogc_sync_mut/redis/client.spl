"""
# Redis Client

RESP protocol client for Redis, using sync TCP sockets.
Supports core key-value operations, TTL, and authentication.

## Usage

```simple
use std.nogc_sync_mut.redis.client.{RedisClient}

var client = RedisClient.connect("127.0.0.1", 6379)?
client.set("greeting", "hello")?
val value = client.get("greeting")?
client.close()?
```
"""

use std.common.io.types.{IoError, IoErrorKind}

# ============================================================================
# RedisClient
# ============================================================================

class RedisClient:
    """RESP protocol Redis client over sync TCP.

    Connects to a Redis server and provides typed command methods.
    Uses byte-level RESP parsing to avoid text-encoding data corruption.
    """
    host: text
    port: i64
    fd: i64
    is_connected: bool

    static fn connect(host: text, port: i64) -> Result<RedisClient, IoError>:
        """Connect to a Redis server.

        Args:
            host: Redis server hostname or IP
            port: Redis server port (typically 6379)

        Returns:
            Connected RedisClient or IoError
        """
        val addr = "{host}:{port}"
        val fd = rt_io_tcp_connect(addr)
        if fd < 0:
            return Err(IoError(kind: IoErrorKind.ConnectionRefused, message: "redis connect failed: {addr}", source: nil))
        Ok(RedisClient(host: host, port: port, fd: fd, is_connected: true))

    static fn connect_timeout(host: text, port: i64, ms: i64) -> Result<RedisClient, IoError>:
        """Connect with timeout.

        Args:
            host: Redis server hostname
            port: Redis server port
            ms: Timeout in milliseconds

        Returns:
            Connected RedisClient or IoError
        """
        val addr = "{host}:{port}"
        val fd = rt_io_tcp_connect_timeout(addr, ms)
        if fd < 0:
            return Err(IoError(kind: IoErrorKind.TimedOut, message: "redis connect timed out: {addr}", source: nil))
        Ok(RedisClient(host: host, port: port, fd: fd, is_connected: true))

impl RedisClient:
    fn auth(password: text) -> Result<(), IoError>:
        """Authenticate with the Redis server.

        Args:
            password: Redis AUTH password
        """
        val cmd = resp_encode(["AUTH", password])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Status(s):
                if s == "OK":
                    return Ok(())
                return Err(IoError(kind: IoErrorKind.Other, message: "auth failed: {s}", source: nil))
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "auth error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected auth reply", source: nil))

    fn ping() -> Result<text, IoError>:
        """Ping the Redis server.

        Returns:
            "PONG" on success
        """
        val cmd = resp_encode(["PING"])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Status(s): return Ok(s)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "ping error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected ping reply", source: nil))

    fn get(key: text) -> Result<Option<text>, IoError>:
        """Get value by key.

        Args:
            key: Redis key

        Returns:
            Some(value) if key exists, nil if key does not exist
        """
        val cmd = resp_encode(["GET", key])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Bulk(s): return Ok(Some(s))
            case RedisReply.Nil: return Ok(nil)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "get error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected get reply", source: nil))

    fn set(key: text, value: text) -> Result<(), IoError>:
        """Set key to value.

        Args:
            key: Redis key
            value: Value to store
        """
        val cmd = resp_encode(["SET", key, value])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Status(_): return Ok(())
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "set error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected set reply", source: nil))

    fn set_ex(key: text, value: text, ttl_seconds: i64) -> Result<(), IoError>:
        """Set key with expiration.

        Args:
            key: Redis key
            value: Value to store
            ttl_seconds: Time-to-live in seconds
        """
        val ttl_str = "{ttl_seconds}"
        val cmd = resp_encode(["SET", key, value, "EX", ttl_str])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Status(_): return Ok(())
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "set_ex error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected set_ex reply", source: nil))

    fn del(key: text) -> Result<i64, IoError>:
        """Delete a key.

        Args:
            key: Redis key to delete

        Returns:
            Number of keys removed (0 or 1)
        """
        val cmd = resp_encode(["DEL", key])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Integer(n): return Ok(n)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "del error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected del reply", source: nil))

    fn expire(key: text, seconds: i64) -> Result<bool, IoError>:
        """Set expiration on a key.

        Args:
            key: Redis key
            seconds: TTL in seconds

        Returns:
            true if timeout was set, false if key does not exist
        """
        val sec_str = "{seconds}"
        val cmd = resp_encode(["EXPIRE", key, sec_str])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Integer(n): return Ok(n == 1)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "expire error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected expire reply", source: nil))

    fn key_exists(key: text) -> Result<bool, IoError>:
        """Check if a key exists.

        Args:
            key: Redis key

        Returns:
            true if key exists
        """
        val cmd = resp_encode(["EXISTS", key])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Integer(n): return Ok(n > 0)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "exists error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected exists reply", source: nil))

    fn incr(key: text) -> Result<i64, IoError>:
        """Increment integer value at key.

        Args:
            key: Redis key

        Returns:
            Value after increment
        """
        val cmd = resp_encode(["INCR", key])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Integer(n): return Ok(n)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "incr error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected incr reply", source: nil))

    fn ttl(key: text) -> Result<i64, IoError>:
        """Get remaining TTL of a key in seconds.

        Args:
            key: Redis key

        Returns:
            TTL in seconds, -1 if no expiry, -2 if key missing
        """
        val cmd = resp_encode(["TTL", key])
        self.send_raw(cmd)?
        val reply = self.read_reply()?
        match reply:
            case RedisReply.Integer(n): return Ok(n)
            case RedisReply.Error(e):
                return Err(IoError(kind: IoErrorKind.Other, message: "ttl error: {e}", source: nil))
            _:
                return Err(IoError(kind: IoErrorKind.InvalidData, message: "unexpected ttl reply", source: nil))

    me close() -> Result<(), IoError>:
        """Close the Redis connection."""
        if not self.is_connected:
            return Ok(())
        val ok = rt_io_tcp_close(self.fd)
        self.is_connected = false
        if not ok:
            return Err(IoError(kind: IoErrorKind.Other, message: "close failed", source: nil))
        Ok(())

    fn is_alive() -> bool:
        """Check if connection is still open."""
        self.is_connected

    # --- Internal helpers ---

    fn send_raw(data: text) -> Result<(), IoError>:
        """Send raw RESP text to the server."""
        if not self.is_connected:
            return Err(IoError(kind: IoErrorKind.Other, message: "not connected", source: nil))
        val written = rt_io_tcp_write_text(self.fd, data)
        if written <= 0:
            return Err(IoError(kind: IoErrorKind.BrokenPipe, message: "send failed", source: nil))
        Ok(())

    fn read_reply() -> Result<RedisReply, IoError>:
        """Read and parse one RESP reply from the server.

        Loops until a complete RESP frame is received, handling
        partial reads from TCP fragmentation or large bulk strings.
        """
        if not self.is_connected:
            return Err(IoError(kind: IoErrorKind.Other, message: "not connected", source: nil))
        var buf: [u8] = []
        while true:
            val chunk = rt_io_tcp_read(self.fd, 4096)
            if chunk.len() == 0:
                if buf.len() == 0:
                    return Err(IoError(kind: IoErrorKind.UnexpectedEof, message: "empty reply", source: nil))
                return Err(IoError(kind: IoErrorKind.UnexpectedEof, message: "incomplete reply", source: nil))
            buf = buf + chunk
            val attempt = try_parse_resp(buf, 0)
            if attempt.?:
                return Ok(attempt.unwrap().reply)

# ============================================================================
# RESP Reply Type
# ============================================================================

enum RedisReply:
    """Parsed RESP protocol reply."""
    Status(value: text)
    Error(value: text)
    Integer(value: i64)
    Bulk(value: text)
    Nil
    Array(values: [RedisReply])

struct ParseResult:
    """Internal: parsed reply plus byte offset consumed."""
    reply: RedisReply
    offset: i64

# ============================================================================
# RESP Encoding
# ============================================================================

fn resp_encode(args: [text]) -> text:
    """Encode a command as a RESP array of bulk strings.

    Args:
        args: Command tokens (e.g. ["SET", "key", "value"])

    Returns:
        RESP-encoded command string
    """
    var out = "*{args.len()}\r\n"
    for arg in args:
        out = out + "${arg.len()}\r\n{arg}\r\n"
    out

# ============================================================================
# RESP Parsing
# ============================================================================

fn try_parse_resp(buf: [u8], start: i64) -> Option<ParseResult>:
    """Try to parse a single RESP reply from a byte buffer.

    Returns nil if the buffer is incomplete (need more data).
    Handles +status, -error, :integer, $bulk, *array, _null replies.
    """
    if start >= buf.len():
        return nil

    val type_byte = buf[start]
    val rest_start = start + 1

    if type_byte == 43:
        val line = try_read_line_from(buf, rest_start)
        if not line.?:
            return nil
        val l = line.unwrap()
        return Some(ParseResult(reply: RedisReply.Status(value: l.content), offset: l.end))

    if type_byte == 45:
        val line = try_read_line_from(buf, rest_start)
        if not line.?:
            return nil
        val l = line.unwrap()
        return Some(ParseResult(reply: RedisReply.Error(value: l.content), offset: l.end))

    if type_byte == 58:
        val line = try_read_line_from(buf, rest_start)
        if not line.?:
            return nil
        val l = line.unwrap()
        val num = l.content.to_int() ?? 0
        return Some(ParseResult(reply: RedisReply.Integer(value: num), offset: l.end))

    if type_byte == 36:
        val line = try_read_line_from(buf, rest_start)
        if not line.?:
            return nil
        val l = line.unwrap()
        val length = l.content.to_int() ?? -1
        if length < 0:
            return Some(ParseResult(reply: RedisReply.Nil, offset: l.end))
        val data_start = l.end
        val data_end = data_start + length
        val after_crlf = data_end + 2
        if after_crlf > buf.len():
            return nil
        var data_bytes: [u8] = []
        var di = data_start
        while di < data_end:
            data_bytes.push(buf[di])
            di = di + 1
        val data_text = rt_bytes_to_text(data_bytes)
        return Some(ParseResult(reply: RedisReply.Bulk(value: data_text), offset: after_crlf))

    if type_byte == 42:
        val line = try_read_line_from(buf, rest_start)
        if not line.?:
            return nil
        val l = line.unwrap()
        val count = l.content.to_int() ?? -1
        if count < 0:
            return Some(ParseResult(reply: RedisReply.Nil, offset: l.end))
        var elements: [RedisReply] = []
        var pos = l.end
        var idx = 0
        while idx < count:
            val parsed = try_parse_resp(buf, pos)
            if not parsed.?:
                return nil
            val p = parsed.unwrap()
            elements.push(p.reply)
            pos = p.offset
            idx = idx + 1
        return Some(ParseResult(reply: RedisReply.Array(values: elements), offset: pos))

    Some(ParseResult(reply: RedisReply.Nil, offset: start + 1))

struct LineResult:
    """Internal: a line read from a byte buffer."""
    content: text
    end: i64

fn try_read_line_from(buf: [u8], start: i64) -> Option<LineResult>:
    """Read bytes until CRLF, return as text and position after CRLF.

    Returns nil if no CRLF found (incomplete buffer).
    """
    var line_bytes: [u8] = []
    var pos = start
    while pos < buf.len():
        if (pos + 1 < buf.len() and
            buf[pos] == 13 and buf[pos + 1] == 10):
            val content = rt_bytes_to_text(line_bytes)
            return Some(LineResult(content: content, end: pos + 2))
        line_bytes.push(buf[pos])
        pos = pos + 1
    nil

# ============================================================================
# FFI
# ============================================================================

extern fn rt_io_tcp_connect(addr: text) -> i64
extern fn rt_io_tcp_connect_timeout(addr: text, ms: i64) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool
extern fn rt_bytes_to_text(data: [u8]) -> text
