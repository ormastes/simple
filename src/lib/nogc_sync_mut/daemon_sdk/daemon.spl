# Daemon SDK Runner — Generic daemon poll loop with request dispatch
#
# Provides a composable daemon runner that handles lock acquisition,
# directory setup, poll cycles, and request dispatch via callback.


use std.daemon_sdk.types.{
    DaemonConfig, DaemonState, DaemonRequest, DaemonResponse,
    daemon_state_new, daemon_response_new,
    DAEMON_IDLE, DAEMON_POLLING, DAEMON_PROCESSING, DAEMON_SHUTTING_DOWN
}
use std.daemon_sdk.lock.{
    try_acquire_daemon_lock, release_daemon_lock
}
use std.daemon_sdk.protocol.{
    read_daemon_requests, write_daemon_response, clear_processed_requests,
    clear_old_responses
}

extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_sleep_ms(ms: i64)

# ============================================================================
# Daemon Runner
# ============================================================================

class DaemonRunner:
    config: DaemonConfig
    state: DaemonState
    lock_pid: i64
    running: bool

impl DaemonRunner:
    fn is_running() -> bool:
        self.running

    fn get_state() -> DaemonState:
        self.state

    fn get_config() -> DaemonConfig:
        self.config

    # --- Poll cycle: read requests, dispatch to handler, write responses ---

    me run_poll_cycle(handler: fn(DaemonRequest) -> DaemonResponse):
        if not self.running:
            return

        self.state.status = DAEMON_POLLING
        self.state.last_poll_time = rt_time_now_unix_micros()

        val requests = read_daemon_requests(self.config.request_dir)
        if requests.len() == 0:
            self.state.cycle_count = self.state.cycle_count + 1
            self.state.status = DAEMON_IDLE
            return

        self.state.status = DAEMON_PROCESSING

        var processed_ids: [text] = []
        var count = 0
        var i = 0
        while i < requests.len() and count < self.config.max_concurrent:
            val req = requests[i]
            val resp = handler(req)
            write_daemon_response(resp, self.config.response_dir)
            processed_ids.push(req.id)
            count = count + 1
            i = i + 1

        clear_processed_requests(self.config.request_dir, processed_ids)
        self.state.items_processed = self.state.items_processed + count
        self.state.cycle_count = self.state.cycle_count + 1
        self.state.status = DAEMON_IDLE

    # --- Main loop: poll + sleep + periodic cleanup ---

    me run_loop(handler: fn(DaemonRequest) -> DaemonResponse):
        while self.running:
            self.run_poll_cycle(handler)
            # Periodic response cleanup every 100 cycles
            if self.state.cycle_count % 100 == 0:
                val max_age_ms = self.config.request_timeout_ms * 10
                clear_old_responses(self.config.response_dir, max_age_ms)
            rt_sleep_ms(self.config.poll_interval_ms)

    # --- Shutdown ---

    me shutdown():
        self.running = false
        self.state.status = DAEMON_SHUTTING_DOWN
        release_daemon_lock(self.lock_pid, self.config.lock_path)

# ============================================================================
# Factory
# ============================================================================

fn daemon_runner_start(config: DaemonConfig) -> DaemonRunner:
    rt_mkdir_p(config.request_dir)
    rt_mkdir_p(config.response_dir)

    val pid = try_acquire_daemon_lock(config.lock_path)

    DaemonRunner(
        config: config,
        state: daemon_state_new(),
        lock_pid: pid,
        running: pid > 0
    )
