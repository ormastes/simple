@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Test Database Extended - Factory Functions
#
# Functions for creating and loading TestDatabaseExtended instances

use std.database.core.{SdnDatabase, SdnTable, SdnRow, StringInterner}
use std.io.{file_exists}
use std.database.test_extended.database.{TestDatabaseExtended}

fn create_test_database_extended(path: text) -> TestDatabaseExtended:
    TestDatabaseExtended.create(path)

fn load_test_database_extended(path: text) -> TestDatabaseExtended?:
    val db_opt = SdnDatabase.load(path)
    if not db_opt.?:
        return nil

    var db = match db_opt:
        case Some(loaded_db):
            loaded_db
        case None:
            return nil

    # Use the interner already loaded by SdnDatabase.load()
    # No need to manually rebuild it - db.interner is already populated

    Some(TestDatabaseExtended(
        db: db,
        interner: db.interner,
        next_file_id: 0,
        next_suite_id: 0,
        next_test_id: 0,
        next_timing_run_id: 0,
        next_change_id: 0
    ))

fn migrate_from_dual_file(
    stable_path: text,
    volatile_path: text,
    target_path: text
) -> bool:
    # Load stable database (files, suites, tests)
    val stable_db_opt = SdnDatabase.load(stable_path)
    if not stable_db_opt.?:
        return false

    # Load volatile database (counters, timing, runs)
    val volatile_db_opt = SdnDatabase.load(volatile_path)
    if not volatile_db_opt.?:
        return false

    # Create new unified database
    var target_db = create_test_database_extended(target_path)

    # Migrate stable data (strings, files, suites, tests)
    val stable_db = match stable_db_opt:
        case Some(db):
            db
        case None:
            return false

    # Copy strings table
    match stable_db.get_table("strings"):
        case Some(table):
            target_db.db.set_table("strings", table)
        case None:
            pass

    # Copy files table
    match stable_db.get_table("files"):
        case Some(table):
            target_db.db.set_table("files", table)
        case None:
            pass

    # Copy suites table
    match stable_db.get_table("suites"):
        case Some(table):
            target_db.db.set_table("suites", table)
        case None:
            pass

    # Copy tests table
    match stable_db.get_table("tests"):
        case Some(table):
            target_db.db.set_table("tests", table)
        case None:
            pass

    # Migrate volatile data (counters, timing, timing_runs, changes, test_runs)
    val volatile_db = match volatile_db_opt:
        case Some(db):
            db
        case None:
            return false

    # Copy counters table
    match volatile_db.get_table("counters"):
        case Some(table):
            target_db.db.set_table("counters", table)
        case None:
            pass

    # Copy timing table
    match volatile_db.get_table("timing"):
        case Some(table):
            target_db.db.set_table("timing", table)
        case None:
            pass

    # Copy timing_runs table
    match volatile_db.get_table("timing_runs"):
        case Some(table):
            target_db.db.set_table("timing_runs", table)
        case None:
            pass

    # Copy changes table
    match volatile_db.get_table("changes"):
        case Some(table):
            target_db.db.set_table("changes", table)
        case None:
            pass

    # Copy test_runs table
    match volatile_db.get_table("test_runs"):
        case Some(table):
            target_db.db.set_table("test_runs", table)
        case None:
            pass

    # Rebuild StringInterner from strings table
    match target_db.db.get_table("strings"):
        case Some(strings_table):
            for row in strings_table.valid_rows():
                # BUG-044: Use ?? instead of ? to avoid "try: early return"
                val id_str = row.get("id") ?? ""
                val value = row.get("value") ?? ""
                if id_str != "" and value != "":
                    val id = id_str.parse_i32() ?? 0
                    if id > 0:
                        target_db.interner.str_to_id[value] = id
                        target_db.interner.id_to_str[id] = value
                        if id >= target_db.interner.next_id:
                            target_db.interner.next_id = id + 1
        case None:
            pass

    # Save unified database
    target_db.save()

fn load_with_migration(base_path: text) -> TestDatabaseExtended?:
    # Try loading unified file first
    val unified_path = "{base_path}.sdn"
    if file_exists(unified_path):
        return load_test_database_extended(unified_path)

    # Check if old dual-file format exists
    val stable_path = "{base_path}_stable.sdn"
    val volatile_path = "{base_path}_runs.sdn"

    if file_exists(stable_path) and file_exists(volatile_path):
        # Migrate from dual-file to single-file
        val success = migrate_from_dual_file(stable_path, volatile_path, unified_path)
        if not success:
            return nil

        # Load the migrated database
        return load_test_database_extended(unified_path)

    # No database found
    nil
