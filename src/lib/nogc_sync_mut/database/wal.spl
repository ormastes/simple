# Write-Ahead Log for crash recovery
# Format: one entry per line, pipe-separated: seq|type|table|key|data|timestamp

use nogc_sync_mut.database.atomic (atomic_write, atomic_read, atomic_append, get_timestamp)

enum WalEntryType:
    Insert
    Update
    Delete
    Checkpoint

struct WalEntry:
    sequence: i64
    entry_type: WalEntryType
    table_name: text
    row_key: text
    data: text
    timestamp: i64

fn wal_entry_type_to_text(t: WalEntryType) -> text:
    if t == WalEntryType.Insert:
        "Insert"
    elif t == WalEntryType.Update:
        "Update"
    elif t == WalEntryType.Delete:
        "Delete"
    else:
        "Checkpoint"

fn wal_entry_type_from_text(s: text) -> WalEntryType?:
    if s == "Insert":
        Some(WalEntryType.Insert)
    elif s == "Update":
        Some(WalEntryType.Update)
    elif s == "Delete":
        Some(WalEntryType.Delete)
    elif s == "Checkpoint":
        Some(WalEntryType.Checkpoint)
    else:
        nil

fn wal_entry_to_line(entry: WalEntry) -> text:
    val type_str = wal_entry_type_to_text(entry.entry_type)
    "{entry.sequence}|{type_str}|{entry.table_name}|{entry.row_key}|{entry.data}|{entry.timestamp}\n"

fn wal_entry_from_line(line: text) -> WalEntry?:
    val parts = line.split("|")
    if parts.len() < 6:
        return nil
    val seq = parts[0].trim().to_int() ?? 0
    val etype = wal_entry_type_from_text(parts[1].trim())
    if not etype.?:
        return nil
    val table_name = parts[2].trim()
    val row_key = parts[3].trim()
    # data may contain pipes — rejoin remaining parts except last
    var data_parts: [text] = []
    var i = 4
    while i < parts.len() - 1:
        data_parts.push(parts[i])
        i = i + 1
    val data = data_parts.join("|")
    val ts = parts[parts.len() - 1].trim().to_int() ?? 0
    Some(WalEntry(
        sequence: seq,
        entry_type: etype.unwrap(),
        table_name: table_name,
        row_key: row_key,
        data: data,
        timestamp: ts
    ))

class WriteAheadLog:
    path: text
    entries: [WalEntry]
    sequence_counter: i64
    flushed_up_to: i64

    static fn open(db_path: text) -> WriteAheadLog:
        val wal_path = db_path + ".wal"
        WriteAheadLog(
            path: wal_path,
            entries: [],
            sequence_counter: 0,
            flushed_up_to: 0
        )

    me append(entry: WalEntry) -> bool:
        self.sequence_counter = self.sequence_counter + 1
        val e = WalEntry(
            sequence: self.sequence_counter,
            entry_type: entry.entry_type,
            table_name: entry.table_name,
            row_key: entry.row_key,
            data: entry.data,
            timestamp: entry.timestamp
        )
        var entries = self.entries
        entries.push(e)
        self.entries = entries
        val line = wal_entry_to_line(e)
        atomic_append(self.path, line)

    me flush() -> bool:
        # All writes go through atomic_append which syncs per call; nothing extra needed
        true

    me checkpoint() -> bool:
        val ts = get_timestamp()
        val cp = WalEntry(
            sequence: self.sequence_counter + 1,
            entry_type: WalEntryType.Checkpoint,
            table_name: "",
            row_key: "",
            data: "",
            timestamp: ts
        )
        self.sequence_counter = self.sequence_counter + 1
        val line = wal_entry_to_line(cp)
        val ok = atomic_write(self.path, line)
        if ok:
            self.flushed_up_to = self.sequence_counter
            self.entries = []
        ok

    fn pending_entries() -> [WalEntry]:
        var result: [WalEntry] = []
        for e in self.entries:
            if e.sequence > self.flushed_up_to:
                result.push(e)
        result

    fn replay() -> [WalEntry]:
        val content_opt = atomic_read(self.path)
        if not content_opt.?:
            return []
        val content = content_opt.unwrap()
        val lines = content.split("\n")
        var result: [WalEntry] = []
        for line in lines:
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val entry_opt = wal_entry_from_line(trimmed)
            if entry_opt.?:
                val entry = entry_opt.unwrap()
                if entry.entry_type != WalEntryType.Checkpoint:
                    result.push(entry)
        result

    me clear() -> bool:
        self.entries = []
        self.flushed_up_to = self.sequence_counter
        atomic_write(self.path, "")
