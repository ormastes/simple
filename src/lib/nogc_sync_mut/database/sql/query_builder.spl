# Typed SQL Query Builder
#
# Type-safe SQL query builder that generates parameterized SQL with ?
# placeholders and corresponding [DbValue] parameter arrays.
# All values go into the params array, NEVER interpolated into SQL.

use std.database.sql.types.{DbValue, DbError}
use std.database.sql.escape.{quote_ident, placeholder_list, set_clause, column_list}

# ============================================================================
# Expression types
# ============================================================================

enum SqlOp:
    Eq
    Ne
    Gt
    Ge
    Lt
    Le
    Like
    In
    IsNull
    IsNotNull

enum SqlOrder:
    Asc
    Desc

enum SqlExpr:
    Compare(field: text, op: SqlOp, value: DbValue)
    And(left: SqlExpr, right: SqlExpr)
    Or(left: SqlExpr, right: SqlExpr)
    Not(inner: SqlExpr)
    IsNull(field: text)
    IsNotNull(field: text)
    InList(field: text, values: [DbValue])
    Raw(sql: text)

# ============================================================================
# Helper constructors (module-level functions)
# ============================================================================

fn sql_eq(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Eq, value: value)

fn sql_ne(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Ne, value: value)

fn sql_gt(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Gt, value: value)

fn sql_ge(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Ge, value: value)

fn sql_lt(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Lt, value: value)

fn sql_le(field: text, value: DbValue) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Le, value: value)

fn sql_like(field: text, pattern: text) -> SqlExpr:
    SqlExpr.Compare(field: field, op: SqlOp.Like, value: DbValue.Text(value: pattern))

fn sql_is_null(field: text) -> SqlExpr:
    SqlExpr.IsNull(field: field)

fn sql_is_not_null(field: text) -> SqlExpr:
    SqlExpr.IsNotNull(field: field)

fn sql_in(field: text, values: [DbValue]) -> SqlExpr:
    SqlExpr.InList(field: field, values: values)

fn sql_and(a: SqlExpr, b: SqlExpr) -> SqlExpr:
    SqlExpr.And(left: a, right: b)

fn sql_or(a: SqlExpr, b: SqlExpr) -> SqlExpr:
    SqlExpr.Or(left: a, right: b)

fn sql_not(expr: SqlExpr) -> SqlExpr:
    SqlExpr.Not(inner: expr)

fn sql_raw(sql: text) -> SqlExpr:
    SqlExpr.Raw(sql: sql)

# ============================================================================
# Internal: Compile expression to SQL + params
# ============================================================================

struct CompiledExpr:
    sql: text
    params: [DbValue]

fn _op_to_sql(op: SqlOp) -> text:
    match op:
        SqlOp.Eq: "="
        SqlOp.Ne: "!="
        SqlOp.Gt: ">"
        SqlOp.Ge: ">="
        SqlOp.Lt: "<"
        SqlOp.Le: "<="
        SqlOp.Like: "LIKE"
        SqlOp.In: "IN"
        SqlOp.IsNull: "IS NULL"
        SqlOp.IsNotNull: "IS NOT NULL"

fn compile_expr(expr: SqlExpr) -> CompiledExpr:
    match expr:
        SqlExpr.Compare(field, op, value):
            val quoted = quote_ident(field)
            val op_sql = _op_to_sql(op)
            CompiledExpr(sql: "{quoted} {op_sql} ?", params: [value])

        SqlExpr.And(left, right):
            val left_c = compile_expr(left)
            val right_c = compile_expr(right)
            var params: [DbValue] = []
            for p in left_c.params:
                params.push(p)
            for p in right_c.params:
                params.push(p)
            CompiledExpr(sql: "({left_c.sql} AND {right_c.sql})", params: params)

        SqlExpr.Or(left, right):
            val left_c = compile_expr(left)
            val right_c = compile_expr(right)
            var params: [DbValue] = []
            for p in left_c.params:
                params.push(p)
            for p in right_c.params:
                params.push(p)
            CompiledExpr(sql: "({left_c.sql} OR {right_c.sql})", params: params)

        SqlExpr.Not(inner):
            val inner_c = compile_expr(inner)
            CompiledExpr(sql: "NOT ({inner_c.sql})", params: inner_c.params)

        SqlExpr.IsNull(field):
            val quoted = quote_ident(field)
            CompiledExpr(sql: "{quoted} IS NULL", params: [])

        SqlExpr.IsNotNull(field):
            val quoted = quote_ident(field)
            CompiledExpr(sql: "{quoted} IS NOT NULL", params: [])

        SqlExpr.InList(field, values):
            val quoted = quote_ident(field)
            val placeholders = placeholder_list(values.len())
            CompiledExpr(sql: "{quoted} IN ({placeholders})", params: values)

        SqlExpr.Raw(sql):
            CompiledExpr(sql: sql, params: [])

# ============================================================================
# Internal: Compile a list of WHERE expressions ANDed together
# ============================================================================

fn _compile_where(exprs: [SqlExpr]) -> CompiledExpr:
    if exprs.len() == 0:
        return CompiledExpr(sql: "", params: [])

    var sql_parts: [text] = []
    var all_params: [DbValue] = []

    for expr in exprs:
        val compiled = compile_expr(expr)
        sql_parts.push(compiled.sql)
        for p in compiled.params:
            all_params.push(p)

    val where_sql = sql_parts.join(" AND ")
    CompiledExpr(sql: " WHERE {where_sql}", params: all_params)

# ============================================================================
# SelectQuery
# ============================================================================

class SelectQuery:
    table_name: text
    select_cols: [text]
    where_exprs: [SqlExpr]
    order_cols: [(text, SqlOrder)]
    limit_val: i64?
    offset_val: i64?

impl SelectQuery:
    static fn from(table: text) -> SelectQuery:
        SelectQuery(
            table_name: table,
            select_cols: [],
            where_exprs: [],
            order_cols: [],
            limit_val: nil,
            offset_val: nil
        )

    me select(cols: [text]) -> SelectQuery:
        self.select_cols = cols
        self

    me where(expr: SqlExpr) -> SelectQuery:
        self.where_exprs.push(expr)
        self

    me where_eq(col: text, val_arg: DbValue) -> SelectQuery:
        self.where_exprs.push(SqlExpr.Compare(field: col, op: SqlOp.Eq, value: val_arg))
        self

    me order(col: text, dir: SqlOrder) -> SelectQuery:
        self.order_cols.push((col, dir))
        self

    me limit(n: i64) -> SelectQuery:
        self.limit_val = Some(n)
        self

    me offset(n: i64) -> SelectQuery:
        self.offset_val = Some(n)
        self

    fn build() -> (text, [DbValue]):
        # SELECT clause
        var cols_sql = "*"
        if self.select_cols.len() > 0:
            cols_sql = column_list(self.select_cols)

        val table_sql = quote_ident(self.table_name)
        var sql = "SELECT {cols_sql} FROM {table_sql}"
        var params: [DbValue] = []

        # WHERE clause
        val where_compiled = _compile_where(self.where_exprs)
        if where_compiled.sql.len() > 0:
            sql = sql + where_compiled.sql
            for p in where_compiled.params:
                params.push(p)

        # ORDER BY clause
        if self.order_cols.len() > 0:
            var order_parts: [text] = []
            for entry in self.order_cols:
                val col_name = entry.0
                val dir = entry.1
                val quoted_col = quote_ident(col_name)
                val dir_sql = match dir:
                    SqlOrder.Asc: "ASC"
                    SqlOrder.Desc: "DESC"
                order_parts.push("{quoted_col} {dir_sql}")
            val order_sql = order_parts.join(", ")
            sql = sql + " ORDER BY {order_sql}"

        # LIMIT clause
        if self.limit_val.?:
            val limit_n = self.limit_val?
            sql = sql + " LIMIT ?"
            params.push(DbValue.Integer(value: limit_n))

        # OFFSET clause
        if self.offset_val.?:
            val offset_n = self.offset_val?
            sql = sql + " OFFSET ?"
            params.push(DbValue.Integer(value: offset_n))

        (sql, params)

# ============================================================================
# InsertQuery
# ============================================================================

class InsertQuery:
    table_name: text
    col_names: [text]
    row_values: [[DbValue]]

impl InsertQuery:
    static fn into(table: text) -> InsertQuery:
        InsertQuery(
            table_name: table,
            col_names: [],
            row_values: []
        )

    me columns(cols: [text]) -> InsertQuery:
        self.col_names = cols
        self

    me row(values: [DbValue]) -> InsertQuery:
        self.row_values.push(values)
        self

    fn build() -> (text, [DbValue]):
        val table_sql = quote_ident(self.table_name)
        val cols_sql = column_list(self.col_names)
        val placeholders = placeholder_list(self.col_names.len())
        val sql = "INSERT INTO {table_sql} ({cols_sql}) VALUES ({placeholders})"

        var params: [DbValue] = []
        if self.row_values.len() > 0:
            val first_row = self.row_values[0]
            for v in first_row:
                params.push(v)

        (sql, params)

    fn build_batch() -> [(text, [DbValue])]:
        val table_sql = quote_ident(self.table_name)
        val cols_sql = column_list(self.col_names)
        val placeholders = placeholder_list(self.col_names.len())
        val sql = "INSERT INTO {table_sql} ({cols_sql}) VALUES ({placeholders})"

        var results: [(text, [DbValue])] = []
        for row in self.row_values:
            var params: [DbValue] = []
            for v in row:
                params.push(v)
            results.push((sql, params))

        results

# ============================================================================
# UpdateQuery
# ============================================================================

class UpdateQuery:
    table_name: text
    set_pairs: [(text, DbValue)]
    where_exprs: [SqlExpr]

impl UpdateQuery:
    static fn table(name: text) -> UpdateQuery:
        UpdateQuery(
            table_name: name,
            set_pairs: [],
            where_exprs: []
        )

    me set(col: text, val_arg: DbValue) -> UpdateQuery:
        self.set_pairs.push((col, val_arg))
        self

    me where(expr: SqlExpr) -> UpdateQuery:
        self.where_exprs.push(expr)
        self

    me where_eq(col: text, val_arg: DbValue) -> UpdateQuery:
        self.where_exprs.push(SqlExpr.Compare(field: col, op: SqlOp.Eq, value: val_arg))
        self

    fn build() -> (text, [DbValue]):
        val table_sql = quote_ident(self.table_name)
        var params: [DbValue] = []

        # Build SET clause
        var set_parts: [text] = []
        for pair in self.set_pairs:
            val col_name = pair.0
            val col_val = pair.1
            val quoted_col = quote_ident(col_name)
            set_parts.push("{quoted_col} = ?")
            params.push(col_val)

        val set_sql = set_parts.join(", ")
        var sql = "UPDATE {table_sql} SET {set_sql}"

        # WHERE clause
        val where_compiled = _compile_where(self.where_exprs)
        if where_compiled.sql.len() > 0:
            sql = sql + where_compiled.sql
            for p in where_compiled.params:
                params.push(p)

        (sql, params)

# ============================================================================
# DeleteQuery
# ============================================================================

class DeleteQuery:
    table_name: text
    where_exprs: [SqlExpr]

impl DeleteQuery:
    static fn from(table: text) -> DeleteQuery:
        DeleteQuery(
            table_name: table,
            where_exprs: []
        )

    me where(expr: SqlExpr) -> DeleteQuery:
        self.where_exprs.push(expr)
        self

    me where_eq(col: text, val_arg: DbValue) -> DeleteQuery:
        self.where_exprs.push(SqlExpr.Compare(field: col, op: SqlOp.Eq, value: val_arg))
        self

    fn build() -> (text, [DbValue]):
        val table_sql = quote_ident(self.table_name)
        var sql = "DELETE FROM {table_sql}"
        var params: [DbValue] = []

        # WHERE clause
        val where_compiled = _compile_where(self.where_exprs)
        if where_compiled.sql.len() > 0:
            sql = sql + where_compiled.sql
            for p in where_compiled.params:
                params.push(p)

        (sql, params)
