# Typed SQL Database Library - Transaction Management
#
# Provides ACID transaction support with savepoint nesting.
# Wraps raw sqlite_ffi calls with typed error handling.

use std.io.sqlite_ffi.{SqliteConnection, sqlite_execute, sqlite_error_message, sqlite_begin, sqlite_commit, sqlite_rollback, sqlite_query_all, SqliteRow}
use std.database.sql.types.{DbValue, DbRow, DbError}

# ============================================================================
# TxState — transaction lifecycle
# ============================================================================

enum TxState:
    Active
    Committed
    RolledBack

# ============================================================================
# Transaction — scoped database transaction with savepoint support
# ============================================================================

class Transaction:
    conn: SqliteConnection
    state: TxState

    # ------------------------------------------------------------------
    # Commit the transaction.
    # Returns Err if the transaction is not active or COMMIT fails.
    # ------------------------------------------------------------------
    me commit() -> Result<(), DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val ok = sqlite_commit(self.conn)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.TransactionFailed("commit failed: {msg}"))

        self.state = TxState.Committed
        Ok(())

    # ------------------------------------------------------------------
    # Rollback the transaction.
    # Returns Err if the transaction is not active or ROLLBACK fails.
    # ------------------------------------------------------------------
    me rollback() -> Result<(), DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val ok = sqlite_rollback(self.conn)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.TransactionFailed("rollback failed: {msg}"))

        self.state = TxState.RolledBack
        Ok(())

    # ------------------------------------------------------------------
    # Create a named savepoint within the transaction.
    # ------------------------------------------------------------------
    me savepoint(name: text) -> Result<(), DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val sql = "SAVEPOINT {name}"
        val ok = sqlite_execute(self.conn, sql)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.TransactionFailed("savepoint '{name}' failed: {msg}"))

        Ok(())

    # ------------------------------------------------------------------
    # Release (commit) a named savepoint.
    # ------------------------------------------------------------------
    me release_savepoint(name: text) -> Result<(), DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val sql = "RELEASE SAVEPOINT {name}"
        val ok = sqlite_execute(self.conn, sql)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.TransactionFailed("release savepoint '{name}' failed: {msg}"))

        Ok(())

    # ------------------------------------------------------------------
    # Rollback to a named savepoint (without ending the transaction).
    # ------------------------------------------------------------------
    me rollback_to(name: text) -> Result<(), DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val sql = "ROLLBACK TO SAVEPOINT {name}"
        val ok = sqlite_execute(self.conn, sql)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.TransactionFailed("rollback to savepoint '{name}' failed: {msg}"))

        Ok(())

    # ------------------------------------------------------------------
    # Execute a SQL statement within this transaction.
    # Returns the number of affected rows (via sqlite_changes).
    # ------------------------------------------------------------------
    me execute(sql: text) -> Result<i64, DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val ok = sqlite_execute(self.conn, sql)
        if not ok:
            val msg = sqlite_error_message(self.conn)
            return Err(DbError.QueryFailed(sql, msg))

        # sqlite_execute returns bool; affected rows not directly available
        # from sqlite_execute wrapper. Return 0 to indicate success.
        Ok(0)

    # ------------------------------------------------------------------
    # Query rows within this transaction (basic, no params).
    # For parameterized queries use Database.query with params instead.
    # ------------------------------------------------------------------
    fn query(sql: text) -> Result<[DbRow], DbError>:
        if not self.is_active():
            return Err(DbError.TransactionFailed("transaction not active"))

        val raw_rows = sqlite_query_all(self.conn, sql)
        var result: [DbRow] = []
        for row in raw_rows:
            var values: [DbValue] = []
            for v in row.values:
                values.push(DbValue.Text(value: v))
            result.push(DbRow(columns: row.column_names, values: values))

        Ok(result)

    # ------------------------------------------------------------------
    # Check whether the transaction is still active.
    # ------------------------------------------------------------------
    fn is_active() -> bool:
        match self.state:
            TxState.Active: true
            _: false
