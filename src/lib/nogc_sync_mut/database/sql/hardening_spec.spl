"""SQL injection prevention, parameterized query enforcement, and connection
pool safety hardening specification.

Covers:
- Identifier validation (validate_ident, is_safe_identifier)
- Dangerous SQL fragment detection (is_dangerous_sql)
- Parameterized query builder — all values are bound as ? placeholders
- sql_raw_safe rejects dangerous fragments
- Pool double-release guard (leaked_connections counter)
- Pool force_release_all safety valve
"""

mod nogc_sync_mut.database.sql.escape
mod nogc_sync_mut.database.sql.query_builder
mod nogc_sync_mut.database.sql.pool
mod nogc_sync_mut.database.sql.types

use std.database.sql.escape.{validate_ident, is_safe_identifier, is_dangerous_sql, quote_ident}
use std.database.sql.query_builder.{SelectQuery, InsertQuery, UpdateQuery, DeleteQuery,
    sql_raw, sql_raw_safe, sql_eq, compile_expr, SqlExpr, SqlOrder}
use std.database.sql.types.{DbValue, DbError}

# =============================================================================
# Identifier Validation
# =============================================================================

describe "validate_ident — identifier safety":
    """Ensures SQL identifiers are validated before use in queries."""

    it "accepts a normal identifier":
        val result = validate_ident("users")
        expect(result != nil).to_equal(true)

    it "accepts identifier with underscores and digits":
        val result = validate_ident("user_id_42")
        expect(result != nil).to_equal(true)

    it "rejects empty identifier":
        val result = validate_ident("")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects identifier exceeding max length":
        val long_name = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        val result = validate_ident(long_name)
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects identifier with semicolon":
        val result = validate_ident("users;drop table users")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects identifier with space":
        val result = validate_ident("user name")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects identifier with single quote":
        val result = validate_ident("user'")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

describe "is_safe_identifier":
    it "returns true for safe name":
        expect(is_safe_identifier("orders")).to_equal(true)

    it "returns false for empty string":
        expect(is_safe_identifier("")).to_equal(false)

    it "returns false for name with dash":
        expect(is_safe_identifier("bad-name")).to_equal(false)

    it "returns false for name with SQL comment start":
        expect(is_safe_identifier("x--y")).to_equal(false)

# =============================================================================
# Dangerous SQL Detection
# =============================================================================

describe "is_dangerous_sql — injection pattern detection":
    """Detects common SQL injection payloads in raw SQL fragments."""

    it "flags inline comment --":
        expect(is_dangerous_sql("1 -- comment")).to_equal(true)

    it "flags statement terminator ;":
        expect(is_dangerous_sql("1; DROP TABLE users")).to_equal(true)

    it "flags block comment open /*":
        expect(is_dangerous_sql("1 /* bypass")).to_equal(true)

    it "flags block comment close */":
        expect(is_dangerous_sql("bypass */ 1")).to_equal(true)

    it "flags DROP keyword":
        expect(is_dangerous_sql("drop table users")).to_equal(true)

    it "flags TRUNCATE keyword":
        expect(is_dangerous_sql("TRUNCATE TABLE users")).to_equal(true)

    it "flags EXEC keyword":
        expect(is_dangerous_sql("exec xp_cmdshell('cmd')")).to_equal(true)

    it "returns false for safe ORDER BY fragment":
        expect(is_dangerous_sql("ORDER BY created_at")).to_equal(false)

    it "returns false for empty string":
        expect(is_dangerous_sql("")).to_equal(false)

    it "returns false for simple column expression":
        expect(is_dangerous_sql("status = 'active'")).to_equal(false)

# =============================================================================
# Parameterized Query Builder — values never in SQL string
# =============================================================================

describe "SelectQuery — parameterized output":
    """All WHERE values must appear in the params array, not the SQL string."""

    it "builds SELECT with ? placeholder for value":
        val q = SelectQuery.from("users")
        val built = q.where_eq("email", DbValue.Text(value: "alice@example.com")).build()
        val sql = built.0
        val params = built.1
        # SQL must contain ? not the literal value
        expect(sql.contains("?")).to_equal(true)
        expect(sql.contains("alice@example.com")).to_equal(false)
        expect(params.len()).to_equal(1)

    it "builds SELECT LIMIT with ? placeholder":
        val q = SelectQuery.from("orders")
        val built = q.limit(10).build()
        val sql = built.0
        val params = built.1
        expect(sql.contains("LIMIT ?")).to_equal(true)
        expect(params.len()).to_equal(1)

    it "quotes table name with double quotes":
        val q = SelectQuery.from("user_profiles")
        val built = q.build()
        val sql = built.0
        expect(sql.contains("\"user_profiles\"")).to_equal(true)

describe "InsertQuery — parameterized output":
    it "builds INSERT with ? placeholders for all columns":
        val q = InsertQuery.into("products")
        val built = q.columns(["name", "price"]).row([DbValue.Text(value: "widget"), DbValue.Real(value: 9.99)]).build()
        val sql = built.0
        val params = built.1
        expect(sql.contains("?")).to_equal(true)
        expect(sql.contains("widget")).to_equal(false)
        expect(params.len()).to_equal(2)

describe "UpdateQuery — parameterized output":
    it "builds UPDATE SET with ? placeholder":
        val q = UpdateQuery.table("accounts")
        val built = q.set("balance", DbValue.Integer(value: 500)).where_eq("id", DbValue.Integer(value: 1)).build()
        val sql = built.0
        val params = built.1
        expect(sql.contains("?")).to_equal(true)
        expect(sql.contains("500")).to_equal(false)
        expect(params.len()).to_equal(2)

describe "DeleteQuery — parameterized output":
    it "builds DELETE WHERE with ? placeholder":
        val q = DeleteQuery.from("sessions")
        val built = q.where_eq("token", DbValue.Text(value: "secret-token")).build()
        val sql = built.0
        val params = built.1
        expect(sql.contains("?")).to_equal(true)
        expect(sql.contains("secret-token")).to_equal(false)
        expect(params.len()).to_equal(1)

# =============================================================================
# sql_raw_safe — rejects dangerous fragments
# =============================================================================

describe "sql_raw_safe — injection prevention on raw fragments":
    it "accepts a safe fragment":
        val result = sql_raw_safe("status = 'active'")
        match result:
            Ok(_): expect(true).to_equal(true)
            Err(_): expect(false).to_equal(true)

    it "rejects fragment with -- comment":
        val result = sql_raw_safe("1 -- bypass")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects fragment with DROP keyword":
        val result = sql_raw_safe("1; DROP TABLE users")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

    it "rejects fragment with semicolon":
        val result = sql_raw_safe("x; SELECT 1")
        match result:
            Err(_): expect(true).to_equal(true)
            Ok(_): expect(false).to_equal(true)

