# Typed SQL Database Library - DDL Generation
#
# Stateless functions that produce SQL DDL strings for table creation,
# alteration, index management, and schema migration operations.

use std.database.sql.schema.{TableSchema, ColumnDef}
use std.database.sql.escape.{quote_ident, column_list}

# ============================================================================
# Table DDL
# ============================================================================

# Generate CREATE TABLE statement from schema.
fn gen_create_table(schema: TableSchema) -> text:
    schema.to_create_sql()

# Generate CREATE TABLE IF NOT EXISTS statement from schema.
fn gen_create_table_if_not_exists(schema: TableSchema) -> text:
    schema.to_create_if_not_exists_sql()

# Generate DROP TABLE statement.
# When if_exists is true, adds IF EXISTS clause.
fn gen_drop_table(name: text, if_exists: bool) -> text:
    val quoted = quote_ident(name)
    if if_exists:
        "DROP TABLE IF EXISTS {quoted}"
    else:
        "DROP TABLE {quoted}"

# ============================================================================
# Column DDL
# ============================================================================

# Generate ALTER TABLE ADD COLUMN statement.
fn gen_add_column(table: text, col: ColumnDef) -> text:
    val quoted_table = quote_ident(table)
    val col_sql = col.to_sql()
    "ALTER TABLE {quoted_table} ADD COLUMN {col_sql}"

# Generate ALTER TABLE RENAME COLUMN statement.
fn gen_rename_column(table: text, old_name: text, new_name: text) -> text:
    val quoted_table = quote_ident(table)
    val quoted_old = quote_ident(old_name)
    val quoted_new = quote_ident(new_name)
    "ALTER TABLE {quoted_table} RENAME COLUMN {quoted_old} TO {quoted_new}"

# ============================================================================
# Index DDL
# ============================================================================

# Generate CREATE INDEX statement.
# When unique is true, creates a UNIQUE index.
# When name is nil, auto-generates: "idx_{table}_{col1}_{col2}".
fn gen_create_index(table: text, columns: [text], unique: bool, name: text?) -> text:
    val index_name = _resolve_index_name(table, columns, name)
    val quoted_index = quote_ident(index_name)
    val quoted_table = quote_ident(table)
    val cols_str = column_list(columns)
    if unique:
        "CREATE UNIQUE INDEX IF NOT EXISTS {quoted_index} ON {quoted_table} ({cols_str})"
    else:
        "CREATE INDEX IF NOT EXISTS {quoted_index} ON {quoted_table} ({cols_str})"

# Generate DROP INDEX IF EXISTS statement.
fn gen_drop_index(name: text) -> text:
    val quoted = quote_ident(name)
    "DROP INDEX IF EXISTS {quoted}"

# ============================================================================
# Helpers
# ============================================================================

# Resolve index name: use provided name or auto-generate from table + columns.
fn _resolve_index_name(table: text, columns: [text], name: text?) -> text:
    if val Some(n) = name:
        return n
    var parts: [text] = []
    parts.push("idx")
    parts.push(table)
    for col in columns:
        parts.push(col)
    parts.join("_")
