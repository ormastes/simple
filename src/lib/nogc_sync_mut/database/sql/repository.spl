# Typed SQL Database Library - Generic CRUD Repository
#
# Provides a generic Repository<T> that uses DbCodec<T> to perform
# type-safe CRUD operations: create_table, insert, insert_batch,
# find_by_id, find_all, find_where, count, update, delete_by_id,
# delete_where, and select().

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.connection.{Database}
use std.database.sql.codec.{DbCodec}
use std.database.sql.query_builder.{SelectQuery, SqlExpr, compile_expr, sql_eq}
use std.database.sql.escape.{quote_ident, placeholder_list, set_clause, column_list}

# ============================================================================
# Repository<T> — generic CRUD repository using DbCodec<T>
# ============================================================================

class Repository<T>:
    """Generic CRUD repository for any type T that has a DbCodec<T>.

    Handles table creation, single and batch inserts, queries by id or
    filter expression, counting, updates, and deletes. All SQL is built
    using safe identifier quoting and parameterized queries.

    ## Example

    ```simple
    var db = Database.memory()?
    val codec = UserCodec()
    var repo = Repository.new(db, codec)
    repo.create_table()?
    val id = repo.insert(User(name: "Alice", age: 30))?
    val user = repo.find_by_id(id)?
    ```
    """
    db: Database
    codec: DbCodec<T>

impl Repository<T>:
    # ------------------------------------------------------------------
    # Constructor
    # ------------------------------------------------------------------
    static fn new(db: Database, codec: DbCodec<T>) -> Repository<T>:
        Repository(db: db, codec: codec)

    # ------------------------------------------------------------------
    # Create the table from the codec's schema definition.
    # Uses CREATE TABLE IF NOT EXISTS so it is safe to call repeatedly.
    # ------------------------------------------------------------------
    me create_table() -> Result<(), DbError>:
        val schema = self.codec.schema()
        val sql = schema.to_create_if_not_exists_sql()
        self.db.exec(sql, [])?
        Ok(())

    # ------------------------------------------------------------------
    # Insert a single entity.
    # Returns the last_insert_rowid (auto-increment id).
    # ------------------------------------------------------------------
    me insert(entity: T) -> Result<i64, DbError>:
        val table = quote_ident(self.codec.table_name())
        val cols = self.codec.columns()
        val cols_sql = column_list(cols)
        val placeholders = placeholder_list(cols.len())
        val sql = "INSERT INTO {table} ({cols_sql}) VALUES ({placeholders})"
        val params = self.codec.encode(entity)
        self.db.exec(sql, params)?
        val row_id = self.db.last_insert_rowid()
        Ok(row_id)

    # ------------------------------------------------------------------
    # Insert a batch of entities in a single transaction.
    # Returns the number of successfully inserted entities.
    # On error, rolls back the entire batch.
    # ------------------------------------------------------------------
    me insert_batch(entities: [T]) -> Result<i64, DbError>:
        if entities.len() == 0:
            return Ok(0)

        val table = quote_ident(self.codec.table_name())
        val cols = self.codec.columns()
        val cols_sql = column_list(cols)
        val placeholders = placeholder_list(cols.len())
        val sql = "INSERT INTO {table} ({cols_sql}) VALUES ({placeholders})"

        var tx = self.db.begin()?
        var count: i64 = 0

        for entity in entities:
            val params = self.codec.encode(entity)
            val result = self.db.exec(sql, params)
            if val Err(e) = result:
                tx.rollback()?
                return Err(e)
            count = count + 1

        tx.commit()?
        Ok(count)

    # ------------------------------------------------------------------
    # Find a single entity by its integer primary key ("id" column).
    # Returns nil if no row matches.
    # ------------------------------------------------------------------
    fn find_by_id(id: i64) -> Result<T?, DbError>:
        val table = quote_ident(self.codec.table_name())
        val sql = "SELECT * FROM {table} WHERE \"id\" = ? LIMIT 1"
        val params: [DbValue] = [DbValue.Integer(value: id)]
        val row_opt = self.db.query_one(sql, params)?
        if val Some(row) = row_opt:
            val entity = self.codec.decode(row)?
            return Ok(Some(entity))
        Ok(nil)

    # ------------------------------------------------------------------
    # Find all rows in the table.
    # Returns a list of decoded entities.
    # ------------------------------------------------------------------
    fn find_all() -> Result<[T], DbError>:
        val table = quote_ident(self.codec.table_name())
        val sql = "SELECT * FROM {table}"
        val rows = self.db.query(sql, [])?
        var result: [T] = []
        for row in rows:
            val entity = self.codec.decode(row)?
            result.push(entity)
        Ok(result)

    # ------------------------------------------------------------------
    # Find rows matching a filter expression.
    # Uses compile_expr to convert SqlExpr into a WHERE clause + params.
    # ------------------------------------------------------------------
    fn find_where(expr: SqlExpr) -> Result<[T], DbError>:
        val table = quote_ident(self.codec.table_name())
        val compiled = compile_expr(expr)
        val sql = "SELECT * FROM {table} WHERE {compiled.sql}"
        val rows = self.db.query(sql, compiled.params)?
        var result: [T] = []
        for row in rows:
            val entity = self.codec.decode(row)?
            result.push(entity)
        Ok(result)

    # ------------------------------------------------------------------
    # Count all rows in the table.
    # ------------------------------------------------------------------
    fn count() -> Result<i64, DbError>:
        val table = quote_ident(self.codec.table_name())
        val sql = "SELECT COUNT(*) FROM {table}"
        val value_opt = self.db.query_value(sql, [])?
        if val Some(value) = value_opt:
            if val Some(n) = value.as_int():
                return Ok(n)
            # COUNT(*) may come back as text from raw query path
            if val Some(t) = value.as_text():
                return Ok(t.to_int() ?? 0)
        Ok(0)

    # ------------------------------------------------------------------
    # Update an entity by its integer primary key ("id" column).
    # Returns the number of rows changed (0 or 1).
    # ------------------------------------------------------------------
    me update(id: i64, entity: T) -> Result<i64, DbError>:
        val table = quote_ident(self.codec.table_name())
        val cols = self.codec.columns()
        val set_sql = set_clause(cols)
        val sql = "UPDATE {table} SET {set_sql} WHERE \"id\" = ?"
        var params = self.codec.encode(entity)
        params.push(DbValue.Integer(value: id))
        val changed = self.db.exec(sql, params)?
        Ok(changed)

    # ------------------------------------------------------------------
    # Delete a single row by its integer primary key ("id" column).
    # Returns the number of rows deleted (0 or 1).
    # ------------------------------------------------------------------
    me delete_by_id(id: i64) -> Result<i64, DbError>:
        val table = quote_ident(self.codec.table_name())
        val sql = "DELETE FROM {table} WHERE \"id\" = ?"
        val params: [DbValue] = [DbValue.Integer(value: id)]
        val changed = self.db.exec(sql, params)?
        Ok(changed)

    # ------------------------------------------------------------------
    # Delete rows matching a filter expression.
    # Uses compile_expr to convert SqlExpr into a WHERE clause + params.
    # Returns the number of rows deleted.
    # ------------------------------------------------------------------
    me delete_where(expr: SqlExpr) -> Result<i64, DbError>:
        val table = quote_ident(self.codec.table_name())
        val compiled = compile_expr(expr)
        val sql = "DELETE FROM {table} WHERE {compiled.sql}"
        val changed = self.db.exec(sql, compiled.params)?
        Ok(changed)

    # ------------------------------------------------------------------
    # Return a SelectQuery pre-configured for this table.
    # Allows building complex queries with the query builder API.
    # ------------------------------------------------------------------
    fn select() -> SelectQuery:
        SelectQuery.from(self.codec.table_name())
