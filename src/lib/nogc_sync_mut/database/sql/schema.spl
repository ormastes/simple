# Typed SQL Database Library - Schema Metadata DSL
#
# Provides a fluent builder API for defining table schemas,
# column definitions, and constraints. Generates CREATE TABLE
# and related DDL statements.

use std.database.sql.types.{DbType}
use std.database.sql.escape.{quote_ident}

# ============================================================================
# ColumnConstraint — possible constraints on a column
# ============================================================================

enum ColumnConstraint:
    PrimaryKey
    AutoIncrement
    NotNull
    Unique
    Default(value: text)
    ForeignKey(table: text, column: text)
    Check(expr: text)

impl ColumnConstraint:
    fn to_sql() -> text:
        match self:
            ColumnConstraint.PrimaryKey: "PRIMARY KEY"
            ColumnConstraint.AutoIncrement: "AUTOINCREMENT"
            ColumnConstraint.NotNull: "NOT NULL"
            ColumnConstraint.Unique: "UNIQUE"
            ColumnConstraint.Default(value): "DEFAULT {value}"
            ColumnConstraint.ForeignKey(table, column):
                val qt = quote_ident(table)
                val qc = quote_ident(column)
                "REFERENCES {qt}({qc})"
            ColumnConstraint.Check(expr): "CHECK ({expr})"

# ============================================================================
# ColumnDef — a single column definition
# ============================================================================

struct ColumnDef:
    name: text
    db_type: DbType
    constraints: [ColumnConstraint]

impl ColumnDef:
    # Constructors for common types
    static fn integer(name: text) -> ColumnDef:
        ColumnDef(name: name, db_type: DbType.Integer, constraints: [])

    static fn real(name: text) -> ColumnDef:
        ColumnDef(name: name, db_type: DbType.Real, constraints: [])

    static fn text_col(name: text) -> ColumnDef:
        ColumnDef(name: name, db_type: DbType.Text, constraints: [])

    static fn blob(name: text) -> ColumnDef:
        ColumnDef(name: name, db_type: DbType.Blob, constraints: [])

    # Fluent constraint builders
    # Since chained methods are broken, user assigns to intermediate var:
    #   var c = ColumnDef.integer("id")
    #   c = c.pk()
    #   c = c.not_null()
    me pk() -> ColumnDef:
        self.constraints.push(ColumnConstraint.PrimaryKey)
        self.constraints.push(ColumnConstraint.AutoIncrement)
        self

    me not_null() -> ColumnDef:
        self.constraints.push(ColumnConstraint.NotNull)
        self

    me unique() -> ColumnDef:
        self.constraints.push(ColumnConstraint.Unique)
        self

    me default_val(val_text: text) -> ColumnDef:
        self.constraints.push(ColumnConstraint.Default(value: val_text))
        self

    me fk(table: text, col: text) -> ColumnDef:
        self.constraints.push(ColumnConstraint.ForeignKey(table: table, column: col))
        self

    me check(expr: text) -> ColumnDef:
        self.constraints.push(ColumnConstraint.Check(expr: expr))
        self

    # Convert to SQL column definition fragment
    # e.g. "\"id\" INTEGER PRIMARY KEY AUTOINCREMENT"
    fn to_sql() -> text:
        val quoted_name = quote_ident(self.name)
        val type_str = _db_type_to_sql(self.db_type)
        var result = "{quoted_name} {type_str}"
        for constraint in self.constraints:
            val constraint_sql = constraint.to_sql()
            result = result + " " + constraint_sql
        result

# ============================================================================
# TableSchema — full table definition with columns
# ============================================================================

struct TableSchema:
    name: text
    columns: [ColumnDef]

impl TableSchema:
    static fn new(name: text) -> TableSchema:
        TableSchema(name: name, columns: [])

    # Fluent column addition
    me col(c: ColumnDef) -> TableSchema:
        self.columns.push(c)
        self

    # Convenience: add auto-increment primary key "id" column
    me id_col() -> TableSchema:
        var c = ColumnDef.integer("id")
        c = c.pk()
        self.columns.push(c)
        self

    # Convenience: add NOT NULL text column
    me text_col(name: text) -> TableSchema:
        var c = ColumnDef.text_col(name)
        c = c.not_null()
        self.columns.push(c)
        self

    # Convenience: add NOT NULL integer column
    me int_col(name: text) -> TableSchema:
        var c = ColumnDef.integer(name)
        c = c.not_null()
        self.columns.push(c)
        self

    # Convenience: add NOT NULL real column
    me real_col(name: text) -> TableSchema:
        var c = ColumnDef.real(name)
        c = c.not_null()
        self.columns.push(c)
        self

    # Convenience: add nullable text column (no NOT NULL)
    me nullable_text(name: text) -> TableSchema:
        val c = ColumnDef.text_col(name)
        self.columns.push(c)
        self

    # Convenience: add nullable integer column (no NOT NULL)
    me nullable_int(name: text) -> TableSchema:
        val c = ColumnDef.integer(name)
        self.columns.push(c)
        self

    # Get list of column names
    fn column_names() -> [text]:
        var names: [text] = []
        for col in self.columns:
            names.push(col.name)
        names

    # Generate CREATE TABLE statement
    fn to_create_sql() -> text:
        val quoted_name = quote_ident(self.name)
        var col_defs: [text] = []
        for col in self.columns:
            col_defs.push(col.to_sql())
        val cols_str = col_defs.join(", ")
        "CREATE TABLE {quoted_name} ({cols_str})"

    # Generate CREATE TABLE IF NOT EXISTS statement
    fn to_create_if_not_exists_sql() -> text:
        val quoted_name = quote_ident(self.name)
        var col_defs: [text] = []
        for col in self.columns:
            col_defs.push(col.to_sql())
        val cols_str = col_defs.join(", ")
        "CREATE TABLE IF NOT EXISTS {quoted_name} ({cols_str})"

# ============================================================================
# Helper: DbType to SQL type string
# ============================================================================

fn _db_type_to_sql(t: DbType) -> text:
    match t:
        DbType.Integer: "INTEGER"
        DbType.Real: "REAL"
        DbType.Text: "TEXT"
        DbType.Blob: "BLOB"
        DbType.Null: "NULL"
