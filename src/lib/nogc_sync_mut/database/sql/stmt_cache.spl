# Typed SQL Database Library - Statement Cache
#
# LRU statement cache keyed by SQL string. When capacity is exceeded,
# the oldest (least recently used) entry is finalized and evicted.

use std.database.sql.types.{DbError}
use std.database.sql.statement.{PreparedStatement}
use std.io.sqlite_ffi.{SqliteConnection, sqlite_prepare, SqliteStatement, sqlite_error_message}
use std.io.sffi_common.{is_valid_handle}

# ============================================================================
# StatementCache — LRU cache for PreparedStatement
# ============================================================================

class StatementCache:
    entries: Dict<text, PreparedStatement>
    order: [text]               # LRU order: front = oldest, back = most recent
    capacity: i64
    hits: i64
    misses: i64

impl StatementCache:
    static fn new(capacity: i64) -> StatementCache:
        StatementCache(
            entries: {},
            order: [],
            capacity: capacity,
            hits: 0,
            misses: 0
        )

    me get_or_prepare(conn: SqliteConnection, sql: text) -> Result<PreparedStatement, DbError>:
        """Get a cached statement or prepare a new one.

        If the SQL is already cached, moves it to the back of the LRU order
        (most recently used), resets it for reuse, and returns it.
        If not cached, prepares a new statement, adds it to the cache,
        and evicts the oldest entry if over capacity.
        """
        var entries: Dict<text, PreparedStatement> = self.entries
        if entries.has(sql):
            # Cache hit — move to back of LRU order
            self.hits = self.hits + 1
            self._move_to_back(sql)
            var stmt = entries[sql]
            stmt.reset_stmt()?
            return Ok(stmt)

        # Cache miss — prepare new statement
        self.misses = self.misses + 1
        val stmt = PreparedStatement.prepare(conn, sql)?

        # Evict oldest if at capacity
        if self.order.len() >= self.capacity:
            self._evict_oldest()

        self.entries[sql] = stmt
        self.order = self.order + [sql]
        Ok(stmt)

    me invalidate(sql: text):
        """Finalize and remove a specific entry from the cache"""
        var entries: Dict<text, PreparedStatement> = self.entries
        if entries.has(sql):
            var stmt = entries[sql]
            stmt.finalize_stmt()
            self.entries.remove(sql)
            self._remove_from_order(sql)

    me clear():
        """Finalize all entries and empty the cache"""
        var entries: Dict<text, PreparedStatement> = self.entries
        for key in self.order:
            if entries.has(key):
                var stmt = entries[key]
                stmt.finalize_stmt()
        self.entries.clear()
        self.order = []
        self.hits = 0
        self.misses = 0

    fn size() -> i64:
        """Return number of cached statements"""
        self.entries.len()

    fn hit_rate() -> f64:
        """Return cache hit rate as a fraction 0.0..1.0"""
        val total = self.hits + self.misses
        if total == 0:
            return 0.0
        self.hits.to_f64() / total.to_f64()

    # --- Internal helpers ---

    me _move_to_back(sql: text):
        """Remove sql from its current position and append to back"""
        self._remove_from_order(sql)
        self.order = self.order + [sql]

    me _remove_from_order(sql: text):
        """Remove first occurrence of sql from the order list"""
        var new_order: [text] = []
        for entry in self.order:
            if entry != sql:
                new_order = new_order + [entry]
        self.order = new_order

    me _evict_oldest():
        """Finalize and remove the least recently used entry"""
        if self.order.len() == 0:
            return

        val oldest_sql = self.order[0]
        var entries: Dict<text, PreparedStatement> = self.entries
        if entries.has(oldest_sql):
            var stmt = entries[oldest_sql]
            stmt.finalize_stmt()
            self.entries.remove(oldest_sql)

        # Remove front element
        var new_order: [text] = []
        for i in 1..self.order.len():
            new_order = new_order + [self.order[i]]
        self.order = new_order
