# Typed SQL Database Library - AOP-Style Interceptors
#
# Called explicitly by Database before/after DB operations.
# Not compiler-woven (AOP weaving is stubbed); use manual invocation.

use std.database.sql.types.{DbError}

# ============================================================================
# DbInterceptor — trait called before/after DB operations
# ============================================================================

trait DbInterceptor:
    fn before_execute(sql: text)
    fn after_execute(sql: text, duration_ms: i64, success: bool)
    fn before_query(sql: text)
    fn after_query(sql: text, duration_ms: i64, row_count: i64)

# ============================================================================
# TimingInterceptor — logs slow queries
# ============================================================================

class TimingInterceptor with DbInterceptor:
    threshold_ms: i64
    slow_queries: [text]

    static fn new(threshold_ms: i64) -> TimingInterceptor:
        TimingInterceptor(threshold_ms: threshold_ms, slow_queries: [])

    fn before_execute(sql: text):
        pass_do_nothing

    me after_execute(sql: text, duration_ms: i64, success: bool):
        if duration_ms >= self.threshold_ms:
            self.slow_queries.push("[EXEC] {sql} ({duration_ms}ms, success={success})")

    fn before_query(sql: text):
        pass_do_nothing

    me after_query(sql: text, duration_ms: i64, row_count: i64):
        if duration_ms >= self.threshold_ms:
            self.slow_queries.push("[QUERY] {sql} ({duration_ms}ms, {row_count} rows)")

    fn get_slow_queries() -> [text]:
        self.slow_queries

# ============================================================================
# LoggingInterceptor — logs all SQL operations
# ============================================================================

class LoggingInterceptor with DbInterceptor:
    log_entries: [text]

    static fn new() -> LoggingInterceptor:
        LoggingInterceptor(log_entries: [])

    me before_execute(sql: text):
        self.log_entries.push("[EXEC] {sql}")

    me after_execute(sql: text, duration_ms: i64, success: bool):
        self.log_entries.push("[EXEC DONE] {sql} ({duration_ms}ms, success={success})")

    me before_query(sql: text):
        self.log_entries.push("[QUERY] {sql}")

    me after_query(sql: text, duration_ms: i64, row_count: i64):
        self.log_entries.push("[QUERY DONE] {sql} ({duration_ms}ms, {row_count} rows)")

    fn get_log() -> [text]:
        self.log_entries

    me clear_log():
        self.log_entries = []

# ============================================================================
# RetryInterceptor — tracks retries on failure
# ============================================================================

class RetryInterceptor with DbInterceptor:
    max_retries: i64
    delay_ms: i64
    retry_count: i64

    static fn new(max_retries: i64, delay_ms: i64) -> RetryInterceptor:
        RetryInterceptor(max_retries: max_retries, delay_ms: delay_ms, retry_count: 0)

    fn before_execute(sql: text):
        pass_do_nothing

    me after_execute(sql: text, duration_ms: i64, success: bool):
        if not success:
            self.retry_count = self.retry_count + 1

    fn before_query(sql: text):
        pass_do_nothing

    fn after_query(sql: text, duration_ms: i64, row_count: i64):
        pass_do_nothing

    fn get_retry_count() -> i64:
        self.retry_count
