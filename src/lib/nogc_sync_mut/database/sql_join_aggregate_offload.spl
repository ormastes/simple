# codex-impl
# CPU-authoritative SQL join/aggregate adapter over the reusable DB query offload facade.

use std.database.sql.types.{DbRow, DbValue}
use std.database.offload_profile.{DbOffloadProfile, db_offload_profile_execute}
use std.database.query_offload.{db_query_offload_execute, db_query_offload_execute_rows_device_validated, db_query_rows}
use std.database.storage_mode_offload.{
    DbStorageOffloadMode,
    DbStorageOffloadWorkload,
    DbStorageOffloadExecution,
    DbStorageDeviceOffloadExecution,
    db_storage_offload_used_gpu
}
use std.web_db_offload.contract.{GpuWdbBudget}
use std.web_db_offload.queue.{GpuWdbQueueState}
use std.web_db_offload.library.{GpuWdbLibraryRegistry}
use std.web_db_offload.device_backend.{GpuWdbDeviceBackend}

struct SqlJoinAggregateOffloadExecution:
    rows: [DbRow]
    offload: DbStorageOffloadExecution
    cpu_authoritative: bool
    gpu_candidate_validated: bool
    validation_reason: text

struct SqlJoinAggregateDeviceOffloadExecution:
    rows: [DbRow]
    offload: DbStorageOffloadExecution
    device_offload: DbStorageDeviceOffloadExecution
    cpu_authoritative: bool
    gpu_candidate_validated: bool
    validation_reason: text

fn sql_join_aggregate_values_equal(left: DbValue, right: DbValue) -> bool:
    left.to_text() == right.to_text()

fn sql_join_aggregate_rows_equal(left: DbRow, right: DbRow) -> bool:
    if left.columns.len() != right.columns.len():
        return false
    if left.values.len() != right.values.len():
        return false
    var i: i64 = 0
    while i < left.columns.len():
        if left.columns[i] != right.columns[i]:
            return false
        i = i + 1
    var v: i64 = 0
    while v < left.values.len():
        if not sql_join_aggregate_values_equal(left.values[v], right.values[v]):
            return false
        v = v + 1
    true

fn sql_join_aggregate_result_rows_equal(cpu_rows: [DbRow], gpu_rows: [DbRow]) -> bool:
    if cpu_rows.len() != gpu_rows.len():
        return false
    var i: i64 = 0
    while i < cpu_rows.len():
        if not sql_join_aggregate_rows_equal(cpu_rows[i], gpu_rows[i]):
            return false
        i = i + 1
    true

fn sql_join_aggregate_cpu_fallback_from_offload(offload: DbStorageOffloadExecution,
                                                reason: text) -> DbStorageOffloadExecution:
    DbStorageOffloadExecution(
        mode: offload.mode,
        workload: offload.workload,
        profile: offload.profile,
        dispatch_target: "cpu_fallback",
        reason: reason,
        gpu_dispatched: false,
        cpu_authoritative: true,
        row_ids: offload.row_ids,
        document_ids: offload.document_ids,
        vector_ids: offload.vector_ids,
        queue_depth_after: offload.queue_depth_after,
        completed_count: offload.completed_count,
        state_after: offload.state_after,
        gpu_candidate_validated: false,
        validation_reason: reason
    )

fn sql_join_aggregate_offload_with_validation(offload: DbStorageOffloadExecution,
                                              validated: bool,
                                              reason: text) -> DbStorageOffloadExecution:
    DbStorageOffloadExecution(
        mode: offload.mode,
        workload: offload.workload,
        profile: offload.profile,
        dispatch_target: offload.dispatch_target,
        reason: offload.reason,
        gpu_dispatched: offload.gpu_dispatched,
        cpu_authoritative: offload.cpu_authoritative,
        row_ids: offload.row_ids,
        document_ids: offload.document_ids,
        vector_ids: offload.vector_ids,
        queue_depth_after: offload.queue_depth_after,
        completed_count: offload.completed_count,
        state_after: offload.state_after,
        gpu_candidate_validated: validated,
        validation_reason: reason
    )

fn sql_join_aggregate_offload_execute(rows: [DbRow],
                                      cpu_row_ids: [i64],
                                      mode: DbStorageOffloadMode,
                                      state: GpuWdbQueueState,
                                      registry: GpuWdbLibraryRegistry,
                                      gpu_available: bool,
                                      wal_generation_current: bool,
                                      cpu_fallback_available: bool,
                                      budget: GpuWdbBudget,
                                      bytes_per_row: i64) -> SqlJoinAggregateOffloadExecution:
    SqlJoinAggregateOffloadExecution(
        rows: rows,
        offload: db_query_offload_execute(
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                cpu_row_ids.len(),
                bytes_per_row,
                wal_generation_current,
                cpu_row_ids
            ),
            state,
            registry,
            gpu_available,
            cpu_fallback_available,
            budget
        ),
        cpu_authoritative: true,
        gpu_candidate_validated: false,
        validation_reason: "gpu-candidate-not-provided"
    )

fn sql_join_aggregate_offload_execute_profile(rows: [DbRow],
                                              cpu_row_ids: [i64],
                                              profile: DbOffloadProfile,
                                              mode: DbStorageOffloadMode,
                                              wal_generation_current: bool,
                                              bytes_per_row: i64) -> SqlJoinAggregateOffloadExecution:
    SqlJoinAggregateOffloadExecution(
        rows: rows,
        offload: db_offload_profile_execute(
            profile,
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                cpu_row_ids.len(),
                bytes_per_row,
                wal_generation_current,
                cpu_row_ids
            )
        ),
        cpu_authoritative: true,
        gpu_candidate_validated: false,
        validation_reason: "gpu-candidate-not-provided"
    )

fn sql_join_aggregate_offload_execute_profile_validated(rows: [DbRow],
                                                        gpu_candidate_rows: [DbRow],
                                                        cpu_row_ids: [i64],
                                                        profile: DbOffloadProfile,
                                                        mode: DbStorageOffloadMode,
                                                        wal_generation_current: bool,
                                                        bytes_per_row: i64) -> SqlJoinAggregateOffloadExecution:
    val execution = sql_join_aggregate_offload_execute_profile(
        rows,
        cpu_row_ids,
        profile,
        mode,
        wal_generation_current,
        bytes_per_row
    )
    if not db_storage_offload_used_gpu(execution.offload):
        return SqlJoinAggregateOffloadExecution(
            rows: rows,
            offload: sql_join_aggregate_offload_with_validation(
                execution.offload,
                false,
                "gpu-not-dispatched"
            ),
            cpu_authoritative: true,
            gpu_candidate_validated: false,
            validation_reason: "gpu-not-dispatched"
        )
    if sql_join_aggregate_result_rows_equal(rows, gpu_candidate_rows):
        return SqlJoinAggregateOffloadExecution(
            rows: rows,
            offload: sql_join_aggregate_offload_with_validation(
                execution.offload,
                true,
                "gpu-cpu-row-match"
            ),
            cpu_authoritative: true,
            gpu_candidate_validated: true,
            validation_reason: "gpu-cpu-row-match"
        )
    SqlJoinAggregateOffloadExecution(
        rows: rows,
        offload: sql_join_aggregate_cpu_fallback_from_offload(
            execution.offload,
            "gpu-cpu-row-mismatch"
        ),
        cpu_authoritative: true,
        gpu_candidate_validated: false,
        validation_reason: "gpu-cpu-row-mismatch"
    )

fn sql_join_aggregate_offload_execute_validated(rows: [DbRow],
                                                gpu_candidate_rows: [DbRow],
                                                cpu_row_ids: [i64],
                                                mode: DbStorageOffloadMode,
                                                state: GpuWdbQueueState,
                                                registry: GpuWdbLibraryRegistry,
                                                gpu_available: bool,
                                                wal_generation_current: bool,
                                                cpu_fallback_available: bool,
                                                budget: GpuWdbBudget,
                                                bytes_per_row: i64) -> SqlJoinAggregateOffloadExecution:
    val execution = sql_join_aggregate_offload_execute(
        rows,
        cpu_row_ids,
        mode,
        state,
        registry,
        gpu_available,
        wal_generation_current,
        cpu_fallback_available,
        budget,
        bytes_per_row
    )
    if not db_storage_offload_used_gpu(execution.offload):
        return SqlJoinAggregateOffloadExecution(
            rows: rows,
            offload: sql_join_aggregate_offload_with_validation(
                execution.offload,
                false,
                "gpu-not-dispatched"
            ),
            cpu_authoritative: true,
            gpu_candidate_validated: false,
            validation_reason: "gpu-not-dispatched"
        )
    if sql_join_aggregate_result_rows_equal(rows, gpu_candidate_rows):
        return SqlJoinAggregateOffloadExecution(
            rows: rows,
            offload: sql_join_aggregate_offload_with_validation(
                execution.offload,
                true,
                "gpu-cpu-row-match"
            ),
            cpu_authoritative: true,
            gpu_candidate_validated: true,
            validation_reason: "gpu-cpu-row-match"
        )
    SqlJoinAggregateOffloadExecution(
        rows: rows,
        offload: sql_join_aggregate_cpu_fallback_from_offload(
            execution.offload,
            "gpu-cpu-row-mismatch"
        ),
        cpu_authoritative: true,
        gpu_candidate_validated: false,
        validation_reason: "gpu-cpu-row-mismatch"
    )

fn sql_join_aggregate_offload_execute_device_validated(rows: [DbRow],
                                                       gpu_candidate_rows: [DbRow],
                                                       cpu_row_ids: [i64],
                                                       gpu_candidate_row_ids: [i64],
                                                       mode: DbStorageOffloadMode,
                                                       state: GpuWdbQueueState,
                                                       backend: GpuWdbDeviceBackend,
                                                       wal_generation_current: bool,
                                                       expected_backend_generation: i64,
                                                       cpu_fallback_available: bool,
                                                       budget: GpuWdbBudget,
                                                       bytes_per_row: i64,
                                                       started_us: i64,
                                                       finished_us: i64,
                                                       measured_device_time_us: i64,
                                                       timing_source: text) -> SqlJoinAggregateDeviceOffloadExecution:
    val device_offload = db_query_offload_execute_rows_device_validated(
        db_query_rows(
            mode,
            DbStorageOffloadWorkload.JoinAggregate,
            cpu_row_ids.len(),
            bytes_per_row,
            wal_generation_current,
            cpu_row_ids
        ),
        state,
        backend,
        expected_backend_generation,
        cpu_fallback_available,
        budget,
        gpu_candidate_row_ids,
        started_us,
        finished_us,
        measured_device_time_us,
        timing_source
    )
    if not db_storage_offload_used_gpu(device_offload.execution):
        return SqlJoinAggregateDeviceOffloadExecution(
            rows: rows,
            offload: device_offload.execution,
            device_offload: device_offload,
            cpu_authoritative: true,
            gpu_candidate_validated: false,
            validation_reason: device_offload.execution.validation_reason
        )
    if sql_join_aggregate_result_rows_equal(rows, gpu_candidate_rows):
        return SqlJoinAggregateDeviceOffloadExecution(
            rows: gpu_candidate_rows,
            offload: device_offload.execution,
            device_offload: device_offload,
            cpu_authoritative: false,
            gpu_candidate_validated: true,
            validation_reason: device_offload.execution.validation_reason
        )
    val fallback = sql_join_aggregate_cpu_fallback_from_offload(
        device_offload.execution,
        "production-gpu-sql-row-mismatch"
    )
    SqlJoinAggregateDeviceOffloadExecution(
        rows: rows,
        offload: fallback,
        device_offload: device_offload,
        cpu_authoritative: true,
        gpu_candidate_validated: false,
        validation_reason: "production-gpu-sql-row-mismatch"
    )

fn sql_join_aggregate_offload_used_gpu(execution: SqlJoinAggregateOffloadExecution) -> bool:
    db_storage_offload_used_gpu(execution.offload)
