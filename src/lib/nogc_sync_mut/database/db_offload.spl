# codex-impl
# RAM/SSD coarse DB batch adapter for reusable web/db GPU queue accounting.

use std.database.gpu_mode_plan.{
    DbGpuMode,
    DbGpuModePlan,
    db_gpu_mode_plan
}
use std.web_db_offload.contract.{
    GpuWdbWorkKind,
    GpuWdbBudget,
    gpu_wdb_profile_allows_gpu,
    gpu_wdb_default_budget
}
use std.web_db_offload.queue.{
    GpuWdbQueueState,
    GpuWdbQueueSubmission,
    gpu_wdb_queue_snapshot,
    gpu_wdb_complete_submission
}
use std.web_db_offload.library.{
    GpuWdbLibraryRegistry,
    gpu_wdb_library_with_targets,
    gpu_wdb_submit_registered_batch_for_generation
}
use std.web_db_offload.device_backend.{
    GpuWdbDeviceBackend,
    GpuWdbDeviceRunResult,
    gpu_wdb_run_device_batch
}

enum DbGpuBatchKind:
    ScanFilterProject
    JoinAggregate

struct DbGpuBatchOffloadExecution:
    mode: DbGpuMode
    batch_kind: DbGpuBatchKind
    plan: DbGpuModePlan
    submission: GpuWdbQueueSubmission
    state_after: GpuWdbQueueState
    result_row_ids: [i64]
    gpu_dispatched: bool
    cpu_authoritative: bool

struct DbGpuBatchDeviceOffloadExecution:
    execution: DbGpuBatchOffloadExecution
    device_result: GpuWdbDeviceRunResult

fn db_gpu_batch_work_kind(batch_kind: DbGpuBatchKind) -> GpuWdbWorkKind:
    match batch_kind:
        DbGpuBatchKind.ScanFilterProject: GpuWdbWorkKind.DbScanFilterProject
        DbGpuBatchKind.JoinAggregate: GpuWdbWorkKind.DbJoinAggregate

fn db_gpu_batch_offload_execute(mode: DbGpuMode, batch_kind: DbGpuBatchKind,
                                row_count: i64, bytes_per_row: i64,
                                state: GpuWdbQueueState,
                                registry: GpuWdbLibraryRegistry,
                                gpu_available: bool,
                                wal_generation_current: bool,
                                cpu_fallback_available: bool,
                                budget: GpuWdbBudget,
                                cpu_result_row_ids: [i64]) -> DbGpuBatchOffloadExecution:
    db_gpu_batch_offload_execute_for_generation(
        mode,
        batch_kind,
        row_count,
        bytes_per_row,
        state,
        registry,
        gpu_available,
        wal_generation_current,
        registry.generation,
        cpu_fallback_available,
        budget,
        cpu_result_row_ids
    )

fn db_gpu_batch_offload_execute_for_generation(mode: DbGpuMode, batch_kind: DbGpuBatchKind,
                                               row_count: i64, bytes_per_row: i64,
                                               state: GpuWdbQueueState,
                                               registry: GpuWdbLibraryRegistry,
                                               gpu_available: bool,
                                               wal_generation_current: bool,
                                               expected_registry_generation: i64,
                                               cpu_fallback_available: bool,
                                               budget: GpuWdbBudget,
                                               cpu_result_row_ids: [i64]) -> DbGpuBatchOffloadExecution:
    val plan = db_gpu_mode_plan(
        mode,
        row_count,
        bytes_per_row,
        gpu_wdb_queue_snapshot(
            state,
            gpu_available,
            wal_generation_current,
            cpu_fallback_available
        ),
        wal_generation_current,
        true,
        budget
    )
    val work_kind = db_gpu_batch_work_kind(batch_kind)
    val effective_expected_generation =
        if plan.wal_generation_current:
            expected_registry_generation
        else:
            -1
    val submission = gpu_wdb_submit_registered_batch_for_generation(
        state,
        registry,
        work_kind,
        plan.batch_bytes,
        plan.item_count,
        gpu_available,
        effective_expected_generation,
        cpu_fallback_available,
        budget
    )
    val state_after =
        if submission.accepted:
            gpu_wdb_complete_submission(submission.state, submission)
        else:
            submission.state
    DbGpuBatchOffloadExecution(
        mode: mode,
        batch_kind: batch_kind,
        plan: plan,
        submission: submission,
        state_after: state_after,
        result_row_ids: cpu_result_row_ids,
        gpu_dispatched: submission.accepted,
        cpu_authoritative: true
    )

fn db_gpu_batch_offload_execute_device_for_generation(mode: DbGpuMode,
                                                      batch_kind: DbGpuBatchKind,
                                                      row_count: i64,
                                                      bytes_per_row: i64,
                                                      state: GpuWdbQueueState,
                                                      backend: GpuWdbDeviceBackend,
                                                      wal_generation_current: bool,
                                                      expected_backend_generation: i64,
                                                      cpu_fallback_available: bool,
                                                      budget: GpuWdbBudget,
                                                      cpu_result_row_ids: [i64],
                                                      started_us: i64,
                                                      finished_us: i64,
                                                      measured_device_time_us: i64,
                                                      timing_source: text) -> DbGpuBatchDeviceOffloadExecution:
    val registry = gpu_wdb_library_with_targets(backend.backend, backend.generation, backend.available_targets)
    val execution = db_gpu_batch_offload_execute_for_generation(
        mode,
        batch_kind,
        row_count,
        bytes_per_row,
        state,
        registry,
        backend.native_device_execution,
        wal_generation_current,
        expected_backend_generation,
        cpu_fallback_available,
        budget,
        cpu_result_row_ids
    )
    val plan = db_gpu_mode_plan(
        mode,
        row_count,
        bytes_per_row,
        gpu_wdb_queue_snapshot(
            state,
            backend.native_device_execution,
            wal_generation_current,
            cpu_fallback_available
        ),
        wal_generation_current,
        true,
        budget
    )
    val effective_expected_generation =
        if plan.wal_generation_current:
            expected_backend_generation
        else:
            -1
    val device_result = gpu_wdb_run_device_batch(
        state,
        backend,
        db_gpu_batch_work_kind(batch_kind),
        plan.batch_bytes,
        plan.item_count,
        effective_expected_generation,
        cpu_fallback_available,
        budget,
        started_us,
        finished_us,
        measured_device_time_us,
        timing_source
    )
    DbGpuBatchDeviceOffloadExecution(
        execution: execution,
        device_result: device_result
    )

fn db_gpu_batch_offload_execute_default(mode: DbGpuMode, batch_kind: DbGpuBatchKind,
                                        row_count: i64, bytes_per_row: i64,
                                        state: GpuWdbQueueState,
                                        registry: GpuWdbLibraryRegistry,
                                        gpu_available: bool,
                                        wal_generation_current: bool,
                                        cpu_fallback_available: bool,
                                        cpu_result_row_ids: [i64]) -> DbGpuBatchOffloadExecution:
    db_gpu_batch_offload_execute(
        mode,
        batch_kind,
        row_count,
        bytes_per_row,
        state,
        registry,
        gpu_available,
        wal_generation_current,
        cpu_fallback_available,
        gpu_wdb_default_budget(),
        cpu_result_row_ids
    )

fn db_gpu_batch_offload_used_gpu(execution: DbGpuBatchOffloadExecution) -> bool:
    execution.gpu_dispatched and db_gpu_batch_profile_allows_gpu(execution)

fn db_gpu_batch_profile_allows_gpu(execution: DbGpuBatchOffloadExecution) -> bool:
    gpu_wdb_profile_allows_gpu(execution.plan.profile, execution.submission.execution.decision)
