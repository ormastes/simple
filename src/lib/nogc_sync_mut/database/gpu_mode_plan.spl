# codex-impl
# Planner-only DB GPU mode support.  Execution remains CPU authoritative until
# a backend integrates the returned shared offload plan.

use std.web_db_offload.contract.{
    GpuWdbWorkKind,
    GpuWdbBudget,
    GpuWdbRuntimeSnapshot,
    GpuWdbBatchPlan,
    GpuWdbCoarseBatchProfile,
    GpuWdbDecisionPath,
    gpu_wdb_default_budget,
    gpu_wdb_batch_window,
    gpu_wdb_batch_plan,
    gpu_wdb_nosql_mode_admits,
    gpu_wdb_ram_db_profile,
    gpu_wdb_ssd_db_profile,
    gpu_wdb_nosql_db_profile,
    gpu_wdb_vector_db_profile,
    gpu_wdb_profile_allows_gpu
}

enum DbGpuMode:
    RamOnly
    SsdAccelerated
    NoSqlDocument
    VectorSearch

struct DbGpuModePlan:
    mode: DbGpuMode
    work_kind: GpuWdbWorkKind
    batch_bytes: i64
    item_count: i64
    batch: GpuWdbBatchPlan
    profile: GpuWdbCoarseBatchProfile
    wal_generation_current: bool
    metadata_filter_cpu_owned: bool

fn db_gpu_mode_default_budget() -> GpuWdbBudget:
    gpu_wdb_default_budget()

fn db_gpu_mode_work_kind(mode: DbGpuMode) -> GpuWdbWorkKind:
    match mode:
        DbGpuMode.RamOnly: GpuWdbWorkKind.DbScanFilterProject
        DbGpuMode.SsdAccelerated: GpuWdbWorkKind.DbScanFilterProject
        DbGpuMode.NoSqlDocument: GpuWdbWorkKind.DbDocumentFilter
        DbGpuMode.VectorSearch: GpuWdbWorkKind.DbVectorSearch

fn db_gpu_mode_profile(mode: DbGpuMode) -> GpuWdbCoarseBatchProfile:
    match mode:
        DbGpuMode.RamOnly: gpu_wdb_ram_db_profile()
        DbGpuMode.SsdAccelerated: gpu_wdb_ssd_db_profile()
        DbGpuMode.NoSqlDocument: gpu_wdb_nosql_db_profile()
        DbGpuMode.VectorSearch: gpu_wdb_vector_db_profile()

fn db_gpu_mode_estimate_batch_bytes(row_count: i64, bytes_per_row: i64) -> i64:
    if row_count <= 0:
        return 0
    if bytes_per_row <= 0:
        return 0
    row_count * bytes_per_row

fn db_gpu_mode_plan(mode: DbGpuMode, row_count: i64, bytes_per_row: i64,
                    snapshot: GpuWdbRuntimeSnapshot, wal_generation_current: bool,
                    metadata_filter_cpu_owned: bool, budget: GpuWdbBudget) -> DbGpuModePlan:
    val batch_bytes = db_gpu_mode_estimate_batch_bytes(row_count, bytes_per_row)
    val work_kind = db_gpu_mode_work_kind(mode)
    if mode == DbGpuMode.SsdAccelerated and not wal_generation_current:
        val stale_window = gpu_wdb_batch_window(work_kind, batch_bytes, row_count,
            GpuWdbRuntimeSnapshot(
                queue_depth: snapshot.queue_depth,
                gpu_available: snapshot.gpu_available,
                generation_current: false,
                cpu_fallback_available: snapshot.cpu_fallback_available
            )
        )
        return DbGpuModePlan(
            mode: mode,
            work_kind: work_kind,
            batch_bytes: batch_bytes,
            item_count: row_count,
            batch: gpu_wdb_batch_plan(stale_window, budget),
            profile: db_gpu_mode_profile(mode),
            wal_generation_current: wal_generation_current,
            metadata_filter_cpu_owned: metadata_filter_cpu_owned
        )

    if mode == DbGpuMode.NoSqlDocument and not metadata_filter_cpu_owned:
        val reject = gpu_wdb_nosql_mode_admits(batch_bytes, false, budget)
        val reject_window = gpu_wdb_batch_window(work_kind, batch_bytes, row_count, snapshot)
        var batch = gpu_wdb_batch_plan(reject_window, budget)
        batch.execution.decision = reject
        batch.execution.target = "cpu_fallback"
        return DbGpuModePlan(
            mode: mode,
            work_kind: work_kind,
            batch_bytes: batch_bytes,
            item_count: row_count,
            batch: batch,
            profile: db_gpu_mode_profile(mode),
            wal_generation_current: wal_generation_current,
            metadata_filter_cpu_owned: metadata_filter_cpu_owned
        )

    val window = gpu_wdb_batch_window(work_kind, batch_bytes, row_count, snapshot)
    DbGpuModePlan(
        mode: mode,
        work_kind: work_kind,
        batch_bytes: batch_bytes,
        item_count: row_count,
        batch: gpu_wdb_batch_plan(window, budget),
        profile: db_gpu_mode_profile(mode),
        wal_generation_current: wal_generation_current,
        metadata_filter_cpu_owned: metadata_filter_cpu_owned
    )

fn db_gpu_mode_plan_default(mode: DbGpuMode, row_count: i64, bytes_per_row: i64,
                            snapshot: GpuWdbRuntimeSnapshot, wal_generation_current: bool,
                            metadata_filter_cpu_owned: bool) -> DbGpuModePlan:
    db_gpu_mode_plan(
        mode,
        row_count,
        bytes_per_row,
        snapshot,
        wal_generation_current,
        metadata_filter_cpu_owned,
        gpu_wdb_default_budget()
    )

fn db_gpu_mode_plan_uses_gpu(plan: DbGpuModePlan) -> bool:
    gpu_wdb_profile_allows_gpu(plan.profile, plan.batch.execution.decision)
