use nogc_sync_mut.database.core.{SdnDatabase}
use nogc_sync_mut.database.vector.store.{VectorDatabase}
use nogc_sync_mut.database.vector.types.{VectorDbConfig, DistanceMetric, default_vector_config}

struct DbRegistryEntry:
    name: text
    db_type: text
    path: text

class DbRegistry:
    sdn_databases: Dict<text, SdnDatabase>
    vector_databases: Dict<text, VectorDatabase>
    entries: [DbRegistryEntry]

    static fn new() -> DbRegistry:
        DbRegistry(
            sdn_databases: {},
            vector_databases: {},
            entries: []
        )

    static fn from_groups(groups: [DbRegistryEntry]) -> Result<DbRegistry, text>:
        var registry = DbRegistry.new()
        for entry in groups:
            if entry.db_type == "sdn":
                val db = SdnDatabase.new(entry.path)
                registry.sdn_databases.insert(entry.name, db)
                registry.entries.push(entry)
            elif entry.db_type == "vector":
                val cfg = default_vector_config(384)
                val result = VectorDatabase.create(entry.path, cfg)
                match result:
                    Ok(db):
                        registry.vector_databases.insert(entry.name, db)
                        registry.entries.push(entry)
                    Err(_):
                        return Err("failed to create vector database '{entry.name}': {entry.path}")
            elif entry.db_type == "sqlite":
                # Pool creation requires connection config — store entry only; caller opens pool
                registry.entries.push(entry)
            else:
                return Err("unknown db_type '{entry.db_type}' for database '{entry.name}'")
        Ok(registry)

    fn get_sdn(name: text) -> Option<SdnDatabase>:
        self.sdn_databases.get(name)

    fn get_vector(name: text) -> Option<VectorDatabase>:
        self.vector_databases.get(name)

    fn list_databases() -> [DbRegistryEntry]:
        self.entries

    me save_all() -> bool:
        var all_ok = true
        for entry in self.entries:
            if entry.db_type == "sdn":
                val db = self.sdn_databases.get(entry.name)
                if db != nil:
                    if not db.save():
                        all_ok = false
            elif entry.db_type == "vector":
                val db = self.vector_databases.get(entry.name)
                if db != nil:
                    if not db.save():
                        all_ok = false
        all_ok

    me close_all():
        for entry in self.entries:
            if entry.db_type == "sdn":
                val db = self.sdn_databases.get(entry.name)
                if db != nil:
                    db.save()
            elif entry.db_type == "vector":
                val db = self.vector_databases.get(entry.name)
                if db != nil:
                    db.save()
