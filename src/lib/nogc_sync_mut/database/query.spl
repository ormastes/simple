# Query Builder for SDN Databases
#
# Provides fluent query interface with filtering, sorting, and limiting.

use nogc_sync_mut.database.core.{SdnTable, SdnRow}
use std.db.accel.{
    accel_capability_report,
    DB_ACCEL_DEFAULT_BATCH_SIZE, RowBitmap,
    row_bitmap_indices, text_equals_span
}
use std.db.prefix_index.{
    PrefixIndex,
    prefix_index_insert, prefix_index_lookup_prefix, prefix_index_new,
    prefix_index_sort
}
use std.database.storage_mode_offload.{
    DbStorageOffloadMode,
    DbStorageOffloadWorkload,
    DbStorageOffloadExecution,
    DbStorageDeviceOffloadExecution
}
use std.database.query_offload.{
    DbQueryAccumulatedOffloadExecution,
    db_query_join_aggregate_count_execute,
    db_query_offload_execute,
    db_query_offload_execute_rows_device_validated,
    db_query_offload_execute_ssd_materialized_scan_validated,
    db_query_offload_execute_ssd_materialized_scan_device_validated,
    db_query_offload_execute_accumulating,
    db_query_rows
}
use std.db.dbfs_engine.offload_snapshot.{DbfsSsdScanMaterialization}
use std.web_db_offload.contract.{GpuWdbBudget}
use std.web_db_offload.queue.{GpuWdbQueueState}
use std.web_db_offload.library.{GpuWdbLibraryRegistry}
use std.web_db_offload.device_backend.{GpuWdbDeviceBackend}
use std.web_db_offload.scheduler.{GpuWdbBatchAccumulator, GpuWdbScheduleClass}

val QUERY_ACCEL_SIMD_ACTIVE = accel_capability_report().simd_active

# ============================================================================
# Compare Operators
# ============================================================================

enum CompareOp:
    Eq           # Equal
    Ne           # Not equal
    Gt           # Greater than
    Ge           # Greater or equal
    Lt           # Less than
    Le           # Less or equal
    Contains     # String contains
    StartsWith   # String starts with
    EndsWith     # String ends with
    InSet        # Any-of equality

# ============================================================================
# Filter
# ============================================================================

struct Filter:
    field: text
    op: CompareOp
    value: text
    any_values: [text]

    # Check if row matches filter
    fn matches(row: SdnRow) -> bool:
        val field_value = row.get(self.field)
        if not field_value.?:
            return false

        val fv = field_value.unwrap()
        self.matches_value(fv)

    fn matches_value(fv: text) -> bool:
        if self.op == CompareOp.Eq:
            return text_equals_span(fv, self.value)
        if self.op == CompareOp.Ne:
            return not text_equals_span(fv, self.value)
        if self.op == CompareOp.Gt:
            return fv > self.value
        if self.op == CompareOp.Ge:
            return fv >= self.value
        if self.op == CompareOp.Lt:
            return fv < self.value
        if self.op == CompareOp.Le:
            return fv <= self.value
        if self.op == CompareOp.Contains:
            return fv.contains(self.value)
        if self.op == CompareOp.StartsWith:
            return fv.starts_with(self.value)
        if self.op == CompareOp.EndsWith:
            return fv.ends_with(self.value)
        for candidate in self.any_values:
            if text_equals_span(fv, candidate):
                return true
        false

# ============================================================================
# QueryBuilder
# ============================================================================

struct QueryBuilderOffloadExecution:
    rows: [SdnRow]
    offload: DbStorageOffloadExecution

struct QueryBuilderDeviceOffloadExecution:
    rows: [SdnRow]
    offload: DbStorageDeviceOffloadExecution

struct QueryBuilderAggregateOffloadExecution:
    count: i64
    offload: DbStorageOffloadExecution

struct QueryBuilderAggregateDeviceOffloadExecution:
    count: i64
    offload: DbStorageDeviceOffloadExecution

struct QueryBuilderSumOffloadExecution:
    sum: i64
    offload: DbStorageOffloadExecution

struct QueryBuilderSumDeviceOffloadExecution:
    sum: i64
    offload: DbStorageDeviceOffloadExecution

struct QueryBuilderScalarOffloadExecution:
    value: i64
    offload: DbStorageOffloadExecution

struct QueryBuilderScalarDeviceOffloadExecution:
    value: i64
    offload: DbStorageDeviceOffloadExecution

struct QueryBuilderAggregateAccumulatedOffloadExecution:
    count: i64
    accumulated: DbQueryAccumulatedOffloadExecution

fn query_builder_i64_ids_equal(left: [i64], right: [i64]) -> bool:
    if left.len() != right.len():
        return false
    var i: i64 = 0
    while i < left.len():
        if left[i] != right[i]:
            return false
        i = i + 1
    true

fn query_builder_rows_from_ssd_projection(materialization: DbfsSsdScanMaterialization) -> [SdnRow]:
    var rows: [SdnRow] = []
    for projected in materialization.projected_rows:
        val row = SdnRow.empty()
        for column in materialization.projected_columns:
            if projected.values.contains_key(column):
                row.set(column, projected.values[column])
        rows.push(row)
    rows

fn query_builder_sum_from_ssd_projection(materialization: DbfsSsdScanMaterialization, field: text) -> i64:
    var total: i64 = 0
    for projected in materialization.projected_rows:
        if projected.values.contains_key(field):
            total = total + projected.values[field].to_int()
    total

fn query_builder_avg_from_ssd_projection(materialization: DbfsSsdScanMaterialization, field: text) -> i64:
    var total: i64 = 0
    var count: i64 = 0
    for projected in materialization.projected_rows:
        if projected.values.contains_key(field):
            total = total + projected.values[field].to_int()
            count = count + 1
    if count == 0:
        return 0
    total / count

fn query_builder_min_from_ssd_projection(materialization: DbfsSsdScanMaterialization, field: text) -> i64:
    var has_value = false
    var best: i64 = 0
    for projected in materialization.projected_rows:
        if projected.values.contains_key(field):
            val value = projected.values[field].to_int()
            if not has_value or value < best:
                best = value
                has_value = true
    best

fn query_builder_max_from_ssd_projection(materialization: DbfsSsdScanMaterialization, field: text) -> i64:
    var has_value = false
    var best: i64 = 0
    for projected in materialization.projected_rows:
        if projected.values.contains_key(field):
            val value = projected.values[field].to_int()
            if not has_value or value > best:
                best = value
                has_value = true
    best

fn query_builder_count_from_ssd_projection(materialization: DbfsSsdScanMaterialization) -> i64:
    materialization.row_ids.len()

fn query_builder_device_offload_with_cpu_reason(execution: DbStorageDeviceOffloadExecution,
                                                reason: text) -> DbStorageDeviceOffloadExecution:
    val base = execution.execution
    DbStorageDeviceOffloadExecution(
        execution: DbStorageOffloadExecution(
            mode: base.mode,
            workload: base.workload,
            profile: base.profile,
            dispatch_target: "cpu_fallback",
            reason: reason,
            gpu_dispatched: false,
            cpu_authoritative: true,
            row_ids: base.row_ids,
            document_ids: base.document_ids,
            vector_ids: base.vector_ids,
            queue_depth_after: base.queue_depth_after,
            completed_count: base.completed_count,
            state_after: base.state_after,
            gpu_candidate_validated: false,
            validation_reason: reason
        ),
        device_execution: execution.device_execution
    )

class QueryBuilder:
    table: SdnTable
    filters: [Filter]
    sort_field: text
    has_sort_field: bool
    sort_desc: bool
    limit_count: i64
    has_limit_count: bool
    prefix_indexes: Dict<text, PrefixIndex>
    prefix_index_builds: i64

    # Create query builder for table
    static fn for_table(table: SdnTable) -> QueryBuilder:
        QueryBuilder(
            table: table,
            filters: [],
            sort_field: "",
            has_sort_field: false,
            sort_desc: false,
            limit_count: 0,
            has_limit_count: false,
            prefix_indexes: {},
            prefix_index_builds: 0
        )

    # Add filter condition
    me filter_by(field: text, op: CompareOp, value: text) -> QueryBuilder:
        self.filters.push(Filter(field: field, op: op, value: value, any_values: []))
        self

    # Filter by multiple values (field IN (values))
    me filter_in(field: text, values: [text]) -> QueryBuilder:
        self.filters.push(Filter(field: field, op: CompareOp.InSet, value: "", any_values: values))
        self

    # Exclude soft-deleted rows (valid=true)
    me only_valid() -> QueryBuilder:
        self.filter_by("valid", CompareOp.Eq, "true")

    # Sort results
    me order_by(field: text, desc: bool) -> QueryBuilder:
        self.sort_field = field
        self.has_sort_field = true
        self.sort_desc = desc
        self

    # Limit results
    me take(n: i64) -> QueryBuilder:
        self.limit_count = n
        self.has_limit_count = true
        self

    me execute_row_ids() -> [i64]:
        if self.has_limit_count and self.limit_count == 0:
            return []

        var row_ids = all_row_ids(self.table.rows.len())

        if self.filters.len() > 0:
            if QUERY_ACCEL_SIMD_ACTIVE and self.filters.len() > 2:
                val bitmap = self.execute_bitmap()
                row_ids = row_bitmap_indices(bitmap)
            else:
                row_ids = self.execute_scalar_row_ids()

        # Apply sorting (merge sort - O(n log n) stable sort)
        if self.has_sort_field:
            row_ids = merge_sort_row_ids(self.table.rows, row_ids, self.sort_field, self.sort_desc)

        # Apply limit
        if self.has_limit_count:
            row_ids = row_ids.take(self.limit_count)

        row_ids

    fn rows_for_ids(row_ids: [i64]) -> [SdnRow]:
        var results: [SdnRow] = [SdnRow.empty(); row_ids.len()]
        var result_idx = 0
        for row_idx in row_ids:
            val copied_row = SdnRow.empty()
            for column in self.table.columns:
                if val Some(value) = self.table.rows[row_idx].get(column):
                    copied_row.set(column, value)
            results[result_idx as i32] = copied_row
            result_idx = result_idx + 1
        results

    # Execute query
    me execute() -> [SdnRow]:
        self.rows_for_ids(self.execute_row_ids())

    me execute_with_offload(state: GpuWdbQueueState,
                            registry: GpuWdbLibraryRegistry,
                            gpu_available: bool,
                            cpu_fallback_available: bool,
                            budget: GpuWdbBudget,
                            bytes_per_row: i64) -> QueryBuilderOffloadExecution:
        self.execute_with_storage_offload(
            DbStorageOffloadMode.RamOnly,
            state,
            registry,
            gpu_available,
            true,
            cpu_fallback_available,
            budget,
            bytes_per_row
        )

    me execute_with_storage_offload(mode: DbStorageOffloadMode,
                                    state: GpuWdbQueueState,
                                    registry: GpuWdbLibraryRegistry,
                                    gpu_available: bool,
                                    wal_generation_current: bool,
                                    cpu_fallback_available: bool,
                                    budget: GpuWdbBudget,
                                    bytes_per_row: i64) -> QueryBuilderOffloadExecution:
        val row_ids = self.execute_row_ids()
        val rows = self.rows_for_ids(row_ids)
        QueryBuilderOffloadExecution(
            rows: rows,
            offload: db_query_offload_execute(
                db_query_rows(
                    mode,
                    DbStorageOffloadWorkload.ScanFilterProject,
                    self.table.rows.len(),
                    bytes_per_row,
                    wal_generation_current,
                    row_ids
                ),
                state,
                registry,
                gpu_available,
                cpu_fallback_available,
                budget
            )
        )

    me execute_with_device_backend_validated(state: GpuWdbQueueState,
                                             backend: GpuWdbDeviceBackend,
                                             expected_backend_generation: i64,
                                             cpu_fallback_available: bool,
                                             budget: GpuWdbBudget,
                                             bytes_per_row: i64,
                                             gpu_candidate_row_ids: [i64],
                                             started_us: i64,
                                             finished_us: i64,
                                             measured_device_time_us: i64,
                                             timing_source: text) -> QueryBuilderDeviceOffloadExecution:
        val row_ids = self.execute_row_ids()
        val rows = self.rows_for_ids(row_ids)
        QueryBuilderDeviceOffloadExecution(
            rows: rows,
            offload: db_query_offload_execute_rows_device_validated(
                db_query_rows(
                    DbStorageOffloadMode.RamOnly,
                    DbStorageOffloadWorkload.ScanFilterProject,
                    self.table.rows.len(),
                    bytes_per_row,
                    true,
                    row_ids
                ),
                state,
                backend,
                expected_backend_generation,
                cpu_fallback_available,
                budget,
                gpu_candidate_row_ids,
                started_us,
                finished_us,
                measured_device_time_us,
                timing_source
            )
        )

    me execute_with_ssd_materialized_projection(materialization: DbfsSsdScanMaterialization,
                                                state: GpuWdbQueueState,
                                                registry: GpuWdbLibraryRegistry,
                                                gpu_available: bool,
                                                cpu_fallback_available: bool,
                                                budget: GpuWdbBudget,
                                                gpu_candidate_row_ids: [i64]) -> QueryBuilderOffloadExecution:
        val cpu_row_ids = self.execute_row_ids()
        val cpu_rows = self.rows_for_ids(cpu_row_ids)
        val offload = db_query_offload_execute_ssd_materialized_scan_validated(
            materialization,
            state,
            registry,
            gpu_available,
            cpu_fallback_available,
            budget,
            gpu_candidate_row_ids
        )
        if offload.gpu_candidate_validated and query_builder_i64_ids_equal(cpu_row_ids, materialization.row_ids):
            return QueryBuilderOffloadExecution(
                rows: query_builder_rows_from_ssd_projection(materialization),
                offload: offload
            )
        QueryBuilderOffloadExecution(
            rows: cpu_rows,
            offload: offload
        )

    # Count results
    me count() -> i64:
        self.execute().len()

    me sum_i64(field: text) -> i64:
        val rows = self.execute()
        var total: i64 = 0
        for row in rows:
            if val Some(value) = row.get(field):
                total = total + value.to_int()
        total

    me avg_i64(field: text) -> i64:
        val rows = self.execute()
        var total: i64 = 0
        var count: i64 = 0
        for row in rows:
            if val Some(value) = row.get(field):
                total = total + value.to_int()
                count = count + 1
        if count == 0:
            return 0
        total / count

    me min_i64(field: text) -> i64:
        val rows = self.execute()
        var has_value = false
        var best: i64 = 0
        for row in rows:
            if val Some(value_text) = row.get(field):
                val value = value_text.to_int()
                if not has_value or value < best:
                    best = value
                    has_value = true
        best

    me max_i64(field: text) -> i64:
        val rows = self.execute()
        var has_value = false
        var best: i64 = 0
        for row in rows:
            if val Some(value_text) = row.get(field):
                val value = value_text.to_int()
                if not has_value or value > best:
                    best = value
                    has_value = true
        best

    me count_with_storage_offload(mode: DbStorageOffloadMode,
                                  state: GpuWdbQueueState,
                                  registry: GpuWdbLibraryRegistry,
                                  gpu_available: bool,
                                  wal_generation_current: bool,
                                  cpu_fallback_available: bool,
                                  budget: GpuWdbBudget,
                                  bytes_per_row: i64) -> QueryBuilderAggregateOffloadExecution:
        val row_ids = self.execute_row_ids()
        val execution = db_query_join_aggregate_count_execute(
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                self.table.rows.len(),
                bytes_per_row,
                wal_generation_current,
                row_ids
            ),
            row_ids.len(),
            state,
            registry,
            gpu_available,
            cpu_fallback_available,
            budget
        )
        QueryBuilderAggregateOffloadExecution(
            count: execution.count,
            offload: execution.offload
        )

    me count_with_device_backend_validated(mode: DbStorageOffloadMode,
                                           state: GpuWdbQueueState,
                                           backend: GpuWdbDeviceBackend,
                                           wal_generation_current: bool,
                                           expected_backend_generation: i64,
                                           cpu_fallback_available: bool,
                                           budget: GpuWdbBudget,
                                           bytes_per_row: i64,
                                           gpu_candidate_row_ids: [i64],
                                           gpu_candidate_count: i64,
                                           started_us: i64,
                                           finished_us: i64,
                                           measured_device_time_us: i64,
                                           timing_source: text) -> QueryBuilderAggregateDeviceOffloadExecution:
        val row_ids = self.execute_row_ids()
        val cpu_count = row_ids.len()
        val offload = db_query_offload_execute_rows_device_validated(
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                self.table.rows.len(),
                bytes_per_row,
                wal_generation_current,
                row_ids
            ),
            state,
            backend,
            expected_backend_generation,
            cpu_fallback_available,
            budget,
            gpu_candidate_row_ids,
            started_us,
            finished_us,
            measured_device_time_us,
            timing_source
        )
        if offload.execution.gpu_candidate_validated and gpu_candidate_count == cpu_count:
            return QueryBuilderAggregateDeviceOffloadExecution(
                count: gpu_candidate_count,
                offload: offload
            )
        if offload.execution.gpu_candidate_validated:
            return QueryBuilderAggregateDeviceOffloadExecution(
                count: cpu_count,
                offload: query_builder_device_offload_with_cpu_reason(offload, "production-gpu-count-mismatch")
            )
        QueryBuilderAggregateDeviceOffloadExecution(
            count: cpu_count,
            offload: offload
        )

    me sum_i64_with_storage_offload(field: text,
                                    mode: DbStorageOffloadMode,
                                    state: GpuWdbQueueState,
                                    registry: GpuWdbLibraryRegistry,
                                    gpu_available: bool,
                                    wal_generation_current: bool,
                                    cpu_fallback_available: bool,
                                    budget: GpuWdbBudget,
                                    bytes_per_row: i64) -> QueryBuilderSumOffloadExecution:
        val row_ids = self.execute_row_ids()
        QueryBuilderSumOffloadExecution(
            sum: self.sum_i64(field),
            offload: db_query_offload_execute(
                db_query_rows(
                    mode,
                    DbStorageOffloadWorkload.JoinAggregate,
                    self.table.rows.len(),
                    bytes_per_row,
                    wal_generation_current,
                    row_ids
                ),
                state,
                registry,
                gpu_available,
                cpu_fallback_available,
                budget
            )
        )

    me sum_i64_with_device_backend_validated(field: text,
                                             mode: DbStorageOffloadMode,
                                             state: GpuWdbQueueState,
                                             backend: GpuWdbDeviceBackend,
                                             wal_generation_current: bool,
                                             expected_backend_generation: i64,
                                             cpu_fallback_available: bool,
                                             budget: GpuWdbBudget,
                                             bytes_per_row: i64,
                                             gpu_candidate_row_ids: [i64],
                                             gpu_candidate_sum: i64,
                                             started_us: i64,
                                             finished_us: i64,
                                             measured_device_time_us: i64,
                                             timing_source: text) -> QueryBuilderSumDeviceOffloadExecution:
        val row_ids = self.execute_row_ids()
        val cpu_sum = self.sum_i64(field)
        val offload = db_query_offload_execute_rows_device_validated(
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                self.table.rows.len(),
                bytes_per_row,
                wal_generation_current,
                row_ids
            ),
            state,
            backend,
            expected_backend_generation,
            cpu_fallback_available,
            budget,
            gpu_candidate_row_ids,
            started_us,
            finished_us,
            measured_device_time_us,
            timing_source
        )
        if offload.execution.gpu_candidate_validated and gpu_candidate_sum == cpu_sum:
            return QueryBuilderSumDeviceOffloadExecution(
                sum: gpu_candidate_sum,
                offload: offload
            )
        if offload.execution.gpu_candidate_validated:
            return QueryBuilderSumDeviceOffloadExecution(
                sum: cpu_sum,
                offload: query_builder_device_offload_with_cpu_reason(offload, "production-gpu-sum-mismatch")
            )
        QueryBuilderSumDeviceOffloadExecution(
            sum: cpu_sum,
            offload: offload
        )

    me avg_i64_with_storage_offload(field: text,
                                    mode: DbStorageOffloadMode,
                                    state: GpuWdbQueueState,
                                    registry: GpuWdbLibraryRegistry,
                                    gpu_available: bool,
                                    wal_generation_current: bool,
                                    cpu_fallback_available: bool,
                                    budget: GpuWdbBudget,
                                    bytes_per_row: i64) -> QueryBuilderScalarOffloadExecution:
        val row_ids = self.execute_row_ids()
        QueryBuilderScalarOffloadExecution(
            value: self.avg_i64(field),
            offload: db_query_offload_execute(
                db_query_rows(
                    mode,
                    DbStorageOffloadWorkload.JoinAggregate,
                    self.table.rows.len(),
                    bytes_per_row,
                    wal_generation_current,
                    row_ids
                ),
                state,
                registry,
                gpu_available,
                cpu_fallback_available,
                budget
            )
        )

    me avg_i64_with_device_backend_validated(field: text,
                                             mode: DbStorageOffloadMode,
                                             state: GpuWdbQueueState,
                                             backend: GpuWdbDeviceBackend,
                                             wal_generation_current: bool,
                                             expected_backend_generation: i64,
                                             cpu_fallback_available: bool,
                                             budget: GpuWdbBudget,
                                             bytes_per_row: i64,
                                             gpu_candidate_row_ids: [i64],
                                             gpu_candidate_value: i64,
                                             started_us: i64,
                                             finished_us: i64,
                                             measured_device_time_us: i64,
                                             timing_source: text) -> QueryBuilderScalarDeviceOffloadExecution:
        val row_ids = self.execute_row_ids()
        val cpu_value = self.avg_i64(field)
        val offload = db_query_offload_execute_rows_device_validated(
            db_query_rows(
                mode,
                DbStorageOffloadWorkload.JoinAggregate,
                self.table.rows.len(),
                bytes_per_row,
                wal_generation_current,
                row_ids
            ),
            state,
            backend,
            expected_backend_generation,
            cpu_fallback_available,
            budget,
            gpu_candidate_row_ids,
            started_us,
            finished_us,
            measured_device_time_us,
            timing_source
        )
        if offload.execution.gpu_candidate_validated and gpu_candidate_value == cpu_value:
            return QueryBuilderScalarDeviceOffloadExecution(value: gpu_candidate_value, offload: offload)
        if offload.execution.gpu_candidate_validated:
            return QueryBuilderScalarDeviceOffloadExecution(
                value: cpu_value,
                offload: query_builder_device_offload_with_cpu_reason(offload, "production-gpu-avg-mismatch")
            )
        QueryBuilderScalarDeviceOffloadExecution(value: cpu_value, offload: offload)

    me min_i64_with_storage_offload(field: text,
                                    mode: DbStorageOffloadMode,
                                    state: GpuWdbQueueState,
                                    registry: GpuWdbLibraryRegistry,
                                    gpu_available: bool,
                                    wal_generation_current: bool,
                                    cpu_fallback_available: bool,
                                    budget: GpuWdbBudget,
                                    bytes_per_row: i64) -> QueryBuilderScalarOffloadExecution:
        val row_ids = self.execute_row_ids()
        QueryBuilderScalarOffloadExecution(
            value: self.min_i64(field),
            offload: db_query_offload_execute(
                db_query_rows(
                    mode,
                    DbStorageOffloadWorkload.JoinAggregate,
                    self.table.rows.len(),
                    bytes_per_row,
                    wal_generation_current,
                    row_ids
                ),
                state,
                registry,
                gpu_available,
                cpu_fallback_available,
                budget
            )
        )

    me max_i64_with_storage_offload(field: text,
                                    mode: DbStorageOffloadMode,
                                    state: GpuWdbQueueState,
                                    registry: GpuWdbLibraryRegistry,
                                    gpu_available: bool,
                                    wal_generation_current: bool,
                                    cpu_fallback_available: bool,
                                    budget: GpuWdbBudget,
                                    bytes_per_row: i64) -> QueryBuilderScalarOffloadExecution:
        val row_ids = self.execute_row_ids()
        QueryBuilderScalarOffloadExecution(
            value: self.max_i64(field),
            offload: db_query_offload_execute(
                db_query_rows(
                    mode,
                    DbStorageOffloadWorkload.JoinAggregate,
                    self.table.rows.len(),
                    bytes_per_row,
