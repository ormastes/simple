fn row_matches_all_filters_fast(row: SdnRow, filters: [Filter]) -> bool:
    for filter in filters:
        if not row_matches_filter_fast(row, filter):
            return false
    true

fn row_matches_filter_fast(row: SdnRow, filter: Filter) -> bool:
    val field_value = row.get(filter.field)
    if not field_value.?:
        return false

    val fv = field_value.unwrap()
    value_matches_filter_fast(fv, filter)

fn value_matches_filter_fast(fv: text, filter: Filter) -> bool:
    if filter.op == CompareOp.Eq:
        return text_equals_span(fv, filter.value)
    if filter.op == CompareOp.Ne:
        return not text_equals_span(fv, filter.value)
    if filter.op == CompareOp.Gt:
        return fv > filter.value
    if filter.op == CompareOp.Ge:
        return fv >= filter.value
    if filter.op == CompareOp.Lt:
        return fv < filter.value
    if filter.op == CompareOp.Le:
        return fv <= filter.value
    if filter.op == CompareOp.Contains:
        return fv.contains(filter.value)
    if filter.op == CompareOp.StartsWith:
        return fv.starts_with(filter.value)
    if filter.op == CompareOp.EndsWith:
        return fv.ends_with(filter.value)
    for candidate in filter.any_values:
        if text_equals_span(fv, candidate):
            return true
    false
