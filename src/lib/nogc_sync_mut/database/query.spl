# Query Builder for SDN Databases
#
# Provides fluent query interface with filtering, sorting, and limiting.

use nogc_sync_mut.database.core.{SdnTable, SdnRow}
use std.db.accel.{
    accel_capability_report,
    DB_ACCEL_DEFAULT_BATCH_SIZE, RowBitmap, VectorBatch,
    make_vector_batch, row_bitmap_indices, text_equals_span
}

val QUERY_ACCEL_SIMD_ACTIVE = accel_capability_report().simd_active

# ============================================================================
# Compare Operators
# ============================================================================

enum CompareOp:
    Eq           # Equal
    Ne           # Not equal
    Gt           # Greater than
    Ge           # Greater or equal
    Lt           # Less than
    Le           # Less or equal
    Contains     # String contains
    StartsWith   # String starts with
    EndsWith     # String ends with
    InSet        # Any-of equality

# ============================================================================
# Filter
# ============================================================================

struct Filter:
    field: text
    op: CompareOp
    value: text
    any_values: [text]

    # Check if row matches filter
    fn matches(row: SdnRow) -> bool:
        val field_value = row.get(self.field)
        if not field_value.?:
            return false

        val fv = field_value.unwrap()
        self.matches_value(fv)

    fn matches_value(fv: text) -> bool:
        match self.op:
            CompareOp.Eq: text_equals_span(fv, self.value)
            CompareOp.Ne: not text_equals_span(fv, self.value)
            CompareOp.Gt: fv > self.value
            CompareOp.Ge: fv >= self.value
            CompareOp.Lt: fv < self.value
            CompareOp.Le: fv <= self.value
            CompareOp.Contains: fv.contains(self.value)
            CompareOp.StartsWith: fv.starts_with(self.value)
            CompareOp.EndsWith: fv.ends_with(self.value)
            CompareOp.InSet:
                for candidate in self.any_values:
                    if text_equals_span(fv, candidate):
                        return true
                false

# ============================================================================
# QueryBuilder
# ============================================================================

class QueryBuilder:
    table: SdnTable
    filters: [Filter]
    sort_field: text
    has_sort_field: bool
    sort_desc: bool
    limit_count: i64
    has_limit_count: bool

    # Create query builder for table
    static fn for_table(table: SdnTable) -> QueryBuilder:
        QueryBuilder(
            table: table,
            filters: [],
            sort_field: "",
            has_sort_field: false,
            sort_desc: false,
            limit_count: 0,
            has_limit_count: false
        )

    # Add filter condition
    me filter_by(field: text, op: CompareOp, value: text) -> QueryBuilder:
        self.filters.push(Filter(field: field, op: op, value: value, any_values: []))
        self

    # Filter by multiple values (field IN (values))
    me filter_in(field: text, values: [text]) -> QueryBuilder:
        self.filters.push(Filter(field: field, op: CompareOp.InSet, value: "", any_values: values))
        self

    # Exclude soft-deleted rows (valid=true)
    me only_valid() -> QueryBuilder:
        self.filter_by("valid", CompareOp.Eq, "true")

    # Sort results
    me order_by(field: text, desc: bool) -> QueryBuilder:
        self.sort_field = field
        self.has_sort_field = true
        self.sort_desc = desc
        self

    # Limit results
    me take(n: i64) -> QueryBuilder:
        self.limit_count = n
        self.has_limit_count = true
        self

    # Execute query
    fn execute() -> [SdnRow]:
        if self.has_limit_count and self.limit_count == 0:
            return []

        var results = self.table.rows

        if self.filters.len() > 0:
            if QUERY_ACCEL_SIMD_ACTIVE:
                val bitmap = self.execute_bitmap()
                results = []
                for row_idx in row_bitmap_indices(bitmap):
                    results.push(self.table.rows[row_idx])
            else:
                results = self.execute_scalar_fast_path()

        # Apply sorting (merge sort - O(n log n) stable sort)
        if self.has_sort_field:
            results = merge_sort_rows(results, self.sort_field, self.sort_desc)

        # Apply limit
        if self.has_limit_count:
            results = results.take(self.limit_count)

        results

    # Count results
    fn count() -> i64:
        self.execute().len()

    # Check if any match
    fn exists() -> bool:
        self.count() > 0

    fn execute_scalar_fast_path() -> [SdnRow]:
        var results: [SdnRow] = []
        val stop_early = self.has_limit_count and not self.has_sort_field and self.limit_count > 0
        val filter_count = self.filters.len()

        if filter_count == 1:
            val filter0 = self.filters[0]
            val field0 = filter0.field
            for row in self.table.rows:
                if val Some(fv0) = row.get(field0):
                    if value_matches_filter_fast(fv0, filter0):
                        results.push(row)
                        if stop_early and results.len() >= self.limit_count:
                            break
            return results

        if filter_count == 2:
            val filter0 = self.filters[0]
            val filter1 = self.filters[1]
            val field0 = filter0.field
            val field1 = filter1.field
            for row in self.table.rows:
                if val Some(fv0) = row.get(field0):
                    if value_matches_filter_fast(fv0, filter0):
                        if val Some(fv1) = row.get(field1):
                            if value_matches_filter_fast(fv1, filter1):
                                results.push(row)
                                if stop_early and results.len() >= self.limit_count:
                                    break
            return results

        for row in self.table.rows:
            if row_matches_all_filters_fast(row, self.filters):
                results.push(row)
                if stop_early and results.len() >= self.limit_count:
                    break
        results

    fn execute_bitmap() -> RowBitmap:
        var bitmap = RowBitmap.full(self.table.rows.len())
        for filter in self.filters:
            bitmap = bitmap.and_with(self.execute_filter_bitmap(filter))
        bitmap

    fn execute_filter_bitmap(filter: Filter) -> RowBitmap:
        val total_rows = self.table.rows.len()
        var bitmap = RowBitmap.empty(total_rows)
        var start = 0
        while start < total_rows:
            val batch_len = if start + DB_ACCEL_DEFAULT_BATCH_SIZE > total_rows:
                total_rows - start
            else:
                DB_ACCEL_DEFAULT_BATCH_SIZE
            val batch = make_vector_batch(self.table.rows, start, batch_len)
            bitmap = self.fill_batch_bitmap(filter, batch, bitmap)
            start = start + batch_len
        bitmap

    fn fill_batch_bitmap(filter: Filter, batch: VectorBatch<SdnRow>, bitmap: RowBitmap) -> RowBitmap:
        var updated = bitmap
        var idx = 0
        while idx < batch.len:
            val row = batch.values[batch.start + idx]
            val field_value = row.get(filter.field)
            if val Some(fv) = field_value:
                if filter.matches_value(fv):
                    updated.set(batch.start + idx)
            idx = idx + 1
        updated

# ============================================================================
# Extension for SdnDatabase
# ============================================================================

# Add query() method to SdnDatabase
# Note: In actual implementation, this would be in mod.spl as method on SdnDatabase
# For now, we provide standalone function

use nogc_sync_mut.database.core.{SdnDatabase}

# Merge sort for arrays of SdnRow - O(n log n) stable sort
fn merge_sort_rows(rows: [SdnRow], field: text, desc: bool) -> [SdnRow]:
    if rows.len() <= 1:
        return rows
    val mid = rows.len() / 2
    var left: [SdnRow] = []
    var right: [SdnRow] = []
    for i in 0..mid:
        left = left.push(rows[i])
    for i in mid..rows.len():
        right = right.push(rows[i])
    merge_rows(left=merge_sort_rows(left, field, desc), right=merge_sort_rows(right, field, desc), field=field, desc=desc)

fn merge_rows(left: [SdnRow], right: [SdnRow], field: text, desc: bool) -> [SdnRow]:
    var result: [SdnRow] = []
    var i = 0
    var j = 0
    while i < left.len() and j < right.len():
        val a = left[i].get(field) ?? ""
        val b = right[j].get(field) ?? ""
        val take_left = if desc: a >= b else: a <= b
        if take_left:
            result = result.push(left[i])
            i = i + 1
        else:
            result = result.push(right[j])
            j = j + 1
    while i < left.len():
        result = result.push(left[i])
        i = i + 1
    while j < right.len():
        result = result.push(right[j])
        j = j + 1
    result

fn query_table(db: SdnDatabase, table_name: text) -> QueryBuilder?:
    val table = db.get_table(table_name)?
    Some(QueryBuilder.for_table(table))

fn row_matches_all_filters_fast(row: SdnRow, filters: [Filter]) -> bool:
    for filter in filters:
        if not row_matches_filter_fast(row, filter):
            return false
    true

fn row_matches_filter_fast(row: SdnRow, filter: Filter) -> bool:
    val field_value = row.get(filter.field)
    if not field_value.?:
        return false

    val fv = field_value.unwrap()
    value_matches_filter_fast(fv, filter)

fn value_matches_filter_fast(fv: text, filter: Filter) -> bool:
    match filter.op:
        CompareOp.Eq: text_equals_span(fv, filter.value)
        CompareOp.Ne: not text_equals_span(fv, filter.value)
        CompareOp.Gt: fv > filter.value
        CompareOp.Ge: fv >= filter.value
        CompareOp.Lt: fv < filter.value
        CompareOp.Le: fv <= filter.value
        CompareOp.Contains: fv.contains(filter.value)
        CompareOp.StartsWith: fv.starts_with(filter.value)
        CompareOp.EndsWith: fv.ends_with(filter.value)
        CompareOp.InSet:
            for candidate in filter.any_values:
                if text_equals_span(fv, candidate):
                    return true
            false
