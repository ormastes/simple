fn encode_vector(v: [f64]) -> text:
    var parts: [text] = []
    var i = 0
    while i < v.len():
        parts.push(v[i].to_text())
        i = i + 1
    parts.join(",")

fn decode_vector(s: text) -> [f64]?:
    if s.len() == 0:
        return nil
    val parts = s.split(",")
    var out: [f64] = []
    var i = 0
    while i < parts.len():
        val parsed = parts[i].trim().parse_f64()
        if parsed.?:
            out.push(parsed)
        else:
            return nil
        i = i + 1
    out

fn encode_metadata(meta: Dict<text, text>) -> text:
    var parts: [text] = []
    val keys = meta.keys()
    var i = 0
    while i < keys.len():
        val k = keys[i]
        val v = meta.get(k)
        if v.?:
            parts.push(k + "=" + v)
        i = i + 1
    parts.join(";")

fn decode_metadata(s: text) -> Dict<text, text>:
    var out: Dict<text, text> = {}
    if s.len() == 0:
        return out
    val pairs = s.split(";")
    var i = 0
    while i < pairs.len():
        val pair = pairs[i]
        val eq = pair.find("=")
        if eq >= 0:
            val k = pair.slice(0, eq).trim()
            val v = pair.slice(eq + 1, pair.len()).trim()
            out.set(k, v)
        i = i + 1
    out
