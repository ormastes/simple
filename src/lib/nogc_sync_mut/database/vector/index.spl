use std.database.vector.types.{VectorDbError, SearchResult, DistanceMetric}
use std.database.vector.distance.{compute_distance, l2_norm}

trait VectorIndex:
    me add(id: text, vector: [f64]) -> Result<(), VectorDbError>
    me remove(id: text) -> Result<(), VectorDbError>
    fn search(query: [f64], k: i64, metric: DistanceMetric) -> [SearchResult]
    fn size() -> i64
    me clear()

class BruteForceIndex with VectorIndex:
    entries: Dict<text, [f64]>
    norms: Dict<text, f64>
    dimensions: i64

    static fn create(dimensions: i64) -> BruteForceIndex:
        BruteForceIndex(
            entries: {},
            norms: {},
            dimensions: dimensions
        )

    me add(id: text, vector: [f64]) -> Result<(), VectorDbError>:
        if vector.len() as i64 != me.dimensions:
            return Err(VectorDbError.DimensionMismatch(
                expected: me.dimensions,
                got: vector.len() as i64
            ))
        me.norms.set(id, l2_norm(vector))
        me.entries.set(id, vector)
        Ok(())

    me remove(id: text) -> Result<(), VectorDbError>:
        if not me.entries.contains(id):
            return Err(VectorDbError.EntryNotFound(id: id))
        me.entries.remove(id)
        me.norms.remove(id)
        Ok(())

    fn search(query: [f64], k: i64, metric: DistanceMetric) -> [SearchResult]:
        var results: [SearchResult] = []
        val ids = me.entries.keys()
        var i = 0
        while i < ids.len():
            val id = ids[i]
            val vec = me.entries.get(id)
            if vec.?:
                val dist = compute_distance(query, vec, metric)
                var inserted = false
                var j = 0
                while j < results.len() and not inserted:
                    if dist < results[j].distance:
                        results.insert(j, SearchResult(
                            id: id,
                            distance: dist,
                            metadata: {}
                        ))
                        inserted = true
                    j = j + 1
                if not inserted:
                    results.push(SearchResult(
                        id: id,
                        distance: dist,
                        metadata: {}
                    ))
            i = i + 1
        if results.len() as i64 <= k:
            return results
        results.slice(0, k as i32)

    fn size() -> i64:
        me.entries.len() as i64

    me clear():
        me.entries = {}
        me.norms = {}
