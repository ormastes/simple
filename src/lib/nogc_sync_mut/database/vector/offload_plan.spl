# codex-impl
# Planner-only adapter from vector DB search batches to shared GPU web/db offload policy.

use std.database.vector.types.{DistanceMetric}
use std.web_db_offload.contract.{
    GpuWdbWorkKind,
    GpuWdbBudget,
    GpuWdbRuntimeSnapshot,
    GpuWdbDecision,
    GpuWdbDecisionPath,
    GpuWdbExecutionPlan,
    GpuWdbBatchPlan,
    gpu_wdb_default_budget,
    gpu_wdb_batch_window,
    gpu_wdb_batch_plan,
    gpu_wdb_nosql_mode_admits
}

struct VectorSearchOffloadPlan:
    metric: DistanceMetric
    candidate_count: i64
    dimensions: i64
    estimated_batch_bytes: i64
    metadata_filter_cpu_owned: bool
    batch: GpuWdbBatchPlan

fn vector_search_estimated_batch_bytes(candidate_count: i64, dimensions: i64) -> i64:
    if candidate_count <= 0:
        return 0
    if dimensions <= 0:
        return 0
    (candidate_count + 1) * dimensions * 8

fn vector_search_average_item_bytes(estimated_batch_bytes: i64, candidate_count: i64) -> i64:
    if candidate_count <= 0:
        return 0
    estimated_batch_bytes / candidate_count

fn vector_search_cpu_plan(metric: DistanceMetric, candidate_count: i64, dimensions: i64,
                          estimated_batch_bytes: i64, metadata_filter_cpu_owned: bool,
                          snapshot: GpuWdbRuntimeSnapshot, decision: GpuWdbDecision) -> VectorSearchOffloadPlan:
    val execution = GpuWdbExecutionPlan(
        kind: GpuWdbWorkKind.DbVectorSearch,
        target: "cpu_fallback",
        decision: decision
    )
    val batch = GpuWdbBatchPlan(
        execution: execution,
        item_count: candidate_count,
        average_item_bytes: vector_search_average_item_bytes(estimated_batch_bytes, candidate_count),
        queue_depth_after: snapshot.queue_depth
    )
    VectorSearchOffloadPlan(
        metric: metric,
        candidate_count: candidate_count,
        dimensions: dimensions,
        estimated_batch_bytes: estimated_batch_bytes,
        metadata_filter_cpu_owned: metadata_filter_cpu_owned,
        batch: batch
    )

fn plan_vector_search_offload(metric: DistanceMetric, candidate_count: i64, dimensions: i64,
                              metadata_filter_cpu_owned: bool, snapshot: GpuWdbRuntimeSnapshot,
                              budget: GpuWdbBudget) -> VectorSearchOffloadPlan:
    val estimated_batch_bytes = vector_search_estimated_batch_bytes(candidate_count, dimensions)
    if not metadata_filter_cpu_owned:
        val decision = gpu_wdb_nosql_mode_admits(estimated_batch_bytes, false, budget)
        return vector_search_cpu_plan(metric, candidate_count, dimensions, estimated_batch_bytes,
                                      metadata_filter_cpu_owned, snapshot, decision)

    val window = gpu_wdb_batch_window(
        GpuWdbWorkKind.DbVectorSearch,
        estimated_batch_bytes,
        candidate_count,
        snapshot
    )
    val batch = gpu_wdb_batch_plan(window, budget)
    VectorSearchOffloadPlan(
        metric: metric,
        candidate_count: candidate_count,
        dimensions: dimensions,
        estimated_batch_bytes: estimated_batch_bytes,
        metadata_filter_cpu_owned: metadata_filter_cpu_owned,
        batch: batch
    )

fn plan_vector_search_offload_default(metric: DistanceMetric, candidate_count: i64,
                                      dimensions: i64, metadata_filter_cpu_owned: bool,
                                      snapshot: GpuWdbRuntimeSnapshot) -> VectorSearchOffloadPlan:
    plan_vector_search_offload(
        metric,
        candidate_count,
        dimensions,
        metadata_filter_cpu_owned,
        snapshot,
        gpu_wdb_default_budget()
    )

fn vector_search_plan_uses_gpu(plan: VectorSearchOffloadPlan) -> bool:
    plan.batch.execution.decision.path == GpuWdbDecisionPath.GpuEvidence
