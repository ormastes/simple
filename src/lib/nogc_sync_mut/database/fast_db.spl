# Fast in-memory database backed by C runtime (rt_db_*).
#
# Provides O(1) hash-based GET/PUT and O(N) SCAN with ~5ns/row,
# bypassing interpreter dispatch overhead entirely.

# ── Extern declarations ──────────────────────────────────────────────────────

extern fn rt_db_table_create(name: text, num_cols: i64, pk_col: i64) -> i64
extern fn rt_db_table_destroy(handle: i64)
extern fn rt_db_put(table: i64, pk_text: text, num_values: i64) -> i64
extern fn rt_db_put_value_int(table: i64, row: i64, col: i64, value: i64)
extern fn rt_db_put_value_text(table: i64, row: i64, col: i64, value: text)
extern fn rt_db_get(table: i64, pk_text: text) -> i64
extern fn rt_db_get_int(table: i64, row: i64, col: i64) -> i64
extern fn rt_db_get_text(table: i64, row: i64, col: i64) -> text
extern fn rt_db_scan_range(table: i64, col: i64, low: i64, high: i64) -> i64
extern fn rt_db_scan_result(table: i64, result_idx: i64) -> i64
extern fn rt_db_delete(table: i64, pk_text: text) -> i64
extern fn rt_db_row_count(table: i64) -> i64
extern fn rt_db_col_count(table: i64) -> i64

# ── FastTable wrapper ────────────────────────────────────────────────────────

class FastTable:
    _handle: i64
    _num_cols: i64

    static fn create(name: text, num_cols: i64, pk_col: i64) -> FastTable:
        val h = rt_db_table_create(name, num_cols, pk_col)
        FastTable(_handle: h, _num_cols: num_cols)

    me fn destroy():
        rt_db_table_destroy(self._handle)

    me fn put(pk: text) -> i64:
        rt_db_put(self._handle, pk, self._num_cols)

    me fn put_int(row: i64, col: i64, value: i64):
        rt_db_put_value_int(self._handle, row, col, value)

    me fn put_text(row: i64, col: i64, value: text):
        rt_db_put_value_text(self._handle, row, col, value)

    me fn get(pk: text) -> i64:
        rt_db_get(self._handle, pk)

    me fn get_int(row: i64, col: i64) -> i64:
        rt_db_get_int(self._handle, row, col)

    me fn get_text(row: i64, col: i64) -> text:
        rt_db_get_text(self._handle, row, col)

    me fn scan_range(col: i64, low: i64, high: i64) -> i64:
        rt_db_scan_range(self._handle, col, low, high)

    me fn scan_result(result_idx: i64) -> i64:
        rt_db_scan_result(self._handle, result_idx)

    me fn delete(pk: text) -> i64:
        rt_db_delete(self._handle, pk)

    me fn row_count() -> i64:
        rt_db_row_count(self._handle)

    me fn col_count() -> i64:
        rt_db_col_count(self._handle)
