# Pure Simple SQL Database Engine — no FFI, no sqlite dependency.
#
# Drop-in replacement for std.database.sql.Database, backed by
# sql_parser + MVCC in-process storage.

use std.io_runtime
use std.nogc_sync_mut.io.file_ops.{file_exists, file_read, file_write}
use std.database.sql.types.{DbValue, DbRow, DbError}
use nogc_sync_mut.db.dbfs_engine.sql_parser.{
    sql_parse, SqlStmtKind, SqlExprKind, SqlExpr,
    SqlColumnType, SqlColumnDef, SqlSelect, SqlInsert,
    SqlUpdate, SqlDelete, SqlCreateTable, SqlStatement,
    SqlJoin, JoinKind, SqlOrderDir
}
use nogc_sync_mut.db.dbfs_engine.mvcc.{
    MvccTable, MvccTxnManager, MvccSnapshot, MvccTuple, mvcc_is_visible
}
use nogc_sync_mut.db.dbfs_engine.fts.search.{FtsEngine}
use nogc_sync_mut.db.db_query.{query_fts_match, query_page_summary_scan}
use nogc_sync_mut.db.page_summary.{PageSummaryIndex}

# ── Full-text search types ──────────────────────────────────────────────────

enum PureSearchAlgorithm:
    Contains
    TermFrequency
    Bm25

struct PureSearchResult:
    row: DbRow
    score: f64
    row_index: i64

# ── Module-level helpers ─────────────────────────────────────────────────────

var _param_idx: i64 = 0

fn _find_idx(names: [text], target: text) -> i32:
    var i: i32 = 0
    while i < names.len() as i32:
        if names[i] == target:
            return i
        i = i + 1
    -1

fn _build_col_map(cols: [text]) -> Dict<text, i32>:
    var m: Dict<text, i32> = {}
    var i: i32 = 0
    while i < cols.len() as i32:
        m[cols[i]] = i
        i = i + 1
    m

fn _col_idx(m: Dict<text, i32>, name: text) -> i32:
    if m.has(name):
        return m[name]
    -1

# ── Row serialization ────────────────────────────────────────────────────────
# Each cell: TYPE_CHAR ":" value, cells separated by "\t".

fn _serialize_row(values: [DbValue]) -> text:
    var parts: [text] = []
    var i: i32 = 0
    while i < values.len() as i32:
        val v = values[i]
        match v:
            DbValue.Integer(value):
                parts.push("I:{value}")
            DbValue.Real(value):
                parts.push("R:{value}")
            DbValue.Text(value):
                parts.push("T:{value}")
            DbValue.Null:
                parts.push("N:")
            DbValue.Bool(value):
                if value:
                    parts.push("B:1")
                else:
                    parts.push("B:0")
            DbValue.Blob(value):
                parts.push("N:")
        i = i + 1
    var result = ""
    var j: i32 = 0
    while j < parts.len() as i32:
        if j > 0:
            result = result + "\t" + parts[j]
        else:
            result = parts[j]
        j = j + 1
    result

fn _deserialize_row(data: text) -> [DbValue]:
    val parts = data.split("\t")
    var result: [DbValue] = []
    var i: i32 = 0
    while i < parts.len() as i32:
        val p = parts[i]
        if p.starts_with("I:"):
            val ns = p.slice(2, p.len())
            val n = ns.to_int() ?? 0
            result.push(DbValue.Integer(value: n))
        elif p.starts_with("R:"):
            result.push(DbValue.Real(value: 0.0))
        elif p.starts_with("T:"):
            val txt = p.slice(2, p.len())
            result.push(DbValue.Text(value: txt))
        elif p.starts_with("B:"):
            val bv = p.slice(2, p.len())
            result.push(DbValue.Bool(value: bv == "1"))
        else:
            result.push(DbValue.Null)
        i = i + 1
    result

# ── Expression evaluation ────────────────────────────────────────────────────

fn _parse_literal(v: text) -> DbValue:
    if v == "NULL" or v == "null":
        return DbValue.Null
    # Check if the value looks numeric before calling to_int
    # (to_int returns Some(0) for non-numeric strings in interpreter mode)
    if _is_numeric_text(v):
        val n = v.to_int() ?? 0
        return DbValue.Integer(value: n)
    DbValue.Text(value: v)

fn _is_numeric_text(v: text) -> bool:
    if v.len() == 0:
        return false
    var i: i64 = 0
    # Allow leading minus sign
    if v.char_at(0) == "-":
        if v.len() == 1:
            return false
        i = 1
    while i < v.len():
        val c = v.char_at(i)
        if c < "0" or c > "9":
            return false
        i = i + 1
    true

fn _dbval_eq(a: DbValue, b: DbValue) -> bool:
    if a.is_null() and b.is_null():
        return true
    if a.is_null() or b.is_null():
        return false
    a.to_text() == b.to_text()

fn _check_pk_eq_operands(left: SqlExpr, right: SqlExpr, col_names: [text], pk_ci: i32) -> text:
    if left.kind == SqlExprKind.Column:
        val ci = _find_idx(col_names, left.value)
        if ci == pk_ci:
            if right.kind == SqlExprKind.Literal:
                return right.value
    if right.kind == SqlExprKind.Column:
        val ci2 = _find_idx(col_names, right.value)
        if ci2 == pk_ci:
            if left.kind == SqlExprKind.Literal:
                return left.value
    ""

fn _extract_pk_eq_inner(expr: SqlExpr, col_names: [text], pk_ci: i32) -> text:
    if expr.kind != SqlExprKind.BinaryOp:
        return ""
    if expr.value != "=":
        return ""
    if not expr.left.?:
        return ""
    if not expr.right.?:
        return ""
    _check_pk_eq_operands(expr.left, expr.right, col_names, pk_ci)

fn _extract_pk_eq(where_expr: SqlExpr?, col_names: [text], pk_ci: i32) -> text:
    if not where_expr.?:
        return ""
    _extract_pk_eq_inner(where_expr, col_names, pk_ci)

# ── Range predicate extraction for fast SELECT WHERE ────────────────────────

# Resolve a Literal to an integer value.
# Returns [value] on success, [] on failure.
fn _resolve_int_literal(expr: SqlExpr) -> [i64]:
    if expr.kind == SqlExprKind.Literal:
        if not _is_numeric_text(expr.value):
            return []
        val v = expr.value.to_int() ?? 0
        var result: [i64] = []
        result.push(v as i64)
        return result
    []

# Returns [col_index, low_value, high_value, low_inclusive, high_inclusive]
# as a flat i64 array, or empty if the WHERE is not a simple int range.
# low_inclusive/high_inclusive: 1 = inclusive, 0 = exclusive.

fn _extract_int_range(where_expr: SqlExpr?, col_map: Dict<text, i32>) -> [i64]:
    if not where_expr.?:
        return []
    val expr = where_expr
    # BETWEEN col low AND high
    if expr.kind == SqlExprKind.Between:
        if not expr.left.?:
            return []
        if expr.left.kind != SqlExprKind.Column:
            return []
        val ci = _col_idx(col_map, expr.left.value)
        if ci < 0:
            return []
        if expr.args.len() < 2:
            return []
        val lo_expr = expr.args[0]
        val hi_expr = expr.args[1]
        val lo_v = _resolve_int_literal(lo_expr)
        val hi_v = _resolve_int_literal(hi_expr)
        if lo_v.len() == 0 or hi_v.len() == 0:
            return []
        var result: [i64] = []
        result.push(ci as i64)
        result.push(lo_v[0])
        result.push(hi_v[0])
        result.push(1)
        result.push(1)
        return result
    # AND of two binary comparisons on the same column
    if expr.kind != SqlExprKind.BinaryOp:
        return []
    if expr.value != "AND":
        return []
    if not expr.left.? or not expr.right.?:
        return []
    val left = expr.left
    val right = expr.right
    if left.kind != SqlExprKind.BinaryOp or right.kind != SqlExprKind.BinaryOp:
        return []
    # Try to extract (col OP literal) from each side
    val b1 = _extract_bound(left, col_map)
    val b2 = _extract_bound(right, col_map)
    if b1.len() != 3 or b2.len() != 3:
        return []
    # Both must reference the same column
    if b1[0] != b2[0]:
        return []
    val ci = b1[0]
    # b[1] = value, b[2] = kind (0=col>=val, 1=col>val, 2=col<=val, 3=col<val)
    var lo: i64 = 0
    var hi: i64 = 0
    var lo_inc: i64 = 1
    var hi_inc: i64 = 1
    var has_lo = false
    var has_hi = false
    # Process b1
    if b1[2] == 0:
        lo = b1[1]
        lo_inc = 1
        has_lo = true
    elif b1[2] == 1:
        lo = b1[1]
        lo_inc = 0
        has_lo = true
    elif b1[2] == 2:
        hi = b1[1]
        hi_inc = 1
        has_hi = true
    elif b1[2] == 3:
        hi = b1[1]
        hi_inc = 0
        has_hi = true
    # Process b2
    if b2[2] == 0:
        lo = b2[1]
        lo_inc = 1
        has_lo = true
    elif b2[2] == 1:
        lo = b2[1]
        lo_inc = 0
        has_lo = true
    elif b2[2] == 2:
        hi = b2[1]
        hi_inc = 1
        has_hi = true
    elif b2[2] == 3:
        hi = b2[1]
        hi_inc = 0
        has_hi = true
    if not has_lo or not has_hi:
        return []
    var result: [i64] = []
    result.push(ci)
    result.push(lo)
    result.push(hi)
    result.push(lo_inc)
    result.push(hi_inc)
    result

# Returns [col_index, literal_value, kind] where kind:
# 0 = col >= val, 1 = col > val, 2 = col <= val, 3 = col < val
# Returns [] if not a simple column-literal/placeholder comparison.
fn _extract_bound(expr: SqlExpr, col_map: Dict<text, i32>) -> [i64]:
    if expr.kind != SqlExprKind.BinaryOp:
        return []
    val op = expr.value
    if not expr.left.? or not expr.right.?:
        return []
    val left = expr.left
    val right = expr.right
    # col OP value (literal or placeholder)
    if left.kind == SqlExprKind.Column:
        val ci = _col_idx(col_map, left.value)
        if ci < 0:
            return []
        val resolved = _resolve_int_literal(right)
        if resolved.len() == 0:
            return []
        val v = resolved[0]
        var kind: i64 = -1
        if op == ">=":
            kind = 0
        elif op == ">":
            kind = 1
        elif op == "<=":
            kind = 2
        elif op == "<":
            kind = 3
        elif op == "=":
            kind = 4
        if kind < 0:
            return []
        var result: [i64] = []
        result.push(ci as i64)
        result.push(v)
        result.push(kind)
        return result
    # value OP col (reversed)
    if right.kind == SqlExprKind.Column:
        val ci = _col_idx(col_map, right.value)
        if ci < 0:
            return []
        val resolved = _resolve_int_literal(left)
        if resolved.len() == 0:
            return []
        val v = resolved[0]
        var kind: i64 = -1
        # Flip: "50 <= col" means col >= 50
        if op == "<=":
            kind = 0
        elif op == "<":
            kind = 1
        elif op == ">=":
            kind = 2
        elif op == ">":
            kind = 3
        elif op == "=":
            kind = 4
        if kind < 0:
            return []
        var result: [i64] = []
        result.push(ci as i64)
        result.push(v)
        result.push(kind)
        return result
    []

# Extract a LIKE prefix pattern from a WHERE clause.
# Returns (col_index, prefix_string) if pattern is "prefix%" or "prefix_...%"
# Returns (-1, "") if not a simple LIKE prefix pattern.
fn _extract_like_prefix(where_expr: SqlExpr?, col_map: Dict<text, i32>) -> i32:
    if not where_expr.?:
        return -1
    val expr = where_expr
    if expr.kind != SqlExprKind.BinaryOp:
        return -1
    if expr.value != "LIKE":
        return -1
    if not expr.left.? or not expr.right.?:
        return -1
    val left = expr.left
    val right = expr.right
    if left.kind != SqlExprKind.Column:
        return -1
    val ci = _col_idx(col_map, left.value)
    if ci < 0:
        return -1
    if right.kind != SqlExprKind.Literal:
        return -1
    ci

fn _like_prefix_str(where_expr: SqlExpr?) -> text:
    """Extract the literal prefix before the first % wildcard.
    Only returns a non-empty prefix if it contains no _ wildcards,
    since _ matches any single character in LIKE and cannot be
    safely reduced to starts_with."""
    if not where_expr.?:
        return ""
    val expr = where_expr
    if not expr.right.?:
        return ""
    val pattern = expr.right.value
    # Remove surrounding quotes if present
    var pat = pattern
    if pat.starts_with("'") and pat.ends_with("'"):
        pat = pat.slice(1, pat.len() - 1)
    # Find first % and take everything before it as the prefix
    # Reject if any _ wildcard appears before the %
    var i: i64 = 0
    while i < pat.len():
        val ch = pat.char_at(i)
        if ch == "%":
            return pat.slice(0, i)
        if ch == "_":
            return ""
        i = i + 1
    ""

fn _like_any_prefix(where_expr: SqlExpr?) -> text:
    """Extract the literal prefix before the first wildcard (% or _).
    Used as a starts_with pre-filter before running full _like_match.
    Returns "" if no literal prefix exists (pattern starts with wildcard)."""
    if not where_expr.?:
        return ""
    val expr = where_expr
    if not expr.right.?:
        return ""
    val pattern = expr.right.value
    var pat = pattern
    if pat.starts_with("'") and pat.ends_with("'"):
        pat = pat.slice(1, pat.len() - 1)
    var i: i64 = 0
    while i < pat.len():
        val ch = pat.char_at(i)
        if ch == "%" or ch == "_":
            return pat.slice(0, i)
        i = i + 1
    ""

# Extract column index and full LIKE pattern from WHERE col LIKE 'pattern'.
# Returns (col_index, pattern_string). col_index is -1 if not a simple LIKE.
fn _extract_like_col(where_expr: SqlExpr?, col_map: Dict<text, i32>) -> i32:
    if not where_expr.?:
        return -1
    val expr = where_expr
    if expr.kind != SqlExprKind.BinaryOp:
        return -1
    if expr.value != "LIKE":
        return -1
    if not expr.left.? or not expr.right.?:
        return -1
    val left = expr.left
    val right = expr.right
    if left.kind != SqlExprKind.Column:
        return -1
    val ci = _col_idx(col_map, left.value)
    if ci < 0:
        return -1
    if right.kind != SqlExprKind.Literal:
        return -1
    ci

fn _extract_like_pattern(where_expr: SqlExpr?) -> text:
    if not where_expr.?:
        return ""
    val expr = where_expr
    if not expr.right.?:
        return ""
    val pattern = expr.right.value
    var pat = pattern
    if pat.starts_with("'") and pat.ends_with("'"):
        pat = pat.slice(1, pat.len() - 1)
    pat

# Extract a single-sided integer comparison from a WHERE clause.
# Returns [col_index, value, kind] where kind: 0=>=, 1=>, 2=<=, 3=<, 4==
# Returns [] if not a simple single comparison.
fn _extract_single_int_bound(where_expr: SqlExpr?, col_map: Dict<text, i32>) -> [i64]:
    if not where_expr.?:
        return []
    val expr = where_expr
    if expr.kind != SqlExprKind.BinaryOp:
        return []
    # Skip AND/OR — those are handled by _extract_int_range
    val op = expr.value
    if op == "AND" or op == "OR":
        return []
    _extract_bound(expr, col_map)

fn _dbval_is_int(v: DbValue) -> bool:
    match v:
        DbValue.Integer(_): true
        _: false

fn _dbval_as_i64(v: DbValue) -> i64:
    match v:
        DbValue.Integer(value): value
        _: 0

fn _dbval_cmp(a: DbValue, b: DbValue) -> i64:
    if _dbval_is_int(a) and _dbval_is_int(b):
        val ai = _dbval_as_i64(a)
        val bi = _dbval_as_i64(b)
        if ai > bi:
            return 1
        if ai < bi:
            return -1
        return 0
    val at = a.to_text()
    val bt = b.to_text()
    if at > bt:
        return 1
    if at < bt:
        return -1
    0

fn _dbval_truthy(v: DbValue) -> bool:
    match v:
        DbValue.Bool(value): value
        DbValue.Integer(value): value != 0
        DbValue.Null: false
        _: true

fn _text_tokens(value: text) -> [text]:
    val lowered = value.to_lower()
    val parts = lowered.split(" ")
    var result: [text] = []
    var i: i32 = 0
    while i < parts.len() as i32:
        val token = parts[i].trim()
        if token != "":
            result.push(token)
        i = i + 1
    result

fn _row_search_text(row_vals: [DbValue], col_names: [text], selected_cols: [text]) -> text:
    var result = ""
    var ci: i32 = 0
    while ci < col_names.len() as i32:
        var include_col = selected_cols.len() == 0
        var si: i32 = 0
        while si < selected_cols.len() as i32:
            if selected_cols[si] == col_names[ci]:
                include_col = true
            si = si + 1
        if include_col:
            if result != "":
                result = result + " "
            result = result + row_vals[ci].to_text()
        ci = ci + 1
    result

fn _same_text_list(a: [text], b: [text]) -> bool:
    if a.len() != b.len():
        return false
    var i: i32 = 0
    while i < a.len() as i32:
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _count_term(tokens: [text], term: text) -> i64:
    var count: i64 = 0
    var i: i32 = 0
    while i < tokens.len() as i32:
        if tokens[i] == term:
            count = count + 1
        i = i + 1
    count

fn _contains_term(tokens: [text], term: text) -> bool:
    _count_term(tokens, term) > 0

fn _result_score_at(results: [PureSearchResult], idx: i32) -> f64:
    results[idx].score

fn _push_ranked_result(results: [PureSearchResult], next: PureSearchResult, limit: i64) -> [PureSearchResult]:
    var ranked: [PureSearchResult] = []
    var inserted = false
    var i: i32 = 0
    while i < results.len() as i32:
        if not inserted and next.score > _result_score_at(results, i):
            ranked.push(next)
            inserted = true
        ranked.push(results[i])
        i = i + 1
    if not inserted:
        ranked.push(next)
    if limit <= 0 or ranked.len() <= limit:
        return ranked
    var trimmed: [PureSearchResult] = []
    var ti: i32 = 0
    while ti < limit as i32:
        trimmed.push(ranked[ti])
        ti = ti + 1
    trimmed

fn _document_frequency(docs: [[text]], term: text) -> i64:
    var count: i64 = 0
    var i: i32 = 0
    while i < docs.len() as i32:
        if _contains_term(docs[i], term):
            count = count + 1
        i = i + 1
    count

fn _term_frequency_score(doc: [text], terms: [text]) -> f64:
    var score = 0.0
    var i: i32 = 0
    while i < terms.len() as i32:
        score = score + (_count_term(doc, terms[i]) as f64)
        i = i + 1
    score

fn _contains_score(doc: [text], terms: [text]) -> f64:
    var score = 0.0
    var i: i32 = 0
    while i < terms.len() as i32:
        if _contains_term(doc, terms[i]):
            score = score + 1.0
        i = i + 1
    score

fn _fts_match_value(value: text, query: text) -> bool:
    val doc = _text_tokens(value)
    val terms = _text_tokens(query)
    if terms.len() == 0:
        return false
    var i: i32 = 0
    while i < terms.len() as i32:
        if _contains_term(doc, terms[i]):
            return true
        i = i + 1
    false

fn _bm25_score(docs: [[text]], doc_index: i32, terms: [text], total_len: i64) -> f64:
    val doc = docs[doc_index]
    val doc_count = docs.len() as f64
    if doc_count <= 0.0:
        return 0.0
    var avg_len = (total_len as f64) / doc_count
    if avg_len <= 0.0:
        avg_len = 1.0
    val k1 = 1.2
    val b = 0.75
    val doc_len = doc.len() as f64
    var score = 0.0
    var i: i32 = 0
    while i < terms.len() as i32:
        val tf = _count_term(doc, terms[i]) as f64
        if tf > 0.0:
            val df = _document_frequency(docs, terms[i]) as f64
            val idf = (((doc_count - df + 0.5) / (df + 0.5)) + 1.0).log()
            val denom = tf + k1 * (1.0 - b + b * (doc_len / avg_len))
            score = score + idf * ((tf * (k1 + 1.0)) / denom)
        i = i + 1
    score

fn _search_score(docs: [[text]], doc_index: i32, terms: [text], algorithm: PureSearchAlgorithm, total_len: i64) -> f64:
    val doc = docs[doc_index]
    match algorithm:
        PureSearchAlgorithm.Contains:
            _contains_score(doc, terms)
        PureSearchAlgorithm.TermFrequency:
            _term_frequency_score(doc, terms)
        PureSearchAlgorithm.Bm25:
            _bm25_score(docs, doc_index, terms, total_len)

fn _eval_expr(expr: SqlExpr, cols: [text], vals: [DbValue], params: [DbValue]) -> DbValue:
    if expr.kind == SqlExprKind.Literal:
        return _parse_literal(expr.value)
    if expr.kind == SqlExprKind.Column:
        val idx = _find_idx(cols, expr.value)
        if idx >= 0:
            return vals[idx]
        return DbValue.Null
    if expr.kind == SqlExprKind.Placeholder:
        if _param_idx < params.len():
            val v = params[_param_idx]
            _param_idx = _param_idx + 1
            return v
        return DbValue.Null
    if expr.kind == SqlExprKind.IsNull:
        val inner = _eval_expr(expr.left, cols, vals, params)
        return DbValue.Bool(value: inner.is_null())
    if expr.kind == SqlExprKind.IsNotNull:
        val inner = _eval_expr(expr.left, cols, vals, params)
        return DbValue.Bool(value: not inner.is_null())
    if expr.kind == SqlExprKind.UnaryOp:
        val uval = _eval_expr(expr.left, cols, vals, params)
        val uop = expr.value.to_upper()
        if uop == "NOT":
            return DbValue.Bool(value: not _dbval_truthy(uval))
        if uop == "-":
            match uval:
                DbValue.Integer(value):
                    return DbValue.Integer(value: 0 - value)
                DbValue.Real(value):
                    return DbValue.Real(value: 0.0 - value)
                _:
                    return DbValue.Null
        return DbValue.Null
    if expr.kind == SqlExprKind.BinaryOp:
        val lv = _eval_expr(expr.left, cols, vals, params)
        val rv = _eval_expr(expr.right, cols, vals, params)
        return _apply_binop(expr.value, lv, rv)
    if expr.kind == SqlExprKind.Between:
        val bval = _eval_expr(expr.left, cols, vals, params)
        val lo = _eval_expr(expr.args[0], cols, vals, params)
        val hi = _eval_expr(expr.args[1], cols, vals, params)
        val ge_lo = _dbval_cmp(lo, bval) <= 0
        val le_hi = _dbval_cmp(bval, hi) <= 0
        return DbValue.Bool(value: ge_lo and le_hi)
    if expr.kind == SqlExprKind.InList:
        val target = _eval_expr(expr.left, cols, vals, params)
        var found = false
        var ini: i32 = 0
        while ini < expr.args.len() as i32:
            val item = _eval_expr(expr.args[ini], cols, vals, params)
            if _dbval_eq(target, item):
                found = true
            ini = ini + 1
        return DbValue.Bool(value: found)
    if expr.kind == SqlExprKind.FunctionCall:
        val fname = expr.value.to_lower()
        if fname == "fts_match":
            if expr.args.len() < 2:
                return DbValue.Bool(value: false)
            val target = _eval_expr(expr.args[0], cols, vals, params)
            val query = _eval_expr(expr.args[1], cols, vals, params)
            return DbValue.Bool(value: _fts_match_value(target.to_text(), query.to_text()))
        # ── String functions ─────────────────────────────────────────
        if fname == "length":
            if expr.args.len() < 1:
                return DbValue.Null
            val lv = _eval_expr(expr.args[0], cols, vals, params)
            if lv.is_null():
                return DbValue.Null
            val lt = lv.to_text()
            return DbValue.Integer(value: lt.len())
        if fname == "upper":
            if expr.args.len() < 1:
                return DbValue.Null
            val uv = _eval_expr(expr.args[0], cols, vals, params)
            if uv.is_null():
                return DbValue.Null
            val ut = uv.to_text()
            return DbValue.Text(value: ut.to_upper())
        if fname == "lower":
            if expr.args.len() < 1:
                return DbValue.Null
            val lwv = _eval_expr(expr.args[0], cols, vals, params)
            if lwv.is_null():
                return DbValue.Null
            val lwt = lwv.to_text()
            return DbValue.Text(value: lwt.to_lower())
        if fname == "trim":
            if expr.args.len() < 1:
                return DbValue.Null
            val trv = _eval_expr(expr.args[0], cols, vals, params)
            if trv.is_null():
                return DbValue.Null
            val trt = trv.to_text()
            return DbValue.Text(value: trt.trim())
        if fname == "substr" or fname == "substring":
            if expr.args.len() < 2:
                return DbValue.Null
            val sv = _eval_expr(expr.args[0], cols, vals, params)
            if sv.is_null():
                return DbValue.Null
            val st = sv.to_text()
            val start_v = _eval_expr(expr.args[1], cols, vals, params)
            val start_i = _dbval_as_i64(start_v) - 1
            if start_i < 0:
                return DbValue.Text(value: st)
            if expr.args.len() >= 3:
                val len_v = _eval_expr(expr.args[2], cols, vals, params)
                val slen = _dbval_as_i64(len_v)
                var end_i = start_i + slen
                if end_i > st.len():
                    end_i = st.len()
                return DbValue.Text(value: st.slice(start_i, end_i))
            return DbValue.Text(value: st.slice(start_i, st.len()))
        if fname == "replace":
            if expr.args.len() < 3:
                return DbValue.Null
            val rpv = _eval_expr(expr.args[0], cols, vals, params)
            if rpv.is_null():
                return DbValue.Null
            val rpt = rpv.to_text()
            val from_v = _eval_expr(expr.args[1], cols, vals, params)
            val to_v = _eval_expr(expr.args[2], cols, vals, params)
            val from_t = from_v.to_text()
            val to_t = to_v.to_text()
            return DbValue.Text(value: rpt.replace(from_t, to_t))
        # ── Math functions ───────────────────────────────────────────
        if fname == "abs":
            if expr.args.len() < 1:
                return DbValue.Null
            val abv = _eval_expr(expr.args[0], cols, vals, params)
            if abv.is_null():
                return DbValue.Null
            if _dbval_is_int(abv):
                val ai = _dbval_as_i64(abv)
                if ai < 0:
                    return DbValue.Integer(value: 0 - ai)
                return abv
            return abv
        if fname == "max":
            if expr.args.len() < 2:
                return DbValue.Null
            val mxa = _eval_expr(expr.args[0], cols, vals, params)
            val mxb = _eval_expr(expr.args[1], cols, vals, params)
            if mxa.is_null():
                return mxb
            if mxb.is_null():
                return mxa
            if _dbval_cmp(mxa, mxb) >= 0:
                return mxa
            return mxb
        if fname == "min":
            if expr.args.len() < 2:
                return DbValue.Null
            val mna = _eval_expr(expr.args[0], cols, vals, params)
            val mnb = _eval_expr(expr.args[1], cols, vals, params)
            if mna.is_null():
                return mnb
            if mnb.is_null():
                return mna
            if _dbval_cmp(mna, mnb) <= 0:
                return mna
            return mnb
        # ── CASE WHEN expression ────────────────────────────────────
        if fname == "case":
            val nargs = expr.args.len() as i32
            val has_else = (nargs % 2) != 0
            var pair_count = nargs / 2
            var cwi: i32 = 0
            while cwi < pair_count:
                val cond_idx = cwi * 2
                val then_idx = cond_idx + 1
                val cond_val = _eval_expr(expr.args[cond_idx], cols, vals, params)
                if _dbval_truthy(cond_val):
                    return _eval_expr(expr.args[then_idx], cols, vals, params)
                cwi = cwi + 1
            if has_else:
                val else_idx = nargs - 1
                return _eval_expr(expr.args[else_idx], cols, vals, params)
            return DbValue.Null
        # ── NULL handling functions ──────────────────────────────────
        if fname == "coalesce":
            var ci: i32 = 0
            while ci < expr.args.len() as i32:
                val cv = _eval_expr(expr.args[ci], cols, vals, params)
                if not cv.is_null():
                    return cv
                ci = ci + 1
            return DbValue.Null
        if fname == "ifnull":
            if expr.args.len() < 2:
                return DbValue.Null
            val ifv = _eval_expr(expr.args[0], cols, vals, params)
            if not ifv.is_null():
                return ifv
            return _eval_expr(expr.args[1], cols, vals, params)
        # Aggregate functions are evaluated in _do_select, not here.
        # Return Null as placeholder — real eval happens in aggregate path.
        return DbValue.Null
    if expr.kind == SqlExprKind.Star:
        return DbValue.Text(value: "*")
    DbValue.Null

fn _apply_binop(op: text, a: DbValue, b: DbValue) -> DbValue:
    if op == "=":
        return DbValue.Bool(value: _dbval_eq(a, b))
    if op == "!=":
        return DbValue.Bool(value: not _dbval_eq(a, b))
    if op == ">":
        return DbValue.Bool(value: _dbval_cmp(a, b) > 0)
    if op == "<":
        return DbValue.Bool(value: _dbval_cmp(a, b) < 0)
    if op == ">=":
        return DbValue.Bool(value: _dbval_cmp(a, b) >= 0)
    if op == "<=":
        return DbValue.Bool(value: _dbval_cmp(a, b) <= 0)
    if op == "AND":
        return DbValue.Bool(value: _dbval_truthy(a) and _dbval_truthy(b))
    if op == "OR":
        return DbValue.Bool(value: _dbval_truthy(a) or _dbval_truthy(b))
    if op == "+":
        if _dbval_is_int(a) and _dbval_is_int(b):
            return DbValue.Integer(value: _dbval_as_i64(a) + _dbval_as_i64(b))
        return DbValue.Null
    if op == "-":
        if _dbval_is_int(a) and _dbval_is_int(b):
            return DbValue.Integer(value: _dbval_as_i64(a) - _dbval_as_i64(b))
        return DbValue.Null
    if op == "*":
        if _dbval_is_int(a) and _dbval_is_int(b):
            return DbValue.Integer(value: _dbval_as_i64(a) * _dbval_as_i64(b))
        return DbValue.Null
    if op == "LIKE":
        val av = a.to_text()
        val bv = b.to_text()
        return DbValue.Bool(value: _like_match(bv, av))
    if op == "MATCH":
        return DbValue.Bool(value: _fts_match_value(a.to_text(), b.to_text()))
    DbValue.Null

fn _check_where(where_expr: SqlExpr?, cols: [text], vals: [DbValue], params: [DbValue]) -> bool:
    if not where_expr.?:
        return true
    val result = _eval_expr(where_expr, cols, vals, params)
    _dbval_truthy(result)

fn _eval_expr_fast(expr: SqlExpr, cm: Dict<text, i32>, vals: [DbValue], params: [DbValue]) -> DbValue:
    if expr.kind == SqlExprKind.Literal:
        return _parse_literal(expr.value)
    if expr.kind == SqlExprKind.Column:
        val idx = _col_idx(cm, expr.value)
        if idx >= 0:
            return vals[idx]
        return DbValue.Null
    if expr.kind == SqlExprKind.Placeholder:
        if _param_idx < params.len():
            val v = params[_param_idx]
            _param_idx = _param_idx + 1
            return v
        return DbValue.Null
    if expr.kind == SqlExprKind.IsNull:
        val inner = _eval_expr_fast(expr.left, cm, vals, params)
        return DbValue.Bool(value: inner.is_null())
    if expr.kind == SqlExprKind.IsNotNull:
        val inner = _eval_expr_fast(expr.left, cm, vals, params)
        return DbValue.Bool(value: not inner.is_null())
    if expr.kind == SqlExprKind.UnaryOp:
        val uval = _eval_expr_fast(expr.left, cm, vals, params)
        val uop = expr.value.to_upper()
        if uop == "NOT":
            return DbValue.Bool(value: not _dbval_truthy(uval))
        if uop == "-":
            match uval:
                DbValue.Integer(value):
                    return DbValue.Integer(value: 0 - value)
                DbValue.Real(value):
                    return DbValue.Real(value: 0.0 - value)
                _:
                    return DbValue.Null
        return DbValue.Null
    if expr.kind == SqlExprKind.BinaryOp:
        val lv = _eval_expr_fast(expr.left, cm, vals, params)
        val rv = _eval_expr_fast(expr.right, cm, vals, params)
        return _apply_binop(expr.value, lv, rv)
    if expr.kind == SqlExprKind.Between:
        val bval = _eval_expr_fast(expr.left, cm, vals, params)
        val lo = _eval_expr_fast(expr.args[0], cm, vals, params)
        val hi = _eval_expr_fast(expr.args[1], cm, vals, params)
        val ge_lo = _dbval_cmp(lo, bval) <= 0
        val le_hi = _dbval_cmp(bval, hi) <= 0
        return DbValue.Bool(value: ge_lo and le_hi)
    if expr.kind == SqlExprKind.InList:
        val target = _eval_expr_fast(expr.left, cm, vals, params)
        var found = false
        var ini: i32 = 0
        while ini < expr.args.len() as i32:
            val item = _eval_expr_fast(expr.args[ini], cm, vals, params)
            if _dbval_eq(target, item):
                found = true
            ini = ini + 1
        return DbValue.Bool(value: found)
    if expr.kind == SqlExprKind.FunctionCall:
        val fname = expr.value.to_lower()
        if fname == "fts_match":
            if expr.args.len() < 2:
                return DbValue.Bool(value: false)
            val target = _eval_expr_fast(expr.args[0], cm, vals, params)
            val query = _eval_expr_fast(expr.args[1], cm, vals, params)
            return DbValue.Bool(value: _fts_match_value(target.to_text(), query.to_text()))
        if fname == "length":
            if expr.args.len() < 1:
                return DbValue.Null
            val lv = _eval_expr_fast(expr.args[0], cm, vals, params)
            if lv.is_null():
                return DbValue.Null
            return DbValue.Integer(value: lv.to_text().len())
        if fname == "upper":
            if expr.args.len() < 1:
                return DbValue.Null
            val uv = _eval_expr_fast(expr.args[0], cm, vals, params)
            if uv.is_null():
                return DbValue.Null
            return DbValue.Text(value: uv.to_text().to_upper())
        if fname == "lower":
            if expr.args.len() < 1:
                return DbValue.Null
            val lwv = _eval_expr_fast(expr.args[0], cm, vals, params)
            if lwv.is_null():
                return DbValue.Null
            return DbValue.Text(value: lwv.to_text().to_lower())
    DbValue.Null

fn _check_where_fast(where_expr: SqlExpr?, cm: Dict<text, i32>, vals: [DbValue], params: [DbValue]) -> bool:
    if not where_expr.?:
        return true
    val result = _eval_expr_fast(where_expr, cm, vals, params)
    _dbval_truthy(result)

# ── LIKE pattern matching ────────────────────────────────────────────────────
# % matches any sequence, _ matches single character.

fn _like_match(pattern: text, value: text) -> bool:
    val plen = pattern.len()
    val vlen = value.len()
    var pi: i64 = 0
    var vi: i64 = 0
    var star_pi: i64 = -1
    var star_vi: i64 = -1
    var ok = true
    while vi < vlen and ok:
        var done = false
        if pi < plen and not done:
            val pc = pattern.char_at(pi)
            if pc == "_" and not done:
                pi = pi + 1
                vi = vi + 1
                done = true
            if pc == "%" and not done:
                star_pi = pi
                star_vi = vi
                pi = pi + 1
                done = true
            if not done:
                val vc = value.char_at(vi)
                if pc == vc:
                    pi = pi + 1
                    vi = vi + 1
                    done = true
        if not done:
            if star_pi >= 0:
                pi = star_pi + 1
                star_vi = star_vi + 1
                vi = star_vi
                done = true
            else:
                ok = false
    if not ok:
        return false
    while pi < plen:
        if pattern.char_at(pi) != "%":
            return false
        pi = pi + 1
    true

fn _expr_to_dbvalue(expr: SqlExpr, params: [DbValue]) -> DbValue:
    if expr.kind == SqlExprKind.Literal:
        return _parse_literal(expr.value)
    if expr.kind == SqlExprKind.Placeholder:
        if _param_idx < params.len():
            val v = params[_param_idx]
            _param_idx = _param_idx + 1
            return v
        return DbValue.Null
    DbValue.Text(value: expr.value)

# ── Aggregate helpers ────────────────────────────────────────────────────────

fn _unwrap_as_expr(expr: SqlExpr) -> SqlExpr:
    if expr.kind == SqlExprKind.BinaryOp and expr.value == "AS":
        return expr.left
    expr

fn _get_as_alias(expr: SqlExpr) -> text:
    if expr.kind == SqlExprKind.BinaryOp and expr.value == "AS":
        return expr.right.value
    ""

fn _is_agg_name(name: text) -> bool:
    val up = name.to_upper()
    if up == "COUNT":
        return true
    if up == "SUM":
        return true
    if up == "AVG":
        return true
    if up == "MIN":
        return true
    if up == "MAX":
        return true
    false

fn _is_agg_expr(expr: SqlExpr) -> bool:
    val inner = _unwrap_as_expr(expr)
    if inner.kind == SqlExprKind.FunctionCall:
        return _is_agg_name(inner.value)
    false

fn _has_any_agg(columns: [SqlExpr]) -> bool:
    var i: i32 = 0
    while i < columns.len() as i32:
        if _is_agg_expr(columns[i]):
            return true
        i = i + 1
    false

fn _compute_agg(name: text, vals: [DbValue]) -> DbValue:
    val up = name.to_upper()
    if up == "COUNT":
        return DbValue.Integer(value: vals.len() as i64)
    if up == "SUM":
        var s: i64 = 0
        var i: i32 = 0
        while i < vals.len() as i32:
            s = s + _dbval_as_i64(vals[i])
            i = i + 1
        return DbValue.Integer(value: s)
    if up == "AVG":
        if vals.len() == 0:
            return DbValue.Null
        var s: i64 = 0
        var i: i32 = 0
        while i < vals.len() as i32:
            s = s + _dbval_as_i64(vals[i])
            i = i + 1
        return DbValue.Integer(value: s / vals.len() as i64)
    if up == "MIN":
        if vals.len() == 0:
            return DbValue.Null
        var best = vals[0]
        var i: i32 = 1
        while i < vals.len() as i32:
            if _dbval_cmp(vals[i], best) < 0:
                best = vals[i]
            i = i + 1
        return best
    if up == "MAX":
        if vals.len() == 0:
            return DbValue.Null
        var best = vals[0]
        var i: i32 = 1
        while i < vals.len() as i32:
            if _dbval_cmp(vals[i], best) > 0:
                best = vals[i]
            i = i + 1
        return best
    DbValue.Null

fn _eval_agg_col(expr: SqlExpr, col_names: [text], all_rows: [[DbValue]]) -> DbValue:
    val inner = _unwrap_as_expr(expr)
    val fname = inner.value.to_upper()
    # COUNT(*)
    if inner.args.len() > 0:
        val arg0 = inner.args[0]
        if arg0.kind == SqlExprKind.Star:
            if fname == "COUNT":
                return DbValue.Integer(value: all_rows.len() as i64)
    # Collect column values
    var col_vals: [DbValue] = []
    if inner.args.len() > 0:
        val arg0 = inner.args[0]
        if arg0.kind != SqlExprKind.Star:
            val cidx = _find_idx(col_names, arg0.value)
            if cidx >= 0:
                var ri: i32 = 0
                while ri < all_rows.len() as i32:
                    val rv = all_rows[ri]
                    if not rv[cidx].is_null():
                        col_vals.push(rv[cidx])
                    ri = ri + 1
    if fname == "COUNT":
        return DbValue.Integer(value: col_vals.len() as i64)
    _compute_agg(fname, col_vals)

fn _serialize_group_key(exprs: [SqlExpr], col_names: [text], row_vals: [DbValue], params: [DbValue]) -> text:
    var parts: [text] = []
    var i: i32 = 0
    while i < exprs.len() as i32:
        val v = _eval_expr(exprs[i], col_names, row_vals, params)
        parts.push(v.to_text())
        i = i + 1
    var result = ""
    var j: i32 = 0
    while j < parts.len() as i32:
        if j > 0:
            result = result + "\x00" + parts[j]
        else:
            result = parts[j]
        j = j + 1
    result

fn _agg_col_name(expr: SqlExpr) -> text:
    val alias = _get_as_alias(expr)
    if alias != "":
        return alias
    val inner = _unwrap_as_expr(expr)
    if inner.kind == SqlExprKind.FunctionCall:
        if inner.args.len() > 0:
            val arg0 = inner.args[0]
            if arg0.kind == SqlExprKind.Star:
                return inner.value.to_upper() + "(*)"
            return inner.value.to_upper() + "(" + arg0.value + ")"
        return inner.value.to_upper() + "()"
    inner.value

# ── DROP TABLE parser ────────────────────────────────────────────────────────

fn _parse_drop_table(sql: text) -> text:
    val trimmed = sql.trim()
    val upper = trimmed.to_upper()
    if not upper.starts_with("DROP TABLE"):
        return ""
    var rest = trimmed.slice(10, trimmed.len()).trim()
    val rest_up = rest.to_upper()
    if rest_up.starts_with("IF EXISTS"):
        rest = rest.slice(9, rest.len()).trim()
    # Strip trailing semicolon
    if rest.ends_with(";"):
        rest = rest.slice(0, rest.len() - 1).trim()
    rest

# ── CREATE INDEX parser ──────────────────────────────────────────────────────
# Returns [is_unique, index_name, table_name, col1, col2, ...]
# Returns [] if not a CREATE INDEX statement.

fn _parse_create_index(sql: text) -> [text]:
    val trimmed = sql.trim()
    var upper = trimmed.to_upper()
    if upper.ends_with(";"):
        upper = upper.slice(0, upper.len() - 1).trim()
    var is_unique = "false"
    var rest = trimmed
    if upper.starts_with("CREATE UNIQUE INDEX"):
        is_unique = "true"
        rest = trimmed.slice(19, trimmed.len()).trim()
    elif upper.starts_with("CREATE INDEX"):
        rest = trimmed.slice(12, trimmed.len()).trim()
    else:
        return []
    # Strip trailing semicolon from rest too
    if rest.ends_with(";"):
        rest = rest.slice(0, rest.len() - 1).trim()
    # rest = "idx_name ON table (col1, col2)"
    val parts = rest.split(" ")
    if parts.len() < 3:
        return []
    val idx_name = parts[0]
    val on_word = parts[1].to_upper()
    if on_word != "ON":
        return []
    # Find the table name and columns in parentheses
    # Rejoin remainder after "ON"
    var after_on = ""
    var pi: i32 = 2
    while pi < parts.len() as i32:
        if after_on != "":
            after_on = after_on + " "
        after_on = after_on + parts[pi]
        pi = pi + 1
    # Find open paren
    val paren_start = after_on.index_of("(")
    if paren_start < 0:
        return []
    val tbl_name = after_on.slice(0, paren_start).trim()
    if tbl_name == "":
        return []
    val paren_end = after_on.index_of(")")
    if paren_end < 0:
        return []
    val cols_str = after_on.slice(paren_start + 1, paren_end).trim()
    val col_parts = cols_str.split(",")
    var result: [text] = []
    result.push(is_unique)
    result.push(idx_name)
    result.push(tbl_name)
    var ci: i32 = 0
    while ci < col_parts.len() as i32:
        val col = col_parts[ci].trim()
        if col != "":
            result.push(col)
        ci = ci + 1
    result

# ── DROP INDEX parser ───────────────────────────────────────────────────────

fn _parse_drop_index(sql: text) -> text:
    val trimmed = sql.trim()
    val upper = trimmed.to_upper()
    if not upper.starts_with("DROP INDEX"):
        return ""
    var rest = trimmed.slice(10, trimmed.len()).trim()
    if rest.ends_with(";"):
        rest = rest.slice(0, rest.len() - 1).trim()
    rest

fn _parse_txn_command(sql: text) -> text:
    val trimmed = sql.trim()
    var low = trimmed.to_lower()
    # Strip trailing semicolon
    if low.ends_with(";"):
        low = low.slice(0, low.len() - 1).trim()
    if low == "begin" or low == "begin transaction":
        return "BEGIN"
    if low == "commit" or low == "end transaction":
        return "COMMIT"
    if low == "rollback":
        return "ROLLBACK"
    ""

fn _parse_alter_table(sql: text) -> [text]:
    val trimmed = sql.trim()
    val upper = trimmed.to_upper()
    if not upper.starts_with("ALTER TABLE"):
        return []
    var rest = trimmed.slice(11, trimmed.len()).trim()
    # Strip trailing semicolon
    if rest.ends_with(";"):
        rest = rest.slice(0, rest.len() - 1).trim()
    # Extract table name (first token)
    val parts = rest.split(" ")
    if parts.len() < 4:
        return []
    val tbl_name = parts[0]
    # Expect ADD COLUMN
    val p1 = parts[1].to_upper()
    val p2 = parts[2].to_upper()
    if p1 != "ADD" or p2 != "COLUMN":
        return []
    val col_name = parts[3]
    var col_type = "TEXT"
    if parts.len() >= 5:
        col_type = parts[4].to_upper()
    var result: [text] = []
    result.push(tbl_name)
    result.push(col_name)
    result.push(col_type)
    result

fn _join_text(values: [text], sep: text) -> text:
    var result = ""
    var i: i32 = 0
    while i < values.len() as i32:
        if i > 0:
            result = result + sep
        result = result + values[i]
        i = i + 1
    result

fn _split_csv(value: text) -> [text]:
    if value == "":
        return []
    value.split(",")

# ── PureDatabase ─────────────────────────────────────────────────────────────

class PureDatabase:
    _path: text
    _tbl_names: [text]
    _tbl_cols: [[text]]
    _tbl_data: [MvccTable]
    _tbl_rowids: [i64]
    _fts_indexes: [FtsEngine]
    _fts_valid: [bool]
    _fts_columns: [[text]]
    _indexes: [[[text]]]
    _index_unique: [[bool]]
    _txn: MvccTxnManager
    is_open: bool
    _last_rowid: i64
    _last_changes: i64
    _in_transaction: bool
    _dirty: bool
    _auto_checkpoint: bool
    _tbl_fts_next_doc_id: [i64]
    _tbl_fts_doc_ids: [[i64]]
    _snap_tbl_names: [text]
    _snap_tbl_cols: [[text]]
    _snap_row_tidx: [i32]
    _snap_row_data: [text]
    _snap_tbl_rowids: [i64]
    _snap_indexes: [[[text]]]
    _snap_index_unique: [[bool]]
    _tbl_typed: [[[DbValue]]]
    _tbl_pk_col: [i32]
    _tbl_pk_map: [Dict<text, i32>]
    _tbl_dirty: [bool]
    _tbl_name_idx: Dict<text, i32>
    _tbl_col_idx: [Dict<text, i32>]
    _fts_rows: [[DbRow]]
    _tbl_vis: [[bool]]
    _tbl_vis_xmax: [i64]
    _fts_search_key: [text]
    _fts_search_res: [[PureSearchResult]]
    _sel_cache_key: [text]
    _sel_cache_res: [[DbRow]]
    _scan_cache_key: [text]
    _scan_cache_res: [[DbRow]]

    static fn memory() -> Result<PureDatabase, DbError>:
        Ok(PureDatabase(
            _path: "",
            _tbl_names: [],
            _tbl_cols: [],
            _tbl_data: [],
            _tbl_rowids: [],
            _fts_indexes: [],
            _fts_valid: [],
            _fts_columns: [],
            _indexes: [],
            _index_unique: [],
            _txn: MvccTxnManager.new(),
            is_open: true,
            _last_rowid: 0,
            _last_changes: 0,
            _in_transaction: false,
            _dirty: false,
            _auto_checkpoint: true,
            _tbl_fts_next_doc_id: [],
            _tbl_fts_doc_ids: [],
            _snap_tbl_names: [],
            _snap_tbl_cols: [],
            _snap_row_tidx: [],
            _snap_row_data: [],
            _snap_tbl_rowids: [],
            _snap_indexes: [],
            _snap_index_unique: [],
            _tbl_typed: [],
            _tbl_pk_col: [],
            _tbl_pk_map: [],
            _tbl_dirty: [],
            _tbl_name_idx: {},
            _tbl_col_idx: [],
            _fts_rows: [],
            _tbl_vis: [],
            _tbl_vis_xmax: [],
            _fts_search_key: [],
            _fts_search_res: [],
            _sel_cache_key: [],
            _sel_cache_res: [],
            _scan_cache_key: [],
            _scan_cache_res: []
        ))

    static fn memory_deferred() -> Result<PureDatabase, DbError>:
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db._auto_checkpoint = false
        Ok(db)

    static fn open(path: text) -> Result<PureDatabase, DbError>:
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db._path = path
        if file_exists(path):
            val loaded = db._load_from_disk()
            if loaded.is_err():
                return loaded
        else:
            val saved = db._persist()
            if saved.is_err():
                return saved
        Ok(db)

    static fn open_deferred(path: text) -> Result<PureDatabase, DbError>:
        val r = PureDatabase.open(path)
        var db = r.unwrap()
        db._auto_checkpoint = false
        Ok(db)

    me checkpoint() -> Result<(), DbError>:
        if self._dirty:
            self._persist()?
            self._dirty = false
            var ci: i32 = 0
            while ci < self._tbl_dirty.len() as i32:
                self._tbl_dirty[ci] = false
                ci = ci + 1
        Ok(())

    me _mark_dirty() -> Result<(), DbError>:
        self._dirty = true
        if self._auto_checkpoint and not self._in_transaction:
            self.checkpoint()?
        Ok(())

    me _mark_table_dirty(ti: i32) -> Result<(), DbError>:
        if ti >= 0 and ti < self._tbl_dirty.len() as i32:
            self._tbl_dirty[ti] = true
        self._mark_dirty()?
        Ok(())

    me close() -> Result<(), DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        self.checkpoint()?
        self.is_open = false
        Ok(())

    # ── Direct Typed API (Phase 3 — bypass SQL parse) ────────────────

    me get(table: text, key_col: text, key_val: DbValue) -> Result<DbRow?, DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        # Fast table lookup via Dict cache
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "GET", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        # Fast column lookup via Dict cache
        var kci: i32 = -1
        if ti < self._tbl_col_idx.len() as i32:
            val cm = self._tbl_col_idx[ti]
            if cm.has(key_col):
                kci = cm[key_col]
        if kci < 0:
            kci = _find_idx(col_names, key_col)
        if kci < 0:
            return Err(DbError.QueryFailed(sql: "GET", message: "no such column: {key_col}"))
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        val key_txt = key_val.to_text()
        if use_typed and kci == self._tbl_pk_col[ti]:
            val pkm = self._tbl_pk_map[ti]
            if pkm.has(key_txt):
                val tidx = pkm[key_txt]
                if tidx >= 0 and tidx < tbl.tuples.len() as i32:
                    if mvcc_is_visible(tbl.tuples[tidx], snap):
                        return Ok(Some(DbRow(columns: col_names, values: typed[tidx])))
            return Ok(nil)
        if use_typed:
            var gi: i32 = 0
            while gi < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[gi], snap):
                    val rv = typed[gi]
                    if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                        return Ok(Some(DbRow(columns: col_names, values: rv)))
                gi = gi + 1
        else:
            val visible = tbl.scan(snap)
            self._tbl_data[ti] = tbl
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val rv = _deserialize_row(visible[ri])
                if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                    return Ok(Some(DbRow(columns: col_names, values: rv)))
                ri = ri + 1
        Ok(nil)

    me get_batch(table: text, key_col: text, key_vals: [DbValue]) -> Result<[DbRow?], DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "GET_BATCH", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        var kci: i32 = -1
        if ti < self._tbl_col_idx.len() as i32:
            val cm = self._tbl_col_idx[ti]
            if cm.has(key_col):
                kci = cm[key_col]
        if kci < 0:
            kci = _find_idx(col_names, key_col)
        if kci < 0:
            return Err(DbError.QueryFailed(sql: "GET_BATCH", message: "no such column: {key_col}"))
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        val use_pk = use_typed and kci == self._tbl_pk_col[ti]
        val pkm = self._tbl_pk_map[ti]
        var results: [DbRow?] = []
        var ki: i32 = 0
        while ki < key_vals.len() as i32:
            val key_txt = key_vals[ki].to_text()
            var found: DbRow? = nil
            if use_pk:
                if pkm.has(key_txt):
                    val tidx = pkm[key_txt]
                    if tidx >= 0 and tidx < tbl.tuples.len() as i32:
                        if mvcc_is_visible(tbl.tuples[tidx], snap):
                            found = DbRow(columns: col_names, values: typed[tidx])
            elif use_typed:
                var gi: i32 = 0
                while gi < tbl.tuples.len() as i32:
                    if mvcc_is_visible(tbl.tuples[gi], snap):
                        val rv = typed[gi]
                        if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                            found = DbRow(columns: col_names, values: rv)
                    gi = gi + 1
            results.push(found)
            ki = ki + 1
        Ok(results)

    me put(table: text, values: [DbValue]) -> Result<i64, DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "PUT", message: "no such table: {table}"))
        val handle = self._txn.begin()
        val tid = handle.txn_id
        # Skip expensive _serialize_row — use unique index placeholder.
        # _persist and typed reads use _tbl_typed[ti], not tuples[].data.
        var tbl = self._tbl_data[ti]
        val row_idx = tbl.tuples.len() as i32
        tbl.insert(tid, "{row_idx}")
        self._tbl_data[ti] = tbl
        var typed_put = self._tbl_typed[ti]
        typed_put.push(values)
        self._tbl_typed[ti] = typed_put
        val pk_ci = self._tbl_pk_col[ti]
        if pk_ci >= 0 and pk_ci < values.len() as i32:
            var pkm = self._tbl_pk_map[ti]
            pkm[values[pk_ci].to_text()] = row_idx
            self._tbl_pk_map[ti] = pkm
        self._tbl_rowids[ti] = self._tbl_rowids[ti] + 1
        self._last_rowid = self._tbl_rowids[ti]
        self._txn.commit(tid)
        self._last_changes = 1
        self._mark_dirty()?
        Ok(1)

    me delete_by_key(table: text, key_col: text, key_val: DbValue) -> Result<i64, DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "DELETE_BY_KEY", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        var kci: i32 = -1
        if ti < self._tbl_col_idx.len() as i32:
            val cm = self._tbl_col_idx[ti]
            if cm.has(key_col):
                kci = cm[key_col]
        if kci < 0:
            kci = _find_idx(col_names, key_col)
        if kci < 0:
            return Err(DbError.QueryFailed(sql: "DELETE_BY_KEY", message: "no such column: {key_col}"))
        val handle = self._txn.begin()
        val tid = handle.txn_id
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        val key_txt = key_val.to_text()
        var deleted: i64 = 0
        # PK map fast path: O(1) lookup when deleting by primary key
        if use_typed and kci == self._tbl_pk_col[ti]:
            val pkm = self._tbl_pk_map[ti]
            if pkm.has(key_txt):
                val tidx = pkm[key_txt]
                if tidx >= 0 and tidx < tbl.tuples.len() as i32:
                    if mvcc_is_visible(tbl.tuples[tidx], snap):
                        tbl.delete_matching(tid, tbl.tuples[tidx].data)
                        deleted = 1
        elif use_typed:
            var dki: i32 = 0
            while dki < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[dki], snap):
                    val rv = typed[dki]
                    if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                        tbl.delete_matching(tid, tbl.tuples[dki].data)
                        deleted = deleted + 1
                dki = dki + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val rv = _deserialize_row(visible[ri])
                if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                    tbl.delete_matching(tid, visible[ri])
                    deleted = deleted + 1
                ri = ri + 1
        self._tbl_data[ti] = tbl
        self._txn.commit(tid)
        if deleted > 0:
            self._invalidate_fts(ti)
            # Remove from PK map
            if kci == self._tbl_pk_col[ti]:
                var pkm2 = self._tbl_pk_map[ti]
                pkm2.remove(key_txt)
                self._tbl_pk_map[ti] = pkm2
        self._last_changes = deleted
        self._mark_dirty()?
        Ok(deleted)

    me update_by_key(table: text, key_col: text, key_val: DbValue, col_updates: Dict<text, DbValue>) -> Result<i64, DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "UPDATE_BY_KEY", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        var kci: i32 = -1
        if ti < self._tbl_col_idx.len() as i32:
            val cm = self._tbl_col_idx[ti]
            if cm.has(key_col):
                kci = cm[key_col]
        if kci < 0:
            kci = _find_idx(col_names, key_col)
        if kci < 0:
            return Err(DbError.QueryFailed(sql: "UPDATE_BY_KEY", message: "no such column: {key_col}"))
        val handle = self._txn.begin()
        val tid = handle.txn_id
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        val key_txt = key_val.to_text()
        val pk_ci = self._tbl_pk_col[ti]
        var found_tidx: i32 = -1
        # PK map fast path
        if use_typed and kci == pk_ci:
            val pkm = self._tbl_pk_map[ti]
            if pkm.has(key_txt):
                val tidx = pkm[key_txt]
                if tidx >= 0 and tidx < tbl.tuples.len() as i32:
                    if mvcc_is_visible(tbl.tuples[tidx], snap):
                        found_tidx = tidx
        elif use_typed:
            var si: i32 = 0
            while si < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[si], snap):
                    val rv = typed[si]
                    if kci < rv.len() as i32 and rv[kci].to_text() == key_txt:
                        found_tidx = si
                si = si + 1
        if found_tidx < 0:
            self._tbl_data[ti] = tbl
            self._txn.commit(tid)
            self._last_changes = 0
            return Ok(0)
        val row_vals = typed[found_tidx]
        var new_vals: [DbValue] = []
        var ci: i32 = 0
        while ci < col_names.len() as i32:
            val col = col_names[ci]
            if col_updates.has(col):
                new_vals.push(col_updates[col])
            else:
                new_vals.push(row_vals[ci])
            ci = ci + 1
        val old_data = tbl.tuples[found_tidx].data
        tbl.delete_matching(tid, old_data)
        val new_ser = _serialize_row(new_vals)
        tbl.insert(tid, new_ser)
        val new_pos = tbl.tuples.len() as i32 - 1
        self._tbl_data[ti] = tbl
        var typed2 = self._tbl_typed[ti]
        typed2.push(new_vals)
        self._tbl_typed[ti] = typed2
        # Update PK map
        if pk_ci >= 0 and pk_ci < new_vals.len() as i32:
            var pkm2 = self._tbl_pk_map[ti]
            if pk_ci < row_vals.len() as i32:
                pkm2.remove(row_vals[pk_ci].to_text())
            pkm2[new_vals[pk_ci].to_text()] = new_pos
            self._tbl_pk_map[ti] = pkm2
        self._txn.commit(tid)
        self._invalidate_fts(ti)
        self._last_changes = 1
        self._mark_dirty()?
        Ok(1)

    me scan_all(table: text) -> Result<[DbRow], DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "SCAN", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        var rows: [DbRow] = []
        if use_typed:
            var si: i32 = 0
            while si < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[si], snap):
                    rows.push(DbRow(columns: col_names, values: typed[si]))
                si = si + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                rows.push(DbRow(columns: col_names, values: _deserialize_row(visible[ri])))
                ri = ri + 1
        self._tbl_data[ti] = tbl
        Ok(rows)

    me scan_range(table: text, col: text, low: DbValue, high: DbValue) -> Result<[DbRow], DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(sql: "SCAN_RANGE", message: "no such table: {table}"))
        val col_names = self._tbl_cols[ti]
        var cci: i32 = -1
        if ti < self._tbl_col_idx.len() as i32:
            val cm = self._tbl_col_idx[ti]
            if cm.has(col):
                cci = cm[col]
        if cci < 0:
            cci = _find_idx(col_names, col)
        if cci < 0:
            return Err(DbError.QueryFailed(sql: "SCAN_RANGE", message: "no such column: {col}"))
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        var rows: [DbRow] = []
        if use_typed:
            val low_i = _dbval_as_i64(low)
            val high_i = _dbval_as_i64(high)
            val n = tbl.tuples.len() as i32
            var si: i32 = 0
            while si < n:
                if mvcc_is_visible(tbl.tuples[si], snap):
                    val rv = typed[si]
                    if cci < rv.len() as i32:
                        val cv = _dbval_as_i64(rv[cci])
                        if cv >= low_i and cv < high_i:
                            rows.push(DbRow(columns: col_names, values: rv))
                si = si + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val rv = _deserialize_row(visible[ri])
                if cci < rv.len() as i32:
                    val cv = _dbval_as_i64(rv[cci])
                    val lv = _dbval_as_i64(low)
                    val hv = _dbval_as_i64(high)
                    if cv >= lv and cv < hv:
                        rows.push(DbRow(columns: col_names, values: rv))
                ri = ri + 1
        self._tbl_data[ti] = tbl
        Ok(rows)

    me _serialize_disk() -> text:
        var lines: [text] = ["simple-pure-db-v1"]
        var ti: i32 = 0
        while ti < self._tbl_names.len() as i32:
            val table_name = self._tbl_names[ti]
            lines.push("table|" + table_name + "|" + _join_text(self._tbl_cols[ti], ","))
            if self._fts_columns[ti].len() > 0:
                lines.push("fts|" + table_name + "|" + _join_text(self._fts_columns[ti], ","))
            val snap = self._txn.snapshot()
            var tbl = self._tbl_data[ti]
            val typed = self._tbl_typed[ti]
            val use_typed = typed.len() == tbl.tuples.len()
            if use_typed:
                var si: i32 = 0
                while si < tbl.tuples.len() as i32:
                    if mvcc_is_visible(tbl.tuples[si], snap):
                        lines.push("row|" + table_name + "|" + _serialize_row(typed[si]))
                    si = si + 1
            else:
                val visible = tbl.scan(snap)
                var ri: i32 = 0
                while ri < visible.len() as i32:
                    lines.push("row|" + table_name + "|" + visible[ri])
                    ri = ri + 1
            self._tbl_data[ti] = tbl
            ti = ti + 1
        lines.join("\n")

    me _persist() -> Result<(), DbError>:
        if self._path == "":
            return Ok(())
        if file_write(self._path, self._serialize_disk()):
            return Ok(())
        Err(DbError.ConnectionFailed(path: self._path, message: "failed to persist pure database"))

    me _load_from_disk() -> Result<PureDatabase, DbError>:
        val content = file_read(self._path)
        if content == "":
            return Ok(self)
        val lines = content.split("\n")
        if lines.len() == 0 or lines[0].trim() != "simple-pure-db-v1":
            return Err(DbError.ConnectionFailed(path: self._path, message: "unsupported pure database format"))
        var i: i32 = 1
        while i < lines.len() as i32:
            val line = lines[i].trim()
            if line == "":
                i = i + 1
                continue
            val parts = line.split("|")
            if parts.len() >= 3:
                val kind = parts[0]
                val table_name = parts[1]
                if kind == "table":
                    val load_ti = self._tbl_names.len() as i32
                    val load_cols = _split_csv(parts[2])
                    self._tbl_names.push(table_name)
                    self._tbl_cols.push(load_cols)
                    self._tbl_data.push(MvccTable.new())
                    self._tbl_rowids.push(0)
                    self._fts_indexes.push(FtsEngine.new())
                    self._fts_valid.push(false)
                    self._fts_columns.push([])
                    self._fts_rows.push([])
                    self._tbl_vis.push([])
                    self._tbl_vis_xmax.push(-1)
                    self._fts_search_key.push("")
                    self._fts_search_res.push([])
                    self._sel_cache_key.push("")
                    self._sel_cache_res.push([])
                    self._scan_cache_key.push("")
                    self._scan_cache_res.push([])
                    self._indexes.push([])
                    self._index_unique.push([])
                    self._tbl_fts_next_doc_id.push(0)
                    self._tbl_fts_doc_ids.push([])
                    var empty_typed: [[DbValue]] = []
                    self._tbl_typed.push(empty_typed)
                    self._tbl_pk_col.push(-1)
                    var empty_pk: Dict<text, i32> = {}
                    self._tbl_pk_map.push(empty_pk)
                    self._tbl_dirty.push(false)
                    # Update name→index and column→index caches
                    self._tbl_name_idx[table_name] = load_ti
                    self._tbl_col_idx.push(_build_col_map(load_cols))
                elif kind == "fts":
                    val ti = _find_idx(self._tbl_names, table_name)
                    if ti >= 0:
                        self._fts_columns[ti] = _split_csv(parts[2])
                        self._fts_valid[ti] = false
                elif kind == "row":
                    val ti = _find_idx(self._tbl_names, table_name)
                    if ti >= 0:
                        val handle = self._txn.begin()
                        val tid = handle.txn_id
                        var tbl = self._tbl_data[ti]
                        tbl.insert(tid, parts[2])
                        self._tbl_data[ti] = tbl
                        self._txn.commit(tid)
                        val row_vals = _deserialize_row(parts[2])
                        var typed_load = self._tbl_typed[ti]
                        typed_load.push(row_vals)
                        self._tbl_typed[ti] = typed_load
                        self._tbl_rowids[ti] = self._tbl_rowids[ti] + 1
                        self._last_rowid = self._tbl_rowids[ti]
            i = i + 1
        Ok(self)

    me exec(sql: text, params: [DbValue]) -> Result<i64, DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        # Handle transaction control before parsing
        val txn_cmd = _parse_txn_command(sql)
        if txn_cmd == "BEGIN":
            return self._do_begin()
        if txn_cmd == "COMMIT":
            return self._do_commit()
        if txn_cmd == "ROLLBACK":
            return self._do_rollback()
        # Handle ALTER TABLE before parsing
        val alter_parts = _parse_alter_table(sql)
        if alter_parts.len() == 3:
            val a_tbl = alter_parts[0]
            val a_col = alter_parts[1]
            val a_type = alter_parts[2]
            return self._do_alter_add_column(a_tbl, a_col, a_type)
        # Handle CREATE INDEX before parsing
        val ci_parts = _parse_create_index(sql)
        if ci_parts.len() >= 4:
            val ci_unique = ci_parts[0] == "true"
            val ci_name = ci_parts[1]
            val ci_tbl = ci_parts[2]
            var ci_cols: [text] = []
            var cci: i32 = 3
            while cci < ci_parts.len() as i32:
                ci_cols.push(ci_parts[cci])
                cci = cci + 1
            return self._do_create_index(ci_unique, ci_name, ci_tbl, ci_cols)
        # Handle DROP INDEX before parsing
        val drop_idx = _parse_drop_index(sql)
        if drop_idx != "":
            return self._do_drop_index(drop_idx)
        # Handle DROP TABLE before parsing (parser has no DropTable variant)
        val drop_tbl = _parse_drop_table(sql)
        if drop_tbl != "":
            return self._do_drop(drop_tbl)
        # Handle INSERT OR REPLACE / REPLACE INTO
        var actual_sql = sql
        var is_replace = false
        val trimmed_sql = sql.trim()
        val trimmed_upper = trimmed_sql.to_upper()
        if trimmed_upper.starts_with("INSERT OR REPLACE"):
            val trimmed_len = trimmed_sql.len()
            val after_ior = trimmed_sql.slice(17, trimmed_len)
            actual_sql = "INSERT" + after_ior
            is_replace = true
        elif trimmed_upper.starts_with("REPLACE INTO"):
            val trimmed_len2 = trimmed_sql.len()
            val after_rep = trimmed_sql.slice(7, trimmed_len2)
            actual_sql = "INSERT" + after_rep
            is_replace = true
        _param_idx = 0
        val pr = sql_parse(actual_sql)
        if pr.is_err():
            return Err(DbError.QueryFailed(sql: sql, message: "parse error"))
        val stmt = pr.unwrap()
        if stmt.kind == SqlStmtKind.CreateTable:
            return self._do_create(stmt.create_table)
        if stmt.kind == SqlStmtKind.Insert:
            if is_replace:
                return self._do_insert_or_replace(stmt.insert, params)
            return self._do_insert(stmt.insert, params)
        if stmt.kind == SqlStmtKind.Update:
            return self._do_update(stmt.update, params)
        if stmt.kind == SqlStmtKind.Delete:
            return self._do_delete(stmt.delete, params)
        if stmt.kind == SqlStmtKind.Select:
            return Ok(0)
        Err(DbError.QueryFailed(sql: sql, message: "unsupported statement"))

    me exec_sql(sql: text) -> Result<i64, DbError>:
        val stmts = sql.split(";")
        var total: i64 = 0
        var si: i32 = 0
        while si < stmts.len() as i32:
            val s = stmts[si].trim()
            if s != "":
                val r = self.exec(s, [])
                if r.is_err():
                    return r
                total = total + r.unwrap()
            si = si + 1
        Ok(total)

    me query(sql: text, params: [DbValue]) -> Result<[DbRow], DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        # ── SELECT result cache: skip parse+scan for repeated queries ──
        if params.len() == 0:
            _param_idx = 0
            val cpr = sql_parse(sql)
            if cpr.is_err():
                return Err(DbError.QueryFailed(sql: sql, message: "parse error"))
            val cstmt = cpr.unwrap()
            if cstmt.kind == SqlStmtKind.Select:
                val ctable = cstmt.select.from_table
                var cti: i32 = -1
                if self._tbl_name_idx.has(ctable):
                    cti = self._tbl_name_idx[ctable]
                if cti >= 0 and cti < self._sel_cache_key.len() as i32:
                    if self._sel_cache_key[cti] == sql and sql != "":
                        return Ok(self._sel_cache_res[cti])
                val result = self._do_select(cstmt.select, params)
                if result.is_ok() and cti >= 0 and cti < self._sel_cache_key.len() as i32:
                    self._sel_cache_key[cti] = sql
                    self._sel_cache_res[cti] = result.unwrap()
                return result
        _param_idx = 0
        val pr = sql_parse(sql)
        if pr.is_err():
            return Err(DbError.QueryFailed(sql: sql, message: "parse error"))
        val stmt = pr.unwrap()
        if stmt.kind == SqlStmtKind.Select:
            return self._do_select(stmt.select, params)
        Err(DbError.QueryFailed(sql: sql, message: "query() requires SELECT"))

    me query_one(sql: text, params: [DbValue]) -> Result<DbRow?, DbError>:
        val rows = self.query(sql, params)?
        if rows.len() > 0:
            return Ok(Some(rows[0]))
        Ok(nil)

    me query_value(sql: text, params: [DbValue]) -> Result<DbValue?, DbError>:
        val row_opt = self.query_one(sql, params)?
        if val Some(row) = row_opt:
            if row.values.len() > 0:
                return Ok(Some(row.values[0]))
        Ok(nil)

    fn table_exists(name: text) -> bool:
        if not self.is_open:
            return false
        if self._tbl_name_idx.has(name):
            return true
        _find_idx(self._tbl_names, name) >= 0

    fn last_insert_rowid() -> i64:
        self._last_rowid

    fn changes() -> i64:
        self._last_changes

    me _invalidate_fts(ti: i32):
        if ti >= 0 and ti < self._fts_valid.len() as i32:
            self._fts_valid[ti] = false
        if ti >= 0 and ti < self._fts_search_key.len() as i32:
            self._fts_search_key[ti] = ""
            self._fts_search_res[ti] = []
        if ti >= 0 and ti < self._sel_cache_key.len() as i32:
            self._sel_cache_key[ti] = ""
            self._sel_cache_res[ti] = []
        if ti >= 0 and ti < self._scan_cache_key.len() as i32:
            self._scan_cache_key[ti] = ""
            self._scan_cache_res[ti] = []

    me _ensure_fts_index(ti: i32, col_names: [text], selected_cols: [text], visible: [text]):
        if ti < 0 or ti >= self._fts_indexes.len() as i32:
            return
        if self._fts_valid[ti] and _same_text_list(self._fts_columns[ti], selected_cols):
            return
        var engine = FtsEngine.new()
        var doc_ids: [i64] = []
        var ri: i32 = 0
        while ri < visible.len() as i32:
            val row_vals = _deserialize_row(visible[ri])
            val text_value = _row_search_text(row_vals, col_names, selected_cols)
            engine.add_document(ri as i64, text_value)
            doc_ids.push(ri as i64)
            ri = ri + 1
        self._fts_indexes[ti] = engine
        self._fts_valid[ti] = true
        self._fts_columns[ti] = selected_cols
        self._tbl_fts_doc_ids[ti] = doc_ids
        self._tbl_fts_next_doc_id[ti] = visible.len()

    me _ensure_fts_index_typed(ti: i32, col_names: [text], selected_cols: [text], typed_rows: [[DbValue]], visible_indices: [i32]):
        if ti < 0 or ti >= self._fts_indexes.len() as i32:
            return
        if self._fts_valid[ti] and _same_text_list(self._fts_columns[ti], selected_cols):
            return
        var engine = FtsEngine.new()
        var doc_ids: [i64] = []
        var ri: i32 = 0
        while ri < visible_indices.len() as i32:
            val idx = visible_indices[ri]
            val row_vals = typed_rows[idx]
            val text_value = _row_search_text(row_vals, col_names, selected_cols)
            engine.add_document(ri as i64, text_value)
            doc_ids.push(ri as i64)
            ri = ri + 1
        self._fts_indexes[ti] = engine
        self._fts_valid[ti] = true
        self._fts_columns[ti] = selected_cols
        self._tbl_fts_doc_ids[ti] = doc_ids
        self._tbl_fts_next_doc_id[ti] = visible_indices.len()

    me search(table: text, columns: [text], query: text, algorithm: PureSearchAlgorithm, limit: i64) -> Result<[PureSearchResult], DbError>:
        if not self.is_open:
            return Err(DbError.Closed)
        var ti: i32 = -1
        if self._tbl_name_idx.has(table):
            ti = self._tbl_name_idx[table]
        else:
            ti = _find_idx(self._tbl_names, table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "SEARCH",
                message: "no such table: {table}"
            ))
        val terms = _text_tokens(query)
        if terms.len() == 0:
            return Ok([])
        val col_names = self._tbl_cols[ti]
        var results: [PureSearchResult] = []
        # ── Search result cache: return immediately on identical query ──
        val search_cache_key = table + "|" + query + "|" + limit.to_text()
        if ti >= 0 and ti < self._fts_search_key.len() as i32:
            if self._fts_search_key[ti] == search_cache_key and search_cache_key != "":
                self._last_changes = 0
                return Ok(self._fts_search_res[ti])
        # ── BM25 fast path: skip MVCC scan when FTS index is cached ──
        if algorithm == PureSearchAlgorithm.Bm25:
            val fts_cached = self._fts_valid[ti] and _same_text_list(self._fts_columns[ti], columns)
            if not fts_cached:
                # Build FTS index from scratch
                val snap = self._txn.snapshot()
                var tbl = self._tbl_data[ti]
                val typed = self._tbl_typed[ti]
                val use_typed = typed.len() == tbl.tuples.len()
                var rows: [DbRow] = []
                var visible_indices: [i32] = []
                if use_typed:
                    var ri: i32 = 0
                    while ri < tbl.tuples.len() as i32:
                        if mvcc_is_visible(tbl.tuples[ri], snap):
                            val row_vals = typed[ri]
                            rows.push(DbRow(columns: col_names, values: row_vals))
                            visible_indices.push(ri)
                        ri = ri + 1
                    self._ensure_fts_index_typed(ti, col_names, columns, typed, visible_indices)
                else:
                    val visible = tbl.scan(snap)
                    var ri: i32 = 0
                    while ri < visible.len() as i32:
                        val row_vals = _deserialize_row(visible[ri])
                        rows.push(DbRow(columns: col_names, values: row_vals))
                        ri = ri + 1
                    self._ensure_fts_index(ti, col_names, columns, visible)
                self._tbl_data[ti] = tbl
                self._fts_rows[ti] = rows
            val cached_rows = self._fts_rows[ti]
            val engine = self._fts_indexes[ti]
            val fts_results = engine.search(query)
            # Build score map for O(1) lookup instead of O(n*m)
            var score_map: Dict<text, f64> = {}
            var fi: i32 = 0
            while fi < fts_results.len() as i32:
                val fr = fts_results[fi]
                if fr.score > 0:
                    score_map[fr.doc_id.to_text()] = fr.score as f64
                fi = fi + 1
            # Collect matched doc IDs for query_fts_match dispatch
            var matched_ids: [i64] = []
            fi = 0
            while fi < fts_results.len() as i32:
                val row_idx = fts_results[fi].doc_id
                if row_idx >= 0 and row_idx < cached_rows.len():
                    if fts_results[fi].score > 0:
                        matched_ids.push(row_idx)
                fi = fi + 1
            val qr = query_fts_match(matched_ids)
            # Build ranked results using cached rows and score map
            var qi: i32 = 0
            while qi < qr.ids.len() as i32:
                val rid = qr.ids[qi]
                if rid >= 0 and rid < cached_rows.len():
                    var rscore = 1.0
                    val rid_key = rid.to_text()
                    if score_map.has(rid_key):
                        rscore = score_map[rid_key]
                    results = _push_ranked_result(results, PureSearchResult(
                        row: cached_rows[rid as i32],
                        score: rscore,
                        row_index: rid
                    ), limit)
                qi = qi + 1
            self._last_changes = 0
            if ti >= 0 and ti < self._fts_search_key.len() as i32:
                self._fts_search_key[ti] = search_cache_key
                self._fts_search_res[ti] = results
            return Ok(results)
        # ── Non-BM25 fallback: full scan + score ──
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        var docs: [[text]] = []
        var rows: [DbRow] = []
        var total_len: i64 = 0
        if use_typed:
            var ri: i32 = 0
            while ri < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[ri], snap):
                    val row_vals = typed[ri]
                    val text_value = _row_search_text(row_vals, col_names, columns)
                    val tokens = _text_tokens(text_value)
                    total_len = total_len + tokens.len()
                    docs.push(tokens)
                    rows.push(DbRow(columns: col_names, values: row_vals))
                ri = ri + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val row_vals = _deserialize_row(visible[ri])
                val text_value = _row_search_text(row_vals, col_names, columns)
                val tokens = _text_tokens(text_value)
                total_len = total_len + tokens.len()
                docs.push(tokens)
                rows.push(DbRow(columns: col_names, values: row_vals))
                ri = ri + 1
        self._tbl_data[ti] = tbl
        var di: i32 = 0
        while di < docs.len() as i32:
            val score = _search_score(docs, di, terms, algorithm, total_len)
            if score > 0.0:
                results = _push_ranked_result(results, PureSearchResult(
                    row: rows[di],
                    score: score,
                    row_index: di as i64
                ), limit)
            di = di + 1
        self._last_changes = 0
        if ti >= 0 and ti < self._fts_search_key.len() as i32:
            self._fts_search_key[ti] = search_cache_key
            self._fts_search_res[ti] = results
        Ok(results)

    me bm25_search(table: text, columns: [text], query: text, limit: i64) -> Result<[PureSearchResult], DbError>:
        self.search(table, columns, query, PureSearchAlgorithm.Bm25, limit)

    me fts5_search(table: text, columns: [text], query: text, limit: i64) -> Result<[PureSearchResult], DbError>:
        self.search(table, columns, query, PureSearchAlgorithm.Bm25, limit)

    # ── Internal: Transaction control ────────────────────────────────────

    me _snapshot_tables():
        self._snap_tbl_names = []
        self._snap_tbl_cols = []
        self._snap_row_tidx = []
        self._snap_row_data = []
        self._snap_tbl_rowids = []
        self._snap_indexes = []
        self._snap_index_unique = []
        var ti: i32 = 0
        while ti < self._tbl_names.len() as i32:
            self._snap_tbl_names.push(self._tbl_names[ti])
            # Deep copy columns
            var cols_copy: [text] = []
            var ci: i32 = 0
            while ci < self._tbl_cols[ti].len() as i32:
                cols_copy.push(self._tbl_cols[ti][ci])
                ci = ci + 1
            self._snap_tbl_cols.push(cols_copy)
            self._snap_tbl_rowids.push(self._tbl_rowids[ti])
            self._snap_indexes.push(self._indexes[ti])
            self._snap_index_unique.push(self._index_unique[ti])
            # Serialize visible rows for snapshot
            val snap = self._txn.snapshot()
            var tbl = self._tbl_data[ti]
            val visible = tbl.scan(snap)
            self._tbl_data[ti] = tbl
            var ri: i32 = 0
            while ri < visible.len() as i32:
                self._snap_row_tidx.push(ti)
                self._snap_row_data.push(visible[ri])
                ri = ri + 1
            ti = ti + 1

    me _restore_from_snapshot():
        self._tbl_names = []
        self._tbl_cols = []
        self._tbl_data = []
        self._tbl_rowids = []
        self._fts_indexes = []
        self._fts_valid = []
        self._fts_columns = []
        self._fts_rows = []
        self._tbl_vis = []
        self._tbl_vis_xmax = []
        self._fts_search_key = []
        self._fts_search_res = []
        self._sel_cache_key = []
        self._sel_cache_res = []
        self._scan_cache_key = []
        self._scan_cache_res = []
        self._indexes = []
        self._index_unique = []
        var restore_ni: Dict<text, i32> = {}
        var restore_ci: [Dict<text, i32>] = []
        var ti: i32 = 0
        while ti < self._snap_tbl_names.len() as i32:
            self._tbl_names.push(self._snap_tbl_names[ti])
            self._tbl_cols.push(self._snap_tbl_cols[ti])
            self._tbl_data.push(MvccTable.new())
            self._tbl_rowids.push(self._snap_tbl_rowids[ti])
            self._fts_indexes.push(FtsEngine.new())
            self._fts_valid.push(false)
            self._fts_columns.push([])
            self._fts_rows.push([])
            self._tbl_vis.push([])
            self._tbl_vis_xmax.push(-1)
            self._fts_search_key.push("")
            self._fts_search_res.push([])
            self._sel_cache_key.push("")
            self._sel_cache_res.push([])
            self._scan_cache_key.push("")
            self._scan_cache_res.push([])
            self._indexes.push(self._snap_indexes[ti])
            self._index_unique.push(self._snap_index_unique[ti])
            restore_ni[self._snap_tbl_names[ti]] = ti
            restore_ci.push(_build_col_map(self._snap_tbl_cols[ti]))
            ti = ti + 1
        self._tbl_name_idx = restore_ni
        self._tbl_col_idx = restore_ci
        # Re-insert snapshot rows using parallel arrays
        var ri: i32 = 0
        while ri < self._snap_row_tidx.len() as i32:
            val idx = self._snap_row_tidx[ri]
            val row_data = self._snap_row_data[ri]
            if idx >= 0 and idx < self._tbl_data.len() as i32:
                val handle = self._txn.begin()
                val tid = handle.txn_id
                var tbl = self._tbl_data[idx]
                tbl.insert(tid, row_data)
                self._tbl_data[idx] = tbl
                self._txn.commit(tid)
            ri = ri + 1

    me _do_begin() -> Result<i64, DbError>:
        if self._in_transaction:
            return Err(DbError.QueryFailed(sql: "BEGIN", message: "already in transaction"))
        self._snapshot_tables()
        self._in_transaction = true
        self._last_changes = 0
        Ok(0)

    me _do_commit() -> Result<i64, DbError>:
        if not self._in_transaction:
            return Err(DbError.QueryFailed(sql: "COMMIT", message: "no active transaction"))
        self._in_transaction = false
        self._snap_tbl_names = []
        self._snap_tbl_cols = []
        self._snap_row_tidx = []
        self._snap_row_data = []
        self._snap_tbl_rowids = []
        self._snap_indexes = []
        self._snap_index_unique = []
        self._last_changes = 0
        self.checkpoint()?
        Ok(0)

    me _do_rollback() -> Result<i64, DbError>:
        if not self._in_transaction:
            return Err(DbError.QueryFailed(sql: "ROLLBACK", message: "no active transaction"))
        self._restore_from_snapshot()
        self._in_transaction = false
        self._snap_tbl_names = []
        self._snap_tbl_cols = []
        self._snap_row_tidx = []
        self._snap_row_data = []
        self._snap_tbl_rowids = []
        self._snap_indexes = []
        self._snap_index_unique = []
        self._last_changes = 0
        self.checkpoint()?
        Ok(0)

    # ── Internal: ALTER TABLE ADD COLUMN ─────────────────────────────────

    me _do_alter_add_column(table_name: text, col_name: text, col_type: text) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, table_name)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "ALTER TABLE",
                message: "no such table: {table_name}"
            ))
        # Add the new column name
        var cols = self._tbl_cols[ti]
        val new_col_idx = cols.len() as i32
        cols.push(col_name)
        self._tbl_cols[ti] = cols
        # Update column→index cache
        if ti < self._tbl_col_idx.len() as i32:
            var acm = self._tbl_col_idx[ti]
            acm[col_name] = new_col_idx
            self._tbl_col_idx[ti] = acm
        # Rewrite existing rows to append NULL for the new column
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val visible = tbl.scan(snap)
        var new_tbl = MvccTable.new()
        val handle = self._txn.begin()
        val tid = handle.txn_id
        var ri: i32 = 0
        while ri < visible.len() as i32:
            val old_row = visible[ri]
            var new_row = old_row
            if old_row != "":
                new_row = old_row + "\tN:"
            else:
                new_row = "N:"
            new_tbl.insert(tid, new_row)
            ri = ri + 1
        self._tbl_data[ti] = new_tbl
        self._txn.commit(tid)
        self._invalidate_fts(ti)
        self._last_changes = 0
        self._mark_dirty()?
        Ok(0)

    # ── Internal: CREATE INDEX ──────────────────────────────────────────

    me _do_create_index(is_unique: bool, idx_name: text, tbl_name: text, idx_cols: [text]) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, tbl_name)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "CREATE INDEX",
                message: "no such table: {tbl_name}"
            ))
        # Check for duplicate index name across all tables
        var tti: i32 = 0
        while tti < self._indexes.len() as i32:
            val tbl_idxs = self._indexes[tti]
            var ii: i32 = 0
            while ii < tbl_idxs.len() as i32:
                val existing = tbl_idxs[ii]
                if existing.len() > 0:
                    if existing[0] == idx_name:
                        return Err(DbError.QueryFailed(
                            sql: "CREATE INDEX",
                            message: "index already exists: {idx_name}"
                        ))
                ii = ii + 1
            tti = tti + 1
        # Verify columns exist
        val col_names = self._tbl_cols[ti]
        var vi: i32 = 0
        while vi < idx_cols.len() as i32:
            val cidx = _find_idx(col_names, idx_cols[vi])
            if cidx < 0:
                return Err(DbError.QueryFailed(
                    sql: "CREATE INDEX",
                    message: "no such column: {idx_cols[vi]}"
                ))
            vi = vi + 1
        # Build index entry: [idx_name, col1, col2, ...]
        var entry: [text] = []
        entry.push(idx_name)
        var ei: i32 = 0
        while ei < idx_cols.len() as i32:
            entry.push(idx_cols[ei])
            ei = ei + 1
        var tbl_idxs2 = self._indexes[ti]
        tbl_idxs2.push(entry)
        self._indexes[ti] = tbl_idxs2
        var tbl_uniq = self._index_unique[ti]
        tbl_uniq.push(is_unique)
        self._index_unique[ti] = tbl_uniq
        # If unique, validate existing data has no duplicates
        if is_unique:
            val check = self._check_unique_constraint(ti, idx_cols)
            if check.is_err():
                # Rollback: remove the just-added index
                var roll_idxs = self._indexes[ti]
                var new_idxs: [[text]] = []
                var new_uniq: [bool] = []
                var rri: i32 = 0
                while rri < roll_idxs.len() as i32:
                    if rri < roll_idxs.len() as i32 - 1:
                        new_idxs.push(roll_idxs[rri])
                        new_uniq.push(self._index_unique[ti][rri])
                    rri = rri + 1
                self._indexes[ti] = new_idxs
                self._index_unique[ti] = new_uniq
                return check
        self._last_changes = 0
        Ok(0)

    me _do_drop_index(idx_name: text) -> Result<i64, DbError>:
        var found_ti: i32 = -1
        var found_ii: i32 = -1
        var tti: i32 = 0
        while tti < self._indexes.len() as i32:
            val tbl_idxs = self._indexes[tti]
            var ii: i32 = 0
            while ii < tbl_idxs.len() as i32:
                val entry = tbl_idxs[ii]
                if entry.len() > 0:
                    if entry[0] == idx_name:
                        found_ti = tti
                        found_ii = ii
                ii = ii + 1
            tti = tti + 1
        if found_ti < 0:
            return Err(DbError.QueryFailed(
                sql: "DROP INDEX",
                message: "no such index: {idx_name}"
            ))
        # Remove index at found_ii
        val old_idxs = self._indexes[found_ti]
        val old_uniq = self._index_unique[found_ti]
        var new_idxs: [[text]] = []
        var new_uniq: [bool] = []
        var ri: i32 = 0
        while ri < old_idxs.len() as i32:
            if ri != found_ii:
                new_idxs.push(old_idxs[ri])
                new_uniq.push(old_uniq[ri])
            ri = ri + 1
        self._indexes[found_ti] = new_idxs
        self._index_unique[found_ti] = new_uniq
        self._last_changes = 0
        Ok(0)

    me _check_unique_constraint(ti: i32, idx_cols: [text]) -> Result<i64, DbError>:
        val col_names = self._tbl_cols[ti]
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val visible = tbl.scan(snap)
        self._tbl_data[ti] = tbl
        var seen_keys: [text] = []
        var ri: i32 = 0
        while ri < visible.len() as i32:
            val row_vals = _deserialize_row(visible[ri])
            var key = ""
            var ci: i32 = 0
            while ci < idx_cols.len() as i32:
                val cidx = _find_idx(col_names, idx_cols[ci])
                if cidx >= 0 and cidx < row_vals.len() as i32:
                    if ci > 0:
                        key = key + "\x00"
                    key = key + row_vals[cidx].to_text()
                ci = ci + 1
            # Check if key already seen
            var ki: i32 = 0
            while ki < seen_keys.len() as i32:
                if seen_keys[ki] == key:
                    return Err(DbError.QueryFailed(
                        sql: "INSERT",
                        message: "UNIQUE constraint failed"
                    ))
                ki = ki + 1
            seen_keys.push(key)
            ri = ri + 1
        Ok(0)

    me _check_unique_for_insert(ti: i32, row_vals: [DbValue]) -> Result<i64, DbError>:
        val col_names = self._tbl_cols[ti]
        val tbl_idxs = self._indexes[ti]
        val tbl_uniq = self._index_unique[ti]
        var ii: i32 = 0
        while ii < tbl_idxs.len() as i32:
            if tbl_uniq[ii]:
                val entry = tbl_idxs[ii]
                # Build key for the new row
                var new_key = ""
                var ci: i32 = 1
                while ci < entry.len() as i32:
                    val cidx = _find_idx(col_names, entry[ci])
                    if cidx >= 0 and cidx < row_vals.len() as i32:
                        if ci > 1:
                            new_key = new_key + "\x00"
                        new_key = new_key + row_vals[cidx].to_text()
                    ci = ci + 1
                # Check against existing rows (typed fast path)
                val snap = self._txn.snapshot()
                var tbl = self._tbl_data[ti]
                val uq_typed = self._tbl_typed[ti]
                val uq_use_typed = uq_typed.len() == tbl.tuples.len()
                if uq_use_typed:
                    var ui: i32 = 0
                    while ui < tbl.tuples.len() as i32:
                        if mvcc_is_visible(tbl.tuples[ui], snap):
                            val existing = uq_typed[ui]
                            var existing_key = ""
                            var eci: i32 = 1
                            while eci < entry.len() as i32:
                                val ecidx = _find_idx(col_names, entry[eci])
                                if ecidx >= 0 and ecidx < existing.len() as i32:
                                    if eci > 1:
                                        existing_key = existing_key + "\x00"
                                    existing_key = existing_key + existing[ecidx].to_text()
                                eci = eci + 1
                            if existing_key == new_key:
                                self._tbl_data[ti] = tbl
                                return Err(DbError.QueryFailed(
                                    sql: "INSERT",
                                    message: "UNIQUE constraint failed"
                                ))
                        ui = ui + 1
                else:
                    val visible = tbl.scan(snap)
                    var ri: i32 = 0
                    while ri < visible.len() as i32:
                        val existing = _deserialize_row(visible[ri])
                        var existing_key = ""
                        var eci: i32 = 1
                        while eci < entry.len() as i32:
                            val ecidx = _find_idx(col_names, entry[eci])
                            if ecidx >= 0 and ecidx < existing.len() as i32:
                                if eci > 1:
                                    existing_key = existing_key + "\x00"
                                existing_key = existing_key + existing[ecidx].to_text()
                            eci = eci + 1
                        if existing_key == new_key:
                            return Err(DbError.QueryFailed(
                                sql: "INSERT",
                                message: "UNIQUE constraint failed"
                            ))
                        ri = ri + 1
                self._tbl_data[ti] = tbl
            ii = ii + 1
        Ok(0)

    # ── Internal: CREATE TABLE ───────────────────────────────────────────

    me _do_create(ct: SqlCreateTable) -> Result<i64, DbError>:
        val existing = _find_idx(self._tbl_names, ct.table)
        if existing >= 0:
            if ct.if_not_exists:
                return Ok(0)
            return Err(DbError.QueryFailed(
                sql: "CREATE TABLE",
                message: "table already exists: {ct.table}"
            ))
        var col_names: [text] = []
        var ci: i32 = 0
        while ci < ct.columns.len() as i32:
            col_names.push(ct.columns[ci].name)
            ci = ci + 1
        val new_ti = self._tbl_names.len() as i32
        self._tbl_names.push(ct.table)
        self._tbl_cols.push(col_names)
        self._tbl_data.push(MvccTable.new())
        self._tbl_rowids.push(0)
        self._fts_indexes.push(FtsEngine.new())
        self._fts_valid.push(false)
        self._fts_columns.push([])
        self._fts_rows.push([])
        self._tbl_vis.push([])
        self._tbl_vis_xmax.push(-1)
        self._fts_search_key.push("")
        self._fts_search_res.push([])
        self._sel_cache_key.push("")
        self._sel_cache_res.push([])
        self._scan_cache_key.push("")
        self._scan_cache_res.push([])
        self._indexes.push([])
        self._index_unique.push([])
        self._tbl_fts_next_doc_id.push(0)
        self._tbl_fts_doc_ids.push([])
        var empty_typed: [[DbValue]] = []
        self._tbl_typed.push(empty_typed)
        var pk_ci: i32 = -1
        var pki: i32 = 0
        while pki < ct.columns.len() as i32:
            val cdef = ct.columns[pki]
            if cdef.primary_key:
                pk_ci = pki
            pki = pki + 1
        self._tbl_pk_col.push(pk_ci)
        var empty_pk_map: Dict<text, i32> = {}
        self._tbl_pk_map.push(empty_pk_map)
        self._tbl_dirty.push(true)
        # Update name→index cache
        self._tbl_name_idx[ct.table] = new_ti
        # Build column→index cache for new table
        self._tbl_col_idx.push(_build_col_map(col_names))
        self._last_changes = 0
        self._mark_dirty()?
        Ok(0)

    # ── Internal: DROP TABLE ────────────────────────────────────────────

    me _do_drop(table_name: text) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, table_name)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "DROP TABLE",
                message: "no such table: {table_name}"
            ))
        # Rebuild arrays without the dropped table
        var new_names: [text] = []
        var new_cols: [[text]] = []
        var new_data: [MvccTable] = []
        var new_rowids: [i64] = []
        var new_fts_indexes: [FtsEngine] = []
        var new_fts_valid: [bool] = []
        var new_fts_columns: [[text]] = []
        var new_fts_rows: [[DbRow]] = []
        var new_vis: [[bool]] = []
        var new_vis_xmax: [i64] = []
        var new_fts_sk: [text] = []
        var new_fts_sr: [[PureSearchResult]] = []
        var new_sel_ck: [text] = []
        var new_sel_cr: [[DbRow]] = []
        var new_scan_ck: [text] = []
        var new_scan_cr: [[DbRow]] = []
        var new_indexes: [[[text]]] = []
        var new_index_unique: [[bool]] = []
        var i: i32 = 0
        while i < self._tbl_names.len() as i32:
            if i != ti:
                new_names.push(self._tbl_names[i])
                new_cols.push(self._tbl_cols[i])
                new_data.push(self._tbl_data[i])
                new_rowids.push(self._tbl_rowids[i])
                new_fts_indexes.push(self._fts_indexes[i])
                new_fts_valid.push(self._fts_valid[i])
                new_fts_columns.push(self._fts_columns[i])
                new_fts_rows.push(self._fts_rows[i])
                new_vis.push(self._tbl_vis[i])
                new_vis_xmax.push(self._tbl_vis_xmax[i])
                new_fts_sk.push(self._fts_search_key[i])
                new_fts_sr.push(self._fts_search_res[i])
                new_sel_ck.push(self._sel_cache_key[i])
                new_sel_cr.push(self._sel_cache_res[i])
                new_scan_ck.push(self._scan_cache_key[i])
                new_scan_cr.push(self._scan_cache_res[i])
                new_indexes.push(self._indexes[i])
                new_index_unique.push(self._index_unique[i])
            i = i + 1
        self._tbl_names = new_names
        self._tbl_cols = new_cols
        self._tbl_data = new_data
        self._tbl_rowids = new_rowids
        self._fts_indexes = new_fts_indexes
        self._fts_valid = new_fts_valid
        self._fts_columns = new_fts_columns
        self._fts_rows = new_fts_rows
        self._tbl_vis = new_vis
        self._tbl_vis_xmax = new_vis_xmax
        self._fts_search_key = new_fts_sk
        self._fts_search_res = new_fts_sr
        self._sel_cache_key = new_sel_ck
        self._sel_cache_res = new_sel_cr
        self._scan_cache_key = new_scan_ck
        self._scan_cache_res = new_scan_cr
        self._indexes = new_indexes
        self._index_unique = new_index_unique
        # Rebuild typed storage + pk index without the dropped table
        var new_typed: [[[DbValue]]] = []
        var new_pk_col: [i32] = []
        var new_pk_map: [Dict<text, i32>] = []
        var dti: i32 = 0
        while dti < self._tbl_typed.len() as i32:
            if dti != ti:
                new_typed.push(self._tbl_typed[dti])
                new_pk_col.push(self._tbl_pk_col[dti])
                new_pk_map.push(self._tbl_pk_map[dti])
            dti = dti + 1
        self._tbl_typed = new_typed
        self._tbl_pk_col = new_pk_col
        self._tbl_pk_map = new_pk_map
        # Rebuild FTS doc_id arrays without the dropped table
        var new_fts_next_doc_id: [i64] = []
        var new_fts_doc_ids: [[i64]] = []
        var di: i32 = 0
        while di < self._tbl_fts_next_doc_id.len() as i32:
            if di != ti:
                new_fts_next_doc_id.push(self._tbl_fts_next_doc_id[di])
                new_fts_doc_ids.push(self._tbl_fts_doc_ids[di])
            di = di + 1
        self._tbl_fts_next_doc_id = new_fts_next_doc_id
        self._tbl_fts_doc_ids = new_fts_doc_ids
        # Rebuild name→index and column→index caches
        var drop_ni: Dict<text, i32> = {}
        var drop_ci: [Dict<text, i32>] = []
        var dri: i32 = 0
        while dri < self._tbl_names.len() as i32:
            drop_ni[self._tbl_names[dri]] = dri
            drop_ci.push(_build_col_map(self._tbl_cols[dri]))
            dri = dri + 1
        self._tbl_name_idx = drop_ni
        self._tbl_col_idx = drop_ci
        self._last_changes = 0
        self._mark_dirty()?
        Ok(0)

    # ── Internal: INSERT ─────────────────────────────────────────────────

    me _do_insert(ins: SqlInsert, params: [DbValue]) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, ins.table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "INSERT",
                message: "no such table: {ins.table}"
            ))
        val col_names = self._tbl_cols[ti]
        var ins_cols = ins.columns
        if ins_cols.len() == 0:
            ins_cols = col_names
        val handle = self._txn.begin()
        val tid = handle.txn_id
        var inserted: i64 = 0
        var vi: i32 = 0
        while vi < ins.values.len() as i32:
            val vrow = ins.values[vi]
            var row_vals: [DbValue] = []
            var ci: i32 = 0
            while ci < col_names.len() as i32:
                val col = col_names[ci]
                val fi = _find_idx(ins_cols, col)
                if fi >= 0 and fi < vrow.len() as i32:
                    row_vals.push(_expr_to_dbvalue(vrow[fi], params))
                else:
                    row_vals.push(DbValue.Null)
                ci = ci + 1
            # Check UNIQUE constraints before inserting
            val uq_check = self._check_unique_for_insert(ti, row_vals)
            if uq_check.is_err():
                self._txn.commit(tid)
                return uq_check
            # Skip expensive _serialize_row — use unique index placeholder.
            var tbl = self._tbl_data[ti]
            val tuple_pos = tbl.tuples.len() as i32
            tbl.insert(tid, "{tuple_pos}")
            self._tbl_data[ti] = tbl
            var typed = self._tbl_typed[ti]
            typed.push(row_vals)
            self._tbl_typed[ti] = typed
            val pk_ci = self._tbl_pk_col[ti]
            if pk_ci >= 0 and pk_ci < row_vals.len() as i32:
                var pkm = self._tbl_pk_map[ti]
                pkm[row_vals[pk_ci].to_text()] = tuple_pos
                self._tbl_pk_map[ti] = pkm
            self._tbl_rowids[ti] = self._tbl_rowids[ti] + 1
            self._last_rowid = self._tbl_rowids[ti]
            # Incremental FTS: add document if FTS index is built
            if self._fts_valid[ti]:
                val doc_id = self._tbl_fts_next_doc_id[ti]
                self._tbl_fts_next_doc_id[ti] = doc_id + 1
                var doc_ids = self._tbl_fts_doc_ids[ti]
                doc_ids.push(doc_id)
                self._tbl_fts_doc_ids[ti] = doc_ids
                val fts_cols = self._fts_columns[ti]
                val text_value = _row_search_text(row_vals, col_names, fts_cols)
                var eng = self._fts_indexes[ti]
                eng.add_document(doc_id, text_value)
                self._fts_indexes[ti] = eng
                # Keep cached rows in sync
                var fts_r = self._fts_rows[ti]
                fts_r.push(DbRow(columns: col_names, values: row_vals))
                self._fts_rows[ti] = fts_r
            inserted = inserted + 1
            vi = vi + 1
        self._txn.commit(tid)
        self._last_changes = inserted
        self._mark_dirty()?
        Ok(inserted)

    # ── Internal: INSERT OR REPLACE (UPSERT) ──────────────────────────────

    me _do_insert_or_replace(ins: SqlInsert, params: [DbValue]) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, ins.table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "INSERT OR REPLACE",
                message: "no such table: {ins.table}"
            ))
        val col_names = self._tbl_cols[ti]
        var ins_cols = ins.columns
        if ins_cols.len() == 0:
            ins_cols = col_names
        val pk_col_idx: i32 = 0
        val handle = self._txn.begin()
        val tid = handle.txn_id
        var affected: i64 = 0
        var vi: i32 = 0
        while vi < ins.values.len() as i32:
            val vrow = ins.values[vi]
            var row_vals: [DbValue] = []
            var rci: i32 = 0
            while rci < col_names.len() as i32:
                val col = col_names[rci]
                val fi = _find_idx(ins_cols, col)
                if fi >= 0 and fi < vrow.len() as i32:
                    row_vals.push(_expr_to_dbvalue(vrow[fi], params))
                else:
                    row_vals.push(DbValue.Null)
                rci = rci + 1
            val pk_val = row_vals[pk_col_idx]
            val snap = self._txn.snapshot()
            var tbl = self._tbl_data[ti]
            val visible = tbl.scan(snap)
            self._tbl_data[ti] = tbl
            var found_ri: i32 = -1
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val existing = _deserialize_row(visible[ri])
                if existing.len() > pk_col_idx:
                    val existing_pk = existing[pk_col_idx]
                    if _dbval_eq(pk_val, existing_pk):
                        found_ri = ri
                ri = ri + 1
            val ser = _serialize_row(row_vals)
            if found_ri >= 0:
                val old_ser = visible[found_ri]
                var tbl2 = self._tbl_data[ti]
                tbl2.delete_matching(tid, old_ser)
                tbl2.insert(tid, ser)
                self._tbl_data[ti] = tbl2
            else:
                var tbl3 = self._tbl_data[ti]
                tbl3.insert(tid, ser)
                self._tbl_data[ti] = tbl3
                self._tbl_rowids[ti] = self._tbl_rowids[ti] + 1
                self._last_rowid = self._tbl_rowids[ti]
            affected = affected + 1
            vi = vi + 1
        self._txn.commit(tid)
        if affected > 0:
            self._invalidate_fts(ti)
        self._last_changes = affected
        self._mark_dirty()?
        Ok(affected)

    # ── Internal: SELECT ─────────────────────────────────────────────────

    me _do_select(sel: SqlSelect, params: [DbValue]) -> Result<[DbRow], DbError>:
        var ti: i32 = -1
        if self._tbl_name_idx.has(sel.from_table):
            ti = self._tbl_name_idx[sel.from_table]
        else:
            ti = _find_idx(self._tbl_names, sel.from_table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "SELECT",
                message: "no such table: {sel.from_table}"
            ))
        var col_names = self._tbl_cols[ti]
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val col_map = self._tbl_col_idx[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()

        # ── Visibility cache: recompute only when snapshot changes ───
        val n_tuples = tbl.tuples.len() as i32
        var vis = self._tbl_vis[ti]
        if self._tbl_vis_xmax[ti] != snap.xmax or vis.len() != n_tuples as i64:
            var new_vis: [bool] = []
            var vi: i32 = 0
            while vi < n_tuples:
                new_vis.push(mvcc_is_visible(tbl.tuples[vi], snap))
                vi = vi + 1
            self._tbl_vis[ti] = new_vis
            self._tbl_vis_xmax[ti] = snap.xmax
            vis = new_vis

        # ── Hash index fast path for point lookups ───────────────────
        val pk_ci = self._tbl_pk_col[ti]
        val has_join = sel.joins.len() > 0
        var base_rows: [[DbValue]] = []
        var used_pk_path = false
        if use_typed and not has_join and pk_ci >= 0:
            val pk_eq = _extract_pk_eq(sel.where_expr, col_names, pk_ci)
            if pk_eq != "":
                val pkm = self._tbl_pk_map[ti]
                if pkm.has(pk_eq):
                    val tidx = pkm[pk_eq]
                    if tidx >= 0 and tidx < n_tuples:
                        if vis[tidx]:
                            base_rows.push(typed[tidx])
                used_pk_path = true

        # ── Integer range fast path for WHERE col >= L AND col < H ────
        var used_range_path = false
        if not used_pk_path and use_typed and not has_join:
            val rng = _extract_int_range(sel.where_expr, col_map)
            if rng.len() == 5:
                val rng_ci = rng[0] as i32
                val rng_lo = rng[1]
                val rng_hi = rng[2]
                val rng_lo_inc = rng[3] == 1
                val rng_hi_inc = rng[4] == 1
                var ri: i32 = 0
                while ri < n_tuples:
                    if vis[ri]:
                        val rv = typed[ri]
                        if rng_ci < rv.len() as i32:
                            val cv = _dbval_as_i64(rv[rng_ci])
                            var lo_ok = false
                            if rng_lo_inc:
                                lo_ok = cv >= rng_lo
                            else:
                                lo_ok = cv > rng_lo
                            if lo_ok:
                                var hi_ok = false
                                if rng_hi_inc:
                                    hi_ok = cv <= rng_hi
                                else:
                                    hi_ok = cv < rng_hi
                                if hi_ok:
                                    base_rows.push(rv)
                    ri = ri + 1
                used_range_path = true

        # ── Single-bound integer fast path (e.g. score > 150) ────────
        var used_single_bound = false
        if not used_pk_path and not used_range_path and use_typed and not has_join:
            val sb = _extract_single_int_bound(sel.where_expr, col_map)
            if sb.len() == 3:
                val sb_ci = sb[0] as i32
                val sb_val = sb[1]
                val sb_kind = sb[2]
                var ri: i32 = 0
                while ri < n_tuples:
                    if vis[ri]:
                        val rv = typed[ri]
                        if sb_ci < rv.len() as i32:
                            val cv = _dbval_as_i64(rv[sb_ci])
                            var ok = false
                            if sb_kind == 0:
                                ok = cv >= sb_val
                            elif sb_kind == 1:
                                ok = cv > sb_val
                            elif sb_kind == 2:
                                ok = cv <= sb_val
                            elif sb_kind == 3:
                                ok = cv < sb_val
                            elif sb_kind == 4:
                                ok = cv == sb_val
                            if ok:
                                base_rows.push(rv)
                    ri = ri + 1
                used_single_bound = true

        # ── LIKE prefix fast path ────────────────────────────────────
        var used_like_prefix = false
        if not used_pk_path and not used_range_path and not used_single_bound and use_typed and not has_join:
            val like_ci = _extract_like_prefix(sel.where_expr, col_map)
            if like_ci >= 0:
                val like_prefix = _like_prefix_str(sel.where_expr)
                if like_prefix != "":
                    var ri: i32 = 0
                    while ri < n_tuples:
                        if vis[ri]:
                            val rv = typed[ri]
                            if like_ci < rv.len() as i32:
                                val sv = rv[like_ci].to_text()
                                if sv.starts_with(like_prefix):
                                    base_rows.push(rv)
                        ri = ri + 1
                    used_like_prefix = true

        # ── Typed LIKE fast path (any pattern including _ wildcards) ──
        var used_like_typed = false
        if not used_pk_path and not used_range_path and not used_single_bound and not used_like_prefix and use_typed and not has_join:
            val like_col = _extract_like_col(sel.where_expr, col_map)
            if like_col >= 0:
                val like_pat = _extract_like_pattern(sel.where_expr)
                if like_pat != "":
                    val like_pre = _like_any_prefix(sel.where_expr)
                    val has_pre = like_pre != ""
                    var ri: i32 = 0
                    while ri < n_tuples:
                        if vis[ri]:
                            val rv = typed[ri]
                            if like_col < rv.len() as i32:
                                val sv = rv[like_col].to_text()
                                var pre_ok = true
                                if has_pre:
                                    pre_ok = sv.starts_with(like_pre)
                                if pre_ok:
                                    if _like_match(like_pat, sv):
                                        base_rows.push(rv)
                        ri = ri + 1
                    used_like_typed = true

        # ── Full scan path (typed or fallback) ───────────────────────
        if not used_pk_path and not used_range_path and not used_single_bound and not used_like_prefix and not used_like_typed:
            if use_typed:
                var ti2: i32 = 0
                while ti2 < n_tuples:
                    if vis[ti2]:
                        val row_vals = typed[ti2]
                        if has_join or _check_where_fast(sel.where_expr, col_map, row_vals, params):
                            base_rows.push(row_vals)
                    ti2 = ti2 + 1
            else:
                val visible = tbl.scan(snap)
                var ri: i32 = 0
                while ri < visible.len() as i32:
                    val row_vals = _deserialize_row(visible[ri])
                    if has_join or _check_where_fast(sel.where_expr, col_map, row_vals, params):
                        base_rows.push(row_vals)
                    ri = ri + 1
        self._tbl_data[ti] = tbl

        val joins_arr = sel.joins
        if joins_arr.len() > 0:
            var ji: i32 = 0
            while ji < joins_arr.len() as i32:
                val jn = joins_arr[ji]
                val jti = _find_idx(self._tbl_names, jn.table)
                if jti < 0:
                    return Err(DbError.QueryFailed(
                        sql: "SELECT",
                        message: "no such table: {jn.table}"
                    ))
                val jcols = self._tbl_cols[jti]
                val jsnap = self._txn.snapshot()
                var jtbl = self._tbl_data[jti]
                val jvisible = jtbl.scan(jsnap)
                self._tbl_data[jti] = jtbl
                # Build combined columns
                var combined_cols: [text] = []
                var cci: i32 = 0
                while cci < col_names.len() as i32:
                    combined_cols.push(col_names[cci])
                    cci = cci + 1
                var jci: i32 = 0
                while jci < jcols.len() as i32:
                    combined_cols.push(jcols[jci])
                    jci = jci + 1
                # Nested loop join
                var joined_rows: [[DbValue]] = []
                var li: i32 = 0
                while li < base_rows.len() as i32:
                    val left_vals = base_rows[li]
                    var any_match = false
                    var rri: i32 = 0
                    while rri < jvisible.len() as i32:
                        val right_vals = _deserialize_row(jvisible[rri])
                        # Combine values
                        var combo: [DbValue] = []
                        var lci: i32 = 0
                        while lci < left_vals.len() as i32:
                            combo.push(left_vals[lci])
                            lci = lci + 1
                        var rci: i32 = 0
                        while rci < right_vals.len() as i32:
                            combo.push(right_vals[rci])
                            rci = rci + 1
                        # Evaluate ON condition
                        if _check_where(jn.on_expr, combined_cols, combo, params):
                            joined_rows.push(combo)
                            any_match = true
                        rri = rri + 1
                    # LEFT JOIN: emit left row padded with NULLs if no match
                    if not any_match and jn.kind == JoinKind.Left:
                        var null_combo: [DbValue] = []
                        var nli: i32 = 0
                        while nli < left_vals.len() as i32:
                            null_combo.push(left_vals[nli])
                            nli = nli + 1
                        var nri: i32 = 0
                        while nri < jcols.len() as i32:
                            null_combo.push(DbValue.Null)
                            nri = nri + 1
                        joined_rows.push(null_combo)
                    li = li + 1
                base_rows = joined_rows
                col_names = combined_cols
                ji = ji + 1

        # ── Page summary range skip optimization ─────────────────────
        # When a page summary index is available for range predicates,
        # use query_page_summary_scan to skip non-matching pages.
        var page_summary_idx = PageSummaryIndex(pages: [])
        if page_summary_idx.pages.len() > 0 and sel.where_expr.?:
            val ps_result = query_page_summary_scan(page_summary_idx, 0, 0)
            # Future: use ps_result to prune base_rows before linear filter
            val _ps_count = ps_result.count

        # ── WHERE filter ─────────────────────────────────────────────
        var filtered: [[DbValue]] = []
        if has_join:
            var fi: i32 = 0
            while fi < base_rows.len() as i32:
                if _check_where_fast(sel.where_expr, col_map, base_rows[fi], params):
                    filtered.push(base_rows[fi])
                fi = fi + 1
        else:
            filtered = base_rows

        # ── Aggregate / GROUP BY path ────────────────────────────────
        var rows: [DbRow] = []
        if _has_any_agg(sel.columns):
            if sel.group_by.len() > 0:
                # Group rows by key
                var group_keys: [text] = []
                var group_rows: [[[DbValue]]] = []
                var gi: i32 = 0
                while gi < filtered.len() as i32:
                    val gk = _serialize_group_key(sel.group_by, col_names, filtered[gi], params)
                    val gki = _find_idx(group_keys, gk)
                    if gki < 0:
                        group_keys.push(gk)
                        var new_group: [[DbValue]] = []
                        new_group.push(filtered[gi])
                        group_rows.push(new_group)
                    else:
                        var existing = group_rows[gki]
                        existing.push(filtered[gi])
                        group_rows[gki] = existing
                    gi = gi + 1
                # Build one row per group
                var gri: i32 = 0
                while gri < group_keys.len() as i32:
                    val grp = group_rows[gri]
                    val rep = grp[0]
                    var out_cols: [text] = []
                    var out_vals: [DbValue] = []
                    var ci: i32 = 0
                    while ci < sel.columns.len() as i32:
                        val cexpr = sel.columns[ci]
                        if _is_agg_expr(cexpr):
                            out_cols.push(_agg_col_name(cexpr))
                            out_vals.push(_eval_agg_col(cexpr, col_names, grp))
                        else:
                            val inner = _unwrap_as_expr(cexpr)
                            val col_alias = _get_as_alias(cexpr)
                            if inner.kind == SqlExprKind.Column:
                                val idx = _find_idx(col_names, inner.value)
                                if col_alias != "":
                                    out_cols.push(col_alias)
                                else:
                                    out_cols.push(inner.value)
                                if idx >= 0:
                                    out_vals.push(rep[idx])
                                else:
                                    out_vals.push(DbValue.Null)
                            else:
                                if col_alias != "":
                                    out_cols.push(col_alias)
                                else:
                                    out_cols.push(inner.value)
                                out_vals.push(_eval_expr(inner, col_names, rep, params))
                        ci = ci + 1
                    # HAVING filter
                    if _check_where(sel.having, out_cols, out_vals, params):
                        rows.push(DbRow(columns: out_cols, values: out_vals))
                    gri = gri + 1
            else:
                # Aggregate without GROUP BY — single result row
                var out_cols: [text] = []
                var out_vals: [DbValue] = []
                var ci: i32 = 0
                while ci < sel.columns.len() as i32:
                    val cexpr = sel.columns[ci]
                    if _is_agg_expr(cexpr):
                        out_cols.push(_agg_col_name(cexpr))
                        out_vals.push(_eval_agg_col(cexpr, col_names, filtered))
                    else:
                        val inner = _unwrap_as_expr(cexpr)
                        val col_alias = _get_as_alias(cexpr)
                        if col_alias != "":
                            out_cols.push(col_alias)
                        else:
                            out_cols.push(inner.value)
                        if filtered.len() > 0:
                            out_vals.push(_eval_expr(inner, col_names, filtered[0], params))
                        else:
                            out_vals.push(DbValue.Null)
                    ci = ci + 1
                rows.push(DbRow(columns: out_cols, values: out_vals))
        else:
            # Non-aggregate path — project each row
            var pri: i32 = 0
            while pri < filtered.len() as i32:
                val proj = _project_row_fast(sel, col_map, col_names, filtered[pri])
                rows.push(proj)
                pri = pri + 1

        # ── DISTINCT ─────────────────────────────────────────────────
        if sel.distinct:
            var seen: Dict<text, bool> = {}
            var unique: [DbRow] = []
            var di: i32 = 0
            while di < rows.len() as i32:
                val key = _serialize_row(rows[di].values)
                if not seen.contains_key(key):
                    seen[key] = true
                    unique.push(rows[di])
                di = di + 1
            rows = unique

        # ── ORDER BY ─────────────────────────────────────────────────
        if sel.order_by.len() > 0:
            # Insertion sort by order_by keys
            var oi: i32 = 1
            while oi < rows.len() as i32:
                val cur = rows[oi]
                var pos = oi
                var should_move = true
                while pos > 0 and should_move:
                    val prev = rows[pos - 1]
                    # Compare using first order_by key (multi-key: first wins)
                    var cmp_result: i64 = 0
                    var oki: i32 = 0
                    while oki < sel.order_by.len() as i32:
                        val ob = sel.order_by[oki]
                        val cur_key = _eval_expr(ob.expr, cur.columns, cur.values, params)
                        val prev_key = _eval_expr(ob.expr, prev.columns, prev.values, params)
                        val c = _dbval_cmp(cur_key, prev_key)
                        if c != 0:
                            if ob.dir == SqlOrderDir.Desc:
                                cmp_result = 0 - c
                            else:
                                cmp_result = c
                            oki = sel.order_by.len() as i32
                        else:
                            oki = oki + 1
                    if cmp_result < 0:
                        rows[pos] = prev
                        pos = pos - 1
                    else:
                        should_move = false
                rows[pos] = cur
                oi = oi + 1

        # ── LIMIT / OFFSET ───────────────────────────────────────────
        if sel.offset > 0 or sel.limit > 0:
            var limited: [DbRow] = []
            var off = sel.offset
            var lim = sel.limit
            if lim == 0:
                lim = rows.len()
            var lli: i32 = 0
            while lli < rows.len() as i32:
                if lli >= off as i32 and limited.len() < lim:
                    limited.push(rows[lli])
                lli = lli + 1
            rows = limited
        self._last_changes = 0
        Ok(rows)

    # ── Internal: UPDATE ─────────────────────────────────────────────────

    me _do_update(upd: SqlUpdate, params: [DbValue]) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, upd.table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "UPDATE",
                message: "no such table: {upd.table}"
            ))
        val col_names = self._tbl_cols[ti]
        val handle = self._txn.begin()
        val tid = handle.txn_id
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        var updated: i64 = 0
        if use_typed:
            var ui: i32 = 0
            while ui < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[ui], snap):
                    val row_vals = typed[ui]
                    if _check_where(upd.where_expr, col_names, row_vals, params):
                        var new_vals: [DbValue] = []
                        var ci: i32 = 0
                        while ci < col_names.len() as i32:
                            val col = col_names[ci]
                            if upd.assignments.contains_key(col):
                                val aexpr = upd.assignments[col]
                                new_vals.push(_eval_expr(aexpr, col_names, row_vals, params))
                            else:
                                new_vals.push(row_vals[ci])
                            ci = ci + 1
                        val old_data = tbl.tuples[ui].data
                        tbl.delete_matching(tid, old_data)
                        tbl.insert(tid, _serialize_row(new_vals))
                        var typed2 = self._tbl_typed[ti]
                        typed2.push(new_vals)
                        self._tbl_typed[ti] = typed2
                        updated = updated + 1
                ui = ui + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val old_data = visible[ri]
                val row_vals = _deserialize_row(old_data)
                if _check_where(upd.where_expr, col_names, row_vals, params):
                    var new_vals: [DbValue] = []
                    var ci: i32 = 0
                    while ci < col_names.len() as i32:
                        val col = col_names[ci]
                        if upd.assignments.contains_key(col):
                            val aexpr = upd.assignments[col]
                            new_vals.push(_eval_expr(aexpr, col_names, row_vals, params))
                        else:
                            new_vals.push(row_vals[ci])
                        ci = ci + 1
                    tbl.delete_matching(tid, old_data)
                    tbl.insert(tid, _serialize_row(new_vals))
                    updated = updated + 1
                ri = ri + 1
        self._tbl_data[ti] = tbl
        self._txn.commit(tid)
        if updated > 0:
            self._invalidate_fts(ti)
        self._last_changes = updated
        self._mark_dirty()?
        Ok(updated)

    # ── Internal: DELETE ─────────────────────────────────────────────────

    me _do_delete(del: SqlDelete, params: [DbValue]) -> Result<i64, DbError>:
        val ti = _find_idx(self._tbl_names, del.table)
        if ti < 0:
            return Err(DbError.QueryFailed(
                sql: "DELETE",
                message: "no such table: {del.table}"
            ))
        val col_names = self._tbl_cols[ti]
        val handle = self._txn.begin()
        val tid = handle.txn_id
        val snap = self._txn.snapshot()
        var tbl = self._tbl_data[ti]
        val typed = self._tbl_typed[ti]
        val use_typed = typed.len() == tbl.tuples.len()
        var deleted: i64 = 0
        if use_typed:
            var di: i32 = 0
            while di < tbl.tuples.len() as i32:
                if mvcc_is_visible(tbl.tuples[di], snap):
                    val row_vals = typed[di]
                    if _check_where(del.where_expr, col_names, row_vals, params):
                        tbl.delete_matching(tid, tbl.tuples[di].data)
                        deleted = deleted + 1
                di = di + 1
        else:
            val visible = tbl.scan(snap)
            var ri: i32 = 0
            while ri < visible.len() as i32:
                val row_data = visible[ri]
                val row_vals = _deserialize_row(row_data)
                if _check_where(del.where_expr, col_names, row_vals, params):
                    tbl.delete_matching(tid, row_data)
                    deleted = deleted + 1
                ri = ri + 1
        self._tbl_data[ti] = tbl
        self._txn.commit(tid)
        if deleted > 0:
            self._invalidate_fts(ti)
        self._last_changes = deleted
        self._mark_dirty()?
        Ok(deleted)

# ── Column projection ────────────────────────────────────────────────────────

fn _project_row_fast(sel: SqlSelect, cm: Dict<text, i32>, col_names: [text], row_vals: [DbValue]) -> DbRow:
    if sel.columns.len() == 1:
        val first = sel.columns[0]
        if first.kind == SqlExprKind.Star:
            return DbRow(columns: col_names, values: row_vals)
    var proj_cols: [text] = []
    var proj_vals: [DbValue] = []
    var ci: i32 = 0
    while ci < sel.columns.len() as i32:
        val expr = sel.columns[ci]
        val inner = _unwrap_as_expr(expr)
        val col_alias = _get_as_alias(expr)
        if inner.kind == SqlExprKind.Column:
            val idx = _col_idx(cm, inner.value)
            if col_alias != "":
                proj_cols.push(col_alias)
            else:
                proj_cols.push(inner.value)
            if idx >= 0:
                proj_vals.push(row_vals[idx])
            else:
                proj_vals.push(DbValue.Null)
        elif inner.kind == SqlExprKind.Star:
            return DbRow(columns: col_names, values: row_vals)
        else:
            if col_alias != "":
                proj_cols.push(col_alias)
            else:
                proj_cols.push(inner.value)
            proj_vals.push(_eval_expr_fast(inner, cm, row_vals, []))
        ci = ci + 1
    DbRow(columns: proj_cols, values: proj_vals)

fn _project_row(sel: SqlSelect, col_names: [text], row_vals: [DbValue]) -> DbRow:
    if sel.columns.len() == 1:
        val first = sel.columns[0]
        if first.kind == SqlExprKind.Star:
            return DbRow(columns: col_names, values: row_vals)
    var proj_cols: [text] = []
    var proj_vals: [DbValue] = []
    var ci: i32 = 0
    while ci < sel.columns.len() as i32:
        val expr = sel.columns[ci]
        val inner = _unwrap_as_expr(expr)
        val col_alias = _get_as_alias(expr)
        if inner.kind == SqlExprKind.Column:
            val idx = _find_idx(col_names, inner.value)
            if col_alias != "":
                proj_cols.push(col_alias)
            else:
                proj_cols.push(inner.value)
            if idx >= 0:
                proj_vals.push(row_vals[idx])
            else:
                proj_vals.push(DbValue.Null)
        elif inner.kind == SqlExprKind.Star:
            return DbRow(columns: col_names, values: row_vals)
        else:
            if col_alias != "":
                proj_cols.push(col_alias)
            else:
                proj_cols.push(inner.value)
            proj_vals.push(_eval_expr(inner, col_names, row_vals, []))
        ci = ci + 1
    DbRow(columns: proj_cols, values: proj_vals)
