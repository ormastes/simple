# Baremetal Host Communication Library
#
# Unified host ↔ device terminal communication framework.
# Supports SSH, Serial, TRACE32, OpenOCD, STLink, and dedicated UART hardware.

use std.nogc_sync_mut.baremetal.types.{
    TransportKind, CommError, HostCommConfig,
    transport_kind_from_text, transport_kind_to_text,
    comm_error_message, default_hostcomm_config
}
use std.nogc_sync_mut.baremetal.transport
use std.nogc_sync_mut.baremetal.config.{parse_hostcomm_config, parse_hostcomm_config_text}
use std.nogc_sync_mut.baremetal.factory.{
    create_loopback, create_ssh, create_serial, create_serial_ffi,
    create_t32, create_openocd, create_stlink, create_dedicated_hw
}
use std.nogc_sync_mut.baremetal.host_comm.HostComm
use std.nogc_sync_mut.baremetal.terminal.HostTerminal
use std.nogc_sync_mut.baremetal.dap_comm_adapter.DapCommAdapter

# Transport implementations
use std.nogc_sync_mut.baremetal.transport.loopback.LoopbackTransport
use std.nogc_sync_mut.baremetal.transport.ssh.SshTransport
use std.nogc_sync_mut.baremetal.transport.serial.SerialTransport
use std.nogc_sync_mut.baremetal.transport.serial_ffi.SerialFfiTransport
use std.nogc_sync_mut.baremetal.transport.t32_semihost.T32SemihostTransport
use std.nogc_sync_mut.baremetal.transport.openocd_semihost.OpenocdSemihostTransport
use std.nogc_sync_mut.baremetal.transport.stlink.StlinkTransport
use std.nogc_sync_mut.baremetal.transport.dedicated_hw.DedicatedHwTransport
