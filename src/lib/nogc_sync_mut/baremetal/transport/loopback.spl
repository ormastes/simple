# Baremetal Host Communication - Loopback Transport
#
# Echo-back transport for testing. Sends data back to the sender.

# Loopback transport — echoes all sent data back on receive
class LoopbackTransport:
    connected: bool
    buffer: [text]
    send_count: i32

impl LoopbackTransport:
    static fn create() -> LoopbackTransport:
        LoopbackTransport(
            connected: false,
            buffer: [],
            send_count: 0
        )

    fn name() -> text:
        "loopback"

    fn is_connected() -> bool:
        self.connected

    me connect() -> Result<text, text>:
        self.connected = true
        Ok("loopback connected")

    me disconnect() -> Result<text, text>:
        self.connected = false
        self.buffer = []
        self.send_count = 0
        Ok("loopback disconnected")

    me send(data: text) -> Result<i32, text>:
        if not self.connected:
            return Err("not connected")
        self.buffer.push(data)
        self.send_count = self.send_count + 1
        Ok(data.len())

    me receive() -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        if self.buffer.len() == 0:
            return Ok("")
        val data = self.buffer[0]
        self.buffer = self.buffer[1:]
        Ok(data)

    fn receive_timeout(timeout_ms: i64) -> Result<text, text>:
        self.receive()

    me send_command(cmd: text) -> Result<text, text>:
        self.send(cmd)?
        self.receive()

    fn flush() -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        Ok("flushed")

    fn available() -> Result<i32, text>:
        if not self.connected:
            return Err("not connected")
        Ok(self.buffer.len())

    # Test helper: peek at buffer without consuming
    fn peek_buffer() -> [text]:
        self.buffer

    fn total_sent() -> i32:
        self.send_count
