"""
# Redis Session Backend

Session store backed by Redis instead of a local database.
Uses Redis EXPIRE for automatic TTL management.

## Usage

```simple
use std.nogc_sync_mut.web_framework.session_redis.{RedisSessionStore}
use std.nogc_sync_mut.redis.client.{RedisClient}

var client = RedisClient.connect("127.0.0.1", 6379)?
var store = RedisSessionStore(client: client, prefix: "session:", default_ttl: 86400)
val sid = store.set_session("abc123", SessionData(user_id: "u1", values: {}), 3600)?
val data = store.get_session("abc123")?
```
"""

use std.io.types.{IoError, IoErrorKind}
use std.nogc_sync_mut.redis.client.{RedisClient}
use std.nogc_sync_mut.web_framework.session.{generate_session_id, serialize_session_data, deserialize_session_data}

# ============================================================================
# SessionData
# ============================================================================

struct SessionData:
    """Session payload for the Redis backend.

    Holds user identity and arbitrary key-value data.
    """
    user_id: text
    values: Dict<text, text>

# ============================================================================
# RedisSessionStore
# ============================================================================

class RedisSessionStore:
    """Redis-backed session store.

    Each session is stored as a single Redis key with serialized data.
    Redis EXPIRE handles TTL automatically.
    """
    client: RedisClient
    prefix: text
    default_ttl: i64

impl RedisSessionStore:
    fn make_key(sid: text) -> text:
        """Build the full Redis key for a session ID."""
        "{self.prefix}{sid}"

    fn get_session(sid: text) -> Result<Option<SessionData>, IoError>:
        """Retrieve session data by session ID.

        Returns nil if session does not exist or has expired.

        Args:
            sid: Session identifier
        """
        val key = self.make_key(sid)
        val raw = self.client.get(key)?
        if not raw.?:
            return Ok(nil)
        val payload = raw.unwrap()
        val data = decode_session_payload(payload)
        Ok(Some(data))

    fn set_session(sid: text, data: SessionData, ttl: i64) -> Result<(), IoError>:
        """Store session data with TTL.

        Args:
            sid: Session identifier
            data: Session payload
            ttl: Time-to-live in seconds
        """
        val key = self.make_key(sid)
        val payload = encode_session_payload(data)
        val effective_ttl = if ttl > 0: ttl else: self.default_ttl
        self.client.set_ex(key, payload, effective_ttl)

    fn delete_session(sid: text) -> Result<(), IoError>:
        """Delete a session.

        Args:
            sid: Session identifier to remove
        """
        val key = self.make_key(sid)
        self.client.del(key)?
        Ok(())

    me rotate_session(old_sid: text) -> Result<text, IoError>:
        """Rotate a session to a new ID.

        Copies data to a new session, preserves remaining TTL,
        and deletes the old session. Prevents session fixation.

        Args:
            old_sid: Current session ID

        Returns:
            New session ID
        """
        val old_key = self.make_key(old_sid)
        val raw = self.client.get(old_key)?
        if not raw.?:
            return Err(IoError(kind: IoErrorKind.Other, message: "session not found: {old_sid}", source: nil))
        val payload = raw.unwrap()

        val remaining = self.client.ttl(old_key)?
        val effective_ttl = if remaining > 0: remaining else: self.default_ttl

        val new_sid = generate_session_id()
        val new_key = self.make_key(new_sid)
        self.client.set_ex(new_key, payload, effective_ttl)?
        self.client.del(old_key)?
        Ok(new_sid)

    fn session_ttl(sid: text) -> Result<i64, IoError>:
        """Get remaining TTL of a session in seconds.

        Args:
            sid: Session identifier

        Returns:
            TTL in seconds, -1 if no expiry, -2 if missing
        """
        val key = self.make_key(sid)
        self.client.ttl(key)

    fn session_active(sid: text) -> Result<bool, IoError>:
        """Check whether a session exists.

        Args:
            sid: Session identifier
        """
        val key = self.make_key(sid)
        self.client.key_exists(key)

    fn touch_session(sid: text, ttl: i64) -> Result<bool, IoError>:
        """Extend a session's TTL.

        Args:
            sid: Session identifier
            ttl: New TTL in seconds

        Returns:
            true if session existed and was updated
        """
        val key = self.make_key(sid)
        self.client.expire(key, ttl)

# ============================================================================
# Payload Encoding
# ============================================================================

fn encode_session_payload(data: SessionData) -> text:
    """Encode SessionData as a storable string.

    Format: user_id + TAB + serialized key-value pairs.
    """
    val kv = serialize_session_data(data.values)
    "{data.user_id}\t{kv}"

fn decode_session_payload(payload: text) -> SessionData:
    """Decode a stored payload back to SessionData."""
    val tab_pos = payload.index_of("\t")
    if tab_pos < 0:
        return SessionData(user_id: payload, values: {})
    val user_id = payload[0:tab_pos]
    val kv_str = payload[tab_pos + 1:]
    val values = deserialize_session_data(kv_str)
    SessionData(user_id: user_id, values: values)
