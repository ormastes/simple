"""
# Asset Pipeline

Fingerprinted asset serving for cache busting. Maps original
asset paths to fingerprinted versions using content hashing.

## Usage

```simple
var pipeline = AssetPipeline(
    root: "public",
    fingerprint: true,
    manifest: {}
)
pipeline.build()?

val url = pipeline.resolve("/css/app.css")
# Returns: "/css/app-a1b2c3d4.css"

val tag = pipeline.asset_path("/js/app.js")
# Returns: "/assets/js/app-e5f6g7h8.js"
```
"""

# ============================================================================
# Asset Pipeline
# ============================================================================

class AssetPipeline:
    """Fingerprinted asset serving and manifest management.

    Scans a root directory, computes content hashes for each file,
    and maintains a manifest mapping original paths to fingerprinted
    paths for cache busting.
    """
    root: text
    fingerprint: bool
    manifest: Dict<text, text>

impl AssetPipeline:
    static fn new(root: text, fingerprint: bool) -> AssetPipeline:
        """Create a new asset pipeline.

        Args:
            root: Root directory for static assets
            fingerprint: Whether to fingerprint asset URLs

        Returns:
            AssetPipeline instance
        """
        AssetPipeline(root: root, fingerprint: fingerprint, manifest: {})

    me build() -> Result<(), text>:
        """Build the asset manifest by scanning the root directory.

        Reads all files, computes hashes, and populates the manifest.

        Returns:
            Ok(()) on success
        """
        if not self.fingerprint:
            return Ok(())

        # In a full implementation, this would recursively scan
        # the root directory and compute content hashes.
        # For now, we initialize with an empty manifest that
        # can be populated via add_asset().
        Ok(())

    me add_asset(original_path: text, content: text) -> AssetPipeline:
        """Manually register an asset with its content for fingerprinting.

        Computes a hash of the content and stores the mapping.

        Args:
            original_path: Original asset path (e.g., "/css/app.css")
            content: File content for hashing

        Returns:
            Self for chaining
        """
        if not self.fingerprint:
            self.manifest[original_path] = original_path
            return self

        val hash = simple_hash(content)
        val fingerprinted = insert_fingerprint(original_path, hash)
        self.manifest[original_path] = fingerprinted
        self

    fn resolve(path: text) -> text:
        """Resolve an original asset path to its fingerprinted version.

        If fingerprinting is disabled or the asset is not in the manifest,
        returns the original path.

        Args:
            path: Original asset path

        Returns:
            Fingerprinted path or original path
        """
        if not self.fingerprint:
            return path

        val fingerprinted = self.manifest.get(path)
        if fingerprinted != nil:
            return fingerprinted ?? path
        path

    fn asset_path(path: text) -> text:
        """Get the full asset URL path for use in templates.

        Prepends "/assets" prefix and resolves fingerprint.

        Args:
            path: Asset path relative to root

        Returns:
            Full URL path for the asset
        """
        val resolved = self.resolve(path)
        if resolved.starts_with("/"):
            return "/assets{resolved}"
        "/assets/{resolved}"

    fn asset_tag_css(path: text) -> text:
        """Generate an HTML link tag for a CSS asset.

        Args:
            path: CSS file path

        Returns:
            HTML link element
        """
        val url = self.asset_path(path)
        "<link rel=\"stylesheet\" href=\"{url}\">"

    fn asset_tag_js(path: text) -> text:
        """Generate an HTML script tag for a JS asset.

        Args:
            path: JS file path

        Returns:
            HTML script element
        """
        val url = self.asset_path(path)
        "<script src=\"{url}\"></script>"

    fn asset_tag_img(path: text, alt: text) -> text:
        """Generate an HTML img tag for an image asset.

        Args:
            path: Image file path
            alt: Alt text

        Returns:
            HTML img element
        """
        val url = self.asset_path(path)
        "<img src=\"{url}\" alt=\"{alt}\">"

# ============================================================================
# Fingerprinting Helpers
# ============================================================================

fn simple_hash(content: text) -> text:
    """Compute a simple 8-character hash of content.

    Uses a basic hash function. In production, use SHA-256.

    Args:
        content: Content to hash

    Returns:
        8-character hex hash
    """
    var hash: i64 = 5381
    var i = 0
    while i < content.len():
        val c = content[i:i + 1]
        val code = char_code_safe(c)
        hash = ((hash * 33) + code) % 0xFFFFFFFF
        i = i + 1

    # Convert to 8-char hex
    var result: [text] = []
    var n = hash
    if n < 0:
        n = -n
    var j = 0
    while j < 8:
        val digit = n % 16
        n = n / 16
        if digit < 10:
            result.push("{digit}")
        else:
            match digit:
                10: result.push("a")
                11: result.push("b")
                12: result.push("c")
                13: result.push("d")
                14: result.push("e")
                _: result.push("f")
        j = j + 1

    # Reverse since we built it backwards
    var hex = ""
    var k = result.len() - 1
    while k >= 0:
        hex = hex + result[k]
        k = k - 1
    hex

fn insert_fingerprint(path: text, hash: text) -> text:
    """Insert a fingerprint hash into a file path before the extension.

    e.g., "/css/app.css" + "a1b2c3d4" -> "/css/app-a1b2c3d4.css"

    Args:
        path: Original file path
        hash: Hash to insert

    Returns:
        Path with fingerprint inserted
    """
    val dot_pos = path.last_index_of(".")
    if dot_pos < 0:
        return "{path}-{hash}"

    val base = path[0:dot_pos]
    val ext = path[dot_pos:]
    "{base}-{hash}{ext}"

fn char_code_safe(c: text) -> i64:
    """Get character code, returning 0 for empty strings."""
    if c.len() == 0:
        return 0
    val code = c[0:1]
    # Simple ASCII approximation
    var result = 0
    var i = 0
    while i < c.len() and i < 1:
        result = char_code(c)
        i = i + 1
    result

extern fn char_code(c: text) -> i64
