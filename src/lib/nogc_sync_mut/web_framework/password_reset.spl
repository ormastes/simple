"""
# Password Reset Service

Token-based password reset flow using HMAC-signed tokens and bcrypt
for password hashing. Tokens carry a user_id, creation timestamp, and
random bytes, signed with HMAC-SHA256.

## Token Format

    base64url(user_id|timestamp|random_hex) + "." + base64url(hmac_signature)

The `|` delimiter inside the payload is escaped: any literal `|` in
user_id is replaced with `%7C` before encoding.

## Usage

```simple
val svc = PasswordResetService.new("my-hmac-secret", 3600)

# Generate a reset token
val token_result = svc.generate_token("user_42")
match token_result:
    Ok(token_str): send_email(user_email, token_str)
    Err(e): print "Failed: {e}"

# Verify a token from the reset link
val verify_result = svc.verify_token(token_str)
match verify_result:
    Ok(reset_token):
        print "Reset for user: {reset_token.user_id}"
    Err(e):
        print "Invalid token: {e}"

# Hash and verify passwords
val hash = svc.hash_password("new_password")?
val ok = svc.verify_password("new_password", hash)?
```
"""

use std.crypto.hmac.{hmac_sha256}
use std.common.bcrypt.hash.{bcrypt_hash, bcrypt_hash_default}
use std.common.bcrypt.verify.{bcrypt_verify}
use std.common.bcrypt.salt.{generate_random_bytes}
use std.common.jwt.claims.{current_timestamp}
use std.crypto.types.{text_to_bytes}

# ============================================================================
# Reset Token Struct
# ============================================================================

struct ResetToken:
    """Parsed and verified password-reset token."""
    token: text
    user_id: text
    created_at: i64
    expires_at: i64

# ============================================================================
# Password Reset Service
# ============================================================================

class PasswordResetService:
    """Stateless password-reset token generator and verifier.

    Tokens are HMAC-SHA256 signed. Passwords are hashed with bcrypt.

    NOTE: The random bytes use a simplified PRNG from bcrypt.salt.
    For production, replace generate_random_bytes with a CSPRNG source
    (e.g., std.nogc_sync_mut.io.crypto_sffi.random_bytes).
    """
    secret_key: text
    token_ttl_seconds: i64

    static fn new(secret_key: text, token_ttl_seconds: i64) -> PasswordResetService:
        """Create a new PasswordResetService.

        Args:
            secret_key: HMAC signing key for tokens
            token_ttl_seconds: Token lifetime in seconds (default: 3600 = 1 hour)
        """
        PasswordResetService(secret_key: secret_key, token_ttl_seconds: token_ttl_seconds)

impl PasswordResetService:

    me generate_token(user_id: text) -> Result<text, text>:
        """Generate a signed password-reset token for a user.

        Args:
            user_id: The user identifier to embed in the token

        Returns:
            Ok(token_string) in format payload_b64.signature_b64
            Err(reason) on failure
        """
        if user_id.len() == 0:
            return Err("user_id must not be empty")

        val now = current_timestamp()

        # Generate 16 random bytes and hex-encode them
        val rand_bytes = generate_random_bytes(16)
        val random_hex = bytes_to_hex_local(rand_bytes)

        # Escape pipe in user_id to avoid delimiter collision
        val safe_uid = escape_pipe(user_id)

        # Build payload: user_id|timestamp|random_hex
        val payload_raw = safe_uid + "|" + i64_to_text(now) + "|" + random_hex

        # Base64url-encode the payload
        val payload_bytes = text_to_bytes(payload_raw)
        val payload_b64 = base64url_encode_list(payload_bytes)

        # HMAC-sign the payload
        val sig_bytes = hmac_sha256(self.secret_key, payload_b64)
        val sig_b64 = base64url_encode_list(sig_bytes)

        Ok(payload_b64 + "." + sig_b64)

    me verify_token(token_string: text) -> Result<ResetToken, text>:
        """Verify and decode a password-reset token.

        Checks HMAC signature and expiration.

        Args:
            token_string: The full token string (payload.signature)

        Returns:
            Ok(ResetToken) if valid and not expired
            Err(reason) otherwise
        """
        val dot_pos = token_string.index_of(".")
        if dot_pos < 0:
            return Err("Invalid token format: missing separator")

        val payload_b64 = token_string[0:dot_pos]
        val sig_b64 = token_string[dot_pos + 1:]

        if payload_b64.len() == 0 or sig_b64.len() == 0:
            return Err("Invalid token format: empty payload or signature")

        # Verify HMAC signature
        val expected_sig_bytes = hmac_sha256(self.secret_key, payload_b64)
        val expected_sig_b64 = base64url_encode_list(expected_sig_bytes)
        if sig_b64 != expected_sig_b64:
            return Err("Invalid token signature")

        # Decode payload
        val payload_raw = base64url_decode_to_text(payload_b64)
        val parts = payload_raw.split("|")
        if parts.len() < 3:
            return Err("Invalid token payload: expected user_id|timestamp|random")

        val raw_uid = parts[0]
        val timestamp_str = parts[1]

        # Unescape pipe in user_id
        val user_id = unescape_pipe(raw_uid)

        val created_at = parse_i64_local(timestamp_str)
        if created_at == 0:
            return Err("Invalid token: bad timestamp")

        val expires_at = created_at + self.token_ttl_seconds

        # Check expiration
        val now = current_timestamp()
        if now > expires_at:
            return Err("Token has expired")

        Ok(ResetToken(
            token: token_string,
            user_id: user_id,
            created_at: created_at,
            expires_at: expires_at
        ))

    me hash_password(password: text) -> Result<text, text>:
        """Hash a password using bcrypt with default cost.

        Args:
            password: The plaintext password

        Returns:
            Ok(bcrypt_hash_string)
        """
        if password.len() == 0:
            return Err("Password must not be empty")
        val hashed = bcrypt_hash_default(password)
        Ok(hashed)

    me verify_password(password: text, hash_str: text) -> Result<bool, text>:
        """Verify a password against a bcrypt hash.

        Args:
            password: The plaintext password to check
            hash_str: The stored bcrypt hash string

        Returns:
            Ok(true) if password matches, Ok(false) if not
        """
        if password.len() == 0:
            return Err("Password must not be empty")
        if hash_str.len() == 0:
            return Err("Hash must not be empty")
        val matched = bcrypt_verify(password, hash_str)
        Ok(matched)

# ============================================================================
# Internal Helpers
# ============================================================================

fn escape_pipe(s: text) -> text:
    """Replace literal | with %7C."""
    s.replace("|", "%7C")

fn unescape_pipe(s: text) -> text:
    """Replace %7C back to |."""
    s.replace("%7C", "|")

fn i64_to_text(n: i64) -> text:
    """Convert i64 to decimal text."""
    if n == 0:
        return "0"
    var result: [text] = []
    var remaining = n
    var is_neg = false
    if remaining < 0:
        is_neg = true
        remaining = 0 - remaining
    while remaining > 0:
        val digit = remaining % 10
        result.push(digit_char(digit))
        remaining = remaining / 10
    if is_neg:
        result.push("-")
    # Reverse
    var reversed: [text] = []
    var i = result.len() - 1
    while i >= 0:
        reversed.push(result[i])
        i = i - 1
    reversed.join("")

fn parse_i64_local(s: text) -> i64:
    """Parse decimal string to i64. Returns 0 on invalid input."""
    var result: i64 = 0
    var i = 0
    while i < s.len():
        val c = s[i:i + 1]
        val d = char_to_digit(c)
        if d < 0:
            return 0
        result = result * 10 + d
        i = i + 1
    result

fn digit_char(d: i64) -> text:
    """Single digit to character."""
    if d == 0: return "0"
    if d == 1: return "1"
    if d == 2: return "2"
    if d == 3: return "3"
    if d == 4: return "4"
    if d == 5: return "5"
    if d == 6: return "6"
    if d == 7: return "7"
    if d == 8: return "8"
    if d == 9: return "9"
    "0"

fn char_to_digit(c: text) -> i64:
    """Character to digit value, or -1."""
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    -1

fn bytes_to_hex_local(bytes: list) -> text:
    """Convert byte list to hex string."""
    val hex_chars = "0123456789abcdef"
    var result: [text] = []
    var i = 0
    while i < bytes.len():
        val b = bytes[i]
        val hi = (b >> 4) & 0x0F
        val lo = b & 0x0F
        result.push(hex_chars[hi:hi + 1])
        result.push(hex_chars[lo:lo + 1])
        i = i + 1
    result.join("")

fn base64url_encode_list(bytes: list) -> text:
    """Base64url-encode a byte list (no padding)."""
    val chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
    var result: [text] = []
    var i = 0
    while i < bytes.len():
        val b0 = bytes[i]
        val b1 = if i + 1 < bytes.len(): bytes[i + 1] else: 0
        val b2 = if i + 2 < bytes.len(): bytes[i + 2] else: 0

        result.push(chars[(b0 >> 2) % 64:(b0 >> 2) % 64 + 1])
        result.push(chars[((b0 & 3) * 16 + (b1 >> 4)) % 64:((b0 & 3) * 16 + (b1 >> 4)) % 64 + 1])

        if i + 1 < bytes.len():
            result.push(chars[((b1 & 15) * 4 + (b2 >> 6)) % 64:((b1 & 15) * 4 + (b2 >> 6)) % 64 + 1])

        if i + 2 < bytes.len():
            result.push(chars[(b2 & 63) % 64:(b2 & 63) % 64 + 1])

        i = i + 3
    result.join("")

fn base64url_decode_to_text(s: text) -> text:
    """Base64url-decode to text string."""
    val chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
    var bytes: [i64] = []
    var buffer = 0
    var bits = 0
    var i = 0
    while i < s.len():
        val c = s[i:i + 1]
        val idx = chars.index_of(c)
        if idx >= 0:
            buffer = (buffer * 64) + idx
            bits = bits + 6
            if bits >= 8:
                bits = bits - 8
                val byte_val = (buffer >> bits) & 0xFF
                bytes.push(byte_val)
                buffer = buffer & ((1 << bits) - 1)
        i = i + 1
    var result: [text] = []
    var j = 0
    while j < bytes.len():
        result.push(char_from_code(bytes[j]))
        j = j + 1
    result.join("")

extern fn char_from_code(code: i64) -> text
