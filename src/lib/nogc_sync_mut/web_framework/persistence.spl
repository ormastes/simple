#![allow(unnamed_duplicate_typed_args)]
# Backend-neutral record storage for the Simple web framework.

use std.database.core.{SdnDatabase, SdnTable, SdnRow, load_sdn_database, new_sdn_database}
use std.database.sql.repository.{Repository}
class SimpleDbRecordAdapter<T>:
    table_name: text
    columns: [text]
    to_row_fn: fn(i64, T) -> SdnRow
    from_row_fn: fn(SdnRow) -> Result<T, text>
    field_text_fn: fn(T, text) -> text

class WebRecordStore<T>:
    backend_kind: text
    sql_repo: Repository<T>?
    simple_db: SdnDatabase?
    adapter: SimpleDbRecordAdapter<T>

impl WebRecordStore<T>:
    static fn sql(repo: Repository<T>, adapter: SimpleDbRecordAdapter<T>) -> WebRecordStore<T>:
        WebRecordStore(
            backend_kind: "sqlite",
            sql_repo: Some(repo),
            simple_db: nil,
            adapter: adapter
        )

    static fn simpledb(db: SdnDatabase, adapter: SimpleDbRecordAdapter<T>) -> WebRecordStore<T>:
        WebRecordStore(
            backend_kind: "simpledb",
            sql_repo: nil,
            simple_db: Some(db),
            adapter: adapter
        )

    me create_table() -> Result<(), text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.create_table()
                match result:
                    Ok(_): return Ok(())
                    Err(_e): return Err("Failed to create SQL table")
            return Err("SQL repository is not configured")
        self.ensure_simple_table()

    me insert(entity: T) -> Result<i64, text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.insert(entity)
                match result:
                    Ok(id): return Ok(id)
                    Err(_e): return Err("Failed to insert record")
            return Err("SQL repository is not configured")

        var db = self.fresh_simple_db()?
        var table = self.load_or_create_table(db)
        val next_id = self.next_simple_id(table)
        val to_row = self.adapter.to_row_fn
        val row = to_row(next_id, entity)
        table.add_row(row)
        db.set_table(self.adapter.table_name, table)
        if not db.save():
            return Err("Failed to save Simple DB record")
        self.simple_db = Some(db)
        Ok(next_id)

    me update(id: i64, entity: T) -> Result<i64, text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.update(id, entity)
                match result:
                    Ok(changed): return Ok(changed)
                    Err(_e): return Err("Failed to update record")
            return Err("SQL repository is not configured")

        var db = self.fresh_simple_db()?
        var table = self.load_or_create_table(db)
        val key = "{id}"
        if not table.index.has(key):
            return Ok(0)
        val to_row = self.adapter.to_row_fn
        val row = to_row(id, entity)
        table.update_row(key, row)
        db.set_table(self.adapter.table_name, table)
        if not db.save():
            return Err("Failed to save Simple DB update")
        self.simple_db = Some(db)
        Ok(1)

    me delete_by_id(id: i64) -> Result<i64, text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.delete_by_id(id)
                match result:
                    Ok(changed): return Ok(changed)
                    Err(_e): return Err("Failed to delete record")
            return Err("SQL repository is not configured")

        var db = self.fresh_simple_db()?
        var table = self.load_or_create_table(db)
        val key = "{id}"
        if not table.index.has(key):
            return Ok(0)
        table.mark_deleted(key)
        db.set_table(self.adapter.table_name, table)
        if not db.save():
            return Err("Failed to save Simple DB delete")
        self.simple_db = Some(db)
        Ok(1)

    fn find_by_id(id: i64) -> Result<T?, text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.find_by_id(id)
                match result:
                    Ok(found): return Ok(found)
                    Err(_e): return Err("Failed to find record")
            return Err("SQL repository is not configured")

        val db = self.fresh_simple_db()?
        val table = self.lookup_table(db)
        if not table.?:
            return Ok(nil)
        val key = "{id}"
        val row = table.unwrap().get_row(key)
        if not row.?:
            return Ok(nil)
        val candidate = row.unwrap()
        if candidate.get("valid") == Some("false"):
            return Ok(nil)
        val from_row = self.adapter.from_row_fn
        val entity = from_row(candidate)?
        Ok(Some(entity))

    fn find_all() -> Result<[T], text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.find_all()
                match result:
                    Ok(items): return Ok(items)
                    Err(_e): return Err("Failed to load records")
            return Err("SQL repository is not configured")

        val db = self.fresh_simple_db()?
        val table = self.lookup_table(db)
        if not table.?:
            return Ok([])
        self.decode_valid_rows(table.unwrap().valid_rows())

    fn count() -> Result<i64, text>:
        if self.backend_kind == "sqlite":
            if val Some(repo) = self.sql_repo:
                val result = repo.count()
                match result:
                    Ok(count): return Ok(count)
                    Err(_e): return Err("Failed to count records")
            return Err("SQL repository is not configured")
        val rows = self.find_all()?
        Ok(rows.len())

    fn find_by_field_equals(field: text, expected: text) -> Result<[T], text>:
        val all = self.find_all()?
        var matches: [T] = []
        for entity in all:
            val field_text = self.adapter.field_text_fn
            if field_text(entity, field) == expected:
                matches.push(entity)
        Ok(matches)

    fn find_by_field_contains(field: text, needle: text) -> Result<[T], text>:
        val all = self.find_all()?
        val folded = needle.lower()
        var matches: [T] = []
        for entity in all:
            val field_text = self.adapter.field_text_fn
            if field_text(entity, field).lower().contains(folded):
                matches.push(entity)
        Ok(matches)

    me reload_simple_db(path: text) -> Result<(), text>:
        if self.backend_kind != "simpledb":
            return Ok(())
        val loaded = load_sdn_database(path)
        if loaded.?:
            self.simple_db = loaded
            return Ok(())
        self.simple_db = Some(new_sdn_database(path))
        Ok(())

    fn simple_db_path() -> text:
        if val Some(db) = self.simple_db:
            return db.path
        ""

    me ensure_simple_table() -> Result<(), text>:
        var db = self.fresh_simple_db()?
        val table = self.load_or_create_table(db)
        db.set_table(self.adapter.table_name, table)
        if not db.save():
            return Err("Failed to save Simple DB schema")
        self.simple_db = Some(db)
        Ok(())

    fn require_simple_db() -> Result<SdnDatabase, text>:
        if val Some(db) = self.simple_db:
            return Ok(db)
        Err("Simple DB is not configured")

    me fresh_simple_db() -> Result<SdnDatabase, text>:
        self.reload_simple_db(self.simple_db_path())?
        self.require_simple_db()

    fn lookup_table(db: SdnDatabase) -> SdnTable?:
        db.get_table(self.adapter.table_name)

    fn load_or_create_table(db: SdnDatabase) -> SdnTable:
        if val Some(table) = db.get_table(self.adapter.table_name):
            return table
        var columns: [text] = ["id", "valid"]
        for col in self.adapter.columns:
            columns.push(col)
        SdnTable.new(self.adapter.table_name, columns)

    fn next_simple_id(table: SdnTable) -> i64:
        var max_id = 0
        for row in table.rows:
            if val Some(id_text) = row.get("id"):
                val id = id_text.to_int() ?? 0
                if id > max_id:
                    max_id = id
        max_id + 1

    fn decode_valid_rows(rows: [SdnRow]) -> Result<[T], text>:
        var result: [T] = []
        for row in rows:
            if row.get("valid") == Some("false"):
                continue
            val from_row = self.adapter.from_row_fn
            val entity = from_row(row)?
            result.push(entity)
        Ok(result)
