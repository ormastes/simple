"""
Pagination

Provides Paginator (offset/limit calculator) and PagedResult<T>
(page of items + metadata). Includes paginator_to_html for
rendering standard prev/next HTML navigation.

Usage:
    val paginator = Paginator.new(page, per_page, total)
    val offset = paginator.offset()
    val html = paginator_to_html(paginator, "/packages?page=")
"""

# ============================================================================
# Paginator
# ============================================================================

class Paginator:
    """Offset/limit calculator for database queries."""
    current_page: i64
    per_page: i64
    total_items: i64

impl Paginator:
    static fn new(page: i64, per_page: i64, total: i64) -> Paginator:
        """Create a Paginator.

        Args:
            page:      1-based current page number (clamped to >= 1)
            per_page:  Items per page (clamped to >= 1)
            total:     Total item count
        """
        val safe_page = if page < 1: 1 else: page
        val safe_per = if per_page < 1: 1 else: per_page
        val safe_total = if total < 0: 0 else: total
        Paginator(current_page: safe_page, per_page: safe_per, total_items: safe_total)

    fn offset() -> i64:
        """SQL OFFSET value for the current page."""
        (self.current_page - 1) * self.per_page

    fn limit() -> i64:
        """SQL LIMIT value (same as per_page)."""
        self.per_page

    fn page_count() -> i64:
        """Total number of pages."""
        if self.total_items == 0:
            return 1
        val full = self.total_items / self.per_page
        val rem = self.total_items % self.per_page
        if rem > 0: full + 1 else: full

    fn has_prev() -> bool:
        """True if there is a page before the current one."""
        self.current_page > 1

    fn has_next() -> bool:
        """True if there is a page after the current one."""
        self.current_page < self.page_count()

    fn prev_page() -> i64:
        """Previous page number (1 if already on page 1)."""
        if self.current_page > 1: self.current_page - 1 else: 1

    fn next_page() -> i64:
        """Next page number (page_count if on last page)."""
        val pc = self.page_count()
        if self.current_page < pc: self.current_page + 1 else: pc

# ============================================================================
# PagedResult
# ============================================================================

class PagedResult<T>:
    """A single page of results plus pagination metadata."""
    items: [T]
    paginator: Paginator

impl PagedResult<T>:
    static fn new(items: [T], paginator: Paginator) -> PagedResult<T>:
        """Wrap a list of items with its paginator."""
        PagedResult(items: items, paginator: paginator)

    fn total_items() -> i64:
        self.paginator.total_items

    fn current_page() -> i64:
        self.paginator.current_page

    fn page_count() -> i64:
        self.paginator.page_count()

# ============================================================================
# HTML rendering
# ============================================================================

fn paginator_to_html(paginator: Paginator, base_url: text) -> text:
    """Render a simple prev/next/numbered pagination widget as HTML.

    Args:
        paginator: Paginator instance
        base_url:  URL prefix to which the page number is appended,
                   e.g. "/packages?page="
    """
    val page_count = paginator.page_count()
    if page_count <= 1:
        return ""

    var parts: [text] = []
    parts.push("<nav class=\"pagination\">")

    if paginator.has_prev():
        val prev = paginator.prev_page()
        parts.push("<a href=\"{base_url}{prev}\" class=\"prev\">&laquo; Prev</a>")
    else:
        parts.push("<span class=\"prev disabled\">&laquo; Prev</span>")

    # Page number links — show up to 7 pages around the current page
    val window = 3
    var start = paginator.current_page - window
    if start < 1:
        start = 1
    var end = paginator.current_page + window
    if end > page_count:
        end = page_count

    if start > 1:
        parts.push("<a href=\"{base_url}1\">1</a>")
        if start > 2:
            parts.push("<span class=\"ellipsis\">…</span>")

    var p = start
    while p <= end:
        if p == paginator.current_page:
            parts.push("<span class=\"current\">{p}</span>")
        else:
            parts.push("<a href=\"{base_url}{p}\">{p}</a>")
        p = p + 1

    if end < page_count:
        if end < page_count - 1:
            parts.push("<span class=\"ellipsis\">…</span>")
        parts.push("<a href=\"{base_url}{page_count}\">{page_count}</a>")

    if paginator.has_next():
        val nxt = paginator.next_page()
        parts.push("<a href=\"{base_url}{nxt}\" class=\"next\">Next &raquo;</a>")
    else:
        parts.push("<span class=\"next disabled\">Next &raquo;</span>")

    parts.push("</nav>")
    parts.join("\n")
