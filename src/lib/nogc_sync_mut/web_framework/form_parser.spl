"""
# Form Body Parser

Parse URL-encoded and multipart form request bodies into Dict<text, text>.

## URL-encoded

```simple
val params = parse_url_encoded("name=Alice&age=30&city=New+York")
# params = {"name": "Alice", "age": "30", "city": "New York"}
```

## Multipart

```simple
val boundary = extract_boundary("multipart/form-data; boundary=----WebKitFormBoundary")
val params = parse_multipart(body, boundary ?? "")
```
"""

# ============================================================================
# URL-Encoded Form Parsing
# ============================================================================

fn parse_url_encoded(body: text) -> Dict<text, text>:
    """Parse application/x-www-form-urlencoded body.

    Handles plus-as-space and percent-encoding.

    Args:
        body: URL-encoded form body

    Returns:
        Dict of parameter name to value
    """
    var result: Dict<text, text> = {}

    if body.len() == 0:
        return result

    val pairs = body.split("&")
    for pair in pairs:
        if pair.len() == 0:
            pass_do_nothing
        else:
            val eq_pos = pair.index_of("=")
            if eq_pos >= 0:
                val raw_key = pair[0:eq_pos]
                val raw_value = pair[eq_pos + 1:]
                val key = url_decode(raw_key)
                val value = url_decode(raw_value)
                result[key] = value
            else:
                # Key with no value
                val key = url_decode(pair)
                result[key] = ""

    result

# ============================================================================
# Multipart Form Parsing
# ============================================================================

fn parse_multipart(body: text, boundary: text) -> Dict<text, text>:
    """Parse multipart/form-data body.

    Extracts text fields from multipart body. Binary file uploads
    are stored as their raw text representation.

    Args:
        body: Raw multipart body
        boundary: Boundary string (without leading --)

    Returns:
        Dict of field name to value
    """
    var result: Dict<text, text> = {}

    if body.len() == 0 or boundary.len() == 0:
        return result

    val delim = "--{boundary}"
    val end_delim = "--{boundary}--"

    val parts = body.split(delim)

    for part in parts:
        if part.len() == 0:
            pass_do_nothing
        else:
            if part.starts_with("--"):
                # End marker
                pass_do_nothing
            else:
                val parsed = parse_multipart_part(part)
                if parsed.name.len() > 0:
                    result[parsed.name] = parsed.value

    result

fn extract_boundary(content_type: text) -> text?:
    """Extract boundary string from Content-Type header.

    Args:
        content_type: Full Content-Type header value
            e.g., "multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW"

    Returns:
        Boundary string or nil if not found
    """
    val lower = content_type.to_lower()
    if not lower.starts_with("multipart/"):
        return nil

    val parts = content_type.split(";")
    for part in parts:
        val trimmed = part.trim()
        if trimmed.to_lower().starts_with("boundary="):
            val boundary = trimmed[9:]
            # Remove surrounding quotes if present
            if boundary.len() >= 2:
                if boundary.starts_with("\"") and boundary.ends_with("\""):
                    return Some(boundary[1:boundary.len() - 1])
            return Some(boundary)

    nil

fn detect_content_type(content_type: text) -> text:
    """Detect form content type from Content-Type header.

    Returns:
        "url_encoded", "multipart", or "unknown"
    """
    val lower = content_type.to_lower()
    if lower.starts_with("application/x-www-form-urlencoded"):
        return "url_encoded"
    if lower.starts_with("multipart/form-data"):
        return "multipart"
    "unknown"

# ============================================================================
# Multipart Part Parsing
# ============================================================================

class MultipartField:
    """A single parsed multipart field."""
    name: text
    value: text
    filename: text
    content_type: text

fn parse_multipart_part(part: text) -> MultipartField:
    """Parse a single multipart part into a field.

    A part looks like:
    ```
    Content-Disposition: form-data; name="field_name"

    field_value
    ```
    """
    var name = ""
    var value = ""
    var filename = ""
    var ct = ""

    # Find the blank line separating headers from body
    val double_newline = part.index_of("\r\n\r\n")
    var header_part = ""
    var body_part = ""

    if double_newline >= 0:
        header_part = part[0:double_newline]
        body_part = part[double_newline + 4:]
    else:
        # Try with just \n\n
        val dn = part.index_of("\n\n")
        if dn >= 0:
            header_part = part[0:dn]
            body_part = part[dn + 2:]
        else:
            return MultipartField(name: "", value: "", filename: "", content_type: "")

    # Parse headers
    val headers = header_part.split("\n")
    for header in headers:
        val trimmed = header.trim()
        val lower = trimmed.to_lower()

        if lower.starts_with("content-disposition:"):
            val disp = trimmed[20:]
            name = extract_header_param(disp, "name")
            filename = extract_header_param(disp, "filename")

        if lower.starts_with("content-type:"):
            ct = trimmed[14:].trim()

    # Clean up body (remove trailing \r\n)
    if body_part.ends_with("\r\n"):
        value = body_part[0:body_part.len() - 2]
    elif body_part.ends_with("\n"):
        value = body_part[0:body_part.len() - 1]
    else:
        value = body_part

    MultipartField(name: name, value: value, filename: filename, content_type: ct)

fn extract_header_param(header: text, param_name: text) -> text:
    """Extract a named parameter from a header value.

    e.g., extract_header_param('form-data; name="field"', "name") -> "field"
    """
    val search = "{param_name}=\""
    val pos = header.index_of(search)
    if pos < 0:
        return ""

    val start = pos + search.len()
    val rest = header[start:]
    val end_quote = rest.index_of("\"")
    if end_quote < 0:
        return rest

    rest[0:end_quote]

# ============================================================================
# URL Decoding
# ============================================================================

fn url_decode(s: text) -> text:
    """Decode URL-encoded string (percent-encoding + plus-as-space)."""
    var result: [text] = []
    var i = 0
    val len = s.len()

    while i < len:
        val c = s[i:i + 1]
        if c == "+":
            result.push(" ")
            i = i + 1
        elif c == "%":
            if i + 2 < len:
                val hex = s[i + 1:i + 3]
                val code = hex_to_int(hex)
                result.push(char_from_code(code))
                i = i + 3
            else:
                result.push(c)
                i = i + 1
        else:
            result.push(c)
            i = i + 1

    result.join("")

fn hex_to_int(hex: text) -> i64:
    """Convert 2-char hex string to integer."""
    var result = 0
    var i = 0
    while i < hex.len():
        val c = hex[i:i + 1]
        val code = char_code(c)
        var digit = 0
        if code >= 48 and code <= 57:
            digit = code - 48
        elif code >= 65 and code <= 70:
            digit = code - 65 + 10
        elif code >= 97 and code <= 102:
            digit = code - 97 + 10
        result = result * 16 + digit
        i = i + 1
    result

extern fn char_from_code(code: i64) -> text
extern fn char_code(c: text) -> i64

# ============================================================================
# Auto-parse request body
# ============================================================================

fn parse_request_body(body: text, content_type: text) -> Dict<text, text>:
    """Automatically parse request body based on content type.

    Args:
        body: Raw request body
        content_type: Content-Type header value

    Returns:
        Parsed parameters dict
    """
    val ct = detect_content_type(content_type)
    match ct:
        "url_encoded":
            parse_url_encoded(body)
        "multipart":
            val boundary = extract_boundary(content_type)
            if boundary != nil:
                parse_multipart(body, boundary ?? "")
            else:
                {}
        _:
            {}
