"""
# Session Store

Database-backed session store and signed cookie session support.
Sessions map a session_id to key-value data with expiry.

## DB-backed sessions

```simple
var db = Database.memory()?
var store = SessionStore(db: db)
store.init()?

val sid = store.create("user_42")?
store.set(sid, "role", "admin")
val data = store.get(sid)?
store.destroy(sid)
```

## Signed cookie sessions

```simple
val data = {"user_id": "42", "role": "admin"}
val cookie = SignedCookieSession.encode(data, "my-secret-key")
val decoded = SignedCookieSession.decode(cookie, "my-secret-key")
```
"""

use std.database.{SdnDatabase, SdnTable, SdnRow}
use std.database.sql.connection.{Database}
use std.database.sql.types.{DbValue, DbError}
use std.crypto.hmac.{hmac_sha256}

# ============================================================================
# Session Store (DB-backed)
# ============================================================================

class SessionStore:
    """Database-backed session store.

    Sessions are stored in a `sessions` table with columns:
    session_id (text PK), user_id (text), data (text), created_at (i64),
    expires_at (i64), version (i64).

    Session data is stored as pipe-delimited key=value pairs.
    Typed values use prefix tags: "i:42" for ints, "b:true" for bools.
    """
    backend_kind: text
    db: Database?
    simple_db: SdnDatabase?

    static fn sqlite(db: Database) -> SessionStore:
        SessionStore(backend_kind: "sqlite", db: Some(db), simple_db: nil)

    static fn simpledb(db: SdnDatabase) -> SessionStore:
        SessionStore(backend_kind: "simpledb", db: nil, simple_db: Some(db))

impl SessionStore:
    me init() -> Result<(), text>:
        """Initialize the sessions table. Safe to call repeatedly."""
        if self.backend_kind == "sqlite":
            val sql = "CREATE TABLE IF NOT EXISTS sessions (" +
                "session_id TEXT PRIMARY KEY, " +
                "user_id TEXT NOT NULL, " +
                "data TEXT DEFAULT '', " +
                "created_at INTEGER NOT NULL, " +
                "expires_at INTEGER NOT NULL, " +
                "version INTEGER DEFAULT 1" +
                ")"
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, [])
            match result:
                Ok(_): return Ok(())
                Err(_e): return Err("Failed to create sessions table")

        var db = self.fresh_simple_db()?
        if not self.simple_session_table_opt(db).?:
            db.set_table("sessions", SdnTable.new("sessions", ["id", "valid", "user_id", "data", "created_at", "expires_at", "version"]))
        if not db.save():
            return Err("Failed to initialize Simple DB sessions")
        self.simple_db = Some(db)
        Ok(())

    me create(user_id: text) -> Result<text, text>:
        """Create a new session for a user.

        Generates a random hex session ID and inserts a row.

        Args:
            user_id: User identifier to associate with session

        Returns:
            Ok(session_id) on success
        """
        val sid = generate_session_id()
        val now = current_timestamp()
        val expires = now + 86400
        if self.backend_kind == "sqlite":
            val sql = "INSERT INTO sessions (session_id, user_id, data, created_at, expires_at, version) VALUES (?, ?, ?, ?, ?, ?)"
            val params: [DbValue] = [
                DbValue.Text(value: sid),
                DbValue.Text(value: user_id),
                DbValue.Text(value: ""),
                DbValue.Integer(value: now),
                DbValue.Integer(value: expires),
                DbValue.Integer(value: 1)
            ]
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
            match result:
                Ok(_): return Ok(sid)
                Err(_e): return Err("Failed to create session")

        var db = self.fresh_simple_db()?
        var table = self.simple_session_table(db)
        val row = SdnRow.empty()
        row.set("id", sid)
        row.set("valid", "true")
        row.set("user_id", user_id)
        row.set("data", "")
        row.set("created_at", "{now}")
        row.set("expires_at", "{expires}")
        row.set("version", "1")
        table.add_row(row)
        db.set_table("sessions", table)
        if not db.save():
            return Err("Failed to create Simple DB session")
        self.simple_db = Some(db)
        Ok(sid)

    me get(session_id: text) -> Result<Dict<text, text>, text>:
        """Retrieve session data by session ID.

        Returns empty dict if session not found or expired.

        Args:
            session_id: Session identifier

        Returns:
            Ok(data_dict) with session key-value pairs
        """
        val now = current_timestamp()
        if self.backend_kind == "sqlite":
            val sql = "SELECT data, user_id FROM sessions WHERE session_id = ? AND expires_at > ? LIMIT 1"
            val params: [DbValue] = [
                DbValue.Text(value: session_id),
                DbValue.Integer(value: now)
            ]
            val result = (self.db ?? Database.memory_unsafe()).query(sql, params)
            match result:
                Ok(rows):
                    if rows.len() == 0:
                        return Ok({})
                    val row = rows[0]
                    val data_str = row.get_text("data") ?? ""
                    val user_id = row.get_text("user_id") ?? ""
                    var data = deserialize_session_data(data_str)
                    data["_user_id"] = user_id
                    return Ok(data)
                Err(_e):
                    return Err("Failed to get session")

        val db = self.fresh_simple_db()?
        val table_opt = self.simple_session_table_opt(db)
        if not table_opt.?:
            return Ok({})
        val row = table_opt.unwrap().get_row(session_id)
        if not row.?:
            return Ok({})
        val session = row.unwrap()
        if session.get("valid") == Some("false"):
            return Ok({})
        val expires = (session.get("expires_at") ?? "0").to_int() ?? 0
        if expires <= now:
            return Ok({})
        var data = deserialize_session_data(session.get("data") ?? "")
        data["_user_id"] = session.get("user_id") ?? ""
        Ok(data)

    me set(session_id: text, key: text, value: text) -> Result<(), text>:
        """Set a key-value pair in a session.

        Args:
            session_id: Session identifier
            key: Data key
            value: Data value
        """
        val get_result = self.get(session_id)
        match get_result:
            Ok(data):
                var updated = data
                updated.remove("_user_id")
                updated[key] = value
                val serialized = serialize_session_data(updated)
                if self.backend_kind == "sqlite":
                    val sql = "UPDATE sessions SET data = ? WHERE session_id = ?"
                    val params: [DbValue] = [
                        DbValue.Text(value: serialized),
                        DbValue.Text(value: session_id)
                    ]
                    val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
                    match result:
                        Ok(_): return Ok(())
                        Err(_e): return Err("Failed to update session")

                var db = self.fresh_simple_db()?
                var table = self.simple_session_table(db)
                val current = table.get_row(session_id)
                if not current.?:
                    return Err("Session not found")
                var row = current.unwrap()
                row.set("data", serialized)
                table.update_row(session_id, row)
                db.set_table("sessions", table)
                if not db.save():
                    return Err("Failed to update Simple DB session")
                self.simple_db = Some(db)
                Ok(())
            Err(e):
                Err(e)

    me destroy(session_id: text) -> Result<(), text>:
        """Delete a session.

        Args:
            session_id: Session identifier to destroy
        """
        if self.backend_kind == "sqlite":
            val sql = "DELETE FROM sessions WHERE session_id = ?"
            val params: [DbValue] = [DbValue.Text(value: session_id)]
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
            match result:
                Ok(_): return Ok(())
                Err(_e): return Err("Failed to destroy session")

        var db = self.fresh_simple_db()?
        var table = self.simple_session_table(db)
        if table.mark_deleted(session_id):
            db.set_table("sessions", table)
            if not db.save():
                return Err("Failed to destroy Simple DB session")
            self.simple_db = Some(db)
        Ok(())

    me gc() -> Result<i64, text>:
        """Garbage collect expired sessions.

        Returns:
            Ok(count) of deleted sessions
        """
        val now = current_timestamp()
        if self.backend_kind == "sqlite":
            val sql = "DELETE FROM sessions WHERE expires_at <= ?"
            val params: [DbValue] = [DbValue.Integer(value: now)]
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
            match result:
                Ok(count): return Ok(count)
                Err(_e): return Err("Failed to gc sessions")

        var db = self.fresh_simple_db()?
        var table = self.simple_session_table(db)
        var deleted = 0
        for row in table.rows:
            val expires = (row.get("expires_at") ?? "0").to_int() ?? 0
            if row.get("valid") != Some("false") and expires <= now:
                if table.mark_deleted(row.get("id") ?? ""):
                    deleted = deleted + 1
        db.set_table("sessions", table)
        if not db.save():
            return Err("Failed to gc Simple DB sessions")
        self.simple_db = Some(db)
        Ok(deleted)

    me touch(session_id: text, ttl: i64) -> Result<(), text>:
        """Extend a session's expiry.

        Args:
            session_id: Session to extend
            ttl: New time-to-live in seconds from now
        """
        val now = current_timestamp()
        val expires = now + ttl
        if self.backend_kind == "sqlite":
            val sql = "UPDATE sessions SET expires_at = ? WHERE session_id = ?"
            val params: [DbValue] = [
                DbValue.Integer(value: expires),
                DbValue.Text(value: session_id)
            ]
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
            match result:
                Ok(_): return Ok(())
                Err(_e): return Err("Failed to touch session")

        var db = self.require_simple_db()?
        var table = self.simple_session_table(db)
        val current = table.get_row(session_id)
        if not current.?:
            return Err("Session not found")
        var row = current.unwrap()
        row.set("expires_at", "{expires}")
        table.update_row(session_id, row)
        db.set_table("sessions", table)
        if not db.save():
            return Err("Failed to touch Simple DB session")
        self.simple_db = Some(db)
        Ok(())

    me set_int(session_id: text, key: text, value: i64) -> Result<(), text>:
        """Set a typed integer value in a session.

        Stored with "i:" prefix tag for type-safe retrieval.

        Args:
            session_id: Session identifier
            key: Data key
            value: Integer value
        """
        self.set(session_id, key, "i:{value}")

    me set_bool(session_id: text, key: text, value: bool) -> Result<(), text>:
        """Set a typed boolean value in a session.

        Stored with "b:" prefix tag for type-safe retrieval.

        Args:
            session_id: Session identifier
            key: Data key
            value: Boolean value
        """
        val tag = if value: "b:true" else: "b:false"
        self.set(session_id, key, tag)

    me get_int(session_id: text, key: text) -> Option<i64>:
        """Get a typed integer value from a session.

        Returns nil if session/key missing or value lacks "i:" prefix.

        Args:
            session_id: Session identifier
            key: Data key

        Returns:
            Some(value) if present and correctly tagged, nil otherwise
        """
        val data = self.get(session_id)
        match data:
            Ok(dict):
                val raw = dict.get(key)
                if not raw.?:
                    return nil
                val s = raw.unwrap()
                if s.len() < 3:
                    return nil
                if s[0:2] != "i:":
                    return nil
                return s[2:].to_int()
            Err(_):
                return nil

    me get_bool(session_id: text, key: text) -> Option<bool>:
        """Get a typed boolean value from a session.

        Returns nil if session/key missing or value lacks "b:" prefix.

        Args:
            session_id: Session identifier
            key: Data key

        Returns:
            Some(value) if present and correctly tagged, nil otherwise
        """
        val data = self.get(session_id)
        match data:
            Ok(dict):
                val raw = dict.get(key)
                if not raw.?:
                    return nil
                val s = raw.unwrap()
                if s.len() < 3:
                    return nil
                if s[0:2] != "b:":
                    return nil
                val payload = s[2:]
                if payload == "true":
                    return Some(true)
                if payload == "false":
                    return Some(false)
                return nil
            Err(_):
                return nil

    me cleanup() -> Result<i64, text>:
        """Remove all expired sessions. Alias for gc().

        Returns:
            Ok(count) of deleted sessions
        """
        self.gc()

    me rotate(old_sid: text) -> Result<text, text>:
        """Rotate a session: copy data to a new ID and destroy the old one.

        Prevents session fixation attacks by issuing a fresh session ID
        while preserving all session data.

        Args:
            old_sid: Current session ID to rotate away from

        Returns:
            Ok(new_sid) with the replacement session ID
        """
        val old_data = self.get(old_sid)?
        val user_id = old_data.get("_user_id") ?? ""
        if user_id.len() == 0:
            return Err("Session not found or expired")
        val new_sid = self.create(user_id)?
        var filtered = old_data
        filtered.remove("_user_id")
        for key in filtered.keys():
            val value = filtered.get(key) ?? ""
            self.set(new_sid, key, value)?
        self.destroy(old_sid)?
        Ok(new_sid)

    me check_version(session_id: text, expected: i64) -> Result<bool, text>:
        """Check if a session's version matches the expected value.

        Used for optimistic locking: read version, do work, check before write.

        Args:
            session_id: Session identifier
            expected: Expected version number

        Returns:
            Ok(true) if version matches, Ok(false) otherwise
        """
        if self.backend_kind == "sqlite":
            val sql = "SELECT version FROM sessions WHERE session_id = ? LIMIT 1"
            val params: [DbValue] = [DbValue.Text(value: session_id)]
            val result = (self.db ?? Database.memory_unsafe()).query(sql, params)
            match result:
                Ok(rows):
                    if rows.len() == 0:
                        return Err("Session not found")
                    val row = rows[0]
                    val ver = row.get_int("version") ?? 0
                    return Ok(ver == expected)
                Err(_e):
                    return Err("Failed to check session version")

        val db = self.fresh_simple_db()?
        val table_opt = self.simple_session_table_opt(db)
        if not table_opt.?:
            return Err("Session not found")
        val row = table_opt.unwrap().get_row(session_id)
        if not row.?:
            return Err("Session not found")
        val ver = (row.unwrap().get("version") ?? "0").to_int() ?? 0
        Ok(ver == expected)

    me bump_version(session_id: text) -> Result<i64, text>:
        """Increment a session's version number.

        Args:
            session_id: Session identifier

        Returns:
            Ok(new_version) after increment
        """
        if self.backend_kind == "sqlite":
            val sql = "UPDATE sessions SET version = version + 1 WHERE session_id = ?"
            val params: [DbValue] = [DbValue.Text(value: session_id)]
            val result = (self.db ?? Database.memory_unsafe()).exec(sql, params)
            match result:
                Ok(_):
                    val q = "SELECT version FROM sessions WHERE session_id = ? LIMIT 1"
                    val qp: [DbValue] = [DbValue.Text(value: session_id)]
                    val qr = (self.db ?? Database.memory_unsafe()).query(q, qp)
                    match qr:
                        Ok(rows):
                            if rows.len() > 0:
                                return Ok(rows[0].get_int("version") ?? 1)
                            return Ok(1)
                        Err(_e):
                            return Ok(1)
                Err(_e):
                    return Err("Failed to bump session version")

        var db = self.fresh_simple_db()?
        var table = self.simple_session_table(db)
        val current = table.get_row(session_id)
        if not current.?:
            return Err("Session not found")
        var row = current.unwrap()
        val old_ver = (row.get("version") ?? "0").to_int() ?? 0
        val new_ver = old_ver + 1
        row.set("version", "{new_ver}")
        table.update_row(session_id, row)
        db.set_table("sessions", table)
        if not db.save():
            return Err("Failed to bump Simple DB session version")
        self.simple_db = Some(db)
        Ok(new_ver)

    fn require_simple_db() -> Result<SdnDatabase, text>:
        if val Some(db) = self.simple_db:
            return Ok(db)
        Err("Simple DB session store is not configured")

    me fresh_simple_db() -> Result<SdnDatabase, text>:
        val db = self.require_simple_db()?
        val path = db.path
        if path.len() > 0:
            val loaded = SdnDatabase.load(path)
            if loaded.?:
                self.simple_db = loaded
                return Ok(loaded.unwrap())
        Ok(db)

    fn simple_session_table(db: SdnDatabase) -> SdnTable:
        if val Some(table) = self.simple_session_table_opt(db):
            return table
        SdnTable.new("sessions", ["id", "valid", "user_id", "data", "created_at", "expires_at", "version"])

    fn simple_session_table_opt(db: SdnDatabase) -> SdnTable?:
        for (name, table) in db.tables:
            if name == "sessions":
                return Some(table)
        nil

# ============================================================================
# Signed Cookie Session
# ============================================================================

class SignedCookieSession:
    """Stateless session stored entirely in a signed cookie.

    Data is serialized as pipe-delimited key=value pairs,
    then signed with HMAC-SHA256. Format: `data.signature`.
    """

impl SignedCookieSession:
    static fn encode(data: Dict<text, text>, secret: text) -> text:
        """Encode session data into a signed cookie value.

        Args:
            data: Session data as key-value pairs
            secret: Secret key for HMAC signing

        Returns:
            Signed cookie string in format `encoded_data.signature`
        """
        val serialized = serialize_session_data(data)
        val signature = compute_signature(serialized, secret)
        "{serialized}.{signature}"

    static fn decode(cookie_value: text, secret: text) -> Dict<text, text>?:
        """Decode and verify a signed cookie value.

        Args:
            cookie_value: Signed cookie string
            secret: Secret key for HMAC verification

        Returns:
            Session data if signature is valid, nil otherwise
        """
        val dot_pos = cookie_value.last_index_of(".")
        if dot_pos <= 0:
            return nil

        val data_part = cookie_value[0:dot_pos]
        val sig_part = cookie_value[dot_pos + 1:]

        val expected_sig = compute_signature(data_part, secret)
        if sig_part != expected_sig:
            return nil

        Some(deserialize_session_data(data_part))

# ============================================================================
# Session Data Serialization
# ============================================================================

fn serialize_session_data(data: Dict<text, text>) -> text:
    """Serialize session data to pipe-delimited key=value format.

    Values are percent-encoded to prevent delimiter collisions.
    """
    var parts: [text] = []
    for key in data.keys():
        val value = data.get(key) ?? ""
        val encoded_key = simple_encode(key)
        val encoded_value = simple_encode(value)
        parts.push("{encoded_key}={encoded_value}")
    parts.join("|")

fn deserialize_session_data(s: text) -> Dict<text, text>:
    """Deserialize pipe-delimited key=value string to dict."""
    var result: Dict<text, text> = {}
    if s.len() == 0:
        return result

    val pairs = s.split("|")
    for pair in pairs:
        val eq_pos = pair.index_of("=")
        if eq_pos > 0:
            val key = simple_decode(pair[0:eq_pos])
            val value = simple_decode(pair[eq_pos + 1:])
            result[key] = value
    result

fn simple_encode(s: text) -> text:
    """Simple percent-encoding for pipe and equals characters."""
    var result = s
    result = result.replace("%", "%25")
    result = result.replace("|", "%7C")
    result = result.replace("=", "%3D")
    result = result.replace(".", "%2E")
    result

fn simple_decode(s: text) -> text:
    """Decode simple percent-encoding."""
    var result = s
    result = result.replace("%2E", ".")
    result = result.replace("%3D", "=")
    result = result.replace("%7C", "|")
    result = result.replace("%25", "%")
    result

# ============================================================================
# Helpers
# ============================================================================

fn generate_session_id() -> text:
    """Generate a random-looking session ID.

    Uses timestamp + counter for uniqueness. In production,
    this would use a CSPRNG.
    """
    val ts = current_timestamp()
    var parts: [text] = []
    var n = ts
    var i = 0
    while i < 16:
        val digit = (n * 2654435761) % 16
        n = n + digit + i + 7
        if digit < 10:
            parts.push("{digit}")
        else:
            match digit:
                10: parts.push("a")
                11: parts.push("b")
                12: parts.push("c")
                13: parts.push("d")
                14: parts.push("e")
                _: parts.push("f")
        i = i + 1
    parts.join("")

fn compute_signature(data: text, secret: text) -> text:
    """Compute HMAC-SHA256 signature as hex string."""
    val hash_bytes = hmac_sha256(secret, data)
    bytes_to_hex(hash_bytes)

fn bytes_to_hex(bytes: [i64]) -> text:
    """Convert byte array to hex string."""
    var parts: [text] = []
    for b in bytes:
        val hi = (b / 16) % 16
        val lo = b % 16
        parts.push(hex_digit(hi))
        parts.push(hex_digit(lo))
    parts.join("")

fn hex_digit(n: i64) -> text:
    """Convert 0-15 to hex character."""
    if n < 10:
        return "{n}"
    match n:
        10: "a"
        11: "b"
        12: "c"
        13: "d"
        14: "e"
        _: "f"

extern fn rt_time_now_unix_micros() -> i64

fn current_timestamp() -> i64:
    rt_time_now_unix_micros() / 1000000
