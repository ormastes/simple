# i18n Resource Bundle Module
#
# Provides Java-like locale-based resource bundles using SDN format.
# Convention: i18n/messages.sdn (default), i18n/messages_{locale}.sdn
#
# Usage:
#   use std.i18n.{ResourceBundle}
#   use std.i18n.{t, t_fmt, i18n_init}
#   use std.i18n.{detect_locale, list_available_locales}

# Re-exported from bundle.spl
export ResourceBundle
export parse_i18n_file
export detect_locale
export list_available_locales

# Re-exported from global.spl
export i18n_init, i18n_init_auto
export t, t_fmt
export i18n_is_initialized, i18n_current_locale, i18n_has_key
