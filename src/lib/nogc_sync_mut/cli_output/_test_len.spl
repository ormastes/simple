# Shared module for testing .len() corruption on module-level arrays.
# This file gets copied to src/lib/nogc_sync_mut/cli_output/_test_len.spl
# before tests run.
#
# BUG: Calling .len() twice on a module-level array in the same function
# corrupts the variable (becomes i64(0)) when the module is imported via use.
# Calling .len() once works fine.

var text_arr: [text] = []
var i64_arr: [i64] = []
var second_arr: [text] = []

fn get_text_len() -> i64:
    text_arr.len()

fn get_text_len_twice() -> i64:
    val a = text_arr.len()
    text_arr.len()

fn get_i64_len() -> i64:
    i64_arr.len()

fn get_i64_len_twice() -> i64:
    val a = i64_arr.len()
    i64_arr.len()

fn push_then_get_len() -> i64:
    text_arr.push("x")
    text_arr.len()

fn len_then_push() -> i64:
    val l = text_arr.len()
    text_arr.push("x")
    l

fn get_text_len_cached() -> i64:
    val cached = text_arr.len()
    cached + cached

fn get_multi_arr_lens() -> i64:
    val a = text_arr.len()
    val b = i64_arr.len()
    val c = second_arr.len()
    a + b + c
