# CLI Output Buffer
#
# Thin wrapper around std.log log points for CLI output buffering.
# Adds dual-write to log file on top of log point deferred printing.
#
# Usage:
#   buffer_start("build/log/build/20260313.log")
#   buffer_capture("Compiling...")    # deferred via log point + written to log file
#   if failed:
#       buffer_flush()                # prints buffered output
#   else:
#       buffer_discard()              # silent

use std.log.{log_point_start, log_point_flush, log_point_discard, log_point_has_active, log_print}

extern fn rt_file_append(path: text, content: text)

var _current_point_id: i64 = -1
var _log_path: text = ""

fn buffer_start(log_path: text):
    _log_path = log_path
    _current_point_id = log_point_start("cli_buffer")

fn buffer_capture(line: text):
    # Dual-write: defer via log point + write to log file immediately
    log_print(line)
    if _log_path != "":
        rt_file_append(_log_path, "{line}\n")

fn buffer_flush():
    if _current_point_id < 0:
        return
    log_point_flush(_current_point_id)
    _current_point_id = -1
    _log_path = ""

fn buffer_discard():
    if _current_point_id < 0:
        return
    log_point_discard(_current_point_id)
    _current_point_id = -1
    _log_path = ""

fn buffer_is_active() -> bool:
    _current_point_id >= 0

fn buffer_line_count() -> i64:
    0  # Not tracked directly; use log_point internals if needed
