# zstd/frame.spl — Frame and block header parsing (RFC 8878)
#
# Handles:
#   - Zstd magic (0xFD2FB528)
#   - Skippable frame magic (0x184D2A50..0x184D2A5F)
#   - Frame_Header_Descriptor (FHD)
#   - Window_Descriptor
#   - Dictionary_ID field (parsed; non-zero returns Unsupported)
#   - Frame_Content_Size (FCS)
#   - Block_Header: Last_Block, Block_Type, Block_Size

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.zstd.bit_reader.{
    ZstdBitReader, ZstdBitsResult,
    zstd_br_init, zstd_br_read, zstd_br_read_u16, zstd_br_read_u32
}

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

val ZSTD_MAGIC        = 0xFD2FB528
val ZSTD_SKIP_MAGIC_LO = 0x184D2A50
val ZSTD_SKIP_MAGIC_HI = 0x184D2A5F

val ZSTD_BLOCK_RAW        = 0
val ZSTD_BLOCK_RLE        = 1
val ZSTD_BLOCK_COMPRESSED = 2
val ZSTD_BLOCK_RESERVED   = 3

val ZSTD_MAX_BLOCK_SIZE = 131072  # 128 KiB

# ---------------------------------------------------------------------------
# Frame header result
# ---------------------------------------------------------------------------

struct ZstdFrameHeader:
    window_size: i64          # decompressed window size
    dict_id: i64              # 0 = no dictionary
    content_size: i64         # -1 = unknown
    has_checksum: bool         # content checksum flag
    reader: ZstdBitReader     # reader positioned after frame header

# Parse the 4-byte magic and determine frame type.
# Returns (is_skippable, reader) or Err.
struct ZstdMagicResult:
    is_skippable: bool
    skip_size: i64            # only valid if is_skippable
    reader: ZstdBitReader

fn zstd_parse_magic(r: ZstdBitReader) -> Result<ZstdMagicResult, CompressionError>:
    val r1 = zstd_br_read_u32(r)?
    val magic = r1.value
    if magic == ZSTD_MAGIC:
        return Ok(ZstdMagicResult(is_skippable: false, skip_size: 0, reader: r1.reader))
    # Skippable frame check
    if (magic >= ZSTD_SKIP_MAGIC_LO) and (magic <= ZSTD_SKIP_MAGIC_HI):
        val r2 = zstd_br_read_u32(r1.reader)?
        val skip_size = r2.value
        return Ok(ZstdMagicResult(is_skippable: true, skip_size: skip_size, reader: r2.reader))
    Err(CompressionError.InvalidHeader("zstd bad magic"))

# Parse Frame_Header_Descriptor + window + dict_id + FCS.
fn zstd_parse_frame_header(r: ZstdBitReader) -> Result<ZstdFrameHeader, CompressionError>:
    # FHD byte
    val r1 = zstd_br_read(r, 8)?
    val fhd = r1.value
    var cur = r1.reader

    val fcs_flag     = (fhd >> 6) & 3   # Frame_Content_Size_Flag
    val single_seg   = (fhd >> 5) & 1   # Single_Segment_Flag
    val has_checksum = ((fhd >> 2) & 1) == 1
    val dict_id_flag = fhd & 3          # Dictionary_ID_Flag

    # Window_Descriptor (only present if Single_Segment_Flag == 0)
    var window_size = 0
    if single_seg == 0:
        val rw = zstd_br_read(cur, 8)?
        val wd = rw.value
        cur = rw.reader
        val mantissa  = wd & 7
        val exponent  = (wd >> 3) & 31
        # window_size = (1 + mantissa/8) * 2^(10 + exponent)
        val base = 1 << (10 + exponent)
        window_size = base + (base >> 3) * mantissa

    # Dictionary_ID
    var dict_id = 0
    if dict_id_flag == 1:
        val rd = zstd_br_read(cur, 8)?
        dict_id = rd.value
        cur = rd.reader
    else:
        if dict_id_flag == 2:
            val rd = zstd_br_read_u16(cur)?
            dict_id = rd.value
            cur = rd.reader
        else:
            if dict_id_flag == 3:
                val rd = zstd_br_read_u32(cur)?
                dict_id = rd.value
                cur = rd.reader

    if dict_id != 0:
        return Err(CompressionError.Unsupported("zstd dictionary frames not supported"))

    # Frame_Content_Size
    var content_size = -1
    if fcs_flag == 0:
        if single_seg == 1:
            val rc = zstd_br_read(cur, 8)?
            content_size = rc.value
            cur = rc.reader
        # else content_size stays -1
    else:
        if fcs_flag == 1:
            val rc = zstd_br_read_u16(cur)?
            content_size = rc.value + 256
            cur = rc.reader
        else:
            if fcs_flag == 2:
                # 3-byte: not directly readable as 24-bit with helpers, do manually
                val rb0 = zstd_br_read(cur, 8)?
                val rb1 = zstd_br_read(rb0.reader, 8)?
                val rb2 = zstd_br_read(rb1.reader, 8)?
                content_size = rb0.value | (rb1.value << 8) | (rb2.value << 16)
                cur = rb2.reader
            else:
                # fcs_flag == 3: 8 bytes
                val r0 = zstd_br_read_u32(cur)?
                val lo = r0.value
                val r1h = zstd_br_read_u32(r0.reader)?
                val hi = r1h.value
                content_size = lo | (hi << 32)
                cur = r1h.reader

    # If single_seg, window_size == content_size
    if single_seg == 1 and content_size >= 0:
        window_size = content_size

    Ok(ZstdFrameHeader(
        window_size:  window_size,
        dict_id:      dict_id,
        content_size: content_size,
        has_checksum: has_checksum,
        reader:       cur
    ))

# ---------------------------------------------------------------------------
# Block header
# ---------------------------------------------------------------------------

struct ZstdBlockHeader:
    last_block:  bool
    block_type:  i64
    block_size:  i64
    reader:      ZstdBitReader

fn zstd_parse_block_header(r: ZstdBitReader) -> Result<ZstdBlockHeader, CompressionError>:
    # Block_Header is 3 bytes, little-endian
    val r0 = zstd_br_read(r, 8)?
    val r1 = zstd_br_read(r0.reader, 8)?
    val r2 = zstd_br_read(r1.reader, 8)?
    val raw = r0.value | (r1.value << 8) | (r2.value << 16)
    val last_block  = (raw & 1) == 1
    val block_type  = (raw >> 1) & 3
    val block_size  = raw >> 3
    if block_type == ZSTD_BLOCK_RESERVED:
        return Err(CompressionError.CorruptData("zstd reserved block type"))
    Ok(ZstdBlockHeader(
        last_block: last_block,
        block_type: block_type,
        block_size: block_size,
        reader:     r2.reader
    ))

# Advance the reader by `n` bytes (used to skip skippable frame payload).
fn zstd_skip_bytes(r: ZstdBitReader, n: i64) -> Result<ZstdBitReader, CompressionError>:
    var cur = r
    var remaining = n
    while remaining > 0:
        val chunk = if remaining > 32: 32 else: remaining
        val res = zstd_br_read(cur, chunk * 8)?
        cur = res.reader
        remaining = remaining - chunk
    Ok(cur)

export ZSTD_MAGIC, ZSTD_SKIP_MAGIC_LO, ZSTD_SKIP_MAGIC_HI
export ZSTD_BLOCK_RAW, ZSTD_BLOCK_RLE, ZSTD_BLOCK_COMPRESSED, ZSTD_BLOCK_RESERVED, ZSTD_MAX_BLOCK_SIZE
