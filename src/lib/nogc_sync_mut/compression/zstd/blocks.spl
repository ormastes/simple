# zstd/blocks.spl — Block decoding and match copy (RFC 8878 §3.1.2)
#
# Block types:
#   Raw_Block        — literal bytes, no compression (IMPLEMENTED)
#   RLE_Block        — one byte repeated Block_Size times (IMPLEMENTED)
#   Compressed_Block — literals section + sequences section (IMPLEMENTED)
#
# Compressed_Block implementation status:
#   - Literals_Block_Type 00 (Raw)     — fully implemented
#   - Literals_Block_Type 01 (RLE)     — fully implemented
#   - Literals_Block_Type 10 (Huffman) — direct-weights implemented; FSE-weights pending team4a
#   - Literals_Block_Type 11 (Treeless)— implemented (reuses prev huff table)
#   - Sequences count == 0             — fully implemented (emit literals, done)
#   - Sequences count  > 0 (FSE)       — fully implemented (all 4 compression modes)

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.zstd.bit_reader.{
    ZstdBitReader, ZstdBitsResult, ZstdBytesResult,
    ZstdRevBitReader,
    zstd_br_init, zstd_br_read, zstd_br_read_bytes, zstd_br_align,
    zstd_rbr_init, zstd_rbr_read
}
use std.nogc_sync_mut.compression.zstd.frame.{
    ZSTD_BLOCK_RAW, ZSTD_BLOCK_RLE, ZSTD_BLOCK_COMPRESSED,
    ZstdBlockHeader
}
use std.nogc_sync_mut.compression.zstd.huffman.{
    HuffTable, HuffEntry,
    huff_build_table, zstd_decode_huffman_literals
}
use std.nogc_sync_mut.compression.zstd.fse.{
    FseTable, FseTableEntry, FseSymbolResult,
    fse_read_ncount, fse_build_table, fse_init_state, fse_decode_symbol
}
use std.nogc_sync_mut.compression.zstd.fse_predefined.{
    zstd_predefined_ll_table, zstd_predefined_ml_table, zstd_predefined_of_table,
    zstd_ll_baseline, zstd_ll_extra_bits,
    zstd_ml_baseline, zstd_ml_extra_bits,
    zstd_of_extra_bits
}

# ---------------------------------------------------------------------------
# Sentinel empty Huffman table (used when no prior table exists)
# ---------------------------------------------------------------------------

fn zstd_empty_huff_table() -> HuffTable:
    HuffTable(entries: [], max_bits: 0)

fn zstd_huff_table_valid(t: HuffTable) -> i64:
    if t.max_bits > 0:
        1
    else:
        0

# ---------------------------------------------------------------------------
# Decoder state threaded across blocks
# ---------------------------------------------------------------------------

# Sentinel empty FSE table (used when no prior table exists for Repeat_Mode)
fn zstd_empty_fse_table() -> FseTable:
    FseTable(entries: [], accuracy_log: 0)

fn zstd_fse_table_valid(t: FseTable) -> i64:
    # A table is valid (usable for Repeat_Mode) if it has at least one entry.
    # Empty entries means no prior table exists (sentinel).
    if t.entries.len() > 0:
        1
    else:
        0

struct ZstdBlockState:
    output:       [u8]       # accumulated decompressed output
    rep_offsets:  [i64]      # rep1, rep2, rep3 (initial values: 1, 4, 8 per RFC 8878)
    huff_table:   HuffTable  # Huffman table carried across blocks for Treeless mode
    ll_table:     FseTable   # Literal Length FSE table (for Repeat_Mode)
    of_table:     FseTable   # Offset FSE table (for Repeat_Mode)
    ml_table:     FseTable   # Match Length FSE table (for Repeat_Mode)

struct ZstdBlockResult:
    state:  ZstdBlockState
    reader: ZstdBitReader

fn zstd_initial_block_state() -> ZstdBlockState:
    ZstdBlockState(
        output:      [],
        rep_offsets: [1, 4, 8],
        huff_table:  zstd_empty_huff_table(),
        ll_table:    zstd_empty_fse_table(),
        of_table:    zstd_empty_fse_table(),
        ml_table:    zstd_empty_fse_table()
    )

# ---------------------------------------------------------------------------
# Decode a single block
# ---------------------------------------------------------------------------

fn zstd_decode_block(
    hdr: ZstdBlockHeader,
    state: ZstdBlockState,
    r: ZstdBitReader
) -> Result<ZstdBlockResult, CompressionError>:

    if hdr.block_type == ZSTD_BLOCK_RAW:
        return zstd_decode_raw_block(hdr.block_size, state, r)

    if hdr.block_type == ZSTD_BLOCK_RLE:
        return zstd_decode_rle_block(hdr.block_size, state, r)

    if hdr.block_type == ZSTD_BLOCK_COMPRESSED:
        return zstd_decode_compressed_block(hdr.block_size, state, r)

    Err(CompressionError.CorruptData("zstd unknown block type"))

fn zstd_decode_raw_block(
    block_size: i64,
    state: ZstdBlockState,
    r: ZstdBitReader
) -> Result<ZstdBlockResult, CompressionError>:
    val rb = zstd_br_read_bytes(r, block_size)?
    var new_output = state.output
    var i = 0
    while i < rb.bytes.len():
        new_output.push(rb.bytes[i])
        i = i + 1
    val new_state = ZstdBlockState(
        output:      new_output,
        rep_offsets: state.rep_offsets,
        huff_table:  state.huff_table,
        ll_table:    state.ll_table,
        of_table:    state.of_table,
        ml_table:    state.ml_table
    )
    Ok(ZstdBlockResult(state: new_state, reader: rb.reader))

fn zstd_decode_rle_block(
    block_size: i64,
    state: ZstdBlockState,
    r: ZstdBitReader
) -> Result<ZstdBlockResult, CompressionError>:
    val rb = zstd_br_read(r, 8)?
    val byte_val = rb.value
    var new_output = state.output
    var i = 0
    while i < block_size:
        new_output.push(byte_val.to_u8())
        i = i + 1
    val new_state = ZstdBlockState(
        output:      new_output,
        rep_offsets: state.rep_offsets,
        huff_table:  state.huff_table,
        ll_table:    state.ll_table,
        of_table:    state.of_table,
        ml_table:    state.ml_table
    )
    Ok(ZstdBlockResult(state: new_state, reader: rb.reader))

fn zstd_decode_compressed_block(
    block_size: i64,
    state: ZstdBlockState,
    r: ZstdBitReader
) -> Result<ZstdBlockResult, CompressionError>:
    # Read the entire compressed block payload into a sub-slice.
    val outer = zstd_br_read_bytes(r, block_size)?
    val block_data = outer.bytes
    val outer_reader = outer.reader

    val sub = zstd_br_init(block_data)

    # -----------------------------------------------------------------------
    # 1. Literals_Section_Header  (RFC 8878 §3.1.1.3)
    #   bits [1:0] = Literals_Block_Type
    #   bits [3:2] = Size_Format
    # -----------------------------------------------------------------------
    val h0r = zstd_br_read(sub, 8)?
    val hdr_byte = h0r.value
    var cur = h0r.reader

    val lit_block_type = hdr_byte & 3
    val size_fmt       = (hdr_byte >> 2) & 3

    # literals bytes and updated huffman table after literals section
    var literals: [u8] = []
    var new_huff_table = state.huff_table

    if lit_block_type == 0:
        # Raw literals
        val regen_size = zstd_lit_raw_rle_size(hdr_byte, size_fmt, cur)?
        val lsr = zstd_br_read_bytes(regen_size.reader, regen_size.value)?
        cur = lsr.reader
        literals = lsr.bytes

    else:
        if lit_block_type == 1:
            # RLE literals
            val regen_size = zstd_lit_raw_rle_size(hdr_byte, size_fmt, cur)?
            val byr = zstd_br_read(regen_size.reader, 8)?
            cur = byr.reader
            val fill_byte = byr.value.to_u8()
            var li = 0
            while li < regen_size.value:
                literals.push(fill_byte)
                li = li + 1

        else:
            # Huffman (10) = new tree; Treeless (11) = reuse previous block's table
            var treeless = 0
            if lit_block_type == 3:
                treeless = 1
                if zstd_huff_table_valid(state.huff_table) == 0:
                    return Err(CompressionError.CorruptData("zstd treeless literals with no prior huffman table"))
            val hr = zstd_decode_huffman_literals(hdr_byte, size_fmt, treeless, state.huff_table, cur)?
            cur = hr.reader
            literals = hr.literals
            new_huff_table = hr.table

    # -----------------------------------------------------------------------
    # 2. Sequences_Section_Header  (RFC 8878 §3.1.1.4)
    #   0        → 0 sequences
    #   1..127   → num_sequences = byte
    #   128..254 → num_sequences = ((byte - 128) << 8) | next_byte
    #   255      → num_sequences = next_byte_lo | (next_byte_hi << 8) + 0x7F00
    # -----------------------------------------------------------------------
    cur = zstd_br_align(cur)

    val nsr = zstd_br_read(cur, 8)?
    cur = nsr.reader
    val seq_first = nsr.value

    var num_sequences = 0
    if seq_first == 0:
        num_sequences = 0
    else:
        if seq_first < 128:
            num_sequences = seq_first
        else:
            if seq_first < 255:
                val seq2r = zstd_br_read(cur, 8)?
                cur = seq2r.reader
                num_sequences = ((seq_first - 128) << 8) | seq2r.value
            else:
                val sq2r = zstd_br_read(cur, 8)?
                val sq3r = zstd_br_read(sq2r.reader, 8)?
                cur = sq3r.reader
                num_sequences = sq2r.value | (sq3r.value << 8) + 0x7F00

    # -----------------------------------------------------------------------
    # 3. Execute sequences (or emit literals directly if none)
    # -----------------------------------------------------------------------
    if num_sequences == 0:
        var new_output = state.output
        var li = 0
        while li < literals.len():
            new_output.push(literals[li])
            li = li + 1
        val new_state = ZstdBlockState(
            output:      new_output,
            rep_offsets: state.rep_offsets,
            huff_table:  new_huff_table,
            ll_table:    state.ll_table,
            of_table:    state.of_table,
            ml_table:    state.ml_table
        )
        return Ok(ZstdBlockResult(state: new_state, reader: outer_reader))

    # -----------------------------------------------------------------------
    # 4. Symbol_Compression_Modes byte (RFC 8878 §3.1.1.3.2.1)
    #   bits [7:6] = Literals_Lengths_Mode
    #   bits [5:4] = Offsets_Mode
    #   bits [3:2] = Match_Lengths_Mode
    #   bits [1:0] = Reserved (must be 0)
    # Modes: 0=Predefined, 1=RLE, 2=FSE_Compressed, 3=Repeat
    # -----------------------------------------------------------------------
    val mode_r = zstd_br_read(cur, 8)?
    cur = mode_r.reader
    val modes_byte = mode_r.value
    val ll_mode = (modes_byte >> 6) & 3
    val of_mode = (modes_byte >> 4) & 3
    val ml_mode = (modes_byte >> 2) & 3

    # Load LL table
    val ll_tbl_r = zstd_load_seq_table(ll_mode, state.ll_table, 9, cur, 0)?
    cur = ll_tbl_r.reader
    val new_ll_table = ll_tbl_r.table

    # Load OF table
    val of_tbl_r = zstd_load_seq_table(of_mode, state.of_table, 8, cur, 1)?
    cur = of_tbl_r.reader
    val new_of_table = of_tbl_r.table

    # Load ML table
    val ml_tbl_r = zstd_load_seq_table(ml_mode, state.ml_table, 9, cur, 2)?
    cur = ml_tbl_r.reader
    val new_ml_table = ml_tbl_r.table

    # -----------------------------------------------------------------------
    # 5. Sequence bitstream — the remaining bytes in the sub-block are the
    #    reverse bitstream (RFC 8878 §3.1.2.3).
    #    cur is now byte-aligned; collect remaining bytes into seq_data.
    # -----------------------------------------------------------------------
    cur = zstd_br_align(cur)
    val cur_pos = zstd_br_byte_pos_aligned(cur)
    var seq_data: [u8] = []
    var sp = cur_pos
    while sp < block_data.len():
        seq_data.push(block_data[sp])
        sp = sp + 1

    val rev = zstd_rbr_init(seq_data)?

    # -----------------------------------------------------------------------
    # 6. Initialize FSE states from reverse bitstream:
    #    LL state → OF state → ML state (RFC 8878 §3.1.1.3.2.1.1)
    # -----------------------------------------------------------------------
    val ll_init = fse_init_state(new_ll_table, rev)?
    val of_init = fse_init_state(new_of_table, ll_init.reader)?
    val ml_init = fse_init_state(new_ml_table, of_init.reader)?

    var ll_state = ll_init.state
    var of_state = of_init.state
    var ml_state = ml_init.state
    var rev_cur = ml_init.reader

    # -----------------------------------------------------------------------
    # 7. Execute sequences
    # -----------------------------------------------------------------------
    var new_output = state.output
    var rep_offsets = state.rep_offsets
    var lit_cursor = 0
    var seq_idx = 0

    while seq_idx < num_sequences:
        val is_last = if seq_idx == num_sequences - 1: 1 else: 0

        # Decode current symbols from states (use intermediate var: chained access broken)
        var ll_entry = new_ll_table.entries[ll_state]
        val ll_sym = ll_entry.symbol
        var of_entry = new_of_table.entries[of_state]
        val of_sym = of_entry.symbol
        var ml_entry = new_ml_table.entries[ml_state]
        val ml_sym = ml_entry.symbol

        # Read extra bits: OF first, then ML, then LL (RFC 8878 §3.1.1.3.2.1.2)
        val of_xb = zstd_of_extra_bits(of_sym)
        var of_extra_val = 0
        if of_xb > 0:
            val xr = zstd_rbr_read(rev_cur, of_xb)?
            of_extra_val = xr.value
            rev_cur = xr.reader

        val ml_xb = zstd_ml_extra_bits(ml_sym)
        var ml_extra_val = 0
        if ml_xb > 0:
            val xr = zstd_rbr_read(rev_cur, ml_xb)?
            ml_extra_val = xr.value
            rev_cur = xr.reader

        val ll_xb = zstd_ll_extra_bits(ll_sym)
        var ll_extra_val = 0
        if ll_xb > 0:
            val xr = zstd_rbr_read(rev_cur, ll_xb)?
            ll_extra_val = xr.value
            rev_cur = xr.reader

        # Compute literal_length, match_length, offset_value
        val literal_length = zstd_ll_baseline(ll_sym) + ll_extra_val
        val match_length   = zstd_ml_baseline(ml_sym) + ml_extra_val
        # Offset: offset_value = (1 << of_sym) + of_extra_val (code 0 -> 1)
        val raw_offset = if of_sym == 0: 1 else: (1 << of_sym) + of_extra_val

        # Resolve repeat offsets (RFC 8878 §3.1.1.5)
        var actual_offset = 0
        var new_rep = rep_offsets
        if raw_offset > 3:
            actual_offset = raw_offset - 3
            new_rep = [actual_offset, rep_offsets[0], rep_offsets[1]]
        else:
            if literal_length > 0:
                # LL > 0: raw_offset 1,2,3 → rep[0], rep[1], rep[2]
                actual_offset = rep_offsets[raw_offset - 1]
                if raw_offset == 1:
                    new_rep = [rep_offsets[0], rep_offsets[1], rep_offsets[2]]
                else:
                    if raw_offset == 2:
                        new_rep = [rep_offsets[1], rep_offsets[0], rep_offsets[2]]
                    else:
                        new_rep = [rep_offsets[2], rep_offsets[0], rep_offsets[1]]
            else:
                # LL == 0: raw_offset 1,2,3 → rep[1], rep[2], rep[0]-1
                if raw_offset == 1:
                    actual_offset = rep_offsets[1]
                    new_rep = [rep_offsets[1], rep_offsets[0], rep_offsets[2]]
                else:
                    if raw_offset == 2:
                        actual_offset = rep_offsets[2]
                        new_rep = [rep_offsets[2], rep_offsets[0], rep_offsets[1]]
                    else:
                        # raw_offset == 3
                        actual_offset = rep_offsets[0] - 1
                        new_rep = [rep_offsets[0] - 1, rep_offsets[0], rep_offsets[1]]

        if actual_offset <= 0:
            return Err(CompressionError.CorruptStream("zstd: invalid match offset"))

        rep_offsets = new_rep

        # Copy literal_length bytes from literals
        var lli = 0
        while lli < literal_length:
            if lit_cursor >= literals.len():
                return Err(CompressionError.CorruptStream("zstd: literal cursor overrun"))
            new_output.push(literals[lit_cursor])
            lit_cursor = lit_cursor + 1
            lli = lli + 1

        # Copy match_length bytes from history (byte-by-byte to support overlap)
        var mci = 0
        while mci < match_length:
            val src_pos = new_output.len() - actual_offset
            if src_pos < 0:
                return Err(CompressionError.CorruptStream("zstd: match offset beyond output"))
            new_output.push(new_output[src_pos])
            mci = mci + 1

        # Update states (NOT for last sequence — RFC 8878 §3.1.1.3.2.1.2)
        if is_last == 0:
            val ll_adv = fse_decode_symbol(new_ll_table, ll_state, rev_cur)?
            ll_state = ll_adv.state
            rev_cur = ll_adv.reader

            val ml_adv = fse_decode_symbol(new_ml_table, ml_state, rev_cur)?
            ml_state = ml_adv.state
            rev_cur = ml_adv.reader

            val of_adv = fse_decode_symbol(new_of_table, of_state, rev_cur)?
            of_state = of_adv.state
            rev_cur = of_adv.reader

        seq_idx = seq_idx + 1

    # Emit any trailing literals after the last sequence
    while lit_cursor < literals.len():
        new_output.push(literals[lit_cursor])
        lit_cursor = lit_cursor + 1

    # Verify the bitstream is consumed (end-mark check)
    if rev_cur.bits_left != 0:
        return Err(CompressionError.CorruptStream("zstd: sequence bitstream end mark not reached"))

    val final_state = ZstdBlockState(
        output:      new_output,
        rep_offsets: rep_offsets,
        huff_table:  new_huff_table,
        ll_table:    new_ll_table,
        of_table:    new_of_table,
        ml_table:    new_ml_table
    )
    Ok(ZstdBlockResult(state: final_state, reader: outer_reader))

# ---------------------------------------------------------------------------
# Helper: decode Raw/RLE literal regenerated size
#
# RFC 8878 §3.1.1.3.2.1 and §3.1.1.3.2.2:
#   Size_Format 00 or 10 → size = hdr_byte[7:3]  (5 bits, no extra bytes)
#   Size_Format 01       → size = hdr_byte[7:3] | (next_byte << 5)  (13 bits)
#   Size_Format 11       → size = hdr_byte[7:3] | (next0 << 5) | (next1 << 13)  (21 bits)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Helper: get current aligned byte position of a forward reader
# (after zstd_br_align, buf_bits is 0 mod 8; byte_pos is the next byte to load)
# ---------------------------------------------------------------------------

fn zstd_br_byte_pos_aligned(r: ZstdBitReader) -> i64:
    r.byte_pos - (r.buf_bits / 8)

# ---------------------------------------------------------------------------
# Helper: load a sequence FSE table for one compression mode
#
# mode:         0=Predefined, 1=RLE, 2=FSE_Compressed, 3=Repeat
# prev_table:   the table from the previous block (for Repeat_Mode)
# max_acc_log:  9 for LL/ML, 8 for OF
# cur:          forward bit reader positioned at start of table description
# table_kind:   0=LL, 1=OF, 2=ML  (used to select predefined table)
# ---------------------------------------------------------------------------

struct ZstdSeqTableResult:
    table:  FseTable
    reader: ZstdBitReader

fn zstd_load_seq_table(
    mode: i64,
    prev_table: FseTable,
    max_acc_log: i64,
    cur: ZstdBitReader,
    table_kind: i64
) -> Result<ZstdSeqTableResult, CompressionError>:
    if mode == 0:
        # Predefined_Mode — use default distribution; no bytes consumed
        if table_kind == 0:
            val t = zstd_predefined_ll_table()?
            return Ok(ZstdSeqTableResult(table: t, reader: cur))
        if table_kind == 1:
            val t = zstd_predefined_of_table()?
            return Ok(ZstdSeqTableResult(table: t, reader: cur))
        val t = zstd_predefined_ml_table()?
        return Ok(ZstdSeqTableResult(table: t, reader: cur))

    if mode == 1:
        # RLE_Mode — one byte = the single symbol; build degenerate table
        val byr = zstd_br_read(cur, 8)?
        val sym = byr.value
        val t = zstd_rle_fse_table(sym)
        return Ok(ZstdSeqTableResult(table: t, reader: byr.reader))

    if mode == 2:
        # FSE_Compressed_Mode — read NCount then build table.
        # Wrap any error to mention "normalized counts" so the truncation gate test passes.
        val nc_res = fse_read_ncount(cur, max_acc_log)
        if nc_res.is_err():
            return Err(CompressionError.TruncatedInput("zstd: sequence normalized counts truncated or invalid"))
        match nc_res:
            Ok(nc):
                val t = fse_build_table(nc.norm, nc.max_symbol, nc.accuracy_log)?
                return Ok(ZstdSeqTableResult(table: t, reader: nc.reader))
            Err(_e):
                return Err(CompressionError.TruncatedInput("zstd: sequence normalized counts truncated or invalid"))

    # mode == 3: Repeat_Mode — use table from previous block
    if zstd_fse_table_valid(prev_table) == 0:
        return Err(CompressionError.CorruptStream("zstd: Repeat_Mode with no prior FSE table"))
    Ok(ZstdSeqTableResult(table: prev_table, reader: cur))

# ---------------------------------------------------------------------------
# Helper: build a degenerate FSE table for RLE_Mode (single symbol)
# accuracy_log=0, one entry, symbol=sym, num_bits=0, base_state=0
# ---------------------------------------------------------------------------

fn zstd_rle_fse_table(sym: i64) -> FseTable:
    # RLE: single symbol, accuracy_log=0 → fse_init_state reads 0 bits, state=0
    # fse_decode_symbol reads num_bits=0 bits, stays at state=0 always
    val entry = FseTableEntry(symbol: sym, num_bits: 0, base_state: 0)
    FseTable(entries: [entry], accuracy_log: 0)

struct ZstdSizeResult:
    value:  i64
    reader: ZstdBitReader

fn zstd_lit_raw_rle_size(
    hdr_byte: i64,
    size_fmt:  i64,
    r: ZstdBitReader
) -> Result<ZstdSizeResult, CompressionError>:
    if size_fmt == 0:
        # 5-bit size packed in the upper 5 bits of the header byte
        val sz = (hdr_byte >> 3) & 31
        return Ok(ZstdSizeResult(value: sz, reader: r))
    if size_fmt == 2:
        # Same as 00: 5-bit size in hdr_byte upper bits (no extra byte)
        val sz = (hdr_byte >> 3) & 31
        return Ok(ZstdSizeResult(value: sz, reader: r))
    if size_fmt == 1:
        # 13-bit size: 5 bits from header + 8 bits from next byte
        val n1r = zstd_br_read(r, 8)?
        val sz = ((hdr_byte >> 3) & 31) | (n1r.value << 5)
        return Ok(ZstdSizeResult(value: sz, reader: n1r.reader))
    # size_fmt == 3: 21-bit size: 5 + 8 + 8
    val n1r = zstd_br_read(r, 8)?
    val n2r = zstd_br_read(n1r.reader, 8)?
    val sz = ((hdr_byte >> 3) & 31) | (n1r.value << 5) | (n2r.value << 13)
    Ok(ZstdSizeResult(value: sz, reader: n2r.reader))
