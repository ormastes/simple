# zstd/decoder.spl — Top-level Zstd decompressor (RFC 8878)
#
# Supported:
#   - Standard Zstd frame (magic 0xFD2FB528)
#   - Skippable frames (skipped)
#   - Chained frames
#   - Raw blocks and RLE blocks (fully)
#   - Compressed blocks: raw literals + RLE literals + zero-sequence path
#   - Window descriptor + FCS parsing
#
# Not supported (returns Err(Unsupported)):
#   - Dictionary frames (dict_id != 0)
#   - XXH64 content checksum verification
#   - Huffman-compressed literals (type 10/11)
#   - FSE-encoded sequences (any compressed block with sequences > 0)

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.zstd.bit_reader.{
    ZstdBitReader,
    zstd_br_init, zstd_br_read, zstd_br_read_u32
}
use std.nogc_sync_mut.compression.zstd.frame.{
    ZstdFrameHeader, ZstdBlockHeader, ZstdMagicResult,
    ZSTD_BLOCK_RAW, ZSTD_BLOCK_RLE, ZSTD_BLOCK_COMPRESSED,
    zstd_parse_magic, zstd_parse_frame_header, zstd_parse_block_header,
    zstd_skip_bytes
}
use std.nogc_sync_mut.compression.zstd.blocks.{
    ZstdBlockState, ZstdBlockResult,
    zstd_initial_block_state, zstd_decode_block
}

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

# Decompress a Zstd-encoded byte slice.
# Returns Ok(decompressed_bytes) or Err(CompressionError).
fn zstd_decode(input: [u8]) -> Result<[u8], CompressionError>:
    if input.len() == 0:
        return Err(CompressionError.TruncatedInput("zstd empty input"))

    var r = zstd_br_init(input)
    var all_output: [u8] = []

    # Outer loop: process all chained frames
    while zstd_br_has_bytes(r, 4):
        val magic_res = zstd_parse_magic(r)?
        if magic_res.is_skippable:
            # Skip skippable frame payload
            val skip_r = zstd_skip_bytes(magic_res.reader, magic_res.skip_size)?
            r = skip_r
        else:
            r = magic_res.reader
            val fh = zstd_parse_frame_header(r)?
            r = fh.reader
            # Decode blocks
            var block_state = zstd_initial_block_state()
            while true:
                val bh = zstd_parse_block_header(r)?
                r = bh.reader
                val blk_res = zstd_decode_block(bh, block_state, r)?
                block_state = blk_res.state
                r = blk_res.reader
                if bh.last_block:
                    break
            # Skip content checksum (4 bytes) if present
            if fh.has_checksum:
                if zstd_br_has_bytes(r, 4):
                    val skip_cs = zstd_br_read_u32(r)?
                    r = skip_cs.reader
            # Collect output from this frame
            var fo = 0
            while fo < block_state.output.len():
                all_output.push(block_state.output[fo])
                fo = fo + 1

    Ok(all_output)

# Check if at least `n` bytes remain in the reader.
fn zstd_br_has_bytes(r: ZstdBitReader, n: i64) -> bool:
    val buffered = r.buf_bits / 8
    val pos = r.byte_pos - buffered
    pos + n <= r.data.len()
