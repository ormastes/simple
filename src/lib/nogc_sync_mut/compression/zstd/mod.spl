# zstd/mod.spl — public re-exports for the zstd module
#
# Usage:
#   use std.nogc_sync_mut.compression.zstd.{zstd_decode}
#   use std.nogc_sync_mut.compression.zstd.fse.{FseTable, fse_read_ncount, fse_build_table, fse_init_state, fse_decode_symbol}

use std.nogc_sync_mut.compression.zstd.decoder.{zstd_decode}
use std.nogc_sync_mut.compression.zstd.fse.{
    FseTableEntry, FseTable, FseNCountResult, FseSymbolResult,
    fse_read_ncount, fse_build_table, fse_init_state, fse_decode_symbol
}
