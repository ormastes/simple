# brotli/encoder.spl — RFC 7932 brotli encoder seed (uncompressed meta blocks)
#
# Emits valid brotli streams using only ISUNCOMPRESSED=1 meta blocks.  No
# LZ77, no Huffman / prefix codes — pure framing for round-trip compatibility
# with the existing decoder and HTTP `Content-Encoding: br` plumbing.
#
# Stream layout (RFC 7932 §9.1 + §3.5):
#   - WBITS prefix code (1 bit, value 0 ⇒ WBITS=16)
#   - One or more uncompressed meta blocks:
#       ISLAST       : 1 bit   = 0
#       MNIBBLES_code: 2 bits  = 0  (⇒ MNIBBLES=4, max payload 65536 bytes)
#       MLEN-1       : 16 bits (LSB-first)
#       ISUNCOMPRESSED: 1 bit  = 1
#       <pad to next byte boundary>
#       <raw payload bytes>
#   - Terminator empty last block:
#       ISLAST       : 1 bit   = 1
#       ISLASTEMPTY  : 1 bit   = 1
#       <pad to next byte boundary>
#
# Empty input collapses to just the WBITS=16 + terminator → bytes [0x06].

use std.nogc_sync_mut.compression.brotli.bit_writer.{
    BrotliBitWriter,
    brotli_bits_writer_init,
    brotli_bits_write,
    brotli_bits_pad_to_byte,
    brotli_bits_write_bytes,
    brotli_bits_writer_finish
}

# Maximum payload bytes per uncompressed meta-block when MNIBBLES_code = 0
# (MNIBBLES=4 nibbles = 16 bits for MLEN-1, so MLEN_max = 65536).
val BROTLI_UNCOMPRESSED_BLOCK_MAX = 65536

# Encode `data` as a brotli stream containing only uncompressed meta blocks.
# Always succeeds for any input length; returns the byte buffer.
fn brotli_encode_uncompressed(data: [u8]) -> [u8]:
    var w = brotli_bits_writer_init()

    # --- Stream header: WBITS = 16 (single 0 bit, RFC 7932 §9.1) ---
    w = brotli_bits_write(w, 0, 1)

    # --- Emit uncompressed meta blocks for the payload ---
    val total = data.len()
    var offset = 0
    while offset < total:
        val remaining = total - offset
        var chunk = remaining
        if chunk > BROTLI_UNCOMPRESSED_BLOCK_MAX:
            chunk = BROTLI_UNCOMPRESSED_BLOCK_MAX
        w = _emit_uncompressed_block(w, data, offset, chunk)
        offset = offset + chunk

    # --- Terminator: ISLAST=1, ISLASTEMPTY=1 ---
    w = brotli_bits_write(w, 1, 1)  # ISLAST
    w = brotli_bits_write(w, 1, 1)  # ISLASTEMPTY

    brotli_bits_writer_finish(w)

# Emit a single uncompressed meta block covering `data[offset..offset+chunk]`.
# `chunk` must be in 1..=BROTLI_UNCOMPRESSED_BLOCK_MAX.
fn _emit_uncompressed_block(w: BrotliBitWriter, data: [u8], offset: i64, chunk: i64) -> BrotliBitWriter:
    var out = w
    # ISLAST = 0
    out = brotli_bits_write(out, 0, 1)
    # MNIBBLES_code = 0 (⇒ MNIBBLES=4, 16-bit MLEN-1)
    out = brotli_bits_write(out, 0, 2)
    # MLEN-1 in 16 bits (LSB first), value range 0..65535
    val mlen_m1 = chunk - 1
    out = brotli_bits_write(out, mlen_m1, 16)
    # ISUNCOMPRESSED = 1
    out = brotli_bits_write(out, 1, 1)
    # Pad to byte boundary (RFC 7932 §3.5)
    out = brotli_bits_pad_to_byte(out)
    # Copy the raw payload slice
    val payload = _slice(data, offset, chunk)
    out = brotli_bits_write_bytes(out, payload)
    out

# Helper: copy `len` bytes starting at `offset` out of `data` into a new [u8].
# Simple has no native slice op visible to the encoder; use a copy loop.
fn _slice(data: [u8], offset: i64, len: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < len:
        out.push(data[offset + i])
        i = i + 1
    out
