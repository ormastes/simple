# brotli/bit_writer.spl — LSB-first forward bit writer for RFC 7932 brotli streams
#
# Mirrors bit_reader.spl: bits within a byte are packed LSB-first
# (first bit written occupies bit 0 of the byte).  RFC 7932 §1.2.

# Forward bit writer state.
# - bytes:    output buffer (whole bytes already committed)
# - buf:      pending bits not yet flushed to a byte (0..7 bits)
# - buf_bits: count of bits in `buf`
struct BrotliBitWriter:
    bytes: [u8]
    buf: i64
    buf_bits: i64

fn brotli_bits_writer_init() -> BrotliBitWriter:
    BrotliBitWriter(bytes: [], buf: 0, buf_bits: 0)

# Write `n` bits (1..32) of `value` into the stream, LSB first.
# Returns a new writer.  `value` is masked to `n` bits.
fn brotli_bits_write(w: BrotliBitWriter, value: i64, n: i64) -> BrotliBitWriter:
    if n <= 0:
        return w
    val mask = (1 << n) - 1
    val masked = value & mask
    var new_buf = w.buf | (masked << w.buf_bits)
    var new_bits = w.buf_bits + n
    var out = w.bytes
    while new_bits >= 8:
        val byte_val = (new_buf & 0xff).to_u8()
        out.push(byte_val)
        new_buf = new_buf >> 8
        new_bits = new_bits - 8
    BrotliBitWriter(bytes: out, buf: new_buf, buf_bits: new_bits)

# Pad with zero bits up to the next byte boundary (RFC 7932 §3.5 / §9.2).
# After ISUNCOMPRESSED=1, the meta-block header must be byte-aligned before
# the raw payload begins.
fn brotli_bits_pad_to_byte(w: BrotliBitWriter) -> BrotliBitWriter:
    if w.buf_bits == 0:
        return w
    val pad = 8 - w.buf_bits
    brotli_bits_write(w, 0, pad)

# Append `n` raw bytes to the (byte-aligned) writer.
# Caller must have padded with `brotli_bits_pad_to_byte` first.
fn brotli_bits_write_bytes(w: BrotliBitWriter, payload: [u8]) -> BrotliBitWriter:
    var out = w.bytes
    var i = 0
    while i < payload.len():
        out.push(payload[i])
        i = i + 1
    BrotliBitWriter(bytes: out, buf: w.buf, buf_bits: w.buf_bits)

# Finish: pad the final partial byte (if any) with zero bits and return the
# completed byte buffer.
fn brotli_bits_writer_finish(w: BrotliBitWriter) -> [u8]:
    val padded = brotli_bits_pad_to_byte(w)
    padded.bytes
