# brotli/decoder.spl — RFC 7932 brotli decoder (uncompressed meta blocks)
#
# Supported:
#   - WBITS = 16 (default, bit0 = 0 in stream header)
#   - WBITS = 9..15 (bit0=1, then N=1..7)
#   - Empty stream (ISLAST=1, ISLASTEMPTY=1)
#   - Uncompressed meta blocks (ISLAST=0, ISUNCOMPRESSED=1)
#   - Chained meta blocks (last block terminates with ISLAST=1, ISLASTEMPTY=1)
#
# Not supported (returns Err(UnsupportedFeature)):
#   - Compressed meta blocks (ISLAST=0, ISUNCOMPRESSED=0)
#   - ISLAST=1 non-empty compressed last block
#   - Metadata meta blocks (MNIBBLES=11)

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.brotli.bit_reader.{
    BrotliBitReader,
    BrotliBitsResult,
    BrotliBytesResult,
    brotli_bits_init,
    brotli_bits_read,
    brotli_bits_align_to_byte,
    brotli_bits_read_bytes
}

# Decode a brotli-compressed byte stream.
# Returns Ok(decompressed_bytes) or Err(CompressionError).
fn brotli_decode(input: [u8]) -> Result<[u8], CompressionError>:
    if input.len() == 0:
        return Err(CompressionError.TruncatedInput("brotli empty input"))

    var r = brotli_bits_init(input)

    # --- Stream header: WBITS ---
    val wbits_res = _brotli_read_wbits(r)
    if wbits_res.is_err():
        return Err(wbits_res.unwrap_err())
    val wbits_pair = wbits_res.unwrap()
    r = wbits_pair.reader
    # wbits_pair.value is WBITS (10..24); we accept any valid value.

    var output: [u8] = []

    # --- Meta-block loop ---
    while true:
        val block_res = _brotli_read_meta_block(r, output)
        if block_res.is_err():
            return Err(block_res.unwrap_err())
        val block_result = block_res.unwrap()
        r = block_result.reader
        output = block_result.output
        if block_result.is_last:
            break

    Ok(output)

# -------------------------------------------------------------------------
# Internal: WBITS prefix code (RFC 7932 §9.1)
# -------------------------------------------------------------------------
struct _WbitsResult:
    value: i64
    reader: BrotliBitReader

fn _brotli_read_wbits(r: BrotliBitReader) -> Result<_WbitsResult, CompressionError>:
    val b0_res = brotli_bits_read(r, 1)
    if b0_res.is_err():
        return Err(b0_res.unwrap_err())
    val b0 = b0_res.unwrap()
    if b0.value == 0:
        return Ok(_WbitsResult(value: 16, reader: b0.reader))
    # bit0=1: read 3 more bits N
    val n_res = brotli_bits_read(b0.reader, 3)
    if n_res.is_err():
        return Err(n_res.unwrap_err())
    val n = n_res.unwrap()
    if n.value != 0:
        # WBITS = 17 + N, but RFC says valid range is 10..24
        # N=1..7 -> WBITS = 18..24 for this branch
        # Actually RFC: if N!=0 then WBITS = 8 + N (giving 9..15)
        val wbits = 8 + n.value
        return Ok(_WbitsResult(value: wbits, reader: n.reader))
    # N=0: read 3 more bits M
    val m_res = brotli_bits_read(n.reader, 3)
    if m_res.is_err():
        return Err(m_res.unwrap_err())
    val m = m_res.unwrap()
    if m.value == 0:
        return Err(CompressionError.InvalidHeader("brotli reserved WBITS code (all zero extended)"))
    val wbits = 17 + m.value
    Ok(_WbitsResult(value: wbits, reader: m.reader))

# -------------------------------------------------------------------------
# Internal: one meta-block
# -------------------------------------------------------------------------
struct _MetaBlockResult:
    output: [u8]
    reader: BrotliBitReader
    is_last: bool

fn _brotli_read_meta_block(r: BrotliBitReader, output: [u8]) -> Result<_MetaBlockResult, CompressionError>:
    # ISLAST: 1 bit
    val islast_res = brotli_bits_read(r, 1)
    if islast_res.is_err():
        return Err(islast_res.unwrap_err())
    val islast = islast_res.unwrap().value
    var r2 = islast_res.unwrap().reader

    if islast == 1:
        # ISLASTEMPTY: 1 bit
        val ile_res = brotli_bits_read(r2, 1)
        if ile_res.is_err():
            return Err(ile_res.unwrap_err())
        val ile = ile_res.unwrap().value
        r2 = ile_res.unwrap().reader
        if ile == 1:
            # Empty last block — stream ends
            return Ok(_MetaBlockResult(output: output, reader: r2, is_last: true))
        # Non-empty last block => compressed, not supported
        return Err(CompressionError.UnsupportedFeature("brotli compressed last meta block"))

    # ISLAST=0: read MNIBBLES (2 bits)
    val mnib_res = brotli_bits_read(r2, 2)
    if mnib_res.is_err():
        return Err(mnib_res.unwrap_err())
    val mnibbles_code = mnib_res.unwrap().value
    r2 = mnib_res.unwrap().reader

    if mnibbles_code == 3:
        # Metadata meta-block (MNIBBLES=0 / code=11 = 3 in 2 bits)
        return Err(CompressionError.UnsupportedFeature("brotli metadata meta block"))

    # MNIBBLES = 4 + mnibbles_code (yields 4, 5, or 6 nibbles = 16/20/24 bits for MLEN-1)
    val mnibbles = 4 + mnibbles_code
    val mlen_bits = mnibbles * 4
    val mlen_m1_res = brotli_bits_read(r2, mlen_bits)
    if mlen_m1_res.is_err():
        return Err(mlen_m1_res.unwrap_err())
    val mlen_m1 = mlen_m1_res.unwrap().value
    r2 = mlen_m1_res.unwrap().reader
    val mlen = mlen_m1 + 1

    if mlen <= 0:
        return Err(CompressionError.CorruptStream("brotli MLEN zero after decode"))

    # ISUNCOMPRESSED: 1 bit (only present when ISLAST=0)
    val isu_res = brotli_bits_read(r2, 1)
    if isu_res.is_err():
        return Err(isu_res.unwrap_err())
    val isuncompressed = isu_res.unwrap().value
    r2 = isu_res.unwrap().reader

    if isuncompressed == 0:
        return Err(CompressionError.UnsupportedFeature("brotli compressed meta block"))

    # Align to byte boundary, then read mlen raw bytes
    r2 = brotli_bits_align_to_byte(r2)
    val raw_res = brotli_bits_read_bytes(r2, mlen)
    if raw_res.is_err():
        return Err(raw_res.unwrap_err())
    val raw = raw_res.unwrap()
    r2 = raw.reader

    # Append raw bytes to output
    var new_output = output
    var i = 0
    while i < raw.bytes.len():
        new_output.push(raw.bytes[i])
        i = i + 1

    Ok(_MetaBlockResult(output: new_output, reader: r2, is_last: false))
