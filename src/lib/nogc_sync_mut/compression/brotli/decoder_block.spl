# brotli/decoder_block.spl — Distance decoding and compressed meta-block decode.
# RFC 7932 §4, §9.2

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.brotli.bit_reader.{
    BrotliBitReader,
    brotli_bits_read
}
use std.nogc_sync_mut.compression.brotli.decoder_tables.{
    _IcpDecomp, _decompose_icp,
    _insert_length_base, _insert_length_extra,
    _copy_length_base, _copy_length_extra
}
use std.nogc_sync_mut.compression.brotli.decoder_huffman.{
    _SimplePrefix, _SymReadResult,
    _read_simple_prefix, _decode_symbol
}

# -------------------------------------------------------------------------
# Internal: VarLenUint8 (RFC 7932 §9.2)
# -------------------------------------------------------------------------
struct _IntReaderResult:
    value: i64
    reader: BrotliBitReader

fn _read_varlen_uint8(r: BrotliBitReader) -> Result<_IntReaderResult, CompressionError>:
    val b0_res = brotli_bits_read(r, 1)
    if b0_res.is_err():
        return Err(b0_res.unwrap_err())
    val b0 = b0_res.unwrap()
    if b0.value == 0:
        return Ok(_IntReaderResult(value: 0, reader: b0.reader))
    val n_res = brotli_bits_read(b0.reader, 3)
    if n_res.is_err():
        return Err(n_res.unwrap_err())
    val n = n_res.unwrap()
    if n.value == 0:
        return Ok(_IntReaderResult(value: 1, reader: n.reader))
    val extra_res = brotli_bits_read(n.reader, n.value)
    if extra_res.is_err():
        return Err(extra_res.unwrap_err())
    val extra = extra_res.unwrap()
    val value = (1 << n.value) + extra.value
    Ok(_IntReaderResult(value: value, reader: extra.reader))

# -------------------------------------------------------------------------
# Internal: distance code decoding (RFC 7932 §4) for NPOSTFIX=0, NDIRECT=0.
# -------------------------------------------------------------------------
struct _DistanceResult:
    distance: i64
    update_ring: bool
    reader: BrotliBitReader

fn _ring_at(ring: [i64], idx: i64, offset: i64) -> i64:
    val pos = (idx - offset) & 3
    ring[pos]

fn _decode_distance(sym: i64, r: BrotliBitReader, ring: [i64], ring_idx: i64) -> Result<_DistanceResult, CompressionError>:
    if sym < 0:
        return Err(CompressionError.CorruptStream("brotli negative distance symbol"))
    if sym <= 3:
        val d = _ring_at(ring, ring_idx, sym)
        return Ok(_DistanceResult(distance: d, update_ring: false, reader: r))
    if sym <= 15:
        var ring_pick = 0
        var delta = 0
        if sym <= 9:
            ring_pick = 0  # R[3] = ring[ring_idx]
            val k = sym - 4
            val mag = (k >> 1) + 1
            if (k & 1) == 0:
                delta = -mag
            else:
                delta = mag
        else:
            ring_pick = 1  # R[2] = ring[ring_idx - 1]
            val k = sym - 10
            val mag = (k >> 1) + 1
            if (k & 1) == 0:
                delta = -mag
            else:
                delta = mag
        val base = _ring_at(ring, ring_idx, ring_pick)
        val d = base + delta
        if d <= 0:
            return Err(CompressionError.CorruptStream("brotli ring distance non-positive"))
        return Ok(_DistanceResult(distance: d, update_ring: true, reader: r))
    # sym in 16..63: regular distance with extra bits.
    if sym > 63:
        return Err(CompressionError.CorruptStream("brotli distance symbol out of range"))
    val s16 = sym - 16
    val ndistbits = 1 + (s16 >> 1)
    val hcode = s16
    val offset = ((2 + (hcode & 1)) << ndistbits) - 4
    val de_res = brotli_bits_read(r, ndistbits)
    if de_res.is_err():
        return Err(de_res.unwrap_err())
    val de = de_res.unwrap()
    val distance = offset + de.value + 1
    if distance <= 0:
        return Err(CompressionError.CorruptStream("brotli regular distance non-positive"))
    Ok(_DistanceResult(distance: distance, update_ring: true, reader: de.reader))

# -------------------------------------------------------------------------
# Internal: compressed meta block result
# -------------------------------------------------------------------------
struct _MetaBlockResult:
    output: [u8]
    reader: BrotliBitReader
    is_last: bool

# -------------------------------------------------------------------------
# Internal: compressed meta block (literal-only tier) RFC 7932 §9.2
# -------------------------------------------------------------------------
fn _decode_compressed_block(r0: BrotliBitReader, output: [u8], mlen: i64, is_last: bool) -> Result<_MetaBlockResult, CompressionError>:
    var r = r0

    # NBLTYPESL/I/D: each is VarLenUint8 + 1 (so VarLen=0 -> NBLTYPES=1).
    val nl_res = _read_varlen_uint8(r)
    if nl_res.is_err():
        return Err(nl_res.unwrap_err())
    val nl = nl_res.unwrap()
    r = nl.reader
    if nl.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NBLTYPESL > 1 not supported"))

    val ni_res = _read_varlen_uint8(r)
    if ni_res.is_err():
        return Err(ni_res.unwrap_err())
    val ni = ni_res.unwrap()
    r = ni.reader
    if ni.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NBLTYPESI > 1 not supported"))

    val nd_res = _read_varlen_uint8(r)
    if nd_res.is_err():
        return Err(nd_res.unwrap_err())
    val nd = nd_res.unwrap()
    r = nd.reader
    if nd.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NBLTYPESD > 1 not supported"))

    # NPOSTFIX (2 bits), NDIRECT (4 bits)
    val np_res = brotli_bits_read(r, 2)
    if np_res.is_err():
        return Err(np_res.unwrap_err())
    val np = np_res.unwrap()
    r = np.reader
    if np.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NPOSTFIX > 0 not supported"))

    val ndi_res = brotli_bits_read(r, 4)
    if ndi_res.is_err():
        return Err(ndi_res.unwrap_err())
    val ndi = ndi_res.unwrap()
    r = ndi.reader
    if ndi.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NDIRECT > 0 not supported"))

    # CMODE[0] (2 bits per literal block type).
    val cm_res = brotli_bits_read(r, 2)
    if cm_res.is_err():
        return Err(cm_res.unwrap_err())
    val cm = cm_res.unwrap()
    r = cm.reader
    if cm.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli context mode != 0"))

    # NTREESL (VarLenUint8 + 1)
    val ntl_res = _read_varlen_uint8(r)
    if ntl_res.is_err():
        return Err(ntl_res.unwrap_err())
    val ntl = ntl_res.unwrap()
    r = ntl.reader
    if ntl.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NTREESL > 1 not supported"))

    # Literal prefix tree (alphabet 256 -> 8 bits per symbol).
    val lit_res = _read_simple_prefix(r, 8)
    if lit_res.is_err():
        return Err(lit_res.unwrap_err())
    val lit_tree = lit_res.unwrap()
    r = lit_tree.reader

    # Insert-and-copy prefix tree (alphabet 704 -> 10 bits).
    val icp_res = _read_simple_prefix(r, 10)
    if icp_res.is_err():
        return Err(icp_res.unwrap_err())
    val icp_tree = icp_res.unwrap()
    r = icp_tree.reader

    # NTREESD (VarLenUint8 + 1)
    val ntd_res = _read_varlen_uint8(r)
    if ntd_res.is_err():
        return Err(ntd_res.unwrap_err())
    val ntd = ntd_res.unwrap()
    r = ntd.reader
    if ntd.value != 0:
        return Err(CompressionError.UnsupportedFeature("brotli NTREESD > 1 not supported"))

    # Distance prefix tree (alphabet 64 -> 6 bits).
    val dist_res = _read_simple_prefix(r, 6)
    if dist_res.is_err():
        return Err(dist_res.unwrap_err())
    val dist_tree = dist_res.unwrap()
    r = dist_tree.reader

    # Distance ring buffer (RFC 7932 §4): initialized to (16, 15, 11, 4).
    var dist_ring: [i64] = []
    dist_ring.push(16)
    dist_ring.push(15)
    dist_ring.push(11)
    dist_ring.push(4)
    var dist_ring_idx = 3

    # Command loop
    var out = output
    val target = out.len() + mlen
    while out.len() < target:
        # Decode one ICP symbol
        val ic_res = _decode_symbol(icp_tree, r)
        if ic_res.is_err():
            return Err(ic_res.unwrap_err())
        val ic = ic_res.unwrap()
        r = ic.reader
        val decomp = _decompose_icp(ic.symbol)

        # Compute insert_length
        val ins_base = _insert_length_base(decomp.ins_code)
        val ins_extra_bits = _insert_length_extra(decomp.ins_code)
        var insert_length = ins_base
        if ins_extra_bits > 0:
            val ie_res = brotli_bits_read(r, ins_extra_bits)
            if ie_res.is_err():
                return Err(ie_res.unwrap_err())
            val ie = ie_res.unwrap()
            insert_length = insert_length + ie.value
            r = ie.reader

        # Compute copy_length (still need extra bits to keep bitstream aligned)
        val cop_base = _copy_length_base(decomp.cop_code)
        val cop_extra_bits = _copy_length_extra(decomp.cop_code)
        var copy_length = cop_base
        if cop_extra_bits > 0:
            val ce_res = brotli_bits_read(r, cop_extra_bits)
            if ce_res.is_err():
                return Err(ce_res.unwrap_err())
            val ce = ce_res.unwrap()
            copy_length = copy_length + ce.value
            r = ce.reader

        # Emit insert_length literals
        var k = 0
        while k < insert_length:
            if out.len() >= target:
                return Err(CompressionError.CorruptStream("brotli insert exceeds MLEN"))
            val ls_res = _decode_symbol(lit_tree, r)
            if ls_res.is_err():
                return Err(ls_res.unwrap_err())
            val ls = ls_res.unwrap()
            out.push((ls.symbol & 0xff).to_u8())
            r = ls.reader
            k = k + 1

        # If we've reached MLEN exactly, the copy is omitted (RFC §9.2).
        if out.len() == target:
            break

        # Real copy: requires a distance.
        var distance = 0
        if decomp.has_distance:
            val ds_res = _decode_symbol(dist_tree, r)
            if ds_res.is_err():
                return Err(ds_res.unwrap_err())
            val ds = ds_res.unwrap()
            r = ds.reader
            val dist_decoded = _decode_distance(ds.symbol, r, dist_ring, dist_ring_idx)
            if dist_decoded.is_err():
                return Err(dist_decoded.unwrap_err())
            val dd = dist_decoded.unwrap()
            distance = dd.distance
            r = dd.reader
            if dd.update_ring:
                dist_ring_idx = (dist_ring_idx + 1) & 3
                dist_ring[dist_ring_idx] = distance
        else:
            distance = dist_ring[dist_ring_idx]

        if distance <= 0:
            return Err(CompressionError.CorruptStream("brotli zero/negative distance"))
        if distance > out.len():
            return Err(CompressionError.UnsupportedFeature("brotli static dictionary distance"))

        # Emit copy_length bytes from the sliding window.
        var c = 0
        val src_start = out.len() - distance
        while c < copy_length:
            if out.len() >= target:
                return Err(CompressionError.CorruptStream("brotli copy exceeds MLEN"))
            val src_idx = src_start + c
            val byte = out[src_idx]
            out.push(byte)
            c = c + 1

    Ok(_MetaBlockResult(output: out, reader: r, is_last: is_last))
