# Huffman Coding and Decoding
#
# Purpose: Huffman tree construction and coding operations
#
# Contains:
# - Huffman tree node creation
# - Frequency table building
# - Huffman tree construction
# - Code table generation
# - Data encoding/decoding
# - Fixed Huffman codes (DEFLATE standard)
#
# Huffman tree node: (symbol, frequency, left, right)
# - symbol: character or nil for internal nodes
# - frequency: occurrence count
# - left, right: child nodes

use std.nogc_sync_mut.compression.gzip.types.{
    MAX_BITS, MAX_LITERALS, MAX_DISTANCES
}

# =============================================================================
# HUFFMAN CODING
# =============================================================================

# Create Huffman leaf node
fn huffman_leaf(symbol, freq):
    return [symbol, freq, nil, nil]

# Create Huffman internal node
fn huffman_internal(freq, left, right):
    return [nil, freq, left, right]

# Get node frequency
fn huffman_node_freq(node):
    if node == nil:
        return 0
    return node[1]

# Check if node is leaf
fn huffman_node_is_leaf(node):
    if node == nil:
        return false
    return node[2] == nil

# Build frequency table from tokens
fn huffman_freq_table(tokens):
    if tokens == nil:
        return []

    var freqs = []
    var i = 0

    loop:
        if i >= tokens.len():
            break

        val token = tokens[i]
        val token_type = token[0]
        val value = token[1]

        # Count symbol frequency
        var symbol = value
        if token_type == 1:
            # For matches, use special code (256+)
            symbol = 256 + (value % 30)  # Distance codes

        var found = false
        var j = 0
        var new_freqs = []

        loop:
            if j >= freqs.len():
                break

            val entry = freqs[j]
            val sym = entry[0]
            val count = entry[1]

            if sym == symbol:
                new_freqs.push([sym, count + 1])
                found = true
            else:
                new_freqs.push([sym, count])

            j = j + 1

        if found:
            freqs = new_freqs
        else:
            freqs.push([symbol, 1])

        i = i + 1

    return freqs

# Build Huffman tree from frequency table
fn huffman_build_tree(freqs):
    if freqs == nil:
        return nil

    if freqs.len() == 0:
        return nil

    # Create leaf nodes
    var nodes = []
    var i = 0

    loop:
        if i >= freqs.len():
            break

        val entry = freqs[i]
        val symbol = entry[0]
        val count = entry[1]
        nodes.push(huffman_leaf(symbol, count))

        i = i + 1

    # Build tree bottom-up
    loop:
        if nodes.len() <= 1:
            break

        # Find two minimum frequency nodes
        var min1_idx = huffman_find_min_node(nodes, -1)
        val min1 = nodes[min1_idx]
        nodes = huffman_remove_node(nodes, min1_idx)

        var min2_idx = huffman_find_min_node(nodes, -1)
        val min2 = nodes[min2_idx]
        nodes = huffman_remove_node(nodes, min2_idx)

        # Create parent node
        val combined_freq = huffman_node_freq(min1) + huffman_node_freq(min2)
        val parent = huffman_internal(combined_freq, min1, min2)
        nodes.push(parent)

    if nodes.len() > 0:
        return nodes[0]

    return nil

# Find minimum frequency node index
fn huffman_find_min_node(nodes, exclude_idx):
    if nodes == nil:
        return -1

    var min_idx = -1
    var min_freq = 999999999

    var i = 0
    loop:
        if i >= nodes.len():
            break

        if i != exclude_idx:
            val freq = huffman_node_freq(nodes[i])
            if freq < min_freq:
                min_freq = freq
                min_idx = i

        i = i + 1

    return min_idx

# Remove node at index
fn huffman_remove_node(nodes, idx):
    if nodes == nil:
        return []

    var result = []
    var i = 0

    loop:
        if i >= nodes.len():
            break

        if i != idx:
            result.push(nodes[i])

        i = i + 1

    return result

# Generate Huffman code table from tree
# Returns: array of (symbol, code_bits, code_length)
fn huffman_generate_codes(tree):
    if tree == nil:
        return []

    var codes = []
    codes = huffman_traverse_tree(tree, 0, 0, codes)
    return codes

# Traverse tree to generate codes
fn huffman_traverse_tree(node, code_bits, code_len, codes):
    if node == nil:
        return codes

    if huffman_node_is_leaf(node):
        val symbol = node[0]
        var result = codes + [[symbol, code_bits, code_len]]
        return result

    val left = node[2]
    val right = node[3]

    # Left child: append 0
    var new_codes = huffman_traverse_tree(left, code_bits << 1, code_len + 1, codes)

    # Right child: append 1
    new_codes = huffman_traverse_tree(right, (code_bits << 1) | 1, code_len + 1, new_codes)

    return new_codes

# Look up Huffman code for symbol
fn huffman_lookup(codes, symbol):
    if codes == nil:
        return nil

    var i = 0
    loop:
        if i >= codes.len():
            break

        val entry = codes[i]
        val sym = entry[0]

        if sym == symbol:
            return [entry[1], entry[2]]

        i = i + 1

    return nil

# Encode data using Huffman codes
fn huffman_encode(data, codes):
    if data == nil:
        return []

    var bits = []
    var i = 0

    loop:
        if i >= data.len():
            break

        val symbol = data[i]
        val code_info = huffman_lookup(codes, symbol)

        if code_info != nil:
            val code_bits = code_info[0]
            val code_len = code_info[1]

            # Append bits
            var j = code_len - 1
            loop:
                if j < 0:
                    break

                val bit = (code_bits >> j) & 1
                bits.push(bit)

                j = j - 1

        i = i + 1

    return bits

# Decode Huffman encoded bits
fn huffman_decode(bits, tree):
    if bits == nil:
        return []

    if tree == nil:
        return []

    var result = []
    var current = tree
    var i = 0

    loop:
        if i >= bits.len():
            break

        val bit = bits[i]

        if bit == 0:
            current = current[2]  # Go left
        else:
            current = current[3]  # Go right

        if huffman_node_is_leaf(current):
            val symbol = current[0]
            result.push(symbol)
            current = tree  # Reset to root

        i = i + 1

    return result

# =============================================================================
# FIXED HUFFMAN CODES (DEFLATE Standard)
# =============================================================================

# Generate fixed Huffman codes (DEFLATE RFC 1951)
fn deflate_fixed_huffman():
    var codes = []

    # Literal/length codes 0-143: 8 bits (00110000 - 10111111)
    var i = 0
    loop:
        if i > 143:
            break
        codes.push([i, 0b00110000 + i, 8])
        i = i + 1

    # Literal/length codes 144-255: 9 bits (110010000 - 111111111)
    i = 144
    loop:
        if i > 255:
            break
        codes.push([i, 0b110010000 + (i - 144), 9])
        i = i + 1

    # Literal/length codes 256-279: 7 bits (0000000 - 0010111)
    i = 256
    loop:
        if i > 279:
            break
        codes.push([i, i - 256, 7])
        i = i + 1

    # Literal/length codes 280-287: 8 bits (11000000 - 11000111)
    i = 280
    loop:
        if i > 287:
            break
        codes.push([i, 0b11000000 + (i - 280), 8])
        i = i + 1

    return codes

# Generate fixed distance codes
fn deflate_fixed_distances():
    var codes = []

    # All distance codes are 5 bits
    var i = 0
    loop:
        if i >= 30:
            break

        codes.push([i, i, 5])

        i = i + 1

    return codes

# =============================================================================
# BITSTREAM — LSB-first byte packing (RFC 1951 §3.1.1)
#
# State: [bytes: [u8], bit_buf: i64, bit_count: i64]
#   bytes     — fully packed output bytes so far
#   bit_buf   — bits waiting to be flushed (LSB = oldest bit waiting)
#   bit_count — how many valid bits are in bit_buf
# =============================================================================

# Create a new empty BitStream writer
fn bitstream_new():
    var bytes: [u8] = []
    return [bytes, 0, 0]

# Write `n` bits of `value` LSB-first (for non-Huffman values: BFINAL, BTYPE, extra bits)
fn bitstream_write_bits_lsb(bs, value, n):
    var bytes   = bs[0]
    var bit_buf = bs[1]
    var bit_cnt = bs[2]

    var v = value
    var remaining = n
    loop:
        if remaining <= 0:
            break
        val bit = v & 1
        bit_buf = bit_buf | (bit << bit_cnt)
        bit_cnt = bit_cnt + 1
        v = v >> 1
        remaining = remaining - 1
        if bit_cnt == 8:
            bytes.push(bit_buf.to_u8())
            bit_buf = 0
            bit_cnt = 0

    return [bytes, bit_buf, bit_cnt]

# Write `n`-bit Huffman code `code` MSB-first (packed LSB into bytes per RFC 1951)
fn bitstream_write_huffman(bs, code, n):
    var bytes   = bs[0]
    var bit_buf = bs[1]
    var bit_cnt = bs[2]

    # emit MSB first: bit (n-1) down to bit 0
    var i = n - 1
    loop:
        if i < 0:
            break
        val bit = (code >> i) & 1
        bit_buf = bit_buf | (bit << bit_cnt)
        bit_cnt = bit_cnt + 1
        i = i - 1
        if bit_cnt == 8:
            bytes.push(bit_buf.to_u8())
            bit_buf = 0
            bit_cnt = 0

    return [bytes, bit_buf, bit_cnt]

# Flush remaining bits (zero-pad to byte boundary), return final [u8] byte array
fn bitstream_finish(bs):
    var bytes   = bs[0]
    var bit_buf = bs[1]
    var bit_cnt = bs[2]

    if bit_cnt > 0:
        bytes.push(bit_buf.to_u8())

    return bytes

# =============================================================================
# BITSTREAM READER — LSB-first (RFC 1951 §3.1.1)
#
# State: [data: [u8], byte_pos: i64, bit_pos: i64]
#   data     — input byte array
#   byte_pos — current byte index
#   bit_pos  — bit within current byte (0 = LSB)
# =============================================================================

# Create a new BitStream reader over a byte array
fn bitstream_reader_new(data):
    return [data, 0, 0]

# Read `n` bits LSB-first (non-Huffman values: BFINAL, BTYPE, extra bits)
# Returns [value, new_reader_state]
fn bitstream_read_bits_lsb(br, n):
    var data     = br[0]
    var byte_pos = br[1]
    var bit_pos  = br[2]

    var result = 0
    var shift = 0
    var remaining = n
    loop:
        if remaining <= 0:
            break
        if byte_pos >= data.len():
            break
        val cur_byte = data[byte_pos].to_i64()
        val bit = (cur_byte >> bit_pos) & 1
        result = result | (bit << shift)
        shift = shift + 1
        bit_pos = bit_pos + 1
        if bit_pos == 8:
            bit_pos = 0
            byte_pos = byte_pos + 1
        remaining = remaining - 1

    return [result, [data, byte_pos, bit_pos]]

# Read one Huffman code bit-by-bit (MSB-first encoding, packed LSB-first into bytes).
# Caller accumulates bits from calls to bitstream_read_one_bit.
# Returns [bit_value, new_reader_state]
fn bitstream_read_one_bit(br):
    var data     = br[0]
    var byte_pos = br[1]
    var bit_pos  = br[2]

    if byte_pos >= data.len():
        return [0, [data, byte_pos, bit_pos]]

    val cur_byte = data[byte_pos].to_i64()
    val bit = (cur_byte >> bit_pos) & 1

    bit_pos = bit_pos + 1
    if bit_pos == 8:
        bit_pos = 0
        byte_pos = byte_pos + 1

    return [bit, [data, byte_pos, bit_pos]]

# Get current byte/bit position for block-boundary tracking
fn bitstream_reader_pos(br):
    return [br[1], br[2]]

# =============================================================================
# FIXED HUFFMAN DECODE TABLES (symbol → code lookup by code value+length)
# =============================================================================

# Decode a fixed-Huffman literal/length symbol from the bit stream.
# Reads 7 bits first (codes 256..279), then 8 bits (0..143, 280..287), then 9 bits (144..255).
# Returns [symbol, new_reader_state]  or  [-1, new_reader_state] on error.
fn deflate_fixed_decode_litlen(br):
    # Read 7 bits (MSB-first accumulation)
    var acc = 0
    var cur_br = br
    var i = 0
    loop:
        if i >= 7:
            break
        val ret = bitstream_read_one_bit(cur_br)
        val bit = ret[0]
        cur_br = ret[1]
        acc = (acc << 1) | bit
        i = i + 1

    # 7-bit codes: 0000000..0010111 → symbols 256..279
    if acc >= 0 and acc <= 23:
        return [256 + acc, cur_br]

    # Need one more bit (8 bits total)
    val ret8 = bitstream_read_one_bit(cur_br)
    val bit8 = ret8[0]
    cur_br = ret8[1]
    val acc8 = (acc << 1) | bit8

    # 8-bit codes 00110000..10111111 → symbols 0..143
    if acc8 >= 0b00110000 and acc8 <= 0b10111111:
        return [acc8 - 0b00110000, cur_br]

    # 8-bit codes 11000000..11000111 → symbols 280..287
    if acc8 >= 0b11000000 and acc8 <= 0b11000111:
        return [280 + (acc8 - 0b11000000), cur_br]

    # Need one more bit (9 bits total)
    val ret9 = bitstream_read_one_bit(cur_br)
    val bit9 = ret9[0]
    cur_br = ret9[1]
    val acc9 = (acc8 << 1) | bit9

    # 9-bit codes 110010000..111111111 → symbols 144..255
    if acc9 >= 0b110010000 and acc9 <= 0b111111111:
        return [144 + (acc9 - 0b110010000), cur_br]

    return [-1, cur_br]

# Decode a fixed-Huffman distance code (5 bits, MSB-first).
# Returns [dist_code, new_reader_state]
fn deflate_fixed_decode_dist(br):
    var acc = 0
    var cur_br = br
    var i = 0
    loop:
        if i >= 5:
            break
        val ret = bitstream_read_one_bit(cur_br)
        val bit = ret[0]
        cur_br = ret[1]
        acc = (acc << 1) | bit
        i = i + 1
    return [acc, cur_br]

# =============================================================================
# LENGTH + DISTANCE EXTRA-BITS TABLES (RFC 1951 §3.2.5)
# =============================================================================

# Given a length code (257..285), return [base_length, extra_bits_count]
fn deflate_length_decode_info(code):
    if code == 257: return [3, 0]
    if code == 258: return [4, 0]
    if code == 259: return [5, 0]
    if code == 260: return [6, 0]
    if code == 261: return [7, 0]
    if code == 262: return [8, 0]
    if code == 263: return [9, 0]
    if code == 264: return [10, 0]
    if code == 265: return [11, 1]
    if code == 266: return [13, 1]
    if code == 267: return [15, 1]
    if code == 268: return [17, 1]
    if code == 269: return [19, 2]
    if code == 270: return [23, 2]
    if code == 271: return [27, 2]
    if code == 272: return [31, 2]
    if code == 273: return [35, 3]
    if code == 274: return [43, 3]
    if code == 275: return [51, 3]
    if code == 276: return [59, 3]
    if code == 277: return [67, 4]
    if code == 278: return [83, 4]
    if code == 279: return [99, 4]
    if code == 280: return [115, 4]
    if code == 281: return [131, 5]
    if code == 282: return [163, 5]
    if code == 283: return [195, 5]
    if code == 284: return [227, 5]
    if code == 285: return [258, 0]
    return [3, 0]

# Given a distance code (0..29), return [base_distance, extra_bits_count]
fn deflate_distance_decode_info(code):
    if code == 0:  return [1, 0]
    if code == 1:  return [2, 0]
    if code == 2:  return [3, 0]
    if code == 3:  return [4, 0]
    if code == 4:  return [5, 1]
    if code == 5:  return [7, 1]
    if code == 6:  return [9, 2]
    if code == 7:  return [13, 2]
    if code == 8:  return [17, 3]
    if code == 9:  return [25, 3]
    if code == 10: return [33, 4]
    if code == 11: return [49, 4]
    if code == 12: return [65, 5]
    if code == 13: return [97, 5]
    if code == 14: return [129, 6]
    if code == 15: return [193, 6]
    if code == 16: return [257, 7]
    if code == 17: return [385, 7]
    if code == 18: return [513, 8]
    if code == 19: return [769, 8]
    if code == 20: return [1025, 9]
    if code == 21: return [1537, 9]
    if code == 22: return [2049, 10]
    if code == 23: return [3073, 10]
    if code == 24: return [4097, 11]
    if code == 25: return [6145, 11]
    if code == 26: return [8193, 12]
    if code == 27: return [12289, 12]
    if code == 28: return [16385, 13]
    if code == 29: return [24577, 13]
    return [1, 0]

# Given a length (3..258), return [extra_bits_value, extra_bits_count]
fn deflate_length_extra(length):
    if length <= 10: return [0, 0]
    if length <= 12: return [length - 11, 1]
    if length <= 14: return [length - 13, 1]
    if length <= 16: return [length - 15, 1]
    if length <= 18: return [length - 17, 1]
    if length <= 22: return [length - 19, 2]
    if length <= 26: return [length - 23, 2]
    if length <= 30: return [length - 27, 2]
    if length <= 34: return [length - 31, 2]
    if length <= 42: return [length - 35, 3]
    if length <= 50: return [length - 43, 3]
    if length <= 58: return [length - 51, 3]
    if length <= 66: return [length - 59, 3]
    if length <= 82: return [length - 67, 4]
    if length <= 98: return [length - 83, 4]
    if length <= 114: return [length - 99, 4]
    if length <= 130: return [length - 115, 4]
    if length <= 162: return [length - 131, 5]
    if length <= 194: return [length - 163, 5]
    if length <= 226: return [length - 195, 5]
    if length <= 257: return [length - 227, 5]
    return [0, 0]

# Given a distance (1..32768), return [extra_bits_value, extra_bits_count]
fn deflate_distance_extra(distance):
    if distance <= 4:     return [0, 0]
    if distance <= 6:     return [distance - 5, 1]
    if distance <= 8:     return [distance - 7, 1]
    if distance <= 12:    return [distance - 9, 2]
    if distance <= 16:    return [distance - 13, 2]
    if distance <= 24:    return [distance - 17, 3]
    if distance <= 32:    return [distance - 25, 3]
    if distance <= 48:    return [distance - 33, 4]
    if distance <= 64:    return [distance - 49, 4]
    if distance <= 96:    return [distance - 65, 5]
    if distance <= 128:   return [distance - 97, 5]
    if distance <= 192:   return [distance - 129, 6]
    if distance <= 256:   return [distance - 193, 6]
    if distance <= 384:   return [distance - 257, 7]
    if distance <= 512:   return [distance - 385, 7]
    if distance <= 768:   return [distance - 513, 8]
    if distance <= 1024:  return [distance - 769, 8]
    if distance <= 1536:  return [distance - 1025, 9]
    if distance <= 2048:  return [distance - 1537, 9]
    if distance <= 3072:  return [distance - 2049, 10]
    if distance <= 4096:  return [distance - 3073, 10]
    if distance <= 6144:  return [distance - 4097, 11]
    if distance <= 8192:  return [distance - 6145, 11]
    if distance <= 12288: return [distance - 8193, 12]
    if distance <= 16384: return [distance - 12289, 12]
    if distance <= 24576: return [distance - 16385, 13]
    return [distance - 24577, 13]

