# GZIP Types and Constants
#
# Purpose: Core type definitions and constants for GZIP compression
#
# Contains:
# - GZIP magic bytes and format constants
# - Compression method identifiers
# - Operating system type codes
# - GZIP flag definitions
# - DEFLATE algorithm constants
# - Huffman coding constants
# - Block type identifiers
# - Compression level constants

# =============================================================================
# GZIP HEADER CONSTANTS
# =============================================================================

# GZIP magic bytes
pub val GZIP_MAGIC1 = 0x1f
pub val GZIP_MAGIC2 = 0x8b

# Compression methods
pub val CM_DEFLATE = 8

# Operating systems
pub val OS_FAT = 0
pub val OS_UNIX = 3
pub val OS_NTFS = 11
pub val OS_UNKNOWN = 255

# GZIP flags
pub val FLAG_TEXT = 1
pub val FLAG_HCRC = 2
pub val FLAG_EXTRA = 4
pub val FLAG_NAME = 8
pub val FLAG_COMMENT = 16

# =============================================================================
# DEFLATE CONSTANTS
# =============================================================================

# Sliding window parameters
pub val WINDOW_SIZE = 32768  # 32KB sliding window
pub val MIN_MATCH = 3
pub val MAX_MATCH = 258
pub val MAX_DISTANCE = 32768

# =============================================================================
# HUFFMAN CODING CONSTANTS
# =============================================================================

# Huffman tree parameters
pub val MAX_BITS = 15
pub val MAX_LITERALS = 286
pub val MAX_DISTANCES = 30

# =============================================================================
# BLOCK TYPES
# =============================================================================

# DEFLATE block types
pub val BLOCK_STORED = 0
pub val BLOCK_FIXED = 1
pub val BLOCK_DYNAMIC = 2

# =============================================================================
# COMPRESSION LEVELS
# =============================================================================

# Compression level constants (0-9)
pub val LEVEL_NONE = 0
pub val LEVEL_FAST = 1
pub val LEVEL_DEFAULT = 6
pub val LEVEL_BEST = 9


export BLOCK_DYNAMIC, BLOCK_FIXED, BLOCK_STORED, CM_DEFLATE, FLAG_COMMENT, FLAG_EXTRA, FLAG_HCRC, FLAG_NAME, FLAG_TEXT, GZIP_MAGIC1, GZIP_MAGIC2, LEVEL_BEST, LEVEL_DEFAULT, LEVEL_FAST, LEVEL_NONE, MAX_BITS, MAX_DISTANCE, MAX_DISTANCES, MAX_LITERALS, MAX_MATCH, MIN_MATCH, OS_FAT, OS_NTFS, OS_UNIX, OS_UNKNOWN, WINDOW_SIZE
