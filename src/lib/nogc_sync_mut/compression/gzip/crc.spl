# CRC32 Checksum Operations
#
# Purpose: CRC32 checksum calculation for data integrity verification
#
# Contains:
# - CRC32 lookup table generation
# - CRC32 calculation (full data)
# - CRC32 streaming updates (chunked data)
# - CRC32 finalization
# - CRC32 verification

# =============================================================================
# CRC32 CHECKSUM
# =============================================================================

# CRC32 lookup table (256 entries, reflected polynomial 0xEDB88320, RFC 1952)
fn crc32_table():
    var table: [i64] = []
    var i = 0
    loop:
        if i >= 256:
            break
        var crc = i
        var j = 0
        loop:
            if j >= 8:
                break
            if (crc & 1) != 0:
                crc = (crc >> 1) ^ 0xEDB88320
            else:
                crc = crc >> 1
            j = j + 1
        table.push(crc)
        i = i + 1
    return table

# Calculate CRC32 checksum
fn crc32_calculate(data: [u8]) -> i64:
    if data == nil:
        return 0

    var crc = 0xffffffff
    var i = 0
    val table = crc32_table()

    loop:
        if i >= data.len():
            break

        val byte_val = data[i]
        val index = (crc ^ byte_val) & 0xff
        crc = (crc >> 8) ^ table[index]

        i = i + 1

    return crc ^ 0xffffffff

# Update running CRC32 with new data
fn crc32_update(crc, data: [u8]) -> i64:
    if data == nil:
        return crc

    var current = crc
    var i = 0
    val table = crc32_table()

    loop:
        if i >= data.len():
            break

        val byte_val = data[i]
        val index = (current ^ byte_val) & 0xff
        current = (current >> 8) ^ table[index]

        i = i + 1

    return current

# Finalize CRC32 (XOR with 0xffffffff)
fn crc32_finalize(crc):
    return crc ^ 0xffffffff

# Calculate CRC32 in chunks
fn crc32_chunked(chunks):
    if chunks == nil:
        return 0

    var crc = 0xffffffff
    var i = 0

    loop:
        if i >= chunks.len():
            break

        val chunk = chunks[i]
        crc = crc32_update(crc, chunk)

        i = i + 1

    return crc32_finalize(crc)

# Verify CRC32 checksum
fn crc32_verify(data, expected):
    val calculated = crc32_calculate(data)
    return calculated == expected

