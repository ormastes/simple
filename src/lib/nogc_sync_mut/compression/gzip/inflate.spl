# DEFLATE Decompression Algorithm (RFC 1951)
#
# Purpose: DEFLATE decompression (inflate) operations
#
# Contains:
# - BitStream reader (LSB-first, RFC 1951 §3.1.1)
# - Stored block decompression
# - Fixed-Huffman block decompression (RFC 1951 §3.2.6)
# - Multi-block stream handling

use std.nogc_sync_mut.compression.gzip.types.{
    BLOCK_STORED, BLOCK_FIXED, BLOCK_DYNAMIC
}
use std.nogc_sync_mut.compression.gzip.huffman.{
    bitstream_reader_new, bitstream_read_bits_lsb, bitstream_read_one_bit,
    deflate_fixed_decode_litlen, deflate_fixed_decode_dist,
    deflate_length_decode_info, deflate_distance_decode_info
}

# =============================================================================
# DEFLATE INFLATE
# =============================================================================

# Decompress a stored block starting at bit-stream reader state br.
# Returns [output_bytes: [u8], new_br]  or  [nil, br] on error.
fn inflate_block_stored(br):
    # Stored blocks start on a byte boundary; skip remaining bits in current byte
    var data     = br[0]
    var byte_pos = br[1]
    var bit_pos  = br[2]

    if bit_pos != 0:
        byte_pos = byte_pos + 1
        bit_pos = 0

    # LEN (2 bytes) + NLEN (2 bytes)
    if byte_pos + 4 > data.len():
        return [nil, [data, byte_pos, bit_pos]]

    val blen  = data[byte_pos].to_i64() | (data[byte_pos + 1].to_i64() << 8)
    val bnlen = data[byte_pos + 2].to_i64() | (data[byte_pos + 3].to_i64() << 8)
    byte_pos = byte_pos + 4

    # NLEN should be one's complement of LEN (only lower 16 bits)
    val nlen_check = (~blen) & 0xffff
    if bnlen != nlen_check:
        # Accept anyway — some encoders may not set it correctly
        pass_dn

    if byte_pos + blen > data.len():
        return [nil, [data, byte_pos, bit_pos]]

    var out: [u8] = []
    var i = 0
    loop:
        if i >= blen:
            break
        out.push(data[byte_pos + i])
        i = i + 1

    byte_pos = byte_pos + blen
    return [out, [data, byte_pos, bit_pos]]

# Decompress a fixed-Huffman block starting at bit-stream reader state br.
# Returns [output_bytes: [u8], new_br]  or  [nil, br] on error.
fn inflate_block_fixed(br):
    var cur_br = br
    var out: [u8] = []

    loop:
        # Decode next literal/length symbol
        val sym_ret = deflate_fixed_decode_litlen(cur_br)
        val symbol  = sym_ret[0]
        cur_br = sym_ret[1]

        if symbol < 0:
            # Decode error
            return [nil, cur_br]

        if symbol == 256:
            # End of block
            break

        if symbol < 256:
            # Literal byte
            out.push(symbol.to_u8())
        else:
            # Length/distance pair
            val len_info = deflate_length_decode_info(symbol)
            val base_len = len_info[0]
            val ex_cnt   = len_info[1]

            var length = base_len
            if ex_cnt > 0:
                val ex_ret = bitstream_read_bits_lsb(cur_br, ex_cnt)
                val ex_val = ex_ret[0]
                cur_br = ex_ret[1]
                length = base_len + ex_val

            # Distance code (5 bits MSB-first)
            val dc_ret   = deflate_fixed_decode_dist(cur_br)
            val dist_code = dc_ret[0]
            cur_br = dc_ret[1]

            val di_info  = deflate_distance_decode_info(dist_code)
            val base_dist = di_info[0]
            val dex_cnt  = di_info[1]

            var distance = base_dist
            if dex_cnt > 0:
                val dex_ret = bitstream_read_bits_lsb(cur_br, dex_cnt)
                val dex_val = dex_ret[0]
                cur_br = dex_ret[1]
                distance = base_dist + dex_val

            # Copy length bytes from distance back in output buffer
            val start_pos = out.len() - distance
            var j = 0
            loop:
                if j >= length:
                    break
                val cp = start_pos + j
                if cp >= 0:
                    if cp < out.len():
                        out.push(out[cp])
                j = j + 1

    return [out, cur_br]

# Decompress a complete DEFLATE stream (one or more blocks).
# Returns decompressed [u8] or nil on error.
fn inflate(input: [u8]) -> [u8]?:
    if input.len() == 0:
        var empty: [u8] = []
        return empty

    var br = bitstream_reader_new(input)
    var out: [u8] = []

    loop:
        # Read BFINAL (1 bit) and BTYPE (2 bits) — LSB-first
        val bf_ret  = bitstream_read_bits_lsb(br, 1)
        val bfinal  = bf_ret[0]
        br = bf_ret[1]

        val bt_ret = bitstream_read_bits_lsb(br, 2)
        val btype  = bt_ret[0]
        br = bt_ret[1]

        if btype == BLOCK_STORED:
            val sr = inflate_block_stored(br)
            val block_out = sr[0]
            br = sr[1]
            if block_out == nil:
                return nil
            var k = 0
            loop:
                if k >= block_out.len():
                    break
                out.push(block_out[k])
                k = k + 1

        if btype == BLOCK_FIXED:
            val fr = inflate_block_fixed(br)
            val block_out = fr[0]
            br = fr[1]
            if block_out == nil:
                return nil
            var k = 0
            loop:
                if k >= block_out.len():
                    break
                out.push(block_out[k])
                k = k + 1

        if btype == BLOCK_DYNAMIC:
            # Dynamic Huffman blocks not supported in this commit (separate follow-up)
            return nil

        if bfinal == 1:
            break

    return out

# =============================================================================
# LEGACY INTERFACE — used by compress.spl's gzip_decompress via deflate_block_parse
# =============================================================================

# Parse a single DEFLATE block from a raw byte array at byte offset `offset`.
# Returns [block_type, is_final, block_data, next_byte_offset] or nil on error.
# NOTE: For fixed-Huffman blocks the caller should use inflate() directly.
# This shim is kept for backward compatibility with stored blocks.
fn deflate_block_parse(data, offset):
    if data == nil:
        return nil

    if offset >= data.len():
        return nil

    # Peek at first byte to get BFINAL + BTYPE
    val header_byte = data[offset].to_i64()
    val is_final = (header_byte & 1) != 0
    val block_type = (header_byte >> 1) & 3

    if block_type == BLOCK_STORED:
        var next_offset = offset + 1
        if next_offset + 4 > data.len():
            return nil

        val blen  = data[next_offset].to_i64() | (data[next_offset + 1].to_i64() << 8)
        next_offset = next_offset + 4

        if next_offset + blen > data.len():
            return nil

        var block_data: [u8] = []
        var i = 0
        loop:
            if i >= blen:
                break
            block_data.push(data[next_offset + i])
            i = i + 1

        next_offset = next_offset + blen
        return [block_type, is_final, block_data, next_offset]

    # For fixed/dynamic blocks, inflate_block_parse is not byte-aligned; return marker.
    return [block_type, is_final, [], offset]
