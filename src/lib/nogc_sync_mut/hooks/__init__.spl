# Hooks Module
#
# Hook system for extending compiler and runtime behavior.
# Provides plugin points and event handlers.
#
# Public API:
#   - use std.hooks.{register_hook, Hook}

# All submodules are automatically available.

# Re-exported from mod.spl
export Hook, HookCallback, HookResult, HookRegistry
export register_hook, run_hooks, create_registry

# Re-exported from stop.spl
export register_stop_hooks, maybe_run_stop_hooks, run_stop_hooks
