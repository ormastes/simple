# fs.nvfs.superblock_if — read surface for the NVFS superblock.
#
# The superblock lives in META_DURABLE class and is written with the
# checkpoint ring (see doc/05_design/nvfs_design.md §3). Readers go through
# this trait so test doubles can stand in for a real device.

struct SuperblockHeader:
    """Canonical superblock fields exposed to readers."""
    magic: i64
    version_major: i32
    version_minor: i32
    fs_uuid_lo: i64
    fs_uuid_hi: i64
    checkpoint_gen: i64
    created_unix_ns: i64

trait SuperblockReader:
    """Read the on-device superblock and expose its header fields."""
    fn read_header() -> SuperblockHeader
    fn is_mounted() -> bool
    fn last_checkpoint_generation() -> i64
