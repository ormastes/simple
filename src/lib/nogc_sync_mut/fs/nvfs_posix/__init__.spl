# POSIX-over-NVFS compatibility shim — module root.
#
# This module provides the NvfsPosixOps trait contract and CowShadow struct
# for the POSIX-semantics wrapper over NVFS arena storage.
#
# The stdlib-owned fd table and POSIX shim live under this module; the fuller
# example NVFS driver still lives under examples/11_advanced/nvfs/src/posix/.
# Import this module from main-repo code via std.fs.nvfs_posix.
#
# Phase 9 B2 — doc/05_design/nvfs_posix_wrapper.md.

use std.fs.nvfs_posix.api.{NvfsPosixOps}
use std.fs.nvfs_posix.cow_engine.{CowShadow, CowShadowOps}
use std.fs.nvfs_posix.fd_table.{FdTable, NvfsFdEntry}
