# NvfsPosixDriver — POSIX shim with fd_table refcounting.
#
# B3 upgrade: dup() now uses FdTable refcounting from examples/nvfs.
# set_nonblock delegates to rt_socket_set_nonblocking.
#
# Phase 9 B3 — doc/05_design/nvfs_posix_wrapper.md §3+§5.

use std.fs.nvfs_posix.api.{NvfsPosixOps, FdId}
use std.fs_driver.types.{FileHandle}
use std.fs_driver.error.{FsError}
use examples.nvfs.src.posix.fd_table.{FdTable, FdEntry}

extern fn rt_socket_set_nonblocking(fd: i64, enabled: bool) -> bool

var _posix_fd_table: FdTable = FdTable.new()
var _posix_fd_table_init: bool = false

fn _ensure_fd_table() -> FdTable:
    if not _posix_fd_table_init:
        _posix_fd_table = FdTable.new()
        _posix_fd_table_init = true
    _posix_fd_table

struct NvfsPosixDriver:
    """POSIX shim driver with fd_table refcounting (B3).

    Implements NvfsPosixOps. dup() increments refcount via FdTable.
    close() decrements; slot is freed when refcount hits zero.
    """
    name: text

    static fn new() -> NvfsPosixDriver:
        NvfsPosixDriver(name: "nvfs-posix-v1")

    fn fd_table() -> FdTable:
        _ensure_fd_table()

impl NvfsPosixOps for NvfsPosixDriver:
    fn dup(handle: FileHandle) -> Result<FileHandle, FsError>:
        var table = _ensure_fd_table()
        val fd = handle.id as u32
        val result = table.dup(fd)
        match result:
            case Ok(new_fd):
                _posix_fd_table = table
                Ok(FileHandle(id: new_fd as i64))
            case Err(e):
                Err(e)

    fn set_nonblock(handle: FileHandle, enable: bool) -> Result<(), FsError>:
        var fd: i64 = handle.id as i64
        var ok: bool = rt_socket_set_nonblocking(fd, enable)
        if ok:
            Ok(())
        else:
            Err(IoError(code: 0))

    fn shim_name() -> text:
        self.name
