# Stitch designMd sidecar loader
#
# Loads the expanded designMd content from disk for Stitch push payloads.
# Separated from common.ui.glass.tokens to keep the pure type definitions
# free of file I/O.

extern fn rt_file_read_text(path: text) -> text

fn load_stitch_design_md() -> text:
    val body = rt_file_read_text("src/lib/common/ui/stitch_design_md.sdn")
    return body
