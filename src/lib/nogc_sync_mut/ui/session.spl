# UI Session — Unified Session Model
#
# Central shared-state container that owns UIState, WidgetStore,
# Viewport, ChangeLog, LifecycleRegistry, and SurfaceManager.
# All state transitions flow through the session, enabling
# shared state across CLI, TUI, and GUI backends.

use common.ui.widget.{WidgetNode, UITree, UIState, UIEvent, UIMode}
use common.ui.widget_store.{WidgetStore}
use common.ui.viewport.{Viewport, default_viewport}
use common.ui.changelog.{ChangeLog, default_changelog}
use common.ui.lifecycle.{LifecycleRegistry, LifecycleEvent, new_lifecycle_registry, emit_lifecycle_events, describe_lifecycle_event}
use common.ui.access.{UiAccessSnapshot, UiAccessNode, UiAccessEvent, ui_access_record_action, ui_access_lifecycle_events, ui_access_history_events, ui_access_snapshot_from_session, ui_access_snapshot_from_state, ui_access_snapshot_persistable}
use nogc_sync_mut.ui.access_store.{UiAccessStore}
use common.ui.diff.{diff_trees_with}
use common.ui.state.{update_state}
use common.ui.surface.{SurfaceHandle, SurfaceManager, new_surface_manager}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry}
use common.ui.profile.{ProfileResolver, ProfileSet, ProfileSetEntry, Orientation, LayoutProfile, compute_profile}
use common.ui.capability.{Capability}
use common.ui.capability_policy.{CapabilityPolicy, check_capability, require_capability}
use common.ui.patch_stream.{PatchStream}
use common.ui.semantic_contract.{SemanticUiCommand, SemanticUiDispatchResult, semantic_ui_command_to_event}
use common.ui.clipboard_service.{ClipboardService, ClipboardEntry}

# =========================================================================
# UISession
# =========================================================================

class UISession:
    state: UIState
    store: WidgetStore
    viewport: Viewport
    changelog: ChangeLog
    lifecycle: LifecycleRegistry
    surfaces: SurfaceManager
    profile_resolver: ProfileResolver
    profile_sets: [ProfileSetEntry]
    capability_policy: CapabilityPolicy?
    access_events: [UiAccessEvent]
    access_sequence: i64
    access_store: UiAccessStore?
    window_surfaces: UiWindowSurfaceRegistry
    patch_stream: PatchStream
    clipboard: ClipboardService

    static fn new(tree: UITree) -> UISession:
        """Create a session with a main tree and default settings."""
        val store = WidgetStore.new()
        var sm = new_surface_manager()
        sm.open("main", tree)
        return UISession(
            state: UIState.new(tree),
            store: store,
            viewport: default_viewport(),
            changelog: default_changelog(),
            lifecycle: new_lifecycle_registry(),
            surfaces: sm,
            profile_resolver: ProfileResolver.new(),
            profile_sets: [],
            capability_policy: nil,
            access_events: [],
            access_sequence: 0,
            access_store: nil,
            window_surfaces: UiWindowSurfaceRegistry.new(),
            patch_stream: PatchStream.new(),
            clipboard: ClipboardService.new()
        )

    static fn new_with_store(tree: UITree, store: WidgetStore) -> UISession:
        """Create a session with a pre-populated widget store."""
        var sm = new_surface_manager()
        sm.open("main", tree)
        return UISession(
            state: UIState.new(tree),
            store: store,
            viewport: default_viewport(),
            changelog: default_changelog(),
            lifecycle: new_lifecycle_registry(),
            surfaces: sm,
            profile_resolver: ProfileResolver.new(),
            profile_sets: [],
            capability_policy: nil,
            access_events: [],
            access_sequence: 0,
            access_store: nil,
            window_surfaces: UiWindowSurfaceRegistry.new(),
            patch_stream: PatchStream.new(),
            clipboard: ClipboardService.new()
        )

    static fn new_with_policy(tree: UITree, policy: CapabilityPolicy) -> UISession:
        """Create a session with a specific capability policy."""
        val store = WidgetStore.new()
        var sm = new_surface_manager()
        sm.open("main", tree)
        return UISession(
            state: UIState.new(tree),
            store: store,
            viewport: default_viewport(),
            changelog: default_changelog(),
            lifecycle: new_lifecycle_registry(),
            surfaces: sm,
            profile_resolver: ProfileResolver.new(),
            profile_sets: [],
            capability_policy: policy,
            access_events: [],
            access_sequence: 0,
            access_store: nil,
            window_surfaces: UiWindowSurfaceRegistry.new(),
            patch_stream: PatchStream.new(),
            clipboard: ClipboardService.new()
        )

# =========================================================================
# Constructor Shorthand
# =========================================================================

fn new_session(tree: UITree) -> UISession:
    """Create a new UI session with the given tree."""
    return UISession.new(tree)

# =========================================================================
# UISession Methods
# =========================================================================

impl UISession:

    # -- State access --------------------------------------------------------

    fn current_state() -> UIState:
        """Get the current UI state."""
        return self.state

    fn current_tree() -> UITree:
        """Get the current widget tree."""
        return self.state.tree

    fn current_mode() -> text:
        """Get the current mode name (NORMAL, COMMAND, etc.)."""
        return self.state.mode_name()

    fn focused_widget() -> text:
        """Get the ID of the currently focused widget."""
        return self.state.focused_id

    fn recent_changes(count: i32) -> [text]:
        """Get human-readable descriptions of recent lifecycle events."""
        return self.changelog.recent_descriptions(count)

    fn viewport_width() -> i32:
        """Get viewport width."""
        return self.viewport.width

    fn viewport_height() -> i32:
        """Get viewport height."""
        return self.viewport.height

    fn active_backend() -> text:
        """Get the name of the active backend."""
        return self.viewport.active_backend

    fn access_snapshot() -> UiAccessSnapshot:
        """Build a canonical access snapshot for all open surfaces."""
        return ui_access_snapshot_from_session(self.state, self.surfaces, self.surfaces.active(), self.access_events, self.window_surfaces)

    fn access_recent_events(count: i32) -> [UiAccessEvent]:
        """Get the most recent UI access events."""
        return ui_access_history_events(self.access_events, "", count)

    fn access_recent_surface_events(surface_id: text, count: i32) -> [UiAccessEvent]:
        """Get recent access events for one surface."""
        return ui_access_history_events(self.access_events, surface_id, count)

    fn record_access_correlation(surface_id: text, widget_id: text, request_id: text, phase: text, code: text) -> i64:
        """Record a correlated access request or result in bounded history."""
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            surface_id,
            widget_id,
            "access_" + phase,
            "request_id=" + request_id + ";code=" + code
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()
        self.access_sequence

    fn access_persisted_events(surface_id: text, count: i64) -> Result<[UiAccessEvent], text>:
        """Read persisted access events when a store is attached."""
        if self.access_store == nil:
            return Err("no access store attached")
        match self.access_store.list_events(surface_id, count):
            Ok(events):
                return Ok(events)
            Err(e):
                return Err(e.message())

    fn access_search_nodes(surface_id: text, kind: text, text_query: text, limit: i64) -> Result<[UiAccessNode], text>:
        """Query persisted latest-node rows when a store is attached."""
        if self.access_store == nil:
            return Err("no access store attached")
        match self.access_store.query_nodes(surface_id, kind, text_query, limit):
            Ok(nodes):
                return Ok(nodes)
            Err(e):
                return Err(e.message())

    me attach_access_store(store: UiAccessStore):
        """Attach a persisted UI access store and immediately seed it."""
        self.access_store = store
        self._sync_access_store_snapshot()

    # -- State mutation ------------------------------------------------------

    me dispatch(event: UIEvent):
        """Process a UI event through the state update pipeline."""
        val surface_id = if self.surfaces.active() != "": self.surfaces.active() else: "main"
        var target_widget_id = self.state.focused_id
        var event_kind = "event"
        var payload = ""
        match event:
            UIEvent.KeyPress(key):
                event_kind = "key_press"
                payload = key
            UIEvent.Resize(width, height):
                event_kind = "resize"
                payload = "{width}x{height}"
            UIEvent.Quit:
                event_kind = "quit"
                payload = "quit"
            UIEvent.Action(name):
                event_kind = "action"
                payload = name
                # Editor Cut/Copy/Paste buttons (editor.spl) fire generic
                # UIEvent.Action(name) values; translate the well-known
                # "editor.edit.*" names into real ClipboardService calls
                # here rather than widening process_event's pure signature.
                if name == "editor.edit.copy":
                    payload = self._clipboard_copy_focused()
                elif name == "editor.edit.cut":
                    payload = self._clipboard_cut_focused()
                elif name == "editor.edit.paste":
                    payload = self._clipboard_paste_focused()
                elif name.starts_with("editor.edit.paste_history_"):
                    val idx_str = name.slice(26, name.len())
                    val idx = idx_str.to_int() ?? 0
                    payload = self._clipboard_paste_history_focused(idx)
            UIEvent.FocusNext:
                event_kind = "focus_next"
                payload = "focus_next"
            UIEvent.FocusPrev:
                event_kind = "focus_prev"
                payload = "focus_prev"
            UIEvent.CommandMode:
                event_kind = "mode"
                payload = "command"
            UIEvent.NormalMode:
                event_kind = "mode"
                payload = "normal"
            UIEvent.InsertMode:
                event_kind = "mode"
                payload = "insert"
            UIEvent.TouchPress(x, y):
                event_kind = "touch_press"
                payload = "{x},{y}"
            UIEvent.TouchMove(x, y):
                event_kind = "touch_move"
                payload = "{x},{y}"
            UIEvent.TouchRelease(x, y):
                event_kind = "touch_release"
                payload = "{x},{y}"
            UIEvent.MouseEvent(x, y, button, kind):
                event_kind = "mouse_" + kind
                payload = "{x},{y}:{button}"
            UIEvent.ScrollEvent(x, y, dx, dy):
                event_kind = "scroll"
                payload = "{x},{y}:{dx},{dy}"
            UIEvent.FocusEvent(target_id, kind):
                event_kind = "focus_" + kind
                target_widget_id = target_id
                payload = target_id
            UIEvent.InputChange(target_id, value):
                event_kind = "input_change"
                target_widget_id = target_id
                payload = value
            UIEvent.FetchResult(request_id, url, status, headers, body, error):
                event_kind = "fetch_result"
                payload = "{request_id}:{status}:{url}"
            UIEvent.FileChanged:
                event_kind = "file_changed"
                payload = "file_changed"
            UIEvent.DragStart(source_id, mime, data):
                event_kind = "drag_start"
                target_widget_id = source_id
                payload = mime + ":" + data
            UIEvent.DragMove(x, y):
                event_kind = "drag_move"
                payload = "{x},{y}"
            UIEvent.DragDrop(mime, data, x, y, source_id):
                event_kind = "drag_drop"
                target_widget_id = source_id
                payload = mime + ":" + data
            UIEvent.Copy:
                event_kind = "clipboard_copy"
                payload = self._clipboard_copy_focused()
            UIEvent.Cut:
                event_kind = "clipboard_cut"
                payload = self._clipboard_cut_focused()
            UIEvent.Paste:
                event_kind = "clipboard_paste"
                payload = self._clipboard_paste_focused()
            UIEvent.PasteFromHistory(index):
                event_kind = "clipboard_paste_history"
                payload = self._clipboard_paste_history_focused(index)
        self.state = update_state(self.state, event)
        self.surfaces.update_tree(surface_id, self.state.tree)
        self.surfaces.update_focus(surface_id, self.state.focused_id)
        if target_widget_id == "":
            target_widget_id = self.state.focused_id
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            surface_id,
            target_widget_id,
            event_kind,
            payload
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()
        # Check for resize events and trigger profile switching
        match event:
            UIEvent.Resize(width, height):
                val old_orientation = self.profile_resolver.orientation()
                self.profile_resolver.update(self.viewport)
                if self.profile_resolver.orientation_changed(old_orientation):
                    self._apply_profiles(self.profile_resolver.orientation())
            _:
                pass_dn

    me dispatch_semantic_command(command: SemanticUiCommand) -> SemanticUiDispatchResult:
        """Dispatch a shared semantic UI command through the existing event pipeline."""
        val event = semantic_ui_command_to_event(command)
        if event == nil:
            return SemanticUiDispatchResult.failure(command, "unsupported_semantic_command", self.access_sequence)
        if command.surface_id != "":
            if not self.surfaces.has(command.surface_id):
                return SemanticUiDispatchResult.failure(command, "surface_not_found", self.access_sequence)
            self.set_active_surface(command.surface_id)
        self.dispatch(event)
        var affected_id = command.target_id
        if affected_id == "":
            affected_id = self.state.focused_id
        if affected_id != "" and not affected_id.contains("#"):
            affected_id = self.surfaces.active() + "#" + affected_id
        return SemanticUiDispatchResult.success(command, affected_id, self.access_sequence)

    me update_tree(new_tree: UITree):
        """Replace the main tree, computing diff and emitting lifecycle events."""
        val surface_id = "main"
        val old_tree = self.surfaces.get(surface_id)
        val new_root = new_tree.root_node()
        if old_tree != nil:
            val patches = diff_trees_with(old_tree.root_node(), new_root, self.store)
            emit_lifecycle_events(self.lifecycle, patches)
        # Push lifecycle events to changelog
        for event in self.lifecycle.event_log:
            self.changelog.push(event)
            self.access_sequence = self.access_sequence + 1
            self.access_events = ui_access_lifecycle_events(
                self.access_events,
                self.access_sequence - 1,
                surface_id,
                [event]
            )
        self.lifecycle.clear_log()
        if self.surfaces.has("main"):
            self.surfaces.update_tree("main", new_tree)
        else:
            self.surfaces.open("main", new_tree)
        if self.surfaces.active() == "main":
            self._load_surface_state("main")
        self._sync_access_store_snapshot()

    # -- Viewport management -------------------------------------------------

    me set_viewport(width: i32, height: i32, backend: text):
        """Set viewport dimensions. Only the active backend can update."""
        val current_backend = self.viewport.active_backend
        if current_backend == backend or current_backend == "none":
            self.viewport = Viewport(
                width: width,
                height: height,
                active_backend: backend
            )

    me set_active_backend(name: text):
        """Set which backend is the active renderer."""
        self.viewport = Viewport(
            width: self.viewport.width,
            height: self.viewport.height,
            active_backend: name
        )

    # -- Surface lifecycle ---------------------------------------------------

    me open_surface(id: text, tree: UITree) -> SurfaceHandle:
        """Open a named surface with the given tree."""
        val handle = self.surfaces.open(id, tree)
        if self.surfaces.active() == id:
            self._load_surface_state(id)
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            id,
            tree.root_node().id,
            "surface_open",
            id
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()
        return handle

    me close_surface(handle: SurfaceHandle) -> bool:
        """Close a surface by its handle. Returns false if stale."""
        val was_active = self.surfaces.active() == handle.id
        val closed = self.surfaces.close(handle)
        if closed:
            if was_active:
                self._load_surface_state(self.surfaces.active())
            self.window_surfaces.clear_surface(handle.id)
            self.access_sequence = self.access_sequence + 1
            self.access_events = ui_access_record_action(
                self.access_events,
                self.access_sequence,
                handle.id,
                "",
                "surface_close",
                handle.id
            )
            self._persist_latest_access_event()
            self._sync_access_store_snapshot()
        return closed

    fn get_surface(id: text) -> UITree?:
        """Get the tree for a named surface."""
        return self.surfaces.get(id)

    fn has_surface(id: text) -> bool:
        """Check whether a named surface exists."""
        return self.surfaces.has(id)

    fn surface_count() -> i32:
        """How many surfaces are open."""
        return self.surfaces.surface_count()

    me set_surface_widget_value(surface_id: text, widget_id: text, value: text) -> bool:
        """Set the live value prop for a widget on a surface."""
        val tree = self.surfaces.get(surface_id)
        if tree == nil:
            return false
        val node = tree.find_widget(widget_id)
        if node == nil:
            return false
        node.set_prop("value", value)
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            surface_id,
            widget_id,
            "value_set",
            value
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()
        return true

    me set_surface_widget_prop(surface_id: text, widget_id: text, key: text, value: text) -> bool:
        """Set an arbitrary live prop for a widget on a surface.

        Visibility is special-cased because it lives on WidgetRecord rather than
        the generic prop store. All successful writes record an `update` access
        event so ui.web clients can reconcile from the retained event stream.
        """
        val tree = self.surfaces.get(surface_id)
        if tree == nil:
            return false
        val node = tree.find_widget(widget_id)
        if node == nil:
            return false
        if key == "visible":
            node.set_visible(value != "false")
        else:
            node.set_prop(key, value)
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            surface_id,
            widget_id,
            "update",
            "{key}={value}"
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()
        return true

    me set_active_surface(id: text):
        """Set which surface is active."""
        if not self.surfaces.has(id):
            return
        val previous = self.surfaces.active()
        self.surfaces.update_tree(previous, self.state.tree)
        self.surfaces.update_focus(previous, self.state.focused_id)
        self.surfaces.set_active(id)
        self._load_surface_state(id)
        self.access_sequence = self.access_sequence + 1
        self.access_events = ui_access_record_action(
            self.access_events,
            self.access_sequence,
            id,
            "",
            "surface_focus",
            id
        )
        self._persist_latest_access_event()
        self._sync_access_store_snapshot()

    fn active_surface() -> text:
        """Get the active surface ID."""
        return self.surfaces.active()

    me _load_surface_state(id: text):
        val tree = self.surfaces.get(id)
        if tree == nil:
            return
        self.state = UIState(
            tree: tree,
            mode: self.state.mode,
            focused_id: self.surfaces.focused(id),
            command_buffer: self.state.command_buffer
        )

    fn validate_surface_handle(handle: SurfaceHandle) -> bool:
        """Check whether a surface handle is still valid."""
        return self.surfaces.validate_handle(handle)

    fn surface_handle(id: text) -> SurfaceHandle?:
        """Get a current handle for an existing surface."""
        return self.surfaces.handle_for(id)

    me bind_window_surface(window_id: text, surface_id: text, process_id: u64, app_id: text, title: text):
        """Bind runtime window metadata to a surface."""
        self.window_surfaces.bind(window_id, surface_id, process_id, app_id, title)
        self._sync_access_store_snapshot()

    me bind_window_surface_with_kind(window_id: text, surface_id: text, process_id: u64, app_id: text, title: text, surface_kind: text):
        """Bind runtime window metadata to a surface with an explicit kind."""
        self.window_surfaces.bind_with_kind(window_id, surface_id, process_id, app_id, title, surface_kind)
        self._sync_access_store_snapshot()

    me update_window_surface_title(surface_id: text, title: text) -> bool:
        """Update the runtime title metadata for a bound surface."""
        val binding = self.window_surfaces.for_surface(surface_id)
        if binding == nil:
            return false
        self.window_surfaces.bind_with_kind(
            binding.window_id,
            surface_id,
            binding.process_id,
            binding.app_id,
            title,
            binding.surface_kind
        )
        self._sync_access_store_snapshot()
        return true

    me clear_window_surface_binding(surface_id: text):
        """Remove any runtime window binding for a surface."""
        self.window_surfaces.clear_surface(surface_id)
        self._sync_access_store_snapshot()

    me clear_window_binding(window_id: text):
        """Remove any runtime window binding for a window id."""
        self.window_surfaces.clear_window(window_id)
        self._sync_access_store_snapshot()

    me update_surface_tree(handle: SurfaceHandle, new_tree: UITree):
        """Update a surface's tree. Does nothing if handle is stale."""
        if not self.surfaces.validate_handle(handle):
            return
        val old_tree = self.surfaces.get(handle.id)
        if old_tree == nil:
            return
        val old_root = old_tree.root_node()
        val new_root = new_tree.root_node()
        # Diff and emit
        val patches = diff_trees_with(old_root, new_root, self.store)
        emit_lifecycle_events(self.lifecycle, patches)
        for event in self.lifecycle.event_log:
            self.changelog.push(event)
            self.access_sequence = self.access_sequence + 1
            self.access_events = ui_access_lifecycle_events(
                self.access_events,
                self.access_sequence - 1,
                handle.id,
                [event]
            )
        self.lifecycle.clear_log()
        # Commit new tree
        self.surfaces.update_tree(handle.id, new_tree)
        if self.surfaces.active() == handle.id:
            self._load_surface_state(handle.id)
        self._sync_access_store_snapshot()

    # -- Profile management --------------------------------------------------

    me register_profile_set(surface_id: text, profiles: ProfileSet):
        """Register landscape/portrait profiles for a surface."""
        # Replace existing entry for this surface, or append
        var new_sets: [ProfileSetEntry] = []
        var found = false
        for entry in self.profile_sets:
            if entry.surface_id == surface_id:
                new_sets = new_sets.push(ProfileSetEntry(surface_id: surface_id, profiles: profiles))
                found = true
            else:
                new_sets = new_sets.push(entry)
        if not found:
            new_sets = new_sets.push(ProfileSetEntry(surface_id: surface_id, profiles: profiles))
        self.profile_sets = new_sets

    me _apply_profiles(orientation: Orientation):
        """Switch all registered surfaces to the matching profile."""
        for entry in self.profile_sets:
            val new_root = entry.profiles.resolve(orientation)
            val new_tree = UITree.new(new_root)
            if entry.surface_id == "main":
                self.update_tree(new_tree)
            else:
                if self.surfaces.has(entry.surface_id):
                    self.surfaces.update_tree(entry.surface_id, new_tree)
        self._load_surface_state(self.surfaces.active())

    fn current_profile() -> LayoutProfile:
        """Get the current computed layout profile."""
        return self.profile_resolver.current_profile()

    fn current_orientation() -> Orientation:
        """Get the current detected orientation."""
        return self.profile_resolver.orientation()

    me _persist_latest_access_event():
        if self.access_store == nil:
            return
        if self.access_events.len() == 0:
            return
        val latest = self.access_events[self.access_events.len() - 1]
        match self.access_store.insert_event(latest):
            Ok(_):
                pass_dn
            Err(_):
                pass_dn

    me _sync_access_store_snapshot():
        if self.access_store == nil:
            return
        val snapshot = ui_access_snapshot_persistable(self.access_snapshot())
        match self.access_store.persist_snapshot(snapshot):
            Ok(_):
                pass_dn
            Err(_):
                pass_dn

    # -- Capability enforcement -----------------------------------------------

    fn check_cap(cap: Capability) -> Result<bool, text>:
        """Check if a capability is allowed by this session's policy."""
        if self.capability_policy == nil:
            return Ok(true)
        return check_capability(self.capability_policy, cap)

    me set_capability_policy(policy: CapabilityPolicy):
        """Replace the session's capability policy."""
        self.capability_policy = policy

    # -- Clipboard (ClipboardService-backed) ----------------------------------
    #
    # Copy/Cut/Paste/PasteFromHistory act on the currently focused widget's
    # `value` prop — the same generic surface an input/textfield already
    # exposes (see widget_hit.widget_dispatch_key), so this works uniformly
    # for any GUI or TUI widget tree with a focused input, not just editor.spl.
    # Capability-gated via the session's CapabilityPolicy (default-allow when
    # no policy is attached, matching check_cap's existing convention).

    me _clipboard_copy_focused() -> text:
        if self.check_cap(Capability.ClipboardWrite).is_err():
            return ""
        val id = self.state.focused_id
        if id == "":
            return ""
        val node = self.state.tree.find_widget(id)
        if node == nil:
            return ""
        val value = node.get_prop("value")
        self.clipboard.copy("text/plain", value)
        return value

    me _clipboard_cut_focused() -> text:
        if self.check_cap(Capability.ClipboardWrite).is_err():
            return ""
        val id = self.state.focused_id
        if id == "":
            return ""
        val node = self.state.tree.find_widget(id)
        if node == nil:
            return ""
        val value = node.get_prop("value")
        self.clipboard.cut("text/plain", value)
        node.set_prop("value", "")
        return value

    me _clipboard_paste_focused() -> text:
        if self.check_cap(Capability.ClipboardRead).is_err():
            return ""
        val id = self.state.focused_id
        if id == "":
            return ""
        val node = self.state.tree.find_widget(id)
        if node == nil:
            return ""
        val entry = self.clipboard.paste()
        if entry == nil:
            return ""
        node.set_prop("value", entry.data)
        return entry.data

    me _clipboard_paste_history_focused(index: i32) -> text:
        if self.check_cap(Capability.ClipboardRead).is_err():
            return ""
        val id = self.state.focused_id
        if id == "":
            return ""
        val node = self.state.tree.find_widget(id)
        if node == nil:
            return ""
        val entry = self.clipboard.paste_from_history(index)
        if entry == nil:
            return ""
        node.set_prop("value", entry.data)
        return entry.data

    me open_surface_gated(id: text, tree: UITree, required_cap: Capability) -> Result<SurfaceHandle, text>:
        """Open a surface only if the required capability is granted."""
        if self.capability_policy == nil:
            return Ok(self.open_surface(id, tree))
        val cap_check = check_capability(self.capability_policy, required_cap)
        match cap_check:
            Ok(_): Ok(self.open_surface(id, tree))
            Err(msg): Err(msg)
