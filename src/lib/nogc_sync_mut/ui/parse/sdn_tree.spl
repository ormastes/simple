# UI SDN Tree File Parser — file I/O wrapper
#
# Reads .ui.sdn files from disk and delegates to the pure parser
# in common.ui.parse.sdn_tree for UITree construction.

use common.ui.widget.{UITree}
use common.ui.parse.sdn_tree.{build_tree_from_source}

extern fn rt_file_read_text(path: text) -> text?
extern fn rt_file_exists(path: text) -> bool

fn parse_ui_to_tree(path: text) -> Result<UITree, text>:
    if not rt_file_exists(path):
        return Err("File not found: {path}")
    val source = rt_file_read_text(path) ?? ""
    return build_tree_from_source(source)
