# Folder-based UI theme packages.
#
# Loads config/themes/theme.sdn plus family/theme folders once, validates the
# package graph, and exposes resolved CSS/tokens/numeric colors to renderers.

use common.ui.simple_theme.{SimpleTheme}
use common.ui.glass.tokens.{GlassDesignTokens}
use common.ui.style.{UITheme, UIThemeColors, Spacing, BorderStyle, FontStyle}
use common.ui.color.{UIColor}
use common.ui.theme_render_snapshot.{ThemeShadowLayer, ThemeMaterialSemantics, ThemeRenderSnapshot, theme_material_sha256}
use std.common.crypto.sha256.{sha256_text}
use std.io_runtime.{file_exists, read_file}

val THEME_REGISTRY_PATH = "config/themes/theme.sdn"

class ResolvedThemeColors:
    bg: u32
    fg: u32
    accent: u32
    panel: u32
    border: u32
    button: u32
    button_hover: u32
    status: u32

class ResolvedThemeGlassConfig:
    surface_color: u32
    surface_alpha: u8
    blur_radius: u32
    border_color: u32
    border_alpha: u8
    shadow_offset: i32
    shadow_blur: u32
    shadow_alpha: u8
    accent_color: u32
    accent2_color: u32
    bg_top: u32
    bg_bottom: u32

class ResolvedThemeIcon:
    role: text
    icon_id: text
    label: text
    color_token: text
    size_role: text

class ResolvedThemePackage:
    id: text
    display_name: text
    family_id: text
    registry_path: text
    theme_path: text
    family_path: text
    base_css: text
    shape_css: text
    family_widget_css: text
    theme_widget_css: text
    widget_css: text
    icon_css: text
    source_reference: text
    source_paths: [text]
    fingerprint: text
    mtime_key: text
    tokens: GlassDesignTokens
    token_map: Dict<text, text>
    widget_css_by_name: Dict<text, text>
    icons: Dict<text, ResolvedThemeIcon>
    colors: ResolvedThemeColors
    ui_theme: UITheme
    glass_config: ResolvedThemeGlassConfig
    snapshot: ThemeRenderSnapshot

class ThemeValidationIssue:
    path: text
    key: text
    message: text

var _theme_package_cache: Dict<text, ResolvedThemePackage> = {}

fn default_theme_id() -> text:
    val content = _read_if_exists(THEME_REGISTRY_PATH)
    val value = _root_value(content, "default_theme")
    if value == "":
        return "aetheric_dark"
    value

fn resolve_theme_alias(theme_id: text) -> text:
    val requested = if theme_id == "": default_theme_id() else: theme_id
    val content = _read_if_exists(THEME_REGISTRY_PATH)
    val alias = _section_value(content, "aliases", requested)
    if alias != "":
        return alias
    requested

fn load_default_theme_package() -> ResolvedThemePackage:
    load_theme_package(default_theme_id())

fn load_theme_package(theme_id: text) -> ResolvedThemePackage:
    val resolved_id = resolve_theme_alias(theme_id)
    match _theme_package_cache.get(resolved_id):
        case Some(cached):
            return cached
        case _: pass_dn

    val registry = _read_if_exists(THEME_REGISTRY_PATH)
    val theme_path = _section_value(registry, "themes", resolved_id)
    val final_theme_path = if theme_path == "": "config/themes/{resolved_id}/theme.sdn" else: theme_path
    val theme_sdn = _read_if_exists(final_theme_path)
    val family_id = _root_value(theme_sdn, "family")
    val family_path = _section_value(registry, "families", family_id)
    val final_family_path = if family_path == "": "config/themes/families/{family_id}/theme.sdn" else: family_path
    val family_sdn = _read_if_exists(final_family_path)

    val base_path = _root_value(theme_sdn, "base_css")
    val shape_path = _root_value(family_sdn, "shape_css")
    val icons_path = _root_value(family_sdn, "icons")
    val local_widget_dir = _root_value(theme_sdn, "widget_css_dir")
    val family_widget_dir = _root_value(family_sdn, "widget_css_dir")
    val required_widgets = _section_items(registry, "required_widgets")
    val base_css = _read_if_exists(base_path)
    val shape_css = _read_if_exists(shape_path)
    val icon_sdn = _read_if_exists(icons_path)
    val family_widget_css = _load_family_widget_css(required_widgets, family_widget_dir)
    val theme_widget_css = _load_theme_widget_css(required_widgets, local_widget_dir)
    val widget_css = "{family_widget_css}\n{theme_widget_css}"
    val required_icons = _required_icon_roles(registry)
    val icons = _resolved_icons(icon_sdn, required_icons)
    val icon_css = _icons_to_css(icons, required_icons)
    val css_for_tokens = "{shape_css}\n{base_css}"
    val parsed = SimpleTheme.from_css(resolved_id, css_for_tokens)
    val colors = _resolved_colors_from_css(base_css)
    val ui_theme = _ui_theme_from_css(resolved_id, base_css, colors)
    val glass_cfg = _glass_config_from_colors(colors, shape_css)
    val token_map = _token_map_from_css("{shape_css}\n{base_css}")
    val widget_map = _load_widget_css_map(required_widgets, local_widget_dir, family_widget_dir)

    val source_reference = _root_value(theme_sdn, "source_raw_reference")
    var paths = [THEME_REGISTRY_PATH, final_theme_path, final_family_path, base_path, shape_path, icons_path, source_reference]
    for widget in required_widgets:
        val local_path = "{local_widget_dir}/{widget}.css"
        val family_path_for_widget = "{family_widget_dir}/{widget}.css"
        val family_default = "{family_widget_dir}/defaults.css"
        if file_exists(local_path):
            paths = paths.push(local_path)
        if file_exists(family_path_for_widget):
            paths = paths.push(family_path_for_widget)
        if file_exists(family_default):
            paths = paths.push(family_default)
    paths = _sorted_unique_paths(paths)

    val source_manifest_sha256 = _source_manifest_sha256(paths)
    val material = _material_from_css(base_css, shape_css)
    val material_sha256 = theme_material_sha256(material)
    val composed_css = "{shape_css}\n{family_widget_css}\n{base_css}\n{theme_widget_css}\n{icon_css}\n"
    val snapshot = ThemeRenderSnapshot(
        id: resolved_id,
        family_id: family_id,
        source_reference: source_reference,
        source_manifest_sha256: source_manifest_sha256,
        material_sha256: material_sha256,
        composed_css: composed_css,
        background_rgba: colors.bg,
        foreground_rgba: colors.fg,
        accent_rgba: colors.accent,
        material: material
    )

    val pkg = ResolvedThemePackage(
        id: resolved_id,
        display_name: _root_value(theme_sdn, "display_name"),
        family_id: family_id,
        registry_path: THEME_REGISTRY_PATH,
        theme_path: final_theme_path,
        family_path: final_family_path,
        base_css: base_css,
        shape_css: shape_css,
        family_widget_css: family_widget_css,
        theme_widget_css: theme_widget_css,
        widget_css: widget_css,
        icon_css: icon_css,
        source_reference: source_reference,
        source_paths: paths,
        fingerprint: source_manifest_sha256,
        mtime_key: source_manifest_sha256,
        tokens: parsed.tokens,
        token_map: token_map,
        widget_css_by_name: widget_map,
        icons: icons,
        colors: colors,
        ui_theme: ui_theme,
        glass_config: glass_cfg,
        snapshot: snapshot
    )
    _theme_package_cache[resolved_id] = pkg
    pkg

fn resolved_theme_css(theme_id: text) -> text:
    load_theme_package(theme_id).snapshot.composed_css

fn invalidate_theme_package_cache(theme_id: text):
    val resolved_id = resolve_theme_alias(theme_id)
    _theme_package_cache.remove(resolved_id)

fn invalidate_all_theme_package_cache():
    _theme_package_cache = {}

fn theme_ui_theme(theme_id: text) -> UITheme:
    load_theme_package(theme_id).ui_theme

fn theme_design_tokens(theme_id: text) -> GlassDesignTokens:
    load_theme_package(theme_id).tokens

fn theme_numeric_colors(theme_id: text) -> ResolvedThemeColors:
    load_theme_package(theme_id).colors

fn theme_glass_config(theme_id: text) -> ResolvedThemeGlassConfig:
    load_theme_package(theme_id).glass_config

fn theme_icon_defaults(theme_id: text) -> Dict<text, ResolvedThemeIcon>:
    load_theme_package(theme_id).icons

fn validate_default_theme_package() -> [ThemeValidationIssue]:
    validate_theme_package(THEME_REGISTRY_PATH)

fn validate_theme_package(registry_path: text) -> [ThemeValidationIssue]:
    var issues: [ThemeValidationIssue] = []
    if not file_exists(registry_path):
        return [ThemeValidationIssue(path: registry_path, key: "registry", message: "theme registry file is missing")]

    val registry = read_file(registry_path)
    val default_id = _root_value(registry, "default_theme")
    if default_id == "":
        issues = _push_issue(issues, registry_path, "default_theme", "default_theme is required")
    val theme_id = if default_id == "": "aetheric_dark" else: default_id
    val theme_path = _section_value(registry, "themes", theme_id)
    if theme_path == "":
        issues = _push_issue(issues, registry_path, "themes.{theme_id}", "default theme is not listed in themes")
        return issues
    if not file_exists(theme_path):
        issues = _push_issue(issues, theme_path, "themes.{theme_id}", "theme package file is missing")
        return issues

    val theme_sdn = read_file(theme_path)
    val family_id = _root_value(theme_sdn, "family")
    val family_path = _section_value(registry, "families", family_id)
    if family_id == "":
        issues = _push_issue(issues, theme_path, "family", "theme family is required")
    elif family_path == "":
        issues = _push_issue(issues, registry_path, "families.{family_id}", "theme references an unknown family")
    elif not file_exists(family_path):
        issues = _push_issue(issues, family_path, "families.{family_id}", "family package file is missing")

    val family_sdn = if family_path != "" and file_exists(family_path): read_file(family_path) else: ""
    issues = _require_file(issues, theme_path, "base_css", _root_value(theme_sdn, "base_css"))
    issues = _require_file(issues, family_path, "shape_css", _root_value(family_sdn, "shape_css"))
    issues = _require_file(issues, family_path, "icons", _root_value(family_sdn, "icons"))
    issues = _require_file(issues, theme_path, "source_raw_reference", _root_value(theme_sdn, "source_raw_reference"))

    val base_path = _root_value(theme_sdn, "base_css")
    val shape_path = _root_value(family_sdn, "shape_css")
    val icons_path = _root_value(family_sdn, "icons")
    val base_css = _read_if_exists(base_path)
    val shape_css = _read_if_exists(shape_path)
    val icon_sdn = _read_if_exists(icons_path)
    val local_widget_dir = _root_value(theme_sdn, "widget_css_dir")
    val family_widget_dir = _root_value(family_sdn, "widget_css_dir")
    val widgets = _section_items(registry, "required_widgets")
    val defaults_css = _read_if_exists("{family_widget_dir}/defaults.css")
    for widget in widgets:
        val local_path = "{local_widget_dir}/{widget}.css"
        val family_path_for_widget = "{family_widget_dir}/{widget}.css"
        val widget_class = widget.replace("_", "-")
        val class_name = ".widget-{widget_class}"
        if not file_exists(local_path) and not file_exists(family_path_for_widget) and not defaults_css.contains(class_name):
            issues = _push_issue(issues, registry_path, "required_widgets.{widget}", "missing widget CSS in local package or family defaults")

    val required_icons = _required_icon_roles(registry)
    for role in required_icons:
        val icon_id = _icon_id_for_role(icon_sdn, role)
        if icon_id == "":
            issues = _push_issue(issues, icons_path, "icons.{role}", "missing required default icon")
        if _section_value(icon_sdn, "labels", role) == "":
            issues = _push_issue(issues, icons_path, "labels.{role}", "missing required icon label")
        val color_token = _section_value(icon_sdn, "colors", role)
        if color_token == "":
            issues = _push_issue(issues, icons_path, "colors.{role}", "missing required icon semantic color token")
        elif not color_token.starts_with("var(--"):
            issues = _push_issue(issues, icons_path, "colors.{role}", "icon color must reference a semantic CSS token")
        if _section_value(icon_sdn, "sizes", role) == "":
            issues = _push_issue(issues, icons_path, "sizes.{role}", "missing required icon size role")

    issues = issues + _validate_token_layers(base_path, base_css, shape_path, shape_css, local_widget_dir, family_widget_dir, widgets)
    issues = issues + _validate_var_refs(base_path, base_css, shape_path, shape_css, icons_path, icon_sdn, local_widget_dir, family_widget_dir, widgets)
    issues

fn _read_if_exists(path: text) -> text:
    if path == "":
        return ""
    if not file_exists(path):
        return ""
    read_file(path)

fn _push_issue(issues: [ThemeValidationIssue], path: text, key: text, message: text) -> [ThemeValidationIssue]:
    var out = issues
    out.push(ThemeValidationIssue(path: path, key: key, message: message))
    out

fn _require_file(issues: [ThemeValidationIssue], owner: text, key: text, path: text) -> [ThemeValidationIssue]:
    if path == "":
        return _push_issue(issues, owner, key, "{key} is required")
    if not file_exists(path):
        return _push_issue(issues, path, key, "referenced file is missing")
    issues

fn _sorted_unique_paths(paths: [text]) -> [text]:
    var out: [text] = []
    for path in paths:
        if path == "":
            continue
        var seen = false
        for existing in out:
            if existing == path:
                seen = true
                break
        if not seen:
            out.push(path)
    var i = 0
    while i < out.len():
        var j = i + 1
        while j < out.len():
            if out[j] < out[i]:
                val tmp = out[i]
                out[i] = out[j]
                out[j] = tmp
            j = j + 1
        i = i + 1
    out

fn _source_manifest_sha256(paths: [text]) -> text:
    var manifest = "theme-source-manifest-v1\n"
    for path in paths:
        val content = _read_if_exists(path)
        # Hash each source independently, then hash the sorted path/hash
        # manifest. This keeps the identity content-addressed without copying
        # whole CSS payloads into the manifest string.
        val content_sha256 = sha256_text(content)
        manifest = "{manifest}{path.len()}:{path}\n{content_sha256}\n"
    sha256_text(manifest)

fn _strip_value(value: text) -> text:
    var v: text = "{value.trim()}"
    if v.starts_with("\"") and v.ends_with("\"") and v.len() >= 2:
        v = v[1:v.len() - 1]
    v

fn _root_value(content: text, key: text) -> text:
    val prefix = "{key}:"
    for line in content.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed.starts_with(prefix):
            return _strip_value(trimmed[prefix.len():])
    ""

fn _section_value(content: text, section: text, key: text) -> text:
    var current = ""
    val section_header = "{section}:"
    val prefix = "{key}:"
    for line in content.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        if not "{line}".starts_with(" ") and trimmed.ends_with(":"):
            current = trimmed[0:trimmed.len() - 1]
            continue
        if trimmed == section_header:
            current = section
            continue
        if current == section and trimmed.starts_with(prefix):
            return _strip_value(trimmed[prefix.len():])
    ""

fn _section_items(content: text, section: text) -> [text]:
    var items: [text] = []
    var current = ""
    val section_header = "{section}:"
    for line in content.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        if trimmed == section_header:
            current = section
            continue
        if not "{line}".starts_with(" ") and trimmed.ends_with(":"):
            current = trimmed[0:trimmed.len() - 1]
            continue
        if current == section and trimmed.starts_with("- "):
            items.push(_strip_value(trimmed[2:]))
    items

fn _load_family_widget_css(widgets: [text], family_dir: text) -> text:
    var css = _read_if_exists("{family_dir}/defaults.css")
    for widget in widgets:
        val family_path = "{family_dir}/{widget}.css"
        val family_css = _read_if_exists(family_path)
        if family_css != "":
            css = "{css}\n{family_css}"
    css

fn _load_theme_widget_css(widgets: [text], local_dir: text) -> text:
    var css = ""
    for widget in widgets:
        val local_path = "{local_dir}/{widget}.css"
        val local_css = _read_if_exists(local_path)
        if local_css != "":
            css = "{css}\n{local_css}"
    css

fn _load_widget_css_map(widgets: [text], local_dir: text, family_dir: text) -> Dict<text, text>:
    var out: Dict<text, text> = {}
    val defaults_css = _read_if_exists("{family_dir}/defaults.css")
    for widget in widgets:
        val family_css = _read_if_exists("{family_dir}/{widget}.css")
        val local_css = _read_if_exists("{local_dir}/{widget}.css")
        var css = defaults_css
        if family_css != "":
            css = "{css}\n{family_css}"
        if local_css != "":
            css = "{css}\n{local_css}"
        out[widget] = css
    out

fn _required_icon_roles(registry: text) -> [text]:
    val roles = _section_items(registry, "required_icons")
    if roles.len() > 0:
        return roles
    [
        "terminal", "browser", "file_manager", "finder", "editor", "calculator", "settings", "generic_app",
        "close", "minimize", "maximize", "restore", "fullscreen", "launcher", "search", "running_indicator", "fallback_app", "fallback_file",
        "back", "forward", "refresh", "home", "new_window", "command_palette",
        "folder", "file", "document", "image", "media", "archive", "executable", "unknown",
        "info", "success", "warning", "error"
    ]

fn _icon_id_for_role(icon_sdn: text, role: text) -> text:
    for section in ["apps", "system", "navigation", "content", "status"]:
        val value = _section_value(icon_sdn, section, role)
        if value != "":
            return value
    ""

fn _resolved_icons(icon_sdn: text, roles: [text]) -> Dict<text, ResolvedThemeIcon>:
    var out: Dict<text, ResolvedThemeIcon> = {}
    for role in roles:
        val icon_id = _icon_id_for_role(icon_sdn, role)
        val label = _section_value(icon_sdn, "labels", role)
        val color = _section_value(icon_sdn, "colors", role)
        val size = _section_value(icon_sdn, "sizes", role)
        out[role] = ResolvedThemeIcon(role: role, icon_id: icon_id, label: label, color_token: color, size_role: size)
    out

fn _icons_to_css(icons: Dict<text, ResolvedThemeIcon>, roles: [text]) -> text:
    var css = ":root {\n"
    for role in roles:
        match icons.get(role):
            case Some(icon):
                val key = role.replace("_", "-")
                css = "{css}  --theme-icon-{key}: \"{icon.icon_id}\";\n"
                css = "{css}  --theme-icon-{key}-label: \"{icon.label}\";\n"
                css = "{css}  --theme-icon-{key}-color: {icon.color_token};\n"
                css = "{css}  --theme-icon-{key}-size: \"{icon.size_role}\";\n"
            case _: pass_dn
    css = "{css}\}\n"
    css

fn _css_var(css: text, name: text, fallback: text) -> text:
    val prefix = "{name}:"
    for line in css.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed.starts_with(prefix):
            var value = trimmed[prefix.len():].trim()
            if value.ends_with(";"):
                value = value[0:value.len() - 1].trim()
            return value
    fallback

fn _resolved_colors_from_css(base_css: text) -> ResolvedThemeColors:
    val bg = _argb_from_css(_css_var(base_css, "--ui-bg", "#0e0e10"), 0xFF0E0E10)
    val fg = _argb_from_css(_css_var(base_css, "--ui-fg", "#e4e2e4"), 0xFFE4E2E4)
    val accent = _argb_from_css(_css_var(base_css, "--ui-accent", "#adc6ff"), 0xFFADC6FF)
    val panel = _argb_from_css(_css_var(base_css, "--app-surface", "#1F1F21"), 0xFF1F1F21)
    val border = _argb_from_css(_css_var(base_css, "--app-border", "#8B90A0"), 0xFF8B90A0)
    val hover = _argb_from_css(_css_var(base_css, "--app-surface-hover", "#353437"), 0xFF353437)
    ResolvedThemeColors(bg: bg, fg: fg, accent: accent, panel: panel, border: border, button: hover, button_hover: hover, status: panel)

fn _token_map_from_css(css: text) -> Dict<text, text>:
    var out: Dict<text, text> = {}
    for line in css.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed.starts_with("--") and trimmed.contains(":"):
            val parts = trimmed.split(":")
            if parts.len() >= 2:
                val key = parts[0].trim()
                out[key] = _css_var(css, key, "")
    out

fn _ui_theme_from_css(name: text, base_css: text, colors: ResolvedThemeColors) -> UITheme:
    UITheme(
        name: name,
        colors: UIThemeColors(
            background: UIColor.from_hex(_css_var(base_css, "--ui-bg", "#0e0e10")),
            foreground: UIColor.from_hex(_css_var(base_css, "--ui-fg", "#e4e2e4")),
            border: _css_var(base_css, "--app-border", "rgba(139,144,160,0.20)"),
            accent: UIColor.from_hex(_css_var(base_css, "--ui-accent", "#adc6ff")),
            panel_bg: _css_var(base_css, "--app-surface", "rgba(31,31,33,0.80)"),
            hover_bg: _css_var(base_css, "--app-surface-hover", "rgba(53,52,55,0.80)"),
            error: UIColor.from_hex(_css_var(base_css, "--ui-error", "#ffb4ab")),
            warning: UIColor.from_hex(_css_var(base_css, "--ui-warning", "#f4bd78")),
            success: UIColor.from_hex(_css_var(base_css, "--ui-success", "#b1b1ff")),
            info: UIColor.from_hex(_css_var(base_css, "--ui-info", "#9bdcff"))
        ),
        spacing: Spacing.default_spacing(),
        border: BorderStyle(width: 1, radius: _px_int(_css_var(base_css, "--widget-radius", "8px"), 8), style: "solid"),
        font: FontStyle(
            family: _css_var(base_css, "--font-main", "\"Inter\", sans-serif"),
            size: _px_int(_css_var(base_css, "--font-size-base", "14px"), 14),
            weight: _css_var(base_css, "--font-weight-normal", "400"),
            line_height: 1.5
        )
    )

fn _glass_config_from_colors(colors: ResolvedThemeColors, shape_css: text) -> ResolvedThemeGlassConfig:
    ResolvedThemeGlassConfig(
        surface_color: colors.panel & 0x00FFFFFF,
        surface_alpha: ((colors.panel >> 24) & 0xFF).to_u8(),
        blur_radius: _px_int(_css_var(shape_css, "--blur-surface", "30px"), 30).to_u32(),
        border_color: colors.border & 0x00FFFFFF,
        border_alpha: ((colors.border >> 24) & 0xFF).to_u8(),
        shadow_offset: 4,
        shadow_blur: 14,
        shadow_alpha: 44,
        accent_color: colors.accent & 0x00FFFFFF,
        accent2_color: colors.accent & 0x00FFFFFF,
        bg_top: colors.bg & 0x00FFFFFF,
        bg_bottom: colors.panel & 0x00FFFFFF
    )

fn _material_from_css(base_css: text, shape_css: text) -> ThemeMaterialSemantics:
    val desktop = _argb_from_css(_css_var(base_css, "--app-bg", "#131315"), 0xFF131315)
    val window = _argb_from_css(_css_var(base_css, "--app-surface", "rgba(31,31,33,0.80)"), 0xCC1F1F21)
    val active_title = _argb_from_css(_css_var(base_css, "--app-surface-elevated", "rgba(42,42,44,0.88)"), 0xE02A2A2C)
    val inactive_title = window
    val border = _argb_from_css(_css_var(base_css, "--app-border", "rgba(139,144,160,0.20)"), 0x338B90A0)
    val text_color = _argb_from_css(_css_var(base_css, "--ui-fg", "#e4e2e4"), 0xFFE4E2E4)
    val secondary_text = _argb_from_css(_css_var(base_css, "--ui-dim", "rgba(193,198,215,0.68)"), 0xADC1C6D7)
    val active_shadows = _shadow_layers(_css_var(shape_css, "--elevation-high", "0 28px 76px rgba(0,0,0,0.46)"))
    val inactive_shadows = _shadow_layers(_css_var(shape_css, "--elevation-mid", "0 18px 46px rgba(0,0,0,0.34)"))
    val surface_alpha = (((window >> 24) & 0xFF).to_i64() * 1000 + 127) / 255
    val solid_fallback = 0xFF000000 | (window & 0x00FFFFFF)
    ThemeMaterialSemantics(
        desktop_fill_rgba: desktop,
        window_fill_rgba: window,
        active_title_fill_rgba: active_title,
        inactive_title_fill_rgba: inactive_title,
        surface_alpha_milli: surface_alpha.to_i32(),
        backdrop_blur_px: _px_int(_css_var(shape_css, "--blur-surface", "30px"), 30),
        # Aetheric's canonical widget material declares saturate(170%). Keep
        # this renderer-neutral value aligned even when no optional numeric
        # override token is present in base.css.
        backdrop_saturation_milli: _decimal_milli(_css_var(base_css, "--glass-backdrop-saturation", "1.7"), 1700),
        border_width_px: _px_int(_css_var(shape_css, "--border-width-hairline", "1px"), 1),
        border_rgba: border,
        corner_radius_px: _px_int(_css_var(shape_css, "--radius-md", "12px"), 12),
        active_shadows: active_shadows,
        inactive_shadows: inactive_shadows,
        font_family: _css_var(base_css, "--font-main", "system-ui, sans-serif"),
        font_size_px: _px_int(_css_var(base_css, "--font-size-base", "14px"), 14),
        font_weight: (_css_var(base_css, "--font-weight-normal", "400").to_i64() ?? 400).to_i32(),
        text_rgba: text_color,
        secondary_text_rgba: secondary_text,
        solid_fallback_rgba: solid_fallback,
        fallback_contrast_milli: _argb_contrast_milli(text_color, solid_fallback)
    )

fn _argb_luminance(color: u32) -> i64:
    val r = ((color >> 16) & 0xFF).to_i64()
    val g = ((color >> 8) & 0xFF).to_i64()
    val b = (color & 0xFF).to_i64()
    (r * 299 + g * 587 + b * 114) / 1000

fn _argb_contrast_milli(fg: u32, bg: u32) -> i32:
    val fg_l = _argb_luminance(fg)
    val bg_l = _argb_luminance(bg)
    val lighter = if fg_l > bg_l: fg_l else: bg_l
    val darker = if fg_l > bg_l: bg_l else: fg_l
    (((lighter + 5) * 1000) / (darker + 5)).to_i32()

fn _clamp_css_channel(value: i64) -> u32:
    if value < 0:
        return 0
    if value > 255:
        return 255
    value.to_u32()

fn _clamp_css_alpha(value: f64) -> u32:
    if value <= 0.0:
        return 0
    if value >= 1.0:
        return 255
    ((value * 255.0) + 0.5).to_i64().to_u32()

fn _decimal_milli(value: text, fallback: i32) -> i32:
    val trimmed = value.trim()
    if trimmed == "":
        return fallback
    ((trimmed.to_f64() * 1000.0) + 0.5).to_i32()

fn _split_top_level_commas(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var depth = 0
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "(":
            depth = depth + 1
            current = "{current}{ch}"
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
            current = "{current}{ch}"
        elif ch == "," and depth == 0:
            if current.trim() != "":
                out.push(current.trim())
            current = ""
        else:
            current = "{current}{ch}"
        i = i + 1
    if current.trim() != "":
        out.push(current.trim())
    out

fn _split_shadow_tokens(value: text) -> [text]:
    var out: [text] = []
    var current = ""
    var depth = 0
    var i = 0
    while i < value.len():
        val ch = value.char_at(i)
        if ch == "(":
            depth = depth + 1
            current = "{current}{ch}"
        elif ch == ")":
            if depth > 0:
                depth = depth - 1
            current = "{current}{ch}"
        elif (ch == " " or ch == "\t") and depth == 0:
            if current.trim() != "":
                out.push(current.trim())
                current = ""
        else:
            current = "{current}{ch}"
        i = i + 1
    if current.trim() != "":
        out.push(current.trim())
    out

fn _shadow_layers(value: text) -> [ThemeShadowLayer]:
    var out: [ThemeShadowLayer] = []
    for raw_layer in _split_top_level_commas(value):
        val tokens = _split_shadow_tokens(raw_layer)
        var lengths: [i32] = []
        var color = 0x00000000u32
        var inset = false
        for token in tokens:
            if token == "inset":
                inset = true
            elif token.starts_with("#") or token.starts_with("rgb"):
                color = _argb_from_css(token, 0x00000000)
            elif lengths.len() < 4:
                lengths.push(_px_int(token, 0))
        if lengths.len() >= 2:
            val blur = if lengths.len() >= 3: lengths[2] else: 0
            val spread = if lengths.len() >= 4: lengths[3] else: 0
            out.push(ThemeShadowLayer(
                offset_x_px: lengths[0],
                offset_y_px: lengths[1],
                blur_radius_px: blur,
                spread_radius_px: spread,
                rgba: color,
                inset: inset
            ))
    out

fn _px_int(value: text, fallback: i32) -> i32:
    val trimmed = value.trim()
    val v = trimmed.replace("px", "")
    val parsed = v.to_i64() ?? fallback.to_i64()
    parsed.to_i32()

fn _argb_from_css(value: text, fallback: u32) -> u32:
    val v: text = "{value.trim()}"
    if v.starts_with("rgba(") and v.ends_with(")"):
        val parts = v[5:v.len() - 1].split(",")
        if parts.len() == 4:
            val r = _clamp_css_channel(parts[0].trim().to_i64() ?? 0)
            val g = _clamp_css_channel(parts[1].trim().to_i64() ?? 0)
            val b = _clamp_css_channel(parts[2].trim().to_i64() ?? 0)
            val alpha_text = parts[3].trim()
            if alpha_text == "":
                return fallback
            val alpha = _clamp_css_alpha(alpha_text.to_f64())
            return (alpha << 24) | (r << 16) | (g << 8) | b
        return fallback
    if v.starts_with("rgb(") and v.ends_with(")"):
        val parts = v[4:v.len() - 1].split(",")
        if parts.len() == 3:
            val r = _clamp_css_channel(parts[0].trim().to_i64() ?? 0)
            val g = _clamp_css_channel(parts[1].trim().to_i64() ?? 0)
            val b = _clamp_css_channel(parts[2].trim().to_i64() ?? 0)
            return 0xFF000000 | (r << 16) | (g << 8) | b
        return fallback
    if not v.starts_with("#"):
        return fallback
    if v.len() == 4:
        val r = _theme_package_hex_digit(v.char_code_at(1) as i64)
        val g = _theme_package_hex_digit(v.char_code_at(2) as i64)
        val b = _theme_package_hex_digit(v.char_code_at(3) as i64)
        return 0xFF000000 | ((r * 17).to_u32() << 16) | ((g * 17).to_u32() << 8) | (b * 17).to_u32()
    if v.len() < 7:
        return fallback
    val hex = v[1:7]
    val r = _theme_package_hex_digit(hex.char_code_at(0) as i64) * 16 + _theme_package_hex_digit(hex.char_code_at(1) as i64)
    val g = _theme_package_hex_digit(hex.char_code_at(2) as i64) * 16 + _theme_package_hex_digit(hex.char_code_at(3) as i64)
    val b = _theme_package_hex_digit(hex.char_code_at(4) as i64) * 16 + _theme_package_hex_digit(hex.char_code_at(5) as i64)
    0xFF000000 | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()

fn _theme_package_hex_digit(ch: i64) -> i64:
    if ch >= 48 and ch <= 57:
        return ch - 48
    if ch >= 97 and ch <= 102:
        return ch - 87
    if ch >= 65 and ch <= 70:
        return ch - 55
    0

fn _validate_token_layers(base_path: text, base_css: text, shape_path: text, shape_css: text, local_widget_dir: text, family_widget_dir: text, widgets: [text]) -> [ThemeValidationIssue]:
    var issues: [ThemeValidationIssue] = []
    for forbidden in ["--ui-", "--app-", "--font-", "--motion-"]:
        if shape_css.contains(forbidden):
            issues = _push_issue(issues, shape_path, forbidden, "family shape CSS must only define shape tokens")
    for forbidden in ["--radius-", "--spacing-", "--blur-", "--border-width-", "--elevation-"]:
        if base_css.contains(forbidden):
            issues = _push_issue(issues, base_path, forbidden, "theme base CSS must not define family shape tokens")
    for widget in widgets:
        val local_path = "{local_widget_dir}/{widget}.css"
        val family_path = "{family_widget_dir}/{widget}.css"
        val local_css = _read_if_exists(local_path)
        val family_css = _read_if_exists(family_path)
        if _defined_tokens(local_css).len() > 0:
            issues = _push_issue(issues, local_path, widget, "local widget CSS must use existing var(--token) references instead of defining tokens")
        val family_defs = _defined_tokens(family_css)
        for token in family_defs:
            if token.starts_with("--ui-") or token.starts_with("--app-"):
                issues = _push_issue(issues, family_path, widget, "family widget CSS must not define theme color tokens")
    issues

fn _defined_tokens(css: text) -> [text]:
    var tokens: [text] = []
    for line in css.split("\n"):
        val trimmed: text = "{line.trim()}"
        if trimmed.starts_with("--") and trimmed.contains(":"):
            val parts = trimmed.split(":")
            tokens.push(parts[0].trim())
    tokens

fn _has_token(tokens: [text], token: text) -> bool:
    for item in tokens:
        if item == token:
            return true
    false

fn _validate_refs_in_css(issues: [ThemeValidationIssue], path: text, css: text, tokens: [text]) -> [ThemeValidationIssue]:
    var out = issues
    var rest = css
    while rest.contains("var(--"):
        val parts = rest.split("var(")
        if parts.len() < 2:
            return out
        val tail = parts[1]
        val end_parts = tail.split(")")
        if end_parts.len() < 1:
            return out
        val token = end_parts[0].trim()
        if not _has_token(tokens, token):
            out = _push_issue(out, path, token, "unresolved CSS token reference")
        rest = tail
        if end_parts.len() > 1:
            rest = end_parts[1]
        else:
            return out
    out

fn _validate_var_refs(base_path: text, base_css: text, shape_path: text, shape_css: text, icons_path: text, icon_sdn: text, local_widget_dir: text, family_widget_dir: text, widgets: [text]) -> [ThemeValidationIssue]:
    var issues: [ThemeValidationIssue] = []
    val tokens = _defined_tokens(base_css) + _defined_tokens(shape_css)
    issues = _validate_refs_in_css(issues, base_path, base_css, tokens)
    issues = _validate_refs_in_css(issues, shape_path, shape_css, tokens)
    issues = _validate_refs_in_css(issues, icons_path, icon_sdn, tokens)
    issues = _validate_refs_in_css(issues, "{family_widget_dir}/defaults.css", _read_if_exists("{family_widget_dir}/defaults.css"), tokens)
    for widget in widgets:
        val local_path = "{local_widget_dir}/{widget}.css"
        val family_path = "{family_widget_dir}/{widget}.css"
        issues = _validate_refs_in_css(issues, local_path, _read_if_exists(local_path), tokens)
        issues = _validate_refs_in_css(issues, family_path, _read_if_exists(family_path), tokens)
    issues

fn render_theme_validation_report(issues: [ThemeValidationIssue]) -> text:
    var lines: [text] = []
    lines.push("=== Verification Report: Theme Packages ===")
    if issues.len() == 0:
        lines.push("[PASS] config/themes/theme.sdn - theme package graph is valid")
        lines.push("")
        lines.push("STATUS: PASS (0 failures, 0 warnings)")
        return lines.join("\n")
    for issue in issues:
        lines.push("[FAIL] {issue.path} {issue.key} - {issue.message}")
    lines.push("")
    lines.push("STATUS: FAIL ({issues.len()} failures, 0 warnings)")
    lines.join("\n")

export ResolvedThemePackage, ResolvedThemeColors, ResolvedThemeGlassConfig, ResolvedThemeIcon, ThemeValidationIssue
export default_theme_id, resolve_theme_alias, load_default_theme_package, load_theme_package
export invalidate_theme_package_cache, invalidate_all_theme_package_cache
export resolved_theme_css, theme_ui_theme, theme_design_tokens, theme_numeric_colors, theme_glass_config, theme_icon_defaults
export validate_default_theme_package, validate_theme_package, render_theme_validation_report
