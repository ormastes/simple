# ZIP Reader - Pure Simple implementation of ZIP archive reading
#
# Reads ZIP files by parsing the End of Central Directory record (EOCD),
# then the Central Directory entries, and extracting file data from
# local file headers.
#
# Compatible with ZIP files created by standard tools and ZipWriter.
#
# Usage:
#   val archive = ZipArchive.open("archive.zip")?
#   val files = archive.list_files()
#   val data = archive.read_file("hello.txt")?
#   val count = archive.file_count()

use app.io.{file_exists}

extern fn rt_file_read_bytes(path: text) -> [u8]

# ============================================================================
# Constants
# ============================================================================

val ZIP_LOCAL_FILE_SIG: u32 = 0x04034B50       # PK\x03\x04
val ZIP_CENTRAL_DIR_SIG: u32 = 0x02014B50      # PK\x01\x02
val ZIP_EOCD_SIG: u32 = 0x06054B50             # PK\x05\x06
val ZIP_EOCD_SIZE: i64 = 22                     # Minimum EOCD size (no comment)

# ============================================================================
# ZIP File Info
# ============================================================================

# Information about a single file entry in a ZIP archive,
# parsed from the central directory.
struct ZipFileInfo:
    path: text              # File path inside the archive
    offset: i64             # Offset to local file header
    compressed_size: i64    # Compressed data size
    uncompressed_size: i64  # Uncompressed data size
    method: i64             # Compression method (0=store, 8=deflate)
    crc32: u32              # CRC-32 of uncompressed data
    is_directory: bool      # True if entry is a directory

# ============================================================================
# ZIP Archive
# ============================================================================

# Reader for ZIP archive files.
#
# Opens a ZIP file, parses its central directory, and provides
# random access to individual entries.
#
# Example:
#   val archive = ZipArchive.open("mylib.zip")?
#   for file in archive.list_files():
#       print "  {file}"
#   val readme = archive.read_file("README.txt")?
struct ZipArchive:
    path: text
    entries: [ZipFileInfo]
    file_data: [u8]

impl ZipArchive:
    # Open a ZIP file for reading.
    #
    # Reads the entire file into memory, locates the EOCD record,
    # and parses the central directory to build the file index.
    #
    # Args:
    #   path: Path to the ZIP file on disk
    #
    # Returns:
    #   Ok(ZipArchive) on success, Err with message on failure
    static fn open(path: text) -> Result<ZipArchive, text>:
        if not file_exists(path):
            return Err("ZIP file not found: {path}")

        val data = rt_file_read_bytes(path)
        if data.len() < ZIP_EOCD_SIZE:
            return Err("File too small to be a ZIP archive: {path}")

        # Find EOCD record by scanning backwards from end of file.
        # EOCD signature is 0x06054B50 (PK\x05\x06).
        # We scan up to 65557 bytes back (max comment size = 65535 + 22).
        val eocd_offset = find_eocd(data)
        if eocd_offset < 0:
            return Err("Cannot find End of Central Directory record in: {path}")

        # Parse EOCD
        val cd_entries_total = read_u16_le(data, eocd_offset + 10) as i64
        val cd_size = read_u32_le(data, eocd_offset + 12) as i64
        val cd_offset = read_u32_le(data, eocd_offset + 16) as i64

        # Validate central directory bounds
        if cd_offset + cd_size > data.len():
            return Err("Central directory extends beyond file bounds")

        # Parse central directory entries
        var entries: [ZipFileInfo] = []
        var pos = cd_offset
        var count = 0

        while count < cd_entries_total:
            if pos + 46 > data.len():
                return Err("Unexpected end of central directory at entry {count}")

            val sig = read_u32_le(data, pos)
            if sig != ZIP_CENTRAL_DIR_SIG:
                return Err("Invalid central directory signature at offset {pos}")

            val method = read_u16_le(data, pos + 10) as i64
            val crc = read_u32_le(data, pos + 16)
            val comp_size = read_u32_le(data, pos + 20) as i64
            val uncomp_size = read_u32_le(data, pos + 24) as i64
            val name_len = read_u16_le(data, pos + 28) as i64
            val extra_len = read_u16_le(data, pos + 30) as i64
            val comment_len = read_u16_le(data, pos + 32) as i64
            val local_offset = read_u32_le(data, pos + 42) as i64

            # Read filename
            val name_start = pos + 46
            val name_end = name_start + name_len
            if name_end > data.len():
                return Err("Filename extends beyond file at entry {count}")

            val name = bytes_to_text(data, name_start, name_end)
            val is_dir = name.ends_with("/")

            val info = ZipFileInfo(
                path: name,
                offset: local_offset,
                compressed_size: comp_size,
                uncompressed_size: uncomp_size,
                method: method,
                crc32: crc,
                is_directory: is_dir
            )
            entries.push(info)

            # Advance to next central directory entry
            pos = name_end + extra_len + comment_len
            count = count + 1

        Ok(ZipArchive(
            path: path,
            entries: entries,
            file_data: data
        ))

    # List all file paths in the archive (including directories).
    fn list_files() -> [text]:
        var names: [text] = []
        for entry in self.entries:
            names.push(entry.path)
        names

    # Read the uncompressed contents of a file in the archive.
    #
    # Currently supports Store method (method 0) only.
    #
    # Args:
    #   path: File path inside the archive
    #
    # Returns:
    #   Ok(bytes) on success, Err with message on failure
    fn read_file(path: text) -> Result<[u8], text>:
        # Find the entry
        var found: ZipFileInfo? = nil
        for entry in self.entries:
            if entry.path == path:
                found = entry
                break

        if found == nil:
            return Err("File not found in archive: {path}")

        val entry = found.unwrap()

        if entry.is_directory:
            return Err("Cannot read directory entry: {path}")

        # Parse local file header to find actual data offset
        val local_offset = entry.offset
        if local_offset + 30 > self.file_data.len():
            return Err("Local header extends beyond file for: {path}")

        val local_sig = read_u32_le(self.file_data, local_offset)
        if local_sig != ZIP_LOCAL_FILE_SIG:
            return Err("Invalid local file header signature for: {path}")

        val local_name_len = read_u16_le(self.file_data, local_offset + 26) as i64
        val local_extra_len = read_u16_le(self.file_data, local_offset + 28) as i64
        val data_offset = local_offset + 30 + local_name_len + local_extra_len

        # Handle store method (no compression)
        if entry.method == 0:
            val data_end = data_offset + entry.uncompressed_size
            if data_end > self.file_data.len():
                return Err("File data extends beyond archive for: {path}")

            val file_bytes = slice_bytes(self.file_data, data_offset, data_end)

            # Verify CRC-32
            val computed_crc = crc32(file_bytes)
            if computed_crc != entry.crc32:
                return Err("CRC-32 mismatch for {path}: expected {entry.crc32}, got {computed_crc}")

            return Ok(file_bytes)

        Err("Unsupported compression method {entry.method} for: {path}")

    # Check if a file exists in the archive.
    fn has_file(path: text) -> bool:
        for entry in self.entries:
            if entry.path == path:
                return true
        false

    # Get the number of entries in the archive.
    fn file_count() -> i64:
        self.entries.len()

    # Get all entry information records.
    fn get_entries() -> [ZipFileInfo]:
        self.entries

# ============================================================================
# Helper Functions
# ============================================================================

# Find the End of Central Directory record by scanning backwards.
# Returns the offset of the EOCD signature, or -1 if not found.
fn find_eocd(data: [u8]) -> i64:
    val data_len = data.len()
    if data_len < ZIP_EOCD_SIZE:
        return -1

    # Maximum scan distance: EOCD (22) + max comment (65535)
    var max_scan = 65557
    if max_scan > data_len:
        max_scan = data_len

    var offset = data_len - ZIP_EOCD_SIZE
    val min_offset = data_len - max_scan

    while offset >= min_offset:
        val sig = read_u32_le(data, offset)
        if sig == ZIP_EOCD_SIG:
            return offset
        offset = offset - 1

    -1

# CRC-32 calculation (shared with zip_writer).
fn crc32(data: [u8]) -> u32:
    var crc: u32 = 0xFFFFFFFF
    var i = 0
    while i < data.len():
        val byte_val = data[i] as u32
        crc = crc xor byte_val
        var bit = 0
        while bit < 8:
            if (crc and 1) != 0:
                crc = (crc >> 1) xor 0xEDB88320
            else:
                crc = crc >> 1
            bit = bit + 1
        i = i + 1
    crc xor 0xFFFFFFFF

# Read a u16 from bytes at the given offset (little-endian).
fn read_u16_le(data: [u8], offset: i64) -> u16:
    if offset < 0 or offset + 1 >= data.len():
        return 0
    val b0 = data[offset] as u16
    val b1 = (data[offset + 1] as u16) << 8
    b0 or b1

# Read a u32 from bytes at the given offset (little-endian).
fn read_u32_le(data: [u8], offset: i64) -> u32:
    if offset < 0 or offset + 3 >= data.len():
        return 0
    val b0 = data[offset] as u32
    val b1 = (data[offset + 1] as u32) << 8
    val b2 = (data[offset + 2] as u32) << 16
    val b3 = (data[offset + 3] as u32) << 24
    b0 or b1 or b2 or b3

# Convert a byte range to text.
fn bytes_to_text(data: [u8], start: i64, end: i64) -> text:
    val safe_start = if start < 0: 0 else: start
    val safe_end = if end > data.len(): data.len() else: end
    if safe_end < safe_start:
        return ""
    var chars: [text] = []
    var i = safe_start
    while i < safe_end:
        chars.push(char_from_byte(data[i]))
        i = i + 1
    chars.join("")

# Convert a byte to a single-character text.
fn char_from_byte(b: u8) -> text:
    val c = b as i64
    "{c}"

# Extract a byte range from a byte array.
fn slice_bytes(data: [u8], start: i64, end: i64) -> [u8]:
    val safe_start = if start < 0: 0 else: start
    val safe_end = if end > data.len(): data.len() else: end
    var result: [u8] = []
    if safe_end < safe_start:
        return result
    var i = safe_start
    while i < safe_end:
        result.push(data[i])
        i = i + 1
    result

# ============================================================================
# Exports
# ============================================================================
