# ZIP Writer - Pure Simple implementation of ZIP archive creation
#
# Creates ZIP files compatible with standard unzip tools.
# Supports Store method (no compression, type 0) by default.
#
# ZIP format uses little-endian byte ordering throughout.
#
# Usage:
#   var zip = ZipWriter.new()
#   zip.add_file("hello.txt", text_to_bytes("Hello, world!"))
#   zip.add_directory("subdir/")
#   zip.add_file_from_disk("data.bin", "/path/to/data.bin")
#   zip.write("output.zip")

use app.io.{file_read, file_write, file_exists}

extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

# ============================================================================
# Constants
# ============================================================================

val ZIP_LOCAL_FILE_SIGNATURE: u32 = 0x04034B50      # PK\x03\x04
val ZIP_CENTRAL_DIR_SIGNATURE: u32 = 0x02014B50     # PK\x01\x02
val ZIP_EOCD_SIGNATURE: u32 = 0x06054B50            # PK\x05\x06
val ZIP_METHOD_STORE: u16 = 0                        # No compression
val ZIP_VERSION_NEEDED: u16 = 20                     # Version 2.0
val ZIP_VERSION_MADE: u16 = 20                       # Version 2.0

# ============================================================================
# CRC-32 Calculation
# ============================================================================

# Compute CRC-32 (ISO 3309) with polynomial 0xEDB88320.
# This is the standard CRC-32 used by ZIP, gzip, PNG, etc.
fn crc32(data: [u8]) -> u32:
    var crc: u32 = 0xFFFFFFFF
    var i = 0
    while i < data.len():
        val byte_val = data[i] as u32
        crc = crc xor byte_val
        var bit = 0
        while bit < 8:
            if (crc and 1) != 0:
                crc = (crc >> 1) xor 0xEDB88320
            else:
                crc = crc >> 1
            bit = bit + 1
        i = i + 1
    crc xor 0xFFFFFFFF

# ============================================================================
# ZIP Entry
# ============================================================================

# Represents a single file or directory entry in a ZIP archive.
struct ZipEntry:
    path: text           # File path inside ZIP (forward slashes)
    data: [u8]           # File contents (empty for directories)
    method: u16          # 0=store, 8=deflate
    crc: u32             # CRC-32 of uncompressed data
    is_directory: bool   # True if this is a directory entry

# ============================================================================
# ZIP Writer
# ============================================================================

# Builder for creating ZIP archive files.
#
# Example:
#   var zip = ZipWriter.new()
#   zip.add_file("README.txt", text_to_bytes("Hello"))
#   zip.add_directory("lib/")
#   zip.write("archive.zip")
struct ZipWriter:
    entries: [ZipEntry]

impl ZipWriter:
    # Create a new empty ZIP writer.
    static fn new() -> ZipWriter:
        ZipWriter(entries: [])

    # Add a file with in-memory data (store method, no compression).
    #
    # Args:
    #   path: File path inside the ZIP archive (use forward slashes)
    #   data: File contents as bytes
    #
    # Returns:
    #   Ok(()) on success, Err with message on failure
    me add_file(path: text, data: [u8]) -> Result<(), text>:
        if path.len() == 0:
            return Err("ZIP entry path cannot be empty")

        val checksum = crc32(data)
        val entry = ZipEntry(
            path: normalize_zip_path(path),
            data: data,
            method: ZIP_METHOD_STORE,
            crc: checksum,
            is_directory: false
        )
        self.entries.push(entry)
        Ok(())

    # Add a file from disk (store method, no compression).
    #
    # Args:
    #   path: File path inside the ZIP archive
    #   disk_path: Path to the file on disk
    #
    # Returns:
    #   Ok(()) on success, Err with message on failure
    me add_file_from_disk(path: text, disk_path: text) -> Result<(), text>:
        if not file_exists(disk_path):
            return Err("File not found: {disk_path}")

        val data = rt_file_read_bytes(disk_path)
        self.add_file(path, data)

    # Add a directory entry to the ZIP archive.
    # Directory paths must end with '/'.
    #
    # Args:
    #   path: Directory path inside the ZIP archive
    me add_directory(path: text):
        var dir_path = normalize_zip_path(path)
        if not dir_path.ends_with("/"):
            dir_path = dir_path + "/"

        val entry = ZipEntry(
            path: dir_path,
            data: [],
            method: ZIP_METHOD_STORE,
            crc: 0,
            is_directory: true
        )
        self.entries.push(entry)

    # Write the ZIP archive to a file on disk.
    #
    # The ZIP format is:
    # 1. Local file headers + file data (for each entry)
    # 2. Central directory headers (for each entry)
    # 3. End of central directory record (EOCD)
    #
    # Args:
    #   output_path: Path for the output ZIP file
    #
    # Returns:
    #   Ok(()) on success, Err with message on failure
    fn write(output_path: text) -> Result<(), text>:
        var output: [u8] = []

        # Track local header offsets for the central directory
        var local_offsets: [i64] = []

        # --- Phase 1: Write local file headers + data ---
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            local_offsets.push(output.len())

            val path_bytes = text_to_bytes(entry.path)
            val compressed_size = entry.data.len() as u32
            val uncompressed_size = entry.data.len() as u32

            # Local file header (30 bytes + filename)
            write_u32_le(output, ZIP_LOCAL_FILE_SIGNATURE)
            write_u16_le(output, ZIP_VERSION_NEEDED)      # version needed
            write_u16_le(output, 0)                        # flags
            write_u16_le(output, entry.method)             # compression method
            write_u16_le(output, 0)                        # mod time
            write_u16_le(output, 0)                        # mod date
            write_u32_le(output, entry.crc)                # crc32
            write_u32_le(output, compressed_size)          # compressed size
            write_u32_le(output, uncompressed_size)        # uncompressed size
            write_u16_le(output, path_bytes.len() as u16)  # filename length
            write_u16_le(output, 0)                        # extra field length

            # Filename
            append_bytes(output, path_bytes)

            # File data
            append_bytes(output, entry.data)

            i = i + 1

        # --- Phase 2: Write central directory ---
        val cd_offset = output.len()
        var cd_count = 0

        i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            val local_offset = local_offsets[i]
            val path_bytes = text_to_bytes(entry.path)
            val compressed_size = entry.data.len() as u32
            val uncompressed_size = entry.data.len() as u32

            # External attributes: set directory bit if needed
            var external_attrs: u32 = 0
            if entry.is_directory:
                external_attrs = 0x10  # MS-DOS directory attribute

            # Central directory file header (46 bytes + filename)
            write_u32_le(output, ZIP_CENTRAL_DIR_SIGNATURE)
            write_u16_le(output, ZIP_VERSION_MADE)          # version made by
            write_u16_le(output, ZIP_VERSION_NEEDED)        # version needed
            write_u16_le(output, 0)                          # flags
            write_u16_le(output, entry.method)               # compression method
            write_u16_le(output, 0)                          # mod time
            write_u16_le(output, 0)                          # mod date
            write_u32_le(output, entry.crc)                  # crc32
            write_u32_le(output, compressed_size)            # compressed size
            write_u32_le(output, uncompressed_size)          # uncompressed size
            write_u16_le(output, path_bytes.len() as u16)    # filename length
            write_u16_le(output, 0)                          # extra field length
            write_u16_le(output, 0)                          # file comment length
            write_u16_le(output, 0)                          # disk number start
            write_u16_le(output, 0)                          # internal file attributes
            write_u32_le(output, external_attrs)             # external file attributes
            write_u32_le(output, local_offset as u32)        # relative offset of local header

            # Filename
            append_bytes(output, path_bytes)

            cd_count = cd_count + 1
            i = i + 1

        val cd_size = output.len() - cd_offset

        # --- Phase 3: Write end of central directory record (EOCD) ---
        write_u32_le(output, ZIP_EOCD_SIGNATURE)
        write_u16_le(output, 0)                          # disk number
        write_u16_le(output, 0)                          # disk with central directory
        write_u16_le(output, cd_count as u16)            # entries on this disk
        write_u16_le(output, cd_count as u16)            # total entries
        write_u32_le(output, cd_size as u32)             # size of central directory
        write_u32_le(output, cd_offset as u32)           # offset of central directory
        write_u16_le(output, 0)                          # comment length

        # Write to disk
        val ok = rt_file_write_bytes(output_path, output)
        if not ok:
            return Err("Failed to write ZIP file: {output_path}")

        Ok(())

    # Get number of entries.
    fn entry_count() -> i64:
        self.entries.len()

# ============================================================================
# Helper Functions
# ============================================================================

# Write a u16 value in little-endian to a byte array.
fn write_u16_le(buf: [u8], value: u16):
    buf.push((value and 0xFF) as u8)
    buf.push(((value >> 8) and 0xFF) as u8)

# Write a u32 value in little-endian to a byte array.
fn write_u32_le(buf: [u8], value: u32):
    buf.push((value and 0xFF) as u8)
    buf.push(((value >> 8) and 0xFF) as u8)
    buf.push(((value >> 16) and 0xFF) as u8)
    buf.push(((value >> 24) and 0xFF) as u8)

# Read a u16 from bytes at the given offset (little-endian).
fn read_u16_le(data: [u8], offset: i64) -> u16:
    if offset < 0 or offset + 1 >= data.len():
        return 0
    val b0 = data[offset] as u16
    val b1 = (data[offset + 1] as u16) << 8
    b0 or b1

# Read a u32 from bytes at the given offset (little-endian).
fn read_u32_le(data: [u8], offset: i64) -> u32:
    if offset < 0 or offset + 3 >= data.len():
        return 0
    val b0 = data[offset] as u32
    val b1 = (data[offset + 1] as u32) << 8
    val b2 = (data[offset + 2] as u32) << 16
    val b3 = (data[offset + 3] as u32) << 24
    b0 or b1 or b2 or b3

# Convert text to bytes (UTF-8).
fn text_to_bytes(t: text) -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < t.len():
        bytes.push(t[i] as u8)
        i = i + 1
    bytes

# Convert bytes to text.
fn bytes_to_text(bytes: [u8]) -> text:
    var chars: [text] = []
    for b in bytes:
        chars.push(char_from_byte(b))
    chars.join("")

# Convert a byte to a single-character text.
fn char_from_byte(b: u8) -> text:
    val c = b as i64
    "{c}"

# Append all bytes from src to dst.
fn append_bytes(dst: [u8], src: [u8]):
    for b in src:
        dst.push(b)

# Normalize a ZIP path: use forward slashes, no leading slash.
fn normalize_zip_path(path: text) -> text:
    var result = path.replace("\\", "/")
    if result.starts_with("/"):
        result = result.slice(1, result.len())
    result

# ============================================================================
# Exports
# ============================================================================
