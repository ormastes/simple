# Coroutine Helpers — game-loop yield helpers
#
# Simple timer and frame-counter structs for game loops.
# These track elapsed time or frame counts without needing
# the full coroutine system.

# ============================================================================
# WaitTimer — time-based wait helper
# ============================================================================

struct WaitTimer:
    elapsed: f64
    duration: f64
    done: bool

impl WaitTimer:
    static fn wait_seconds(duration: f64) -> WaitTimer:
        """Create a timer that waits for the given duration in seconds."""
        WaitTimer(
            elapsed: 0.0,
            duration: duration,
            done: false
        )

    me tick(dt: f64) -> bool:
        """Advance the timer by dt seconds. Returns true when done."""
        if self.done:
            return true
        self.elapsed = self.elapsed + dt
        if self.elapsed >= self.duration:
            self.elapsed = self.duration
            self.done = true
        self.done

    fn is_done(self) -> bool:
        """Check if the timer has completed."""
        self.done

    fn progress(self) -> f64:
        """Return progress from 0.0 to 1.0."""
        if self.duration <= 0.0:
            return 1.0
        val p = self.elapsed / self.duration
        if p > 1.0:
            return 1.0
        p

# ============================================================================
# FrameCounter — frame-based wait helper
# ============================================================================

struct FrameCounter:
    current: i64
    target: i64
    done: bool

impl FrameCounter:
    static fn wait_frames(count: i64) -> FrameCounter:
        """Create a counter that waits for the given number of frames."""
        FrameCounter(
            current: 0,
            target: count,
            done: false
        )

    me tick() -> bool:
        """Advance by one frame. Returns true when done."""
        if self.done:
            return true
        self.current = self.current + 1
        if self.current >= self.target:
            self.done = true
        self.done

    fn is_done(self) -> bool:
        """Check if the counter has completed."""
        self.done

# ============================================================================
# ConditionWait — named condition placeholder
# ============================================================================

struct ConditionWait:
    check_fn_name: text
    done: bool
