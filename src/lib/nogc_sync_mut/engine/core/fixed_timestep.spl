"""
Fixed Timestep Accumulator — shared physics-step driver for 2D and 3D game loops.

Provides a standalone accumulator that converts variable-length frame deltas into
a deterministic number of fixed-duration physics steps, plus an interpolation alpha
for smooth rendering between steps.  It is intentionally decoupled from the
wall-clock / nanosecond machinery in `time.spl` so that it can be composed into
any loop.

Usage:
    var ts = FixedTimestep.create(1.0 / 60.0, 5)
    # each frame:
    val steps = ts.advance(frame_dt_seconds)
    var i = 0
    while i < steps:
        physics.step(ts.fixed_dt)
        i = i + 1
    val alpha = ts.interpolation_alpha()
    renderer.draw_interpolated(alpha)

Wiring note for game_loop.spl (2D):
    Replace the inlined `Clock.consume_fixed_steps()` call with a `FixedTimestep`
    field on `GameLoop`.  In `run()`, call `ts.advance(frame.delta.value)` to
    obtain the step count, then iterate physics as above.  Pass `ts.interpolation_alpha()`
    to `on_render` so the 2D renderer can interpolate sprite positions.

Wiring note for game_loop3d.spl (3D):
    Replace the `Clock.consume_fixed_steps()` call in `GameLoop3D.run()` with
    `ts.advance(frame.delta.value)`.  Add a `FixedTimestep` field to `GameLoop3D`
    alongside `clock`.  Forward `ts.interpolation_alpha()` to the 3D renderer via
    an extra parameter on `on_render` (or store it on `FrameTime`).  Both loops
    use `f64` seconds natively, so no unit conversion is required.
"""

use std.io_runtime

# ============================================================================
# FixedTimestep — fixed-rate physics accumulator
# ============================================================================

class FixedTimestep:
    """Fixed-timestep accumulator for deterministic physics updates.

    Collects variable-length frame deltas and converts them into an integer
    count of fixed-duration steps.  Caps steps per frame to prevent the
    spiral-of-death when the simulation falls behind.

    Fields:
        fixed_dt:     Duration of each physics step in seconds (e.g. 1.0/60.0)
        max_substeps: Maximum number of steps allowed per frame
        accumulator:  Leftover time (seconds) carried between frames; always in [0, fixed_dt)
    """
    fixed_dt: f64
    max_substeps: i64
    accumulator: f64

impl FixedTimestep:
    static fn create(fixed_dt: f64, max_substeps: i64) -> FixedTimestep:
        """Create a FixedTimestep accumulator.

        Args:
            fixed_dt:     Seconds per physics step (e.g. 1.0/60.0 for 60 Hz physics)
            max_substeps: Maximum fixed steps per frame; excess is drained to zero
                          to avoid the spiral-of-death.

        Returns:
            A new FixedTimestep with a zeroed accumulator.
        """
        FixedTimestep(
            fixed_dt: fixed_dt,
            max_substeps: max_substeps,
            accumulator: 0.0
        )

    me fn advance(frame_dt: f64) -> i64:
        """Accumulate a frame delta and return the number of fixed steps to run.

        Adds `frame_dt` to the internal accumulator, then counts how many
        complete `fixed_dt` slices fit.  If that count exceeds `max_substeps`,
        the count is capped and the accumulator is drained to zero to prevent
        the simulation from spiralling behind real time.

        Args:
            frame_dt: Wall-clock seconds elapsed since the previous frame.

        Returns:
            Number of fixed physics steps to execute this frame (0 .. max_substeps).
        """
        self.accumulator = self.accumulator + frame_dt

        var steps = 0
        while self.accumulator >= self.fixed_dt:
            self.accumulator = self.accumulator - self.fixed_dt
            steps = steps + 1

        if steps > self.max_substeps:
            steps = self.max_substeps
            self.accumulator = 0.0

        steps

    me fn interpolation_alpha() -> f64:
        """Return the render-interpolation factor for the current frame.

        Represents how far (as a fraction in [0, 1)) the simulation has
        progressed into the next fixed step.  Use this to linearly interpolate
        between the previous and current physics state for smooth rendering.

        Returns:
            accumulator / fixed_dt, in [0, 1).  Returns 0.0 if fixed_dt <= 0.
        """
        if self.fixed_dt > 0.0:
            self.accumulator / self.fixed_dt
        else:
            0.0

export FixedTimestep
