# Physics2 — Configuration
#
# World simulation parameters for 2D and 3D physics.

use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics2.backend.{PhysicsBackend}

struct PhysicsConfig2D:
    gravity: Vec2
    fixed_timestep: f64
    sub_steps: i64
    velocity_iterations: i64
    position_iterations: i64
    sleep_enabled: bool
    sleep_threshold: f64
    sleep_time_required: f64
    restitution: f64
    friction: f64
    baumgarte_factor: f64
    slop: f64
    backend: PhysicsBackend

fn default_physics_config_2d() -> PhysicsConfig2D:
    PhysicsConfig2D(
        gravity: Vec2(x: 0.0, y: -9.81),
        fixed_timestep: 0.008333333333333333,
        sub_steps: 2,
        velocity_iterations: 6,
        position_iterations: 2,
        sleep_enabled: true,
        sleep_threshold: 0.01,
        sleep_time_required: 0.5,
        restitution: 0.3,
        friction: 0.4,
        baumgarte_factor: 0.2,
        slop: 0.01,
        backend: PhysicsBackend.Auto
    )

struct Vec3:
    x: f64
    y: f64
    z: f64

impl Vec3:
    static fn zero() -> Vec3:
        Vec3(x: 0.0, y: 0.0, z: 0.0)

struct PhysicsConfig3D:
    gravity: Vec3
    fixed_timestep: f64
    sub_steps: i64
    velocity_iterations: i64
    position_iterations: i64
    sleep_enabled: bool
    sleep_threshold: f64
    sleep_time_required: f64
    restitution: f64
    friction: f64
    baumgarte_factor: f64
    slop: f64
    backend: PhysicsBackend

fn default_physics_config_3d() -> PhysicsConfig3D:
    PhysicsConfig3D(
        gravity: Vec3(x: 0.0, y: -9.81, z: 0.0),
        fixed_timestep: 0.008333333333333333,
        sub_steps: 2,
        velocity_iterations: 6,
        position_iterations: 2,
        sleep_enabled: true,
        sleep_threshold: 0.01,
        sleep_time_required: 0.5,
        restitution: 0.3,
        friction: 0.4,
        baumgarte_factor: 0.2,
        slop: 0.01,
        backend: PhysicsBackend.Auto
    )
