# Physics2 — Constraint Data (SoA)
#
# Contact and joint constraints stored as structure-of-arrays for
# cache-friendly iteration and SIMD batching.

struct ContactConstraintSoA:
    body_a: [i64]
    body_b: [i64]
    normal_x: [f64]
    normal_y: [f64]
    point_x: [f64]
    point_y: [f64]
    penetration: [f64]
    restitution: [f64]
    friction: [f64]
    lambda_n: [f64]
    lambda_t: [f64]
    feature_id_a: [i64]
    feature_id_b: [i64]
    count: i64

impl ContactConstraintSoA:
    static fn create() -> ContactConstraintSoA:
        ContactConstraintSoA(
            body_a: [], body_b: [],
            normal_x: [], normal_y: [],
            point_x: [], point_y: [],
            penetration: [],
            restitution: [], friction: [],
            lambda_n: [], lambda_t: [],
            feature_id_a: [], feature_id_b: [],
            count: 0
        )

    me add(a: i64, b: i64, nx: f64, ny: f64, px: f64, py: f64, pen: f64, rest: f64, fric: f64, feat_a: i64, feat_b: i64):
        self.body_a.push(a)
        self.body_b.push(b)
        self.normal_x.push(nx)
        self.normal_y.push(ny)
        self.point_x.push(px)
        self.point_y.push(py)
        self.penetration.push(pen)
        self.restitution.push(rest)
        self.friction.push(fric)
        self.lambda_n.push(0.0)
        self.lambda_t.push(0.0)
        self.feature_id_a.push(feat_a)
        self.feature_id_b.push(feat_b)
        self.count = self.count + 1

    me clear():
        self.body_a = []
        self.body_b = []
        self.normal_x = []
        self.normal_y = []
        self.point_x = []
        self.point_y = []
        self.penetration = []
        self.restitution = []
        self.friction = []
        self.lambda_n = []
        self.lambda_t = []
        self.feature_id_a = []
        self.feature_id_b = []
        self.count = 0

struct JointConstraint2D:
    joint_type: i64
    body_a: i64
    body_b: i64
    anchor_a_x: f64
    anchor_a_y: f64
    anchor_b_x: f64
    anchor_b_y: f64
    rest_length: f64
    stiffness: f64
    damping: f64

struct JointConstraintStore:
    constraints: [JointConstraint2D]
    count: i64

impl JointConstraintStore:
    static fn create() -> JointConstraintStore:
        JointConstraintStore(constraints: [], count: 0)

    me add(jc: JointConstraint2D):
        self.constraints.push(jc)
        self.count = self.count + 1
