# Physics2 — SoA Solver Bodies (2D)
#
# Structure-of-Arrays layout for cache-friendly, SIMD-ready body data.
# Bodies are stored as parallel arrays (SoA) rather than array-of-structs.
# For SIMD backends, data is packed into AoSoA blocks of lane_width.

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}

struct SolverBodyStore2D:
    pos_x: [f64]
    pos_y: [f64]
    prev_pos_x: [f64]
    prev_pos_y: [f64]
    vel_x: [f64]
    vel_y: [f64]
    ang_vel: [f64]
    rotation: [f64]
    prev_rotation: [f64]
    force_x: [f64]
    force_y: [f64]
    torque: [f64]
    inv_mass: [f64]
    inv_inertia: [f64]
    linear_damping: [f64]
    angular_damping: [f64]
    gravity_scale: [f64]
    body_type: [i64]
    node_ids: [NodeId]
    body_count: i64

impl SolverBodyStore2D:
    static fn create() -> SolverBodyStore2D:
        SolverBodyStore2D(
            pos_x: [], pos_y: [],
            prev_pos_x: [], prev_pos_y: [],
            vel_x: [], vel_y: [],
            ang_vel: [], rotation: [], prev_rotation: [],
            force_x: [], force_y: [], torque: [],
            inv_mass: [], inv_inertia: [],
            linear_damping: [], angular_damping: [],
            gravity_scale: [],
            body_type: [],
            node_ids: [],
            body_count: 0
        )

    me add_dynamic(node_id: NodeId, x: f64, y: f64, mass: f64) -> i64:
        val idx = self.body_count
        val im = 1.0 / mass
        val inertia = mass * 0.4
        val ii = 1.0 / inertia
        self.pos_x.push(x)
        self.pos_y.push(y)
        self.prev_pos_x.push(x)
        self.prev_pos_y.push(y)
        self.vel_x.push(0.0)
        self.vel_y.push(0.0)
        self.ang_vel.push(0.0)
        self.rotation.push(0.0)
        self.prev_rotation.push(0.0)
        self.force_x.push(0.0)
        self.force_y.push(0.0)
        self.torque.push(0.0)
        self.inv_mass.push(im)
        self.inv_inertia.push(ii)
        self.linear_damping.push(0.01)
        self.angular_damping.push(0.01)
        self.gravity_scale.push(1.0)
        self.body_type.push(2)
        self.node_ids.push(node_id)
        self.body_count = self.body_count + 1
        idx

    me add_static(node_id: NodeId, x: f64, y: f64) -> i64:
        val idx = self.body_count
        self.pos_x.push(x)
        self.pos_y.push(y)
        self.prev_pos_x.push(x)
        self.prev_pos_y.push(y)
        self.vel_x.push(0.0)
        self.vel_y.push(0.0)
        self.ang_vel.push(0.0)
        self.rotation.push(0.0)
        self.prev_rotation.push(0.0)
        self.force_x.push(0.0)
        self.force_y.push(0.0)
        self.torque.push(0.0)
        self.inv_mass.push(0.0)
        self.inv_inertia.push(0.0)
        self.linear_damping.push(0.0)
        self.angular_damping.push(0.0)
        self.gravity_scale.push(0.0)
        self.body_type.push(0)
        self.node_ids.push(node_id)
        self.body_count = self.body_count + 1
        idx

    me add_kinematic(node_id: NodeId, x: f64, y: f64) -> i64:
        val idx = self.body_count
        self.pos_x.push(x)
        self.pos_y.push(y)
        self.prev_pos_x.push(x)
        self.prev_pos_y.push(y)
        self.vel_x.push(0.0)
        self.vel_y.push(0.0)
        self.ang_vel.push(0.0)
        self.rotation.push(0.0)
        self.prev_rotation.push(0.0)
        self.force_x.push(0.0)
        self.force_y.push(0.0)
        self.torque.push(0.0)
        self.inv_mass.push(0.0)
        self.inv_inertia.push(0.0)
        self.linear_damping.push(0.0)
        self.angular_damping.push(0.0)
        self.gravity_scale.push(0.0)
        self.body_type.push(1)
        self.node_ids.push(node_id)
        self.body_count = self.body_count + 1
        idx

    me is_dynamic(idx: i64) -> bool:
        self.body_type[idx] == 2

    me is_static(idx: i64) -> bool:
        self.body_type[idx] == 0

    me is_kinematic(idx: i64) -> bool:
        self.body_type[idx] == 1

    me save_prev_transforms():
        var i = 0
        while i < self.body_count:
            self.prev_pos_x[i] = self.pos_x[i]
            self.prev_pos_y[i] = self.pos_y[i]
            self.prev_rotation[i] = self.rotation[i]
            i = i + 1

    me integrate(dt: f64, gravity_x: f64, gravity_y: f64):
        var i = 0
        while i < self.body_count:
            if self.body_type[i] == 2:
                val gx = gravity_x * self.gravity_scale[i]
                val gy = gravity_y * self.gravity_scale[i]
                val ax = (self.force_x[i] * self.inv_mass[i]) + gx
                val ay = (self.force_y[i] * self.inv_mass[i]) + gy
                self.vel_x[i] = (self.vel_x[i] + ax * dt) * (1.0 - self.linear_damping[i] * dt)
                self.vel_y[i] = (self.vel_y[i] + ay * dt) * (1.0 - self.linear_damping[i] * dt)
                self.pos_x[i] = self.pos_x[i] + self.vel_x[i] * dt
                self.pos_y[i] = self.pos_y[i] + self.vel_y[i] * dt
                val alpha = self.torque[i] * self.inv_inertia[i]
                self.ang_vel[i] = (self.ang_vel[i] + alpha * dt) * (1.0 - self.angular_damping[i] * dt)
                self.rotation[i] = self.rotation[i] + self.ang_vel[i] * dt
                self.force_x[i] = 0.0
                self.force_y[i] = 0.0
                self.torque[i] = 0.0
            i = i + 1

    me apply_force_at(idx: i64, fx: f64, fy: f64):
        self.force_x[idx] = self.force_x[idx] + fx
        self.force_y[idx] = self.force_y[idx] + fy

    me apply_impulse_at(idx: i64, ix: f64, iy: f64):
        self.vel_x[idx] = self.vel_x[idx] + ix * self.inv_mass[idx]
        self.vel_y[idx] = self.vel_y[idx] + iy * self.inv_mass[idx]

    me get_position(idx: i64) -> Vec2:
        Vec2(x: self.pos_x[idx], y: self.pos_y[idx])

    me get_velocity(idx: i64) -> Vec2:
        Vec2(x: self.vel_x[idx], y: self.vel_y[idx])

    me set_position(idx: i64, x: f64, y: f64):
        self.pos_x[idx] = x
        self.pos_y[idx] = y

    me set_velocity(idx: i64, vx: f64, vy: f64):
        self.vel_x[idx] = vx
        self.vel_y[idx] = vy
