# Physics2 — SoA Solver Bodies (3D)
#
# Structure-of-Arrays layout for 3D physics bodies with quaternion rotation.

use std.common.engine.ids.{NodeId}
use std.nogc_sync_mut.engine.physics2.config.{Vec3}

struct SolverBodyStore3D:
    pos_x: [f64]
    pos_y: [f64]
    pos_z: [f64]
    prev_pos_x: [f64]
    prev_pos_y: [f64]
    prev_pos_z: [f64]
    vel_x: [f64]
    vel_y: [f64]
    vel_z: [f64]
    ang_vel_x: [f64]
    ang_vel_y: [f64]
    ang_vel_z: [f64]
    # Quaternion rotation (w, x, y, z)
    rot_w: [f64]
    rot_x: [f64]
    rot_y: [f64]
    rot_z: [f64]
    prev_rot_w: [f64]
    prev_rot_x: [f64]
    prev_rot_y: [f64]
    prev_rot_z: [f64]
    force_x: [f64]
    force_y: [f64]
    force_z: [f64]
    torque_x: [f64]
    torque_y: [f64]
    torque_z: [f64]
    inv_mass: [f64]
    inv_inertia_x: [f64]
    inv_inertia_y: [f64]
    inv_inertia_z: [f64]
    linear_damping: [f64]
    angular_damping: [f64]
    gravity_scale: [f64]
    body_type: [i64]
    node_ids: [NodeId]
    body_count: i64

impl SolverBodyStore3D:
    static fn create() -> SolverBodyStore3D:
        SolverBodyStore3D(
            pos_x: [], pos_y: [], pos_z: [],
            prev_pos_x: [], prev_pos_y: [], prev_pos_z: [],
            vel_x: [], vel_y: [], vel_z: [],
            ang_vel_x: [], ang_vel_y: [], ang_vel_z: [],
            rot_w: [], rot_x: [], rot_y: [], rot_z: [],
            prev_rot_w: [], prev_rot_x: [], prev_rot_y: [], prev_rot_z: [],
            force_x: [], force_y: [], force_z: [],
            torque_x: [], torque_y: [], torque_z: [],
            inv_mass: [],
            inv_inertia_x: [], inv_inertia_y: [], inv_inertia_z: [],
            linear_damping: [], angular_damping: [],
            gravity_scale: [],
            body_type: [],
            node_ids: [],
            body_count: 0
        )

    me add_dynamic(node_id: NodeId, x: f64, y: f64, z: f64, mass: f64) -> i64:
        val idx = self.body_count
        val im = 1.0 / mass
        val inertia = mass * 0.4
        val ii = 1.0 / inertia
        self.pos_x.push(x)
        self.pos_y.push(y)
        self.pos_z.push(z)
        self.prev_pos_x.push(x)
        self.prev_pos_y.push(y)
        self.prev_pos_z.push(z)
        self.vel_x.push(0.0)
        self.vel_y.push(0.0)
        self.vel_z.push(0.0)
        self.ang_vel_x.push(0.0)
        self.ang_vel_y.push(0.0)
        self.ang_vel_z.push(0.0)
        self.rot_w.push(1.0)
        self.rot_x.push(0.0)
        self.rot_y.push(0.0)
        self.rot_z.push(0.0)
        self.prev_rot_w.push(1.0)
        self.prev_rot_x.push(0.0)
        self.prev_rot_y.push(0.0)
        self.prev_rot_z.push(0.0)
        self.force_x.push(0.0)
        self.force_y.push(0.0)
        self.force_z.push(0.0)
        self.torque_x.push(0.0)
        self.torque_y.push(0.0)
        self.torque_z.push(0.0)
        self.inv_mass.push(im)
        self.inv_inertia_x.push(ii)
        self.inv_inertia_y.push(ii)
        self.inv_inertia_z.push(ii)
        self.linear_damping.push(0.01)
        self.angular_damping.push(0.01)
        self.gravity_scale.push(1.0)
        self.body_type.push(2)
        self.node_ids.push(node_id)
        self.body_count = self.body_count + 1
        idx

    me add_static(node_id: NodeId, x: f64, y: f64, z: f64) -> i64:
        val idx = self.body_count
        self.pos_x.push(x)
        self.pos_y.push(y)
        self.pos_z.push(z)
        self.prev_pos_x.push(x)
        self.prev_pos_y.push(y)
        self.prev_pos_z.push(z)
        self.vel_x.push(0.0)
        self.vel_y.push(0.0)
        self.vel_z.push(0.0)
        self.ang_vel_x.push(0.0)
        self.ang_vel_y.push(0.0)
        self.ang_vel_z.push(0.0)
        self.rot_w.push(1.0)
        self.rot_x.push(0.0)
        self.rot_y.push(0.0)
        self.rot_z.push(0.0)
        self.prev_rot_w.push(1.0)
        self.prev_rot_x.push(0.0)
        self.prev_rot_y.push(0.0)
        self.prev_rot_z.push(0.0)
        self.force_x.push(0.0)
        self.force_y.push(0.0)
        self.force_z.push(0.0)
        self.torque_x.push(0.0)
        self.torque_y.push(0.0)
        self.torque_z.push(0.0)
        self.inv_mass.push(0.0)
        self.inv_inertia_x.push(0.0)
        self.inv_inertia_y.push(0.0)
        self.inv_inertia_z.push(0.0)
        self.linear_damping.push(0.0)
        self.angular_damping.push(0.0)
        self.gravity_scale.push(0.0)
        self.body_type.push(0)
        self.node_ids.push(node_id)
        self.body_count = self.body_count + 1
        idx

    me is_dynamic(idx: i64) -> bool:
        self.body_type[idx] == 2

    me save_prev_transforms():
        var i = 0
        while i < self.body_count:
            self.prev_pos_x[i] = self.pos_x[i]
            self.prev_pos_y[i] = self.pos_y[i]
            self.prev_pos_z[i] = self.pos_z[i]
            self.prev_rot_w[i] = self.rot_w[i]
            self.prev_rot_x[i] = self.rot_x[i]
            self.prev_rot_y[i] = self.rot_y[i]
            self.prev_rot_z[i] = self.rot_z[i]
            i = i + 1

    me integrate(dt: f64, gx: f64, gy: f64, gz: f64):
        var i = 0
        while i < self.body_count:
            if self.body_type[i] == 2:
                val gravity_x = gx * self.gravity_scale[i]
                val gravity_y = gy * self.gravity_scale[i]
                val gravity_z = gz * self.gravity_scale[i]
                val ax = (self.force_x[i] * self.inv_mass[i]) + gravity_x
                val ay = (self.force_y[i] * self.inv_mass[i]) + gravity_y
                val az = (self.force_z[i] * self.inv_mass[i]) + gravity_z
                val damp = 1.0 - self.linear_damping[i] * dt
                self.vel_x[i] = (self.vel_x[i] + ax * dt) * damp
                self.vel_y[i] = (self.vel_y[i] + ay * dt) * damp
                self.vel_z[i] = (self.vel_z[i] + az * dt) * damp
                self.pos_x[i] = self.pos_x[i] + self.vel_x[i] * dt
                self.pos_y[i] = self.pos_y[i] + self.vel_y[i] * dt
                self.pos_z[i] = self.pos_z[i] + self.vel_z[i] * dt
                # Angular integration
                val ang_damp = 1.0 - self.angular_damping[i] * dt
                val tx = self.torque_x[i] * self.inv_inertia_x[i]
                val ty = self.torque_y[i] * self.inv_inertia_y[i]
                val tz = self.torque_z[i] * self.inv_inertia_z[i]
                self.ang_vel_x[i] = (self.ang_vel_x[i] + tx * dt) * ang_damp
                self.ang_vel_y[i] = (self.ang_vel_y[i] + ty * dt) * ang_damp
                self.ang_vel_z[i] = (self.ang_vel_z[i] + tz * dt) * ang_damp
                # Quaternion integration: q' = q + 0.5 * dt * omega * q
                val wx = self.ang_vel_x[i]
                val wy = self.ang_vel_y[i]
                val wz = self.ang_vel_z[i]
                val qw = self.rot_w[i]
                val qx = self.rot_x[i]
                val qy = self.rot_y[i]
                val qz = self.rot_z[i]
                val half_dt = 0.5 * dt
                self.rot_w[i] = qw + half_dt * (-wx * qx - wy * qy - wz * qz)
                self.rot_x[i] = qx + half_dt * (wx * qw + wy * qz - wz * qy)
                self.rot_y[i] = qy + half_dt * (-wx * qz + wy * qw + wz * qx)
                self.rot_z[i] = qz + half_dt * (wx * qy - wy * qx + wz * qw)
                # Normalize quaternion
                val nw = self.rot_w[i]
                val nx = self.rot_x[i]
                val ny = self.rot_y[i]
                val nz = self.rot_z[i]
                val len_sq = nw * nw + nx * nx + ny * ny + nz * nz
                if len_sq > 0.0001:
                    var len = len_sq
                    var iter = 0
                    while iter < 8:
                        len = (len + len_sq / len) / 2.0
                        iter = iter + 1
                    val inv_len = 1.0 / len
                    self.rot_w[i] = nw * inv_len
                    self.rot_x[i] = nx * inv_len
                    self.rot_y[i] = ny * inv_len
                    self.rot_z[i] = nz * inv_len
                # Clear forces
                self.force_x[i] = 0.0
                self.force_y[i] = 0.0
                self.force_z[i] = 0.0
                self.torque_x[i] = 0.0
                self.torque_y[i] = 0.0
                self.torque_z[i] = 0.0
            i = i + 1

    me get_position(idx: i64) -> Vec3:
        Vec3(x: self.pos_x[idx], y: self.pos_y[idx], z: self.pos_z[idx])

    me get_velocity(idx: i64) -> Vec3:
        Vec3(x: self.vel_x[idx], y: self.vel_y[idx], z: self.vel_z[idx])

    me apply_force_at(idx: i64, fx: f64, fy: f64, fz: f64):
        self.force_x[idx] = self.force_x[idx] + fx
        self.force_y[idx] = self.force_y[idx] + fy
        self.force_z[idx] = self.force_z[idx] + fz

    me apply_impulse_at(idx: i64, ix: f64, iy: f64, iz: f64):
        self.vel_x[idx] = self.vel_x[idx] + ix * self.inv_mass[idx]
        self.vel_y[idx] = self.vel_y[idx] + iy * self.inv_mass[idx]
        self.vel_z[idx] = self.vel_z[idx] + iz * self.inv_mass[idx]
