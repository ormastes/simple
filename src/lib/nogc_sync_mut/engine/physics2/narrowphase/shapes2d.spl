# Physics2 — 2D Collider Shapes
#
# Shape definitions for 2D collision detection.

use std.common.engine.ids.{NodeId}

enum ShapeType2D:
    Circle
    Box
    Polygon

struct Collider2D:
    body_index: i64
    node_id: NodeId
    shape_type: ShapeType2D
    radius: f64
    half_width: f64
    half_height: f64
    is_sensor: bool
    offset_x: f64
    offset_y: f64

impl Collider2D:
    static fn circle(body_idx: i64, node_id: NodeId, radius: f64) -> Collider2D:
        Collider2D(
            body_index: body_idx,
            node_id: node_id,
            shape_type: ShapeType2D.Circle,
            radius: radius,
            half_width: radius,
            half_height: radius,
            is_sensor: false,
            offset_x: 0.0,
            offset_y: 0.0
        )

    static fn box_shape(body_idx: i64, node_id: NodeId, hw: f64, hh: f64) -> Collider2D:
        Collider2D(
            body_index: body_idx,
            node_id: node_id,
            shape_type: ShapeType2D.Box,
            radius: 0.0,
            half_width: hw,
            half_height: hh,
            is_sensor: false,
            offset_x: 0.0,
            offset_y: 0.0
        )

struct ColliderStore2D:
    colliders: [Collider2D]
    count: i64

impl ColliderStore2D:
    static fn create() -> ColliderStore2D:
        ColliderStore2D(colliders: [], count: 0)

    me add(c: Collider2D) -> i64:
        val idx = self.count
        self.colliders.push(c)
        self.count = self.count + 1
        idx

    me get_aabb(idx: i64, pos_x: f64, pos_y: f64) -> (f64, f64, f64, f64):
        val c = self.colliders[idx]
        val min_x = pos_x + c.offset_x - c.half_width
        val min_y = pos_y + c.offset_y - c.half_height
        val max_x = pos_x + c.offset_x + c.half_width
        val max_y = pos_y + c.offset_y + c.half_height
        (min_x, min_y, max_x, max_y)
