# Physics2 — GPU Buffer Management
#
# Handles upload/download of body and constraint data between CPU and GPU.
# Uses existing CUDA runtime (rt_cuda_*) and Vulkan compute FFI.

use std.nogc_sync_mut.engine.physics2.data.solver_body2d.{SolverBodyStore2D}
use std.nogc_sync_mut.engine.physics2.data.constraint.{ContactConstraintSoA}

struct GpuBodyBuffer:
    device_ptr: i64
    capacity: i64
    uploaded: bool

impl GpuBodyBuffer:
    static fn create() -> GpuBodyBuffer:
        GpuBodyBuffer(device_ptr: 0, capacity: 0, uploaded: false)

struct GpuConstraintBuffer:
    device_ptr: i64
    capacity: i64
    uploaded: bool

impl GpuConstraintBuffer:
    static fn create() -> GpuConstraintBuffer:
        GpuConstraintBuffer(device_ptr: 0, capacity: 0, uploaded: false)

struct GpuPhysicsBuffers:
    body_pos_x: GpuBodyBuffer
    body_pos_y: GpuBodyBuffer
    body_vel_x: GpuBodyBuffer
    body_vel_y: GpuBodyBuffer
    body_ang_vel: GpuBodyBuffer
    body_inv_mass: GpuBodyBuffer
    body_inv_inertia: GpuBodyBuffer
    constraint_buf: GpuConstraintBuffer
    body_count: i64
    constraint_count: i64

impl GpuPhysicsBuffers:
    static fn create() -> GpuPhysicsBuffers:
        GpuPhysicsBuffers(
            body_pos_x: GpuBodyBuffer.create(),
            body_pos_y: GpuBodyBuffer.create(),
            body_vel_x: GpuBodyBuffer.create(),
            body_vel_y: GpuBodyBuffer.create(),
            body_ang_vel: GpuBodyBuffer.create(),
            body_inv_mass: GpuBodyBuffer.create(),
            body_inv_inertia: GpuBodyBuffer.create(),
            constraint_buf: GpuConstraintBuffer.create(),
            body_count: 0,
            constraint_count: 0
        )
