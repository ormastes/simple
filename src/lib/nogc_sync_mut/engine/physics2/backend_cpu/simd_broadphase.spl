# Physics2 — SIMD-Friendly Broad Phase Utilities
#
# 4-wide AABB overlap testing for BVH traversal. Tests one query AABB
# against 4 child bounds simultaneously. In compiled SIMD mode, this
# becomes a single set of SIMD comparisons producing a 4-bit mask.

use std.nogc_sync_mut.engine.physics2.broadphase.bvh2d.{AABB2D}

struct FourWideResult:
    overlap_0: bool
    overlap_1: bool
    overlap_2: bool
    overlap_3: bool
    count: i64

fn test_4wide_overlap(query: AABB2D, c0: AABB2D, c1: AABB2D, c2: AABB2D, c3: AABB2D) -> FourWideResult:
    val o0 = query.overlaps(c0)
    val o1 = query.overlaps(c1)
    val o2 = query.overlaps(c2)
    val o3 = query.overlaps(c3)
    var cnt = 0
    if o0:
        cnt = cnt + 1
    if o1:
        cnt = cnt + 1
    if o2:
        cnt = cnt + 1
    if o3:
        cnt = cnt + 1
    FourWideResult(overlap_0: o0, overlap_1: o1, overlap_2: o2, overlap_3: o3, count: cnt)

fn test_4wide_overlap_soa(q_min_x: f64, q_min_y: f64, q_max_x: f64, q_max_y: f64, c_min_x: [f64], c_min_y: [f64], c_max_x: [f64], c_max_y: [f64]) -> [bool]:
    var results: [bool] = []
    var i = 0
    val n = c_min_x.len()
    while i < n:
        val no_overlap_x = q_max_x < c_min_x[i] or q_min_x > c_max_x[i]
        val no_overlap_y = q_max_y < c_min_y[i] or q_min_y > c_max_y[i]
        results.push(not no_overlap_x and not no_overlap_y)
        i = i + 1
    results
