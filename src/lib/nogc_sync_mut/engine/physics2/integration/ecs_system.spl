# Physics2 — ECS System Integration
#
# PhysicsStepSystem wraps the physics world as an ECS-style system
# for use in MDSOC+ architectures. Manages fixed-timestep accumulator
# and exposes query interface for gameplay code.

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics2.config.{PhysicsConfig2D, default_physics_config_2d}
use std.nogc_sync_mut.engine.physics2.world2d.{PhysicsWorld2D, Transform2D}

struct PhysicsStepSystem2D:
    world: PhysicsWorld2D
    enabled: bool
    time_scale: f64
    frame_count: i64

impl PhysicsStepSystem2D:
    static fn create() -> PhysicsStepSystem2D:
        val config = default_physics_config_2d()
        PhysicsStepSystem2D(
            world: PhysicsWorld2D.create(config),
            enabled: true,
            time_scale: 1.0,
            frame_count: 0
        )

    static fn from_config(config: PhysicsConfig2D) -> PhysicsStepSystem2D:
        PhysicsStepSystem2D(
            world: PhysicsWorld2D.create(config),
            enabled: true,
            time_scale: 1.0,
            frame_count: 0
        )

    me update(dt: f64):
        if self.enabled:
            self.world.step(dt * self.time_scale)
            self.frame_count = self.frame_count + 1

    me pause():
        self.enabled = false

    me resume():
        self.enabled = true

    me set_time_scale(scale: f64):
        self.time_scale = scale

    me add_dynamic_body(node_id: NodeId, x: f64, y: f64, mass: f64) -> i64:
        self.world.add_dynamic_body(node_id, x, y, mass)

    me add_static_body(node_id: NodeId, x: f64, y: f64) -> i64:
        self.world.add_static_body(node_id, x, y)

    me add_box_collider(node_id: NodeId, half_w: f64, half_h: f64) -> i64:
        self.world.add_box_collider(node_id, half_w, half_h)

    me add_circle_collider(node_id: NodeId, radius: f64) -> i64:
        self.world.add_circle_collider(node_id, radius)

    me get_position(node_id: NodeId) -> Vec2:
        self.world.get_position(node_id)

    me get_transforms() -> [Transform2D]:
        self.world.get_all_dynamic_transforms()

    me body_count() -> i64:
        self.world.body_count()

    me destroy():
        self.world.destroy()
