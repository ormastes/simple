# Animation FSM — FSM-driven animation clip playback with transitions
#
# Manages animation states with named clips and transition rules.
# Supports blended transitions between states and auto-transition
# when a clip finishes.
#
# Usage:
#   var fsm = AnimationFSM.new()
#   fsm.add_state("idle", AnimClip.new("idle", 4, 0.25, true))
#   fsm.add_state("run", AnimClip.new("run", 8, 0.1, true))
#   fsm.add_transition("idle", "run", 0.3, false)
#   fsm.set_initial("idle")
#   fsm.update(0.016)

# ============================================================================
# AnimClip — A named animation clip definition
# ============================================================================

struct AnimClip:
    name: text
    frame_count: i32
    frame_duration: f64
    looping: bool

impl AnimClip:
    static fn new(name: text, frame_count: i32, frame_duration: f64, looping: bool) -> AnimClip:
        AnimClip(name: name, frame_count: frame_count, frame_duration: frame_duration, looping: looping)

    fn total_duration(self) -> f64:
        """Total duration of this clip in seconds."""
        self.frame_count * self.frame_duration

# ============================================================================
# AnimTransition — A transition rule between two states
# ============================================================================

struct AnimTransition:
    from_state: text
    to_state: text
    duration: f64
    auto_transition: bool

# ============================================================================
# AnimState — A named state holding a clip and playback progress
# ============================================================================

struct AnimState:
    name: text
    clip: AnimClip
    elapsed: f64
    current_frame: i32

impl AnimState:
    static fn new(name: text, clip: AnimClip) -> AnimState:
        AnimState(name: name, clip: clip, elapsed: 0.0, current_frame: 0)

    fn is_finished(self) -> bool:
        """True if elapsed >= total duration and clip is not looping."""
        if self.clip.looping:
            return false
        self.elapsed >= self.clip.total_duration()

# ============================================================================
# AnimationFSM — Manages states and transitions for animation playback
# ============================================================================

class AnimationFSM:
    states: [AnimState]
    transitions: [AnimTransition]
    current_state_name: text
    blend_alpha: f64
    transitioning: bool
    transition_elapsed: f64
    transition_duration: f64
    target_state_name: text

impl AnimationFSM:
    static fn new() -> AnimationFSM:
        AnimationFSM(
            states: [],
            transitions: [],
            current_state_name: "",
            blend_alpha: 0.0,
            transitioning: false,
            transition_elapsed: 0.0,
            transition_duration: 0.0,
            target_state_name: ""
        )

    me add_state(name: text, clip: AnimClip):
        """Register a new animation state."""
        val s = AnimState.new(name, clip)
        self.states = self.states.push(s)

    me add_transition(from_name: text, to_name: text, duration: f64, auto_trans: bool):
        """Register a transition rule between two states."""
        val t = AnimTransition(
            from_state: from_name,
            to_state: to_name,
            duration: duration,
            auto_transition: auto_trans
        )
        self.transitions = self.transitions.push(t)

    me set_initial(name: text):
        """Set the starting state."""
        self.current_state_name = name

    me trigger_transition(target_name: text) -> bool:
        """Start transitioning to target state. Returns false if no valid transition exists."""
        val from_name = self.current_state_name
        val ti = self._find_transition_index(from_name, target_name)
        if ti < 0:
            return false
        self.transitioning = true
        self.transition_elapsed = 0.0
        self.transition_duration = self.transitions[ti].duration
        self.target_state_name = target_name
        self.blend_alpha = 0.0
        true

    me update(dt: f64):
        """Advance the current state and handle transitions."""
        if self.transitioning:
            self.transition_elapsed = self.transition_elapsed + dt
            if self.transition_duration > 0.0:
                self.blend_alpha = self.transition_elapsed / self.transition_duration
            else:
                self.blend_alpha = 1.0
            if self.blend_alpha > 1.0:
                self.blend_alpha = 1.0
            if self.transition_elapsed >= self.transition_duration:
                self.current_state_name = self.target_state_name
                self.transitioning = false
                self.blend_alpha = 0.0
                self.transition_elapsed = 0.0
                self.target_state_name = ""
            return

        # Advance current state
        val cur_name = self.current_state_name
        val si = self._find_state_index(cur_name)
        if si < 0:
            return

        var cur = self.states[si]
        var new_elapsed = cur.elapsed + dt
        var new_frame = 0

        if cur.clip.frame_duration > 0.0:
            val total_dur = cur.clip.total_duration()
            if cur.clip.looping:
                if new_elapsed >= total_dur:
                    new_elapsed = new_elapsed - total_dur
                # Floor division: count how many full frames fit
                var frame_acc = 0
                while (frame_acc + 1) * cur.clip.frame_duration <= new_elapsed:
                    frame_acc = frame_acc + 1
                new_frame = frame_acc
                if new_frame >= cur.clip.frame_count:
                    new_frame = cur.clip.frame_count - 1
            else:
                if new_elapsed >= total_dur:
                    new_elapsed = total_dur
                    new_frame = cur.clip.frame_count - 1
                else:
                    var frame_acc = 0
                    while (frame_acc + 1) * cur.clip.frame_duration <= new_elapsed:
                        frame_acc = frame_acc + 1
                    new_frame = frame_acc
                    if new_frame >= cur.clip.frame_count:
                        new_frame = cur.clip.frame_count - 1

        self.states[si] = AnimState(
            name: cur.name,
            clip: cur.clip,
            elapsed: new_elapsed,
            current_frame: new_frame
        )

        # Check for auto-transition if clip finished
        if not cur.clip.looping:
            if new_elapsed >= cur.clip.total_duration():
                # Look for auto-transition
                var ti = 0
                while ti < self.transitions.len():
                    var tr = self.transitions[ti]
                    if tr.from_state == self.current_state_name and tr.auto_transition:
                        self.transitioning = true
                        self.transition_elapsed = 0.0
                        self.transition_duration = tr.duration
                        self.target_state_name = tr.to_state
                        self.blend_alpha = 0.0
                        return
                    ti = ti + 1

    fn get_current_state_name(self) -> text:
        self.current_state_name

    fn get_current_frame(self) -> i32:
        val cur_name = self.current_state_name
        val si = self._find_state_index(cur_name)
        if si < 0:
            return 0
        self.states[si].current_frame

    fn is_transitioning(self) -> bool:
        self.transitioning

    fn get_blend_alpha(self) -> f64:
        self.blend_alpha

    fn state_count(self) -> i32:
        self.states.len()

    fn _find_state_index(self, name: text) -> i32:
        """Returns index of named state, or -1 if not found."""
        var i = 0
        while i < self.states.len():
            if self.states[i].name == name:
                return i
            i = i + 1
        -1

    fn _find_transition_index(self, from_name: text, to_name: text) -> i32:
        """Returns index of matching transition, or -1 if not found."""
        var i = 0
        while i < self.transitions.len():
            if self.transitions[i].from_state == from_name and self.transitions[i].to_state == to_name:
                return i
            i = i + 1
        -1
