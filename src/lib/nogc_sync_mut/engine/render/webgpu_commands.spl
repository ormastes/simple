# std.nogc_sync_mut.engine.render.webgpu_commands — WebGpuCommand3D tagged enum
#
# Recorded WebGPU draw commands. Variants use parenthesised named fields
# matching Simple enum syntax (not brace syntax). The backend drains this
# list in end_frame() by matching each variant and calling the corresponding
# rt_wgpu_3d_cmd_* extern.
#
# No dependencies — pure data.

enum WebGpuCommand3D:
    BeginRenderPass(color_tex: i64, depth_tex: i64)
    SetPipeline(pipeline_id: i64)
    BindVertexBuffer(buffer_id: i64, slot: i64)
    BindIndexBuffer(buffer_id: i64)
    BindTexture(texture_id: i64, slot: i64)
    BindUniformBuffer(buffer_id: i64, slot: i64)
    DrawIndexed(index_count: i64, base_vertex: i64)
    EndRenderPass
