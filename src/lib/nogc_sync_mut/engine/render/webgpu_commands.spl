# std.nogc_sync_mut.engine.render.webgpu_commands — WebGpuCommand3D tagged enum
#
# Recorded WebGPU draw commands using the kind-tag flat-class pattern
# (matches vulkan_commands.spl).  Named-field multi-payload enum variants
# are not reliably supported by the compiler; this pattern works around that
# by storing all payload fields in a single flat class keyed by a kind enum.
#
# No dependencies — pure data.

# ============================================================================
# WebGpuCommand3DKind — tag discriminator
# ============================================================================

enum WebGpuCommand3DKind:
    BeginRenderPass
    SetPipeline
    BindVertexBuffer
    BindIndexBuffer
    BindTexture
    BindUniformBuffer
    DrawIndexed
    EndRenderPass

# ============================================================================
# WebGpuCommand3D — a single recorded 3D WebGPU-like command
#
# Fields are overloaded by kind:
#   BeginRenderPass   -> color_tex_id, depth_tex_id
#   SetPipeline       -> pipeline_id
#   BindVertexBuffer  -> buffer_id, slot
#   BindIndexBuffer   -> buffer_id
#   BindTexture       -> texture_id (stored in buffer_id), slot
#   BindUniformBuffer -> buffer_id, slot
#   DrawIndexed       -> index_count, base_vertex (stored in slot, buffer_id)
#   EndRenderPass     -> (no fields used)
# ============================================================================

class WebGpuCommand3D:
    kind:         WebGpuCommand3DKind
    color_tex_id: i64
    depth_tex_id: i64
    pipeline_id:  i64
    buffer_id:    i64
    texture_id:   i64
    slot:         i64
    index_count:  i64
    base_vertex:  i64

fn wgpu_cmd3d_begin_render_pass(color_tex_id: i64, depth_tex_id: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.BeginRenderPass,
        color_tex_id: color_tex_id,
        depth_tex_id: depth_tex_id,
        pipeline_id:  0,
        buffer_id:    0,
        texture_id:   0,
        slot:         0,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_set_pipeline(pipeline_id: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.SetPipeline,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  pipeline_id,
        buffer_id:    0,
        texture_id:   0,
        slot:         0,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_bind_vertex_buffer(buffer_id: i64, slot: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.BindVertexBuffer,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    buffer_id,
        texture_id:   0,
        slot:         slot,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_bind_index_buffer(buffer_id: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.BindIndexBuffer,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    buffer_id,
        texture_id:   0,
        slot:         0,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_bind_texture(texture_id: i64, slot: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.BindTexture,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    0,
        texture_id:   texture_id,
        slot:         slot,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_bind_uniform_buffer(buffer_id: i64, slot: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.BindUniformBuffer,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    buffer_id,
        texture_id:   0,
        slot:         slot,
        index_count:  0,
        base_vertex:  0
    )

fn wgpu_cmd3d_draw_indexed(index_count: i64, base_vertex: i64) -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.DrawIndexed,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    0,
        texture_id:   0,
        slot:         0,
        index_count:  index_count,
        base_vertex:  base_vertex
    )

fn wgpu_cmd3d_end_render_pass() -> WebGpuCommand3D:
    WebGpuCommand3D(
        kind:         WebGpuCommand3DKind.EndRenderPass,
        color_tex_id: 0,
        depth_tex_id: 0,
        pipeline_id:  0,
        buffer_id:    0,
        texture_id:   0,
        slot:         0,
        index_count:  0,
        base_vertex:  0
    )
