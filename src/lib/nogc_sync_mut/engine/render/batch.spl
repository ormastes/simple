# Render Batching — Command sorting by z-order
#
# For the software renderer, batching is straightforward: sort all
# render commands by z_order so that lower z_order draws first (back to front).
#
# Usage:
#   val sorted = sort_commands_by_z(buffer.commands)

use std.nogc_sync_mut.engine.render.command.{RenderCommand}

# ============================================================================
# Z-order extraction
# ============================================================================

fn get_z_order(cmd: RenderCommand) -> i64:
    """Extract the z_order from a render command. Clear has z_order -1 (always first)."""
    match cmd:
        case Clear(color): -1
        case DrawRect(rect, color, z_order): z_order
        case DrawCircle(cx, cy, radius, color, z_order): z_order
        case DrawLine(x1, y1, x2, y2, width, color, z_order): z_order
        case DrawSprite(texture_id, src_rect, dst_rect, tint, z_order): z_order
        case DrawTriangles(vertices, indices, color, z_order): z_order

# ============================================================================
# Insertion sort by z_order (stable, efficient for small command lists)
# ============================================================================

fn sort_commands_by_z(commands: [RenderCommand]) -> [RenderCommand]:
    """Sort render commands by z_order using insertion sort. Returns a new sorted list."""
    var sorted: [RenderCommand] = []
    for cmd in commands:
        sorted.push(cmd)
    # Insertion sort — stable and efficient for typical frame command counts
    val n = sorted.len()
    var i = 1
    while i < n:
        val key = sorted[i]
        val key_z = get_z_order(key)
        var j = i - 1
        while j >= 0:
            val j_z = get_z_order(sorted[j])
            if j_z > key_z:
                sorted[j + 1] = sorted[j]
                j = j - 1
            else:
                j = -1  # break
        sorted[j + 1] = key
        i = i + 1
    sorted
