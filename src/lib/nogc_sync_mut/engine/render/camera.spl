# Camera — effects and controllers for 2D cameras
#
# Smooth-follow with dead zone, bounds clamping, screen shake,
# and zoom. Uses deterministic sin/cos for shake computation.
#
# Usage:
#   var cam = Camera2D.new(0.0, 0.0)
#   cam.set_bounds(CameraBounds(min_x: 0.0, min_y: 0.0, max_x: 800.0, max_y: 600.0))
#   cam.set_follow_speed(5.0)
#   cam.follow(player_x, player_y)
#   cam.update(0.016)
#   val view_x = cam.effective_x()

use std.common.math.{MATH_PI, MATH_INF, math_abs, math_lerp, math_clamp}

# ============================================================================
# Sin/cos approximation for shake
# ============================================================================

fn _cam_sin(x: f64) -> f64:
    """Taylor series sine approximation, normalized to [-PI, PI]."""
    var a = x
    val two_pi = MATH_PI * 2.0
    while a > MATH_PI:
        a = a - two_pi
    while a < -MATH_PI:
        a = a + two_pi
    val x2 = a * a
    val x3 = a * x2
    val x5 = x3 * x2
    val x7 = x5 * x2
    val x9 = x7 * x2
    a - x3 / 6.0 + x5 / 120.0 - x7 / 5040.0 + x9 / 362880.0

fn _cam_cos(x: f64) -> f64:
    """Cosine via sine shift."""
    _cam_sin(x + MATH_PI / 2.0)

# ============================================================================
# ShakeConfig — screen shake parameters
# ============================================================================

struct ShakeConfig:
    intensity: f64
    frequency: f64
    decay: f64

# ============================================================================
# CameraBounds — world-space limits for camera position
# ============================================================================

struct CameraBounds:
    min_x: f64
    min_y: f64
    max_x: f64
    max_y: f64

# ============================================================================
# Unbounded helper
# ============================================================================

fn unbounded() -> CameraBounds:
    """Returns very large bounds (effectively unbounded)."""
    CameraBounds(
        min_x: -MATH_INF,
        min_y: -MATH_INF,
        max_x: MATH_INF,
        max_y: MATH_INF
    )

# ============================================================================
# Camera2D — 2D camera with follow, shake, bounds, dead zone, zoom
# ============================================================================

class Camera2D:
    x: f64
    y: f64
    zoom: f64
    rotation: f64
    target_x: f64
    target_y: f64
    follow_speed: f64
    bounds: CameraBounds
    shake_offset_x: f64
    shake_offset_y: f64
    shake_time: f64
    shake_config: ShakeConfig
    dead_zone_width: f64
    dead_zone_height: f64

impl Camera2D:
    static fn new(x: f64, y: f64) -> Camera2D:
        """Create a camera at position (x, y) with default settings."""
        Camera2D(
            x: x,
            y: y,
            zoom: 1.0,
            rotation: 0.0,
            target_x: x,
            target_y: y,
            follow_speed: 5.0,
            bounds: unbounded(),
            shake_offset_x: 0.0,
            shake_offset_y: 0.0,
            shake_time: 0.0,
            shake_config: ShakeConfig(intensity: 0.0, frequency: 10.0, decay: 5.0),
            dead_zone_width: 0.0,
            dead_zone_height: 0.0
        )

    me follow(target_x: f64, target_y: f64):
        """Set the target position for smooth follow."""
        self.target_x = target_x
        self.target_y = target_y

    me update(dt: f64):
        """Advance camera: lerp toward target, apply dead zone, clamp bounds, update shake."""
        # --- Dead zone check ---
        val dx = self.target_x - self.x
        val dy = self.target_y - self.y
        val abs_dx = math_abs(dx)
        val abs_dy = math_abs(dy)
        val half_dz_w = self.dead_zone_width / 2.0
        val half_dz_h = self.dead_zone_height / 2.0

        var move_x = self.x
        var move_y = self.y

        # Only move if target is outside dead zone
        if abs_dx > half_dz_w:
            val t = 1.0 - _cam_pow_decay(dt, self.follow_speed)
            move_x = math_lerp(self.x, self.target_x, t)

        if abs_dy > half_dz_h:
            val t = 1.0 - _cam_pow_decay(dt, self.follow_speed)
            move_y = math_lerp(self.y, self.target_y, t)

        # --- Clamp to bounds ---
        self.x = math_clamp(move_x, self.bounds.min_x, self.bounds.max_x)
        self.y = math_clamp(move_y, self.bounds.min_y, self.bounds.max_y)

        # --- Update shake ---
        if self.shake_time > 0.0:
            self.shake_time = self.shake_time - dt
            if self.shake_time < 0.0:
                self.shake_time = 0.0
            val remaining = self.shake_time * self.shake_config.decay
            var intensity = self.shake_config.intensity * remaining
            if intensity < 0.0:
                intensity = 0.0
            val freq = self.shake_config.frequency
            val phase = self.shake_time * freq * MATH_PI * 2.0
            self.shake_offset_x = _cam_sin(phase) * intensity
            self.shake_offset_y = _cam_cos(phase * 1.3) * intensity
        else:
            self.shake_offset_x = 0.0
            self.shake_offset_y = 0.0

    me shake(config: ShakeConfig):
        """Trigger a screen shake with the given parameters."""
        self.shake_config = config
        # Compute duration from intensity and decay: shakes until intensity * remaining ~ 0
        val duration = config.intensity / config.decay
        var dur = duration
        if dur < 0.1:
            dur = 0.5
        self.shake_time = dur

    me set_bounds(bounds: CameraBounds):
        """Set the world-space bounds for camera clamping."""
        self.bounds = bounds

    me set_dead_zone(width: f64, height: f64):
        """Set the dead zone size. Camera won't move if target is within this area."""
        self.dead_zone_width = width
        self.dead_zone_height = height

    me set_follow_speed(speed: f64):
        """Set the camera follow interpolation speed."""
        self.follow_speed = speed

    fn effective_x(self) -> f64:
        """Camera X position including shake offset."""
        self.x + self.shake_offset_x

    fn effective_y(self) -> f64:
        """Camera Y position including shake offset."""
        self.y + self.shake_offset_y

    fn is_shaking(self) -> bool:
        """Check whether the camera is currently shaking."""
        self.shake_time > 0.0

    me zoom_to(target_zoom: f64):
        """Set the target zoom level."""
        self.zoom = target_zoom

    me reset():
        """Reset camera to origin with default settings."""
        self.x = 0.0
        self.y = 0.0
        self.zoom = 1.0
        self.rotation = 0.0
        self.target_x = 0.0
        self.target_y = 0.0
        self.shake_offset_x = 0.0
        self.shake_offset_y = 0.0
        self.shake_time = 0.0

# ============================================================================
# Exponential decay helper for smooth follow
# ============================================================================

fn _cam_pow_decay(dt: f64, speed: f64) -> f64:
    """Approximate e^(-speed * dt) using Taylor series for smooth follow.
    Result in [0, 1] where 0 = instant follow, 1 = no follow."""
    val x = -speed * dt
    # Taylor: e^x ~ 1 + x + x^2/2 + x^3/6 + x^4/24
    val x2 = x * x
    val x3 = x2 * x
    val x4 = x3 * x
    var result = 1.0 + x + x2 / 2.0 + x3 / 6.0 + x4 / 24.0
    if result < 0.0:
        result = 0.0
    if result > 1.0:
        result = 1.0
    result
