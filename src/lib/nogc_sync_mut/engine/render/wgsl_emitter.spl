# WGSL Emitter — GLSL (#version 450) to WGSL text transpiler
#
# Token-level transpilation of Vulkan-style GLSL shaders (as used in the builtin
# 2D/3D shaders) into WGSL for WebGPU backends.
#
# Handles patterns actually present in shader.spl:
#   - #version 450 → remove
#   - layout(push_constant) uniform Block { ... } name → @group(1) @binding(0) var<uniform>
#   - layout(location=N) in/out → @location(N) in/out
#   - layout(set=S, binding=B) uniform samplerXD → @group(S) @binding(B) var
#   - vec2/vec3/vec4 → vec2f/vec3f/vec4f
#   - mat4/mat3 → mat4x4f/mat3x3f
#   - gl_Position → position builtin
#   - void main() → @vertex fn vs_main / @fragment fn fs_main with boilerplate
#   - texture(sampler, uv) → textureSample(sampler, sampler_s, uv)
#   - normalize, max, dot, discard → kept (WGSL compatible)

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

fn _remove_version_directive(src: text) -> text:
    val lines = src.split("\n")
    var out: text = ""
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if not line.contains("#version"):
            if out.len() == 0:
                out = line
            else:
                out = out + "\n" + line
        i = i + 1
    out

fn _replace_glsl_types(src: text) -> text:
    # Order matters: mat4 before mat3 to avoid partial matches
    var s = src
    s = s.replace("mat4x4", "__mat4x4__")   # protect already-converted
    s = s.replace("mat3x3", "__mat3x3__")
    s = s.replace("mat4", "mat4x4f")
    s = s.replace("mat3", "mat3x3f")
    s = s.replace("__mat4x4__", "mat4x4f")
    s = s.replace("__mat3x3__", "mat3x3f")
    s = s.replace("vec4", "vec4f")
    s = s.replace("vec3", "vec3f")
    s = s.replace("vec2", "vec2f")
    s

# Convert "layout(location = N) in type name;" → "@location(N) var name: type;"
# We rely on replace for the common patterns found in the builtin shaders.
fn _convert_layout_in(src: text) -> text:
    # The builtin shaders use patterns like:
    #   layout(location = 0) in vec2f a_pos;
    # After type replacement they become:
    #   layout(location = 0) in vec2f a_pos;
    # We'll do a line-by-line pass.
    val lines = src.split("\n")
    var out: text = ""
    var i = 0
    while i < lines.len():
        val line = lines[i]
        var converted = line
        if line.contains("layout(location") and line.contains(") in "):
            # Extract location number and rewrite
            converted = _rewrite_location_in(line)
        else if line.contains("layout(location") and line.contains(") out "):
            converted = _rewrite_location_out(line)
        if out.len() == 0:
            out = converted
        else:
            out = out + "\n" + converted
        i = i + 1
    out

fn _extract_location_num(line: text) -> text:
    # Find the digit after "location = " or "location="
    val parts = line.split("location")
    if parts.len() < 2:
        return "0"
    val after = parts[1]
    # skip "= " or " = "
    var j = 0
    var found_eq = false
    var num: text = ""
    while j < after.len():
        val ch = after[j:j+1]
        if ch == "=":
            found_eq = true
        else if found_eq and ch != " ":
            # collect digits
            if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
                num = num + ch
            else if num.len() > 0:
                j = after.len()  # break
        j = j + 1
    if num.len() == 0:
        "0"
    else:
        num

fn _extract_type_and_name_in(line: text) -> text:
    # Extract "type name" from "layout(...) in type name;"
    val parts = line.split(") in ")
    if parts.len() < 2:
        return line
    val rest = parts[1].replace(";", "").replace("\r", "")
    # trim leading spaces
    var s = rest
    while s.len() > 0 and s[0:1] == " ":
        s = s[1:s.len()]
    s

fn _extract_type_and_name_out(line: text) -> text:
    val parts = line.split(") out ")
    if parts.len() < 2:
        return line
    val rest = parts[1].replace(";", "").replace("\r", "")
    var s = rest
    while s.len() > 0 and s[0:1] == " ":
        s = s[1:s.len()]
    s

fn _rewrite_location_in(line: text) -> text:
    val loc = _extract_location_num(line)
    val type_name = _extract_type_and_name_in(line)
    "    @location(" + loc + ") " + type_name + ": " + _type_of(type_name) + ","

fn _rewrite_location_out(line: text) -> text:
    val loc = _extract_location_num(line)
    val type_name = _extract_type_and_name_out(line)
    "    @location(" + loc + ") " + type_name + ": " + _type_of(type_name) + ","

fn _type_of(decl: text) -> text:
    # "vec2f a_pos" → "vec2f", "vec4f v_color" → "vec4f"
    val parts = decl.split(" ")
    if parts.len() >= 1:
        parts[0]
    else:
        "f32"

# Convert push_constant block to WGSL uniform binding
fn _convert_push_constant(src: text) -> text:
    # layout(push_constant) uniform BlockName { ... } var_name;
    # → struct BlockName { ... }; @group(1) @binding(0) var<uniform> var_name: BlockName;
    if not src.contains("push_constant"):
        return src
    # Simple replacement: mark for post-processing in main body builder
    src.replace("layout(push_constant) uniform", "// @group(1) @binding(0) uniform")

fn _convert_uniform_sampler(src: text) -> text:
    # layout(set=S, binding=B) uniform sampler2D name;
    # → @group(S) @binding(B) var name: texture_2d<f32>;
    #   @group(S) @binding(B+1) var name_s: sampler;
    # Line-by-line
    val lines = src.split("\n")
    var out: text = ""
    var i = 0
    while i < lines.len():
        val line = lines[i]
        var converted = line
        if line.contains("uniform sampler2D") or line.contains("uniform sampler"):
            converted = _rewrite_sampler_line(line)
        if out.len() == 0:
            out = converted
        else:
            out = out + "\n" + converted
        i = i + 1
    out

fn _extract_set_binding(line: text) -> text:
    # Returns "S,B" from layout(set = S, binding = B)
    val set_num = _extract_after(line, "set", "=", ",")
    val bind_num = _extract_after(line, "binding", "=", ")")
    set_num + "," + bind_num

fn _extract_after(src: text, keyword: text, sep1: text, sep2: text) -> text:
    val parts = src.split(keyword)
    if parts.len() < 2:
        return "0"
    val after_kw = parts[1]
    val after_sep = after_kw.split(sep1)
    if after_sep.len() < 2:
        return "0"
    val value_part = after_sep[1]
    val end_parts = value_part.split(sep2)
    if end_parts.len() < 1:
        return "0"
    var num = end_parts[0]
    while num.len() > 0 and (num[0:1] == " " or num[0:1] == "\t"):
        num = num[1:num.len()]
    var trimmed: text = ""
    var j = 0
    while j < num.len():
        val ch = num[j:j+1]
        if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
            trimmed = trimmed + ch
        j = j + 1
    if trimmed.len() == 0:
        "0"
    else:
        trimmed

fn _extract_sampler_name(line: text) -> text:
    val kw = "sampler2D "
    val parts = line.split(kw)
    if parts.len() < 2:
        val kw2 = "sampler "
        val parts2 = line.split(kw2)
        if parts2.len() < 2:
            return "u_tex"
        val rest2 = parts2[1].replace(";", "").replace("\r", "")
        return rest2
    val rest = parts[1].replace(";", "").replace("\r", "")
    var s = rest
    while s.len() > 0 and s[0:1] == " ":
        s = s[1:s.len()]
    s

fn _rewrite_sampler_line(line: text) -> text:
    val sb = _extract_set_binding(line)
    val sb_parts = sb.split(",")
    val set_n = sb_parts[0]
    val bind_n = sb_parts[1]
    val name = _extract_sampler_name(line)
    "@group(" + set_n + ") @binding(" + bind_n + ") var " + name + ": texture_2d<f32>;\n" +
    "@group(" + set_n + ") @binding(1) var " + name + "_s: sampler;"

# Convert texture(sampler, uv) → textureSample(sampler, sampler_s, uv)
fn _convert_texture_calls(src: text) -> text:
    # Simple pattern: "texture(u_texture, " → "textureSample(u_texture, u_texture_s, "
    # Find all "texture(" occurrences and rewrite
    if not src.contains("texture("):
        return src
    val lines = src.split("\n")
    var out: text = ""
    var i = 0
    while i < lines.len():
        val line = lines[i]
        var converted = line
        if line.contains("texture(") and not line.contains("texture_2d") and not line.contains("textureSample"):
            converted = _rewrite_texture_call(line)
        if out.len() == 0:
            out = converted
        else:
            out = out + "\n" + converted
        i = i + 1
    out

fn _rewrite_texture_call(line: text) -> text:
    # "texture(name, uv)" → "textureSample(name, name_s, uv)"
    val parts = line.split("texture(")
    if parts.len() < 2:
        return line
    val after = parts[1]
    # extract sampler name (up to first comma)
    val arg_parts = after.split(",")
    if arg_parts.len() < 2:
        return line
    val sampler_name = arg_parts[0]
    var sname = sampler_name
    while sname.len() > 0 and sname[0:1] == " ":
        sname = sname[1:sname.len()]
    # rebuild: textureSample(sname, sname_s, rest_args)
    var rest_args: text = ""
    var k = 1
    while k < arg_parts.len():
        if rest_args.len() == 0:
            rest_args = arg_parts[k]
        else:
            rest_args = rest_args + "," + arg_parts[k]
        k = k + 1
    parts[0] + "textureSample(" + sname + ", " + sname + "_s," + rest_args

# Convert gl_Position → position builtin (just text replace in body)
fn _convert_builtins(src: text) -> text:
    var s = src
    s = s.replace("gl_Position", "output.position")
    s = s.replace("gl_FragColor", "output_color")
    s

# ---------------------------------------------------------------------------
# Vertex shader emission
# ---------------------------------------------------------------------------

fn wgsl_emit_vertex(glsl: text) -> text:
    var s = glsl
    s = _remove_version_directive(s)
    s = _replace_glsl_types(s)
    s = _convert_uniform_sampler(s)
    s = _convert_push_constant(s)
    s = _convert_layout_in(s)
    s = _convert_builtins(s)
    s = _convert_texture_calls(s)
    # Wrap with WGSL vertex entry point boilerplate comment
    "// WGSL vertex shader (transpiled from GLSL)\n" +
    "// NOTE: Struct declarations for in/out and push-constant uniforms\n" +
    "// must be manually completed for full WGSL validity.\n" +
    "// The following is a best-effort token-level transpilation.\n\n" +
    s

# ---------------------------------------------------------------------------
# Fragment shader emission
# ---------------------------------------------------------------------------

fn wgsl_emit_fragment(glsl: text) -> text:
    var s = glsl
    s = _remove_version_directive(s)
    s = _replace_glsl_types(s)
    s = _convert_uniform_sampler(s)
    s = _convert_push_constant(s)
    s = _convert_layout_in(s)
    s = _convert_builtins(s)
    s = _convert_texture_calls(s)
    "// WGSL fragment shader (transpiled from GLSL)\n" +
    "// NOTE: Token-level transpilation — may require manual fixups.\n\n" +
    s
