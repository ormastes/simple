# std.nogc_sync_mut.engine.render.software_backend3d — SoftwareRenderBackend3D
#
# Wraps ForwardRenderer3D via composition. Implements RenderBackend3D using
# CPU buffer/texture stores keyed by auto-incrementing handle IDs.
#
# Buffer and texture data are stored in parallel arrays (ids + data).
# draw_indexed decodes vertex/index data from the CPU buffer store and
# delegates rendering to ForwardRenderer3D's rasterize path.

use std.nogc_sync_mut.engine.render.renderer3d.{ForwardRenderer3D, LightInstance}
use std.nogc_sync_mut.engine.render.capability3d.{RenderCapability3D, capability_software_3d}
use std.common.engine.math3d.{Vec3, Mat4}
use std.common.engine.color.{EngineColor}
use std.nogc_sync_mut.engine.component.mesh.{Vertex3D, MeshData}
use std.nogc_sync_mut.engine.render.material3d.{Material3D, MaterialType3D}
use std.common.engine.ids.{TextureId}
use std.nogc_sync_mut.engine.render.backend3d.{
    RenderBackend3D, PipelineDesc3D, PipelineHandle, BufferHandle,
    TextureHandle, TextureFormat3D, RenderPassHandle
}

# ============================================================================
# CpuBuffer — raw byte store for a single buffer handle
# ============================================================================

class CpuBuffer:
    id: i64
    data: [u8]

    static fn create(id: i64, byte_count: i64) -> CpuBuffer:
        var d: [u8] = []
        var i = 0
        while i < byte_count:
            d.push(0)
            i = i + 1
        CpuBuffer(id: id, data: d)

# ============================================================================
# CpuTexture — raw pixel store for a single texture handle
# ============================================================================

class CpuTexture:
    id: i64
    width: i64
    height: i64
    data: [u8]

    static fn create(id: i64, width: i64, height: i64) -> CpuTexture:
        val size = width * height * 4
        var d: [u8] = []
        var i = 0
        while i < size:
            d.push(0)
            i = i + 1
        CpuTexture(id: id, width: width, height: height, data: d)

# ============================================================================
# ActivePass — tracks per-pass state (bound buffers/pipeline)
# ============================================================================

class ActivePass:
    pass_id: i64
    color_tex_id: i64
    depth_tex_id: i64
    pipeline_id: i64
    vertex_buf_id: i64
    index_buf_id: i64

    static fn invalid() -> ActivePass:
        ActivePass(
            pass_id: -1,
            color_tex_id: -1,
            depth_tex_id: -1,
            pipeline_id: -1,
            vertex_buf_id: -1,
            index_buf_id: -1
        )

# ============================================================================
# SoftwareRenderBackend3D
# ============================================================================

class SoftwareRenderBackend3D:
    renderer: ForwardRenderer3D
    next_id: i64
    buffers: [CpuBuffer]
    textures: [CpuTexture]
    active_pass: ActivePass
    initialized: bool

    static fn create() -> SoftwareRenderBackend3D:
        SoftwareRenderBackend3D(
            renderer: ForwardRenderer3D.create(1, 1),
            next_id: 1,
            buffers: [],
            textures: [],
            active_pass: ActivePass.invalid(),
            initialized: false
        )

# ============================================================================
# Internal helpers (module-level fns to avoid chained-method issues)
# ============================================================================

fn _swb_alloc_id(backend: SoftwareRenderBackend3D) -> i64:
    val id = backend.next_id
    backend.next_id = backend.next_id + 1
    id

fn _swb_find_buffer(backend: SoftwareRenderBackend3D, id: i64) -> i64:
    """Return the index into backend.buffers for the given id, or -1."""
    var i = 0
    while i < backend.buffers.len():
        if backend.buffers[i].id == id:
            return i
        i = i + 1
    -1

fn _swb_find_texture(backend: SoftwareRenderBackend3D, id: i64) -> i64:
    """Return the index into backend.textures for the given id, or -1."""
    var i = 0
    while i < backend.textures.len():
        if backend.textures[i].id == id:
            return i
        i = i + 1
    -1

fn _read_byte_as_f64(data: [u8], off: i64) -> f64:
    """Read a single byte at offset and scale to [0..1]. Returns 0 if out of range."""
    if off < data.len():
        val bv: i64 = data[off]
        bv * 1.0 / 255.0
    else:
        0.0

fn _swb_decode_vertex(data: [u8], offset: i64) -> Vertex3D:
    """Decode a Vertex3D from raw bytes at byte offset.
    Layout (little-endian f64): px, py, pz, nx, ny, nz, u, v, cr, cg, cb, ca
    Each f64 occupies 8 bytes. Stride = 96 bytes.
    Simple does not yet have a bytes->f64 builtin, so we do a best-effort
    approximation — read the first byte of each 8-byte slot as a fraction.
    Real GPU backends use SPIRV/WGSL; this path provides a working fallback."""
    val base = offset
    val px = _read_byte_as_f64(data, base)
    val py = _read_byte_as_f64(data, base + 8)
    val pz = _read_byte_as_f64(data, base + 16)
    val nx = _read_byte_as_f64(data, base + 24)
    val ny = _read_byte_as_f64(data, base + 32)
    val nz = _read_byte_as_f64(data, base + 40)
    val u  = _read_byte_as_f64(data, base + 48)
    val v  = _read_byte_as_f64(data, base + 56)
    val cr = _read_byte_as_f64(data, base + 64)
    val cg = _read_byte_as_f64(data, base + 72)
    val cb = _read_byte_as_f64(data, base + 80)
    val ca = _read_byte_as_f64(data, base + 88)
    Vertex3D(
        position: Vec3(x: px, y: py, z: pz),
        normal: Vec3(x: nx, y: ny, z: nz),
        uv_x: u,
        uv_y: v,
        color: EngineColor(r: cr, g: cg, b: cb, a: ca)
    )

fn _swb_decode_index(data: [u8], offset: i64) -> i64:
    """Decode a 4-byte little-endian i32 index from raw bytes."""
    if offset + 3 < data.len():
        val b0: i64 = data[offset]
        val b1: i64 = data[offset + 1]
        val b2: i64 = data[offset + 2]
        val b3: i64 = data[offset + 3]
        b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
    else:
        0

fn _swb_do_draw(
    backend: SoftwareRenderBackend3D,
    index_count: i64,
    base_vertex: i64
):
    """Decode CPU buffers and rasterize via ForwardRenderer3D._render_mesh."""
    val vbuf_idx = _swb_find_buffer(backend, backend.active_pass.vertex_buf_id)
    val ibuf_idx = _swb_find_buffer(backend, backend.active_pass.index_buf_id)
    if vbuf_idx < 0:
        return
    if ibuf_idx < 0:
        return

    val vdata = backend.buffers[vbuf_idx].data
    val idata = backend.buffers[ibuf_idx].data

    # Vertex stride: 96 bytes (12 f64 fields × 8 bytes each)
    val vertex_stride = 96

    # Decode indices and vertices
    var indices: [i64] = []
    var idx = 0
    while idx < index_count:
        val raw_idx = _swb_decode_index(idata, idx * 4)
        val adjusted = raw_idx + base_vertex
        indices.push(adjusted)
        idx = idx + 1

    # Determine vertex count from index range
    var max_vi = 0
    var qi = 0
    while qi < indices.len():
        if indices[qi] > max_vi:
            max_vi = indices[qi]
        qi = qi + 1
    val vertex_count = max_vi + 1

    var vertices: [Vertex3D] = []
    var vi = 0
    while vi < vertex_count:
        val vert = _swb_decode_vertex(vdata, vi * vertex_stride)
        vertices.push(vert)
        vi = vi + 1

    val mesh = MeshData(
        vertices: vertices,
        indices: indices,
        aabb_min: Vec3.zero(),
        aabb_max: Vec3.zero()
    )

    val material = Material3D(
        material_type: MaterialType3D.Unlit,
        albedo: EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0),
        albedo_texture: TextureId.invalid(),
        roughness: 0.5,
        metallic: 0.0,
        emissive: EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 0.0),
        emissive_intensity: 0.0
    )

    var no_lights: [LightInstance] = []
    val cam_pos = Vec3.zero()

    val mvp = Mat4.identity()
    val model = Mat4.identity()

    backend.renderer._render_mesh(mesh, material, mvp, model, no_lights, cam_pos)

# ============================================================================
# impl SoftwareRenderBackend3D: RenderBackend3D
# ============================================================================

impl SoftwareRenderBackend3D: RenderBackend3D:
    fn capabilities(self) -> RenderCapability3D:
        capability_software_3d()

    fn init(self, width: i64, height: i64) -> bool:
        self.renderer = ForwardRenderer3D.create(width, height)
        self.initialized = true
        true

    fn create_pipeline(self, desc: PipelineDesc3D) -> PipelineHandle:
        val id = _swb_alloc_id(self)
        PipelineHandle(id: id)

    fn create_vertex_buffer(self, byte_count: i64) -> BufferHandle:
        val id = _swb_alloc_id(self)
        self.buffers.push(CpuBuffer.create(id, byte_count))
        BufferHandle(id: id)

    fn create_index_buffer(self, byte_count: i64) -> BufferHandle:
        val id = _swb_alloc_id(self)
        self.buffers.push(CpuBuffer.create(id, byte_count))
        BufferHandle(id: id)

    fn create_uniform_buffer(self, byte_count: i64) -> BufferHandle:
        val id = _swb_alloc_id(self)
        self.buffers.push(CpuBuffer.create(id, byte_count))
        BufferHandle(id: id)

    fn upload_buffer(self, buf: BufferHandle, data: [u8], offset: i64):
        val idx = _swb_find_buffer(self, buf.id)
        if idx < 0:
            return
        var src_i = 0
        var dst_i = offset
        while src_i < data.len():
            if dst_i < self.buffers[idx].data.len():
                self.buffers[idx].data[dst_i] = data[src_i]
            src_i = src_i + 1
            dst_i = dst_i + 1

    fn create_texture(self, width: i64, height: i64, format: TextureFormat3D) -> TextureHandle:
        val id = _swb_alloc_id(self)
        self.textures.push(CpuTexture.create(id, width, height))
        TextureHandle(id: id)

    fn upload_texture(self, tex: TextureHandle, data: [u8]):
        val idx = _swb_find_texture(self, tex.id)
        if idx < 0:
            return
        var i = 0
        while i < data.len():
            if i < self.textures[idx].data.len():
                self.textures[idx].data[i] = data[i]
            i = i + 1

    fn begin_frame(self):
        self.renderer.clear()

    fn begin_render_pass(self, color_tex: TextureHandle, depth_tex: TextureHandle) -> RenderPassHandle:
        val id = _swb_alloc_id(self)
        self.active_pass = ActivePass(
            pass_id: id,
            color_tex_id: color_tex.id,
            depth_tex_id: depth_tex.id,
            pipeline_id: -1,
            vertex_buf_id: -1,
            index_buf_id: -1
        )
        RenderPassHandle(id: id)

    fn set_pipeline(self, pass: RenderPassHandle, pipeline: PipelineHandle):
        if self.active_pass.pass_id == pass.id:
            self.active_pass.pipeline_id = pipeline.id

    fn bind_vertex_buffer(self, pass: RenderPassHandle, buf: BufferHandle, slot: i64):
        if self.active_pass.pass_id == pass.id:
            self.active_pass.vertex_buf_id = buf.id

    fn bind_index_buffer(self, pass: RenderPassHandle, buf: BufferHandle):
        if self.active_pass.pass_id == pass.id:
            self.active_pass.index_buf_id = buf.id

    fn bind_texture(self, pass: RenderPassHandle, tex: TextureHandle, slot: i64):
        # Software backend does not yet sample textures during rasterization
        pass_dn

    fn bind_uniform_buffer(self, pass: RenderPassHandle, buf: BufferHandle, slot: i64):
        # Uniform data (MVP matrices) not yet decoded from bytes in software path
        pass_dn

    fn draw_indexed(self, pass: RenderPassHandle, index_count: i64, base_vertex: i64):
        if self.active_pass.pass_id == pass.id:
            _swb_do_draw(self, index_count, base_vertex)

    fn end_render_pass(self, pass: RenderPassHandle):
        if self.active_pass.pass_id == pass.id:
            self.active_pass = ActivePass.invalid()

    fn end_frame(self):
        pass_dn

    fn present(self):
        # Software backend — pixels are accessible via renderer.get_pixels()
        pass_dn

    fn shutdown(self):
        self.buffers = []
        self.textures = []
        self.initialized = false
