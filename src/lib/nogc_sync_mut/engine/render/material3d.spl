# Material3D — 3D surface appearance description
#
# PBR, Phong, and Unlit material types for the 3D render pipeline.
#
# Usage:
#   val mat = pbr_material(EngineColor.red(), 0.5, 0.3)
#   val unlit = unlit_material(EngineColor.white())

use std.common.engine.color.{EngineColor}
use std.common.engine.ids.{TextureId}

# ============================================================================
# MaterialType3D
# ============================================================================

enum MaterialType3D:
    PBR
    Phong
    Unlit

# ============================================================================
# Material3D
# ============================================================================

class Material3D:
    material_type: MaterialType3D
    albedo: EngineColor
    albedo_texture: TextureId
    metallic: f64
    roughness: f64
    emissive: EngineColor
    emissive_intensity: f64

impl Material3D:
    fn has_texture() -> bool:
        """Check whether this material references a valid albedo texture."""
        self.albedo_texture.is_valid()

# ============================================================================
# Material constructors
# ============================================================================

fn pbr_material(albedo: EngineColor, metallic: f64, roughness: f64) -> Material3D:
    """Create a PBR material with given albedo, metallic, and roughness."""
    Material3D(
        material_type: MaterialType3D.PBR,
        albedo: albedo,
        albedo_texture: TextureId.invalid(),
        metallic: metallic,
        roughness: roughness,
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )

fn phong_material(diffuse: EngineColor, shininess: f64) -> Material3D:
    """Create a Phong material. Shininess maps to inverse roughness."""
    Material3D(
        material_type: MaterialType3D.Phong,
        albedo: diffuse,
        albedo_texture: TextureId.invalid(),
        metallic: 0.0,
        roughness: 1.0 / (shininess + 1.0),
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )

fn unlit_material(color: EngineColor) -> Material3D:
    """Create an unlit material (no lighting calculations)."""
    Material3D(
        material_type: MaterialType3D.Unlit,
        albedo: color,
        albedo_texture: TextureId.invalid(),
        metallic: 0.0,
        roughness: 1.0,
        emissive: EngineColor.black(),
        emissive_intensity: 0.0
    )
