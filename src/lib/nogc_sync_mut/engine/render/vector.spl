# Vector Renderer — high-level shape helpers to RenderCommand primitives
#
# Keeps the new 2D engine on the software-renderer path without depending on
# Lyon tessellation in the runtime. Shapes are emitted directly as primitive
# render commands.
#
# Usage:
#   val vec_renderer = VectorRenderer.create()
#   vec_renderer.fill_rect(cmds, rect, EngineColor.red(), ZIndex(value: 0))
#   vec_renderer.fill_circle(cmds, 100.0, 100.0, 50.0, EngineColor.blue(), ZIndex(value: 1))

use std.common.engine.color.{EngineColor}
use std.common.engine.rect.{Rect2}
use std.common.engine.units.{Tolerance, ZIndex}
use std.nogc_sync_mut.engine.render.command.{RenderCommand, RenderCommandBuffer}

# ============================================================================
# VectorRenderer
# ============================================================================

class VectorRenderer:
    tolerance: Tolerance

impl VectorRenderer:
    static fn create() -> VectorRenderer:
        """Create a vector renderer with default primitive settings."""
        VectorRenderer(tolerance: Tolerance(value: 0.1))

    fn fill_rect(cmds: RenderCommandBuffer, rect: Rect2, color: EngineColor, z_order: ZIndex):
        """Push a filled rectangle render command."""
        cmds.push(RenderCommand.DrawRect(rect: rect, color: color, z_order: z_order))

    fn fill_circle(cmds: RenderCommandBuffer, cx: f64, cy: f64, radius: f64, color: EngineColor, z_order: ZIndex):
        """Push a filled circle render command."""
        cmds.push(RenderCommand.DrawCircle(cx: cx, cy: cy, radius: radius, color: color, z_order: z_order))

    fn stroke_rect(cmds: RenderCommandBuffer, rect: Rect2, width: f64, color: EngineColor, z_order: ZIndex):
        """Approximate a rectangle stroke with four filled rectangles."""
        if width <= 0.0:
            return
        self.fill_rect(cmds, Rect2.new(rect.x, rect.y, rect.width, width), color, z_order)
        self.fill_rect(cmds, Rect2.new(rect.x, rect.y + rect.height - width, rect.width, width), color, z_order)
        self.fill_rect(cmds, Rect2.new(rect.x, rect.y, width, rect.height), color, z_order)
        self.fill_rect(cmds, Rect2.new(rect.x + rect.width - width, rect.y, width, rect.height), color, z_order)

    fn stroke_line(cmds: RenderCommandBuffer, x1: f64, y1: f64, x2: f64, y2: f64, width: f64, color: EngineColor, z_order: ZIndex):
        """Push a line render command."""
        cmds.push(RenderCommand.DrawLine(
            x1: x1, y1: y1, x2: x2, y2: y2,
            width: width, color: color, z_order: z_order
        ))
