# Render Commands — Immediate-mode draw command buffer
#
# Collects draw commands during scene traversal for later sorting and
# rasterization by the software render pipeline.
#
# Usage:
#   var buf = RenderCommandBuffer.create()
#   buf.push(RenderCommand.Clear(color: EngineColor.black()))
#   buf.push(RenderCommand.DrawRect(rect: r, color: EngineColor.red(), z_order: ZIndex(value: 0)))

use std.common.engine.color.{EngineColor}
use std.common.engine.rect.{Rect2}
use std.common.engine.ids.{TextureId}
use std.common.engine.units.{ZIndex}
use std.nogc_sync_mut.engine.render.types.{Vertex2D}

# ============================================================================
# RenderCommand — A single draw operation
# ============================================================================

enum RenderCommand:
    Clear(color: EngineColor)
    DrawRect(rect: Rect2, color: EngineColor, z_order: ZIndex)
    DrawCircle(cx: f64, cy: f64, radius: f64, color: EngineColor, z_order: ZIndex)
    DrawLine(x1: f64, y1: f64, x2: f64, y2: f64, width: f64, color: EngineColor, z_order: ZIndex)
    DrawSprite(texture_id: TextureId, src_rect: Rect2, dst_rect: Rect2, tint: EngineColor, z_order: ZIndex)
    DrawTriangles(vertices: [Vertex2D], indices: [i64], color: EngineColor, z_order: ZIndex)

# ============================================================================
# RenderCommandBuffer — Accumulates commands for a frame
# ============================================================================

class RenderCommandBuffer:
    commands: [RenderCommand]

impl RenderCommandBuffer:
    static fn create() -> RenderCommandBuffer:
        """Create an empty command buffer."""
        RenderCommandBuffer(commands: [])

    me push(cmd: RenderCommand):
        """Append a render command to the buffer."""
        self.commands.push(cmd)

    me clear():
        """Remove all commands from the buffer."""
        self.commands = []

    fn len() -> i64:
        """Return the number of queued commands."""
        self.commands.len()
