# Physics2 — Continuous Collision Detection (CCD)
#
# Sweep-based time-of-impact tests for fast-moving bodies.
# Uses binary search bisection to find the first contact time within a
# physics step, preventing tunnelling.

use std.common.math.{math_sqrt}

# --------------------------------------------------------------------------
# Configuration
# --------------------------------------------------------------------------

struct CCDConfig:
    enabled: bool
    velocity_threshold: f64
    max_substeps: i32
    toi_tolerance: f64

fn default_ccd_config() -> CCDConfig:
    CCDConfig(
        enabled: true,
        velocity_threshold: 100.0,
        max_substeps: 8,
        toi_tolerance: 0.001
    )

# --------------------------------------------------------------------------
# Result
# --------------------------------------------------------------------------

struct CCDResult:
    hit: bool
    time_of_impact: f64
    contact_x: f64
    contact_y: f64
    normal_x: f64
    normal_y: f64

impl CCDResult:
    static fn no_hit() -> CCDResult:
        CCDResult(
            hit: false,
            time_of_impact: 1.0,
            contact_x: 0.0, contact_y: 0.0,
            normal_x: 0.0, normal_y: 0.0
        )

    static fn impact(toi: f64, cx: f64, cy: f64, nx: f64, ny: f64) -> CCDResult:
        CCDResult(
            hit: true,
            time_of_impact: toi,
            contact_x: cx, contact_y: cy,
            normal_x: nx, normal_y: ny
        )

# --------------------------------------------------------------------------
# Threshold check
# --------------------------------------------------------------------------

fn needs_ccd(vx: f64, vy: f64, radius: f64, config: CCDConfig) -> bool:
    if not config.enabled:
        return false
    val speed_sq = vx * vx + vy * vy
    # Body needs CCD if speed exceeds threshold relative to its size
    val threshold = config.velocity_threshold
    var effective_threshold = threshold
    if radius > 0.0:
        # Scale threshold by body size — smaller bodies need CCD sooner
        effective_threshold = threshold * radius
        if effective_threshold < threshold * 0.1:
            effective_threshold = threshold * 0.1
    speed_sq > effective_threshold * effective_threshold

# --------------------------------------------------------------------------
# Circle vs circle sweep (binary search bisection)
# --------------------------------------------------------------------------

fn sweep_circle_vs_circle(
    a_x: f64, a_y: f64, a_vx: f64, a_vy: f64, a_r: f64,
    b_x: f64, b_y: f64, b_vx: f64, b_vy: f64, b_r: f64,
    dt: f64
) -> CCDResult:
    # Use relative velocity to reduce to moving-vs-stationary
    val rel_vx = (a_vx - b_vx) * dt
    val rel_vy = (a_vy - b_vy) * dt
    val combined_r = a_r + b_r
    val dx0 = a_x - b_x
    val dy0 = a_y - b_y

    # Quick check: are they already overlapping at t=0?
    val dist0_sq = dx0 * dx0 + dy0 * dy0
    if dist0_sq <= combined_r * combined_r:
        val dist0 = math_sqrt(dist0_sq)
        var nx = 0.0
        var ny = 1.0
        if dist0 > 0.0001:
            nx = dx0 / dist0
            ny = dy0 / dist0
        val cx = (a_x + b_x) * 0.5
        val cy = (a_y + b_y) * 0.5
        return CCDResult.impact(0.0, cx, cy, nx, ny)

    # Quick check: will they get closer? (dot of relative vel with separation)
    val approach = dx0 * rel_vx + dy0 * rel_vy
    if approach >= 0.0:
        # Moving apart
        return CCDResult.no_hit()

    # Check end positions
    val dx1 = dx0 + rel_vx
    val dy1 = dy0 + rel_vy
    val dist1_sq = dx1 * dx1 + dy1 * dy1

    # Find closest approach: t_min = -dot(d0, relv) / dot(relv, relv)
    val rel_v_sq = rel_vx * rel_vx + rel_vy * rel_vy
    if rel_v_sq < 0.0000001:
        return CCDResult.no_hit()

    val t_closest = -(dx0 * rel_vx + dy0 * rel_vy) / rel_v_sq
    if t_closest < 0.0 or t_closest > 1.0:
        return CCDResult.no_hit()

    # Distance at closest approach
    val dx_min = dx0 + rel_vx * t_closest
    val dy_min = dy0 + rel_vy * t_closest
    val dist_min_sq = dx_min * dx_min + dy_min * dy_min
    if dist_min_sq > combined_r * combined_r:
        return CCDResult.no_hit()

    # Binary search to find exact TOI
    var t_lo = 0.0
    var t_hi = t_closest
    var iterations = 0
    while iterations < 32:
        val t_mid = (t_lo + t_hi) * 0.5
        val mx = dx0 + rel_vx * t_mid
        val my = dy0 + rel_vy * t_mid
        val md_sq = mx * mx + my * my
        if md_sq <= combined_r * combined_r:
            t_hi = t_mid
        else:
            t_lo = t_mid
        val range = t_hi - t_lo
        if range < 0.001:
            iterations = 100
        else:
            iterations = iterations + 1

    val toi = t_hi
    # Compute contact point and normal at TOI
    val fx_a = a_x + a_vx * dt * toi
    val fy_a = a_y + a_vy * dt * toi
    val fx_b = b_x + b_vx * dt * toi
    val fy_b = b_y + b_vy * dt * toi
    val cdx = fx_a - fx_b
    val cdy = fy_a - fy_b
    val cdist = math_sqrt(cdx * cdx + cdy * cdy)
    var cnx = 0.0
    var cny = 1.0
    if cdist > 0.0001:
        cnx = cdx / cdist
        cny = cdy / cdist
    val cpx = fx_b + cnx * b_r
    val cpy = fy_b + cny * b_r
    CCDResult.impact(toi, cpx, cpy, cnx, cny)

# --------------------------------------------------------------------------
# Circle vs line segment sweep
# --------------------------------------------------------------------------

fn sweep_circle_vs_line(
    cx: f64, cy: f64, cvx: f64, cvy: f64, cr: f64,
    lx1: f64, ly1: f64, lx2: f64, ly2: f64,
    dt: f64
) -> CCDResult:
    # Line segment direction
    val seg_dx = lx2 - lx1
    val seg_dy = ly2 - ly1
    val seg_len_sq = seg_dx * seg_dx + seg_dy * seg_dy
    if seg_len_sq < 0.0000001:
        # Degenerate segment — treat as point
        return sweep_circle_vs_circle(
            cx, cy, cvx, cvy, cr,
            lx1, ly1, 0.0, 0.0, 0.0,
            dt
        )

    val seg_len = math_sqrt(seg_len_sq)
    # Line normal (perpendicular, left-hand)
    val line_nx = -seg_dy / seg_len
    val line_ny = seg_dx / seg_len

    # Motion of circle in this timestep
    val move_x = cvx * dt
    val move_y = cvy * dt

    # Binary search for TOI
    var t_lo = 0.0
    var t_hi = 1.0
    var found = false
    var best_toi = 1.0
    var iterations = 0

    # First check: does the circle hit the infinite line at all?
    val d0 = (cx - lx1) * line_nx + (cy - ly1) * line_ny
    val d1 = ((cx + move_x) - lx1) * line_nx + ((cy + move_y) - ly1) * line_ny

    # Check if circle crosses within cr of the line during motion
    var d0_abs = d0
    if d0_abs < 0.0:
        d0_abs = -d0_abs
    var d1_abs = d1
    if d1_abs < 0.0:
        d1_abs = -d1_abs

    if d0_abs > cr and d1_abs > cr:
        # Check if they're on the same side
        if (d0 > 0.0 and d1 > 0.0) or (d0 < 0.0 and d1 < 0.0):
            return CCDResult.no_hit()

    # Binary search
    while iterations < 32:
        val t_mid = (t_lo + t_hi) * 0.5
        val px = cx + move_x * t_mid
        val py = cy + move_y * t_mid

        # Distance from circle center to line segment
        val dist = _point_segment_dist(px, py, lx1, ly1, lx2, ly2)
        if dist <= cr:
            t_hi = t_mid
            found = true
        else:
            t_lo = t_mid
        val range = t_hi - t_lo
        if range < 0.001:
            iterations = 100
        else:
            iterations = iterations + 1

    if not found:
        return CCDResult.no_hit()

    best_toi = t_hi
    # Compute contact point at TOI
    val hit_x = cx + move_x * best_toi
    val hit_y = cy + move_y * best_toi
    # Closest point on segment
    val cp = _closest_point_on_segment(hit_x, hit_y, lx1, ly1, lx2, ly2)
    val ndx = hit_x - cp.x
    val ndy = hit_y - cp.y
    val ndist = math_sqrt(ndx * ndx + ndy * ndy)
    var nnx = line_nx
    var nny = line_ny
    if ndist > 0.0001:
        nnx = ndx / ndist
        nny = ndy / ndist
    val contact_x = cp.x
    val contact_y = cp.y
    CCDResult.impact(best_toi, contact_x, contact_y, nnx, nny)

# --------------------------------------------------------------------------
# Internal geometry helpers
# --------------------------------------------------------------------------

struct _Vec2Result:
    x: f64
    y: f64

fn _point_segment_dist(px: f64, py: f64, ax: f64, ay: f64, bx: f64, by: f64) -> f64:
    val abx = bx - ax
    val aby = by - ay
    val apx = px - ax
    val apy = py - ay
    val ab_sq = abx * abx + aby * aby
    if ab_sq < 0.0000001:
        return math_sqrt(apx * apx + apy * apy)
    var t = (apx * abx + apy * aby) / ab_sq
    if t < 0.0:
        t = 0.0
    if t > 1.0:
        t = 1.0
    val closest_x = ax + abx * t
    val closest_y = ay + aby * t
    val dx = px - closest_x
    val dy = py - closest_y
    math_sqrt(dx * dx + dy * dy)

fn _closest_point_on_segment(px: f64, py: f64, ax: f64, ay: f64, bx: f64, by: f64) -> _Vec2Result:
    val abx = bx - ax
    val aby = by - ay
    val apx = px - ax
    val apy = py - ay
    val ab_sq = abx * abx + aby * aby
    if ab_sq < 0.0000001:
        return _Vec2Result(x: ax, y: ay)
    var t = (apx * abx + apy * aby) / ab_sq
    if t < 0.0:
        t = 0.0
    if t > 1.0:
        t = 1.0
    _Vec2Result(x: ax + abx * t, y: ay + aby * t)
