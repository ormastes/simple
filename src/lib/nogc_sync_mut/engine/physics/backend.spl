# Physics2 — Backend Selection
#
# Multi-backend dispatch for the physics engine. Follows the same pattern
# as GpuBackendType in the rendering system: enum + priority-based auto-selection.

use std.nogc_sync_mut.simd.profile.{detect_profile, SimdTier}

enum PhysicsBackend:
    CpuScalar
    CpuSimd
    Cuda
    VulkanCompute
    Auto

fn select_backend(preferred: PhysicsBackend) -> PhysicsBackend:
    if preferred != PhysicsBackend.Auto:
        return preferred
    val tier = detect_profile()
    if tier != SimdTier.scalar:
        return PhysicsBackend.CpuSimd
    PhysicsBackend.CpuScalar

fn backend_name(b: PhysicsBackend) -> text:
    match b:
        PhysicsBackend.CpuScalar => "cpu_scalar"
        PhysicsBackend.CpuSimd => "cpu_simd"
        PhysicsBackend.Cuda => "cuda"
        PhysicsBackend.VulkanCompute => "vulkan_compute"
        PhysicsBackend.Auto => "auto"

fn backend_priority(b: PhysicsBackend) -> i64:
    match b:
        PhysicsBackend.CpuScalar => 0
        PhysicsBackend.CpuSimd => 1
        PhysicsBackend.VulkanCompute => 2
        PhysicsBackend.Cuda => 3
        PhysicsBackend.Auto => -1
