# Physics System — Core Types
#
# Data types for the 2D physics system. These map engine NodeIds
# to internal body/collider array indices for the pure Simple
# physics engine (no FFI).
#
# Usage:
#   val config = default_physics_config()
#   val body = PhysicsBody2D(node_id: my_node, body_index: 0, body_type_code: 2, gravity_scale: 1.0)

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}
use std.common.engine.units.{Seconds, Distance}

# ============================================================================
# PhysicsConfig — World simulation parameters
# ============================================================================

struct PhysicsConfig:
    gravity: Vec2
    fixed_timestep: Seconds
    sleep_enabled: bool

fn default_physics_config() -> PhysicsConfig:
    PhysicsConfig(
        gravity: Vec2(x: 0.0, y: -9.81),
        fixed_timestep: Seconds(value: 0.016666666666666666),
        sleep_enabled: true
    )

# ============================================================================
# PhysicsBody2D — Maps a scene node to an internal rigid body
# ============================================================================

struct PhysicsBody2D:
    node_id: NodeId
    body_index: i64
    body_type_code: i64      # 0 = static, 1 = kinematic, 2 = dynamic
    gravity_scale: f64

impl PhysicsBody2D:
    fn is_static() -> bool:
        self.body_type_code == 0

    fn is_kinematic() -> bool:
        self.body_type_code == 1

    fn is_dynamic() -> bool:
        self.body_type_code == 2

# ============================================================================
# PhysicsCollider2D — Maps a scene node to an internal collider shape
# ============================================================================

struct PhysicsCollider2D:
    node_id: NodeId
    collider_index: i64
    shape_code: i64     # 0 = circle, 1 = box
    is_sensor: bool

# ============================================================================
# CollisionEvent — Emitted when two bodies contact or separate
# ============================================================================

struct CollisionEvent:
    node_a: NodeId
    node_b: NodeId
    normal: Vec2
    depth: Distance
    is_sensor: bool

impl CollisionEvent:
    fn to_string() -> text:
        val a_idx = self.node_a.to_index()
        val b_idx = self.node_b.to_index()
        val d = self.depth.value
        "CollisionEvent(a={a_idx}, b={b_idx}, depth={d})"

# ============================================================================
# RaycastHit2D — Result from a physics raycast query
# ============================================================================

struct RaycastHit2D:
    node_id: NodeId
    point: Vec2
    normal: Vec2
    distance: Distance

impl RaycastHit2D:
    fn to_string() -> text:
        val idx = self.node_id.to_index()
        val dist = self.distance.value
        "RaycastHit2D(node={idx}, dist={dist})"
