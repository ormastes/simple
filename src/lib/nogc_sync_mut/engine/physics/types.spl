# Physics System — Core Types
#
# Data types for the 2D physics system. These wrap engine IDs
# and Rapier2D FFI handles into ergonomic structures for the
# game engine layer.
#
# Usage:
#   val config = default_physics_config()
#   val body = PhysicsBody2D(node_id: my_node, body_handle: h, body_type_code: 2, gravity_scale: 1.0)

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}

# ============================================================================
# PhysicsConfig — World simulation parameters
# ============================================================================

struct PhysicsConfig:
    gravity: Vec2
    fixed_timestep: f64
    sleep_enabled: bool

fn default_physics_config() -> PhysicsConfig:
    PhysicsConfig(
        gravity: Vec2(x: 0.0, y: -9.81),
        fixed_timestep: 0.016666666666666666,
        sleep_enabled: true
    )

# ============================================================================
# PhysicsBody2D — Maps a scene node to a Rapier rigid body
# ============================================================================

struct PhysicsBody2D:
    node_id: NodeId
    body_handle: i64
    body_type_code: i64      # 0 = static, 1 = kinematic, 2 = dynamic
    gravity_scale: f64

impl PhysicsBody2D:
    fn is_static() -> bool:
        self.body_type_code == 0

    fn is_kinematic() -> bool:
        self.body_type_code == 1

    fn is_dynamic() -> bool:
        self.body_type_code == 2

# ============================================================================
# PhysicsCollider2D — Maps a scene node to a Rapier collider
# ============================================================================

struct PhysicsCollider2D:
    node_id: NodeId
    collider_handle: i64
    shape_code: i64     # 0 = circle, 1 = box, 2 = capsule, 3 = polygon
    is_sensor: bool

# ============================================================================
# CollisionEvent — Emitted when two bodies contact or separate
# ============================================================================

struct CollisionEvent:
    node_a: NodeId
    node_b: NodeId
    normal: Vec2
    depth: f64
    is_sensor: bool

impl CollisionEvent:
    fn to_string() -> text:
        val a_idx = self.node_a.to_index()
        val b_idx = self.node_b.to_index()
        "CollisionEvent(a={a_idx}, b={b_idx}, depth={self.depth})"

# ============================================================================
# RaycastHit2D — Result from a physics raycast query
# ============================================================================

struct RaycastHit2D:
    node_id: NodeId
    point: Vec2
    normal: Vec2
    distance: f64

impl RaycastHit2D:
    fn to_string() -> text:
        val idx = self.node_id.to_index()
        "RaycastHit2D(node={idx}, dist={self.distance})"
