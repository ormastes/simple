# Physics2 — 3D Contact Constraint Data (SoA)
#
# Full 3D contact constraints: normal + two tangent directions, 3D contact
# point, accumulated clamped lambdas for normal and both tangents. Stored as
# structure-of-arrays for cache-friendly iteration.
#
# ponytail: no persistent manifolds / warm-start yet — cleared every
# substep by PhysicsWorld3D.detect_contacts(). Feature ids are carried so a
# later tranche can match contacts across steps without touching this
# layout.

use std.common.math.{math_sqrt, math_abs}

class ContactConstraint3DSoA:
    body_a: [i64]
    body_b: [i64]
    normal_x: [f64]
    normal_y: [f64]
    normal_z: [f64]
    point_x: [f64]
    point_y: [f64]
    point_z: [f64]
    tangent1_x: [f64]
    tangent1_y: [f64]
    tangent1_z: [f64]
    tangent2_x: [f64]
    tangent2_y: [f64]
    tangent2_z: [f64]
    penetration: [f64]
    restitution: [f64]
    friction: [f64]
    lambda_normal: [f64]
    lambda_tangent1: [f64]
    lambda_tangent2: [f64]
    feature_id_a: [i64]
    feature_id_b: [i64]
    count: i64

impl ContactConstraint3DSoA:
    static fn create() -> ContactConstraint3DSoA:
        ContactConstraint3DSoA(
            body_a: [], body_b: [],
            normal_x: [], normal_y: [], normal_z: [],
            point_x: [], point_y: [], point_z: [],
            tangent1_x: [], tangent1_y: [], tangent1_z: [],
            tangent2_x: [], tangent2_y: [], tangent2_z: [],
            penetration: [],
            restitution: [], friction: [],
            lambda_normal: [], lambda_tangent1: [], lambda_tangent2: [],
            feature_id_a: [], feature_id_b: [],
            count: 0
        )

    # Adds a contact. Builds an orthonormal tangent basis from the normal
    # via standard basis-pick (avoid the axis nearest-parallel to n) plus
    # two cross products, so callers only ever supply the normal.
    me add(a: i64, b: i64, nx: f64, ny: f64, nz: f64, px: f64, py: f64, pz: f64, pen: f64, rest: f64, fric: f64, feat_a: i64, feat_b: i64):
        self.body_a.push(a)
        self.body_b.push(b)
        self.normal_x.push(nx)
        self.normal_y.push(ny)
        self.normal_z.push(nz)
        self.point_x.push(px)
        self.point_y.push(py)
        self.point_z.push(pz)

        var ax = 1.0
        var ay = 0.0
        var az = 0.0
        if math_abs(nx) > 0.9:
            ax = 0.0
            ay = 1.0
            az = 0.0

        var t1x = ay * nz - az * ny
        var t1y = az * nx - ax * nz
        var t1z = ax * ny - ay * nx
        val t1_len = math_sqrt(t1x * t1x + t1y * t1y + t1z * t1z)
        if t1_len > 0.0000001:
            t1x = t1x / t1_len
            t1y = t1y / t1_len
            t1z = t1z / t1_len
        else:
            t1x = 1.0
            t1y = 0.0
            t1z = 0.0

        val t2x = ny * t1z - nz * t1y
        val t2y = nz * t1x - nx * t1z
        val t2z = nx * t1y - ny * t1x

        self.tangent1_x.push(t1x)
        self.tangent1_y.push(t1y)
        self.tangent1_z.push(t1z)
        self.tangent2_x.push(t2x)
        self.tangent2_y.push(t2y)
        self.tangent2_z.push(t2z)

        self.penetration.push(pen)
        self.restitution.push(rest)
        self.friction.push(fric)
        self.lambda_normal.push(0.0)
        self.lambda_tangent1.push(0.0)
        self.lambda_tangent2.push(0.0)
        self.feature_id_a.push(feat_a)
        self.feature_id_b.push(feat_b)
        self.count = self.count + 1

    me clear():
        self.body_a = []
        self.body_b = []
        self.normal_x = []
        self.normal_y = []
        self.normal_z = []
        self.point_x = []
        self.point_y = []
        self.point_z = []
        self.tangent1_x = []
        self.tangent1_y = []
        self.tangent1_z = []
        self.tangent2_x = []
        self.tangent2_y = []
        self.tangent2_z = []
        self.penetration = []
        self.restitution = []
        self.friction = []
        self.lambda_normal = []
        self.lambda_tangent1 = []
        self.lambda_tangent2 = []
        self.feature_id_a = []
        self.feature_id_b = []
        self.count = 0
