@allow(primitive_api)
# Physics System — 2D Collision Detection
#
# Narrow-phase collision detection for circle and box shapes.
# Returns Contact2D with contact point, normal, and penetration depth.
#
# Supported pairs:
#   - Circle vs Circle
#   - AABB vs AABB (axis-aligned boxes)
#   - Circle vs AABB
#   - OBB vs OBB (oriented boxes, 2D SAT with 4 axes)

use std.common.engine.math2d.{Vec2, _sqrt, _sin, _cos}
use std.common.math.{math_abs, math_clamp, math_min, math_max}

# ============================================================================
# Contact2D — collision contact information
# ============================================================================

class Contact2D:
    point: Vec2
    normal: Vec2
    penetration: f64

# ============================================================================
# Circle vs Circle
# ============================================================================

fn collide_circle_circle(pos_a: Vec2, radius_a: f64, pos_b: Vec2, radius_b: f64) -> Option<Contact2D>:
    """Detect and generate contact between two circles."""
    val dx = pos_b.x - pos_a.x
    val dy = pos_b.y - pos_a.y
    val dist_sq = dx * dx + dy * dy
    val sum_radii = radius_a + radius_b

    if dist_sq >= sum_radii * sum_radii:
        return nil

    val dist = _sqrt(dist_sq)

    # Handle overlapping centers
    var normal = Vec2(x: 1.0, y: 0.0)
    if dist > 0.0000001:
        normal = Vec2(x: dx / dist, y: dy / dist)

    val penetration = sum_radii - dist
    val point = Vec2(x: pos_a.x + normal.x * radius_a, y: pos_a.y + normal.y * radius_a)

    Contact2D(point: point, normal: normal, penetration: penetration)

# ============================================================================
# AABB vs AABB (no rotation)
# ============================================================================

fn collide_aabb_aabb(pos_a: Vec2, hw_a: f64, hh_a: f64, pos_b: Vec2, hw_b: f64, hh_b: f64) -> Option<Contact2D>:
    """Detect and generate contact between two axis-aligned boxes."""
    val dx = pos_b.x - pos_a.x
    val dy = pos_b.y - pos_a.y

    val overlap_x = hw_a + hw_b - math_abs(dx)
    if overlap_x <= 0.0:
        return nil

    val overlap_y = hh_a + hh_b - math_abs(dy)
    if overlap_y <= 0.0:
        return nil

    # Use axis with smallest overlap (minimum penetration axis)
    var normal = Vec2.zero()
    var penetration = 0.0
    var point = Vec2.zero()

    if overlap_x < overlap_y:
        # Separate along X
        penetration = overlap_x
        if dx < 0.0:
            normal = Vec2(x: -1.0, y: 0.0)
            point = Vec2(x: pos_a.x - hw_a, y: pos_a.y)
        else:
            normal = Vec2(x: 1.0, y: 0.0)
            point = Vec2(x: pos_a.x + hw_a, y: pos_a.y)
    else:
        # Separate along Y
        penetration = overlap_y
        if dy < 0.0:
            normal = Vec2(x: 0.0, y: -1.0)
            point = Vec2(x: pos_a.x, y: pos_a.y - hh_a)
        else:
            normal = Vec2(x: 0.0, y: 1.0)
            point = Vec2(x: pos_a.x, y: pos_a.y + hh_a)

    Contact2D(point: point, normal: normal, penetration: penetration)

# ============================================================================
# Circle vs AABB
# ============================================================================

fn collide_circle_aabb(circle_pos: Vec2, radius: f64, box_pos: Vec2, hw: f64, hh: f64) -> Option<Contact2D>:
    """Detect and generate contact between a circle and an axis-aligned box."""
    # Clamp circle center to box extent to find closest point on box
    val closest_x = math_clamp(circle_pos.x, box_pos.x - hw, box_pos.x + hw)
    val closest_y = math_clamp(circle_pos.y, box_pos.y - hh, box_pos.y + hh)

    val dx = circle_pos.x - closest_x
    val dy = circle_pos.y - closest_y
    val dist_sq = dx * dx + dy * dy

    if dist_sq >= radius * radius:
        return nil

    val dist = _sqrt(dist_sq)

    var normal = Vec2(x: 1.0, y: 0.0)
    if dist > 0.0000001:
        normal = Vec2(x: dx / dist, y: dy / dist)
    else:
        # Circle center is inside the box — push out along shortest axis
        val diff_x = hw - math_abs(circle_pos.x - box_pos.x)
        val diff_y = hh - math_abs(circle_pos.y - box_pos.y)
        if diff_x < diff_y:
            if circle_pos.x < box_pos.x:
                normal = Vec2(x: -1.0, y: 0.0)
            else:
                normal = Vec2(x: 1.0, y: 0.0)
        else:
            if circle_pos.y < box_pos.y:
                normal = Vec2(x: 0.0, y: -1.0)
            else:
                normal = Vec2(x: 0.0, y: 1.0)

    val penetration = radius - dist
    val point = Vec2(x: closest_x, y: closest_y)

    Contact2D(point: point, normal: normal, penetration: penetration)

# ============================================================================
# OBB vs OBB — 2D SAT with 4 axes (2 per box)
# ============================================================================

fn collide_box_box(pos_a: Vec2, hw_a: f64, hh_a: f64, rot_a: f64, pos_b: Vec2, hw_b: f64, hh_b: f64, rot_b: f64) -> Option<Contact2D>:
    """Detect and generate contact between two oriented boxes using 2D SAT."""
    # Compute local axes for box A
    val cos_a = _cos(rot_a)
    val sin_a = _sin(rot_a)
    val ax_a0 = Vec2(x: cos_a, y: sin_a)
    val ax_a1 = Vec2(x: -sin_a, y: cos_a)

    # Compute local axes for box B
    val cos_b = _cos(rot_b)
    val sin_b = _sin(rot_b)
    val ax_b0 = Vec2(x: cos_b, y: sin_b)
    val ax_b1 = Vec2(x: -sin_b, y: cos_b)

    # Vector from A center to B center
    val d = pos_b.sub(pos_a)

    # We test 4 axes and track the one with minimum penetration
    var min_pen = 999999999.0
    var min_axis = Vec2(x: 1.0, y: 0.0)

    # Test axis ax_a0
    val pen0 = _sat_overlap(d, ax_a0, hw_a, hh_a, ax_a0, ax_a1, hw_b, hh_b, ax_b0, ax_b1)
    if pen0 <= 0.0:
        return nil
    if pen0 < min_pen:
        min_pen = pen0
        min_axis = ax_a0

    # Test axis ax_a1
    val pen1 = _sat_overlap(d, ax_a1, hh_a, hw_a, ax_a1, ax_a0, hw_b, hh_b, ax_b0, ax_b1)
    if pen1 <= 0.0:
        return nil
    if pen1 < min_pen:
        min_pen = pen1
        min_axis = ax_a1

    # Test axis ax_b0
    val pen2 = _sat_overlap(d, ax_b0, hw_b, hh_b, ax_b0, ax_b1, hw_a, hh_a, ax_a0, ax_a1)
    if pen2 <= 0.0:
        return nil
    if pen2 < min_pen:
        min_pen = pen2
        min_axis = ax_b0

    # Test axis ax_b1
    val pen3 = _sat_overlap(d, ax_b1, hh_b, hw_b, ax_b1, ax_b0, hw_a, hh_a, ax_a0, ax_a1)
    if pen3 <= 0.0:
        return nil
    if pen3 < min_pen:
        min_pen = pen3
        min_axis = ax_b1

    # Ensure normal points from A to B
    if d.dot(min_axis) < 0.0:
        min_axis = min_axis.mul_scalar(-1.0)

    val mid = Vec2(x: (pos_a.x + pos_b.x) * 0.5, y: (pos_a.y + pos_b.y) * 0.5)

    Contact2D(point: mid, normal: min_axis, penetration: min_pen)

# ============================================================================
# SAT helper — project both boxes onto axis and return overlap
# ============================================================================

fn _sat_overlap(d: Vec2, axis: Vec2, hw_self: f64, hh_self: f64, ax_s0: Vec2, ax_s1: Vec2, hw_other: f64, hh_other: f64, ax_o0: Vec2, ax_o1: Vec2) -> f64:
    """Project both OBBs onto axis and return overlap (negative = separated)."""
    # Half-extent projection of first box along axis
    val proj_self = hw_self * math_abs(axis.dot(ax_s0)) + hh_self * math_abs(axis.dot(ax_s1))
    # Half-extent projection of second box along axis
    val proj_other = hw_other * math_abs(axis.dot(ax_o0)) + hh_other * math_abs(axis.dot(ax_o1))
    # Distance between centers projected onto axis
    val dist = math_abs(d.dot(axis))
    # Overlap
    proj_self + proj_other - dist
