# Destruction System — mesh fracturing and fragment physics

struct Fragment:
    id: i32
    center_x: f64
    center_y: f64
    center_z: f64
    velocity_x: f64
    velocity_y: f64
    velocity_z: f64
    mass: f64
    active: bool

class Destructible:
    name: text
    fragments: [Fragment]
    destroyed: bool
    health: f64
    max_health: f64
    next_id: i32

impl Destructible:
    static fn new(name: text, health: f64) -> Destructible:
        Destructible(
            name: name, fragments: [], destroyed: false,
            health: health, max_health: health, next_id: 1
        )

    me add_fragment(cx: f64, cy: f64, cz: f64, mass: f64) -> i32:
        val fid = self.next_id
        self.next_id = self.next_id + 1
        val frag = Fragment(
            id: fid, center_x: cx, center_y: cy, center_z: cz,
            velocity_x: 0.0, velocity_y: 0.0, velocity_z: 0.0,
            mass: mass, active: false
        )
        self.fragments.push(frag)
        fid

    me apply_damage(amount: f64) -> bool:
        self.health = self.health - amount
        if self.health <= 0.0:
            self.health = 0.0
            self.destroyed = true
            self._activate_fragments()
            return true
        false

    me apply_impulse(fragment_id: i32, vx: f64, vy: f64, vz: f64):
        var i = 0
        while i < self.fragments.len():
            if self.fragments[i].id == fragment_id:
                val old = self.fragments[i]
                self.fragments[i] = Fragment(
                    id: old.id, center_x: old.center_x, center_y: old.center_y, center_z: old.center_z,
                    velocity_x: old.velocity_x + vx, velocity_y: old.velocity_y + vy, velocity_z: old.velocity_z + vz,
                    mass: old.mass, active: old.active
                )
                return
            i = i + 1

    me update(dt: f64):
        if not self.destroyed:
            return
        var i = 0
        while i < self.fragments.len():
            val f = self.fragments[i]
            if f.active:
                self.fragments[i] = Fragment(
                    id: f.id,
                    center_x: f.center_x + f.velocity_x * dt,
                    center_y: f.center_y + f.velocity_y * dt,
                    center_z: f.center_z + f.velocity_z * dt,
                    velocity_x: f.velocity_x, velocity_y: f.velocity_y, velocity_z: f.velocity_z,
                    mass: f.mass, active: true
                )
            i = i + 1

    fn is_destroyed() -> bool:
        self.destroyed

    fn fragment_count() -> i32:
        self.fragments.len().to_i32()

    fn active_fragment_count() -> i32:
        var count = 0
        var i = 0
        while i < self.fragments.len():
            if self.fragments[i].active:
                count = count + 1
            i = i + 1
        count

    fn get_health() -> f64:
        self.health

    me _activate_fragments():
        var i = 0
        while i < self.fragments.len():
            val old = self.fragments[i]
            self.fragments[i] = Fragment(
                id: old.id, center_x: old.center_x, center_y: old.center_y, center_z: old.center_z,
                velocity_x: old.velocity_x, velocity_y: old.velocity_y, velocity_z: old.velocity_z,
                mass: old.mass, active: true
            )
            i = i + 1
