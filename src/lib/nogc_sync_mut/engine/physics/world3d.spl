# Physics2 — PhysicsWorld3D (Multi-Backend)
#
# 3D physics world with the same backend dispatch as world2d.
# Uses quaternion rotation, 3D collision detection, and TGS solver.
#
# [C29 fix] Contacts are detected in full 3D (NarrowContact3D carries xyz
# point/normal) and now resolved in full 3D too: ContactConstraint3DSoA
# carries a 3D normal, two tangents, and three accumulated lambdas; the
# solver applies linear + angular impulses on all three axes for both the
# normal and both tangent directions.
#
# ponytail: SolverBodyStore3D only carries a diagonal inverse inertia
# (inv_inertia_x/y/z, body-local axes never re-derived from rotation), so
# angular_term_3d() uses that diagonal directly rather than a full 3x3
# world-space inertia tensor. Matches the diagonal-tensor approach already
# used by physics/contact3d.spl elsewhere in this tree. Upgrade to a
# world-space tensor when OBB/general rotation lands (Phase 6).

use std.common.engine.ids.{NodeId}
use std.common.math.{math_sqrt, math_abs}
use std.nogc_sync_mut.engine.physics.config.{PhysicsConfig3D, Vec3}
use std.nogc_sync_mut.engine.physics.backend.{PhysicsBackend, select_backend}
use std.nogc_sync_mut.engine.physics.data.solver_body3d.{SolverBodyStore3D}
use std.nogc_sync_mut.engine.physics.data.constraint3d.{ContactConstraint3DSoA}
use std.nogc_sync_mut.engine.physics.events3d.{ContactEvent3D, ContactPairTracker3D}
use std.nogc_sync_mut.engine.physics.narrowphase.collision3d.{collide_sphere_sphere, collide_aabb_aabb_3d, collide_sphere_aabb_3d, NarrowContact3D}

enum ShapeType3D:
    Sphere
    Box
    Capsule

struct Collider3D:
    body_index: i64
    node_id: NodeId
    shape_type: ShapeType3D
    radius: f64
    half_x: f64
    half_y: f64
    half_z: f64

struct Transform3D:
    node_id: NodeId
    x: f64
    y: f64
    z: f64
    rot_w: f64
    rot_x: f64
    rot_y: f64
    rot_z: f64

# 3D cross product, returned as a 3-element array [x, y, z]. Not a tuple —
# an ordinary value-typed array, matching get_all_dynamic_transforms()'s
# array-return style elsewhere in this file.
fn vec3_cross(ax: f64, ay: f64, az: f64, bx: f64, by: f64, bz: f64) -> [f64]:
    [ay * bz - az * by, az * bx - ax * bz, ax * by - ay * bx]

class PhysicsWorld3D:
    config: PhysicsConfig3D
    active_backend: PhysicsBackend
    bodies: SolverBodyStore3D
    colliders: [Collider3D]
    collider_count: i64
    constraints: ContactConstraint3DSoA
    pair_tracker: ContactPairTracker3D
    last_events: [ContactEvent3D]
    accumulator: f64
    node_to_body: [i64]
    max_node_index: i64

impl PhysicsWorld3D:
    static fn create(config: PhysicsConfig3D) -> PhysicsWorld3D:
        val backend = select_backend(config.backend)
        PhysicsWorld3D(
            config: config,
            active_backend: backend,
            bodies: SolverBodyStore3D.create(),
            colliders: [],
            collider_count: 0,
            constraints: ContactConstraint3DSoA.create(),
            pair_tracker: ContactPairTracker3D.create(),
            last_events: [],
            accumulator: 0.0,
            node_to_body: [],
            max_node_index: 0
        )

    me add_dynamic_body(node_id: NodeId, x: f64, y: f64, z: f64, mass: f64) -> i64:
        val idx = self.bodies.add_dynamic(node_id, x, y, z, mass)
        self.ensure_node_map(node_id.to_index())
        self.node_to_body[node_id.to_index()] = idx
        idx

    me add_static_body(node_id: NodeId, x: f64, y: f64, z: f64) -> i64:
        val idx = self.bodies.add_static(node_id, x, y, z)
        self.ensure_node_map(node_id.to_index())
        self.node_to_body[node_id.to_index()] = idx
        idx

    me add_sphere_collider(node_id: NodeId, radius: f64) -> i64:
        val body_idx = self.node_to_body[node_id.to_index()]
        val c = Collider3D(
            body_index: body_idx, node_id: node_id,
            shape_type: ShapeType3D.Sphere,
            radius: radius, half_x: radius, half_y: radius, half_z: radius
        )
        self.colliders.push(c)
        val idx = self.collider_count
        self.collider_count = self.collider_count + 1
        idx

    me add_box_collider(node_id: NodeId, hx: f64, hy: f64, hz: f64) -> i64:
        val body_idx = self.node_to_body[node_id.to_index()]
        val c = Collider3D(
            body_index: body_idx, node_id: node_id,
            shape_type: ShapeType3D.Box,
            radius: 0.0, half_x: hx, half_y: hy, half_z: hz
        )
        self.colliders.push(c)
        val idx = self.collider_count
        self.collider_count = self.collider_count + 1
        idx

    me step(dt: f64):
        self.last_events = []
        self.accumulator = self.accumulator + dt
        val fixed_dt = self.config.fixed_timestep
        while self.accumulator >= fixed_dt:
            self.bodies.save_prev_transforms()
            self.fixed_step(fixed_dt)
            self.accumulator = self.accumulator - fixed_dt

    me fixed_step(dt: f64):
        val sub_dt = dt / self.config.sub_steps.to_f64()
        var sub = 0
        while sub < self.config.sub_steps:
            self.bodies.integrate(sub_dt, self.config.gravity.x, self.config.gravity.y, self.config.gravity.z)
            self.detect_contacts()
            self.solve_contacts()
            sub = sub + 1
        # Contact events are frame-level (once per fixed step), not
        # per-substep — substepping is an internal solver detail.
        val step_events = self.pair_tracker.diff(self.constraints.body_a, self.constraints.body_b, self.constraints.count)
        var ei = 0
        while ei < step_events.len():
            self.last_events.push(step_events[ei])
            ei = ei + 1

    # Buffered Begin/Stay/End contact events produced by the most recent
    # step() call. Never dispatched as callbacks during the solve.
    me events() -> [ContactEvent3D]:
        self.last_events

    me detect_contacts():
        self.constraints.clear()
        var i = 0
        while i < self.collider_count:
            var j = i + 1
            while j < self.collider_count:
                val ca = self.colliders[i]
                val cb = self.colliders[j]
                val ai = ca.body_index
                val bi = cb.body_index
                if self.bodies.inv_mass[ai] == 0.0 and self.bodies.inv_mass[bi] == 0.0:
                    j = j + 1
                    continue
                val contact = self.collide_3d(ca, cb)
                if contact.has_contact:
                    self.constraints.add(
                        ai, bi,
                        contact.normal_x, contact.normal_y, contact.normal_z,
                        contact.point_x, contact.point_y, contact.point_z,
                        contact.penetration,
                        self.config.restitution,
                        self.config.friction,
                        contact.feature_id_a, contact.feature_id_b
                    )
                j = j + 1
            i = i + 1

    me collide_3d(ca: Collider3D, cb: Collider3D) -> NarrowContact3D:
        val ax = self.bodies.pos_x[ca.body_index]
        val ay = self.bodies.pos_y[ca.body_index]
        val az = self.bodies.pos_z[ca.body_index]
        val bx = self.bodies.pos_x[cb.body_index]
        val by = self.bodies.pos_y[cb.body_index]
        val bz = self.bodies.pos_z[cb.body_index]
        if ca.shape_type == ShapeType3D.Sphere and cb.shape_type == ShapeType3D.Sphere:
            return collide_sphere_sphere(ax, ay, az, ca.radius, bx, by, bz, cb.radius)
        if ca.shape_type == ShapeType3D.Box and cb.shape_type == ShapeType3D.Box:
            return collide_aabb_aabb_3d(ax, ay, az, ca.half_x, ca.half_y, ca.half_z, bx, by, bz, cb.half_x, cb.half_y, cb.half_z)
        if ca.shape_type == ShapeType3D.Box and cb.shape_type == ShapeType3D.Sphere:
            # Helper normal points box -> sphere == a -> b here.
            return collide_sphere_aabb_3d(bx, by, bz, cb.radius, ax, ay, az, ca.half_x, ca.half_y, ca.half_z)
        if ca.shape_type == ShapeType3D.Sphere and cb.shape_type == ShapeType3D.Box:
            val c = collide_sphere_aabb_3d(ax, ay, az, ca.radius, bx, by, bz, cb.half_x, cb.half_y, cb.half_z)
            if not c.has_contact:
                return c
            # Flip: helper normal is box -> sphere, solver wants a -> b.
            return NarrowContact3D(
                point_x: c.point_x, point_y: c.point_y, point_z: c.point_z,
                normal_x: -c.normal_x, normal_y: -c.normal_y, normal_z: -c.normal_z,
                penetration: c.penetration,
                feature_id_a: c.feature_id_b, feature_id_b: c.feature_id_a,
                has_contact: true
            )
        NarrowContact3D(
            point_x: 0.0, point_y: 0.0, point_z: 0.0,
            normal_x: 0.0, normal_y: 1.0, normal_z: 0.0,
            penetration: 0.0, feature_id_a: 0, feature_id_b: 0,
            has_contact: false
        )

    me solve_contacts():
        if self.constraints.count == 0:
            return
        self.solve_velocity_inline_3d(self.config.velocity_iterations)
        self.solve_position_inline_3d(self.config.position_iterations, self.config.baumgarte_factor, self.config.slop)

    # Velocity at the contact point for body `idx`, given the lever arm r
    # (contact point minus body center): v_linear + omega x r. Returned as
    # a 3-element array, read immediately by the caller.
    me contact_velocity_3d(idx: i64, rx: f64, ry: f64, rz: f64) -> [f64]:
        val wx = self.bodies.ang_vel_x[idx]
        val wy = self.bodies.ang_vel_y[idx]
        val wz = self.bodies.ang_vel_z[idx]
        val c = vec3_cross(wx, wy, wz, rx, ry, rz)
        [self.bodies.vel_x[idx] + c[0], self.bodies.vel_y[idx] + c[1], self.bodies.vel_z[idx] + c[2]]

    # Angular contribution to the effective mass along direction d for
    # body `idx`: d . ((Iinv * (r x d)) x r), diagonal inertia tensor.
    me angular_term_3d(idx: i64, rx: f64, ry: f64, rz: f64, dx: f64, dy: f64, dz: f64) -> f64:
        val r_cross_d = vec3_cross(rx, ry, rz, dx, dy, dz)
        val ix = self.bodies.inv_inertia_x[idx] * r_cross_d[0]
        val iy = self.bodies.inv_inertia_y[idx] * r_cross_d[1]
        val iz = self.bodies.inv_inertia_z[idx] * r_cross_d[2]
        val ang = vec3_cross(ix, iy, iz, rx, ry, rz)
        ang[0] * dx + ang[1] * dy + ang[2] * dz

    me solve_velocity_inline_3d(iterations: i64):
        var iter = 0
        while iter < iterations:
            var ci = 0
            while ci < self.constraints.count:
                val a = self.constraints.body_a[ci]
                val b = self.constraints.body_b[ci]
                val nx = self.constraints.normal_x[ci]
                val ny = self.constraints.normal_y[ci]
                val nz = self.constraints.normal_z[ci]
                val px = self.constraints.point_x[ci]
                val py = self.constraints.point_y[ci]
                val pz = self.constraints.point_z[ci]
                val ra_x = px - self.bodies.pos_x[a]
                val ra_y = py - self.bodies.pos_y[a]
                val ra_z = pz - self.bodies.pos_z[a]
                val rb_x = px - self.bodies.pos_x[b]
                val rb_y = py - self.bodies.pos_y[b]
                val rb_z = pz - self.bodies.pos_z[b]

                val va = self.contact_velocity_3d(a, ra_x, ra_y, ra_z)
                val vb = self.contact_velocity_3d(b, rb_x, rb_y, rb_z)
                val rel_vx = vb[0] - va[0]
                val rel_vy = vb[1] - va[1]
                val rel_vz = vb[2] - va[2]
                val vn = rel_vx * nx + rel_vy * ny + rel_vz * nz

                val ang_a_n = self.angular_term_3d(a, ra_x, ra_y, ra_z, nx, ny, nz)
                val ang_b_n = self.angular_term_3d(b, rb_x, rb_y, rb_z, nx, ny, nz)
                val eff_mass = self.bodies.inv_mass[a] + self.bodies.inv_mass[b] + ang_a_n + ang_b_n

                if eff_mass > 0.0:
                    val restitution = self.constraints.restitution[ci]
                    val bias = if vn < -1.0: restitution * vn else: 0.0
                    val lambda_raw = -(vn + bias) / eff_mass
                    val old_lambda = self.constraints.lambda_normal[ci]
                    var new_lambda = old_lambda + lambda_raw
                    if new_lambda < 0.0:
                        new_lambda = 0.0
                    self.constraints.lambda_normal[ci] = new_lambda
                    val j = new_lambda - old_lambda
                    val jx = nx * j
                    val jy = ny * j
                    val jz = nz * j

                    self.bodies.vel_x[a] = self.bodies.vel_x[a] - jx * self.bodies.inv_mass[a]
                    self.bodies.vel_y[a] = self.bodies.vel_y[a] - jy * self.bodies.inv_mass[a]
                    self.bodies.vel_z[a] = self.bodies.vel_z[a] - jz * self.bodies.inv_mass[a]
                    self.bodies.vel_x[b] = self.bodies.vel_x[b] + jx * self.bodies.inv_mass[b]
                    self.bodies.vel_y[b] = self.bodies.vel_y[b] + jy * self.bodies.inv_mass[b]
                    self.bodies.vel_z[b] = self.bodies.vel_z[b] + jz * self.bodies.inv_mass[b]

                    val ra_cross_j = vec3_cross(ra_x, ra_y, ra_z, jx, jy, jz)
                    self.bodies.ang_vel_x[a] = self.bodies.ang_vel_x[a] - ra_cross_j[0] * self.bodies.inv_inertia_x[a]
                    self.bodies.ang_vel_y[a] = self.bodies.ang_vel_y[a] - ra_cross_j[1] * self.bodies.inv_inertia_y[a]
                    self.bodies.ang_vel_z[a] = self.bodies.ang_vel_z[a] - ra_cross_j[2] * self.bodies.inv_inertia_z[a]

                    val rb_cross_j = vec3_cross(rb_x, rb_y, rb_z, jx, jy, jz)
                    self.bodies.ang_vel_x[b] = self.bodies.ang_vel_x[b] + rb_cross_j[0] * self.bodies.inv_inertia_x[b]
                    self.bodies.ang_vel_y[b] = self.bodies.ang_vel_y[b] + rb_cross_j[1] * self.bodies.inv_inertia_y[b]
                    self.bodies.ang_vel_z[b] = self.bodies.ang_vel_z[b] + rb_cross_j[2] * self.bodies.inv_inertia_z[b]

                    val max_friction = math_abs(new_lambda) * self.constraints.friction[ci]

                    val t1x = self.constraints.tangent1_x[ci]
                    val t1y = self.constraints.tangent1_y[ci]
                    val t1z = self.constraints.tangent1_z[ci]
                    self.solve_tangent_3d(ci, a, b, ra_x, ra_y, ra_z, rb_x, rb_y, rb_z, t1x, t1y, t1z, max_friction, true)

                    val t2x = self.constraints.tangent2_x[ci]
                    val t2y = self.constraints.tangent2_y[ci]
                    val t2z = self.constraints.tangent2_z[ci]
                    self.solve_tangent_3d(ci, a, b, ra_x, ra_y, ra_z, rb_x, rb_y, rb_z, t2x, t2y, t2z, max_friction, false)

                ci = ci + 1
            iter = iter + 1

    # Applies one tangent-direction friction impulse (Coulomb, clamped to
    # +/- max_friction) for contact `ci`. `is_t1` selects which of the two
    # accumulated tangent lambdas to read/update — each tangent axis is
    # clamped independently (box friction, not a combined friction cone).
    me solve_tangent_3d(ci: i64, a: i64, b: i64, ra_x: f64, ra_y: f64, ra_z: f64, rb_x: f64, rb_y: f64, rb_z: f64, tx: f64, ty: f64, tz: f64, max_friction: f64, is_t1: bool):
        val va = self.contact_velocity_3d(a, ra_x, ra_y, ra_z)
        val vb = self.contact_velocity_3d(b, rb_x, rb_y, rb_z)
        val rel_vx = vb[0] - va[0]
        val rel_vy = vb[1] - va[1]
        val rel_vz = vb[2] - va[2]
        val vt = rel_vx * tx + rel_vy * ty + rel_vz * tz

        val ang_a_t = self.angular_term_3d(a, ra_x, ra_y, ra_z, tx, ty, tz)
        val ang_b_t = self.angular_term_3d(b, rb_x, rb_y, rb_z, tx, ty, tz)
        val eff_mass_t = self.bodies.inv_mass[a] + self.bodies.inv_mass[b] + ang_a_t + ang_b_t
        if eff_mass_t <= 0.0:
            return

        val jt_raw = 0.0 - vt / eff_mass_t
        var old_lambda_t = 0.0
        if is_t1:
            old_lambda_t = self.constraints.lambda_tangent1[ci]
        else:
            old_lambda_t = self.constraints.lambda_tangent2[ci]
        var new_lambda_t = old_lambda_t + jt_raw
        if new_lambda_t > max_friction:
            new_lambda_t = max_friction
        if new_lambda_t < 0.0 - max_friction:
            new_lambda_t = 0.0 - max_friction
        if is_t1:
            self.constraints.lambda_tangent1[ci] = new_lambda_t
        else:
            self.constraints.lambda_tangent2[ci] = new_lambda_t
        val jt = new_lambda_t - old_lambda_t
        val jx = tx * jt
        val jy = ty * jt
        val jz = tz * jt

        self.bodies.vel_x[a] = self.bodies.vel_x[a] - jx * self.bodies.inv_mass[a]
        self.bodies.vel_y[a] = self.bodies.vel_y[a] - jy * self.bodies.inv_mass[a]
        self.bodies.vel_z[a] = self.bodies.vel_z[a] - jz * self.bodies.inv_mass[a]
        self.bodies.vel_x[b] = self.bodies.vel_x[b] + jx * self.bodies.inv_mass[b]
        self.bodies.vel_y[b] = self.bodies.vel_y[b] + jy * self.bodies.inv_mass[b]
        self.bodies.vel_z[b] = self.bodies.vel_z[b] + jz * self.bodies.inv_mass[b]

        val ra_cross_j = vec3_cross(ra_x, ra_y, ra_z, jx, jy, jz)
        self.bodies.ang_vel_x[a] = self.bodies.ang_vel_x[a] - ra_cross_j[0] * self.bodies.inv_inertia_x[a]
        self.bodies.ang_vel_y[a] = self.bodies.ang_vel_y[a] - ra_cross_j[1] * self.bodies.inv_inertia_y[a]
        self.bodies.ang_vel_z[a] = self.bodies.ang_vel_z[a] - ra_cross_j[2] * self.bodies.inv_inertia_z[a]

        val rb_cross_j = vec3_cross(rb_x, rb_y, rb_z, jx, jy, jz)
        self.bodies.ang_vel_x[b] = self.bodies.ang_vel_x[b] + rb_cross_j[0] * self.bodies.inv_inertia_x[b]
        self.bodies.ang_vel_y[b] = self.bodies.ang_vel_y[b] + rb_cross_j[1] * self.bodies.inv_inertia_y[b]
        self.bodies.ang_vel_z[b] = self.bodies.ang_vel_z[b] + rb_cross_j[2] * self.bodies.inv_inertia_z[b]

    me solve_position_inline_3d(iterations: i64, baumgarte: f64, slop: f64):
        var iter = 0
        while iter < iterations:
            var ci = 0
            while ci < self.constraints.count:
                val pen = self.constraints.penetration[ci]
                if pen > slop:
                    val a = self.constraints.body_a[ci]
                    val b = self.constraints.body_b[ci]
                    val nx = self.constraints.normal_x[ci]
                    val ny = self.constraints.normal_y[ci]
                    val nz = self.constraints.normal_z[ci]
                    val inv_mass_sum = self.bodies.inv_mass[a] + self.bodies.inv_mass[b]
                    if inv_mass_sum > 0.0:
                        val correction = (pen - slop) * baumgarte / inv_mass_sum
                        self.bodies.pos_x[a] = self.bodies.pos_x[a] - nx * correction * self.bodies.inv_mass[a]
                        self.bodies.pos_y[a] = self.bodies.pos_y[a] - ny * correction * self.bodies.inv_mass[a]
                        self.bodies.pos_z[a] = self.bodies.pos_z[a] - nz * correction * self.bodies.inv_mass[a]
                        self.bodies.pos_x[b] = self.bodies.pos_x[b] + nx * correction * self.bodies.inv_mass[b]
                        self.bodies.pos_y[b] = self.bodies.pos_y[b] + ny * correction * self.bodies.inv_mass[b]
                        self.bodies.pos_z[b] = self.bodies.pos_z[b] + nz * correction * self.bodies.inv_mass[b]
                ci = ci + 1
            iter = iter + 1

    me get_position(node_id: NodeId) -> Vec3:
        val idx = self.node_to_body[node_id.to_index()]
        self.bodies.get_position(idx)

    me get_velocity(node_id: NodeId) -> Vec3:
        val idx = self.node_to_body[node_id.to_index()]
        self.bodies.get_velocity(idx)

    me get_angular_velocity(node_id: NodeId) -> Vec3:
        val idx = self.node_to_body[node_id.to_index()]
        Vec3(x: self.bodies.ang_vel_x[idx], y: self.bodies.ang_vel_y[idx], z: self.bodies.ang_vel_z[idx])

    me apply_force(node_id: NodeId, fx: f64, fy: f64, fz: f64):
        val idx = self.node_to_body[node_id.to_index()]
        self.bodies.apply_force_at(idx, fx, fy, fz)

    me get_all_dynamic_transforms() -> [Transform3D]:
        var result: [Transform3D] = []
        var i = 0
        while i < self.bodies.body_count:
            if self.bodies.is_dynamic(i):
                result.push(Transform3D(
                    node_id: self.bodies.node_ids[i],
                    x: self.bodies.pos_x[i],
                    y: self.bodies.pos_y[i],
                    z: self.bodies.pos_z[i],
                    rot_w: self.bodies.rot_w[i],
                    rot_x: self.bodies.rot_x[i],
                    rot_y: self.bodies.rot_y[i],
                    rot_z: self.bodies.rot_z[i]
                ))
            i = i + 1
        result

    me body_count() -> i64:
        self.bodies.body_count

    me destroy():
        pass_dn

    me ensure_node_map(idx: i64):
        while self.node_to_body.len() <= idx:
            self.node_to_body.push(-1)
        if idx >= self.max_node_index:
            self.max_node_index = idx + 1

export PhysicsWorld3D, ShapeType3D, Collider3D, Transform3D
export use std.nogc_sync_mut.engine.physics.simple.joints3d_data.{Joint3D, JointStorage3D}
