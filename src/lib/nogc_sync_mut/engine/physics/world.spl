# Physics System — PhysicsWorld2D
#
# Main physics world that wraps Rapier2D FFI with a node-centric API.
# Bodies are identified by NodeId, so the scene graph and physics world
# stay synchronized. Uses a fixed-timestep accumulator for deterministic
# simulation, and diffs contact pairs each step to emit start/end signals.
#
# Usage:
#   var world = PhysicsWorld2D.create(default_physics_config())
#   world.add_dynamic_body(player_id, 0.0, 5.0)
#   world.add_box_collider(player_id, 0.5, 0.5)
#   world.step(dt)
#   val transforms = world.get_all_dynamic_transforms()

use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math2d.{Vec2}
use std.common.engine.signal.signal.{Signal}
use std.nogc_sync_mut.io.rapier2d_ffi.*
use std.nogc_sync_mut.engine.physics.types.*

# ============================================================================
# PhysicsWorld2D
# ============================================================================

class PhysicsWorld2D:
    world: PhysicsWorld
    config: PhysicsConfig
    bodies: [PhysicsBody2D]
    colliders: [PhysicsCollider2D]
    accumulator: f64
    on_contact_start: Signal
    on_contact_end: Signal
    prev_contact_keys: [text]

impl PhysicsWorld2D:

    # ------------------------------------------------------------------
    # Construction / Destruction
    # ------------------------------------------------------------------

    static fn create(config: PhysicsConfig) -> PhysicsWorld2D:
        val grav = Vector2(x: config.gravity.x, y: config.gravity.y)
        val pw = physics_create_world(grav)
        PhysicsWorld2D(
            world: pw,
            config: config,
            bodies: [],
            colliders: [],
            accumulator: 0.0,
            on_contact_start: Signal.create("on_contact_start"),
            on_contact_end: Signal.create("on_contact_end"),
            prev_contact_keys: []
        )

    me destroy():
        physics_destroy_world(self.world)

    # ------------------------------------------------------------------
    # Body Management
    # ------------------------------------------------------------------

    me add_dynamic_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vector2(x: x, y: y)
        val body = physics_create_dynamic_body(self.world, pos)
        if not body.is_valid:
            return false
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_handle: body.handle,
            body_type_code: 2,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me add_static_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vector2(x: x, y: y)
        val body = physics_create_static_body(self.world, pos)
        if not body.is_valid:
            return false
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_handle: body.handle,
            body_type_code: 0,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me add_kinematic_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vector2(x: x, y: y)
        val rot = Rotation2(angle: 0.0)
        val xform = Transform2(position: pos, rotation: rot)
        val body = physics_create_body(self.world, BodyType.Kinematic, xform)
        if not body.is_valid:
            return false
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_handle: body.handle,
            body_type_code: 1,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me remove_body(node_id: NodeId) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val ok = physics_destroy_body(rb)
        # Remove from list
        var new_bodies: [PhysicsBody2D] = []
        var i = 0
        while i < self.bodies.len():
            if i != idx:
                new_bodies.push(self.bodies[i])
            i = i + 1
        self.bodies = new_bodies
        # Also remove associated colliders
        var new_colliders: [PhysicsCollider2D] = []
        for c in self.colliders:
            if not c.node_id.eq(node_id):
                new_colliders.push(c)
        self.colliders = new_colliders
        ok

    # ------------------------------------------------------------------
    # Collider Management
    # ------------------------------------------------------------------

    me add_box_collider(node_id: NodeId, hx: f64, hy: f64) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val col = physics_create_box_collider(self.world, rb, hx, hy)
        if not col.is_valid:
            return false
        val pc = PhysicsCollider2D(
            node_id: node_id,
            collider_handle: col.handle,
            is_sensor: false
        )
        self.colliders.push(pc)
        true

    me add_circle_collider(node_id: NodeId, radius: f64) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val col = physics_create_circle_collider(self.world, rb, radius)
        if not col.is_valid:
            return false
        val pc = PhysicsCollider2D(
            node_id: node_id,
            collider_handle: col.handle,
            is_sensor: false
        )
        self.colliders.push(pc)
        true

    me set_sensor(node_id: NodeId, is_sensor: bool) -> bool:
        var found = false
        for c in self.colliders:
            if c.node_id.eq(node_id):
                val col = Collider(
                    handle: c.collider_handle,
                    world: self.world,
                    shape: ColliderShape.Box,
                    is_valid: true
                )
                physics_collider_set_sensor(col, is_sensor)
                found = true
        found

    # ------------------------------------------------------------------
    # Simulation Step — Fixed-Timestep Accumulator
    # ------------------------------------------------------------------

    me step(dt: f64):
        self.accumulator = self.accumulator + dt

        while self.accumulator >= self.config.fixed_timestep:
            physics_step(self.world, self.config.fixed_timestep)
            self.accumulator = self.accumulator - self.config.fixed_timestep
            self._process_contacts()

    # ------------------------------------------------------------------
    # Contact Diffing — emit start/end signals
    # ------------------------------------------------------------------

    me _process_contacts():
        val contact_list = physics_get_contacts(self.world)
        val count = physics_contacts_count(contact_list)

        var current_keys: [text] = []
        var current_events: [CollisionEvent] = []

        var i = 0
        while i < count:
            val contact = physics_contacts_get(contact_list, i)

            # Map collider handles back to node IDs
            val node_a_opt = self._find_node_by_collider(contact.collider1)
            val node_b_opt = self._find_node_by_collider(contact.collider2)

            if node_a_opt.to_index() >= 0 and node_b_opt.to_index() >= 0:
                # Build canonical key: smaller index first
                val a_idx = node_a_opt.to_index()
                val b_idx = node_b_opt.to_index()
                var key = ""
                if a_idx <= b_idx:
                    key = "{a_idx}_{b_idx}"
                else:
                    key = "{b_idx}_{a_idx}"

                current_keys.push(key)

                val evt = CollisionEvent(
                    node_a: node_a_opt,
                    node_b: node_b_opt,
                    normal: Vec2(x: contact.normal.x, y: contact.normal.y),
                    depth: contact.penetration,
                    is_sensor: false
                )
                current_events.push(evt)
            i = i + 1

        physics_destroy_contacts(contact_list)

        # Emit on_contact_start for new contacts
        for key in current_keys:
            if not self._key_in_list(key, self.prev_contact_keys):
                self.on_contact_start.emit(key)

        # Emit on_contact_end for removed contacts
        for key in self.prev_contact_keys:
            if not self._key_in_list(key, current_keys):
                self.on_contact_end.emit(key)

        self.prev_contact_keys = current_keys

    fn _key_in_list(key: text, list: [text]) -> bool:
        for item in list:
            if item == key:
                return true
        false

    # ------------------------------------------------------------------
    # Position / Velocity Queries
    # ------------------------------------------------------------------

    fn get_position(node_id: NodeId) -> Vec2:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return Vec2.zero()
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val xform = physics_body_get_position(rb)
        Vec2(x: xform.position.x, y: xform.position.y)

    fn get_rotation(node_id: NodeId) -> f64:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return 0.0
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val xform = physics_body_get_position(rb)
        xform.rotation.angle

    me set_position(node_id: NodeId, pos: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val xform = Transform2(
            position: Vector2(x: pos.x, y: pos.y),
            rotation: Rotation2(angle: 0.0)
        )
        physics_body_set_position(rb, xform)

    me apply_force(node_id: NodeId, force: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val fv = Vector2(x: force.x, y: force.y)
        physics_body_apply_force(rb, fv)

    me apply_impulse(node_id: NodeId, impulse: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val iv = Vector2(x: impulse.x, y: impulse.y)
        physics_body_apply_impulse(rb, iv)

    me set_velocity(node_id: NodeId, vel: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val lv = Vector2(x: vel.x, y: vel.y)
        physics_body_set_velocity(rb, lv, 0.0)

    fn get_velocity(node_id: NodeId) -> Vec2:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return Vec2.zero()
        val pb = self.bodies[idx]
        val rb = self._make_rigid_body(pb)
        val result = physics_body_get_velocity(rb)
        Vec2(x: result.0.x, y: result.0.y)

    # ------------------------------------------------------------------
    # Bulk Query — for syncing physics back to scene graph
    # ------------------------------------------------------------------

    fn get_all_dynamic_transforms() -> [(NodeId, Vec2, f64)]:
        var results: [(NodeId, Vec2, f64)] = []
        for pb in self.bodies:
            if pb.body_type_code == 2:
                val rb = self._make_rigid_body(pb)
                val xform = physics_body_get_position(rb)
                val pos = Vec2(x: xform.position.x, y: xform.position.y)
                val rot = xform.rotation.angle
                results.push((pb.node_id, pos, rot))
        results

    # ------------------------------------------------------------------
    # Internal Helpers
    # ------------------------------------------------------------------

    fn _find_body_index(node_id: NodeId) -> i64:
        var i = 0
        while i < self.bodies.len():
            if self.bodies[i].node_id.eq(node_id):
                return i
            i = i + 1
        -1

    fn _find_node_by_collider(collider_handle: i64) -> NodeId:
        for c in self.colliders:
            if c.collider_handle == collider_handle:
                return c.node_id
        NodeId.invalid()

    fn _make_rigid_body(pb: PhysicsBody2D) -> RigidBody:
        val bt = if pb.body_type_code == 0:
            BodyType.Static
        elif pb.body_type_code == 1:
            BodyType.Kinematic
        else:
            BodyType.Dynamic
        RigidBody(
            handle: pb.body_handle,
            world: self.world,
            body_type: bt,
            is_valid: true
        )
