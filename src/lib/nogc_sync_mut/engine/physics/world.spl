# Physics System — PhysicsWorld2D
#
# Main physics world with a pure Simple 2D physics engine.
# Bodies are identified by NodeId, so the scene graph and physics world
# stay synchronized. Uses a fixed-timestep accumulator for deterministic
# simulation, and diffs contact pairs each step to emit start/end signals.
#
# No external FFI dependencies — all collision detection, contact resolution,
# and integration are implemented in pure Simple.
#
# Usage:
#   var world = PhysicsWorld2D.create(default_physics_config())
#   world.add_dynamic_body(player_id, 0.0, 5.0)
#   world.add_box_collider(player_id, 0.5, 0.5)
#   world.step(dt)
#   val transforms = world.get_all_dynamic_transforms()

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}
use std.common.engine.signal.signal.{Signal}
use std.common.engine.units.{Seconds, Distance}
use std.nogc_sync_mut.engine.physics.types.{CollisionEvent, PhysicsBody2D, PhysicsCollider2D, PhysicsConfig}
use std.nogc_sync_mut.engine.physics.body2d.{InternalBody2D}
use std.nogc_sync_mut.engine.physics.shapes2d.{ColliderShape2D}
use std.nogc_sync_mut.engine.physics.collision2d.{Contact2D, collide_circle_circle, collide_aabb_aabb, collide_circle_aabb, collide_box_box}
use std.nogc_sync_mut.engine.physics.contact2d.{resolve_contact}

# ============================================================================
# Joint2D — Internal joint representation
# ============================================================================

class Joint2D:
    joint_type: i64        # 0=revolute, 1=fixed, 2=spring
    node_a: NodeId
    node_b: NodeId
    anchor_a: Vec2         # Local anchor on body A
    anchor_b: Vec2         # Local anchor on body B
    rest_length: f64       # For spring joints
    stiffness: f64         # For spring joints
    damping: f64           # For spring joints
    offset: Vec2           # Initial offset for fixed joints

# ============================================================================
# JointStorage — manages all joints in the world
# ============================================================================

class JointStorage:
    joints: [Joint2D]
    next_id: i64

impl JointStorage:
    static fn create() -> JointStorage:
        JointStorage(joints: [], next_id: 0)

    me add(joint: Joint2D) -> i64:
        val id = self.next_id
        self.joints.push(joint)
        self.next_id = self.next_id + 1
        id

    me remove(idx: i64) -> bool:
        if idx < 0 or idx >= self.joints.len():
            return false
        var new_joints: [Joint2D] = []
        var i = 0
        while i < self.joints.len():
            if i != idx:
                new_joints.push(self.joints[i])
            i = i + 1
        self.joints = new_joints
        true

# ============================================================================
# PhysicsWorld2D
# ============================================================================

class PhysicsWorld2D:
    config: PhysicsConfig
    bodies: [PhysicsBody2D]
    colliders: [PhysicsCollider2D]
    internal_bodies: [InternalBody2D]
    shapes: [ColliderShape2D]
    accumulator: f64
    on_contact_start: Signal
    on_contact_end: Signal
    prev_contact_keys: [text]
    restitution: f64
    friction: f64
    joint_storage: JointStorage

impl PhysicsWorld2D:

    # ------------------------------------------------------------------
    # Construction / Destruction
    # ------------------------------------------------------------------

    static fn create(config: PhysicsConfig) -> PhysicsWorld2D:
        PhysicsWorld2D(
            config: config,
            bodies: [],
            colliders: [],
            internal_bodies: [],
            shapes: [],
            accumulator: 0.0,
            on_contact_start: Signal(name: "on_contact_start", connections: [], next_id: 0, enabled: true),
            on_contact_end: Signal(name: "on_contact_end", connections: [], next_id: 0, enabled: true),
            prev_contact_keys: [],
            restitution: 0.3,
            friction: 0.4,
            joint_storage: JointStorage.create()
        )

    me destroy():
        self.bodies = []
        self.colliders = []
        self.internal_bodies = []
        self.shapes = []

    # ------------------------------------------------------------------
    # Body Management
    # ------------------------------------------------------------------

    me add_dynamic_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vec2(x: x, y: y)
        val ib = InternalBody2D.create_dynamic(pos, 1.0)
        val idx = self.internal_bodies.len()
        self.internal_bodies.push(ib)
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_index: idx,
            body_type_code: 2,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me add_static_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vec2(x: x, y: y)
        val ib = InternalBody2D.create_static(pos)
        val idx = self.internal_bodies.len()
        self.internal_bodies.push(ib)
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_index: idx,
            body_type_code: 0,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me add_kinematic_body(node_id: NodeId, x: f64, y: f64) -> bool:
        val pos = Vec2(x: x, y: y)
        val ib = InternalBody2D.create_kinematic(pos)
        val idx = self.internal_bodies.len()
        self.internal_bodies.push(ib)
        val pb = PhysicsBody2D(
            node_id: node_id,
            body_index: idx,
            body_type_code: 1,
            gravity_scale: 1.0
        )
        self.bodies.push(pb)
        true

    me remove_body(node_id: NodeId) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        # Remove body from lists (rebuild without the target)
        var new_bodies: [PhysicsBody2D] = []
        var i = 0
        while i < self.bodies.len():
            if i != idx:
                new_bodies.push(self.bodies[i])
            i = i + 1
        self.bodies = new_bodies
        # Also remove associated colliders
        var new_colliders: [PhysicsCollider2D] = []
        for c in self.colliders:
            if not c.node_id.eq(node_id):
                new_colliders.push(c)
        self.colliders = new_colliders
        true

    # ------------------------------------------------------------------
    # Collider Management
    # ------------------------------------------------------------------

    me add_box_collider(node_id: NodeId, hx: f64, hy: f64) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val shape = ColliderShape2D.box(hx, hy)
        val shape_idx = self.shapes.len()
        self.shapes.push(shape)
        val pc = PhysicsCollider2D(
            node_id: node_id,
            collider_index: shape_idx,
            shape_code: 1,
            is_sensor: false
        )
        self.colliders.push(pc)
        true

    me add_circle_collider(node_id: NodeId, radius: f64) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val shape = ColliderShape2D.circle(radius)
        val shape_idx = self.shapes.len()
        self.shapes.push(shape)
        val pc = PhysicsCollider2D(
            node_id: node_id,
            collider_index: shape_idx,
            shape_code: 0,
            is_sensor: false
        )
        self.colliders.push(pc)
        true

    me set_sensor(node_id: NodeId, is_sensor: bool) -> bool:
        var found = false
        var updated_colliders: [PhysicsCollider2D] = []
        for c in self.colliders:
            var next = c
            if c.node_id.eq(node_id):
                next = PhysicsCollider2D(
                    node_id: c.node_id,
                    collider_index: c.collider_index,
                    shape_code: c.shape_code,
                    is_sensor: is_sensor
                )
                found = true
            updated_colliders.push(next)
        self.colliders = updated_colliders
        found

    # ------------------------------------------------------------------
    # Simulation Step — Fixed-Timestep Accumulator
    # ------------------------------------------------------------------

    me step(dt: Seconds):
        self.accumulator = self.accumulator + dt.value

        while self.accumulator >= self.config.fixed_timestep.value:
            self._fixed_step(self.config.fixed_timestep.value)
            self.accumulator = self.accumulator - self.config.fixed_timestep.value

    me _fixed_step(dt: f64):
        # 1. Apply gravity to dynamic bodies
        var i = 0
        while i < self.bodies.len():
            val pb = self.bodies[i]
            if pb.body_type_code == 2:
                val ib = self.internal_bodies[pb.body_index]
                val gx = self.config.gravity.x * ib.gravity_scale * ib.mass
                val gy = self.config.gravity.y * ib.gravity_scale * ib.mass
                val gravity_force = Vec2(x: gx, y: gy)
                ib.apply_force(gravity_force)
            i = i + 1

        # 2. Integrate all bodies
        var j = 0
        while j < self.internal_bodies.len():
            self.internal_bodies[j].integrate(dt)
            j = j + 1

        # 3. Narrow-phase collision detection and resolution
        self._detect_and_resolve_collisions()

        # 4. Contact diffing for signals
        self._process_contacts()

    # ------------------------------------------------------------------
    # Collision Detection and Resolution
    # ------------------------------------------------------------------

    me _detect_and_resolve_collisions():
        val n = self.colliders.len()
        var i = 0
        while i < n:
            var j = i + 1
            while j < n:
                val col_a = self.colliders[i]
                val col_b = self.colliders[j]

                # Skip sensor-only pairs (sensors detect but do not resolve)
                val both_sensors = col_a.is_sensor and col_b.is_sensor

                # Find bodies for each collider
                val body_idx_a = self._find_body_index(col_a.node_id)
                val body_idx_b = self._find_body_index(col_b.node_id)

                if body_idx_a >= 0 and body_idx_b >= 0:
                    val pb_a = self.bodies[body_idx_a]
                    val pb_b = self.bodies[body_idx_b]
                    val ib_a = self.internal_bodies[pb_a.body_index]
                    val ib_b = self.internal_bodies[pb_b.body_index]
                    val shape_a = self.shapes[col_a.collider_index]
                    val shape_b = self.shapes[col_b.collider_index]

                    val contact = self._narrow_phase(ib_a, shape_a, ib_b, shape_b)
                    if val c = contact:
                        if not col_a.is_sensor and not col_b.is_sensor:
                            resolve_contact(ib_a, ib_b, c, self.restitution, self.friction)
                j = j + 1
            i = i + 1

    fn _narrow_phase(body_a: InternalBody2D, shape_a: ColliderShape2D, body_b: InternalBody2D, shape_b: ColliderShape2D) -> Option<Contact2D>:
        if shape_a.is_circle() and shape_b.is_circle():
            return collide_circle_circle(
                body_a.position, shape_a.circle.radius,
                body_b.position, shape_b.circle.radius
            )

        if shape_a.is_box() and shape_b.is_box():
            # Use OBB if either has rotation, otherwise AABB
            if body_a.rotation == 0.0 and body_b.rotation == 0.0:
                return collide_aabb_aabb(
                    body_a.position, shape_a.box_shape.half_width, shape_a.box_shape.half_height,
                    body_b.position, shape_b.box_shape.half_width, shape_b.box_shape.half_height
                )
            return collide_box_box(
                body_a.position, shape_a.box_shape.half_width, shape_a.box_shape.half_height, body_a.rotation,
                body_b.position, shape_b.box_shape.half_width, shape_b.box_shape.half_height, body_b.rotation
            )

        if shape_a.is_circle() and shape_b.is_box():
            return collide_circle_aabb(
                body_a.position, shape_a.circle.radius,
                body_b.position, shape_b.box_shape.half_width, shape_b.box_shape.half_height
            )

        if shape_a.is_box() and shape_b.is_circle():
            # Swap and flip normal
            val result = collide_circle_aabb(
                body_b.position, shape_b.circle.radius,
                body_a.position, shape_a.box_shape.half_width, shape_a.box_shape.half_height
            )
            if val c = result:
                return Contact2D(
                    point: c.point,
                    normal: c.normal.mul_scalar(-1.0),
                    penetration: c.penetration
                )
            return nil

        nil

    # ------------------------------------------------------------------
    # Contact Diffing — emit start/end signals
    # ------------------------------------------------------------------

    me _process_contacts():
        var current_keys: [text] = []

        val n = self.colliders.len()
        var i = 0
        while i < n:
            var j = i + 1
            while j < n:
                val col_a = self.colliders[i]
                val col_b = self.colliders[j]
                val body_idx_a = self._find_body_index(col_a.node_id)
                val body_idx_b = self._find_body_index(col_b.node_id)

                if body_idx_a >= 0 and body_idx_b >= 0:
                    val pb_a = self.bodies[body_idx_a]
                    val pb_b = self.bodies[body_idx_b]
                    val ib_a = self.internal_bodies[pb_a.body_index]
                    val ib_b = self.internal_bodies[pb_b.body_index]
                    val shape_a = self.shapes[col_a.collider_index]
                    val shape_b = self.shapes[col_b.collider_index]

                    val contact = self._narrow_phase(ib_a, shape_a, ib_b, shape_b)
                    if val c = contact:
                        val a_idx = col_a.node_id.to_index()
                        val b_idx = col_b.node_id.to_index()
                        var key = ""
                        if a_idx <= b_idx:
                            key = "{a_idx}_{b_idx}"
                        else:
                            key = "{b_idx}_{a_idx}"
                        current_keys.push(key)
                j = j + 1
            i = i + 1

        # Emit on_contact_start for new contacts
        for key in current_keys:
            if not self._key_in_list(key, self.prev_contact_keys):
                self.on_contact_start.emit(key)

        # Emit on_contact_end for removed contacts
        for key in self.prev_contact_keys:
            if not self._key_in_list(key, current_keys):
                self.on_contact_end.emit(key)

        self.prev_contact_keys = current_keys

    fn _key_in_list(key: text, list: [text]) -> bool:
        for item in list:
            if item == key:
                return true
        false

    # ------------------------------------------------------------------
    # Position / Velocity Queries
    # ------------------------------------------------------------------

    fn get_position(node_id: NodeId) -> Vec2:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return Vec2.zero()
        val pb = self.bodies[idx]
        val ib = self.internal_bodies[pb.body_index]
        ib.position

    fn get_rotation(node_id: NodeId) -> f64:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return 0.0
        val pb = self.bodies[idx]
        val ib = self.internal_bodies[pb.body_index]
        ib.rotation

    me set_position(node_id: NodeId, pos: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        self.internal_bodies[pb.body_index].position = pos
        true

    me apply_force(node_id: NodeId, force: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        self.internal_bodies[pb.body_index].apply_force(force)
        true

    me apply_impulse(node_id: NodeId, impulse: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        self.internal_bodies[pb.body_index].apply_impulse(impulse)
        true

    me set_velocity(node_id: NodeId, vel: Vec2) -> bool:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return false
        val pb = self.bodies[idx]
        self.internal_bodies[pb.body_index].velocity = vel
        true

    fn get_velocity(node_id: NodeId) -> Vec2:
        val idx = self._find_body_index(node_id)
        if idx < 0:
            return Vec2.zero()
        val pb = self.bodies[idx]
        val ib = self.internal_bodies[pb.body_index]
        ib.velocity

    # ------------------------------------------------------------------
    # Bulk Query — for syncing physics back to scene graph
    # ------------------------------------------------------------------

    fn get_all_dynamic_transforms() -> [(NodeId, Vec2, f64)]:
        var results: [(NodeId, Vec2, f64)] = []
        for pb in self.bodies:
            if pb.body_type_code == 2:
                val ib = self.internal_bodies[pb.body_index]
                results.push((pb.node_id, ib.position, ib.rotation))
        results

    # ------------------------------------------------------------------
    # Internal Helpers
    # ------------------------------------------------------------------

    fn _find_body_index(node_id: NodeId) -> i64:
        var i = 0
        while i < self.bodies.len():
            if self.bodies[i].node_id.eq(node_id):
                return i
            i = i + 1
        -1

    fn _find_node_by_collider_index(collider_index: i64) -> NodeId:
        for c in self.colliders:
            if c.collider_index == collider_index:
                return c.node_id
        NodeId.invalid()
