# Physics System — 2D Collider Shapes
#
# Shape definitions for the pure Simple 2D physics engine.
# Each shape stores its own geometry; ColliderShape2D wraps them
# with a type code for dispatch in narrow-phase collision detection.
#
# Usage:
#   val circle = ColliderShape2D.circle(0.5)
#   val box = ColliderShape2D.box(1.0, 0.5)

# ============================================================================
# Circle2D
# ============================================================================

class Circle2D:
    radius: f64

    static fn create(radius: f64) -> Circle2D:
        Circle2D(radius: radius)

# ============================================================================
# Box2D
# ============================================================================

class Box2D:
    half_width: f64
    half_height: f64

    static fn create(hw: f64, hh: f64) -> Box2D:
        Box2D(half_width: hw, half_height: hh)

# ============================================================================
# ColliderShape2D — tagged union via shape_type code
#   0 = circle, 1 = box
# ============================================================================

class ColliderShape2D:
    shape_type: i64
    circle: Circle2D
    box_shape: Box2D

    static fn circle(radius: f64) -> ColliderShape2D:
        ColliderShape2D(
            shape_type: 0,
            circle: Circle2D.create(radius),
            box_shape: Box2D.create(0.0, 0.0)
        )

    static fn box(hw: f64, hh: f64) -> ColliderShape2D:
        ColliderShape2D(
            shape_type: 1,
            circle: Circle2D.create(0.0),
            box_shape: Box2D.create(hw, hh)
        )

    fn is_circle() -> bool:
        self.shape_type == 0

    fn is_box() -> bool:
        self.shape_type == 1
