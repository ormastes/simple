# UI Canvas — Game-oriented screen-space UI system
#
# Provides anchoring, layout computation, and element management
# for screen-space and world-space UI overlays.
#
# Usage:
#   var canvas = UICanvas.new(1920.0, 1080.0, "screen")
#   val label = UIElement.new("title", "label", 200.0, 40.0)
#   canvas.add_element(label)

# ============================================================================
# Anchor
# ============================================================================

struct Anchor:
    min_x: f64
    min_y: f64
    max_x: f64
    max_y: f64

impl Anchor:
    static fn top_left() -> Anchor:
        Anchor(min_x: 0.0, min_y: 0.0, max_x: 0.0, max_y: 0.0)

    static fn center() -> Anchor:
        Anchor(min_x: 0.5, min_y: 0.5, max_x: 0.5, max_y: 0.5)

    static fn stretch() -> Anchor:
        Anchor(min_x: 0.0, min_y: 0.0, max_x: 1.0, max_y: 1.0)

    static fn top_right() -> Anchor:
        Anchor(min_x: 1.0, min_y: 0.0, max_x: 1.0, max_y: 0.0)

# ============================================================================
# UIRect
# ============================================================================

struct UIRect:
    x: f64
    y: f64
    width: f64
    height: f64

impl UIRect:
    fn contains_point(px: f64, py: f64) -> bool:
        if px < self.x:
            return false
        if py < self.y:
            return false
        if px > self.x + self.width:
            return false
        if py > self.y + self.height:
            return false
        true

    fn center_x() -> f64:
        self.x + self.width / 2.0

    fn center_y() -> f64:
        self.y + self.height / 2.0

# ============================================================================
# UIElement
# ============================================================================

struct UIElement:
    name: text
    element_type: text
    anchor: Anchor
    offset_x: f64
    offset_y: f64
    width: f64
    height: f64
    visible: bool
    children: [i32]
    parent_index: i32
    content: text

impl UIElement:
    static fn new(name: text, element_type: text, width: f64, height: f64) -> UIElement:
        UIElement(
            name: name,
            element_type: element_type,
            anchor: Anchor.top_left(),
            offset_x: 0.0,
            offset_y: 0.0,
            width: width,
            height: height,
            visible: true,
            children: [],
            parent_index: -1,
            content: ""
        )

# ============================================================================
# UICanvas
# ============================================================================

class UICanvas:
    elements: [UIElement]
    screen_width: f64
    screen_height: f64
    render_mode: text

impl UICanvas:
    static fn new(screen_w: f64, screen_h: f64, render_mode: text) -> UICanvas:
        UICanvas(elements: [], screen_width: screen_w, screen_height: screen_h, render_mode: render_mode)

    me add_element(element: UIElement) -> i32:
        self.elements.push(element)
        var idx: i32 = self.elements.len() - 1
        idx

    me set_parent(child_index: i32, parent_index: i32) -> bool:
        var ci: i64 = child_index
        var pi: i64 = parent_index
        if ci < 0:
            return false
        if ci >= self.elements.len():
            return false
        if pi < 0:
            return false
        if pi >= self.elements.len():
            return false
        if child_index == parent_index:
            return false
        val child = self.elements[ci]
        self.elements[ci] = UIElement(
            name: child.name,
            element_type: child.element_type,
            anchor: child.anchor,
            offset_x: child.offset_x,
            offset_y: child.offset_y,
            width: child.width,
            height: child.height,
            visible: child.visible,
            children: child.children,
            parent_index: parent_index,
            content: child.content
        )
        val parent = self.elements[pi]
        var new_children = parent.children
        new_children.push(child_index)
        self.elements[pi] = UIElement(
            name: parent.name,
            element_type: parent.element_type,
            anchor: parent.anchor,
            offset_x: parent.offset_x,
            offset_y: parent.offset_y,
            width: parent.width,
            height: parent.height,
            visible: parent.visible,
            children: new_children,
            parent_index: parent.parent_index,
            content: parent.content
        )
        true

    me set_visible(index: i32, visible: bool) -> bool:
        var idx: i64 = index
        if idx < 0:
            return false
        if idx >= self.elements.len():
            return false
        val elem = self.elements[idx]
        self.elements[idx] = UIElement(
            name: elem.name,
            element_type: elem.element_type,
            anchor: elem.anchor,
            offset_x: elem.offset_x,
            offset_y: elem.offset_y,
            width: elem.width,
            height: elem.height,
            visible: visible,
            children: elem.children,
            parent_index: elem.parent_index,
            content: elem.content
        )
        true

    me set_content(index: i32, content: text) -> bool:
        var idx: i64 = index
        if idx < 0:
            return false
        if idx >= self.elements.len():
            return false
        val elem = self.elements[idx]
        self.elements[idx] = UIElement(
            name: elem.name,
            element_type: elem.element_type,
            anchor: elem.anchor,
            offset_x: elem.offset_x,
            offset_y: elem.offset_y,
            width: elem.width,
            height: elem.height,
            visible: elem.visible,
            children: elem.children,
            parent_index: elem.parent_index,
            content: content
        )
        true

    fn get_element(index: i32) -> UIElement?:
        var idx: i64 = index
        if idx < 0:
            return None
        if idx >= self.elements.len():
            return None
        Some(self.elements[idx])

    fn find_by_name(name: text) -> i32:
        var i = 0
        while i < self.elements.len():
            if self.elements[i].name == name:
                var result: i32 = i
                return result
            i = i + 1
        -1

    fn compute_rect(index: i32) -> UIRect:
        var idx: i64 = index
        if idx < 0:
            return UIRect(x: 0.0, y: 0.0, width: 0.0, height: 0.0)
        if idx >= self.elements.len():
            return UIRect(x: 0.0, y: 0.0, width: 0.0, height: 0.0)
        val elem = self.elements[idx]
        val anchor = elem.anchor
        # Position: anchor point on screen + offset
        val ax = anchor.min_x * self.screen_width + elem.offset_x
        val ay = anchor.min_y * self.screen_height + elem.offset_y
        # Size: if anchor is a point (min == max), use element size;
        # otherwise stretch across the anchor range
        val span_x = anchor.max_x - anchor.min_x
        val span_y = anchor.max_y - anchor.min_y
        var w = elem.width
        var h = elem.height
        if span_x > 0.0:
            w = span_x * self.screen_width
        if span_y > 0.0:
            h = span_y * self.screen_height
        UIRect(x: ax, y: ay, width: w, height: h)

    fn element_count() -> i32:
        var count: i32 = self.elements.len()
        count

    fn get_visible_elements() -> [i32]:
        var result: [i32] = []
        var i = 0
        while i < self.elements.len():
            if self.elements[i].visible:
                var idx: i32 = i
                result.push(idx)
            i = i + 1
        result

    me clear():
        self.elements = []
