# Skeletal Animation — Skeleton and Bone Hierarchy
#
# Bone transform (translation, rotation quaternion, scale),
# bone hierarchy with parent indices, and skeleton management.

# --------------------------------------------------------------------------
# BoneTransform — per-bone TRS data
# --------------------------------------------------------------------------

struct BoneTransform:
    tx: f64
    ty: f64
    tz: f64
    rx: f64
    ry: f64
    rz: f64
    rw: f64
    sx: f64
    sy: f64
    sz: f64

impl BoneTransform:
    static fn identity() -> BoneTransform:
        BoneTransform(
            tx: 0.0, ty: 0.0, tz: 0.0,
            rx: 0.0, ry: 0.0, rz: 0.0, rw: 1.0,
            sx: 1.0, sy: 1.0, sz: 1.0
        )

    fn lerp_to(other: BoneTransform, t: f64) -> BoneTransform:
        val one_minus_t = 1.0 - t
        BoneTransform(
            tx: self.tx * one_minus_t + other.tx * t,
            ty: self.ty * one_minus_t + other.ty * t,
            tz: self.tz * one_minus_t + other.tz * t,
            rx: self.rx * one_minus_t + other.rx * t,
            ry: self.ry * one_minus_t + other.ry * t,
            rz: self.rz * one_minus_t + other.rz * t,
            rw: self.rw * one_minus_t + other.rw * t,
            sx: self.sx * one_minus_t + other.sx * t,
            sy: self.sy * one_minus_t + other.sy * t,
            sz: self.sz * one_minus_t + other.sz * t
        )

# --------------------------------------------------------------------------
# Bone — single bone in a skeleton
# --------------------------------------------------------------------------

struct Bone:
    name: text
    index: i32
    parent_index: i32
    bind_pose: BoneTransform
    local_transform: BoneTransform

# --------------------------------------------------------------------------
# Skeleton — bone hierarchy
# --------------------------------------------------------------------------

class Skeleton:
    bones: [Bone]
    name: text

impl Skeleton:
    static fn new(name: text) -> Skeleton:
        Skeleton(
            bones: [],
            name: name
        )

    me add_bone(name: text, parent_index: i32, bind_pose: BoneTransform) -> i32:
        val idx: i32 = self.bones.len()
        val bone = Bone(
            name: name,
            index: idx,
            parent_index: parent_index,
            bind_pose: bind_pose,
            local_transform: BoneTransform.identity()
        )
        self.bones.push(bone)
        idx

    fn get_bone(index: i32) -> Bone?:
        if index < 0:
            return nil
        if index >= self.bones.len():
            return nil
        self.bones[index]

    fn find_bone(bone_name: text) -> i32:
        var i = 0
        while i < self.bones.len():
            val b = self.bones[i]
            if b.name == bone_name:
                return i
            i = i + 1
        -1

    fn bone_count() -> i32:
        self.bones.len()

    fn get_children(parent_index: i32) -> [i32]:
        var result: [i32] = []
        var i = 0
        while i < self.bones.len():
            val b = self.bones[i]
            if b.parent_index == parent_index:
                result.push(i)
            i = i + 1
        result

    me set_local_transform(index: i32, transform: BoneTransform) -> bool:
        if index < 0:
            return false
        if index >= self.bones.len():
            return false
        val old = self.bones[index]
        self.bones[index] = Bone(
            name: old.name,
            index: old.index,
            parent_index: old.parent_index,
            bind_pose: old.bind_pose,
            local_transform: transform
        )
        true
