# Generational Index Arena — Handle-Based Resource Access
#
# Provides a generational arena for safe handle-based resource management.
# Handles are (index, generation) tuples. When a slot is removed and reused,
# its generation is bumped, so stale handles return nil from get().
#
# This prevents use-after-free bugs without garbage collection.

# ============================================================================
# Handle Entry
# ============================================================================

struct HandleEntry<T>:
    """A single slot in the arena.

    When value is nil, the slot is free and available for reuse.
    Generation is bumped on each reuse to invalidate stale handles.
    """
    value: T?
    generation: i64
    ref_count: i64

# ============================================================================
# Handle Arena
# ============================================================================

class HandleArena<T>:
    """Generational index arena for handle-based resource access.

    Stores values in a flat array with generational indices.
    Removed slots are recycled via a free list.
    Old handles are automatically invalidated by generation mismatch.

    Example:
        var arena = HandleArena.new()
        val handle = arena.insert(my_texture)
        val idx = handle.0
        val generation = handle.1
        val tex = arena.get(idx, generation)    # Returns my_texture
        arena.remove(idx, generation)
        val stale = arena.get(idx, generation)  # Returns nil
    """
    entries: [HandleEntry<T>]
    free_indices: [i64]
    count: i64

impl HandleArena<T>:
    static fn new() -> HandleArena<T>:
        """Create an empty arena."""
        HandleArena(
            entries: [],
            free_indices: [],
            count: 0
        )

    me insert(value: T) -> (i64, i64):
        """Insert a value and return its (index, generation) handle.

        Reuses free slots with bumped generation when available.
        Appends a new entry when no free slots exist.

        Args:
            value: The value to store

        Returns:
            Tuple of (index, generation) identifying this value
        """
        if self.free_indices.len() > 0:
            # Reuse a free slot
            val idx = self.free_indices[self.free_indices.len() - 1]
            self.free_indices.pop()
            var entry = self.entries[idx]
            val new_gen = entry.generation + 1
            self.entries[idx] = HandleEntry(
                value: value,
                generation: new_gen,
                ref_count: 1
            )
            self.count = self.count + 1
            return (idx, new_gen)

        # No free slot — append new entry
        val idx = self.entries.len()
        val gen_val = 1
        self.entries.push(HandleEntry(
            value: value,
            generation: gen_val,
            ref_count: 1
        ))
        self.count = self.count + 1
        (idx, gen_val)

    fn get(index: i64, generation: i64) -> T?:
        """Look up a value by its handle.

        Returns nil if the index is out of range, the slot is free,
        or the generation does not match (stale handle).

        Args:
            index: Slot index from insert()
            generation: Generation from insert()

        Returns:
            The stored value, or nil if the handle is invalid
        """
        if index < 0 or index >= self.entries.len():
            return nil
        val entry = self.entries[index]
        if entry.generation != generation:
            return nil
        entry.value

    fn contains(index: i64, generation: i64) -> bool:
        """Check whether a handle is still valid.

        Args:
            index: Slot index
            generation: Generation

        Returns:
            true if the handle points to a live entry
        """
        if index < 0 or index >= self.entries.len():
            return false
        val entry = self.entries[index]
        if entry.generation != generation:
            return false
        if val Some(_) = entry.value:
            return true
        false

    me remove(index: i64, generation: i64) -> bool:
        """Remove a value by its handle.

        Sets the slot value to nil and adds the index to the free list.
        Returns false if the handle was already invalid.

        Args:
            index: Slot index
            generation: Generation

        Returns:
            true if the entry was removed, false if the handle was invalid
        """
        if index < 0 or index >= self.entries.len():
            return false
        val entry = self.entries[index]
        if entry.generation != generation:
            return false
        if val Some(_) = entry.value:
            self.entries[index] = HandleEntry(
                value: nil,
                generation: entry.generation,
                ref_count: 0
            )
            self.free_indices.push(index)
            self.count = self.count - 1
            return true
        false

    fn len() -> i64:
        """Number of live entries in the arena."""
        self.count

    fn is_empty() -> bool:
        """Check whether the arena has no live entries."""
        self.count == 0

    me clear():
        """Remove all entries and reset the free list."""
        self.entries = []
        self.free_indices = []
        self.count = 0
