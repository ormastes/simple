# Resource Manager — Unified resource ownership for the 2D game engine
#
# Owns TextureStore and AudioClip cache. Provides a single point of access
# for loading, retrieving, and removing game resources.
#
# Usage:
#   var rm = ResourceManager.create("assets")
#   val tex_id = rm.add_texture(my_texture)
#   val tex = rm.get_texture(tex_id)
#   rm.cache_audio_clip("sfx/hit.wav", clip)
#   val clip = rm.get_audio_clip("sfx/hit.wav")

use std.common.engine.ids.{TextureId}
use std.nogc_sync_mut.engine.sprite.texture.{Texture, TextureStore}
use std.nogc_sync_mut.engine.audio.types.{AudioClip}

# ============================================================================
# ResourceManager
# ============================================================================

class ResourceManager:
    """Unified resource manager that owns texture and audio clip storage.

    Delegates texture operations to TextureStore and maintains a
    path-keyed cache for audio clips. The base_path field provides
    a root directory hint for asset loading.
    """
    textures: TextureStore
    audio_clips: Dict<text, AudioClip>
    base_path: text

impl ResourceManager:
    static fn create(base_path: text) -> ResourceManager:
        """Create a resource manager with the given asset base path.

        Args:
            base_path: Root directory for resolving asset paths

        Returns:
            A new ResourceManager with empty stores
        """
        var audio_clips: Dict<text, AudioClip> = {}
        ResourceManager(
            textures: TextureStore.new(),
            audio_clips: audio_clips,
            base_path: base_path
        )

    # ========================================================================
    # Texture Operations
    # ========================================================================

    me add_texture(texture: Texture) -> TextureId:
        """Store a texture and return its handle.

        Delegates to TextureStore.add().

        Args:
            texture: The CPU texture to store

        Returns:
            A TextureId handle for later retrieval
        """
        self.textures.add(texture)

    fn get_texture(id: TextureId) -> Texture?:
        """Look up a texture by handle.

        Returns nil if the handle is invalid or stale.

        Args:
            id: TextureId from a previous add_texture call

        Returns:
            The texture, or nil if not found
        """
        self.textures.get(id)

    me remove_texture(id: TextureId) -> bool:
        """Remove a texture by handle.

        Returns false if the handle was already invalid.

        Args:
            id: TextureId to remove

        Returns:
            true if the texture was removed
        """
        self.textures.remove(id)

    # ========================================================================
    # Audio Clip Cache
    # ========================================================================

    me cache_audio_clip(path: text, clip: AudioClip):
        """Cache an audio clip by its file path.

        Overwrites any existing entry for the same path.

        Args:
            path: File path key for the clip
            clip: The loaded AudioClip to cache
        """
        self.audio_clips[path] = clip

    fn get_audio_clip(path: text) -> AudioClip?:
        """Retrieve a cached audio clip by path.

        Args:
            path: File path used when caching

        Returns:
            The cached AudioClip, or nil if not found
        """
        if val Some(clip) = self.audio_clips.get(path):
            return clip
        nil

    # ========================================================================
    # Queries
    # ========================================================================

    fn texture_count() -> i64:
        """Return the number of live textures in the store."""
        self.textures.texture_count()

    fn audio_clip_count() -> i64:
        """Return the number of cached audio clips."""
        self.audio_clips.len()
