# Resource Types — State and Classification
#
# Enums for tracking resource lifecycle state and categorizing
# resource types within the engine.

# ============================================================================
# Resource State
# ============================================================================

enum ResourceState:
    """Lifecycle state of a managed resource."""
    Unloaded
    Loading
    Loaded
    Failed

impl ResourceState:
    fn to_text() -> text:
        """Convert state to human-readable text."""
        match self:
            case Unloaded: "Unloaded"
            case Loading: "Loading"
            case Loaded: "Loaded"
            case Failed: "Failed"

    fn is_loaded() -> bool:
        """Check whether the resource is fully loaded."""
        match self:
            case Loaded: true
            case _: false

    fn is_failed() -> bool:
        """Check whether the resource failed to load."""
        match self:
            case Failed: true
            case _: false

# ============================================================================
# Resource Type
# ============================================================================

enum ResourceType:
    """Classification of engine resource kinds."""
    Texture
    SpriteSheet
    Atlas
    AudioClip
    Scene
    TileSet
    Font

impl ResourceType:
    fn to_text() -> text:
        """Convert resource type to human-readable text."""
        match self:
            case Texture: "Texture"
            case SpriteSheet: "SpriteSheet"
            case Atlas: "Atlas"
            case AudioClip: "AudioClip"
            case Scene: "Scene"
            case TileSet: "TileSet"
            case Font: "Font"
