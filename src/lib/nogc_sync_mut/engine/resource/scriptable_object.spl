# Scriptable Object — typed data-asset wrapper
#
# A named, typed container for key-value fields, plus a store
# for managing collections of scriptable objects by name or type.

# ============================================================================
# ScriptableField — single named value
# ============================================================================

struct ScriptableField:
    """A single named field within a scriptable object."""
    name: text
    value: text

# ============================================================================
# ScriptableObject — typed data asset
# ============================================================================

struct ScriptableObject:
    """A named, typed data asset holding arbitrary key-value fields."""
    type_name: text
    name: text
    fields: [ScriptableField]

impl ScriptableObject:
    static fn new(type_name: text, name: text) -> ScriptableObject:
        """Create an empty scriptable object with the given type and name."""
        ScriptableObject(
            type_name: type_name,
            name: name,
            fields: []
        )

    me set_field(field_name: text, value: text):
        """Add or update a field by name."""
        var i = 0
        while i < self.fields.len():
            if self.fields[i].name == field_name:
                # Update existing field — rebuild list
                var new_fields: [ScriptableField] = []
                var j = 0
                while j < self.fields.len():
                    if j == i:
                        new_fields.push(ScriptableField(name: field_name, value: value))
                    else:
                        new_fields.push(self.fields[j])
                    j = j + 1
                self.fields = new_fields
                return
            i = i + 1
        # Field not found — append
        self.fields.push(ScriptableField(name: field_name, value: value))

    fn get_field(field_name: text) -> text?:
        """Look up a field value by name. Returns nil if not found."""
        var i = 0
        while i < self.fields.len():
            if self.fields[i].name == field_name:
                return self.fields[i].value
            i = i + 1
        nil

    fn has_field(field_name: text) -> bool:
        """Check whether a field with the given name exists."""
        var i = 0
        while i < self.fields.len():
            if self.fields[i].name == field_name:
                return true
            i = i + 1
        false

    fn field_count() -> i64:
        """Return the number of fields."""
        self.fields.len()

# ============================================================================
# ScriptableObjectStore — collection manager
# ============================================================================

class ScriptableObjectStore:
    """Manages a collection of scriptable objects with lookup by index, name, or type."""
    objects: [ScriptableObject]
    count: i64

impl ScriptableObjectStore:
    static fn new() -> ScriptableObjectStore:
        """Create an empty store."""
        ScriptableObjectStore(
            objects: [],
            count: 0
        )

    me add(obj: ScriptableObject) -> i64:
        """Add an object and return its index."""
        self.objects.push(obj)
        val idx = self.count
        self.count = self.count + 1
        idx

    fn get(index: i64) -> ScriptableObject?:
        """Look up an object by index. Returns nil if out of bounds."""
        if index < 0 or index >= self.objects.len():
            return nil
        self.objects[index]

    fn find_by_name(name: text) -> ScriptableObject?:
        """Find the first object with the given name. Returns nil if not found."""
        var i = 0
        while i < self.objects.len():
            if self.objects[i].name == name:
                return self.objects[i]
            i = i + 1
        nil

    fn find_by_type(type_name: text) -> [ScriptableObject]:
        """Return all objects matching the given type name."""
        var result: [ScriptableObject] = []
        var i = 0
        while i < self.objects.len():
            if self.objects[i].type_name == type_name:
                result.push(self.objects[i])
            i = i + 1
        result

    me remove(index: i64) -> bool:
        """Remove the object at the given index. Returns false if out of bounds."""
        if index < 0 or index >= self.objects.len():
            return false
        var new_objects: [ScriptableObject] = []
        var i = 0
        while i < self.objects.len():
            if i != index:
                new_objects.push(self.objects[i])
            i = i + 1
        self.objects = new_objects
        self.count = self.count - 1
        true

    fn size() -> i64:
        """Return the number of objects in the store."""
        self.count
