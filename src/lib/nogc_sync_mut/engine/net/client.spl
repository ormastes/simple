# Game Client — client-side prediction and state reconciliation

struct StateSnapshot:
    tick: i32
    position_x: f64
    position_y: f64
    position_z: f64
    velocity_x: f64
    velocity_y: f64
    velocity_z: f64

struct InputCommand:
    tick: i32
    move_x: f64
    move_y: f64
    move_z: f64

class GameClient:
    client_id: i32
    server_address: text
    connected: bool
    local_tick: i32
    server_tick: i32
    state_buffer: [StateSnapshot]
    input_buffer: [InputCommand]
    prediction_enabled: bool
    interpolation_factor: f64

impl GameClient:
    static fn new(server_address: text) -> GameClient:
        GameClient(
            client_id: 0, server_address: server_address,
            connected: false, local_tick: 0, server_tick: 0,
            state_buffer: [], input_buffer: [],
            prediction_enabled: true, interpolation_factor: 0.1
        )

    me connect(client_id: i32):
        self.client_id = client_id
        self.connected = true

    me disconnect():
        self.connected = false

    me send_input(move_x: f64, move_y: f64, move_z: f64):
        if not self.connected:
            return
        val cmd = InputCommand(
            tick: self.local_tick,
            move_x: move_x, move_y: move_y, move_z: move_z
        )
        self.input_buffer.push(cmd)

    me advance_tick():
        self.local_tick = self.local_tick + 1

    me receive_state(tick: i32, px: f64, py: f64, pz: f64, vx: f64, vy: f64, vz: f64):
        self.server_tick = tick
        val snap = StateSnapshot(
            tick: tick, position_x: px, position_y: py, position_z: pz,
            velocity_x: vx, velocity_y: vy, velocity_z: vz
        )
        self.state_buffer.push(snap)
        if self.state_buffer.len() > 60:
            var trimmed: [StateSnapshot] = []
            var i = 30
            while i < self.state_buffer.len():
                trimmed.push(self.state_buffer[i])
                i = i + 1
            self.state_buffer = trimmed

    me set_prediction(enabled: bool):
        self.prediction_enabled = enabled

    fn is_connected() -> bool:
        self.connected

    fn get_local_tick() -> i32:
        self.local_tick

    fn get_server_tick() -> i32:
        self.server_tick

    fn input_count() -> i32:
        self.input_buffer.len().to_i32()

    fn state_count() -> i32:
        self.state_buffer.len().to_i32()

    fn get_latest_state() -> StateSnapshot?:
        if self.state_buffer.len() == 0:
            return nil
        self.state_buffer[self.state_buffer.len() - 1]
