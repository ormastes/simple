# Game Server — authoritative server with client management

struct ClientInfo:
    client_id: i32
    address: text
    latency_ms: f64
    connected: bool
    last_tick: i32

class GameServer:
    clients: [ClientInfo]
    max_clients: i32
    tick_rate: i32
    current_tick: i32
    next_client_id: i32
    running: bool

impl GameServer:
    static fn new(max_clients: i32, tick_rate: i32) -> GameServer:
        GameServer(
            clients: [], max_clients: max_clients, tick_rate: tick_rate,
            current_tick: 0, next_client_id: 1, running: false
        )

    me start():
        self.running = true

    me stop():
        self.running = false

    me connect_client(address: text) -> i32:
        if self.clients.len() >= self.max_clients:
            return -1
        val cid = self.next_client_id
        self.next_client_id = self.next_client_id + 1
        val info = ClientInfo(
            client_id: cid, address: address, latency_ms: 0.0,
            connected: true, last_tick: self.current_tick
        )
        self.clients.push(info)
        cid

    me disconnect_client(client_id: i32) -> bool:
        var i = 0
        while i < self.clients.len():
            if self.clients[i].client_id == client_id:
                val old = self.clients[i]
                self.clients[i] = ClientInfo(
                    client_id: old.client_id, address: old.address,
                    latency_ms: old.latency_ms, connected: false,
                    last_tick: old.last_tick
                )
                return true
            i = i + 1
        false

    me tick():
        if not self.running:
            return
        self.current_tick = self.current_tick + 1

    me update_client_latency(client_id: i32, latency: f64):
        var i = 0
        while i < self.clients.len():
            if self.clients[i].client_id == client_id:
                val old = self.clients[i]
                self.clients[i] = ClientInfo(
                    client_id: old.client_id, address: old.address,
                    latency_ms: latency, connected: old.connected,
                    last_tick: self.current_tick
                )
                return
            i = i + 1

    fn client_count() -> i32:
        var count = 0
        var i = 0
        while i < self.clients.len():
            if self.clients[i].connected:
                count = count + 1
            i = i + 1
        count

    fn get_client(client_id: i32) -> ClientInfo?:
        var i = 0
        while i < self.clients.len():
            if self.clients[i].client_id == client_id:
                return self.clients[i]
            i = i + 1
        nil

    fn is_running() -> bool:
        self.running

    fn get_tick() -> i32:
        self.current_tick
