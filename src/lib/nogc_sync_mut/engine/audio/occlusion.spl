# Occlusion — Raycast-based audio occlusion
#
# Computes a volume multiplier (0.0..1.0) based on the number of
# obstacles between listener and source. Each hit multiplies the
# signal by attenuation_per_hit (e.g. 0.5 = halve per obstacle).
#
# Usage:
#   val config = default_occlusion_config()
#   val mult = compute_occlusion_2d(listener_pos, source_pos, 2, config)

use std.common.engine.math2d.{Vec2}
use std.common.engine.math3d.{Vec3}

# ============================================================================
# OcclusionConfig
# ============================================================================

struct OcclusionConfig:
    """Configuration for raycast-based audio occlusion.

    attenuation_per_hit is multiplied per obstacle (e.g. 0.5 = halve volume
    per obstacle hit).
    """
    enabled: bool
    max_ray_distance: f64
    attenuation_per_hit: f64

fn default_occlusion_config() -> OcclusionConfig:
    """Create default occlusion config: enabled, 1000.0 max distance, 0.5 attenuation."""
    OcclusionConfig(
        enabled: true,
        max_ray_distance: 1000.0,
        attenuation_per_hit: 0.5
    )

# ============================================================================
# Occlusion computation
# ============================================================================

fn compute_occlusion_2d(listener: Vec2, source: Vec2, hit_count: i32, config: OcclusionConfig) -> f64:
    """Compute 2D occlusion volume multiplier.

    Returns 1.0 if occlusion is disabled or hit_count <= 0.
    Otherwise returns attenuation_per_hit^hit_count, clamped to [0.0, 1.0].
    Distance beyond max_ray_distance returns 0.0.
    """
    if not config.enabled:
        return 1.0
    if hit_count <= 0:
        return 1.0

    # Check distance
    val dx = source.x - listener.x
    val dy = source.y - listener.y
    val dist = (dx * dx + dy * dy) ** 0.5
    if dist > config.max_ray_distance:
        return 0.0

    # Multiply attenuation per hit
    var result = 1.0
    var i = 0
    while i < hit_count:
        result = result * config.attenuation_per_hit
        i = i + 1

    # Clamp to [0.0, 1.0]
    if result < 0.0:
        result = 0.0
    if result > 1.0:
        result = 1.0
    result

fn compute_occlusion_3d(listener: Vec3, source: Vec3, hit_count: i32, config: OcclusionConfig) -> f64:
    """Compute 3D occlusion volume multiplier.

    Same logic as 2D but uses 3D distance.
    """
    if not config.enabled:
        return 1.0
    if hit_count <= 0:
        return 1.0

    # Check distance
    val dx = source.x - listener.x
    val dy = source.y - listener.y
    val dz = source.z - listener.z
    val dist = (dx * dx + dy * dy + dz * dz) ** 0.5
    if dist > config.max_ray_distance:
        return 0.0

    # Multiply attenuation per hit
    var result = 1.0
    var i = 0
    while i < hit_count:
        result = result * config.attenuation_per_hit
        i = i + 1

    # Clamp to [0.0, 1.0]
    if result < 0.0:
        result = 0.0
    if result > 1.0:
        result = 1.0
    result
