# AudioManager — Silent backend for the new 2D engine
#
# The new 2D engine keeps the public audio API shape, but the Rust driver does
# not currently expose the host `rt_audio_*` extern family. Instead of
# pretending audio is connected, this module implements an explicit silent
# backend. Callers can still cache clips, create sound handles, and adjust bus
# state without pulling in unavailable runtime symbols.

use std.nogc_sync_mut.engine.audio.types.{
    AudioClip, SoundHandle, AudioBus, AudioConfig
}

# ============================================================================
# AudioManager
# ============================================================================

class AudioManager:
    """Audio API with an explicit silent backend.

    The manager tracks clip metadata, bus state, and listener position, but
    performs no host-side playback until a real runtime audio backend is wired.
    """
    engine_handle: i64
    config: AudioConfig
    buses: Dict<text, AudioBus>
    clip_cache: Dict<text, AudioClip>
    listener_x: f64
    listener_y: f64
    next_playback_handle: i64

impl AudioManager:
    static fn create(config: AudioConfig) -> AudioManager:
        var buses: Dict<text, AudioBus> = {}
        buses["sfx"] = AudioBus(name: "sfx", mixer_handle: 0, volume: 1.0, muted: false)
        buses["music"] = AudioBus(name: "music", mixer_handle: 0, volume: 1.0, muted: false)
        buses["ui"] = AudioBus(name: "ui", mixer_handle: 0, volume: 1.0, muted: false)

        AudioManager(
            engine_handle: 0,
            config: config,
            buses: buses,
            clip_cache: {},
            listener_x: 0.0,
            listener_y: 0.0,
            next_playback_handle: 1
        )

    me load_clip(path: text) -> AudioClip:
        val clip = AudioClip(source_handle: 0, path: path, is_loaded: true)
        self.clip_cache[path] = clip
        clip

    me load_clip_cached(path: text) -> AudioClip:
        if val Some(cached) = self.clip_cache.get(path):
            return cached
        self.load_clip(path)

    me play(clip: AudioClip, bus_name: text) -> SoundHandle:
        self._new_sound_handle(clip.path, bus_name, false)

    me play_with_volume(clip: AudioClip, bus_name: text, volume: f64) -> SoundHandle:
        self.play(clip, bus_name)

    me play_looped(clip: AudioClip, bus_name: text) -> SoundHandle:
        self._new_sound_handle(clip.path, bus_name, false)

    me play_one_shot(path: text) -> SoundHandle:
        val clip = self.load_clip_cached(path)
        self.play(clip, "sfx")

    me play_music(path: text) -> SoundHandle:
        val clip = self.load_clip_cached(path)
        self.play_looped(clip, "music")

    me play_at(clip: AudioClip, bus_name: text, x: f64, y: f64) -> SoundHandle:
        self._new_sound_handle(clip.path, bus_name, true)

    me set_listener_position(x: f64, y: f64):
        self.listener_x = x
        self.listener_y = y

    me stop_sound(handle: SoundHandle) -> bool:
        handle.is_valid()

    me pause_sound(handle: SoundHandle) -> bool:
        handle.is_valid()

    me resume_sound(handle: SoundHandle) -> bool:
        handle.is_valid()

    me set_sound_volume(handle: SoundHandle, volume: f64) -> bool:
        handle.is_valid()

    me set_bus_volume(bus_name: text, volume: f64) -> bool:
        if val Some(bus) = self.buses.get(bus_name):
            self.buses[bus_name] = AudioBus(
                name: bus.name,
                mixer_handle: bus.mixer_handle,
                volume: volume,
                muted: bus.muted
            )
            return true
        false

    fn get_bus_volume(bus_name: text) -> f64:
        if val Some(bus) = self.buses.get(bus_name):
            return bus.volume
        0.0

    me mute_bus(bus_name: text) -> bool:
        if val Some(bus) = self.buses.get(bus_name):
            self.buses[bus_name] = AudioBus(
                name: bus.name,
                mixer_handle: bus.mixer_handle,
                volume: bus.volume,
                muted: true
            )
            return true
        false

    me unmute_bus(bus_name: text) -> bool:
        if val Some(bus) = self.buses.get(bus_name):
            self.buses[bus_name] = AudioBus(
                name: bus.name,
                mixer_handle: bus.mixer_handle,
                volume: bus.volume,
                muted: false
            )
            return true
        false

    me set_master_volume(volume: f64):
        self.config = AudioConfig(
            master_volume: volume,
            spatial_max_distance: self.config.spatial_max_distance,
            spatial_min_distance: self.config.spatial_min_distance
        )

    fn get_master_volume() -> f64:
        self.config.master_volume

    me stop_all():
        self.clip_cache = {}

    me destroy():
        self.stop_all()

    me _new_sound_handle(clip_path: text, bus_name: text, is_spatial: bool) -> SoundHandle:
        val handle = self.next_playback_handle
        self.next_playback_handle = self.next_playback_handle + 1
        SoundHandle(
            playback_handle: handle,
            clip_path: clip_path,
            bus_name: bus_name,
            is_spatial: is_spatial
        )
