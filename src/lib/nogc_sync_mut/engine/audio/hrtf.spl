# HRTF Spatialization — head-related transfer function for 3D audio

struct HRIREntry:
    azimuth: f64
    elevation: f64
    left_delay_samples: i32
    right_delay_samples: i32
    left_gain: f64
    right_gain: f64

class HRTFData:
    entries: [HRIREntry]
    sample_rate: i32

impl HRTFData:
    static fn new(sample_rate: i32) -> HRTFData:
        HRTFData(entries: [], sample_rate: sample_rate)

    me add_entry(azimuth: f64, elevation: f64, left_delay: i32, right_delay: i32, left_gain: f64, right_gain: f64):
        val entry = HRIREntry(
            azimuth: azimuth, elevation: elevation,
            left_delay_samples: left_delay, right_delay_samples: right_delay,
            left_gain: left_gain, right_gain: right_gain
        )
        self.entries.push(entry)

    fn entry_count() -> i32:
        self.entries.len().to_i32()

    fn find_nearest(azimuth: f64, elevation: f64) -> HRIREntry?:
        if self.entries.len() == 0:
            return nil
        var best_idx = 0
        var best_dist = 999999.0
        var i = 0
        while i < self.entries.len():
            val e = self.entries[i]
            val da = e.azimuth - azimuth
            val de = e.elevation - elevation
            val dist = da * da + de * de
            if dist < best_dist:
                best_dist = dist
                best_idx = i
            i = i + 1
        self.entries[best_idx]

struct HRTFSource:
    source_id: i32
    position_x: f64
    position_y: f64
    position_z: f64
    active: bool

class HRTFProcessor:
    hrtf_data: HRTFData
    sources: [HRTFSource]
    listener_x: f64
    listener_y: f64
    listener_z: f64

impl HRTFProcessor:
    static fn new(data: HRTFData) -> HRTFProcessor:
        HRTFProcessor(
            hrtf_data: data, sources: [],
            listener_x: 0.0, listener_y: 0.0, listener_z: 0.0
        )

    me set_listener_position(x: f64, y: f64, z: f64):
        self.listener_x = x
        self.listener_y = y
        self.listener_z = z

    me add_source(source_id: i32, x: f64, y: f64, z: f64) -> i32:
        val idx: i32 = self.sources.len()
        val src = HRTFSource(source_id: source_id, position_x: x, position_y: y, position_z: z, active: true)
        self.sources.push(src)
        idx

    me update_source_position(source_id: i32, x: f64, y: f64, z: f64):
        var i = 0
        while i < self.sources.len():
            if self.sources[i].source_id == source_id:
                val old = self.sources[i]
                self.sources[i] = HRTFSource(
                    source_id: old.source_id, position_x: x, position_y: y, position_z: z, active: old.active
                )
                return
            i = i + 1

    fn source_count() -> i32:
        self.sources.len().to_i32()

    fn get_source(source_id: i32) -> HRTFSource?:
        var i = 0
        while i < self.sources.len():
            if self.sources[i].source_id == source_id:
                return self.sources[i]
            i = i + 1
        nil
