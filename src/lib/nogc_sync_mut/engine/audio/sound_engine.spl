# codex-impl
# SoundEngine facade foundation.
#
# This module exposes the selected platform/no-audio/codec/mixer contracts
# through the existing mutable engine audio package without touching native
# device I/O yet.

use std.common.engine.audio.sound_contract.{
    SoundBackendCapability, SoundCommand, SoundCodecResult, SoundParallelEvidence,
    sound_capability, sound_no_audio_capability, sound_backend_status_valid,
    sound_command_2d, sound_command_3d, sound_decode_design_vector,
    sound_parallel_plan
}

struct SoundEngineConfig:
    platform: text
    host: text
    prefer_no_audio: bool

impl SoundEngineConfig:
    static fn no_audio() -> SoundEngineConfig:
        SoundEngineConfig(platform: "ci", host: "ci", prefer_no_audio: true)

    static fn platform(platform: text, host: text) -> SoundEngineConfig:
        SoundEngineConfig(platform: platform, host: host, prefer_no_audio: false)

class SoundEngine:
    capability: SoundBackendCapability
    command_log: [SoundCommand]
    teardown_count: i64

impl SoundEngine:
    static fn create(config: SoundEngineConfig) -> SoundEngine:
        var cap = sound_capability(config.platform, config.host)
        if config.prefer_no_audio:
            cap = sound_no_audio_capability()
        SoundEngine(capability: cap, command_log: [], teardown_count: 0)

    me play_2d(entity_id: text, clip_id: text, x_milli: i64, listener_x_milli: i64) -> SoundCommand:
        val cmd = sound_command_2d(entity_id, clip_id, x_milli, listener_x_milli)
        self.command_log = self.command_log.push(cmd)
        cmd

    me play_3d(entity_id: text, clip_id: text, distance_milli: i64, doppler_milli: i64, occlusion_milli: i64) -> SoundCommand:
        val cmd = sound_command_3d(entity_id, clip_id, distance_milli, doppler_milli, occlusion_milli)
        self.command_log = self.command_log.push(cmd)
        cmd

    fn command_count() -> i64:
        self.command_log.len()

    me teardown():
        self.command_log = []
        self.teardown_count = self.teardown_count + 1

fn sound_engine_decode_vector(input: text) -> SoundCodecResult:
    sound_decode_design_vector(input)

fn sound_engine_parallel_plan(has_worker_pool: bool) -> SoundParallelEvidence:
    sound_parallel_plan(has_worker_pool)

fn sound_engine_status_valid(status: text) -> bool:
    sound_backend_status_valid(status)
