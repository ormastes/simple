# Audio Types — Clips, Handles, Buses, and Configuration
#
# Core data structures for the game engine audio system.
# These types wrap raw FFI handles with meaningful domain context
# for use by AudioManager.
#
# Usage:
#   val config = default_audio_config()
#   val clip = AudioClip(source_handle: handle, path: "sfx/hit.wav", is_loaded: true)
#   val sound = SoundHandle(playback_handle: pb, clip_path: "sfx/hit.wav", bus_name: "sfx", is_spatial: false)

use std.common.engine.units.{Volume, Distance}
use std.common.engine.math3d.{Vec3}

# ============================================================================
# AudioClip — A loaded audio resource
# ============================================================================

struct AudioClip:
    """A loaded audio resource backed by an FFI AudioSource handle.

    Clips are cached by file path in AudioManager to avoid redundant loads.
    """
    source_handle: i64       # FFI AudioSource handle
    path: text
    is_loaded: bool

# ============================================================================
# SoundHandle — An active playback instance
# ============================================================================

struct SoundHandle:
    """Handle to an active sound playback instance.

    Wraps an FFI AudioPlayback handle with metadata about which clip
    is playing, which bus it belongs to, and whether it uses spatial audio.
    """
    playback_handle: i64     # FFI AudioPlayback handle
    clip_path: text
    bus_name: text
    is_spatial: bool

impl SoundHandle:
    fn is_valid() -> bool:
        """Check whether this handle points to a valid playback instance."""
        self.playback_handle > 0

# ============================================================================
# AudioBus — A named audio channel with volume control
# ============================================================================

struct AudioBus:
    """A named audio mixing bus backed by an FFI AudioMixer handle.

    Buses group sounds by category (sfx, music, ui) for independent
    volume control and muting.
    """
    name: text
    mixer_handle: i64        # FFI AudioMixer handle
    volume: Volume
    muted: bool

# ============================================================================
# AudioConfig — Engine-level audio settings
# ============================================================================

struct AudioConfig:
    """Configuration for the audio system.

    Controls master volume and spatial audio distance parameters.
    """
    master_volume: Volume
    spatial_max_distance: Distance
    spatial_min_distance: Distance

fn default_audio_config() -> AudioConfig:
    """Create default audio configuration.

    Defaults: master volume 1.0, spatial max distance 1000.0, min distance 50.0.
    """
    AudioConfig(
        master_volume: Volume(value: 1.0),
        spatial_max_distance: Distance(value: 1000.0),
        spatial_min_distance: Distance(value: 50.0)
    )

# ============================================================================
# Listener3D — 3D audio listener orientation
# ============================================================================

struct Listener3D:
    """3D audio listener with position and orientation.

    Used by AudioManager to set the miniaudio listener state for spatial audio.
    """
    position: Vec3
    forward: Vec3
    up: Vec3

fn default_listener_3d() -> Listener3D:
    """Create a default listener at the origin facing forward (+Z), up (+Y)."""
    Listener3D(
        position: Vec3.zero(),
        forward: Vec3.forward(),
        up: Vec3.up()
    )
