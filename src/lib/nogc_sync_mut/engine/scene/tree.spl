# Scene Tree Queries — Transform, Search, Traversal
#
# Free functions that operate on a NodeStore to query the scene graph.
# Includes world-transform calculation, search by name/tag,
# depth-first traversal, and z-sorted rendering order.
#
# Usage:
#   val world_t = get_world_transform(store, node_id)
#   val found = find_by_name(store, "player")
#   val render_order = traverse_z_sorted(store)

use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2, Transform2D}
use std.nogc_sync_mut.engine.scene.node.{Node2D, NodeStore}

# ============================================================================
# Transform Queries
# ============================================================================

fn get_world_transform(store: NodeStore, id: NodeId) -> Transform2D:
    """Compute the world transform by walking up the parent chain.

    At each level, composes parent.compose(child) so that the final
    transform applies all ancestor transforms in order.
    Returns identity if the node is invalid.
    """
    # Collect transforms from node up to root
    var transforms: [Transform2D] = []
    var current_id = id

    while current_id.is_valid():
        val maybe_node = store.get_node(current_id)
        if maybe_node == nil:
            break
        if val Some(node) = maybe_node:
            val local_t = node.get_local_transform()
            transforms.push(local_t)
            current_id = node.parent
        else:
            break

    # Compose from root (last) down to leaf (first)
    # transforms[0] = leaf, transforms[N-1] = root
    # Result = root.compose(child1).compose(child2)...compose(leaf)
    if transforms.len() == 0:
        return Transform2D.identity()

    var i = transforms.len() - 1
    var result = transforms[i]
    i = i - 1
    while i >= 0:
        result = result.compose(transforms[i])
        i = i - 1
    result

fn get_world_position(store: NodeStore, id: NodeId) -> Vec2:
    """Get the world-space position of a node (shortcut for world transform)."""
    val world_t = get_world_transform(store, id)
    world_t.position

# ============================================================================
# Search Queries
# ============================================================================

fn find_by_name(store: NodeStore, name: text) -> NodeId?:
    """Find the first node with a matching name (linear scan).

    Returns nil if no node matches.
    """
    var i = 0
    while i < store.nodes.len():
        val maybe_node = store.nodes[i]
        if val Some(node) = maybe_node:
            if node.name == name:
                return node.id
        i = i + 1
    nil

fn find_by_tag(store: NodeStore, tag: text) -> [NodeId]:
    """Find all nodes that have the given tag."""
    var result: [NodeId] = []
    var i = 0
    while i < store.nodes.len():
        val maybe_node = store.nodes[i]
        if val Some(node) = maybe_node:
            if node.has_tag(tag):
                result.push(node.id)
        i = i + 1
    result

fn get_children(store: NodeStore, id: NodeId) -> [NodeId]:
    """Get the direct children of a node. Returns empty if node invalid."""
    val maybe_node = store.get_node(id)
    if val Some(node) = maybe_node:
        return node.children
    []

fn get_descendants(store: NodeStore, id: NodeId) -> [NodeId]:
    """Get all descendants of a node (recursive DFS, excludes the node itself)."""
    var result: [NodeId] = []
    val maybe_node = store.get_node(id)
    if maybe_node == nil:
        return result
    if val Some(node) = maybe_node:
        # Use a stack for iterative DFS
        var stack: [NodeId] = []
        # Push children in reverse order so first child is processed first
        var ci = node.children.len() - 1
        while ci >= 0:
            stack.push(node.children[ci])
            ci = ci - 1

        while stack.len() > 0:
            val current = stack[stack.len() - 1]
            stack.pop()
            result.push(current)
            val maybe_current = store.get_node(current)
            if val Some(cur_node) = maybe_current:
                # Push children in reverse order
                var ki = cur_node.children.len() - 1
                while ki >= 0:
                    stack.push(cur_node.children[ki])
                    ki = ki - 1
    result

fn get_root_nodes(store: NodeStore) -> [NodeId]:
    """Get all root nodes (nodes with no parent)."""
    store.root_nodes

# ============================================================================
# Traversal
# ============================================================================

fn traverse_depth_first(store: NodeStore, root: NodeId) -> [NodeId]:
    """Depth-first traversal starting from root (parent before children).

    Returns the root itself followed by all descendants in DFS order.
    """
    var result: [NodeId] = []
    val maybe_root = store.get_node(root)
    if maybe_root == nil:
        return result

    # Iterative DFS with a stack
    var stack: [NodeId] = []
    stack.push(root)

    while stack.len() > 0:
        val current = stack[stack.len() - 1]
        stack.pop()
        result.push(current)
        val maybe_node = store.get_node(current)
        if val Some(node) = maybe_node:
            # Push children in reverse order so first child is visited first
            var ci = node.children.len() - 1
            while ci >= 0:
                stack.push(node.children[ci])
                ci = ci - 1
    result

fn traverse_z_sorted(store: NodeStore) -> [NodeId]:
    """Collect all visible+active nodes, sorted by z_index ascending.

    Used for rendering: lower z_index drawn first (background),
    higher z_index drawn last (foreground). Uses insertion sort
    since node counts are typically small.
    """
    # Collect visible+active nodes with their z_index
    var ids: [NodeId] = []
    var z_values: [i64] = []
    var i = 0
    while i < store.nodes.len():
        val maybe_node = store.nodes[i]
        if val Some(node) = maybe_node:
            val is_visible = node.visible
            val is_active = node.active
            if is_visible and is_active:
                ids.push(node.id)
                z_values.push(node.z_index.value)
        i = i + 1

    # Insertion sort by z_index
    var si = 1
    while si < ids.len():
        val key_id = ids[si]
        val key_z = z_values[si]
        var j = si - 1
        while j >= 0 and z_values[j] > key_z:
            ids[j + 1] = ids[j]
            z_values[j + 1] = z_values[j]
            j = j - 1
        ids[j + 1] = key_id
        z_values[j + 1] = key_z
        si = si + 1
    ids

# ============================================================================
# Utility
# ============================================================================

fn is_ancestor(store: NodeStore, ancestor: NodeId, descendant: NodeId) -> bool:
    """Check whether ancestor is an ancestor of descendant.

    Walks up the parent chain from descendant looking for ancestor.
    Returns false if either id is invalid or they are the same node.
    """
    if not ancestor.is_valid() or not descendant.is_valid():
        return false
    if ancestor.eq(descendant):
        return false

    var current = descendant
    while current.is_valid():
        val maybe_node = store.get_node(current)
        if maybe_node == nil:
            return false
        if val Some(node) = maybe_node:
            val parent = node.parent
            if parent.eq(ancestor):
                return true
            current = parent
        else:
            return false
    false

fn get_depth(store: NodeStore, id: NodeId) -> i64:
    """Get the depth of a node from the root (root = 0).

    Returns -1 if the node is invalid.
    """
    if not id.is_valid():
        return -1
    val maybe_node = store.get_node(id)
    if maybe_node == nil:
        return -1

    var depth = 0
    var current = id
    while current.is_valid():
        val maybe_cur = store.get_node(current)
        if maybe_cur == nil:
            break
        if val Some(node) = maybe_cur:
            val parent = node.parent
            if not parent.is_valid():
                break
            depth = depth + 1
            current = parent
        else:
            break
    depth
