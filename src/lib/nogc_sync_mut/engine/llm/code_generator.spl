# Code Generator — Template-Based Code Scaffolding
#
# Generates Simple language code snippets from natural language
# descriptions using template-based code scaffolding.
#
# Usage:
#   var gen = CodeGenerator.new()
#   val code = gen.generate("entity", "Player")
#   # code.source => "struct Player:\n    x: f64\n    y: f64\n    active: bool"

# ============================================================================
# CodeTemplate — named code template with parameters
# ============================================================================

struct CodeTemplate:
    name: text
    description: text
    template_code: text
    parameters: [text]

impl CodeTemplate:
    static fn new(name: text, description: text, template_code: text) -> CodeTemplate:
        """Create a new code template."""
        CodeTemplate(
            name: name,
            description: description,
            template_code: template_code,
            parameters: []
        )

    me add_parameter(param: text):
        """Add a parameter to the template."""
        self.parameters.push(param)

    fn parameter_count() -> i32:
        """Return number of parameters."""
        self.parameters.len().to_i32()

# ============================================================================
# GeneratedCode — result of code generation
# ============================================================================

struct GeneratedCode:
    source: text
    template_name: text
    valid: bool

impl GeneratedCode:
    static fn new(source: text, template_name: text) -> GeneratedCode:
        """Create a new generated code result."""
        GeneratedCode(
            source: source,
            template_name: template_name,
            valid: true
        )

    fn line_count() -> i32:
        """Count lines in generated source (newlines + 1)."""
        var count = 1
        var i = 0
        val chars = self.source.split("")
        while i < chars.len():
            if chars[i] == "\n":
                count = count + 1
            i = i + 1
        count

# ============================================================================
# CodeGenerator — template registry and code generation engine
# ============================================================================

class CodeGenerator:
    templates: [CodeTemplate]

impl CodeGenerator:
    static fn new() -> CodeGenerator:
        """Create a code generator with default templates."""
        var gen = CodeGenerator(templates: [])

        var entity_tmpl = CodeTemplate.new(
            "entity",
            "Entity with position and active flag",
            "struct EntityName:\n    x: f64\n    y: f64\n    active: bool"
        )
        gen.templates.push(entity_tmpl)

        var component_tmpl = CodeTemplate.new(
            "component",
            "Simple component with a value",
            "struct ComponentName:\n    value: f64"
        )
        gen.templates.push(component_tmpl)

        var system_tmpl = CodeTemplate.new(
            "system",
            "System function stub",
            "fn system_name(dt: f64):\n    pass_do_nothing"
        )
        gen.templates.push(system_tmpl)

        gen

    me add_template(template: CodeTemplate):
        """Register a new template."""
        self.templates.push(template)

    fn find_template(name: text) -> Option<CodeTemplate>:
        """Find a template by name."""
        var i = 0
        while i < self.templates.len():
            if self.templates[i].name == name:
                return Some(self.templates[i])
            i = i + 1
        None

    fn generate(template_name: text, entity_name: text) -> GeneratedCode:
        """Generate code by applying entity_name to the named template."""
        val tmpl_opt = self.find_template(template_name)
        if val Some(tmpl) = tmpl_opt:
            # Replace placeholder name in template code with entity_name
            var result = tmpl.template_code
            if template_name == "entity":
                result = result.replace("EntityName", entity_name)
            elif template_name == "component":
                result = result.replace("ComponentName", entity_name)
            elif template_name == "system":
                result = result.replace("system_name", entity_name)
            else:
                # Generic: try all common placeholders
                result = result.replace("EntityName", entity_name)
                result = result.replace("ComponentName", entity_name)
                result = result.replace("system_name", entity_name)
            GeneratedCode.new(result, template_name)
        else:
            GeneratedCode(
                source: "",
                template_name: template_name,
                valid: false
            )

    fn template_count() -> i32:
        """Return number of registered templates."""
        self.templates.len().to_i32()

    fn list_template_names() -> [text]:
        """Return all template names."""
        var names: [text] = []
        var i = 0
        while i < self.templates.len():
            names.push(self.templates[i].name)
            i = i + 1
        names
