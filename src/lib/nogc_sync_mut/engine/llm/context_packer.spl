# Context Packer
#
# Serializes scene/engine state into prompt text for LLM calls.
# Collects categorized key-value entries and packs them into
# a formatted context string.
#
# Usage:
#   var packer = ContextPacker.new(100)
#   packer.add_scene_info("Level1", 42)
#   packer.add_physics_info(10, -9.8)
#   val ctx = packer.pack()

# ============================================================================
# ContextEntry — single key-value pair with category
# ============================================================================

struct ContextEntry:
    category: text
    key: text
    value: text

# ============================================================================
# ContextPacker — collects and formats context entries
# ============================================================================

class ContextPacker:
    entries: [ContextEntry]
    max_entries: i64

impl ContextPacker:
    static fn new(max_entries: i64) -> ContextPacker:
        """Create a new context packer with entry limit."""
        ContextPacker(entries: [], max_entries: max_entries)

    me add_entry(category: text, key: text, value: text):
        """Add a categorized entry if under the limit."""
        if self.entries.len().to_i64() < self.max_entries:
            self.entries.push(ContextEntry(category: category, key: key, value: value))

    me add_scene_info(scene_name: text, node_count: i64):
        """Convenience: add scene category entry."""
        self.add_entry("scene", "name", scene_name)
        self.add_entry("scene", "node_count", node_count.to_text())

    me add_physics_info(body_count: i64, gravity: f64):
        """Convenience: add physics category entry."""
        self.add_entry("physics", "body_count", body_count.to_text())
        self.add_entry("physics", "gravity", gravity.to_text())

    fn pack() -> text:
        """Concatenate entries into formatted context text."""
        var result = ""
        var current_category = ""
        var i = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if entry.category != current_category:
                if result.len() > 0:
                    result = result + "\n"
                result = result + "## " + entry.category + "\n"
                current_category = entry.category
            result = result + "- " + entry.key + ": " + entry.value + "\n"
            i = i + 1
        result

    fn entry_count() -> i64:
        """Return number of entries."""
        self.entries.len().to_i64()

    me clear():
        """Remove all entries."""
        self.entries = []
