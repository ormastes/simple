# LLM CLI Command Dispatch
#
# Command dispatch for LLM engine interactions. Parses user commands
# and routes to the appropriate handler.
#
# Usage:
#   val req = LLMRequest.parse("create a forest scene")
#   var dispatcher = LLMCommandDispatcher.new()
#   val resp = dispatcher.dispatch(req)

# ============================================================================
# LLMRequest — parsed command + prompt from user input
# ============================================================================

struct LLMRequest:
    command: text
    prompt: text
    context_data: text

impl LLMRequest:
    static fn new(command: text, prompt: text) -> LLMRequest:
        """Create a new LLM request with command and prompt."""
        LLMRequest(command: command, prompt: prompt, context_data: "")

    static fn parse(input: text) -> LLMRequest:
        """Parse 'command prompt...' format. Split on first space."""
        var cmd = input
        var prm = ""
        var i = 0
        while i < input.len():
            if input[i] == ' ':
                cmd = input.substring(0, i)
                prm = input.substring(i + 1, input.len())
                i = input.len()
            else:
                i = i + 1
        LLMRequest(command: cmd, prompt: prm, context_data: "")

# ============================================================================
# LLMResponse — result of dispatching a command
# ============================================================================

struct LLMResponse:
    success: bool
    output: text
    response_type: text

impl LLMResponse:
    static fn ok(output: text, response_type: text) -> LLMResponse:
        """Create a successful response."""
        LLMResponse(success: true, output: output, response_type: response_type)

    static fn error(message: text) -> LLMResponse:
        """Create an error response."""
        LLMResponse(success: false, output: message, response_type: "error")

# ============================================================================
# LLMCommandDispatcher — routes commands to handlers
# ============================================================================

class LLMCommandDispatcher:
    registered_commands: [text]

impl LLMCommandDispatcher:
    static fn new() -> LLMCommandDispatcher:
        """Create dispatcher with default commands registered."""
        LLMCommandDispatcher(
            registered_commands: ["create", "describe", "debug", "generate", "suggest"]
        )

    me register_command(name: text):
        """Register a new command name."""
        self.registered_commands.push(name)

    fn has_command(name: text) -> bool:
        """Check if a command is registered."""
        var i = 0
        while i < self.registered_commands.len():
            if self.registered_commands[i] == name:
                return true
            i = i + 1
        false

    fn dispatch(request: LLMRequest) -> LLMResponse:
        """Dispatch a request to the matched command handler."""
        if !self.has_command(request.command):
            return LLMResponse.error("Unknown command: " + request.command)
        LLMResponse.ok(
            "Dispatched " + request.command + ": " + request.prompt,
            request.command
        )

    fn command_count() -> i32:
        """Return number of registered commands."""
        self.registered_commands.len().to_i32()
