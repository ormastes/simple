#![allow(primitive_api)]
# 3D Camera Component
#
# Camera3DData provides projection and view matrix generation
# for perspective and orthographic 3D rendering.

use std.common.engine.math3d.{Vec3, Mat4, Transform3D}
use std.common.engine.units.{Angle}

class Camera3DData:
    fov: Angle
    aspect_ratio: f64
    near_plane: f64
    far_plane: f64
    is_active: bool
    is_orthographic: bool
    ortho_size: f64

impl Camera3DData:
    static fn perspective(fov: Angle, aspect: f64, near: f64, far: f64) -> Camera3DData:
        Camera3DData(
            fov: fov,
            aspect_ratio: aspect,
            near_plane: near,
            far_plane: far,
            is_active: true,
            is_orthographic: false,
            ortho_size: 1.0
        )

    static fn orthographic(size: f64, aspect: f64, near: f64, far: f64) -> Camera3DData:
        Camera3DData(
            fov: Angle(radians: 0.0),
            aspect_ratio: aspect,
            near_plane: near,
            far_plane: far,
            is_active: true,
            is_orthographic: true,
            ortho_size: size
        )

    fn projection_matrix() -> Mat4:
        if self.is_orthographic:
            val half_h = self.ortho_size
            val half_w = half_h * self.aspect_ratio
            return Mat4.orthographic(-half_w, half_w, -half_h, half_h, self.near_plane, self.far_plane)
        Mat4.perspective(self.fov, self.aspect_ratio, self.near_plane, self.far_plane)

    fn view_matrix(transform: Transform3D) -> Mat4:
        # View = inverse of camera's world transform
        # look_at: eye = position, target = position + forward, up = up direction
        val eye = transform.position
        val fwd = transform.forward()
        val target = Vec3(x: eye.x + fwd.x, y: eye.y + fwd.y, z: eye.z + fwd.z)
        val up = transform.up()
        Mat4.look_at(eye, target, up)
