#![allow(primitive_api)]
# 3D Component Registry
#
# Mirrors ComponentRegistry (2D) for 3D components.
# Maps NodeId to lists of Component3D via generational index.

use std.common.engine.ids.{NodeId}
use std.common.engine.color.{EngineColor}
use std.nogc_sync_mut.engine.component.mesh.{MeshData, LightData}
use std.nogc_sync_mut.engine.render.material3d.{Material3D}
use std.nogc_sync_mut.engine.component.camera3d.{Camera3DData}

enum Component3D:
    Mesh(mesh: MeshData, material: Material3D)
    Light(data: LightData)
    Camera(data: Camera3DData)

impl Component3D:
    fn type_name() -> text:
        match self:
            Mesh(_, _): "Mesh"
            Light(_): "Light"
            Camera(_): "Camera"

    fn is_mesh() -> bool:
        match self:
            Mesh(_, _): true
            _: false

    fn is_light() -> bool:
        match self:
            Light(_): true
            _: false

    fn is_camera() -> bool:
        match self:
            Camera(_): true
            _: false

class ComponentRegistry3D:
    entries: Dict<i64, [Component3D]>

impl ComponentRegistry3D:
    static fn create() -> ComponentRegistry3D:
        ComponentRegistry3D(entries: {})

    fn _entry_key(node_id: NodeId) -> i64:
        node_id.to_index()

    me attach(node_id: NodeId, component: Component3D):
        val key = self._entry_key(node_id)
        if val Some(existing) = self.entries.get(key):
            var list = existing
            list.push(component)
            self.entries[key] = list
        else:
            self.entries[key] = [component]

    me detach_all(node_id: NodeId):
        val key = self._entry_key(node_id)
        self.entries.remove(key)

    fn get_components(node_id: NodeId) -> [Component3D]:
        val key = self._entry_key(node_id)
        if val Some(list) = self.entries.get(key):
            return list
        []

    fn get_mesh(node_id: NodeId) -> (MeshData, Material3D)?:
        val components = self.get_components(node_id)
        var i = 0
        while i < components.len():
            val c = components[i]
            match c:
                Component3D.Mesh(mesh, material):
                    return (mesh, material)
                _:
                    pass
            i = i + 1
        nil

    fn get_light(node_id: NodeId) -> LightData?:
        val components = self.get_components(node_id)
        var i = 0
        while i < components.len():
            val c = components[i]
            match c:
                Component3D.Light(data):
                    return data
                _:
                    pass
            i = i + 1
        nil

    fn get_camera(node_id: NodeId) -> Camera3DData?:
        val components = self.get_components(node_id)
        var i = 0
        while i < components.len():
            val c = components[i]
            match c:
                Component3D.Camera(data):
                    return data
                _:
                    pass
            i = i + 1
        nil
