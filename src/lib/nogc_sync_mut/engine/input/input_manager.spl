#![allow(primitive_api)]
# Input System — InputManager
#
# Central input manager that polls window and gamepad events, tracks per-frame
# button state transitions, and supports named action bindings.
#
# Usage:
#   var el = window_create_event_loop()
#   var mgr = InputManager.create(el.handle)
#   mgr.bind_key_action("jump", 32)   # Space
#   # game loop:
#   mgr.poll()
#   if mgr.is_action_just_pressed("jump"):
#       player_jump()

use std.nogc_sync_mut.io.window_ffi.{
    rt_winit_event_loop_poll_events,
    rt_winit_event_get_type,
    rt_winit_event_keyboard_input,
    rt_winit_event_keyboard_virtual_keycode,
    rt_winit_event_keyboard_modifiers,
    rt_winit_event_mouse_button,
    rt_winit_event_mouse_moved,
    rt_winit_event_mouse_wheel,
    rt_winit_event_window_close_requested,
    rt_winit_event_free
}

use std.common.engine.signal.signal.{Signal}
use std.common.engine.units.{KeyCode, MouseButtonId}

use std.nogc_sync_mut.engine.input.types.{
    ButtonState,
    MouseState,
    ActionBinding
}

# ============================================================================
# Helper: compute ButtonState from current and previous pressed booleans
# ============================================================================

fn _compute_button_state(current: bool, previous: bool) -> ButtonState:
    if current and not previous:
        ButtonState.JustPressed
    elif current and previous:
        ButtonState.Held
    elif not current and previous:
        ButtonState.JustReleased
    else:
        ButtonState.Released

# ============================================================================
# InputManager
# ============================================================================

class InputManager:
    event_loop_handle: i64
    gamepad_ctx: i64
    # Key states: parallel arrays (keycode -> pressed bool)
    key_current_codes: [i64]
    key_current_states: [bool]
    key_previous_codes: [i64]
    key_previous_states: [bool]
    # Mouse
    mouse: MouseState
    mouse_prev_left: bool
    mouse_prev_right: bool
    mouse_prev_middle: bool
    mouse_cur_left: bool
    mouse_cur_right: bool
    mouse_cur_middle: bool
    # Action bindings: parallel arrays
    action_names: [text]
    action_bindings: [ActionBinding]
    # Signals
    on_key_pressed: Signal
    on_key_released: Signal
    on_action_pressed: Signal
    on_action_released: Signal
    # Window close requested
    should_close: bool

impl InputManager:
    static fn create(event_loop_handle: i64) -> InputManager:
        """Initialize InputManager with event loop handle and fresh gamepad context."""
        InputManager(
            event_loop_handle: event_loop_handle,
            gamepad_ctx: 0,
            key_current_codes: [],
            key_current_states: [],
            key_previous_codes: [],
            key_previous_states: [],
            mouse: MouseState.initial(),
            mouse_prev_left: false,
            mouse_prev_right: false,
            mouse_prev_middle: false,
            mouse_cur_left: false,
            mouse_cur_right: false,
            mouse_cur_middle: false,
            action_names: [],
            action_bindings: [],
            on_key_pressed: Signal(name: "on_key_pressed", connections: [], next_id: 0, enabled: true),
            on_key_released: Signal(name: "on_key_released", connections: [], next_id: 0, enabled: true),
            on_action_pressed: Signal(name: "on_action_pressed", connections: [], next_id: 0, enabled: true),
            on_action_released: Signal(name: "on_action_released", connections: [], next_id: 0, enabled: true),
            should_close: false
        )

    # ------------------------------------------------------------------
    # Internal: set a key's current pressed state in the parallel arrays
    # ------------------------------------------------------------------
    me _set_key_state(keycode: i64, pressed: bool):
        var i = 0
        while i < self.key_current_codes.len():
            if self.key_current_codes[i] == keycode:
                self.key_current_states[i] = pressed
                return
            i = i + 1
        # Not found — add new entry
        self.key_current_codes.push(keycode)
        self.key_current_states.push(pressed)

    # ------------------------------------------------------------------
    # Internal: look up a key's state in specified parallel arrays
    # ------------------------------------------------------------------
    fn _get_key_in(codes: [i64], states: [bool], keycode: i64) -> bool:
        var i = 0
        while i < codes.len():
            if codes[i] == keycode:
                return states[i]
            i = i + 1
        false

    # ------------------------------------------------------------------
    # Internal: snapshot current key states into previous
    # ------------------------------------------------------------------
    me _snapshot_keys():
        self.key_previous_codes = []
        self.key_previous_states = []
        var i = 0
        while i < self.key_current_codes.len():
            self.key_previous_codes.push(self.key_current_codes[i])
            self.key_previous_states.push(self.key_current_states[i])
            i = i + 1

    # ------------------------------------------------------------------
    # Poll: process all pending window + gamepad events for this frame
    # ------------------------------------------------------------------
    me poll():
        # Snapshot previous frame state
        self._snapshot_keys()
        self.mouse_prev_left = self.mouse_cur_left
        self.mouse_prev_right = self.mouse_cur_right
        self.mouse_prev_middle = self.mouse_cur_middle

        # Reset per-frame deltas
        self.mouse.delta_x = 0.0
        self.mouse.delta_y = 0.0
        self.mouse.wheel_x = 0.0
        self.mouse.wheel_y = 0.0

        # Drain the full queue one event at a time to avoid dropping
        # same-frame input bursts behind an opaque batch handle.
        var event_handle = rt_winit_event_loop_poll_events(self.event_loop_handle, 1)
        while event_handle != 0:
            self._process_window_events(event_handle)
            event_handle = rt_winit_event_loop_poll_events(self.event_loop_handle, 1)

        # Compute mouse button states from current vs previous
        self.mouse.left = _compute_button_state(self.mouse_cur_left, self.mouse_prev_left)
        self.mouse.right = _compute_button_state(self.mouse_cur_right, self.mouse_prev_right)
        self.mouse.middle = _compute_button_state(self.mouse_cur_middle, self.mouse_prev_middle)

        # Emit action signals
        self._emit_action_signals()

    # ------------------------------------------------------------------
    # Internal: process a batch of window events
    # ------------------------------------------------------------------
    me _process_window_events(batch_handle: i64):
        # Process events from the batch
        # Event type codes: 3=WindowCloseRequested, 10=KeyboardInput,
        # 20=MouseButton, 21=MouseMoved, 22=MouseWheel
        var event_handle = batch_handle
        if event_handle == 0:
            return

        val event_type = rt_winit_event_get_type(event_handle)

        # Close requested
        if event_type == 3:
            self.should_close = true

        # Keyboard input
        if event_type == 10:
            val kb_result = rt_winit_event_keyboard_input(event_handle)
            val keycode = kb_result.1
            val pressed = kb_result.2
            self._set_key_state(keycode, pressed)

            # Emit keyboard signals
            if pressed:
                self.on_key_pressed.emit("{keycode}")
            else:
                self.on_key_released.emit("{keycode}")

        # Mouse button
        if event_type == 20:
            val mb_result = rt_winit_event_mouse_button(event_handle)
            val button_code = mb_result.0
            val mb_pressed = mb_result.1
            if button_code == 0:
                self.mouse_cur_left = mb_pressed
            elif button_code == 1:
                self.mouse_cur_right = mb_pressed
            elif button_code == 2:
                self.mouse_cur_middle = mb_pressed

        # Mouse moved
        if event_type == 21:
            val pos = rt_winit_event_mouse_moved(event_handle)
            self.mouse.delta_x = pos.0 - self.mouse.x
            self.mouse.delta_y = pos.1 - self.mouse.y
            self.mouse.x = pos.0
            self.mouse.y = pos.1

        # Mouse wheel
        if event_type == 22:
            val wheel = rt_winit_event_mouse_wheel(event_handle)
            self.mouse.wheel_x = wheel.0
            self.mouse.wheel_y = wheel.1

        rt_winit_event_free(event_handle)

    # ------------------------------------------------------------------
    # Internal: process pending gamepad events
    # ------------------------------------------------------------------
    me _process_gamepad_events():
        # Gamepad support is intentionally disconnected until the new engine
        # has a working end-to-end runtime path. Keyboard/mouse remain live.
        ()

    # ------------------------------------------------------------------
    # Internal: check action transitions and emit signals
    # ------------------------------------------------------------------
    me _emit_action_signals():
        var i = 0
        while i < self.action_names.len():
            val name = self.action_names[i]
            val binding = self.action_bindings[i]

            val was_pressed = self._was_action_pressed(binding)
            val now_pressed = self._is_action_currently_pressed(binding)

            if now_pressed and not was_pressed:
                self.on_action_pressed.emit(name)
            elif not now_pressed and was_pressed:
                self.on_action_released.emit(name)

            i = i + 1

    # ------------------------------------------------------------------
    # Internal: check if action was pressed in previous frame
    # ------------------------------------------------------------------
    fn _was_action_pressed(binding: ActionBinding) -> bool:
        # Check keys
        var k = 0
        while k < binding.key_codes.len():
            val kc = binding.key_codes[k].code
            if self._get_key_in(self.key_previous_codes, self.key_previous_states, kc):
                return true
            k = k + 1
        # Check mouse buttons
        var m = 0
        while m < binding.mouse_buttons.len():
            val mb = binding.mouse_buttons[m].code
            if mb == 0 and self.mouse_prev_left:
                return true
            if mb == 1 and self.mouse_prev_right:
                return true
            if mb == 2 and self.mouse_prev_middle:
                return true
            m = m + 1
        false

    # ------------------------------------------------------------------
    # Internal: check if action is pressed in current frame
    # ------------------------------------------------------------------
    fn _is_action_currently_pressed(binding: ActionBinding) -> bool:
        # Check keys
        var k = 0
        while k < binding.key_codes.len():
            val kc = binding.key_codes[k].code
            if self._get_key_in(self.key_current_codes, self.key_current_states, kc):
                return true
            k = k + 1
        # Check mouse buttons
        var m = 0
        while m < binding.mouse_buttons.len():
            val mb = binding.mouse_buttons[m].code
            if mb == 0 and self.mouse_cur_left:
                return true
            if mb == 1 and self.mouse_cur_right:
                return true
            if mb == 2 and self.mouse_cur_middle:
                return true
            m = m + 1
        false

    # ==================================================================
    # Action Bindings API
    # ==================================================================

    me bind_action(name: text, binding: ActionBinding):
        """Register a named action with its input binding."""
        # Replace if already exists
        var i = 0
        while i < self.action_names.len():
            if self.action_names[i] == name:
                self.action_bindings[i] = binding
                return
            i = i + 1
        self.action_names.push(name)
        self.action_bindings.push(binding)

    me bind_key_action(name: text, keycode: KeyCode):
        """Convenience: bind a single key to an action."""
        val binding = ActionBinding.key_only(name, keycode)
        self.bind_action(name, binding)

    me unbind_action(name: text):
        """Remove a named action binding."""
        var new_names: [text] = []
        var new_bindings: [ActionBinding] = []
        var i = 0
        while i < self.action_names.len():
            if self.action_names[i] != name:
                new_names.push(self.action_names[i])
                new_bindings.push(self.action_bindings[i])
            i = i + 1
        self.action_names = new_names
        self.action_bindings = new_bindings

    # ==================================================================
    # Key Query API
    # ==================================================================

    fn is_key_pressed(keycode: KeyCode) -> bool:
        """True if the key is currently down (JustPressed or Held)."""
        self._get_key_in(self.key_current_codes, self.key_current_states, keycode.code)

    fn is_key_just_pressed(keycode: KeyCode) -> bool:
        """True only on the frame the key transitioned to pressed."""
        val current = self._get_key_in(self.key_current_codes, self.key_current_states, keycode.code)
        val previous = self._get_key_in(self.key_previous_codes, self.key_previous_states, keycode.code)
        current and not previous

    fn is_key_just_released(keycode: KeyCode) -> bool:
        """True only on the frame the key transitioned to released."""
        val current = self._get_key_in(self.key_current_codes, self.key_current_states, keycode.code)
        val previous = self._get_key_in(self.key_previous_codes, self.key_previous_states, keycode.code)
        not current and previous

    # ==================================================================
    # Action Query API
    # ==================================================================

    fn _find_action_binding(name: text) -> ActionBinding?:
        var i = 0
        while i < self.action_names.len():
            if self.action_names[i] == name:
                return self.action_bindings[i]
            i = i + 1
        nil

    fn is_action_pressed(name: text) -> bool:
        """True if any input source for this action is currently pressed."""
        if val Some(binding) = self._find_action_binding(name):
            return self._is_action_currently_pressed(binding)
        false

    fn is_action_just_pressed(name: text) -> bool:
        """True only on the frame the action transitioned to pressed."""
        if val Some(binding) = self._find_action_binding(name):
            val was = self._was_action_pressed(binding)
            val now = self._is_action_currently_pressed(binding)
            return now and not was
        false

    fn is_action_just_released(name: text) -> bool:
        """True only on the frame the action transitioned to released."""
        if val Some(binding) = self._find_action_binding(name):
            val was = self._was_action_pressed(binding)
            val now = self._is_action_currently_pressed(binding)
            return not now and was
        false

    fn get_action_strength(name: text) -> f64:
        """Return 1.0 if action is pressed, 0.0 otherwise."""
        if self.is_action_pressed(name):
            1.0
        else:
            0.0

    # ==================================================================
    # Mouse Query API
    # ==================================================================

    fn get_mouse() -> MouseState:
        """Return current mouse state snapshot."""
        self.mouse

    fn is_mouse_pressed(button: MouseButtonId) -> bool:
        """Check if a mouse button is currently pressed (0=left, 1=right, 2=middle)."""
        if button.code == 0:
            self.mouse.left.is_pressed()
        elif button.code == 1:
            self.mouse.right.is_pressed()
        elif button.code == 2:
            self.mouse.middle.is_pressed()
        else:
            false

    # ==================================================================
    # Window API
    # ==================================================================

    fn window_should_close() -> bool:
        """True if the window close was requested."""
        self.should_close

    # ==================================================================
    # Lifecycle
    # ==================================================================

    me destroy():
        """Shutdown gamepad context and clean up resources."""
        self.on_key_pressed.disconnect_all()
        self.on_key_released.disconnect_all()
        self.on_action_pressed.disconnect_all()
        self.on_action_released.disconnect_all()
