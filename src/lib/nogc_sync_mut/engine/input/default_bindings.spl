# Input System — Default Bindings
#
# Preset action bindings for common game input patterns.
# Call these helpers after creating an InputManager to get sensible defaults.

use std.nogc_sync_mut.engine.input.types.{ActionBinding}
use std.nogc_sync_mut.engine.input.input_manager.{InputManager}

# ============================================================================
# WASD + Arrow Key Movement
# ============================================================================

fn bind_wasd_movement(mgr: InputManager):
    """Bind move_up/down/left/right to WASD and arrow keys.

    Keycodes: W=87, A=65, S=83, D=68, Up=38, Down=40, Left=37, Right=39
    """
    val up = ActionBinding(
        action_name: "move_up",
        key_codes: [87, 38],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    val down = ActionBinding(
        action_name: "move_down",
        key_codes: [83, 40],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    val left = ActionBinding(
        action_name: "move_left",
        key_codes: [65, 37],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    val right = ActionBinding(
        action_name: "move_right",
        key_codes: [68, 39],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    mgr.bind_action("move_up", up)
    mgr.bind_action("move_down", down)
    mgr.bind_action("move_left", left)
    mgr.bind_action("move_right", right)

# ============================================================================
# Platformer Defaults
# ============================================================================

fn bind_platformer_defaults(mgr: InputManager):
    """Bind jump (Space), move_left (A/Left), move_right (D/Right).

    Keycodes: Space=32, A=65, D=68, Left=37, Right=39
    """
    val jump = ActionBinding(
        action_name: "jump",
        key_codes: [32],
        mouse_buttons: [],
        gamepad_buttons: [0],   # Gamepad South (A/Cross)
        deadzone: 0.15
    )
    val left = ActionBinding(
        action_name: "move_left",
        key_codes: [65, 37],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    val right = ActionBinding(
        action_name: "move_right",
        key_codes: [68, 39],
        mouse_buttons: [],
        gamepad_buttons: [],
        deadzone: 0.15
    )
    mgr.bind_action("jump", jump)
    mgr.bind_action("move_left", left)
    mgr.bind_action("move_right", right)

# ============================================================================
# Common UI Actions
# ============================================================================

fn bind_common_actions(mgr: InputManager):
    """Bind confirm (Enter/Space) and cancel (Escape).

    Keycodes: Enter=13, Space=32, Escape=27
    """
    val confirm = ActionBinding(
        action_name: "confirm",
        key_codes: [13, 32],
        mouse_buttons: [],
        gamepad_buttons: [0],   # Gamepad South (A/Cross)
        deadzone: 0.15
    )
    val cancel = ActionBinding(
        action_name: "cancel",
        key_codes: [27],
        mouse_buttons: [],
        gamepad_buttons: [1],   # Gamepad East (B/Circle)
        deadzone: 0.15
    )
    mgr.bind_action("confirm", confirm)
    mgr.bind_action("cancel", cancel)
