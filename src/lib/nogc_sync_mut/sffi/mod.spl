# SFFI - Centralized Foreign Function Interface
#
# All extern fn declarations and wrappers live in this module hierarchy.
# This eliminates scattered SFFI calls and provides a single source of truth.
#
# Structure:
# - io.spl: File, directory, path operations (~50 functions)
# - system.spl: Environment, process, time (~34 functions)
# - codegen.spl: Cranelift backend (JIT/AOT) (~24 functions)
# - cli.spl: CLI command delegation (~39 functions)
# - runtime.spl: RuntimeValue operations (~29 functions)
# - ast.spl: AST operations (~29 functions)
# - debug.spl: Debug, ptrace, dwarf (~28 functions)
# - package.spl: Package, cargo, build (~19 functions)
# - error.spl: Error handling (~9 functions)
# - coverage.spl: Coverage instrumentation (~3 functions)
#
# Usage:
#   use std.sffi.io*          # Import all I/O functions
#   use std.sffi.system*      # Import all system functions
#   use std.sffi*             # Import everything
#
# Two-Tier Pattern:
#   extern fn rt_file_exists(path: text) -> bool  # Tier 1: Raw SFFI
#   fn file_exists(path: text) -> bool:           # Tier 2: Wrapper
#       rt_file_exists(path)

# Re-export all submodules for convenience
