# spl_fonts Typed Wrapper (SFFI — Phase 2)
#
# Typed Simple facade over the `libspl_fonts` native dynamic library
# (see src/compiler_rust/spl_fonts). Wraps the C ABI entry points:
#
#   rt_fonts_init(path_ptr: i64, path_len: i64) -> i64
#   rt_fonts_rasterize_glyph(codepoint: i64, font_size_px: i64) -> i64
#   rt_fonts_rasterize_glyph_subpixel(codepoint: i64, font_size_px: i64) -> i64
#   rt_fonts_glyph_metric(handle: i64, field: i64) -> i64
#   rt_fonts_glyph_pixels_ptr/len(handle: i64) -> i64
#   rt_fonts_glyph_free(handle: i64) -> i64
#   rt_fonts_has_glyph(codepoint: i64) -> i64
#   rt_fonts_generation() -> i64
#   rt_fonts_glyph_pixel(handle: i64, x: i64, y: i64) -> i64
#   rt_fonts_glyph_subpixel_pixel(handle: i64, x: i64, y: i64, channel: i64) -> i64
#   rt_fonts_horizontal_kern(left: i64, right: i64, size_px: i64) -> i64
#   rt_fonts_horizontal_line_metric(size_px: i64, field: i64) -> i64
#   rt_fonts_layout_text(text_ptr: i64, text_len: i64, size_px: i64, max_width: i64) -> i64
#   rt_fonts_layout_glyph_metric(index: i64, field: i64) -> i64
#
# Owner invariants (internal model is one process-global face/layout slot):
#   - rasterization returns an owned glyph handle, copied and freed here
#   - successful face selection advances generation for cache invalidation
#   - Metric fields: 0=width, 1=height, 2=advance, 3=bearing_x,
#     4=fontdue bitmap ymin/bottom offset. The legacy Simple field is named
#     bearing_y; layout_text() positions already expose top-y for PositiveYDown.
#   - Pixel reads return alpha in 0..255
#
# Intentionally does NOT depend on DynLib — under the Rust seed interpreter,
# DynLib.unwrap method lookup is broken. Raw spl_dlopen/spl_dlsym only.
# Phase 4 cleanup: once DynLib works in interpreter mode, refactor to reuse.
#
# FontRenderer integrates this owner as its selected TTF path and falls back to
# the built-in vector/bitmap renderers for unsupported glyphs.

use std.nogc_sync_mut.sffi.io.{file_read_bytes}
use std.common.encoding.sfnt.{font_runtime_ttf_default_supported, parse_offset_table}
use std.common.encoding.sfnt_cmap.{sfnt_cmap_glyph_id}
use std.common.encoding.sfnt_glyf.{rasterize_sfnt_glyf}
use std.common.encoding.font_registry.{selected_font_asset_candidate_for_path, validate_selected_font_asset, load_selected_font_file}
#
# Usage:
#   val maybe = FontRasterizer.load("build/libspl_fonts.dylib",
#                                   "/System/Library/Fonts/Supplemental/Arial.ttf")
#   match maybe:
#     case Some(fr):
#       val mg = fr.rasterize(65, 16)   # 'A' at 16px
#       match mg:
#         case Some(g):
#           print("width={g.width} height={g.height} advance={g.advance}")
#           val a = g.alpha_at(5, 5)
#         case None:
#           pass
#     case None:
#       pass

# ============================================================================
# Raw SFFI externs (interpreter + native both provide these)
# ============================================================================

extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_dlclose(handle: i64) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64
extern fn rt_bytes_from_raw(ptr: i64, len: i64) -> [u8]
extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_array_data_ptr_u8(bytes: [u8]) -> i64

# ============================================================================
# GlyphBitmap — metrics + an owned snapshot of the glyph pixel coverage
# ============================================================================
#
# Phase 3a: GlyphBitmap owns its pixel data. `rasterize()` eagerly copies
# width*height alpha samples out of the dylib's single-slot buffer into
# `pixels` before returning, so subsequent rasterize calls cannot silently
# clobber this glyph's bitmap. `handle` is retained only for diagnostics.

class GlyphBitmap:
    width: i64
    height: i64
    advance: i64
    bearing_x: i64
    bearing_y: i64
    handle: i64
    pixels: [u8]

impl GlyphBitmap:
    # Alpha coverage (0..255) at pixel (x,y) in the rasterized glyph.
    # Out-of-bounds coordinates return 0 (no panic, no dylib round-trip).
    fn alpha_at(x: i64, y: i64) -> i64:
        if x < 0 or y < 0:
            return 0
        if x >= self.width or y >= self.height:
            return 0
        val idx = y * self.width + x
        self.pixels[idx].to_i64()

class LayoutGlyph:
    codepoint: i64
    x: i64
    y: i64
    width: i64
    height: i64
    byte_offset: i64

class SubpixelGlyphBitmap:
    width: i64
    height: i64
    advance: i64
    bearing_x: i64
    bearing_y: i64
    handle: i64
    pixels: [i64]  # RGB triplets, row-major

impl SubpixelGlyphBitmap:
    fn coverage_at(x: i64, y: i64, channel: i64) -> i64:
        if x < 0 or y < 0 or channel < 0 or channel > 2:
            return 0
        if x >= self.width or y >= self.height:
            return 0
        val idx = y * self.width * 3 + x * 3 + channel
        self.pixels[idx]

# ============================================================================
# FontRasterizer — holds the dylib handle + cached symbol pointers for a
# single loaded TTF/OTF file.
# ============================================================================

class FontRasterizer:
    lib_handle: i64
    init_fp: i64
    raster_fp: i64
    subpixel_raster_fp: i64
    metric_fp: i64
    pixel_fp: i64
    subpixel_pixel_fp: i64
    kern_fp: i64
    line_metric_fp: i64
    layout_fp: i64
    layout_glyph_metric_fp: i64
    glyph_pixels_ptr_fp: i64
    glyph_pixels_len_fp: i64
    glyph_free_fp: i64
    has_glyph_fp: i64
    generation_fp: i64
    font_path: text
    dylib_path: text
    font_cache_identity: text
    loaded_generation: i64
    selected_blob: [u8]

impl FontRasterizer:
    static fn load_selected(ttf_path: text) -> FontRasterizer?:
        if selected_font_asset_candidate_for_path(ttf_path) == nil:
            return nil
        val loaded = load_selected_font_file(ttf_path)
        if not loaded.1.valid:
            return nil
        FontRasterizer._load_selected_bytes(ttf_path, loaded.0, true)

    static fn load_selected_bytes(ttf_path: text, blob: [u8]) -> FontRasterizer?:
        FontRasterizer._load_selected_bytes(ttf_path, blob, false)

    static fn _load_selected_bytes(ttf_path: text, blob: [u8], file_backed: bool) -> FontRasterizer?:
        val selected = selected_font_asset_candidate_for_path(ttf_path)
        if selected == nil:
            return nil
        val candidate = selected.?
        if not file_backed and not validate_selected_font_asset(ttf_path, blob).valid:
            return nil
        if not font_runtime_ttf_default_supported(blob):
            return nil
        FontRasterizer(
            lib_handle: 0, init_fp: 0, raster_fp: 0, subpixel_raster_fp: 0,
            metric_fp: 0, pixel_fp: 0, subpixel_pixel_fp: 0, kern_fp: 0,
            line_metric_fp: 0, layout_fp: 0, layout_glyph_metric_fp: 0,
            glyph_pixels_ptr_fp: 0, glyph_pixels_len_fp: 0, glyph_free_fp: 0,
            has_glyph_fp: 0, generation_fp: 0, font_path: ttf_path,
            dylib_path: "", font_cache_identity: "sha256={candidate.sha256};axes={candidate.default_axes}",
            loaded_generation: 1, selected_blob: blob,
        )

    # Load libspl_fonts from `dylib_path` and initialize it with the TTF at
    # `ttf_path`. Returns nil on any failure (dylib missing, symbol missing,
    # font file unreadable, font parse error).
    #
    # Selected assets initialize from this owned blob; unmanaged font paths are
    # marshalled as UTF-8 bytes for the legacy native initializer.
    static fn load(dylib_path: text, ttf_path: text) -> FontRasterizer?:
        val selected = selected_font_asset_candidate_for_path(ttf_path)
        val blob = if selected != nil:
            val loaded = load_selected_font_file(ttf_path)
            if not loaded.1.valid:
                return nil
            loaded.0
        else:
            file_read_bytes(ttf_path)
        var font_cache_identity = ""
        if val candidate = selected:
            font_cache_identity = "sha256={candidate.sha256};axes={candidate.default_axes}"
        if not font_runtime_ttf_default_supported(blob):
            return nil
        val h = spl_dlopen(dylib_path)
        if h == 0:
            return nil
        val init_fp = if selected != nil:
            spl_dlsym(h, "rt_fonts_init_verified_bytes")
        else:
            spl_dlsym(h, "rt_fonts_init")
        val raster_fp = if selected != nil:
            spl_dlsym(h, "rt_fonts_rasterize_glyph_native_only")
        else:
            spl_dlsym(h, "rt_fonts_rasterize_glyph")
        val subpixel_raster_fp = spl_dlsym(h, "rt_fonts_rasterize_glyph_subpixel")
        val metric_fp = spl_dlsym(h, "rt_fonts_glyph_metric")
        val pixel_fp = spl_dlsym(h, "rt_fonts_glyph_pixel")
        val subpixel_pixel_fp = spl_dlsym(h, "rt_fonts_glyph_subpixel_pixel")
        val kern_fp = spl_dlsym(h, "rt_fonts_horizontal_kern")
        val line_metric_fp = spl_dlsym(h, "rt_fonts_horizontal_line_metric")
        val layout_fp = spl_dlsym(h, "rt_fonts_layout_text")
        val layout_glyph_metric_fp = spl_dlsym(h, "rt_fonts_layout_glyph_metric")
        val glyph_pixels_ptr_fp = spl_dlsym(h, "rt_fonts_glyph_pixels_ptr")
        val glyph_pixels_len_fp = spl_dlsym(h, "rt_fonts_glyph_pixels_len")
        val glyph_free_fp = spl_dlsym(h, "rt_fonts_glyph_free")
        val has_glyph_fp = spl_dlsym(h, "rt_fonts_has_glyph")
        val generation_fp = spl_dlsym(h, "rt_fonts_generation")
        if init_fp == 0 or raster_fp == 0 or metric_fp == 0 or pixel_fp == 0 or glyph_pixels_ptr_fp == 0 or glyph_pixels_len_fp == 0 or glyph_free_fp == 0 or has_glyph_fp == 0 or generation_fp == 0:
            spl_dlclose(h)
            return nil
        var init_args: [i64] = []
        var rc = 0
        if val candidate = selected:
            val expected_digest_bytes = rt_text_to_bytes(candidate.sha256)
            init_args.push(rt_array_data_ptr_u8(blob))
            init_args.push(blob.len())
            init_args.push(rt_array_data_ptr_u8(expected_digest_bytes))
            init_args.push(expected_digest_bytes.len())
            rc = spl_wffi_call_i64(init_fp, init_args, 4)
        else:
            val path_bytes = rt_text_to_bytes(ttf_path)
            init_args.push(rt_array_data_ptr_u8(path_bytes))
            init_args.push(path_bytes.len())
            rc = spl_wffi_call_i64(init_fp, init_args, 2)
        if rc != 1:
            spl_dlclose(h)
            return nil
        var generation_args: [i64] = []
        val loaded_generation = spl_wffi_call_i64(generation_fp, generation_args, 0)
        if loaded_generation <= 0:
            spl_dlclose(h)
            return nil
        FontRasterizer(
            lib_handle: h,
            init_fp: init_fp,
            raster_fp: raster_fp,
            subpixel_raster_fp: subpixel_raster_fp,
            metric_fp: metric_fp,
            pixel_fp: pixel_fp,
            subpixel_pixel_fp: subpixel_pixel_fp,
            kern_fp: kern_fp,
            line_metric_fp: line_metric_fp,
            layout_fp: layout_fp,
            layout_glyph_metric_fp: layout_glyph_metric_fp,
            glyph_pixels_ptr_fp: glyph_pixels_ptr_fp,
            glyph_pixels_len_fp: glyph_pixels_len_fp,
            glyph_free_fp: glyph_free_fp,
            has_glyph_fp: has_glyph_fp,
            generation_fp: generation_fp,
            font_path: ttf_path,
            dylib_path: dylib_path,
            font_cache_identity: font_cache_identity,
            loaded_generation: loaded_generation,
            selected_blob: if selected != nil: blob else: [],
        )

    # Internal: read a single metric field for the active glyph handle.
    fn _metric(handle: i64, field: i64) -> i64:
        var args: [i64] = []
        args.push(handle)
        args.push(field)
        spl_wffi_call_i64(self.metric_fp, args, 2)

    fn _free_glyph(handle: i64):
        var args: [i64] = []
        args.push(handle)
        spl_wffi_call_i64(self.glyph_free_fp, args, 1)

    fn _rasterize_selected_outline(codepoint: i64, size_px: i64) -> GlyphBitmap?:
        if self.selected_blob.len() == 0 or codepoint < 0 or codepoint > 1114111 or size_px <= 0:
            return nil
        if val font = parse_offset_table(self.selected_blob):
            val glyph_id = sfnt_cmap_glyph_id(font, codepoint as u32)
            if glyph_id == 0:
                return nil
            if val bitmap = rasterize_sfnt_glyf(font, glyph_id, size_px):
                if not self.is_current():
                    return nil
                return GlyphBitmap(
                    width: bitmap.width,
                    height: bitmap.height,
                    advance: bitmap.advance,
                    bearing_x: bitmap.bearing_x,
                    bearing_y: bitmap.bearing_y,
                    handle: 0,
                    pixels: bitmap.pixels,
                )
        nil

    # Rasterize the given Unicode codepoint at the given pixel size.
    # Returns a GlyphBitmap with metrics and an OWNED pixel snapshot, or nil
    # on failure (invalid codepoint, non-positive size, not yet initialized).
    #
    # Phase 3a: even though the Phase 1 dylib still uses a single global
    # glyph slot, we eagerly copy the entire w*h alpha buffer into the
    # returned GlyphBitmap. Subsequent rasterize calls clobber the dylib
    # slot but leave previously returned GlyphBitmaps untouched, so callers
    # can safely interleave rasterize/read. A 0x0 glyph (whitespace) still
    # yields a valid GlyphBitmap with an empty `pixels` array.
    fn rasterize(codepoint: i64, size_px: i64) -> GlyphBitmap?:
        if not self.is_current():
            return nil
        if self.lib_handle == 0:
            return self._rasterize_selected_outline(codepoint, size_px)
        var args: [i64] = []
        args.push(codepoint)
        args.push(size_px)
        val handle = spl_wffi_call_i64(self.raster_fp, args, 2)
        if handle < 0:
            return nil
        if handle == 0:
            if not self.is_current():
                return nil
            return self._rasterize_selected_outline(codepoint, size_px)
        val w = self._metric(handle, 0)
        val h = self._metric(handle, 1)
        val adv = self._metric(handle, 2)
        val bx = self._metric(handle, 3)
        val by = self._metric(handle, 4)
        # Eagerly copy the glyph slot's alpha buffer into an owned array
        # so it cannot be aliased out from under the caller by a later
        # rasterize() that overwrites the global slot in the dylib.
        var pixel_args: [i64] = []
        pixel_args.push(handle)
        val pixel_ptr = spl_wffi_call_i64(self.glyph_pixels_ptr_fp, pixel_args, 1)
        val pixel_len = spl_wffi_call_i64(self.glyph_pixels_len_fp, pixel_args, 1)
        if pixel_ptr == 0 or pixel_len != w * h:
            self._free_glyph(handle)
            return nil
        val pixels = rt_bytes_from_raw(pixel_ptr, pixel_len)
        self._free_glyph(handle)
        if not self.is_current():
            return nil
        GlyphBitmap(
            width: w,
            height: h,
            advance: adv,
            bearing_x: bx,
            bearing_y: by,
            handle: 0,
            pixels: pixels,
        )

    # Rasterize a producer-shaped glyph ID from this exact selected face.
    # The result owns its pixels and never exposes the selected face handle.
    fn rasterize_glyph_index(glyph_index: i64, size_px: i64) -> GlyphBitmap?:
        if (not self.is_current() or self.selected_blob.len() == 0 or
            glyph_index <= 0 or glyph_index > 4294967295 or size_px <= 0 or size_px > 512):
            return nil
        if val font = parse_offset_table(self.selected_blob):
            if val bitmap = rasterize_sfnt_glyf(font, glyph_index as u32, size_px):
                if not self.is_current():
                    return nil
                return GlyphBitmap(
                    width: bitmap.width,
                    height: bitmap.height,
                    advance: bitmap.advance,
                    bearing_x: bitmap.bearing_x,
                    bearing_y: bitmap.bearing_y,
                    handle: 0,
                    pixels: bitmap.pixels,
                )
        nil

    fn has_glyph(codepoint: i64) -> bool:
        if not self.is_current():
            return false
        if self.lib_handle == 0:
            if val font = parse_offset_table(self.selected_blob):
                return sfnt_cmap_glyph_id(font, codepoint as u32) != 0
            return false
        var args: [i64] = []
        args.push(codepoint)
        val present = spl_wffi_call_i64(self.has_glyph_fp, args, 1) == 1
        present and self.is_current()

    fn generation() -> i64:
        if self.lib_handle == 0:
            return self.loaded_generation
        var args: [i64] = []
        spl_wffi_call_i64(self.generation_fp, args, 0)

    fn cache_identity_snapshot() -> (i64, text):
        if self.loaded_generation <= 0:
            return (0, "")
        if self.lib_handle == 0:
            if self.selected_blob.len() == 0:
                return (0, "")
            return (self.loaded_generation, self.font_cache_identity)
        if self.generation_fp == 0:
            return (0, "")
        val generation_before = self.generation()
        if generation_before != self.loaded_generation:
            return (0, "")
        val identity = self.font_cache_identity
        val generation_after = self.generation()
        if generation_after != generation_before or generation_after != self.loaded_generation:
            return (0, "")
        (generation_after, identity)

    fn is_current() -> bool:
        self.cache_identity_snapshot().0 > 0

    fn cache_identity() -> text:
        self.cache_identity_snapshot().1

    fn rasterize_subpixel(codepoint: i64, size_px: i64) -> SubpixelGlyphBitmap?:
        if not self.is_current() or self.subpixel_raster_fp == 0 or self.subpixel_pixel_fp == 0:
            return nil
        var args: [i64] = []
        args.push(codepoint)
        args.push(size_px)
        val handle = spl_wffi_call_i64(self.subpixel_raster_fp, args, 2)
        if handle <= 0:
            return nil
        val w = self._metric(handle, 0)
        val h = self._metric(handle, 1)
        val adv = self._metric(handle, 2)
        val bx = self._metric(handle, 3)
        val by = self._metric(handle, 4)
        var pixels: [i64] = []
        var y: i64 = 0
        while y < h:
            var x: i64 = 0
            while x < w:
                var channel: i64 = 0
                while channel < 3:
                    var pa: [i64] = []
                    pa.push(handle)
                    pa.push(x)
                    pa.push(y)
                    pa.push(channel)
                    pixels.push(spl_wffi_call_i64(self.subpixel_pixel_fp, pa, 4))
                    channel = channel + 1
                x = x + 1
            y = y + 1
        self._free_glyph(handle)
        if not self.is_current():
            return nil
        SubpixelGlyphBitmap(
            width: w,
            height: h,
            advance: adv,
            bearing_x: bx,
            bearing_y: by,
            handle: 0,
            pixels: pixels,
        )

    fn horizontal_kern(left_codepoint: i64, right_codepoint: i64, size_px: i64) -> i64:
        if not self.is_current() or self.kern_fp == 0:
            return 0
        var args: [i64] = []
        args.push(left_codepoint)
        args.push(right_codepoint)
        args.push(size_px)
        val result = spl_wffi_call_i64(self.kern_fp, args, 3)
        if self.is_current(): result else: 0

    fn horizontal_line_metric(size_px: i64, field: i64) -> i64:
        if not self.is_current() or self.line_metric_fp == 0:
            return 0
        var args: [i64] = []
        args.push(size_px)
        args.push(field)
        val result = spl_wffi_call_i64(self.line_metric_fp, args, 2)
        if self.is_current(): result else: 0

    fn layout_text(text_val: text, size_px: i64, max_width: i64) -> [LayoutGlyph]:
        if not self.is_current() or self.layout_fp == 0 or self.layout_glyph_metric_fp == 0:
            return []
        val text_bytes = rt_text_to_bytes(text_val)
        var args: [i64] = []
        args.push(rt_array_data_ptr_u8(text_bytes))
        args.push(text_bytes.len())
        args.push(size_px)
        args.push(max_width)
        val count = spl_wffi_call_i64(self.layout_fp, args, 4)
        if count <= 0:
            return []
        var glyphs: [LayoutGlyph] = []
        var idx: i64 = 0
        while idx < count:
            glyphs.push(LayoutGlyph(
                codepoint: self._layout_metric(idx, 0),
                x: self._layout_metric(idx, 1),
                y: self._layout_metric(idx, 2),
                width: self._layout_metric(idx, 3),
                height: self._layout_metric(idx, 4),
                byte_offset: self._layout_metric(idx, 5),
            ))
            idx = idx + 1
        if self.is_current(): glyphs else: []

    fn _layout_metric(index: i64, field: i64) -> i64:
        var args: [i64] = []
        args.push(index)
        args.push(field)
        spl_wffi_call_i64(self.layout_glyph_metric_fp, args, 2)

    # Release the dynamic library handle. The typed wrapper becomes unusable
    # after this call. Returns 0 on success (matching libc dlclose).
    me close() -> i64:
        val rc = if self.lib_handle == 0: 0 else: spl_dlclose(self.lib_handle)
        self.lib_handle = 0
        self.init_fp = 0
        self.raster_fp = 0
        self.subpixel_raster_fp = 0
        self.metric_fp = 0
        self.pixel_fp = 0
        self.subpixel_pixel_fp = 0
        self.kern_fp = 0
        self.line_metric_fp = 0
        self.layout_fp = 0
        self.layout_glyph_metric_fp = 0
        self.glyph_pixels_ptr_fp = 0
        self.glyph_pixels_len_fp = 0
        self.glyph_free_fp = 0
        self.has_glyph_fp = 0
        self.generation_fp = 0
        self.loaded_generation = 0
        self.selected_blob = []
        rc
