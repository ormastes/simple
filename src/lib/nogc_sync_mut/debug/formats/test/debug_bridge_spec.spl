fn _build_line() -> [u8]:
    var b: [u8] = []
    b = b.push(0x2b)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x03)
    b = b.push(0x00)
    b = b.push(0x13)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0xfb)
    b = b.push(0x0e)
    b = b.push(0x0d)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x05)
    b = b.push(0x02)
    b = b.push(0x00)
    b = b.push(0x10)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x03)
    b = b.push(0x09)
    b = b.push(0x01)
    b = b.push(0x02)
    b = b.push(0x20)
    b = b.push(0x03)
    b = b.push(0x0a)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b

fn _make_parser() -> DwarfParser:
    val sections = DwarfSections(
        debug_info: _build_info(),
        debug_abbrev: _build_abbrev(),
        debug_line: _build_line(),
        debug_str: [],
        debug_line_str: [],
        addr_size: 4,
    )
    DwarfParser.from_sections(sections).ok()!

describe "DebugInfoBridge construction":
    it "wraps a DwarfParser":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        expect(bridge.format_kind().to_string()).to_equal("DWARF")

    it "delegates addr_to_source":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1000)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(10)

    it "returns location for in-range address":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1020)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(20)

    it "delegates function_at":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val func = bridge.function_at(0x1000)
        expect(func != nil).to_equal(true)
        expect(func!.low_pc).to_equal(0x1000)

    it "function_name_at returns empty for unknown":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val name = bridge.function_name_at(0x9999)
        expect(name).to_equal("")

    it "delegates compilation_units":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val units = bridge.compilation_units()
        expect(units.len()).to_equal(1)
        expect(units[0].low_pc).to_equal(0x1000)

    it "delegates line_entries":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val entries = bridge.line_entries()
        expect(entries.len() > 0).to_equal(true)

    it "delegates locals_at":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val locals = bridge.locals_at(0x1000)
        expect(locals.len()).to_equal(0)

    it "delegates functions_in_range":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val funcs = bridge.functions_in_range(0x1000, 0x1100)
        expect(funcs.len() > 0).to_equal(true)

    it "source_to_addr delegates correctly":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1000)
        if loc != nil:
            val addr = bridge.source_to_addr(loc!.file, loc!.line)
            expect(addr != nil).to_equal(true)
