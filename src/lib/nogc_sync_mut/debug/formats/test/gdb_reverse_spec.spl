#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.protocol.gdb_mi_reverse.GdbMiReverseController
use std.nogc_sync_mut.debug.remote.feature.features.FeatureId

fn main():
    describe("GdbMiReverseController command builders"):
        it("builds record full command"):
            val cmd = GdbMiReverseController.build_record_full_cmd()
            expect(cmd).to_equal("record full")

        it("builds record stop command"):
            val cmd = GdbMiReverseController.build_record_stop_cmd()
            expect(cmd).to_equal("record stop")

        it("builds reverse step command"):
            val cmd = GdbMiReverseController.build_reverse_step_cmd()
            expect(cmd).to_equal("reverse-step")

        it("builds reverse continue command"):
            val cmd = GdbMiReverseController.build_reverse_continue_cmd()
            expect(cmd).to_equal("reverse-continue")

        it("builds reverse next command"):
            val cmd = GdbMiReverseController.build_reverse_next_cmd()
            expect(cmd).to_equal("reverse-next")

        it("builds reverse finish command"):
            val cmd = GdbMiReverseController.build_reverse_finish_cmd()
            expect(cmd).to_equal("reverse-finish")

        it("builds goto begin command"):
            val cmd = GdbMiReverseController.build_goto_begin_cmd()
            expect(cmd).to_equal("record goto begin")

        it("builds goto end command"):
            val cmd = GdbMiReverseController.build_goto_end_cmd()
            expect(cmd).to_equal("record goto end")

        it("reverse step command starts with reverse"):
            val cmd = GdbMiReverseController.build_reverse_step_cmd()
            expect(cmd).to_start_with("reverse")

        it("reverse continue command starts with reverse"):
            val cmd = GdbMiReverseController.build_reverse_continue_cmd()
            expect(cmd).to_start_with("reverse")

    describe("FeatureId reverse variants"):
        it("has ReverseStep"):
            expect(FeatureId.ReverseStep.to_string()).to_equal("ReverseStep")

        it("has ReverseContinue"):
            expect(FeatureId.ReverseContinue.to_string()).to_equal("ReverseContinue")
