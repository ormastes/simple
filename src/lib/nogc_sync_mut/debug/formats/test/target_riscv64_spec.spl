"""RISC-V 64-bit target definition specification tests."""

use std.nogc_sync_mut.debug.remote.target.riscv64.RiscV64Target
use std.nogc_sync_mut.debug.remote.types.{Architecture, Endianness}

describe "RiscV64Target":
    it "has 33 registers":
        val t = RiscV64Target.create()
        expect(t.register_count()).to_equal(33)

    it "returns correct register names":
        val t = RiscV64Target.create()
        expect(t.register_name(0)).to_equal("zero")
        expect(t.register_name(1)).to_equal("ra")
        expect(t.register_name(2)).to_equal("sp")
        expect(t.register_name(32)).to_equal("pc")
        expect(t.register_name(33)).to_equal("unknown")
        expect(t.register_name(-1)).to_equal("unknown")

    it "resolves register indices by name":
        val t = RiscV64Target.create()
        expect(t.register_index("zero")).to_equal(0)
        expect(t.register_index("ra")).to_equal(1)
        expect(t.register_index("sp")).to_equal(2)
        expect(t.register_index("pc")).to_equal(32)
        expect(t.register_index("nonexistent")).to_equal(-1)

    it "uses 8-byte register size":
        val t = RiscV64Target.create()
        expect(t.register_size(0)).to_equal(8)
        expect(t.register_size(31)).to_equal(8)

    it "reports RiscV64 architecture":
        val t = RiscV64Target.create()
        expect(t.arch().to_string()).to_equal("riscv64")
        expect(t.endianness().to_string()).to_equal("little")

    it "has correct breakpoint instruction":
        val t = RiscV64Target.create()
        val bp = t.breakpoint_instruction()
        expect(bp[0]).to_equal(0x73)
        expect(bp[1]).to_equal(0x00)
        expect(bp[2]).to_equal(0x10)
        expect(bp[3]).to_equal(0x00)

    it "has correct PC SP FP indices":
        val t = RiscV64Target.create()
        expect(t.pc_register_index()).to_equal(32)
        expect(t.sp_register_index()).to_equal(2)
        expect(t.fp_register_index()).to_equal(8)
        expect(t.return_register_index()).to_equal(10)

    it "reports correct name and calling convention":
        val t = RiscV64Target.create()
        expect(t.name()).to_equal("RISC-V64 (RV64GC)")
        val args = t.arg_registers()
        expect(args[0]).to_equal(10)
        expect(args[7]).to_equal(17)
        val saved = t.callee_saved_registers()
        expect(saved[0]).to_equal(8)
        expect(saved[11]).to_equal(27)

    it "reports debug hardware capabilities":
        val t = RiscV64Target.create()
        expect(t.hw_breakpoint_count()).to_equal(4)
        expect(t.hw_watchpoint_count()).to_equal(4)
        expect(t.supports_single_step()).to_equal(true)

    it "has correct QEMU virtual addresses":
        val t = RiscV64Target.create()
        expect(t.qemu_virt_ram_base()).to_equal(0x80000000)
        expect(t.qemu_virt_uart_base()).to_equal(0x10000000)
