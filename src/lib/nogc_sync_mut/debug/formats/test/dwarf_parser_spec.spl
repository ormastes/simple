"""DWARF parser specification tests."""

use std.debug.formats.dwarf_parser.{DwarfParser, DwarfSections}

# ============================================================================
# Helper: encode a u32 little-endian into a [u8]
# ============================================================================

fn _le_u32(value: i64) -> [u8]:
    var b: [u8] = []
    b = b.push((value % 256) as u8)
    b = b.push(((value / 256) % 256) as u8)
    b = b.push(((value / 65536) % 256) as u8)
    b = b.push(((value / 16777216) % 256) as u8)
    b

fn _le_u16(value: i64) -> [u8]:
    var b: [u8] = []
    b = b.push((value % 256) as u8)
    b = b.push(((value / 256) % 256) as u8)
    b

fn _append(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    var i = 0
    while i < src.len():
        out = out.push(src[i])
        i = i + 1
    out

fn _push_string(dst: [u8], s: text) -> [u8]:
    var out = dst
    var i = 0
    while i < s.len():
        out = out.push(s.char_code_at(i) as u8)
        i = i + 1
    out = out.push(0x00) # null terminator
    out

# ============================================================================
# Helper: build minimal .debug_abbrev
# ============================================================================
# Abbrev 1: DW_TAG_compile_unit (0x11), has_children=true
#   attrs: DW_AT_name(0x03)/DW_FORM_string(0x08),
#          DW_AT_low_pc(0x11)/DW_FORM_addr(0x01),
#          DW_AT_high_pc(0x12)/DW_FORM_data4(0x06),
#          DW_AT_stmt_list(0x10)/DW_FORM_sec_offset(0x17)
# Abbrev 2: DW_TAG_subprogram (0x2e), has_children=false
#   attrs: DW_AT_name(0x03)/DW_FORM_string(0x08),
#          DW_AT_low_pc(0x11)/DW_FORM_addr(0x01),
#          DW_AT_high_pc(0x12)/DW_FORM_data4(0x06)
# Table terminator: 0x00

fn _build_debug_abbrev() -> [u8]:
    var b: [u8] = []
    # Abbrev 1: compile_unit
    b = b.push(0x01) # code
    b = b.push(0x11) # DW_TAG_compile_unit
    b = b.push(0x01) # has_children = true
    b = b.push(0x03) # DW_AT_name
    b = b.push(0x08) # DW_FORM_string
    b = b.push(0x11) # DW_AT_low_pc
    b = b.push(0x01) # DW_FORM_addr
    b = b.push(0x12) # DW_AT_high_pc
    b = b.push(0x06) # DW_FORM_data4
    b = b.push(0x10) # DW_AT_stmt_list
    b = b.push(0x17) # DW_FORM_sec_offset
    b = b.push(0x00) # attr terminator
    b = b.push(0x00)
    # Abbrev 2: subprogram
    b = b.push(0x02) # code
    b = b.push(0x2e) # DW_TAG_subprogram
    b = b.push(0x00) # has_children = false
    b = b.push(0x03) # DW_AT_name
    b = b.push(0x08) # DW_FORM_string
    b = b.push(0x11) # DW_AT_low_pc
    b = b.push(0x01) # DW_FORM_addr
    b = b.push(0x12) # DW_AT_high_pc
    b = b.push(0x06) # DW_FORM_data4
    b = b.push(0x00) # attr terminator
    b = b.push(0x00)
    # Table terminator
    b = b.push(0x00)
    b

# ============================================================================
# Helper: build minimal .debug_info
# ============================================================================
# CU header (11 bytes for DWARF v4, addr_size=4):
#   u32 unit_length, u16 version=4, u32 abbrev_offset=0, u8 addr_size=4
# CU DIE (abbrev 1): name="hello.spl", low_pc=0x1000, high_pc=0x100 (offset), stmt_list=0
# Subprogram DIE (abbrev 2): name="main", low_pc=0x1000, high_pc=0x80 (offset)
# Children terminator: 0x00

fn _build_debug_info() -> [u8]:
    # Build DIE payload first, then compute unit_length
    var dies: [u8] = []
    # CU DIE: abbrev code 1
    dies = dies.push(0x01)
    # DW_AT_name = "hello.spl\0"
    dies = _push_string(dies, "hello.spl")
    # DW_AT_low_pc = 0x00001000 (4 bytes LE, addr_size=4)
    dies = _append(dies, _le_u32(0x1000))
    # DW_AT_high_pc = 0x100 (DW_FORM_data4 offset)
    dies = _append(dies, _le_u32(0x100))
    # DW_AT_stmt_list = 0 (DW_FORM_sec_offset, 4 bytes)
    dies = _append(dies, _le_u32(0))

    # Subprogram DIE: abbrev code 2
    dies = dies.push(0x02)
    # DW_AT_name = "main\0"
    dies = _push_string(dies, "main")
    # DW_AT_low_pc = 0x1000 (4 bytes LE)
    dies = _append(dies, _le_u32(0x1000))
    # DW_AT_high_pc = 0x80 (offset)
    dies = _append(dies, _le_u32(0x80))

    # Children terminator for CU
    dies = dies.push(0x00)

    # unit_length = version(2) + abbrev_offset(4) + addr_size(1) + dies
    val unit_length = 2 + 4 + 1 + dies.len()

    var b: [u8] = []
    # unit_length (u32 LE)
    b = _append(b, _le_u32(unit_length))
    # version (u16 LE) = 4
    b = _append(b, _le_u16(4))
    # abbrev_offset (u32 LE) = 0
    b = _append(b, _le_u32(0))
    # addr_size (u8) = 4
    b = b.push(0x04)
    # DIE data
    b = _append(b, dies)
    b

# ============================================================================
# Helper: build minimal .debug_line for one CU
# ============================================================================
# Produces a line program that emits:
#   addr=0x1000, line=10, file="hello.spl"
#   addr=0x1020, line=20, file="hello.spl"
#   end_sequence

fn _build_debug_line() -> [u8]:
    # Build prologue body (after header_length field)
    var prologue: [u8] = []
    prologue = prologue.push(1)   # min_instruction_length
    # version 3 — no maximum_ops_per_instruction field
    prologue = prologue.push(1)   # default_is_stmt
    prologue = prologue.push(251) # line_base = -5
    prologue = prologue.push(14)  # line_range
    prologue = prologue.push(13)  # opcode_base
    # 12 standard opcode lengths
    prologue = prologue.push(0)
    prologue = prologue.push(1)
    prologue = prologue.push(1)
    prologue = prologue.push(1)
    prologue = prologue.push(1)
    prologue = prologue.push(0)
    prologue = prologue.push(0)
    prologue = prologue.push(0)
    prologue = prologue.push(1)
    prologue = prologue.push(0)
    prologue = prologue.push(0)
    prologue = prologue.push(1)
    # include_directories: empty
    prologue = prologue.push(0x00)
    # file_names: "hello.spl", dir_idx=0, mtime=0, size=0
    prologue = _push_string(prologue, "hello.spl")
    prologue = prologue.push(0x00) # dir_idx
    prologue = prologue.push(0x00) # mtime
    prologue = prologue.push(0x00) # size
    # file table terminator
    prologue = prologue.push(0x00)

    val header_length = prologue.len()

    # Program bytes
    var prog: [u8] = []
    # DW_LNE_set_address(0x1000) addr_size=4
    prog = prog.push(0x00)
    prog = prog.push(0x05) # ext_len = 5
    prog = prog.push(0x02) # DW_LNE_set_address
    prog = _append(prog, _le_u32(0x1000))
    # DW_LNS_advance_line +9 (line 1 -> 10)
    prog = prog.push(0x03)
    prog = prog.push(0x09)
    # DW_LNS_copy
    prog = prog.push(0x01)
    # DW_LNS_advance_pc +32 (0x20)
    prog = prog.push(0x02)
    prog = prog.push(0x20)
    # DW_LNS_advance_line +10 (line 10 -> 20)
    prog = prog.push(0x03)
    prog = prog.push(0x0a)
    # DW_LNS_copy
    prog = prog.push(0x01)
    # DW_LNE_end_sequence
    prog = prog.push(0x00)
    prog = prog.push(0x01)
    prog = prog.push(0x01)

    val total_after_unit_length = 2 + 4 + header_length + prog.len()

    var b: [u8] = []
    # unit_length (u32 LE)
    b = _append(b, _le_u32(total_after_unit_length))
    # version (u16 LE) = 3
    b = _append(b, _le_u16(3))
    # header_length (u32 LE)
    b = _append(b, _le_u32(header_length))
    # prologue
    b = _append(b, prologue)
    # program
    b = _append(b, prog)
    b

# ============================================================================
# Tests
# ============================================================================

describe "DwarfParser Construction":
    it "rejects empty debug_info":
        val sections = DwarfSections(
            debug_info: [],
            debug_abbrev: [],
            debug_line: [],
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val result = DwarfParser.from_sections(sections)
        expect(result.is_err()).to_equal(true)

    it "creates parser from valid sections":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val result = DwarfParser.from_sections(sections)
        expect(result.is_ok()).to_equal(true)

    it "reports DWARF format kind":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        expect(parser.format_kind().to_string()).to_equal("DWARF")

describe "DwarfParser Compilation Units":
    it "parses one compilation unit":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val units = parser.compilation_units()
        expect(units.len()).to_equal(1)

    it "compilation unit has correct name":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val cu = parser.compilation_units()[0]
        expect(cu.name).to_equal("hello.spl")

    it "compilation unit has correct address range":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val cu = parser.compilation_units()[0]
        expect(cu.low_pc).to_equal(0x1000)
        expect(cu.high_pc).to_equal(0x1100)

describe "DwarfParser Queries":
    it "addr_to_source resolves address to source location":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val loc = parser.addr_to_source(0x1000)
        expect(loc.?).to_equal(true)
        expect(loc!.line).to_equal(10)
        expect(loc!.file).to_equal("hello.spl")

    it "addr_to_source picks best match for mid-range address":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        # 0x1010 is between 0x1000 (line 10) and 0x1020 (line 20)
        # Should pick the entry with greatest address <= query → 0x1000, line 10
        val loc = parser.addr_to_source(0x1010)
        expect(loc.?).to_equal(true)
        expect(loc!.line).to_equal(10)

    it "addr_to_source returns nil for address before all entries":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val loc = parser.addr_to_source(0x0100)
        expect(loc.?).to_equal(false)

    it "function_at finds function containing address":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val func = parser.function_at(0x1040)
        expect(func.?).to_equal(true)
        expect(func!.name).to_equal("main")
        expect(func!.low_pc).to_equal(0x1000)
        expect(func!.high_pc).to_equal(0x1080)

    it "function_at returns nil for address outside all functions":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val func = parser.function_at(0x2000)
        expect(func.?).to_equal(false)

    it "line_entries returns all decoded line entries":
        val sections = DwarfSections(
            debug_info: _build_debug_info(),
            debug_abbrev: _build_debug_abbrev(),
            debug_line: _build_debug_line(),
            debug_str: [],
            debug_line_str: [],
            addr_size: 4,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val entries = parser.line_entries()
        # 2 copy rows + 1 end_sequence = 3 entries
        expect(entries.len()).to_equal(3)
