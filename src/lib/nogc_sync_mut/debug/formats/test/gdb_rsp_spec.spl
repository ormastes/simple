#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.protocol.gdb_rsp.GdbRspClient
use std.nogc_sync_mut.debug.remote.feature.features.FeatureId

fn main():
    describe("GdbRspClient checksum"):
        it("computes empty string checksum"):
            val cs = GdbRspClient.compute_checksum("")
            expect(cs).to_equal("00")

        it("computes 'g' checksum"):
            val cs = GdbRspClient.compute_checksum("g")
            expect(cs).to_equal("67")

        it("computes 'c' checksum"):
            val cs = GdbRspClient.compute_checksum("c")
            expect(cs).to_equal("63")

        it("computes 's' checksum"):
            val cs = GdbRspClient.compute_checksum("s")
            expect(cs).to_equal("73")

        it("computes 'qSupported' checksum"):
            val cs = GdbRspClient.compute_checksum("qSupported")
            expect(cs.len()).to_equal(2)

        it("computes 'm0,4' checksum"):
            val cs = GdbRspClient.compute_checksum("m0,4")
            expect(cs.len()).to_equal(2)

        it("computes 'Z0,1000,1' checksum"):
            val cs = GdbRspClient.compute_checksum("Z0,1000,1")
            expect(cs.len()).to_equal(2)

    describe("GdbRspClient packet encoding"):
        it("encodes empty packet"):
            val pkt = GdbRspClient.encode_packet("")
            expect(pkt).to_equal("$#00")

        it("encodes 'g' packet"):
            val pkt = GdbRspClient.encode_packet("g")
            expect(pkt).to_equal("$g#67")

        it("encodes 'c' packet"):
            val pkt = GdbRspClient.encode_packet("c")
            expect(pkt).to_equal("$c#63")

        it("encodes 's' packet"):
            val pkt = GdbRspClient.encode_packet("s")
            expect(pkt).to_equal("$s#73")

    describe("GdbRspClient response parsing"):
        it("parses simple response"):
            val parsed = GdbRspClient.parse_response("$OK#9a")
            expect(parsed).to_equal("OK")

        it("parses response with leading ack"):
            val parsed = GdbRspClient.parse_response("+$OK#9a")
            expect(parsed).to_equal("OK")

        it("parses error response"):
            val parsed = GdbRspClient.parse_response("$E01#a6")
            expect(parsed).to_equal("E01")

        it("parses hex data response"):
            val parsed = GdbRspClient.parse_response("$deadbeef#xx")
            expect(parsed).to_equal("deadbeef")

    describe("GdbRspClient hex utilities"):
        it("converts i64 to hex"):
            expect(GdbRspClient._i64_to_hex(255)).to_equal("ff")

        it("converts zero to hex"):
            expect(GdbRspClient._i64_to_hex(0)).to_equal("0")

        it("converts 4096 to hex"):
            expect(GdbRspClient._i64_to_hex(4096)).to_equal("1000")

        it("converts hex byte to i32"):
            expect(GdbRspClient._hex_to_i32("ff")).to_equal(255)

        it("converts hex byte 00 to 0"):
            expect(GdbRspClient._hex_to_i32("00")).to_equal(0)

        it("converts hex byte a5 to 165"):
            expect(GdbRspClient._hex_to_i32("a5")).to_equal(165)

        it("formats i32 as hex byte"):
            expect(GdbRspClient._i32_to_hex_byte(255)).to_equal("ff")

        it("formats i32 zero as hex byte"):
            expect(GdbRspClient._i32_to_hex_byte(0)).to_equal("00")

    describe("FeatureId new variants"):
        it("has RspConnect"):
            expect(FeatureId.RspConnect.to_string()).to_equal("RspConnect")

        it("has ReverseStep"):
            expect(FeatureId.ReverseStep.to_string()).to_equal("ReverseStep")

        it("has ReverseContinue"):
            expect(FeatureId.ReverseContinue.to_string()).to_equal("ReverseContinue")

        it("has NonStopMode"):
            expect(FeatureId.NonStopMode.to_string()).to_equal("NonStopMode")

        it("has PrettyPrint"):
            expect(FeatureId.PrettyPrint.to_string()).to_equal("PrettyPrint")

        it("has LldbDapLaunch"):
            expect(FeatureId.LldbDapLaunch.to_string()).to_equal("LldbDapLaunch")

        it("has DbgEngAttach"):
            expect(FeatureId.DbgEngAttach.to_string()).to_equal("DbgEngAttach")

        it("has AsyncInterrupt"):
            expect(FeatureId.AsyncInterrupt.to_string()).to_equal("AsyncInterrupt")

        it("has RspPacketSend"):
            expect(FeatureId.RspPacketSend.to_string()).to_equal("RspPacketSend")

        it("has LldbDapAttach"):
            expect(FeatureId.LldbDapAttach.to_string()).to_equal("LldbDapAttach")
