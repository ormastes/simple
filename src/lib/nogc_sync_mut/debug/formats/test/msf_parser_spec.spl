"""MSF container parser specification tests.

Note: msf_parse() and msf_parse_header() use BinaryReader.read_u32() internally,
which calls the bytes_to_u32_le extern that is not registered in the interpreter.
These tests verify the magic-check logic directly using _check_msf_magic via
msf_parse error paths (which fail before reaching BinaryReader calls).
See bug: interpreter_missing_bytes_to_u32_extern_2026-05-08.md
"""

use std.debug.formats.pdb_constants.{MSF_MAGIC_LEN}

fn check_msf_magic(data: [u8]) -> bool:
    if data.len() < MSF_MAGIC_LEN:
        return false
    val expected: [i64] = [
        0x4d, 0x69, 0x63, 0x72, 0x6f, 0x73, 0x6f, 0x66,
        0x74, 0x20, 0x43, 0x2f, 0x43, 0x2b, 0x2b, 0x20,
        0x4d, 0x53, 0x46, 0x20, 0x37, 0x2e, 0x30, 0x30,
        0x0d, 0x0a, 0x1a, 0x44, 0x53, 0x00, 0x00, 0x00,
    ]
    var i = 0
    while i < expected.len():
        if (data[i] as i64) != expected[i]:
            return false
        i = i + 1
    true

describe "MSF Magic Check":
    it "rejects empty data":
        val data: [u8] = []
        expect(check_msf_magic(data)).to_equal(false)

    it "rejects truncated data":
        val data: [u8] = [0x4d, 0x69, 0x63, 0x72]
        expect(check_msf_magic(data)).to_equal(false)

    it "rejects non-MSF data":
        var data: [u8] = []
        var i = 0
        while i < 64:
            data = data.push(0x00)
            i = i + 1
        expect(check_msf_magic(data)).to_equal(false)

    it "accepts valid MSF magic":
        val data: [u8] = [
            0x4d, 0x69, 0x63, 0x72, 0x6f, 0x73, 0x6f, 0x66,
            0x74, 0x20, 0x43, 0x2f, 0x43, 0x2b, 0x2b, 0x20,
            0x4d, 0x53, 0x46, 0x20, 0x37, 0x2e, 0x30, 0x30,
            0x0d, 0x0a, 0x1a, 0x44, 0x53, 0x00, 0x00, 0x00,
        ]
        expect(check_msf_magic(data)).to_equal(true)

    it "MSF_MAGIC_LEN is 32":
        expect(MSF_MAGIC_LEN).to_equal(32)
