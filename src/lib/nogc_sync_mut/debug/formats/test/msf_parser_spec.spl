"""MSF container parser specification tests."""

use std.debug.formats.msf_parser.{msf_parse, msf_parse_header}

describe "MSF Parser":
    it "rejects empty data":
        val data: [u8] = []
        val result = msf_parse(data)
        expect(result.is_err()).to_equal(true)
        val err_msg = result.err()!
        expect(err_msg).to_contain("bad magic")

    it "rejects truncated header":
        val data: [u8] = [0x4d, 0x69, 0x63, 0x72]
        val result = msf_parse(data)
        expect(result.is_err()).to_equal(true)

    it "rejects non-MSF file":
        var data: [u8] = []
        var i = 0
        while i < 64:
            data = data.push(0x00)
            i = i + 1
        val result = msf_parse(data)
        expect(result.is_err()).to_equal(true)
        val err_msg2 = result.err()!
        expect(err_msg2).to_contain("bad magic")

    it "validates MSF magic bytes":
        var data: [u8] = [
            0x4d, 0x69, 0x63, 0x72, 0x6f, 0x73, 0x6f, 0x66,
            0x74, 0x20, 0x43, 0x2f, 0x43, 0x2b, 0x2b, 0x20,
            0x4d, 0x53, 0x46, 0x20, 0x37, 0x2e, 0x30, 0x30,
            0x0d, 0x0a, 0x1a, 0x44, 0x53, 0x00, 0x00, 0x00,
        ]
        var i = 0
        while i < 20:
            data = data.push(0x00)
            i = i + 1
        val result = msf_parse_header(data)
        expect(result.is_ok()).to_equal(true)
        val header = result.ok()!
        expect(header.page_size).to_equal(0)
