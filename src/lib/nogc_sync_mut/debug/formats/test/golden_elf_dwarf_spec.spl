"""Golden-file ELF+DWARF integration tests.

Exercises the full DwarfParser pipeline with hand-crafted synthetic DWARF
sections: abbreviation tables, compilation unit DIEs, subprogram DIEs,
line number programs, and the higher-level query methods (addr_to_source,
function_at, compilation_units, line_entries).

Also tests from_elf() with a minimal hand-crafted ELF64 binary containing
embedded .debug_info, .debug_abbrev, .debug_str, and .debug_line sections.
"""

use std.debug.formats.dwarf_parser.{DwarfParser, DwarfSections}
use std.debug.formats.debug_types.{SourceLocation, DebugLineEntry, DebugFunction, DebugCompilationUnit, DebugFormatKind}

# =============================================================================
# Helpers: build synthetic DWARF section bytes
# =============================================================================

# Build a minimal .debug_abbrev section:
#   abbrev 1 = DW_TAG_compile_unit (0x11), has_children=true
#     attrs: DW_AT_name (0x03) / DW_FORM_string (0x08)
#            DW_AT_comp_dir (0x1b) / DW_FORM_string (0x08)
#            DW_AT_low_pc (0x11) / DW_FORM_addr (0x01)
#            DW_AT_high_pc (0x12) / DW_FORM_data4 (0x06)   (offset form)
#            DW_AT_language (0x13) / DW_FORM_data1 (0x0b)
#            DW_AT_stmt_list (0x10) / DW_FORM_sec_offset (0x17)
#   abbrev 2 = DW_TAG_subprogram (0x2e), has_children=false
#     attrs: DW_AT_name (0x03) / DW_FORM_string (0x08)
#            DW_AT_low_pc (0x11) / DW_FORM_addr (0x01)
#            DW_AT_high_pc (0x12) / DW_FORM_data4 (0x06)
fn build_debug_abbrev() -> [u8]:
    var b: [u8] = []
    # --- abbrev code 1: DW_TAG_compile_unit ---
    b = b.push(0x01)        # code = 1
    b = b.push(0x11)        # DW_TAG_compile_unit
    b = b.push(0x01)        # has_children = true
    # attr: DW_AT_name / DW_FORM_string
    b = b.push(0x03)
    b = b.push(0x08)
    # attr: DW_AT_comp_dir / DW_FORM_string
    b = b.push(0x1b)
    b = b.push(0x08)
    # attr: DW_AT_low_pc / DW_FORM_addr
    b = b.push(0x11)
    b = b.push(0x01)
    # attr: DW_AT_high_pc / DW_FORM_data4  (offset form)
    b = b.push(0x12)
    b = b.push(0x06)
    # attr: DW_AT_language / DW_FORM_data1
    b = b.push(0x13)
    b = b.push(0x0b)
    # attr: DW_AT_stmt_list / DW_FORM_sec_offset
    b = b.push(0x10)
    b = b.push(0x17)
    # terminator
    b = b.push(0x00)
    b = b.push(0x00)

    # --- abbrev code 2: DW_TAG_subprogram ---
    b = b.push(0x02)        # code = 2
    b = b.push(0x2e)        # DW_TAG_subprogram
    b = b.push(0x00)        # has_children = false
    # attr: DW_AT_name / DW_FORM_string
    b = b.push(0x03)
    b = b.push(0x08)
    # attr: DW_AT_low_pc / DW_FORM_addr
    b = b.push(0x11)
    b = b.push(0x01)
    # attr: DW_AT_high_pc / DW_FORM_data4
    b = b.push(0x12)
    b = b.push(0x06)
    # terminator
    b = b.push(0x00)
    b = b.push(0x00)

    # table terminator
    b = b.push(0x00)
    b

# Append a little-endian u32 to a byte array
fn push_u32_le(buf: [u8], v: i64) -> [u8]:
    var b = buf
    b = b.push((v & 0xff) as u8)
    b = b.push(((v >> 8) & 0xff) as u8)
    b = b.push(((v >> 16) & 0xff) as u8)
    b = b.push(((v >> 24) & 0xff) as u8)
    b

# Append a little-endian u64 to a byte array
fn push_u64_le(buf: [u8], v: i64) -> [u8]:
    var b = buf
    b = b.push((v & 0xff) as u8)
    b = b.push(((v >> 8) & 0xff) as u8)
    b = b.push(((v >> 16) & 0xff) as u8)
    b = b.push(((v >> 24) & 0xff) as u8)
    b = b.push(((v >> 32) & 0xff) as u8)
    b = b.push(((v >> 40) & 0xff) as u8)
    b = b.push(((v >> 48) & 0xff) as u8)
    b = b.push(((v >> 56) & 0xff) as u8)
    b

# Append a little-endian u16 to a byte array
fn push_u16_le(buf: [u8], v: i64) -> [u8]:
    var b = buf
    b = b.push((v & 0xff) as u8)
    b = b.push(((v >> 8) & 0xff) as u8)
    b

# Append a null-terminated string to a byte array
fn push_string(buf: [u8], s: text) -> [u8]:
    var b = buf
    var i = 0
    while i < s.len():
        b = b.push(s.char_code_at(i) as u8)
        i = i + 1
    b = b.push(0x00)
    b

# Build .debug_info section containing one CU with one subprogram.
# CU name = "hello.spl", comp_dir = "/src", low_pc = 0x1000, high_pc offset = 0x200
# language = 28 (DW_LANG_Simple -- custom), stmt_list = 0
# Subprogram: name = "main", low_pc = 0x1000, high_pc offset = 0x80
fn build_debug_info() -> [u8]:
    # We build the DIE payload first, then prepend the CU header.
    var die: [u8] = []

    # --- CU DIE (abbrev code 1) ---
    die = die.push(0x01)
    # DW_AT_name: inline string "hello.spl\0"
    die = push_string(die, "hello.spl")
    # DW_AT_comp_dir: inline string "/src\0"
    die = push_string(die, "/src")
    # DW_AT_low_pc: 8-byte addr = 0x1000
    die = push_u64_le(die, 0x1000)
    # DW_AT_high_pc: 4-byte data (offset) = 0x200
    die = push_u32_le(die, 0x200)
    # DW_AT_language: 1-byte = 28
    die = die.push(28)
    # DW_AT_stmt_list: 4-byte sec_offset = 0
    die = push_u32_le(die, 0)

    # --- Subprogram DIE (abbrev code 2) ---
    die = die.push(0x02)
    # DW_AT_name: inline string "main\0"
    die = push_string(die, "main")
    # DW_AT_low_pc: 8-byte addr = 0x1000
    die = push_u64_le(die, 0x1000)
    # DW_AT_high_pc: 4-byte data (offset) = 0x80
    die = push_u32_le(die, 0x80)

    # null terminator for children of CU
    die = die.push(0x00)

    # CU header: unit_length (4) + version (2) + abbrev_offset (4) + addr_size (1) = 11 bytes
    val unit_length = die.len() + 7  # 2 (version) + 4 (abbrev_offset) + 1 (addr_size) + die payload
    var info: [u8] = []
    info = push_u32_le(info, unit_length)
    info = push_u16_le(info, 4)     # DWARF version 4
    info = push_u32_le(info, 0)     # abbrev_offset = 0
    info = info.push(8)             # addr_size = 8

    # Append DIE payload
    var j = 0
    while j < die.len():
        info = info.push(die[j])
        j = j + 1

    info

# Build a minimal .debug_line section (DWARF v4 line number program).
# Contains one file "hello.spl" and a short program that produces two line entries:
#   addr 0x1000 -> hello.spl:1
#   addr 0x1040 -> hello.spl:5
# Followed by an end_sequence.
fn build_debug_line() -> [u8]:
    # Build the line program opcodes first
    var prog: [u8] = []

    # Extended opcode: DW_LNE_set_address (0x02), addr = 0x1000
    prog = prog.push(0x00)         # extended escape
    prog = prog.push(9)            # length = 1 (opcode) + 8 (address)
    prog = prog.push(0x02)         # DW_LNE_set_address
    prog = push_u64_le(prog, 0x1000)

    # DW_LNS_copy (0x01) -- emit row: addr=0x1000, file=1, line=1
    prog = prog.push(0x01)

    # DW_LNS_advance_pc (0x02), operand = 0x40 (ULEB128)
    prog = prog.push(0x02)
    prog = prog.push(0x40)         # ULEB128: 64

    # DW_LNS_advance_line (0x03), operand = 4 (SLEB128, line goes from 1 to 5)
    prog = prog.push(0x03)
    prog = prog.push(0x04)         # SLEB128: +4

    # DW_LNS_copy (0x01) -- emit row: addr=0x1040, file=1, line=5
    prog = prog.push(0x01)

    # Extended opcode: DW_LNE_end_sequence (0x01)
    prog = prog.push(0x00)         # extended escape
    prog = prog.push(1)            # length = 1
    prog = prog.push(0x01)         # DW_LNE_end_sequence

    # --- Now build the header ---
    # Standard opcode lengths for opcodes 1..12 (opcode_base=13):
    #   copy=0, advance_pc=1, advance_line=1, set_file=1, set_column=1,
    #   negate_stmt=0, set_basic_block=0, const_add_pc=0, fixed_advance_pc=1,
    #   set_prologue_end=0, set_epilogue_begin=0, set_isa=1
    val std_opcode_lengths: [u8] = [0, 1, 1, 1, 1, 0, 0, 0, 1, 0, 0, 1]

    var header: [u8] = []
    # version = 4
    header = push_u16_le(header, 4)

    # We need to compute header_length after building the header content
    var header_content: [u8] = []
    # min_instruction_length = 1
    header_content = header_content.push(1)
    # maximum_operations_per_instruction = 1 (DWARF v4)
    header_content = header_content.push(1)
    # default_is_stmt = 1
    header_content = header_content.push(1)
    # line_base = -5 (signed byte: 0xfb)
    header_content = header_content.push(0xfb)
    # line_range = 14
    header_content = header_content.push(14)
    # opcode_base = 13
    header_content = header_content.push(13)
    # standard_opcode_lengths [12 entries]
    var k = 0
    while k < std_opcode_lengths.len():
        header_content = header_content.push(std_opcode_lengths[k])
        k = k + 1

    # include_directories: empty (null terminator)
    header_content = header_content.push(0x00)

    # file_names: one entry "hello.spl", dir_index=0, mtime=0, size=0
    header_content = push_string(header_content, "hello.spl")
    header_content = header_content.push(0x00)   # dir_index = 0 (ULEB128)
    header_content = header_content.push(0x00)   # mtime = 0
    header_content = header_content.push(0x00)   # file_size = 0

    # file_names terminator
    header_content = header_content.push(0x00)

    val header_length = header_content.len()

    # Prepend header_length (4 bytes) to header
    header = push_u32_le(header, header_length)

    # Append header content
    var m = 0
    while m < header_content.len():
        header = header.push(header_content[m])
        m = m + 1

    # Append program opcodes
    var n = 0
    while n < prog.len():
        header = header.push(prog[n])
        n = n + 1

    # Now wrap with unit_length
    val unit_length = header.len()
    var result: [u8] = []
    result = push_u32_le(result, unit_length)

    var p = 0
    while p < header.len():
        result = result.push(header[p])
        p = p + 1

    result

# =============================================================================
# Helpers: build minimal ELF64 binary with DWARF sections
# =============================================================================

# Build a minimal ELF64 binary with sections:
#   [0] SHT_NULL
#   [1] .debug_info   (SHT_PROGBITS)
#   [2] .debug_abbrev (SHT_PROGBITS)
#   [3] .debug_line   (SHT_PROGBITS)
#   [4] .debug_str    (SHT_PROGBITS)  -- empty
#   [5] .shstrtab     (SHT_STRTAB)
fn build_minimal_elf(debug_info: [u8], debug_abbrev: [u8], debug_line: [u8]) -> [u8]:
    # Build .shstrtab content: section names
    # offset 0: \0  (null section name)
    # offset 1: .debug_info\0
    # offset 13: .debug_abbrev\0
    # offset 27: .debug_line\0
    # offset 39: .debug_str\0
    # offset 50: .shstrtab\0
    var shstrtab: [u8] = []
    shstrtab = shstrtab.push(0x00)                      # [0] null
    shstrtab = push_string(shstrtab, ".debug_info")      # [1..12]
    shstrtab = push_string(shstrtab, ".debug_abbrev")    # [13..26]
    shstrtab = push_string(shstrtab, ".debug_line")      # [27..38]
    shstrtab = push_string(shstrtab, ".debug_str")       # [39..49]
    shstrtab = push_string(shstrtab, ".shstrtab")        # [50..59]

    # Layout:
    # [0..63]       ELF header (64 bytes)
    # [64..63+info] .debug_info data
    # [64+info..]   .debug_abbrev data
    # [..]          .debug_line data
    # [..]          .shstrtab data
    # [..]          section headers (6 x 64 = 384 bytes)

    val data_start = 64
    val info_off = data_start
    val info_size = debug_info.len()
    val abbrev_off = info_off + info_size
    val abbrev_size = debug_abbrev.len()
    val line_off = abbrev_off + abbrev_size
    val line_size = debug_line.len()
    val shstrtab_off = line_off + line_size
    val shstrtab_size = shstrtab.len()
    val shdr_off = shstrtab_off + shstrtab_size

    # Pad shdr_off to 8-byte alignment
    val shdr_off_aligned = ((shdr_off + 7) / 8) * 8

    val num_sections = 6
    val shstrtab_index = 5

    # --- ELF64 header (64 bytes) ---
    var elf: [u8] = []
    # e_ident[0..3]: magic
    elf = elf.push(0x7f)
    elf = elf.push(0x45)  # 'E'
    elf = elf.push(0x4c)  # 'L'
    elf = elf.push(0x46)  # 'F'
    # e_ident[4]: EI_CLASS = ELFCLASS64
    elf = elf.push(2)
    # e_ident[5]: EI_DATA = ELFDATA2LSB
    elf = elf.push(1)
    # e_ident[6]: EI_VERSION = EV_CURRENT
    elf = elf.push(1)
    # e_ident[7]: EI_OSABI = ELFOSABI_NONE
    elf = elf.push(0)
    # e_ident[8..15]: padding
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    elf = elf.push(0)
    # e_type = ET_EXEC (2)
    elf = push_u16_le(elf, 2)
    # e_machine = EM_X86_64 (62)
    elf = push_u16_le(elf, 62)
    # e_version = 1
    elf = push_u32_le(elf, 1)
    # e_entry = 0x1000
    elf = push_u64_le(elf, 0x1000)
    # e_phoff = 0
    elf = push_u64_le(elf, 0)
    # e_shoff
    elf = push_u64_le(elf, shdr_off_aligned)
    # e_flags = 0
    elf = push_u32_le(elf, 0)
    # e_ehsize = 64
    elf = push_u16_le(elf, 64)
    # e_phentsize = 0
    elf = push_u16_le(elf, 0)
    # e_phnum = 0
    elf = push_u16_le(elf, 0)
    # e_shentsize = 64
    elf = push_u16_le(elf, 64)
    # e_shnum
    elf = push_u16_le(elf, num_sections)
    # e_shstrndx
    elf = push_u16_le(elf, shstrtab_index)

    # --- Section data ---
    # .debug_info
    var i = 0
    while i < info_size:
        elf = elf.push(debug_info[i])
        i = i + 1

    # .debug_abbrev
    i = 0
    while i < abbrev_size:
        elf = elf.push(debug_abbrev[i])
        i = i + 1

    # .debug_line
    i = 0
    while i < line_size:
        elf = elf.push(debug_line[i])
        i = i + 1

    # .shstrtab
    i = 0
    while i < shstrtab_size:
        elf = elf.push(shstrtab[i])
        i = i + 1

    # Pad to alignment
    while elf.len() < shdr_off_aligned:
        elf = elf.push(0x00)

    # --- Section headers (6 entries, 64 bytes each) ---
    # Helper: build one section header
    # sh_name(4), sh_type(4), sh_flags(8), sh_addr(8)=file_offset, sh_size(8)=actual_size
    # sh_link(4), sh_info(4), sh_addralign(8), sh_entsize(8)
    # Note: _elf_section_by_name reads: sh_name at +0, offset at +24 (u64), size at +32 (u64)

    # [0] SHT_NULL
    elf = push_u32_le(elf, 0)     # sh_name
    elf = push_u32_le(elf, 0)     # sh_type = SHT_NULL
    elf = push_u64_le(elf, 0)     # sh_flags
    elf = push_u64_le(elf, 0)     # sh_addr (virtual)
    elf = push_u64_le(elf, 0)     # sh_offset
    elf = push_u64_le(elf, 0)     # sh_size
    elf = push_u32_le(elf, 0)     # sh_link
    elf = push_u32_le(elf, 0)     # sh_info
    elf = push_u64_le(elf, 0)     # sh_addralign
    elf = push_u64_le(elf, 0)     # sh_entsize

    # [1] .debug_info  (sh_name index = 1 in shstrtab)
    elf = push_u32_le(elf, 1)     # sh_name = 1 (".debug_info")
    elf = push_u32_le(elf, 1)     # sh_type = SHT_PROGBITS
    elf = push_u64_le(elf, 0)     # sh_flags
    elf = push_u64_le(elf, 0)     # sh_addr (virtual)
    elf = push_u64_le(elf, info_off)   # sh_offset
    elf = push_u64_le(elf, info_size)  # sh_size
    elf = push_u32_le(elf, 0)     # sh_link
    elf = push_u32_le(elf, 0)     # sh_info
    elf = push_u64_le(elf, 1)     # sh_addralign
    elf = push_u64_le(elf, 0)     # sh_entsize

    # [2] .debug_abbrev  (sh_name index = 13)
    elf = push_u32_le(elf, 13)
    elf = push_u32_le(elf, 1)     # SHT_PROGBITS
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, abbrev_off)
    elf = push_u64_le(elf, abbrev_size)
    elf = push_u32_le(elf, 0)
    elf = push_u32_le(elf, 0)
    elf = push_u64_le(elf, 1)
    elf = push_u64_le(elf, 0)

    # [3] .debug_line  (sh_name index = 27)
    elf = push_u32_le(elf, 27)
    elf = push_u32_le(elf, 1)     # SHT_PROGBITS
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, line_off)
    elf = push_u64_le(elf, line_size)
    elf = push_u32_le(elf, 0)
    elf = push_u32_le(elf, 0)
    elf = push_u64_le(elf, 1)
    elf = push_u64_le(elf, 0)

    # [4] .debug_str  (sh_name index = 39, empty)
    elf = push_u32_le(elf, 39)
    elf = push_u32_le(elf, 1)     # SHT_PROGBITS
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, 0)     # offset = 0 (empty)
    elf = push_u64_le(elf, 0)     # size = 0
    elf = push_u32_le(elf, 0)
    elf = push_u32_le(elf, 0)
    elf = push_u64_le(elf, 1)
    elf = push_u64_le(elf, 0)

    # [5] .shstrtab  (sh_name index = 50)
    elf = push_u32_le(elf, 50)
    elf = push_u32_le(elf, 3)     # SHT_STRTAB
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, 0)
    elf = push_u64_le(elf, shstrtab_off)
    elf = push_u64_le(elf, shstrtab_size)
    elf = push_u32_le(elf, 0)
    elf = push_u32_le(elf, 0)
    elf = push_u64_le(elf, 1)
    elf = push_u64_le(elf, 0)

    elf

# =============================================================================
# Tests: DwarfParser.from_sections() with synthetic DWARF data
# =============================================================================

describe "DwarfParser from_sections":
    it "rejects empty debug_info":
        val sections = DwarfSections(
            debug_info: [],
            debug_abbrev: [],
            debug_line: [],
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val result = DwarfParser.from_sections(sections)
        expect(result.is_err()).to_equal(true)

    it "parses synthetic CU with subprogram":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val result = DwarfParser.from_sections(sections)
        expect(result.is_ok()).to_equal(true)

        val parser = result.ok()!
        expect(parser.format_kind().to_string()).to_equal("DWARF")

        # Compilation units
        val units = parser.compilation_units()
        expect(units.len()).to_equal(1)

        val cu = units[0]
        expect(cu.name).to_equal("hello.spl")
        expect(cu.comp_dir).to_equal("/src")
        expect(cu.low_pc).to_equal(0x1000)
        # high_pc = low_pc + offset = 0x1000 + 0x200 = 0x1200
        expect(cu.high_pc).to_equal(0x1200)
        expect(cu.language).to_equal(28)

    it "finds subprogram function":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        val units = parser.compilation_units()
        val cu = units[0]
        # The CU should have at least one function
        expect(cu.functions.len() >= 1).to_equal(true)

        val func = cu.functions[0]
        expect(func.name).to_equal("main")
        expect(func.low_pc).to_equal(0x1000)
        # high_pc = low_pc + offset = 0x1000 + 0x80 = 0x1080
        expect(func.high_pc).to_equal(0x1080)

    it "function_at finds correct function":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        # Address inside the function
        val found = parser.function_at(0x1020)
        expect(found.?).to_equal(true)
        expect(found!.name).to_equal("main")

        # Address outside the function
        val not_found = parser.function_at(0x2000)
        expect(not_found.?).to_equal(false)

    it "line_entries produces entries from line program":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        val entries = parser.line_entries()
        # Should have at least 2 real entries + 1 end_sequence
        expect(entries.len() >= 2).to_equal(true)

        # Find non-end-sequence entries
        var real_entries: [DebugLineEntry] = []
        var idx = 0
        while idx < entries.len():
            if entries[idx].end_sequence == false:
                real_entries = real_entries.push(entries[idx])
            idx = idx + 1

        expect(real_entries.len() >= 2).to_equal(true)
        # First entry: addr=0x1000, line=1, file=hello.spl
        expect(real_entries[0].address).to_equal(0x1000)
        expect(real_entries[0].location.line).to_equal(1)
        expect(real_entries[0].location.file).to_equal("hello.spl")

        # Second entry: addr=0x1040, line=5
        expect(real_entries[1].address).to_equal(0x1040)
        expect(real_entries[1].location.line).to_equal(5)

    it "addr_to_source maps address to source location":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        # Exact match at line entry address
        val loc1 = parser.addr_to_source(0x1000)
        expect(loc1.?).to_equal(true)
        expect(loc1!.line).to_equal(1)
        expect(loc1!.file).to_equal("hello.spl")

        # Address between two entries -- should map to the earlier one
        val loc2 = parser.addr_to_source(0x1020)
        expect(loc2.?).to_equal(true)
        expect(loc2!.line).to_equal(1)

        # Address at second entry
        val loc3 = parser.addr_to_source(0x1040)
        expect(loc3.?).to_equal(true)
        expect(loc3!.line).to_equal(5)

    it "functions_in_range finds overlapping functions":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        # Range that overlaps with main (0x1000..0x1080)
        val funcs = parser.functions_in_range(0x1000, 0x1100)
        expect(funcs.len()).to_equal(1)
        expect(funcs[0].name).to_equal("main")

        # Range that does not overlap
        val no_funcs = parser.functions_in_range(0x2000, 0x3000)
        expect(no_funcs.len()).to_equal(0)

# =============================================================================
# Tests: DwarfParser.from_elf() with hand-crafted ELF binary
# =============================================================================

describe "DwarfParser from_elf":
    it "rejects data shorter than ELF header":
        val tiny: [u8] = [0x7f, 0x45, 0x4c, 0x46]
        val result = DwarfParser.from_elf(tiny)
        expect(result.is_err()).to_equal(true)

    it "rejects ELF with no debug sections":
        # Valid ELF header but e_shnum=0, e_shoff=0
        var elf: [u8] = []
        # ELF magic
        elf = elf.push(0x7f)
        elf = elf.push(0x45)
        elf = elf.push(0x4c)
        elf = elf.push(0x46)
        # class=64, data=LSB, version=1, osabi=0
        elf = elf.push(2)
        elf = elf.push(1)
        elf = elf.push(1)
        elf = elf.push(0)
        # padding
        var pad = 0
        while pad < 8:
            elf = elf.push(0)
            pad = pad + 1
        # e_type=2, e_machine=62
        elf = push_u16_le(elf, 2)
        elf = push_u16_le(elf, 62)
        # e_version=1
        elf = push_u32_le(elf, 1)
        # e_entry=0
        elf = push_u64_le(elf, 0)
        # e_phoff=0
        elf = push_u64_le(elf, 0)
        # e_shoff=0  (no section headers)
        elf = push_u64_le(elf, 0)
        # e_flags=0
        elf = push_u32_le(elf, 0)
        # e_ehsize=64
        elf = push_u16_le(elf, 64)
        # e_phentsize=0, e_phnum=0
        elf = push_u16_le(elf, 0)
        elf = push_u16_le(elf, 0)
        # e_shentsize=64, e_shnum=0, e_shstrndx=0
        elf = push_u16_le(elf, 64)
        elf = push_u16_le(elf, 0)
        elf = push_u16_le(elf, 0)

        val result = DwarfParser.from_elf(elf)
        expect(result.is_err()).to_equal(true)

    it "parses minimal ELF with embedded DWARF sections":
        val debug_info = build_debug_info()
        val debug_abbrev = build_debug_abbrev()
        val debug_line = build_debug_line()

        val elf = build_minimal_elf(debug_info, debug_abbrev, debug_line)
        val result = DwarfParser.from_elf(elf)
        expect(result.is_ok()).to_equal(true)

        val parser = result.ok()!
        val units = parser.compilation_units()
        expect(units.len()).to_equal(1)
        expect(units[0].name).to_equal("hello.spl")
        expect(units[0].low_pc).to_equal(0x1000)

        # Verify function was parsed through ELF path
        val func = parser.function_at(0x1000)
        expect(func.?).to_equal(true)
        expect(func!.name).to_equal("main")

        # Verify line entries came through
        val loc = parser.addr_to_source(0x1000)
        expect(loc.?).to_equal(true)
        expect(loc!.file).to_equal("hello.spl")
        expect(loc!.line).to_equal(1)

    it "source_to_addr round-trips with addr_to_source":
        val debug_info = build_debug_info()
        val debug_abbrev = build_debug_abbrev()
        val debug_line = build_debug_line()

        val elf = build_minimal_elf(debug_info, debug_abbrev, debug_line)
        val parser = DwarfParser.from_elf(elf).ok()!

        # Look up address for hello.spl line 5
        val addr = parser.source_to_addr("hello.spl", 5)
        expect(addr.?).to_equal(true)
        expect(addr!).to_equal(0x1040)

        # Round-trip: addr -> source
        val loc = parser.addr_to_source(addr!)
        expect(loc.?).to_equal(true)
        expect(loc!.line).to_equal(5)

# =============================================================================
# Tests: edge cases
# =============================================================================

describe "DwarfParser edge cases":
    it "addr_to_source returns nil for address before all entries":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        # Address well before any code
        val loc = parser.addr_to_source(0x0010)
        # addr_to_source uses <= so any address >= 0 would match if entries start at 0x1000
        # Since 0x0010 < 0x1000, no entry has address <= 0x0010
        expect(loc.?).to_equal(false)

    it "compilation unit contains_address works with parsed data":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val cu = parser.compilation_units()[0]

        expect(cu.contains_address(0x1000)).to_equal(true)
        expect(cu.contains_address(0x1100)).to_equal(true)
        expect(cu.contains_address(0x1200)).to_equal(false)
        expect(cu.contains_address(0x0fff)).to_equal(false)

    it "function size is correct":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!
        val func = parser.function_at(0x1000)!
        # size = high_pc - low_pc = 0x1080 - 0x1000 = 0x80 = 128
        expect(func.size()).to_equal(128)

    it "line entry is_stmt flag is preserved":
        val debug_abbrev = build_debug_abbrev()
        val debug_info = build_debug_info()
        val debug_line = build_debug_line()

        val sections = DwarfSections(
            debug_info: debug_info,
            debug_abbrev: debug_abbrev,
            debug_line: debug_line,
            debug_str: [],
            debug_line_str: [],
            addr_size: 8,
        )
        val parser = DwarfParser.from_sections(sections).ok()!

        val entries = parser.line_entries()
        # default_is_stmt=1 in our header, so is_stmt should be true for
        # rows emitted by DW_LNS_copy
        var found_stmt = false
        var ei = 0
        while ei < entries.len():
            if entries[ei].end_sequence == false:
                if entries[ei].is_stmt:
                    found_stmt = true
            ei = ei + 1
        expect(found_stmt).to_equal(true)
