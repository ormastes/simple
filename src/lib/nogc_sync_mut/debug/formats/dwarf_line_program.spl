# DWARF Line Number Program Decoder
# Decodes .debug_line sections into DebugLineEntry sequences.
# Supports DWARF v2-v4 line number programs.

use std.binary_io.{BinaryReader, ByteOrder}
use std.debug.formats.debug_types.{SourceLocation, DebugLineEntry}
use std.debug.formats.dwarf_constants.{
    DW_LNS_copy, DW_LNS_advance_pc, DW_LNS_advance_line,
    DW_LNS_set_file, DW_LNS_set_column, DW_LNS_negate_stmt,
    DW_LNS_set_basic_block, DW_LNS_const_add_pc, DW_LNS_fixed_advance_pc,
    DW_LNS_set_prologue_end, DW_LNS_set_epilogue_begin, DW_LNS_set_isa,
    DW_LNE_end_sequence, DW_LNE_set_address, DW_LNE_define_file,
    DW_LNE_set_discriminator,
}
use std.debug.formats.dwarf_abbrev.{read_uleb128, read_sleb128}

# ============================================================================
# Data Structures
# ============================================================================

struct DwarfLineHeader:
    unit_length: i64
    version: i64
    header_length: i64
    min_instruction_length: i64
    maximum_ops_per_instruction: i64
    default_is_stmt: bool
    line_base: i64
    line_range: i64
    opcode_base: i64
    standard_opcode_lengths: [i64]
    include_directories: [text]
    file_names: [text]
    file_dir_indices: [i64]
    program_offset: i64
    program_end: i64

struct DwarfLineState:
    address: i64
    file_index: i64
    line: i64
    column: i64
    is_stmt: bool
    basic_block: bool
    end_sequence: bool
    prologue_end: bool
    epilogue_begin: bool

# ============================================================================
# Line Header Parsing
# ============================================================================

fn _read_null_terminated_string(data: [u8], offset: i64) -> (text, i64):
    var result = ""
    var pos = offset
    while pos < data.len():
        val b = data[pos]
        pos = pos + 1
        if b == 0:
            break
        result = result + text.from_char_code(b)
    (result, pos)

fn dwarf_parse_line_header(data: [u8], offset: i64, addr_size: i64) -> Result<DwarfLineHeader, text>:
    val order = ByteOrder.LittleEndian
    var pos = offset

    if pos + 4 > data.len():
        return Err("line header: truncated unit_length")

    var reader = BinaryReader.new(data)
    reader.skip(pos)
    val unit_length = reader.read_u32(order) ?? 0
    pos = pos + 4

    val unit_end = pos + unit_length
    if unit_end > data.len():
        return Err("line header: unit_length exceeds data")

    var reader2 = BinaryReader.new(data)
    reader2.skip(pos)
    val version = reader2.read_u16(order) ?? 0
    pos = pos + 2

    if version < 2 or version > 4:
        return Err("line header: unsupported DWARF line version {version}")

    var reader3 = BinaryReader.new(data)
    reader3.skip(pos)
    val header_length = reader3.read_u32(order) ?? 0
    pos = pos + 4

    val program_offset = pos + header_length

    var reader4 = BinaryReader.new(data)
    reader4.skip(pos)
    val min_instruction_length = reader4.read_u8() ?? 1
    pos = pos + 1

    var maximum_ops: i64 = 1
    if version >= 4:
        var reader5 = BinaryReader.new(data)
        reader5.skip(pos)
        maximum_ops = reader5.read_u8() ?? 1
        pos = pos + 1

    var reader6 = BinaryReader.new(data)
    reader6.skip(pos)
    val default_is_stmt_byte = reader6.read_u8() ?? 0
    pos = pos + 1

    var reader7 = BinaryReader.new(data)
    reader7.skip(pos)
    val line_base_raw = reader7.read_u8() ?? 0
    pos = pos + 1
    var line_base = line_base_raw as i64
    if line_base > 127:
        line_base = line_base - 256

    var reader8 = BinaryReader.new(data)
    reader8.skip(pos)
    val line_range = reader8.read_u8() ?? 1
    pos = pos + 1

    var reader9 = BinaryReader.new(data)
    reader9.skip(pos)
    val opcode_base = reader9.read_u8() ?? 1
    pos = pos + 1

    var standard_opcode_lengths: [i64] = []
    var op_i = 1
    while op_i < opcode_base:
        if pos >= data.len():
            break
        standard_opcode_lengths = standard_opcode_lengths.push(data[pos] as i64)
        pos = pos + 1
        op_i = op_i + 1

    var include_directories: [text] = []
    while pos < data.len():
        if data[pos] == 0:
            pos = pos + 1
            break
        val dir_result = _read_null_terminated_string(data, pos)
        include_directories = include_directories.push(dir_result.0)
        pos = dir_result.1

    var file_names: [text] = []
    var file_dir_indices: [i64] = []
    while pos < data.len():
        if data[pos] == 0:
            pos = pos + 1
            break
        val fname_result = _read_null_terminated_string(data, pos)
        file_names = file_names.push(fname_result.0)
        pos = fname_result.1

        val dir_idx_result = read_uleb128(data, pos)
        file_dir_indices = file_dir_indices.push(dir_idx_result.0)
        pos = dir_idx_result.1

        val time_result = read_uleb128(data, pos)
        pos = time_result.1
        val size_result = read_uleb128(data, pos)
        pos = size_result.1

    Ok(DwarfLineHeader(
        unit_length: unit_length,
        version: version,
        header_length: header_length,
        min_instruction_length: min_instruction_length,
        maximum_ops_per_instruction: maximum_ops,
        default_is_stmt: default_is_stmt_byte != 0,
        line_base: line_base,
        line_range: line_range,
        opcode_base: opcode_base,
        standard_opcode_lengths: standard_opcode_lengths,
        include_directories: include_directories,
        file_names: file_names,
        file_dir_indices: file_dir_indices,
        program_offset: program_offset,
        program_end: unit_end,
    ))

# ============================================================================
# Line Program Execution
# ============================================================================

fn _initial_state(header: DwarfLineHeader) -> DwarfLineState:
    DwarfLineState(
        address: 0,
        file_index: 1,
        line: 1,
        column: 0,
        is_stmt: header.default_is_stmt,
        basic_block: false,
        end_sequence: false,
        prologue_end: false,
        epilogue_begin: false,
    )

fn _resolve_file_name(header: DwarfLineHeader, file_index: i64) -> text:
    val idx = file_index - 1
    if idx < 0 or idx >= header.file_names.len():
        return "<unknown>"

    val fname = header.file_names[idx]
    if idx < header.file_dir_indices.len():
        val dir_idx = header.file_dir_indices[idx]
        if dir_idx > 0 and dir_idx <= header.include_directories.len():
            val dir = header.include_directories[dir_idx - 1]
            return dir + "/" + fname

    fname

fn _emit_row(state: DwarfLineState, header: DwarfLineHeader) -> DebugLineEntry:
    val file = _resolve_file_name(header, state.file_index)
    DebugLineEntry(
        address: state.address,
        location: SourceLocation(file: file, line: state.line, column: state.column),
        is_stmt: state.is_stmt,
        end_sequence: state.end_sequence,
        prologue_end: state.prologue_end,
        epilogue_begin: state.epilogue_begin,
    )

fn dwarf_decode_line_program(data: [u8], header: DwarfLineHeader, addr_size: i64) -> [DebugLineEntry]:
    var entries: [DebugLineEntry] = []
    var state = _initial_state(header)
    var pos = header.program_offset
    val order = ByteOrder.LittleEndian

    while pos < header.program_end and pos < data.len():
        val opcode = data[pos] as i64
        pos = pos + 1

        if opcode == 0:
            val len_result = read_uleb128(data, pos)
            val ext_len = len_result.0
            pos = len_result.1
            val ext_end = pos + ext_len

            if pos >= data.len():
                break
            val ext_opcode = data[pos] as i64
            pos = pos + 1

            if ext_opcode == DW_LNE_end_sequence:
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: true,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )
                entries = entries.push(_emit_row(state, header))
                state = _initial_state(header)

            else if ext_opcode == DW_LNE_set_address:
                if addr_size == 8:
                    var reader_a = BinaryReader.new(data)
                    reader_a.skip(pos)
                    val addr = reader_a.read_u64(order) ?? 0
                    state = DwarfLineState(
                        address: addr, file_index: state.file_index,
                        line: state.line, column: state.column,
                        is_stmt: state.is_stmt, basic_block: state.basic_block,
                        end_sequence: false,
                        prologue_end: state.prologue_end,
                        epilogue_begin: state.epilogue_begin,
                    )
                else:
                    var reader_b = BinaryReader.new(data)
                    reader_b.skip(pos)
                    val addr = reader_b.read_u32(order) ?? 0
                    state = DwarfLineState(
                        address: addr, file_index: state.file_index,
                        line: state.line, column: state.column,
                        is_stmt: state.is_stmt, basic_block: state.basic_block,
                        end_sequence: false,
                        prologue_end: state.prologue_end,
                        epilogue_begin: state.epilogue_begin,
                    )

            pos = ext_end

        else if opcode < header.opcode_base:
            if opcode == DW_LNS_copy:
                entries = entries.push(_emit_row(state, header))
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: false,
                    end_sequence: false, prologue_end: false, epilogue_begin: false,
                )

            else if opcode == DW_LNS_advance_pc:
                val adv_result = read_uleb128(data, pos)
                pos = adv_result.1
                state = DwarfLineState(
                    address: state.address + (adv_result.0 * header.min_instruction_length),
                    file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_advance_line:
                val line_result = read_sleb128(data, pos)
                pos = line_result.1
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line + line_result.0, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_set_file:
                val file_result = read_uleb128(data, pos)
                pos = file_result.1
                state = DwarfLineState(
                    address: state.address, file_index: file_result.0,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_set_column:
                val col_result = read_uleb128(data, pos)
                pos = col_result.1
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: col_result.0,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_negate_stmt:
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: not state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_set_basic_block:
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: true,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_const_add_pc:
                val adjusted = 255 - header.opcode_base
                val addr_increment = (adjusted / header.line_range) * header.min_instruction_length
                state = DwarfLineState(
                    address: state.address + addr_increment,
                    file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_fixed_advance_pc:
                var reader_c = BinaryReader.new(data)
                reader_c.skip(pos)
                val advance = reader_c.read_u16(order) ?? 0
                pos = pos + 2
                state = DwarfLineState(
                    address: state.address + advance,
                    file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false,
                    prologue_end: state.prologue_end,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_set_prologue_end:
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false, prologue_end: true,
                    epilogue_begin: state.epilogue_begin,
                )

            else if opcode == DW_LNS_set_epilogue_begin:
                state = DwarfLineState(
                    address: state.address, file_index: state.file_index,
                    line: state.line, column: state.column,
                    is_stmt: state.is_stmt, basic_block: state.basic_block,
                    end_sequence: false, prologue_end: state.prologue_end,
                    epilogue_begin: true,
                )

            else if opcode == DW_LNS_set_isa:
                val isa_result = read_uleb128(data, pos)
                pos = isa_result.1

            else:
                val op_idx = opcode - 1
                if op_idx < header.standard_opcode_lengths.len():
                    val arg_count = header.standard_opcode_lengths[op_idx]
                    var a = 0
                    while a < arg_count:
                        val skip_result = read_uleb128(data, pos)
                        pos = skip_result.1
                        a = a + 1

        else:
            val adjusted = opcode - header.opcode_base
            val addr_increment = (adjusted / header.line_range) * header.min_instruction_length
            val line_increment = header.line_base + (adjusted % header.line_range)

            state = DwarfLineState(
                address: state.address + addr_increment,
                file_index: state.file_index,
                line: state.line + line_increment, column: state.column,
                is_stmt: state.is_stmt, basic_block: false,
                end_sequence: false, prologue_end: false, epilogue_begin: false,
            )
            entries = entries.push(_emit_row(state, header))

    entries
