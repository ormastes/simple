# Remote RISC-V 32 Debug Backend — thin facade over RemoteGenericBackend

use app.debug.coordinator.{DebugBackend, VarInfo, FrameInfo, LocationInfo}
use app.debug.remote.types.{DebugConfig, Architecture}
use app.debug.remote.target.riscv32.RiscV32Target
use app.debug.remote.backend_generic.RemoteGenericBackend
use app.debug.remote.feature.features.FeatureId

class RemoteRiscV32Backend:
    inner: RemoteGenericBackend

impl RemoteRiscV32Backend:
    static fn gdb_only(config: DebugConfig) -> Result<RemoteRiscV32Backend, text>:
        val inner = RemoteGenericBackend.gdb_only(config, RiscV32Target.create())?
        Ok(RemoteRiscV32Backend(inner: inner))

    static fn trace32_only(config: DebugConfig) -> Result<RemoteRiscV32Backend, text>:
        val inner = RemoteGenericBackend.trace32_only(config, RiscV32Target.create())?
        Ok(RemoteRiscV32Backend(inner: inner))

    me add_emulation():
        self.inner.add_emulation()

    fn capabilities() -> text:
        self.inner.capabilities()

    fn supports(feat: FeatureId) -> bool:
        self.inner.supports(feat)

    fn name() -> String:
        "remote-riscv32"

    fn attach(program_path: String, args: [String]) -> Result<Nil, String>:
        self.inner.attach(program_path, args)

    fn detach() -> Result<Nil, String>:
        self.inner.detach()

    fn run() -> Result<Nil, String>:
        self.inner.run()

    fn pause() -> Result<Nil, String>:
        self.inner.pause()

    fn resume() -> Result<Nil, String>:
        self.inner.resume()

    fn step_over() -> Result<Nil, String>:
        self.inner.step_over()

    fn step_in() -> Result<Nil, String>:
        self.inner.step_in()

    fn step_out() -> Result<Nil, String>:
        self.inner.step_out()

    fn add_breakpoint(file: String, line: Int) -> Result<Int, String>:
        self.inner.add_breakpoint(file, line)

    fn remove_breakpoint(file: String, line: Int) -> Result<Nil, String>:
        self.inner.remove_breakpoint(file, line)

    fn stack_trace() -> Result<[FrameInfo], String>:
        self.inner.stack_trace()

    fn locals() -> Result<[VarInfo], String>:
        self.inner.locals()

    fn evaluate(expr: String) -> Result<String, String>:
        self.inner.evaluate(expr)

    fn current_location() -> Result<LocationInfo, String>:
        self.inner.current_location()

    fn read_memory(addr: i64, size: i32) -> Result<[i32], text>:
        self.inner.read_memory(addr, size)

    fn write_memory(addr: i64, data: [i32]) -> Result<text, text>:
        self.inner.write_memory(addr, data)

    fn read_register(name: text) -> Result<i64, text>:
        self.inner.read_register(name)

    fn read_all_registers() -> Result<Dict<text, i64>, text>:
        self.inner.read_all_registers()

    fn set_breakpoint_at_addr(addr: i64) -> Result<i32, text>:
        self.inner.set_breakpoint_at_addr(addr)

    fn set_watchpoint(expr: text, access: text) -> Result<i32, text>:
        self.inner.set_watchpoint(expr, access)

    fn watchpoint_capacity() -> i32:
        self.inner.watchpoint_capacity()
