
class MemorySnapshot:
    addr: i64
    data: [i32]

    static fn capture(addr: i64, data: [i32]) -> MemorySnapshot:
        MemorySnapshot(addr: addr, data: data)

class WatchRegion:
    addr: i64
    size: i64

    static fn of(addr: i64, size: i64) -> WatchRegion:
        WatchRegion(addr: addr, size: size)
