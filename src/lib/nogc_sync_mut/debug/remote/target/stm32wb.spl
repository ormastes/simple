# STM32WB Target Definition
# Wraps ArmCortexMTarget with STM32WB-specific configuration.

use std.nogc_sync_mut.debug.remote.target.arm_cortex_m.ArmCortexMTarget

class Stm32WbTarget:
    core: ArmCortexMTarget
    stlink_serial: text
    openocd_cfg: text
    gdb_port: i32

impl Stm32WbTarget:
    static fn default() -> Stm32WbTarget:
        Stm32WbTarget(
            core: ArmCortexMTarget.cortex_m4(),
            stlink_serial: "0671FF555755846687041216",
            openocd_cfg: "board/st_nucleo_wb55.cfg",
            gdb_port: 3334
        )

    static fn with_serial(serial: text) -> Stm32WbTarget:
        Stm32WbTarget(
            core: ArmCortexMTarget.cortex_m4(),
            stlink_serial: serial,
            openocd_cfg: "board/st_nucleo_wb55.cfg",
            gdb_port: 3334
        )

    fn name() -> text:
        "STM32WB (Cortex-M4)"

    fn core_name() -> text:
        self.core.core_name()

    fn register_count() -> i32:
        self.core.register_count()

    fn register_name(index: i32) -> text:
        self.core.register_name(index)

    fn register_index(name: text) -> i32:
        self.core.register_index(name)

    fn hw_breakpoint_count() -> i32:
        self.core.hw_breakpoint_count()

    fn hw_watchpoint_count() -> i32:
        self.core.hw_watchpoint_count()

    fn breakpoint_instruction() -> [i32]:
        self.core.breakpoint_instruction()

    fn word_size() -> i32:
        self.core.word_size()

    # Flash base address for STM32WB
    fn flash_base() -> i64:
        val _ = self.core.word_size()
        0x08000000

    # SRAM1 base address
    fn sram_base() -> i64:
        val _ = self.core.word_size()
        0x20000000

    # SRAM1 size in bytes (256 KB for WB55)
    fn sram_size() -> i64:
        val _ = self.core.word_size()
        262144
