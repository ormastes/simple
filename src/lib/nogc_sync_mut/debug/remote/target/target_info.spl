#![allow(primitive_api)]
# Debug Target Info Trait
# Unified interface for architecture-specific register layout, calling convention,
# and debug hardware capabilities. All target classes implement this trait
# structurally, enabling RemoteGenericBackend to work with any architecture.

use std.nogc_sync_mut.debug.remote.types.{Architecture, Endianness}

trait DebugTargetInfo:
    fn name() -> text
    fn arch() -> Architecture
    fn endianness() -> Endianness
    fn register_count() -> i32
    fn register_name(index: i32) -> text
    fn register_index(name: text) -> i32
    fn register_size(index: i32) -> i32
    fn arg_registers() -> [i32]
    fn callee_saved_registers() -> [i32]
    fn pc_register_index() -> i32
    fn sp_register_index() -> i32
    fn fp_register_index() -> i32
    fn return_register_index() -> i32
    fn hw_breakpoint_count() -> i32
    fn hw_watchpoint_count() -> i32
    fn supports_single_step() -> bool
    fn breakpoint_instruction() -> [i32]
