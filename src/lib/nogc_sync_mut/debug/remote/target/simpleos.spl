#![allow(primitive_api)]
use std.nogc_sync_mut.debug.remote.types.{Architecture, Endianness}
use std.nogc_sync_mut.debug.remote.target.x86_64.X86_64Target

class SimpleOsTarget:
    core: X86_64Target
    kernel_base: i64

impl SimpleOsTarget:
    static fn create() -> SimpleOsTarget:
        SimpleOsTarget(core: X86_64Target.create(), kernel_base: 0xFFFFFFFF80000000)

    fn name() -> text:
        self.core.name()

    fn arch() -> Architecture:
        self.core.arch()

    fn endianness() -> Endianness:
        self.core.endianness()

    fn register_count() -> i32:
        self.core.register_count()

    fn register_name(index: i32) -> text:
        self.core.register_name(index)

    fn register_index(name: text) -> i32:
        self.core.register_index(name)

    fn register_size(index: i32) -> i32:
        self.core.register_size(index)

    fn arg_registers() -> [i32]:
        self.core.arg_registers()

    fn callee_saved_registers() -> [i32]:
        self.core.callee_saved_registers()

    fn pc_register_index() -> i32:
        self.core.pc_register_index()

    fn sp_register_index() -> i32:
        self.core.sp_register_index()

    fn fp_register_index() -> i32:
        self.core.fp_register_index()

    fn return_register_index() -> i32:
        self.core.return_register_index()

    fn hw_breakpoint_count() -> i32:
        self.core.hw_breakpoint_count()

    fn hw_watchpoint_count() -> i32:
        self.core.hw_watchpoint_count()

    fn supports_single_step() -> bool:
        self.core.supports_single_step()

    fn breakpoint_instruction() -> [i32]:
        self.core.breakpoint_instruction()

    # Kernel addresses occupy the upper half of 64-bit space (high bit set = negative in signed i64)
    fn is_kernel_addr(addr: i64) -> bool:
        addr < 0

    fn qemu_virt_ram_base() -> i64:
        self.core.qemu_virt_ram_base()

    fn qemu_virt_uart_base() -> i64:
        self.core.qemu_virt_uart_base()
