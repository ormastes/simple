fn t32_exit() -> Result<i64, T32Error>:
    if _fp_Exit == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_Exit, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

