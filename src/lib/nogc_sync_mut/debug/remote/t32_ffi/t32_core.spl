fn t32_nop_ex() -> Result<i64, T32Error>:
    if _fp_NopEx == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_NopEx, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_NopFail(void)
fn t32_nop_fail() -> Result<i64, T32Error>:
    if _fp_NopFail == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_NopFail, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Cmd(const char* command)
fn t32_cmd(command: text) -> Result<i64, T32Error>:
    if _fp_Cmd == 0: return Err(make_t32_error(-999))
    val cmd = spl_str_to_cstr(command)
    var args: [i64] = [cmd]
    val rc = spl_wffi_call_i64(_fp_Cmd, args, 1)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetPracticeState(int* pstate)
fn t32_get_practice_state() -> Result<i64, T32Error>:
    if _fp_GetPracticeState == 0: return Err(make_t32_error(-999))
    val state_buf = spl_alloc_buffer(8)
    var args: [i64] = [state_buf]
    val rc = spl_wffi_call_i64(_fp_GetPracticeState, args, 1)
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val state = spl_read_i32(state_buf)
        spl_free_buffer(state_buf)
        Ok(state)
    else:
        spl_free_buffer(state_buf)
        Err(make_t32_error(rc))

# int T32_GetState(int* pstate)
fn t32_get_state() -> Result<i64, T32Error>:
    if _fp_GetState == 0: return Err(make_t32_error(-999))
    val state_buf = spl_alloc_buffer(8)
    var args: [i64] = [state_buf]
    val rc = spl_wffi_call_i64(_fp_GetState, args, 1)
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val state = spl_read_i32(state_buf)
        spl_free_buffer(state_buf)
        Ok(state)
    else:
        spl_free_buffer(state_buf)
        Err(make_t32_error(rc))

# int T32_Stop(void)
fn t32_stop() -> Result<i64, T32Error>:
    if _fp_Stop == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_Stop, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_CmdWin(uint32_t win_handle, const char* command)
fn t32_cmd_win(win_handle: i64, command: text) -> Result<i64, T32Error>:
    if _fp_CmdWin == 0: return Err(make_t32_error(-999))
    val cmd = spl_str_to_cstr(command)
    var args: [i64] = [win_handle, cmd]
    val rc = spl_wffi_call_i64(_fp_CmdWin, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetMessage(char* msg, uint16_t* ptype)
fn t32_get_message() -> Result<(text, i64), T32Error>:
    if _fp_GetMessage == 0: return Err(make_t32_error(-999))
    val msg_buf = spl_alloc_buffer(1024)
    val type_buf = spl_alloc_buffer(8)
    var args: [i64] = [msg_buf, type_buf]
    val rc = spl_wffi_call_i64(_fp_GetMessage, args, 2)
    extern fn spl_cstr_to_str(ptr: i64) -> text
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val msg = spl_cstr_to_str(msg_buf)
        val msg_type = spl_read_i32(type_buf)
        spl_free_buffer(msg_buf)
        spl_free_buffer(type_buf)
        Ok((msg, msg_type))
    else:
        spl_free_buffer(msg_buf)
        spl_free_buffer(type_buf)
        Err(make_t32_error(rc))

# int T32_GetTriggerMessage(char* msg)
fn t32_get_trigger_message() -> Result<text, T32Error>:
    if _fp_GetTriggerMessage == 0: return Err(make_t32_error(-999))
    val msg_buf = spl_alloc_buffer(1024)
    var args: [i64] = [msg_buf]
    val rc = spl_wffi_call_i64(_fp_GetTriggerMessage, args, 1)
    extern fn spl_cstr_to_str(ptr: i64) -> text
    if rc == T32_OK:
        val msg = spl_cstr_to_str(msg_buf)
        spl_free_buffer(msg_buf)
        Ok(msg)
    else:
        spl_free_buffer(msg_buf)
        Err(make_t32_error(rc))
