# T32 Core API FFI — connect, disconnect, ping, cmd, state, message

use std.ffi.dynamic.{spl_dlsym, spl_wffi_call_i64}
use std.ffi.dynamic_versioned.{VersionedDynLib}
use std.debug.remote.t32_ffi.t32_types.{T32_OK, T32Error, make_t32_error}

extern fn spl_str_to_cstr(s: text) -> i64
extern fn spl_alloc_buffer(size: i64) -> i64
extern fn spl_free_buffer(ptr: i64)

var _fp_Config: i64 = 0
var _fp_Init: i64 = 0
var _fp_Attach: i64 = 0
var _fp_Terminate: i64 = 0
var _fp_Exit: i64 = 0
var _fp_Ping: i64 = 0
var _fp_Nop: i64 = 0
var _fp_NopEx: i64 = 0
var _fp_NopFail: i64 = 0
var _fp_Cmd: i64 = 0
var _fp_CmdWin: i64 = 0
var _fp_GetPracticeState: i64 = 0
var _fp_GetState: i64 = 0
var _fp_Stop: i64 = 0
var _fp_GetMessage: i64 = 0
var _fp_GetTriggerMessage: i64 = 0

fn t32_core_bind(lib: VersionedDynLib) -> [text]:
    var missing: [text] = []
    _fp_Config = lib.lib.sym("T32_Config")
    if _fp_Config == 0: missing.push("T32_Config")
    _fp_Init = lib.lib.sym("T32_Init")
    if _fp_Init == 0: missing.push("T32_Init")
    _fp_Attach = lib.lib.sym("T32_Attach")
    if _fp_Attach == 0: missing.push("T32_Attach")
    _fp_Terminate = lib.lib.sym("T32_Terminate")
    if _fp_Terminate == 0: missing.push("T32_Terminate")
    _fp_Exit = lib.lib.sym("T32_Exit")
    if _fp_Exit == 0: missing.push("T32_Exit")
    _fp_Ping = lib.lib.sym("T32_Ping")
    if _fp_Ping == 0: missing.push("T32_Ping")
    _fp_Nop = lib.lib.sym("T32_Nop")
    _fp_NopEx = lib.lib.sym("T32_NopEx")
    _fp_NopFail = lib.lib.sym("T32_NopFail")
    _fp_Cmd = lib.lib.sym("T32_Cmd")
    if _fp_Cmd == 0: missing.push("T32_Cmd")
    _fp_CmdWin = lib.lib.sym("T32_CmdWin")
    _fp_GetPracticeState = lib.lib.sym("T32_GetPracticeState")
    _fp_GetState = lib.lib.sym("T32_GetState")
    _fp_Stop = lib.lib.sym("T32_Stop")
    _fp_GetMessage = lib.lib.sym("T32_GetMessage")
    _fp_GetTriggerMessage = lib.lib.sym("T32_GetTriggerMessage")
    missing

fn t32_core_function_names() -> [text]:
    ["T32_Config", "T32_Init", "T32_Attach", "T32_Terminate", "T32_Exit",
     "T32_Ping", "T32_Nop", "T32_NopEx", "T32_NopFail",
     "T32_Cmd", "T32_CmdWin", "T32_GetPracticeState", "T32_GetState",
     "T32_Stop", "T32_GetMessage", "T32_GetTriggerMessage"]

# int T32_Config(const char* str1, const char* str2)
fn t32_config(key: text, value: text) -> Result<i64, T32Error>:
    if _fp_Config == 0: return Err(make_t32_error(-999))
    val k = spl_str_to_cstr(key)
    val v = spl_str_to_cstr(value)
    var args: [i64] = [k, v]
    val rc = spl_wffi_call_i64(_fp_Config, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Init(void)
fn t32_init() -> Result<i64, T32Error>:
    if _fp_Init == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_Init, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Attach(int dev)
fn t32_attach(dev: i64) -> Result<i64, T32Error>:
    if _fp_Attach == 0: return Err(make_t32_error(-999))
    var args: [i64] = [dev]
    val rc = spl_wffi_call_i64(_fp_Attach, args, 1)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Terminate(void)
fn t32_terminate() -> Result<i64, T32Error>:
    if _fp_Terminate == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_Terminate, args, 0)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

