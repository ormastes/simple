# int T32_DAPAccessInitSWD(uint32_t handle, int instance)
fn t32_dap_access_init_swd(handle: i64, instance: i64) -> Result<i64, T32Error>:
    if _fp_DAPAccessInitSWD == 0: return Err(make_t32_error(-999))
    var args: [i64] = [handle, instance]
    val rc = spl_wffi_call_i64(_fp_DAPAccessInitSWD, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_ExecuteLua(const char* filename, int mode)
fn t32_execute_lua(filename: text, mode: i64) -> Result<i64, T32Error>:
    if _fp_ExecuteLua == 0: return Err(make_t32_error(-999))
    val fname = spl_str_to_cstr(filename)
    var args: [i64] = [fname, mode]
    val rc = spl_wffi_call_i64(_fp_ExecuteLua, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetSocketHandle(void) -> socket fd
fn t32_get_socket_handle() -> Result<i64, T32Error>:
    if _fp_GetSocketHandle == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_GetSocketHandle, args, 0)
    # Returns socket handle (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))
