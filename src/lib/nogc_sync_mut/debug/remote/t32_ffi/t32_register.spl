@allow(primitive_api)
# T32 Register/Variable/Symbol API FFI — register R/W, CPU info, source, variables, symbols

use std.ffi.dynamic.{spl_dlsym, spl_wffi_call_i64}
use std.ffi.dynamic_versioned.{VersionedDynLib}
use std.debug.remote.t32_ffi.t32_types.{T32_OK, T32Error, make_t32_error}

extern fn spl_str_to_cstr(s: text) -> i64
extern fn spl_alloc_buffer(size: i64) -> i64
extern fn spl_free_buffer(ptr: i64)
extern fn spl_read_bytes(ptr: i64, len: i64) -> [i64]
extern fn spl_write_bytes(ptr: i64, data: [i64], len: i64)

var _fp_ReadRegisterByName: i64 = 0
var _fp_WriteRegisterByName: i64 = 0
var _fp_ReadRegister: i64 = 0
var _fp_WriteRegister: i64 = 0
var _fp_GetCpuInfo: i64 = 0
var _fp_GetSource: i64 = 0
var _fp_GetSelectedSource: i64 = 0
var _fp_ReadVariableValue: i64 = 0
var _fp_WriteVariableValue: i64 = 0
var _fp_GetSymbolFromAddress: i64 = 0

fn t32_register_bind(lib: VersionedDynLib) -> [text]:
    var missing: [text] = []
    _fp_ReadRegisterByName = lib.lib.sym("T32_ReadRegisterByName")
    if _fp_ReadRegisterByName == 0: missing.push("T32_ReadRegisterByName")
    _fp_WriteRegisterByName = lib.lib.sym("T32_WriteRegisterByName")
    if _fp_WriteRegisterByName == 0: missing.push("T32_WriteRegisterByName")
    _fp_ReadRegister = lib.lib.sym("T32_ReadRegister")
    _fp_WriteRegister = lib.lib.sym("T32_WriteRegister")
    _fp_GetCpuInfo = lib.lib.sym("T32_GetCpuInfo")
    _fp_GetSource = lib.lib.sym("T32_GetSource")
    _fp_GetSelectedSource = lib.lib.sym("T32_GetSelectedSource")
    _fp_ReadVariableValue = lib.lib.sym("T32_ReadVariableValue")
    _fp_WriteVariableValue = lib.lib.sym("T32_WriteVariableValue")
    _fp_GetSymbolFromAddress = lib.lib.sym("T32_GetSymbolFromAddress")
    missing

fn t32_register_function_names() -> [text]:
    ["T32_ReadRegisterByName", "T32_WriteRegisterByName",
     "T32_ReadRegister", "T32_WriteRegister",
     "T32_GetCpuInfo", "T32_GetSource", "T32_GetSelectedSource",
     "T32_ReadVariableValue", "T32_WriteVariableValue",
     "T32_GetSymbolFromAddress"]

# int T32_ReadRegisterByName(const char* name, uint32_t* pval, uint32_t* phval)
fn t32_read_register_by_name(name: text) -> Result<(i64, i64), T32Error>:
    if _fp_ReadRegisterByName == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    val val_buf = spl_alloc_buffer(8)
    val hval_buf = spl_alloc_buffer(8)
    var args: [i64] = [n, val_buf, hval_buf]
    val rc = spl_wffi_call_i64(_fp_ReadRegisterByName, args, 3)
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val lo = spl_read_i32(val_buf)
        val hi = spl_read_i32(hval_buf)
        spl_free_buffer(val_buf)
        spl_free_buffer(hval_buf)
        Ok((lo, hi))
    else:
        spl_free_buffer(val_buf)
        spl_free_buffer(hval_buf)
        Err(make_t32_error(rc))

# int T32_WriteRegisterByName(const char* name, uint32_t val, uint32_t hval)
fn t32_write_register_by_name(name: text, value: i64, hvalue: i64) -> Result<i64, T32Error>:
    if _fp_WriteRegisterByName == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    var args: [i64] = [n, value, hvalue]
    val rc = spl_wffi_call_i64(_fp_WriteRegisterByName, args, 3)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_ReadRegister(uint32_t mask_lo, uint32_t mask_hi, uint32_t* values)
fn t32_read_register(mask_lo: i64, mask_hi: i64) -> Result<[i64], T32Error>:
    if _fp_ReadRegister == 0: return Err(make_t32_error(-999))
    # Allocate buffer for up to 64 register values (32 bits each)
    val max_regs: i64 = 64
    val buf = spl_alloc_buffer(max_regs * 4)
    var args: [i64] = [mask_lo, mask_hi, buf]
    val rc = spl_wffi_call_i64(_fp_ReadRegister, args, 3)
    if rc == T32_OK:
        val data = spl_read_bytes(buf, max_regs * 4)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_WriteRegister(uint32_t mask_lo, uint32_t mask_hi, uint32_t* values)
fn t32_write_register(mask_lo: i64, mask_hi: i64, values: [i64]) -> Result<i64, T32Error>:
    if _fp_WriteRegister == 0: return Err(make_t32_error(-999))
    val size = values.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, values, size)
    var args: [i64] = [mask_lo, mask_hi, buf]
    val rc = spl_wffi_call_i64(_fp_WriteRegister, args, 3)
    spl_free_buffer(buf)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetCpuInfo(char** pname, uint16_t* pfpu, uint16_t* pendian, uint16_t* pbitwidth)
fn t32_get_cpu_info() -> Result<(text, i64, i64, i64), T32Error>:
    if _fp_GetCpuInfo == 0: return Err(make_t32_error(-999))
    val name_ptr_buf = spl_alloc_buffer(8)
    val fpu_buf = spl_alloc_buffer(8)
    val endian_buf = spl_alloc_buffer(8)
    val width_buf = spl_alloc_buffer(8)
    var args: [i64] = [name_ptr_buf, fpu_buf, endian_buf, width_buf]
    val rc = spl_wffi_call_i64(_fp_GetCpuInfo, args, 4)
    extern fn spl_read_i32(ptr: i64) -> i64
    extern fn spl_read_ptr(ptr: i64) -> i64
    extern fn spl_cstr_to_str(ptr: i64) -> text
    if rc == T32_OK:
        val name_ptr = spl_read_ptr(name_ptr_buf)
        val name = spl_cstr_to_str(name_ptr)
        val fpu = spl_read_i32(fpu_buf)
        val endian = spl_read_i32(endian_buf)
        val width = spl_read_i32(width_buf)
        spl_free_buffer(name_ptr_buf)
        spl_free_buffer(fpu_buf)
        spl_free_buffer(endian_buf)
        spl_free_buffer(width_buf)
        Ok((name, fpu, endian, width))
    else:
        spl_free_buffer(name_ptr_buf)
        spl_free_buffer(fpu_buf)
        spl_free_buffer(endian_buf)
        spl_free_buffer(width_buf)
        Err(make_t32_error(rc))

# int T32_GetSource(uint32_t addr, char* filename, uint32_t* pline)
fn t32_get_source(addr: i64) -> Result<(text, i64), T32Error>:
    if _fp_GetSource == 0: return Err(make_t32_error(-999))
    val fname_buf = spl_alloc_buffer(1024)
    val line_buf = spl_alloc_buffer(8)
    var args: [i64] = [addr, fname_buf, line_buf]
    val rc = spl_wffi_call_i64(_fp_GetSource, args, 3)
    extern fn spl_cstr_to_str(ptr: i64) -> text
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val filename = spl_cstr_to_str(fname_buf)
        val line = spl_read_i32(line_buf)
        spl_free_buffer(fname_buf)
        spl_free_buffer(line_buf)
        Ok((filename, line))
    else:
        spl_free_buffer(fname_buf)
        spl_free_buffer(line_buf)
        Err(make_t32_error(rc))

# int T32_GetSelectedSource(char* filename, uint32_t* pline)
fn t32_get_selected_source() -> Result<(text, i64), T32Error>:
    if _fp_GetSelectedSource == 0: return Err(make_t32_error(-999))
    val fname_buf = spl_alloc_buffer(1024)
    val line_buf = spl_alloc_buffer(8)
    var args: [i64] = [fname_buf, line_buf]
    val rc = spl_wffi_call_i64(_fp_GetSelectedSource, args, 2)
    extern fn spl_cstr_to_str(ptr: i64) -> text
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val filename = spl_cstr_to_str(fname_buf)
        val line = spl_read_i32(line_buf)
        spl_free_buffer(fname_buf)
        spl_free_buffer(line_buf)
        Ok((filename, line))
    else:
        spl_free_buffer(fname_buf)
        spl_free_buffer(line_buf)
        Err(make_t32_error(rc))

# int T32_ReadVariableValue(const char* name, uint32_t* pval, uint32_t* phval)
fn t32_read_variable_value(name: text) -> Result<(i64, i64), T32Error>:
    if _fp_ReadVariableValue == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    val val_buf = spl_alloc_buffer(8)
    val hval_buf = spl_alloc_buffer(8)
    var args: [i64] = [n, val_buf, hval_buf]
    val rc = spl_wffi_call_i64(_fp_ReadVariableValue, args, 3)
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val lo = spl_read_i32(val_buf)
        val hi = spl_read_i32(hval_buf)
        spl_free_buffer(val_buf)
        spl_free_buffer(hval_buf)
        Ok((lo, hi))
    else:
        spl_free_buffer(val_buf)
        spl_free_buffer(hval_buf)
        Err(make_t32_error(rc))

# int T32_WriteVariableValue(const char* name, uint32_t val, uint32_t hval)
fn t32_write_variable_value(name: text, value: i64, hvalue: i64) -> Result<i64, T32Error>:
    if _fp_WriteVariableValue == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    var args: [i64] = [n, value, hvalue]
    val rc = spl_wffi_call_i64(_fp_WriteVariableValue, args, 3)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetSymbolFromAddress(char* name, uint32_t addr, uint32_t* psize, uint32_t* poffs)
fn t32_get_symbol_from_address(addr: i64) -> Result<(text, i64, i64), T32Error>:
    if _fp_GetSymbolFromAddress == 0: return Err(make_t32_error(-999))
    val name_buf = spl_alloc_buffer(1024)
    val size_buf = spl_alloc_buffer(8)
    val offs_buf = spl_alloc_buffer(8)
    var args: [i64] = [name_buf, addr, size_buf, offs_buf]
    val rc = spl_wffi_call_i64(_fp_GetSymbolFromAddress, args, 4)
    extern fn spl_cstr_to_str(ptr: i64) -> text
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val name = spl_cstr_to_str(name_buf)
        val size = spl_read_i32(size_buf)
        val offs = spl_read_i32(offs_buf)
        spl_free_buffer(name_buf)
        spl_free_buffer(size_buf)
        spl_free_buffer(offs_buf)
        Ok((name, size, offs))
    else:
        spl_free_buffer(name_buf)
        spl_free_buffer(size_buf)
        spl_free_buffer(offs_buf)
        Err(make_t32_error(rc))
