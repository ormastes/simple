# Register Replay Features
#
# Registers replay-related feature handlers (reverse step, reverse continue,
# record start, replay start) into the FeatureRegistry at appropriate ranks.

use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}
use std.nogc_sync_mut.debug.remote.feature.registry.{FeatureRegistry}

fn register_replay_features(registry: FeatureRegistry, backend_name: text):
    registry.register(FeatureId.ReverseStep, backend_name, FeatureRank.NATIVE())
    registry.register(FeatureId.ReverseContinue, backend_name, FeatureRank.NATIVE())

fn register_qemu_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "qemu-replay")

fn register_process_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "process-replay")

fn register_vm_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "vm-replay")
