# Register Replay Features
#
# Registers replay-related feature handlers (reverse step, reverse continue)
# into the FeatureRegistry at appropriate ranks.
# Software/emulator backends use NATIVE rank; hardware backends use EMULATED.

use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}
use std.nogc_sync_mut.debug.remote.feature.registry.{FeatureRegistry, FeatureHandler}

fn register_replay_features_at_rank(registry: FeatureRegistry, backend_name: text, rank: i32):
    registry.register(FeatureHandler.of(
        FeatureId.ReverseStep, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "reverse step via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.ReverseContinue, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "reverse continue via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.RecordStart, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "record start via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.RecordStop, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "record stop via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.ReplayStart, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "replay start via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.ReplayStop, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "replay stop via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.ReverseFinish, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "reverse finish via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.ReverseWatch, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "reverse watch via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.CheckpointSave, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "checkpoint save via {backend_name}"
    ))
    registry.register(FeatureHandler.of(
        FeatureId.CheckpointRestore, rank, backend_name,
        \args: Err("replay not wired: {backend_name}"),
        "checkpoint restore via {backend_name}"
    ))

fn register_replay_features(registry: FeatureRegistry, backend_name: text):
    register_replay_features_at_rank(registry, backend_name, FeatureRank.NATIVE())

fn register_qemu_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "qemu-replay")

fn register_process_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "process-replay")

fn register_vm_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "vm-replay")

# Hardware adapter replay registration — uses EMULATED rank (4)
# since replay on real hardware is software-emulated via checkpoint/restore.

fn register_hw_replay_features(registry: FeatureRegistry, backend_name: text):
    register_replay_features_at_rank(registry, backend_name, FeatureRank.EMULATED())

fn register_stm32h7_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "stm32h7-replay")

fn register_stm32wb_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "stm32wb-replay")

fn register_ch32v307_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "ch32v307-replay")

fn register_arduino_r4_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "arduino-r4-replay")

fn register_qemu_arm_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "qemu-arm-replay")

fn register_qemu_rv32_replay_features(registry: FeatureRegistry):
    register_replay_features(registry, "qemu-rv32-replay")

fn register_ghdl_rv32_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "ghdl-rv32-replay")

fn register_trace32_replay_features(registry: FeatureRegistry):
    register_hw_replay_features(registry, "trace32-replay")
