# GDB RSP Feature Registration
# Registers GDB Remote Serial Protocol features for direct RSP connections.

use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}
use std.nogc_sync_mut.debug.remote.feature.registry.FeatureRegistry

fn register_rsp_features(registry: FeatureRegistry):
    registry.register_stub(FeatureId.RspConnect, FeatureRank.NATIVE())
    registry.register_stub(FeatureId.RspPacketSend, FeatureRank.NATIVE())
    registry.register_stub(FeatureId.Halt, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.Resume, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.SingleStep, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.ReadMemory, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.WriteMemory, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.ReadAllRegisters, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.SetBreakpoint, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.ClearBreakpoint, FeatureRank.BRIDGE())
    registry.register_stub(FeatureId.SetWatchpoint, FeatureRank.BRIDGE())
