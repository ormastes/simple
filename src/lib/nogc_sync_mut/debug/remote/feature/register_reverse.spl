# GDB Reverse Debugging Feature Registration
# Registers reverse-step and reverse-continue features for GDB MI backends.

use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}
use std.nogc_sync_mut.debug.remote.feature.registry.FeatureRegistry

fn register_reverse_features(registry: FeatureRegistry):
    registry.register_stub(FeatureId.ReverseStep, FeatureRank.NATIVE())
    registry.register_stub(FeatureId.ReverseContinue, FeatureRank.NATIVE())
