# GDB Non-Stop Mode Feature Registration
# Registers non-stop and async interrupt features for GDB MI backends.

use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}
use std.nogc_sync_mut.debug.remote.feature.registry.FeatureRegistry

fn register_nonstop_features(registry: FeatureRegistry):
    registry.register(FeatureId.NonStopMode, FeatureRank.NATIVE())
    registry.register(FeatureId.AsyncInterrupt, FeatureRank.NATIVE())
