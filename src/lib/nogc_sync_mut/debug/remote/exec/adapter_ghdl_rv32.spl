#![allow(export_outside_init)]
# GHDL RV32 Adapter
#
# ExecTarget implementation for GHDL RISC-V 32-bit VHDL simulation.
# Connects to a running GHDL simulation with GDB remote stub.
#
# Feature ID: #RJE-009

use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap, Architecture, rv32_reg_name
}
use std.nogc_sync_mut.debug.remote.exec.manager.{RemoteExecutionManager}
use std.nogc_sync_mut.debug.remote.protocol.gdb_mi.{GdbMiClient}
use std.nogc_sync_mut.debug.remote.types.{DebugConfig, Architecture}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{CapabilityReport, probe_ghdl, probe_ghdl_mailbox}

fn default_ghdl_gdb_port() -> i32:
    3333

class GhdlRv32Adapter:
    """GHDL RV32 adapter using GDB-MI for VHDL-simulated RISC-V execution."""
    gdb: Option<GdbMiClient>
    port: i32
    memory_map: MemoryMap
    connected: bool

    static fn new() -> GhdlRv32Adapter:
        GhdlRv32Adapter(
            gdb: nil,
            port: default_ghdl_gdb_port(),
            memory_map: MemoryMap.ghdl_rv32(),
            connected: false
        )

    fn is_available() -> bool:
        val report = probe_ghdl()
        report.is_runnable()

    fn capability_report() -> CapabilityReport:
        probe_ghdl()

    me connect() -> Result<text, text>:
        if not self.is_available():
            val report = probe_ghdl()
            return Err("GHDL semihost prerequisites missing: {report.detail}")

        val config = DebugConfig(
            host: "localhost",
            port: self.port,
            target: Architecture.RiscV32,
            program: "",
            options: {}
        )
        val gdb_result = GdbMiClient.connect(config)
        if gdb_result.is_err():
            return Err("GDB connect to GHDL failed: {gdb_result.err().unwrap()}")

        self.gdb = Some(gdb_result.ok.unwrap())
        self.connected = true
        Ok("connected to GHDL RV32 via GDB-MI on port {self.port}")

    me disconnect():
        match self.gdb:
            Some(g): g.disconnect()
            nil: pass_dn
        self.gdb = nil
        self.connected = false

    fn write_code(addr: i64, bytes: [i32]) -> Result<text, text>:
        match self.gdb:
            Some(g): g.write_memory(addr, bytes)
            nil: Err("not connected")

    fn read_code(addr: i64, size: i64) -> Result<[i32], text>:
        match self.gdb:
            Some(g): g.read_memory(addr, size as i32)
            nil: Err("not connected")

    fn write_register(reg: i64, value: i64) -> Result<text, text>:
        match self.gdb:
            Some(g):
                val name = rv32_reg_name(reg)
                g.write_register(name, value)
            nil: Err("not connected")

    fn read_register(reg: i64) -> Result<i64, text>:
        match self.gdb:
            Some(g):
                val name = rv32_reg_name(reg)
                g.read_register(name)
            nil: Err("not connected")

    fn resume() -> Result<text, text>:
        match self.gdb:
            Some(g): g.resume()
            nil: Err("not connected")

    fn wait_halt(timeout_ms: i64) -> Result<text, text>:
        match self.gdb:
            Some(g):
                val secs = if timeout_ms <= 0: 1 else:
                    val whole = timeout_ms / 1000
                    if whole < 1: 1 else: whole
                shell("sleep {secs}")
                g.halt()
            nil: Err("not connected")

    fn create_manager() -> Result<RemoteExecutionManager, text>:
        if not self.connected:
            return Err("not connected — call connect() first")

        Ok(RemoteExecutionManager.new(
            arch: Architecture.RiscV32,
            memory_map: self.memory_map,
            write_code_fn: \addr, bytes: self.write_code(addr, bytes),
            read_code_fn: \addr, size: self.read_code(addr, size),
            write_register_fn: \reg, val_: self.write_register(reg, val_),
            read_register_fn: \reg: self.read_register(reg),
            resume_fn: \: self.resume(),
            wait_halt_fn: \timeout: self.wait_halt(timeout)
        ))

class GhdlRv32MailboxAdapter:
    """GHDL RV32 mailbox adapter — runs simulation directly via ghdl_mailbox_runner.

    Unlike the semihost adapter (GDB-MI based), this adapter invokes the
    runner script and parses the ram_sentinel result from simulation output.
    No GDB connection is needed."""
    runner_path: text
    elf_path: text
    timeout_s: i64
    last_exit_code: i64
    last_output: text

    static fn new() -> GhdlRv32MailboxAdapter:
        GhdlRv32MailboxAdapter(
            runner_path: "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_mailbox_runner.shs",
            elf_path: "",
            timeout_s: 30,
            last_exit_code: -1,
            last_output: ""
        )

    fn is_available() -> bool:
        val report = probe_ghdl_mailbox()
        report.is_runnable()

    fn capability_report() -> CapabilityReport:
        probe_ghdl_mailbox()

    me set_elf(path: text):
        self.elf_path = path

    me set_timeout(seconds: i64):
        self.timeout_s = seconds

    me execute() -> Result<text, text>:
        if self.elf_path == "":
            return Err("no ELF path set — call set_elf() first")
        if not self.is_available():
            val report = probe_ghdl_mailbox()
            return Err("GHDL mailbox prerequisites missing: {report.detail}")

        val result = shell("bash {self.runner_path} {self.elf_path} {self.timeout_s}")
        self.last_exit_code = result.exit_code
        self.last_output = result.stdout

        if result.exit_code == 0:
            Ok(result.stdout)
        else:
            Err("mailbox runner failed (exit {result.exit_code}): {result.stderr}")

    fn get_exit_code() -> i64:
        self.last_exit_code

    fn get_output() -> text:
        self.last_output

export GhdlRv32Adapter
export GhdlRv32MailboxAdapter
