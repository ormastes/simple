# QEMU ARM Adapter
#
# ExecTarget implementation for QEMU ARM Cortex-M (lm3s6965evb machine).
# Launches qemu-system-arm, connects via GDB-MI for memory/register
# access and execution control.
#
# Feature ID: #RJE-008

use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap, Architecture, arm_reg_name
}
use std.nogc_sync_mut.debug.remote.exec.manager.{RemoteExecutionManager}
use std.nogc_sync_mut.debug.remote.protocol.gdb_mi.{GdbMiClient}
use std.nogc_sync_mut.debug.remote.types.{DebugConfig, Architecture}

fn default_qemu_arm_gdb_port() -> i32:
    1235

class QemuArmAdapter:
    """QEMU ARM adapter using GDB-MI for remote execution."""
    qemu_pid: i64
    gdb: Option<GdbMiClient>
    port: i32
    memory_map: MemoryMap
    connected: bool

    static fn new() -> QemuArmAdapter:
        QemuArmAdapter(
            qemu_pid: 0,
            gdb: nil,
            port: default_qemu_arm_gdb_port(),
            memory_map: MemoryMap.qemu_arm(),
            connected: false
        )

    fn is_available() -> bool:
        val qemu = shell("command -v qemu-system-arm >/dev/null 2>&1")
        val gdb = shell("command -v gdb-multiarch >/dev/null 2>&1 || command -v arm-none-eabi-gdb >/dev/null 2>&1")
        qemu.exit_code == 0 and gdb.exit_code == 0

    me connect() -> Result<text, text>:
        if not self.is_available():
            return Err("qemu-system-arm or target-aware GDB not available")

        val cmd = "qemu-system-arm -machine lm3s6965evb -nographic -no-reboot -gdb tcp::{self.port} -S >/dev/null 2>&1 & echo $!"
        val start = shell(cmd)
        val pid_text = start.stdout.trim()
        self.qemu_pid = if pid_text.len() > 0: pid_text.to_i64() else: -1

        if self.qemu_pid <= 0:
            return Err("failed to launch QEMU")

        shell("sleep 0.5")

        val config = DebugConfig(
            host: "localhost",
            port: self.port,
            target: Architecture.Arm32,
            program: "",
            options: {}
        )
        val gdb_result = GdbMiClient.connect(config)
        if gdb_result.is_err():
            self.stop_qemu()
            return Err("GDB connect failed: {gdb_result.err().unwrap()}")

        self.gdb = Some(gdb_result.ok.unwrap())
        self.connected = true
        Ok("connected to QEMU ARM via GDB-MI on port {self.port}")

    me disconnect():
        match self.gdb:
            Some(g): g.disconnect()
            nil: pass_dn
        self.gdb = nil
        self.stop_qemu()
        self.connected = false

    me stop_qemu():
        if self.qemu_pid > 0:
            shell("kill {self.qemu_pid} >/dev/null 2>&1 || true")
            shell("sleep 0.1")
            shell("kill -9 {self.qemu_pid} >/dev/null 2>&1 || true")
            self.qemu_pid = 0

    fn write_code(addr: i64, bytes: [i32]) -> Result<text, text>:
        match self.gdb:
            Some(g): g.write_memory(addr, bytes)
            nil: Err("not connected")

    fn read_code(addr: i64, size: i64) -> Result<[i32], text>:
        match self.gdb:
            Some(g): g.read_memory(addr, size as i32)
            nil: Err("not connected")

    fn write_register(reg: i64, value: i64) -> Result<text, text>:
        match self.gdb:
            Some(g):
                val name = arm_reg_name(reg)
                g.write_register(name, value)
            nil: Err("not connected")

    fn read_register(reg: i64) -> Result<i64, text>:
        match self.gdb:
            Some(g):
                val name = arm_reg_name(reg)
                g.read_register(name)
            nil: Err("not connected")

    fn resume() -> Result<text, text>:
        match self.gdb:
            Some(g): g.resume()
            nil: Err("not connected")

    fn wait_halt(timeout_ms: i64) -> Result<text, text>:
        match self.gdb:
            Some(g):
                val secs = if timeout_ms <= 0: 1 else:
                    val whole = timeout_ms / 1000
                    if whole < 1: 1 else: whole
                shell("sleep {secs}")
                g.halt()
            nil: Err("not connected")

    fn create_manager() -> Result<RemoteExecutionManager, text>:
        if not self.connected:
            return Err("not connected — call connect() first")

        Ok(RemoteExecutionManager.new(
            arch: Architecture.Arm32,
            memory_map: self.memory_map,
            write_code_fn: \addr, bytes: self.write_code(addr, bytes),
            read_code_fn: \addr, size: self.read_code(addr, size),
            write_register_fn: \reg, val_: self.write_register(reg, val_),
            read_register_fn: \reg: self.read_register(reg),
            resume_fn: \: self.resume(),
            wait_halt_fn: \timeout: self.wait_halt(timeout)
        ))

export QemuArmAdapter
