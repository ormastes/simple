#![allow(export_outside_init)]
# Capability Report Types
#
# Normalized capability detection and status reporting for remote
# execution lanes. Centralizes probe logic so specs consume a
# uniform report shape instead of ad-hoc string checks.
#
# Feature ID: #RJE-015

use std.io_runtime.{shell}

# ============================================================================
# Capability Status
# ============================================================================

enum CapabilityStatus:
    """Status of a capability probe for a remote execution lane."""
    ready
    skip_missing_tool
    skip_missing_board
    blocked_permissions
    blocked_host_config
    failed_runtime

    fn to_text() -> text:
        match self:
            CapabilityStatus.ready: "ready"
            CapabilityStatus.skip_missing_tool: "skip_missing_tool"
            CapabilityStatus.skip_missing_board: "skip_missing_board"
            CapabilityStatus.blocked_permissions: "blocked_permissions"
            CapabilityStatus.blocked_host_config: "blocked_host_config"
            CapabilityStatus.failed_runtime: "failed_runtime"

    fn is_runnable() -> bool:
        match self:
            CapabilityStatus.ready: true
            _: false

    fn is_acceptable() -> bool:
        match self:
            CapabilityStatus.failed_runtime: false
            _: true

# ============================================================================
# Capability Report
# ============================================================================

class CapabilityReport:
    """Report from probing a single remote execution lane's readiness.

    NOTE: probe_duration_ms is a nominal field reported as 0 for probes
    that only check tool presence (command -v). Actual timing instrumentation
    is deferred until probes perform substantive work (e.g., JTAG handshake,
    GHDL elaboration) where latency measurement is meaningful."""
    lane_id: text
    status: CapabilityStatus
    tool_name: text
    detail: text
    probe_duration_ms: i64

    fn to_text() -> text:
        "[{self.lane_id}] {self.status.to_text()}: {self.detail}"

    fn is_runnable() -> bool:
        self.status.is_runnable()

    fn is_acceptable() -> bool:
        self.status.is_acceptable()

    static fn ready(lane_id: text, tool: text) -> CapabilityReport:
        CapabilityReport(
            lane_id: lane_id,
            status: CapabilityStatus.ready,
            tool_name: tool,
            detail: "{tool} is available",
            probe_duration_ms: 0
        )

    static fn skip_tool(lane_id: text, tool: text) -> CapabilityReport:
        CapabilityReport(
            lane_id: lane_id,
            status: CapabilityStatus.skip_missing_tool,
            tool_name: tool,
            detail: "{tool} not found in PATH",
            probe_duration_ms: 0
        )

    static fn skip_board(lane_id: text, board: text) -> CapabilityReport:
        CapabilityReport(
            lane_id: lane_id,
            status: CapabilityStatus.skip_missing_board,
            tool_name: board,
            detail: "{board} not detected",
            probe_duration_ms: 0
        )

    static fn blocked(lane_id: text, reason: text) -> CapabilityReport:
        CapabilityReport(
            lane_id: lane_id,
            status: CapabilityStatus.blocked_permissions,
            tool_name: "",
            detail: reason,
            probe_duration_ms: 0
        )

    static fn failed(lane_id: text, error: text) -> CapabilityReport:
        CapabilityReport(
            lane_id: lane_id,
            status: CapabilityStatus.failed_runtime,
            tool_name: "",
            detail: error,
            probe_duration_ms: 0
        )

class ExternalFormalToolchainStatus:
    yosys: bool
    sby: bool
    solver: bool
    ghdl: bool
    yosys_ghdl_plugin: bool
    detail: text

    fn is_runnable() -> bool:
        self.yosys and self.sby and self.solver and self.ghdl and self.yosys_ghdl_plugin

# ============================================================================
# Shared Probe Functions
# ============================================================================

fn probe_command(cmd: text) -> bool:
    """Check whether a command is available on the host."""
    val result = shell("command -v {cmd} >/dev/null 2>&1")
    result.exit_code == 0

fn probe_qemu_rv32() -> CapabilityReport:
    """Probe for qemu-system-riscv32 and a suitable GDB."""
    if not probe_command("qemu-system-riscv32"):
        return CapabilityReport.skip_tool("qemu-rv32", "qemu-system-riscv32")
    if not probe_command("gdb-multiarch") and not probe_command("riscv32-unknown-elf-gdb"):
        return CapabilityReport.skip_tool("qemu-rv32", "gdb-multiarch")
    CapabilityReport.ready("qemu-rv32", "qemu-system-riscv32")

fn probe_qemu_arm() -> CapabilityReport:
    """Probe for qemu-system-arm and a suitable GDB."""
    if not probe_command("qemu-system-arm"):
        return CapabilityReport.skip_tool("qemu-arm", "qemu-system-arm")
    if not probe_command("gdb-multiarch") and not probe_command("arm-none-eabi-gdb"):
        return CapabilityReport.skip_tool("qemu-arm", "gdb-multiarch")
    CapabilityReport.ready("qemu-arm", "qemu-system-arm")

fn probe_wlink() -> CapabilityReport:
    """Probe for wlink and CH32V307 board detection."""
    if not probe_command("wlink"):
        return CapabilityReport.skip_tool("ch32v307", "wlink")
    val status_result = shell("timeout 5 wlink status --chip CH32V30X 2>&1")
    if status_result.exit_code != 0:
        return CapabilityReport.skip_board("ch32v307", "CH32V307")
    CapabilityReport.ready("ch32v307", "wlink")

fn probe_openocd() -> CapabilityReport:
    """Probe for openocd availability."""
    if not probe_command("openocd"):
        return CapabilityReport.skip_tool("openocd", "openocd")
    CapabilityReport.ready("openocd", "openocd")

fn probe_trace32() -> CapabilityReport:
    """Probe for t32rem (TRACE32 remote API) availability."""
    if not probe_command("t32rem"):
        return CapabilityReport.skip_tool("trace32", "t32rem")
    CapabilityReport.ready("trace32", "t32rem")

fn probe_ghdl() -> CapabilityReport:
    """Probe for ghdl and the full semihost toolchain (clang, ld.lld, llvm-objcopy)."""
    if not probe_command("ghdl"):
        return CapabilityReport.skip_tool("ghdl_rv32_semihost", "ghdl")
    if not probe_command("clang"):
        return CapabilityReport.skip_tool("ghdl_rv32_semihost", "clang")
    if not probe_command("ld.lld"):
        return CapabilityReport.skip_tool("ghdl_rv32_semihost", "ld.lld")
    if not probe_command("llvm-objcopy"):
        return CapabilityReport.skip_tool("ghdl_rv32_semihost", "llvm-objcopy")
    CapabilityReport.ready("ghdl_rv32_semihost", "ghdl")

fn probe_ghdl_mailbox() -> CapabilityReport:
    """Probe for ghdl and the mailbox toolchain (same tools as semihost)."""
    if not probe_command("ghdl"):
        return CapabilityReport.skip_tool("ghdl_rv32_mailbox", "ghdl")
    if not probe_command("clang"):
        return CapabilityReport.skip_tool("ghdl_rv32_mailbox", "clang")
    if not probe_command("ld.lld"):
        return CapabilityReport.skip_tool("ghdl_rv32_mailbox", "ld.lld")
    if not probe_command("llvm-objcopy"):
        return CapabilityReport.skip_tool("ghdl_rv32_mailbox", "llvm-objcopy")
    CapabilityReport.ready("ghdl_rv32_mailbox", "ghdl")

fn probe_external_formal_tools() -> ExternalFormalToolchainStatus:
    val has_yosys = probe_command("yosys")
    val has_sby = probe_command("sby") or probe_command("symbiyosys")
    val has_solver = probe_command("boolector") or probe_command("z3") or probe_command("cvc5")
    val has_ghdl = probe_command("ghdl")
    val has_yosys_ghdl_plugin = if has_yosys:
        shell("yosys -m ghdl -p 'help' >/dev/null 2>&1").exit_code == 0
    else:
        false
    var missing: [text] = []
    if not has_yosys:
        missing.push("yosys")
    if not has_sby:
        missing.push("sby|symbiyosys")
    if not has_solver:
        missing.push("solver(boolector|z3|cvc5)")
    if not has_ghdl:
        missing.push("ghdl")
    if not has_yosys_ghdl_plugin:
        missing.push("yosys-ghdl-plugin")
    val detail = if missing.len() == 0:
        "external formal toolchain available: yosys, sby|symbiyosys, solver(boolector|z3|cvc5), ghdl, yosys-ghdl-plugin"
    else:
        "missing external formal tools: {missing.join(', ')}"
    ExternalFormalToolchainStatus(
        yosys: has_yosys,
        sby: has_sby,
        solver: has_solver,
        ghdl: has_ghdl,
        yosys_ghdl_plugin: has_yosys_ghdl_plugin,
        detail: detail
    )

fn probe_external_formal() -> CapabilityReport:
    """Probe for the external RTL formal toolchain (yosys + sby + SMT solver + VHDL bridge)."""
    val tools = probe_external_formal_tools()
    if tools.is_runnable():
        return CapabilityReport(
            lane_id: "riscv_external_formal",
            status: CapabilityStatus.ready,
            tool_name: "yosys+ghdl",
            detail: tools.detail,
            probe_duration_ms: 0
        )
    CapabilityReport(
        lane_id: "riscv_external_formal",
        status: CapabilityStatus.skip_missing_tool,
        tool_name: "yosys+ghdl",
        detail: tools.detail,
        probe_duration_ms: 0
    )

# ============================================================================
# Exports
# ============================================================================

export CapabilityStatus
export CapabilityReport
export probe_command
export probe_qemu_rv32
export probe_qemu_arm
export probe_wlink
export probe_openocd
export probe_trace32
export probe_ghdl
export probe_ghdl_mailbox
export ExternalFormalToolchainStatus
export probe_external_formal_tools
export probe_external_formal
