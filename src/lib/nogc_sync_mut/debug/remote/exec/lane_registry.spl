# Lane Registry
#
# Instantiates all known remote execution lanes with their descriptors.
# Single source of truth for lane metadata, used by status reporting
# and test infrastructure.
#
# Feature ID: #RJE-017

use std.nogc_sync_mut.debug.remote.exec.lane_descriptor.{
    LaneDescriptor, LaneStatus, ProofClass, AdapterKind, ResultChannelKind
}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{
    CapabilityReport, probe_qemu_rv32, probe_qemu_arm, probe_wlink,
    probe_openocd, probe_trace32, probe_ghdl
}

# ============================================================================
# Probe Helper
# ============================================================================

fn probe_for_lane(lane: LaneDescriptor) -> CapabilityReport:
    """Dispatch a capability probe based on the lane's adapter kind and target arch."""
    match lane.adapter_kind:
        AdapterKind.qemu_gdb:
            if lane.target_arch == "arm32":
                val report = probe_qemu_arm()
                CapabilityReport(
                    lane_id: lane.lane_id,
                    status: report.status,
                    tool_name: report.tool_name,
                    detail: report.detail,
                    probe_duration_ms: report.probe_duration_ms
                )
            else:
                val report = probe_qemu_rv32()
                CapabilityReport(
                    lane_id: lane.lane_id,
                    status: report.status,
                    tool_name: report.tool_name,
                    detail: report.detail,
                    probe_duration_ms: report.probe_duration_ms
                )
        AdapterKind.wlink_cli:
            val report = probe_wlink()
            CapabilityReport(
                lane_id: lane.lane_id,
                status: report.status,
                tool_name: report.tool_name,
                detail: report.detail,
                probe_duration_ms: report.probe_duration_ms
            )
        AdapterKind.openocd_gdb:
            val report = probe_openocd()
            CapabilityReport(
                lane_id: lane.lane_id,
                status: report.status,
                tool_name: report.tool_name,
                detail: report.detail,
                probe_duration_ms: report.probe_duration_ms
            )
        AdapterKind.trace32:
            val report = probe_trace32()
            CapabilityReport(
                lane_id: lane.lane_id,
                status: report.status,
                tool_name: report.tool_name,
                detail: report.detail,
                probe_duration_ms: report.probe_duration_ms
            )
        AdapterKind.ghdl_sim:
            val report = probe_ghdl()
            CapabilityReport(
                lane_id: lane.lane_id,
                status: report.status,
                tool_name: report.tool_name,
                detail: report.detail,
                probe_duration_ms: report.probe_duration_ms
            )
        AdapterKind.direct_boot:
            CapabilityReport.ready(lane.lane_id, "direct")

# ============================================================================
# Lane Registry
# ============================================================================

class LaneRegistry:
    """Registry of all known remote execution lanes.

    Provides the single source of truth for lane metadata.
    Use `LaneRegistry.default()` to get the full set of known lanes.
    """
    lanes: [LaneDescriptor]

    static fn default() -> LaneRegistry:
        """Create a registry populated with all known lanes."""
        val all_lanes = [
            # 1. qemu_rv32_semihost — stable QEMU RISC-V 32 semihosting lane
            LaneDescriptor(
                lane_id: "qemu_rv32_semihost",
                target_arch: "riscv32",
                adapter_kind: AdapterKind.qemu_gdb,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.semihost_text,
                fallback_result_channel: Some(ResultChannelKind.exit_code),
                authoritative_spec_path: "test/integration/remote_jit/qemu_rv32_library_semihost_spec.spl",
                status: LaneStatus.stable
            ),
            # 2. qemu_arm_semihost — stable QEMU ARM semihosting lane
            LaneDescriptor(
                lane_id: "qemu_arm_semihost",
                target_arch: "arm32",
                adapter_kind: AdapterKind.qemu_gdb,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.semihost_text,
                fallback_result_channel: Some(ResultChannelKind.exit_code),
                authoritative_spec_path: "test/integration/remote_jit/qemu_arm_composite_runner_spec.spl",
                status: LaneStatus.stable
            ),
            # 3. x86_64_direct_boot — stable direct boot lane
            LaneDescriptor(
                lane_id: "x86_64_direct_boot",
                target_arch: "x86_64",
                adapter_kind: AdapterKind.direct_boot,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.exit_code,
                fallback_result_channel: nil,
                authoritative_spec_path: "test/integration/baremetal/remote_riscv32_spec.spl",
                status: LaneStatus.stable
            ),
            # 4. ch32v307_wlink — host-aware WCH-Link lane
            LaneDescriptor(
                lane_id: "ch32v307_wlink",
                target_arch: "riscv32",
                adapter_kind: AdapterKind.wlink_cli,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.register_readback,
                fallback_result_channel: Some(ResultChannelKind.ram_sentinel),
                authoritative_spec_path: "test/integration/remote_jit/ch32v307_composite_runner_spec.spl",
                status: LaneStatus.host_aware
            ),
            # 5. stm32h7_openocd — host-aware OpenOCD lane
            LaneDescriptor(
                lane_id: "stm32h7_openocd",
                target_arch: "arm32",
                adapter_kind: AdapterKind.openocd_gdb,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.register_readback,
                fallback_result_channel: Some(ResultChannelKind.ram_sentinel),
                authoritative_spec_path: "test/integration/remote_jit/stm32h7_composite_runner_spec.spl",
                status: LaneStatus.host_aware
            ),
            # 6. stm32h7_trace32 — host-aware TRACE32 lane
            LaneDescriptor(
                lane_id: "stm32h7_trace32",
                target_arch: "arm32",
                adapter_kind: AdapterKind.trace32,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.debugger_console,
                fallback_result_channel: Some(ResultChannelKind.register_readback),
                authoritative_spec_path: "test/system/t32_terminal_power_remote_spec.spl",
                status: LaneStatus.host_aware
            ),
            # 7. ghdl_rv32_sim — in-progress GHDL simulation lane
            LaneDescriptor(
                lane_id: "ghdl_rv32_sim",
                target_arch: "riscv32",
                adapter_kind: AdapterKind.ghdl_sim,
                proof_class: ProofClass.compiled,
                primary_result_channel: ResultChannelKind.semihost_text,
                fallback_result_channel: Some(ResultChannelKind.ram_sentinel),
                authoritative_spec_path: "test/integration/remote_jit/ghdl_rv32_composite_runner_spec.spl",
                status: LaneStatus.in_progress
            ),
            # 8. fpga_jtag_zedboard — in-progress FPGA JTAG lane
            LaneDescriptor(
                lane_id: "fpga_jtag_zedboard",
                target_arch: "arm32",
                adapter_kind: AdapterKind.openocd_gdb,
                proof_class: ProofClass.structural,
                primary_result_channel: ResultChannelKind.register_readback,
                fallback_result_channel: nil,
                authoritative_spec_path: "",
                status: LaneStatus.in_progress
            ),
            # 9. rv32_raw_injected — transport-only raw injection lane
            LaneDescriptor(
                lane_id: "rv32_raw_injected",
                target_arch: "riscv32",
                adapter_kind: AdapterKind.qemu_gdb,
                proof_class: ProofClass.structural,
                primary_result_channel: ResultChannelKind.register_readback,
                fallback_result_channel: nil,
                authoritative_spec_path: "test/integration/remote_jit/qemu_rv32_raw_injected_regression_spec.spl",
                status: LaneStatus.transport_only
            ),
            # 10. baremetal_runtime_check — transport-only runtime check lane
            LaneDescriptor(
                lane_id: "baremetal_runtime_check",
                target_arch: "riscv32",
                adapter_kind: AdapterKind.qemu_gdb,
                proof_class: ProofClass.interpreter,
                primary_result_channel: ResultChannelKind.exit_code,
                fallback_result_channel: nil,
                authoritative_spec_path: "test/feature/app/remote_baremetal/remote_baremetal_runtime_spec.spl",
                status: LaneStatus.transport_only
            )
        ]
        LaneRegistry(lanes: all_lanes)

    # ========================================================================
    # Query Methods
    # ========================================================================

    fn all() -> [LaneDescriptor]:
        """Return all registered lanes."""
        self.lanes

    fn stable_lanes() -> [LaneDescriptor]:
        """Return lanes with LaneStatus.stable."""
        self.lanes.filter(\lane: lane.status == LaneStatus.stable)

    fn host_aware_lanes() -> [LaneDescriptor]:
        """Return lanes with LaneStatus.host_aware."""
        self.lanes.filter(\lane: lane.status == LaneStatus.host_aware)

    fn transport_only_lanes() -> [LaneDescriptor]:
        """Return lanes with LaneStatus.transport_only."""
        self.lanes.filter(\lane: lane.status == LaneStatus.transport_only)

    fn in_progress_lanes() -> [LaneDescriptor]:
        """Return lanes with LaneStatus.in_progress."""
        self.lanes.filter(\lane: lane.status == LaneStatus.in_progress)

    fn authoritative_lanes() -> [LaneDescriptor]:
        """Return lanes that are authoritative (stable + host_aware)."""
        self.lanes.filter(\lane: lane.status.is_authoritative())

    fn find(lane_id: text) -> Option<LaneDescriptor>:
        """Look up a lane by its ID. Returns nil if not found."""
        self.lanes.find(\lane: lane.lane_id == lane_id)

    fn probe_all() -> [CapabilityReport]:
        """Run capability probes for all registered lanes."""
        self.lanes.map(\lane: probe_for_lane(lane))

# ============================================================================
# Exports
# ============================================================================

export LaneRegistry
export probe_for_lane
