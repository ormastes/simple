# Remote Execution Manager
#
# Orchestrates the compile-upload-execute-collect pipeline for remote
# baremetal targets. Wired to a specific target through function pointers
# provided by the adapter (QEMU, OpenOCD, TRACE32, etc.).
#
# Feature ID: #RJE-005

use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap, CodeInfo, ExecResult, Architecture,
    pc_register_index, sp_register_index, return_register_index,
    link_register_index, halt_instruction_for, halt_instruction_size
}
use std.nogc_sync_mut.debug.remote.exec.uploader.{CodeUploader}
use std.nogc_sync_mut.debug.remote.exec.memory_alloc.{TargetMemoryAllocator}

class RemoteExecutionManager:
    """Orchestrates upload-execute-collect on a remote target."""
    arch: Architecture
    memory_map: MemoryMap
    write_code_fn: fn(i64, [i32]) -> Result<text, text>
    read_code_fn: fn(i64, i64) -> Result<[i32], text>
    write_register_fn: fn(i64, i64) -> Result<text, text>
    read_register_fn: fn(i64) -> Result<i64, text>
    resume_fn: fn() -> Result<text, text>
    wait_halt_fn: fn(i64) -> Result<text, text>
    allocator: TargetMemoryAllocator

    static fn new(
        arch: Architecture,
        memory_map: MemoryMap,
        write_code_fn: fn(i64, [i32]) -> Result<text, text>,
        read_code_fn: fn(i64, i64) -> Result<[i32], text>,
        write_register_fn: fn(i64, i64) -> Result<text, text>,
        read_register_fn: fn(i64) -> Result<i64, text>,
        resume_fn: fn() -> Result<text, text>,
        wait_halt_fn: fn(i64) -> Result<text, text>
    ) -> RemoteExecutionManager:
        RemoteExecutionManager(
            arch: arch,
            memory_map: memory_map,
            write_code_fn: write_code_fn,
            read_code_fn: read_code_fn,
            write_register_fn: write_register_fn,
            read_register_fn: read_register_fn,
            resume_fn: resume_fn,
            wait_halt_fn: wait_halt_fn,
            allocator: TargetMemoryAllocator.new(memory_map)
        )

    me execute_bytes(name: text, bytes: [i32], args: [i64]) -> Result<ExecResult, text>:
        """Upload code bytes, set registers, execute, and collect result."""
        # Append halt instruction so execution stops after the code returns
        var code = append_halt(bytes, self.arch)

        # Allocate target memory
        val alloc_result = self.allocator.allocate(code.len(), 4)
        if alloc_result.is_err():
            return Err(alloc_result.err().unwrap())
        val addr = alloc_result.ok.unwrap()

        # Upload code
        val upload_result = CodeUploader.upload(
            name, code, addr, self.write_code_fn, self.read_code_fn
        )
        if upload_result.is_err():
            return Err("upload failed: {upload_result.err().unwrap()}")

        # Set up registers
        val pc_idx = pc_register_index(self.arch)
        val sp_idx = sp_register_index(self.arch)
        val lr_idx = link_register_index(self.arch)

        # Entry point — for ARM Thumb, set bit 0
        val entry = if self.arch == Architecture.Arm32: addr + 1 else: addr
        val pc_write = self.write_register_fn(pc_idx, entry)
        if pc_write.is_err():
            return Err("failed to set PC: {pc_write.err().unwrap()}")

        # Stack pointer
        val sp_write = self.write_register_fn(sp_idx, self.memory_map.stack_top)
        if sp_write.is_err():
            return Err("failed to set SP: {sp_write.err().unwrap()}")

        # Link register points to halt trampoline (end of code - halt_size)
        val halt_size = halt_instruction_size(self.arch)
        val halt_addr = addr + bytes.len()
        val lr_entry = if self.arch == Architecture.Arm32: halt_addr + 1 else: halt_addr
        val lr_write = self.write_register_fn(lr_idx, lr_entry)
        if lr_write.is_err():
            return Err("failed to set LR: {lr_write.err().unwrap()}")

        # Set argument registers
        val arg_indices = arg_register_indices_for(self.arch)
        var i = 0
        while i < args.len() and i < arg_indices.len():
            val arg_write = self.write_register_fn(arg_indices[i], args[i])
            if arg_write.is_err():
                return Err("failed to set arg register {i}: {arg_write.err().unwrap()}")
            i = i + 1

        # Resume execution
        val resume_result = self.resume_fn()
        if resume_result.is_err():
            return Err("resume failed: {resume_result.err().unwrap()}")

        # Wait for halt (10 second default timeout)
        val halt_result = self.wait_halt_fn(10000)
        if halt_result.is_err():
            return Err("wait for halt failed: {halt_result.err().unwrap()}")

        # Read return value from return register (a0/r0)
        val ret_idx = return_register_index(self.arch)
        val ret_result = self.read_register_fn(ret_idx)
        if ret_result.is_err():
            return Err("failed to read return register: {ret_result.err().unwrap()}")

        val ret_value = ret_result.ok.unwrap()
        Ok(ExecResult.success(ret_value, 0, halt_result.ok.unwrap()))

fn append_halt(bytes: [i32], arch: Architecture) -> [i32]:
    """Append a halt instruction (EBREAK/BKPT) to the end of the code."""
    var result = bytes
    val halt = halt_instruction_for(arch)
    val size = halt_instruction_size(arch)
    if size >= 1:
        result.push((halt & 0xFF) as i32)
    if size >= 2:
        result.push(((halt >> 8) & 0xFF) as i32)
    if size >= 3:
        result.push(((halt >> 16) & 0xFF) as i32)
    if size >= 4:
        result.push(((halt >> 24) & 0xFF) as i32)
    result

fn arg_register_indices_for(arch: Architecture) -> [i64]:
    match arch:
        Architecture.RiscV32: [10, 11, 12, 13, 14, 15, 16, 17]
        Architecture.Arm32: [0, 1, 2, 3]
        _: [10, 11, 12, 13, 14, 15, 16, 17]

export RemoteExecutionManager
