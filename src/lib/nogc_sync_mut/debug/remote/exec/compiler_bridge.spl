#![allow(export_outside_init)]
#![allow(unnamed_duplicate_typed_args)]
# Simple-to-Bytes Compiler Bridge
#
# Parser-safe minimal bridge for remote JIT execution.
# Current behavior emits tiny target-native stubs that return 0 so the
# upload/execute path can be exercised while the full compiler pipeline is
# being stabilized.

use std.nogc_sync_mut.debug.remote.exec.types.{Architecture}

class CompilerBridge:
    static fn compile(source: text, arch: Architecture, base_addr: i64) -> Result<[i32], text>:
        compile_remote_binary(source, arch, base_addr)

    static fn compile_in_dir(source: text, arch: Architecture, base_addr: i64, tmpdir: text) -> Result<[i32], text>:
        compile_remote_binary_in_dir(source, arch, base_addr, tmpdir)

fn compile_remote_binary(source: text, arch: Architecture, base_addr: i64) -> Result<[i32], text>:
    compile_remote_binary_in_dir(source, arch, base_addr, "")

fn compile_remote_binary_arm32(source: text, base_addr: i64) -> Result<[i32], text>:
    Ok(arm32_return_zero_bytes())

fn compile_remote_binary_in_dir(source: text, arch: Architecture, base_addr: i64, tmpdir: text) -> Result<[i32], text>:
    match arch:
        Architecture.Arm32: Ok(arm32_return_zero_bytes())
        Architecture.RiscV32: Ok(rv32_return_zero_bytes())
        _: Err("unsupported remote JIT arch")

fn arm32_return_zero_bytes() -> [i32]:
    # movs r0, #0
    [0x00, 0x20]

fn rv32_return_zero_bytes() -> [i32]:
    # addi a0, x0, 0
    [0x13, 0x05, 0x00, 0x00]

export CompilerBridge, compile_remote_binary, compile_remote_binary_in_dir, compile_remote_binary_arm32
