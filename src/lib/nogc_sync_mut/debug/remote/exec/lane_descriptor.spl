#![allow(export_outside_init)]
# Lane Descriptor Types
#
# Central lane descriptor for the remote execution stack.
# Every lane has exactly one descriptor defining its identity,
# classification, and result channel configuration.
#
# Feature ID: #RJE-014

# ============================================================================
# Lane Status
# ============================================================================

enum LaneStatus:
    """Status of a lane in the remote execution stack.

    - stable: fully verified, authoritative for its target
    - host_aware: verified with host-specific adaptations; authoritative
      when prerequisites are present
    - transport_only: connection works but results do not count as
      completion evidence
    - in_progress: under development, not yet usable
    """
    stable
    host_aware
    transport_only
    in_progress

    fn to_text() -> text:
        match self:
            LaneStatus.stable: "stable"
            LaneStatus.host_aware: "host_aware"
            LaneStatus.transport_only: "transport_only"
            LaneStatus.in_progress: "in_progress"

    fn is_authoritative() -> bool:
        match self:
            LaneStatus.stable: true
            LaneStatus.host_aware: true
            _: false

# ============================================================================
# Proof Class
# ============================================================================

enum ProofClass:
    """Classification of how a lane proves execution correctness.

    - compiled: native AOT binary runs on real/emulated hardware
    - interpreter: interpreted execution with runtime checking
    - structural: structural verification without full execution
    """
    compiled
    interpreter
    structural

    fn to_text() -> text:
        match self:
            ProofClass.compiled: "compiled"
            ProofClass.interpreter: "interpreter"
            ProofClass.structural: "structural"

# ============================================================================
# Adapter Kind
# ============================================================================

enum AdapterKind:
    """Kind of debug/execution adapter used by a lane."""
    qemu_gdb
    wlink_cli
    openocd_gdb
    trace32
    ghdl_sim
    external_formal
    direct_boot

    fn to_text() -> text:
        match self:
            AdapterKind.qemu_gdb: "qemu_gdb"
            AdapterKind.wlink_cli: "wlink_cli"
            AdapterKind.openocd_gdb: "openocd_gdb"
            AdapterKind.trace32: "trace32"
            AdapterKind.ghdl_sim: "ghdl_sim"
            AdapterKind.external_formal: "external_formal"
            AdapterKind.direct_boot: "direct_boot"

# ============================================================================
# Result Channel Kind
# ============================================================================

enum ResultChannelKind:
    """How execution results are collected from the target."""
    semihost_text
    exit_code
    ram_sentinel
    register_readback
    debugger_console

    fn to_text() -> text:
        match self:
            ResultChannelKind.semihost_text: "semihost_text"
            ResultChannelKind.exit_code: "exit_code"
            ResultChannelKind.ram_sentinel: "ram_sentinel"
            ResultChannelKind.register_readback: "register_readback"
            ResultChannelKind.debugger_console: "debugger_console"

# ============================================================================
# Lane Descriptor
# ============================================================================

class LaneDescriptor:
    """Central descriptor for a remote execution lane.

    Every lane has exactly one descriptor that defines its identity,
    target architecture, adapter kind, proof classification, and
    result channel configuration.
    """
    lane_id: text
    target_arch: text
    adapter_kind: AdapterKind
    proof_class: ProofClass
    primary_result_channel: ResultChannelKind
    fallback_result_channel: Option<ResultChannelKind>
    authoritative_spec_path: text
    status: LaneStatus

    fn to_text() -> text:
        "[{self.lane_id}] arch={self.target_arch} adapter={self.adapter_kind.to_text()} proof={self.proof_class.to_text()} status={self.status.to_text()}"

    fn is_authoritative() -> bool:
        self.status.is_authoritative()

# ============================================================================
# Exports
# ============================================================================

export LaneStatus, ProofClass, AdapterKind, ResultChannelKind, LaneDescriptor
