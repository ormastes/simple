#![allow(export_outside_init)]
# Lane Status Reporter
#
# Generates human-readable and machine-readable lane status reports
# from the lane registry. Supports text, SDN, and markdown output.
#
# Feature ID: #RJE-018

use std.nogc_sync_mut.debug.remote.exec.lane_descriptor.{
    LaneDescriptor, LaneStatus
}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{
    CapabilityReport, CapabilityStatus
}
use std.nogc_sync_mut.debug.remote.exec.lane_registry.{
    LaneRegistry, probe_for_lane
}

# ============================================================================
# Helper
# ============================================================================

fn format_lane_line(lane: LaneDescriptor, report: CapabilityReport) -> text:
    """Format a single lane as a human-readable status line."""
    val status_label = report.status.to_text()
    "  [{lane.lane_id}] {lane.target_arch} {lane.adapter_kind.to_text()} {lane.proof_class.to_text()} — {status_label}"

# ============================================================================
# Lane Status Reporter
# ============================================================================

class LaneStatusReporter:
    """Generates lane status reports in text, SDN, and markdown formats.

    Uses the lane registry to enumerate all known lanes and optionally
    probes each lane for live capability status.
    """
    registry: LaneRegistry

    static fn new() -> LaneStatusReporter:
        """Create a reporter backed by the default lane registry."""
        LaneStatusReporter(registry: LaneRegistry.default())

    fn report_text() -> text:
        """Generate a human-readable text report of all lane statuses."""
        val lanes = self.registry.all()

        var stable_lines: [text] = []
        var host_aware_lines: [text] = []
        var transport_lines: [text] = []
        var in_progress_lines: [text] = []

        var i = 0
        while i < lanes.len():
            val lane = lanes[i]
            val report = probe_for_lane(lane)
            val line = format_lane_line(lane, report)
            match lane.status:
                LaneStatus.stable:
                    stable_lines.push(line)
                LaneStatus.host_aware:
                    host_aware_lines.push(line)
                LaneStatus.transport_only:
                    transport_lines.push(line)
                LaneStatus.in_progress:
                    in_progress_lines.push(line)
            i = i + 1

        var out = "=== Remote Execution Lane Status ===\n"
        out = out + "Note: stable and host-aware lanes are authoritative; transport-only lanes do not count toward completion.\n"

        out = out + "\nStable Lanes:\n"
        if stable_lines.len() == 0:
            out = out + "  (none)\n"
        else:
            var si = 0
            while si < stable_lines.len():
                out = out + stable_lines[si] + "\n"
                si = si + 1

        out = out + "\nHost-Aware Lanes:\n"
        if host_aware_lines.len() == 0:
            out = out + "  (none)\n"
        else:
            var hi = 0
            while hi < host_aware_lines.len():
                out = out + host_aware_lines[hi] + "\n"
                hi = hi + 1

        out = out + "\nTransport-Only Lanes:\n"
        if transport_lines.len() == 0:
            out = out + "  (none)\n"
        else:
            var ti = 0
            while ti < transport_lines.len():
                out = out + transport_lines[ti] + "\n"
                ti = ti + 1

        out = out + "\nIn-Progress Lanes:\n"
        if in_progress_lines.len() == 0:
            out = out + "  (none)\n"
        else:
            var pi = 0
            while pi < in_progress_lines.len():
                out = out + in_progress_lines[pi] + "\n"
                pi = pi + 1

        out = out + "\nSummary: {stable_lines.len()} stable, {host_aware_lines.len()} host-aware, {transport_lines.len()} transport-only, {in_progress_lines.len()} in-progress"
        out

    fn report_sdn() -> text:
        """Generate an SDN (Simple Data Notation) report of all lanes."""
        val lanes = self.registry.all()
        var out = "[lane_matrix]\ngenerated = \"2026-04-04\"\n"

        var i = 0
        while i < lanes.len():
            val lane = lanes[i]
            out = out + "\n[[lanes]]\n"
            out = out + "id = \"{lane.lane_id}\"\n"
            out = out + "arch = \"{lane.target_arch}\"\n"
            out = out + "adapter = \"{lane.adapter_kind.to_text()}\"\n"
            out = out + "proof = \"{lane.proof_class.to_text()}\"\n"
            out = out + "status = \"{lane.status.to_text()}\"\n"
            out = out + "authoritative = \"{lane.status.is_authoritative()}\"\n"
            out = out + "primary_channel = \"{lane.primary_result_channel.to_text()}\"\n"
            out = out + "spec = \"{lane.authoritative_spec_path}\"\n"
            i = i + 1

        out

    fn generate_matrix_markdown() -> text:
        """Generate a markdown table of the lane matrix."""
        val lanes = self.registry.all()

        var stable_count = 0
        var host_aware_count = 0
        var transport_count = 0
        var in_progress_count = 0
        var authoritative_count = 0

        var out = "# Remote Execution Lane Matrix\n\n"
        out = out + "Generated: 2026-04-04\n\n"
        out = out + "| Lane ID | Arch | Adapter | Proof | Status | Authoritative | Primary Channel | Spec |\n"
        out = out + "|---------|------|---------|-------|--------|---------------|-----------------|------|\n"

        var i = 0
        while i < lanes.len():
            val lane = lanes[i]
            val is_authoritative = lane.status.is_authoritative()
            out = out + "| {lane.lane_id} | {lane.target_arch} | {lane.adapter_kind.to_text()} | {lane.proof_class.to_text()} | {lane.status.to_text()} | {is_authoritative} | {lane.primary_result_channel.to_text()} | {lane.authoritative_spec_path} |\n"
            match lane.status:
                LaneStatus.stable:
                    stable_count = stable_count + 1
                    authoritative_count = authoritative_count + 1
                LaneStatus.host_aware:
                    host_aware_count = host_aware_count + 1
                    authoritative_count = authoritative_count + 1
                LaneStatus.transport_only:
                    transport_count = transport_count + 1
                LaneStatus.in_progress:
                    in_progress_count = in_progress_count + 1
            i = i + 1

        out = out + "\n## Summary\n"
        out = out + "- **Authoritative**: {authoritative_count} lanes (stable + host-aware)\n"
        out = out + "- **Stable**: {stable_count} lanes\n"
        out = out + "- **Host-aware**: {host_aware_count} lanes\n"
        out = out + "- **Transport-only**: {transport_count} lanes\n"
        out = out + "- **In-progress**: {in_progress_count} lanes\n"
        out

    fn probe_and_report() -> text:
        """Probe every lane and generate a detailed capability report."""
        val lanes = self.registry.all()
        var out = "=== Lane Probe Results ===\n\n"

        var ready_count = 0
        var skip_count = 0
        var blocked_count = 0
        var failed_count = 0

        var i = 0
        while i < lanes.len():
            val lane = lanes[i]
            val report = probe_for_lane(lane)
            val line = format_lane_line(lane, report)
            out = out + line + "\n"
            out = out + "    tool: {report.tool_name}  detail: {report.detail}  probe: {report.probe_duration_ms}ms\n"
            out = out + "    authoritative: {lane.status.is_authoritative()}\n"

            match report.status:
                CapabilityStatus.ready:
                    ready_count = ready_count + 1
                CapabilityStatus.skip_missing_tool:
                    skip_count = skip_count + 1
                CapabilityStatus.skip_missing_board:
                    skip_count = skip_count + 1
                CapabilityStatus.blocked_permissions:
                    blocked_count = blocked_count + 1
                CapabilityStatus.blocked_host_config:
                    blocked_count = blocked_count + 1
                CapabilityStatus.failed_runtime:
                    failed_count = failed_count + 1
            i = i + 1

        out = out + "\nProbe Summary: {ready_count} ready, {skip_count} skipped, {blocked_count} blocked, {failed_count} failed"
        out

# ============================================================================
# Exports
# ============================================================================

export LaneStatusReporter, format_lane_line
