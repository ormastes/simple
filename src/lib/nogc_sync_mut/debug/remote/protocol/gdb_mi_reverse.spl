# GDB MI Reverse Debugging Controller
# Provides reverse execution via GDB record-replay.
# Requires GDB's "record full" to be active.

use std.nogc_sync_mut.debug.remote.protocol.gdb_mi.GdbMiClient

# Controller for GDB reverse debugging (record and replay)
class GdbMiReverseController:
    client: GdbMiClient
    recording: bool

impl GdbMiReverseController:
    # Start recording execution for reverse debugging.
    # Sends: -interpreter-exec console "record full"
    static fn start_recording(client: GdbMiClient) -> Result<GdbMiReverseController, text>:
        client.console_exec("record full")?
        Ok(GdbMiReverseController(client: client, recording: true))

    # Stop recording execution.
    # Sends: -interpreter-exec console "record stop"
    me stop_recording() -> Result<text, text>:
        self.client.console_exec("record stop")?
        self.recording = false
        Ok("recording stopped")

    # Check whether recording is active.
    fn is_recording() -> bool:
        self.recording

    # Reverse step (step backward one source line, entering functions).
    # Sends: -interpreter-exec console "reverse-step"
    me reverse_step() -> Result<text, text>:
        self.client.console_exec("reverse-step")?
        Ok("reverse stepped")

    # Reverse continue (run backward to previous breakpoint/stop).
    # Sends: -interpreter-exec console "reverse-continue"
    me reverse_continue() -> Result<text, text>:
        self.client.console_exec("reverse-continue")?
        Ok("reverse continued")

    # Reverse next (step backward one source line, skipping over functions).
    # Sends: -interpreter-exec console "reverse-next"
    me reverse_next() -> Result<text, text>:
        self.client.console_exec("reverse-next")?
        Ok("reverse next")

    # Reverse finish (run backward until current function entry).
    # Sends: -interpreter-exec console "reverse-finish"
    me reverse_finish() -> Result<text, text>:
        self.client.console_exec("reverse-finish")?
        Ok("reverse finish")

    # Jump to the beginning of the recording.
    # Sends: -interpreter-exec console "record goto begin"
    me goto_begin() -> Result<text, text>:
        self.client.console_exec("record goto begin")?
        Ok("at recording begin")

    # Jump to the end of the recording.
    # Sends: -interpreter-exec console "record goto end"
    me goto_end() -> Result<text, text>:
        self.client.console_exec("record goto end")?
        Ok("at recording end")

    # --- Static command builders (for testing without live GDB) ---

    static fn build_record_full_cmd() -> text:
        "record full"

    static fn build_record_stop_cmd() -> text:
        "record stop"

    static fn build_reverse_step_cmd() -> text:
        "reverse-step"

    static fn build_reverse_continue_cmd() -> text:
        "reverse-continue"

    static fn build_reverse_next_cmd() -> text:
        "reverse-next"

    static fn build_reverse_finish_cmd() -> text:
        "reverse-finish"

    static fn build_goto_begin_cmd() -> text:
        "record goto begin"

    static fn build_goto_end_cmd() -> text:
        "record goto end"
