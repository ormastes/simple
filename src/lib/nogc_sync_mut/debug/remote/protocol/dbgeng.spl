# DbgEng Protocol Client
# Windows Debugging Engine (WinDbg) remote protocol client.
# DbgEng is Windows-only; all methods return platform errors on non-Windows hosts.

class DbgEngClient:
    host: text
    port: i32
    connected: bool
    target_pid: i32
    platform: text

impl DbgEngClient:
    # Connect to a DbgEng remote server
    static fn connect(host: text, port: i32) -> Result<DbgEngClient, text>:
        Err(DbgEngClient._platform_error())

    # Attach to a running process by PID
    static fn attach_pid(pid: i32) -> Result<DbgEngClient, text>:
        Err(DbgEngClient._platform_error())

    # Launch a new debuggee process
    static fn launch(program: text, args: [text]) -> Result<DbgEngClient, text>:
        Err(DbgEngClient._platform_error())

    # Load a crash dump file
    static fn load_dump(path: text) -> Result<DbgEngClient, text>:
        Err(DbgEngClient._platform_error())

    # Disconnect from the debug target
    fn disconnect() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Check if currently connected
    fn is_connected() -> bool:
        false

    # --- Execution Control ---

    # Resume execution
    fn resume() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Halt (break) execution
    fn halt() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Single step (step into)
    fn single_step() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Step over function calls
    fn step_over() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Step out of current function
    fn step_out() -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # --- Breakpoints ---

    # Set breakpoint at file:line
    fn set_breakpoint(file: text, line: i32) -> Result<i32, text>:
        Err(DbgEngClient._platform_error())

    # Set breakpoint at address
    fn set_breakpoint_at_addr(addr: i64) -> Result<i32, text>:
        Err(DbgEngClient._platform_error())

    # Delete breakpoint by ID
    fn delete_breakpoint(id: i32) -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Set watchpoint (memory access breakpoint)
    fn set_watchpoint(expr: text, access: text) -> Result<i32, text>:
        Err(DbgEngClient._platform_error())

    # --- Variable Inspection ---

    # Read local variables in current frame
    fn read_locals() -> Result<[text], text>:
        Err(DbgEngClient._platform_error())

    # Read global variables
    fn read_globals() -> Result<[text], text>:
        Err(DbgEngClient._platform_error())

    # Evaluate expression in current context
    fn evaluate(expr: text) -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # Get full stack trace
    fn stack_trace() -> Result<[text], text>:
        Err(DbgEngClient._platform_error())

    # Get stack depth
    fn stack_depth() -> Result<i32, text>:
        Err(DbgEngClient._platform_error())

    # --- Memory Access ---

    # Read memory bytes at address
    fn read_memory(addr: i64, size: i32) -> Result<[i32], text>:
        Err(DbgEngClient._platform_error())

    # Write memory bytes at address
    fn write_memory(addr: i64, data: [i32]) -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # --- Register Access ---

    # Read single register by name
    fn read_register(name: text) -> Result<i64, text>:
        Err(DbgEngClient._platform_error())

    # Read all registers
    fn read_all_registers() -> Result<Dict<text, i64>, text>:
        Err(DbgEngClient._platform_error())

    # Write register value
    fn write_register(name: text, value: i64) -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # --- Windows-specific ---

    # Execute a WinDbg command string (e.g. "!analyze -v", "lm")
    fn execute_command(cmd: text) -> Result<text, text>:
        Err(DbgEngClient._platform_error())

    # List loaded modules
    fn list_modules() -> Result<[text], text>:
        Err(DbgEngClient._platform_error())

    # Platform error message for non-Windows hosts
    static fn _platform_error() -> text:
        "DbgEng only supported on Windows"
