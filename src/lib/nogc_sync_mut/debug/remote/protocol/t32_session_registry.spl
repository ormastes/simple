# T32 Session Registry — manages multiple TRACE32 PowerView instances
# Provides multi-instance session management with core tracking and InterCom support.

use std.io.{shell, ProcessResult}
use std.nogc_sync_mut.debug.remote.protocol.trace32.Trace32Client

# Module state — module-level vars support read+write from module functions
var T32_SESSIONS: [T32SessionEntry] = []
var T32_CURRENT_SESSION: text = ""

# A registered TRACE32 session with its client and core bindings
class T32SessionEntry:
    id: text
    host: text
    port: i32
    intercom_name: text
    architecture: text
    client: Trace32Client
    cores: [T32CoreEntry]

# A core within a multi-core TRACE32 session
class T32CoreEntry:
    core_id: text
    instance_binding: text
    label: text

# Register a new session in the global registry
fn t32_register_session(id: text, host: text, port: i32, intercom_name: text, arch: text, client: Trace32Client):
    var entry = T32SessionEntry(
        id: id,
        host: host,
        port: port,
        intercom_name: intercom_name,
        architecture: arch,
        client: client,
        cores: []
    )
    T32_SESSIONS.push(entry)
    # Auto-select if first session
    if T32_SESSIONS.len() == 1:
        T32_CURRENT_SESSION = id

# Look up a session by id
fn t32_get_session(id: text) -> Option<T32SessionEntry>:
    for s in T32_SESSIONS:
        if s.id == id:
            return Some(s)
    nil

# Return list of all registered session ids
fn t32_list_sessions() -> [text]:
    var ids: [text] = []
    for s in T32_SESSIONS:
        ids.push(s.id)
    ids

# Disconnect and remove a session from the registry
fn t32_close_session(id: text) -> Result<text, text>:
    var found_idx = -1
    var idx = 0
    for s in T32_SESSIONS:
        if s.id == id:
            s.client.disconnect()
            found_idx = idx
        idx = idx + 1

    if found_idx < 0:
        return Err("session not found: {id}")

    # Rebuild list without the closed session
    var new_sessions: [T32SessionEntry] = []
    var i = 0
    for s in T32_SESSIONS:
        if i != found_idx:
            new_sessions.push(s)
        i = i + 1
    T32_SESSIONS = new_sessions

    # Clear current if it was the closed one
    if T32_CURRENT_SESSION == id:
        if T32_SESSIONS.len() > 0:
            T32_CURRENT_SESSION = T32_SESSIONS[0].id
        else:
            T32_CURRENT_SESSION = ""

    Ok("closed session {id}")

# Return the currently selected session
fn t32_current_session() -> Option<T32SessionEntry>:
    if T32_CURRENT_SESSION.len() == 0:
        return nil
    t32_get_session(T32_CURRENT_SESSION)

# Select a session as the current active session
fn t32_select_session(id: text) -> Result<text, text>:
    val session = t32_get_session(id)
    if session == nil:
        return Err("session not found: {id}")
    T32_CURRENT_SESSION = id
    Ok("selected session {id}")

# Add a core binding to an existing session
fn t32_add_core(session_id: text, core_id: text, instance_binding: text, label: text) -> Result<text, text>:
    val session = t32_get_session(session_id)
    if session == nil:
        return Err("session not found: {session_id}")

    val entry = T32CoreEntry(
        core_id: core_id,
        instance_binding: instance_binding,
        label: label
    )

    val s = session ?? T32SessionEntry(id: "", host: "", port: 0, intercom_name: "", architecture: "", client: Trace32Client(host: "", port: 0, t32rem_path: "", connected: false, program: "", bp_counter: 0), cores: [])
    s.cores.push(entry)
    Ok("added core {core_id} to session {session_id}")

# List all cores for a session
fn t32_list_cores(session_id: text) -> [T32CoreEntry]:
    val session = t32_get_session(session_id)
    if session == nil:
        return []
    val s = session ?? T32SessionEntry(id: "", host: "", port: 0, intercom_name: "", architecture: "", client: Trace32Client(host: "", port: 0, t32rem_path: "", connected: false, program: "", bp_counter: 0), cores: [])
    s.cores

# Send a command to another TRACE32 instance via InterCom
fn t32_intercom_send(session_id: text, target_intercom: text, cmd: text) -> Result<text, text>:
    val session = t32_get_session(session_id)
    if session == nil:
        return Err("session not found: {session_id}")
    val s = session ?? T32SessionEntry(id: "", host: "", port: 0, intercom_name: "", architecture: "", client: Trace32Client(host: "", port: 0, t32rem_path: "", connected: false, program: "", bp_counter: 0), cores: [])
    s.client.intercom_execute(target_intercom, cmd)
