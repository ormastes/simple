# Bare-Metal Entry Point
#
# Minimal startup for bare-metal targets (cortex_m4, cortex_m0, riscv32).
# No heap, no args, no filesystem — just the app lifecycle.
#
# The actual _start assembly is generated by the compiler backend
# (see entry_point.spl). This module provides the Simple-level entry
# that the generated _start calls into.
#
# Startup sequence:
#   1. Hardware _start (generated assembly)
#   2. Zero BSS, set stack pointer (generated)
#   3. __simple_runtime_init() (runtime)
#   4. __simple_main() → calls baremetal_app_main()
#   5. __simple_runtime_shutdown() (runtime)
#   6. Halt loop (wfi/hlt)

use nogc_sync_mut.src.app.config.{AppConfig}
use nogc_sync_mut.src.app.lifecycle.{AppLifecycle}

# ============================================================================
# Bare-Metal App Entry
# ============================================================================

"""Entry point for bare-metal applications.

Creates a minimal AppConfig with no args and platform="none",
then runs the app lifecycle. The app must not use filesystem,
networking, or other OS services.
"""
fn baremetal_app_main(app: AppLifecycle) -> i32:
    val config = AppConfig.create(
        name: app.name(),
        version: "0.1.0",
        args: [],
        platform: "none",
        arch: detect_baremetal_arch()
    )

    val init_result = app.init(config)
    if init_result.is_err():
        return 1

    # For bare-metal, we typically run a single update loop
    var running = true
    while running:
        running = app.update()

    app.shutdown()
    0

# ============================================================================
# Bare-Metal Arch Detection
# ============================================================================

"""Detect architecture at compile time for bare-metal.
Falls back to "unknown" — the compiler should set this via target preset.
"""
fn detect_baremetal_arch() -> text:
    # On bare-metal, we can't run uname. The arch is known at compile time
    # and should be set by the target preset. This is a runtime fallback.
    "unknown"
