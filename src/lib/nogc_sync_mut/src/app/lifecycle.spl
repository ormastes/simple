# App Lifecycle
#
# Defines the AppLifecycle trait — the common interface for all Simple apps.
# Two usage modes:
#   - One-shot: init → (run logic) → shutdown (CLI tools, scripts)
#   - Loop-based: init → update loop → shutdown (games, servers, daemons)

use nogc_sync_mut.src.app.config.{AppConfig}

# ============================================================================
# AppLifecycle Trait
# ============================================================================

trait AppLifecycle:
    """Initialize the application with config. Return error text on failure."""
    me init(config: AppConfig) -> Result<Nil, text>

    """Called each frame/tick for loop-based apps. Return false to quit."""
    me update() -> bool

    """Clean up resources before exit."""
    me shutdown()

    """Return the application name."""
    fn name() -> text

# ============================================================================
# AppState — Tracks app lifecycle state
# ============================================================================

enum AppState:
    Created      # Not yet initialized
    Running      # init() succeeded, update loop active
    ShuttingDown # shutdown() in progress
    Stopped      # shutdown() complete

impl AppState:
    fn is_running() -> bool:
        match self:
            AppState.Running: true
            _: false

    fn is_stopped() -> bool:
        match self:
            AppState.Stopped: true
            _: false
