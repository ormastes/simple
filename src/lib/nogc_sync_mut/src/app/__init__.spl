# App Interface Library
#
# Common startup and lifecycle abstraction for Simple applications.
# Works across desktop, mobile (iOS/Android), WASM, and bare-metal.
#
# Usage:
#   use std.src.app.{AppConfig, AppLifecycle, MappedFile, run_app, run_oneshot}

# Re-exported from config.spl
use nogc_sync_mut.src.app.config.{AppConfig}

# Re-exported from lifecycle.spl
use nogc_sync_mut.src.app.lifecycle.{AppLifecycle, AppState}

# Re-exported from mapped_file.spl
use nogc_sync_mut.src.app.mapped_file.{MappedFile}

# Re-exported from runner.spl
use nogc_sync_mut.src.app.runner.{run_app, run_oneshot, run_simple}

# Re-exported from startup.spl
use nogc_sync_mut.src.app.startup.{app_main, desktop_start, wasm_start, baremetal_start, mobile_start}

# Re-exported from baremetal_entry.spl
use nogc_sync_mut.src.app.baremetal_entry.{baremetal_app_main}

# ============================================================================
# Exports
# ============================================================================

# Config
export AppConfig

# Lifecycle
export AppLifecycle, AppState

# Memory-Mapped Files
export MappedFile

# Runners
export run_app, run_oneshot, run_simple

# Startup
export app_main, desktop_start, wasm_start, baremetal_start, mobile_start
export baremetal_app_main
