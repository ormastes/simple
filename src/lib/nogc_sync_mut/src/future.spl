# Future Module - Future/Promise abstraction for async programming
#
# Provides a synchronous Future<T> type suitable for nogc_sync_mut contexts.
# Callbacks are type-erased (fn(Any) -> ()) because Simple does not support
# higher-kinded or fully reified generic closures at this layer.

enum FutureState:
    Pending
    Ready(value: Any)
    Failed(error: text)

struct Future<T>:
    state: FutureState
    callbacks: [fn(Any) -> ()]
    error_handlers: [fn(text) -> ()]

impl Future<T>:
    static fn pending() -> Future<T>:
        Future(state: FutureState.Pending, callbacks: [], error_handlers: [])

# ============================================================
# Construction
# ============================================================

pub fn future_new<T>() -> Future<T>:
    """Create a new Future in the Pending state."""
    Future(state: FutureState.Pending, callbacks: [], error_handlers: [])

# ============================================================
# Resolution
# ============================================================

pub fn future_resolve<T>(f: Future<T>, value: T):
    """Resolve the future with a value, invoking all registered callbacks."""
    f.state = FutureState.Ready(value: value as Any)
    var i = 0
    while i < f.callbacks.len():
        val cb = f.callbacks[i]
        i = i + 1
        cb(value as Any)

pub fn future_reject<T>(f: Future<T>, error: text):
    """Reject the future with an error message, invoking all error handlers."""
    f.state = FutureState.Failed(error: error)
    var i = 0
    while i < f.error_handlers.len():
        val eh = f.error_handlers[i]
        i = i + 1
        eh(error)

# ============================================================
# Query
# ============================================================

pub fn future_is_ready<T>(f: Future<T>) -> bool:
    """Return true if the future has been resolved with a value."""
    match f.state:
        case FutureState.Ready(_):
            return true
        case _:
            return false

pub fn future_is_failed<T>(f: Future<T>) -> bool:
    """Return true if the future has been rejected with an error."""
    match f.state:
        case FutureState.Failed(_):
            return true
        case _:
            return false

pub fn future_is_pending<T>(f: Future<T>) -> bool:
    """Return true if the future is still pending."""
    match f.state:
        case FutureState.Pending:
            return true
        case _:
            return false

pub fn future_get_value<T>(f: Future<T>) -> T?:
    """Return Some(value) if ready, nil otherwise."""
    match f.state:
        case FutureState.Ready(value):
            return Some(value as T)
        case _:
            return nil

pub fn future_get_error<T>(f: Future<T>) -> text?:
    """Return Some(error) if failed, nil otherwise."""
    match f.state:
        case FutureState.Failed(error):
            return Some(error)
        case _:
            return nil

# ============================================================
# Chaining
# ============================================================

pub fn future_then<T, U>(f: Future<T>, callback: fn(T) -> U) -> Future<U>:
    """Chain a transformation. If f is already resolved, apply callback immediately.
    If pending, register callback to run when f resolves."""
    val next = future_new<U>()
    match f.state:
        case FutureState.Ready(value):
            val result = callback(value as T)
            future_resolve(next, result)
        case FutureState.Failed(error):
            future_reject(next, error)
        case FutureState.Pending:
            val wrapped_cb: fn(Any) -> () = \v:
                val result = callback(v as T)
                future_resolve(next, result)
            f.callbacks = f.callbacks.push(wrapped_cb)
            val wrapped_eh: fn(text) -> () = future_reject(next, _1)
            f.error_handlers = f.error_handlers.push(wrapped_eh)
    next

pub fn future_map<T, U>(f: Future<T>, func: fn(T) -> U) -> Future<U>:
    """Alias for future_then — map a function over the resolved value."""
    future_then(f, func)

pub fn future_catch<T>(f: Future<T>, handler: fn(text) -> T) -> Future<T>:
    """Recover from a rejection by mapping the error to a value."""
    val next = future_new<T>()
    match f.state:
        case FutureState.Ready(value):
            future_resolve(next, value as T)
        case FutureState.Failed(error):
            val recovered = handler(error)
            future_resolve(next, recovered)
        case FutureState.Pending:
            val wrapped_cb: fn(Any) -> () = future_resolve(next, _1 as T)
            f.callbacks = f.callbacks.push(wrapped_cb)
            val wrapped_eh: fn(text) -> () = \e:
                val recovered = handler(e)
                future_resolve(next, recovered)
            f.error_handlers = f.error_handlers.push(wrapped_eh)
    next

pub fn future_on_resolve<T>(f: Future<T>, callback: fn(T) -> ()):
    """Register a side-effect callback that runs when the future resolves."""
    match f.state:
        case FutureState.Ready(value):
            callback(value as T)
        case FutureState.Pending:
            val wrapped: fn(Any) -> () = callback(_1 as T)
            f.callbacks = f.callbacks.push(wrapped)
        case _:
            pass_do_nothing

pub fn future_on_reject<T>(f: Future<T>, handler: fn(text) -> ()):
    """Register a side-effect handler that runs when the future is rejected."""
    match f.state:
        case FutureState.Failed(error):
            handler(error)
        case FutureState.Pending:
            f.error_handlers = f.error_handlers.push(handler)
        case _:
            pass_do_nothing
