# HashSet - Pure Simple Implementation
#
# No FFI, no Rust - 100% Pure Simple
# Uses HashMap internally


use collections.hashmap.HashMap

class HashSet:
    """Pure Simple HashSet using HashMap internally.

    Example:
        var set = HashSet.new()
        set.insert("apple")
        set.insert("banana")
        val has_apple = set.contains("apple")  # true
    """
    map: HashMap

    static fn new() -> HashSet:
        """Create new empty HashSet."""
        HashSet(map: HashMap.new())

    me insert(value: text) -> bool:
        """Insert value into set.

        Returns:
            true if newly inserted, false if already present
        """
        self.map.insert_if_absent(value, "")  # Use empty string as value

    fn contains(value: text) -> bool:
        """Check if value exists."""
        self.map.has(value)

    me remove(value: text) -> bool:
        """Remove value from set.

        Returns:
            true if value was present
        """
        val result = self.map.remove(value)
        result.?

    me clear():
        """Remove all values."""
        self.map.clear()

    fn len() -> i64:
        """Get number of values."""
        self.map.len()

    fn is_empty() -> bool:
        """Check if empty."""
        self.map.is_empty()

    fn to_vec() -> [text]:
        """Convert to vector."""
        self.map.keys()

    fn to_array() -> [text]:
        """Compatibility alias matching the std HashSet API."""
        self.to_vec()

    fn union(other: HashSet) -> HashSet:
        """Return a new set with values from both sets."""
        var result = HashSet.new()
        for value in self.to_vec():
            result.insert(value)
        for value in other.to_vec():
            result.insert(value)
        result

    fn intersection(other: HashSet) -> HashSet:
        """Return a new set containing values present in both sets."""
        var result = HashSet.new()
        for value in self.to_vec():
            if other.contains(value):
                result.insert(value)
        result

    fn difference(other: HashSet) -> HashSet:
        """Return a new set containing values present only in this set."""
        var result = HashSet.new()
        for value in self.to_vec():
            if not other.contains(value):
                result.insert(value)
        result

    fn symmetric_difference(other: HashSet) -> HashSet:
        """Return a new set containing values present in either set but not both."""
        var result = self.difference(other)
        val other_only = other.difference(self)
        for value in other_only.to_vec():
            result.insert(value)
        result

    fn is_subset(other: HashSet) -> bool:
        """Check whether every value in this set is present in other."""
        for value in self.to_vec():
            if not other.contains(value):
                return false
        true

    fn is_superset(other: HashSet) -> bool:
        """Check whether every value in other is present in this set."""
        other.is_subset(self)

    fn each(f: fn(text) -> void):
        """Call f for every set value."""
        for value in self.to_vec():
            f(value)

    fn map(f: fn(text) -> text) -> HashSet:
        """Map values into a new set."""
        var result = HashSet.new()
        for value in self.to_vec():
            result.insert(f(value))
        result

    fn filter(predicate: fn(text) -> bool) -> HashSet:
        """Filter values into a new set."""
        var result = HashSet.new()
        for value in self.to_vec():
            if predicate(value):
                result.insert(value)
        result
