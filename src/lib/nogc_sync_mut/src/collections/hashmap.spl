# HashMap - Pure Simple Implementation
#
# No FFI, no Rust - 100% Pure Simple
# Hash table with chaining for collision resolution


struct HashMapEntry:
    """Key-value pair in HashMap."""
    key: text
    value: text
    hash: i64

extern fn rt_hash_text(s: text) -> i64

class HashMap:
    """Pure Simple HashMap using array of buckets with chaining.

    Example:
        var map = HashMap.new()
        map.insert("name", "Alice")
        val name = map.get("name")  # Some("Alice")
    """
    buckets: [[HashMapEntry]]
    size: i64
    capacity: i64

    static fn new() -> HashMap:
        """Create new empty HashMap with default capacity."""
        HashMap.with_capacity(16)

    static fn with_capacity(requested_capacity: i64) -> HashMap:
        """Create new empty HashMap with at least requested_capacity buckets."""
        var capacity = requested_capacity
        if capacity < 1:
            capacity = 1
        var buckets: [[HashMapEntry]] = []
        var i = 0
        while i < capacity:
            var bucket: [HashMapEntry] = []
            buckets.push(bucket)
            i = i + 1

        HashMap(buckets: buckets, size: 0, capacity: capacity)

    me insert(key: text, value: text):
        """Insert or update key-value pair."""
        # Resize if load factor > 0.75
        if self.size * 4 > self.capacity * 3:
            self._resize()

        val hash = rt_hash_text(key)
        val idx = self._bucket_index_hash(hash)
        var bucket = self.buckets[idx]

        # Update if key exists
        for i in 0..bucket.len():
            if bucket[i].hash == hash and bucket[i].key == key:
                bucket[i] = HashMapEntry(key: key, value: value, hash: hash)
                self.buckets[idx] = bucket
                return

        # Add new entry
        bucket.push(HashMapEntry(key: key, value: value, hash: hash))
        self.buckets[idx] = bucket
        self.size = self.size + 1

    me insert_if_absent(key: text, value: text) -> bool:
        """Insert key-value pair only when the key is missing."""
        if self.size * 4 > self.capacity * 3:
            self._resize()

        val hash = rt_hash_text(key)
        val idx = self._bucket_index_hash(hash)
        var bucket = self.buckets[idx]

        for entry in bucket:
            if entry.hash == hash:
                if entry.key == key:
                    return false

        bucket.push(HashMapEntry(key: key, value: value, hash: hash))
        self.buckets[idx] = bucket
        self.size = self.size + 1
        true

    fn get(key: text) -> text?:
        """Get value for key."""
        val hash = rt_hash_text(key)
        val idx = self._bucket_index_hash(hash)
        val bucket = self.buckets[idx]

        for entry in bucket:
            if entry.hash == hash:
                if entry.key == key:
                    return Some(entry.value)

        nil

    fn contains_key(key: text) -> bool:
        """Check if key exists."""
        val hash = rt_hash_text(key)
        val cap = self.capacity
        val idx = if (cap & (cap - 1)) == 0: hash & (cap - 1) else: if hash < 0: (0 - hash) % cap else: hash % cap
        val bucket = self.buckets[idx]

        for entry in bucket:
            if entry.hash == hash:
                if entry.key == key:
                    return true

        false

    fn has(key: text) -> bool:
        """Compatibility alias for contains_key."""
        self.contains_key(key)

    me remove(key: text) -> text?:
        """Remove key and return value."""
        val hash = rt_hash_text(key)
        val idx = self._bucket_index_hash(hash)
        var bucket = self.buckets[idx]

        for i in 0..bucket.len():
            if bucket[i].hash == hash and bucket[i].key == key:
                val value = bucket[i].value
                val last_idx = bucket.len() - 1
                if i != last_idx:
                    bucket[i] = bucket[last_idx]
                bucket.pop()
                self.buckets[idx] = bucket
                self.size = self.size - 1
                return Some(value)

        nil

    fn keys() -> [text]:
        """Get all keys."""
        var result: [text] = []
        for bucket in self.buckets:
            for entry in bucket:
                result.push(entry.key)
        result

    fn values() -> [text]:
        """Get all values."""
        var result: [text] = []
        for bucket in self.buckets:
            for entry in bucket:
                result.push(entry.value)
        result

    fn entries() -> [[text]]:
        """Get all entries as [key, value] pairs."""
        var result: [[text]] = []
        for bucket in self.buckets:
            for entry in bucket:
                result.push([entry.key, entry.value])
        result

    fn each(f: fn(text, text) -> void):
        """Call f for every key-value pair."""
        for bucket in self.buckets:
            for entry in bucket:
                f(entry.key, entry.value)

    fn map_values(f: fn(text) -> text) -> HashMap:
        """Return a new map with the same keys and transformed values."""
        var result = HashMap.new()
        for bucket in self.buckets:
            for entry in bucket:
                result.insert(entry.key, f(entry.value))
        result

    fn filter(predicate: fn(text, text) -> bool) -> HashMap:
        """Return a new map containing entries accepted by predicate."""
        var result = HashMap.new()
        for bucket in self.buckets:
            for entry in bucket:
                if predicate(entry.key, entry.value):
                    result.insert(entry.key, entry.value)
        result

    me clear():
        """Remove all entries."""
        var i = 0
        while i < self.capacity:
            var bucket: [HashMapEntry] = []
            self.buckets[i] = bucket
            i = i + 1
        self.size = 0

    fn len() -> i64:
        """Get number of entries."""
        self.size

    fn is_empty() -> bool:
        """Check if empty."""
        self.size == 0

    fn _bucket_index(key: text) -> i64:
        """Compute bucket index for key."""
        val hash = rt_hash_text(key)
        self._bucket_index_hash(hash)

    fn _bucket_index_hash(hash: i64) -> i64:
        """Compute bucket index from a precomputed hash."""
        val cap = self.capacity
        if (cap & (cap - 1)) == 0:
            hash & (cap - 1)
        elif hash < 0:
            (0 - hash) % cap
        else:
            hash % cap

    fn _hash(s: text) -> i64:
        """Hash text using the shared runtime text hash primitive."""
        rt_hash_text(s)

    me _resize():
        """Double capacity and rehash."""
        val new_capacity = self.capacity * 2
        var new_buckets: [[HashMapEntry]] = []
        var i = 0
        while i < new_capacity:
            var bucket: [HashMapEntry] = []
            new_buckets.push(bucket)
            i = i + 1

        # Rehash all entries
        for bucket in self.buckets:
            for entry in bucket:
                val idx = entry.hash & (new_capacity - 1)
                var target_bucket = new_buckets[idx]
                target_bucket.push(entry)
                new_buckets[idx] = target_bucket

        self.buckets = new_buckets
        self.capacity = new_capacity

fn hashmap_with_capacity(capacity: i64) -> HashMap:
    """Create a HashMap with preallocated buckets."""
    var actual_capacity = capacity
    if actual_capacity < 1:
        actual_capacity = 1
    var buckets: [[HashMapEntry]] = []
    var i = 0
    while i < actual_capacity:
        var bucket: [HashMapEntry] = []
        buckets.push(bucket)
        i = i + 1
    HashMap(buckets: buckets, size: 0, capacity: actual_capacity)

export hashmap_with_capacity
