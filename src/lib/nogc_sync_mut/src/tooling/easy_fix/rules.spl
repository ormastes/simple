#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# EasyFix Shared Rules Module
# Each rule: fn check_<rule>(source: String, file: String) -> [EasyFix]
#
# Rule IDs:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:spipe_missing_docstrings   — Add template docstring to describe/context
#   L:spipe_manual_assertions    — Replace manual if/fail with expect()
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:typo_suggestion            — Fix misspelled identifiers (Levenshtein)
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   E:type_mismatch_coercion     — Insert type coercion (.to_string() etc.)
#   L:deprecated_if_let          — Replace `if let` with `if val`

# ============================================================================
# Data types imported from stdlib
# ============================================================================

use std.tooling.easy_fix.types.{EasyFix, FixConfidence, Replacement}

struct DuplicateTypedArgSignature:
    name: text
    line_num: i64
    decl_paren_start: i64
    decl_paren_end: i64
    decl_column: i64
    arg_count: i64
    param_names: [text]
    new_params_text: text
    has_decl_rewrite: bool
    can_rewrite_calls: bool

# ============================================================================
# Helper: Line Iteration with Context
# ============================================================================

struct LineContext:
    """Context information for processing a source line."""
    line: text
    line_num: i64
    byte_offset: i64
    trimmed: text
    indent: i64

fn for_each_line(source: text, callback: fn(LineContext) -> [EasyFix]) -> [EasyFix]:
    """
    Iterate over source lines and collect fixes from callback.

    Handles the common pattern of splitting source, tracking line numbers/offsets,
    and collecting fixes. Reduces duplication in rule implementations.
    """
    val lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var all_fixes: [EasyFix] = []

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        val context = LineContext(
            line: line,
            line_num: line_num,
            byte_offset: byte_offset,
            trimmed: trimmed,
            indent: indent
        )

        val line_fixes = callback(context)
        for fix in line_fixes:
            all_fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    all_fixes

fn line_contexts(source: text) -> [LineContext]:
    val lines = source.split("\n")
    var result: [LineContext] = []
    var line_num = 0
    var byte_offset = 0
    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()
        result.push(LineContext(line: line, line_num: line_num, byte_offset: byte_offset, trimmed: trimmed, indent: indent))
        byte_offset = byte_offset + line.len() + 1
    result

# ============================================================================
# Helper: compute byte offset for a given line/column (1-based)
# ============================================================================

fn byte_offset_of(source: String, target_line: Int, target_col: Int) -> Int:
    val lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + target_col - 1
        offset = offset + line.len() + 1  # +1 for \n
        line_num = line_num + 1
    offset

fn line_start_offset(source: String, target_line: Int) -> Int:
    byte_offset_of(source: source, target_line: target_line, target_col: 1)

fn line_end_offset(source: String, target_line: Int) -> Int:
    val lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + line.len()
        offset = offset + line.len() + 1
        line_num = line_num + 1
    offset

# ============================================================================
# Rule 1: print_in_test_spec
# Detects print(...) calls in _spec.spl files and suggests expect().
# Confidence: Likely
# ============================================================================

fn check_print_in_test_spec(source: String, file: String) -> [EasyFix]:
    # Only applies to spec files
    if not file.ends_with("_spec.spl"):
        return []

    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        if ctx.trimmed.starts_with("print(") or ctx.trimmed.starts_with("print "):
            val start = ctx.byte_offset + ctx.indent
            val end = ctx.byte_offset + ctx.line.len()

            var arg = ""
            if ctx.trimmed.starts_with("print("):
                val inner = ctx.trimmed.slice(6)
                if inner.ends_with(")"):
                    arg = inner.slice(0, inner.len() - 1)
                else:
                    arg = inner

            if arg.len() > 0:
                var fix = EasyFix.create(
                    id: "L:print_in_test_spec:{ctx.line_num}",
                    description: "replace print() with expect() in test spec",
                    confidence: FixConfidence.Likely
                )
                val spaces = " ".repeat(ctx.indent)
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: start,
                    end: end,
                    line: ctx.line_num,
                    column: ctx.indent + 1,
                    new_text: "{spaces}expect({arg}).to_be_truthy()"
                ))
                fixes.push(fix)

    fixes

# ============================================================================
# Rule 2: unnamed_duplicate_typed_args
# Detects fn signatures with duplicate types that lack distinct names.
# Confidence: Uncertain
# ============================================================================

fn check_unnamed_duplicate_typed_args(source: String, file: String) -> [EasyFix]:
    val signatures = _collect_duplicate_typed_arg_signatures(source: source)
    var fixes: [EasyFix] = []

    for sig in signatures:
        var replacements: [Replacement] = []

        if sig.has_decl_rewrite:
            replacements.push(Replacement.create(
                file: file,
                start: sig.decl_paren_start,
                end: sig.decl_paren_end,
                line: sig.line_num,
                column: sig.decl_column,
                new_text: sig.new_params_text
            ))

        if sig.can_rewrite_calls and _is_unique_call_target(signatures: signatures, sig: sig):
            val call_replacements = _collect_call_replacements_for_signature(source: source, file: file, sig: sig)
            for rep in call_replacements:
                replacements.push(rep)

        if not replacements.is_empty():
            val description = if sig.has_decl_rewrite:
                "add distinct parameter names for duplicate types"
            else:
                "rewrite positional duplicate-typed arguments as named calls"
            var fix = EasyFix.create(
                id: "L:unnamed_duplicate_typed_args:{sig.line_num}",
                description: description,
                confidence: FixConfidence.Uncertain
            )
            for rep in replacements:
                fix.add_replacement(rep)
            fixes.push(fix)

    fixes

fn _collect_duplicate_typed_arg_signatures(source: text) -> [DuplicateTypedArgSignature]:
    var signatures: [DuplicateTypedArgSignature] = []
    for ctx in line_contexts(source):
        val sig = _parse_duplicate_typed_arg_signature(ctx)
        match sig:
            case Some(found):
                signatures.push(found)
            case nil:
                pass
    signatures

fn _parse_duplicate_typed_arg_signature(ctx: LineContext) -> Option<DuplicateTypedArgSignature>:
    if not _dup_is_fn_sig(trimmed: ctx.trimmed):
        return nil
    if not ctx.trimmed.contains("("):
        return nil

    val paren_start = ctx.trimmed.find("(")
    if paren_start < 0:
        return nil
    val paren_end = _find_matching_paren_on_line(text: ctx.trimmed, open_paren: paren_start)
    if paren_end <= paren_start:
        return nil

    val name = _extract_sig_name(trimmed: ctx.trimmed, paren_start: paren_start)
    if name == "":
        return nil

    val params_str = ctx.trimmed.slice(paren_start + 1, paren_end)
    val params = _split_top_level_csv(text: params_str)
    if params.is_empty():
        return nil

    var raw_names: [text] = []
    var raw_types: [text] = []
    var normalized_types: [text] = []
    var has_unnamed = false

    for param in params:
        val trimmed_param = param.trim()
        if trimmed_param == "":
            continue
        val colon_pos = _find_top_level_colon(text: trimmed_param)
        if colon_pos >= 0:
            raw_names.push(trimmed_param.slice(0, colon_pos).trim())
            raw_types.push(trimmed_param.slice(colon_pos + 1).trim())
        else:
            raw_names.push("")
            raw_types.push(trimmed_param)
            has_unnamed = true
        normalized_types.push(raw_types[raw_types.len() - 1].trim())

    if raw_types.len() < 2:
        return nil

    var type_counts: Dict<text, i64> = {}
    var has_duplicate_types = false
    for ty in normalized_types:
        val count = type_counts[ty] ?? 0
        type_counts[ty] = count + 1
        if count + 1 >= 2:
            has_duplicate_types = true
    if not has_duplicate_types:
        return nil

    var resolved_names: [text] = []
    var rewritten_params: [text] = []
    var generated_counts: Dict<text, i64> = {}
    var i = 0
    while i < raw_types.len():
        val param_name = raw_names[i]
        val param_type = raw_types[i]
        var resolved_name = param_name
        if resolved_name == "":
            val key = normalized_types[i]
            val next_count = (generated_counts[key] ?? 0) + 1
            generated_counts[key] = next_count
            resolved_name = "{_type_name_to_identifier(text: param_type)}{next_count}"
        rewritten_params.push("{resolved_name}: {param_type}")
        resolved_names.push(resolved_name)
        i = i + 1

    var stable_names = true
    var seen_names: Dict<text, bool> = {}
    i = 0
    while i < resolved_names.len():
        if type_counts[normalized_types[i]] >= 2:
            val name_i = resolved_names[i]
            if name_i == "" or name_i == "_" or name_i.starts_with("_"):
                stable_names = false
            elif seen_names.has(name_i):
                stable_names = false
            else:
                seen_names[name_i] = true
        i = i + 1

    Some(DuplicateTypedArgSignature(
        name: name,
        line_num: ctx.line_num,
        decl_paren_start: ctx.byte_offset + ctx.indent + paren_start + 1,
        decl_paren_end: ctx.byte_offset + ctx.indent + paren_end,
        decl_column: paren_start + 2,
        arg_count: resolved_names.len(),
        param_names: resolved_names,
        new_params_text: rewritten_params.join(", "),
        has_decl_rewrite: has_unnamed,
        can_rewrite_calls: stable_names
    ))

fn _collect_call_replacements_for_signature(source: text, file: text, sig: DuplicateTypedArgSignature) -> [Replacement]:
    var replacements: [Replacement] = []

    for ctx in line_contexts(source):
        val line_replacements = _collect_line_call_replacements(line: ctx.line, file: file, sig: sig, line_num: ctx.line_num, byte_offset: ctx.byte_offset)
        for rep in line_replacements:
            replacements.push(rep)

    replacements

fn _collect_line_call_replacements(line: text, file: text, sig: DuplicateTypedArgSignature, line_num: i64, byte_offset: i64) -> [Replacement]:
    var replacements: [Replacement] = []
    var i = 0
    while i < line.len():
        if not _matches_identifier_at(line: line, start: i, name: sig.name):
            i = i + 1
            continue
        if _is_definition_context(line: line, token_start: i):
            i = i + sig.name.len()
            continue
        val open_paren = _find_call_open_paren(line: line, start: i + sig.name.len())
        if open_paren < 0:
            i = i + sig.name.len()
            continue
        val close_paren = _find_matching_paren_on_line(text: line, open_paren: open_paren)
        if close_paren <= open_paren:
            i = i + sig.name.len()
            continue
        val args_str = line.slice(open_paren + 1, close_paren)
        val args = _split_top_level_csv(text: args_str)
        if args.len() != sig.arg_count or _args_have_named_entries(args: args):
            i = close_paren + 1
            continue
        var named_args: [text] = []
        var arg_index = 0
        while arg_index < args.len():
            named_args.push("{sig.param_names[arg_index]}: {args[arg_index].trim()}")
            arg_index = arg_index + 1
        replacements.push(Replacement.create(
            file: file,
            start: byte_offset + open_paren + 1,
            end: byte_offset + close_paren,
            line: line_num,
            column: open_paren + 2,
            new_text: named_args.join(", ")
        ))
        i = close_paren + 1
    replacements

fn _is_unique_call_target(signatures: [DuplicateTypedArgSignature], sig: DuplicateTypedArgSignature) -> bool:
    var matches = 0
    for candidate in signatures:
        if candidate.can_rewrite_calls and candidate.name == sig.name and candidate.arg_count == sig.arg_count:
            matches = matches + 1
    matches == 1

fn _dup_is_fn_sig(trimmed: text) -> bool:
    trimmed.starts_with("fn ")
        or trimmed.starts_with("me ")
        or trimmed.starts_with("static fn ")
        or trimmed.starts_with("pub fn ")
        or trimmed.starts_with("pub me ")
        or trimmed.starts_with("pub static fn ")

fn _extract_sig_name(trimmed: text, paren_start: i64) -> text:
    val before = trimmed.slice(0, paren_start).trim()
    val parts = before.split(" ")
    if parts.is_empty():
        return ""
    parts[parts.len() - 1].trim()

fn _split_top_level_csv(text: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    var paren_depth = 0
    var bracket_depth = 0
    var brace_depth = 0
    var angle_depth = 0
    var in_string = false

    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")":
                paren_depth = paren_depth - 1
            elif ch == "[":
                bracket_depth = bracket_depth + 1
            elif ch == "]":
                bracket_depth = bracket_depth - 1
            elif ch == "{":
                brace_depth = brace_depth + 1
            elif ch == "}":
                brace_depth = brace_depth - 1
            elif ch == "<":
                angle_depth = angle_depth + 1
            elif ch == ">":
                angle_depth = angle_depth - 1
            elif ch == "," and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 and angle_depth == 0:
                parts.push(text.slice(start, i).trim())
                start = i + 1
        i = i + 1

    val tail = text.slice(start).trim()
    if tail != "":
        parts.push(tail)
    parts

fn _find_top_level_colon(text: text) -> i64:
    var i = 0
    var paren_depth = 0
    var bracket_depth = 0
    var brace_depth = 0
    var angle_depth = 0
    var in_string = false

    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                paren_depth = paren_depth + 1
            elif ch == ")":
                paren_depth = paren_depth - 1
            elif ch == "[":
                bracket_depth = bracket_depth + 1
            elif ch == "]":
                bracket_depth = bracket_depth - 1
            elif ch == "{":
                brace_depth = brace_depth + 1
            elif ch == "}":
                brace_depth = brace_depth - 1
            elif ch == "<":
                angle_depth = angle_depth + 1
            elif ch == ">":
                angle_depth = angle_depth - 1
            elif ch == ":" and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 and angle_depth == 0:
                return i
        i = i + 1
    -1

fn _find_matching_paren_on_line(text: text, open_paren: i64) -> i64:
    var i = open_paren
    var depth = 0
    var in_string = false
    while i < text.len():
        val ch = text.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == "(":
                depth = depth + 1
            elif ch == ")":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    -1

fn _type_name_to_identifier(text: text) -> text:
    var out = ""
    var prev_underscore = false
    var i = 0
    while i < text.len():
        val ch = text.slice(i, i + 1).lower()
        if _is_identifier_char(ch):
            out = out + ch
            prev_underscore = false
        elif not prev_underscore:
            out = out + "_"
            prev_underscore = true
        i = i + 1
    while out.starts_with("_"):
        out = out.slice(1)
    while out.ends_with("_"):
        out = out.slice(0, out.len() - 1)
    if out == "":
        return "arg"
    if _is_digit_char(out.slice(0, 1)):
        return "arg_{out}"
    out

fn _matches_identifier_at(line: text, start: i64, name: text) -> bool:
    if start < 0 or start + name.len() > line.len():
        return false
    if line.slice(start, start + name.len()) != name:
        return false
    if start > 0 and _is_identifier_char(line.slice(start - 1, start)):
        return false
    val end = start + name.len()
    if end < line.len() and _is_identifier_char(line.slice(end, end + 1)):
        return false
    true

fn _is_definition_context(line: text, token_start: i64) -> bool:
    val before = line.slice(0, token_start).trim()
    before.ends_with("fn") or before.ends_with("me")

fn _find_call_open_paren(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line.slice(i, i + 1)
        if ch == " " or ch == "\t":
            i = i + 1
            continue
        if ch == "(":
            return i
        return -1
    -1

fn _args_have_named_entries(args: [text]) -> bool:
    for arg in args:
        if _find_top_level_colon(text: arg.trim()) >= 0:
            return true
    false

fn _is_identifier_char(ch: text) -> bool:
    if ch == "_":
        return true
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or _is_digit_char(ch)

fn _is_digit_char(ch: text) -> bool:
    ch >= "0" and ch <= "9"

# ============================================================================
# Rule 3: resource_leak
# Detects open()/connect() calls not wrapped in `with` blocks.
# Confidence: Uncertain
# ============================================================================

fn check_resource_leak(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        # Detect val x = open(...) or val x = connect(...) not inside with
        val is_resource_open = ctx.trimmed.contains("= open(") or ctx.trimmed.contains("= connect(") or ctx.trimmed.contains("= File.open(")
        if is_resource_open and ctx.trimmed.starts_with("val ") and not ctx.trimmed.starts_with("with"):
            val eq_pos = ctx.trimmed.find("=")
            if eq_pos > 4:
                val var_name = ctx.trimmed.slice(4, eq_pos).trim()
                val expr = ctx.trimmed.slice(eq_pos + 1).trim()

                val start = ctx.byte_offset + ctx.indent
                val end = ctx.byte_offset + ctx.line.len()

                val spaces = " ".repeat(ctx.indent)
                val inner_spaces = " ".repeat(ctx.indent + 4)
                val new_text = "{spaces}with {var_name} = {expr}:\n{inner_spaces}# TODO: use {var_name} here"

                var fix = EasyFix.create(
                    id: "L:resource_leak:{ctx.line_num}",
                    description: "wrap resource in `with` block to ensure cleanup",
                    confidence: FixConfidence.Uncertain
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: start,
                    end: end,
                    line: ctx.line_num,
                    column: ctx.indent + 1,
                    new_text: new_text
                ))
                fixes.push(fix)

    fixes

# ============================================================================
# Rule 4: spipe_missing_docstrings
# Detects describe/context blocks without docstrings.
# Confidence: Safe
# ============================================================================

fn check_spipe_missing_docstrings(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []

    if not file.ends_with("_spec.spl"):
        return fixes

    val lines = source.split("\n")

    for ctx in line_contexts(source):
        val is_describe = ctx.trimmed.starts_with("describe ")
        val is_context = ctx.trimmed.starts_with("context ")

        if is_describe or is_context:
            val keyword = if is_describe: "describe" else: "context"

            # Extract the name string
            val after_kw = ctx.trimmed.slice(keyword.len()).trim()
            var block_name = after_kw
            if after_kw.starts_with("\""):
                val close_quote = after_kw.slice(1).find("\"")
                if close_quote >= 0:
                    block_name = after_kw.slice(1, close_quote + 1)

            # Check if next non-empty line is a docstring (""")
            var next_idx = ctx.line_num  # 0-indexed for next line
            var has_docstring = false

            if next_idx < lines.len():
                val next_line = lines[next_idx]
                val next_trimmed = next_line.trim()
                if next_trimmed.starts_with("\"\"\""):
                    has_docstring = true

            if not has_docstring:
                val insert_pos = ctx.byte_offset + ctx.line.len() + 1  # After newline
                val spaces = " ".repeat(ctx.indent + 4)
                val header = if is_describe: "##" else: "###"
                val scenario = if is_describe: "" else: "Scenario: "
                val docstring = "{spaces}\"\"\"\n{spaces}{header} {scenario}{block_name}\n{spaces}\n{spaces}Description of this {keyword} block.\n{spaces}\"\"\"\n"

                var fix = EasyFix.create(
                    id: "L:spipe_missing_docstrings:{ctx.line_num}",
                    description: "add template docstring to {keyword} block",
                    confidence: FixConfidence.Safe
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: insert_pos,
                    end: insert_pos,
                    line: ctx.line_num + 1,
                    column: 1,
                    new_text: docstring
                ))
                fixes.push(fix)

    fixes

# ============================================================================
# Rule 5: spipe_manual_assertions
# Detects `if condition: fail(...)` and suggests `expect(condition)`.
# Confidence: Likely
# ============================================================================

fn check_spipe_manual_assertions(source: String, file: String) -> [EasyFix]:
    if not file.ends_with("_spec.spl"):
        return []

    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        # Pattern: if <cond>: fail(...) or if not <cond>: fail(...)
        if ctx.trimmed.starts_with("if ") and ctx.trimmed.contains("fail("):
            # Extract condition: between "if " and ":"
            val colon_pos = ctx.trimmed.find(":")
            if colon_pos > 3:
                val condition = ctx.trimmed.slice(3, colon_pos).trim()
                val after_colon = ctx.trimmed.slice(colon_pos + 1).trim()

                if after_colon.starts_with("fail("):
                    val start = ctx.byte_offset + ctx.indent
                    val end = ctx.byte_offset + ctx.line.len()
                    val spaces = " ".repeat(ctx.indent)

                    # If condition is negated, expect the positive
                    val expect_expr = if condition.starts_with("not ") then "expect({condition.slice(4).trim()}).to_be_truthy()" else "expect({condition}).to_be_falsy()"

                    var fix = EasyFix.create(
                        id: "L:spipe_manual_assertions:{ctx.line_num}",
                        description: "replace manual if/fail with expect()",
                        confidence: FixConfidence.Likely
                    )
                    fix.add_replacement(Replacement.create(
                        file: file,
                        start: start,
                        end: end,
                        line: ctx.line_num,
                        column: ctx.indent + 1,
                        new_text: "{spaces}{expect_expr}"
                    ))
                    fixes.push(fix)

    fixes

# ============================================================================
# Rule 6: non_exhaustive_match
# Detects match blocks without a catch-all `case _:` arm.
# Confidence: Safe
# ============================================================================

fn check_non_exhaustive_match(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var in_match = false
    var match_indent = 0
    var has_catch_all = false
    var match_end_line = 0
    var match_end_offset = 0
    var last_case_indent = 0

    for ctx in line_contexts(source):
        if ctx.trimmed.starts_with("match ") and ctx.trimmed.ends_with(":"):
            # Start of match block
            if in_match and not has_catch_all:
                # Previous match was non-exhaustive — emit fix
                _emit_non_exhaustive_fix(fixes: fixes, file: file, after_line: match_end_line, after_offset: match_end_offset, case_indent: last_case_indent)
            in_match = true
            match_indent = ctx.indent
            has_catch_all = false
            match_end_line = ctx.line_num
            match_end_offset = ctx.byte_offset + ctx.line.len()

        if in_match and ctx.trimmed.starts_with("case "):
            last_case_indent = ctx.indent
            match_end_line = ctx.line_num
            match_end_offset = ctx.byte_offset + ctx.line.len()

            if ctx.trimmed.starts_with("case _:") or ctx.trimmed.starts_with("case _"):
                has_catch_all = true

        # Detect end of match block (dedent)
        if in_match and ctx.line.len() > 0 and ctx.indent <= match_indent and not ctx.trimmed.starts_with("match ") and not ctx.trimmed.starts_with("case "):
            if not has_catch_all:
                _emit_non_exhaustive_fix(fixes: fixes, file: file, after_line: match_end_line, after_offset: match_end_offset, case_indent: last_case_indent)
            in_match = false

    # Handle match at end of file
    if in_match and not has_catch_all:
        _emit_non_exhaustive_fix(fixes: fixes, file: file, after_line: match_end_line, after_offset: match_end_offset, case_indent: last_case_indent)

    fixes

fn _emit_non_exhaustive_fix(fixes: [EasyFix], file: String, after_line: Int, after_offset: Int, case_indent: Int):
    val spaces = " ".repeat(case_indent)
    val inner_spaces = " ".repeat(case_indent + 4)
    val new_arm = "\n{spaces}case _:\n{inner_spaces}todo(\"handle remaining cases\")"
    var fix = EasyFix.create(
        id: "L:non_exhaustive_match:{after_line}",
        description: "add missing catch-all arm with todo()",
        confidence: FixConfidence.Safe
    )
    fix.add_replacement(Replacement.create(
        file: file,
        start: after_offset,
        end: after_offset,
        line: after_line,
        column: 1,
        new_text: new_arm
    ))
    fixes.push(fix)

# ============================================================================
# Rule 7: typo_suggestion (Levenshtein distance)
# Detects likely misspelled identifiers and suggests corrections.
# Confidence: Likely
# ============================================================================

fn levenshtein(a: String, b: String) -> Int:
    val m = a.len()
    val n = b.len()
    if m == 0:
        return n
    if n == 0:
        return m

    # Use single-row DP
    var prev: [Int] = []
    var i = 0
    while i <= n:
        prev.push(i)
        i = i + 1

    i = 1
    while i <= m:
        var curr: [Int] = [i]
        var j = 1
        while j <= n:
            val cost = if a[i - 1] == b[j - 1]: 0 else: 1
            val del = prev[j] + 1
            val ins = curr[j - 1] + 1
            val sub = prev[j - 1] + cost
            var min_val = del
            if ins < min_val:
                min_val = ins
            if sub < min_val:
                min_val = sub
            curr.push(min_val)
            j = j + 1
        prev = curr
        i = i + 1

    prev[n]

fn check_typo_suggestion(source: String, file: String, known_names: [String]) -> [EasyFix]:
    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        # Look for lines with "undefined" or "not found" error patterns
        # This rule is primarily used with compiler error output, but we can also
        # scan for identifiers that are close to known names
        # For text-scanning mode: check val/var assignments with unknown identifiers
        pass

    # This rule is primarily for compiler diagnostics integration.
    # The text-scanning version is a no-op; the Rust version hooks into name resolution.
    fixes

fn suggest_typo_fix(file: String, line_num: Int, col: Int, byte_start: Int, byte_end: Int, misspelled: String, known_names: [String]) -> Option<EasyFix>:
    var best_name = ""
    var best_dist = 3  # Max distance threshold

    for name in known_names:
        val dist = levenshtein(a: misspelled, b: name)
        if dist > 0 and dist < best_dist:
            best_dist = dist
            best_name = name

    if best_name.len() > 0:
        var fix = EasyFix.create(
            id: "E:typo_suggestion:{line_num}",
            description: "did you mean `{best_name}`?",
            confidence: FixConfidence.Likely
        )
        fix.add_replacement(Replacement.create(
            file: file,
            start: byte_start,
            end: byte_end,
            line: line_num,
            column: col,
            new_text: best_name
        ))
        return Some(fix)

    nil

# ============================================================================
# Rule 8: parser_contextual_keyword (E0013)
# Detects common parser errors with contextual keywords.
# Confidence: Safe
# ============================================================================

fn check_parser_contextual_keyword(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        if ctx.trimmed.starts_with("async static fn "):
            val start = ctx.byte_offset + ctx.indent
            val end = start + 16
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: ctx.indent + 1,
                new_text: "static async fn "
            ))
            fixes.push(fix)

        if ctx.trimmed.starts_with("static pub fn "):
            val start = ctx.byte_offset + ctx.indent
            val end = start + 14
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `pub static fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: ctx.indent + 1,
                new_text: "pub static fn "
            ))
            fixes.push(fix)

        if ctx.trimmed.starts_with("pub async static fn "):
            val start = ctx.byte_offset + ctx.indent
            val end = start + 20
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `pub static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: ctx.indent + 1,
                new_text: "pub static async fn "
            ))
            fixes.push(fix)

    fixes

# ============================================================================
# Rule 9: type_mismatch_coercion
# Detects type mismatches where a simple coercion can fix the issue.
# Confidence: Likely
# ============================================================================

fn check_type_mismatch_coercion(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    # This rule works primarily with compiler type-check errors.
    # The text-scanning version is a no-op; the Rust version hooks into type checker.
    fixes

fn suggest_type_coercion_fix(file: String, line_num: Int, col: Int, byte_end: Int, expected_type: String, actual_type: String) -> Option<EasyFix>:
    # Common coercions
    var coercion = ""

    if expected_type == "String" and actual_type == "Int":
        coercion = ".to_string()"
    if expected_type == "String" and actual_type == "Float":
        coercion = ".to_string()"
    if expected_type == "String" and actual_type == "Bool":
        coercion = ".to_string()"
    if expected_type == "Int" and actual_type == "Float":
        coercion = ".to_int()"
    if expected_type == "Float" and actual_type == "Int":
        coercion = ".to_float()"
    if expected_type == "Bool" and actual_type == "Int":
        coercion = " != 0"

    if coercion.len() > 0:
        var fix = EasyFix.create(
            id: "E:type_mismatch_coercion:{line_num}",
            description: "insert `{coercion}` to convert {actual_type} to {expected_type}",
            confidence: FixConfidence.Likely
        )
        fix.add_replacement(Replacement.create(
            file: file,
            start: byte_end,
            end: byte_end,
            line: line_num,
            column: col,
            new_text: coercion
        ))
        return Some(fix)

    nil

# ============================================================================
# Rule 10: deprecated_if_let
# Detects `if let`, `while let`, `elif let` and replaces `let` with `val`.
# Confidence: Safe
# ============================================================================

fn check_deprecated_if_let(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []

    for ctx in line_contexts(source):
        val idx_if = ctx.trimmed.find("if let ")
        if idx_if >= 0:
            val let_start = ctx.byte_offset + ctx.indent + idx_if + 3  # "if " is 3 chars
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{ctx.line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: ctx.line_num,
                column: ctx.indent + idx_if + 4,
                new_text: "val"
            ))
            fixes.push(fix)

        val idx_while = ctx.trimmed.find("while let ")
        if idx_while >= 0:
            val let_start = ctx.byte_offset + ctx.indent + idx_while + 6  # "while " is 6 chars
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{ctx.line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: ctx.line_num,
                column: ctx.indent + idx_while + 7,
                new_text: "val"
            ))
            fixes.push(fix)

        val idx_elif = ctx.trimmed.find("elif let ")
        if idx_elif >= 0:
            val let_start = ctx.byte_offset + ctx.indent + idx_elif + 5  # "elif " is 5 chars
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{ctx.line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: ctx.line_num,
                column: ctx.indent + idx_elif + 6,
                new_text: "val"
            ))
            fixes.push(fix)

    fixes

# ============================================================================
# Master: run all text-scanning rules
# ============================================================================

fn check_all_rules(source: String, file: String) -> [EasyFix]:
    var all_fixes: [EasyFix] = []

    val fixes1 = check_print_in_test_spec(source: source, file: file)
    for f in fixes1:
        all_fixes.push(f)

    val fixes2 = check_unnamed_duplicate_typed_args(source: source, file: file)
    for f in fixes2:
        all_fixes.push(f)

    val fixes3 = check_resource_leak(source: source, file: file)
    for f in fixes3:
        all_fixes.push(f)

    val fixes4 = check_spipe_missing_docstrings(source: source, file: file)
    for f in fixes4:
        all_fixes.push(f)

    val fixes5 = check_spipe_manual_assertions(source: source, file: file)
    for f in fixes5:
        all_fixes.push(f)

    val fixes6 = check_non_exhaustive_match(source: source, file: file)
    for f in fixes6:
        all_fixes.push(f)

    val fixes7 = check_parser_contextual_keyword(source: source, file: file)
    for f in fixes7:
        all_fixes.push(f)

    val fixes8 = check_deprecated_if_let(source: source, file: file)
    for f in fixes8:
        all_fixes.push(f)

    val fixes9 = check_stub_impl_text(source: source, file: file)
    for f in fixes9:
        all_fixes.push(f)

    # Rules 7 (typo) and 9 (type coercion) are no-ops in text-scanning mode.
    # They require compiler integration (Rust side).

    all_fixes

# ============================================================================
# Rule 12: stub_impl (text-scanning)
# Detects function signatures followed by trivial body expressions.
# Confidence: Likely
# ============================================================================

fn _stub_trivial() -> [text]:
    ["0", "\"\"", "false", "nil", "[]", "()", "true",
     "return 0", "return \"\"", "return false", "return nil",
     "return []", "return ()", "return true",
     "Ok(nil)", "Ok(0)", "return Ok(nil)", "return Ok(0)"]

fn check_stub_impl_text(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    val lines = source.split("\n")

    for ctx in line_contexts(source):
        if _stub_is_fn(ctx.trimmed):
            val body = _stub_inline_body(ctx.trimmed)
            if body != "" and _stub_is_trivial(body) and _stub_has_params(ctx.trimmed):
                var fix = EasyFix.create(
                    id: "L:stub_impl:{ctx.line_num}",
                    description: "function with params returns trivial '{body}' — possible stub",
                    confidence: FixConfidence.Likely
                )
                fix.add_replacement(Replacement.create(
                    file: file, start: ctx.byte_offset, end: ctx.byte_offset + ctx.line.len(),
                    line: ctx.line_num, column: 1, new_text: ctx.line
                ))
                fixes.push(fix)

        if _stub_is_fn_header(ctx.trimmed) and _stub_has_params(ctx.trimmed):
            if ctx.line_num < lines.len():
                val nl = lines[ctx.line_num]
                val nt = nl.trim()
                val ni = nl.len() - nt.len()
                if ni > ctx.indent and _stub_is_trivial(nt):
                    var single = true
                    if ctx.line_num + 1 < lines.len():
                        val al = lines[ctx.line_num + 1]
                        val at = al.trim()
                        val ai = al.len() - at.len()
                        if at != "" and ai > ctx.indent:
                            single = false
                    if single:
                        var fix = EasyFix.create(
                            id: "L:stub_impl:{ctx.line_num}",
                            description: "function with params returns trivial '{nt}' — possible stub",
                            confidence: FixConfidence.Likely
                        )
                        fix.add_replacement(Replacement.create(
                            file: file, start: ctx.byte_offset, end: ctx.byte_offset + ctx.line.len(),
                            line: ctx.line_num, column: 1, new_text: ctx.line
                        ))
                        fixes.push(fix)

    fixes

fn _stub_is_fn(t: text) -> bool:
    t.starts_with("fn ") or t.starts_with("me ") or t.starts_with("static fn ")

fn _stub_is_fn_header(t: text) -> bool:
    _stub_is_fn(t) and t.ends_with(":")

fn _stub_has_params(t: text) -> bool:
    if not t.contains("(") or not t.contains(")"):
        return false
    val paren_parts = t.split("(")
    if paren_parts.len() < 2:
        return false
    val after_open = paren_parts[1]
    if not after_open.contains(")"):
        return false
    val close_parts = after_open.split(")")
    val inner = close_parts[0].trim()
    inner.len() > 0

fn _stub_inline_body(t: text) -> text:
    if not t.contains(")"):
        return ""
    val paren_parts = t.split(")")
    if paren_parts.len() < 2:
        return ""
    val after = paren_parts[1]
    if not after.contains(":"):
        return ""
    val colon_parts = after.split(":")
    if colon_parts.len() < 2:
        return ""
    val body_raw = colon_parts[1]
    body_raw.trim()

fn _stub_is_trivial(body: text) -> bool:
    if body.starts_with("pass_todo") or body.starts_with("pass_do_nothing") or body.starts_with("pass_dn"):
        return false
    for p in _stub_trivial():
        if body == p:
            return true
    body == "pass"
