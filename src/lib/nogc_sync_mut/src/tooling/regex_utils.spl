@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Regex Utilities Module - Thompson NFA-based Implementation
# Pattern matching, validation, and text extraction using regular expressions
# Pure Simple — no FFI, no extern, no Rust

# Match result structure
struct RegexMatch:
    text: text
    start: i64
    end: i64

# Capture groups result
struct Captures:
    full_match: text
    groups: [Option<text>]

# Helper struct for named captures since Dict may not be available
struct NamedCaptureResult:
    has_year: bool
    year: text
    has_month: bool
    month: text
    has_day: bool
    day: text

impl NamedCaptureResult:
    fn get(key: text) -> text:
        if key == "year" and self.has_year:
            return self.year
        if key == "month" and self.has_month:
            return self.month
        if key == "day" and self.has_day:
            return self.day
        return ""

# ---------------------------------------------------------------------------
# NFA instruction representation
# ---------------------------------------------------------------------------
# kind constants:
#   0 = Literal         (ch field)
#   1 = Dot
#   2 = CharClass       (chars field, negated field)
#   3 = Split           (out1, out2)
#   4 = Jump            (out1)
#   5 = Match
#   6 = GroupStart       (group_id)
#   7 = GroupEnd         (group_id)
#   8 = AnchorStart      (^)
#   9 = AnchorEnd        ($)

struct _NfaOp:
    kind: i64
    ch: text
    chars: text
    negated: bool
    out1: i64
    out2: i64
    group_id: i64

fn _op_literal(ch: text) -> _NfaOp:
    _NfaOp(kind: 0, ch: ch, chars: "", negated: false, out1: 0, out2: 0, group_id: 0)

fn _op_dot() -> _NfaOp:
    _NfaOp(kind: 1, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: 0)

fn _op_char_class(chars: text, negated: bool) -> _NfaOp:
    _NfaOp(kind: 2, ch: "", chars: chars, negated: negated, out1: 0, out2: 0, group_id: 0)

fn _op_split(out1: i64, out2: i64) -> _NfaOp:
    _NfaOp(kind: 3, ch: "", chars: "", negated: false, out1: out1, out2: out2, group_id: 0)

fn _op_jump(target: i64) -> _NfaOp:
    _NfaOp(kind: 4, ch: "", chars: "", negated: false, out1: target, out2: 0, group_id: 0)

fn _op_match() -> _NfaOp:
    _NfaOp(kind: 5, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: 0)

fn _op_group_start(gid: i64) -> _NfaOp:
    _NfaOp(kind: 6, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: gid)

fn _op_group_end(gid: i64) -> _NfaOp:
    _NfaOp(kind: 7, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: gid)

fn _op_anchor_start() -> _NfaOp:
    _NfaOp(kind: 8, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: 0)

fn _op_anchor_end() -> _NfaOp:
    _NfaOp(kind: 9, ch: "", chars: "", negated: false, out1: 0, out2: 0, group_id: 0)

# ---------------------------------------------------------------------------
# Character classification helpers
# ---------------------------------------------------------------------------
fn _is_digit_char(c: text) -> bool:
    val code = c as i64
    return code >= 48 and code <= 57

fn _is_word_char(c: text) -> bool:
    val code = c as i64
    return (code >= 48 and code <= 57) or (code >= 65 and code <= 90) or (code >= 97 and code <= 122) or code == 95

fn _is_space_char(c: text) -> bool:
    val code = c as i64
    return code == 32 or code == 9 or code == 10 or code == 13

fn _is_special(c: text) -> bool:
    return (c == "." or c == "*" or c == "+" or c == "?" or c == "[" or
        c == "]" or c == "(" or c == ")" or c == "|" or c == "\\" or
        c == "^" or c == "$")

# Expand shorthand classes to a string of chars for matching
fn _shorthand_chars(code: text) -> text:
    if code == "d":
        return "0123456789"
    if code == "w":
        return "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_"
    if code == "s":
        return " \t\n\r"
    return ""

fn _char_in_class(c: text, class_chars: text, negated: bool) -> bool:
    # class_chars is a set of individual characters to match against
    var i = 0
    while i < class_chars.len():
        val cc = class_chars[i:i+1]
        if cc == c:
            return not negated
        i = i + 1
    return negated

# ---------------------------------------------------------------------------
# Regex compiler: pattern text -> [_NfaOp]
# ---------------------------------------------------------------------------

# Parse a single atom (literal, dot, class, group, anchor, escape)
fn _parse_atom(pattern: text, pos: i64, depth: i64) -> ([_NfaOp], i64):
    val c = pattern[pos:pos+1]

    if c == "(":
        return _parse_group(pattern: pattern, pos: pos, depth: depth)
    if c == "[":
        return _parse_char_class(pattern: pattern, pos: pos)
    if c == ".":
        return ([_op_dot()], pos + 1)
    if c == "^":
        return ([_op_anchor_start()], pos + 1)
    if c == "$":
        return ([_op_anchor_end()], pos + 1)
    if c == "\\":
        return _parse_escape(pattern: pattern, pos: pos)

    # Plain literal
    return ([_op_literal(ch: c)], pos + 1)

# Parse an escape sequence
fn _parse_escape(pattern: text, pos: i64) -> ([_NfaOp], i64):
    if pos + 1 >= pattern.len():
        return ([_op_literal(ch: "\\")], pos + 1)

    val next = pattern[pos+1:pos+2]
    if next == "d":
        return ([_op_char_class(chars: _shorthand_chars("d"), negated: false)], pos + 2)
    if next == "D":
        return ([_op_char_class(chars: _shorthand_chars("d"), negated: true)], pos + 2)
    if next == "w":
        return ([_op_char_class(chars: _shorthand_chars("w"), negated: false)], pos + 2)
    if next == "W":
        return ([_op_char_class(chars: _shorthand_chars("w"), negated: true)], pos + 2)
    if next == "s":
        return ([_op_char_class(chars: _shorthand_chars("s"), negated: false)], pos + 2)
    if next == "S":
        return ([_op_char_class(chars: _shorthand_chars("s"), negated: true)], pos + 2)
    # Escaped special char treated as literal
    return ([_op_literal(ch: next)], pos + 2)

# Parse a character class [...]
fn _parse_char_class(pattern: text, pos: i64) -> ([_NfaOp], i64):
    var cur = pos + 1  # skip [
    var negated = false
    var chars_parts: [text] = []

    if cur < pattern.len() and pattern[cur:cur+1] == "^":
        negated = true
        cur = cur + 1

    while cur < pattern.len():
        val cc = pattern[cur:cur+1]
        if cc == "]":
            cur = cur + 1
            break

        if cc == "\\":
            # Escape inside class
            if cur + 1 < pattern.len():
                val esc = pattern[cur+1:cur+2]
                if esc == "d":
                    chars_parts.push(_shorthand_chars("d"))
                else if esc == "D":
                    # For negated shorthand inside class, expand all non-digit printable ASCII
                    chars_parts.push(_shorthand_chars("d"))
                    # This is approximate; handle via negation logic instead
                else if esc == "w":
                    chars_parts.push(_shorthand_chars("w"))
                else if esc == "s":
                    chars_parts.push(_shorthand_chars("s"))
                else:
                    chars_parts.push(esc)
                cur = cur + 2
            else:
                chars_parts.push(cc)
                cur = cur + 1
        else:
            # Check for range a-z
            if (cur + 2 < pattern.len() and
                pattern[cur+1:cur+2] == "-" and
                pattern[cur+2:cur+3] != "]"):
                val range_end = pattern[cur+2:cur+3]
                val start_code = cc as i64
                val end_code = range_end as i64
                var rc = start_code
                while rc <= end_code:
                    # Build character from code point
                    chars_parts.push(_chr(rc))
                    rc = rc + 1
                cur = cur + 3
            else:
                chars_parts.push(cc)
                cur = cur + 1

    val all_chars = chars_parts.join("")
    return ([_op_char_class(chars: all_chars, negated: negated)], cur)

# Parse a group (...)
fn _parse_group(pattern: text, pos: i64, depth: i64) -> ([_NfaOp], i64):
    # pos points at (
    var cur = pos + 1
    # Allocate group id from parsing context
    # For simplicity, count opening parens before this position
    var gid = _count_open_parens(pattern: pattern, up_to: pos) + 1

    var result: [_NfaOp] = []
    result.push(_op_group_start(gid: gid))

    # Compile inner expression at base=1 to account for the GroupStart op
    # that we prepended (so inner Split/Jump offsets are correct within
    # this fragment which starts at GroupStart=0, inner content at 1)
    val inner = _nfa_compile_expr(pattern: pattern, pos: cur, depth: depth + 1, base: 1)
    var inner_ops = inner.0
    cur = inner.1

    var ii = 0
    while ii < inner_ops.len():
        result.push(inner_ops[ii])
        ii = ii + 1

    result.push(_op_group_end(gid: gid))

    # Skip closing )
    if cur < pattern.len() and pattern[cur:cur+1] == ")":
        cur = cur + 1

    return (result, cur)

# Count opening parens before position
fn _count_open_parens(pattern: text, up_to: i64) -> i64:
    var count = 0
    var i = 0
    while i < up_to:
        val c = pattern[i:i+1]
        if c == "(":
            count = count + 1
        else if c == "\\":
            i = i + 1  # skip escaped char
        i = i + 1
    return count

# Convert integer code point to single-char text
fn _chr(code: i64) -> text:
    # Use string building - for ASCII range
    var i = 0
    var result = ""
    val ref = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789 \t\n\r!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
    while i < ref.len():
        val c = ref[i:i+1]
        if c as i64 == code:
            return c
        i = i + 1
    return ""

# ---------------------------------------------------------------------------
# Quantifier wrappers — emit fragment-relative (0-based) offsets.
# _nfa_compile_seq rebases them to absolute program offsets on append.
# ---------------------------------------------------------------------------

# star (greedy): [split(1, alen+2)] [atom...] [jump(0)]
fn _wrap_star(atom: [_NfaOp]) -> [_NfaOp]:
    val alen = atom.len()
    var result: [_NfaOp] = []
    result.push(_op_split(out1: 1, out2: alen + 2))
    var i = 0
    while i < alen:
        result.push(atom[i])
        i = i + 1
    result.push(_op_jump(target: 0))
    return result

# plus (greedy): [atom...] [split(0, alen+1)]
fn _wrap_plus(atom: [_NfaOp]) -> [_NfaOp]:
    val alen = atom.len()
    var result: [_NfaOp] = []
    var i = 0
    while i < alen:
        result.push(atom[i])
        i = i + 1
    result.push(_op_split(out1: 0, out2: alen + 1))
    return result

# question (greedy): [split(1, alen+1)] [atom...]
fn _wrap_question(atom: [_NfaOp]) -> [_NfaOp]:
    val alen = atom.len()
    var result: [_NfaOp] = []
    result.push(_op_split(out1: 1, out2: alen + 1))
    var i = 0
    while i < alen:
        result.push(atom[i])
        i = i + 1
    return result

# ---------------------------------------------------------------------------
# NFA compilation — offset-aware
# ---------------------------------------------------------------------------

# Top-level compile
fn _nfa_compile(pattern: text) -> [_NfaOp]:
    val result = _nfa_compile_expr(pattern: pattern, pos: 0, depth: 0, base: 0)
    var ops = result.0
    ops.push(_op_match())
    return ops

fn _nfa_compile_expr(pattern: text, pos: i64, depth: i64, base: i64) -> ([_NfaOp], i64):
    var branches: [[_NfaOp]] = []
    val first = _nfa_compile_seq(pattern: pattern, pos: pos, depth: depth, base: base)
    branches.push(first.0)
    var cur_pos = first.1

    while cur_pos < pattern.len():
        val c = pattern[cur_pos:cur_pos+1]
        if c == "|":
            cur_pos = cur_pos + 1
            # base doesn't matter for branches yet; we'll rebase
            val branch = _nfa_compile_seq(pattern: pattern, pos: cur_pos, depth: depth, base: 0)
            branches.push(branch.0)
            cur_pos = branch.1
        else:
            break

    if branches.len() == 1:
        return (branches[0], cur_pos)

    # Build alternation with absolute offsets
    var branch_sizes: [i64] = []
    var total_branch_code = 0
    var bi = 0
    while bi < branches.len():
        branch_sizes.push(branches[bi].len())
        total_branch_code = total_branch_code + branches[bi].len()
        bi = bi + 1

    val num_splits = branches.len() - 1
    val branches_start = base + num_splits

    var branch_offsets: [i64] = []
    var offset = branches_start
    var bj = 0
    while bj < branches.len():
        branch_offsets.push(offset)
        offset = offset + branch_sizes[bj]
        if bj < branches.len() - 1:
            offset = offset + 1  # jump
        bj = bj + 1
    val end_offset = offset

    var result: [_NfaOp] = []

    # Emit splits
    var si = 0
    while si < num_splits:
        val left_target = branch_offsets[si]
        var right_target = base + si + 1
        if si == num_splits - 1:
            right_target = branch_offsets[si + 1]
        result.push(_op_split(out1: left_target, out2: right_target))
        si = si + 1

    # Emit branches with jumps, rebasing internal offsets
    var bk = 0
    while bk < branches.len():
        val branch = branches[bk]
        val branch_base = branch_offsets[bk]
        var bi2 = 0
        while bi2 < branch.len():
            var op = branch[bi2]
            if op.kind == 3 or op.kind == 4:
                # Rebase: op offsets are 0-based within the branch
                op = _rebase_op(op: op, old_base: 0, new_base: branch_base)
            result.push(op)
            bi2 = bi2 + 1
        if bk < branches.len() - 1:
            result.push(_op_jump(target: end_offset))
        bk = bk + 1

    return (result, cur_pos)

fn _rebase_op(op: _NfaOp, old_base: i64, new_base: i64) -> _NfaOp:
    val delta = new_base - old_base
    if op.kind == 3:
        return _op_split(out1: op.out1 + delta, out2: op.out2 + delta)
    if op.kind == 4:
        return _op_jump(target: op.out1 + delta)
    return op

fn _nfa_compile_seq(pattern: text, pos: i64, depth: i64, base: i64) -> ([_NfaOp], i64):
    var ops: [_NfaOp] = []
    var cur_pos = pos

    while cur_pos < pattern.len():
        val c = pattern[cur_pos:cur_pos+1]

        if c == "|":
            break
        if c == ")":
            if depth > 0:
                break
            ops.push(_op_literal(ch: c))
            cur_pos = cur_pos + 1
            continue

        val atom_result = _parse_atom(pattern: pattern, pos: cur_pos, depth: depth)
        var atom_ops = atom_result.0
        cur_pos = atom_result.1

        # Check for quantifier
        if cur_pos < pattern.len():
            val qc = pattern[cur_pos:cur_pos+1]
            if qc == "*" or qc == "+" or qc == "?":
                val current_base = base + ops.len()
                atom_ops = _apply_quantifier(atom: atom_ops, quantifier: qc, frag_base: current_base)
                cur_pos = cur_pos + 1

        # Compute fragment base ONCE before appending any ops
        val frag_insert_base = base + ops.len()
        var ai = 0
        while ai < atom_ops.len():
            var op = atom_ops[ai]
            # Rebase fragment-relative offsets to absolute
            if op.kind == 3 or op.kind == 4:
                op = _rebase_op(op: op, old_base: 0, new_base: frag_insert_base)
            ops.push(op)
            ai = ai + 1

    return (ops, cur_pos)

fn _apply_quantifier(atom: [_NfaOp], quantifier: text, frag_base: i64) -> [_NfaOp]:
    if quantifier == "*":
        return _wrap_star(atom)
    if quantifier == "+":
        return _wrap_plus(atom)
    if quantifier == "?":
        return _wrap_question(atom)
    return atom

# ---------------------------------------------------------------------------
# NFA simulation (Thompson algorithm)
# ---------------------------------------------------------------------------

# Thread state for NFA simulation
struct _Thread:
    pc: i64
    groups: [i64]  # group boundaries: [start1, end1, start2, end2, ...]

fn _new_thread(pc: i64, num_groups: i64) -> _Thread:
    var groups: [i64] = []
    var i = 0
    while i < num_groups * 2:
        groups.push(-1)
        i = i + 1
    _Thread(pc: pc, groups: groups)

fn _clone_thread(t: _Thread) -> _Thread:
    var groups: [i64] = []
    var i = 0
    while i < t.groups.len():
        groups.push(t.groups[i])
        i = i + 1
    _Thread(pc: t.pc, groups: groups)

fn _count_groups(pattern: text) -> i64:
    var count = 0
    var i = 0
    while i < pattern.len():
        val c = pattern[i:i+1]
        if c == "\\":
            i = i + 2
            continue
        if c == "(":
            count = count + 1
        i = i + 1
    return count

# Simulate NFA from a given start position in the input
# Returns (matched: bool, match_end: i64, groups: [i64])
fn _simulate(ops: [_NfaOp], input: text, start_pos: i64, num_groups: i64) -> (matched: bool, match_end: i64, groups: [i64]):
    var current: [_Thread] = []
    var next_threads: [_Thread] = []
    val init_thread = _new_thread(pc: 0, num_groups: num_groups)
    current.push(init_thread)
    # Add epsilon-reachable states
    current = _add_epsilon_states(threads: current, ops: ops, input: input, sp: start_pos, input_len: input.len())

    var best_matched = false
    var best_end = -1
    var best_groups: [i64] = []
    var gi = 0
    while gi < num_groups * 2:
        best_groups.push(-1)
        gi = gi + 1

    # Check if any initial thread is already at Match
    var ci = 0
    while ci < current.len():
        val t = current[ci]
        if t.pc < ops.len() and ops[t.pc].kind == 5:
            best_matched = true
            best_end = start_pos
            best_groups = t.groups
        ci = ci + 1

    var sp = start_pos
    while sp < input.len():
        if current.len() == 0:
            break

        val ch = input[sp:sp+1]
        next_threads = []

        var ti = 0
        while ti < current.len():
            val t = current[ti]
            if t.pc >= ops.len():
                ti = ti + 1
                continue
            val op = ops[t.pc]

            if op.kind == 0:
                # Literal
                if ch == op.ch:
                    var nt = _clone_thread(t)
                    nt = _Thread(pc: t.pc + 1, groups: nt.groups)
                    next_threads.push(nt)
            else if op.kind == 1:
                # Dot - match any char
                var nt = _clone_thread(t)
                nt = _Thread(pc: t.pc + 1, groups: nt.groups)
                next_threads.push(nt)
            else if op.kind == 2:
                # CharClass
                if _char_in_class(c: ch, class_chars: op.chars, negated: op.negated):
                    var nt = _clone_thread(t)
                    nt = _Thread(pc: t.pc + 1, groups: nt.groups)
                    next_threads.push(nt)
            # kinds 3,4,5,6,7,8,9 are handled by epsilon expansion

            ti = ti + 1

        # Advance to next input position
        sp = sp + 1

        # Expand epsilon states in next_threads
        next_threads = _add_epsilon_states(threads: next_threads, ops: ops, input: input, sp: sp, input_len: input.len())

        # Check for Match states
        var ni = 0
        while ni < next_threads.len():
            val nt = next_threads[ni]
            if nt.pc < ops.len() and ops[nt.pc].kind == 5:
                # Greedy: prefer longest match
                if not best_matched or sp > best_end:
                    best_matched = true
                    best_end = sp
                    best_groups = nt.groups
            ni = ni + 1

        current = next_threads

    return (matched: best_matched, match_end: best_end, groups: best_groups)

# Expand epsilon transitions (Split, Jump, GroupStart, GroupEnd, Anchors)
fn _add_epsilon_states(threads: [_Thread], ops: [_NfaOp], input: text, sp: i64, input_len: i64) -> [_Thread]:
    var result: [_Thread] = []
    var stack: [_Thread] = []

    # Initialize stack with all threads
    var i = 0
    while i < threads.len():
        stack.push(threads[i])
        i = i + 1

    # Track visited PCs to avoid infinite loops
    var visited: [i64] = []

    while stack.len() > 0:
        val t = stack[stack.len() - 1]
        # Remove last element
        var new_stack: [_Thread] = []
        var si = 0
        while si < stack.len() - 1:
            new_stack.push(stack[si])
            si = si + 1
        stack = new_stack

        if t.pc >= ops.len():
            result.push(t)
            continue

        # Check if already visited this PC
        var already = false
        var vi = 0
        while vi < visited.len():
            if visited[vi] == t.pc:
                already = true
                break
            vi = vi + 1
        if already:
            continue
        visited.push(t.pc)

        val op = ops[t.pc]

        if op.kind == 3:
            # Split: fork into two threads
            var t1 = _clone_thread(t)
            t1 = _Thread(pc: op.out1, groups: t1.groups)
            var t2 = _clone_thread(t)
            t2 = _Thread(pc: op.out2, groups: t2.groups)
            stack.push(t1)
            stack.push(t2)
        else if op.kind == 4:
            # Jump
            var nt = _clone_thread(t)
            nt = _Thread(pc: op.out1, groups: nt.groups)
            stack.push(nt)
        else if op.kind == 5:
            # Match — keep as-is
            result.push(t)
        else if op.kind == 6:
            # GroupStart
            var nt = _clone_thread(t)
            val gid = op.group_id
            if gid >= 1 and (gid - 1) * 2 < nt.groups.len():
                nt.groups[(gid - 1) * 2] = sp
            nt = _Thread(pc: t.pc + 1, groups: nt.groups)
            stack.push(nt)
        else if op.kind == 7:
            # GroupEnd
            var nt = _clone_thread(t)
            val gid = op.group_id
            if gid >= 1 and (gid - 1) * 2 + 1 < nt.groups.len():
                nt.groups[(gid - 1) * 2 + 1] = sp
            nt = _Thread(pc: t.pc + 1, groups: nt.groups)
            stack.push(nt)
        else if op.kind == 8:
            # AnchorStart: only match at position 0
            if sp == 0:
                var nt = _clone_thread(t)
                nt = _Thread(pc: t.pc + 1, groups: nt.groups)
                stack.push(nt)
            # else: this thread dies
        else if op.kind == 9:
            # AnchorEnd: only match at end of input
            if sp == input_len:
                var nt = _clone_thread(t)
                nt = _Thread(pc: t.pc + 1, groups: nt.groups)
                stack.push(nt)
            # else: this thread dies
        else:
            # Consuming op — keep for input processing
            result.push(t)

    return result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn regex_is_match(pattern: text, input_text: text) -> bool:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    # Try matching at each position (unanchored unless pattern has ^)
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            return true
        pos = pos + 1
    return false

fn regex_find(pattern: text, input_text: text) -> Option<RegexMatch>:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            val matched_text = input_text[pos:result.match_end]
            return Some(RegexMatch(text: matched_text, start: pos, end: result.match_end))
        pos = pos + 1
    return nil

fn regex_find_all(pattern: text, input_text: text) -> [RegexMatch]:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var matches: [RegexMatch] = []
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            val matched_text = input_text[pos:result.match_end]
            matches.push(RegexMatch(text: matched_text, start: pos, end: result.match_end))
            # Advance past match (non-overlapping); at least 1 to avoid infinite loop
            if result.match_end > pos:
                pos = result.match_end
            else:
                pos = pos + 1
        else:
            pos = pos + 1
    return matches

fn regex_captures(pattern: text, input_text: text) -> Option<Captures>:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            val full = input_text[pos:result.match_end]
            var groups: [Option<text>] = []
            var gi = 0
            while gi < num_groups:
                val gs = result.groups[gi * 2]
                val ge = result.groups[gi * 2 + 1]
                if gs >= 0 and ge >= 0:
                    groups.push(Some(input_text[gs:ge]))
                else:
                    groups.push(nil)
                gi = gi + 1
            return Some(Captures(full_match: full, groups: groups))
        pos = pos + 1
    return nil

fn regex_named_captures(pattern: text, input_text: text) -> NamedCaptureResult:
    # Named captures are not supported by the NFA engine.
    # Provide backward-compatible heuristic for date patterns.
    if pattern.contains("year") and pattern.contains("month"):
        val parts = input_text.split(" ")
        for part in parts:
            if part.contains("-"):
                val segments = part.split("-")
                if segments.len() == 3 and segments[0].len() == 4:
                    return NamedCaptureResult(
                        has_year: true,
                        year: segments[0],
                        has_month: true,
                        month: segments[1],
                        has_day: true,
                        day: segments[2]
                    )
    return NamedCaptureResult(has_year: false, year: "", has_month: false, month: "", has_day: false, day: "")

fn regex_replace(pattern: text, input_text: text, replacement: text) -> text:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            val before = input_text[0:pos]
            val after = if result.match_end < input_text.len(): input_text[result.match_end:input_text.len()] else: ""
            return before + replacement + after
        pos = pos + 1
    return input_text

fn regex_replace_all(pattern: text, input_text: text, replacement: text) -> text:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var parts: [text] = []
    var last_end = 0
    var pos = 0
    while pos <= input_text.len():
        val result = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if result.matched:
            # Push text between previous match end and this match start
            if pos > last_end:
                parts.push(input_text[last_end:pos])
            parts.push(replacement)
            if result.match_end > pos:
                last_end = result.match_end
                pos = result.match_end
            else:
                last_end = pos + 1
                pos = pos + 1
        else:
            pos = pos + 1
    # Push remaining text after last match
    if last_end < input_text.len():
        parts.push(input_text[last_end:input_text.len()])
    return parts.join("")

fn regex_split(pattern: text, input_text: text) -> [text]:
    val ops = _nfa_compile(pattern)
    val num_groups = _count_groups(pattern)
    var result: [text] = []
    var last_end = 0
    var pos = 0
    while pos <= input_text.len():
        val sim = _simulate(ops: ops, input: input_text, start_pos: pos, num_groups: num_groups)
        if sim.matched and sim.match_end > pos:
            val segment = input_text[last_end:pos]
            result.push(segment)
            last_end = sim.match_end
            pos = sim.match_end
        else:
            pos = pos + 1
    # Add remaining
    if last_end <= input_text.len():
        result.push(input_text[last_end:input_text.len()])
    return result

fn regex_split_n(pattern: text, input_text: text, limit: i64) -> [text]:
    val all = regex_split(pattern: pattern, input_text: input_text)
    if all.len() <= limit:
        return all
    var result: [text] = []
    var i = 0
    while i < limit:
        result.push(all[i])
        i = i + 1
    return result

# ---------------------------------------------------------------------------
# Validation functions (kept for backward compatibility)
# ---------------------------------------------------------------------------

fn is_valid_email(email: text) -> bool:
    if not email.contains("@"):
        return false
    if email.starts_with("@"):
        return false
    val parts = email.split("@")
    if parts.len() != 2:
        return false
    if parts[0].len() == 0 or parts[1].len() == 0:
        return false
    if not parts[1].contains("."):
        return false
    return true

fn is_valid_url(url: text) -> bool:
    return url.starts_with("http://") or url.starts_with("https://")

fn is_valid_ipv4(ip: text) -> bool:
    val parts = ip.split(".")
    if parts.len() != 4:
        return false
    for part in parts:
        if not is_only_digits(part):
            return false
        val num = str_to_int(part)
        if num < 0 or num > 255:
            return false
    return true

# Extraction functions

fn extract_emails(input_text: text) -> [text]:
    var emails: [text] = []
    val words = input_text.split(" ")
    for word in words:
        if is_valid_email(word):
            emails.push(word)
    return emails

fn extract_numbers(input_text: text) -> [text]:
    var result: [text] = []
    val matches = regex_find_all(pattern: r"\d+", input_text: input_text)
    for m in matches:
        result.push(m.text)
    return result

fn extract_urls(input_text: text) -> [text]:
    var urls: [text] = []
    val words = input_text.split(" ")
    for word in words:
        if is_valid_url(word):
            urls.push(word)
    return urls

# Helper functions (kept for backward compatibility)

fn contains_digit(s: text) -> bool:
    for c in s:
        val code = c as i64
        if code >= 48 and code <= 57:
            return true
    return false

fn is_only_digits(s: text) -> bool:
    if s.len() == 0:
        return false
    for c in s:
        val code = c as i64
        if code < 48 or code > 57:
            return false
    return true

fn contains_lower(s: text) -> bool:
    for c in s:
        val code = c as i64
        if code >= 97 and code <= 122:
            return true
    return false

fn contains_upper(s: text) -> bool:
    for c in s:
        val code = c as i64
        if code >= 65 and code <= 90:
            return true
    return false

fn contains_word(s: text, word: text) -> bool:
    val words = s.split(" ")
    for w in words:
        if w == word:
            return true
    return false

fn find_number(s: text) -> (start: i64, num: text):
    var num_parts: [text] = []
    var start = -1
    var pos = 0
    for c in s:
        val code = c as i64
        if code >= 48 and code <= 57:
            if start == -1:
                start = pos
            num_parts.push(c.to_string())
        else:
            if num_parts.len() > 0:
                return (start: start, num: num_parts.join(""))
        pos = pos + 1
    if num_parts.len() > 0:
        return (start: start, num: num_parts.join(""))
    return (start: -1, num: "")

fn find_all_nums(s: text) -> [RegexMatch]:
    var result: [RegexMatch] = []
    var num_parts: [text] = []
    var start = -1
    var pos = 0
    for c in s:
        val code = c as i64
        if code >= 48 and code <= 57:
            if start == -1:
                start = pos
            num_parts.push(c.to_string())
        else:
            if num_parts.len() > 0:
                result.push(RegexMatch(text: num_parts.join(""), start: start, end: pos))
                num_parts = []
                start = -1
        pos = pos + 1
    if num_parts.len() > 0:
        result.push(RegexMatch(text: num_parts.join(""), start: start, end: pos))
    return result

fn split_ws(s: text) -> [text]:
    var result: [text] = []
    var current_parts: [text] = []
    for c in s:
        val code = c as i64
        if code == 32 or code == 9 or code == 10:
            if current_parts.len() > 0:
                result.push(current_parts.join(""))
                current_parts = []
        else:
            current_parts.push(c.to_string())
    if current_parts.len() > 0:
        result.push(current_parts.join(""))
    return result

fn str_to_int(s: text) -> i64:
    var result = 0
    for c in s:
        val code = c as i64
        if code >= 48 and code <= 57:
            result = result * 10 + (code - 48)
    return result
