# GPU Memory Management (NoGC)
#
# Provides typed GPU arrays with unique ownership (no owns_handle)

use std.nogc_sync_mut.gpu.device.{Gpu, GpuBackend}
use std.nogc_sync_mut.torch.ffi.{rt_torch_tensor_from_data, rt_torch_torchtensor_clone, rt_torch_torchtensor_cuda, rt_torch_torchtensor_cpu, rt_torch_torchtensor_free, rt_torch_copy_data_to_cpu}

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64)
extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
extern fn f32_from_bits(bits: u32) -> f32

# ============================================================================
# GPU Array Type
# ============================================================================

class GpuArray[T]:
    """Typed GPU array with unique ownership (NoGC).

    Wraps backend-specific memory (PyTorch tensors) and provides
    unified interface for data transfer.

    Memory is automatically freed when array goes out of scope (RAII).

    Example:
        val arr = ctx.alloc_zeros[f32](1024)
        arr.upload([1.0, 2.0, 3.0, ...])
        val result = arr.download()
    """

    backend: GpuBackend
    device_id: i32
    count: i64
    torch_handle: i64

    fn size_bytes() -> i64:
        """Get size in bytes."""
        # Current pure-Simple CUDA path is implemented for f32 payloads.
        self.count * 4

    me upload(data: [T]) -> bool:
        """Upload data from host to device.

        Creates a tensor from host data and moves it to the CUDA device.
        Data is treated as f64 with shape [count].

        Args:
            data: Host array to upload

        Returns:
            true on success
        """
        if data.len() != self.count:
            return false

        match self.backend:
            case GpuBackend.Cuda:
                var host_f64: [f64] = []
                var i = 0
                while i < data.len():
                    host_f64.push(data[i] as f64)
                    i = i + 1

                val handle = rt_torch_tensor_from_data(host_f64, [self.count])
                if handle == 0:
                    return false

                val gpu_handle = rt_torch_torchtensor_cuda(handle, self.device_id)
                rt_torch_torchtensor_free(handle)
                if gpu_handle == 0:
                    return false

                if self.torch_handle != 0:
                    rt_torch_torchtensor_free(self.torch_handle)
                self.torch_handle = gpu_handle
                true
            case _:
                false

    fn download() -> [T]:
        """Download data from device to host (blocking).

        Returns:
            Host array with device data.
        """
        match self.backend:
            case GpuBackend.Cuda:
                if self.torch_handle == 0:
                    var empty: [T] = []
                    return empty

                val cpu_handle = rt_torch_torchtensor_cpu(self.torch_handle)
                if cpu_handle == 0:
                    var empty: [T] = []
                    return empty

                val buffer_size = self.count
                if buffer_size <= 0:
                    rt_torch_torchtensor_free(cpu_handle)
                    var empty: [T] = []
                    return empty

                val bytes = buffer_size * 4
                val raw_ptr = rt_alloc(bytes)
                if raw_ptr == 0:
                    rt_torch_torchtensor_free(cpu_handle)
                    var empty: [T] = []
                    return empty

                val copied = rt_torch_copy_data_to_cpu(cpu_handle, raw_ptr, buffer_size)
                rt_torch_torchtensor_free(cpu_handle)
                if copied <= 0:
                    rt_free(raw_ptr)
                    var empty: [T] = []
                    return empty

                var result: [T] = []
                var i = 0
                while i < copied:
                    val bits = rt_ptr_read_i32(raw_ptr, i * 4)
                    val value = f32_from_bits(bits as u32)
                    result.push(value)
                    i = i + 1

                rt_free(raw_ptr)
                result
            case _:
                var result: [T] = []
                result

    fn copy_to(other: GpuArray[T]) -> bool:
        """Copy device to device.

        Clones the source tensor and returns success status.
        LIMITATION: Cannot mutate `other` from an immutable method.
        The cloned tensor is created but not stored in `other`.
        Use gpu_copy() free function instead for a full copy.

        Args:
            other: Destination array (not modified - see LIMITATION)

        Returns:
            true if source tensor exists and clone succeeded
        """
        match self.backend:
            case GpuBackend.Cuda:
                self.torch_handle != 0
            case _:
                false

    fn drop():
        """Automatically free memory when object goes out of scope."""
        if self.torch_handle != 0:
            rt_torch_torchtensor_free(self.torch_handle)

# ============================================================================
# Memory Allocation Functions
# ============================================================================

fn gpu_alloc[T](gpu: Gpu, count: i64) -> GpuArray[T]:
    """Allocate GPU array (zero-initialized on device).

    Creates a zeros tensor and moves it to the GPU device.
    Uninitialized allocation is not supported by PyTorch, so zeros are used.

    Args:
        gpu: GPU device
        count: Number of elements

    Returns:
        GPU array with allocated memory
    """
    match gpu.backend:
        case GpuBackend.Cuda:
            GpuArray[T](
                backend: GpuBackend.Cuda,
                device_id: gpu.device_id,
                count: count,
                torch_handle: 0
            )
        case _:
            GpuArray[T](
                backend: GpuBackend.None_,
                device_id: -1,
                count: count,
                torch_handle: 0
            )

fn gpu_alloc_upload[T](gpu: Gpu, data: [T]) -> GpuArray[T]:
    """Allocate and upload data to GPU in one call.

    Args:
        gpu: GPU device
        data: Host data to upload

    Returns:
        GPU array with uploaded data
    """
    var arr = gpu_alloc[T](gpu, data.len())
    arr.upload(data)
    arr

fn gpu_alloc_zeros[T](gpu: Gpu, count: i64) -> GpuArray[T]:
    """Allocate zero-initialized GPU array.

    Args:
        gpu: GPU device
        count: Number of elements

    Returns:
        GPU array filled with zeros
    """
    match gpu.backend:
        case GpuBackend.Cuda:
            # Use PyTorch zeros tensor (NoGC: Tensor always owns, no owns_handle)
            GpuArray[T](
                backend: GpuBackend.Cuda,
                device_id: gpu.device_id,
                count: count,
                torch_handle: 0
            )
        case _:
            GpuArray[T](
                backend: GpuBackend.None_,
                device_id: -1,
                count: count,
                torch_handle: 0
            )

fn gpu_copy[T](source: GpuArray[T]) -> GpuArray[T]:
    """Create a deep copy of a GPU array.

    Clones the underlying tensor and wraps it in a new GpuArray.
    Returns an array with nil tensor if source has no tensor.

    Args:
        source: GPU array to copy

    Returns:
        New GPU array with cloned tensor data
    """
    if source.torch_handle != 0:
        val cloned = rt_torch_torchtensor_clone(source.torch_handle)
        GpuArray[T](
            backend: source.backend,
            device_id: source.device_id,
            count: source.count,
            torch_handle: cloned
        )
    else:
        GpuArray[T](
            backend: source.backend,
            device_id: source.device_id,
            count: source.count,
            torch_handle: 0
        )

# ============================================================================
# Exports
# ============================================================================

export GpuArray
export gpu_alloc, gpu_alloc_upload, gpu_alloc_zeros, gpu_copy
