# Shared 3D backend math runtime hooks.

extern fn rt_f64_sqrt(x: f64) -> f64
extern fn rt_f64_sin(x: f64) -> f64
extern fn rt_f64_cos(x: f64) -> f64

fn gpu3d_sqrt_f32(x: f32) -> f32:
    rt_f64_sqrt(x as f64) as f32

fn gpu3d_sin_f32(x: f32) -> f32:
    rt_f64_sin(x as f64) as f32

fn gpu3d_cos_f32(x: f32) -> f32:
    rt_f64_cos(x as f64) as f32
