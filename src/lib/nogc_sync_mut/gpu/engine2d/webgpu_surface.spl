"""No-GC WebGPU surface helpers shared by Engine2D backends."""

use std.common.gpu.webgpu_sffi.{
    webgpu_sffi_is_available, webgpu_sffi_init, webgpu_sffi_shutdown,
    webgpu_sffi_create_surface, webgpu_sffi_destroy_surface,
    webgpu_sffi_upload_pixels, webgpu_sffi_present,
    webgpu_sffi_readback_checksum, webgpu_sffi_compute_draw
}

fn webgpu_surface_create(width: i32, height: i32) -> i64:
    if not webgpu_sffi_is_available():
        return 0
    if not webgpu_sffi_init():
        return 0
    webgpu_sffi_create_surface(width, height)

fn webgpu_surface_shutdown(handle: i64) -> bool:
    var ok = true
    if handle != 0:
        ok = webgpu_sffi_destroy_surface(handle)
    val shutdown_ok = webgpu_sffi_shutdown()
    ok and shutdown_ok

fn webgpu_surface_compute_draw(ready: bool, handle: i64, op_kind: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> bool:
    ready and handle != 0 and webgpu_sffi_compute_draw(handle, op_kind, x, y, w, h, color)

fn webgpu_surface_present(ready: bool, handle: i64, pixels: [u32], w: i32, h: i32) -> bool:
    if not ready or handle == 0:
        return false
    if not webgpu_sffi_upload_pixels(handle, pixels, w, h):
        return false
    webgpu_sffi_present(handle)

fn webgpu_surface_readback_checksum(ready: bool, handle: i64) -> i64:
    if not ready or handle <= 0:
        return -1
    webgpu_sffi_readback_checksum(handle)

export webgpu_surface_create, webgpu_surface_shutdown
export webgpu_surface_compute_draw, webgpu_surface_present, webgpu_surface_readback_checksum
