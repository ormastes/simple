"""Narrow native ABI for packed RGBA SIMD row operations."""

extern fn rt_engine2d_simd_fill_row_u32(count: i64, color: u32) -> [u32]
extern fn rt_engine2d_simd_copy_row_u32(src: [u32]) -> [u32]
extern fn rt_engine2d_simd_blend_row_u32(dst_row: [u32], src_row: [u32]) -> [u32]

pub fn engine2d_simd_fill_row_u32(count: i64, color: u32) -> [u32]:
    rt_engine2d_simd_fill_row_u32(count, color)

pub fn engine2d_simd_copy_row_u32(src: [u32]) -> [u32]:
    rt_engine2d_simd_copy_row_u32(src)

pub fn engine2d_simd_blend_row_u32(dst_row: [u32], src_row: [u32]) -> [u32]:
    rt_engine2d_simd_blend_row_u32(dst_row, src_row)
