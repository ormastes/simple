"""Narrow native ABI for packed RGBA SIMD row operations."""

extern fn rt_engine2d_simd_fill_row_u32(count: i64, color: u32) -> [u32]
extern fn rt_engine2d_simd_fill_rows_u32(width: i64, height: i64, color: u32, worker_limit: i64) -> [u32]
pub extern fn rt_engine2d_simd_fill_span_u32(dst: [u32], offset: i64, count: i64, color: u32) -> [u32]
pub extern fn rt_engine2d_simd_copy_span_u32(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64) -> [u32]
extern fn rt_engine2d_simd_copy_row_u32(src: [u32]) -> [u32]
extern fn rt_engine2d_simd_blend_row_u32(dst_row: [u32], src_row: [u32]) -> [u32]
extern fn rt_simd_engine2d_neon_hits() -> i64
extern fn rt_simd_engine2d_neon_reset() -> i64

pub fn engine2d_simd_fill_row_u32(count: i64, color: u32) -> [u32]:
    rt_engine2d_simd_fill_row_u32(count, color)

pub fn engine2d_simd_fill_buffer_u32(count: i64, color: u32) -> [u32]:
    if count <= 0:
        return []
    engine2d_simd_fill_row_u32(count, color)

pub fn engine2d_simd_fill_rows_u32(width: i64, height: i64, color: u32, worker_limit: i64) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    rt_engine2d_simd_fill_rows_u32(width, height, color, worker_limit)

pub fn engine2d_simd_copy_row_u32(src: [u32]) -> [u32]:
    rt_engine2d_simd_copy_row_u32(src)

pub fn engine2d_simd_blend_row_u32(dst_row: [u32], src_row: [u32]) -> [u32]:
    rt_engine2d_simd_blend_row_u32(dst_row, src_row)

pub fn engine2d_simd_native_hits() -> i64:
    rt_simd_engine2d_neon_hits()

pub fn engine2d_simd_native_reset() -> i64:
    rt_simd_engine2d_neon_reset()
