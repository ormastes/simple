"""Generic OpenCL ICD SFFI Dispatch — Dynamic-First Dual-Path

@tag:stdlib
@tag:gpu

Wraps the generic OpenCL ICD (`libOpenCL.so`) behind an OpenClFfi class. The
default name-only launch path fails closed until a session owns explicit
platform/context/queue/program/kernel handles.
"""

use std.sffi.dynamic.{DynLib}
use std.gpu.engine2d.sffi_dispatch.{GpuFfiMode, FfiDispatchBase, try_load_gpu_lib}

extern fn rt_opencl_is_available() -> bool
extern fn rt_opencl_platform_count() -> i64
extern fn rt_opencl_create_context(platform: i64) -> i64
extern fn rt_opencl_create_queue(context: i64) -> i64
extern fn rt_opencl_create_program(context: i64, source: text) -> i64
extern fn rt_opencl_build_program(program: i64) -> bool
extern fn rt_opencl_create_kernel(program: i64, name: text) -> i64
extern fn rt_opencl_mem_alloc(context: i64, size: i64) -> i64
extern fn rt_opencl_mem_free(buffer: i64) -> bool
extern fn rt_opencl_write_buffer(queue: i64, buffer: i64, host_ptr: i64, size: i64) -> bool
extern fn rt_opencl_read_buffer(queue: i64, buffer: i64, host_ptr: i64, size: i64) -> bool
extern fn rt_opencl_set_kernel_arg_i64(kernel: i64, index: i64, value: i64) -> bool
extern fn rt_opencl_set_kernel_arg_buffer(kernel: i64, index: i64, buffer: i64) -> bool
extern fn rt_opencl_enqueue_ndrange(queue: i64, kernel: i64, gx: i64, gy: i64, gz: i64, lx: i64, ly: i64, lz: i64) -> bool
extern fn rt_opencl_finish(queue: i64) -> bool
extern fn rt_opencl_release_kernel(kernel: i64) -> bool
extern fn rt_opencl_release_program(program: i64) -> bool
extern fn rt_opencl_release_queue(queue: i64) -> bool
extern fn rt_opencl_release_context(context: i64) -> bool

class OpenClFfi:
    _mode: GpuFfiMode
    _dyn_lib: DynLib?

impl FfiDispatchBase for OpenClFfi:

    fn mode() -> GpuFfiMode:
        self._mode

    static fn create_static() -> OpenClFfi:
        OpenClFfi(_mode: GpuFfiMode.Static, _dyn_lib: nil)

    static fn create_dynamic() -> OpenClFfi?:
        val lib = try_load_gpu_lib("OpenCL")
        if lib == nil:
            return nil
        OpenClFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create_dynamic_from(path: text) -> OpenClFfi?:
        val lib = DynLib.load(path)
        if lib == nil:
            return nil
        OpenClFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create(sffi_mode: GpuFfiMode) -> OpenClFfi?:
        match sffi_mode:
            case Dynamic:
                val dyn_sffi = OpenClFfi.create_dynamic()
                if dyn_sffi != nil:
                    return dyn_sffi
                nil
            case Static:
                OpenClFfi.create_static()

    fn is_available() -> bool:
        match self._mode:
            case Static: rt_opencl_is_available()
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.sym("clGetPlatformIDs") != 0
                else:
                    false

    fn platform_count() -> i64:
        match self._mode:
            case Static: rt_opencl_platform_count()
            case Dynamic:
                if self._dyn_lib != nil and self._dyn_lib.sym("clGetPlatformIDs") != 0:
                    1
                else:
                    0

    fn create_context(platform: i64) -> i64:
        match self._mode:
            case Static: rt_opencl_create_context(platform)
            case Dynamic: 0

    fn create_queue(context: i64) -> i64:
        match self._mode:
            case Static: rt_opencl_create_queue(context)
            case Dynamic: 0

    fn create_program(context: i64, source: text) -> i64:
        match self._mode:
            case Static: rt_opencl_create_program(context, source)
            case Dynamic: 0

    fn build_program(program: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_build_program(program)
            case Dynamic: false

    fn create_kernel(program: i64, name: text) -> i64:
        match self._mode:
            case Static: rt_opencl_create_kernel(program, name)
            case Dynamic: 0

    fn mem_alloc(context: i64, size: i64) -> i64:
        match self._mode:
            case Static: rt_opencl_mem_alloc(context, size)
            case Dynamic: 0

    fn mem_free(buffer: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_mem_free(buffer)
            case Dynamic: false

    fn write_buffer(queue: i64, buffer: i64, host_ptr: i64, size: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_write_buffer(queue, buffer, host_ptr, size)
            case Dynamic: false

    fn read_buffer(queue: i64, buffer: i64, host_ptr: i64, size: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_read_buffer(queue, buffer, host_ptr, size)
            case Dynamic: false

    fn set_kernel_arg_i64(kernel: i64, index: i64, value: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_set_kernel_arg_i64(kernel, index, value)
            case Dynamic: false

    fn set_kernel_arg_buffer(kernel: i64, index: i64, buffer: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_set_kernel_arg_buffer(kernel, index, buffer)
            case Dynamic: false

    fn enqueue_ndrange(queue: i64, kernel: i64, gx: i64, gy: i64, gz: i64, lx: i64, ly: i64, lz: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_enqueue_ndrange(queue, kernel, gx, gy, gz, lx, ly, lz)
            case Dynamic: false

    fn finish(queue: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_finish(queue)
            case Dynamic: false

    fn release_kernel(kernel: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_release_kernel(kernel)
            case Dynamic: false

    fn release_program(program: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_release_program(program)
            case Dynamic: false

    fn release_queue(queue: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_release_queue(queue)
            case Dynamic: false

    fn release_context(context: i64) -> bool:
        match self._mode:
            case Static: rt_opencl_release_context(context)
            case Dynamic: false

    fn launch_kernel(name: text, gx: i64, gy: i64, gz: i64, lx: i64, ly: i64, lz: i64) -> bool:
        false
