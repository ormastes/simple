"""ARM/RISC-V Session Validation — scalar session checks with feature-gated NEON/RVV planning.

@tag:stdlib
@tag:gpu

Validates session capability for ARM32, AArch64, RV32, and RV64 targets.
NEON (arm32/aarch64) and RVV (riscv32/riscv64) are feature-gated.
All i64 handles are safe because Simple uses i64 universally (no truncation).

Usage:
    val cap = ArchSessionCapability.aarch64()
    val v = ArchSessionValidator.create("aarch64", 64)
    val report = v.run_all()
"""

# ============================================================================
# ArchSessionCapability
# ============================================================================

class ArchSessionCapability:
    arch:           text
    bits:           i64
    scalar_available: bool
    simd_available: bool
    simd_kind:      text
    gpu_available:  bool
    gpu_api:        text
    jit_available:  bool
    jit_backend:    text
    pointer_width:  i64
    handle_safe:    bool

impl ArchSessionCapability:
    static fn arm32() -> ArchSessionCapability:
        ArchSessionCapability(
            arch:             "arm32",
            bits:             32,
            scalar_available: true,
            simd_available:   false,
            simd_kind:        "neon",
            gpu_available:    false,
            gpu_api:          "webgpu",
            jit_available:    true,
            jit_backend:      "llvm",
            pointer_width:    4,
            handle_safe:      true
        )

    static fn aarch64() -> ArchSessionCapability:
        ArchSessionCapability(
            arch:             "aarch64",
            bits:             64,
            scalar_available: true,
            simd_available:   true,
            simd_kind:        "neon",
            gpu_available:    true,
            gpu_api:          "vulkan",
            jit_available:    true,
            jit_backend:      "cranelift",
            pointer_width:    8,
            handle_safe:      true
        )

    static fn riscv32() -> ArchSessionCapability:
        ArchSessionCapability(
            arch:             "riscv32",
            bits:             32,
            scalar_available: true,
            simd_available:   false,
            simd_kind:        "rvv",
            gpu_available:    false,
            gpu_api:          "webgpu",
            jit_available:    true,
            jit_backend:      "llvm",
            pointer_width:    4,
            handle_safe:      true
        )

    static fn riscv64() -> ArchSessionCapability:
        ArchSessionCapability(
            arch:             "riscv64",
            bits:             64,
            scalar_available: true,
            simd_available:   false,
            simd_kind:        "rvv",
            gpu_available:    true,
            gpu_api:          "vulkan",
            jit_available:    true,
            jit_backend:      "cranelift",
            pointer_width:    8,
            handle_safe:      true
        )

    me can_use_session() -> bool:
        true

    me default_backend() -> text:
        "cpu"

    me simd_status() -> text:
        if self.simd_available:
            return "simd_active:{self.simd_kind}"
        if self.simd_kind == "none":
            return "simd_none"
        "simd_gated:{self.simd_kind}:feature_required"

    me summary() -> text:
        "arch={self.arch} bits={self.bits} scalar={self.scalar_available} simd={self.simd_available}({self.simd_kind}) gpu={self.gpu_available}({self.gpu_api}) jit={self.jit_backend} ptr={self.pointer_width} handle_safe={self.handle_safe}"

# ============================================================================
# ArchSessionValidator
# ============================================================================

class ArchSessionValidator:
    target_arch:  text
    target_bits:  i64
    validated:    bool
    errors_found: i64
    last_error:   text

impl ArchSessionValidator:
    static fn create(arch: text, bits: i64) -> ArchSessionValidator:
        ArchSessionValidator(
            target_arch:  arch,
            target_bits:  bits,
            validated:    false,
            errors_found: 0,
            last_error:   ""
        )

    me validate_handle_width() -> text:
        # i64 handles are safe on all targets; Simple uses i64 universally
        "ok:handle_width:i64_universal_no_truncation"

    me validate_scalar_fallback() -> text:
        # Scalar always works on all ARM/RV targets
        "ok:scalar_fallback:always_available"

    me validate_simd_gating() -> text:
        if self.target_arch == "aarch64":
            return "ok:simd_gating:neon_unconditional_on_aarch64"
        if self.target_arch == "arm32":
            return "ok:simd_gating:neon_feature_gated_arm32"
        if self.target_arch == "riscv32":
            return "ok:simd_gating:rvv_feature_gated_riscv32_future"
        if self.target_arch == "riscv64":
            return "ok:simd_gating:rvv_feature_gated_riscv64_future"
        "ok:simd_gating:no_simd_for_arch"

    me validate_gpu_diagnostics() -> text:
        if self.target_arch == "aarch64":
            return "ok:gpu:vulkan_available_aarch64"
        if self.target_arch == "riscv64":
            return "ok:gpu:vulkan_available_riscv64"
        if self.target_arch == "arm32":
            return "ok:gpu:webgpu_if_available_arm32_not_crash"
        if self.target_arch == "riscv32":
            return "ok:gpu:webgpu_if_available_riscv32_not_crash"
        "ok:gpu:unavailable_typed"

    me validate_jit_backend() -> text:
        if self.target_bits == 64:
            return "ok:jit:cranelift_64bit"
        if self.target_bits == 32:
            return "ok:jit:llvm_32bit"
        self.errors_found = self.errors_found + 1
        self.last_error = "unknown_bit_width:{self.target_bits}"
        "error:jit:unknown_bit_width:{self.target_bits}"

    me run_all() -> text:
        var r1 = self.validate_handle_width()
        var r2 = self.validate_scalar_fallback()
        var r3 = self.validate_simd_gating()
        var r4 = self.validate_gpu_diagnostics()
        var r5 = self.validate_jit_backend()
        self.validated = true
        "{r1}|{r2}|{r3}|{r4}|{r5}"

    me passed() -> bool:
        if self.validated == false:
            return false
        self.errors_found == 0

    me report() -> text:
        if self.validated == false:
            return "not_validated:call_run_all_first"
        if self.errors_found == 0:
            return "passed:arch={self.target_arch} bits={self.target_bits} errors=0"
        "failed:arch={self.target_arch} bits={self.target_bits} errors={self.errors_found} last={self.last_error}"
