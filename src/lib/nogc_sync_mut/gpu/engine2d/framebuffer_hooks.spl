# Shared framebuffer runtime hooks for 2D engine backends.

extern fn rt_fb_blit32(dst_addr: u64, dst_stride_pixels: u64,
                       src_addr: u64, src_stride_pixels: u64,
                       copy_w: u64, copy_h: u64)

fn framebuffer_blit32(dst_addr: u64, dst_stride_pixels: u64,
                      src_addr: u64, src_stride_pixels: u64,
                      copy_w: u64, copy_h: u64):
    rt_fb_blit32(dst_addr, dst_stride_pixels, src_addr, src_stride_pixels, copy_w, copy_h)
