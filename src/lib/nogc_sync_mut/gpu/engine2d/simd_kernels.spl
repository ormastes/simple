"""SIMD-Accelerated Pixel Operations

@tag:stdlib
@tag:gpu

Provides vectorized fill, blend, blit, copy, and scroll operations with
runtime CPU feature detection. Falls back to scalar loops when no SIMD
is available.

The actual SIMD intrinsics live in the C/Rust runtime (rt_simd_*).
This module detects the CPU's capability level and dispatches to the
appropriate runtime function.

Each span/rect kernel increments the matching SimdHitCounts counter in
g_simd_hits (from simd_provider.spl) so that the optimization plugin
metadata hook can report accurate per-frame hit counts.

Usage:
    val level = detect_simd_level()
    fill_span(buffer, 0, 256, 0xFFFF0000)
    alpha_blend_span(dst, src, 0, 128)
    blit_rect(dst, 1920, 0, 0, src, 1920, 0, 0, 256, 256)
    scroll_region(buf, 1920, 0, 0, 1920, 1080, -2)
"""

use std.nogc_sync_mut.gpu.engine2d.simd_provider.{SimdHitCounts, SimdProvider, g_simd_hits}

# ============================================================================
# SIMD Level Enum
# ============================================================================

enum SimdLevel:
    None_
    Sse42
    Avx2
    Avx512
    Neon
    Rvv

impl SimdLevel:
    fn to_text() -> text:
        match self:
            case None_: "scalar"
            case Sse42: "sse42"
            case Avx2: "avx2"
            case Avx512: "avx512"
            case Neon: "neon"
            case Rvv: "rvv"

    fn arch_text() -> text:
        match self:
            case None_: "unknown"
            case Sse42: "x86_64"
            case Avx2: "x86_64"
            case Avx512: "x86_64"
            case Neon: "aarch64"
            case Rvv: "riscv64"

    fn feature_text() -> text:
        match self:
            case None_: "scalar"
            case Sse42: "sse42"
            case Avx2: "avx2"
            case Avx512: "avx2"
            case Neon: "neon"
            case Rvv: "rvv"

# ============================================================================
# Runtime externs for CPU feature detection
# ============================================================================

extern fn rt_cpu_has_sse42() -> bool
extern fn rt_cpu_has_avx2() -> bool
extern fn rt_cpu_has_avx512() -> bool
extern fn rt_cpu_has_neon() -> bool

# ============================================================================
# Runtime externs for SIMD kernels
# ============================================================================

extern fn rt_simd_fill_row_avx2(buf: [u32], offset: i64, count: i64, color: u32)
extern fn rt_simd_fill_row_sse42(buf: [u32], offset: i64, count: i64, color: u32)
extern fn rt_simd_fill_row_neon(buf: [u32], offset: i64, count: i64, color: u32)

extern fn rt_simd_blend_row_avx2(dst: [u32], src: [u32], offset: i64, count: i64)
extern fn rt_simd_blend_row_sse42(dst: [u32], src: [u32], offset: i64, count: i64)
extern fn rt_simd_blend_row_neon(dst: [u32], src: [u32], offset: i64, count: i64)

extern fn rt_simd_blit_row_avx2(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64)
extern fn rt_simd_blit_row_sse42(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64)
extern fn rt_simd_blit_row_neon(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64)

# ============================================================================
# Runtime externs — RISC-V V (RVV) SIMD
# ============================================================================

extern fn rt_cpu_has_rvv() -> bool

extern fn rt_simd_fill_row_rvv(buf: [u32], offset: i64, count: i64, color: u32)
extern fn rt_simd_blend_row_rvv(dst: [u32], src: [u32], offset: i64, count: i64)
extern fn rt_simd_blit_row_rvv(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64)

# ============================================================================
# Detection
# ============================================================================

var _cached_simd_level: SimdLevel = SimdLevel.None_
var _simd_detected: bool = false

fn detect_simd_level() -> SimdLevel:
    if _simd_detected:
        return _cached_simd_level

    if rt_cpu_has_avx512():
        _cached_simd_level = SimdLevel.Avx512
    elif rt_cpu_has_avx2():
        _cached_simd_level = SimdLevel.Avx2
    elif rt_cpu_has_sse42():
        _cached_simd_level = SimdLevel.Sse42
    elif rt_cpu_has_neon():
        _cached_simd_level = SimdLevel.Neon
    elif rt_cpu_has_rvv():
        _cached_simd_level = SimdLevel.Rvv
    else:
        _cached_simd_level = SimdLevel.None_

    _simd_detected = true
    _cached_simd_level

fn active_feature_text() -> text:
    detect_simd_level().feature_text()

fn active_arch_text() -> text:
    detect_simd_level().arch_text()

fn active_target_features() -> [text]:
    val feat = detect_simd_level().feature_text()
    [feat]

# ============================================================================
# Fill Row — write solid color across a pixel row
# ============================================================================

fn simd_fill_row(buf: [u32], offset: i64, count: i64, color: u32):
    if count <= 0:
        return

    val level = detect_simd_level()
    match level:
        case Avx512:
            rt_simd_fill_row_avx2(buf, offset, count, color)
        case Avx2:
            rt_simd_fill_row_avx2(buf, offset, count, color)
        case Sse42:
            rt_simd_fill_row_sse42(buf, offset, count, color)
        case Neon:
            rt_simd_fill_row_neon(buf, offset, count, color)
        case Rvv:
            rt_simd_fill_row_rvv(buf, offset, count, color)
        case None_:
            _scalar_fill_row(buf, offset, count, color)

fn _scalar_fill_row(buf: [u32], offset: i64, count: i64, color: u32):
    var i: i64 = 0
    while i < count:
        buf[offset + i] = color
        i = i + 1

# ============================================================================
# Blend Row — Porter-Duff src-over alpha blending
# ============================================================================

fn simd_blend_row(dst: [u32], src: [u32], offset: i64, count: i64):
    if count <= 0:
        return

    val level = detect_simd_level()
    match level:
        case Avx512:
            rt_simd_blend_row_avx2(dst, src, offset, count)
        case Avx2:
            rt_simd_blend_row_avx2(dst, src, offset, count)
        case Sse42:
            rt_simd_blend_row_sse42(dst, src, offset, count)
        case Neon:
            rt_simd_blend_row_neon(dst, src, offset, count)
        case Rvv:
            rt_simd_blend_row_rvv(dst, src, offset, count)
        case None_:
            _scalar_blend_row(dst, src, offset, count)

fn _scalar_blend_row(dst: [u32], src: [u32], offset: i64, count: i64):
    var i: i64 = 0
    while i < count:
        val idx = offset + i
        val s = src[idx]
        val sa = (s >> 24) & 0xFF
        if sa == 255:
            dst[idx] = s
        elif sa > 0:
            val d = dst[idx]
            val inv_a = 255 - sa
            val dr = (d >> 16) & 0xFF
            val dg = (d >> 8) & 0xFF
            val db = d & 0xFF
            val sr = (s >> 16) & 0xFF
            val sg = (s >> 8) & 0xFF
            val sb = s & 0xFF
            val r = (sr * sa + dr * inv_a) / 255
            val g = (sg * sa + dg * inv_a) / 255
            val b = (sb * sa + db * inv_a) / 255
            dst[idx] = (255 << 24) | (r << 16) | (g << 8) | b
        i = i + 1

# ============================================================================
# Blit Row — pixel copy
# ============================================================================

fn simd_blit_row(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64):
    if count <= 0:
        return

    val level = detect_simd_level()
    match level:
        case Avx512:
            rt_simd_blit_row_avx2(dst, dst_offset, src, src_offset, count)
        case Avx2:
            rt_simd_blit_row_avx2(dst, dst_offset, src, src_offset, count)
        case Sse42:
            rt_simd_blit_row_sse42(dst, dst_offset, src, src_offset, count)
        case Neon:
            rt_simd_blit_row_neon(dst, dst_offset, src, src_offset, count)
        case Rvv:
            rt_simd_blit_row_rvv(dst, dst_offset, src, src_offset, count)
        case None_:
            _scalar_blit_row(dst, dst_offset, src, src_offset, count)

fn _scalar_blit_row(dst: [u32], dst_offset: i64, src: [u32], src_offset: i64, count: i64):
    var i: i64 = 0
    while i < count:
        dst[dst_offset + i] = src[src_offset + i]
        i = i + 1

# ============================================================================
# fill_span — solid color fill across a span, with hit-count tracking
# ============================================================================

fn fill_span(buf: [u32], offset: i64, count: i64, color: u32):
    """Fill buf[offset..offset+count] with color. Increments fill_hits."""
    if count <= 0:
        return
    simd_fill_row(buf, offset, count, color)
    g_simd_hits.fill_hits = g_simd_hits.fill_hits + 1

fn _scalar_fill_span(buf: [u32], offset: i64, count: i64, color: u32):
    """Scalar reference path for parity testing (identical output to SIMD)."""
    _scalar_fill_row(buf, offset, count, color)

# ============================================================================
# copy_span — pixel copy across a span, with hit-count tracking
# ============================================================================

fn copy_span(dst: [u32], dst_off: i64, src: [u32], src_off: i64, count: i64):
    """Copy src[src_off..] into dst[dst_off..]. Increments copy_hits."""
    if count <= 0:
        return
    simd_blit_row(dst, dst_off, src, src_off, count)
    g_simd_hits.copy_hits = g_simd_hits.copy_hits + 1

fn _scalar_copy_span(dst: [u32], dst_off: i64, src: [u32], src_off: i64, count: i64):
    """Scalar reference path for parity testing."""
    _scalar_blit_row(dst, dst_off, src, src_off, count)

# ============================================================================
# alpha_blend_span — Porter-Duff src-over for a span, with hit-count tracking
# ============================================================================

fn alpha_blend_span(dst: [u32], src: [u32], offset: i64, count: i64):
    """Blend src into dst using src-over. Increments alpha_hits."""
    if count <= 0:
        return
    simd_blend_row(dst, src, offset, count)
    g_simd_hits.alpha_hits = g_simd_hits.alpha_hits + 1

fn _scalar_alpha_blend_span(dst: [u32], src: [u32], offset: i64, count: i64):
    """Scalar reference path for parity testing."""
    _scalar_blend_row(dst, src, offset, count)

# ============================================================================
# blit_rect — copy a rectangular region row-by-row, with hit-count tracking
# ============================================================================

fn blit_rect(dst: [u32], dst_stride: i64, dst_x: i64, dst_y: i64,
             src: [u32], src_stride: i64, src_x: i64, src_y: i64,
             w: i64, h: i64):
    """Blit src rect into dst rect. Increments blit_hits once per call."""
    if w <= 0 or h <= 0:
        return
    var row: i64 = 0
    while row < h:
        val d_off = (dst_y + row) * dst_stride + dst_x
        val s_off = (src_y + row) * src_stride + src_x
        simd_blit_row(dst, d_off, src, s_off, w)
        row = row + 1
    g_simd_hits.blit_hits = g_simd_hits.blit_hits + 1

fn _scalar_blit_rect(dst: [u32], dst_stride: i64, dst_x: i64, dst_y: i64,
                     src: [u32], src_stride: i64, src_x: i64, src_y: i64,
                     w: i64, h: i64):
    """Scalar reference path for parity testing."""
    if w <= 0 or h <= 0:
        return
    var row: i64 = 0
    while row < h:
        val d_off = (dst_y + row) * dst_stride + dst_x
        val s_off = (src_y + row) * src_stride + src_x
        _scalar_blit_row(dst, d_off, src, s_off, w)
        row = row + 1

# ============================================================================
# scroll_region — shift pixel rows within a region, with hit-count tracking
#
# Positive delta_y scrolls content DOWN (rows move toward higher y).
# Negative delta_y scrolls content UP  (rows move toward lower y).
# ============================================================================

fn scroll_region(buf: [u32], stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    """Scroll a rect within buf by delta_y rows. Increments scroll_hits."""
    if w <= 0 or h <= 0 or delta_y == 0:
        return

    val abs_dy = if delta_y < 0: -delta_y else: delta_y
    val rows_to_copy = h - abs_dy
    if rows_to_copy <= 0:
        return

    if delta_y < 0:
        # Scroll up: copy rows upward (src row > dst row — iterate top to bottom)
        var row: i64 = 0
        while row < rows_to_copy:
            val dst_off = (y + row) * stride + x
            val src_off = (y + row + abs_dy) * stride + x
            simd_blit_row(buf, dst_off, buf, src_off, w)
            row = row + 1
    else:
        # Scroll down: copy rows downward (dst row > src row — iterate bottom to top)
        var row: i64 = rows_to_copy - 1
        while row >= 0:
            val dst_off = (y + row + abs_dy) * stride + x
            val src_off = (y + row) * stride + x
            simd_blit_row(buf, dst_off, buf, src_off, w)
            row = row - 1

    g_simd_hits.scroll_hits = g_simd_hits.scroll_hits + 1

fn _scalar_scroll_region(buf: [u32], stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    """Scalar reference path for parity testing."""
    if w <= 0 or h <= 0 or delta_y == 0:
        return

    val abs_dy = if delta_y < 0: -delta_y else: delta_y
    val rows_to_copy = h - abs_dy
    if rows_to_copy <= 0:
        return

    if delta_y < 0:
        var row: i64 = 0
        while row < rows_to_copy:
            val dst_off = (y + row) * stride + x
            val src_off = (y + row + abs_dy) * stride + x
            _scalar_blit_row(buf, dst_off, buf, src_off, w)
            row = row + 1
    else:
        var row: i64 = rows_to_copy - 1
        while row >= 0:
            val dst_off = (y + row + abs_dy) * stride + x
            val src_off = (y + row) * stride + x
            _scalar_blit_row(buf, dst_off, buf, src_off, w)
            row = row - 1

# ============================================================================
# CpuSimdProvider — concrete SimdProvider backed by the kernel dispatch above
# ============================================================================

class CpuSimdProvider:
    """Concrete SimdProvider backed by the CPU SIMD kernel dispatch layer.

    Instantiate once per engine and register via register_simd_provider().
    """
    _dummy: i32   # classes must have at least one field

fn make_cpu_simd_provider() -> CpuSimdProvider:
    CpuSimdProvider(_dummy: 0)

impl SimdProvider for CpuSimdProvider:

    fn hit_counts() -> SimdHitCounts:
        g_simd_hits

    fn target_features() -> [text]:
        active_target_features()
