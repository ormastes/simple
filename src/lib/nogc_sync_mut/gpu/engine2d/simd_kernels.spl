"""SIMD-Accelerated Pixel Operations

@tag:stdlib
@tag:gpu

Provides vectorized fill, blend, blit, copy, and scroll operations with
runtime CPU feature detection. Falls back to scalar loops when no SIMD
is available.

This pure Simple layer detects the CPU's capability level and exposes the
same kernel API regardless of host. The first pass keeps row operations in
Simple so backend behavior is correct before native Rust/NEON kernels are
introduced behind the same functions.

Each span/rect kernel records the matching SimdHitCounts value through
simd_provider.spl so the optimization plugin metadata hook can report
accurate per-frame hit counts without importing provider globals directly.

Usage:
    val level = detect_simd_level()
    fill_span(buffer, 0, 256, 0xFFFF0000)
    alpha_blend_span(dst, src, 0, 128)
    blit_rect(dst, 1920, 0, 0, src, 1920, 0, 0, 256, 256)
    scroll_region(buf, 1920, 0, 0, 1920, 1080, -2)
"""

use std.nogc_sync_mut.gpu.engine2d.simd_provider.{SimdHitCounts, SimdProvider, record_simd_fill_hit, record_simd_copy_hit, record_simd_alpha_hit, record_simd_blit_hit, record_simd_scroll_hit, simd_hit_counts}

# ============================================================================
# SIMD Level Enum
# ============================================================================

enum SimdLevel:
    None_
    Sse42
    Avx2
    Avx512
    Neon
    Rvv

impl SimdLevel:
    fn to_text() -> text:
        match self:
            case None_: "None"
            case Sse42: "SSE4.2"
            case Avx2: "AVX2"
            case Avx512: "AVX-512"
            case Neon: "NEON"
            case Rvv: "RVV"

    fn arch_text() -> text:
        match self:
            case None_: "unknown"
            case Sse42: "x86_64"
            case Avx2: "x86_64"
            case Avx512: "x86_64"
            case Neon: "aarch64"
            case Rvv: "riscv64"

    fn feature_text() -> text:
        match self:
            case None_: "scalar"
            case Sse42: "sse42"
            case Avx2: "avx2"
            case Avx512: "avx2"
            case Neon: "neon"
            case Rvv: "rvv"

# ============================================================================
# Runtime externs for CPU feature detection
# ============================================================================

extern fn rt_simd_has_sse() -> bool
extern fn rt_simd_has_avx2() -> bool
extern fn rt_simd_has_neon() -> bool
extern fn rt_simd_has_rvv() -> bool

# ============================================================================
# Native SIMD pixel-row kernels (NEON on aarch64 / SSE2 on x86_64)
#
# These are the genuine vectorized span kernels: the Rust runtime executes
# `vdupq_n_u32`/`vst1q_u32` (fill) and `vld1q_u32`/`vst1q_u32` (copy) over a
# packed pixel buffer. Output is bit-identical to the scalar reference. The
# neon-hit counter only increments when a real SIMD (not scalar-fallback)
# chunk runs, so the evidence layer can prove NEON actually executed instead
# of trusting a scalar path that merely reports `has_neon`.
#
# Implementation: src/compiler_rust/runtime/src/value/engine2d_simd_ops.rs;
# interpreter dispatch: compiler/src/interpreter_extern/simd.rs.
# ============================================================================

# engine2d SIMD row kernels — C-backed in native builds (runtime_simd_dispatch.c,
# aarch64 NEON / x86 AVX2 / scalar), with a Rust *seed* shim for interpreter mode
# (the interpreter is the seed). Return-style so the same call works in both modes
# (the interpreter passes an Arc clone, so in-place mutation can't propagate).
extern fn rt_engine2d_simd_fill_row_u32(count: i64, color: u32) -> [u32]
extern fn rt_engine2d_simd_copy_row_u32(src: [u32]) -> [u32]
extern fn rt_engine2d_simd_blend_row_u32(dst_row: [u32], src_row: [u32]) -> [u32]
extern fn rt_simd_engine2d_neon_hits() -> i64
extern fn rt_simd_engine2d_neon_reset() -> i64

# ============================================================================
# Detection
# ============================================================================

var _cached_simd_level: SimdLevel = SimdLevel.None_
var _simd_detected: bool = false

fn detect_simd_level() -> SimdLevel:
    if _simd_detected:
        return _cached_simd_level

    if rt_simd_has_avx2():
        _cached_simd_level = SimdLevel.Avx2
    elif rt_simd_has_sse():
        _cached_simd_level = SimdLevel.Sse42
    elif rt_simd_has_neon():
        _cached_simd_level = SimdLevel.Neon
    elif rt_simd_has_rvv():
        _cached_simd_level = SimdLevel.Rvv
    else:
        _cached_simd_level = SimdLevel.None_

    _simd_detected = true
    _cached_simd_level

fn active_feature_text() -> text:
    detect_simd_level().feature_text()

fn active_arch_text() -> text:
    detect_simd_level().arch_text()

fn active_target_features() -> [text]:
    val feat = detect_simd_level().feature_text()
    [feat]

class CpuSimdRuntimeEvidence:
    arch: text
    feature: text
    level: text
    x86_available: bool
    arm_available: bool
    riscv_available: bool
    executed_fill: bool
    executed_copy: bool
    executed_alpha: bool
    executed_scroll: bool
    checksum: i64
    hit_summary: text
    reason: text
    # Genuine native-SIMD proof (NEON on aarch64 / SSE2 on x86_64): set by
    # running the native pixel-row kernels and comparing to a scalar reference.
    native_simd_executed: bool   # a real SIMD chunk ran (hit counter advanced)
    native_simd_bit_exact: bool  # native output == scalar reference, byte-exact
    native_simd_hits: i64

impl CpuSimdRuntimeEvidence:
    fn executed_all() -> bool:
        self.executed_fill and self.executed_copy and self.executed_alpha and self.executed_scroll

    fn diagnostic_text() -> text:
        "arch={self.arch};feature={self.feature};level={self.level};x86={self.x86_available.to_text()};arm={self.arm_available.to_text()};riscv={self.riscv_available.to_text()};executed={self.executed_all().to_text()};checksum={self.checksum};hits={self.hit_summary};native_simd_executed={self.native_simd_executed.to_text()};native_simd_bit_exact={self.native_simd_bit_exact.to_text()};native_simd_hits={self.native_simd_hits};reason={self.reason}"

class NativeSimdPixelEvidence:
    """Proof that the native vectorized pixel-row kernels actually ran on
    real SIMD hardware (not the scalar fallback) and stayed bit-identical."""
    executed: bool
    bit_exact: bool
    hits: i64
    fill_checksum: i64

fn native_simd_pixel_evidence() -> NativeSimdPixelEvidence:
    """Run the native fill/copy row kernels and verify SIMD genuinely executed.

    `executed` is true only when the runtime's NEON/SSE2 chunk path ran (the
    hit counter advanced); a scalar host leaves it false. `bit_exact` compares
    the native output against an independent scalar reference computed here.
    """
    rt_simd_engine2d_neon_reset()
    val count: i64 = 64
    val color: u32 = 0xFF8040C0
    val native_fill = rt_engine2d_simd_fill_row_u32(count, color)

    var ref_fill: [u32] = [0u32; 64]
    var i: i64 = 0
    while i < count:
        ref_fill[i.to_i32()] = color
        i = i + 1

    var fill_exact = native_fill.len() == count
    i = 0
    while i < count:
        if native_fill[i.to_i32()] != ref_fill[i.to_i32()]:
            fill_exact = false
        i = i + 1

    val native_copy = rt_engine2d_simd_copy_row_u32(native_fill)
    var copy_exact = native_copy.len() == native_fill.len()
    i = 0
    while i < native_fill.len():
        if native_copy[i.to_i32()] != native_fill[i.to_i32()]:
            copy_exact = false
        i = i + 1

    val hits = rt_simd_engine2d_neon_hits()
    NativeSimdPixelEvidence(
        executed: hits > 0,
        bit_exact: fill_exact and copy_exact,
        hits: hits,
        fill_checksum: _cpu_simd_checksum(native_fill)
    )

fn _cpu_simd_checksum(buf: [u32]) -> i64:
    var sum: i64 = 0
    var i: i64 = 0
    while i < buf.len():
        val pixel = buf[i.to_i32()]
        val low = (pixel & 0xFFu32) as i64
        val mid = ((pixel >> 8) & 0xFFu32) as i64
        val high = ((pixel >> 16) & 0xFFu32) as i64
        sum = sum + low + (mid * 3) + (high * 5)
        i = i + 1
    sum

fn cpu_simd_runtime_evidence() -> CpuSimdRuntimeEvidence:
    val level = detect_simd_level()
    val arch = level.arch_text()
    val feature = level.feature_text()
    val before = simd_hit_counts()

    var pixels: [u32] = [0u32; 16]
    var copy_src: [u32] = [0xFF112233; 16]
    var alpha_src: [u32] = [0x804488CC; 16]
    fill_span(pixels, 0, 16, 0xFF102030)
    copy_span(pixels, 4, copy_src, 0, 4)
    alpha_blend_span(pixels, alpha_src, 8, 4)
    simd_scroll_region(pixels, 4, 0, 0, 4, 4, 1)

    val after = simd_hit_counts()
    val fill_delta = after.fill_hits - before.fill_hits
    val copy_delta = after.copy_hits - before.copy_hits
    val alpha_delta = after.alpha_hits - before.alpha_hits
    val scroll_delta = after.scroll_hits - before.scroll_hits
    val executed_fill = fill_delta > 0
    val executed_copy = copy_delta > 0
    val executed_alpha = alpha_delta > 0
    val executed_scroll = scroll_delta > 0
    val native = native_simd_pixel_evidence()
    val reason = if feature == "scalar":
        "runtime reported scalar fallback; SIMD feature unavailable"
    else if native.executed and native.bit_exact:
        "native SIMD kernels executed (hits={native.hits}) and matched scalar bit-for-bit"
    else if native.executed:
        "native SIMD kernels executed but diverged from scalar reference"
    else:
        "SIMD feature reported but native kernels did not take the vectorized path"
    CpuSimdRuntimeEvidence(
        arch: arch,
        feature: feature,
        level: level.to_text(),
        x86_available: arch == "x86_64" and (feature == "sse42" or feature == "avx2"),
        arm_available: arch == "aarch64" and feature == "neon",
        riscv_available: arch == "riscv64" and feature == "rvv",
        executed_fill: executed_fill,
        executed_copy: executed_copy,
        executed_alpha: executed_alpha,
        executed_scroll: executed_scroll,
        checksum: _cpu_simd_checksum(pixels),
        hit_summary: "fill_delta={fill_delta},copy_delta={copy_delta},alpha_delta={alpha_delta},scroll_delta={scroll_delta}",
        reason: reason,
        native_simd_executed: native.executed,
        native_simd_bit_exact: native.bit_exact,
        native_simd_hits: native.hits
    )

# ============================================================================
# Native-SIMD routing gate
#
# When the host has real SIMD (NEON on aarch64), the hot fill/blend rows route
# through the C-backed `rt_engine2d_simd_*_row_u32` kernels (runtime_simd_dispatch.c,
# NEON/AVX2/scalar) so the live CPU-SIMD render path genuinely executes vector
# code rather than a scalar loop. Output is bit-identical to the scalar path
# (the C blend uses the same truncating /255 floor; verified exhaustively).
#
# Interpreter note: a `[u32]` framebuffer is a boxed array here, so the native
# row is built/blended with NEON and then copied into the framebuffer element-
# by-element — the per-row marshalling is an interpreter artifact, not a win,
# but it is the path that genuinely runs NEON. Under AOT the framebuffer is
# packed i64 and the same kernels run over it. (blit/scroll stay pure-Simple
# scalar: they are in-place sub-range copies that a return-style row kernel
# can't express without extra marshalling, and they were never Rust-backed.)
var _neon_rows_cached: bool = false
var _neon_rows_detected: bool = false

fn _neon_pixel_rows_enabled() -> bool:
    if _neon_rows_detected:
        return _neon_rows_cached
    _neon_rows_cached = detect_simd_level() == SimdLevel.Neon
    _neon_rows_detected = true
    _neon_rows_cached

# ============================================================================
# Fill Row — write solid color across a pixel row
# ============================================================================

pub fn simd_fill_row(mut buf: any, offset: i64, count: i64, color: u32):
    if count <= 0:
        return
    if _neon_pixel_rows_enabled():
        # Genuine NEON (C kernel): vdupq + vst1q build the row in the runtime.
        val row = rt_engine2d_simd_fill_row_u32(count, color)
        var j: i64 = 0
        while j < count:
            buf[(offset + j).to_i32()] = row[j.to_i32()]
            j = j + 1
        return
    _scalar_fill_row(buf, offset, count, color)

pub fn _scalar_fill_row(mut buf: any, offset: i64, count: i64, color: u32):
    var i: i64 = 0
    while i < count:
        val idx = (offset + i).to_i32()
        buf[idx] = color
        i = i + 1

# ============================================================================
# Blend Row — Porter-Duff src-over alpha blending
# ============================================================================

pub fn simd_blend_row(mut dst: any, src: [u32], offset: i64, count: i64):
    if count <= 0:
        return
    if _neon_pixel_rows_enabled():
        # Gather aligned dst/src rows, src-over blend via the C NEON kernel,
        # scatter back. Bit-identical to _scalar_blend_row (same floor /255).
        val n = count.to_i32()
        var dst_row: [u32] = [0u32; n]
        var src_row: [u32] = [0u32; n]
        var j: i64 = 0
        while j < count:
            val idx = (offset + j).to_i32()
            dst_row[j.to_i32()] = dst[idx]
            src_row[j.to_i32()] = src[idx]
            j = j + 1
        val blended = rt_engine2d_simd_blend_row_u32(dst_row, src_row)
        j = 0
        while j < count:
            dst[(offset + j).to_i32()] = blended[j.to_i32()]
            j = j + 1
        return
    _scalar_blend_row(dst, src, offset, count)

pub fn _scalar_blend_row(mut dst: any, src: [u32], offset: i64, count: i64):
    var i: i64 = 0
    while i < count:
        val idx = (offset + i).to_i32()
        val s = src[idx]
        val sa = (s >> 24) & 0xFF
        if sa == 255:
            dst[idx] = s
        elif sa > 0:
            val d = dst[idx]
            val inv_a = 255 - sa
            val dr = (d >> 16) & 0xFF
            val dg = (d >> 8) & 0xFF
            val db = d & 0xFF
            val sr = (s >> 16) & 0xFF
            val sg = (s >> 8) & 0xFF
            val sb = s & 0xFF
            val r = (sr * sa + dr * inv_a) / 255
            val g = (sg * sa + dg * inv_a) / 255
            val b = (sb * sa + db * inv_a) / 255
            dst[idx] = (255 << 24) | (r << 16) | (g << 8) | b
        i = i + 1

# ============================================================================
# Blit Row — pixel copy
# ============================================================================

pub fn simd_blit_row(mut dst: any, dst_offset: i64, src: [u32], src_offset: i64, count: i64):
    if count <= 0:
        return
    _scalar_blit_row(dst, dst_offset, src, src_offset, count)

pub fn _scalar_blit_row(mut dst: any, dst_offset: i64, src: [u32], src_offset: i64, count: i64):
    var i: i64 = 0
    while i < count:
        val dst_idx = (dst_offset + i).to_i32()
        val src_idx = (src_offset + i).to_i32()
        dst[dst_idx] = src[src_idx]
        i = i + 1

# ============================================================================
# fill_span — solid color fill across a span, with hit-count tracking
# ============================================================================

pub fn fill_span(mut buf: any, offset: i64, count: i64, color: u32):
    """Fill buf[offset..offset+count] with color. Increments fill_hits."""
    if count <= 0:
        return
    record_simd_fill_hit()
    simd_fill_row(buf, offset, count, color)

pub fn _scalar_fill_span(mut buf: any, offset: i64, count: i64, color: u32):
    """Scalar reference path for parity testing (identical output to SIMD)."""
    _scalar_fill_row(buf, offset, count, color)

# ============================================================================
# copy_span — pixel copy across a span, with hit-count tracking
# ============================================================================

pub fn copy_span(mut dst: any, dst_off: i64, src: [u32], src_off: i64, count: i64):
    """Copy src[src_off..] into dst[dst_off..]. Increments copy_hits."""
    if count <= 0:
        return
    record_simd_copy_hit()
    simd_blit_row(dst, dst_off, src, src_off, count)

pub fn _scalar_copy_span(mut dst: any, dst_off: i64, src: [u32], src_off: i64, count: i64):
    """Scalar reference path for parity testing."""
    _scalar_blit_row(dst, dst_off, src, src_off, count)

# ============================================================================
# alpha_blend_span — Porter-Duff src-over for a span, with hit-count tracking
# ============================================================================

pub fn alpha_blend_span(mut dst: any, src: [u32], offset: i64, count: i64):
    """Blend src into dst using src-over. Increments alpha_hits."""
    if count <= 0:
        return
    record_simd_alpha_hit()
    simd_blend_row(dst, src, offset, count)

pub fn _scalar_alpha_blend_span(mut dst: any, src: [u32], offset: i64, count: i64):
    """Scalar reference path for parity testing."""
    _scalar_blend_row(dst, src, offset, count)

# ============================================================================
# blit_rect — copy a rectangular region row-by-row, with hit-count tracking
# ============================================================================

pub fn simd_blit_rect(mut dst: any, dst_stride: i64, dst_x: i64, dst_y: i64,
                      src: [u32], src_stride: i64, src_x: i64, src_y: i64,
                      w: i64, h: i64):
    """Blit src rect into dst rect. Increments blit_hits once per call."""
    if w <= 0 or h <= 0:
        return
    record_simd_blit_hit()
    var row: i64 = 0
    while row < h:
        val d_off = (dst_y + row) * dst_stride + dst_x
        val s_off = (src_y + row) * src_stride + src_x
        simd_blit_row(dst, d_off, src, s_off, w)
        row = row + 1

fn blit_rect(mut dst: any, dst_stride: i64, dst_x: i64, dst_y: i64,
             src: [u32], src_stride: i64, src_x: i64, src_y: i64,
             w: i64, h: i64):
    simd_blit_rect(dst, dst_stride, dst_x, dst_y, src, src_stride, src_x, src_y, w, h)

fn _scalar_blit_rect(mut dst: any, dst_stride: i64, dst_x: i64, dst_y: i64,
                     src: [u32], src_stride: i64, src_x: i64, src_y: i64,
                     w: i64, h: i64):
    """Scalar reference path for parity testing."""
    if w <= 0 or h <= 0:
        return
    var row: i64 = 0
    while row < h:
        val d_off = (dst_y + row) * dst_stride + dst_x
        val s_off = (src_y + row) * src_stride + src_x
        _scalar_blit_row(dst, d_off, src, s_off, w)
        row = row + 1

# ============================================================================
# scroll_region — shift pixel rows within a region, with hit-count tracking
#
# Positive delta_y scrolls content DOWN (rows move toward higher y).
# Negative delta_y scrolls content UP  (rows move toward lower y).
# ============================================================================

pub fn simd_scroll_region(mut buf: any, stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    """Scroll a rect within buf by delta_y rows. Increments scroll_hits."""
    if w <= 0 or h <= 0 or delta_y == 0:
        return
    record_simd_scroll_hit()

    val abs_dy = if delta_y < 0: -delta_y else: delta_y
    val rows_to_copy = h - abs_dy
    if rows_to_copy <= 0:
        return

    if delta_y < 0:
        # Scroll up: copy rows upward (src row > dst row — iterate top to bottom)
        var row: i64 = 0
        while row < rows_to_copy:
            val dst_off = (y + row) * stride + x
            val src_off = (y + row + abs_dy) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row + 1
    else:
        # Scroll down: copy rows downward (dst row > src row — iterate bottom to top)
        var row: i64 = rows_to_copy - 1
        while row >= 0:
            val dst_off = (y + row + abs_dy) * stride + x
            val src_off = (y + row) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row - 1

fn scroll_region(mut buf: any, stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    simd_scroll_region(buf, stride, x, y, w, h, delta_y)


fn _scalar_scroll_region(mut buf: any, stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    """Scalar reference path for parity testing."""
    if w <= 0 or h <= 0 or delta_y == 0:
        return

    val abs_dy = if delta_y < 0: -delta_y else: delta_y
    val rows_to_copy = h - abs_dy
    if rows_to_copy <= 0:
        return

    if delta_y < 0:
        var row: i64 = 0
        while row < rows_to_copy:
            val dst_off = (y + row) * stride + x
            val src_off = (y + row + abs_dy) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row + 1
    else:
        var row: i64 = rows_to_copy - 1
        while row >= 0:
            val dst_off = (y + row + abs_dy) * stride + x
            val src_off = (y + row) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row - 1

# ============================================================================
# CpuSimdProvider — concrete SimdProvider backed by the kernel dispatch above
# ============================================================================

class CpuSimdProvider:
    """Concrete SimdProvider backed by the CPU SIMD kernel dispatch layer.

    Instantiate once per engine and register via register_simd_provider().
    """
    _dummy: i32   # classes must have at least one field

fn make_cpu_simd_provider() -> CpuSimdProvider:
    CpuSimdProvider(_dummy: 0)

impl SimdProvider for CpuSimdProvider:

    fn hit_counts() -> SimdHitCounts:
        simd_hit_counts()

    fn target_features() -> [text]:
        active_target_features()
