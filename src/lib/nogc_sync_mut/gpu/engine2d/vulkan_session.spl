"""Vulkan Session — Instance, Device, Queue, Allocator, Command Pools, Caches

@tag:stdlib
@tag:gpu

Owns the full Vulkan session lifetime: instance → device → queue → allocator →
command pool(s) → pipeline cache → descriptor pool. SPIR-V only (no GLSL).

Thread policy:
  "single"  — one shared command pool for all frames
  "multi"   — per-frame command pools created on begin_frame

Usage:
    val sess = VulkanSession.create("2d", "single")
    sess.init_device()
    val cmd = sess.begin_frame(1920, 1080)
    sess.submit_frame(cmd)
    sess.release()
"""

# ============================================================================
# Extern declarations
# ============================================================================

extern fn rt_vk_create_instance() -> i64
extern fn rt_vk_create_device(instance: i64) -> i64
extern fn rt_vk_get_queue(device: i64, family: i64) -> i64
extern fn rt_vk_create_allocator(device: i64) -> i64
extern fn rt_vk_create_cmd_pool(device: i64, family: i64) -> i64
extern fn rt_vk_create_pipeline_cache(device: i64) -> i64
extern fn rt_vk_create_descriptor_pool(device: i64) -> i64
extern fn rt_vk_load_spirv(device: i64, spirv_name: text) -> i64
extern fn rt_vk_destroy_device(device: i64) -> i64
extern fn rt_vk_destroy_instance(instance: i64) -> i64

# Additional session operations
extern fn rt_vk_alloc_cmd_buffer(pool: i64) -> i64
extern fn rt_vk_begin_cmd(cmd: i64) -> bool
extern fn rt_vk_end_cmd(cmd: i64) -> bool
extern fn rt_vk_queue_submit(queue: i64, cmd: i64) -> bool
extern fn rt_vk_queue_wait_idle(queue: i64) -> bool
extern fn rt_vk_present(queue: i64, cmd: i64) -> bool
extern fn rt_vk_readback(cmd: i64, x: i64, y: i64, w: i64, h: i64) -> bool
extern fn rt_vk_device_name(device: i64) -> text
extern fn rt_vk_destroy_cmd_pool(pool: i64) -> bool

# ============================================================================
# VulkanSession
# ============================================================================

class VulkanSession:
    instance_handle: i64
    device_handle: i64
    queue_handle: i64
    queue_family: i64
    allocator_handle: i64
    cmd_pool_handle: i64
    pipeline_cache_handle: i64
    descriptor_pool_handle: i64
    shader_count: i64
    mode: text
    thread_policy: text
    initialized: bool
    generation: i64
    device_name: text

    static fn create(mode: text, thread_policy: text) -> VulkanSession:
        VulkanSession(
            instance_handle: 0,
            device_handle: 0,
            queue_handle: 0,
            queue_family: 0,
            allocator_handle: 0,
            cmd_pool_handle: 0,
            pipeline_cache_handle: 0,
            descriptor_pool_handle: 0,
            shader_count: 0,
            mode: mode,
            thread_policy: thread_policy,
            initialized: false,
            generation: 0,
            device_name: ""
        )

    fn init_device() -> text:
        val inst = rt_vk_create_instance()
        if inst == 0:
            return "error: vkCreateInstance failed"
        self.instance_handle = inst

        val dev = rt_vk_create_device(inst)
        if dev == 0:
            return "error: vkCreateDevice failed"
        self.device_handle = dev
        self.device_name = rt_vk_device_name(dev)

        self.queue_family = 0
        val q = rt_vk_get_queue(dev, self.queue_family)
        if q == 0:
            return "error: vkGetDeviceQueue failed"
        self.queue_handle = q

        val alloc = rt_vk_create_allocator(dev)
        if alloc == 0:
            return "error: vmaCreateAllocator failed"
        self.allocator_handle = alloc

        self.initialized = true
        self.generation = self.generation + 1
        "ok"

    fn create_command_pool() -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val pool = rt_vk_create_cmd_pool(self.device_handle, self.queue_family)
        if pool == 0:
            return "error: vkCreateCommandPool failed"
        self.cmd_pool_handle = pool
        "ok"

    fn create_pipeline_cache() -> text:
        if self.initialized == false:
            return "error: device not initialized"
        val pc = rt_vk_create_pipeline_cache(self.device_handle)
        if pc == 0:
            return "error: vkCreatePipelineCache failed"
        self.pipeline_cache_handle = pc

        val dp = rt_vk_create_descriptor_pool(self.device_handle)
        if dp == 0:
            return "error: vkCreateDescriptorPool failed"
        self.descriptor_pool_handle = dp
        "ok"

    fn load_shader(name: text) -> i64:
        if self.initialized == false:
            return 0
        val handle = rt_vk_load_spirv(self.device_handle, name)
        if handle != 0:
            self.shader_count = self.shader_count + 1
        handle

    fn begin_frame(width: i64, height: i64) -> i64:
        if self.initialized == false:
            return 0
        var pool = self.cmd_pool_handle
        if self.thread_policy == "multi":
            pool = rt_vk_create_cmd_pool(self.device_handle, self.queue_family)
            if pool == 0:
                return 0
        val cmd = rt_vk_alloc_cmd_buffer(pool)
        if cmd == 0:
            return 0
        val ok = rt_vk_begin_cmd(cmd)
        if ok == false:
            return 0
        cmd

    fn submit_frame(cmd: i64) -> text:
        if cmd == 0:
            return "error: invalid cmd buffer"
        val ended = rt_vk_end_cmd(cmd)
        if ended == false:
            return "error: vkEndCommandBuffer failed"
        val submitted = rt_vk_queue_submit(self.queue_handle, cmd)
        if submitted == false:
            return "error: vkQueueSubmit failed"
        "ok"

    fn present(cmd: i64) -> text:
        if cmd == 0:
            return "error: invalid cmd buffer"
        val ok = rt_vk_present(self.queue_handle, cmd)
        if ok == false:
            return "error: vkQueuePresentKHR failed"
        "ok"

    fn sync_readback(cmd: i64, x: i64, y: i64, w: i64, h: i64) -> text:
        if cmd == 0:
            return "error: invalid cmd buffer"
        val waited = rt_vk_queue_wait_idle(self.queue_handle)
        if waited == false:
            return "error: queue wait idle failed"
        val ok = rt_vk_readback(cmd, x, y, w, h)
        if ok == false:
            return "error: readback failed"
        "ok"

    fn release() -> text:
        if self.initialized == false:
            return "ok"
        if self.cmd_pool_handle != 0:
            rt_vk_destroy_cmd_pool(self.cmd_pool_handle)
            self.cmd_pool_handle = 0
        if self.device_handle != 0:
            rt_vk_destroy_device(self.device_handle)
            self.device_handle = 0
        if self.instance_handle != 0:
            rt_vk_destroy_instance(self.instance_handle)
            self.instance_handle = 0
        self.initialized = false
        "ok"

    fn stats() -> text:
        "device=" + self.device_name
            + " mode=" + self.mode
            + " policy=" + self.thread_policy
            + " shaders=" + self.shader_count.to_text()
            + " gen=" + self.generation.to_text()
            + " init=" + self.initialized.to_text()
