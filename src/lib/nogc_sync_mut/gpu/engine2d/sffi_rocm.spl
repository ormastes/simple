"""ROCm/HIP SFFI Dispatch — Dynamic-First Dual-Path

@tag:stdlib
@tag:gpu

Wraps HIP runtime API functions behind a RocmFfi class. Dynamic-first
since no Rust runtime exists for rt_rocm_*. The static path resolves
to extern fn stubs that will link-error unless the runtime is built.

Usage:
    val sffi = RocmFfi.create(GpuFfiMode.Dynamic)  # primary path
    if sffi != nil and ffi.is_available():
        ffi.init()
"""

use std.sffi.dynamic.{DynLib}
use std.gpu.engine2d.sffi_dispatch.{GpuFfiMode, FfiDispatchBase, try_load_gpu_lib}

# ============================================================================
# Static extern declarations (no runtime impl yet — will link-error)
# ============================================================================

extern fn rt_rocm_init() -> bool
extern fn rt_rocm_shutdown() -> bool
extern fn rt_rocm_is_available() -> bool
extern fn rt_rocm_device_count() -> i64
extern fn rt_rocm_device_get(id: i64) -> i64
extern fn rt_rocm_mem_alloc(size: i64) -> i64
extern fn rt_rocm_mem_free(ptr: i64) -> bool
extern fn rt_rocm_memcpy_htod(dst: i64, src: [u8], size: i64) -> bool
extern fn rt_rocm_memcpy_dtoh(dst: [u8], src: i64, size: i64) -> bool
extern fn rt_rocm_module_load(source: text) -> i64
extern fn rt_rocm_kernel_get(module: i64, name: text) -> i64
extern fn rt_rocm_launch_kernel(kernel: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64, shared_mem: i64, args_ptr: i64) -> bool
extern fn rt_rocm_synchronize() -> bool
extern fn rt_engine2d_rocm_upload_pixels(d_dst: i64, pixels: [u32], count: i64) -> i64
extern fn rt_engine2d_rocm_download_pixels(d_src: i64, pixels: [u32], byte_size: i64) -> i64
extern fn rt_engine2d_rocm_upload_host_buf(d_dst: i64, host_buf: [u32], byte_size: i64) -> i64

fn rocm_engine2d_upload_pixels(d_dst: i64, pixels: [u32], count: i64) -> i64:
    rt_engine2d_rocm_upload_pixels(d_dst, pixels, count)

fn rocm_engine2d_download_pixels(d_src: i64, pixels: [u32], byte_size: i64) -> i64:
    rt_engine2d_rocm_download_pixels(d_src, pixels, byte_size)

fn rocm_engine2d_upload_host_buf(d_dst: i64, host_buf: [u32], byte_size: i64) -> i64:
    rt_engine2d_rocm_upload_host_buf(d_dst, host_buf, byte_size)

# ============================================================================
# RocmFfi
# ============================================================================

class RocmFfi:
    _mode: GpuFfiMode
    _dyn_lib: DynLib?

impl FfiDispatchBase for RocmFfi:

    fn mode() -> GpuFfiMode:
        self._mode

    static fn create_static() -> RocmFfi:
        RocmFfi(_mode: GpuFfiMode.Static, _dyn_lib: nil)

    static fn create_dynamic() -> RocmFfi?:
        val lib = try_load_gpu_lib("amdhip64")
        if lib == nil:
            return nil
        RocmFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create_dynamic_from(path: text) -> RocmFfi?:
        val lib = DynLib.load(path)
        if lib == nil:
            return nil
        RocmFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create(sffi_mode: GpuFfiMode) -> RocmFfi?:
        match sffi_mode:
            case Dynamic:
                val dyn_sffi = RocmFfi.create_dynamic()
                if dyn_sffi != nil:
                    return dyn_sffi
                nil
            case Static:
                RocmFfi.create_static()

    fn is_available() -> bool:
        match self._mode:
            case Static: rt_rocm_is_available()
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("hipInit", 0)
                    result == 0
                else:
                    false

    fn init() -> bool:
        match self._mode:
            case Static: rt_rocm_init()
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("hipInit", 0)
                    result == 0
                else:
                    false

    fn shutdown() -> bool:
        match self._mode:
            case Static: rt_rocm_shutdown()
            case Dynamic: true

    fn device_count() -> i64:
        match self._mode:
            case Static: rt_rocm_device_count()
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.call0("hipGetDeviceCount")
                else:
                    0

    fn mem_alloc(size: i64) -> i64:
        match self._mode:
            case Static: rt_rocm_mem_alloc(size)
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.call1("hipMalloc", size)
                else:
                    0

    fn mem_free(ptr: i64) -> bool:
        match self._mode:
            case Static: rt_rocm_mem_free(ptr)
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("hipFree", ptr)
                    result == 0
                else:
                    false

    fn launch_kernel(name: text, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64, shared_mem: i64) -> bool:
        # A kernel name alone is not enough for HIP dispatch. Launching with
        # module/kernel handle 0 can report misleading success or crash in real
        # runtimes, so this convenience path fails closed until RocmSession owns
        # a loaded module and explicit kernel handle.
        false

    fn synchronize() -> bool:
        match self._mode:
            case Static: rt_rocm_synchronize()
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call0("hipDeviceSynchronize")
                    result == 0
                else:
                    false
