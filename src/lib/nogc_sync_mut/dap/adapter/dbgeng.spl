# DbgEng Debug Adapter
# Wraps DbgEngClient to implement the DebugAdapter trait.
# Provides unified interface for Windows DbgEng-based debugging.

use std.nogc_sync_mut.debug.coordinator.{VarInfo, FrameInfo, LocationInfo}
use std.nogc_sync_mut.dap.adapter.mod.{DebugAdapter, AdapterCapabilities, AdapterConfig}
use std.nogc_sync_mut.debug.remote.protocol.dbgeng.DbgEngClient

# DbgEng adapter implementing DebugAdapter trait
class DbgEngAdapter:
    client: Option<DbgEngClient>
    config: AdapterConfig
    attached: bool
    capabilities: AdapterCapabilities

impl DbgEngAdapter:
    # Create adapter from config (connects to DbgEng remote)
    static fn create(config: AdapterConfig) -> Result<DbgEngAdapter, text>:
        val client = DbgEngClient.connect(config.host, config.port)?
        Ok(DbgEngAdapter(
            client: Some(client),
            config: config,
            attached: true,
            capabilities: AdapterCapabilities.basic()
                .with_memory()
                .with_registers()
                .with_watchpoints(256)
        ))

    # Create adapter from a crash dump file
    static fn from_dump(dump_path: text) -> Result<DbgEngAdapter, text>:
        val client = DbgEngClient.load_dump(dump_path)?
        val config = dbgeng_config("", 0, dump_path)
        Ok(DbgEngAdapter(
            client: Some(client),
            config: config,
            attached: true,
            capabilities: AdapterCapabilities.basic()
                .with_memory()
                .with_registers()
        ))

    # --- DebugAdapter trait implementation ---

    fn name() -> text:
        "dbgeng"

    fn is_attached() -> bool:
        self.attached

    fn attach(program: text, args: [text]) -> Result<text, text>:
        match self.client:
            Some(c):
                Err(DbgEngClient._platform_error())
            nil:
                val client = DbgEngClient.launch(program, args)?
                self.client = Some(client)
                self.attached = true
                Ok("attached to {program}")

    fn detach() -> Result<text, text>:
        match self.client:
            Some(c):
                c.disconnect()?
                self.client = nil
                self.attached = false
                Ok("detached")
            nil:
                Err("not connected")

    # --- Execution Control ---

    fn halt() -> Result<text, text>:
        match self.client:
            Some(c): c.halt()
            nil: Err("not connected")

    fn resume() -> Result<text, text>:
        match self.client:
            Some(c): c.resume()
            nil: Err("not connected")

    fn single_step() -> Result<text, text>:
        match self.client:
            Some(c): c.single_step()
            nil: Err("not connected")

    fn step_over() -> Result<text, text>:
        match self.client:
            Some(c): c.step_over()
            nil: Err("not connected")

    fn step_out() -> Result<text, text>:
        match self.client:
            Some(c): c.step_out()
            nil: Err("not connected")

    fn reset() -> Result<text, text>:
        Err("reset not supported by DbgEng adapter")

    # --- Breakpoints ---

    fn set_breakpoint(file: text, line: i32) -> Result<i32, text>:
        match self.client:
            Some(c): c.set_breakpoint(file, line)
            nil: Err("not connected")

    fn set_breakpoint_at_addr(addr: i64) -> Result<i32, text>:
        match self.client:
            Some(c): c.set_breakpoint_at_addr(addr)
            nil: Err("not connected")

    fn delete_breakpoint(id: i32) -> Result<text, text>:
        match self.client:
            Some(c): c.delete_breakpoint(id)
            nil: Err("not connected")

    fn set_watchpoint(expr: text, access: text) -> Result<i32, text>:
        match self.client:
            Some(c): c.set_watchpoint(expr, access)
            nil: Err("not connected")

    # --- Variable Inspection ---

    fn read_locals() -> Result<[VarInfo], text>:
        match self.client:
            Some(c):
                val raw = c.read_locals()?
                var result: [VarInfo] = []
                var i = 0
                while i < raw.len():
                    result.push(VarInfo.of(raw[i], "", "unknown"))
                    i = i + 1
                Ok(result)
            nil: Err("not connected")

    fn read_arguments() -> Result<[VarInfo], text>:
        # DbgEng does not distinguish arguments from locals
        Err("read_arguments not supported by DbgEng")

    fn read_globals() -> Result<[VarInfo], text>:
        match self.client:
            Some(c):
                val raw = c.read_globals()?
                var result: [VarInfo] = []
                var i = 0
                while i < raw.len():
                    result.push(VarInfo.of(raw[i], "", "unknown"))
                    i = i + 1
                Ok(result)
            nil: Err("not connected")

    fn evaluate(expr: text) -> Result<text, text>:
        match self.client:
            Some(c): c.evaluate(expr)
            nil: Err("not connected")

    # --- Stack Inspection ---

    fn stack_trace() -> Result<[FrameInfo], text>:
        match self.client:
            Some(c):
                val raw = c.stack_trace()?
                var result: [FrameInfo] = []
                var i = 0
                while i < raw.len():
                    result.push(FrameInfo.of(i, raw[i], "", 0))
                    i = i + 1
                Ok(result)
            nil: Err("not connected")

    fn stack_depth() -> Result<i32, text>:
        match self.client:
            Some(c): c.stack_depth()
            nil: Err("not connected")

    fn select_frame(level: i32) -> Result<text, text>:
        match self.client:
            Some(c):
                val cmd = ".frame {level}"
                c.execute_command(cmd)
            nil: Err("not connected")

    fn current_location() -> Result<LocationInfo, text>:
        match self.client:
            Some(c):
                val frames = c.stack_trace()?
                if frames.len() > 0:
                    Ok(LocationInfo.at(frames[0], 0, ""))
                else:
                    Err("no frames available")
            nil:
                Err("not connected")

    # --- Memory Access ---

    fn read_memory(addr: i64, size: i32) -> Result<[i32], text>:
        match self.client:
            Some(c): c.read_memory(addr, size)
            nil: Err("not connected")

    fn write_memory(addr: i64, data: [i32]) -> Result<text, text>:
        match self.client:
            Some(c): c.write_memory(addr, data)
            nil: Err("not connected")

    # --- Register Access ---

    fn read_register(name: text) -> Result<i64, text>:
        match self.client:
            Some(c): c.read_register(name)
            nil: Err("not connected")

    fn read_all_registers() -> Result<Dict<text, i64>, text>:
        match self.client:
            Some(c): c.read_all_registers()
            nil: Err("not connected")

    fn write_register(name: text, value: i64) -> Result<text, text>:
        match self.client:
            Some(c): c.write_register(name, value)
            nil: Err("not connected")

    # --- Context Management ---

    fn clear_context() -> Result<text, text>:
        Ok("context clearing not supported (DbgEng target)")

    fn reload_program(program: text) -> Result<text, text>:
        Err("reload not supported by DbgEng adapter")

    fn set_breakpoint_rich(file: text, line: i32, condition: Option<text>,
                           hit_condition: Option<text>, log_message: Option<text>) -> Result<i32, text>:
        self.set_breakpoint(file, line)

    fn list_children(var_ref: text) -> Result<[VarInfo], text>:
        Err("nested variable expansion not supported")

    fn capabilities() -> AdapterCapabilities:
        self.capabilities

# Factory function for DbgEng adapter config
fn dbgeng_config(host: text, port: i32, program: text) -> AdapterConfig:
    AdapterConfig(
        adapter_type: "dbgeng",
        host: host,
        port: port,
        program: program,
        args: [],
        timeout_ms: 30000,
        architecture: "x86_64"
    )
