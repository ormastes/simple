# HAL volatile operations — typed MMIO read/write wrapping std.io.volatile_ops.
#
# Delegates to the existing volatile_ops extern+fallback API.
# MmioAddress carries base + offset; effective address = base + offset.

use std.io.volatile_ops.{volatile_read_u8, volatile_read_u16, volatile_read_u32, volatile_read_u64}
use std.io.volatile_ops.{volatile_write_u8, volatile_write_u16, volatile_write_u32, volatile_write_u64}
use std.io.volatile_ops.{memory_barrier, load_barrier}
use std.hal.types.{MmioAddress}

# ============================================================================
# Typed volatile reads
# ============================================================================

fn mmio_read_u8(addr: MmioAddress) -> i64:
    val effective = addr.base + addr.offset
    volatile_read_u8(effective)

fn mmio_read_u16(addr: MmioAddress) -> i64:
    val effective = addr.base + addr.offset
    volatile_read_u16(effective)

fn mmio_read_u32(addr: MmioAddress) -> i64:
    val effective = addr.base + addr.offset
    volatile_read_u32(effective)

fn mmio_read_u64(addr: MmioAddress) -> i64:
    val effective = addr.base + addr.offset
    volatile_read_u64(effective)

# ============================================================================
# Typed volatile writes
# ============================================================================

fn mmio_write_u8(addr: MmioAddress, value: i64):
    val effective = addr.base + addr.offset
    volatile_write_u8(effective, value)

fn mmio_write_u16(addr: MmioAddress, value: i64):
    val effective = addr.base + addr.offset
    volatile_write_u16(effective, value)

fn mmio_write_u32(addr: MmioAddress, value: i64):
    val effective = addr.base + addr.offset
    volatile_write_u32(effective, value)

fn mmio_write_u64(addr: MmioAddress, value: i64):
    val effective = addr.base + addr.offset
    volatile_write_u64(effective, value)

# ============================================================================
# Barrier-wrapped operations
# ============================================================================

fn mmio_read_with_barrier(addr: MmioAddress) -> i64:
    load_barrier()
    val effective = addr.base + addr.offset
    val value = volatile_read_u64(effective)
    memory_barrier()
    value

fn mmio_write_with_barrier(addr: MmioAddress, value: i64):
    val effective = addr.base + addr.offset
    volatile_write_u64(effective, value)
    memory_barrier()
