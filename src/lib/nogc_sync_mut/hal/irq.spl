# HAL IRQ — interrupt registration, enable/disable, and pending queries.
#
# Hosted/interpreter mode: stubs that always succeed.
# Compiled baremetal mode: would delegate to arch-specific NVIC/PLIC/APIC.

use std.hal.types.{IrqLine, IrqConfig}

# ============================================================================
# IRQ control
# ============================================================================

fn irq_enable(config: IrqConfig) -> Result<bool, text>:
    # Hosted stub — always succeeds. Real impl delegates to arch IRQ controller.
    val _line = config.line
    val _trigger = config.trigger
    val _priority = config.priority
    Ok(true)

fn irq_disable(line: IrqLine) -> Result<bool, text>:
    # Hosted stub — always succeeds.
    val _number = line.number
    Ok(true)

fn irq_is_pending(line: IrqLine) -> bool:
    # Hosted stub — no real IRQ hardware, always false.
    val _number = line.number
    false

fn irq_clear_pending(line: IrqLine):
    # Hosted stub — no-op.
    val _number = line.number
