# STOMP Utilities Module

# ============================================================================
# Utility Functions
# ============================================================================

# Convert frame to debug string
fn frame_to_debug_string(frame: tuple) -> text:
    val command = get_frame_command(frame)
    val headers = get_frame_headers(frame)
    val body = get_frame_body(frame)

    var parts: [text] = []
    parts.push("STOMP Frame:\n")
    parts.push("  Command: ")
    parts.push(command)
    parts.push("\n")
    parts.push("  Headers:\n")

    var i = 0
    while i < headers.len():
        val header = headers[i]
        val name = header[0]
        val value = header[1]
        parts.push("    ")
        parts.push(name)
        parts.push(": ")
        parts.push(value)
        parts.push("\n")
        i = i + 1

    parts.push("  Body: ")
    val body_preview = body.substring(0, 50)
    parts.push(body_preview)
    if body.len() > 50:
        parts.push("...")
    parts.push("\n")

    return parts.join("")

# Count frames in buffer
fn count_frames(buffer: text) -> i64:
    var count = 0
    var i = 0
    while i < buffer.len():
        val ch = buffer.substring(i, i + 1)
        if ch == "\0":
            count = count + 1
        i = i + 1
    return count

# Split buffer into individual frames
fn split_frames(buffer: text) -> list:
    var result = []
    var current_parts: [text] = []
    var i = 0

    while i < buffer.len():
        val ch = buffer.substring(i, i + 1)

        if ch == "\0":
            if current_parts.len() > 0:
                result.push(current_parts.join(""))
                current_parts = []
        else:
            current_parts.push(ch)

        i = i + 1

    return result

