# Language-facing memory-leveling intent.
#
# This module is platform-neutral: it describes Simple ownership and placement
# intent without importing SimpleOS, hardware drivers, or runtime probes.

const SIMPLE_MEMORY_OWNER_SHARED = "shared"
const SIMPLE_MEMORY_OWNER_MUT = "mut"
const SIMPLE_MEMORY_OWNER_ISO = "iso"
const SIMPLE_MEMORY_OWNER_DEVICE_HANDLE = "device_handle"

const SIMPLE_MEMORY_PLACEMENT_CPU = "cpu"
const SIMPLE_MEMORY_PLACEMENT_GPU = "gpu"
const SIMPLE_MEMORY_PLACEMENT_NIC = "nic"
const SIMPLE_MEMORY_PLACEMENT_DMA = "dma"
const SIMPLE_MEMORY_PLACEMENT_UNKNOWN = "unknown"

const SIMPLE_MEMORY_ARCH_GENERIC = "generic"
const SIMPLE_MEMORY_ARCH_X86 = "x86"
const SIMPLE_MEMORY_ARCH_ARM = "arm"
const SIMPLE_MEMORY_ARCH_RISCV = "riscv"

const SIMPLE_MEMORY_BACKEND_CPU = "cpu"
const SIMPLE_MEMORY_BACKEND_VULKAN = "vulkan"
const SIMPLE_MEMORY_BACKEND_METAL = "metal"
const SIMPLE_MEMORY_BACKEND_CUDA = "cuda"
const SIMPLE_MEMORY_BACKEND_RDMA = "rdma"
const SIMPLE_MEMORY_BACKEND_UNKNOWN = "unknown"

const SIMPLE_MEMORY_EVIDENCE_MODEL = "model"
const SIMPLE_MEMORY_EVIDENCE_REAL = "real"
const SIMPLE_MEMORY_EVIDENCE_VULKAN_READBACK = "vulkan_readback"
const SIMPLE_MEMORY_EVIDENCE_METAL_READBACK = "metal_readback"
const SIMPLE_MEMORY_EVIDENCE_CUDA_READBACK = "cuda_readback"

const SIMPLE_MEMORY_HOTNESS_HOT = "hot"
const SIMPLE_MEMORY_HOTNESS_COLD = "cold"
const SIMPLE_MEMORY_HOTNESS_UNKNOWN = "unknown"

# Shared, platform-neutral memory-leveling names.
const MEMORY_TIER_CPU_HOT = "cpu_hot"
const MEMORY_TIER_CPU_COLD = "cpu_cold"
const MEMORY_TIER_GPU_LOCAL = "gpu_local"
const MEMORY_TIER_GPU_COHERENT = "gpu_coherent"
const MEMORY_TIER_NIC_BUFFER = "nic_buffer"
const MEMORY_TIER_DMA_PINNED = "dma_pinned"
const MEMORY_TIER_SWAP_BACKED = "swap_backed"
const MEMORY_TIER_UNKNOWN = "unknown"

const MEMORY_DOMAIN_CPU = "cpu"
const MEMORY_DOMAIN_GPU = "gpu"
const MEMORY_DOMAIN_NIC = "nic"
const MEMORY_DOMAIN_DMA = "dma"
const MEMORY_DOMAIN_SWAP = "swap"
const MEMORY_DOMAIN_UNKNOWN = "unknown"

const MEMORY_PAGE_STATE_CPU_OWNED = "cpu_owned"
const MEMORY_PAGE_STATE_SYNCING_FOR_DEVICE = "syncing_for_device"
const MEMORY_PAGE_STATE_DEVICE_OWNED = "device_owned"
const MEMORY_PAGE_STATE_SYNCING_FOR_CPU = "syncing_for_cpu"
const MEMORY_PAGE_STATE_MIGRATING = "migrating"
const MEMORY_PAGE_STATE_SWAPPED = "swapped"
const MEMORY_PAGE_STATE_RELEASED = "released"
const MEMORY_PAGE_STATE_FAILED = "failed"

const MEMORY_FALLBACK_REJECT = "reject"
const MEMORY_FALLBACK_CPU = "cpu"

const MEMORY_DMA_DIRECTION_NONE = "none"
const MEMORY_DMA_DIRECTION_TO_DEVICE = "to_device"
const MEMORY_DMA_DIRECTION_FROM_DEVICE = "from_device"
const MEMORY_DMA_DIRECTION_BIDIRECTIONAL = "bidirectional"

struct MemoryTier:
    name: text
    device_visible: bool
    reclaimable: bool

struct MemoryDomain:
    name: text
    externally_visible: bool

struct MemoryPageState:
    name: text
    device_owned: bool
    reclaimable: bool

struct SimpleMemoryPlacementConfig:
    intent: SimpleMemoryIntent
    preferred_tier: MemoryTier
    fallback_tier: MemoryTier
    acceptable_backend: text
    movable: bool
    fallback_policy: text

struct MemoryLevelingPolicy:
    preferred_tier: MemoryTier
    fallback_tier: MemoryTier
    movable: bool
    swap_allowed: bool
    device_migration_allowed: bool
    minimum_resident_bytes: u64
    priority: u64
    cooldown_epochs: u64

struct MemoryAllocation:
    allocation_id: u64
    byte_length: u64
    page_count: u64
    owner_id: u64
    owner: text
    domain: MemoryDomain
    tier: MemoryTier
    state: MemoryPageState
    pin_count: u64
    in_flight_count: u64
    mapping_count: u64
    dma_direction: text
    coherent: bool
    access_epoch: u64
    cooldown_epoch: u64
    reclaimable: bool
    contiguous: bool
    physical_base: u64
    swap_slot_id: u64

struct MemoryLevelingStats:
    allocation_count: u64
    byte_count: u64
    cpu_bytes: u64
    gpu_bytes: u64
    nic_bytes: u64
    dma_bytes: u64
    swap_bytes: u64
    candidate_count: u64
    skipped_count: u64
    pin_count: u64
    in_flight_count: u64
    mapping_count: u64
    transition_count: u64
    failure_count: u64
    refault_count: u64
    cooldown_count: u64
    swap_read_count: u64
    swap_write_count: u64
    swap_error_count: u64

fn memory_tier(name: text, device_visible: bool, reclaimable: bool) -> MemoryTier:
    MemoryTier(name: name, device_visible: device_visible, reclaimable: reclaimable)

fn memory_tier_cpu_hot() -> MemoryTier:
    memory_tier(MEMORY_TIER_CPU_HOT, false, true)

fn memory_tier_cpu_cold() -> MemoryTier:
    memory_tier(MEMORY_TIER_CPU_COLD, false, true)

fn memory_tier_gpu_local() -> MemoryTier:
    memory_tier(MEMORY_TIER_GPU_LOCAL, true, false)

fn memory_tier_gpu_coherent() -> MemoryTier:
    memory_tier(MEMORY_TIER_GPU_COHERENT, true, false)

fn memory_tier_nic_buffer() -> MemoryTier:
    memory_tier(MEMORY_TIER_NIC_BUFFER, true, false)

fn memory_tier_dma_pinned() -> MemoryTier:
    memory_tier(MEMORY_TIER_DMA_PINNED, true, false)

fn memory_tier_swap_backed() -> MemoryTier:
    memory_tier(MEMORY_TIER_SWAP_BACKED, false, false)

# Compatibility helpers for the original broad tier names.
fn memory_tier_cpu() -> MemoryTier:
    memory_tier_cpu_hot()

fn memory_tier_swap() -> MemoryTier:
    memory_tier_swap_backed()

fn memory_tier_gpu() -> MemoryTier:
    memory_tier_gpu_local()

fn memory_tier_nic() -> MemoryTier:
    memory_tier_nic_buffer()

fn memory_tier_dma() -> MemoryTier:
    memory_tier_dma_pinned()

fn memory_tier_unknown() -> MemoryTier:
    memory_tier(MEMORY_TIER_UNKNOWN, false, false)

fn memory_domain(name: text, externally_visible: bool) -> MemoryDomain:
    MemoryDomain(name: name, externally_visible: externally_visible)

fn memory_domain_from_intent(intent: SimpleMemoryIntent) -> MemoryDomain:
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_GPU:
        return memory_domain(MEMORY_DOMAIN_GPU, intent.externally_visible)
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_NIC:
        return memory_domain(MEMORY_DOMAIN_NIC, intent.externally_visible)
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_DMA:
        return memory_domain(MEMORY_DOMAIN_DMA, intent.externally_visible)
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_CPU and not intent.externally_visible:
        return memory_domain(MEMORY_DOMAIN_CPU, false)
    if intent.placement == MEMORY_TIER_SWAP_BACKED:
        return memory_domain(MEMORY_DOMAIN_SWAP, false)
    memory_domain(MEMORY_DOMAIN_UNKNOWN, intent.externally_visible)

fn memory_tier_from_intent(intent: SimpleMemoryIntent) -> MemoryTier:
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_CPU:
        if intent.hotness == SIMPLE_MEMORY_HOTNESS_COLD:
            return memory_tier_cpu_cold()
        return memory_tier_cpu_hot()
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_GPU:
        return memory_tier_gpu()
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_NIC:
        return memory_tier_nic()
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_DMA:
        return memory_tier_dma()
    memory_tier_unknown()

fn memory_page_state(name: text, device_owned: bool, reclaimable: bool) -> MemoryPageState:
    MemoryPageState(name: name, device_owned: device_owned, reclaimable: reclaimable)

fn memory_page_state_from_intent(intent: SimpleMemoryIntent) -> MemoryPageState:
    if intent.placement == SIMPLE_MEMORY_PLACEMENT_CPU and not intent.externally_visible:
        return memory_page_state(MEMORY_PAGE_STATE_CPU_OWNED, false, simple_memory_intent_movable(intent))
    if intent.externally_visible:
        return memory_page_state(MEMORY_PAGE_STATE_DEVICE_OWNED, true, false)
    memory_page_state(MEMORY_PAGE_STATE_FAILED, false, false)

fn simple_memory_placement_config(intent: SimpleMemoryIntent, preferred_tier: MemoryTier, fallback_tier: MemoryTier, acceptable_backend: text, movable: bool, fallback_policy: text) -> SimpleMemoryPlacementConfig:
    SimpleMemoryPlacementConfig(
        intent: intent,
        preferred_tier: preferred_tier,
        fallback_tier: fallback_tier,
        acceptable_backend: acceptable_backend,
        movable: movable,
        fallback_policy: fallback_policy
    )

fn simple_memory_placement_config_from_intent(intent: SimpleMemoryIntent) -> SimpleMemoryPlacementConfig:
    val movable = simple_memory_intent_movable(intent)
    val fallback_tier = if movable: memory_tier_swap() else: memory_tier_unknown()
    val fallback_policy = if movable: MEMORY_FALLBACK_CPU else: MEMORY_FALLBACK_REJECT
    simple_memory_placement_config(intent, memory_tier_from_intent(intent), fallback_tier, intent.hardware_backend, movable, fallback_policy)

fn memory_leveling_policy_from_intent(intent: SimpleMemoryIntent) -> MemoryLevelingPolicy:
    val movable = simple_memory_intent_movable(intent)
    MemoryLevelingPolicy(
        preferred_tier: memory_tier_from_intent(intent),
        fallback_tier: if movable: memory_tier_swap() else: memory_tier_unknown(),
        movable: movable,
        swap_allowed: movable,
        device_migration_allowed: movable and simple_memory_intent_real_hardware(intent),
        minimum_resident_bytes: 0,
        priority: 0,
        cooldown_epochs: 0
    )

fn memory_allocation_from_intent(allocation_id: u64, byte_length: u64, page_count: u64, intent: SimpleMemoryIntent) -> MemoryAllocation:
    val tier = memory_tier_from_intent(intent)
    MemoryAllocation(
        allocation_id: allocation_id,
        byte_length: byte_length,
        page_count: page_count,
        owner_id: 0,
        owner: intent.owner,
        domain: memory_domain_from_intent(intent),
        tier: tier,
        state: memory_page_state_from_intent(intent),
        pin_count: 0,
        in_flight_count: 0,
        mapping_count: 0,
        dma_direction: if intent.externally_visible: MEMORY_DMA_DIRECTION_BIDIRECTIONAL else: MEMORY_DMA_DIRECTION_NONE,
        coherent: not intent.externally_visible,
        access_epoch: 0,
        cooldown_epoch: 0,
        reclaimable: simple_memory_intent_movable(intent),
        contiguous: false,
        physical_base: 0,
        swap_slot_id: 0
    )

fn memory_leveling_stats_empty() -> MemoryLevelingStats:
    MemoryLevelingStats(
        allocation_count: 0,
        byte_count: 0,
        cpu_bytes: 0,
        gpu_bytes: 0,
        nic_bytes: 0,
        dma_bytes: 0,
        swap_bytes: 0,
        candidate_count: 0,
        skipped_count: 0,
        pin_count: 0,
        in_flight_count: 0,
        mapping_count: 0,
        transition_count: 0,
        failure_count: 0,
        refault_count: 0,
        cooldown_count: 0,
        swap_read_count: 0,
        swap_write_count: 0,
        swap_error_count: 0
    )

struct SimpleMemoryIntent:
    owner: text
    placement: text
    hotness: text
    externally_visible: bool
    hardware_arch: text
    hardware_backend: text
    hardware_evidence: text

fn simple_memory_intent(owner: text, placement: text, hotness: text, externally_visible: bool) -> SimpleMemoryIntent:
    simple_memory_hardware_intent(owner, placement, hotness, externally_visible, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_UNKNOWN, SIMPLE_MEMORY_EVIDENCE_MODEL)

fn simple_memory_hardware_intent(owner: text, placement: text, hotness: text, externally_visible: bool, hardware_arch: text, hardware_backend: text, hardware_evidence: text) -> SimpleMemoryIntent:
    SimpleMemoryIntent(
        owner: owner,
        placement: placement,
        hotness: hotness,
        externally_visible: externally_visible,
        hardware_arch: hardware_arch,
        hardware_backend: hardware_backend,
        hardware_evidence: hardware_evidence
    )

fn simple_memory_shared_cpu_hot() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_SHARED, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_HOT, false)

fn simple_memory_mut_cpu_cold() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_MUT, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_COLD, false)

fn simple_memory_iso_cpu_cold() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_ISO, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_COLD, false)

fn simple_memory_device_gpu() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true)

fn simple_memory_network_registered() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_NIC, SIMPLE_MEMORY_HOTNESS_COLD, true)

fn simple_memory_dma_pinned() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_DMA, SIMPLE_MEMORY_HOTNESS_COLD, true)

fn simple_memory_unknown_external() -> SimpleMemoryIntent:
    simple_memory_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_UNKNOWN, SIMPLE_MEMORY_HOTNESS_UNKNOWN, true)

fn simple_memory_x86_cpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_SHARED, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_HOT, false, SIMPLE_MEMORY_ARCH_X86, SIMPLE_MEMORY_BACKEND_CPU, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_arm_cpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_SHARED, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_HOT, false, SIMPLE_MEMORY_ARCH_ARM, SIMPLE_MEMORY_BACKEND_CPU, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_riscv_cpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_SHARED, SIMPLE_MEMORY_PLACEMENT_CPU, SIMPLE_MEMORY_HOTNESS_HOT, false, SIMPLE_MEMORY_ARCH_RISCV, SIMPLE_MEMORY_BACKEND_CPU, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_vulkan_gpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_VULKAN, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_vulkan_gpu_readback_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_VULKAN, SIMPLE_MEMORY_EVIDENCE_VULKAN_READBACK)

fn simple_memory_metal_gpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_METAL, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_metal_gpu_readback_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_METAL, SIMPLE_MEMORY_EVIDENCE_METAL_READBACK)

fn simple_memory_cuda_gpu_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_CUDA, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_cuda_gpu_readback_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_GPU, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_CUDA, SIMPLE_MEMORY_EVIDENCE_CUDA_READBACK)

fn simple_memory_rdma_nic_real() -> SimpleMemoryIntent:
    simple_memory_hardware_intent(SIMPLE_MEMORY_OWNER_DEVICE_HANDLE, SIMPLE_MEMORY_PLACEMENT_NIC, SIMPLE_MEMORY_HOTNESS_COLD, true, SIMPLE_MEMORY_ARCH_GENERIC, SIMPLE_MEMORY_BACKEND_RDMA, SIMPLE_MEMORY_EVIDENCE_REAL)

fn simple_memory_intent_movable(intent: SimpleMemoryIntent) -> bool:
    intent.placement == SIMPLE_MEMORY_PLACEMENT_CPU and not intent.externally_visible

fn simple_memory_intent_real_hardware(intent: SimpleMemoryIntent) -> bool:
    intent.hardware_evidence == SIMPLE_MEMORY_EVIDENCE_REAL or intent.hardware_evidence == SIMPLE_MEMORY_EVIDENCE_VULKAN_READBACK or intent.hardware_evidence == SIMPLE_MEMORY_EVIDENCE_METAL_READBACK or intent.hardware_evidence == SIMPLE_MEMORY_EVIDENCE_CUDA_READBACK

fn simple_memory_intent_summary(intent: SimpleMemoryIntent) -> text:
    "owner={intent.owner} placement={intent.placement} hotness={intent.hotness} external={intent.externally_visible} arch={intent.hardware_arch} backend={intent.hardware_backend} evidence={intent.hardware_evidence}"
