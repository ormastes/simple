# I/O Runtime Module - Direct extern fn wrappers for common I/O operations
#
# This module provides reusable I/O functions using direct `extern fn rt_*`
# calls. It works around the broken `use app.io.{...}` module import issue
# by declaring the extern functions directly.
#
# Usage:
#   use std.io_runtime.{shell, file_write, file_read, file_exists, ...}
#
# This replaces the pattern of duplicating extern fn declarations in every
# test file and compiler module that needs I/O.


# ============================================================================
# Extern Function Declarations (runtime built-ins)
# ============================================================================

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_copy(src: text, dst: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_hash_sha256(path: text) -> text
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value_str: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_size(path: text) -> i64
extern fn sys_get_args() -> [text]
extern fn rt_exit(code: i64)
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_dir_walk(path: text) -> [text]
extern fn rt_dir_remove(path: text, recursive: bool) -> bool
extern fn rt_dir_remove_all(path: text) -> bool
extern fn rt_file_write_bytes(path: text, bytes: [u8]) -> bool
extern fn rt_dir_exists(path: text) -> bool
extern fn rt_platform_name() -> text
extern fn rt_thread_sleep(millis: i64)

# ============================================================================
# Shell Result
# ============================================================================

struct ShellResult:
    stdout: text
    stderr: text
    exit_code: i64

# ============================================================================
# Shell Execution
# ============================================================================

pub fn shell(command: text) -> ShellResult:
    val (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    ShellResult(stdout: stdout, stderr: stderr, exit_code: code)

pub fn shell_output(command: text) -> text:
    val (stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    if code == 0:
        stdout.trim()
    else:
        ""

pub fn shell_output_trimmed(command: text, default: text) -> text:
    val (stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    if code == 0:
        val trimmed = stdout.trim()
        if trimmed == "":
            return default
        return trimmed
    default

pub fn shell_bool(command: text) -> bool:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    code == 0

# ============================================================================
# File Operations
# ============================================================================

pub fn file_read(path: text) -> text:
    val content = rt_file_read_text(path)
    content ?? ""

pub fn read_file(path: text) -> text:
    file_read(path)

pub fn read_file_text(path: text) -> text:
    file_read(path)

pub fn file_write(path: text, content: text) -> bool:
    if rt_file_write_text(path, content):
        return true
    # Writing into a nonexistent directory otherwise no-ops silently
    # (bug interp_examples_dir_f64_zero_and_write_noop_2026-07-03):
    # create the missing parent directory and retry once.
    val sep_idx = path.rfind("/") ?? 0
    if sep_idx <= 0:
        return false
    val parent = path.substring(0, sep_idx)
    if rt_file_exists(parent):
        return false
    rt_dir_create_all(parent)
    rt_file_write_text(path, content)

pub fn write_file(path: text, content: text) -> bool:
    file_write(path, content)

pub fn file_exists(path: text) -> bool:
    rt_file_exists(path)

pub fn file_delete(path: text) -> bool:
    rt_file_delete(path)

pub fn remove_file_if_exists(path: text) -> bool:
    # Idempotent delete: true when the file was removed or did not exist.
    if not rt_file_exists(path):
        return true
    rt_file_delete(path)

pub fn file_copy(src: text, dst: text) -> bool:
    rt_file_copy(src, dst)

pub fn file_read_bytes(path: text) -> [u8]:
    rt_file_read_bytes(path) ?? []

pub fn file_write_bytes(path: text, bytes: [u8]) -> bool:
    rt_file_write_bytes(path, bytes)

pub fn file_hash_sha256(path: text) -> text:
    val hash = rt_file_hash_sha256(path)
    if hash.len() == 64:
        return hash
    shell_output("sha256sum '" + path + "' 2>/dev/null | awk '{print $1}'")

pub fn file_size(path: text) -> i64:
    val size = rt_file_size(path)
    if size < 0:
        return 0
    size

pub fn file_size_raw(path: text) -> i64:
    file_size(path)

# ============================================================================
# Process Execution
# ============================================================================

# NOTE (process_run_tuple_ambiguity_2026-07-17): the return tuple is labeled
# (stdout/stderr/exit_code) rather than left as a bare (text, text, i64).
# An unlabeled tuple with two repeated `text` fields trips a standalone-
# compile-mode-only ambiguity check ("anonymous multi-return tuple contains
# repeated field types; add labels to disambiguate") the moment any entry
# file does field access (`.0`/`.2`) or destructuring on this function's
# result — confirmed via a 5-line minimal repro that fails identically to
# src/app/mcp/main_lazy_json.spl's standalone compile. Labeling here is the
# true root fix: it requires no caller changes (both `.0`/`.1`/`.2` indexed
# access and `val (a, b, c) = process_run(...)` destructuring keep compiling
# and behave identically at runtime — verified with matching probes before
# this change), unlike migrating ~150 call sites (`grep -rl "use std.io_runtime.*process_run"
# src test` excluding vendor) to a struct or adding a parallel
# process_run_result API. See
# doc/08_tracking/bug/mcp_main_lazy_json_standalone_compile_process_run_tuple_ambiguity_2026-07-17.md
pub fn process_run(cmd: text, args: [text]) -> (stdout: text, stderr: text, exit_code: i64):
    rt_process_run(cmd, args)

# ============================================================================
# Environment
# ============================================================================

pub fn env_get(key: text) -> text:
    val value = rt_env_get(key)
    if value == nil:
        ""
    else:
        value

pub fn env_set(key: text, value: text) -> bool:
    rt_env_set(key, value)

pub fn cwd() -> text:
    shell_output("pwd")

pub fn home() -> text:
    rt_env_get("HOME")

# ============================================================================
# System
# ============================================================================

pub fn getpid() -> i64:
    rt_getpid()

pub fn time_now_unix_micros() -> i64:
    rt_time_now_unix_micros()

pub fn get_args() -> [text]:
    sys_get_args()

pub fn cli_arg_count() -> i64:
    sys_get_args().len()

pub fn cli_arg_at(index: i64) -> text:
    val args = sys_get_args()
    if index >= 0 and index < args.len():
        return args[index]
    ""

pub fn exit(code: i64):
    rt_exit(code)

pub fn thread_sleep(ms: i64):
    rt_thread_sleep(ms)

# ============================================================================
# Directory Operations
# ============================================================================

pub fn dir_create(path: text, recursive: bool) -> bool:
    if recursive:
        rt_dir_create_all(path)
    else:
        rt_dir_create(path, false)

pub fn dir_create_all(path: text) -> bool:
    rt_dir_create_all(path)

pub fn mkdir_p(path: text) -> bool:
    rt_dir_create_all(path)

pub fn is_dir(path: text) -> bool:
    shell_bool("test -d '{path}'")

pub fn is_file(path: text) -> bool:
    shell_bool("test -f '{path}'")

pub fn list_dir(path: text) -> [text]:
    val (stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", "ls '{path}'"])
    if code != 0:
        return []
    val trimmed = stdout.trim()
    if trimmed == "":
        return []
    trimmed.split("\n")

pub fn dir_list(path: text) -> [text]:
    rt_dir_list(path)

pub fn dir_walk(path: text) -> [text]:
    rt_dir_walk(path)

pub fn dir_remove(path: text, recursive: bool) -> bool:
    if recursive:
        rt_dir_remove_all(path)
    else:
        rt_dir_remove(path, false)

pub fn dir_remove_all(path: text) -> bool:
    rt_dir_remove_all(path)

pub fn file_append_text(path: text, content: text) -> bool:
    rt_file_append_text(path, content)

pub fn dir_exists(path: text) -> bool:
    rt_dir_exists(path)

pub fn process_spawn_async(cmd: text, args: [text]) -> i64:
    rt_process_spawn_async(cmd, args)

pub fn process_is_running(pid: i64) -> bool:
    rt_process_is_running(pid)

pub fn process_kill(pid: i64) -> bool:
    if pid <= 1:
        return false
    rt_process_kill(pid)

# ============================================================================
# Platform Detection
# ============================================================================

pub fn host_os() -> text:
    val os = shell_output("uname -s")
    if os == "Linux":
        return "linux"
    if os == "Darwin":
        return "macos"
    if os == "FreeBSD":
        return "freebsd"
    os.lower()

pub fn platform_name() -> text:
    rt_platform_name()

pub fn host_arch() -> text:
    val arch = shell_output("uname -m")
    if arch == "x86_64" or arch == "amd64":
        return "x86_64"
    if arch == "aarch64" or arch == "arm64":
        return "aarch64"
    if arch == "armv7l" or arch == "armv7" or arch == "arm":
        return "armv7"
    arch

# ============================================================================
# Exports
# ============================================================================

export shell, shell_output, shell_bool, shell_output_trimmed, ShellResult
export file_read, read_file, read_file_text, file_write, write_file, file_exists
export file_delete, file_copy, file_size, file_size_raw, file_hash_sha256
export file_read_bytes, file_write_bytes, file_append_text, remove_file_if_exists
export dir_create, dir_create_all, is_dir, is_file, list_dir, mkdir_p
export dir_list, dir_walk, dir_remove, dir_remove_all, dir_exists
export env_get, env_set, cwd, home, host_os, host_arch, platform_name
export getpid, process_kill, process_run, process_spawn_async, process_is_running
export time_now_unix_micros, get_args, cli_arg_count, cli_arg_at, exit, thread_sleep
export rt_file_write_text, rt_file_read_text
