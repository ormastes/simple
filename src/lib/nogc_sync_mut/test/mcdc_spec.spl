"""MC/DC module specification tests."""

use std.nogc_sync_mut.mcdc.*

describe "Mcdc":
    """Tests Modified Condition/Decision Coverage tracking, analysis, and reporting."""

    it "enables and disables mcdc tag":
        disable_mcdc_tag()
        expect(is_mcdc_tag_enabled()).to_equal(false)
        enable_mcdc_tag()
        expect(is_mcdc_tag_enabled()).to_equal(true)
        disable_mcdc_tag()
        expect(is_mcdc_tag_enabled()).to_equal(false)

    it "registers decisions":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("a and b", ["a", "b"], "and", "test.spl", 1)
        expect(id).to_equal(0)
        val d = get_decision(id)
        expect(d.?).to_equal(true)
        disable_mcdc_tag()

    it "tracks mcdc_and":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("x and y", ["x", "y"], "and", "t.spl", 1)

        val r1 = track_mcdc_and(id, true, true)
        expect(r1).to_equal(true)

        val r2 = track_mcdc_and(id, false, true)
        expect(r2).to_equal(false)

        val r3 = track_mcdc_and(id, true, false)
        expect(r3).to_equal(false)

        val result = analyze_mcdc(id)
        expect(result.is_covered).to_equal(true)
        expect(result.mcdc_percent).to_equal(100.0)

        disable_mcdc_tag()

    it "tracks mcdc_or":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("p or q", ["p", "q"], "or", "t.spl", 1)

        track_mcdc_or(id, false, false)
        track_mcdc_or(id, true, false)
        track_mcdc_or(id, false, true)

        val result = analyze_mcdc(id)
        expect(result.is_covered).to_equal(true)

        disable_mcdc_tag()

    it "detects incomplete mcdc":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("a and b", ["a", "b"], "and", "t.spl", 1)

        # Only one test - not enough for MC/DC
        track_mcdc_and(id, true, true)

        val result = analyze_mcdc(id)
        expect(result.is_covered).to_equal(false)
        expect(result.conditions_covered).to_equal(0)

        disable_mcdc_tag()

    it "get_decision returns nil for invalid id":
        enable_mcdc_tag()
        clear_mcdc_data()
        val d = get_decision(9999)
        expect(d.?).to_equal(false)
        disable_mcdc_tag()

    it "detects incomplete mcdc_or":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("p or q", ["p", "q"], "or", "t.spl", 1)

        # Only one test - not enough for MC/DC
        track_mcdc_or(id, true, false)

        val result = analyze_mcdc(id)
        expect(result.is_covered).to_equal(false)

        disable_mcdc_tag()

    it "tracks mcdc_and all false":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("a and b", ["a", "b"], "and", "t.spl", 1)

        val r = track_mcdc_and(id, false, false)
        expect(r).to_equal(false)

        disable_mcdc_tag()

    it "no-ops track when mcdc disabled":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("a and b", ["a", "b"], "and", "t.spl", 1)
        disable_mcdc_tag()
        track_mcdc_and(id, true, true)
        enable_mcdc_tag()
        val result = analyze_mcdc(id)
        expect(result.evaluation_count).to_equal(0)
        disable_mcdc_tag()

    it "analyze_mcdc returns uncovered for invalid id":
        enable_mcdc_tag()
        clear_mcdc_data()
        val result = analyze_mcdc(9999)
        expect(result.is_covered).to_equal(false)
        expect(result.expression).to_equal("unknown")
        disable_mcdc_tag()

    it "handles same-outcome and same-value-target conditions":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("a and b", ["a", "b"], "and", "t.spl", 1)
        track_mcdc_and(id, true, true)
        track_mcdc_and(id, true, false)
        track_mcdc_and(id, true, true)
        val result = analyze_mcdc(id)
        expect(result.conditions_covered).to_equal(1)
        disable_mcdc_tag()
