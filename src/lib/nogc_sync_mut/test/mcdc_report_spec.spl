"""MC/DC per-decision report specification.

Proves the report layer is a real measurement, not a rubber stamp:
a decision `A and (B or C)` reaches 100% MC/DC with the minimal
independence-pair-adequate vector set, and drops below 100% (naming the
now-uncovered condition) when one independence-pair vector is removed.

Short-circuit evaluation of `A and (B or C)`:
  - A always evaluated
  - B evaluated iff A
  - C evaluated iff A and not B
The `evaluated` mask below reflects that so masked conditions do not
disqualify an otherwise-valid independence pair.
"""

use std.spec.*
use std.nogc_sync_mut.mcdc.*

# Minimal MC/DC-adequate vector set for A and (B or C):
#   A-pair: (T,T,F)->T vs (F,T,F)->F   (only A differs)
#   B-pair: (T,T,F)->T vs (T,F,F)->F   (only B differs, C masked in first)
#   C-pair: (T,F,T)->T vs (T,F,F)->F   (only C differs)
fn _feed_full_set(id: i64):
    # (A=T,B=T,C=F) -> T ; C masked (A true, B true)
    record_evaluation(id, [true, true, false], [true, true, false], true)
    # (A=F,B=T,C=F) -> F ; B,C masked (A false)
    record_evaluation(id, [false, true, false], [true, false, false], false)
    # (A=T,B=F,C=F) -> F ; all evaluated
    record_evaluation(id, [true, false, false], [true, true, true], false)
    # (A=T,B=F,C=T) -> T ; all evaluated
    record_evaluation(id, [true, false, true], [true, true, true], true)

describe "MCDC report":
    """Per-decision MC/DC coverage report: covered/uncovered conditions and percentage."""

    it "reports 100% MC/DC with all conditions covered for the adequate set":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("A and (B or C)", ["A", "B", "C"], "mixed", "flight.spl", 42)
        _feed_full_set(id)

        val rep = build_decision_report(id)
        expect(rep.condition_count).to_equal(3)
        expect(rep.conditions_covered).to_equal(3)
        expect(rep.mcdc_percent).to_equal(100.0)
        assert_true(rep.is_covered)
        expect(rep.covered_conditions.len()).to_equal(3)
        expect(rep.uncovered_conditions.len()).to_equal(0)
        assert_contains(rep.covered_conditions, "A")
        assert_contains(rep.covered_conditions, "B")
        assert_contains(rep.covered_conditions, "C")
        disable_mcdc_tag()

    it "drops below 100% and names the uncovered condition when a pair is removed":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("A and (B or C)", ["A", "B", "C"], "mixed", "flight.spl", 42)
        # Omit (A=T,B=F,C=T): now C has no independence pair (C only ever
        # evaluated with value F), so condition index 2 becomes uncovered.
        record_evaluation(id, [true, true, false], [true, true, false], true)
        record_evaluation(id, [false, true, false], [true, false, false], false)
        record_evaluation(id, [true, false, false], [true, true, true], false)

        val rep = build_decision_report(id)
        expect(rep.condition_count).to_equal(3)
        expect(rep.conditions_covered).to_equal(2)
        assert_true(rep.mcdc_percent < 100.0)
        assert_false(rep.is_covered)
        expect(rep.uncovered_conditions.len()).to_equal(1)
        assert_contains(rep.uncovered_conditions, "C")
        assert_contains(rep.uncovered_indices, 2)
        # Covered set still names A and B.
        assert_contains(rep.covered_conditions, "A")
        assert_contains(rep.covered_conditions, "B")
        disable_mcdc_tag()

    it "renders a human-readable report string naming the uncovered condition":
        enable_mcdc_tag()
        clear_mcdc_data()
        val id = register_decision("A and (B or C)", ["A", "B", "C"], "mixed", "flight.spl", 42)
        record_evaluation(id, [true, true, false], [true, true, false], true)
        record_evaluation(id, [false, true, false], [true, false, false], false)
        record_evaluation(id, [true, false, false], [true, true, true], false)

        val text_report = format_decision_report(id)
        assert_contains(text_report, "A and (B or C)")
        assert_contains(text_report, "Uncovered")
        assert_contains(text_report, "C")
        disable_mcdc_tag()
