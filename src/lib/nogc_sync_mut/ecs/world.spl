# ECS World — the per-service container
#
# Services define their own `World` struct owning `WorldBase` + one
# `ComponentStore<T>` field per component type they use. This module
# provides the shared base.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.system.{Scheduler}

struct WorldBase:
    alloc: EntityAllocator
    sched: Scheduler
    tick: i64

    static fn new() -> WorldBase:
        WorldBase(
            alloc: EntityAllocator.new(),
            sched: Scheduler.new(),
            tick: 0
        )

    static fn with_capacity(capacity: i32) -> WorldBase:
        WorldBase(
            alloc: EntityAllocator.with_capacity(capacity),
            sched: Scheduler.new(),
            tick: 0
        )

    fn spawn(self) -> Entity:
        self.alloc.alloc()

    fn despawn(self, e: Entity) -> bool:
        self.alloc.free(e)

    fn is_live(self, e: Entity) -> bool:
        self.alloc.is_live(e)

    fn advance(self):
        """Bump the write-tick after a batch of component mutations."""
        self.tick = self.tick + 1

    fn now(self) -> i64:
        self.tick
