# Driver framework — shared primitive types.
#
# These types are used by every concrete driver regardless of device class.
# Concrete device classes (block, net, input, display, etc.) add their own
# typed extensions on top via their own traits (FsDriver, GpuDriver, …).

# Driver class — what kind of device the driver services.
# The manifest (Phase B) uses this to route probe callbacks.
enum DriverClass:
    Block          # block-device (AHCI, NVMe, virtio-blk)
    Char           # character-device (serial, tty)
    Net            # network interface
    Input          # keyboard, mouse, touch
    Display        # framebuffer, GPU
    Storage        # higher-level storage stack (above Block)
    Bus            # bus driver (PCI, USB, virtio-bus)
    Fs             # filesystem driver (FsDriver extension)
    Gpu            # GPU compute driver (GpuDriver extension)
    Audio          # audio codec / DSP
    Sensor         # temp / accel / light
    Timer          # HPET, APIC-timer, arch-timer
    Irq            # IRQ controller (IOAPIC, GIC, PLIC)
    Power          # ACPI, power mgmt
    Virt           # virtio generic
    Misc           # anything else

# Probe outcome — driver tells the core whether it can drive this device.
enum ProbeResult:
    Accept         # driver claims the device; proceed to attach
    Reject         # not a match; try next driver
    Defer          # match, but cannot attach yet (dependency missing)

# Driver attach / init status.
enum DriverStatus:
    Ok
    NoDevice
    NoMemory
    Busy
    Unsupported
    Timeout
    BadConfig
    DependencyMissing

# Opaque device identifier (per-class meaning; PCI BDF for Bus, MAC for Net, ...).
struct DeviceId:
    value: i64
    class: DriverClass

# Opaque per-attachment handle returned from driver_attach.
# Kernel owns the lifetime; drivers must not fabricate handles.
struct DriverHandle:
    value: i64

# Driver runtime context handed to every entry point by the kernel.
# Opaque pointer; concrete shape lives in kernel side of the loader.
struct DriverContext:
    opaque: i64

# ioctl command code — class-agnostic envelope.
struct IoctlCmd:
    code: i32
    arg:  i64

# Power-management state for suspend / resume.
enum PowerState:
    Active
    Idle
    Suspend
    Off
