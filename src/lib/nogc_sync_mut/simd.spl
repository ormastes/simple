# ============================================================================
# u8x16 Intrinsics (128-bit) — Phase 2 of SIMD int intrinsics for crypto
# (FR: doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md)
#
# Vec16u8 = 16 u8 lanes; maps to __m128i (x86 SSE2 _mm_add_epi8) /
# uint8x16_t (AArch64 NEON vaddq_u8). u8 add wraps per-lane; carry does
# NOT propagate across lane boundaries (this is the core property AES /
# AES-GCM rely on for byte-shuffle/round work).
#
# This is the Phase 2 SEED — type carrier + add op only. simd_aes_round /
# simd_xor_u8x16 / simd_shuffle_u8x16 / PCLMUL are deferred to follow-up
# waves (they require AES-NI exposure / different intrinsics).
# ============================================================================

"""
16-lane u8 vector (128-bit SSE/NEON register).
Maps to __m128i (x86) or uint8x16_t (ARM).
"""
struct Vec16u8:
    u0: u8
    u1: u8
    u2: u8
    u3: u8
    u4: u8
    u5: u8
    u6: u8
    u7: u8
    u8_: u8
    u9: u8
    u10: u8
    u11: u8
    u12: u8
    u13: u8
    u14: u8
    u15: u8

impl Vec16u8:
    static fn splat(value: u8) -> Vec16u8:
        """Create vector with all 16 lanes set to value."""
        Vec16u8(
            u0: value, u1: value, u2: value, u3: value,
            u4: value, u5: value, u6: value, u7: value,
            u8_: value, u9: value, u10: value, u11: value,
            u12: value, u13: value, u14: value, u15: value,
        )

    static fn from_array(arr: [u8]) -> Vec16u8:
        """Create from array (must have 16+ elements)."""
        Vec16u8(
            u0: arr[0], u1: arr[1], u2: arr[2], u3: arr[3],
            u4: arr[4], u5: arr[5], u6: arr[6], u7: arr[7],
            u8_: arr[8], u9: arr[9], u10: arr[10], u11: arr[11],
            u12: arr[12], u13: arr[13], u14: arr[14], u15: arr[15],
        )

    static fn zero() -> Vec16u8:
        """Zero vector."""
        Vec16u8(
            u0: 0, u1: 0, u2: 0, u3: 0,
            u4: 0, u5: 0, u6: 0, u7: 0,
            u8_: 0, u9: 0, u10: 0, u11: 0,
            u12: 0, u13: 0, u14: 0, u15: 0,
        )

    fn to_array() -> [u8]:
        """Convert to array."""
        [
            self.u0, self.u1, self.u2, self.u3,
            self.u4, self.u5, self.u6, self.u7,
            self.u8_, self.u9, self.u10, self.u11,
            self.u12, self.u13, self.u14, self.u15,
        ]

extern fn rt_simd_add_u8x16(a: Vec16u8, b: Vec16u8) -> Vec16u8

fn simd_add_u8x16(a: Vec16u8, b: Vec16u8) -> Vec16u8:
    """Lane-wise wrapping add of two u8x16 vectors. Carry does NOT
    propagate across lane boundaries (each lane wraps mod 256).
    """
    rt_simd_add_u8x16(a, b)

# ============================================================================
# AES Round Intrinsics (Phase 2, matches Intel _mm_aesenc_si128 ordering)
# ============================================================================

extern fn rt_simd_aes_round_u8x16(state: Vec16u8, key: Vec16u8) -> Vec16u8
extern fn rt_simd_aes_round_last_u8x16(state: Vec16u8, key: Vec16u8) -> Vec16u8

fn simd_aes_round(state: Vec16u8, key: Vec16u8) -> Vec16u8:
    """One regular AES encryption round, matching `_mm_aesenc_si128`:
    `MixColumns(SubBytes(ShiftRows(state))) XOR key`.

    Caller is responsible for the initial AddRoundKey (XOR plaintext
    with K0) before round 1, and for using `simd_aes_round_last` for
    the final round (Nr) which omits MixColumns. Key expansion lives
    in the AES helpers in `std.os.crypto.aes` — this primitive only
    exposes the round step.
    """
    rt_simd_aes_round_u8x16(state, key)

fn simd_aes_round_last(state: Vec16u8, key: Vec16u8) -> Vec16u8:
    """One final AES encryption round, matching `_mm_aesenclast_si128`:
    `SubBytes(ShiftRows(state)) XOR key`.

    Use for the final (Nr) round of an AES-128/192/256 encrypt. The
    MixColumns step is intentionally skipped per FIPS 197 §5.1.
    """
    rt_simd_aes_round_last_u8x16(state, key)

# ============================================================================
# u64x2 Intrinsics + PCLMUL (128-bit) — Phase 3 of SIMD int intrinsics
# (FR: doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md)
#
# Vec2u64 = 2 u64 lanes; maps to __m128i (x86 SSE2) / uint64x2_t (AArch64
# NEON). The carryless multiply (PCLMUL) primitive is the inner kernel for
# GHASH (AES-GCM authentication tag) and Polyval. Carry does NOT propagate
# across u64 lane boundaries.
#
# Two pieces needed besides the PCLMUL itself: a u64x2 XOR (used by GHASH
# accumulation) and lo/hi accessors for round-tripping product halves back
# into Simple-side arithmetic.
# ============================================================================

"""
2-lane u64 vector (128-bit SSE/NEON register).
Maps to __m128i (x86) or uint64x2_t (ARM).
Lane 0 is the low 64 bits; lane 1 is the high 64 bits — matching the
Intel/`_mm_set_epi64x(hi, lo)` convention so that `clmul_lo` operates on
both inputs' lane 0 and `clmul_hi` operates on both inputs' lane 1.
"""
struct Vec2u64:
    lo: u64
    hi: u64

impl Vec2u64:
    static fn new(lo: u64, hi: u64) -> Vec2u64:
        """Create a Vec2u64 with the given low (lane 0) and high (lane 1)
        64-bit lanes. Mirrors `_mm_set_epi64x(hi, lo)`."""
        Vec2u64(lo: lo, hi: hi)

    static fn zero() -> Vec2u64:
        """Zero vector."""
        Vec2u64(lo: 0, hi: 0)

    fn lane_lo() -> u64:
        """Return the low 64-bit lane (lane 0)."""
        self.lo

    fn lane_hi() -> u64:
        """Return the high 64-bit lane (lane 1)."""
        self.hi

extern fn rt_simd_vec2u64_new(lo: u64, hi: u64) -> Vec2u64
extern fn rt_simd_vec2u64_lo(v: Vec2u64) -> u64
extern fn rt_simd_vec2u64_hi(v: Vec2u64) -> u64

extern fn rt_simd_clmul_lo_u64(a: Vec2u64, b: Vec2u64) -> Vec2u64
extern fn rt_simd_clmul_hi_u64(a: Vec2u64, b: Vec2u64) -> Vec2u64
extern fn rt_simd_xor_u64x2(a: Vec2u64, b: Vec2u64) -> Vec2u64

fn simd_clmul_lo_u64(a: Vec2u64, b: Vec2u64) -> Vec2u64:
    """Carryless multiply of `a.lo` and `b.lo` (both u64), returning the
    128-bit product as a Vec2u64 (lane 0 = low 64 bits, lane 1 = high 64
    bits of the product). Matches Intel `_mm_clmulepi64_si128(a, b, 0x00)`.

    This is the GF(2)[x] polynomial multiplication primitive used by
    GHASH (AES-GCM authentication) and Polyval. Carry does NOT propagate
    in carryless multiplication — every output bit is an XOR of selected
    AND products of input bits.
    """
    rt_simd_clmul_lo_u64(a, b)

fn simd_clmul_hi_u64(a: Vec2u64, b: Vec2u64) -> Vec2u64:
    """Carryless multiply of `a.hi` and `b.hi` (both u64), returning the
    128-bit product as a Vec2u64. Matches Intel
    `_mm_clmulepi64_si128(a, b, 0x11)`.

    See `simd_clmul_lo_u64` for the GF(2)[x] semantics.
    """
    rt_simd_clmul_hi_u64(a, b)

fn simd_xor_u64x2(a: Vec2u64, b: Vec2u64) -> Vec2u64:
    """Bitwise XOR of two 2-lane u64 vectors. Maps to `_mm_xor_si128`
    on x86_64 SSE2 and `veorq_u64` on AArch64 NEON. Used to accumulate
    GHASH/Polyval products into a running 128-bit state.
    """
    rt_simd_xor_u64x2(a, b)

# ============================================================================
# Horizontal Operations
# ============================================================================

extern fn rt_simd_hadd_f32x4(a: Vec4f) -> f32
extern fn rt_simd_hmax_f32x4(a: Vec4f) -> f32
extern fn rt_simd_hmin_f32x4(a: Vec4f) -> f32

fn simd_hadd_f32x4(a: Vec4f) -> f32:
    """Horizontal add: sum all elements of vector."""
    rt_simd_hadd_f32x4(a)

fn simd_hmax_f32x4(a: Vec4f) -> f32:
    """Horizontal max: find maximum element of vector."""
    rt_simd_hmax_f32x4(a)

fn simd_hmin_f32x4(a: Vec4f) -> f32:
    """Horizontal min: find minimum element of vector."""
    rt_simd_hmin_f32x4(a)

# ============================================================================
# Exports
# ============================================================================
