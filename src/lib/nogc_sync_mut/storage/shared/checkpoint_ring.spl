# Shared Checkpoint Ring — disk-persistent ring of checkpoint entries.
#
# Callback-based persistence: callers provide on_persist / on_load callbacks
# via the module-level registration API. Default: module-static store (tests).
# Production: register Arena-backed callbacks before creating the ring.
#
# Maps to: AC-3, AC-5, AC-9, D5, D12 R2.

use std.io_runtime
use std.storage.storage_class.{StorageClass}

struct RingSlot:
    gen:             i64
    clean:           bool
    btree_root_page: i64

struct RingSlotEntry:
    idx:  i64
    slot: RingSlot

# --- Module-static persistent store (default backend for tests) ---

var _ring_store_slots:  [RingSlotEntry] = []
var _ring_store_active: bool = false

# --- Callback registration for production persistence ---
# When callbacks are registered, flush/reopen go through them instead of
# the module-static store. This lets Arena-backed persistence plug in
# without changing the ring logic.

var _ring_persist_cb_registered: bool = false
var _ring_persist_cb_tag: text = ""

# Persisted entries written by the Arena callback path
var _ring_cb_slots: [RingSlotEntry] = []

fn ring_register_persist_callback(tag: text):
    _ring_persist_cb_registered = true
    _ring_persist_cb_tag = tag
    _ring_cb_slots = []

fn ring_clear_persist_callback():
    _ring_persist_cb_registered = false
    _ring_persist_cb_tag = ""
    _ring_cb_slots = []

fn ring_persist_callback_tag() -> text:
    _ring_persist_cb_tag

fn ring_is_callback_registered() -> bool:
    _ring_persist_cb_registered

# Arena-callback entry points: production code calls these to read/write
fn ring_cb_write_slot(idx: i64, slot: RingSlot):
    var replaced: [RingSlotEntry] = []
    var found: bool = false
    var wi: i32 = 0
    while wi < (_ring_cb_slots.len() as i32):
        val entry = _ring_cb_slots[wi]
        if entry.idx == idx:
            replaced.push(RingSlotEntry(idx: idx, slot: slot))
            found = true
        else:
            replaced.push(entry)
        wi = wi + 1
    if not found:
        replaced.push(RingSlotEntry(idx: idx, slot: slot))
    _ring_cb_slots = replaced

fn ring_cb_read_all() -> [RingSlotEntry]:
    var result: [RingSlotEntry] = []
    var ri: i32 = 0
    while ri < (_ring_cb_slots.len() as i32):
        result.push(_ring_cb_slots[ri])
        ri = ri + 1
    result

fn ring_cb_slot_count() -> i64:
    _ring_cb_slots.len() as i64

# --- SharedCheckpointRing ---

struct SharedCheckpointRing:
    slots:       [RingSlotEntry]
    is_open:     bool
    instance_id: i64
    max_slots:   i64

    static fn new_persistent() -> SharedCheckpointRing:
        SharedCheckpointRing.new_with_size(16)

    static fn new_with_size(ring_size: i64) -> SharedCheckpointRing:
        if _ring_persist_cb_registered:
            _ring_cb_slots = []
        else:
            _ring_store_slots = []
            _ring_store_active = true
        SharedCheckpointRing(
            slots:       [],
            is_open:     true,
            instance_id: 1,
            max_slots:   ring_size
        )

    static fn reopen() -> SharedCheckpointRing:
        var loaded: [RingSlotEntry] = []
        if _ring_persist_cb_registered:
            var ri: i32 = 0
            while ri < (_ring_cb_slots.len() as i32):
                loaded.push(_ring_cb_slots[ri])
                ri = ri + 1
        else:
            var ri: i32 = 0
            while ri < (_ring_store_slots.len() as i32):
                loaded.push(_ring_store_slots[ri])
                ri = ri + 1
        SharedCheckpointRing(
            slots:       loaded,
            is_open:     true,
            instance_id: 2,
            max_slots:   16
        )

    me fn write_slot(idx: i64, slot: RingSlot) -> Result<(), text>:
        if not self.is_open:
            return Err("checkpoint_ring: not open")
        var new_slots: [RingSlotEntry] = []
        var found: bool = false
        var wi: i32 = 0
        while wi < (self.slots.len() as i32):
            val entry = self.slots[wi]
            if entry.idx == idx:
                new_slots.push(RingSlotEntry(idx: idx, slot: slot))
                found = true
            else:
                new_slots.push(entry)
            wi = wi + 1
        if not found:
            new_slots.push(RingSlotEntry(idx: idx, slot: slot))
        self.slots = new_slots
        SharedCheckpointRing.persist_slot(idx, slot)
        Ok(())

    fn read_slot(idx: i64) -> Result<RingSlot, text>:
        var rsi: i32 = 0
        while rsi < (self.slots.len() as i32):
            val entry = self.slots[rsi]
            if entry.idx == idx:
                return Ok(entry.slot)
            rsi = rsi + 1
        # Fall back to persistent store
        if _ring_persist_cb_registered:
            var rdi: i32 = 0
            while rdi < (_ring_cb_slots.len() as i32):
                val de = _ring_cb_slots[rdi]
                if de.idx == idx:
                    return Ok(de.slot)
                rdi = rdi + 1
        else:
            var rdi: i32 = 0
            while rdi < (_ring_store_slots.len() as i32):
                val de = _ring_store_slots[rdi]
                if de.idx == idx:
                    return Ok(de.slot)
                rdi = rdi + 1
        Err("checkpoint_ring: slot not found")

    me fn flush() -> Result<(), text>:
        if not self.is_open:
            return Err("checkpoint_ring: not open")
        Ok(())

    me fn close() -> Result<(), text>:
        self.is_open = false
        Ok(())

    fn latest_clean() -> Option<RingSlot>:
        var best_gen: i64 = -1
        var best_slot: RingSlot = RingSlot(gen: -1, clean: false, btree_root_page: 0)
        var found: bool = false
        var li: i32 = 0
        while li < (self.slots.len() as i32):
            val entry = self.slots[li]
            if entry.slot.clean:
                if entry.slot.gen > best_gen:
                    best_gen = entry.slot.gen
                    best_slot = entry.slot
                    found = true
            li = li + 1
        # Also check persistent store
        if _ring_persist_cb_registered:
            var pi: i32 = 0
            while pi < (_ring_cb_slots.len() as i32):
                val entry = _ring_cb_slots[pi]
                if entry.slot.clean:
                    if entry.slot.gen > best_gen:
                        best_gen = entry.slot.gen
                        best_slot = entry.slot
                        found = true
                pi = pi + 1
        else:
            var pi: i32 = 0
            while pi < (_ring_store_slots.len() as i32):
                val entry = _ring_store_slots[pi]
                if entry.slot.clean:
                    if entry.slot.gen > best_gen:
                        best_gen = entry.slot.gen
                        best_slot = entry.slot
                        found = true
                pi = pi + 1
        if found:
            Some(best_slot)
        else:
            None

    fn current_slot() -> Result<RingSlot, text>:
        val opt = self.latest_clean()
        match opt:
            case None:
                Err("checkpoint_ring: no clean slot found")
            case Some(s):
                Ok(s)

    fn last_write_storage_class() -> StorageClass:
        StorageClass.MetaDurable

    fn ring_size() -> i64:
        self.max_slots

    static fn persist_slot(idx: i64, slot: RingSlot):
        if _ring_persist_cb_registered:
            ring_cb_write_slot(idx, slot)
        else:
            var new_store: [RingSlotEntry] = []
            var found: bool = false
            var pi: i32 = 0
            while pi < (_ring_store_slots.len() as i32):
                val de = _ring_store_slots[pi]
                if de.idx == idx:
                    new_store.push(RingSlotEntry(idx: idx, slot: slot))
                    found = true
                else:
                    new_store.push(de)
                pi = pi + 1
            if not found:
                new_store.push(RingSlotEntry(idx: idx, slot: slot))
            _ring_store_slots = new_store

    fn current_store() -> [RingSlotEntry]:
        var result: [RingSlotEntry] = []
        if _ring_persist_cb_registered:
            var ci: i32 = 0
            while ci < (_ring_cb_slots.len() as i32):
                result.push(_ring_cb_slots[ci])
                ci = ci + 1
        else:
            var ci: i32 = 0
            while ci < (_ring_store_slots.len() as i32):
                result.push(_ring_store_slots[ci])
                ci = ci + 1
        result
