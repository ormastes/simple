# Shared Checkpoint Ring — disk-persistent ring of checkpoint entries.
#
# Callback-based persistence: callers provide on_persist / on_load callbacks
# via the module-level registration API. Default: module-static store (tests).
# Production: register Arena-backed callbacks before creating the ring.
#
# Maps to: AC-3, AC-5, AC-9, D5, D12 R2.

use std.io_runtime
use std.storage.storage_class.{StorageClass}
use os.services.block_device.{BlockDevice}

extern fn rt_bytes_alloc(len: i64) -> [u8]

struct RingSlot:
    gen:             i64
    clean:           bool
    btree_root_page: i64

struct RingSlotEntry:
    idx:  i64
    slot: RingSlot

# --- Module-static persistent store (default backend for tests) ---

var _ring_store_slots:  [RingSlotEntry] = []
var _ring_store_active: bool = false

# --- Callback registration for production persistence ---
# When callbacks are registered, flush/reopen go through them instead of
# the module-static store. This lets Arena-backed persistence plug in
# without changing the ring logic.

var _ring_persist_cb_registered: bool = false
var _ring_persist_cb_tag: text = ""

# Persisted entries written by the Arena callback path
var _ring_cb_slots: [RingSlotEntry] = []

# --- BlockDevice-backed persistence for callbacks ---
var _ring_dev_store: [BlockDevice] = []
var _ring_dev_ready: bool = false
var _ring_dev_base:  i64 = 0

fn ring_set_block_device(dev: BlockDevice, base_block: i64):
    if _ring_dev_ready:
        _ring_dev_store[0] = dev
    else:
        _ring_dev_store.push(dev)
        _ring_dev_ready = true
    _ring_dev_base = base_block

fn ring_has_block_device() -> bool:
    _ring_dev_ready

fn _ring_write_sector(lba: u64, data: [u8]) -> bool:
    var dev = _ring_dev_store[0]
    val r = dev.write_sector(lba, data)
    _ring_dev_store[0] = dev
    r.is_ok()

fn _ring_read_sector(lba: u64) -> [u8]:
    val sz = _ring_dev_store[0].sector_size() as i64
    var buf = rt_bytes_alloc(sz)
    val r = _ring_dev_store[0].read_sector(lba, buf)
    if r.is_ok(): buf else: []

fn _ring_put_i64_le(buf: [u8], off: i64, v: i64) -> [u8]:
    buf[off]     = (v % 256) as u8
    buf[off + 1] = ((v / 256) % 256) as u8
    buf[off + 2] = ((v / 65536) % 256) as u8
    buf[off + 3] = ((v / 16777216) % 256) as u8
    val hi = v / 4294967296
    buf[off + 4] = (hi % 256) as u8
    buf[off + 5] = ((hi / 256) % 256) as u8
    buf[off + 6] = ((hi / 65536) % 256) as u8
    buf[off + 7] = ((hi / 16777216) % 256) as u8
    buf

fn _ring_get_i64_le(buf: [u8], off: i64) -> i64:
    val b0 = buf[off] as i64
    val b1 = buf[off + 1] as i64
    val b2 = buf[off + 2] as i64
    val b3 = buf[off + 3] as i64
    val b4 = buf[off + 4] as i64
    val b5 = buf[off + 5] as i64
    val b6 = buf[off + 6] as i64
    val b7 = buf[off + 7] as i64
    b0 + b1 * 256 + b2 * 65536 + b3 * 16777216 + (b4 + b5 * 256 + b6 * 65536 + b7 * 16777216) * 4294967296

fn _ring_flush_to_device():
    if not _ring_dev_ready:
        return
    val sz = _ring_dev_store[0].sector_size() as i64
    val n = _ring_cb_slots.len() as i64
    var hdr = rt_bytes_alloc(sz)
    hdr = _ring_put_i64_le(hdr, 0, n)
    val base_lba = _ring_dev_base as u64
    val _ = _ring_write_sector(base_lba, hdr)
    val entry_size: i64 = 25
    val entries_per_sector = sz / entry_size
    var ri: i64 = 0
    var sec_idx: i64 = 1
    while ri < n:
        var sec_buf = rt_bytes_alloc(sz)
        var pos: i64 = 0
        var count: i64 = 0
        while count < entries_per_sector and ri < n:
            val entry = _ring_cb_slots[ri]
            sec_buf = _ring_put_i64_le(sec_buf, pos, entry.idx)
            sec_buf = _ring_put_i64_le(sec_buf, pos + 8, entry.slot.gen)
            sec_buf[pos + 16] = if entry.slot.clean: 1u8 else: 0u8
            sec_buf = _ring_put_i64_le(sec_buf, pos + 17, entry.slot.btree_root_page)
            pos = pos + entry_size
            ri = ri + 1
            count = count + 1
        val lba = ((_ring_dev_base + sec_idx) as u64)
        val _ = _ring_write_sector(lba, sec_buf)
        sec_idx = sec_idx + 1

fn _ring_load_from_device():
    if not _ring_dev_ready:
        return
    val sz = _ring_dev_store[0].sector_size() as i64
    val base_lba = _ring_dev_base as u64
    val hdr = _ring_read_sector(base_lba)
    if hdr.len() < 8:
        return
    val n = _ring_get_i64_le(hdr, 0)
    _ring_cb_slots = []
    val entry_size: i64 = 25
    val entries_per_sector = sz / entry_size
    var ri: i64 = 0
    var sec_idx: i64 = 1
    while ri < n:
        val lba = ((_ring_dev_base + sec_idx) as u64)
        val sec_buf = _ring_read_sector(lba)
        if sec_buf.len() == 0:
            return
        var pos: i64 = 0
        var count: i64 = 0
        while count < entries_per_sector and ri < n:
            val slot_idx = _ring_get_i64_le(sec_buf, pos)
            val slot_gen = _ring_get_i64_le(sec_buf, pos + 8)
            val slot_clean = sec_buf[pos + 16] != 0u8
            val slot_root = _ring_get_i64_le(sec_buf, pos + 17)
            _ring_cb_slots.push(RingSlotEntry(
                idx: slot_idx,
                slot: RingSlot(gen: slot_gen, clean: slot_clean, btree_root_page: slot_root)
            ))
            pos = pos + entry_size
            ri = ri + 1
            count = count + 1
        sec_idx = sec_idx + 1

fn ring_register_persist_callback(tag: text):
    _ring_persist_cb_registered = true
    _ring_persist_cb_tag = tag
    _ring_cb_slots = []

fn ring_clear_persist_callback():
    _ring_persist_cb_registered = false
    _ring_persist_cb_tag = ""
    _ring_cb_slots = []

fn ring_persist_callback_tag() -> text:
    _ring_persist_cb_tag

fn ring_is_callback_registered() -> bool:
    _ring_persist_cb_registered

# Arena-callback entry points: production code calls these to read/write
fn ring_cb_write_slot(idx: i64, slot: RingSlot):
    var replaced: [RingSlotEntry] = []
    var found: bool = false
    var wi: i32 = 0
    while wi < (_ring_cb_slots.len() as i32):
        val entry = _ring_cb_slots[wi]
        if entry.idx == idx:
            replaced.push(RingSlotEntry(idx: idx, slot: slot))
            found = true
        else:
            replaced.push(entry)
        wi = wi + 1
    if not found:
        replaced.push(RingSlotEntry(idx: idx, slot: slot))
    _ring_cb_slots = replaced

fn ring_cb_read_all() -> [RingSlotEntry]:
    var result: [RingSlotEntry] = []
    var ri: i32 = 0
    while ri < (_ring_cb_slots.len() as i32):
        result.push(_ring_cb_slots[ri])
        ri = ri + 1
    result

fn ring_cb_slot_count() -> i64:
    _ring_cb_slots.len() as i64

# --- SharedCheckpointRing ---

struct SharedCheckpointRing:
    slots:       [RingSlotEntry]
    is_open:     bool
    instance_id: i64
    max_slots:   i64

    static fn new_persistent() -> SharedCheckpointRing:
        SharedCheckpointRing.new_with_size(16)

    static fn new_with_size(ring_size: i64) -> SharedCheckpointRing:
        if _ring_persist_cb_registered:
            _ring_cb_slots = []
        else:
            _ring_store_slots = []
            _ring_store_active = true
        SharedCheckpointRing(
            slots:       [],
            is_open:     true,
            instance_id: 1,
            max_slots:   ring_size
        )

    static fn reopen() -> SharedCheckpointRing:
        var loaded: [RingSlotEntry] = []
        if _ring_persist_cb_registered:
            _ring_load_from_device()
            var ri: i32 = 0
            while ri < (_ring_cb_slots.len() as i32):
                loaded.push(_ring_cb_slots[ri])
                ri = ri + 1
        else:
            var ri: i32 = 0
            while ri < (_ring_store_slots.len() as i32):
                loaded.push(_ring_store_slots[ri])
                ri = ri + 1
        SharedCheckpointRing(
            slots:       loaded,
            is_open:     true,
            instance_id: 2,
            max_slots:   16
        )

    me fn write_slot(idx: i64, slot: RingSlot) -> Result<(), text>:
        if not self.is_open:
            return Err("checkpoint_ring: not open")
        var new_slots: [RingSlotEntry] = []
        var found: bool = false
        var wi: i32 = 0
        while wi < (self.slots.len() as i32):
            val entry = self.slots[wi]
            if entry.idx == idx:
                new_slots.push(RingSlotEntry(idx: idx, slot: slot))
                found = true
            else:
                new_slots.push(entry)
            wi = wi + 1
        if not found:
            new_slots.push(RingSlotEntry(idx: idx, slot: slot))
        self.slots = new_slots
        SharedCheckpointRing.persist_slot(idx, slot)
        Ok(())

    fn read_slot(idx: i64) -> Result<RingSlot, text>:
        var rsi: i32 = 0
        while rsi < (self.slots.len() as i32):
            val entry = self.slots[rsi]
            if entry.idx == idx:
                return Ok(entry.slot)
            rsi = rsi + 1
        # Fall back to persistent store
        if _ring_persist_cb_registered:
            var rdi: i32 = 0
            while rdi < (_ring_cb_slots.len() as i32):
                val de = _ring_cb_slots[rdi]
                if de.idx == idx:
                    return Ok(de.slot)
                rdi = rdi + 1
        else:
            var rdi: i32 = 0
            while rdi < (_ring_store_slots.len() as i32):
                val de = _ring_store_slots[rdi]
                if de.idx == idx:
                    return Ok(de.slot)
                rdi = rdi + 1
        Err("checkpoint_ring: slot not found")

    me fn flush() -> Result<(), text>:
        if not self.is_open:
            return Err("checkpoint_ring: not open")
        Ok(())

    me fn close() -> Result<(), text>:
        self.is_open = false
        Ok(())

    fn latest_clean() -> Option<RingSlot>:
        var best_gen: i64 = -1
        var best_slot: RingSlot = RingSlot(gen: -1, clean: false, btree_root_page: 0)
        var found: bool = false
        var li: i32 = 0
        while li < (self.slots.len() as i32):
            val entry = self.slots[li]
            if entry.slot.clean:
                if entry.slot.gen > best_gen:
                    best_gen = entry.slot.gen
                    best_slot = entry.slot
                    found = true
            li = li + 1
        # Also check persistent store
        if _ring_persist_cb_registered:
            var pi: i32 = 0
            while pi < (_ring_cb_slots.len() as i32):
                val entry = _ring_cb_slots[pi]
                if entry.slot.clean:
                    if entry.slot.gen > best_gen:
                        best_gen = entry.slot.gen
                        best_slot = entry.slot
                        found = true
                pi = pi + 1
        else:
            var pi: i32 = 0
            while pi < (_ring_store_slots.len() as i32):
                val entry = _ring_store_slots[pi]
                if entry.slot.clean:
                    if entry.slot.gen > best_gen:
                        best_gen = entry.slot.gen
                        best_slot = entry.slot
                        found = true
                pi = pi + 1
        if found:
            Some(best_slot)
        else:
            None

    fn current_slot() -> Result<RingSlot, text>:
        val opt = self.latest_clean()
        match opt:
            case None:
                Err("checkpoint_ring: no clean slot found")
            case Some(s):
                Ok(s)

    fn last_write_storage_class() -> StorageClass:
        StorageClass.MetaDurable

    fn ring_size() -> i64:
        self.max_slots

    static fn persist_slot(idx: i64, slot: RingSlot):
        if _ring_persist_cb_registered:
            ring_cb_write_slot(idx, slot)
            _ring_flush_to_device()
        else:
            var new_store: [RingSlotEntry] = []
            var found: bool = false
            var pi: i32 = 0
            while pi < (_ring_store_slots.len() as i32):
                val de = _ring_store_slots[pi]
                if de.idx == idx:
                    new_store.push(RingSlotEntry(idx: idx, slot: slot))
                    found = true
                else:
                    new_store.push(de)
                pi = pi + 1
            if not found:
                new_store.push(RingSlotEntry(idx: idx, slot: slot))
            _ring_store_slots = new_store

    fn current_store() -> [RingSlotEntry]:
        var result: [RingSlotEntry] = []
        if _ring_persist_cb_registered:
            var ci: i32 = 0
            while ci < (_ring_cb_slots.len() as i32):
                result.push(_ring_cb_slots[ci])
                ci = ci + 1
        else:
            var ci: i32 = 0
            while ci < (_ring_store_slots.len() as i32):
                result.push(_ring_store_slots[ci])
                ci = ci + 1
        result
