# Shared Intent Log — disk-persistent log of intent records.
#
# Callback-based persistence: callers register on_persist / on_load callbacks
# via the module-level API. Default: module-static store (tests).
# Production: register Arena-backed callbacks before creating the log.
#
# R1 HIGH-risk gap: records must survive a simulated remount.
# Maps to: AC-3, AC-5, AC-9, D5, D12 R1.

use std.io_runtime
use std.storage.shared.wal.{WalRecord, WAL_RECORD_COMMIT, WAL_RECORD_DATA}
use std.storage.storage_class.{StorageClass}
use std.fs_driver.block_device.{BlockDevice}

extern fn rt_bytes_alloc(len: i64) -> [u8]

struct IntentLogRecord:
    txn_id:    i64
    lsn:       i64
    committed: bool

struct IntentLogHead:
    lsn:      i64
    tail_lsn: i64

# --- Module-static persistent store (default backend for tests) ---

var _intent_store_records: [IntentLogRecord] = []
var _intent_store_head:    i64 = 0
var _intent_store_active:  bool = false

# --- Callback registration for production persistence ---

var _intent_persist_cb_registered: bool = false
var _intent_persist_cb_tag: text = ""

# Arena-callback backing store
var _intent_cb_records: [IntentLogRecord] = []
var _intent_cb_head:    i64 = 0

# --- BlockDevice-backed persistence for callbacks ---
var _intent_dev_store: [BlockDevice] = []
var _intent_dev_ready: bool = false
var _intent_dev_base:  i64 = 0

fn intent_set_block_device(dev: BlockDevice, base_block: i64):
    if _intent_dev_ready:
        _intent_dev_store[0] = dev
    else:
        _intent_dev_store.push(dev)
        _intent_dev_ready = true
    _intent_dev_base = base_block

fn intent_has_block_device() -> bool:
    _intent_dev_ready

fn _intent_write_sector(lba: u64, data: [u8]) -> bool:
    var dev = _intent_dev_store[0]
    val r = dev.write_sector(lba, data)
    _intent_dev_store[0] = dev
    r.is_ok()

fn _intent_read_sector(lba: u64) -> [u8]:
    val r = _intent_dev_store[0].read_sector(lba)
    if r.is_ok(): r.unwrap() else: []

fn _intent_put_i64_le(buf: [u8], off: i64, v: i64) -> [u8]:
    buf[off]     = (v % 256) as u8
    buf[off + 1] = ((v / 256) % 256) as u8
    buf[off + 2] = ((v / 65536) % 256) as u8
    buf[off + 3] = ((v / 16777216) % 256) as u8
    val hi = v / 4294967296
    buf[off + 4] = (hi % 256) as u8
    buf[off + 5] = ((hi / 256) % 256) as u8
    buf[off + 6] = ((hi / 65536) % 256) as u8
    buf[off + 7] = ((hi / 16777216) % 256) as u8
    buf

fn _intent_get_i64_le(buf: [u8], off: i64) -> i64:
    val b0 = buf[off] as i64
    val b1 = buf[off + 1] as i64
    val b2 = buf[off + 2] as i64
    val b3 = buf[off + 3] as i64
    val b4 = buf[off + 4] as i64
    val b5 = buf[off + 5] as i64
    val b6 = buf[off + 6] as i64
    val b7 = buf[off + 7] as i64
    b0 + b1 * 256 + b2 * 65536 + b3 * 16777216 + (b4 + b5 * 256 + b6 * 65536 + b7 * 16777216) * 4294967296

fn _intent_flush_to_device():
    if not _intent_dev_ready:
        return
    val sz = _intent_dev_store[0].sector_size() as i64
    val n = _intent_cb_records.len() as i64
    var hdr = rt_bytes_alloc(sz)
    hdr = _intent_put_i64_le(hdr, 0, n)
    hdr = _intent_put_i64_le(hdr, 8, _intent_cb_head)
    val base_lba = _intent_dev_base as u64
    val _ = _intent_write_sector(base_lba, hdr)
    val rec_per_sector = sz / 17
    var ri: i64 = 0
    var sec_idx: i64 = 1
    while ri < n:
        var sec_buf = rt_bytes_alloc(sz)
        var pos: i64 = 0
        var count: i64 = 0
        while count < rec_per_sector and ri < n:
            val rec = _intent_cb_records[ri]
            sec_buf = _intent_put_i64_le(sec_buf, pos, rec.txn_id)
            sec_buf = _intent_put_i64_le(sec_buf, pos + 8, rec.lsn)
            sec_buf[pos + 16] = if rec.committed: 1u8 else: 0u8
            pos = pos + 17
            ri = ri + 1
            count = count + 1
        val lba = ((_intent_dev_base + sec_idx) as u64)
        val _ = _intent_write_sector(lba, sec_buf)
        sec_idx = sec_idx + 1

fn _intent_load_from_device():
    if not _intent_dev_ready:
        return
    val sz = _intent_dev_store[0].sector_size() as i64
    val base_lba = _intent_dev_base as u64
    val hdr = _intent_read_sector(base_lba)
    if hdr.len() < 16:
        return
    val n = _intent_get_i64_le(hdr, 0)
    val head = _intent_get_i64_le(hdr, 8)
    _intent_cb_head = head
    _intent_cb_records = []
    val rec_per_sector = sz / 17
    var ri: i64 = 0
    var sec_idx: i64 = 1
    while ri < n:
        val lba = ((_intent_dev_base + sec_idx) as u64)
        val sec_buf = _intent_read_sector(lba)
        if sec_buf.len() == 0:
            return
        var pos: i64 = 0
        var count: i64 = 0
        while count < rec_per_sector and ri < n:
            val txn_id = _intent_get_i64_le(sec_buf, pos)
            val lsn = _intent_get_i64_le(sec_buf, pos + 8)
            val committed = sec_buf[pos + 16] != 0u8
            _intent_cb_records.push(IntentLogRecord(txn_id: txn_id, lsn: lsn, committed: committed))
            pos = pos + 17
            ri = ri + 1
            count = count + 1
        sec_idx = sec_idx + 1

fn intent_register_persist_callback(tag: text):
    _intent_persist_cb_registered = true
    _intent_persist_cb_tag = tag
    _intent_cb_records = []
    _intent_cb_head = 0

fn intent_clear_persist_callback():
    _intent_persist_cb_registered = false
    _intent_persist_cb_tag = ""
    _intent_cb_records = []
    _intent_cb_head = 0

fn intent_persist_callback_tag() -> text:
    _intent_persist_cb_tag

fn intent_is_callback_registered() -> bool:
    _intent_persist_cb_registered

# Arena-callback entry points
fn intent_cb_write_record(rec: IntentLogRecord):
    _intent_cb_records.push(rec)

fn intent_cb_write_head(lsn: i64):
    _intent_cb_head = lsn

fn intent_cb_read_all() -> [IntentLogRecord]:
    var result: [IntentLogRecord] = []
    for rec in _intent_cb_records:
        result.push(rec)
    result

fn intent_cb_read_head() -> i64:
    _intent_cb_head

fn intent_cb_record_count() -> i64:
    _intent_cb_records.len() as i64

# --- SharedIntentLog ---

struct SharedIntentLog:
    records:      [IntentLogRecord]
    head_lsn:     i64
    is_open:      bool

    static fn new_persistent() -> SharedIntentLog:
        if _intent_persist_cb_registered:
            _intent_cb_records = []
            _intent_cb_head = 0
        else:
            _intent_store_records = []
            _intent_store_head = 0
            _intent_store_active = true
        SharedIntentLog(
            records:  [],
            head_lsn: 0,
            is_open:  true
        )

    static fn reopen() -> SharedIntentLog:
        var loaded: [IntentLogRecord] = []
        var loaded_head: i64 = 0
        if _intent_persist_cb_registered:
            _intent_load_from_device()
            for rec in _intent_cb_records:
                loaded.push(rec)
            loaded_head = _intent_cb_head
        else:
            for rec in _intent_store_records:
                loaded.push(rec)
            loaded_head = _intent_store_head
        SharedIntentLog(
            records:  loaded,
            head_lsn: loaded_head,
            is_open:  true
        )

    me fn append(rec: IntentLogRecord) -> Result<(), text>:
        if not self.is_open:
            return Err("intent_log: not open")
        self.records.push(rec)
        Ok(())

    me fn flush() -> Result<(), text>:
        if not self.is_open:
            return Err("intent_log: not open")
        if _intent_persist_cb_registered:
            _intent_cb_records = []
            for rec in self.records:
                _intent_cb_records.push(rec)
            _intent_cb_head = self.head_lsn
            _intent_flush_to_device()
        else:
            _intent_store_records = []
            for rec in self.records:
                _intent_store_records.push(rec)
            _intent_store_head = self.head_lsn
        Ok(())

    me fn close() -> Result<(), text>:
        self.is_open = false
        Ok(())

    fn scan_all() -> Result<[IntentLogRecord], text>:
        var result: [IntentLogRecord] = []
        for rec in self.records:
            result.push(rec)
        Ok(result)

    fn scan_committed() -> Result<[IntentLogRecord], text>:
        var result: [IntentLogRecord] = []
        for rec in self.records:
            if rec.committed:
                result.push(rec)
        Ok(result)

    fn get_tail_lsn() -> i64:
        var max_lsn: i64 = 0
        for rec in self.records:
            if rec.lsn > max_lsn:
                max_lsn = rec.lsn
        max_lsn

    fn head_pointer() -> IntentLogHead:
        IntentLogHead(lsn: self.head_lsn, tail_lsn: self.get_tail_lsn())

    fn head() -> Result<IntentLogHead, text>:
        Ok(IntentLogHead(lsn: self.head_lsn, tail_lsn: self.get_tail_lsn()))

    fn last_write_storage_class() -> StorageClass:
        StorageClass.MetaDurable

    me fn set_head(lsn: i64):
        self.head_lsn = lsn
