# BTree<V> — CLRS B-tree keyed by BTreeKey { a: i64, b: i64 }.
#
# Extracted from dbfs_engine/ns_btree.spl and nvfs/core/pmap_btree.spl.
# Both consumers use two-i64 composite keys with lexicographic ordering.
# Value type V is generic: DBFS uses BTreeValue, NVFS uses PmapBTreeEntry.
#
# Node-pool representation avoids recursive struct definitions: children are
# indices (i64) into BTree.nodes.
#
# Invariants:
#   fanout = minimum degree t (parameter to constructor).
#   max_keys = 2*fanout - 1
#   Deletion: top-down proactive fix-up (CLRS-style).

use std.io_runtime

struct BTreeKey:
    a: i64
    b: i64

struct BTreeNode<V>:
    keys:     [BTreeKey]
    vals:     [V]
    children: [i64]
    is_leaf:  bool

    static fn new_leaf() -> BTreeNode<V>:
        BTreeNode<V>(keys: [], vals: [], children: [], is_leaf: true)

    static fn new_internal() -> BTreeNode<V>:
        BTreeNode<V>(keys: [], vals: [], children: [], is_leaf: false)

struct BTreeSnapshot:
    gen: i64

struct BTreePredEntry<V>:
    key: BTreeKey
    val: V

struct BTree<V>:
    nodes:    [BTreeNode<V>]
    fanout:   i64
    next_gen: i64

    static fn new(fanout: i64) -> BTree<V>:
        val root = BTreeNode<V>.new_leaf()
        BTree<V>(nodes: [root], fanout: fanout, next_gen: 1)

    fn cmp_key(a: BTreeKey, b: BTreeKey) -> i64:
        if a.a < b.a:
            return -1
        if a.a > b.a:
            return 1
        if a.b < b.b:
            return -1
        if a.b > b.b:
            return 1
        0

    me fn replace_node(idx: i64, node: BTreeNode<V>):
        var new_nodes: [BTreeNode<V>] = []
        var i: i32 = 0
        while i < me.nodes.len() as i32:
            if i as i64 == idx:
                new_nodes.push(node)
            else:
                new_nodes.push(me.nodes[i])
            i = i + 1
        me.nodes = new_nodes

    fn lookup(key: BTreeKey) -> Option<V>:
        self.lookup_in_node(0, key)

    fn lookup_in_node(node_idx: i64, key: BTreeKey) -> Option<V>:
        val node = self.nodes[node_idx as i32]
        var i: i32 = 0
        while i < node.keys.len() as i32:
            val c = self.cmp_key(key, node.keys[i])
            if c == 0:
                return Some(node.vals[i])
            if c < 0:
                if node.is_leaf:
                    return None
                return self.lookup_in_node(node.children[i], key)
            i = i + 1
        if node.is_leaf:
            None
        else:
            self.lookup_in_node(node.children[node.keys.len() as i32], key)

    fn current_gen() -> i64:
        self.next_gen - 1

    me fn swap_nodes(a: i64, b: i64):
        val node_a = me.nodes[a as i32]
        val node_b = me.nodes[b as i32]
        me.replace_node(a, node_b)
        me.replace_node(b, node_a)

    me fn remap_children(node_idx: i64, old_child: i64, new_child: i64):
        val node = me.nodes[node_idx as i32]
        var new_ch: [i64] = []
        var ci: i32 = 0
        while ci < node.children.len() as i32:
            if node.children[ci] == old_child:
                new_ch.push(new_child)
            else if node.children[ci] == new_child:
                new_ch.push(old_child)
            else:
                new_ch.push(node.children[ci])
            ci = ci + 1
        val updated = BTreeNode<V>(
            keys:     node.keys,
            vals:     node.vals,
            children: new_ch,
            is_leaf:  node.is_leaf
        )
        me.replace_node(node_idx, updated)

    me fn insert(key: BTreeKey, value: V) -> Result<(), text>:
        me.next_gen = me.next_gen + 1
        val max_keys = (2 * me.fanout - 1) as i32
        if me.nodes[0].keys.len() as i32 == max_keys:
            val tmp_idx = me.nodes.len() as i64
            me.nodes.push(BTreeNode<V>.new_internal())
            var tmp_root = me.nodes[tmp_idx as i32]
            tmp_root.children.push(0)
            me.replace_node(tmp_idx, tmp_root)
            me.split_child(tmp_idx, 0, 0)
            # Now tmp_idx is the real root; swap with node 0 so root stays at 0
            me.swap_nodes(0, tmp_idx)
            # Fix children of new node-0 (was tmp_idx): they pointed to old-0
            # which is now at tmp_idx, and possibly to a sibling
            me.remap_children(0, tmp_idx, 0)
            # Also fix: node-0's children may reference 0 meaning "old root left half"
            # After swap, old node-0 content is at tmp_idx. Children of new root (now 0)
            # that pointed to 0 should now point to tmp_idx
            # remap_children already swapped 0<->tmp_idx in children, which is correct
            me.insert_non_full(0, key, value)
        else:
            me.insert_non_full(0, key, value)
        Ok(())

    me fn insert_non_full(node_idx: i64, key: BTreeKey, value: V):
        val node = me.nodes[node_idx as i32]
        val n = node.keys.len() as i32
        if node.is_leaf:
            var i: i32 = 0
            var found_dup: bool = false
            while i < n:
                val c = me.cmp_key(key, node.keys[i])
                if c == 0:
                    var new_vals: [V] = []
                    var vi: i32 = 0
                    while vi < n:
                        if vi == i:
                            new_vals.push(value)
                        else:
                            new_vals.push(node.vals[vi])
                        vi = vi + 1
                    val updated = BTreeNode<V>(
                        keys:     node.keys,
                        vals:     new_vals,
                        children: node.children,
                        is_leaf:  node.is_leaf
                    )
                    me.replace_node(node_idx, updated)
                    found_dup = true
                    i = n
                else:
                    i = i + 1
            if not found_dup:
                var pos: i32 = n
                var pi: i32 = 0
                while pi < n:
                    val c = me.cmp_key(key, node.keys[pi])
                    if c < 0:
                        pos = pi
                        pi = n
                    else:
                        pi = pi + 1
                var new_keys: [BTreeKey] = []
                var new_vals: [V] = []
                var ki: i32 = 0
                while ki < n:
                    if ki == pos:
                        new_keys.push(key)
                        new_vals.push(value)
                    new_keys.push(node.keys[ki])
                    new_vals.push(node.vals[ki])
                    ki = ki + 1
                if pos == n:
                    new_keys.push(key)
                    new_vals.push(value)
                val updated = BTreeNode<V>(
                    keys:     new_keys,
                    vals:     new_vals,
                    children: node.children,
                    is_leaf:  node.is_leaf
                )
                me.replace_node(node_idx, updated)
        else:
            val node2 = me.nodes[node_idx as i32]
            val n2 = node2.keys.len() as i32
            var j: i32 = 0
            var found_dup2: bool = false
            while j < n2:
                val c = me.cmp_key(key, node2.keys[j])
                if c == 0:
                    var new_vals2: [V] = []
                    var vi2: i32 = 0
                    while vi2 < n2:
                        if vi2 == j:
                            new_vals2.push(value)
                        else:
                            new_vals2.push(node2.vals[vi2])
                        vi2 = vi2 + 1
                    val updated2 = BTreeNode<V>(
                        keys:     node2.keys,
                        vals:     new_vals2,
                        children: node2.children,
                        is_leaf:  node2.is_leaf
                    )
                    me.replace_node(node_idx, updated2)
                    found_dup2 = true
                    j = n2
                else:
                    j = j + 1
            if not found_dup2:
                var ci: i32 = n2
                var k: i32 = 0
                val node3 = me.nodes[node_idx as i32]
                while k < n2:
                    val c = me.cmp_key(key, node3.keys[k])
                    if c < 0:
                        ci = k
                        k = n2
                    else:
                        k = k + 1
                val child_idx = me.nodes[node_idx as i32].children[ci]
                val max_keys = (2 * me.fanout - 1) as i32
                if me.nodes[child_idx as i32].keys.len() as i32 == max_keys:
                    me.split_child(node_idx, ci as i64, child_idx)
                    val c2 = me.cmp_key(key, me.nodes[node_idx as i32].keys[ci])
                    if c2 > 0:
                        val new_child = me.nodes[node_idx as i32].children[(ci + 1)]
                        me.insert_non_full(new_child, key, value)
                    else if c2 == 0:
                        val node4 = me.nodes[node_idx as i32]
                        var new_vals3: [V] = []
                        var vi3: i32 = 0
                        while vi3 < node4.keys.len() as i32:
                            if vi3 == ci:
                                new_vals3.push(value)
                            else:
                                new_vals3.push(node4.vals[vi3])
                            vi3 = vi3 + 1
                        val updated3 = BTreeNode<V>(
                            keys:     node4.keys,
                            vals:     new_vals3,
                            children: node4.children,
                            is_leaf:  node4.is_leaf
                        )
                        me.replace_node(node_idx, updated3)
                    else:
                        val same_child = me.nodes[node_idx as i32].children[ci]
                        me.insert_non_full(same_child, key, value)
                else:
                    me.insert_non_full(child_idx, key, value)

    me fn split_child(parent_idx: i64, ci: i64, child_idx: i64):
        val t = me.fanout
        val child = me.nodes[child_idx as i32]
        val mid = t as i32 - 1

        var sibling = if child.is_leaf:
            BTreeNode<V>.new_leaf()
        else:
            BTreeNode<V>.new_internal()

        val median_key = child.keys[mid]
        val median_val = child.vals[mid]

        var si: i32 = mid + 1
        while si < child.keys.len() as i32:
            sibling.keys.push(child.keys[si])
            sibling.vals.push(child.vals[si])
            si = si + 1
        if not child.is_leaf:
            var sci: i32 = mid + 1
            while sci <= child.keys.len() as i32:
                sibling.children.push(child.children[sci])
                sci = sci + 1

        var new_child_keys: [BTreeKey] = []
        var new_child_vals: [V] = []
        var new_child_children: [i64] = []
        var ki: i32 = 0
        while ki < mid:
            new_child_keys.push(child.keys[ki])
            new_child_vals.push(child.vals[ki])
            ki = ki + 1
        if not child.is_leaf:
            var cci: i32 = 0
            while cci <= mid:
                new_child_children.push(child.children[cci])
                cci = cci + 1
        val updated_child = BTreeNode<V>(
            keys:     new_child_keys,
            vals:     new_child_vals,
            children: new_child_children,
            is_leaf:  child.is_leaf
        )
        me.replace_node(child_idx, updated_child)

        val sibling_idx = me.nodes.len() as i64
        me.nodes.push(sibling)

        val parent = me.nodes[parent_idx as i32]
        var new_pkeys: [BTreeKey] = []
        var new_pvals: [V] = []
        var new_pchildren: [i64] = []
        var pi: i32 = 0
        while pi < parent.keys.len() as i32:
            if pi as i64 == ci:
                new_pkeys.push(median_key)
                new_pvals.push(median_val)
            new_pkeys.push(parent.keys[pi])
            new_pvals.push(parent.vals[pi])
            pi = pi + 1
        if ci >= parent.keys.len() as i64:
            new_pkeys.push(median_key)
            new_pvals.push(median_val)
        var ci2: i32 = 0
        while ci2 <= parent.keys.len() as i32:
            new_pchildren.push(parent.children[ci2])
            if ci2 as i64 == ci:
                new_pchildren.push(sibling_idx)
            ci2 = ci2 + 1
        val updated_parent = BTreeNode<V>(
            keys:     new_pkeys,
            vals:     new_pvals,
            children: new_pchildren,
            is_leaf:  parent.is_leaf
        )
        me.replace_node(parent_idx, updated_parent)

    me fn borrow_from_left(parent_idx: i64, i: i64):
        val parent = me.nodes[parent_idx as i32]
        val left_idx = parent.children[(i as i32) - 1]
        val right_idx = parent.children[i as i32]
        val left = me.nodes[left_idx as i32]
        val right = me.nodes[right_idx as i32]
        val sep_pos = (i as i32) - 1

        # Build new right: prepend separator from parent, then existing keys
        var new_rkeys: [BTreeKey] = []
        var new_rvals: [V] = []
        new_rkeys.push(parent.keys[sep_pos])
        new_rvals.push(parent.vals[sep_pos])
        var ri: i32 = 0
        while ri < right.keys.len() as i32:
            new_rkeys.push(right.keys[ri])
            new_rvals.push(right.vals[ri])
            ri = ri + 1
        var new_rch: [i64] = []
        if not right.is_leaf:
            # Prepend last child of left sibling
            new_rch.push(left.children[left.children.len() as i32 - 1])
            var rci: i32 = 0
            while rci < right.children.len() as i32:
                new_rch.push(right.children[rci])
                rci = rci + 1
        val updated_right = BTreeNode<V>(
            keys: new_rkeys, vals: new_rvals,
            children: new_rch, is_leaf: right.is_leaf
        )
        me.replace_node(right_idx, updated_right)

        # Update parent: replace separator with last key of left sibling
        val last_left = left.keys.len() as i32 - 1
        var new_pkeys: [BTreeKey] = []
        var new_pvals: [V] = []
        var pi: i32 = 0
        while pi < parent.keys.len() as i32:
            if pi == sep_pos:
                new_pkeys.push(left.keys[last_left])
                new_pvals.push(left.vals[last_left])
            else:
                new_pkeys.push(parent.keys[pi])
                new_pvals.push(parent.vals[pi])
            pi = pi + 1
        val updated_parent = BTreeNode<V>(
            keys: new_pkeys, vals: new_pvals,
            children: parent.children, is_leaf: parent.is_leaf
        )
        me.replace_node(parent_idx, updated_parent)

        # Shrink left sibling: remove last key (and last child if internal)
        var new_lkeys: [BTreeKey] = []
        var new_lvals: [V] = []
        var li: i32 = 0
        while li < last_left:
            new_lkeys.push(left.keys[li])
            new_lvals.push(left.vals[li])
            li = li + 1
        var new_lch: [i64] = []
        if not left.is_leaf:
            var lci: i32 = 0
            while lci < left.children.len() as i32 - 1:
                new_lch.push(left.children[lci])
                lci = lci + 1
        val updated_left = BTreeNode<V>(
            keys: new_lkeys, vals: new_lvals,
            children: new_lch, is_leaf: left.is_leaf
        )
        me.replace_node(left_idx, updated_left)

    me fn borrow_from_right(parent_idx: i64, i: i64):
        val parent = me.nodes[parent_idx as i32]
        val left_idx = parent.children[i as i32]
        val right_idx = parent.children[(i as i32) + 1]
        val left = me.nodes[left_idx as i32]
        val right = me.nodes[right_idx as i32]
        val sep_pos = i as i32

        # Build new left: append separator from parent
        var new_lkeys: [BTreeKey] = []
        var new_lvals: [V] = []
        var li: i32 = 0
        while li < left.keys.len() as i32:
            new_lkeys.push(left.keys[li])
            new_lvals.push(left.vals[li])
            li = li + 1
        new_lkeys.push(parent.keys[sep_pos])
        new_lvals.push(parent.vals[sep_pos])
        var new_lch: [i64] = []
        if not left.is_leaf:
            var lci: i32 = 0
            while lci < left.children.len() as i32:
                new_lch.push(left.children[lci])
                lci = lci + 1
            # Append first child of right sibling
            new_lch.push(right.children[0])
        val updated_left = BTreeNode<V>(
            keys: new_lkeys, vals: new_lvals,
            children: new_lch, is_leaf: left.is_leaf
        )
        me.replace_node(left_idx, updated_left)

        # Update parent: replace separator with first key of right sibling
        var new_pkeys: [BTreeKey] = []
        var new_pvals: [V] = []
        var pi: i32 = 0
        while pi < parent.keys.len() as i32:
            if pi == sep_pos:
                new_pkeys.push(right.keys[0])
                new_pvals.push(right.vals[0])
            else:
                new_pkeys.push(parent.keys[pi])
                new_pvals.push(parent.vals[pi])
            pi = pi + 1
        val updated_parent = BTreeNode<V>(
            keys: new_pkeys, vals: new_pvals,
            children: parent.children, is_leaf: parent.is_leaf
        )
        me.replace_node(parent_idx, updated_parent)

        # Shrink right sibling: remove first key (and first child if internal)
        var new_rkeys: [BTreeKey] = []
        var new_rvals: [V] = []
        var ri: i32 = 1
        while ri < right.keys.len() as i32:
            new_rkeys.push(right.keys[ri])
            new_rvals.push(right.vals[ri])
            ri = ri + 1
        var new_rch: [i64] = []
        if not right.is_leaf:
            var rci: i32 = 1
            while rci < right.children.len() as i32:
                new_rch.push(right.children[rci])
                rci = rci + 1
        val updated_right = BTreeNode<V>(
            keys: new_rkeys, vals: new_rvals,
            children: new_rch, is_leaf: right.is_leaf
        )
        me.replace_node(right_idx, updated_right)

    me fn merge_children(parent_idx: i64, i: i64):
        val parent = me.nodes[parent_idx as i32]
        val left_idx = parent.children[i as i32]
        val right_idx = parent.children[(i as i32) + 1]
        val left = me.nodes[left_idx as i32]
        val right = me.nodes[right_idx as i32]

        # Build merged node: left keys + separator + right keys
        var merged_keys: [BTreeKey] = []
        var merged_vals: [V] = []
        var li: i32 = 0
        while li < left.keys.len() as i32:
            merged_keys.push(left.keys[li])
            merged_vals.push(left.vals[li])
            li = li + 1
        merged_keys.push(parent.keys[i as i32])
        merged_vals.push(parent.vals[i as i32])
        var ri: i32 = 0
        while ri < right.keys.len() as i32:
            merged_keys.push(right.keys[ri])
            merged_vals.push(right.vals[ri])
            ri = ri + 1
        var merged_ch: [i64] = []
        if not left.is_leaf:
            var lci: i32 = 0
            while lci < left.children.len() as i32:
                merged_ch.push(left.children[lci])
                lci = lci + 1
            var rci: i32 = 0
            while rci < right.children.len() as i32:
                merged_ch.push(right.children[rci])
                rci = rci + 1
        val merged = BTreeNode<V>(
            keys: merged_keys, vals: merged_vals,
            children: merged_ch, is_leaf: left.is_leaf
        )
        me.replace_node(left_idx, merged)

        # Remove separator and right child pointer from parent
        var new_pkeys: [BTreeKey] = []
        var new_pvals: [V] = []
        var pi: i32 = 0
        while pi < parent.keys.len() as i32:
            if pi != i as i32:
                new_pkeys.push(parent.keys[pi])
                new_pvals.push(parent.vals[pi])
            pi = pi + 1
        var new_pch: [i64] = []
        var ci: i32 = 0
        while ci < parent.children.len() as i32:
            if ci != (i as i32) + 1:
                new_pch.push(parent.children[ci])
            ci = ci + 1
        val updated_parent = BTreeNode<V>(
            keys: new_pkeys, vals: new_pvals,
            children: new_pch, is_leaf: parent.is_leaf
        )
        me.replace_node(parent_idx, updated_parent)

    me fn ensure_min_keys(parent_idx: i64, child_i: i64):
        val t = me.fanout
        val parent = me.nodes[parent_idx as i32]
        val child_idx = parent.children[child_i as i32]
        val child = me.nodes[child_idx as i32]
        if child.keys.len() as i64 >= t:
            return
        # Child has fewer than t keys; try borrow, else merge
        val has_left = child_i > 0
        val has_right = child_i < (parent.keys.len() as i64)
        if has_left:
            val left_sib_idx = parent.children[(child_i as i32) - 1]
            val left_sib = me.nodes[left_sib_idx as i32]
            if left_sib.keys.len() as i64 >= t:
                me.borrow_from_left(parent_idx, child_i)
                return
        if has_right:
            val right_sib_idx = parent.children[(child_i as i32) + 1]
            val right_sib = me.nodes[right_sib_idx as i32]
            if right_sib.keys.len() as i64 >= t:
                me.borrow_from_right(parent_idx, child_i)
                return
        # Must merge
        if has_left:
            me.merge_children(parent_idx, child_i - 1)
        else:
            me.merge_children(parent_idx, child_i)

    me fn delete(key: BTreeKey) -> Result<(), text>:
        me.delete_from_node(0, key)
        # Root collapse: if root is internal with 0 keys and 1 child, pull child up
        val root = me.nodes[0]
        if (not root.is_leaf) and root.keys.len() == 0 and root.children.len() > 0:
            val only_child_idx = root.children[0]
            val child_node = me.nodes[only_child_idx as i32]
            me.replace_node(0, child_node)
        Ok(())

    me fn delete_from_node(node_idx: i64, key: BTreeKey) -> bool:
        var node = me.nodes[node_idx as i32]
        var i: i32 = 0
        while i < node.keys.len() as i32:
            val c = me.cmp_key(key, me.nodes[node_idx as i32].keys[i])
            if c == 0:
                if me.nodes[node_idx as i32].is_leaf:
                    val nd = me.nodes[node_idx as i32]
                    var new_keys: [BTreeKey] = []
                    var new_vals: [V] = []
                    var ki: i32 = 0
                    while ki < nd.keys.len() as i32:
                        if ki != i:
                            new_keys.push(nd.keys[ki])
                            new_vals.push(nd.vals[ki])
                        ki = ki + 1
                    val updated = BTreeNode<V>(
                        keys:     new_keys,
                        vals:     new_vals,
                        children: nd.children,
                        is_leaf:  nd.is_leaf
                    )
                    me.replace_node(node_idx, updated)
                    return true
                else:
                    # Internal node: ensure left child has >= t keys before descent
                    me.ensure_min_keys(node_idx, i as i64)
                    # Re-read node after rebalancing (key may have moved)
                    val nd_after = me.nodes[node_idx as i32]
                    # Re-find the key in this node (it may have shifted or merged)
                    var fi: i32 = 0
                    var found_at: i32 = -1
                    while fi < nd_after.keys.len() as i32:
                        val fc = me.cmp_key(key, nd_after.keys[fi])
                        if fc == 0:
                            found_at = fi
                            fi = nd_after.keys.len() as i32
                        else:
                            fi = fi + 1
                    if found_at < 0:
                        # Key moved into child during merge; re-search from this node
                        return me.delete_from_node(node_idx, key)
                    val left_child = nd_after.children[found_at]
                    val pred = me.get_max_leaf_entry(left_child)
                    val nd2 = me.nodes[node_idx as i32]
                    var new_keys2: [BTreeKey] = []
                    var new_vals2: [V] = []
                    var ki2: i32 = 0
                    while ki2 < nd2.keys.len() as i32:
                        if ki2 == found_at:
                            new_keys2.push(pred.key)
                            new_vals2.push(pred.val)
                        else:
                            new_keys2.push(nd2.keys[ki2])
                            new_vals2.push(nd2.vals[ki2])
                        ki2 = ki2 + 1
                    val updated2 = BTreeNode<V>(
                        keys:     new_keys2,
                        vals:     new_vals2,
                        children: nd2.children,
                        is_leaf:  nd2.is_leaf
                    )
                    me.replace_node(node_idx, updated2)
                    return me.delete_from_node(left_child, pred.key)
            if c < 0:
                if me.nodes[node_idx as i32].is_leaf:
                    return false
                # Ensure child has >= t keys before descending
                me.ensure_min_keys(node_idx, i as i64)
                # After rebalancing, child may have shifted due to merge-left
                # Re-read parent and find correct child to descend into
                val par_after = me.nodes[node_idx as i32]
                # Find correct child: scan for the position where key < keys[j]
                var j: i32 = 0
                while j < par_after.keys.len() as i32:
                    val cj = me.cmp_key(key, par_after.keys[j])
                    if cj < 0:
                        val ch = par_after.children[j]
                        return me.delete_from_node(ch, key)
                    if cj == 0:
                        # Key is now at this position in parent (merged up)
                        return me.delete_from_node(node_idx, key)
                    j = j + 1
                val last_ch = par_after.children[par_after.keys.len() as i32]
                return me.delete_from_node(last_ch, key)
            i = i + 1
        if me.nodes[node_idx as i32].is_leaf:
            return false
        # Key is greater than all keys; descend into last child
        val last_ci = me.nodes[node_idx as i32].keys.len() as i64
        me.ensure_min_keys(node_idx, last_ci)
        # After rebalancing, re-read parent and find correct child
        val par_end = me.nodes[node_idx as i32]
        var ej: i32 = 0
        while ej < par_end.keys.len() as i32:
            val cej = me.cmp_key(key, par_end.keys[ej])
            if cej < 0:
                val ech = par_end.children[ej]
                return me.delete_from_node(ech, key)
            if cej == 0:
                return me.delete_from_node(node_idx, key)
            ej = ej + 1
        val end_ch = par_end.children[par_end.keys.len() as i32]
        me.delete_from_node(end_ch, key)

    fn get_max_leaf_entry(node_idx: i64) -> BTreePredEntry<V>:
        val node = self.nodes[node_idx as i32]
        if node.is_leaf:
            val last = node.keys.len() as i32 - 1
            return BTreePredEntry<V>(
                key: node.keys[last],
                val: node.vals[last]
            )
        val last_child = node.children[node.keys.len() as i32]
        self.get_max_leaf_entry(last_child)

    fn range_scan(lo: BTreeKey, hi: BTreeKey) -> Result<[(BTreeKey, V)], text>:
        var result: [(BTreeKey, V)] = []
        self.collect_scan(0, lo, hi, result)
        Ok(result)

    fn collect_scan(node_idx: i64, lo: BTreeKey, hi: BTreeKey, result: [(BTreeKey, V)]):
        val node = self.nodes[node_idx as i32]
        var i: i32 = 0
        while i < node.keys.len() as i32:
            if not node.is_leaf:
                if self.cmp_key(lo, node.keys[i]) <= 0:
                    self.collect_scan(node.children[i], lo, hi, result)
            val c_lo = self.cmp_key(node.keys[i], lo)
            val c_hi = self.cmp_key(node.keys[i], hi)
            if c_lo >= 0 and c_hi <= 0:
                result.push((node.keys[i], node.vals[i]))
            i = i + 1
        if not node.is_leaf:
            if node.keys.len() > 0:
                if self.cmp_key(lo, node.keys[node.keys.len() as i32 - 1]) <= 0:
                    self.collect_scan(node.children[node.keys.len() as i32], lo, hi, result)

    fn snapshot() -> BTreeSnapshot:
        BTreeSnapshot(gen: self.next_gen - 1)

    fn node_count() -> i64:
        self.nodes.len()
