# Shared Storage Primitives — cross-feature data structures.
#
# Extracted from dbfs_engine and nvfs/core to eliminate structural duplication.
#
# Submodules:
#   wal             — SharedWal: append-only WAL with DURABLE_GROUP_COMMIT
#   btree           — BTree<V>: CLRS B-tree keyed by BTreeKey { a: i64, b: i64 }
#   checkpoint_ring — SharedCheckpointRing: callback-persistent checkpoint ring
#   intent_log      — SharedIntentLog: callback-persistent intent log
#
# Consumers:
#   dbfs_engine/wal.spl             → type DbfsWal = SharedWal
#   dbfs_engine/ns_btree.spl        → type NsBTree = BTree<BTreeValue>
#   dbfs_engine/checkpoint_ring.spl → facade over SharedCheckpointRing
#   dbfs_engine/intent_log.spl      → facade over SharedIntentLog

use std.io_runtime
