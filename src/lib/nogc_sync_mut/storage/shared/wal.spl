# SharedWal — Write-Ahead Log shared across dbfs_engine and simple_db.
#
# Append-only log of WalRecord entries, each tagged with a monotonically
# increasing LSN. The only fsync point is flush_wal() which implements
# DURABLE_GROUP_COMMIT (one flush per committed txn group).

use std.io_runtime

val WAL_RECORD_DATA:   i64 = 1
val WAL_RECORD_META:   i64 = 2
val WAL_RECORD_COMMIT: i64 = 3
val WAL_RECORD_ABORT:  i64 = 4

struct Lsn:
    value: i64

    static fn zero() -> Lsn:
        Lsn(value: 0)

    me fn is_zero() -> bool:
        self.value == 0

struct WalRecord:
    txn_id:      i64
    record_type: i64
    payload:     text

struct WalEntry:
    lsn:    Lsn
    record: WalRecord

struct RecoveryCursor:
    lsn:     i64
    entries: [WalEntry]

    me fn start_lsn() -> i64:
        self.lsn

    me fn collect_committed() -> Result<[WalRecord], text>:
        var result: [WalRecord] = []
        for entry in self.entries:
            if entry.lsn.value >= self.lsn:
                result.push(entry.record)
        Ok(result)

struct SharedWal:
    entries:          [WalEntry]
    next_lsn:         i64
    durable_lsn:      i64
    intent_log_head:  i64
    flush_count:      i64

    static fn new() -> SharedWal:
        SharedWal(
            entries:         [],
            next_lsn:        1,
            durable_lsn:     0,
            intent_log_head: 0,
            flush_count:     0
        )

    me fn append(rec: WalRecord) -> Result<Lsn, text>:
        val lsn = Lsn(value: self.next_lsn)
        self.next_lsn = self.next_lsn + 1
        self.entries.push(WalEntry(lsn: lsn, record: rec))
        Ok(lsn)

    me fn read_record(lsn: Lsn) -> Result<WalRecord, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].lsn.value == lsn.value:
                return Ok(self.entries[i].record)
            i = i + 1
        Err("wal: record not found")

    me fn flush_wal() -> Result<(), text>:
        if self.entries.len() > 0:
            val last_idx = self.entries.len() as i32 - 1
            val last_lsn = self.entries[last_idx].lsn.value
            if last_lsn > self.durable_lsn:
                self.durable_lsn = last_lsn
        self.flush_count = self.flush_count + 1
        Ok(())

    me fn get_durable_lsn() -> Lsn:
        Lsn(value: self.durable_lsn)

    me fn durable_lsn() -> i64:
        self.durable_lsn

    me fn flush() -> Result<(), text>:
        self.flush_wal()

    me fn intent_log_head() -> i64:
        self.intent_log_head

    me fn recovery_cursor() -> RecoveryCursor:
        var snapshot: [WalEntry] = []
        for entry in self.entries:
            snapshot.push(entry)
        RecoveryCursor(lsn: self.intent_log_head, entries: snapshot)

    me fn get_intent_log_head() -> Lsn:
        Lsn(value: self.intent_log_head)

    me fn set_intent_log_head(lsn: Lsn):
        self.intent_log_head = lsn.value

    me fn get_flush_count() -> i64:
        self.flush_count

    me fn scan_from(from_lsn: Lsn) -> [WalEntry]:
        var result: [WalEntry] = []
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].lsn.value >= from_lsn.value:
                result.push(self.entries[i])
            i = i + 1
        result

export SharedWal, Lsn, WalRecord, WalEntry, RecoveryCursor
export WAL_RECORD_DATA, WAL_RECORD_META, WAL_RECORD_COMMIT, WAL_RECORD_ABORT
