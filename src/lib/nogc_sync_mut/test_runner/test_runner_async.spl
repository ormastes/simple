# Async Test Execution - True Parallel Test Running
#
# Implements parallel test execution using process_spawn_async + process_wait.
# Manages worker pool, stdout/stderr capture via temp files, and result collection.

use std.io.{file_write, file_read_text_at, file_size, file_delete, file_exists}
use std.io.{time_now_unix_micros}
use std.nogc_sync_mut.io.env_ops.{env_get, host_os}
use std.io.sysinfo_ops.{cpu_count}
use std.test_runner.test_runner_types.{TestFileResult, TestOptions, TEST_OUTPUT_CAPTURE_BYTES}
use std.test_runner.test_runner_execute.{find_simple_binary, build_child_args, make_result_from_output}
use std.test_runner.test_runner_fork.{run_test_file_fork}
use std.test_runner.runner_lifecycle.{spawn_tracked_process, wait_tracked_process, poll_tracked_process, cleanup_all_children}
use std.test_runner.resource_governor.{ResourceGovernor, governor_create, governor_can_spawn, governor_wait_until_ready}
use std.nogc_sync_mut.io.signal_handlers.{install_signal_handlers}
use std.nogc_sync_mut.io.signal_stubs.{signal_dispatch_pending}

extern fn rt_thread_sleep(millis: i64)

# ============================================================================
# Async Test Execution State
# ============================================================================

struct AsyncTestRun:
    pid: i64
    file_path: text
    start_time: i64          # microseconds
    stdout_file: text
    stderr_file: text
    timeout_ms: i64

val _WAIT_POLL_INITIAL_MS = 10
val _WAIT_POLL_MEDIUM_MS = 50
val _WAIT_POLL_MAX_MS = 100
var _runner_signal_handlers_installed = false

fn _cleanup_tracked_test_children():
    val _ = cleanup_all_children()

fn _ensure_runner_signal_handlers():
    if not _runner_signal_handlers_installed and host_os() != "windows":
        _runner_signal_handlers_installed = install_signal_handlers(_cleanup_tracked_test_children)

# ============================================================================
# Temp File Management
# ============================================================================

fn _get_temp_dir() -> text:
    """Get platform-appropriate temp directory"""
    val os = host_os()
    if os == "windows":
        val temp_env = env_get("TEMP").trim()
        if temp_env != "":
            return temp_env
        return "C:\\Temp"
    val tmpdir = env_get("TMPDIR").trim()
    if tmpdir != "":
        return tmpdir
    "/tmp"

fn create_temp_files(file_path: text) -> (text, text):
    """
    Create temp files for stdout/stderr capture.

    Returns: (stdout_file, stderr_file)
    """
    val timestamp = time_now_unix_micros()

    # Replace path separators (chained replace breaks in runtime)
    var base = file_path
    var temp_chars: [text] = []
    var i = 0
    while i < base.len():
        val ch = base[i:i + 1]
        if ch == "/" or ch == "\\":
            temp_chars.push("_")
        elif ch == ".":
            temp_chars.push("_")
        elif ch == ":":
            temp_chars.push("_")
        else:
            temp_chars.push(ch)
        i = i + 1
    base = temp_chars.join("")

    val tmp_dir = _get_temp_dir()
    val os = host_os()
    var sep = "/"
    if os == "windows":
        sep = "\\"
    val stdout_file = "{tmp_dir}{sep}simple_test_{base}_{timestamp}_out.txt"
    val stderr_file = "{tmp_dir}{sep}simple_test_{base}_{timestamp}_err.txt"

    # Initialize empty files
    file_write(stdout_file, "")
    file_write(stderr_file, "")

    (stdout_file, stderr_file)

fn cleanup_temp_files(stdout_file: text, stderr_file: text):
    """Delete temp files after result collection"""
    if file_exists(stdout_file):
        file_delete(stdout_file)
    if file_exists(stderr_file):
        file_delete(stderr_file)

fn read_bounded_temp_output(path: text) -> text:
    val size = file_size(path)
    if size <= TEST_OUTPUT_CAPTURE_BYTES:
        return file_read_text_at(path, 0, size)
    val head_size = (TEST_OUTPUT_CAPTURE_BYTES + 1) / 2
    val tail_size = TEST_OUTPUT_CAPTURE_BYTES - head_size
    val head = file_read_text_at(path, 0, head_size)
    val tail = file_read_text_at(path, size - tail_size, tail_size)
    head + "\n[output truncated: {size - TEST_OUTPUT_CAPTURE_BYTES} bytes omitted]\n" + tail

fn _wait_poll_sleep_ms(poll_iteration: i64) -> i64:
    """Adaptive backoff for process polling."""
    if poll_iteration >= 50:
        return _WAIT_POLL_MAX_MS
    if poll_iteration >= 10:
        return _WAIT_POLL_MEDIUM_MS
    _WAIT_POLL_INITIAL_MS

# ============================================================================
# Async Test Spawning
# ============================================================================

fn spawn_async_test(file_path: text, options: TestOptions) -> AsyncTestRun:
    """
    Spawn test as async process with stdout/stderr redirect.

    Args:
        file_path: Path to test file
        options: Test options

    Returns: AsyncTestRun tracking structure
    """
    val binary = find_simple_binary()
    val child_args = build_child_args(file_path, options)
    val timeout_ms = options.timeout * 1000

    # Create temp files for stdout/stderr
    val (stdout_file, stderr_file) = create_temp_files(file_path)

    var pid: i64 = -1
    if host_os() == "windows":
        # Fail closed until the runtime exposes native redirected argv spawn.
        file_write(stderr_file, "parallel test capture is unavailable on Windows")
    else:
        val redirect_script = "out=$1; err=$2; shift 2; exec \"$@\" >\"$out\" 2>\"$err\""
        var shell_args = ["-c", redirect_script, "simple-test", stdout_file, stderr_file, binary]
        for arg in child_args:
            shell_args.push(arg)
        pid = spawn_tracked_process("/bin/sh", shell_args)

    val start_time = time_now_unix_micros()

    AsyncTestRun(
        pid: pid,
        file_path: file_path,
        start_time: start_time,
        stdout_file: stdout_file,
        stderr_file: stderr_file,
        timeout_ms: timeout_ms
    )

# ============================================================================
# Result Collection
# ============================================================================

fn collect_async_result(run: AsyncTestRun, observed_exit_code: i64, deadline_expired: bool = false) -> TestFileResult:
    """
    Wait for async test to complete and collect results.

    Args:
        run: AsyncTestRun tracking structure

    Returns: TestFileResult
    """
    # Wait for process to complete (with timeout)
    var exit_code = observed_exit_code
    if run.pid > 0 and observed_exit_code == -2:
        val elapsed_ms = (time_now_unix_micros() - run.start_time) / 1000
        val remaining_ms = if elapsed_ms < run.timeout_ms: run.timeout_ms - elapsed_ms else: 1
        exit_code = wait_tracked_process(run.pid, remaining_ms)

    val end_time = time_now_unix_micros()
    val duration_ms = (end_time - run.start_time) / 1000

    # Read stdout/stderr from temp files
    var stdout = ""
    var stderr = ""

    if file_exists(run.stdout_file):
        stdout = read_bounded_temp_output(run.stdout_file)

    if file_exists(run.stderr_file):
        stderr = read_bounded_temp_output(run.stderr_file)

    # Cleanup temp files
    cleanup_temp_files(stdout_file: run.stdout_file, stderr_file: run.stderr_file)

    # A monitor-enforced deadline is authoritative.  Handle captures first
    # without trusting -1, which also represents a child crash/start failure.
    if deadline_expired:
        return TestFileResult(
            path: run.file_path,
            passed: 0,
            failed: 1,
            skipped: 0,
            pending: 0,
            duration_ms: duration_ms,
            setup_ms: 0,
            error: "TIMEOUT after {run.timeout_ms / 1000}s",
            timed_out: true,
            cached: false
        )

    # Build normal completions using the same logic as sync execution.
    make_result_from_output(
        run.file_path,
        stdout,
        stderr,
        exit_code,
        duration_ms,
        run.timeout_ms / 1000
    )

# ============================================================================
# Fork-based Test Execution (for parallel + fork mode)
# ============================================================================

fn spawn_fork_test(file_path: text, options: TestOptions) -> TestFileResult:
    """Run a single test via fork() instead of subprocess spawn.
    Returns the result directly (fork is synchronous from parent perspective).
    Used when fork_mode is enabled to eliminate 220ms CLI startup overhead."""
    run_test_file_fork(file_path, options)

# ============================================================================
# Parallel Execution with Timeout Check
# ============================================================================

fn run_tests_parallel_with_monitoring(
    files: [text],
    options: TestOptions,
    max_workers: i64
) -> [TestFileResult]:
    """
    Run tests in parallel with timeout monitoring and resource governor.

    Checks each active process for timeout and kills if exceeded.
    Uses resource governor to avoid exceeding system memory/CPU limits.

    Args:
        files: List of test file paths
        options: Test options
        max_workers: Maximum parallel workers

    Returns: List of TestFileResult
    """
    _ensure_runner_signal_handlers()
    var results: [TestFileResult] = []
    var active_runs: [AsyncTestRun] = []
    var next_file_idx = 0
    var poll_iteration = 0

    # Fork mode is sequential — skip it when parallel is explicitly requested.
    # Subprocess parallelism with N workers is faster than sequential fork
    # even with the per-test startup overhead.

    # Create resource governor (default 75%, overridable via options)
    val gov = governor_create(options.resource_limit_pct)
    print "  [parallel] Resource governor: max {gov.max_cpu_cores} cores, {gov.max_memory_mb}MB memory ({gov.resource_limit_pct}% limit)"

    while next_file_idx < files.len() or active_runs.len() > 0:
        signal_dispatch_pending()
        # Spawn new tests (respecting both max_workers and resource governor)
        while active_runs.len() < max_workers and next_file_idx < files.len():
            # Check resource governor before spawning
            if not governor_can_spawn(gov, active_runs.len()):
                governor_wait_until_ready(gov, active_runs.len())

            val file_path = files[next_file_idx]
            val run = spawn_async_test(file_path, options)
            active_runs.push(run)
            next_file_idx = next_file_idx + 1

        # Check for timeouts and completions
        var new_runs: [AsyncTestRun] = []
        val current_time = time_now_unix_micros()
        var had_completion = false

        for run in active_runs:
            # Poll first: a child that completed at the deadline is complete,
            # not a timeout.  Only still-pending work can expire.
            val exit_code = poll_tracked_process(run.pid)
            if exit_code != -2:
                val result = collect_async_result(run, exit_code)
                results.push(result)
                had_completion = true
                continue

            val elapsed_ms = (current_time - run.start_time) / 1000
            if elapsed_ms > run.timeout_ms:
                val result = collect_async_result(run, -2, true)
                results.push(result)
                had_completion = true
            else:
                new_runs.push(run)

        active_runs = new_runs

        # Only sleep after a full pass with no completion.
        if had_completion:
            poll_iteration = 0
        else:
            rt_thread_sleep(_wait_poll_sleep_ms(poll_iteration))
            poll_iteration = poll_iteration + 1

    results

# ============================================================================
# Helper: CPU Count Detection
# ============================================================================

fn get_cpu_count() -> i64:
    """
    Detect number of CPU cores on Linux, macOS, FreeBSD, and Windows.

    Returns: CPU count, or 4 if detection fails
    """
    val count = cpu_count()
    if count > 0: count else: 4

# ============================================================================
# Exports
# ============================================================================
