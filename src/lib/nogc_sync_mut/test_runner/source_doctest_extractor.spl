# Source Doctest Extraction
#
# Kept separate from execution so manifest scans do not load process externs.

use std.io.{file_read, file_exists}

struct Doctest:
    source_file: text
    line_number: i64
    code: text
    expected_output: text
    should_fail: bool
    # True only for a bare ```simple/```spl/```sdoctest fence found directly
    # inside a plain `"""..."""` docstring (e.g. an API "Example:" block).
    # These are illustrative documentation prose, not opted-in test intent —
    # unlike the established `///`/`#` comment-embedded fence convention or
    # an explicit `sdoctest:` keyword block (either form), which always mark
    # deliberate test authoring. Extraction still returns them (so doc
    # generation and this file's own unit test keep seeing every fenced
    # block), but callers that decide *candidacy* for running as a real test
    # (discover_spl_doctest_files, test_manifest_scanner) must exclude them —
    # see doc/08_tracking/bug/whole_test_runner_doctest_import_comment_guard_2026-07-18.md.
    is_docstring_example: bool

fn extract_doctests(file_path: text) -> [Doctest]:
    if not file_exists(file_path):
        return []

    val content = file_read(file_path)
    val lines = content.split("\n")
    var doctests: [Doctest] = []
    var i = 0
    var in_code_block = false
    var in_docstring = false
    var in_sdoctest = false
    var sdoctest_indent = 0
    var doc_fence_indent = 0
    var code_lines: [text] = []
    var start_line = 0
    var should_fail = false

    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()

        if trimmed.contains("\"\"\""):
            val quote_at = trimmed.index_of("\"\"\"") ?? -1
            val quote_tail = trimmed[quote_at + 3:]
            if quote_tail.contains("\"\"\""):
                i = i + 1
                continue
            if in_sdoctest and code_lines.len() > 0:
                doctests.push(Doctest(
                    source_file: file_path,
                    line_number: start_line,
                    code: code_lines.join("\n"),
                    expected_output: "",
                    should_fail: false,
                    is_docstring_example: false
                ))
            in_docstring = not in_docstring
            in_sdoctest = false
            in_code_block = false
            code_lines = []
            i = i + 1
            continue

        if in_docstring:
            val indent = line.len() - line.trim_start().len()
            if in_code_block:
                if trimmed == "```":
                    in_code_block = false
                    if code_lines.len() > 0:
                        doctests.push(Doctest(
                            source_file: file_path,
                            line_number: start_line,
                            code: code_lines.join("\n"),
                            expected_output: "",
                            should_fail: should_fail,
                            is_docstring_example: true
                        ))
                    code_lines = []
                else:
                    var code_start = doc_fence_indent
                    if code_start > line.len():
                        code_start = indent
                    code_lines.push(line[code_start:])
            elif trimmed.starts_with("```simple") or trimmed.starts_with("```spl") or trimmed.starts_with("```sdoctest"):
                in_code_block = true
                doc_fence_indent = indent
                start_line = i + 1
                should_fail = trimmed.contains("should_fail")
                code_lines = []
            elif trimmed == "sdoctest:":
                in_sdoctest = true
                sdoctest_indent = indent
                start_line = i + 2
                code_lines = []
            elif in_sdoctest and trimmed != "" and indent > sdoctest_indent:
                var code_start = sdoctest_indent + 4
                if code_start > line.len():
                    code_start = indent
                code_lines.push(line[code_start:])
            elif in_sdoctest and trimmed != "":
                if code_lines.len() > 0:
                    doctests.push(Doctest(
                        source_file: file_path,
                        line_number: start_line,
                        code: code_lines.join("\n"),
                        expected_output: "",
                        should_fail: false,
                        is_docstring_example: false
                    ))
                in_sdoctest = false
                code_lines = []
            i = i + 1
            continue

        if trimmed.starts_with("///") or trimmed.starts_with("#"):
            val doc_content = if trimmed.starts_with("///"):
                trimmed[3:].trim()
            elif trimmed.starts_with("##"):
                trimmed[2:].trim()
            else:
                trimmed[1:].trim()

            if doc_content.starts_with("```simple") or doc_content.starts_with("```spl") or doc_content.starts_with("```sdoctest"):
                in_code_block = true
                code_lines = []
                start_line = i + 1
                should_fail = doc_content.contains("should_fail")
            elif doc_content == "```" and in_code_block:
                in_code_block = false
                if code_lines.len() > 0:
                    doctests.push(Doctest(
                        source_file: file_path,
                        line_number: start_line,
                        code: code_lines.join("\n"),
                        expected_output: "",
                        should_fail: should_fail,
                        is_docstring_example: false
                    ))
            elif in_code_block:
                code_lines.push(doc_content)
        elif in_code_block:
            in_code_block = false
            code_lines = []

        i = i + 1

    doctests
