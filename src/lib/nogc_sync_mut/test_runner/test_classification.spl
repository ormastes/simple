# Test Classification — Categorizes tests for QEMU session sharing
#
# Classifies test files by their QEMU session requirements so the
# test runner can batch tests that share the same VM.

extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# Session Mode Constants
# ============================================================================

val SESSION_READ_ONLY: i64 = 0     # Share VM, no reset between tests
val SESSION_MUTATING: i64 = 1      # Snapshot/restore between tests (default for QEMU)
val SESSION_DESTRUCTIVE: i64 = 2   # Fresh VM per test
val SESSION_NOT_QEMU: i64 = 3      # Regular test, no QEMU needed

# ============================================================================
# Classification Result
# ============================================================================

struct TestClassification:
    file_path: text
    session_mode: i64
    arch: text
    needs_qemu: bool

# ============================================================================
# Classifier
# ============================================================================

fn classify_test(file_path: text) -> TestClassification:
    # Path-based detection
    val is_qemu = file_path.contains("/qemu/") or file_path.contains("/baremetal/")

    if not is_qemu:
        return TestClassification(
            file_path: file_path,
            session_mode: SESSION_NOT_QEMU,
            arch: "host",
            needs_qemu: false
        )

    # Read first 20 lines for file markers
    var session_mode = SESSION_MUTATING  # default for QEMU tests
    var arch = "riscv32"                 # default arch

    val content = rt_file_read_text(file_path) ?? ""
    if content != "":
        val lines = content.split("\n")
        var line_count = 0
        var i = 0
        while i < lines.len() and line_count < 20:
            val line = lines[i].trim()

            # Parse @session marker
            if line.starts_with("# @session:"):
                val mode_str = line[11:].trim()
                if mode_str == "read_only":
                    session_mode = SESSION_READ_ONLY
                elif mode_str == "destructive":
                    session_mode = SESSION_DESTRUCTIVE
                elif mode_str == "mutating":
                    session_mode = SESSION_MUTATING

            # Parse @arch marker
            if line.starts_with("# @arch:"):
                arch = line[8:].trim()

            line_count = line_count + 1
            i = i + 1

    # Infer arch from path if not set by marker
    if arch == "riscv32":
        if file_path.contains("x86_64"):
            arch = "x86_64"
        elif file_path.contains("arm") or file_path.contains("aarch64"):
            arch = "arm"

    TestClassification(
        file_path: file_path,
        session_mode: session_mode,
        arch: arch,
        needs_qemu: true
    )

# ============================================================================
# Grouping
# ============================================================================

fn group_by_session(tests: [TestClassification]) -> [[TestClassification]]:
    # Group by (arch, session_mode) for batch scheduling
    # read_only tests share 1 VM per arch
    # mutating tests share 1 VM with snapshot/restore per arch
    # destructive tests get individual VMs
    var groups: [[TestClassification]] = []
    var group_keys: [text] = []

    for test in tests:
        val key = "{test.arch}_{test.session_mode}"

        # Destructive tests each get their own group
        if test.session_mode == SESSION_DESTRUCTIVE:
            var solo: [TestClassification] = []
            solo.push(test)
            groups.push(solo)
        else:
            # Find existing group or create new one
            var found = false
            var gi = 0
            while gi < group_keys.len():
                if group_keys[gi] == key:
                    groups[gi].push(test)
                    found = true
                    break
                gi = gi + 1

            if not found:
                group_keys.push(key)
                var new_group: [TestClassification] = []
                new_group.push(test)
                groups.push(new_group)

    groups

fn separate_qemu_tests(files: [text]) -> ([text], [text]):
    # Returns (normal_files, qemu_files)
    var normal: [text] = []
    var qemu: [text] = []
    for f in files:
        if f.contains("/qemu/") or f.contains("/baremetal/"):
            qemu.push(f)
        else:
            normal.push(f)
    (normal, qemu)

# ============================================================================
# Exports
# ============================================================================

export SESSION_READ_ONLY, SESSION_MUTATING, SESSION_DESTRUCTIVE, SESSION_NOT_QEMU
export TestClassification
export classify_test, group_by_session, separate_qemu_tests
