# Test Manifest Scanner — Full and incremental scanning for test discovery
#
# Walks test/src/doc directories, extracts metadata from each file,
# and builds/updates the TestManifest used for fast discovery.

use test_manifest.{
    TestManifest, TestManifestEntry, SdoctestManifestEntry,
    MANIFEST_VERSION, manifest_new, manifest_find_entry
}
use app.io.dir_ops.{dir_walk_native}
use app.io.sysinfo_ops.{path_basename}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_stat(path: text) -> i64
extern fn rt_file_size(path: text) -> i64
extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Full Scan
# ============================================================================

fn manifest_full_scan(dirs: [text]) -> TestManifest:
    var manifest = manifest_new()
    manifest.scan_timestamp = rt_time_now_unix_micros()

    for dir in dirs:
        val all_files = dir_walk_native(dir)
        for f in all_files:
            if is_spec_file(f):
                val entry = scan_test_file(f)
                manifest.entries.push(entry)
            elif is_sdoctest_candidate(f):
                val sd = scan_sdoctest_file(f)
                if sd.block_count > 0:
                    manifest.sdoctest_entries.push(sd)

    manifest

# ============================================================================
# Incremental Update
# ============================================================================

fn manifest_incremental_update(old: TestManifest, dirs: [text]) -> TestManifest:
    var manifest = manifest_new()
    manifest.scan_timestamp = rt_time_now_unix_micros()

    # Build lookup set of old entries by path for quick access
    var old_paths: {text: bool} = {}
    for entry in old.entries:
        old_paths[entry.path] = true
    var old_sd_paths: {text: bool} = {}
    for sd in old.sdoctest_entries:
        old_sd_paths[sd.path] = true

    # Track which old paths we saw in the new walk (for deletion detection)
    var seen_paths: {text: bool} = {}

    for dir in dirs:
        val all_files = dir_walk_native(dir)
        for f in all_files:
            if is_spec_file(f):
                seen_paths[f] = true
                val current_size = rt_file_size(f)
                val current_mtime = rt_file_stat(f)

                # Check if file exists in old manifest with same size+mtime
                val old_entry = manifest_find_entry(old, f)
                if (old_entry.path != "" and
                    old_entry.file_size == current_size and
                    old_entry.file_mtime == current_mtime):
                    # Unchanged — reuse old entry
                    manifest.entries.push(old_entry)
                else:
                    # New or changed — full rescan
                    val entry = scan_test_file(f)
                    manifest.entries.push(entry)

            elif is_sdoctest_candidate(f):
                seen_paths[f] = true
                val current_size = rt_file_size(f)
                val current_mtime = rt_file_stat(f)

                val old_sd = manifest_find_sdoctest_entry(old, f)
                if (old_sd.path != "" and
                    old_sd.file_size == current_size and
                    old_sd.file_mtime == current_mtime):
                    manifest.sdoctest_entries.push(old_sd)
                else:
                    val sd = scan_sdoctest_file(f)
                    if sd.block_count > 0:
                        manifest.sdoctest_entries.push(sd)

    # Deleted files are automatically excluded — they won't be in seen_paths
    manifest

# ============================================================================
# File Classification
# ============================================================================

fn is_spec_file(path: text) -> bool:
    val name = path_basename(path)
    if not name.ends_with(".spl"):
        return false
    name.contains("_spec.") or name.contains("_test.")

fn is_sdoctest_candidate(path: text) -> bool:
    path.ends_with(".md") or (path.ends_with(".spl") and not is_spec_file(path))

# ============================================================================
# File Scanning — Extract Metadata
# ============================================================================

fn scan_test_file(path: text) -> TestManifestEntry:
    val size = rt_file_size(path)
    val mtime = rt_file_stat(path)
    val content = rt_file_read_text(path) ?? ""

    val cat = extract_category(content)
    var resolved_cat = cat
    if resolved_cat == "":
        resolved_cat = auto_detect_category(content, path)

    TestManifestEntry(
        path: path,
        file_size: size,
        file_mtime: mtime,
        test_level: detect_test_level(path),
        has_slow: content.contains("slow_it "),
        has_skip: (content.contains("tag: \"skip\"") or
                   content.contains("tag: 'skip'") or
                   content.contains("# @skip")),
        has_pending: (content.contains("# @pending") or
                      content.contains("tag: \"pending\"") or
                      content.contains("tag: 'pending'")),
        tags: extract_tags(content),
        platform_tags: extract_platform_tags(content),
        is_fuzz: path.contains("/fuzz/"),
        is_chaos: path.contains("/resilience/"),
        is_deploy: path.contains("/deploy/"),
        is_security: path.contains("/security/"),
        is_baremetal: path.contains("/baremetal/"),
        mode_tags: extract_mode_tags(content),
        category: resolved_cat,
        speed_default: extract_speed_default(content),
        speed_contexts: extract_speed_contexts(content)
    )

fn scan_sdoctest_file(path: text) -> SdoctestManifestEntry:
    val size = rt_file_size(path)
    val mtime = rt_file_stat(path)
    val content = rt_file_read_text(path) ?? ""
    val blocks = count_sdoctest_blocks(content)

    SdoctestManifestEntry(
        path: path,
        file_size: size,
        file_mtime: mtime,
        block_count: blocks
    )

# ============================================================================
# Metadata Extraction Helpers
# ============================================================================

fn detect_test_level(path: text) -> i64:
    if path.contains("/unit/"):
        return 1
    if path.contains("/integration/"):
        return 2
    if path.contains("/system/") or path.contains("/feature/"):
        return 3
    0

fn extract_tags(content: text) -> text:
    # Extract tag: "name" patterns
    var tags: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("tag:"):
            val rest = trimmed[4:].trim()
            # Strip quotes: "foo" or 'foo'
            if rest.len() >= 2:
                val first = rest[0:1]
                if first == "\"" or first == "'":
                    val inner = rest[1:rest.len() - 1]
                    if inner != "skip" and inner != "pending":
                        var already = false
                        for t in tags:
                            if t == inner:
                                already = true
                        if not already:
                            tags.push(inner)
    tags.join(",")

fn extract_platform_tags(content: text) -> text:
    var tags: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @platform:"):
            val tag = trimmed[12:].trim()
            if tag != "":
                tags.push(tag)
    tags.join(",")

fn extract_mode_tags(content: text) -> text:
    """Extract # @mode: and # @skip_mode: annotations from file content.
    Returns comma-separated mode names, or names prefixed with ! for skip_mode."""
    var tags: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @mode:"):
            val tag = trimmed[8:].trim()
            if tag != "":
                # Split on comma for multi-mode: "# @mode: interpreter, native"
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push(p)
        elif trimmed.starts_with("# @skip_mode:"):
            val tag = trimmed[13:].trim()
            if tag != "":
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push("!{p}")
    tags.join(",")

fn count_sdoctest_blocks(content: text) -> i64:
    # Count ```simple or ```spl code blocks in markdown
    var count = 0
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "```simple" or trimmed == "```spl":
            count = count + 1
    count

# ============================================================================
# Category & Speed Annotation Extraction
# ============================================================================

fn extract_category(content: text) -> text:
    """Parse explicit # @category: annotation from file content."""
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @category:"):
            val cat = trimmed[12:].trim()
            if cat != "":
                return cat
    ""

fn extract_speed_default(content: text) -> text:
    """Parse # @speed: annotation (without context parentheses)."""
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @speed:"):
            val speed = trimmed[9:].trim()
            if speed != "":
                return speed
        elif trimmed.starts_with("# @speed("):
            # Skip contextual speed annotations — handled by extract_speed_contexts
            continue
    ""

fn extract_speed_contexts(content: text) -> text:
    """Parse all # @speed(ctx): val annotations, return 'baremetal=short,native=short'."""
    val lines = content.split("\n")
    var pairs: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @speed("):
            val rest = trimmed[9:]
            val paren_end = rest.index_of(")")
            if paren_end > 0:
                val ctx = rest[0:paren_end].trim()
                val after_paren = rest[paren_end + 1:]
                if after_paren.starts_with(":"):
                    val speed = after_paren[1:].trim()
                    if ctx != "" and speed != "":
                        pairs.push("{ctx}={speed}")
    pairs.join(",")

fn auto_detect_category(content: text, path: text) -> text:
    """Auto-detect category from path and content when no explicit annotation."""
    # Path-based detection
    if (path.contains("/baremetal/") or path.contains("/qemu/") or
        path.contains("/cuda/") or path.contains("/gpu/")):
        return "platform"

    # Check for non-all/non-host platform tags
    val lines = content.split("\n")
    var has_use = false
    var only_spec_use = true
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @platform:"):
            val tag = trimmed[12:].trim()
            if tag != "" and tag != "all" and tag != "host":
                return "platform"
        if trimmed.starts_with("use "):
            has_use = true
            val module = trimmed[4:].trim()
            # Check if it's more than just std.spec
            val is_spec = module.starts_with("std.spec") or module.starts_with("nogc_sync_mut.spec")
            if not is_spec:
                only_spec_use = false

    # No use statements or only spec import → standalone
    if not has_use or only_spec_use:
        return "standalone"

    # Has non-spec use statements → lib
    if has_use and not only_spec_use:
        return "lib"

    "other"

# ============================================================================
# Internal Lookup Helper
# ============================================================================

fn manifest_find_sdoctest_entry(manifest: TestManifest, path: text) -> SdoctestManifestEntry:
    for sd in manifest.sdoctest_entries:
        if sd.path == path:
            return sd
    SdoctestManifestEntry(path: "", file_size: 0, file_mtime: 0, block_count: 0)

# ============================================================================
# Exports
# ============================================================================
