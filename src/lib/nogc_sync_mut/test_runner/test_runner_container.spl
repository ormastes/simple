# Test Runner Container Backend
#
# Container-based test execution using Docker or Podman.
# Provides isolation and resource limits via container runtime.

use std.io.{file_exists, process_run_timeout}

extern fn rt_time_now_unix_micros() -> i64

# =========================================================================
# Container Detection
# =========================================================================

fn container_detect_runtime() -> text:
    """
    Detect available container runtime (docker or podman).

    Returns: "docker", "podman", or "none"
    """
    val (_docker_out, _docker_err, docker_code) = process_run_timeout("docker", ["--version"], 5000)
    if docker_code == 0:
        return "docker"

    val (_podman_out, _podman_err, podman_code) = process_run_timeout("podman", ["--version"], 5000)
    if podman_code == 0:
        return "podman"

    "none"

fn container_check_image(image: text, runtime: text) -> bool:
    """
    Check if a container image exists locally.

    Args:
        image: Image name (e.g., "simple-test-runner:latest")
        runtime: Container runtime ("docker" or "podman")

    Returns: true if image exists, false otherwise
    """
    if runtime != "docker" and runtime != "podman":
        return false
    val (_out, _err, code) = process_run_timeout(runtime, ["image", "inspect", image], 30000)
    code == 0

# =========================================================================
# Container Execution
# =========================================================================

fn container_run_test(
    test_file: text,
    runtime: text,
    image: text,
    memory_mb: i64,
    cpu_count: f64,
    network: text,
    readonly: bool,
    workspace: text
) -> (text, text, i64, i64):
    """
    Run a test file inside a container.

    Args:
        test_file: Path to test file (relative to workspace)
        runtime: Container runtime ("docker" or "podman")
        image: Container image name
        memory_mb: Memory limit in MB
        cpu_count: CPU limit (fractional allowed)
        network: Network mode ("none", "bridge", "host")
        readonly: Mount workspace as read-only
        workspace: Workspace directory (usually current directory)

    Returns: (stdout, stderr, exit_code, duration_ms)
    """

    if runtime != "docker" and runtime != "podman":
        val error = "Container runtime '{runtime}' not supported. Use 'docker' or 'podman'."
        return ("", error, 1, 0)

    val args = container_run_args(test_file, image, memory_mb, cpu_count, network, readonly, workspace)

    val start_time = time_now_ms()
    val (stdout, stderr, exit_code) = process_run_timeout(runtime, args, 300000)
    val end_time = time_now_ms()
    val duration = end_time - start_time

    (stdout, stderr, exit_code as i64, duration)

fn container_run_args(test_file: text, image: text, memory_mb: i64, cpu_count: f64, network: text, readonly: bool, workspace: text) -> [text]:
    val mount_flag = if readonly: "ro" else: "rw"
    [
        "run", "--rm", "--memory={memory_mb}m", "--cpus={cpu_count}",
        "--network={network}", "-v", "{workspace}:/workspace:{mount_flag}",
        "-w", "/workspace", image, "test", test_file
    ]

fn container_build_test_image(runtime: text, dockerfile_path: text, image_name: text) -> bool:
    """
    Build container test image from Dockerfile.

    Args:
        runtime: Container runtime ("docker" or "podman")
        dockerfile_path: Path to Dockerfile
        image_name: Name for the built image

    Returns: true on success, false on failure
    """
    if not file_exists(dockerfile_path):
        print "ERROR: Dockerfile not found: {dockerfile_path}"
        return false

    if runtime != "docker" and runtime != "podman":
        return false
    print "Building container image: {image_name}"

    val (_stdout, stderr, exit_code) = process_run_timeout(
        runtime, ["build", "-f", dockerfile_path, "-t", image_name, "."], 600000
    )
    if exit_code == 0:
        print "Successfully built image: {image_name}"
        return true
    else:
        print "Failed to build image: {stderr}"
        return false

# =========================================================================
# Helper Functions
# =========================================================================

fn time_now_ms() -> i64:
    """Get current time in milliseconds."""
    rt_time_now_unix_micros() / 1000

fn container_get_version(runtime: text) -> text:
    """
    Get container runtime version.

    Args:
        runtime: Container runtime ("docker" or "podman")

    Returns: Version string or empty string on error
    """
    if runtime != "docker" and runtime != "podman":
        return ""
    val (stdout, _stderr, exit_code) = process_run_timeout(runtime, ["--version"], 5000)
    if exit_code == 0: stdout.trim() else: ""

fn container_cleanup_volumes(runtime: text) -> bool:
    """
    Clean up unused container volumes.

    Args:
        runtime: Container runtime ("docker" or "podman")

    Returns: true on success, false on failure
    """
    if runtime != "docker" and runtime != "podman":
        return false
    val (_stdout, _stderr, exit_code) = process_run_timeout(runtime, ["volume", "prune", "-f"], 30000)
    exit_code == 0

# =========================================================================
# Exports
# =========================================================================
