# Bounded test-runner batch transport.

use std.io.{file_atomic_write, file_exists, file_read}
use std.test_runner.test_runner_types.{TestFileResult, TestRunResult}

struct TestBatchRead:
    result: TestRunResult
    valid: bool
    error: text

fn empty_test_run_result() -> TestRunResult:
    TestRunResult(files: [], total_passed: 0, total_failed: 0, total_skipped: 0, total_pending: 0, total_timed_out: 0, total_duration_ms: 0, total_setup_ms: 0, total_cached: 0)

fn encode_batch_field(value: text) -> text:
    var encoded = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "\\":
            encoded = encoded + "\\\\"
        elif ch == "\t":
            encoded = encoded + "\\t"
        elif ch == "\n":
            encoded = encoded + "\\n"
        elif ch == "\r":
            encoded = encoded + "\\r"
        else:
            encoded = encoded + ch
        i = i + 1
    encoded

fn decode_batch_field(value: text) -> text:
    var decoded = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "\\" and i + 1 < value.len():
            val next = value.substring(i + 1, i + 2)
            if next == "t":
                decoded = decoded + "\t"
            elif next == "n":
                decoded = decoded + "\n"
            elif next == "r":
                decoded = decoded + "\r"
            else:
                decoded = decoded + next
            i = i + 2
            continue
        decoded = decoded + ch
        i = i + 1
    decoded

fn write_test_batch_manifest(path: text, files: [text]) -> bool:
    var lines: [text] = []
    for file_path in files:
        lines.push(encode_batch_field(file_path))
    file_atomic_write(path, lines.join("\n"))

fn read_test_batch_manifest(path: text) -> [text]:
    if not file_exists(path):
        return []
    var files: [text] = []
    for line in file_read(path).split("\n"):
        if line != "":
            files.push(decode_batch_field(line))
    files

fn write_test_batch_result(path: text, result: TestRunResult) -> bool:
    var lines: [text] = []
    lines.push("run\t{result.total_passed}\t{result.total_failed}\t{result.total_skipped}\t{result.total_pending}\t{result.total_timed_out}\t{result.total_duration_ms}\t{result.total_setup_ms}\t{result.total_cached}\t{result.files.len()}")
    for file_result in result.files:
        val timed_out = if file_result.timed_out: 1 else: 0
        val cached = if file_result.cached: 1 else: 0
        lines.push("file\t{encode_batch_field(file_result.path)}\t{file_result.passed}\t{file_result.failed}\t{file_result.skipped}\t{file_result.pending}\t{file_result.duration_ms}\t{file_result.setup_ms}\t{encode_batch_field(file_result.error)}\t{timed_out}\t{cached}")
    file_atomic_write(path, lines.join("\n"))

fn read_test_batch_result(path: text) -> TestBatchRead:
    if not file_exists(path):
        return TestBatchRead(result: empty_test_run_result(), valid: false, error: "batch result is missing")
    val lines = file_read(path).split("\n")
    if lines.len() == 0:
        return TestBatchRead(result: empty_test_run_result(), valid: false, error: "batch result is empty")
    val header = lines[0].split("\t")
    if header.len() != 10 or header[0] != "run":
        return TestBatchRead(result: empty_test_run_result(), valid: false, error: "invalid batch result header")
    val expected_files = to_int(header[9])
    var files: [TestFileResult] = []
    var i = 1
    while i < lines.len():
        if lines[i] != "":
            val fields = lines[i].split("\t")
            if fields.len() != 11 or fields[0] != "file":
                return TestBatchRead(result: empty_test_run_result(), valid: false, error: "invalid batch file result")
            files.push(TestFileResult(
                path: decode_batch_field(fields[1]),
                passed: to_int(fields[2]),
                failed: to_int(fields[3]),
                skipped: to_int(fields[4]),
                pending: to_int(fields[5]),
                duration_ms: to_int(fields[6]),
                setup_ms: to_int(fields[7]),
                error: decode_batch_field(fields[8]),
                timed_out: fields[9] == "1",
                cached: fields[10] == "1"
            ))
        i = i + 1
    if files.len() != expected_files:
        return TestBatchRead(result: empty_test_run_result(), valid: false, error: "batch result file count mismatch")
    TestBatchRead(
        result: TestRunResult(
            files: files,
            total_passed: to_int(header[1]),
            total_failed: to_int(header[2]),
            total_skipped: to_int(header[3]),
            total_pending: to_int(header[4]),
            total_timed_out: to_int(header[5]),
            total_duration_ms: to_int(header[6]),
            total_setup_ms: to_int(header[7]),
            total_cached: to_int(header[8])
        ),
        valid: true,
        error: ""
    )

fn test_batch_result_matches_manifest(manifest: [text], result: TestRunResult) -> bool:
    if manifest.len() != result.files.len():
        return false
    var remaining: {text: i64} = {}
    for path in manifest:
        remaining[path] = (remaining.get(path) ?? 0) + 1
    for file_result in result.files:
        val count = remaining.get(file_result.path) ?? 0
        if count <= 0:
            return false
        remaining[file_result.path] = count - 1
    true

export TestBatchRead, empty_test_run_result, encode_batch_field, decode_batch_field
export write_test_batch_manifest, read_test_batch_manifest
export write_test_batch_result, read_test_batch_result
export test_batch_result_matches_manifest
