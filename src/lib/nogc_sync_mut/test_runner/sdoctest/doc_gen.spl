# SDoctest Documentation Generator
#
# Generates doc/08_tracking/test/sdoctest_result.md from test results.

use std.io.{file_atomic_write}
use std.test_runner.sdoctest.types.{BlockStatus, SdoctestRunResult}
use common.text.{string_trim}

# =========================================================================
# Public API
# =========================================================================

fn generate_sdoctest_report(result: SdoctestRunResult, report_path: text):
    var parts: [text] = []
    parts.push("# SDoctest Results\n")
    parts.push("> Auto-generated by sdoctest runner. Do not edit manually.\n")

    # Summary
    parts.push("## Summary\n")
    parts.push("| Metric | Count |")
    parts.push("|--------|-------|")
    parts.push("| Total blocks | {result.total} |")
    parts.push("| Passed | {result.passed} |")
    parts.push("| Failed | {result.failed} |")
    parts.push("| Skipped | {result.skipped} |")
    parts.push("| Errors | {result.errors} |")
    if result.accepted > 0:
        parts.push("| Accepted (fail-as-success) | {result.accepted} |")
    parts.push("| Duration | {result.duration_ms}ms |")
    parts.push("")

    val status_emoji = if result.is_ok(): "PASS" else: "FAIL"
    parts.push("**Status: {status_emoji}**\n")

    # Per-file breakdown
    parts.push("## Files\n")
    if result.accepted > 0:
        parts.push("| File | Total | Passed | Failed | Accepted | Skipped | Duration |")
        parts.push("|------|-------|--------|--------|----------|---------|----------|")
        for fr in result.files:
            parts.push("| {fr.source_file} | {fr.total} | {fr.passed} | {fr.failed} | {fr.accepted} | {fr.skipped} | {fr.duration_ms}ms |")
    else:
        parts.push("| File | Total | Passed | Failed | Skipped | Duration |")
        parts.push("|------|-------|--------|--------|---------|----------|")
        for fr in result.files:
            parts.push("| {fr.source_file} | {fr.total} | {fr.passed} | {fr.failed} | {fr.skipped} | {fr.duration_ms}ms |")

    parts.push("")

    # Failure details
    var has_failures = false
    for fr in result.files:
        for br in fr.blocks:
            if br.status == BlockStatus.Failed or br.status == BlockStatus.Error:
                if not has_failures:
                    parts.push("## Failures\n")
                    has_failures = true
                val status_str = if br.status == BlockStatus.Failed: "FAILED" else: "ERROR"
                parts.push("### {fr.source_file}:{br.block.line_number} ({status_str})\n")
                parts.push("```\n{br.error}\n```\n")
                val stderr_trimmed = string_trim(br.stderr)
                if stderr_trimmed != "":
                    val stderr_preview = truncate_text(stderr_trimmed, 500)
                    parts.push("**Stderr:**\n```\n{stderr_preview}\n```\n")

    val content = parts.join("\n")
    file_atomic_write(report_path, content)

# =========================================================================
# Helpers
# =========================================================================

fn truncate_text(s: text, max_len: i64) -> text:
    if s.len() <= max_len:
        return s
    s[0:max_len] + "... (truncated)"

# =========================================================================
# Exports
# =========================================================================

