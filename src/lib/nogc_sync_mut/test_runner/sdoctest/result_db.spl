# SDoctest Result Database
#
# Writes sdoctest results to doc/08_tracking/test/sdoctest_db.sdn in SDN table format.

use std.io.{file_atomic_write}
use std.io.{time_now_unix_micros}
use std.io.{getpid, hostname}
use sdoctest.types.{BlockStatus, SdoctestRunResult}

# =========================================================================
# Public API
# =========================================================================

fn write_sdoctest_db(result: SdoctestRunResult, db_path: text):
    var parts: [text] = []
    parts.push("# SDoctest Results Database")
    parts.push("# Auto-generated by sdoctest runner")
    parts.push("")

    # Run summary table
    val timestamp = time_now_unix_micros()
    val pid = getpid()
    val host = hostname()

    parts.push("sdoctest_runs |run_id, timestamp, pid, hostname, total, passed, failed, skipped, errors, accepted, duration_ms|")
    parts.push("    {timestamp}, {timestamp}, {pid}, {host}, {result.total}, {result.passed}, {result.failed}, {result.skipped}, {result.errors}, {result.accepted}, {result.duration_ms}")
    parts.push("")

    # Block results table
    parts.push("sdoctest_blocks |source_file, line, status, duration_ms, error|")
    for file_result in result.files:
        for br in file_result.blocks:
            val status_str = block_status_to_str(br.status)
            var escaped_error = br.error.replace("\"", "'")
            escaped_error = escaped_error.replace("\n", " ")
            val error_field = if escaped_error != "": "\"{escaped_error}\"" else: "\"\""
            parts.push("    \"{br.block.source_file}\", {br.block.line_number}, {status_str}, {br.duration_ms}, {error_field}")

    file_atomic_write(db_path, parts.join("\n") + "\n")

# =========================================================================
# Helpers
# =========================================================================

fn block_status_to_str(status: BlockStatus) -> text:
    match status:
        case BlockStatus.Passed: "passed"
        case BlockStatus.Failed: "failed"
        case BlockStatus.Skipped: "skipped"
        case BlockStatus.Error: "error"

# =========================================================================
# Exports
# =========================================================================

