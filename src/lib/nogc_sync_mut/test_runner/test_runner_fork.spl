# Test Runner Fork Mode
#
# Runs test files using fork()-without-exec for fast isolation.
# The child process inherits the loaded binary (COW pages) and calls
# rt_cli_run_file() directly — no exec, no binary loading, no CLI parsing.
# OS reclaims all child memory on _exit().
# src/runtime/runtime_fork.c independently applies the same 4 MiB-per-stream
# head/tail capture contract because fork mode does not use the process facade.

use std.test_runner.test_runner_types.{TestFileResult, TestOptions}
use std.test_runner.test_runner_execute.{make_result_from_output}
use std.test_runner.test_result_wrapper.{build_interpreter_result_wrapper}
use std.io.{file_delete, file_exists, time_now_unix_micros}

# SFFI declarations for fork bridge
extern fn rt_fork_child_setup() -> i64
extern fn rt_fork_parent_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_fork_parent_stdout() -> text
extern fn rt_fork_parent_stderr() -> text
extern fn rt_fork_child_exit(code: i64)

# SFFI declaration for running interpreter on a file (Rust-side, already in binary)
extern fn rt_cli_run_file(path: text, args: [text], gc_log: bool, gc_off: bool) -> i64

# =========================================================================
# Fork Mode Execution
# =========================================================================

fn run_test_file_fork(file_path: text, options: TestOptions) -> TestFileResult:
    val (result_path, result_cleanup_path) = build_interpreter_result_wrapper(file_path)
    if result_path == "":
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: 0, setup_ms: 0, error: "failed to build interpreter result wrapper", timed_out: false, cached: false)
    val timeout_ms = options.timeout * 1000
    val start = time_now_unix_micros()

    val pid_or_zero = rt_fork_child_setup()

    # Measure session setup time (fork overhead)
    val after_fork = time_now_unix_micros()
    val setup_ms = (after_fork - start) / 1000

    if pid_or_zero == 0:
        # === CHILD PROCESS ===
        # Binary already in memory (COW), no loading needed.
        # rt_cli_run_file calls the Rust interpreter directly.
        var args: [text] = []
        val result = rt_cli_run_file(result_path, args, options.gc_log, options.gc_off)
        rt_fork_child_exit(result)
        # UNREACHABLE — rt_fork_child_exit calls _exit()
        # Return a dummy value to satisfy type checker
        return TestFileResult(path: file_path, passed: 0, failed: 0, skipped: 0, pending: 0, duration_ms: 0, setup_ms: 0, error: "", timed_out: false, cached: false)

    if pid_or_zero < 0:
        # Fork failed — return error result
        val end = time_now_unix_micros()
        val duration_ms = (end - start) / 1000
        if result_cleanup_path != "" and not options.keep_artifacts and file_exists(result_cleanup_path):
            file_delete(result_cleanup_path)
        return TestFileResult(
            path: file_path,
            passed: 0,
            failed: 1,
            skipped: 0,
            pending: 0,
            duration_ms: duration_ms,
            setup_ms: setup_ms,
            error: "fork() failed",
            timed_out: false,
            cached: false
        )

    # === PARENT PROCESS ===
    val exit_code = rt_fork_parent_wait(pid_or_zero, timeout_ms)
    val stdout = rt_fork_parent_stdout()
    val stderr = rt_fork_parent_stderr()
    val end = time_now_unix_micros()
    if result_cleanup_path != "" and not options.keep_artifacts and file_exists(result_cleanup_path):
        file_delete(result_cleanup_path)
    # duration_ms = only test execution time (excludes fork setup)
    val duration_ms = (end - after_fork) / 1000

    val result = make_result_from_output(file_path, stdout, stderr, exit_code, duration_ms, options.timeout)
    # Attach setup_ms to the result
    TestFileResult(
        path: result.path,
        passed: result.passed,
        failed: result.failed,
        skipped: result.skipped,
        pending: result.pending,
        duration_ms: result.duration_ms,
        setup_ms: setup_ms,
        error: result.error,
        timed_out: result.timed_out,
        cached: result.cached
    )

# =========================================================================
# Exports
# =========================================================================
