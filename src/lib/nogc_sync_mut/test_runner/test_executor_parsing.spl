# Test Executor Parsing & Discovery
#
# Binary location discovery, test output parsing, coverage wrapper generation,
# and static test listing helpers.
#
# Split from test_runner_execute.spl for maintainability.

use std.test_runner.test_runner_types.{TestFileResult, TestOptions}
use std.test_runner.test_runner_files.{strip_ansi, read_file_content}
use std.io.{file_exists, file_write, file_delete}
use std.io.{env_get}
use std.sffi.cli.{cli_get_args}

fn _tp_get_temp_dir() -> text:
    val tmpdir = env_get("TMPDIR")
    if tmpdir != "" and tmpdir != nil:
        return tmpdir
    val tmp = env_get("TMP")
    if tmp != "" and tmp != nil:
        return tmp
    val temp = env_get("TEMP")
    if temp != "" and temp != nil:
        return temp
    val os_env = env_get("OS")
    if os_env != "" and os_env != nil:
        if os_env.lower().contains("windows"):
            return "C:/Windows/Temp"
    "/tmp"

# =========================================================================
# Binary Location Discovery
# =========================================================================

val COVERAGE_BEGIN = "__SIMPLE_COVERAGE_SDN_BEGIN__"
val COVERAGE_END = "__SIMPLE_COVERAGE_SDN_END__"

fn find_simple_new_binary() -> text:
    ""

fn find_runtime_lib_dir() -> text:
    val env_path = env_get("SIMPLE_RUNTIME_PATH")
    if env_path != "" and env_path != nil:
        return env_path
    if file_exists("build/lib/libsimple_compiler.so"):
        return "build/lib"
    if file_exists("build/bootstrap/lib/libsimple_compiler.so"):
        return "build/bootstrap/lib"
    if file_exists("lib/libsimple_compiler.so"):
        return "lib"
    ""

# Cache for find_simple_binary — avoids 15 file_exists probes per test spawn
var _cached_binary_path = ""

fn find_simple_binary() -> text:
    if _cached_binary_path != "":
        return _cached_binary_path

    # Prefer the currently running executable — subprocess tests should use
    # the same binary that invoked the test runner (self-hosted consistency).
    # Guard: when "test" is dispatched by interpreting a .spl entry file
    # in-process (e.g. src/app/test_runner_new/main.spl via the seed), argv[0]
    # is that source file's own path — it exists on disk but is not
    # executable, so trusting it verbatim makes the subprocess spawn fail
    # immediately. Only trust argv[0] when it looks like the compiled binary.
    val args = cli_get_args()
    if args.len() > 0:
        val self_exe = args[0]
        if self_exe != "" and (self_exe.ends_with("/simple") or self_exe.ends_with("simple.exe")) and file_exists(self_exe):
            _cached_binary_path = self_exe
            return self_exe

    # Check environment variable
    val env_path = env_get("SIMPLE_RUNTIME")
    if env_path != "" and env_path != nil:
        if file_exists(env_path):
            _cached_binary_path = env_path
            return env_path

    # Fallback: try multiple known locations.
    val candidates = [
        "bin/simple",
        "./bin/simple",
        "bin/release/linux-x86_64/simple",
        "./bin/release/linux-x86_64/simple",
        "bin/release/aarch64-apple-darwin-macho/simple",
        "./bin/release/aarch64-apple-darwin-macho/simple",
        "bin/release/macos-arm64/simple",
        "./bin/release/macos-arm64/simple",
        "bin/release/darwin-aarch64/simple",
        "./bin/release/darwin-aarch64/simple",
        "bin/release/macos-x86_64/simple",
        "./bin/release/macos-x86_64/simple",
    ]

    for candidate in candidates:
        if file_exists(candidate):
            _cached_binary_path = candidate
            return candidate

    # Fallback to bin/simple so the active setup symlink remains the default.
    _cached_binary_path = "bin/simple"
    "bin/simple"

# =========================================================================
# Test Output Parsing
# =========================================================================

fn _is_test_error_line(clean: text) -> bool:
    clean.contains("semantic:") or clean.contains("parse error:") or clean.contains("compile failed:") or clean.contains("ERROR:") or clean.starts_with("Error:") or clean.starts_with("error:") or clean.contains("unsupported path call:") or clean.contains("not found")

fn extract_error_message(output: text) -> text:
    # Extract first meaningful error message from test output.
    # NOTE: iterates via .split("\n") rather than a manual pos/index_of(needle,
    # start) scan — the seed/bootstrap interpreter's two-argument text.index_of
    # ignores the start offset and always returns the first match, which made
    # the old `pos = next + 1` loop never advance (infinite spin). See
    # doc/08_tracking/bug/test_runner_fresh_seed_silent_noop_2026-07-17.md.
    var result = ""
    var count = 0
    for raw_line in output.split("\n"):
        val clean = strip_ansi(raw_line).trim()
        if _is_test_error_line(clean):
            if result != "":
                result = result + "; "
            result = result + clean
            count = count + 1
            if count >= 3:
                break
    result

fn parse_test_output(output: text) -> (i64, i64, i64, i64):
    var total_passed = 0
    var total_failed = 0
    var total_skipped = 0
    var total_pending = 0
    var summary_passed = -1
    var summary_failed = -1
    var summary_skipped = -1
    var summary_pending = -1
    var summary_passed_pos = -1
    var summary_failed_pos = -1
    var bdd_summary_pos = -1
    var results_seen = false
    var results_valid = false
    var results_pos = -1
    var results_passed = 0
    var results_failed = 0
    var results_skipped = 0
    var results_pending = 0
    # NOTE: line_idx replaces a byte-offset `pos` that used to come from a
    # manual index_of(needle, start)-based scan. The seed/bootstrap
    # interpreter's two-argument text.index_of ignores the start offset and
    # always returns the first match, so `pos = next + 1` never advanced and
    # the loop spun forever. Iterating via .split("\n") sidesteps the buggy
    # primitive entirely; line_idx only needs to preserve *relative* ordering
    # between the tracked positions, which an incrementing per-line counter
    # does identically to the old byte offsets. See
    # doc/08_tracking/bug/test_runner_fresh_seed_silent_noop_2026-07-17.md.
    var line_idx = 0
    for raw_line in output.split("\n"):
        val clean = strip_ansi(raw_line)
        val trimmed = clean.trim()
        val canonical_results = trimmed.starts_with("Results:") and trimmed.contains(" total") and trimmed.contains(" passed") and trimmed.contains(" failed")
        if canonical_results:
            # Start a new summary segment. Authored output before a canonical-
            # shaped line must not leak into a later real BDD/direct summary.
            total_passed = 0
            total_failed = 0
            total_skipped = 0
            total_pending = 0
            summary_passed = -1
            summary_failed = -1
            summary_skipped = -1
            summary_pending = -1
            summary_passed_pos = -1
            summary_failed_pos = -1
            bdd_summary_pos = -1
            results_seen = true
            results_valid = false
            results_pos = line_idx
            val result_total = extract_number_before(s: trimmed, keyword: "total")
            val result_passed = extract_number_before(s: trimmed, keyword: "passed")
            val result_failed = extract_number_before(s: trimmed, keyword: "failed")
            if result_total >= 0 and result_passed >= 0 and result_failed >= 0 and result_total == result_passed + result_failed:
                results_valid = true
                results_passed = result_passed
                results_failed = result_failed
                val parsed_skipped = extract_number_before(s: trimmed, keyword: "skipped")
                val parsed_pending = extract_number_before(s: trimmed, keyword: "pending")
                results_skipped = if parsed_skipped >= 0: parsed_skipped else: 0
                results_pending = if parsed_pending >= 0: parsed_pending else: 0
        elif trimmed.starts_with("Passed:"):
            summary_passed = extract_number_after_colon(s: trimmed, prefix: "Passed:")
            summary_passed_pos = line_idx
        elif trimmed.starts_with("Failed:"):
            summary_failed = extract_number_after_colon(s: trimmed, prefix: "Failed:")
            summary_failed_pos = line_idx
        elif clean.contains("example") and clean.contains("failure"):
            # Accept both plural ("2 examples, 0 failures") and singular
            # ("1 example, 1 failure") summary lines. The interpreter's BDD
            # describe-end uses singular when count == 1; the compile/SMF
            # path always uses plural. Searching for the singular substring
            # ("example", "failure") matches both forms because both plurals
            # start with the singular prefix, so a spec with exactly 1 failing
            # example no longer silently false-greens.
            val examples_count = extract_number_before(s: clean, keyword: "example")
            val failures_count = extract_number_before(s: clean, keyword: "failure")
            if examples_count >= 0 and failures_count >= 0:
                bdd_summary_pos = line_idx
                val passed = examples_count - failures_count
                if passed > 0:
                    total_passed = total_passed + passed
                total_failed = total_failed + failures_count
        # Parse summary line: "Pending: N" from spec.spl print_summary
        if trimmed.starts_with("Pending:"):
            summary_pending = extract_number_after_colon(s: trimmed, prefix: "Pending:")
        elif trimmed.starts_with("Skipped:"):
            summary_skipped = extract_number_after_colon(s: trimmed, prefix: "Skipped:")
        # Count individual "... pending" test lines
        elif not canonical_results and clean.contains("... pending"):
            total_pending = total_pending + 1
        # Count skipped (separate from pending)
        if not canonical_results and not trimmed.starts_with("Skipped:") and clean.contains("skipped"):
            val skip_count2 = extract_number_before(s: clean, keyword: "skipped")
            if skip_count2 > 0:
                total_skipped = total_skipped + skip_count2
        line_idx = line_idx + 1
    # The last complete summary family is authoritative: the outer runner emits
    # Results last, while direct specs emit Passed/Failed after authored output.
    val direct_summary_pos = if summary_passed_pos > summary_failed_pos: summary_passed_pos else: summary_failed_pos
    val direct_summary_after_results = summary_passed >= 0 and summary_failed >= 0 and summary_passed_pos > results_pos and summary_failed_pos > results_pos
    if direct_summary_after_results and direct_summary_pos >= bdd_summary_pos:
        val skipped = if summary_skipped >= 0: summary_skipped else: total_skipped
        val pending = if summary_pending >= 0: summary_pending else: total_pending
        return (summary_passed, summary_failed, skipped, pending)
    if bdd_summary_pos > results_pos:
        return (total_passed, total_failed, total_skipped, total_pending)
    if results_seen:
        if not results_valid:
            return (0, 0, 0, 0)
        return (results_passed, results_failed, results_skipped, results_pending)
    if summary_passed >= 0 and summary_failed >= 0:
        val skipped = if summary_skipped >= 0: summary_skipped else: total_skipped
        val pending = if summary_pending >= 0: summary_pending else: total_pending
        return (summary_passed, summary_failed, skipped, pending)
    (total_passed, total_failed, total_skipped, total_pending)

fn output_has_zero_pass_summary(output: text) -> bool:
    var saw_passed_zero = false
    var saw_failed_zero = false
    for raw_line in output.split("\n"):
        val clean = strip_ansi(raw_line).trim()
        if clean == "Passed: 0":
            saw_passed_zero = true
        elif clean == "Failed: 0":
            saw_failed_zero = true
    saw_passed_zero and saw_failed_zero

fn extract_number_after_colon(s: text, prefix: text) -> i64:
    val idx_opt = s.index_of(prefix)
    val idx = idx_opt ?? -1
    if idx < 0:
        return -1
    val after = s[idx + prefix.len():].trim()
    if after.len() == 0:
        return -1
    # Collect digits from start
    var end_pos = 0
    while end_pos < after.len():
        val ch = after[end_pos:end_pos + 1]
        if ch < "0" or ch > "9":
            break
        end_pos = end_pos + 1
    if end_pos == 0:
        return -1
    val num_str = after[0:end_pos]
    to_int(num_str)

fn extract_number_before(s: text, keyword: text) -> i64:
    val idx_opt = s.index_of(keyword)
    val idx = idx_opt ?? -1
    if idx < 0:
        return -1
    var end = idx - 1
    # Skip whitespace
    while end >= 0:
        val ch = s[end:end + 1]
        if ch != " ":
            break
        end = end - 1
    if end < 0:
        return -1
    # Collect digits backwards
    var start = end
    while start >= 0:
        val ch = s[start:start + 1]
        if ch < "0" or ch > "9":
            break
        start = start - 1
    start = start + 1
    if start > end:
        return -1
    val num_str = s[start:end + 1]
    to_int(num_str)

# =========================================================================
# Child Process Arguments & Result Building
# =========================================================================

fn build_child_args(file_path: text, options: TestOptions) -> [text]:
    # Use the explicit run subcommand so *_spec.spl children do not get
    # routed back into `simple test`, which recursively spawns test runners.
    var args: [text] = ["run", file_path]
    if options.gc_log:
        args.push("--gc-log")
    if options.gc_off:
        args.push("--gc=off")
    args

fn make_result_from_output(file_path: text, stdout: text, stderr: text, exit_code: i32, duration_ms: i64, timeout_secs: i64) -> TestFileResult:
    # Check for timeout
    if exit_code == -1:
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0, duration_ms: duration_ms, setup_ms: 0, error: "TIMEOUT after {timeout_secs}s", timed_out: true, cached: false)

    val combined = stdout + "\n" + stderr
    val (passed, failed, skipped, pending) = parse_test_output(combined)

    if passed == 0 and failed == 0:
        if exit_code == 0:
            val filter = env_get("SIMPLE_TEST_FILTER")
            if filter != "" and filter != nil:
                return TestFileResult(path: file_path, passed: 0, failed: 0, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "", timed_out: false, cached: false)
            if output_has_zero_pass_summary(combined):
                return TestFileResult(path: file_path, passed: 0, failed: 0, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "", timed_out: false, cached: false)
            if env_get("SIMPLE_TEST_ASSERT_RAN") == "1":
                return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "--assert-ran: no executed BDD examples were observed; refusing synthetic pass", timed_out: false, cached: false)
            # No parseable pass/fail summary and no explicit zero-result signal
            # (filter / "Passed: 0 + Failed: 0") was found. Silently defaulting
            # to a synthetic PASS here would false-green any spec whose output
            # format we fail to parse. Refuse the synthetic pass instead.
            return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "no parseable pass/fail summary in test output; refusing synthetic pass", timed_out: false, cached: false)
        else:
            # Extract error message from output
            val extracted_error = extract_error_message(combined)
            val error_msg = if extracted_error != "":
                extracted_error
            else:
                "Process exited with code {exit_code}"
            return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: error_msg, timed_out: false, cached: false)

    # A child process failure always makes the file fail, even when it printed
    # a green summary before crashing or hitting an internal error.
    var effective_failed = failed
    if exit_code != 0 and effective_failed == 0:
        effective_failed = 1

    # Extract error messages when tests fail
    var error = ""
    if effective_failed > 0:
        error = extract_error_message(combined)
        if error == "" and exit_code != 0:
            error = "Process exited with code {exit_code}"

    TestFileResult(path: file_path, passed: passed, failed: effective_failed, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: error, timed_out: false, cached: false)

fn read_structured_test_evidence(path: text) -> (i64, i64, i64):
    if path == "" or not file_exists(path):
        return (0, 0, 0)
    val content = read_file_content(path)
    val parts = content.split("\n")
    if parts.len() < 3 or parts[0] != "simple-bdd-v1":
        return (0, 0, 0)
    val passed_text = parts[1].trim()
    val failed_text = parts[2].trim()
    if passed_text == "" or failed_text == "":
        return (0, 0, 0)
    val passed = to_int(passed_text)
    val failed = to_int(failed_text)
    if passed < 0 or failed < 0 or passed.to_text() != passed_text or failed.to_text() != failed_text:
        return (0, 0, 0)
    if content != "simple-bdd-v1\n{passed_text}\n{failed_text}\n":
        return (0, 0, 0)
    (passed, failed, 1)

fn make_result_from_structured_evidence(file_path: text, stdout: text, stderr: text, exit_code: i32, duration_ms: i64, timeout_secs: i64, evidence_path: text) -> TestFileResult:
    if evidence_path == "" or env_get("SIMPLE_TEST_ASSERT_RAN") != "1":
        return make_result_from_output(file_path, stdout, stderr, exit_code, duration_ms, timeout_secs)
    if exit_code == -1:
        return make_result_from_output(file_path, stdout, stderr, exit_code, duration_ms, timeout_secs)
    val combined = stdout + "\n" + stderr
    val (_, _, skipped, pending) = parse_test_output(combined)
    val (passed, evidence_failed, valid) = read_structured_test_evidence(evidence_path)
    if exit_code != 0:
        val failed = if evidence_failed > 0: evidence_failed else: 1
        return TestFileResult(path: file_path, passed: passed, failed: failed, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "Process exited with code {exit_code}", timed_out: false, cached: false)
    if valid == 0 or passed + evidence_failed == 0:
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: "--assert-ran: no BDD examples executed", timed_out: false, cached: false)
    val error = if evidence_failed > 0: "test-runner: spec failed" else: ""
    TestFileResult(path: file_path, passed: passed, failed: evidence_failed, skipped: skipped, pending: pending, duration_ms: duration_ms, setup_ms: 0, error: error, timed_out: false, cached: false)

# =========================================================================
# Coverage Wrapper Generation
# =========================================================================

fn coverage_wrapper_suffix(file_path: text) -> text:
    if file_path.ends_with("_spec.spl"):
        "_spec.spl"
    else:
        ".spl"

fn build_coverage_wrapper(file_path: text, options: TestOptions) -> (text, text):
    if not options.coverage:
        return (file_path, "")
    val content = read_file_content(file_path)
    if content == "":
        return (file_path, "")

    var base = file_path.replace("/", "_")
    base = base.replace(".spl", "")
    val tmp_path = _tp_get_temp_dir() + "/simple_cov_" + base + coverage_wrapper_suffix(file_path)

    var lines: [text] = []
    lines.push(content)
    lines.push("")
    lines.push("# === Coverage Dump (auto-generated) ===")
    lines.push("extern fn rt_coverage_enabled() -> bool")
    lines.push("extern fn rt_coverage_dump_sdn() -> text")
    lines.push("")
    lines.push("fn __simple_cov_dump():")
    lines.push("    if not rt_coverage_enabled():")
    lines.push("        return")
    lines.push("    val sdn = rt_coverage_dump_sdn()")
    lines.push("    print \"" + COVERAGE_BEGIN + "\"")
    lines.push("    print sdn")
    lines.push("    print \"" + COVERAGE_END + "\"")
    lines.push("")
    lines.push("__simple_cov_dump()")

    val wrapped = lines.join("\n")
    file_write(tmp_path, wrapped)
    (tmp_path, tmp_path)

fn extract_coverage_sdn(output: text) -> text:
    var in_block = false
    var result = ""
    for raw_line in output.split("\n"):
        val clean = strip_ansi(raw_line).trim()
        if clean == COVERAGE_BEGIN:
            in_block = true
        elif clean == COVERAGE_END:
            in_block = false
        elif in_block:
            if result != "":
                result = result + "\n"
            result = result + raw_line
    result

fn strip_coverage_blocks(output: text) -> text:
    var in_block = false
    var result = ""
    for raw_line in output.split("\n"):
        val clean = strip_ansi(raw_line).trim()
        if clean == COVERAGE_BEGIN:
            in_block = true
        elif clean == COVERAGE_END:
            in_block = false
        elif not in_block:
            if result != "":
                result = result + "\n"
            result = result + raw_line
    result

# =========================================================================
# G3: Static test listing (parse source without execution)
# =========================================================================

fn list_tests_static(files: [text]) -> [text]:
    var test_names: [text] = []
    for file_path in files:
        val content = read_file_content(file_path)
        if content == "":
            continue
        val lines = content.split("\n")
        for line in lines:
            val trimmed = line.trim()
            # Match: it "...", slow_it "...", test "..."
            val name = extract_static_test_name(trimmed)
            if name != "":
                test_names.push("{file_path}::{name}")
    test_names

fn extract_static_test_name(line: text) -> text:
    # it "description"
    if line.starts_with("it \""):
        val end = line.index_of("\"", 4) ?? -1
        if end > 4:
            return line[4:end]
    # slow_it "description"
    if line.starts_with("slow_it \""):
        val end = line.index_of("\"", 9) ?? -1
        if end > 9:
            return "[slow] " + line[9:end]
    # test "description"
    if line.starts_with("test \""):
        val end = line.index_of("\"", 6) ?? -1
        if end > 6:
            return line[6:end]
    # pending_on "description"
    if line.starts_with("pending_on \""):
        val end = line.index_of("\"", 12) ?? -1
        if end > 12:
            return "[pending] " + line[12:end]
    ""

# =========================================================================
# Exports
# =========================================================================

export COVERAGE_BEGIN, COVERAGE_END
export find_simple_new_binary, find_runtime_lib_dir, find_simple_binary
export extract_error_message, parse_test_output
export extract_number_before, extract_number_after_colon
export build_child_args, make_result_from_output, read_structured_test_evidence, make_result_from_structured_evidence
export coverage_wrapper_suffix, build_coverage_wrapper
export extract_coverage_sdn, strip_coverage_blocks
export list_tests_static, extract_static_test_name
