fn run_test_file_jit_ch32v307(file_path: text, source: text, options: TestOptions) -> TestFileResult:
    val setup_start = time_now_unix_micros()
    val wlink = shell("command -v wlink >/dev/null 2>&1")
    val detected = shell("timeout 10 wlink status --chip CH32V30X 2>&1")
    val setup_end = time_now_unix_micros()
    val setup_ms = (setup_end - setup_start) / 1000

    if wlink.exit_code != 0:
        return TestFileResult(path: file_path, passed: 0, failed: 0, skipped: 1, pending: 0,
            duration_ms: 0, setup_ms: setup_ms,
            error: "CH32V307 direct hardware path unavailable: wlink not installed", timed_out: false, cached: false)

    val combined = detected.stdout + detected.stderr
    if detected.exit_code != 0 or not combined.contains("CH32V307"):
        return TestFileResult(path: file_path, passed: 0, failed: 0, skipped: 1, pending: 0,
            duration_ms: 0, setup_ms: setup_ms,
            error: "CH32V307 direct hardware path unavailable: probe not detected through wlink", timed_out: false, cached: false)

    var adapter = Ch32V307Adapter.new()
    run_test_file_jit_with_adapter(
        file_path, source, options,
        Architecture.RiscV32, MemoryMap.ch32v307(),
        \: adapter.connect(),
        \: adapter.create_manager(),
        \: adapter.disconnect()
    )

