@allow(unnamed_duplicate_typed_args)
# Generic Composite JIT Helpers
#
# Shared QEMU/STM32WB JIT runner helpers extracted out of the STM32H7-first
# composite runner so STM32H7 can load without the generic enum-heavy paths.

use test_runner_types.{TestFileResult, TestOptions}
use std.io.{time_now_unix_micros}
use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.types.{Architecture}
use std.nogc_sync_mut.debug.remote.exec.{ExecResult, MemoryMap}
use std.nogc_sync_mut.debug.remote.exec.manager.{RemoteExecutionManager}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_rv32.{QemuRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_arm.{QemuArmAdapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_stm32wb.{Stm32WbAdapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_stm32h7.{Stm32H7Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_ch32v307.{Ch32V307Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_trace32.{Trace32Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_ghdl_rv32.{GhdlRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{compile_remote_binary}
use std.nogc_sync_mut.jit.jit_types.{JitBinary}
use std.nogc_sync_mut.jit.jit_layout.{plan_binary_layout}

fn run_test_file_jit_qemu_rv32(file_path: text, source: text, options: TestOptions) -> TestFileResult:
    var adapter = QemuRv32Adapter.new()
    run_test_file_jit_with_adapter(
        file_path, source, options,
        Architecture.RiscV32, MemoryMap.qemu_rv32(),
        \: adapter.connect(),
        \: adapter.create_manager(),
        \: adapter.disconnect()
    )

fn run_test_file_jit_qemu_arm(file_path: text, source: text, options: TestOptions) -> TestFileResult:
    var adapter = QemuArmAdapter.new()
    run_test_file_jit_with_adapter(
        file_path, source, options,
        Architecture.Arm32, MemoryMap.qemu_arm(),
        \: adapter.connect(),
        \: adapter.create_manager(),
        \: adapter.disconnect()
    )

