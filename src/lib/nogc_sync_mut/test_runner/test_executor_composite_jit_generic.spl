        \: adapter.disconnect()
    )

fn run_test_file_jit_with_adapter(
    file_path: text,
    source: text,
    options: TestOptions,
    arch: Architecture,
    memory_map: MemoryMap,
    connect_fn: fn() -> Result<text, text>,
    create_manager_fn: fn() -> Result<RemoteExecutionManager, text>,
    disconnect_fn: fn()
) -> TestFileResult:
    val setup_start = time_now_unix_micros()
    val connect_result = connect_fn()
    if connect_result.is_err():
        val end = time_now_unix_micros()
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: 0, setup_ms: (end - setup_start) / 1000,
            error: "JIT target connect failed: {connect_result.err().unwrap()}", timed_out: false, cached: false)

    val compile_result = compile_remote_binary(source, arch, memory_map.code_start)
    if compile_result.is_err():
        disconnect_fn()
        val end = time_now_unix_micros()
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: 0, setup_ms: (end - setup_start) / 1000,
            error: "JIT compile failed: {compile_result.err().unwrap()}", timed_out: false, cached: false)

    val bytes = compile_result.ok.unwrap()
    val binary = JitBinary(name: file_path, bytes: bytes, entry_offset: 0, stack_bytes: 0, arch: arch)
    val layout_result = plan_binary_layout(binary, memory_map, arch)
    if layout_result.is_err():
        disconnect_fn()
        val end = time_now_unix_micros()
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: 0, setup_ms: (end - setup_start) / 1000,
            error: "JIT layout failed: {layout_result.err().unwrap()}", timed_out: false, cached: false)

    val manager_result = create_manager_fn()
    if manager_result.is_err():
        disconnect_fn()
        val end = time_now_unix_micros()
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: 0, setup_ms: (end - setup_start) / 1000,
            error: "JIT manager creation failed: {manager_result.err().unwrap()}", timed_out: false, cached: false)

    val setup_end = time_now_unix_micros()
    val setup_ms = (setup_end - setup_start) / 1000
    var manager = manager_result.ok.unwrap()
    val exec_result = manager.execute_bytes(file_path, bytes, [])
    disconnect_fn()
    make_jit_result(file_path, exec_result, options, setup_ms)

fn make_jit_result(file_path: text, exec_result: Result<ExecResult, text>, options: TestOptions, setup_ms: i64) -> TestFileResult:
    if exec_result.is_err():
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: options.timeout * 1000, setup_ms: setup_ms,
            error: "JIT execute failed: {exec_result.err().unwrap()}", timed_out: false, cached: false)

    val exec = exec_result.ok.unwrap()
    if not exec.is_ok():
        return TestFileResult(path: file_path, passed: 0, failed: 1, skipped: 0, pending: 0,
            duration_ms: exec.duration_ms, setup_ms: setup_ms, error: exec.error, timed_out: false, cached: false)

    val passed = if exec.return_value == 0: 1 else: 0
    val failed = if exec.return_value == 0: 0 else: 1
    val error = if exec.return_value == 0: "" else: "JIT program returned non-zero: {exec.return_value}"
    TestFileResult(path: file_path, passed: passed, failed: failed, skipped: 0, pending: 0,
        duration_ms: exec.duration_ms, setup_ms: setup_ms, error: error, timed_out: false, cached: false)
