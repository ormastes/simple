# QEMU Test Runner — Orchestrates QEMU test execution with session sharing
#
# Uses the QemuBroker for session pooling and QMP for snapshot/restore.
# Groups tests by (arch, session_mode) to minimize VM boots.

use app.test_daemon.qemu_broker.{QemuBroker, QemuSessionEntry, qemu_broker_new, QEMU_IDLE}
use app.test_runner_new.test_runner_types.{TestFileResult, TestOptions}
use app.test_runner_new.test_runner_execute.{run_test_file_composite}
use app.test_runner_new.test_classification.{TestClassification, classify_test, group_by_session, separate_qemu_tests}
use app.test_runner_new.test_classification.{SESSION_READ_ONLY, SESSION_MUTATING, SESSION_DESTRUCTIVE}
use app.test_runner_new.test_runner_output.{print_result}

# ============================================================================
# Run a group of QEMU tests sharing one session
# ============================================================================

fn run_qemu_test_group(
    group: [TestClassification],
    broker: QemuBroker,
    options: TestOptions
) -> [TestFileResult]:
    var results: [TestFileResult] = []

    if group.len() == 0:
        return results

    val arch = group[0].arch
    val mode = group[0].session_mode

    # Acquire session from broker (boots QEMU if needed)
    val session = broker.acquire_with_snapshot(arch, "")

    print "  [qemu] Session {session.session_key}: {group.len()} tests (arch={arch})"

    for test in group:
        # Restore golden snapshot for mutating tests
        if mode == SESSION_MUTATING and session.has_golden_snapshot:
            val restored = broker.snapshot_restore(session.session_key, "golden")
            if not restored:
                print "  [qemu] WARNING: snapshot restore failed for {test.file_path}"

        # Build composite spec for this arch
        val spec = "interpreter(baremetal({arch}))"

        # Run the test
        val result = run_test_file_composite(test.file_path, options, spec)
        print_result(result, options.format)
        results.push(result)

    # Release session back to broker
    broker.release(session.session_key)

    results

# ============================================================================
# Run all QEMU tests with session sharing
# ============================================================================

fn run_qemu_tests_all(
    files: [text],
    options: TestOptions
) -> [TestFileResult]:
    var results: [TestFileResult] = []

    if files.len() == 0:
        return results

    # Classify all test files
    var classifications: [TestClassification] = []
    for f in files:
        classifications.push(classify_test(f))

    # Group by (arch, session_mode)
    val groups = group_by_session(classifications)

    # Create broker (max 4 concurrent QEMU sessions)
    var broker = qemu_broker_new(4)

    print "[qemu] Running {files.len()} QEMU tests in {groups.len()} groups"

    # Run each group
    for group in groups:
        val group_results = run_qemu_test_group(group, broker, options)
        for r in group_results:
            results.push(r)

    # Shutdown all sessions
    broker.shutdown_all()

    results

# ============================================================================
# Exports
# ============================================================================

