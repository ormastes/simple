# DbFsDriver — DBFS filesystem driver for the VFS mount table.
#
# In-memory implementation backed by module-level inode/fd stores keyed by
# instance_id. This works around the interpreter value-semantics limitation
# (field mutations on struct copies are lost when dispatching through MountTable).
#
# Maps to: AC-1, AC-2, AC-6, AC-9, D1.

use std.io_runtime
use common.string_core.{str_char_at}
use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, DirHandle, Path, OpenFlags, DirEntry, StatInfo}
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.fs_driver.extension.{Extension, PosixCompatExt}
use std.db.dbfs_engine.wal.{DbfsWal, WalRecord, WAL_RECORD_DATA}
use std.db.dbfs_engine.txn.{DbfsTxn, TxnId}

# --- Internal inode kinds ---

enum DbFsKind:
    File
    Dir

# --- Internal inode (stored in module-level table) ---

struct DbFsInode:
    inst_id:  i64
    id:       u64
    kind:     DbFsKind
    name:     text
    content:  text
    parent:   u64
    size:     i64
    unlinked: bool

# --- Open file descriptor entry (stored in module-level table) ---

struct DbFsFd:
    inst_id:    i64
    handle_id:  u64
    inode_id:   u64
    is_dir:     bool
    closed:     bool

# --- Module-level persistent stores ---
# Keyed by inst_id so multiple driver instances are isolated.

var _dbfs_inodes: [DbFsInode] = []
var _dbfs_fds:    [DbFsFd] = []
var _dbfs_next_inst: i64 = 1

# --- DbFsDriver struct ---

struct DbFsDriver:
    """DBFS filesystem driver.

    name        — driver identifier returned by driver_name().
    inst_id     — unique instance ID (keys into _dbfs_inodes / _dbfs_fds).
    next_id     — next inode id to assign (module-level ops use this as seed).
    next_fd     — next handle id to assign.
    wal         — write-ahead log for group-commit.
    flush_count — number of group_commit() / WAL flush calls.
    """
    name:        text
    inst_id:     i64
    next_id:     u64
    next_fd:     u64
    wal:         DbfsWal
    flush_count: i64

# --- Module-level store helpers ---

fn _find_inode_idx(inst_id: i64, path: text) -> i32:
    """Return index in _dbfs_inodes for (inst_id, path), or -1."""
    var i: i32 = 0
    while i < _dbfs_inodes.len() as i32:
        val n = _dbfs_inodes[i]
        if n.inst_id == inst_id and n.name == path and not n.unlinked:
            return i
        i = i + 1
    -1

fn _find_fd_idx(inst_id: i64, handle_id: u64) -> i32:
    """Return index in _dbfs_fds for (inst_id, handle_id), or -1."""
    var i: i32 = 0
    while i < _dbfs_fds.len() as i32:
        val f = _dbfs_fds[i]
        if f.inst_id == inst_id and f.handle_id == handle_id:
            return i
        i = i + 1
    -1

fn _fd_inode_idx(inst_id: i64, handle_id: u64) -> i32:
    """Return inode index for an open (non-closed) fd, or -1."""
    val fd_idx = _find_fd_idx(inst_id, handle_id)
    if fd_idx < 0:
        return -1
    val fd = _dbfs_fds[fd_idx]
    if fd.closed:
        return -1
    var j: i32 = 0
    while j < _dbfs_inodes.len() as i32:
        if _dbfs_inodes[j].inst_id == inst_id and _dbfs_inodes[j].id == fd.inode_id:
            return j
        j = j + 1
    -1

fn _alloc_inst_id() -> i64:
    """Allocate a fresh instance id and advance the counter."""
    val id = _dbfs_next_inst
    _dbfs_next_inst = _dbfs_next_inst + 1
    id

fn _alloc_inode_id(inst_id: i64) -> u64:
    """Return max inode id for this instance + 1 (for new allocation)."""
    var max_id: u64 = 1
    for n in _dbfs_inodes:
        if n.inst_id == inst_id and n.id >= max_id:
            max_id = n.id + 1
    max_id

fn _alloc_fd_id(inst_id: i64) -> u64:
    """Return max fd id for this instance + 1 (for new allocation)."""
    var max_id: u64 = 1
    for f in _dbfs_fds:
        if f.inst_id == inst_id and f.handle_id >= max_id:
            max_id = f.handle_id + 1
    max_id

impl DbFsDriver:
    static fn new_hosted() -> DbFsDriver:
        """Create a new in-memory DBFS driver with a root inode."""
        val iid = _alloc_inst_id()
        # Install root inode
        _dbfs_inodes.push(DbFsInode(
            inst_id:  iid,
            id:       1,
            kind:     DbFsKind.Dir,
            name:     "/",
            content:  "",
            parent:   0,
            size:     0,
            unlinked: false,
        ))
        DbFsDriver(
            name:        "DbFsDriver",
            inst_id:     iid,
            next_id:     2,
            next_fd:     1,
            wal:         DbfsWal.new(),
            flush_count: 0,
        )

    # --- stat ---

    fn stat_path(path: Path) -> Result<StatInfo, FsError>:
        """Stat path: look up inode by name in module store."""
        val raw = path.raw
        if raw == "/" or raw == "":
            return Ok(StatInfo(is_dir: true, is_file: false, size: 0))
        val idx = _find_inode_idx(self.inst_id, raw)
        if idx < 0:
            return Err(FsError.NotFound)
        val inode = _dbfs_inodes[idx]
        val is_dir: bool = match inode.kind:
            case Dir:  true
            case File: false
        Ok(StatInfo(is_dir: is_dir, is_file: not is_dir, size: inode.size))

    fn stat(path: text) -> Result<StatInfo, FsError>:
        """Stat path as text."""
        self.stat_path(Path(raw: path))

    # --- open ---

    fn open_path(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Open a file by path. Creates inode if not present."""
        val raw = path.raw
        var inode_id: u64 = 0
        val idx = _find_inode_idx(self.inst_id, raw)
        if idx >= 0:
            inode_id = _dbfs_inodes[idx].id
        else:
            inode_id = _alloc_inode_id(self.inst_id)
            _dbfs_inodes.push(DbFsInode(
                inst_id:  self.inst_id,
                id:       inode_id,
                kind:     DbFsKind.File,
                name:     raw,
                content:  "",
                parent:   1,
                size:     0,
                unlinked: false,
            ))
        val hid = _alloc_fd_id(self.inst_id)
        _dbfs_fds.push(DbFsFd(
            inst_id:    self.inst_id,
            handle_id:  hid,
            inode_id:   inode_id,
            is_dir:     false,
            closed:     false,
        ))
        Ok(FileHandle(id: hid))

    # --- opendir ---

    fn opendir_path(path: Path) -> Result<DirHandle, FsError>:
        """Open a directory by path."""
        val hid = _alloc_fd_id(self.inst_id)
        _dbfs_fds.push(DbFsFd(
            inst_id:    self.inst_id,
            handle_id:  hid,
            inode_id:   1,
            is_dir:     true,
            closed:     false,
        ))
        Ok(DirHandle(id: hid))

    # --- readdir ---

    fn readdir_handle(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """Return directory entries for handle."""
        var entries: [DirEntry] = []
        for inode in _dbfs_inodes:
            if inode.inst_id == self.inst_id and not inode.unlinked and inode.id != 1:
                val is_dir_entry: bool = match inode.kind:
                    case Dir:  true
                    case File: false
                entries.push(DirEntry(name: inode.name, is_dir: is_dir_entry))
        Ok(entries)

    # --- read ---

    fn read_handle(handle: FileHandle, length: i64) -> Result<text, FsError>:
        """Read up to length bytes from open handle."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Ok("")
        val content = _dbfs_inodes[inode_idx].content
        var result: text = ""
        var i: i64 = 0
        val cap: i64 = if length < content.len(): length else: content.len()
        while i < cap:
            result = result + str_char_at(content, i)
            i = i + 1
        Ok(result)

    # --- pread ---

    fn pread_handle(handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
        """Read length chars starting at offset."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val content = _dbfs_inodes[inode_idx].content
        var result: text = ""
        var i: i64 = offset
        val end_pos: i64 = offset + length
        val content_end: i64 = if end_pos < content.len(): end_pos else: content.len()
        while i < content_end:
            result = result + str_char_at(content, i)
            i = i + 1
        # Pad with null chars if beyond content length
        var pad: i64 = content_end - offset
        while pad < length:
            result = result + "\0"
            pad = pad + 1
        Ok(result)

    # --- write ---

    fn write_handle(handle: FileHandle, content: text) -> Result<(), FsError>:
        """Write content to open handle."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  content,
            parent:   old.parent,
            size:     content.len(),
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- pwrite ---

    fn pwrite_handle(handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
        """Write patch starting at offset (COW semantics)."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val old_content = old.content
        var new_content: text = ""
        var i: i64 = 0
        while i < offset:
            if i < old_content.len():
                new_content = new_content + str_char_at(old_content, i)
            else:
                new_content = new_content + "\0"
            i = i + 1
        var j: i64 = 0
        while j < patch.len():
            new_content = new_content + str_char_at(patch, j)
            j = j + 1
        var k: i64 = offset + patch.len()
        while k < old_content.len():
            new_content = new_content + str_char_at(old_content, k)
            k = k + 1
        val new_size: i64 = if new_content.len() > old.size: new_content.len() else: old.size
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  new_content,
            parent:   old.parent,
            size:     new_size,
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- close ---

    fn close_handle(handle: FileHandle) -> Result<(), FsError>:
        """Mark file descriptor closed."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        val old_fd = _dbfs_fds[fd_idx]
        val new_fd = DbFsFd(
            inst_id:    old_fd.inst_id,
            handle_id:  old_fd.handle_id,
            inode_id:   old_fd.inode_id,
            is_dir:     old_fd.is_dir,
            closed:     true,
        )
        _dbfs_fds.remove(fd_idx)
        _dbfs_fds.push(new_fd)
        Ok(())

    # --- unlink ---

    fn unlink_path(path: text) -> Result<(), FsError>:
        """Mark inode unlinked. Open handles still readable until closed."""
        val idx = _find_inode_idx(self.inst_id, path)
        if idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  old.content,
            parent:   old.parent,
            size:     old.size,
            unlinked: true,
        )
        _dbfs_inodes.remove(idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- rename ---

    fn rename_path(old_path: text, new_path: text) -> Result<(), FsError>:
        """Rename: atomically replace new_path with old_path's inode."""
        # Remove existing target if present
        val target_idx = _find_inode_idx(self.inst_id, new_path)
        if target_idx >= 0:
            _dbfs_inodes.remove(target_idx)
        val src_idx = _find_inode_idx(self.inst_id, old_path)
        if src_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[src_idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     new_path,
            content:  old.content,
            parent:   old.parent,
            size:     old.size,
            unlinked: false,
        )
        _dbfs_inodes.remove(src_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- ftruncate ---

    fn ftruncate_handle(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        """Truncate or extend file to new_size."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val old_content = old.content
        var new_content: text = ""
        var i: i64 = 0
        while i < new_size:
            if i < old_content.len():
                new_content = new_content + str_char_at(old_content, i)
            else:
                new_content = new_content + "\0"
            i = i + 1
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  new_content,
            parent:   old.parent,
            size:     new_size,
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- mkdir ---

    fn mkdir_path(path: text, mode: u32) -> Result<(), FsError>:
        """Create a directory at path."""
        val iid = _alloc_inode_id(self.inst_id)
        _dbfs_inodes.push(DbFsInode(
            inst_id:  self.inst_id,
            id:       iid,
            kind:     DbFsKind.Dir,
            name:     path,
            content:  "",
            parent:   1,
            size:     0,
            unlinked: false,
        ))
        Ok(())

    fn mkdir(path: text, mode: u32) -> Result<(), FsError>:
        """Alias for mkdir_path (direct driver API)."""
        self.mkdir_path(path, mode)

    # --- capability / extension ---

    fn probe(cap: Capability) -> Option<Extension>:
        """Return capability extension handle for DBFS-supported capabilities."""
        match cap:
            case PosixCompat:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Xattr:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Acl:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Snapshot:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case COW:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case LargeFiles:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case _:
                None

    fn capabilities() -> CapabilitySet:
        """Return the set of capabilities this driver supports."""
        CapabilitySet.empty()
            .with(Capability.PosixCompat)
            .with(Capability.Xattr)
            .with(Capability.Acl)
            .with(Capability.Snapshot)
            .with(Capability.COW)
            .with(Capability.LargeFiles)

    # --- transaction ---

    fn begin_txn() -> DbfsTxn:
        """Begin a new transaction on this driver."""
        val txn_id = TxnId(value: _alloc_fd_id(self.inst_id) as i64)
        DbfsTxn.new(txn_id)

    fn flush_call_count() -> i64:
        """Return number of WAL flush calls (DURABLE_GROUP_COMMIT counter)."""
        self.flush_count

    me fn group_commit() -> Result<(), text>:
        """Flush all pending WAL records (DURABLE_GROUP_COMMIT)."""
        val r = self.wal.flush_wal()
        if r.is_ok():
            self.flush_count = self.flush_count + 1
        r
