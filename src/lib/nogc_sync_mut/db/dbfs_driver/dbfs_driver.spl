# DbFsDriver — DBFS filesystem driver for the VFS mount table.
#
# In-memory implementation backed by module-level inode/fd stores keyed by
# instance_id. This works around the interpreter value-semantics limitation
# (field mutations on struct copies are lost when dispatching through MountTable).
#
# Maps to: AC-1, AC-2, AC-6, AC-9, D1.

use std.io_runtime
use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, DirHandle, Path, OpenFlags, DirEntry, StatInfo}
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.fs_driver.extension.{Extension, PosixCompatExt}
use std.db.dbfs_engine.wal.{DbfsWal, WalRecord, WAL_RECORD_DATA}
use std.db.dbfs_engine.txn.{DbfsTxn, TxnId}
use std.db.dbfs_engine.raw_nvme_arena.{RawNvmeArena}
use std.fs_driver.block_device.{BlockDevice}
use std.storage.durability.{DurabilityClass}
use std.storage.storage_class.{StorageClass}
use std.storage.nvme_feature_policy.{samsung_mzql2960hcjr_sysfs_facts, nvme_policy_for_class}

extern fn rt_text_to_bytes(s: text) -> [u8]

# --- Internal inode kinds ---

enum DbFsKind:
    File
    Dir

# --- Internal inode (stored in module-level table) ---

struct DbFsInode:
    inst_id:  i64
    id:       u64
    kind:     DbFsKind
    name:     text
    content:  text
    content_bytes: [u8]
    parent:   u64
    size:     i64
    unlinked: bool

# --- Open file descriptor entry (stored in module-level table) ---

struct DbFsFd:
    inst_id:    i64
    handle_id:  u64
    inode_id:   u64
    is_dir:     bool
    closed:     bool

# --- Module-level persistent stores ---
# Keyed by inst_id so multiple driver instances are isolated.

var _dbfs_inodes: [DbFsInode] = []
var _dbfs_fds:    [DbFsFd] = []
var _dbfs_next_inst: i64 = 1

fn _dbfs_text_to_bytes(value: text) -> [u8]:
    rt_text_to_bytes(value)

fn _dbfs_bytes_to_text(buf: [u8], count: i64) -> text:
    var result: text = ""
    var i: i64 = 0
    while i < count and i < buf.len():
        result = result + buf[i as i32].chr()
        i = i + 1
    result

fn _dbfs_slice_bytes(buf: [u8], count: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < count and i < buf.len():
        out.push(buf[i as i32])
        i = i + 1
    out

# --- DbFsDriver struct ---

struct DbFsDriver:
    """DBFS filesystem driver.

    name             — driver identifier returned by driver_name().
    inst_id          — unique instance ID (keys into _dbfs_inodes / _dbfs_fds).
    next_id          — next inode id to assign (module-level ops use this as seed).
    next_fd          — next handle id to assign.
    wal              — write-ahead log for group-commit.
    flush_count      — number of group_commit() / WAL flush calls.
    arena_base       — base_block of the backing RawNvmeArena, or -1 for in-memory.
    arena_block_count — block_count of the backing RawNvmeArena (0 if not device-backed).
    io_unit_bytes    — preferred physical write unit.
    batch_bytes      — preferred batch size for WAL/data writes.
    trim_supported   — backing namespace supports discard/deallocate.
    write_zeroes_supported — backing namespace supports write-zeroes.
    """
    name:             text
    inst_id:          i64
    next_id:          u64
    next_fd:          u64
    wal:              DbfsWal
    flush_count:      i64
    arena_base:       i64
    arena_block_count: i64
    io_unit_bytes:    i64
    batch_bytes:      i64
    trim_supported:   bool
    write_zeroes_supported: bool

# --- Module-level store helpers ---

fn _find_inode_idx(inst_id: i64, path: text) -> i32:
    """Return index in _dbfs_inodes for (inst_id, path), or -1."""
    var i: i32 = 0
    while i < _dbfs_inodes.len() as i32:
        val n = _dbfs_inodes[i]
        if n.inst_id == inst_id and n.name == path and not n.unlinked:
            return i
        i = i + 1
    -1

fn _find_fd_idx(inst_id: i64, handle_id: u64) -> i32:
    """Return index in _dbfs_fds for (inst_id, handle_id), or -1."""
    var i: i32 = 0
    while i < _dbfs_fds.len() as i32:
        val f = _dbfs_fds[i]
        if f.inst_id == inst_id and f.handle_id == handle_id:
            return i
        i = i + 1
    -1

fn _fd_inode_idx(inst_id: i64, handle_id: u64) -> i32:
    """Return inode index for an open (non-closed) fd, or -1."""
    val fd_idx = _find_fd_idx(inst_id, handle_id)
    if fd_idx < 0:
        return -1
    val fd = _dbfs_fds[fd_idx]
    if fd.closed:
        return -1
    var j: i32 = 0
    while j < _dbfs_inodes.len() as i32:
        if _dbfs_inodes[j].inst_id == inst_id and _dbfs_inodes[j].id == fd.inode_id:
            return j
        j = j + 1
    -1

fn _alloc_inst_id() -> i64:
    """Allocate a fresh instance id and advance the counter."""
    val id = _dbfs_next_inst
    _dbfs_next_inst = _dbfs_next_inst + 1
    id

fn _alloc_inode_id(inst_id: i64) -> u64:
    """Return max inode id for this instance + 1 (for new allocation)."""
    var max_id: u64 = 1
    for n in _dbfs_inodes:
        if n.inst_id == inst_id and n.id >= max_id:
            max_id = n.id + 1
    max_id

fn _alloc_fd_id(inst_id: i64) -> u64:
    """Return max fd id for this instance + 1 (for new allocation)."""
    var max_id: u64 = 1
    for f in _dbfs_fds:
        if f.inst_id == inst_id and f.handle_id >= max_id:
            max_id = f.handle_id + 1
    max_id

impl DbFsDriver:
    static fn new_hosted() -> DbFsDriver:
        """Create a new in-memory DBFS driver with a root inode."""
        val iid = _alloc_inst_id()
        # Install root inode
        _dbfs_inodes.push(DbFsInode(
            inst_id:  iid,
            id:       1,
            kind:     DbFsKind.Dir,
            name:     "/",
            content:  "",
            content_bytes: [],
            parent:   0,
            size:     0,
            unlinked: false,
        ))
        DbFsDriver(
            name:              "DbFsDriver",
            inst_id:           iid,
            next_id:           2,
            next_fd:           1,
            wal:               DbfsWal.new(),
            flush_count:       0,
            arena_base:        -1,
            arena_block_count: 0,
            io_unit_bytes:     512,
            batch_bytes:       4096,
            trim_supported:    false,
            write_zeroes_supported: false,
        )

    static fn open_on_device(dev: BlockDevice, base_block: i64, block_count: i64) -> Result<DbFsDriver, FsError>:
        """Create a DBFS driver backed by a real BlockDevice region.

        Registers a RawNvmeArena over [base_block, base_block+block_count) on dev.
        Returns Ok(DbFsDriver) with arena_base set; arena writes go through
        BlockDevice.write_sector. In-memory inode store is still used for the
        directory/file metadata layer (see write_passthrough for raw arena I/O).
        """
        val arena = RawNvmeArena.new(dev, base_block, block_count)
        val iid = _alloc_inst_id()
        # Install root inode in the in-memory layer (same as new_hosted).
        _dbfs_inodes.push(DbFsInode(
            inst_id:  iid,
            id:       1,
            kind:     DbFsKind.Dir,
            name:     "/",
            content:  "",
            content_bytes: [],
            parent:   0,
            size:     0,
            unlinked: false,
        ))
        Ok(DbFsDriver(
            name:              "DbFsDriver",
            inst_id:           iid,
            next_id:           2,
            next_fd:           1,
            wal:               DbfsWal.new(),
            flush_count:       0,
            arena_base:        base_block,
            arena_block_count: block_count,
            io_unit_bytes:     dev.sector_size() as i64,
            batch_bytes:       dev.sector_size() as i64,
            trim_supported:    false,
            write_zeroes_supported: false,
        ))

    static fn open_on_samsung_business_nvme(dev: BlockDevice, base_block: i64, block_count: i64) -> Result<DbFsDriver, FsError>:
        """Open DBFS on the attached Samsung business NVMe policy.

        The current observed MZQL2960HCJR namespace is conventional NVMe
        (not ZNS/FDP) with 4 KiB physical blocks, 128 KiB optimal I/O, discard,
        and write-zeroes. This constructor carries those policy facts into the
        DBFS driver without issuing raw admin/vendor commands.
        """
        val opened = DbFsDriver.open_on_device(dev, base_block, block_count)
        if opened.is_err():
            return opened
        var driver = opened.unwrap()
        val facts = samsung_mzql2960hcjr_sysfs_facts()
        val policy = nvme_policy_for_class(facts, StorageClass.DB_WAL)
        driver.io_unit_bytes = policy.io_unit_bytes
        driver.batch_bytes = policy.batch_bytes
        driver.trim_supported = policy.uses_discard
        driver.write_zeroes_supported = policy.uses_write_zeroes
        Ok(driver)

    fn preferred_io_unit_bytes() -> i64:
        self.io_unit_bytes

    fn preferred_batch_bytes() -> i64:
        self.batch_bytes

    fn has_trim_support() -> bool:
        self.trim_supported

    fn has_write_zeroes_support() -> bool:
        self.write_zeroes_supported

    fn write_passthrough(data: [u8]) -> Result<i64, FsError>:
        """Write raw bytes directly to the backing BlockDevice via RawNvmeArena.

        Only available when the driver was constructed via open_on_device.
        Returns Ok(bytes_written) on success, Err(FsError.Unsupported) when
        the driver is in-memory only (arena_base == -1).
        """
        if self.arena_base < 0:
            return Err(FsError.Unsupported)
        val arena = RawNvmeArena(base_block: self.arena_base, block_count: self.arena_block_count)
        val handle = arena.arena_handle()
        val r = arena.arena_append(handle, data, DurabilityClass.BestEffort)
        if r.generation < 0:
            return Err(FsError.IoError(code: 0))
        Ok(r.bytes_written)

    # --- stat ---

    fn stat_path(path: Path) -> Result<StatInfo, FsError>:
        """Stat path: look up inode by name in module store."""
        val raw = path.raw
        if raw == "/" or raw == "":
            return Ok(StatInfo(is_dir: true, is_file: false, size: 0))
        val idx = _find_inode_idx(self.inst_id, raw)
        if idx < 0:
            return Err(FsError.NotFound)
        val inode = _dbfs_inodes[idx]
        val is_dir: bool = match inode.kind:
            case Dir:  true
            case File: false
        Ok(StatInfo(is_dir: is_dir, is_file: not is_dir, size: inode.size))

    fn stat(path: text) -> Result<StatInfo, FsError>:
        """Stat path as text."""
        self.stat_path(Path(raw: path))

    # --- open ---

    fn open_path(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Open a file by path. Creates inode if not present."""
        val raw = path.raw
        var inode_id: u64 = 0
        val idx = _find_inode_idx(self.inst_id, raw)
        if idx >= 0:
            inode_id = _dbfs_inodes[idx].id
        else:
            inode_id = _alloc_inode_id(self.inst_id)
            _dbfs_inodes.push(DbFsInode(
                inst_id:  self.inst_id,
                id:       inode_id,
                kind:     DbFsKind.File,
                name:     raw,
                content:  "",
                content_bytes: [],
                parent:   1,
                size:     0,
                unlinked: false,
            ))
        val hid = _alloc_fd_id(self.inst_id)
        _dbfs_fds.push(DbFsFd(
            inst_id:    self.inst_id,
            handle_id:  hid,
            inode_id:   inode_id,
            is_dir:     false,
            closed:     false,
        ))
        Ok(FileHandle(id: hid))

    # --- opendir ---

    fn opendir_path(path: Path) -> Result<DirHandle, FsError>:
        """Open a directory by path."""
        val hid = _alloc_fd_id(self.inst_id)
        _dbfs_fds.push(DbFsFd(
            inst_id:    self.inst_id,
            handle_id:  hid,
            inode_id:   1,
            is_dir:     true,
            closed:     false,
        ))
        Ok(DirHandle(id: hid))

    # --- readdir ---

    fn readdir_handle(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """Return directory entries for handle."""
        var entries: [DirEntry] = []
        for inode in _dbfs_inodes:
            if inode.inst_id == self.inst_id and not inode.unlinked and inode.id != 1:
                val is_dir_entry: bool = match inode.kind:
                    case Dir:  true
                    case File: false
                entries.push(DirEntry(name: inode.name, is_dir: is_dir_entry))
        Ok(entries)

    # --- read ---

    fn read_handle(handle: FileHandle, length: i64) -> Result<text, FsError>:
        """Read up to length bytes from open handle."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Ok("")
        val content = _dbfs_inodes[inode_idx].content
        var result: text = ""
        var i: i64 = 0
        val cap: i64 = if length < content.len(): length else: content.len()
        while i < cap:
            result = result + content[i:i + 1]
            i = i + 1
        Ok(result)

    fn read_bytes_handle(handle: FileHandle, length: i64) -> Result<[u8], FsError>:
        """Read bytes from open handle without routing binary data through text."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Ok([])
        val content = _dbfs_inodes[inode_idx].content_bytes
        val cap: i64 = if length < content.len(): length else: content.len()
        Ok(_dbfs_slice_bytes(content, cap))

    # --- pread ---

    fn pread_handle(handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
        """Read length chars starting at offset."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val content = _dbfs_inodes[inode_idx].content
        var result: text = ""
        var i: i64 = offset
        val end_pos: i64 = offset + length
        val content_end: i64 = if end_pos < content.len(): end_pos else: content.len()
        while i < content_end:
            result = result + content[i:i + 1]
            i = i + 1
        # Pad with null chars if beyond content length
        var pad: i64 = content_end - offset
        while pad < length:
            result = result + "\0"
            pad = pad + 1
        Ok(result)

    # --- write ---

    fn write_handle(handle: FileHandle, content: text) -> Result<(), FsError>:
        """Write content to open handle."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  content,
            content_bytes: _dbfs_text_to_bytes(content),
            parent:   old.parent,
            size:     content.len(),
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    fn write_bytes_handle(handle: FileHandle, content: [u8]) -> Result<(), FsError>:
        """Write bytes to open handle without lossy text conversion on readback."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        if _dbfs_fds[fd_idx].closed:
            return Err(FsError.InvalidArg)
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  _dbfs_bytes_to_text(content, content.len() as i64),
            content_bytes: _dbfs_slice_bytes(content, content.len() as i64),
            parent:   old.parent,
            size:     content.len() as i64,
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- pwrite ---

    fn pwrite_handle(handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
        """Write patch starting at offset (COW semantics)."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val old_content = old.content
        var new_content: text = ""
        var i: i64 = 0
        while i < offset:
            if i < old_content.len():
                new_content = new_content + old_content[i:i + 1]
            else:
                new_content = new_content + "\0"
            i = i + 1
        var j: i64 = 0
        while j < patch.len():
            new_content = new_content + patch[j:j + 1]
            j = j + 1
        var k: i64 = offset + patch.len()
        while k < old_content.len():
            new_content = new_content + old_content[k:k + 1]
            k = k + 1
        val new_size: i64 = if new_content.len() > old.size: new_content.len() else: old.size
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  new_content,
            content_bytes: _dbfs_text_to_bytes(new_content),
            parent:   old.parent,
            size:     new_size,
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- close ---

    fn close_handle(handle: FileHandle) -> Result<(), FsError>:
        """Mark file descriptor closed."""
        val fd_idx = _find_fd_idx(self.inst_id, handle.id as u64)
        if fd_idx < 0:
            return Err(FsError.NotFound)
        val old_fd = _dbfs_fds[fd_idx]
        val new_fd = DbFsFd(
            inst_id:    old_fd.inst_id,
            handle_id:  old_fd.handle_id,
            inode_id:   old_fd.inode_id,
            is_dir:     old_fd.is_dir,
            closed:     true,
        )
        _dbfs_fds.remove(fd_idx)
        _dbfs_fds.push(new_fd)
        Ok(())

    # --- unlink ---

    fn unlink_path(path: text) -> Result<(), FsError>:
        """Mark inode unlinked. Open handles still readable until closed."""
        val idx = _find_inode_idx(self.inst_id, path)
        if idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  old.content,
            content_bytes: old.content_bytes,
            parent:   old.parent,
            size:     old.size,
            unlinked: true,
        )
        _dbfs_inodes.remove(idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- rename ---

    fn rename_path(old_path: text, new_path: text) -> Result<(), FsError>:
        """Rename: atomically replace new_path with old_path's inode."""
        # Remove existing target if present
        val target_idx = _find_inode_idx(self.inst_id, new_path)
        if target_idx >= 0:
            _dbfs_inodes.remove(target_idx)
        val src_idx = _find_inode_idx(self.inst_id, old_path)
        if src_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[src_idx]
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     new_path,
            content:  old.content,
            content_bytes: old.content_bytes,
            parent:   old.parent,
            size:     old.size,
            unlinked: false,
        )
        _dbfs_inodes.remove(src_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- ftruncate ---

    fn ftruncate_handle(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        """Truncate or extend file to new_size."""
        val inode_idx = _fd_inode_idx(self.inst_id, handle.id as u64)
        if inode_idx < 0:
            return Err(FsError.NotFound)
        val old = _dbfs_inodes[inode_idx]
        val old_content = old.content
        var new_content: text = ""
        var i: i64 = 0
        while i < new_size:
            if i < old_content.len():
                new_content = new_content + old_content[i:i + 1]
            else:
                new_content = new_content + "\0"
            i = i + 1
        val new_inode = DbFsInode(
            inst_id:  old.inst_id,
            id:       old.id,
            kind:     old.kind,
            name:     old.name,
            content:  new_content,
            content_bytes: _dbfs_text_to_bytes(new_content),
            parent:   old.parent,
            size:     new_size,
            unlinked: old.unlinked,
        )
        _dbfs_inodes.remove(inode_idx)
        _dbfs_inodes.push(new_inode)
        Ok(())

    # --- mkdir ---

    fn mkdir_path(path: text, mode: u32) -> Result<(), FsError>:
        """Create a directory at path."""
        val iid = _alloc_inode_id(self.inst_id)
        _dbfs_inodes.push(DbFsInode(
            inst_id:  self.inst_id,
            id:       iid,
            kind:     DbFsKind.Dir,
            name:     path,
            content:  "",
            content_bytes: [],
            parent:   1,
            size:     0,
            unlinked: false,
        ))
        Ok(())

    fn mkdir(path: text, mode: u32) -> Result<(), FsError>:
        """Alias for mkdir_path (direct driver API)."""
        self.mkdir_path(path, mode)

    # --- capability / extension ---

    fn probe(cap: Capability) -> Option<Extension>:
        """Return capability extension handle for DBFS-supported capabilities."""
        match cap:
            case PosixCompat:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Xattr:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Acl:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case Snapshot:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case COW:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case LargeFiles:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0)))
            case _:
                None

    fn capabilities() -> CapabilitySet:
        """Return the set of capabilities this driver supports."""
        CapabilitySet.empty()
            .with(Capability.PosixCompat)
            .with(Capability.Xattr)
            .with(Capability.Acl)
            .with(Capability.Snapshot)
            .with(Capability.COW)
            .with(Capability.LargeFiles)

    # --- transaction ---

    fn begin_txn() -> DbfsTxn:
        """Begin a new transaction on this driver."""
        val txn_id = TxnId(value: _alloc_fd_id(self.inst_id) as i64)
        DbfsTxn.new(txn_id)

    fn flush_call_count() -> i64:
        """Return number of WAL flush calls (DURABLE_GROUP_COMMIT counter)."""
        self.flush_count

    me fn group_commit() -> Result<(), text>:
        """Flush all pending WAL records (DURABLE_GROUP_COMMIT)."""
        val r = self.wal.flush_wal()
        if r.is_ok():
            self.flush_count = self.flush_count + 1
        r
