"""DB Query — production query primitives over DbTable.

Provides prefix scan, range scan by id, and multi-key lookup.
Replaces placeholder no-op query branches.
"""

class QueryResult:
    ids: [i64]
    count: i64

fn query_result_empty() -> QueryResult:
    QueryResult(ids: [], count: 0)

fn db_prefix_scan(rows: [DbRow], prefix: text) -> QueryResult:
    var ids: [i64] = []
    var i = 0
    while i < rows.len():
        if rows[i].key.starts_with(prefix):
            ids.push(rows[i].id)
        i = i + 1
    QueryResult(ids: ids, count: ids.len())

fn db_range_scan(rows: [DbRow], min_id: i64, max_id: i64) -> QueryResult:
    var ids: [i64] = []
    var i = 0
    while i < rows.len():
        val rid = rows[i].id
        if rid >= min_id and rid <= max_id:
            ids.push(rid)
        i = i + 1
    QueryResult(ids: ids, count: ids.len())

fn db_keys_matching(rows: [DbRow], needle: text) -> QueryResult:
    var ids: [i64] = []
    var i = 0
    while i < rows.len():
        if rows[i].key == needle:
            ids.push(rows[i].id)
        i = i + 1
    QueryResult(ids: ids, count: ids.len())

fn db_all_ids(rows: [DbRow]) -> QueryResult:
    var ids: [i64] = []
    var i = 0
    while i < rows.len():
        ids.push(rows[i].id)
        i = i + 1
    QueryResult(ids: ids, count: ids.len())
