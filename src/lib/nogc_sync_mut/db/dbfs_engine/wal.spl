# DBFS WAL — facade over std.storage.shared.wal.
#
# All types and logic live in SharedWal. This module re-exports them
# under the original DBFS names for backward compatibility.
#
# Maps to: AC-3, AC-5, AC-9, D4.

use std.storage.shared.wal.{
    SharedWal, Lsn, WalRecord, WalEntry, RecoveryCursor,
    WAL_RECORD_DATA, WAL_RECORD_META, WAL_RECORD_COMMIT, WAL_RECORD_ABORT
}

type DbfsWal = SharedWal

export DbfsWal, WalRecord, Lsn
export WAL_RECORD_DATA, WAL_RECORD_META, WAL_RECORD_COMMIT, WAL_RECORD_ABORT
