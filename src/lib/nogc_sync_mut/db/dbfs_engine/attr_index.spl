# DBFS Attribute Index — BeFS-style per-attribute indexes over InodeRow fields.
#
# Uses Dict<text, [i64]> per attribute (size, mtime, ctime, uid, gid, mode).
# Keys are zero-padded i64 strings for lexicographic range queries.
# Supports Eq / Gt / Lt / Ge / Le / Between and multi-query AND intersection.
#
# Maps to: AC-3, AC-10, D3.

use std.db.dbfs_engine.schema.{InodeRow, InodeTable, InodeTableEntry, InodeKey}
use std.database.index.{add_to_index, remove_from_index, intersect_id_lists, pad_i64}

val ATTR_SIZE:  text = "size"
val ATTR_MTIME: text = "mtime"
val ATTR_CTIME: text = "ctime"
val ATTR_UID:   text = "uid"
val ATTR_GID:   text = "gid"
val ATTR_MODE:  text = "mode"

# ============================================================
# Query types
# ============================================================

enum AttrOp:
    Eq(value: text)
    Gt(value: text)
    Lt(value: text)
    Ge(value: text)
    Le(value: text)
    Between(low: text, high: text)

struct AttrQuery:
    attribute: text
    op: AttrOp

struct AttrQueryResult:
    ino_ids:  [i64]
    query_ms: i64

# ============================================================
# AttrIndexManager
# ============================================================

struct AttrIndexManager:
    size_index:    Dict<text, [i64]>
    mtime_index:   Dict<text, [i64]>
    ctime_index:   Dict<text, [i64]>
    uid_index:     Dict<text, [i64]>
    gid_index:     Dict<text, [i64]>
    mode_index:    Dict<text, [i64]>
    indexed_count: i64

impl AttrIndexManager:
    static fn new() -> AttrIndexManager:
        AttrIndexManager(
            size_index:    Dict.new(),
            mtime_index:   Dict.new(),
            ctime_index:   Dict.new(),
            uid_index:     Dict.new(),
            gid_index:     Dict.new(),
            mode_index:    Dict.new(),
            indexed_count: 0
        )

    me fn build_from_inodes(inodes: InodeTable):
        self.size_index  = Dict.new()
        self.mtime_index = Dict.new()
        self.ctime_index = Dict.new()
        self.uid_index   = Dict.new()
        self.gid_index   = Dict.new()
        self.mode_index  = Dict.new()
        self.indexed_count = 0
        var i: i32 = 0
        while i < inodes.entries.len() as i32:
            val row = inodes.entries[i].row
            self.on_inode_insert(row)
            i = i + 1

    me fn on_inode_insert(row: InodeRow):
        add_to_index(self.size_index,  pad_i64(row.size),        row.ino_id)
        add_to_index(self.mtime_index, pad_i64(row.mtime),       row.ino_id)
        add_to_index(self.ctime_index, pad_i64(row.ctime),       row.ino_id)
        add_to_index(self.uid_index,   pad_i64(row.uid as i64),  row.ino_id)
        add_to_index(self.gid_index,   pad_i64(row.gid as i64),  row.ino_id)
        add_to_index(self.mode_index,  pad_i64(row.mode as i64), row.ino_id)
        self.indexed_count = self.indexed_count + 1

    me fn on_inode_update(old_row: InodeRow, new_row: InodeRow):
        self.on_inode_delete(old_row.ino_id, old_row)
        self.on_inode_insert(new_row)

    me fn on_inode_delete(ino_id: i64, row: InodeRow):
        remove_from_index(self.size_index,  pad_i64(row.size),        ino_id)
        remove_from_index(self.mtime_index, pad_i64(row.mtime),       ino_id)
        remove_from_index(self.ctime_index, pad_i64(row.ctime),       ino_id)
        remove_from_index(self.uid_index,   pad_i64(row.uid as i64),  ino_id)
        remove_from_index(self.gid_index,   pad_i64(row.gid as i64),  ino_id)
        remove_from_index(self.mode_index,  pad_i64(row.mode as i64), ino_id)
        self.indexed_count = self.indexed_count - 1

    fn _select_index(attribute: text) -> Dict<text, [i64]>?:
        if attribute == ATTR_SIZE:
            return self.size_index
        if attribute == ATTR_MTIME:
            return self.mtime_index
        if attribute == ATTR_CTIME:
            return self.ctime_index
        if attribute == ATTR_UID:
            return self.uid_index
        if attribute == ATTR_GID:
            return self.gid_index
        if attribute == ATTR_MODE:
            return self.mode_index
        nil

    fn _collect_range(index: Dict<text, [i64]>, low: text, high: text, include_low: bool, include_high: bool) -> [i64]:
        var result: [i64] = []
        for key in index.keys():
            val after_low  = if include_low:  key >= low  else: key > low
            val before_high = if include_high: key <= high else: key < high
            if (after_low and before_high):
                for id in index[key]:
                    result.push(id)
        result

    fn query(q: AttrQuery) -> AttrQueryResult:
        val maybe_index = self._select_index(q.attribute)
        if not maybe_index:
            return AttrQueryResult(ino_ids: [], query_ms: 0)
        val index = maybe_index
        var ids: [i64] = []
        if q.op is AttrOp.Eq:
            val key = q.op.value
            if index.contains(key):
                for id in index[key]:
                    ids.push(id)
        else if q.op is AttrOp.Gt:
            ids = self._collect_range(index, q.op.value, "", false, false)
        else if q.op is AttrOp.Lt:
            ids = self._collect_range(index, "", q.op.value, false, false)
        else if q.op is AttrOp.Ge:
            ids = self._collect_range(index, q.op.value, "", true, false)
        else if q.op is AttrOp.Le:
            ids = self._collect_range(index, "", q.op.value, false, true)
        else if q.op is AttrOp.Between:
            ids = self._collect_range(index, q.op.low, q.op.high, true, true)
        AttrQueryResult(ino_ids: ids, query_ms: 0)

    fn query_multi(queries: [AttrQuery]) -> AttrQueryResult:
        if queries.len() == 0:
            return AttrQueryResult(ino_ids: [], query_ms: 0)
        val first = self.query(queries[0])
        var acc: [i64] = first.ino_ids
        var i: i32 = 1
        while i < queries.len() as i32:
            val r = self.query(queries[i])
            acc = intersect_id_lists(acc, r.ino_ids)
            i = i + 1
        AttrQueryResult(ino_ids: acc, query_ms: 0)

    fn count() -> i64:
        self.indexed_count
