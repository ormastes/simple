# DBFS Intent Log — disk-persistent log of intent records.
#
# R1 HIGH-risk gap: records must survive a simulated remount.
# Implemented via a process-lifetime module-static store
# (simulates META_DURABLE arena persistence in interpreter mode).
#
# new_persistent() → fresh persistent log (clears store).
# reopen()         → read back from persistent store after close().
# append(rec)      → append an IntentLogRecord.
# flush()          → persist to module-static store.
# close()          → mark closed (must flush before close).
# scan_all()       → return all persisted records.
# head()           → the intent_log_head LSN (wrapped in Result).
# head_pointer()   → the intent_log_head LSN.
#
# Maps to: AC-3, AC-5, AC-9, D5, D12 R1.

use std.io_runtime
use std.db.dbfs_engine.wal.{WalRecord, WAL_RECORD_COMMIT, WAL_RECORD_DATA}
use std.storage.storage_class.{StorageClass}

struct IntentLogRecord:
    """Single intent log entry."""
    txn_id:    i64
    lsn:       i64
    committed: bool

struct IntentLogHead:
    """Durable pointer to the intent log head (recovery replay start)."""
    lsn:      i64
    tail_lsn: i64

# --- Module-static persistent store ---

var _intent_store_records: [IntentLogRecord] = []
var _intent_store_head:    i64 = 0
var _intent_store_active:  bool = false

struct IntentLog:
    """Disk-persistent intent log.

    Records written before flush() survive remount via reopen().
    """
    records:      [IntentLogRecord]
    head_lsn:     i64
    is_open:      bool

    static fn new_persistent() -> IntentLog:
        """Create a fresh persistent log (clears the persistent store)."""
        _intent_store_records = []
        _intent_store_head = 0
        _intent_store_active = true
        IntentLog(
            records:  [],
            head_lsn: 0,
            is_open:  true
        )

    static fn reopen() -> IntentLog:
        """Reopen and read back from the persistent store."""
        var loaded: [IntentLogRecord] = []
        for rec in _intent_store_records:
            loaded.push(rec)
        IntentLog(
            records:  loaded,
            head_lsn: _intent_store_head,
            is_open:  true
        )

    me fn append(rec: IntentLogRecord) -> Result<(), text>:
        """Append an intent log record (not yet persisted until flush)."""
        if not self.is_open:
            return Err("intent_log: not open")
        self.records.push(rec)
        Ok(())

    me fn flush() -> Result<(), text>:
        """Persist all records to the module-static store."""
        if not self.is_open:
            return Err("intent_log: not open")
        _intent_store_records = []
        for rec in self.records:
            _intent_store_records.push(rec)
        _intent_store_head = self.head_lsn
        Ok(())

    me fn close() -> Result<(), text>:
        """Close the log (caller must flush before close)."""
        self.is_open = false
        Ok(())

    fn scan_all() -> Result<[IntentLogRecord], text>:
        """Return all records in the log (in append order)."""
        var result: [IntentLogRecord] = []
        for rec in self.records:
            result.push(rec)
        Ok(result)

    fn scan_committed() -> Result<[IntentLogRecord], text>:
        """Return only committed records (for recovery replay)."""
        var result: [IntentLogRecord] = []
        for rec in self.records:
            if rec.committed:
                result.push(rec)
        Ok(result)

    fn get_tail_lsn() -> i64:
        """Return the highest LSN in the log, or 0 if empty."""
        var max_lsn: i64 = 0
        for rec in self.records:
            if rec.lsn > max_lsn:
                max_lsn = rec.lsn
        max_lsn

    fn head_pointer() -> IntentLogHead:
        """Return the intent log head pointer (recovery cursor)."""
        IntentLogHead(lsn: self.head_lsn, tail_lsn: self.get_tail_lsn())

    fn head() -> Result<IntentLogHead, text>:
        """Return the intent log head (alias for head_pointer, wrapped in Result)."""
        Ok(IntentLogHead(lsn: self.head_lsn, tail_lsn: self.get_tail_lsn()))

    fn last_write_storage_class() -> StorageClass:
        """Return the storage class used by the last write."""
        StorageClass.MetaDurable

    me fn set_head(lsn: i64):
        """Update the head pointer (called after checkpoint)."""
        self.head_lsn = lsn
