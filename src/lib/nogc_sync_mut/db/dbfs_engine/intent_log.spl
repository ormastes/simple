# DBFS Intent Log — facade over std.storage.shared.intent_log.
#
# All types and logic live in SharedIntentLog. This module re-exports
# them under the original DBFS names for backward compatibility.
#
# Callback registration: call intent_register_persist_callback("arena:META_DURABLE")
# before new_persistent() to route persistence through Arena-backed callbacks.
# Default (no registration) uses module-static store for tests.
#
# Maps to: AC-3, AC-5, AC-9, D5, D12 R1.

use std.storage.shared.intent_log.{
    SharedIntentLog, IntentLogRecord, IntentLogHead,
    intent_register_persist_callback, intent_clear_persist_callback,
    intent_persist_callback_tag, intent_is_callback_registered,
    intent_cb_write_record, intent_cb_write_head,
    intent_cb_read_all, intent_cb_read_head, intent_cb_record_count
}
use std.storage.shared.wal.{WalRecord, WAL_RECORD_COMMIT, WAL_RECORD_DATA}
use std.storage.storage_class.{StorageClass}

type IntentLog = SharedIntentLog
