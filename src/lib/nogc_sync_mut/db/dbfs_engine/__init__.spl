# DBFS Engine — embedded pager+B-tree+WAL engine for DbFsEngine.
#
# Submodules:
#   pager          — single-cache page manager (PAGE_SIZE_BYTES = 8192)
#   schema         — 11 D3 catalog tables (INODE, DENTRY, FILE_VERSION, …)
#   ns_btree       — namespace B-tree keyed (parent_ino, name_hash)
#   wal            — Write-Ahead Log with DURABLE_GROUP_COMMIT
#   checkpoint     — checkpoint_now() + latest_clean() high-level API
#   checkpoint_ring — disk-persistent ring of RING_SIZE slots
#   intent_log     — disk-persistent intent log (R1 HIGH-risk gap)
#   txn            — 6-step D4 transaction protocol
#   recovery       — 5-step D5 recovery model
#
# Maps to: AC-3, AC-5, AC-9, D2, D3, D4, D5.
#
# ─── Phase 3 D-number map ────────────────────────────────────────────────────
#   D1  engine choice (Option B fork)  → this package
#   D2  gap-list modules               → schema, ns_btree, raw_nvme_arena,
#                                        intent_log, checkpoint_ring
#   D3  on-disk schema (11 tables)     → schema.spl
#   D4  6-step txn write protocol      → txn.spl
#   D5  5-step recovery model          → recovery.spl
#   D6  BlobBackend = Arena trait      → src/lib/nogc_sync_mut/storage/arena.spl
#   D9  8 KiB page size                → pager.spl (PAGE_SIZE_BYTES = 8192)
#
# ─── shared storage layer ─────────────────────────────────────────────────────
#   wal.spl          → facade: type DbfsWal = std.storage.shared.wal.SharedWal
#   ns_btree.spl     → facade: NsBTree wraps std.storage.shared.btree.BTree<BTreeValue>
#                       Adds DentryKey mapping + MVCC snapshot reads.
#                       (fr_dbfs_btree_unify: RESOLVED)
#   intent_log.spl   — local impl (NVFS intent_log has different record shape)
#   checkpoint_ring.spl — local impl (NVFS checkpoint has different entry shape)
#
# ─── Module-static persistence sites (interpreter value-semantics workaround) ─
#   pager.spl            — _pager_disk_pages (list of PageRecord, keyed by page_id)
#   checkpoint_ring.spl  — _ring_store_slots  (list of CheckpointSlot)
#   intent_log.spl       — _intent_records    (list of IntentRecord)
#   All three use the same pattern: module-level list + rescan on every open.
#   This is intentional: MountTable copies DriverInstance structs, so struct-field
#   mutations are lost. See dbfs_driver.spl header for full explanation.

use std.io_runtime

export use nogc_sync_mut.db.dbfs_engine.ns_btree.{NsBTree, ns_dentry_key, ns_ino}
