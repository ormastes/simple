# FTS — Full-Text Search engine for Simple DB.
#
# Submodules:
#   tokenizer       — text tokenization with stop-word filtering
#   inverted_index  — posting lists keyed by term
#   bm25            — BM25 scoring and ranked retrieval
#   trigram         — trigram substring index
#   fuzzy           — Levenshtein edit distance and fuzzy matching
#   search          — unified FtsEngine combining all strategies

use std.io_runtime

export use nogc_sync_mut.db.dbfs_engine.fts.tokenizer.{FtsToken, fts_tokenize, fts_tokenize_raw}
export use nogc_sync_mut.db.dbfs_engine.fts.inverted_index.{FtsPosting, FtsPostingList, FtsInvertedIndex}
export use nogc_sync_mut.db.dbfs_engine.fts.bm25.{FtsSearchResult, fts_bm25_score, fts_bm25_search}
export use nogc_sync_mut.db.dbfs_engine.fts.trigram.{FtsTrigramIndex, fts_generate_trigrams}
export use nogc_sync_mut.db.dbfs_engine.fts.fuzzy.{fts_levenshtein, fts_fuzzy_match}
export use nogc_sync_mut.db.dbfs_engine.fts.search.{FtsEngine}
