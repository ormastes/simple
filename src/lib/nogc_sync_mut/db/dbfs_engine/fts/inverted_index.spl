# FTS Inverted Index — posting lists keyed by term.
#
# Exports: FtsPosting, FtsPostingList, FtsInvertedIndex

use std.io_runtime
use std.db.dbfs_engine.fts.tokenizer.{fts_tokenize, FtsToken}

# ── Posting ────────────────────────────────────────────────────────────────────

struct FtsPosting:
    doc_id: i64
    term_freq: i64
    positions: [i64]

# ── PostingList (convenience struct) ───────────────────────────────────────────

struct FtsPostingList:
    term: text
    postings: [FtsPosting]
    doc_freq: i64

# ── Inverted Index ─────────────────────────────────────────────────────────────

struct FtsInvertedIndex:
    _index: Dict<text, [FtsPosting]>
    _doc_lengths: Dict<text, i64>
    _total_docs: i64
    _total_tokens: i64

impl FtsInvertedIndex:
    static fn new() -> FtsInvertedIndex:
        FtsInvertedIndex(
            _index: {},
            _doc_lengths: {},
            _total_docs: 0,
            _total_tokens: 0
        )

    me fn index_document(doc_id: i64, content: text):
        val tokens = fts_tokenize(content)
        val doc_key = "{doc_id}"
        self._doc_lengths[doc_key] = tokens.len() as i64
        self._total_docs = self._total_docs + 1
        self._total_tokens = self._total_tokens + (tokens.len() as i64)

        # Collect term frequencies and positions per term
        var term_positions: Dict<text, [i64]> = {}
        var ti: i32 = 0
        while ti < tokens.len() as i32:
            val tok = tokens[ti]
            if term_positions.contains_key(tok.term):
                var plist = term_positions[tok.term]
                plist.push(tok.position)
                term_positions[tok.term] = plist
            else:
                term_positions[tok.term] = [tok.position]
            ti = ti + 1

        # Update the inverted index
        for term in term_positions.keys():
            val positions = term_positions[term]
            val posting = FtsPosting(
                doc_id: doc_id,
                term_freq: positions.len() as i64,
                positions: positions
            )
            if self._index.contains_key(term):
                var plist = self._index[term]
                plist.push(posting)
                self._index[term] = plist
            else:
                self._index[term] = [posting]

    me fn remove_document(doc_id: i64):
        val doc_key = "{doc_id}"
        if self._doc_lengths.contains_key(doc_key):
            val old_len = self._doc_lengths[doc_key]
            self._total_tokens = self._total_tokens - old_len
            self._total_docs = self._total_docs - 1
            # Remove doc_key from _doc_lengths by setting to 0
            # (Simple may not have dict.remove — mark as removed)
            self._doc_lengths[doc_key] = -1

        # Remove postings for this doc_id from all terms
        val all_terms = self._index.keys()
        var ki: i32 = 0
        while ki < all_terms.len() as i32:
            val term = all_terms[ki]
            var old_postings = self._index[term]
            var new_postings: [FtsPosting] = []
            var pi: i32 = 0
            while pi < old_postings.len() as i32:
                if old_postings[pi].doc_id != doc_id:
                    new_postings.push(old_postings[pi])
                pi = pi + 1
            self._index[term] = new_postings
            ki = ki + 1

    me fn search(term: text) -> [FtsPosting]:
        val lower_term = term.to_lower()
        if self._index.contains_key(lower_term):
            return self._index[lower_term]
        var empty: [FtsPosting] = []
        empty

    me fn doc_count() -> i64:
        self._total_docs

    me fn avg_doc_length() -> i64:
        if self._total_docs == 0:
            return 0
        self._total_tokens / self._total_docs

    me fn doc_freq(term: text) -> i64:
        val lower_term = term.to_lower()
        if self._index.contains_key(lower_term):
            return self._index[lower_term].len() as i64
        0

    me fn get_all_terms() -> [text]:
        self._index.keys()
