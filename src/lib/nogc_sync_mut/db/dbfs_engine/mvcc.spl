# DBFS MVCC — Multi-Version Concurrency Control visibility module.
#
# Implements PostgreSQL-style HeapTupleSatisfiesMVCC snapshot isolation.
# Each tuple carries an MvccHeader (xmin/xmax/cmin/cmax); readers take
# an MvccSnapshot and only see tuples committed before the snapshot was
# taken and not yet deleted.
#
# Maps to: AC-3 (ACID transactions), D4 (write protocol).

use std.io_runtime

# ─── Module-level transaction status store ────────────────────────────────────
# Keyed by stringified txn_id → "committed" | "aborted".
# Active transactions are NOT in this map (absence = active or unknown).

var _txn_status_map: Dict<text, text> = {}

# ─── MvccHeader ───────────────────────────────────────────────────────────────

struct MvccHeader:
    """Per-tuple MVCC metadata: xmin (inserting txn), xmax (deleting txn),
    cmin/cmax (command counters within the transaction)."""
    xmin: i64
    xmax: i64
    cmin: i64
    cmax: i64

    static fn create(txn_id: i64) -> MvccHeader:
        """Create a header for a newly inserted tuple."""
        MvccHeader(xmin: txn_id, xmax: 0, cmin: 0, cmax: 0)

    me fn mark_deleted(txn_id: i64):
        """Record the deleting transaction."""
        self.xmax = txn_id

# ─── MvccTuple ────────────────────────────────────────────────────────────────

struct MvccTuple:
    """A versioned tuple: MVCC header + opaque data payload."""
    header: MvccHeader
    data:   text

    static fn create(txn_id: i64, data: text) -> MvccTuple:
        """Create a new tuple inserted by txn_id."""
        MvccTuple(header: MvccHeader.create(txn_id), data: data)

    me fn delete(txn_id: i64):
        """Mark this tuple as deleted by txn_id."""
        self.header.mark_deleted(txn_id)

# ─── MvccSnapshot ─────────────────────────────────────────────────────────────

struct MvccSnapshot:
    """Point-in-time snapshot for visibility checks.

    xmin  — lowest active txn_id at snapshot time (all < xmin are committed).
    xmax  — next txn_id that will be allocated (all >= xmax are invisible).
    active_txns — list of txn_ids that were in-progress at snapshot time.
    """
    xmin:        i64
    xmax:        i64
    active_txns: [i64]

    me fn is_txn_active(txn_id: i64) -> bool:
        """Return true if txn_id was active at snapshot time."""
        var i: i32 = 0
        while i < self.active_txns.len() as i32:
            if self.active_txns[i] == txn_id:
                return true
            i = i + 1
        false

# ─── MvccTxnHandle ────────────────────────────────────────────────────────────

struct MvccTxnHandle:
    """Lightweight handle returned by begin()."""
    txn_id:       i64
    is_committed: bool
    is_aborted:   bool

# ─── MvccTable ────────────────────────────────────────────────────────────────

class MvccTable:
    """In-memory table of versioned tuples with MVCC visibility."""
    tuples: [MvccTuple]

    static fn new() -> MvccTable:
        MvccTable(tuples: [])

impl MvccTable:
    me fn insert(txn_id: i64, data: text):
        """Insert a new tuple under the given transaction."""
        self.tuples.push(MvccTuple.create(txn_id, data))

    me fn delete_matching(txn_id: i64, data: text):
        """Mark all tuples whose data matches as deleted by txn_id.

        Uses read-modify-write via indexed assign to persist mutations
        (value-semantics: indexing yields a copy, so we must write back).
        """
        var i: i32 = 0
        while i < self.tuples.len() as i32:
            if self.tuples[i].data == data and self.tuples[i].header.xmax == 0:
                var t = self.tuples[i]
                t.header.xmax = txn_id
                self.tuples[i] = t
            i = i + 1

    me fn scan(snapshot: MvccSnapshot) -> [text]:
        """Return data of all tuples visible to the snapshot."""
        var result: [text] = []
        var i: i32 = 0
        while i < self.tuples.len() as i32:
            if mvcc_is_visible(self.tuples[i], snapshot):
                result.push(self.tuples[i].data)
            i = i + 1
        result

    me fn count_visible(snapshot: MvccSnapshot) -> i64:
        """Count tuples visible to the snapshot."""
        var cnt: i64 = 0
        var i: i32 = 0
        while i < self.tuples.len() as i32:
            if mvcc_is_visible(self.tuples[i], snapshot):
                cnt = cnt + 1
            i = i + 1
        cnt

# ─── MvccTxnManager ──────────────────────────────────────────────────────────

class MvccTxnManager:
    """Manages transaction lifecycle and snapshot creation."""
    next_txn_id: i64
    active:      [i64]

    static fn new() -> MvccTxnManager:
        MvccTxnManager(next_txn_id: 1, active: [])

impl MvccTxnManager:
    me fn begin() -> MvccTxnHandle:
        """Allocate a new transaction id and mark it active."""
        val tid = self.next_txn_id
        self.next_txn_id = self.next_txn_id + 1
        self.active.push(tid)
        MvccTxnHandle(txn_id: tid, is_committed: false, is_aborted: false)

    me fn commit(txn_id: i64):
        """Commit a transaction: remove from active, record status."""
        self._remove_active(txn_id)
        val key = "{txn_id}"
        _txn_status_map[key] = "committed"

    me fn abort(txn_id: i64):
        """Abort a transaction: remove from active, record status."""
        self._remove_active(txn_id)
        val key = "{txn_id}"
        _txn_status_map[key] = "aborted"

    me fn snapshot() -> MvccSnapshot:
        """Create a snapshot of the current transaction state.

        xmin = lowest active txn (or next_txn_id if none active).
        xmax = next_txn_id (upper exclusive bound).
        active_txns = copy of the active list.
        """
        var snap_xmin = self.next_txn_id
        var i: i32 = 0
        while i < self.active.len() as i32:
            if self.active[i] < snap_xmin:
                snap_xmin = self.active[i]
            i = i + 1
        # Copy active list
        var active_copy: [i64] = []
        i = 0
        while i < self.active.len() as i32:
            active_copy.push(self.active[i])
            i = i + 1
        MvccSnapshot(xmin: snap_xmin, xmax: self.next_txn_id, active_txns: active_copy)

    me fn get_status(txn_id: i64) -> text:
        """Return transaction status: active, committed, aborted, or unknown."""
        # Check if currently active
        var i: i32 = 0
        while i < self.active.len() as i32:
            if self.active[i] == txn_id:
                return "active"
            i = i + 1
        # Check status map
        val key = "{txn_id}"
        if _txn_status_map.contains_key(key):
            return _txn_status_map[key]
        "unknown"

    me fn _remove_active(txn_id: i64):
        """Remove a txn_id from the active list."""
        var i: i32 = 0
        while i < self.active.len() as i32:
            if self.active[i] == txn_id:
                self.active.remove(i)
                return
            i = i + 1

# ─── Visibility function ─────────────────────────────────────────────────────

fn mvcc_is_visible(tuple: MvccTuple, snapshot: MvccSnapshot) -> bool:
    """PostgreSQL HeapTupleSatisfiesMVCC visibility check.

    Rules:
      1. xmin in active_txns → inserting txn not committed → NOT visible
      2. xmin >= snapshot.xmax → inserted after snapshot → NOT visible
      3. xmin < snapshot.xmin AND xmax == 0 → committed, not deleted → VISIBLE
      4. xmax != 0 AND xmax in active_txns → deleting txn not committed → VISIBLE
      5. xmax != 0 AND xmax < snapshot.xmax AND xmax not active → deleted → NOT visible
      6. Otherwise → visible (xmin committed before snapshot, xmax pending or after)
    """
    val xmin = tuple.header.xmin
    val xmax = tuple.header.xmax

    # Rule 1: inserting transaction still active
    if snapshot.is_txn_active(xmin):
        return false

    # Rule 2: inserted after snapshot was taken
    if xmin >= snapshot.xmax:
        return false

    # Rule 3: committed before snapshot, not deleted
    if xmin < snapshot.xmin and xmax == 0:
        return true

    # Rule 4: deleting transaction still active → tuple still visible
    if xmax != 0 and snapshot.is_txn_active(xmax):
        return true

    # Rule 5: deleted by committed transaction before snapshot
    if xmax != 0 and xmax < snapshot.xmax and not snapshot.is_txn_active(xmax):
        return false

    # Rule 6: default visible
    true

# ─── Free-function delegates ─────────────────────────────────────────────────

fn mvcc_register_txn(mgr: MvccTxnManager) -> MvccTxnHandle:
    """Allocate a new transaction via the manager."""
    mgr.begin()

fn mvcc_commit_txn(mgr: MvccTxnManager, txn_id: i64):
    """Commit a transaction via the manager."""
    mgr.commit(txn_id)

fn mvcc_abort_txn(mgr: MvccTxnManager, txn_id: i64):
    """Abort a transaction via the manager."""
    mgr.abort(txn_id)

fn mvcc_get_txn_status(mgr: MvccTxnManager, txn_id: i64) -> text:
    """Query transaction status via the manager."""
    mgr.get_status(txn_id)
