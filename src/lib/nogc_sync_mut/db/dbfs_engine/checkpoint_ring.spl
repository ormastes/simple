# DBFS Checkpoint Ring — facade over std.storage.shared.checkpoint_ring.
#
# All types and logic live in SharedCheckpointRing. This module re-exports
# them under the original DBFS names for backward compatibility.
#
# Callback registration: call ring_register_persist_callback("arena:META_DURABLE")
# before new_persistent() to route persistence through Arena-backed callbacks.
# Default (no registration) uses module-static store for tests.
#
# Maps to: AC-3, AC-5, AC-9, D5, D12 R2.

use std.storage.shared.checkpoint_ring.{
    SharedCheckpointRing, RingSlot, RingSlotEntry,
    ring_register_persist_callback, ring_clear_persist_callback,
    ring_persist_callback_tag, ring_is_callback_registered,
    ring_cb_write_slot, ring_cb_read_all, ring_cb_slot_count
}
use std.storage.storage_class.{StorageClass}

val RING_SIZE: i64 = 16
val RING_SIZE_PRODUCTION: i64 = 4096

type CheckpointRing = SharedCheckpointRing
