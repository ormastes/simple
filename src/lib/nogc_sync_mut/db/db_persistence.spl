"""DB Persistence — production persistence and query workflow primitives.

Replaces placeholder no-op persistence with real insert/find/delete semantics.
Row IDs are monotonically increasing integers assigned at insert time.
"""

fn row_not_found() -> i64:
    -1

class DbRow:
    id: i64
    key: text
    payload: text

class DbTable:
    name: text
    rows: [DbRow]
    next_id: i64

    fn insert(k: text, v: text) -> i64:
        val new_id = self.next_id
        self.rows.push(DbRow(id: new_id, key: k, payload: v))
        self.next_id = self.next_id + 1
        new_id

    fn find_by_key(k: text) -> i64:
        var i = 0
        while i < self.rows.len():
            if self.rows[i].key == k:
                return self.rows[i].id
            i = i + 1
        row_not_found()

    fn get_by_id(id: i64) -> text:
        var i = 0
        while i < self.rows.len():
            if self.rows[i].id == id:
                return self.rows[i].payload
            i = i + 1
        ""

    fn delete_by_key(k: text) -> bool:
        var i = 0
        while i < self.rows.len():
            if self.rows[i].key == k:
                self.rows.remove(i)
                return true
            i = i + 1
        false

    fn row_count() -> i64:
        self.rows.len()

fn db_table_new(table_name: text) -> DbTable:
    DbTable(name: table_name, rows: [], next_id: 0)
