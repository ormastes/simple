# Actor runtime hook owner for compatibility actor APIs.

extern fn rt_actor_spawn(handler: Any) -> i64
extern fn rt_actor_send(actor_id: i64, message: Any)
extern fn rt_actor_recv(actor_id: i64) -> Any

fn actor_hook_spawn(handler: Any) -> i64:
    rt_actor_spawn(handler)

fn actor_hook_send(actor_id: i64, message: Any):
    rt_actor_send(actor_id, message)

fn actor_hook_recv(actor_id: i64) -> Any:
    rt_actor_recv(actor_id)
