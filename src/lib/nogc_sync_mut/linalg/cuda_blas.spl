"""
# cuBLAS SFFI Shim Wrappers — Layer A + thin Layer B

Thin wrappers over the `rt_blas_*` / `rt_cuda_*` symbols exported by
`libspl_scilib.so` (mock, openblas, or cublas backend).

These functions use `DynLoader` (SFFI) to dispatch — `spl_dlopen` is not
available in interpreter mode, so calls return `BackendError.BackendUnavailable`
when the shim is not loaded.  CPU/mock tests that need deterministic results
should use `src/lib/nogc_async_mut/linalg/` directly (which already has
`openblas_*` and `cuda_*` dispatch via `linalg_core.spl`).

Symbol naming follows the `rt_blas_*` / `rt_cuda_*` scheme documented in
`src/runtime/scilib/scilib_shim.h` and `doc/01_research/scilib_fortran_port/01_fortran_cuda_abi.md`.

Import path: use std.nogc_sync_mut.linalg.cuda_blas.{blas_handle_create, ...}
"""

use std.linalg.linalg_core.{BackendError, _scilib_call0, _scilib_call_n, dyn_cuda_available, dyn_openblas_available}
use std.nogc_sync_mut.ptr.raw.{rt_alloc, rt_free, rt_ptr_read_i64, rt_ptr_write_i64, spl_f64_to_bits, spl_bits_to_f64}

# ---------------------------------------------------------------------------
# Handle lifecycle
# ---------------------------------------------------------------------------

pub fn blas_handle_create() -> Result<i64, BackendError>:
    """Create a BLAS handle.  Returns the opaque handle as i64 (mock: always 1)."""
    val h = _scilib_call0("rt_blas_handle_create")
    if h == 0:
        return Err(BackendError.BackendUnavailable("rt_blas_handle_create returned null handle"))
    Ok(h)

pub fn blas_handle_destroy(handle: i64) -> Result<i64, BackendError>:
    """Destroy a BLAS handle obtained from blas_handle_create."""
    val rc = _scilib_call_n("rt_blas_handle_destroy", [handle])
    Ok(rc)

pub fn lapack_handle_create() -> Result<i64, BackendError>:
    """Create a LAPACK (cuSOLVER) handle.  Returns the opaque handle as i64."""
    val h = _scilib_call0("rt_lapack_handle_create")
    if h == 0:
        return Err(BackendError.BackendUnavailable("rt_lapack_handle_create returned null handle"))
    Ok(h)

pub fn lapack_handle_destroy(handle: i64) -> Result<i64, BackendError>:
    """Destroy a LAPACK handle obtained from lapack_handle_create."""
    val rc = _scilib_call_n("rt_lapack_handle_destroy", [handle])
    Ok(rc)

# ---------------------------------------------------------------------------
# Backend probe
# ---------------------------------------------------------------------------

pub fn scilib_backend_name() -> text:
    """Return the active backend name from the loaded shim ("mock", "openblas", or "cuda").

    Returns "unavailable" when no shim is loaded (SFFI path not reachable in
    interpreter mode without the .so present).
    """
    if dyn_cuda_available():
        return "cuda"
    if dyn_openblas_available():
        return "openblas"
    "mock"

pub fn cuda_api_version() -> i64:
    """Return the CUDA runtime version * 1000 (mock: 0; cublas: real version)."""
    _scilib_call0("rt_cuda_api_version")

# ---------------------------------------------------------------------------
# Device memory helpers (pass-through to scilib shim)
# ---------------------------------------------------------------------------

pub fn scilib_cuda_malloc(bytes: i64) -> Result<i64, BackendError>:
    """Allocate device memory via rt_cuda_malloc.  Returns pointer as i64.

    On the mock backend this is a malloc(bytes) on the host.  On the cuda
    backend this is cudaMalloc.  Returns BackendError.BackendExecutionFailed
    if allocation returns 0.
    """
    if bytes <= 0:
        return Err(BackendError.BackendExecutionFailed("scilib_cuda_malloc: invalid size"))
    val ptr = _scilib_call_n("rt_cuda_malloc", [bytes])
    if ptr == 0:
        return Err(BackendError.BackendExecutionFailed("rt_cuda_malloc returned null"))
    Ok(ptr)

pub fn scilib_cuda_free(ptr: i64) -> Result<i64, BackendError>:
    """Free device memory via rt_cuda_free."""
    val rc = _scilib_call_n("rt_cuda_free", [ptr])
    Ok(rc)

pub fn scilib_memcpy_htod(dev_dst: i64, values: [f64]) -> Result<i64, BackendError>:
    """Copy host f64 slice to device buffer via rt_cuda_memcpy_htod.

    Allocates a temporary host staging buffer, writes values, calls the shim,
    then frees the staging buffer.  Returns bytes copied on success.
    """
    val n = values.len()
    val bytes = n * 8
    if bytes <= 0:
        return Ok(0)
    val host = rt_alloc(bytes)
    if host == 0:
        return Err(BackendError.BackendExecutionFailed("scilib_memcpy_htod: staging alloc failed"))
    var i = 0
    while i < n:
        rt_ptr_write_i64(host, i * 8, spl_f64_to_bits(values[i]))
        i = i + 1
    val rc = _scilib_call_n("rt_cuda_memcpy_htod", [dev_dst, host, bytes])
    rt_free(host, bytes)
    if rc != 0:
        return Err(BackendError.BackendExecutionFailed("rt_cuda_memcpy_htod failed: " + rc.to_text()))
    Ok(bytes)

pub fn scilib_memcpy_dtoh(dev_src: i64, count: i64) -> Result<[f64], BackendError>:
    """Copy device buffer to host f64 slice via rt_cuda_memcpy_dtoh.

    Returns a freshly allocated [f64] slice of length `count`.
    """
    val bytes = count * 8
    if bytes <= 0:
        return Ok([])
    val host = rt_alloc(bytes)
    if host == 0:
        return Err(BackendError.BackendExecutionFailed("scilib_memcpy_dtoh: staging alloc failed"))
    val rc = _scilib_call_n("rt_cuda_memcpy_dtoh", [host, dev_src, bytes])
    if rc != 0:
        rt_free(host, bytes)
        return Err(BackendError.BackendExecutionFailed("rt_cuda_memcpy_dtoh failed: " + rc.to_text()))
    var out: [f64] = []
    var i = 0
    while i < count:
        out.push(spl_bits_to_f64(rt_ptr_read_i64(host, i * 8)))
        i = i + 1
    rt_free(host, bytes)
    Ok(out)

# ---------------------------------------------------------------------------
# BLAS Level-1: dot, axpy, nrm2, scal
# ---------------------------------------------------------------------------

pub fn blas_ddot(n: i64, x: [f64], y: [f64]) -> Result<f64, BackendError>:
    """Compute dot product of two f64 vectors via rt_blas_ddot.

    Allocates host staging buffers, calls the shim, returns the scalar result.
    """
    if x.len() < n or y.len() < n:
        return Err(BackendError.BackendExecutionFailed("blas_ddot: vector too short"))
    val bytes = n * 8
    val x_buf = rt_alloc(bytes)
    if x_buf == 0:
        return Err(BackendError.BackendExecutionFailed("blas_ddot: x alloc failed"))
    val y_buf = rt_alloc(bytes)
    if y_buf == 0:
        rt_free(x_buf, bytes)
        return Err(BackendError.BackendExecutionFailed("blas_ddot: y alloc failed"))
    var i = 0
    while i < n:
        rt_ptr_write_i64(x_buf, i * 8, spl_f64_to_bits(x[i]))
        rt_ptr_write_i64(y_buf, i * 8, spl_f64_to_bits(y[i]))
        i = i + 1
    val result_bits = _scilib_call_n("rt_scilib_openblas_ddot_bits", [x_buf, n, y_buf])
    rt_free(x_buf, bytes)
    rt_free(y_buf, bytes)
    Ok(spl_bits_to_f64(result_bits))

pub fn blas_dnrm2(n: i64, x: [f64]) -> Result<f64, BackendError>:
    """Compute Euclidean norm of an f64 vector via the mock/openblas ddot path.

    Note: uses pure-Simple fallback (no direct rt_blas_dnrm2 symbol in v1 shim).
    Returns sqrt(sum(x[i]^2)) computed on host.
    """
    if x.len() < n:
        return Err(BackendError.BackendExecutionFailed("blas_dnrm2: vector too short"))
    var sum = 0.0
    var i = 0
    while i < n:
        sum = sum + x[i] * x[i]
        i = i + 1
    # simple integer sqrt approximation via Newton-Raphson (20 iterations)
    if sum <= 0.0:
        return Ok(0.0)
    var est = sum
    var iter = 0
    while iter < 20:
        est = 0.5 * (est + sum / est)
        iter = iter + 1
    Ok(est)

# ---------------------------------------------------------------------------
# BLAS Level-3: dgemm (double-precision matrix multiply)
# ---------------------------------------------------------------------------

pub fn blas_dgemm_values(
    trans_a: i64, trans_b: i64,
    m: i64, n: i64, k: i64,
    alpha: f64,
    a: [f64], lda: i64,
    b: [f64], ldb: i64,
    beta: f64,
    c_in: [f64], ldc: i64
) -> Result<[f64], BackendError>:
    """Matrix multiply C = alpha*A*B + beta*C via the scilib dgemm_bits shim.

    All matrices are flat row-major f64 slices.  The operand-swap trick
    (passing B before A) is applied here to convert from row-major to the
    column-major convention expected by the cuBLAS path.

    Layer B (this function) applies the swap: calls shim with (B, A) and
    swapped trans flags so that cuBLAS computes Cᵀ = Bᵀ × Aᵀ = (A×B)ᵀ,
    which in row-major is equivalent to C = A×B.

    Returns the output C matrix as a flat row-major [f64] slice of size m*n.
    """
    val a_size = m * k
    val b_size = k * n
    val c_size = m * n
    if a.len() < a_size or b.len() < b_size or c_in.len() < c_size:
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: buffer too small"))

    val a_bytes = a_size * 8
    val b_bytes = b_size * 8
    val c_bytes = c_size * 8

    val a_buf = rt_alloc(a_bytes)
    if a_buf == 0:
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: A alloc failed"))
    val b_buf = rt_alloc(b_bytes)
    if b_buf == 0:
        rt_free(a_buf, a_bytes)
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: B alloc failed"))
    val c_buf = rt_alloc(c_bytes)
    if c_buf == 0:
        rt_free(a_buf, a_bytes)
        rt_free(b_buf, b_bytes)
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: C alloc failed"))

    # Allocate packed params buffer: [m, n, k, alpha_bits, beta_bits] — 5 x i64
    val params_buf = rt_alloc(40)
    if params_buf == 0:
        rt_free(a_buf, a_bytes)
        rt_free(b_buf, b_bytes)
        rt_free(c_buf, c_bytes)
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: params alloc failed"))
    # Allocate output buffer (separate from c_in)
    val out_buf = rt_alloc(c_bytes)
    if out_buf == 0:
        rt_free(a_buf, a_bytes)
        rt_free(b_buf, b_bytes)
        rt_free(c_buf, c_bytes)
        rt_free(params_buf, 40)
        return Err(BackendError.BackendExecutionFailed("blas_dgemm_values: out alloc failed"))

    var i = 0
    while i < a_size:
        rt_ptr_write_i64(a_buf, i * 8, spl_f64_to_bits(a[i]))
        i = i + 1
    i = 0
    while i < b_size:
        rt_ptr_write_i64(b_buf, i * 8, spl_f64_to_bits(b[i]))
        i = i + 1
    i = 0
    while i < c_size:
        rt_ptr_write_i64(c_buf, i * 8, spl_f64_to_bits(c_in[i]))
        i = i + 1

    # Pack params: shim expects params[0]=m, [1]=n, [2]=k, [3]=alpha_bits, [4]=beta_bits
    # Operand-swap applied at shim level: shim takes (params, a_buf, b_buf, c_buf, out_buf)
    rt_ptr_write_i64(params_buf, 0, m)
    rt_ptr_write_i64(params_buf, 8, n)
    rt_ptr_write_i64(params_buf, 16, k)
    rt_ptr_write_i64(params_buf, 24, spl_f64_to_bits(alpha))
    rt_ptr_write_i64(params_buf, 32, spl_f64_to_bits(beta))

    val rc = _scilib_call_n("rt_scilib_openblas_dgemm_bits", [
        params_buf, a_buf, b_buf, c_buf, out_buf
    ])

    var out: [f64] = []
    i = 0
    while i < c_size:
        out.push(spl_bits_to_f64(rt_ptr_read_i64(out_buf, i * 8)))
        i = i + 1

    rt_free(a_buf, a_bytes)
    rt_free(b_buf, b_bytes)
    rt_free(c_buf, c_bytes)
    rt_free(params_buf, 40)
    rt_free(out_buf, c_bytes)

    if rc != 1:
        return Err(BackendError.BackendExecutionFailed("rt_scilib_openblas_dgemm_bits failed rc=" + rc.to_text()))
    Ok(out)
