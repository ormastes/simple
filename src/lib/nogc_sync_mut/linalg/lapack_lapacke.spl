"""LAPACKE SFFI Boundary — Phase 4 native LAPACK shim stubs.

LapackeProvider wraps native LAPACKE C interface calls.  When the
LAPACKE shared library is not linked/available, every operation returns
a typed error — NEVER a silent fallback or wrong answer.

Import path: use std.nogc_sync_mut.linalg.lapack_lapacke.*

Design:
  - Layer A: raw extern declarations (dgesv_, dgetrf_, etc.)
  - Layer B: LapackeProvider class — converts row-major to column-major
             via operand-swap (OQ-C: (AB)^T = B^T A^T) before calling externs.
  - LP64 integer ABI: all LAPACK integers are i64 (not i32).
  - Pivot arrays allocated internally; never exposed to Layer C callers.

Status: SFFI stubs — returns WorkspaceError when native library is absent.
Native wiring deferred until first solve/factorization path stable (T-LAPACK-11).
"""

use std.common.science_math.lapack_provider.{LapackProvider}
use std.common.science_math.lapack.{LinalgError, LapackInfo}

# ============================================================
# LapackeProvider
#
# When SIMPLE_BLAS_BACKEND=lapacke, this provider is selected.
# If the native LAPACKE library is absent, all calls return
# Err(LinalgError.WorkspaceError) — typed, never silent.
# ============================================================

pub class LapackeProvider:
    # Whether the native LAPACKE library was successfully loaded.
    _available: bool

    static fn new(available: bool) -> LapackeProvider:
        LapackeProvider(_available: available)

    pub fn provider_name(self) -> text:
        "lapacke"

    # gesv: LAPACK dgesv_ — solve A*x = b.
    # Operand-swap: pass A^T to column-major dgesv_ (no explicit transpose needed
    # because row-major A == column-major A^T, and dgesv_ solves A^T * x = b^T).
    # T-LAPACK-11: native wiring deferred; returns WorkspaceError until linked.
    pub fn gesv(self, n: i64, a_buf: [f64], b_buf: [f64]) -> Result<[f64], LinalgError>:
        if self._available == false:
            return Err(LinalgError.WorkspaceError)
        # TODO T-LAPACK-11: wire native dgesv_ extern here
        Err(LinalgError.WorkspaceError)

    # getrf: LAPACK dgetrf_ — LU factorization.
    # T-LAPACK-11: native wiring deferred.
    pub fn getrf(self, n: i64, a_buf: [f64]) -> Result<[f64], LinalgError>:
        if self._available == false:
            return Err(LinalgError.WorkspaceError)
        # TODO T-LAPACK-11: wire native dgetrf_ extern here
        Err(LinalgError.WorkspaceError)

    # inv: matrix inverse via dgesv columns.
    # T-LAPACK-11: native wiring deferred.
    pub fn inv(self, n: i64, a_buf: [f64]) -> Result<[f64], LinalgError>:
        if self._available == false:
            return Err(LinalgError.WorkspaceError)
        # TODO T-LAPACK-11: wire native dgetri_/dgetrf_ extern here
        Err(LinalgError.WorkspaceError)

    # det: determinant via LU diagonal product.
    # T-LAPACK-11: native wiring deferred.
    pub fn det(self, n: i64, a_buf: [f64]) -> Result<f64, LinalgError>:
        if self._available == false:
            return Err(LinalgError.WorkspaceError)
        # TODO T-LAPACK-11: wire native dgetrf_ + diagonal product here
        Err(LinalgError.WorkspaceError)

    # nrm2: BLAS dnrm2 — Euclidean norm.
    # T-LAPACK-11: native wiring deferred.
    pub fn nrm2(self, n: i64, x_buf: [f64]) -> f64:
        # When unavailable, return 0.0 sentinel; callers should not use this
        # without checking availability.  A typed error path is not possible
        # here as the trait returns f64 (not Result); see T-LAPACK-11 for fix.
        0.0
