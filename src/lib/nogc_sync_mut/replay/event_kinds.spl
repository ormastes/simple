# SReplay — Event Kind Definitions
#
# Library-owned replay event records used by SimpleOS kernel replay and
# host-side replay tooling. Keep this file independent of `os.*` so the OS
# depends on the replay backend library, not the other way around.

enum EventKind:
    Schedule
    SyscallEnter
    SyscallExit
    InterruptDeliver
    IpcSend
    IpcReceive
    TimerRead
    ThreadCreate
    ThreadExit
    MemoryMap
    PageFault
    RandomSeed
    DeviceIo
    Checkpoint

impl EventKind:
    fn to_i32() -> i32:
        match self:
            case EventKind.Schedule: 0
            case EventKind.SyscallEnter: 1
            case EventKind.SyscallExit: 2
            case EventKind.InterruptDeliver: 3
            case EventKind.IpcSend: 4
            case EventKind.IpcReceive: 5
            case EventKind.TimerRead: 6
            case EventKind.ThreadCreate: 7
            case EventKind.ThreadExit: 8
            case EventKind.MemoryMap: 9
            case EventKind.PageFault: 10
            case EventKind.RandomSeed: 11
            case EventKind.DeviceIo: 12
            case EventKind.Checkpoint: 13

    static fn from_i32(v: i32) -> EventKind:
        match v:
            case 0: EventKind.Schedule
            case 1: EventKind.SyscallEnter
            case 2: EventKind.SyscallExit
            case 3: EventKind.InterruptDeliver
            case 4: EventKind.IpcSend
            case 5: EventKind.IpcReceive
            case 6: EventKind.TimerRead
            case 7: EventKind.ThreadCreate
            case 8: EventKind.ThreadExit
            case 9: EventKind.MemoryMap
            case 10: EventKind.PageFault
            case 11: EventKind.RandomSeed
            case 12: EventKind.DeviceIo
            case _: EventKind.Checkpoint

    fn to_text() -> text:
        match self:
            case EventKind.Schedule: "schedule"
            case EventKind.SyscallEnter: "syscall-enter"
            case EventKind.SyscallExit: "syscall-exit"
            case EventKind.InterruptDeliver: "interrupt"
            case EventKind.IpcSend: "ipc-send"
            case EventKind.IpcReceive: "ipc-receive"
            case EventKind.TimerRead: "timer-read"
            case EventKind.ThreadCreate: "thread-create"
            case EventKind.ThreadExit: "thread-exit"
            case EventKind.MemoryMap: "memory-map"
            case EventKind.PageFault: "page-fault"
            case EventKind.RandomSeed: "random-seed"
            case EventKind.DeviceIo: "device-io"
            case EventKind.Checkpoint: "checkpoint"

struct ReplayEntry:
    event_id: i64
    logical_time: i64
    thread_id: i64
    process_id: i64
    cpu_id: i32
    kind: i32
    flags: i32
    payload_a: i64
    payload_b: i64
    payload_c: i64
    payload_d: i64
    crc32: i32

impl ReplayEntry:
    static fn create(kind: EventKind, tid: i64, pid: i64, cpu: i32) -> ReplayEntry:
        ReplayEntry(
            event_id: 0,
            logical_time: 0,
            thread_id: tid,
            process_id: pid,
            cpu_id: cpu,
            kind: kind.to_i32(),
            flags: 0,
            payload_a: 0,
            payload_b: 0,
            payload_c: 0,
            payload_d: 0,
            crc32: 0
        )

    fn event_kind() -> EventKind:
        EventKind.from_i32(self.kind)
