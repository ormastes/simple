# SReplay — Container Replay Driver
#
# Manages container-level checkpoints for the replay debugger (Track 5).
# Supports saving, restoring, listing, and searching checkpoints.
# Uses the local checkpoint format types (not OS-kernel types).

use std.nogc_sync_mut.replay.container.checkpoint_format.{
    ContainerCheckpoint, ProcessSnapshot, DirtyPage, FdEntry,
    IpcSnapshot, IpcMessage, encode_checkpoint, decode_checkpoint
}

# ============================================================================
# Container Replay Driver
# ============================================================================

class ContainerReplayDriver:
    mode: text                          # "record" or "replay"
    checkpoints: [ContainerCheckpoint]
    event_index: i64                    # current replay cursor position
    container_id: text

    static fn create(mode: text, container_id: text) -> ContainerReplayDriver:
        ContainerReplayDriver(
            mode: mode,
            checkpoints: [],
            event_index: 0,
            container_id: container_id
        )

    # ------------------------------------------------------------------
    # save_checkpoint — capture current state as a numbered checkpoint
    # ------------------------------------------------------------------

    me fn save_checkpoint(id: i32) -> Result<text, text>:
        if self.mode != "record":
            return Err("cannot save checkpoint in {self.mode} mode")

        # Check for duplicate checkpoint IDs
        for cp in self.checkpoints:
            if cp.id == id:
                return Err("checkpoint {id} already exists")

        val cp = ContainerCheckpoint.create(id, self.event_index)
        self.checkpoints.push(cp)

        val msg = "checkpoint {id} saved at event {self.event_index} for container {self.container_id}"
        Ok(msg)

    # ------------------------------------------------------------------
    # restore_checkpoint — roll back to a previously saved checkpoint
    # ------------------------------------------------------------------

    me fn restore_checkpoint(id: i32) -> Result<text, text>:
        var found: Option<ContainerCheckpoint> = None

        for cp in self.checkpoints:
            if cp.id == id:
                found = Some(cp)

        match found:
            case Some(cp):
                self.event_index = cp.timestamp
                val msg = "restored to checkpoint {id} at event {cp.timestamp} for container {self.container_id}"
                Ok(msg)
            case None:
                Err("checkpoint {id} not found")

    # ------------------------------------------------------------------
    # list_checkpoints — return summary strings for all checkpoints
    # ------------------------------------------------------------------

    fn list_checkpoints() -> [text]:
        var result: [text] = []
        for cp in self.checkpoints:
            val entry = "id={cp.id} ts={cp.timestamp} procs={cp.processes.len()} ipc={cp.ipc.len()}"
            result.push(entry)
        result

    # ------------------------------------------------------------------
    # find_checkpoint_before — find the latest checkpoint at or before
    # the given timestamp
    # ------------------------------------------------------------------

    fn find_checkpoint_before(timestamp: i64) -> Option<ContainerCheckpoint>:
        var best: Option<ContainerCheckpoint> = None
        var best_ts: i64 = -1

        for cp in self.checkpoints:
            if cp.timestamp <= timestamp and cp.timestamp > best_ts:
                best = Some(cp)
                best_ts = cp.timestamp

        best

    # ------------------------------------------------------------------
    # Convenience helpers
    # ------------------------------------------------------------------

    fn checkpoint_count() -> i32:
        self.checkpoints.len() as i32

    me fn advance_event():
        self.event_index = self.event_index + 1

    fn info() -> text:
        "ContainerReplayDriver container={self.container_id} mode={self.mode} checkpoints={self.checkpoints.len()} event={self.event_index}"

    # ------------------------------------------------------------------
    # Serialization round-trip for a specific checkpoint
    # ------------------------------------------------------------------

    fn serialize_checkpoint(id: i32) -> Result<[i32], text>:
        for cp in self.checkpoints:
            if cp.id == id:
                return Ok(encode_checkpoint(cp))
        Err("checkpoint {id} not found")

    me fn load_checkpoint(data: [i32]) -> Result<text, text>:
        val cp = decode_checkpoint(data)?
        # Replace if same id exists, otherwise append
        var replaced = false
        var idx: i32 = 0
        while idx < self.checkpoints.len():
            if self.checkpoints[idx].id == cp.id:
                self.checkpoints[idx] = cp
                replaced = true
            idx = idx + 1
        if not replaced:
            self.checkpoints.push(cp)
        Ok("loaded checkpoint {cp.id}")
