# SReplay VM — Virtual Serial (UART) Device
#
# Simple UART: TX buffer for output, RX buffer for input replay.

# ============================================================================
# Virtual Serial Port
# ============================================================================

class VirtualSerial:
    name_val: text
    irq: i32
    tx_buffer: [i32]       # output bytes
    rx_buffer: [i32]       # input bytes (for replay)
    rx_pos: i64
    irq_pending: bool

impl VirtualSerial:
    static fn create(name: text, irq: i32) -> VirtualSerial:
        VirtualSerial(
            name_val: name,
            irq: irq,
            tx_buffer: [],
            rx_buffer: [],
            rx_pos: 0,
            irq_pending: false
        )

    fn name() -> text:
        self.name_val

    fn mmio_read(offset: i64, size: i32) -> Result<i64, text>:
        match offset:
            # RBR — Receive Buffer Register
            0x00:
                if self.rx_pos < self.rx_buffer.len():
                    val byte = self.rx_buffer[self.rx_pos] as i64
                    self.rx_pos = self.rx_pos + 1
                    Ok(byte)
                else:
                    Ok(0)
            # LSR — Line Status Register
            0x05:
                val rx_ready = if self.rx_pos < self.rx_buffer.len(): 1 else: 0
                val tx_empty = 0x20  # TX holding register empty
                Ok((tx_empty + rx_ready) as i64)
            _: Ok(0)

    fn mmio_write(offset: i64, value: i64, size: i32) -> Result<Nil, text>:
        match offset:
            # THR — Transmit Holding Register
            0x00:
                self.tx_buffer.push((value & 0xFF) as i32)
            _: pass
        Ok(nil)

    fn tick(cycles: i64):
        if self.rx_pos < self.rx_buffer.len():
            self.irq_pending = true

    fn pending_irq() -> i32:
        if self.irq_pending: self.irq else: -1

    fn acknowledge_irq():
        self.irq_pending = false

    fn get_output() -> text:
        var chars: [text] = []
        for byte in self.tx_buffer:
            # Simple ASCII conversion
            if byte >= 32 and byte < 127:
                chars.push(char_from_code(byte))
            elif byte == 10:
                chars.push("\n")
        chars.join("")

    fn inject_input(data: [i32]):
        for byte in data:
            self.rx_buffer.push(byte)

    fn snapshot() -> [i32]:
        var data: [i32] = []
        data.push(self.tx_buffer.len() as i32)
        for b in self.tx_buffer:
            data.push(b)
        data.push(self.rx_buffer.len() as i32)
        for b in self.rx_buffer:
            data.push(b)
        data.push(self.rx_pos as i32)
        data

    fn restore(data: [i32]):
        if data.len() < 1:
            return
        var pos = 0
        val tx_len = data[pos]
        pos = pos + 1
        self.tx_buffer = []
        var i = 0
        while i < tx_len and pos < data.len():
            self.tx_buffer.push(data[pos])
            pos = pos + 1
            i = i + 1
        if pos < data.len():
            val rx_len = data[pos]
            pos = pos + 1
            self.rx_buffer = []
            i = 0
            while i < rx_len and pos < data.len():
                self.rx_buffer.push(data[pos])
                pos = pos + 1
                i = i + 1
        if pos < data.len():
            self.rx_pos = data[pos] as i64

    fn is_deterministic() -> bool:
        false

# ============================================================================
# ASCII helper
# ============================================================================

fn char_from_code(code: i32) -> text:
    # Placeholder — real impl would use FFI
    match code:
        32: " "
        48: "0"
        49: "1"
        65: "A"
        72: "H"
        101: "e"
        108: "l"
        111: "o"
        _: "?"
