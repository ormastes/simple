
use std.replay.adapters.interpreter_replay_event.InterpreterReplayEventKind
use std.replay.adapters.interpreter_replay_event.InterpreterReplayEvent

struct InterpreterCheckpoint:
    checkpoint_id: i32
    event_index: i64
    debug_state: text

class InterpreterReplayAdapter:
    mode: text
    events: [InterpreterReplayEvent]
    checkpoints: [InterpreterCheckpoint]
    _seq: i64

    static fn create(mode: text) -> InterpreterReplayAdapter:
        InterpreterReplayAdapter(
            mode: mode,
            events: [],
            checkpoints: [],
            _seq: 0
        )

    me fn wrap_step():
        if self.mode == "record":
            val ev = InterpreterReplayEvent(
                seq_id: self._seq,
                kind: InterpreterReplayEventKind::Step,
                file: "",
                line: 0,
                name: "",
                value: "",
                timestamp: 0
            )
            self.events.push(ev)
            self._seq = self._seq + 1

    me fn save_checkpoint() -> i32:
        val id = self.checkpoints.len() as i32
        val cp = InterpreterCheckpoint(
            checkpoint_id: id,
            event_index: self.events.len() as i64,
            debug_state: ""
        )
        self.checkpoints.push(cp)
        id

    me fn restore_checkpoint(id: i32):
        var i = 0
        while i < self.checkpoints.len():
            val cp = self.checkpoints[i]
            if cp.checkpoint_id == id:
                val target = cp.event_index as i32
                while self.events.len() > target:
                    self.events.pop()
                return
            i = i + 1

    me fn reverse_step():
        if self.events.len() > 0:
            self.events.pop()

    me fn reverse_continue():
        var i = self.events.len() - 1
        while i > 0:
            val ev = self.events[i]
            val k = ev.kind.to_i32()
            if k == InterpreterReplayEventKind::BreakpointHit.to_i32():
                while self.events.len() > i:
                    self.events.pop()
                return
            i = i - 1

    fn event_count() -> i64:
        self.events.len() as i64
