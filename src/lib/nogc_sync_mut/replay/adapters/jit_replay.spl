
use std.replay.adapters.jit_replay_event.JitReplayEventKind
use std.replay.adapters.jit_replay_event.JitReplayEvent

enum JitReplayMode:
    Off
    Record
    Replay

    fn to_text(self) -> text:
        match self:
            JitReplayMode::Off => "off"
            JitReplayMode::Record => "record"
            JitReplayMode::Replay => "replay"

struct JitCheckpoint:
    id: i32
    event_index: i64

class JitReplayAdapter:
    mode: JitReplayMode
    events: [JitReplayEvent]
    checkpoints: [JitCheckpoint]
    trace_path: text
    _seq: i64

    static fn create(mode: JitReplayMode, trace_path: text) -> JitReplayAdapter:
        JitReplayAdapter(
            mode: mode,
            events: [],
            checkpoints: [],
            trace_path: trace_path,
            _seq: 0
        )

    me fn on_jit_compile(fn_name: text, module: text):
        val m = self.mode.to_text()
        if m == "record":
            val ev = JitReplayEvent(
                seq_id: self._seq,
                kind: JitReplayEventKind::Compile,
                function_hash: 0,
                module_hash: 0,
                args_hash: 0,
                result: 0,
                timestamp: 0
            )
            self.events.push(ev)
            self._seq = self._seq + 1

    me fn on_jit_execute(fn_name: text, args_hash: i64) -> i64:
        val m = self.mode.to_text()
        if m == "record":
            val ev = JitReplayEvent(
                seq_id: self._seq,
                kind: JitReplayEventKind::Execute,
                function_hash: 0,
                module_hash: 0,
                args_hash: args_hash,
                result: 0,
                timestamp: 0
            )
            self.events.push(ev)
            self._seq = self._seq + 1
        0

    me fn save_checkpoint() -> i32:
        val id = self.checkpoints.len() as i32
        val cp = JitCheckpoint(
            id: id,
            event_index: self.events.len() as i64
        )
        self.checkpoints.push(cp)
        id

    me fn restore_checkpoint(id: i32):
        var i = 0
        while i < self.checkpoints.len():
            val cp = self.checkpoints[i]
            if cp.id == id:
                val target = cp.event_index as i32
                while self.events.len() > target:
                    self.events.pop()
                return
            i = i + 1

    me fn reverse_to_call(fn_name: text):
        var i = self.events.len() - 1
        while i > 0:
            val ev = self.events[i]
            val k = ev.kind.to_i32()
            if k == JitReplayEventKind::Execute.to_i32():
                while self.events.len() > i:
                    self.events.pop()
                return
            i = i - 1

    fn event_count() -> i64:
        self.events.len() as i64

    fn save_trace():
        pass_dn

    fn load_trace():
        pass_dn
