
class QemuReplayAdapter {
    qmp_socket: text,
    gdb_port: i32,
    recording: bool,
    replaying: bool,

    fn create_from_backend(qmp_socket: text, gdb_port: i32) -> QemuReplayAdapter {
        QemuReplayAdapter {
            qmp_socket: qmp_socket,
            gdb_port: gdb_port,
            recording: false,
            replaying: false,
        }
    }

    fn start_record(self, kernel: text, arch: text, trace: text) {
        self.recording = true
        self.replaying = false
    }

    fn start_replay(self, trace: text) {
        self.recording = false
        self.replaying = true
    }

    fn reverse_step(self) {
        // send reverse-step via QMP/GDB
        pass_dn
    }

    fn reverse_continue(self) {
        // send reverse-continue via QMP/GDB
        pass_dn
    }

    fn save_vm_checkpoint(self, name: text) {
        // send savevm QMP command
        pass_dn
    }

    fn restore_vm_checkpoint(self, name: text) {
        // send loadvm QMP command
        pass_dn
    }

    fn status(self) -> text {
        if self.recording {
            "recording"
        } else if self.replaying {
            "replaying"
        } else {
            "off"
        }
    }
}
