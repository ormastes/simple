
enum JitReplayEventKind:
    Compile
    Execute
    Deoptimize
    Checkpoint
    InlineCache

    fn to_i32(self) -> i32:
        match self:
            JitReplayEventKind::Compile => 0
            JitReplayEventKind::Execute => 1
            JitReplayEventKind::Deoptimize => 2
            JitReplayEventKind::Checkpoint => 3
            JitReplayEventKind::InlineCache => 4

    fn from_i32(v: i32) -> JitReplayEventKind:
        if v == 0: JitReplayEventKind::Compile
        else if v == 1: JitReplayEventKind::Execute
        else if v == 2: JitReplayEventKind::Deoptimize
        else if v == 3: JitReplayEventKind::Checkpoint
        else: JitReplayEventKind::InlineCache

    fn to_text(self) -> text:
        match self:
            JitReplayEventKind::Compile => "Compile"
            JitReplayEventKind::Execute => "Execute"
            JitReplayEventKind::Deoptimize => "Deoptimize"
            JitReplayEventKind::Checkpoint => "Checkpoint"
            JitReplayEventKind::InlineCache => "InlineCache"

struct JitReplayEvent:
    seq_id: i64
    kind: JitReplayEventKind
    function_hash: i64
    module_hash: i64
    args_hash: i64
    result: i64
    timestamp: i64
