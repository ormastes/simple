module std.replay.adapters.test_runner_replay

enum TestReplayMode {
    Off,
    RecordOnFail,
    RecordAlways,
    Replay,

    fn to_text(self) -> text {
        match self {
            TestReplayMode::Off => "off",
            TestReplayMode::RecordOnFail => "record_on_fail",
            TestReplayMode::RecordAlways => "record_always",
            TestReplayMode::Replay => "replay",
        }
    }

    fn from_text(v: text) -> TestReplayMode {
        if v == "record_on_fail" { TestReplayMode::RecordOnFail }
        else if v == "record_always" { TestReplayMode::RecordAlways }
        else if v == "replay" { TestReplayMode::Replay }
        else { TestReplayMode::Off }
    }
}

class TestRunnerReplayAdapter {
    mode: TestReplayMode,
    trace_dir: text,
    recorded_tests: [text],

    fn create(mode: TestReplayMode, trace_dir: text) -> TestRunnerReplayAdapter {
        TestRunnerReplayAdapter {
            mode: mode,
            trace_dir: trace_dir,
            recorded_tests: [],
        }
    }

    fn wrap_test_execution(self, test_file: text, strategy: text) {
        match self.mode {
            TestReplayMode::RecordAlways => {
                self.recorded_tests.push(test_file)
            },
            TestReplayMode::RecordOnFail => {
                // will record only on failure; register intent
                self.recorded_tests.push(test_file)
            },
            _ => {},
        }
    }

    fn replay_test(self, test_file: text) {
        // load trace from trace_dir and replay
        pass_dn
    }

    fn record_on_fail(self, test_file: text, result: text, exit_code: i32) {
        if exit_code != 0 {
            self.recorded_tests.push(test_file)
        }
    }

    fn list_recorded_traces(self) -> [text] {
        self.recorded_tests
    }
}
