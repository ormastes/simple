
enum InterpreterReplayEventKind:
    Step
    Evaluate
    VariableChange
    FunctionCall
    FunctionReturn
    BreakpointHit

    fn to_i32(self) -> i32:
        match self:
            InterpreterReplayEventKind::Step => 0
            InterpreterReplayEventKind::Evaluate => 1
            InterpreterReplayEventKind::VariableChange => 2
            InterpreterReplayEventKind::FunctionCall => 3
            InterpreterReplayEventKind::FunctionReturn => 4
            InterpreterReplayEventKind::BreakpointHit => 5

    fn from_i32(v: i32) -> InterpreterReplayEventKind:
        if v == 0: InterpreterReplayEventKind::Step
        else if v == 1: InterpreterReplayEventKind::Evaluate
        else if v == 2: InterpreterReplayEventKind::VariableChange
        else if v == 3: InterpreterReplayEventKind::FunctionCall
        else if v == 4: InterpreterReplayEventKind::FunctionReturn
        else: InterpreterReplayEventKind::BreakpointHit

    fn to_text(self) -> text:
        match self:
            InterpreterReplayEventKind::Step => "Step"
            InterpreterReplayEventKind::Evaluate => "Evaluate"
            InterpreterReplayEventKind::VariableChange => "VariableChange"
            InterpreterReplayEventKind::FunctionCall => "FunctionCall"
            InterpreterReplayEventKind::FunctionReturn => "FunctionReturn"
            InterpreterReplayEventKind::BreakpointHit => "BreakpointHit"

struct InterpreterReplayEvent:
    seq_id: i64
    kind: InterpreterReplayEventKind
    file: text
    line: i32
    name: text
    value: text
    timestamp: i64
