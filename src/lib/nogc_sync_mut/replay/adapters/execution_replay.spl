
class ExecutionReplayHook {
    recording: bool,
    events: [text],
    trace_path: text,

    fn create(trace_path: text) -> ExecutionReplayHook {
        ExecutionReplayHook {
            recording: false,
            events: [],
            trace_path: trace_path,
        }
    }

    fn start_recording(self) {
        self.recording = true
        self.events = []
    }

    fn stop_recording(self) {
        self.recording = false
    }

    fn record_execution_start(self, program: text, args: text, mode: text) {
        if self.recording {
            self.events.push("start:" + program + ":" + args + ":" + mode)
        }
    }

    fn record_execution_result(self, exit_code: i32, stdout: text, duration_ms: i64) {
        if self.recording {
            self.events.push("result:" + exit_code.to_text() + ":" + duration_ms.to_text())
        }
    }

    fn save_trace(self) {
        // write events to trace_path
        pass_dn
    }

    fn load_trace(self) {
        // load events from trace_path
        pass_dn
    }
}
