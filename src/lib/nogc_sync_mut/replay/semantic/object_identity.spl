# SReplay — Object Identity System
#
# Assigns stable logical IDs to heap objects for semantic tracing.
# Used by the trace writer to correlate alloc/drop/transfer events.

# ============================================================================
# Object Identity
# ============================================================================

struct ObjectId:
    id: i64
    type_name_id: i32
    alloc_site_file: i32
    alloc_site_line: i32
    dropped: bool

impl ObjectId:
    fn to_text() -> text:
        "ObjectId({self.id}, type={self.type_name_id}, file={self.alloc_site_file}:{self.alloc_site_line})"

# ============================================================================
# Object Registry
# ============================================================================

class ObjectRegistry:
    next_id: i64
    entries: [ObjectId]

    static fn create() -> ObjectRegistry:
        ObjectRegistry(
            next_id: 1,
            entries: []
        )

    fn register(type_name_id: i32, file_id: i32, line: i32) -> i64:
        """Register a new object and return its unique ID."""
        val obj_id = self.next_id
        self.next_id = self.next_id + 1
        self.entries.push(ObjectId(
            id: obj_id,
            type_name_id: type_name_id,
            alloc_site_file: file_id,
            alloc_site_line: line,
            dropped: false
        ))
        obj_id

    fn mark_dropped(obj_id: i64):
        """Mark an object as dropped."""
        var i = 0
        while i < self.entries.len():
            if self.entries[i].id == obj_id:
                self.entries[i].dropped = true
                return
            i = i + 1

    fn lookup(obj_id: i64) -> Option<ObjectId>:
        """Look up an object by its ID."""
        for entry in self.entries:
            if entry.id == obj_id:
                return Some(entry)
        None

    fn active_count() -> i64:
        """Return the number of non-dropped objects."""
        var count: i64 = 0
        for entry in self.entries:
            if not entry.dropped:
                count = count + 1
        count
