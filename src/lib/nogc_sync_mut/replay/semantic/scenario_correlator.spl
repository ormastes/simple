# SReplay — Scenario Correlator
#
# Correlates semantic trace events with BDD-style scenario descriptions,
# enabling `simple debug trace.srr --scenario "user logs in and sees dashboard"`
# to replay a user story and show exactly what code executed.

# ============================================================================
# Scenario Step
# ============================================================================

struct ScenarioStep:
    name: text
    start_event_id: i64
    end_event_id: i64
    matched_functions: [text]
    matched_objects: [i64]

impl ScenarioStep:
    fn to_text() -> text:
        "ScenarioStep({self.name}, events=[{self.start_event_id}..{self.end_event_id}], fns={self.matched_functions.len()}, objs={self.matched_objects.len()})"

# ============================================================================
# Scenario Correlator
# ============================================================================

class ScenarioCorrelator:
    scenario_name: text
    steps: [ScenarioStep]
    trace_events: [SemanticEvent]

    static fn from_scenario(name: text) -> ScenarioCorrelator:
        """Create a new ScenarioCorrelator for the given scenario name."""
        ScenarioCorrelator(
            scenario_name: name,
            steps: [],
            trace_events: []
        )

    me fn add_step(step_name: text, start_id: i64, end_id: i64):
        """Append a new step covering events [start_id, end_id]."""
        self.steps.push(ScenarioStep(
            name: step_name,
            start_event_id: start_id,
            end_event_id: end_id,
            matched_functions: [],
            matched_objects: []
        ))

    me fn match_functions(step_idx: i32, patterns: [text]):
        """Attach matched function name patterns to the step at step_idx."""
        var new_steps: [ScenarioStep] = []
        var idx: i32 = 0
        for step in self.steps:
            if idx == step_idx:
                new_steps.push(ScenarioStep(
                    name: step.name,
                    start_event_id: step.start_event_id,
                    end_event_id: step.end_event_id,
                    matched_functions: patterns,
                    matched_objects: step.matched_objects
                ))
            else:
                new_steps.push(step)
            idx = idx + 1
        self.steps = new_steps

    me fn match_objects(step_idx: i32, obj_ids: [i64]):
        """Attach matched object IDs to the step at step_idx."""
        var new_steps: [ScenarioStep] = []
        var idx: i32 = 0
        for step in self.steps:
            if idx == step_idx:
                new_steps.push(ScenarioStep(
                    name: step.name,
                    start_event_id: step.start_event_id,
                    end_event_id: step.end_event_id,
                    matched_functions: step.matched_functions,
                    matched_objects: obj_ids
                ))
            else:
                new_steps.push(step)
            idx = idx + 1
        self.steps = new_steps

    fn step_count() -> i32:
        """Return the number of steps in this scenario."""
        self.steps.len()

    fn get_step(idx: i32) -> ScenarioStep:
        """Return the step at the given index."""
        self.steps[idx]

    fn summary() -> text:
        """Return a human-readable summary of the scenario and its steps."""
        var out: text = "Scenario: {self.scenario_name}\n"
        out = out + "Steps: {self.steps.len()}\n"
        var i: i32 = 0
        for step in self.steps:
            out = out + "  [{i}] {step.name} (events {step.start_event_id}..{step.end_event_id}, fns={step.matched_functions.len()}, objs={step.matched_objects.len()})\n"
            i = i + 1
        out
