# SReplay — Process-Level Replay (Track 3)
#
# ptrace/strace-based deterministic replay for Linux user-space processes.
# Records syscall results, signals, and non-deterministic inputs so that
# a process execution can be replayed bit-for-bit.

export ProcessEventKind, ProcessReplayEvent
export ProcessRecorder, RecordingMode
export ProcessReplayer, ReplayVerdict, ReplayStepResult
export DirtyPage, RegisterEntry, PageCheckpoint, CheckpointManager
export write_process_trace, read_process_trace, ProcessTraceMetadata
export save_process_checkpoint, restore_process_checkpoint
