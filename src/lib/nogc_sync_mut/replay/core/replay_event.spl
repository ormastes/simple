module std.replay.core.replay_event

enum ReplayEventKind {
    FunctionEnter,
    FunctionExit,
    Step,
    VariableWrite,
    BreakpointHit,
    Syscall,
    Interrupt,
    TimerRead,
    IoRead,
    IoWrite,
    CheckpointSave,
    CheckpointRestore,

    fn to_i32(self) -> i32 {
        match self {
            ReplayEventKind::FunctionEnter => 0,
            ReplayEventKind::FunctionExit => 1,
            ReplayEventKind::Step => 2,
            ReplayEventKind::VariableWrite => 3,
            ReplayEventKind::BreakpointHit => 4,
            ReplayEventKind::Syscall => 5,
            ReplayEventKind::Interrupt => 6,
            ReplayEventKind::TimerRead => 7,
            ReplayEventKind::IoRead => 8,
            ReplayEventKind::IoWrite => 9,
            ReplayEventKind::CheckpointSave => 10,
            ReplayEventKind::CheckpointRestore => 11,
        }
    }

    fn from_i32(v: i32) -> ReplayEventKind {
        if v == 0 { ReplayEventKind::FunctionEnter }
        else if v == 1 { ReplayEventKind::FunctionExit }
        else if v == 2 { ReplayEventKind::Step }
        else if v == 3 { ReplayEventKind::VariableWrite }
        else if v == 4 { ReplayEventKind::BreakpointHit }
        else if v == 5 { ReplayEventKind::Syscall }
        else if v == 6 { ReplayEventKind::Interrupt }
        else if v == 7 { ReplayEventKind::TimerRead }
        else if v == 8 { ReplayEventKind::IoRead }
        else if v == 9 { ReplayEventKind::IoWrite }
        else if v == 10 { ReplayEventKind::CheckpointSave }
        else { ReplayEventKind::CheckpointRestore }
    }

    fn to_text(self) -> text {
        match self {
            ReplayEventKind::FunctionEnter => "FunctionEnter",
            ReplayEventKind::FunctionExit => "FunctionExit",
            ReplayEventKind::Step => "Step",
            ReplayEventKind::VariableWrite => "VariableWrite",
            ReplayEventKind::BreakpointHit => "BreakpointHit",
            ReplayEventKind::Syscall => "Syscall",
            ReplayEventKind::Interrupt => "Interrupt",
            ReplayEventKind::TimerRead => "TimerRead",
            ReplayEventKind::IoRead => "IoRead",
            ReplayEventKind::IoWrite => "IoWrite",
            ReplayEventKind::CheckpointSave => "CheckpointSave",
            ReplayEventKind::CheckpointRestore => "CheckpointRestore",
        }
    }
}

struct ReplayEvent {
    seq_id: i64,
    kind: ReplayEventKind,
    timestamp: i64,
    file_hash: i64,
    line: i32,
    name_hash: i64,
    value_a: i64,
    value_b: i64,
}
