
trait ReplayHook:
    fn on_function_enter(self, name: text, module: text)
    fn on_function_exit(self, name: text, return_type: text)
    fn on_step(self, file: text, line: i32, column: i32)
    fn on_variable_write(self, name: text, type_name: text, old_hash: i64, new_hash: i64)
    fn on_breakpoint_hit(self, file: text, line: i32)
    fn on_syscall(self, syscall_id: i64, arg0: i64, arg1: i64, result: i64)
    fn on_interrupt(self, vector: i64, timestamp: i64)
    fn on_timer_read(self, source_id: i64, value: i64) -> i64
    fn on_io_read(self, addr: i64, size: i32, value: i64) -> i64
    fn on_io_write(self, addr: i64, size: i32, value: i64)
    fn on_checkpoint_save(self, id: i32)
    fn on_checkpoint_restore(self, id: i32)
    fn is_recording(self) -> bool
    fn is_replaying(self) -> bool
    fn is_off(self) -> bool
