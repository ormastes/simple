
use std.replay.core.replay_hook.ReplayHook

class NoopReplayHook:
    fn on_function_enter(name: text, module: text):
        pass_dn

    fn on_function_exit(name: text, return_type: text):
        pass_dn

    fn on_step(file: text, line: i32, column: i32):
        pass_dn

    fn on_variable_write(name: text, type_name: text, old_hash: i64, new_hash: i64):
        pass_dn

    fn on_breakpoint_hit(file: text, line: i32):
        pass_dn

    fn on_syscall(syscall_id: i64, arg0: i64, arg1: i64, result: i64):
        pass_dn

    fn on_interrupt(vector: i64, timestamp: i64):
        pass_dn

    fn on_timer_read(source_id: i64, value: i64) -> i64:
        value

    fn on_io_read(addr: i64, size: i32, value: i64) -> i64:
        value

    fn on_io_write(addr: i64, size: i32, value: i64):
        pass_dn

    fn on_checkpoint_save(id: i32):
        pass_dn

    fn on_checkpoint_restore(id: i32):
        pass_dn

    fn is_recording() -> bool:
        false

    fn is_replaying() -> bool:
        false

    fn is_off() -> bool:
        true
