# std.game2d.app.app — App trait + lifecycle defaults (Wave C, AC-1)
#
# Pure Simple, no inheritance. The `App` trait declares four lifecycle
# methods with no-op defaults. Concrete games declare
# `class Game : App` and override only what they need.
#
# Composition fallback: `AppDefaults` provides the no-op bodies as a
# standalone helper class — games that prefer composition can hold
# `var defaults: AppDefaults` and forward unhandled calls. Trait
# default-method support carries the primary surface; AppDefaults is
# the parity for arenas where default impl resolution differs.

use std.nogc_sync_mut.game2d.render.canvas.{Canvas}


# AppDefaults — no-op bodies, composition fallback for the App trait.
class AppDefaults:
    static fn new() -> AppDefaults:
        AppDefaults()

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt

    fn fixed_update(self, step: f32):
        val _ = step

    fn draw(self, ctx: Canvas):
        val _ = ctx


# App — trait surface every game implements. Default bodies forward
# to AppDefaults so user games may override only the methods they need.
trait App:
    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt

    fn fixed_update(self, step: f32):
        val _ = step

    fn draw(self, ctx: Canvas):
        val _ = ctx
