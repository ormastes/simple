# std.game2d.asset.error — AssetError diagnostics (Wave B, AC-6)
#
# Diagnostic family GAME-ASSET-NNN. Codes wired this iteration:
#   GAME-ASSET-001 — Missing image/sound/font path (file not on disk).
#   GAME-ASSET-002 — Wrong-type asset (e.g., Sound declared under images:).
#   GAME-ASSET-014 — Atlas region exceeds image bounds.
#
# All variants carry a `code/file/line/key/msg` payload so the spec greps
# (`test/system/game2d_sdn_assets_spec.spl`) find every required field.

use std.common.sdn.value.{Span}


class AssetError:
    code: text
    file: text
    line: i64
    column: i64
    key: text
    msg: text

    static fn missing(span: Span, file: text, key: text) -> AssetError:
        # GAME-ASSET-001 — referenced asset path does not exist.
        AssetError(
            code: "GAME-ASSET-001",
            file: file,
            line: span.line,
            column: span.column,
            key: key,
            msg: "asset '{key}' missing at {file}:{span.line}"
        )

    static fn wrong_type(span: Span, file: text, key: text, expected: text, got: text) -> AssetError:
        # GAME-ASSET-002 — asset declared under wrong type section.
        AssetError(
            code: "GAME-ASSET-002",
            file: file,
            line: span.line,
            column: span.column,
            key: key,
            msg: "asset '{key}' wrong type at {file}:{span.line}: expected {expected}, got {got}"
        )

    static fn atlas_oob(span: Span, file: text, region: text) -> AssetError:
        # GAME-ASSET-014 — atlas region exceeds image bounds.
        AssetError(
            code: "GAME-ASSET-014",
            file: file,
            line: span.line,
            column: span.column,
            key: region,
            msg: "atlas region '{region}' out of bounds at {file}:{span.line}"
        )

    static fn parse_error(file: text, msg: text) -> AssetError:
        AssetError(
            code: "GAME-ASSET-PARSE",
            file: file,
            line: 0,
            column: 0,
            key: "",
            msg: "parse error in {file}: {msg}"
        )

    fn diagnostic() -> text:
        "{self.code}: {self.msg}"
