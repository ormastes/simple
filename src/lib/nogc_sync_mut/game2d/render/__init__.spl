# std.game2d.render — Wave B
#
# Re-exports the public render surface for `import std.game2d.render`:
#   - `Canvas` — frame-builder around RenderCommandBuffer
#   - `Image` — typed image handle (thin wrapper around engine Sprite)
#   - `Font`  — typed font handle (Wave-B software stub)
#   - `DrawMode` — Fill / Stroke (re-exported from game2d/math/__init__.spl)

use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.render.image.{Image}
use std.nogc_sync_mut.game2d.render.font.{Font}
use std.nogc_sync_mut.game2d.math.{DrawMode}

export Canvas
export Image
export Font
export DrawMode
