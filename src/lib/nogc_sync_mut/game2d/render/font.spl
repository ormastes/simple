# std.game2d.render.font — typed Font handle (Wave B)
#
# Tier-0 software-only stub. Wave-A `engine/render/command.spl` introduced
# `class FontId { raw: i64 }` and `RenderCommand.DrawText { font, content,
# pos, color, z_order }`. This module wraps `FontId` with a user-facing
# size and exposes `Font::new(path, size)` for the canvas API.
#
# We do NOT add any new externs. If a future font system lands under
# `engine/render/font/` we'll reroute through it; for now the headless
# backend draws text as a colored bounding box (see backend/headless_backend.spl).

use std.nogc_sync_mut.engine.render.command.{FontId}
use std.nogc_sync_mut.game2d.render.image.{RenderError}

# Built-in 5x7 monospace lookup metrics — used by the headless backend.
# Glyph cell is 8x8 (5x7 with 1px padding).
val GAME2D_FONT_GLYPH_W: i64 = 8
val GAME2D_FONT_GLYPH_H: i64 = 8

class Font:
    id: FontId
    size: i64

    static fn new(path: text, size: i64) -> Result<Font, RenderError>:
        """Create a Font handle. Wave-B Tier-0: `path` is recorded only
        in the FontId hash; rasterization uses the built-in 5x7
        monospace lookup. Real TTF loading is a follow-up.
        """
        if size <= 0:
            return Err(RenderError(
                code: "GAME-RENDER-003",
                msg: "Font::new size must be > 0"
            ))
        # Trivial id derived from path length + size — deterministic.
        val raw = path.len() * 31 + size
        Ok(Font(
            id: FontId(raw: raw),
            size: size
        ))

    static fn default_font() -> Font:
        """Backend default — used when Canvas.text() is called without a
        caller-supplied font.
        """
        Font(
            id: FontId(raw: 0),
            size: 8
        )

    fn glyph_width() -> i64:
        # Software stub: monospace cell width scales with `size / 8`.
        if self.size <= 0:
            GAME2D_FONT_GLYPH_W
        else:
            GAME2D_FONT_GLYPH_W

    fn glyph_height() -> i64:
        GAME2D_FONT_GLYPH_H

    fn measure(content: text) -> i64:
        content.len() * self.glyph_width()
