# std.game2d.audio — sound asset types and playback stub
#
# Sound wraps clip metadata for the asset loader. Actual playback
# delegates to AudioManager via clip_path.

export use nogc_sync_mut.game2d.audio.sound.{Sound}
export use nogc_sync_mut.game2d.audio.sound_asset_sdn.{
    SoundAsset, SoundSource, SoundEnvelope, SoundEffectSpec, SoundEvent, load_sound_asset
}

# AudioError — game2d/audio diagnostic family GAME-AUDIO-NNN
class AudioError:
    code: text
    msg: text

    static fn backend_missing() -> AudioError:
        AudioError(
            code: "GAME-AUDIO-001",
            msg: "audio backend not wired (Wave-B Tier-0 stub)"
        )

    static fn missing_file(path: text) -> AudioError:
        AudioError(
            code: "GAME-AUDIO-002",
            msg: "Sound::new could not find file: {path}"
        )


fn play(s: Sound) -> Result<i64, AudioError>:
    val _ = s
    Err(AudioError.backend_missing())
