# Sound — high-level sound asset wrapper for the game2d framework
#
# Wraps clip metadata for the asset loader. Actual playback is
# delegated to AudioManager via the clip_path.

# ============================================================================
# Sound
# ============================================================================

struct Sound:
    clip_path: text
    bus_name: text
    volume: f64
    looped: bool
    spatial: bool

impl Sound:
    static fn sfx(path: text) -> Sound:
        Sound(clip_path: path, bus_name: "sfx", volume: 1.0, looped: false, spatial: false)

    static fn music(path: text) -> Sound:
        Sound(clip_path: path, bus_name: "music", volume: 1.0, looped: true, spatial: false)

    static fn spatial_sfx(path: text) -> Sound:
        Sound(clip_path: path, bus_name: "sfx", volume: 1.0, looped: false, spatial: true)

    fn is_null(self) -> bool:
        self.clip_path == ""

    fn with_volume(self, vol: f64) -> Sound:
        Sound(
            clip_path: self.clip_path,
            bus_name: self.bus_name,
            volume: vol,
            looped: self.looped,
            spatial: self.spatial
        )
