# std.game2d.backend.frame_hash — FNV-1a over framebuffer (Wave B, AC-5)
#
# Pure Simple, no extern. Iterates each `u32` pixel as 4 little-endian
# bytes through FNV-1a. Used by `HeadlessBackend.frame_hash()` for the
# golden-frame test (`test/system/game2d_golden_spec.spl`).

# FNV-1a 64-bit — RFC-style constants.
val FNV_OFFSET_BASIS: i64 = 0xcbf29ce484222325
val FNV_PRIME: i64 = 0x100000001b3


fn _mix(h: i64, b: i64) -> i64:
    val xored = h ^ (b & 0xff)
    xored * FNV_PRIME


fn frame_hash(fb: [i64]) -> i64:
    """FNV-1a over each pixel's 4 bytes (little-endian). Operates on i64
    because Simple's interpreter normalises u32 channels through i64.

    Returns the 64-bit hash. Distinct buffers → distinct hashes; identical
    buffers → identical hashes (determinism guarantee for AC-5 golden).
    """
    var h: i64 = FNV_OFFSET_BASIS
    var i: i64 = 0
    val n = fb.len()
    while i < n:
        val px = fb[i]
        h = _mix(h, px)
        h = _mix(h, px >> 8)
        h = _mix(h, px >> 16)
        h = _mix(h, px >> 24)
        i = i + 1
    h


fn _nibble_to_hex_char(n: i64) -> text:
    """Map a 0..15 nibble to its lowercase hex char."""
    if n == 0:
        return "0"
    if n == 1:
        return "1"
    if n == 2:
        return "2"
    if n == 3:
        return "3"
    if n == 4:
        return "4"
    if n == 5:
        return "5"
    if n == 6:
        return "6"
    if n == 7:
        return "7"
    if n == 8:
        return "8"
    if n == 9:
        return "9"
    if n == 10:
        return "a"
    if n == 11:
        return "b"
    if n == 12:
        return "c"
    if n == 13:
        return "d"
    if n == 14:
        return "e"
    "f"


fn i64_to_hex16(value: i64) -> text:
    """Format a 64-bit value as a 16-char zero-padded lowercase hex string,
    most-significant nibble first. Uses divide-and-mod (no `>>`) to dodge
    the Cranelift right-shift bug in the bootstrap backend.
    """
    var out: text = ""
    var i: i64 = 0
    var divisor: i64 = 0x1000000000000000
    while i < 16:
        val nib = (value / divisor) & 0xf
        out = out + _nibble_to_hex_char(nib)
        divisor = divisor / 16
        i = i + 1
    out


fn frame_hash_hex(fb: [i64]) -> text:
    """Convenience: format the FNV-1a hash as a 16-char zero-padded
    lowercase hex string (`0x` prefix) for golden-fixture comparison.
    """
    val h = frame_hash(fb)
    "0x" + i64_to_hex16(h)
