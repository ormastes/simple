# std.game2d.backend.frame_hash — FNV-1a over framebuffer (Wave B, AC-5)
#
# Pure Simple, no extern. Iterates each `u32` pixel as 4 little-endian
# bytes through FNV-1a. Used by `HeadlessBackend.frame_hash()` for the
# golden-frame test (`test/system/game2d_golden_spec.spl`).

# FNV-1a 64-bit — RFC-style constants.
val FNV_OFFSET_BASIS: i64 = 0xcbf29ce484222325
val FNV_PRIME: i64 = 0x100000001b3


fn _mix(h: i64, b: i64) -> i64:
    val xored = h ^ (b & 0xff)
    xored * FNV_PRIME


fn frame_hash(fb: [i64]) -> i64:
    """FNV-1a over each pixel's 4 bytes (little-endian). Operates on i64
    because Simple's interpreter normalises u32 channels through i64.

    Returns the 64-bit hash. Distinct buffers → distinct hashes; identical
    buffers → identical hashes (determinism guarantee for AC-5 golden).
    """
    var h: i64 = FNV_OFFSET_BASIS
    var i: i64 = 0
    val n = fb.len()
    while i < n:
        val px = fb[i]
        h = _mix(h, px)
        h = _mix(h, px >> 8)
        h = _mix(h, px >> 16)
        h = _mix(h, px >> 24)
        i = i + 1
    h


fn frame_hash_hex(fb: [i64]) -> text:
    """Convenience: format the FNV-1a hash as a 16-char uppercase hex
    string for golden-fixture comparison.
    """
    val h = frame_hash(fb)
    "0x{h}"
