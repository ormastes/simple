# std.game2d.backend.sdl_backend — windowed backend (Wave C, AC-1)
#
# Composition only — NOT inheritance. The class holds a native window handle
# and rasterizes through the existing `engine/render/pipeline.spl::SoftwareRenderer`
# (reused, not reimplemented), presenting the `[i64]` framebuffer each frame.
#
# Window/present/events route through the `rt_winit_*` SFFI surface — the
# interpreter implements these natively (real winit window + softbuffer,
# `src/compiler_rust/compiler/src/interpreter_extern/winit_sffi/`), and the
# compiled runtime reaches the same names via the SDL2-backed wrappers in
# `nogc_sync_mut/io/window_sffi.spl`. `rt_sdl2_*` externs are NOT declared
# here: neither deployed binary implements them as interpreter externs
# ("semantic: unknown extern function: rt_sdl2_init"), so calling them
# directly can never run today. `HeadlessBackend` stays the no-window path.
#
# KNOWN JIT BLOCKER: calling this backend's trait methods through
# `LoopDriver.step` under `bin/simple run` (Cranelift JIT) SIGSEGVs — see
# doc/08_tracking/bug/jit_game2d_backend_method_dispatch_sigsegv_2026-07-02.md.
# `bin/simple test` (interpreter path) works; drive game2d session/capture
# code through the spec runner until the JIT bug is fixed upstream.

use std.common.engine.math2d.{Vec2}
use std.common.engine.units.{KeyCode}
use std.nogc_sync_mut.engine.render.command.{RenderCommandBuffer}
use std.nogc_sync_mut.engine.render.pipeline.{SoftwareRenderer}
use std.nogc_sync_mut.game2d.backend.trait.{GameBackend, WindowConfig, Window, Event}
use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.render.image.{Image, RenderError}
use std.nogc_sync_mut.game2d.audio.{Sound, AudioError}
use std.nogc_sync_mut.game2d.input.snapshot.{InputSnapshot}
use std.nogc_sync_mut.io.window_winit.{WinitWindow, winit_present_rgba}

# rt_winit_* SFFI (interpreter-native; see module docstring).
extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_event_loop_free(el: i64) -> bool
extern fn rt_winit_event_loop_poll_events(el: i64, max_events: i64) -> i64
extern fn rt_winit_window_new(el: i64, width: i64, height: i64, title: text) -> i64
extern fn rt_winit_window_free(win: i64) -> bool
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_free(ev: i64)

# winit event type codes (interpreter_extern/winit_sffi/mod.rs).
val EV_CLOSE_REQUESTED: i64 = 3
val EV_KEYBOARD_INPUT: i64 = 10

# The game-facing key convention is SDL keysyms (matches
# window_sffi.spl::parse_virtual_key and existing game code). The winit
# surface reports JS-style codes — translate arrows; letters 'A'..'Z'
# (65..90) map to SDL's lowercase ASCII keysyms.
fn _winit_key_to_sdl(code: i64) -> i64:
    if code == 37:
        return 1073741904  # SDLK_LEFT
    if code == 39:
        return 1073741903  # SDLK_RIGHT
    if code == 38:
        return 1073741906  # SDLK_UP
    if code == 40:
        return 1073741905  # SDLK_DOWN
    if code >= 65 and code <= 90:
        return code + 32
    code


# Opaque wrapper around a native window handle. `raw == 0` denotes an
# unavailable backend (parses-clean, errors at runtime).
class SdlWindow:
    raw: i64
    width: i64
    height: i64
    closed: bool

    static fn null() -> SdlWindow:
        SdlWindow(raw: 0, width: 0, height: 0, closed: true)


class SdlBackend:
    window: SdlWindow
    event_loop: i64
    width: i64
    height: i64
    renderer: SoftwareRenderer
    keys_held: [i64]
    keys_pressed: [i64]
    should_close_flag: bool

    static fn create() -> SdlBackend:
        SdlBackend(
            window: SdlWindow.null(),
            event_loop: 0,
            width: 0,
            height: 0,
            renderer: SoftwareRenderer.create(1, 1),
            keys_held: [],
            keys_pressed: [],
            should_close_flag: false
        )

    me _key_held_index(self, code: i64) -> i64:
        var i: i64 = 0
        val n = self.keys_held.len() as i64
        while i < n:
            if self.keys_held[i as i32] == code:
                return i
            i = i + 1
        -1

    me _mark_key_down(self, code: i64):
        if self._key_held_index(code) < 0:
            self.keys_held.push(code)
        self.keys_pressed.push(code)

    me _mark_key_up(self, code: i64):
        var kept: [i64] = []
        for k in self.keys_held:
            if k != code:
                kept.push(k)
        self.keys_held = kept

    # SdlBackend-specific: not part of GameBackend — callers that need a
    # real window-close signal (real event loop) read this after poll_events.
    fn window_should_close(self) -> bool:
        self.should_close_flag

    # SoftwareRenderer packs r<<24|g<<16|b<<8|a; the winit softbuffer surface
    # wants 0x00RRGGBB. Convert once per present.
    me _present_pixels(self) -> [i64]:
        val src = self.renderer.get_pixels()
        val n = src.len()
        var out: [i64] = [0; n]
        var i: i64 = 0
        while i < n:
            val p = src[i]
            out[i] = (((p >> 24) & 0xFF) << 16) | (((p >> 16) & 0xFF) << 8) | ((p >> 8) & 0xFF)
            i = i + 1
        out


# GameBackend surface implementation — composition only.
impl SdlBackend:
    me gb_create_window(self, cfg: WindowConfig) -> Window:
        self.event_loop = rt_winit_event_loop_new()
        val handle = rt_winit_window_new(self.event_loop, cfg.width, cfg.height, cfg.title)
        self.window = SdlWindow(
            raw: handle,
            width: cfg.width,
            height: cfg.height,
            closed: handle == 0
        )
        self.width = cfg.width
        self.height = cfg.height
        self.renderer = SoftwareRenderer.create(cfg.width, cfg.height)
        Window(raw: handle, width: cfg.width, height: cfg.height)

    me poll_native_events(self, events_out: [Event]) -> i64:
        """Drain the native event queue. Updates the internal keys-held/
        pressed state (read back via `current_input`) and `should_close_flag`
        on close. `events_out` is unused (kept for trait-signature parity)."""
        val _ = events_out
        if self.window.raw == 0:
            return 0
        self.keys_pressed = []
        var count: i64 = 0
        var guard: i64 = 0
        var polling = true
        while polling and guard < 256:
            val ev = rt_winit_event_loop_poll_events(self.event_loop, 1)
            if ev == 0:
                polling = false
            else:
                count = count + 1
                val ev_type = rt_winit_event_get_type(ev)
                if ev_type == EV_CLOSE_REQUESTED:
                    self.should_close_flag = true
                elif ev_type == EV_KEYBOARD_INPUT:
                    val kb = rt_winit_event_keyboard_input(ev)
                    val code = _winit_key_to_sdl(kb.1)
                    if kb.2:
                        self._mark_key_down(code)
                    else:
                        self._mark_key_up(code)
                rt_winit_event_free(ev)
            guard = guard + 1
        count

    fn gb_begin_frame(self) -> Canvas:
        Canvas.create(self.width, self.height)

    me gb_end_frame(self):
        if self.window.raw != 0:
            val px = self._present_pixels()
            val win = WinitWindow(handle: self.window.raw, is_valid: true)
            val presented = winit_present_rgba(win, self.width, self.height, px)
            if not presented:
                self.should_close_flag = true
                self.window.closed = true

    me gb_execute_commands(self, cmds: RenderCommandBuffer):
        if self.window.raw != 0:
            val _ = self.renderer.render_frame(cmds)

    fn gb_load_image(self, path: text) -> Result<Image, RenderError>:
        Image.new(path)

    fn gb_load_sound(self, path: text) -> Result<Sound, AudioError>:
        Sound.new(path)

    me gb_shutdown(self):
        if self.window.raw != 0:
            rt_winit_window_free(self.window.raw)
        if self.event_loop != 0:
            rt_winit_event_loop_free(self.event_loop)
        self.window = SdlWindow.null()
        self.event_loop = 0

    me gb_current_input(self) -> InputSnapshot:
        var down: [KeyCode] = []
        for k in self.keys_held:
            down.push(KeyCode(code: k))
        var pressed: [KeyCode] = []
        for k in self.keys_pressed:
            pressed.push(KeyCode(code: k))
        InputSnapshot.from_raw(down, pressed, Vec2(x: 0.0, y: 0.0), [])
