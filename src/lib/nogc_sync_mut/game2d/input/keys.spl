# Game2D Key + MouseButton (AC-3)
#
# Re-exports the engine's typed `KeyCode` as `Key` (game2d's user-facing
# spelling) and re-exports `MouseButtonId` as `MouseButton`. The repo already
# uses `KeyCode`/`MouseButtonId` everywhere; aliasing here keeps user code
# reading like LÖVE2D while staying type-compatible with the engine.
#
# These are pure type aliases — no parallel enum redefinition (avoids
# duplicate-engine-primitive AC-8 violations).

use std.common.engine.units.{KeyCode, MouseButtonId}

# `Key` is the public spelling for `KeyCode` in the game2d API surface.
# Until first-class `type Key = KeyCode` aliases compile cleanly, callers
# can use `Key(code: ...)` via this constructor wrapper.
fn Key(code: i64) -> KeyCode:
    KeyCode(code: code)

# `MouseButton` is the public spelling for `MouseButtonId`.
fn MouseButton(code: i64) -> MouseButtonId:
    MouseButtonId(code: code)

# Common mouse button constants (LÖVE2D-compatible).
fn mouse_left() -> MouseButtonId: MouseButtonId(code: 1)
fn mouse_right() -> MouseButtonId: MouseButtonId(code: 3)
fn mouse_middle() -> MouseButtonId: MouseButtonId(code: 2)
