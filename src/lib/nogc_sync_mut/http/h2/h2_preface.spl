# HTTP/2 Connection Preface — RFC 9113 §3.4
#
# A client opening an HTTP/2 connection in cleartext (h2c) or after ALPN
# negotiation MUST send the 24-byte connection preface:
#
#   PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n
#
# Server reads exactly these 24 bytes before any frame parsing.
# Followed by a (possibly empty) SETTINGS frame from each side, but the
# SETTINGS frame is delivered through the normal frame parser — only the
# 24-byte literal compare lives here.
#
# Pure framing-layer scope (W15-F): preface bytes only. State machine is W16+.

# ============================================================================
# Preface constants
# ============================================================================

val H2_CONNECTION_PREFACE_LEN: i64 = 24

# Build the canonical preface bytes:  "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
# 24 bytes total.
fn h2_connection_preface_bytes() -> [u8]:
    var out: [u8] = []
    # "PRI * HTTP/2.0"
    out.push(0x50)  # P
    out.push(0x52)  # R
    out.push(0x49)  # I
    out.push(0x20)  # space
    out.push(0x2a)  # *
    out.push(0x20)  # space
    out.push(0x48)  # H
    out.push(0x54)  # T
    out.push(0x54)  # T
    out.push(0x50)  # P
    out.push(0x2f)  # /
    out.push(0x32)  # 2
    out.push(0x2e)  # .
    out.push(0x30)  # 0
    # "\r\n\r\n"
    out.push(0x0d)
    out.push(0x0a)
    out.push(0x0d)
    out.push(0x0a)
    # "SM"
    out.push(0x53)
    out.push(0x4d)
    # "\r\n\r\n"
    out.push(0x0d)
    out.push(0x0a)
    out.push(0x0d)
    out.push(0x0a)
    return out

# Validate: do the first 24 bytes of `data` equal the preface?
# Returns false if data is shorter than 24 bytes.
fn h2_validate_preface(data: [u8]) -> bool:
    if data.len() < H2_CONNECTION_PREFACE_LEN:
        return false
    val expected = h2_connection_preface_bytes()
    var i = 0
    loop:
        if i >= H2_CONNECTION_PREFACE_LEN:
            break
        if data[i] != expected[i]:
            return false
        i = i + 1
    return true
