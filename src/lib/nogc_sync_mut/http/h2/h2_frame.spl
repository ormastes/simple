# HTTP/2 Frame Types — RFC 9113 §4 + §6
#
# Pure-Simple seed for HTTP/2 framing.
#
# Scope (W15-F):
#   - Frame header layout (9 bytes: length:24 + type:8 + flags:8 + R:1 + stream_id:31)
#   - Tagged union H2Frame covering all 10 RFC 9113 frame types (§6.1-§6.10)
#   - Frame type + flag constants
#
# Out of scope (deferred to W16+):
#   - HPACK header compression — `header_block` payloads stay opaque [u8]
#   - Connection state machine, stream lifecycle, flow control accounting
#   - PADDED flag handling for DATA / HEADERS / PUSH_PROMISE
#   - PRIORITY-in-HEADERS sub-payload (5 extra bytes when PRIORITY flag set)

# ============================================================================
# Frame header layout constants (RFC 9113 §4.1)
# ============================================================================

# 9-byte fixed frame header.
val H2_FRAME_HEADER_LEN: i64 = 9

# Default SETTINGS_MAX_FRAME_SIZE (16384). Parser does NOT enforce — out of
# scope for the framing layer; connection state machine (W16+) will.
val H2_DEFAULT_MAX_FRAME_SIZE: i64 = 16384

# ============================================================================
# Frame type codes (RFC 9113 §6.1-§6.10)
# ============================================================================

val H2_FRAME_DATA: i64          = 0x0
val H2_FRAME_HEADERS: i64       = 0x1
val H2_FRAME_PRIORITY: i64      = 0x2
val H2_FRAME_RST_STREAM: i64    = 0x3
val H2_FRAME_SETTINGS: i64      = 0x4
val H2_FRAME_PUSH_PROMISE: i64  = 0x5
val H2_FRAME_PING: i64          = 0x6
val H2_FRAME_GOAWAY: i64        = 0x7
val H2_FRAME_WINDOW_UPDATE: i64 = 0x8
val H2_FRAME_CONTINUATION: i64  = 0x9

# ============================================================================
# Frame flag bits (RFC 9113 §6, per-type)
# ============================================================================

# Common flags
val H2_FLAG_END_STREAM: i64  = 0x01   # DATA, HEADERS
val H2_FLAG_ACK: i64         = 0x01   # SETTINGS, PING (same bit, different name)
val H2_FLAG_END_HEADERS: i64 = 0x04   # HEADERS, PUSH_PROMISE, CONTINUATION
val H2_FLAG_PADDED: i64      = 0x08   # DATA, HEADERS, PUSH_PROMISE  (W16+ — payload not parsed)
val H2_FLAG_PRIORITY: i64    = 0x20   # HEADERS                       (W16+ — sub-payload not parsed)

# ============================================================================
# SETTINGS identifiers (RFC 9113 §6.5.2)
# ============================================================================

val H2_SETTINGS_HEADER_TABLE_SIZE: i64      = 0x1
val H2_SETTINGS_ENABLE_PUSH: i64            = 0x2
val H2_SETTINGS_MAX_CONCURRENT_STREAMS: i64 = 0x3
val H2_SETTINGS_INITIAL_WINDOW_SIZE: i64    = 0x4
val H2_SETTINGS_MAX_FRAME_SIZE: i64         = 0x5
val H2_SETTINGS_MAX_HEADER_LIST_SIZE: i64   = 0x6

# ============================================================================
# Error codes (RFC 9113 §7) — for RST_STREAM / GOAWAY
# ============================================================================

val H2_ERR_NO_ERROR: i64            = 0x0
val H2_ERR_PROTOCOL_ERROR: i64      = 0x1
val H2_ERR_INTERNAL_ERROR: i64      = 0x2
val H2_ERR_FLOW_CONTROL_ERROR: i64  = 0x3
val H2_ERR_SETTINGS_TIMEOUT: i64    = 0x4
val H2_ERR_STREAM_CLOSED: i64       = 0x5
val H2_ERR_FRAME_SIZE_ERROR: i64    = 0x6
val H2_ERR_REFUSED_STREAM: i64      = 0x7
val H2_ERR_CANCEL: i64              = 0x8
val H2_ERR_COMPRESSION_ERROR: i64   = 0x9
val H2_ERR_CONNECT_ERROR: i64       = 0xa
val H2_ERR_ENHANCE_YOUR_CALM: i64   = 0xb
val H2_ERR_INADEQUATE_SECURITY: i64 = 0xc
val H2_ERR_HTTP_1_1_REQUIRED: i64   = 0xd

# ============================================================================
# Per-type payload structs
# ============================================================================
#
# Note: stream_id is the 31-bit value (R-bit already masked off on read,
# always zero on write). RFC 9113 §4.1 reserves the top bit and requires
# senders to set it to 0 and receivers to ignore it.

class H2DataFrame:
    """RFC 9113 §6.1 DATA. PADDED flag (W16+) — for now `data` is the raw payload."""
    stream_id: i64       # MUST be > 0
    flags: i64           # END_STREAM only (PADDED deferred)
    data: [u8]           # opaque application bytes

class H2HeadersFrame:
    """RFC 9113 §6.2 HEADERS. PRIORITY/PADDED sub-payloads deferred (W16+).
    `header_block` is the opaque HPACK-encoded fragment — HPACK is W16+."""
    stream_id: i64       # MUST be > 0
    flags: i64           # END_STREAM | END_HEADERS (PADDED, PRIORITY deferred)
    header_block: [u8]

class H2PriorityFrame:
    """RFC 9113 §6.3 PRIORITY. Deprecated by RFC 9113 but framing remains."""
    stream_id: i64           # MUST be > 0
    exclusive: bool          # E-bit on stream_dependency
    stream_dependency: i64   # 31 bits (E masked off)
    weight: i64              # 0..255 (sender wire value; +1 = effective weight)

class H2RstStreamFrame:
    """RFC 9113 §6.4 RST_STREAM."""
    stream_id: i64       # MUST be > 0
    error_code: i64      # u32 error code

class H2SettingsFrame:
    """RFC 9113 §6.5 SETTINGS. payload = sequence of (id:u16, value:u32) 6-byte
    pairs. ACK flag → MUST have empty payload. stream_id MUST be 0."""
    flags: i64           # ACK only
    settings: [H2Setting]   # empty when ACK

class H2Setting:
    """One SETTINGS parameter (id, value)."""
    identifier: i64      # u16
    value: i64           # u32

class H2PushPromiseFrame:
    """RFC 9113 §6.6 PUSH_PROMISE. PADDED deferred (W16+)."""
    stream_id: i64           # MUST be > 0 (associated stream)
    flags: i64               # END_HEADERS (PADDED deferred)
    promised_stream_id: i64  # 31 bits (R masked)
    header_block: [u8]

class H2PingFrame:
    """RFC 9113 §6.7 PING. Payload is exactly 8 opaque bytes. stream_id MUST be 0."""
    flags: i64           # ACK only
    opaque_data: [u8]    # exactly 8 bytes

class H2GoawayFrame:
    """RFC 9113 §6.8 GOAWAY. stream_id MUST be 0."""
    last_stream_id: i64  # 31 bits (R masked)
    error_code: i64      # u32
    debug_data: [u8]     # variable-length, may be empty

class H2WindowUpdateFrame:
    """RFC 9113 §6.9 WINDOW_UPDATE. stream_id may be 0 (connection-level)
    or > 0 (per-stream)."""
    stream_id: i64       # 0 = connection-level
    increment: i64       # 31 bits (reserved top bit masked)

class H2ContinuationFrame:
    """RFC 9113 §6.10 CONTINUATION."""
    stream_id: i64       # MUST be > 0
    flags: i64           # END_HEADERS only
    header_block: [u8]

# ============================================================================
# Tagged union: H2Frame
# ============================================================================

enum H2Frame:
    """Discriminated union of all RFC 9113 frame types."""
    Data(H2DataFrame)
    Headers(H2HeadersFrame)
    Priority(H2PriorityFrame)
    RstStream(H2RstStreamFrame)
    Settings(H2SettingsFrame)
    PushPromise(H2PushPromiseFrame)
    Ping(H2PingFrame)
    Goaway(H2GoawayFrame)
    WindowUpdate(H2WindowUpdateFrame)
    Continuation(H2ContinuationFrame)
