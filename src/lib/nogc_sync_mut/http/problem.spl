"""
# RFC 7807 Problem Details

Structured error responses for HTTP APIs per RFC 7807.

## Usage

```simple
val problem = ProblemDetail.not_found("User 42 does not exist")
val response = problem.to_response()
expect response.status == 404
expect response.headers.len() > 0
```

## JSON Output

```json
{
  "type": "about:blank",
  "title": "Not Found",
  "status": 404,
  "detail": "User 42 does not exist"
}
```
"""

use std.json.builder.{JsonBuilder}
use std.http_server.types.{HttpResponseData}

class ProblemDetail:
    """RFC 7807 Problem Details for HTTP APIs."""
    type_uri: text
    title: text
    status: i64
    detail: text
    instance: text

    static fn new(status: i64, title: text, detail: text) -> ProblemDetail:
        ProblemDetail(
            type_uri: "about:blank",
            title: title,
            status: status,
            detail: detail,
            instance: ""
        )

    me with_type(uri: text) -> ProblemDetail:
        self.type_uri = uri
        self

    me with_instance(uri: text) -> ProblemDetail:
        self.instance = uri
        self

    fn to_json() -> text:
        """Serialize to RFC 7807 JSON."""
        var builder = JsonBuilder.object()
        builder = builder.field("type", self.type_uri)
        builder = builder.field("title", self.title)
        builder = builder.field_int("status", self.status)
        if self.detail != "":
            builder = builder.field("detail", self.detail)
        if self.instance != "":
            builder = builder.field("instance", self.instance)
        builder.build()

    fn content_type() -> text:
        "application/problem+json"

    fn to_response() -> HttpResponseData:
        """Build full HTTP response with correct status and content-type."""
        val body = self.to_json()
        HttpResponseData(
            status: self.status,
            reason: self.title,
            headers: [
                ("Content-Type", self.content_type()),
                ("Server", "SimpleServer")
            ],
            body: body,
            body_bytes: [],
            body_file: "",
            body_offset: 0,
            body_length: 0,
            chunked: false
        )

    # ==================================================================
    # Factory Methods
    # ==================================================================

    static fn not_found(detail: text) -> ProblemDetail:
        ProblemDetail.new(404, "Not Found", detail)

    static fn bad_request(detail: text) -> ProblemDetail:
        ProblemDetail.new(400, "Bad Request", detail)

    static fn unauthorized(detail: text) -> ProblemDetail:
        ProblemDetail.new(401, "Unauthorized", detail)

    static fn forbidden(detail: text) -> ProblemDetail:
        ProblemDetail.new(403, "Forbidden", detail)

    static fn internal_error(detail: text) -> ProblemDetail:
        ProblemDetail.new(500, "Internal Server Error", detail)

    static fn rate_limited(detail: text, retry_after: i64) -> ProblemDetail:
        var p = ProblemDetail.new(429, "Too Many Requests", detail)
        p = p.with_type("https://httpproblems.com/http-status/429")
        p
