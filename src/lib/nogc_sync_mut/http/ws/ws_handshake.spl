# WebSocket Opening Handshake — RFC 6455 §4
#
# Implements the HTTP/1.1 Upgrade handshake that establishes a WebSocket
# connection before any frames (ws_frame/ws_parser/ws_writer) flow:
#
#   - Client request line + headers (RFC 6455 §4.1)
#   - Sec-WebSocket-Key  ->  Sec-WebSocket-Accept derivation (RFC 6455 §4.2.2):
#         accept = base64( SHA1( key + GUID ) )
#     where GUID = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11" (RFC 6455 §1.3).
#   - Server 101 "Switching Protocols" response (RFC 6455 §4.2.2)
#   - Response validation (status 101 + matching Sec-WebSocket-Accept)
#
# SHA-1 output is 20 raw bytes (contains nulls / high bytes); base64 is done
# over a byte array here rather than `text` to avoid the "text-only byte
# cliff" (from_utf8_lossy) that would corrupt the digest.

use std.crypto.sha1.{sha1_bytes}

# ============================================================================
# Constants
# ============================================================================

# RFC 6455 §1.3 magic GUID appended to the client key before hashing.
val WS_HANDSHAKE_GUID: text = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"

# base64 alphabet (RFC 4648 §4) — standard, with '=' padding.
val WS_B64_ALPHABET: text = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

# ============================================================================
# Byte-array base64 (over raw [i64] bytes 0..255) — RFC 4648 §4
# ============================================================================

fn _b64_encode_bytes(data: [i64]) -> text:
    """Standard base64 of a raw byte array (each element treated mod 256)."""
    val n = data.len()
    var out = ""
    var i = 0
    loop:
        if i >= n:
            break
        val b1 = data[i] & 0xff
        var b2: i64 = 0
        var b3: i64 = 0
        val has2 = (i + 1) < n
        val has3 = (i + 2) < n
        if has2:
            b2 = data[i + 1] & 0xff
        if has3:
            b3 = data[i + 2] & 0xff

        val idx0 = b1 >> 2
        val idx1 = ((b1 & 0x03) << 4) | (b2 >> 4)
        val idx2 = ((b2 & 0x0f) << 2) | (b3 >> 6)
        val idx3 = b3 & 0x3f

        out = out + WS_B64_ALPHABET.char_at(idx0)
        out = out + WS_B64_ALPHABET.char_at(idx1)
        if has2:
            out = out + WS_B64_ALPHABET.char_at(idx2)
        else:
            out = out + "="
        if has3:
            out = out + WS_B64_ALPHABET.char_at(idx3)
        else:
            out = out + "="
        i = i + 3
    return out

# ============================================================================
# Accept-key derivation — RFC 6455 §4.2.2
# ============================================================================

fn _text_to_bytes(s: text) -> [i64]:
    """Decompose ASCII/byte text into a raw byte array for hashing."""
    val raw = s.bytes()
    var out: [i64] = []
    var i = 0
    val n = raw.len()
    loop:
        if i >= n:
            break
        out.push((raw[i] as i64) & 0xff)
        i = i + 1
    return out

pub fn ws_compute_accept_key(key: text) -> text:
    """RFC 6455 §4.2.2: accept = base64(SHA1(key + GUID)).

    `key` is the (already base64-encoded) Sec-WebSocket-Key value sent by the
    client. The returned value is the Sec-WebSocket-Accept header value the
    server echoes in its 101 response.
    """
    val concatenated = key + WS_HANDSHAKE_GUID
    val msg = _text_to_bytes(concatenated)
    val digest = sha1_bytes(msg)
    return _b64_encode_bytes(digest)

# ============================================================================
# Client request — RFC 6455 §4.1
# ============================================================================

pub fn ws_build_client_request(host: text, path: text, key: text) -> text:
    """Build the client opening-handshake HTTP/1.1 request (RFC 6455 §4.1).

    `key` is a base64-encoded 16-byte nonce supplied by the caller (PRNG is a
    caller concern). Produces a CRLF-terminated request ending with a blank
    line.
    """
    var req = "GET " + path + " HTTP/1.1\r\n"
    req = req + "Host: " + host + "\r\n"
    req = req + "Upgrade: websocket\r\n"
    req = req + "Connection: Upgrade\r\n"
    req = req + "Sec-WebSocket-Key: " + key + "\r\n"
    req = req + "Sec-WebSocket-Version: 13\r\n"
    req = req + "\r\n"
    return req

# ============================================================================
# Server 101 response — RFC 6455 §4.2.2
# ============================================================================

pub fn ws_build_server_response(key: text) -> text:
    """Build the server 101 Switching Protocols response (RFC 6455 §4.2.2).

    `key` is the client's Sec-WebSocket-Key; the response carries the derived
    Sec-WebSocket-Accept. CRLF-terminated, ending with a blank line.
    """
    val accept = ws_compute_accept_key(key)
    var resp = "HTTP/1.1 101 Switching Protocols\r\n"
    resp = resp + "Upgrade: websocket\r\n"
    resp = resp + "Connection: Upgrade\r\n"
    resp = resp + "Sec-WebSocket-Accept: " + accept + "\r\n"
    resp = resp + "\r\n"
    return resp

# ============================================================================
# Response validation — RFC 6455 §4.1 (client side)
# ============================================================================

fn _starts_with(s: text, prefix: text) -> bool:
    val sl = s.length()
    val pl = prefix.length()
    if pl > sl:
        return false
    var i = 0
    loop:
        if i >= pl:
            break
        if s.char_at(i) != prefix.char_at(i):
            return false
        i = i + 1
    return true

fn _contains(s: text, needle: text) -> bool:
    val sl = s.length()
    val nl = needle.length()
    if nl == 0:
        return true
    if nl > sl:
        return false
    var i = 0
    val last = sl - nl
    loop:
        if i > last:
            break
        var j = 0
        var matched = true
        loop:
            if j >= nl:
                break
            if s.char_at(i + j) != needle.char_at(j):
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false

pub fn ws_validate_server_response(raw: text, key: text) -> bool:
    """Validate a server handshake response (RFC 6455 §4.1, client side).

    Returns true iff the status line is exactly the 101 Switching Protocols
    line AND the response carries the correct Sec-WebSocket-Accept derived
    from `key`. The 101 token must appear in the status line, not merely in
    the body, so we require the response to *start with* the status line.
    """
    val status_line = "HTTP/1.1 101 Switching Protocols\r\n"
    if not _starts_with(raw, status_line):
        return false
    val accept = ws_compute_accept_key(key)
    val accept_header = "Sec-WebSocket-Accept: " + accept + "\r\n"
    return _contains(raw, accept_header)

export WS_HANDSHAKE_GUID
export ws_compute_accept_key
export ws_build_client_request
export ws_build_server_response
export ws_validate_server_response
