# HTTP/1.1 Core Completeness (RFC 9110 / RFC 9112)
#
# Consolidates RFC-completeness helpers that round out the canonical
# nogc_sync_mut/http surface:
#   - Method integer constants + token<->int conversion (RFC 9110 §9)
#   - Version-aware connection persistence (RFC 9112 §9.3, RFC 7230 §6)
#   - Chunked transfer coding with trailers + chunk extensions (RFC 9112 §7.1)
#   - HTTPS scheme/port resolution + HTTP/1.1-over-TLS request composition
#
# Self-contained (no internal cross-module imports) so it loads cleanly via
# `use std.nogc_sync_mut.http.http1.{...}` under the seed driver.

# ============================================================================
# HTTP Method Integer Constants (RFC 9110 §9)
# Plain integer constants (NOT payload enums — known interpreter bug).
# ============================================================================

val METHOD_UNKNOWN = -1
val METHOD_GET = 0
val METHOD_HEAD = 1
val METHOD_POST = 2
val METHOD_PUT = 3
val METHOD_DELETE = 4
val METHOD_CONNECT = 5
val METHOD_OPTIONS = 6
val METHOD_TRACE = 7
val METHOD_PATCH = 8

# Convert a method token to its integer constant. Case-insensitive.
# Returns METHOD_UNKNOWN (-1) for unrecognized tokens.
fn method_to_int(method: text) -> i64:
    val upper = method.upper()
    if upper == "GET":
        return 0
    if upper == "HEAD":
        return 1
    if upper == "POST":
        return 2
    if upper == "PUT":
        return 3
    if upper == "DELETE":
        return 4
    if upper == "CONNECT":
        return 5
    if upper == "OPTIONS":
        return 6
    if upper == "TRACE":
        return 7
    if upper == "PATCH":
        return 8
    return -1

# Convert an integer constant back to its canonical uppercase method token.
fn int_to_method(code: i64) -> text:
    if code == 0:
        return "GET"
    if code == 1:
        return "HEAD"
    if code == 2:
        return "POST"
    if code == 3:
        return "PUT"
    if code == 4:
        return "DELETE"
    if code == 5:
        return "CONNECT"
    if code == 6:
        return "OPTIONS"
    if code == 7:
        return "TRACE"
    if code == 8:
        return "PATCH"
    return ""

# True if the method token is a recognized HTTP method.
fn is_known_method(method: text) -> bool:
    method_to_int(method) >= 0

# ============================================================================
# Connection Persistence (RFC 9112 §9.3, RFC 7230 §6)
# HTTP/1.1 defaults persistent unless `Connection: close`.
# HTTP/1.0 defaults close unless `Connection: keep-alive`.
# Version-aware — a bare "contains close" check is wrong for 1.0.
# ============================================================================

fn should_keep_alive(version: text, connection_header: text) -> bool:
    var conn = ""
    if connection_header != nil:
        conn = connection_header.lower()

    val is_http_11 = version == "HTTP/1.1"

    if is_http_11:
        if conn.contains("close"):
            return false
        return true

    if conn.contains("keep-alive"):
        return true
    return false

# Canonical Connection header value for a desired keep-alive decision.
fn connection_header_value(keep_alive: bool) -> text:
    if keep_alive:
        return "keep-alive"
    return "close"

# ============================================================================
# Self-contained scanning helpers
# ============================================================================

fn http1_to_hex(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var num = n
    while num > 0:
        val digit = num % 16
        val hex_chars = "0123456789abcdef"
        digits.push(hex_chars[digit])
        num = num / 16
    var parts: [text] = []
    var i = digits.len() - 1
    while i >= 0:
        parts.push(digits[i])
        i = i - 1
    return parts.join("")

# Map a single hex digit char to its value via string lookup (avoids
# char_code(), which is not available on text in the seed runtime).
fn http1_hex_to_int(ch: text) -> i64:
    val lower_digits = "0123456789abcdef"
    val li = http1_find_char(lower_digits, ch)
    if li >= 0:
        return li
    val upper_digits = "0123456789ABCDEF"
    val ui = http1_find_char(upper_digits, ch)
    if ui >= 0:
        return ui
    return 0

fn http1_parse_hex(hex: text) -> i64:
    var result = 0
    var i = 0
    while i < hex.length():
        result = result * 16
        result = result + http1_hex_to_int(hex[i])
        i = i + 1
    return result

# BUG(text_index_of_substring_receiver_nonzero_match_nil): text.index_of on a
# substring()-derived receiver returns nil for any non-zero match position, so
# scan for a single char by index comparison instead. Returns -1 if absent.
fn http1_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.length():
        if s[i] == ch:
            return i
        i = i + 1
    return -1

# Find `sub` in `s` starting at `start` by char-scan (robust against the
# substring-index_of bug above). Returns -1 if absent.
fn http1_index_of(s: text, sub: text, start: i64) -> i64:
    if sub.length() == 0:
        return start
    var i = start
    if i < 0:
        i = 0
    while i <= s.length() - sub.length():
        var match = true
        var j = 0
        while j < sub.length():
            if s[i + j] != sub[j]:
                match = false
                break
            j = j + 1
        if match:
            return i
        i = i + 1
    return -1

# ============================================================================
# Chunked Transfer Coding (RFC 9112 §7.1)
# ============================================================================

# Encode a single body as one chunk + terminating zero chunk.
fn encode_chunked(data: text) -> text:
    var result = http1_to_hex(data.length())
    result = result + "\r\n"
    result = result + data
    result = result + "\r\n0\r\n\r\n"
    return result

# Encode body + trailer headers (list of (name, value)) after the zero chunk.
fn encode_chunked_with_trailers(data: text, trailers: list) -> text:
    var result = ""
    if data.length() > 0:
        result = http1_to_hex(data.length())
        result = result + "\r\n"
        result = result + data
        result = result + "\r\n"
    result = result + "0\r\n"
    var i = 0
    while i < trailers.length():
        val tr = trailers[i]
        result = result + tr[0] + ": " + tr[1] + "\r\n"
        i = i + 1
    result = result + "\r\n"
    return result

# Decode a chunked body to its payload. Ignores chunk extensions.
fn decode_chunked(encoded: text) -> text:
    val pair = decode_chunked_with_trailers(encoded)
    return pair.0

# Decode a chunked body, returning (payload, trailers). Handles chunk
# extensions on the size line ("1a;ext=v") and a trailing trailer section.
fn decode_chunked_with_trailers(encoded: text) -> tuple:
    var parts: [text] = []
    var trailers: [(text, text)] = []
    var pos = 0

    while pos < encoded.length():
        val size_end = http1_index_of(encoded, "\r\n", pos)
        if size_end < 0:
            break

        var size_line = encoded.substring(pos, size_end)
        val semi = http1_find_char(size_line, ";")
        if semi >= 0:
            size_line = size_line.substring(0, semi)
        val chunk_size = http1_parse_hex(size_line)

        if chunk_size == 0:
            var tpos = size_end + 2
            while tpos < encoded.length():
                val tend = http1_index_of(encoded, "\r\n", tpos)
                if tend < 0:
                    break
                val tline = encoded.substring(tpos, tend)
                if tline == "":
                    break
                val cpos = http1_find_char(tline, ":")
                if cpos >= 0:
                    val tname = tline.substring(0, cpos)
                    var vstart = cpos + 1
                    if vstart < tline.length() and tline[vstart] == " ":
                        vstart = vstart + 1
                    val tval = tline.substring(vstart, tline.length())
                    trailers = trailers.push((tname, tval))
                tpos = tend + 2
            break

        val data_start = size_end + 2
        val data_end = data_start + chunk_size
        if data_end > encoded.length():
            break
        parts.push(encoded.substring(data_start, data_end))
        pos = data_end + 2

    return (parts.join(""), trailers)

# ============================================================================
# HTTPS scheme/port + HTTP/1.1-over-TLS request composition (RFC 9110 §4.2)
# ============================================================================

val HTTPS_PORT = 443
val HTTP_PORT = 80

# Resolve default port for a scheme. "https"->443, "http"->80, else -1.
fn scheme_default_port(scheme: text) -> i64:
    val lower = scheme.lower()
    if lower == "https":
        return HTTPS_PORT
    if lower == "http":
        return HTTP_PORT
    return -1

fn scheme_is_secure(scheme: text) -> bool:
    scheme.lower() == "https"

# Split "host" or "host:port" into (host, port) using the scheme default
# when no explicit port is present.
fn resolve_authority(scheme: text, authority: text) -> tuple:
    val colon = http1_find_char(authority, ":")
    if colon < 0:
        return (authority, scheme_default_port(scheme))
    val host = authority.substring(0, colon)
    val port_str = authority.substring(colon + 1, authority.length())
    var port = scheme_default_port(scheme)
    if port_str.length() > 0:
        port = port_str.to_i64()
    return (host, port)

# Build the cleartext HTTP/1.1 request bytes an HTTPS client hands to the TLS
# layer. The Host header carries the SNI host; framing is real and testable.
fn https_compose_request(method: text, host: text, path: text, keep_alive: bool) -> text:
    var result = method
    result = result + " "
    result = result + path
    result = result + " HTTP/1.1\r\nHost: "
    result = result + host
    result = result + "\r\nConnection: "
    result = result + connection_header_value(keep_alive)
    result = result + "\r\n\r\n"
    return result

# ============================================================================
# Exports
# ============================================================================

export METHOD_UNKNOWN, METHOD_GET, METHOD_HEAD, METHOD_POST, METHOD_PUT
export METHOD_DELETE, METHOD_CONNECT, METHOD_OPTIONS, METHOD_TRACE, METHOD_PATCH
export method_to_int, int_to_method, is_known_method
export should_keep_alive, connection_header_value
export encode_chunked, encode_chunked_with_trailers
export decode_chunked, decode_chunked_with_trailers
export http1_find_char, http1_index_of
export HTTPS_PORT, HTTP_PORT, scheme_default_port, scheme_is_secure
export resolve_authority, https_compose_request
