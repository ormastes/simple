# HTTPS — thin secure wrapper over HTTP + TLS
# RFC 9110 (HTTP Semantics), RFC 9112 (HTTP/1.1), RFC 8446 (TLS 1.3)
# Port 443 per IANA registry.
#
# NOTE: TlsSessionHandle is a placeholder until tls/ gains a real session struct.
# See FINDING tls_session_type_missing_2026-06-15.

# =============================================================================
# HTTPS default port
# =============================================================================

val HTTPS_DEFAULT_PORT = 443
val HTTP_CLEARTEXT_PORT = 80

fn https_default_port() -> i64: HTTPS_DEFAULT_PORT
fn http_cleartext_port() -> i64: HTTP_CLEARTEXT_PORT

# =============================================================================
# Placeholder TLS handle (same shape as imap/pop3/smtp secure.spl)
# =============================================================================

struct TlsSessionHandle:
    fd: i64

fn tls_session_handle_new(fd: i64) -> TlsSessionHandle:
    TlsSessionHandle(fd: fd)

# =============================================================================
# HttpsSession — composition of TLS handle + connection state text
# =============================================================================

struct HttpsSession:
    tls: TlsSessionHandle
    host: text      # SNI hostname
    state: text     # "IDLE" | "ACTIVE" | "CLOSED"

fn https_session_new(fd: i64, host: text) -> HttpsSession:
    val handle = tls_session_handle_new(fd)
    HttpsSession(tls: handle, host: host, state: "IDLE")

fn https_session_host(s: HttpsSession) -> text:
    s.host

fn https_session_state(s: HttpsSession) -> text:
    s.state
