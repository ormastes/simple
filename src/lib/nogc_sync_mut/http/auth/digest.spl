# HTTP Digest Authentication — RFC 7616
#
# Digest access authentication avoids sending passwords in cleartext.
# The server issues a challenge (WWW-Authenticate header); the client
# computes a response hash and sends it in the Authorization header.
#
# Supported algorithms:
#   MD5       — RFC 7616 §6.4 (legacy, insecure, provided for interop only)
#   SHA-256   — RFC 7616 §6.4 (RECOMMENDED)
#   SHA-512-256 — NOT available; no SHA-512/256 (distinct IV) implementation
#                 in this tree.  See FR:
#                 doc/08_tracking/feature_request/sha512_256_for_digest_auth.md
#
# WARNING: MD5 is cryptographically broken. Use SHA-256 wherever possible.
# WARNING: Always use Digest auth over TLS (HTTPS) to resist MITM.
#
# Public API (server side):
#   http_digest_make_challenge(realm, nonce, algorithm, qop) -> text
#     Returns a WWW-Authenticate header value string.
#
# Public API (client side):
#   http_digest_make_response(params) -> text
#     Computes and returns the Authorization header value.
#     params is a tuple:
#       (username, realm, password, algorithm,
#        method, uri, nonce, nc, cnonce, qop)
#
# Public API (server side — verify):
#   http_digest_verify(params, expected_password) -> bool
#     Constant-time check: re-derives the expected response and compares.
#     params is the same 10-tuple as http_digest_make_response.

mod crypto.types
mod crypto.sha256
mod crypto.sha512
mod crypto.legacy_hash

use std.crypto.types.{text_to_bytes, bytes_to_hex}
use std.crypto.sha256.{sha256_bytes}
use std.crypto.sha512.{sha512_bytes}
use std.crypto.legacy_hash.{md5_bytes}

# =============================================================================
# Internal helpers
# =============================================================================

# Constant-time compare two text values (ASCII hex strings safe).
# Uses XOR-accumulate over the byte representations.
# reason: positional http auth digest API
fn _digest_ct_equal(a: text, b: text) -> bool:
    if a.length() != b.length():
        return false
    val ab = text_to_bytes(a)
    val bb = text_to_bytes(b)
    var diff = 0
    var i = 0
    while i < ab.len():
        diff = diff | (ab.get(i) ^ bb.get(i))
        i = i + 1
    diff == 0

# Hash a byte list with the named algorithm.
# Returns a lowercase hex string.
# Supported: "MD5", "SHA-256".
# Returns "" for unknown algorithm.
# reason: positional http auth digest API
fn _digest_hash(algorithm: text, bytes: list) -> text:
    if algorithm == "MD5":
        return bytes_to_hex(md5_bytes(bytes))
    if algorithm == "SHA-256":
        return bytes_to_hex(sha256_bytes(bytes))
    # SHA-512-256 requires a distinct initial hash value (FIPS 180-4 §5.3.6.2)
    # which is not yet implemented.  Callers must check for "" and reject.
    ""

# Hash a text string with the named algorithm.
# Converts text to bytes, then hashes.
# reason: positional http auth digest API
fn _digest_hash_text(algorithm: text, t: text) -> text:
    _digest_hash(algorithm, text_to_bytes(t))

# Concatenate two texts with a ":" separator.
# reason: positional http auth digest API
fn _colon(a: text, b: text) -> text:
    a + ":" + b

# =============================================================================
# RFC 7616 — H(A1) and H(A2)
# =============================================================================

# H(A1) = H(username:realm:password)  [RFC 7616 §3.4]
# reason: positional http auth digest API
fn _digest_ha1(algorithm: text, username: text, realm: text, password: text) -> text:
    val a1 = _colon(_colon(username, realm), password)
    _digest_hash_text(algorithm, a1)

# H(A2) = H(method:digestURI)  [RFC 7616 §3.4, qop=auth or unset]
# reason: positional http auth digest API
fn _digest_ha2(algorithm: text, method: text, uri: text) -> text:
    val a2 = _colon(method, uri)
    _digest_hash_text(algorithm, a2)

# =============================================================================
# Response computation — RFC 7616 §3.4
# =============================================================================

# Compute the KD-hash response string.
#   With qop=auth:
#     response = H( HA1 : nonce : nc : cnonce : qop : HA2 )
#   Without qop (legacy / RFC 2069):
#     response = H( HA1 : nonce : HA2 )
# reason: positional http auth digest API
fn _digest_compute_response(
    algorithm: text,
    ha1: text, ha2: text,
    nonce: text, nc: text, cnonce: text, qop: text
) -> text:
    var kd_input = ""
    if qop == "auth":
        kd_input = _colon(
            _colon(
                _colon(
                    _colon(
                        _colon(ha1, nonce),
                        nc
                    ),
                    cnonce
                ),
                qop
            ),
            ha2
        )
    else:
        kd_input = _colon(_colon(ha1, nonce), ha2)
    _digest_hash_text(algorithm, kd_input)

# =============================================================================
# Public API — server: challenge
# =============================================================================

# Build a WWW-Authenticate: Digest header value.
#   realm     — protection space name
#   nonce     — server-generated unique value (caller supplies; typically random)
#   algorithm — "MD5" or "SHA-256"
#   qop       — quality-of-protection, typically "auth"; pass "" to omit
#
# Returns the full header value string (without the "WWW-Authenticate: " prefix).
# reason: positional http auth digest API
fn http_digest_make_challenge(realm: text, nonce: text, algorithm: text, qop: text) -> text:
    var result = "Digest realm=\"" + realm + "\""
    result = result + ", nonce=\"" + nonce + "\""
    result = result + ", algorithm=" + algorithm
    if qop != "":
        result = result + ", qop=\"" + qop + "\""
    result

# =============================================================================
# Public API — client: response
# =============================================================================

# Compute the Authorization: Digest header value.
# All string parameters are text (ASCII credentials per RFC 7616).
# Passwords containing arbitrary bytes should be percent-encoded by the caller
# before passing (RFC 7616 §4 requires UTF-8 userinfo).
#
# params tuple (positional):
#   0: username
#   1: realm
#   2: password
#   3: algorithm  ("MD5" or "SHA-256")
#   4: method     (e.g. "GET")
#   5: uri        (request-uri, e.g. "/dir/index.html")
#   6: nonce      (from challenge)
#   7: nc         (nonce count, 8-digit lowercase hex, e.g. "00000001")
#   8: cnonce     (client nonce)
#   9: qop        ("auth" or "")
#
# Returns "" if algorithm is unsupported.
# reason: positional http auth digest API
fn http_digest_make_response(params: tuple) -> text:
    val username  = params.0
    val realm     = params.1
    val password  = params.2
    val algorithm = params.3
    val method    = params.4
    val uri       = params.5
    val nonce     = params.6
    val nc        = params.7
    val cnonce    = params.8
    val qop       = params.9

    val ha1 = _digest_ha1(algorithm, username, realm, password)
    if ha1 == "":
        return ""
    val ha2 = _digest_ha2(algorithm, method, uri)
    val response = _digest_compute_response(algorithm, ha1, ha2, nonce, nc, cnonce, qop)

    var result = "Digest username=\"" + username + "\""
    result = result + ", realm=\"" + realm + "\""
    result = result + ", nonce=\"" + nonce + "\""
    result = result + ", uri=\"" + uri + "\""
    result = result + ", algorithm=" + algorithm
    if qop != "":
        result = result + ", qop=" + qop
        result = result + ", nc=" + nc
        result = result + ", cnonce=\"" + cnonce + "\""
    result = result + ", response=\"" + response + "\""
    result

# =============================================================================
# Public API — server: verify
# =============================================================================

# Verify a Digest Authorization response using constant-time comparison.
# Re-derives the expected response from params + expected_password and
# compares it to params.response_hex using _digest_ct_equal.
#
# params tuple: same positional layout as http_digest_make_response EXCEPT
#   position 2 (password) is ignored — use expected_password instead.
#
# Extra positions (appended to the same tuple):
#   10: response_hex — the "response" field from the Authorization header
#
# Returns true iff the response matches.
# reason: positional http auth digest API
fn http_digest_verify(params: tuple, expected_password: text) -> bool:
    val username      = params.0
    val realm         = params.1
    val algorithm     = params.3
    val method        = params.4
    val uri           = params.5
    val nonce         = params.6
    val nc            = params.7
    val cnonce        = params.8
    val qop           = params.9
    val response_hex  = params.10

    val ha1 = _digest_ha1(algorithm, username, realm, expected_password)
    if ha1 == "":
        return false
    val ha2 = _digest_ha2(algorithm, method, uri)
    val expected = _digest_compute_response(algorithm, ha1, ha2, nonce, nc, cnonce, qop)

    _digest_ct_equal(response_hex, expected)
