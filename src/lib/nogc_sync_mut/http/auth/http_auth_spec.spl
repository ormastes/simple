"""HTTP Basic and Digest Authentication specification tests.

Covers RFC 7617 (Basic) and RFC 7616 (Digest) using official test vectors.
"""

mod nogc_sync_mut.http.auth.basic
mod nogc_sync_mut.http.auth.digest
mod crypto.types

use std.nogc_sync_mut.http.auth.basic.{http_basic_encode, http_basic_parse, http_basic_ct_verify}
use std.nogc_sync_mut.http.auth.digest.{http_digest_make_response, http_digest_make_challenge, http_digest_verify}
use std.crypto.types.{text_to_bytes, bytes_to_text, bytes_to_hex}

# =============================================================================
# RFC 7617 — HTTP Basic Authentication
# =============================================================================

describe "HTTP Basic Auth (RFC 7617)":
    """Tests for Basic authentication encoding and decoding."""

    it "encodes RFC 7617 §2 test vector: Aladdin / open sesame":
        # RFC 7617 §2: Authorization: Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ==
        val user = text_to_bytes("Aladdin")
        val pw   = text_to_bytes("open sesame")
        val header_bytes = http_basic_encode(user, pw)
        val header = bytes_to_text(header_bytes)
        expect(header).to_equal("Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ==")

    it "encodes empty password":
        val user = text_to_bytes("user")
        val pw   = text_to_bytes("")
        val header_bytes = http_basic_encode(user, pw)
        val header = bytes_to_text(header_bytes)
        # "user:" base64-encodes to "dXNlcjo="
        expect(header).to_equal("Basic dXNlcjo=")

    it "encodes empty username":
        val user = text_to_bytes("")
        val pw   = text_to_bytes("secret")
        val header_bytes = http_basic_encode(user, pw)
        val header = bytes_to_text(header_bytes)
        # ":secret" base64-encodes to "OnNlY3JldA=="
        expect(header).to_equal("Basic OnNlY3JldA==")

    it "round-trips: parse recovers encoded credentials":
        val user = text_to_bytes("alice")
        val pw   = text_to_bytes("wonderland")
        val header_bytes = http_basic_encode(user, pw)
        val parsed = http_basic_parse(header_bytes)
        expect(parsed != nil).to_equal(true)
        val parsed_user = bytes_to_text(parsed.0)
        val parsed_pw   = bytes_to_text(parsed.1)
        expect(parsed_user).to_equal("alice")
        expect(parsed_pw).to_equal("wonderland")

    it "round-trips RFC 7617 vector: Aladdin / open sesame":
        # Decode the RFC example header directly
        val header_text = "Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ=="
        val header_bytes = text_to_bytes(header_text)
        val parsed = http_basic_parse(header_bytes)
        expect(parsed != nil).to_equal(true)
        val parsed_user = bytes_to_text(parsed.0)
        val parsed_pw   = bytes_to_text(parsed.1)
        expect(parsed_user).to_equal("Aladdin")
        expect(parsed_pw).to_equal("open sesame")

    it "parse returns nil for missing Basic prefix":
        val bad = text_to_bytes("Bearer sometoken")
        val parsed = http_basic_parse(bad)
        expect(parsed == nil).to_equal(true)

    it "parse returns nil for invalid base64":
        val bad = text_to_bytes("Basic !!!notbase64")
        val parsed = http_basic_parse(bad)
        expect(parsed == nil).to_equal(true)

    it "constant-time verify accepts correct credentials":
        val user = text_to_bytes("admin")
        val pw   = text_to_bytes("s3cr3t")
        val expected_user = text_to_bytes("admin")
        val expected_pw   = text_to_bytes("s3cr3t")
        expect(http_basic_ct_verify(user, pw, expected_user, expected_pw)).to_equal(true)

    it "constant-time verify rejects wrong password":
        val user = text_to_bytes("admin")
        val pw   = text_to_bytes("wrong")
        val expected_user = text_to_bytes("admin")
        val expected_pw   = text_to_bytes("s3cr3t")
        expect(http_basic_ct_verify(user, pw, expected_user, expected_pw)).to_equal(false)

    it "constant-time verify rejects wrong username":
        val user = text_to_bytes("attacker")
        val pw   = text_to_bytes("s3cr3t")
        val expected_user = text_to_bytes("admin")
        val expected_pw   = text_to_bytes("s3cr3t")
        expect(http_basic_ct_verify(user, pw, expected_user, expected_pw)).to_equal(false)

# =============================================================================
# RFC 7616 — HTTP Digest Authentication
# =============================================================================

describe "HTTP Digest Auth challenge (RFC 7616)":
    """Tests for WWW-Authenticate header generation."""

    it "builds challenge with SHA-256 and qop=auth":
        val challenge = http_digest_make_challenge(
            "http-auth@example.org",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "SHA-256",
            "auth"
        )
        expect(challenge.starts_with("Digest realm=\"http-auth@example.org\"")).to_equal(true)
        expect(challenge.contains("algorithm=SHA-256")).to_equal(true)
        expect(challenge.contains("qop=\"auth\"")).to_equal(true)

    it "builds challenge without qop when empty":
        val challenge = http_digest_make_challenge("example.org", "nonce123", "MD5", "")
        expect(challenge.contains("qop")).to_equal(false)
        expect(challenge.contains("algorithm=MD5")).to_equal(true)

describe "HTTP Digest Auth response — SHA-256 (RFC 7616 §3.9.1)":
    """RFC 7616 §3.9.1 worked example using SHA-256.

    username  = Mufasa
    realm     = http-auth@example.org
    password  = Circle of Life
    method    = GET
    uri       = /dir/index.html
    nonce     = 7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v
    nc        = 00000001
    cnonce    = f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ
    qop       = auth
    Expected response = 753927fa0e85d155564e2e272a28d1802ca10daf4496794697cf8db5856cb6c1
    """

    it "computes correct SHA-256 response digest":
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "Circle of Life",
            "SHA-256",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth"
        )
        val header = http_digest_make_response(params)
        expect(header.contains("753927fa0e85d155564e2e272a28d1802ca10daf4496794697cf8db5856cb6c1")).to_equal(true)

    it "includes all required Authorization header fields":
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "Circle of Life",
            "SHA-256",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth"
        )
        val header = http_digest_make_response(params)
        expect(header.starts_with("Digest ")).to_equal(true)
        expect(header.contains("username=\"Mufasa\"")).to_equal(true)
        expect(header.contains("realm=\"http-auth@example.org\"")).to_equal(true)
        expect(header.contains("algorithm=SHA-256")).to_equal(true)
        expect(header.contains("qop=auth")).to_equal(true)
        expect(header.contains("nc=00000001")).to_equal(true)
        expect(header.contains("response=\"")).to_equal(true)

    it "returns empty string for unsupported algorithm":
        val params = (
            "user", "realm", "pass",
            "SHA-512-256",
            "GET", "/", "nonce", "00000001", "cnonce", "auth"
        )
        val header = http_digest_make_response(params)
        expect(header).to_equal("")

    it "verifies correct SHA-256 response":
        # Same params as make_response test — verify accepts known-good response
        val response_hex = "753927fa0e85d155564e2e272a28d1802ca10daf4496794697cf8db5856cb6c1"
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "",
            "SHA-256",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth",
            response_hex
        )
        expect(http_digest_verify(params, "Circle of Life")).to_equal(true)

    it "verify rejects wrong password":
        val response_hex = "753927fa0e85d155564e2e272a28d1802ca10daf4496794697cf8db5856cb6c1"
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "",
            "SHA-256",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth",
            response_hex
        )
        expect(http_digest_verify(params, "WrongPassword")).to_equal(false)

describe "HTTP Digest Auth response — MD5 legacy (RFC 7616 §3.9.1)":
    """RFC 7616 §3.9.1 MD5 interop vector (legacy path — MD5 is cryptographically broken).

    Same credentials as SHA-256 test.
    Expected response = 8ca523f5e9506fed4657c9700eebdbec
    """

    it "computes correct MD5 response digest":
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "Circle of Life",
            "MD5",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth"
        )
        val header = http_digest_make_response(params)
        expect(header.contains("8ca523f5e9506fed4657c9700eebdbec")).to_equal(true)

    it "verifies correct MD5 response":
        val response_hex = "8ca523f5e9506fed4657c9700eebdbec"
        val params = (
            "Mufasa",
            "http-auth@example.org",
            "",
            "MD5",
            "GET",
            "/dir/index.html",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "00000001",
            "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
            "auth",
            response_hex
        )
        expect(http_digest_verify(params, "Circle of Life")).to_equal(true)

describe "HTTP Digest Auth — legacy no-qop mode":
    """RFC 7616 / RFC 2069 compatibility: response without qop."""

    it "computes SHA-256 response without qop":
        # Without qop: response = H(HA1:nonce:HA2)
        val params = (
            "testuser",
            "testrealm",
            "testpass",
            "SHA-256",
            "GET",
            "/resource",
            "testnonce",
            "",
            "",
            ""
        )
        val header = http_digest_make_response(params)
        expect(header.starts_with("Digest ")).to_equal(true)
        # no qop in header
        expect(header.contains("qop=")).to_equal(false)

    it "verify accepts SHA-256 no-qop response":
        val params_make = (
            "testuser",
            "testrealm",
            "testpass",
            "SHA-256",
            "GET",
            "/resource",
            "testnonce",
            "",
            "",
            ""
        )
        val header = http_digest_make_response(params_make)
        # Extract response hex from the generated header
        # response="<hex>" — find it and use it in verify
        val response_hex = _extract_response_hex(header)
        val params_verify = (
            "testuser",
            "testrealm",
            "",
            "SHA-256",
            "GET",
            "/resource",
            "testnonce",
            "",
            "",
            "",
            response_hex
        )
        expect(http_digest_verify(params_verify, "testpass")).to_equal(true)

# Helper: extract the response= field value from a Digest Authorization header
fn _extract_response_hex(header: text) -> text:
    val prefix = "response=\""
    val start_idx = header.index_of(prefix)
    if start_idx < 0:
        return ""
    val value_start = start_idx + prefix.length()
    val end_idx = header.index_of_from("\"", value_start)
    if end_idx < 0:
        return ""
    header.substring(value_start, end_idx)
