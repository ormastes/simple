"""TUI Widget Module - Widget trait and rendering primitives.

@tag:stdlib
@tag:tui

Defines the Rect area type and the widget rendering interface.
Widgets produce lists of StyledLine that can be rendered to the terminal.

# Usage

```simple
use std.tui.widget.*
use std.tui.style.*

val area = make_rect(0, 0, 80, 24)
val inner = rect_inner(area, 1, 1, 1, 1)  # 1-cell padding
```
"""

use std.tui.style.{StyledLine, StyledSegment, Style, make_plain_line, make_styled_line,
                     make_segment, make_line, default_style, render_line}

# ============================================================================
# Rect - Screen Area
# ============================================================================

struct Rect:
    """A rectangular area on the terminal screen.

    All coordinates are 0-based.

    Fields:
        x: Left column
        y: Top row
        width: Width in columns
        height: Height in rows
    """
    x: i64
    y: i64
    width: i64
    height: i64

fn make_rect(x: i64, y: i64, width: i64, height: i64) -> Rect:
    """Create a rectangular area.

    Args:
        x: Left column (0-based)
        y: Top row (0-based)
        width: Width in columns
        height: Height in rows

    Returns:
        Rect with the given dimensions
    """
    Rect(x: x, y: y, width: width, height: height)

fn rect_inner(r: Rect, top: i64, right: i64, bottom: i64, left: i64) -> Rect:
    """Shrink a Rect by the given margins (padding/border).

    Args:
        r: Original rectangle
        top: Top margin
        right: Right margin
        bottom: Bottom margin
        left: Left margin

    Returns:
        Inner Rect, clamped to non-negative dimensions
    """
    var new_x = r.x + left
    var new_y = r.y + top
    var new_w = r.width - left - right
    var new_h = r.height - top - bottom
    if new_w < 0:
        new_w = 0
    if new_h < 0:
        new_h = 0
    Rect(x: new_x, y: new_y, width: new_w, height: new_h)

fn rect_area(r: Rect) -> i64:
    """Calculate the area (width * height) of a Rect."""
    r.width * r.height

fn rect_right(r: Rect) -> i64:
    """Get the right edge column (exclusive)."""
    r.x + r.width

fn rect_bottom(r: Rect) -> i64:
    """Get the bottom edge row (exclusive)."""
    r.y + r.height

fn rect_contains(r: Rect, x: i64, y: i64) -> bool:
    """Check whether a point is inside the Rect.

    Args:
        r: The rectangle
        x: Column to test
        y: Row to test

    Returns:
        true if (x, y) is inside r
    """
    if x < r.x:
        return false
    if y < r.y:
        return false
    if x >= rect_right(r):
        return false
    if y >= rect_bottom(r):
        return false
    true

# ============================================================================
# Padding Helper
# ============================================================================

fn pad_or_truncate(content: text, width: i64) -> text:
    """Pad content with spaces to width, or truncate if too long.

    Args:
        content: Text to adjust
        width: Target width

    Returns:
        Text of exactly the specified width
    """
    val content_len = len(content)
    if content_len == width:
        return content
    if content_len > width:
        if width <= 0:
            return ""
        return substring(content, 0, width)
    # Pad with spaces
    var result = content
    var i = content_len
    while i < width:
        result = "{result} "
        i = i + 1
    result

# ============================================================================
# Render Buffer
# ============================================================================

struct RenderBuffer:
    """A buffer of styled lines ready to be painted to the terminal.

    Fields:
        lines: List of StyledLine (one per row)
        width: Width of the renderable area
        height: Height of the renderable area
    """
    lines: [StyledLine]
    width: i64
    height: i64

fn make_render_buffer(width: i64, height: i64) -> RenderBuffer:
    """Create an empty render buffer filled with blank lines.

    Args:
        width: Buffer width
        height: Buffer height

    Returns:
        RenderBuffer with empty lines
    """
    var lines: [StyledLine] = []
    var i = 0
    while i < height:
        lines = lines + [make_plain_line(pad_or_truncate("", width))]
        i = i + 1
    RenderBuffer(lines: lines, width: width, height: height)

fn buffer_set_line(buf: RenderBuffer, row: i64, line: StyledLine) -> RenderBuffer:
    """Set a specific line in the render buffer.

    Args:
        buf: The buffer
        row: Row index (0-based)
        line: StyledLine to set

    Returns:
        Updated RenderBuffer
    """
    if row < 0:
        return buf
    if row >= buf.height:
        return buf
    var new_lines: [StyledLine] = []
    var i = 0
    while i < len(buf.lines):
        if i == row:
            new_lines = new_lines + [line]
        else:
            new_lines = new_lines + [buf.lines[i]]
        i = i + 1
    RenderBuffer(lines: new_lines, width: buf.width, height: buf.height)
