"""TUI Text Widget - Static text display.

@tag:stdlib
@tag:tui

Renders plain or styled text within a given rectangular area.
Supports word wrapping and alignment.

# Usage

```simple
use std.tui.widgets.text.*
use std.tui.widget.{make_rect}
use std.tui.style.{fg_style, COLOR_GREEN}

val area = make_rect(0, 0, 40, 5)
val lines = text_render("Hello, world!", default_style(), area)
```
"""

use std.tui.style.{Style, StyledLine, StyledSegment, default_style, make_segment,
                     make_line, make_plain_line, make_styled_line}
use std.tui.widget.{Rect, pad_or_truncate}

# ============================================================================
# Text Alignment
# ============================================================================

val ALIGN_LEFT: i64 = 0
val ALIGN_CENTER: i64 = 1
val ALIGN_RIGHT: i64 = 2

# ============================================================================
# Text Widget State
# ============================================================================

struct TextWidget:
    """A static text display widget.

    Fields:
        content: The text content (may contain newlines)
        style: Style to render with
        alignment: Text alignment (ALIGN_LEFT, ALIGN_CENTER, ALIGN_RIGHT)
    """
    content: text
    style: Style
    alignment: i64

fn make_text_widget(content: text, style: Style) -> TextWidget:
    """Create a text widget with left alignment.

    Args:
        content: Text to display (newlines create multiple lines)
        style: Style to apply

    Returns:
        TextWidget
    """
    TextWidget(content: content, style: style, alignment: ALIGN_LEFT)

fn make_text_widget_aligned(content: text, style: Style, alignment: i64) -> TextWidget:
    """Create a text widget with specified alignment.

    Args:
        content: Text to display
        style: Style to apply
        alignment: ALIGN_LEFT, ALIGN_CENTER, or ALIGN_RIGHT

    Returns:
        TextWidget
    """
    TextWidget(content: content, style: style, alignment: alignment)

# ============================================================================
# Line Splitting
# ============================================================================

fn split_lines(content: text) -> [text]:
    """Split text by newlines into a list of lines.

    Args:
        content: Text possibly containing newlines

    Returns:
        List of line strings
    """
    var lines: [text] = []
    var current = ""
    var i = 0
    while i < len(content):
        val ch = substring(content, i, i + 1)
        if ch == "\n":
            lines = lines + [current]
            current = ""
        else:
            current = "{current}{ch}"
        i = i + 1
    lines = lines + [current]
    lines

# ============================================================================
# Alignment
# ============================================================================

fn align_text(content: text, width: i64, alignment: i64) -> text:
    """Align text within a given width.

    Args:
        content: Text to align
        width: Target width
        alignment: ALIGN_LEFT, ALIGN_CENTER, or ALIGN_RIGHT

    Returns:
        Aligned text padded to width
    """
    val content_len = len(content)
    if content_len >= width:
        return substring(content, 0, width)

    val padding = width - content_len

    if alignment == ALIGN_CENTER:
        val left_pad = padding / 2
        val right_pad = padding - left_pad
        var left_spaces = ""
        var li = 0
        while li < left_pad:
            left_spaces = "{left_spaces} "
            li = li + 1
        var right_spaces = ""
        var ri = 0
        while ri < right_pad:
            right_spaces = "{right_spaces} "
            ri = ri + 1
        return "{left_spaces}{content}{right_spaces}"

    if alignment == ALIGN_RIGHT:
        var spaces = ""
        var si = 0
        while si < padding:
            spaces = "{spaces} "
            si = si + 1
        return "{spaces}{content}"

    # ALIGN_LEFT (default)
    pad_or_truncate(content, width)

# ============================================================================
# Rendering
# ============================================================================

fn text_render(widget: TextWidget, area: Rect) -> [StyledLine]:
    """Render a TextWidget into a list of StyledLines for the given area.

    Lines are truncated to area width and excess lines beyond area height
    are discarded. Empty rows are filled with spaces.

    Args:
        widget: The text widget to render
        area: The target area

    Returns:
        List of StyledLine, one per row of the area
    """
    val raw_lines = split_lines(widget.content)
    var result: [StyledLine] = []
    var i = 0

    while i < area.height:
        if i < len(raw_lines):
            val aligned = align_text(raw_lines[i], area.width, widget.alignment)
            result = result + [make_styled_line(aligned, widget.style)]
        else:
            result = result + [make_plain_line(pad_or_truncate("", area.width))]
        i = i + 1

    result
