"""TUI Widgets Module - Built-in widget collection.

@tag:stdlib
@tag:tui

Re-exports all built-in TUI widgets: Text, Box, List, and Input.

# Widgets

| Widget | File | Description |
|--------|------|-------------|
| Text | `text.spl` | Static text display with alignment |
| Box | `box_widget.spl` | Bordered container with optional title |
| List | `list.spl` | Scrollable list with selection |
| Input | `input.spl` | Single-line text input field |
"""

# Re-exported from text.spl
export ALIGN_LEFT, ALIGN_CENTER, ALIGN_RIGHT
export TextWidget, make_text_widget, make_text_widget_aligned
export text_render

# Re-exported from box_widget.spl
export BORDER_TOP_LEFT, BORDER_TOP_RIGHT, BORDER_BOTTOM_LEFT, BORDER_BOTTOM_RIGHT
export BORDER_HORIZONTAL, BORDER_VERTICAL
export BoxWidget, make_box_widget, make_box_widget_with_content
export box_render, box_inner_area

# Re-exported from list.spl
export ListWidget, make_list_widget
export list_select, list_select_next, list_select_prev, list_ensure_visible
export list_render, list_selected_item

# Re-exported from input.spl
export InputWidget, make_input_widget, make_input_widget_with_value
export input_insert_char, input_delete_back, input_delete_forward
export input_move_left, input_move_right, input_move_home, input_move_end
export input_set_focus, input_clear
export input_render, input_cursor_screen_col
