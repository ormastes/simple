# web_ui — Tauri-like desktop application framework in Simple.
#
# Uses the browser engine (examples/browser/) for HTML/CSS rendering
# and SDL2 for windowing. Provides a command system, event bus, and
# plugin architecture for building desktop apps.
#
# Usage:
#   use std.web_ui.app.{WebUIApp}
#   use std.web_ui.command.{CommandRegistry}
#   use std.web_ui.event_bus.{EventBus}
#   use std.web_ui.plugin.{Plugin, PluginRegistry, FsPlugin}
#   use std.web_ui.types.{Payload, CommandResult, AppState}
#   use std.web_ui.window.{WindowManager, WebUIWindow}
#   use std.web_ui.bridge.{RenderBridge}
#   use std.web_ui.input.{InputBridge, WebUIEvent}

use std.nogc_sync_mut.web_ui.types.{Payload, CommandResult, AppState}
use std.nogc_sync_mut.web_ui.app.{WebUIApp, AppConfig}
use std.nogc_sync_mut.web_ui.window.{WindowManager, WebUIWindow}
use std.nogc_sync_mut.web_ui.bridge.{RenderBridge}
use std.nogc_sync_mut.web_ui.input.{InputBridge, WebUIEvent}
use std.nogc_sync_mut.web_ui.command.{CommandRegistry}
use std.nogc_sync_mut.web_ui.event_bus.{EventBus}
use std.nogc_sync_mut.web_ui.plugin.{Plugin, PluginRegistry, FsPlugin}
