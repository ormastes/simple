# WebUIApp — main entry point for web_ui applications.
# Inspired by Tauri: create windows, register commands, emit events, add plugins.
# Uses the browser engine for HTML rendering and SDL2 for windowing.

use std.nogc_sync_mut.web_ui.types.{Payload, CommandResult, AppState}
use std.nogc_sync_mut.web_ui.window.{WindowManager, WebUIWindow}
use std.nogc_sync_mut.web_ui.bridge.{RenderBridge}
use std.nogc_sync_mut.web_ui.input.{InputBridge, WebUIEvent}
use std.nogc_sync_mut.web_ui.command.{CommandRegistry}
use std.nogc_sync_mut.web_ui.event_bus.{EventBus}
use std.nogc_sync_mut.web_ui.plugin.{Plugin, PluginRegistry}
use std.nogc_sync_mut.web_ui.dom_backend.{EngineDomBackend}
use examples.browser.shared.logging.{Logger, LogLevel}
use std.nogc_sync_mut.io.window_ffi.{rt_sdl2_get_ticks_ms}

# Application configuration.
class AppConfig:
    title: text
    width: i64
    height: i64
    html: text
    resizable: bool
    target_fps: i64

    static fn default_config() -> AppConfig:
        AppConfig(
            title: "WebUI App",
            width: 800,
            height: 600,
            html: "",
            resizable: true,
            target_fps: 60
        )

# The main web_ui application.
class WebUIApp:
    config: AppConfig
    window_manager: WindowManager
    command_registry: CommandRegistry
    event_bus: EventBus
    plugin_registry: PluginRegistry
    input_bridge: InputBridge
    logger: Logger
    state: AppState
    running: bool
    dom_backend: EngineDomBackend

    # Create a new app with title, dimensions, and initial HTML.
    static fn create(title: text, width: i64, height: i64, html: text) -> WebUIApp:
        val logger = Logger.new(LogLevel.Info)
        val wm = WindowManager.create(logger)
        val cmds = CommandRegistry.create()
        val events = EventBus.create()
        val plugins = PluginRegistry.create()
        val input = InputBridge.create()
        val dom = EngineDomBackend.create(logger)
        val config = AppConfig(
            title: title,
            width: width,
            height: height,
            html: html,
            resizable: true,
            target_fps: 60
        )
        WebUIApp(
            config: config,
            window_manager: wm,
            command_registry: cmds,
            event_bus: events,
            plugin_registry: plugins,
            input_bridge: input,
            logger: logger,
            state: AppState.Initializing,
            running: false,
            dom_backend: dom
        )

    # Get the DOM backend for direct element manipulation.
    fn dom() -> EngineDomBackend:
        self.dom_backend

    # Register a command handler callable from frontend JS.
    me command(name: text, handler: fn(List<text>) -> Result<text, text>):
        self.command_registry.register(name, handler)

    # Create an additional window.
    me create_window(label: text, title: text, width: i64, height: i64, html: text):
        self.window_manager.create_window(label, title, width, height, html)

    # Emit a global event.
    me emit(event_name: text, payload: text):
        self.event_bus.emit(event_name, payload)

    # Emit to a specific window.
    me emit_to(window_label: text, event_name: text, payload: text):
        self.event_bus.emit_to(window_label, event_name, payload)

    # Listen for an event.
    me listen(event_name: text, handler: fn(text)) -> i64:
        self.event_bus.listen(event_name, handler)

    # Register a plugin.
    me plugin(p: Plugin):
        self.plugin_registry.register(p)

    # Graceful shutdown.
    me quit():
        self.running = false
        self.state = AppState.ShuttingDown

    # Main entry point — starts the event loop, blocks until quit.
    me run():
        self.state = AppState.Running
        self.running = true

        # Initialize all plugins
        self.plugin_registry.init_all(self.command_registry, self.event_bus)

        # Create the primary window
        self.window_manager.create_window("main", self.config.title, self.config.width, self.config.height, self.config.html)

        self.logger.log(LogLevel.Info, "WebUIApp started: {self.config.title}")

        # Calculate frame time budget
        val frame_ms = 1000 / self.config.target_fps

        # Main event loop
        while self.running:
            val frame_start = rt_sdl2_get_ticks_ms()

            # Phase 1: Poll SDL2 events
            val events = self.input_bridge.poll()

            # Phase 2: Process events
            for event in events:
                self.handle_event(event)

            # Phase 3: Render dirty windows and present
            self.window_manager.present_all()

            # Phase 4: Frame pacing (busy-wait to target FPS)
            var now = rt_sdl2_get_ticks_ms()
            val elapsed = now - frame_start
            if elapsed < frame_ms:
                # Busy wait for remaining frame budget
                val target = frame_start + frame_ms
                while now < target:
                    now = rt_sdl2_get_ticks_ms()

        # Shutdown
        self.state = AppState.ShuttingDown
        self.plugin_registry.shutdown_all()
        self.window_manager.destroy_all()
        self.logger.log(LogLevel.Info, "WebUIApp shutdown complete")

    # Handle a single WebUIEvent.
    me handle_event(event: WebUIEvent):
        match event:
            WebUIEvent.CloseRequested:
                self.event_bus.emit("window:close", "main")
                self.running = false

            WebUIEvent.Resize(width, height):
                # Resize the main window's bridge
                val main_win = self.window_manager.get_window("main")
                match main_win:
                    Some(w):
                        w.resize(width, height)
                    nil: pass_dn
                self.event_bus.emit("window:resize", "{width}x{height}")

            WebUIEvent.Click(x, y, button):
                self.event_bus.emit("click", "{x},{y}")

            WebUIEvent.KeyDown(key_sym, modifiers):
                self.event_bus.emit("keydown", "{key_sym}")

            WebUIEvent.KeyUp(key_sym, modifiers):
                self.event_bus.emit("keyup", "{key_sym}")

            WebUIEvent.MouseMove(x, y):
                pass_dn

            WebUIEvent.MouseDown(x, y, button):
                pass_dn

            WebUIEvent.MouseUp(x, y, button):
                pass_dn

            WebUIEvent.Scroll(dx, dy):
                self.event_bus.emit("scroll", "{dx},{dy}")

            WebUIEvent.None:
                pass_dn
