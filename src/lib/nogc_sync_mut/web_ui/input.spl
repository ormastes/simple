# SDL2 event translation for web_ui.
# Polls raw SDL2 events and converts them to WebUIEvent values.
# Provides conversion to browser UiEvent for the render bridge.

use std.nogc_sync_mut.io.window_ffi.{
    rt_sdl2_poll_event,
    rt_sdl2_event_key_sym,
    rt_sdl2_event_key_mod,
    rt_sdl2_event_mouse_x,
    rt_sdl2_event_mouse_y,
    rt_sdl2_event_mouse_button,
    rt_sdl2_event_wheel_x,
    rt_sdl2_event_wheel_y,
    rt_sdl2_event_window_event_id,
    rt_sdl2_event_window_data1,
    rt_sdl2_event_window_data2
}

# Web UI event types produced from SDL2 input.
enum WebUIEvent:
    Click(x: i64, y: i64, button: i64)
    MouseMove(x: i64, y: i64)
    MouseDown(x: i64, y: i64, button: i64)
    MouseUp(x: i64, y: i64, button: i64)
    KeyDown(key_sym: i64, modifiers: i64)
    KeyUp(key_sym: i64, modifiers: i64)
    Scroll(dx: i64, dy: i64)
    Resize(width: i64, height: i64)
    CloseRequested
    None

# Tracks mouse state for click detection.
class InputBridge:
    mouse_x: i64
    mouse_y: i64
    mouse_down: bool

    static fn create() -> InputBridge:
        InputBridge(mouse_x: 0, mouse_y: 0, mouse_down: false)

    # Poll all pending SDL2 events this frame.
    # Returns a list of WebUIEvent values.
    me poll() -> List<WebUIEvent>:
        var events = List<WebUIEvent>()
        var event_type = rt_sdl2_poll_event()
        while event_type != 0:
            val evt = self.translate(event_type)
            match evt:
                WebUIEvent.None: pass_dn
                _: events.push(evt)
            event_type = rt_sdl2_poll_event()
        events

    # Translate a single SDL2 event code to WebUIEvent.
    me translate(event_type: i64) -> WebUIEvent:
        # 1=quit
        if event_type == 1:
            return WebUIEvent.CloseRequested

        # 2=keydown
        if event_type == 2:
            val sym = rt_sdl2_event_key_sym()
            val mods = rt_sdl2_event_key_mod()
            return WebUIEvent.KeyDown(key_sym: sym, modifiers: mods)

        # 3=keyup
        if event_type == 3:
            val sym = rt_sdl2_event_key_sym()
            val mods = rt_sdl2_event_key_mod()
            return WebUIEvent.KeyUp(key_sym: sym, modifiers: mods)

        # 4=mousemotion
        if event_type == 4:
            self.mouse_x = rt_sdl2_event_mouse_x()
            self.mouse_y = rt_sdl2_event_mouse_y()
            return WebUIEvent.MouseMove(x: self.mouse_x, y: self.mouse_y)

        # 5=mousedown
        if event_type == 5:
            self.mouse_x = rt_sdl2_event_mouse_x()
            self.mouse_y = rt_sdl2_event_mouse_y()
            val btn = rt_sdl2_event_mouse_button()
            self.mouse_down = true
            return WebUIEvent.MouseDown(x: self.mouse_x, y: self.mouse_y, button: btn)

        # 6=mouseup
        if event_type == 6:
            self.mouse_x = rt_sdl2_event_mouse_x()
            self.mouse_y = rt_sdl2_event_mouse_y()
            val btn = rt_sdl2_event_mouse_button()
            var result = WebUIEvent.MouseUp(x: self.mouse_x, y: self.mouse_y, button: btn)
            # Generate click on left button (btn=1 in SDL2) release
            if self.mouse_down and btn == 1:
                result = WebUIEvent.Click(x: self.mouse_x, y: self.mouse_y, button: 0)
            self.mouse_down = false
            return result

        # 7=mousewheel
        if event_type == 7:
            val dx = rt_sdl2_event_wheel_x()
            val dy = rt_sdl2_event_wheel_y()
            return WebUIEvent.Scroll(dx: dx, dy: dy)

        # 8=windowevent
        if event_type == 8:
            val window_event_id = rt_sdl2_event_window_event_id()
            # SDL_WINDOWEVENT_SIZE_CHANGED = 6
            if window_event_id == 6:
                val w = rt_sdl2_event_window_data1()
                val h = rt_sdl2_event_window_data2()
                return WebUIEvent.Resize(width: w, height: h)
            # SDL_WINDOWEVENT_CLOSE = 14
            if window_event_id == 14:
                return WebUIEvent.CloseRequested
            return WebUIEvent.None

        WebUIEvent.None
