# Shared types for the web_ui framework.
# Provides Payload (key-value args), CommandResult, and AppState.

class WebUiPayloadEntry:
    key: text
    value: text

    static fn create(key: text, value: text) -> WebUiPayloadEntry:
        WebUiPayloadEntry(key: key, value: value)

# Key-value payload for commands and events.
class Payload:
    entries: List<WebUiPayloadEntry>

    static fn empty() -> Payload:
        Payload(entries: [])

    static fn from_list(entries: List<WebUiPayloadEntry>) -> Payload:
        Payload(entries: entries)

    # Look up a value by key. Returns nil if not found.
    fn get(key: text) -> Option<text>:
        for entry in self.entries:
            if entry.key == key:
                return Some(entry.value)
        nil

    # Set a key-value pair. Updates existing or appends new.
    me set(key: text, value: text):
        var i = 0
        while i < self.entries.len():
            var entry = self.entries.get(i)
            if entry.key == key:
                self.entries[i] = WebUiPayloadEntry.create(key, value)
                return
            i = i + 1
        self.entries.push(WebUiPayloadEntry.create(key, value))

    # Get all keys.
    fn keys() -> List<text>:
        var result: List<text> = []
        for entry in self.entries:
            result.push(entry.key)
        result

    # Get number of entries.
    fn len() -> i64:
        self.entries.len()

# Result of a command invocation.
enum CommandResult:
    Ok(value: text)
    Err(message: text)

# Application lifecycle state.
enum AppState:
    Initializing
    Running
    ShuttingDown
