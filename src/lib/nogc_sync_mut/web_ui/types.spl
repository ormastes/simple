# Shared types for the web_ui framework.
# Provides Payload (key-value args), CommandResult, and AppState.

# Key-value payload for commands and events.
class Payload:
    entries: List<Pair<text, text>>

    static fn empty() -> Payload:
        Payload(entries: List<Pair<text, text>>())

    static fn from_list(entries: List<Pair<text, text>>) -> Payload:
        Payload(entries: entries)

    # Look up a value by key. Returns nil if not found.
    fn get(key: text) -> Option<text>:
        for entry in self.entries:
            if entry.first == key:
                return Some(entry.second)
        nil

    # Set a key-value pair. Updates existing or appends new.
    me set(key: text, value: text):
        var i = 0
        while i < self.entries.len():
            var entry = self.entries.get(i)
            if entry.first == key:
                self.entries.set(i, Pair(first: key, second: value))
                return
            i = i + 1
        self.entries.push(Pair(first: key, second: value))

    # Get all keys.
    fn keys() -> List<text>:
        var result = List<text>()
        for entry in self.entries:
            result.push(entry.first)
        result

    # Get number of entries.
    fn len() -> i64:
        self.entries.len()

# Result of a command invocation.
enum CommandResult:
    Ok(value: text)
    Err(message: text)

# Application lifecycle state.
enum AppState:
    Initializing
    Running
    ShuttingDown
