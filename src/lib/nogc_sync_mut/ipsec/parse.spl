# IPsec wire parsing (RFC 4303 / 4302 / 7296).
#
# ESP and AH ICV lengths are negotiated per-SA and not self-describing on the
# wire, so the caller supplies icv_len. Parsers build a local ByteReader and
# read inline (never pass ByteReader by value).

use std.common.net.byte_cursor.{ByteReader}
use std.common.net.anti_replay.{SecurityParameterIndex}
use std.nogc_sync_mut.ipsec.types.{EspPacket, AhHeader, IkeHeader, IkePayloadHeader, IkeMessage}

# ESP layout: SPI(4) Seq(4) [payload .. pad .. padlen(1) nexthdr(1)] ICV(icv_len).
# The encrypted region length = total - 8 (header) - icv_len. The pad/padlen/
# nexthdr trailer is *inside* the encrypted region, so post-decrypt; here we
# expose payload = the whole encrypted region and leave pad empty (framing).
fn parse_esp_packet(bytes: [u8], icv_len: u64) -> Result<EspPacket, text>:
    var r = ByteReader.new(bytes)
    val spi = r.read_u32()
    if spi.is_err():
        return Err("esp: spi")
    val seq = r.read_u32()
    if seq.is_err():
        return Err("esp: seq")
    val total = bytes.len().to_u64()
    if total < (8 + icv_len):
        return Err("esp: too short for icv")
    val enc_len = (total - 8) - icv_len
    val enc = r.read_bytes(enc_len)
    if enc.is_err():
        return Err("esp: encrypted region truncated")
    val icv = r.read_bytes(icv_len)
    if icv.is_err():
        return Err("esp: icv truncated")
    var pkt = EspPacket.new(SecurityParameterIndex.new(spi.unwrap()), seq.unwrap(), enc.unwrap(), [], 0, icv.unwrap())
    Ok(pkt)

# AH layout: NextHdr(1) PayloadLen(1) Reserved(2) SPI(4) Seq(4) ICV(icv_len).
fn parse_ah_header(bytes: [u8], icv_len: u64) -> Result<AhHeader, text>:
    var r = ByteReader.new(bytes)
    val nh = r.read_u8()
    if nh.is_err():
        return Err("ah: next_header")
    val pl = r.read_u8()
    if pl.is_err():
        return Err("ah: payload_length")
    val resv = r.read_u16()
    if resv.is_err():
        return Err("ah: reserved")
    val spi = r.read_u32()
    if spi.is_err():
        return Err("ah: spi")
    val seq = r.read_u32()
    if seq.is_err():
        return Err("ah: seq")
    val icv = r.read_bytes(icv_len)
    if icv.is_err():
        return Err("ah: icv truncated")
    var ah = AhHeader.new(nh.unwrap(), SecurityParameterIndex.new(spi.unwrap()), seq.unwrap(), icv.unwrap())
    ah.payload_length = pl.unwrap()
    Ok(ah)

# IKEv2 fixed header (RFC 7296 §3.1, 28 bytes).
fn parse_ike_header(bytes: [u8]) -> Result<IkeHeader, text>:
    var r = ByteReader.new(bytes)
    val ispi = r.read_u64()
    if ispi.is_err():
        return Err("ike: initiator_spi")
    val rspi = r.read_u64()
    if rspi.is_err():
        return Err("ike: responder_spi")
    val np = r.read_u8()
    if np.is_err():
        return Err("ike: next_payload")
    val ver = r.read_u8()
    if ver.is_err():
        return Err("ike: version")
    val ex = r.read_u8()
    if ex.is_err():
        return Err("ike: exchange_type")
    val fl = r.read_u8()
    if fl.is_err():
        return Err("ike: flags")
    val mid = r.read_u32()
    if mid.is_err():
        return Err("ike: message_id")
    val len = r.read_u32()
    if len.is_err():
        return Err("ike: length")
    var h = IkeHeader.new(ispi.unwrap(), rspi.unwrap(), np.unwrap(), ex.unwrap(), fl.unwrap(), mid.unwrap(), len.unwrap())
    h.version = ver.unwrap()
    Ok(h)

# Parse a full IKEv2 message: header then a chain of generic payloads.
# The chain is walked by next_payload until 0 (NONE) or input exhausted.
fn parse_ike_message(bytes: [u8]) -> Result<IkeMessage, text>:
    val hres = parse_ike_header(bytes)
    if hres.is_err():
        return Err("ike msg: header")
    val hdr = hres.unwrap()
    var payloads: [IkePayloadHeader] = []
    var next = hdr.next_payload
    var off: u64 = 28
    var guard: u64 = 0
    while next != 0 and off < bytes.len() and guard < 64:
        if (off + 4) > bytes.len():
            return Err("ike msg: payload header truncated")
        val np = bytes[off]
        val crit_byte = bytes[off + 1]
        val len_hi = bytes[off + 2].to_u16()
        val len_lo = bytes[off + 3].to_u16()
        val plen = ((len_hi << 8) | len_lo).to_u64()
        if plen < 4:
            return Err("ike msg: payload length < 4")
        if (off + plen) > bytes.len():
            return Err("ike msg: payload body truncated")
        var body: [u8] = []
        var j: u64 = off + 4
        while j < (off + plen):
            body.push(bytes[j])
            j = j + 1
        val critical = (crit_byte & 0x80) != 0
        var ph = IkePayloadHeader.new(np, critical, body)
        payloads.push(ph)
        next = np
        off = off + plen
        guard = guard + 1
    var msg = IkeMessage.new(hdr, payloads)
    Ok(msg)
