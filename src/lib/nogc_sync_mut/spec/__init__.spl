# Spec Module - Testing Framework
#
# SSpec testing framework for behavior-driven development (BDD).
# Provides describe/it/expect syntax for readable tests.
#
# Features:
#   - BDD-style test organization (describe, context, it)
#   - Rich matchers (to_equal, to_be, to_contain, etc.)
#   - Hooks (before, after, before_each, after_each)
#   - Test isolation and cleanup
#   - Conditional test execution
#   - Feature documentation generation
#
# Public API:
#   - use std.spec.{describe, it, expect}
#   - use std.spec.{before, after, before_each, after_each}
#   - use std.spec.decorators.{skip_it, pending_it}
#   - use std.spec.condition.{when, unless}
#
# Example:
#   describe "Calculator":
#     it "adds numbers":
#       expect(2 + 2).to_equal(4)

# All submodules are automatically available.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn check_msg(condition: bool, message: text):
    if not condition:
        expect(message).to_equal("")

fn skip_it(name: text, block: fn()):
    print "    it {name} ... skipped (compiled-only)"

fn pending(name: text):
    print "    it {name} ... pending"

fn skip(name: text, reason: text):
    print "    it {name} ... skipped ({reason})"

export check, check_msg, skip_it, pending, skip

