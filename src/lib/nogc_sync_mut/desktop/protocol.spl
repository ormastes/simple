# Custom URL protocol/scheme handler registration.
# Linux: .desktop file + xdg-mime. macOS: requires app bundle (limited).

use common.ui.capability.{NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run, env_home}

extern fn rt_platform_name() -> text

struct ProtocolConfig:
    scheme: text
    app_name: text
    binary_path: text

fn register_protocol(config: ProtocolConfig) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val home = env_home()
        val desktop_dir = "{home}/.local/share/applications"
        val desktop_file = "{desktop_dir}/simple-{config.scheme}.desktop"
        val content = "[Desktop Entry]\nType=Application\nName={config.app_name}\nExec={config.binary_path} %u\nMimeType=x-scheme-handler/{config.scheme};\nNoDisplay=true\nTerminal=false"
        val write_result = process_run("/bin/sh", ["-c", "mkdir -p {desktop_dir} && printf '%s' '{content}' > {desktop_file}"])
        if write_result.2 != 0:
            return Err(NotSupported.new("failed to write desktop file: {write_result.1}"))
        val mime_result = process_run("xdg-mime", ["default", "simple-{config.scheme}.desktop", "x-scheme-handler/{config.scheme}"])
        if mime_result.2 != 0:
            return Err(NotSupported.new("xdg-mime registration failed: {mime_result.1}"))
        Ok(true)
    elif platform == "macos":
        Err(NotSupported.new("protocol registration on macOS requires app bundle Info.plist"))
    else:
        Err(NotSupported.new("protocol registration not supported on {platform}"))

fn unregister_protocol(scheme: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val home = env_home()
        val desktop_file = "{home}/.local/share/applications/simple-{scheme}.desktop"
        val result = process_run("/bin/sh", ["-c", "rm -f {desktop_file} && update-desktop-database {home}/.local/share/applications/ 2>/dev/null"])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("protocol unregistration not supported on {platform}"))

fn is_protocol_registered(scheme: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val result = process_run("xdg-mime", ["query", "default", "x-scheme-handler/{scheme}"])
        if result.2 != 0:
            return Ok(false)
        val handler = result.0
        Ok(handler.contains("simple-{scheme}"))
    elif platform == "macos":
        Err(NotSupported.new("protocol query not supported on macOS"))
    else:
        Err(NotSupported.new("protocol query not supported on {platform}"))
