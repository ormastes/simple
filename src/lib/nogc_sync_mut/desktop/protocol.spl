# Custom URL protocol/scheme handler registration.
# Linux: .desktop file + xdg-mime. macOS: requires app bundle (limited).

use common.ui.capability.{NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run, env_home}

extern fn rt_platform_name() -> text

struct ProtocolConfig:
    scheme: text
    app_name: text
    binary_path: text

fn register_protocol(config: ProtocolConfig) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val home = env_home()
        val scheme = config.scheme
        val app_name = config.app_name
        val bin_path = config.binary_path
        val desktop_dir = home + "/.local/share/applications"
        val desktop_filename = "simple-" + scheme + ".desktop"
        val desktop_file = desktop_dir + "/" + desktop_filename
        val content = "[Desktop Entry]\nType=Application\nName=" + app_name + "\nExec=" + bin_path + " %u\nMimeType=x-scheme-handler/" + scheme + ";\nNoDisplay=true\nTerminal=false"
        val write_cmd = "mkdir -p " + desktop_dir + " && printf '%s' '" + content + "' > " + desktop_file
        val write_result = process_run("/bin/sh", ["-c", write_cmd])
        if write_result.2 != 0:
            val err = write_result.1
            return Err(NotSupported.new("failed to write desktop file: " + err))
        val mime_result = process_run("xdg-mime", ["default", desktop_filename, "x-scheme-handler/" + scheme])
        if mime_result.2 != 0:
            val merr = mime_result.1
            return Err(NotSupported.new("xdg-mime registration failed: " + merr))
        Ok(true)
    elif platform == "macos":
        Err(NotSupported.new("protocol registration on macOS requires app bundle Info.plist"))
    else:
        Err(NotSupported.new("protocol registration not supported on " + platform))

fn unregister_protocol(scheme: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val home = env_home()
        val app_dir = home + "/.local/share/applications"
        val desktop_file = app_dir + "/simple-" + scheme + ".desktop"
        val cmd = "rm -f " + desktop_file + " && update-desktop-database " + app_dir + " 2>/dev/null"
        val result = process_run("/bin/sh", ["-c", cmd])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("protocol unregistration not supported on " + platform))

fn is_protocol_registered(scheme: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val mime_type = "x-scheme-handler/" + scheme
        val result = process_run("xdg-mime", ["query", "default", mime_type])
        if result.2 != 0:
            return Ok(false)
        val handler = result.0
        val expected = "simple-" + scheme
        Ok(handler.contains(expected))
    elif platform == "macos":
        Err(NotSupported.new("protocol query not supported on macOS"))
    else:
        Err(NotSupported.new("protocol query not supported on " + platform))
