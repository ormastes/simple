# Host-OS system clipboard access via SDL2.

use common.ui.capability.{Capability, NotSupported}
use std.nogc_sync_mut.io.window_sffi.{window_clipboard_get, window_clipboard_set, window_clipboard_has_text}

fn clipboard_read() -> Result<text, NotSupported>:
    val content = window_clipboard_get()
    Ok(content)

fn clipboard_write(content: text) -> Result<bool, NotSupported>:
    val ok = window_clipboard_set(content)
    Ok(ok)

fn clipboard_has_text() -> bool:
    window_clipboard_has_text()

# -- Plain (text, bool) adapters for common.ui.clipboard_service.
#
# ClipboardService.install_host_bridge takes `fn() -> text` / `fn(text) ->
# bool` function pointers (its host-bridge seam has to stay Result-free so
# the pure common/ui layer never needs to know about NotSupported). These
# two collapse the Result<_, NotSupported> down to that shape.

fn clipboard_read_text() -> text:
    match clipboard_read():
        Ok(v): return v
        Err(_): return ""

fn clipboard_write_text(content: text) -> bool:
    match clipboard_write(content):
        Ok(v): return v
        Err(_): return false
