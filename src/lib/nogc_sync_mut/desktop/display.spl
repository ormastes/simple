# Multi-monitor display information via SDL2.

use common.ui.capability.{NotSupported}

extern fn rt_sdl2_get_num_displays() -> i64
extern fn rt_sdl2_get_display_name(index: i64) -> text
extern fn rt_sdl2_get_display_bounds_x(index: i64) -> i64
extern fn rt_sdl2_get_display_bounds_y(index: i64) -> i64
extern fn rt_sdl2_get_display_bounds_w(index: i64) -> i64
extern fn rt_sdl2_get_display_bounds_h(index: i64) -> i64
extern fn rt_sdl2_get_display_dpi(index: i64) -> f64
extern fn rt_sdl2_get_display_usable_x(index: i64) -> i64
extern fn rt_sdl2_get_display_usable_y(index: i64) -> i64
extern fn rt_sdl2_get_display_usable_w(index: i64) -> i64
extern fn rt_sdl2_get_display_usable_h(index: i64) -> i64

struct DisplayInfo:
    id: i64
    name: text
    width: i64
    height: i64
    x: i64
    y: i64
    dpi: f64
    scale_factor: f64
    is_primary: bool
    usable_x: i64
    usable_y: i64
    usable_width: i64
    usable_height: i64

fn get_display_count() -> i64:
    rt_sdl2_get_num_displays()

fn get_primary_display() -> DisplayInfo:
    build_display_info(0)

fn get_all_displays() -> [DisplayInfo]:
    val count = rt_sdl2_get_num_displays()
    var displays: [DisplayInfo] = []
    var i = 0
    while i < count:
        displays = displays + [build_display_info(i)]
        i = i + 1
    displays

fn build_display_info(index: i64) -> DisplayInfo:
    val dpi = rt_sdl2_get_display_dpi(index)
    DisplayInfo(
        id: index,
        name: rt_sdl2_get_display_name(index),
        width: rt_sdl2_get_display_bounds_w(index),
        height: rt_sdl2_get_display_bounds_h(index),
        x: rt_sdl2_get_display_bounds_x(index),
        y: rt_sdl2_get_display_bounds_y(index),
        dpi: dpi,
        scale_factor: dpi / 96.0,
        is_primary: index == 0,
        usable_x: rt_sdl2_get_display_usable_x(index),
        usable_y: rt_sdl2_get_display_usable_y(index),
        usable_width: rt_sdl2_get_display_usable_w(index),
        usable_height: rt_sdl2_get_display_usable_h(index)
    )
