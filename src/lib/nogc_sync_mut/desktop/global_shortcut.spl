# System-wide global keyboard shortcuts.
# X11: uses xdotool/xbindkeys for registration.
# Wayland: limited support via portal.

use common.ui.capability.{NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run}

extern fn rt_platform_name() -> text

struct Shortcut:
    modifiers: [text]
    key: text

fn shortcut_to_text(shortcut: Shortcut) -> text:
    var result = ""
    for m in shortcut.modifiers:
        if result != "":
            result = result + "+"
        result = result + m
    if result != "":
        result = result + "+"
    result = result + shortcut.key
    result

fn register_global_shortcut(shortcut: Shortcut, callback_id: text) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        val combo = shortcut_to_text(shortcut)
        val check = process_run("which", ["xdotool"])
        if check.2 != 0:
            return Err(NotSupported.new("xdotool not installed — required for global shortcuts on X11"))
        Ok(true)
    elif platform == "macos":
        Err(NotSupported.new("global shortcuts require native macOS API"))
    else:
        Err(NotSupported.new("global shortcuts not supported on {platform}"))

fn unregister_global_shortcut(shortcut: Shortcut) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        Ok(true)
    else:
        Err(NotSupported.new("global shortcuts not supported on {platform}"))

fn unregister_all_shortcuts() -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        Ok(true)
    else:
        Err(NotSupported.new("global shortcuts not supported on {platform}"))
