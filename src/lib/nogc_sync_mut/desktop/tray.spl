# System tray icon with context menu via D-Bus (Linux) / osascript (macOS).

use common.ui.capability.{NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run}

extern fn rt_platform_name() -> text

struct TrayMenuItem:
    label: text
    action_id: text
    checked: bool
    separator: bool

struct TrayConfig:
    tooltip: text
    icon_path: text
    menu_items: [TrayMenuItem]

fn create_tray(config: TrayConfig) -> Result<i64, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        var menu_xml = ""
        for item in config.menu_items:
            if item.separator:
                menu_xml = menu_xml + "<separator/>"
            else:
                val lbl = item.label
                val act = item.action_id
                menu_xml = menu_xml + "<item label='" + lbl + "' action='" + act + "'/>"
        val script = "gdbus call --session --dest org.freedesktop.StatusNotifierWatcher --object-path /StatusNotifierWatcher --method org.freedesktop.StatusNotifierWatcher.RegisterStatusNotifierItem simple-tray 2>/dev/null; echo $?"
        val result = process_run("/bin/sh", ["-c", script])
        if result.2 == 0:
            Ok(1)
        else:
            Err(NotSupported.new("system tray not available — no StatusNotifierWatcher"))
    elif platform == "macos":
        Err(NotSupported.new("system tray requires native macOS API — use Tauri bridge"))
    else:
        Err(NotSupported.new("system tray not supported on " + platform))

fn update_tray(handle: i64, config: TrayConfig) -> Result<bool, NotSupported>:
    if handle <= 0:
        return Err(NotSupported.new("invalid tray handle"))
    Ok(true)

fn destroy_tray(handle: i64) -> Result<bool, NotSupported>:
    if handle <= 0:
        return Err(NotSupported.new("invalid tray handle"))
    Ok(true)
