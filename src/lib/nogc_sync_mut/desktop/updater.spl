# Application auto-update mechanism.
# Checks a feed URL for new versions, downloads, and applies updates.

use common.ui.capability.{NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run}

extern fn rt_platform_name() -> text

struct UpdateInfo:
    version: text
    url: text
    release_notes: text
    mandatory: bool

struct UpdateConfig:
    feed_url: text
    current_version: text
    auto_download: bool

fn check_for_update(config: UpdateConfig) -> Result<UpdateInfo, NotSupported>:
    val feed_url = config.feed_url
    val result = process_run("curl", ["-s", "-f", feed_url])
    if result.2 != 0:
        val err = result.1
        return Err(NotSupported.new("failed to fetch update feed: " + err))
    val body = result.0
    var version = ""
    var url = ""
    var notes = ""
    var mandatory = false
    var lines = split_lines(body)
    for line in lines:
        if line.starts_with("version:"):
            val v_raw = line.slice(8, line.length())
            version = v_raw.trim()
        elif line.starts_with("url:"):
            val u_raw = line.slice(4, line.length())
            url = u_raw.trim()
        elif line.starts_with("notes:"):
            val n_raw = line.slice(6, line.length())
            notes = n_raw.trim()
        elif line.starts_with("mandatory:"):
            val m_raw = line.slice(10, line.length())
            val flag = m_raw.trim()
            mandatory = flag == "true"
    if version == "":
        return Err(NotSupported.new("no version found in update feed"))
    val cur_ver = config.current_version
    if version == cur_ver:
        return Err(NotSupported.new("already up to date"))
    Ok(UpdateInfo(version: version, url: url, release_notes: notes, mandatory: mandatory))

fn download_update(info: UpdateInfo, dest_path: text) -> Result<bool, NotSupported>:
    val dl_url = info.url
    if dl_url == "":
        return Err(NotSupported.new("no download URL in update info"))
    val result = process_run("curl", ["-s", "-f", "-o", dest_path, dl_url])
    if result.2 != 0:
        val dl_err = result.1
        return Err(NotSupported.new("download failed: " + dl_err))
    Ok(true)

fn apply_update(binary_path: text) -> Result<bool, NotSupported>:
    val result = process_run("chmod", ["+x", binary_path])
    if result.2 != 0:
        return Err(NotSupported.new("failed to make update executable"))
    Ok(true)

fn split_lines(input: text) -> [text]:
    var lines: [text] = []
    var current = ""
    for ch in input:
        if ch == '\n':
            lines = lines + [current]
            current = ""
        else:
            current = current + "{ch}"
    if current != "":
        lines = lines + [current]
    lines
