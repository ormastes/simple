# Native OS desktop notifications.

use common.ui.capability.{Capability, NotSupported}
use std.nogc_sync_mut.ffi.system.{process_run}

extern fn rt_platform_name() -> text

struct NotificationOptions:
    title: text
    body: text
    icon: text
    urgency: text
    timeout_ms: i64

fn notify(title: text, body: text) -> Result<bool, NotSupported>:
    val opts = NotificationOptions(title: title, body: body, icon: "", urgency: "normal", timeout_ms: 5000)
    notify_with_options(opts)

fn notify_with_options(opts: NotificationOptions) -> Result<bool, NotSupported>:
    val platform = rt_platform_name()
    if platform == "linux":
        var args: [text] = []
        if opts.icon != "":
            args = ["--icon", opts.icon, opts.title, opts.body]
        else:
            args = [opts.title, opts.body]
        val result = process_run("notify-send", args)
        val exit_code = result.2
        Ok(exit_code == 0)
    elif platform == "macos":
        val script = "display notification \"" + opts.body + "\" with title \"" + opts.title + "\""
        val result = process_run("osascript", ["-e", script])
        Ok(result.2 == 0)
    else:
        Err(NotSupported.new("notifications not supported on " + platform))
