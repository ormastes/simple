# std.desktop — Host-OS desktop integration APIs.
#
# Provides Electron-equivalent desktop features: clipboard, notifications,
# file dialogs, shell integration, display info, power monitoring, system
# tray, global shortcuts, auto-updater, protocol handlers, and app lifecycle.
#
# Usage:
#   use std.desktop.clipboard.{clipboard_read, clipboard_write}
#   use std.desktop.notification.{notify}
#   use std.desktop.dialog.{open_file_dialog, save_file_dialog}
#   use std.desktop.shell_open.{open_url, open_path, show_in_folder}
#   use std.desktop.display.{get_all_displays, get_primary_display}
#   use std.desktop.power.{get_power_state, get_battery_info}
#   use std.desktop.tray.{create_tray, update_tray}
#   use std.desktop.global_shortcut.{register_global_shortcut}
#   use std.desktop.updater.{check_for_update}
#   use std.desktop.protocol.{register_protocol}
#   use std.desktop.lifecycle.{AppLifecycle}

use std.nogc_sync_mut.desktop.clipboard.{clipboard_read, clipboard_write, clipboard_has_text}
use std.nogc_sync_mut.desktop.shell_open.{open_url, open_path, show_in_folder, move_to_trash, beep}
use std.nogc_sync_mut.desktop.notification.{notify, notify_with_options, NotificationOptions}
use std.nogc_sync_mut.desktop.dialog.{open_file_dialog, save_file_dialog, open_directory_dialog, message_dialog, DialogOptions, DialogFilter}
use std.nogc_sync_mut.desktop.display.{get_all_displays, get_primary_display, get_display_count, DisplayInfo}
use std.nogc_sync_mut.desktop.power.{get_power_state, get_battery_info, PowerState, BatteryInfo}
use std.nogc_sync_mut.desktop.tray.{create_tray, update_tray, destroy_tray, TrayConfig, TrayMenuItem}
use std.nogc_sync_mut.desktop.global_shortcut.{register_global_shortcut, unregister_global_shortcut, unregister_all_shortcuts, Shortcut}
use std.nogc_sync_mut.desktop.updater.{check_for_update, download_update, apply_update, UpdateInfo, UpdateConfig}
use std.nogc_sync_mut.desktop.protocol.{register_protocol, unregister_protocol, is_protocol_registered, ProtocolConfig}
use std.nogc_sync_mut.desktop.lifecycle.{AppLifecycle, LifecycleEvent}

use std.nogc_sync_mut.web_ui.types.{Payload, CommandResult, AppState}
