# BGP-4 (RFC 4271) type definitions.
#
# MDSOC: feature dimension, network routing layer.
# Wire format: 19-byte header + type-specific body.
# All multi-byte fields are big-endian (network byte order).
# Dispatch uses integer constants (NOT payload-carrying enums) to avoid
# the known JIT bug with enum-match on message/attr type fields.

use std.common.net.addr.{AsNumber}
use std.common.net.routing.{RoutePrefix, RouterId, RoutingMetric}

# ============================================================================
# Constants
# ============================================================================

# Message types (RFC 4271 §4.1)
val BGP_MSG_OPEN:         u8 = 1
val BGP_MSG_UPDATE:       u8 = 2
val BGP_MSG_NOTIFICATION: u8 = 3
val BGP_MSG_KEEPALIVE:    u8 = 4

# BGP header constants
val BGP_HEADER_LEN: u16       = 19
val BGP_MARKER_LEN: u8        = 16
val BGP_MAX_MSG_LEN: u16      = 4096

# Path attribute type codes (RFC 4271 §5)
val BGP_PA_ORIGIN:         u8 = 1
val BGP_PA_AS_PATH:        u8 = 2
val BGP_PA_NEXT_HOP:       u8 = 3
val BGP_PA_MED:            u8 = 4
val BGP_PA_LOCAL_PREF:     u8 = 5
val BGP_PA_ATOMIC_AGGR:    u8 = 6
val BGP_PA_AGGREGATOR:     u8 = 7

# Path attribute flags (RFC 4271 §4.3)
val BGP_PA_FLAG_OPTIONAL:    u8 = 0x80
val BGP_PA_FLAG_TRANSITIVE:  u8 = 0x40
val BGP_PA_FLAG_PARTIAL:     u8 = 0x20
val BGP_PA_FLAG_EXT_LEN:     u8 = 0x10

# ORIGIN attribute values
val BGP_ORIGIN_IGP:        u8 = 0
val BGP_ORIGIN_EGP:        u8 = 1
val BGP_ORIGIN_INCOMPLETE: u8 = 2

# AS_PATH segment types
val BGP_AS_SET:      u8 = 1
val BGP_AS_SEQUENCE: u8 = 2

# NOTIFICATION error codes (RFC 4271 §6)
val BGP_ERR_MSG_HEADER:  u8 = 1
val BGP_ERR_OPEN:        u8 = 2
val BGP_ERR_UPDATE:      u8 = 3
val BGP_ERR_HOLD_TIMER:  u8 = 4
val BGP_ERR_FSM:         u8 = 5
val BGP_ERR_CEASE:       u8 = 6

# NOTIFICATION subcodes for message header errors
val BGP_ERR_HDR_CONN_SYNC: u8 = 1
val BGP_ERR_HDR_BAD_LEN:   u8 = 2
val BGP_ERR_HDR_BAD_TYPE:  u8 = 3

# ============================================================================
# BgpHeader -- 19-byte message header (RFC 4271 §4.1)
# ============================================================================

struct BgpHeader:
    """19-byte BGP message header: marker[16] + length(2) + type(1)."""
    marker: [u8]    # 16 bytes, all 0xFF for RFC 4271
    length: u16     # total message length including header
    msg_type: u8    # BGP_MSG_* constant

# ============================================================================
# BgpOpenMsg -- OPEN message body (RFC 4271 §4.2)
# ============================================================================

struct BgpOpenMsg:
    """BGP OPEN message body."""
    version: u8         # must be 4
    my_as: AsNumber     # 2-byte AS number on wire (4271 §4.2)
    hold_time: u16      # proposed hold time in seconds
    bgp_id: RouterId    # BGP identifier (dotted-quad)
    opt_params: [u8]    # raw optional parameters TLV blob

# ============================================================================
# BgpPathAttribute -- a single path attribute TLV (RFC 4271 §4.3)
# ============================================================================

struct BgpPathAttribute:
    """A single BGP path attribute TLV."""
    flags: u8       # BGP_PA_FLAG_* bitmask
    type_code: u8   # BGP_PA_* constant
    value: [u8]     # raw value bytes

# ============================================================================
# BgpAsPathSegment -- one segment of AS_PATH (RFC 4271 §5.1.2)
# ============================================================================

struct BgpAsPathSegment:
    """One segment of the BGP AS_PATH attribute."""
    seg_type: u8        # BGP_AS_SET or BGP_AS_SEQUENCE
    asns: [AsNumber]    # ASNs in this segment

# ============================================================================
# BgpUpdateMsg -- UPDATE message body (RFC 4271 §4.3)
# ============================================================================

struct BgpUpdateMsg:
    """BGP UPDATE message body."""
    withdrawn: [RoutePrefix]            # withdrawn routes
    path_attributes: [BgpPathAttribute] # path attributes
    nlri: [RoutePrefix]                 # network layer reachability info

# ============================================================================
# BgpNotificationMsg -- NOTIFICATION message body (RFC 4271 §4.5)
# ============================================================================

struct BgpNotificationMsg:
    """BGP NOTIFICATION message body."""
    error_code: u8
    error_subcode: u8
    data: [u8]  # optional diagnostic data

export BGP_MSG_OPEN
export BGP_MSG_UPDATE
export BGP_MSG_NOTIFICATION
export BGP_MSG_KEEPALIVE
export BGP_HEADER_LEN
export BGP_MARKER_LEN
export BGP_MAX_MSG_LEN
export BGP_PA_ORIGIN
export BGP_PA_AS_PATH
export BGP_PA_NEXT_HOP
export BGP_PA_MED
export BGP_PA_LOCAL_PREF
export BGP_PA_ATOMIC_AGGR
export BGP_PA_AGGREGATOR
export BGP_PA_FLAG_OPTIONAL
export BGP_PA_FLAG_TRANSITIVE
export BGP_PA_FLAG_PARTIAL
export BGP_PA_FLAG_EXT_LEN
export BGP_ORIGIN_IGP
export BGP_ORIGIN_EGP
export BGP_ORIGIN_INCOMPLETE
export BGP_AS_SET
export BGP_AS_SEQUENCE
export BGP_ERR_MSG_HEADER
export BGP_ERR_OPEN
export BGP_ERR_UPDATE
export BGP_ERR_HOLD_TIMER
export BGP_ERR_FSM
export BGP_ERR_CEASE
export BGP_ERR_HDR_CONN_SYNC
export BGP_ERR_HDR_BAD_LEN
export BGP_ERR_HDR_BAD_TYPE
