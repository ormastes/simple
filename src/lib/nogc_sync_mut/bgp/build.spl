# BGP-4 (RFC 4271) wire building.
#
# MDSOC: feature dimension, network routing layer.

use std.common.net.byte_cursor.{ByteWriter}
use std.common.net.addr.{ip_addr_to_bytes}
use std.common.net.routing.{RouterId}
use std.nogc_sync_mut.bgp.types.{BgpHeader, BgpOpenMsg, BgpPathAttribute, BgpUpdateMsg, BgpNotificationMsg, BGP_MARKER_LEN, BGP_HEADER_LEN}

# ============================================================================
# Build BGP common header (19 bytes)
# ============================================================================

fn bgp_header_build(msg_type: u8, body_len: u16) -> [u8]:
    """Emit a 19-byte BGP header. total length = BGP_HEADER_LEN + body_len."""
    var w = ByteWriter.new()
    # 16-byte marker: all 0xFF
    var i: u64 = 0
    while i < 16:
        w.write_u8(0xFF)
        i = i + 1
    val total_len = BGP_HEADER_LEN + body_len
    w.write_u16(total_len)
    w.write_u8(msg_type)
    w.to_bytes()

# ============================================================================
# Build BGP KEEPALIVE (just a header, no body)
# ============================================================================

fn bgp_keepalive_build() -> [u8]:
    """Emit a 19-byte BGP KEEPALIVE message."""
    bgp_header_build(4, 0)

# ============================================================================
# Build BGP OPEN message body
# ============================================================================

fn bgp_open_build(msg: BgpOpenMsg) -> [u8]:
    """Emit BGP OPEN body (without header)."""
    var w = ByteWriter.new()
    w.write_u8(msg.version)
    # my_as as 2-byte legacy field
    w.write_u16(msg.my_as.value.to_u16())
    w.write_u16(msg.hold_time)
    # Typed rebind so the seed's field-index resolver sees a concrete struct
    val bid: RouterId = msg.bgp_id
    w.write_bytes(bid.octets)
    w.write_u8(msg.opt_params.len().to_u8())
    w.write_bytes(msg.opt_params)
    w.to_bytes()

# ============================================================================
# Build a prefix list (NLRI or withdrawn): each entry is prefix_len(1) + ceil(len/8) bytes
# ============================================================================

fn bgp_prefixes_build(prefixes: [RoutePrefix]) -> [u8]:
    """Emit a list of RFC 4271 length-value prefixes."""
    var w = ByteWriter.new()
    var i: u64 = 0
    while i < prefixes.len():
        val pfx = prefixes[i]
        val plen = pfx.prefix_len
        w.write_u8(plen)
        val nbytes: u64 = (plen.to_u64() + 7) / 8
        val addr_bytes = ip_addr_to_bytes(pfx.addr)
        var k: u64 = 0
        while k < nbytes:
            w.write_u8(addr_bytes[k])
            k = k + 1
        i = i + 1
    w.to_bytes()

# ============================================================================
# Build a single path attribute TLV
# ============================================================================

fn bgp_attr_build(attr: BgpPathAttribute) -> [u8]:
    """Emit one path attribute (short-length form)."""
    var w = ByteWriter.new()
    w.write_u8(attr.flags)
    w.write_u8(attr.type_code)
    w.write_u8(attr.value.len().to_u8())
    w.write_bytes(attr.value)
    w.to_bytes()

# ============================================================================
# Build BGP UPDATE message (header + body)
# ============================================================================

fn bgp_update_build(msg: BgpUpdateMsg) -> [u8]:
    """Emit a complete BGP UPDATE message."""
    # build components
    val wd_bytes = bgp_prefixes_build(msg.withdrawn)
    var pa_w = ByteWriter.new()
    var i: u64 = 0
    while i < msg.path_attributes.len():
        val ab = bgp_attr_build(msg.path_attributes[i])
        pa_w.write_bytes(ab)
        i = i + 1
    val pa_bytes = pa_w.to_bytes()
    val nlri_bytes = bgp_prefixes_build(msg.nlri)
    # body: wd_len(2) + wd + pa_len(2) + pa + nlri
    var body_w = ByteWriter.new()
    body_w.write_u16(wd_bytes.len().to_u16())
    body_w.write_bytes(wd_bytes)
    body_w.write_u16(pa_bytes.len().to_u16())
    body_w.write_bytes(pa_bytes)
    body_w.write_bytes(nlri_bytes)
    val body = body_w.to_bytes()
    var out_w = ByteWriter.new()
    val hdr = bgp_header_build(2, body.len().to_u16())
    out_w.write_bytes(hdr)
    out_w.write_bytes(body)
    out_w.to_bytes()

# ============================================================================
# Build BGP NOTIFICATION message (header + body)
# ============================================================================

fn bgp_notification_build(msg: BgpNotificationMsg) -> [u8]:
    """Emit a complete BGP NOTIFICATION message."""
    var body_w = ByteWriter.new()
    body_w.write_u8(msg.error_code)
    body_w.write_u8(msg.error_subcode)
    body_w.write_bytes(msg.data)
    val body = body_w.to_bytes()
    var out_w = ByteWriter.new()
    val hdr = bgp_header_build(3, body.len().to_u16())
    out_w.write_bytes(hdr)
    out_w.write_bytes(body)
    out_w.to_bytes()
