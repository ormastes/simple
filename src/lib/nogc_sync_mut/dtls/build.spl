# DTLS wire serialization (RFC 6347 / RFC 9147).
#
# Builders emit exact network byte order using ByteWriter. Each builder takes
# the typed struct and returns [u8]. The DTLS 1.3 unified header is variable
# length; the flags byte drives which optional fields are emitted.

use std.common.net.byte_cursor.{ByteWriter}
use std.nogc_sync_mut.dtls.types.{DtlsRecord12, DtlsHandshakeFragment, DtlsRecord13}

# DTLS 1.2 record: 1+2+2+6+2 = 13-byte header, then the fragment.
fn build_dtls_record12(rec: DtlsRecord12) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(rec.content_type)
    w.write_u16(rec.version)
    w.write_u16(rec.epoch)
    w.write_u48(rec.sequence_number)
    w.write_u16(rec.fragment.len().to_u16())
    w.write_bytes(rec.fragment)
    w.to_bytes()

# DTLS handshake fragment: 1 + 3 + 2 + 3 + 3 = 12-byte header, then body.
fn build_dtls_handshake_fragment(frag: DtlsHandshakeFragment) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(frag.msg_type)
    w.write_u24(frag.length)
    w.write_u16(frag.message_seq)
    w.write_u24(frag.fragment_offset)
    w.write_u24(frag.fragment_length)
    w.write_bytes(frag.body)
    w.to_bytes()

# DTLS 1.3 unified header: flags, [cid], seq(1|2), [length], encrypted_record.
fn build_dtls_record13(rec: DtlsRecord13) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(rec.flags)
    if rec.has_cid():
        w.write_bytes(rec.connection_id)
    if rec.has_seq16():
        w.write_u16(rec.seq_number)
    else:
        w.write_u8((rec.seq_number & 0xFF).to_u8())
    if rec.has_length():
        w.write_u16(rec.encrypted_record.len().to_u16())
    w.write_bytes(rec.encrypted_record)
    w.to_bytes()
