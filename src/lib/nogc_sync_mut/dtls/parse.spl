# DTLS wire parsing (RFC 6347 / RFC 9147).
#
# Parsers decode big-endian using a locally-constructed ByteReader (never a
# by-value ByteReader parameter -- that loses cursor propagation). Each returns
# Result<Struct, text>; truncated input yields Err.

use std.common.net.byte_cursor.{ByteReader}
use std.nogc_sync_mut.dtls.types.{DtlsRecord12, DtlsHandshakeFragment, DtlsRecord13}
use std.nogc_sync_mut.dtls.types.{DTLS13_FLAG_CID, DTLS13_FLAG_SEQ16, DTLS13_FLAG_LENGTH}

fn parse_dtls_record12(bytes: [u8]) -> Result<DtlsRecord12, text>:
    var r = ByteReader.new(bytes)
    val ct = r.read_u8()
    if ct.is_err():
        return Err("dtls12: content_type")
    val ver = r.read_u16()
    if ver.is_err():
        return Err("dtls12: version")
    val epoch = r.read_u16()
    if epoch.is_err():
        return Err("dtls12: epoch")
    val seq = r.read_u48()
    if seq.is_err():
        return Err("dtls12: sequence_number")
    val length = r.read_u16()
    if length.is_err():
        return Err("dtls12: length")
    val lenv = length.unwrap()
    val frag = r.read_bytes(lenv.to_u64())
    if frag.is_err():
        return Err("dtls12: fragment truncated")
    Ok(DtlsRecord12.new(ct.unwrap(), ver.unwrap(), epoch.unwrap(), seq.unwrap(), frag.unwrap()))

fn parse_dtls_handshake_fragment(bytes: [u8]) -> Result<DtlsHandshakeFragment, text>:
    var r = ByteReader.new(bytes)
    val mt = r.read_u8()
    if mt.is_err():
        return Err("dtls hs: msg_type")
    val length = r.read_u24()
    if length.is_err():
        return Err("dtls hs: length")
    val mseq = r.read_u16()
    if mseq.is_err():
        return Err("dtls hs: message_seq")
    val foff = r.read_u24()
    if foff.is_err():
        return Err("dtls hs: fragment_offset")
    val flen = r.read_u24()
    if flen.is_err():
        return Err("dtls hs: fragment_length")
    val flenv = flen.unwrap()
    val body = r.read_bytes(flenv.to_u64())
    if body.is_err():
        return Err("dtls hs: body truncated")
    var frag = DtlsHandshakeFragment.new(mt.unwrap(), length.unwrap(), mseq.unwrap(), foff.unwrap(), body.unwrap())
    Ok(frag)

# DTLS 1.3 unified header. The connection-id length is not self-describing on
# the wire, so the caller supplies cid_len (0 if none / flag clear).
fn parse_dtls_record13(bytes: [u8], cid_len: u64) -> Result<DtlsRecord13, text>:
    var r = ByteReader.new(bytes)
    val flags = r.read_u8()
    if flags.is_err():
        return Err("dtls13: flags")
    val fv = flags.unwrap()
    var cid: [u8] = []
    if (fv & DTLS13_FLAG_CID) != 0:
        val cidr = r.read_bytes(cid_len)
        if cidr.is_err():
            return Err("dtls13: connection_id truncated")
        cid = cidr.unwrap()
    var seqv: u16 = 0
    if (fv & DTLS13_FLAG_SEQ16) != 0:
        val s16 = r.read_u16()
        if s16.is_err():
            return Err("dtls13: seq16")
        seqv = s16.unwrap()
    else:
        val s8 = r.read_u8()
        if s8.is_err():
            return Err("dtls13: seq8")
        seqv = s8.unwrap().to_u16()
    var bodylen: u64 = r.remaining()
    if (fv & DTLS13_FLAG_LENGTH) != 0:
        val ln = r.read_u16()
        if ln.is_err():
            return Err("dtls13: length")
        bodylen = ln.unwrap().to_u64()
    val body = r.read_bytes(bodylen)
    if body.is_err():
        return Err("dtls13: encrypted_record truncated")
    var rec = DtlsRecord13.new(fv, cid, seqv, body.unwrap())
    Ok(rec)
