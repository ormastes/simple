@allow(unnamed_duplicate_typed_args) # reason: writeback APIs use positional i64 params
# RV64 Writeback (WB) Stage
#
# Writes the result (ALU output or loaded data) back to the register file.
# Selects between ALU result and memory data based on the mem_to_reg control
# signal from the MEM/WB latch.
#
# Feature IDs: #HW-RV64-PIPE-WB
# Category: Hardware / RTL Simulation
# Status: Implemented

use std.hardware.rv64.pipeline.types.{
    Rv64RegisterFile, Rv64MemWbLatch
}

# ============================================================================
# Writeback Stage
# ============================================================================

struct Rv64WbStage:
    """Writeback stage -- writes results to the register file."""
    placeholder: i64

fn create_rv64_wb_stage() -> Rv64WbStage:
    Rv64WbStage(placeholder: 0)

impl Rv64WbStage:
    fn tick(mem_wb: Rv64MemWbLatch, reg_file: Rv64RegisterFile):
        """Execute one clock cycle of the WB stage.

        Args:
            mem_wb: Latch data from the MEM stage.
            reg_file: Register file to write the result into.
        """
        if not mem_wb.valid:
            return
        if not mem_wb.reg_write:
            return

        var wb_data = mem_wb.alu_result
        if mem_wb.mem_to_reg:
            wb_data = mem_wb.mem_data

        reg_file.write(mem_wb.rd, wb_data)

    fn select_wb_data(mem_wb: Rv64MemWbLatch) -> i64:
        """Return the value that would be written back, without writing.

        Useful for forwarding or debug inspection.
        """
        if mem_wb.mem_to_reg:
            return mem_wb.mem_data
        mem_wb.alu_result
