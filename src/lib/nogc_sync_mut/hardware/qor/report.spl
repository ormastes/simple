# RTL QoR reports.

use lib.nogc_sync_mut.hardware.qor.types.{RtlQorRun, RtlQorDelta, compare_qor_runs}

fn rtl_qor_run_markdown(run: RtlQorRun) -> text:
    var out = "## RTL QoR Run " + run.run_id + "\n\n"
    out = out + "| Metric | Value |\n"
    out = out + "|--------|-------|\n"
    out = out + "| Design | " + run.design + " |\n"
    out = out + "| Target | " + run.target + " |\n"
    out = out + "| Toolchain | " + run.toolchain + " |\n"
    out = out + "| LUT | " + run.lut_count.to_text() + " |\n"
    out = out + "| FF | " + run.ff_count.to_text() + " |\n"
    out = out + "| BRAM | " + run.bram_count.to_text() + " |\n"
    out = out + "| DSP | " + run.dsp_count.to_text() + " |\n"
    out = out + "| Fmax MHz | " + run.fmax_mhz.to_text() + " |\n"
    out = out + "| Cycles | " + run.cycles.to_text() + " |\n"
    out = out + "| Passed | " + run.passed.to_text() + " |\n"
    return out

fn rtl_qor_delta_markdown(delta: RtlQorDelta) -> text:
    var out = "## RTL QoR Delta\n\n"
    out = out + "| Metric | Delta |\n"
    out = out + "|--------|-------|\n"
    out = out + "| Baseline | " + delta.baseline_id + " |\n"
    out = out + "| Candidate | " + delta.candidate_id + " |\n"
    out = out + "| LUT | " + delta.lut_delta.to_text() + " |\n"
    out = out + "| FF | " + delta.ff_delta.to_text() + " |\n"
    out = out + "| BRAM | " + delta.bram_delta.to_text() + " |\n"
    out = out + "| DSP | " + delta.dsp_delta.to_text() + " |\n"
    out = out + "| Fmax MHz | " + delta.fmax_delta.to_text() + " |\n"
    out = out + "| Cycles | " + delta.cycle_delta.to_text() + " |\n"
    out = out + "| Area Score | " + delta.area_delta.to_text() + " |\n"
    return out

fn rtl_qor_compare_markdown(baseline: RtlQorRun, candidate: RtlQorRun) -> text:
    return rtl_qor_delta_markdown(compare_qor_runs(baseline, candidate))
