# Driver-framework adapter for the GPU driver.
#
# Mirrors fs_driver/driver_adapter.spl but classed as DriverClass.Gpu.
# The adapter registers the GPU driver into the shared registry so the
# kernel can route gpu_* calls through the same lifecycle path as every
# other device class. Class-specific GPU ops (gpu_alloc, gpu_launch,
# gpu_sync) stay on the existing gpu_driver module surface — the
# adapter only supplies the Driver-trait shell.

use std.driver.error.{DriverError}
use std.driver.manifest.{DriverManifest, DRVS_ABI_REV}
use std.driver.registry.{DriverOps}
use std.driver.static_table.{register_static_driver}
use std.driver.types.{DriverClass, DriverHandle, DriverContext, DeviceId,
                      IoctlCmd, PowerState, ProbeResult}

fn gpu_abi_rev() -> i32:
    return DRVS_ABI_REV

fn gpu_drv_init(ctx: DriverContext) -> Result<(), DriverError>:
    # Real driver calls gpu_init() here. Stub adapter keeps it empty so
    # registration succeeds even when CUDA / Vulkan runtime is absent.
    return Result.Ok(())

fn gpu_drv_probe(dev: DeviceId) -> Result<ProbeResult, DriverError>:
    return Result.Ok(ProbeResult.Reject)

fn gpu_drv_attach(dev: DeviceId) -> Result<DriverHandle, DriverError>:
    return Result.Err(DriverError.NotSupported)

fn gpu_drv_detach(h: DriverHandle) -> Result<(), DriverError>:
    return Result.Ok(())

fn gpu_drv_suspend(h: DriverHandle, s: PowerState) -> Result<(), DriverError>:
    return Result.Ok(())

fn gpu_drv_resume(h: DriverHandle) -> Result<(), DriverError>:
    return Result.Ok(())

fn gpu_drv_ioctl(h: DriverHandle, cmd: IoctlCmd) -> Result<i64, DriverError>:
    return Result.Err(DriverError.NotSupported)

fn register_gpu_driver() -> Result<i32, DriverError>:
    val m: DriverManifest = DriverManifest.for_driver(
        "gpu_stub", "0.1", DriverClass.Gpu, 0, [])
    val ops: DriverOps = DriverOps(
        self_ptr: 0,
        manifest_abi: gpu_abi_rev,
        init_fn:   gpu_drv_init,
        probe_fn:  gpu_drv_probe,
        attach_fn: gpu_drv_attach,
        detach_fn: gpu_drv_detach,
        suspend_fn: gpu_drv_suspend,
        resume_fn:  gpu_drv_resume,
        ioctl_fn:   gpu_drv_ioctl,
    )
    return register_static_driver(m, ops)
