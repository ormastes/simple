#![allow(export_outside_init)]

extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

use nogc_sync_mut.path.{normalize_path, is_absolute_path, join_path}

fn shell_output_trim(command: text) -> text:
    val result = rt_process_run("/bin/sh", ["-c", command])
    val stdout = result[0]
    val code = result[2]
    if code == 0:
        stdout.trim()
    else:
        ""

fn is_windows_env() -> bool:
    val os_env = rt_env_get("OS")
    if os_env == nil:
        false
    else:
        os_env.lower().contains("windows")

fn get_host_os() -> text:
    if is_windows_env():
        "windows"
    else:
        val os = shell_output_trim("uname -s")
        if os.len() == 0:
            "linux"
        else:
            match os:
                case "Linux": "linux"
                case "Darwin": "macos"
                case "FreeBSD": "freebsd"
                case "OpenBSD": "openbsd"
                case "NetBSD": "netbsd"
                case _: os.lower()

fn get_host_arch() -> text:
    if is_windows_env():
        val arch_env = rt_env_get("PROCESSOR_ARCHITECTURE")
        if arch_env == nil:
            "x86_64"
        else:
            match arch_env:
                case "AMD64": "x86_64"
                case "ARM64": "aarch64"
                case "x86": "i686"
                case _: arch_env.lower()
    else:
        val arch = shell_output_trim("uname -m")
        if arch.len() == 0:
            "x86_64"
        else:
            match arch:
                case "x86_64": "x86_64"
                case "amd64": "x86_64"
                case "arm64": "aarch64"
                case "aarch64": "aarch64"
                case "riscv64": "riscv64"
                case "i686": "i686"
                case "i386": "i686"
                case _: arch

fn is_windows() -> bool:
    get_host_os() == "windows"

fn is_unix() -> bool:
    val os = get_host_os()
    os == "linux" or os == "macos" or os == "freebsd" or os == "openbsd" or os == "netbsd"

fn is_macos() -> bool:
    get_host_os() == "macos"

fn is_linux() -> bool:
    get_host_os() == "linux"

fn dir_sep() -> text:
    if is_windows():
        "\\"
    else:
        "/"

fn path_sep() -> text:
    if is_windows():
        ";"
    else:
        ":"

fn exe_ext() -> text:
    if is_windows():
        ".exe"
    else:
        ""

fn lib_ext() -> text:
    if is_macos():
        ".dylib"
    elif is_windows():
        ".dll"
    else:
        ".so"

