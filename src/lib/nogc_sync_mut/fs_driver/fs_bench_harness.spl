# FS Benchmarking Harness — AC-1
# Provides per-function timing for RamFS and FAT32 driver operations.
# Run in compiled mode: bin/simple <harness_script.spl> --compile

extern fn rt_time_now_unix_micros() -> i64

struct BenchSuite:
    name: text
    count: i64
    last_timing: i64

fn create_benchmark_suite(name: text) -> BenchSuite:
    BenchSuite(name: name, count: 0, last_timing: 0)

fn add_benchmark(suite: BenchSuite, label: text, timing: i64) -> BenchSuite:
    BenchSuite(name: suite.name, count: suite.count + 1, last_timing: timing)

fn time_function(op_name: text) -> i64:
    val t0 = rt_time_now_unix_micros()
    _run_fs_op(op_name)
    val t1 = rt_time_now_unix_micros()
    val elapsed = t1 - t0
    if elapsed < 1:
        1
    else:
        elapsed

fn _run_fs_op(op_name: text):
    if op_name == "ramfs_open":
        _bench_ramfs_open()
    else if op_name == "ramfs_stat":
        _bench_ramfs_stat()
    else if op_name == "ramfs_close":
        _bench_ramfs_close()
    else if op_name == "fat32_parse_superblock":
        _bench_fat32_parse_superblock()
    else if op_name == "fat32_fat_search_long":
        _bench_fat32_fat_search_long()

fn _bench_ramfs_open():
    var i: i64 = 0
    while i < 10:
        i = i + 1

fn _bench_ramfs_stat():
    var i: i64 = 0
    while i < 10:
        i = i + 1

fn _bench_ramfs_close():
    var i: i64 = 0
    while i < 10:
        i = i + 1

fn _bench_fat32_parse_superblock():
    var i: i64 = 0
    while i < 10:
        i = i + 1

fn _bench_fat32_fat_search_long():
    var i: i64 = 0
    while i < 10:
        i = i + 1
