# FAT32 — directory mutation operations (create_file, mkdir, unlink, rename).
#
# Free-function helpers that implement the body of Fat32Core directory-mutation
# methods.  Fat32Core.{create_file,mkdir,unlink,rename} delegate here to keep
# fat32_core.spl under the 800-line limit.

use common.string_core.{str_char_at}
use std.fs_driver.types.{FileHandle, DirEntry, Inode}
use std.fs_driver.fat32_core.{
    Fat32Core, OpenFile,
    FAT32_FREE, FAT32_EOC, FAT32_DIR_ENTRY_SIZE,
    FAT32_ATTR_DIRECTORY, FAT32_ATTR_LONG_NAME
}
use std.fs_driver.fat32_parsers.{_read_u16_le, _read_u32_le, _parse_short_name, _split_path}

fn fat32_create_file(core: Fat32Core, path: text) -> Result<FileHandle, text>:
    if not core.mounted:
        return Result.Err("filesystem not mounted")
    val parts = _split_path(path)
    if parts.len() == 0:
        return Result.Err("invalid path")
    var dir_cluster = core.root_cluster
    var pi = 0
    while pi < parts.len() - 1:
        val part = parts[pi]
        if part == "":
            pi = pi + 1
            continue
        val entry_rc = core.find_entry_in_dir(dir_cluster, part)
        if entry_rc.is_err():
            return Result.Err(entry_rc.unwrap_err())
        val entry = entry_rc.unwrap()
        if not entry.is_dir:
            return Result.Err("not a directory in path")
        dir_cluster = entry.inode.id.to_u32()
        pi = pi + 1
    val name = parts[parts.len() - 1]
    val alloc_rc = core.alloc_cluster()
    if alloc_rc.is_err():
        return Result.Err(alloc_rc.unwrap_err())
    val new_cluster = alloc_rc.unwrap()
    val dir_rc = core.read_cluster(dir_cluster)
    if dir_rc.is_err():
        return Result.Err(dir_rc.unwrap_err())
    var dir_data = dir_rc.unwrap()
    val epc = (core.bytes_per_sector * core.sectors_per_cluster) / FAT32_DIR_ENTRY_SIZE
    var ei: u32 = 0
    var slot_off: i32 = -1
    while ei < epc:
        val off = (ei * FAT32_DIR_ENTRY_SIZE).to_i32()
        val fb = dir_data[off]
        if fb == 0x00 or fb == 0xE5:
            slot_off = off
            ei = epc
        ei = ei + 1
    if slot_off < 0:
        return Result.Err("directory full")
    var ni = 0
    while ni < 11:
        dir_data[slot_off + ni] = 0x20
        ni = ni + 1
    var ci = 0
    while ci < name.len() and ci < 8:
        val ch = str_char_at(name, ci)
        var b: u8 = ch.len().to_u8()
        dir_data[slot_off + ci] = b
        ci = ci + 1
    dir_data[slot_off + 11] = 0x20
    dir_data[slot_off + 20] = ((new_cluster >> 16) & 0xFF).to_u8()
    dir_data[slot_off + 21] = ((new_cluster >> 24) & 0xFF).to_u8()
    dir_data[slot_off + 26] = (new_cluster & 0xFF).to_u8()
    dir_data[slot_off + 27] = ((new_cluster >> 8) & 0xFF).to_u8()
    dir_data[slot_off + 28] = 0
    dir_data[slot_off + 29] = 0
    dir_data[slot_off + 30] = 0
    dir_data[slot_off + 31] = 0
    val wrc = core.write_cluster(dir_cluster, dir_data)
    if wrc.is_err():
        return Result.Err(wrc.unwrap_err())
    core.invalidate_path_prefix(path)
    val handle = core.alloc_file_handle(new_cluster, 0, false)
    Result.Ok(handle)

fn fat32_mkdir(core: Fat32Core, path: text) -> Result<(), text>:
    if not core.mounted:
        return Result.Err("filesystem not mounted")
    val parts = _split_path(path)
    if parts.len() == 0:
        return Result.Err("invalid path")
    var dir_cluster = core.root_cluster
    var pi = 0
    while pi < parts.len() - 1:
        val part = parts[pi]
        if part == "":
            pi = pi + 1
            continue
        val entry_rc = core.find_entry_in_dir(dir_cluster, part)
        if entry_rc.is_err():
            return Result.Err(entry_rc.unwrap_err())
        val entry = entry_rc.unwrap()
        if not entry.is_dir:
            return Result.Err("not a directory in path")
        dir_cluster = entry.inode.id.to_u32()
        pi = pi + 1
    val name = parts[parts.len() - 1]
    val alloc_rc = core.alloc_cluster()
    if alloc_rc.is_err():
        return Result.Err(alloc_rc.unwrap_err())
    val new_cluster = alloc_rc.unwrap()
    val dir_rc = core.read_cluster(dir_cluster)
    if dir_rc.is_err():
        return Result.Err(dir_rc.unwrap_err())
    var dir_data = dir_rc.unwrap()
    val epc = (core.bytes_per_sector * core.sectors_per_cluster) / FAT32_DIR_ENTRY_SIZE
    var ei: u32 = 0
    var slot_off: i32 = -1
    while ei < epc:
        val off = (ei * FAT32_DIR_ENTRY_SIZE).to_i32()
        val fb = dir_data[off]
        if fb == 0x00 or fb == 0xE5:
            slot_off = off
            ei = epc
        ei = ei + 1
    if slot_off < 0:
        return Result.Err("directory full")
    var ni = 0
    while ni < 11:
        dir_data[slot_off + ni] = 0x20
        ni = ni + 1
    var ci = 0
    while ci < name.len() and ci < 8:
        val ch = str_char_at(name, ci)
        var b: u8 = ch.len().to_u8()
        dir_data[slot_off + ci] = b
        ci = ci + 1
    dir_data[slot_off + 11] = FAT32_ATTR_DIRECTORY
    dir_data[slot_off + 20] = ((new_cluster >> 16) & 0xFF).to_u8()
    dir_data[slot_off + 21] = ((new_cluster >> 24) & 0xFF).to_u8()
    dir_data[slot_off + 26] = (new_cluster & 0xFF).to_u8()
    dir_data[slot_off + 27] = ((new_cluster >> 8) & 0xFF).to_u8()
    dir_data[slot_off + 28] = 0
    dir_data[slot_off + 29] = 0
    dir_data[slot_off + 30] = 0
    dir_data[slot_off + 31] = 0
    val wrc = core.write_cluster(dir_cluster, dir_data)
    if wrc.is_err():
        return Result.Err(wrc.unwrap_err())
    core.invalidate_path_prefix(path)
    Result.Ok(())

fn fat32_unlink(core: Fat32Core, path: text) -> Result<(), text>:
    if not core.mounted:
        return Result.Err("filesystem not mounted")
    val parts = _split_path(path)
    if parts.len() == 0:
        return Result.Err("invalid path")
    var dir_cluster = core.root_cluster
    var pi = 0
    while pi < parts.len() - 1:
        val part = parts[pi]
        if part == "":
            pi = pi + 1
            continue
        val entry_rc = core.find_entry_in_dir(dir_cluster, part)
        if entry_rc.is_err():
            return Result.Err(entry_rc.unwrap_err())
        val entry = entry_rc.unwrap()
        if not entry.is_dir:
            return Result.Err("not a directory in path")
        dir_cluster = entry.inode.id.to_u32()
        pi = pi + 1
    val target = parts[parts.len() - 1]
    val chain_rc = core.follow_chain(dir_cluster)
    if chain_rc.is_err():
        return Result.Err(chain_rc.unwrap_err())
    val chain = chain_rc.unwrap()
    var ci = 0
    while ci < chain.len():
        val cdata_rc = core.read_cluster(chain[ci])
        if cdata_rc.is_err():
            return Result.Err(cdata_rc.unwrap_err())
        var cdata = cdata_rc.unwrap()
        val epc = (core.bytes_per_sector * core.sectors_per_cluster) / FAT32_DIR_ENTRY_SIZE
        var ei: u32 = 0
        while ei < epc:
            val off = (ei * FAT32_DIR_ENTRY_SIZE).to_i32()
            val fb = cdata[off]
            if fb == 0x00:
                return Result.Err("file not found")
            if fb == 0xE5 or cdata[off + 11] == FAT32_ATTR_LONG_NAME:
                ei = ei + 1
                continue
            val ename = _parse_short_name(cdata, off)
            if ename == target:
                val hi = _read_u16_le(cdata, off + 20).to_u32()
                val lo = _read_u16_le(cdata, off + 26).to_u32()
                val file_cluster = (hi << 16) | lo
                cdata[off] = 0xE5
                val wrc = core.write_cluster(chain[ci], cdata)
                if wrc.is_err():
                    return Result.Err(wrc.unwrap_err())
                if file_cluster >= 2:
                    core.invalidate_chain(file_cluster)
                    val fchain_rc = core.follow_chain(file_cluster)
                    if fchain_rc.is_ok():
                        val fchain = fchain_rc.unwrap()
                        var fi = 0
                        while fi < fchain.len():
                            val free_rc = core.write_fat_entry(fchain[fi], FAT32_FREE)
                            fi = fi + 1
                    core.invalidate_chain(file_cluster)
                core.invalidate_path_prefix(path)
                return Result.Ok(())
            ei = ei + 1
        ci = ci + 1
    Result.Err("file not found")

fn fat32_rename(core: Fat32Core, old_path: text, new_path: text) -> Result<(), text>:
    if not core.mounted:
        return Result.Err("filesystem not mounted")
    val old_parts = _split_path(old_path)
    if old_parts.len() == 0:
        return Result.Err("invalid old path")
    val new_parts = _split_path(new_path)
    if new_parts.len() == 0:
        return Result.Err("invalid new path")
    var old_dir_cluster = core.root_cluster
    var pi = 0
    while pi < old_parts.len() - 1:
        val part = old_parts[pi]
        if part == "":
            pi = pi + 1
            continue
        val entry_rc = core.find_entry_in_dir(old_dir_cluster, part)
        if entry_rc.is_err():
            return Result.Err(entry_rc.unwrap_err())
        old_dir_cluster = entry_rc.unwrap().inode.id.to_u32()
        pi = pi + 1
    val old_name = old_parts[old_parts.len() - 1]
    var new_dir_cluster = core.root_cluster
    pi = 0
    while pi < new_parts.len() - 1:
        val part = new_parts[pi]
        if part == "":
            pi = pi + 1
            continue
        val entry_rc = core.find_entry_in_dir(new_dir_cluster, part)
        if entry_rc.is_err():
            return Result.Err(entry_rc.unwrap_err())
        new_dir_cluster = entry_rc.unwrap().inode.id.to_u32()
        pi = pi + 1
    val new_name = new_parts[new_parts.len() - 1]
    val old_chain_rc = core.follow_chain(old_dir_cluster)
    if old_chain_rc.is_err():
        return Result.Err(old_chain_rc.unwrap_err())
    val old_chain = old_chain_rc.unwrap()
    var old_ci = 0
    var found_cluster: u32 = 0
    var found_size: u32 = 0
    var found_attr: u8 = 0
    var found: bool = false
    while old_ci < old_chain.len() and not found:
        val cdata_rc = core.read_cluster(old_chain[old_ci])
        if cdata_rc.is_err():
            return Result.Err(cdata_rc.unwrap_err())
        var cdata = cdata_rc.unwrap()
        val epc = (core.bytes_per_sector * core.sectors_per_cluster) / FAT32_DIR_ENTRY_SIZE
        var ei: u32 = 0
        while ei < epc:
            val off = (ei * FAT32_DIR_ENTRY_SIZE).to_i32()
            val fb = cdata[off]
            if fb == 0x00:
                ei = epc
                old_ci = old_chain.len()
                continue
            if fb == 0xE5 or cdata[off + 11] == FAT32_ATTR_LONG_NAME:
                ei = ei + 1
                continue
            val ename = _parse_short_name(cdata, off)
            if ename == old_name:
                val hi = _read_u16_le(cdata, off + 20).to_u32()
                val lo = _read_u16_le(cdata, off + 26).to_u32()
                found_cluster = (hi << 16) | lo
                found_size = _read_u32_le(cdata, off + 28)
                found_attr = cdata[off + 11]
                cdata[off] = 0xE5
                val wrc = core.write_cluster(old_chain[old_ci], cdata)
                if wrc.is_err():
                    return Result.Err(wrc.unwrap_err())
                found = true
                ei = epc
            else:
                ei = ei + 1
        old_ci = old_ci + 1
    if not found:
        return Result.Err("file not found")
    val new_chain_rc = core.follow_chain(new_dir_cluster)
    if new_chain_rc.is_err():
        return Result.Err(new_chain_rc.unwrap_err())
    val new_chain = new_chain_rc.unwrap()
    var new_ci = 0
    var placed: bool = false
    while new_ci < new_chain.len() and not placed:
        val cdata_rc = core.read_cluster(new_chain[new_ci])
        if cdata_rc.is_err():
            return Result.Err(cdata_rc.unwrap_err())
        var cdata = cdata_rc.unwrap()
        val epc = (core.bytes_per_sector * core.sectors_per_cluster) / FAT32_DIR_ENTRY_SIZE
        var ei: u32 = 0
        while ei < epc:
            val off = (ei * FAT32_DIR_ENTRY_SIZE).to_i32()
            val fb = cdata[off]
            if fb == 0x00 or fb == 0xE5:
                var ni = 0
                while ni < 11:
                    cdata[off + ni] = 0x20
                    ni = ni + 1
                var nci = 0
                while nci < new_name.len() and nci < 8:
                    val ch = str_char_at(new_name, nci)
                    cdata[off + nci] = ch.len().to_u8()
                    nci = nci + 1
                cdata[off + 11] = found_attr
                cdata[off + 20] = ((found_cluster >> 16) & 0xFF).to_u8()
                cdata[off + 21] = ((found_cluster >> 24) & 0xFF).to_u8()
                cdata[off + 26] = (found_cluster & 0xFF).to_u8()
                cdata[off + 27] = ((found_cluster >> 8) & 0xFF).to_u8()
                cdata[off + 28] = (found_size & 0xFF).to_u8()
                cdata[off + 29] = ((found_size >> 8) & 0xFF).to_u8()
                cdata[off + 30] = ((found_size >> 16) & 0xFF).to_u8()
                cdata[off + 31] = ((found_size >> 24) & 0xFF).to_u8()
                val wrc = core.write_cluster(new_chain[new_ci], cdata)
                if wrc.is_err():
                    return Result.Err(wrc.unwrap_err())
                placed = true
                ei = epc
            else:
                ei = ei + 1
        new_ci = new_ci + 1
    if not placed:
        return Result.Err("destination directory full")
    core.invalidate_path_prefix(old_path)
    core.invalidate_path_prefix(new_path)
    Result.Ok(())
