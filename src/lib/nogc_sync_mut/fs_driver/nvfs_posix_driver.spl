#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Stdlib-owned NVFS POSIX-compatible mount-table driver.
#
# Backed by DbFsDriver for hosted operation; the type exists in stdlib so VFS
# and mount-table code do not depend on examples/nvfs implementation modules.

use std.db.dbfs_driver.dbfs_driver.{DbFsDriver}
use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, DirHandle, Inode, Path, OpenFlags, MountOptions, FileStat, DirEntry, StatInfo}
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.fs_driver.extension.{Extension, PosixCompatExt}
use std.fs_driver.nvfs_arena.{arena_create_nvme_impl, arena_append_impl, nvfs_arena_has_block_device}

struct NvfsPosixFileRecord:
    path: text
    content: [u8]

struct NvfsPosixOpenRecord:
    inst_id: i64
    handle_id: u64
    path: text

var _nvfs_posix_files: [NvfsPosixFileRecord] = []
var _nvfs_posix_open: [NvfsPosixOpenRecord] = []
var _nvfs_posix_next_inst: i64 = 1
var _nvfs_posix_next_nvme_block: i64 = 64
val _NVFS_POSIX_BLOCKS_PER_FILE: i64 = 32

struct NvfsPosixDriver:
    name: text
    inst_id: i64
    inner: DbFsDriver

impl NvfsPosixDriver:
    static fn new(name: text) -> NvfsPosixDriver:
        val inst_id = _nvfs_posix_alloc_inst_id()
        NvfsPosixDriver(name: name, inst_id: inst_id, inner: DbFsDriver.new_hosted())

    fn mount(opts: MountOptions) -> Result<(), FsError>:
        val _ = opts
        Ok(())

    fn remount(opts: MountOptions) -> Result<(), FsError>:
        val _ = opts
        Ok(())

    fn unmount() -> Result<(), FsError>:
        Ok(())

    fn root() -> Result<Inode, FsError>:
        Ok(Inode(id: 1))

    fn stat_path(path: Path) -> Result<StatInfo, FsError>:
        self._ensure_persisted_path(path.raw)?
        self.inner.stat_path(path)

    fn stat(path: Path) -> Result<StatInfo, FsError>:
        self.stat_path(path)

    fn open_path(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        self._ensure_persisted_path(path.raw)?
        val had_persisted_record = _nvfs_posix_file_index(path.raw) >= 0
        val handle = self.inner.open_path(path, flags)?
        if not had_persisted_record:
            _nvfs_posix_store_file(path.raw, [])
        _nvfs_posix_track_open(self.inst_id, handle.id as u64, path.raw)
        Ok(handle)

    fn open(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        self.open_path(path, flags)

    fn opendir_path(path: Path) -> Result<DirHandle, FsError>:
        self.inner.opendir_path(path)

    fn opendir(path: Path) -> Result<DirHandle, FsError>:
        self.opendir_path(path)

    fn readdir_handle(handle: DirHandle) -> Result<[DirEntry], FsError>:
        val entries = self.inner.readdir_handle(handle)?
        var out: [DirEntry] = []
        for entry in entries:
            out.push(DirEntry(
                name: _nvfs_posix_entry_name(entry.name),
                inode: entry.inode,
                is_dir: entry.is_dir,
                size: entry.size
            ))
        Ok(out)

    fn readdir(handle: DirHandle) -> Result<[DirEntry], FsError>:
        self.readdir_handle(handle)

    fn read_handle(handle: FileHandle, length: i64) -> Result<text, FsError>:
        self.inner.read_handle(handle, length)

    fn read(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if offset != 0:
            return Err(FsError.Unsupported)
        val data_r = self.inner.read_bytes_handle(handle, buf.len() as i64)
        if data_r.is_err():
            return Err(data_r.unwrap_err())
        val data = data_r.unwrap()
        var i: i64 = 0
        while i < data.len() as i64 and i < buf.len() as i64:
            buf[i as i32] = data[i as i32]
            i = i + 1
        Ok(i)

    fn pread(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        self.read(handle, offset, buf)

    fn mkdir_path(path: text, mode: u32) -> Result<(), FsError>:
        self.inner.mkdir_path(path, mode)

    fn mkdir(path: Path, mode: u32) -> Result<(), FsError>:
        self.mkdir_path(path.raw, mode)

    fn write_handle(handle: FileHandle, content: text) -> Result<(), FsError>:
        self.inner.write_handle(handle, content)

    fn write(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if offset != 0:
            return Err(FsError.Unsupported)
        val r = self.inner.write_bytes_handle(handle, buf)
        if r.is_err():
            return Err(r.unwrap_err())
        val path = _nvfs_posix_path_for_handle(self.inst_id, handle.id as u64)
        if path != "":
            _nvfs_posix_store_file(path, _nvfs_posix_slice_bytes(buf, buf.len() as i64))
            _nvfs_posix_mirror_to_nvme(buf)
        Ok(buf.len() as i64)

    fn pwrite_handle(handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
        self.inner.pwrite_handle(handle, patch, offset)

    fn pwrite(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        var patch = ""
        var i: i64 = 0
        while i < buf.len() as i64:
            patch = patch + buf[i as i32].chr()
            i = i + 1
        self.inner.pwrite_handle(handle, patch, offset)?
        val path = _nvfs_posix_path_for_handle(self.inst_id, handle.id as u64)
        if path != "":
            val merged = _nvfs_posix_merge_patch(_nvfs_posix_load_file(path), offset, buf)
            _nvfs_posix_store_file(path, merged)
        Ok(buf.len() as i64)

    fn pread_handle(handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
        self.inner.pread_handle(handle, offset, length)

    fn close_handle(handle: FileHandle) -> Result<(), FsError>:
        _nvfs_posix_untrack_open(self.inst_id, handle.id as u64)
        self.inner.close_handle(handle)

    fn close(handle: FileHandle) -> Result<(), FsError>:
        self.close_handle(handle)

    fn unlink_path(path: text) -> Result<(), FsError>:
        _nvfs_posix_remove_file(path)
        self.inner.unlink_path(path)

    fn unlink(path: Path) -> Result<(), FsError>:
        self.unlink_path(path.raw)

    fn rename_path(old_path: text, new_path: text) -> Result<(), FsError>:
        val persisted = _nvfs_posix_load_file(old_path)
        val had_persisted_record = _nvfs_posix_file_index(old_path) >= 0
        self.inner.rename_path(old_path, new_path)?
        if had_persisted_record:
            _nvfs_posix_remove_file(old_path)
            _nvfs_posix_store_file(new_path, persisted)
        _nvfs_posix_retarget_open_paths(self.inst_id, old_path, new_path)
        Ok(())

    fn rename(old_path: Path, new_path: Path) -> Result<(), FsError>:
        self.rename_path(old_path.raw, new_path.raw)

    fn ftruncate_handle(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        val path = _nvfs_posix_path_for_handle(self.inst_id, handle.id as u64)
        self.inner.ftruncate_handle(handle, new_size)?
        if path != "":
            _nvfs_posix_store_file(path, _nvfs_posix_truncate_bytes(_nvfs_posix_load_file(path), new_size))
        Ok(())

    fn ftruncate(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        self.ftruncate_handle(handle, new_size)

    fn fstat(handle: FileHandle) -> Result<FileStat, FsError>:
        val bytes = self.inner.read_bytes_handle(handle, 1000000)?
        val size = bytes.len() as u64
        Ok(FileStat(
            inode: handle.id,
            size: size,
            blocks: (size + 4095u64) / 4096u64,
            block_size: 4096,
            mode: 0o644,
            uid: 0,
            gid: 0,
            nlinks: 1,
            atime_ns: 0u64,
            mtime_ns: 0u64,
            ctime_ns: 0u64,
            birth_time_ns: 0u64
        ))

    fn probe(cap: Capability) -> Option<Extension>:
        match cap:
            Capability.PosixCompat:
                Some(Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 0o644)))
            _:
                None

    fn capabilities() -> CapabilitySet:
        CapabilitySet.empty()
            .with(Capability.PosixCompat)
            .with(Capability.CaseSensitive)
            .with(Capability.Hardlinks)
            .with(Capability.SparseFiles)
            .with(Capability.LargeFiles)
            .with(Capability.UnicodeNames)
            .with(Capability.AsyncIo)

    fn _ensure_persisted_path(path: text) -> Result<(), FsError>:
        val content = _nvfs_posix_load_file(path)
        if content.len() == 0:
            if _nvfs_posix_file_index(path) < 0:
                return Ok(())
        if self.inner.stat_path(Path(raw: path)).is_ok():
            return Ok(())
        val handle = self.inner.open_path(Path(raw: path), OpenFlags.write_only().with_create())?
        val _ = self.inner.write_bytes_handle(handle, content)
        val _ = self.inner.close_handle(handle)
        Ok(())

fn _nvfs_posix_entry_name(path: text) -> text:
    var clean = path
    if clean.ends_with("/") and clean.len() > 1:
        clean = clean.slice(0, clean.len() - 1)
    val parts = clean.split("/")
    if parts.len() == 0:
        return clean
    val last = parts[parts.len() - 1]
    if last == "":
        return clean
    last

fn _nvfs_posix_alloc_inst_id() -> i64:
    val id = _nvfs_posix_next_inst
    _nvfs_posix_next_inst = _nvfs_posix_next_inst + 1
    id

fn _nvfs_posix_file_index(path: text) -> i32:
    var i: i32 = 0
    while i < _nvfs_posix_files.len() as i32:
        if _nvfs_posix_files[i].path == path:
            return i
        i = i + 1
    -1

fn _nvfs_posix_load_file(path: text) -> [u8]:
    val idx = _nvfs_posix_file_index(path)
    if idx < 0:
        return []
    _nvfs_posix_slice_bytes(_nvfs_posix_files[idx].content, _nvfs_posix_files[idx].content.len() as i64)

fn _nvfs_posix_store_file(path: text, content: [u8]):
    val record = NvfsPosixFileRecord(path: path, content: _nvfs_posix_slice_bytes(content, content.len() as i64))
    val idx = _nvfs_posix_file_index(path)
    if idx >= 0:
        _nvfs_posix_files.remove(idx)
    _nvfs_posix_files.push(record)

fn _nvfs_posix_remove_file(path: text):
    val idx = _nvfs_posix_file_index(path)
    if idx >= 0:
        _nvfs_posix_files.remove(idx)

fn _nvfs_posix_track_open(inst_id: i64, handle_id: u64, path: text):
    _nvfs_posix_open.push(NvfsPosixOpenRecord(inst_id: inst_id, handle_id: handle_id, path: path))

fn _nvfs_posix_untrack_open(inst_id: i64, handle_id: u64):
    var i: i32 = 0
    while i < _nvfs_posix_open.len() as i32:
        val rec = _nvfs_posix_open[i]
        if rec.inst_id == inst_id and rec.handle_id == handle_id:
            _nvfs_posix_open.remove(i)
            return
        i = i + 1

fn _nvfs_posix_path_for_handle(inst_id: i64, handle_id: u64) -> text:
    var i: i32 = 0
    while i < _nvfs_posix_open.len() as i32:
        val rec = _nvfs_posix_open[i]
        if rec.inst_id == inst_id and rec.handle_id == handle_id:
            return rec.path
        i = i + 1
    ""

fn _nvfs_posix_retarget_open_paths(inst_id: i64, old_path: text, new_path: text):
    var i: i32 = 0
    while i < _nvfs_posix_open.len() as i32:
        val rec = _nvfs_posix_open[i]
        if rec.inst_id == inst_id and rec.path == old_path:
            _nvfs_posix_open.remove(i)
            _nvfs_posix_open.push(NvfsPosixOpenRecord(inst_id: rec.inst_id, handle_id: rec.handle_id, path: new_path))
        else:
            i = i + 1

fn _nvfs_posix_slice_bytes(buf: [u8], count: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < count and i < buf.len() as i64:
        out.push(buf[i as i32])
        i = i + 1
    out

fn _nvfs_posix_merge_patch(base: [u8], offset: i64, patch: [u8]) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    val end = offset + patch.len() as i64
    val total = if end > base.len() as i64: end else: base.len() as i64
    while i < total:
        if i >= offset and i < end:
            out.push(patch[(i - offset) as i32])
        else:
            if i < base.len() as i64:
                out.push(base[i as i32])
            else:
                out.push(0u8)
        i = i + 1
    out

fn _nvfs_posix_truncate_bytes(base: [u8], new_size: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < new_size:
        if i < base.len() as i64:
            out.push(base[i as i32])
        else:
            out.push(0u8)
        i = i + 1
    out

fn _nvfs_posix_mirror_to_nvme(buf: [u8]):
    if not nvfs_arena_has_block_device():
        return
    val base = _nvfs_posix_next_nvme_block
    _nvfs_posix_next_nvme_block = _nvfs_posix_next_nvme_block + _NVFS_POSIX_BLOCKS_PER_FILE
    val arena_id = arena_create_nvme_impl(0, 4096, base, _NVFS_POSIX_BLOCKS_PER_FILE)
    if arena_id <= 0:
        return
    val _ = arena_append_impl(arena_id, buf, 0)
