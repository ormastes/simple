# Pure Simple byte-buffer utilities
# Replaces C externs rt_bytes_alloc and rt_text_to_bytes used in NVFS.

fn alloc_zeroed_bytes(len: i64) -> [u8]:
    var buf: [u8] = []
    var i: i64 = 0
    while i < len:
        buf = buf.push(0u8)
        i = i + 1
    buf

fn text_to_bytes_pure(s: text) -> [u8]:
    var buf: [u8] = []
    var i: i64 = 0
    while i < s.len():
        buf = buf.push(s[i] as u8)
        i = i + 1
    buf
