# FsFat32Driver — FsDriver wrapper over the stdlib-local FAT32 core.
#
# This module keeps the public fs_driver surface stable while the FAT32
# implementation lives under stdlib-local fs_driver modules instead of
# os.services.

use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, DirHandle, Inode, Path, OpenFlags, MountOptions, FsStatfs, FileStat, DirEntry, StatInfo}
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.fs_driver.extension.{Extension, DirectIoExt}
use std.fs_driver.direct_io.{DirectIoExtent}
use std.fs_driver.ops.{FsDriver}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core, OpenFile}
use common.string_core.{char_from_code}

struct FsFat32Driver:
    name:    text
    inner:   Fat32Core
    mounted: bool
    direct_io: Option<DirectIoExt>

impl FsFat32Driver:
    static fn new(name: text, device: BlockDevice) -> FsFat32Driver:
        FsFat32Driver(
            name: name,
            inner: Fat32Core.new(device),
            mounted: false,
            direct_io: None
        )

    static fn new_with_direct_io(name: text, device: BlockDevice, direct_io: DirectIoExt) -> FsFat32Driver:
        FsFat32Driver(
            name: name,
            inner: Fat32Core.new(device),
            mounted: false,
            direct_io: Some(direct_io)
        )

fn fat32_driver_new(name: text, device: BlockDevice) -> FsFat32Driver:
    FsFat32Driver(
        name: name,
        inner: Fat32Core.new(device),
        mounted: false,
        direct_io: None
    )

impl FsDriver for FsFat32Driver:
    me fn mount(opts: MountOptions) -> Result<(), FsError>:
        val rc = self.inner.mount()
        if rc.is_err():
            return Err(FsError.Corrupt)
        self.mounted = true
        Ok(())

    me fn unmount() -> Result<(), FsError>:
        val rc = self.inner.unmount()
        if rc.is_err():
            return Err(FsError.InvalidArg)
        self.mounted = false
        Ok(())

    me fn remount(opts: MountOptions) -> Result<(), FsError>:
        val u = self.unmount()
        if u.is_err():
            return u
        self.mount(opts)

    fn statfs() -> Result<FsStatfs, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val free_result = self.inner.count_free_clusters()
        if free_result.is_err():
            return Err(FsError.Corrupt)
        val cluster_bytes = (self.inner.sectors_per_cluster * self.inner.bytes_per_sector).to_u64()
        val total_bytes = self.inner.total_clusters.to_u64() * cluster_bytes
        val free_bytes = free_result.unwrap().to_u64() * cluster_bytes
        Ok(FsStatfs(
            total_bytes: total_bytes,
            free_bytes: free_bytes,
            avail_bytes: free_bytes,
            files_total: 0,
            files_free: 0,
            block_size: self.inner.bytes_per_sector
        ))

    fn root() -> Result<Inode, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        Ok(Inode(id: self.inner.root_cluster.to_u64()))

    me fn open(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val create_flag = (flags.bits & 64) != 0
        val path_str = path.raw
        val existing = self.inner.resolve_path(path_str)
        if existing.is_ok():
            val rc = self.inner.open(path_str)
            if rc.is_err():
                return Err(FsError.NotFound)
            return Ok(rc.unwrap())
        if create_flag:
            val rc = self.inner.create_file(path_str)
            if rc.is_err():
                return Err(FsError.NotFound)
            return Ok(rc.unwrap())
        Err(FsError.NotFound)

    me fn close(handle: FileHandle) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.close(handle)
        if rc.is_err():
            return Err(FsError.InvalidArg)
        Ok(())

    me fn read(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.read(handle, buf, buf.len().to_i64())
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(rc.unwrap())

    me fn write(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.write(handle, buf, buf.len().to_i64())
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(rc.unwrap())

    me fn pread(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.read(handle, buf, buf.len().to_i64())
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(rc.unwrap())

    me fn pwrite(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.write(handle, buf, buf.len().to_i64())
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(rc.unwrap())

    fn fstat(handle: FileHandle) -> Result<FileStat, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val of_rc = self.inner.get_open_file(handle)
        if of_rc.is_err():
            return Err(FsError.InvalidArg)
        val of = of_rc.unwrap()
        Ok(FileStat(
            inode: of.start_cluster.to_u64(),
            size: of.size.to_u64(),
            blocks: 0,
            block_size: self.inner.bytes_per_sector,
            mode: 0,
            uid: 0,
            gid: 0,
            nlinks: 1,
            atime_ns: 0,
            mtime_ns: 0,
            ctime_ns: 0,
            birth_time_ns: 0
        ))

    fn stat(path: Path) -> Result<FileStat, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val entry_rc = self.inner.resolve_path(path.raw)
        if entry_rc.is_err():
            return Err(FsError.NotFound)
        val entry = entry_rc.unwrap()
        Ok(FileStat(
            inode: entry.inode.id,
            size: 0,
            blocks: 0,
            block_size: self.inner.bytes_per_sector,
            mode: 0,
            uid: 0,
            gid: 0,
            nlinks: 1,
            atime_ns: 0,
            mtime_ns: 0,
            ctime_ns: 0,
            birth_time_ns: 0
        ))

    me fn opendir(path: Path) -> Result<DirHandle, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val entry_rc = self.inner.resolve_path(path.raw)
        if entry_rc.is_err():
            return Err(FsError.NotFound)
        val entry = entry_rc.unwrap()
        if not entry.is_dir:
            return Err(FsError.InvalidArg)
        Ok(DirHandle(id: entry.inode.id))

    fn truncate(path: Path, length: i64) -> Result<(), FsError>:
        Err(FsError.Unsupported)

    me fn ftruncate(handle: FileHandle, length: i64) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.truncate(handle, length)
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(())

    fn fsync(handle: FileHandle) -> Result<(), FsError>:
        Ok(())

    fn fdatasync(handle: FileHandle) -> Result<(), FsError>:
        Ok(())

    fn readdir(handle: DirHandle) -> Result<[DirEntry], FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val dir_cluster = handle.id.to_u32()
        val rc = self.inner.read_dir_entries(dir_cluster)
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(rc.unwrap())

    me fn mkdir(path: Path, mode: u32) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.mkdir(path.raw)
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(())

    me fn rmdir(path: Path) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.unlink(path.raw)
        if rc.is_err():
            return Err(FsError.NotFound)
        Ok(())

    me fn unlink(path: Path) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.unlink(path.raw)
        if rc.is_err():
            return Err(FsError.NotFound)
        Ok(())

    me fn rename(old: Path, new: Path) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.rename(old.raw, new.raw)
        if rc.is_err():
            return Err(FsError.NotFound)
        Ok(())

    fn symlink(target: Path, link: Path) -> Result<(), FsError>:
        Err(FsError.Unsupported)

    fn readlink(path: Path) -> Result<Path, FsError>:
        Err(FsError.Unsupported)

    fn link(target: Path, link: Path) -> Result<(), FsError>:
        Err(FsError.Unsupported)

    fn capabilities() -> CapabilitySet:
        var caps = CapabilitySet.empty()
            .with(Capability.CaseFold)
            .with(Capability.LargeFiles)
            .with(Capability.UnicodeNames)
        if self.direct_io.is_some():
            caps = caps.with(Capability.DirectIo)
        caps

    fn probe(cap: Capability) -> Option<Extension>:
        if cap == Capability.DirectIo:
            if self.direct_io.is_some():
                return Some(Extension.DirectIo(ext: self.direct_io.unwrap()))
        None

    fn direct_io_extent_for_handle(handle: FileHandle, file_offset: i64, byte_len: u64) -> Result<DirectIoExtent, FsError>:
        if self.direct_io.is_none():
            return Err(FsError.Unsupported)
        val extent = self.inner.direct_io_extent_for_handle(handle, file_offset, byte_len)
        if extent.is_err():
            return Err(FsError.InvalidArg)
        Ok(extent.unwrap())

    fn stat_path(path: Path) -> Result<StatInfo, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val entry_rc = self.inner.resolve_path(path.raw)
        if entry_rc.is_err():
            return Err(FsError.NotFound)
        val entry = entry_rc.unwrap()
        if entry.is_dir:
            return Ok(StatInfo(is_dir: true, is_file: false, size: 0))
        val size_rc = self.inner._get_file_size(path.raw)
        var sz: i64 = 0
        if size_rc.is_ok():
            sz = size_rc.unwrap()
        Ok(StatInfo(is_dir: false, is_file: true, size: sz))

    me fn open_path(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        self.open(path, flags)

    me fn opendir_path(path: Path) -> Result<DirHandle, FsError>:
        self.opendir(path)

    fn readdir_handle(handle: DirHandle) -> Result<[DirEntry], FsError>:
        self.readdir(handle)

    fn read_handle(handle: FileHandle, length: i64) -> Result<text, FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.read_bytes(handle, length)
        if rc.is_err():
            return Err(FsError.Corrupt)
        val bytes = rc.unwrap()
        var result = ""
        var i = 0
        while i < bytes.len():
            result = result + char_from_code(bytes[i].to_i64())
            i = i + 1
        Ok(result)

    me fn mkdir_path(path: text, mode: u32) -> Result<(), FsError>:
        if not self.mounted:
            return Err(FsError.InvalidArg)
        val rc = self.inner.mkdir(path)
        if rc.is_err():
            return Err(FsError.Corrupt)
        Ok(())

    static fn new_ram_backed() -> FsFat32Driver:
        """Create a RAM-backed (empty) FsFat32Driver for tests."""
        FsFat32Driver(
            name:    "Fat32Driver",
            inner:   Fat32Core.new(RamBlockDevice.new_empty()),
            mounted: false,
            direct_io: None
        )

    static fn new_ram_backed_with_file(filename: text, content: text) -> FsFat32Driver:
        """Create a RAM-backed FsFat32Driver pre-populated with one file."""
        FsFat32Driver(
            name:    "Fat32Driver",
            inner:   Fat32Core.new(RamBlockDevice.new_with_file(filename, content)),
            mounted: false,
            direct_io: None
        )

# --- RamBlockDevice — minimal in-memory block device for testing ---

var _ram_block_sectors: [RamSector] = []

struct RamSector:
    """One 512-byte sector in the RAM block device store."""
    lba:  u64
    data: [u8]

struct RamBlockDevice:
    """In-memory block device backed by a module-level sector store."""
    inst_id: i64
    files:   [RamFile]

struct RamFile:
    """A named file pre-loaded in the RAM block device (for test fixtures)."""
    name:    text
    content: text

var _ram_block_next_inst: i64 = 1

fn _ram_block_alloc_inst() -> i64:
    val id = _ram_block_next_inst
    _ram_block_next_inst = _ram_block_next_inst + 1
    id

impl RamBlockDevice:
    static fn new_empty() -> RamBlockDevice:
        """Create an empty RAM block device."""
        RamBlockDevice(inst_id: _ram_block_alloc_inst(), files: [])

    static fn new_with_file(filename: text, content: text) -> RamBlockDevice:
        """Create a RAM block device pre-loaded with one named file."""
        var files: [RamFile] = []
        files.push(RamFile(name: filename, content: content))
        RamBlockDevice(inst_id: _ram_block_alloc_inst(), files: files)

impl BlockDevice for RamBlockDevice:
    fn read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        """Return zeroed sector (or sector data if written)."""
        for s in _ram_block_sectors:
            if s.lba == lba:
                var i: i32 = 0
                while i < s.data.len() as i32 and i < buffer.len() as i32:
                    buffer[i] = s.data[i]
                    i = i + 1
                return Result.Ok(true)
        # Zero fill
        var j: i32 = 0
        while j < buffer.len() as i32:
            buffer[j] = 0
            j = j + 1
        Result.Ok(true)

    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write sector data to the module-level store."""
        var new_store: [RamSector] = []
        var found: bool = false
        for s in _ram_block_sectors:
            if s.lba == lba:
                new_store.push(RamSector(lba: lba, data: data))
                found = true
            else:
                new_store.push(s)
        if not found:
            new_store.push(RamSector(lba: lba, data: data))
        _ram_block_sectors = new_store
        Result.Ok(true)

    fn sector_size() -> u32:
        512

fn ram_block_peek_sector(lba: u64) -> [u8]:
    """Return the raw bytes stored for sector `lba` in the module-level RAM store.

    Used by tests to verify that writes actually landed in _ram_block_sectors
    without relying on the read_sector parameter-mutation path (value semantics
    in the interpreter mean buffer mutations inside read_sector don't propagate
    back to the caller's array).
    Returns an empty slice if the sector has not been written yet.
    """
    for s in _ram_block_sectors:
        if s.lba == lba:
            return s.data
    var empty: [u8] = []
    empty
