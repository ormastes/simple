# Capability — filesystem feature flags negotiated at mount time.
#
# Each capability is optional; drivers return a CapabilitySet from
# capabilities() for cheap pre-check, then callers call probe(cap) to
# obtain the concrete Extension handle.
#
# Source: doc/05_design/fs_driver_interface.md §5, §9.

enum Capability:
    """23-variant filesystem capability set.

    COW            — Copy-on-write writes; no in-place overwrite.
    Snapshot       — Point-in-time consistent snapshot of a volume.
    Clone          — Writable COW clone of a volume.
    Dedup          — Offline content-hash deduplication with extent sharing.
    Checksum       — Per-block checksum verification.
    SelfHeal       — Automatic repair via redundant copies on mismatch.
    SendReceive    — Incremental stream serialization for backup/replication.
    Compress       — Transparent per-file compression.
    Encrypt        — Transparent at-rest encryption.
    Quota          — Per-volume space quota and reservation.
    Reflink        — COW file-range clone (O(1) metadata op).
    Atime          — Full access-time tracking (not just access-date).
    Xattr          — Extended attributes.
    Acl            — POSIX ACLs.
    CaseFold       — Case-folding (case-insensitive) filename matching.
    Hardlinks      — Multiple directory entries pointing at same inode.
    SparseFiles    — Sparse files (holes map to zero, no physical block).
    LargeFiles     — Files larger than 4 GiB.
    UnicodeNames   — Full Unicode filename support (NFC normalization).
    CaseSensitive  — Case-sensitive filename matching.
    PosixCompat    — POSIX random-write/truncate emulation over NVFS arenas.
    AsyncIo        — Asynchronous I/O submission path supported.
    DirectIo       — Caller-owned DMA direct read/write extension supported.
    """
    COW
    Snapshot
    Clone
    Dedup
    Checksum
    SelfHeal
    SendReceive
    Compress
    Encrypt
    Quota
    Reflink
    Atime
    Xattr
    Acl
    CaseFold
    Hardlinks
    SparseFiles
    LargeFiles
    UnicodeNames
    CaseSensitive
    PosixCompat
    AsyncIo
    DirectIo

impl Capability:
    fn bit_index() -> u32:
        """Return the bit position of this capability in a CapabilitySet."""
        match self:
            case COW:           0
            case Snapshot:      1
            case Clone:         2
            case Dedup:         3
            case Checksum:      4
            case SelfHeal:      5
            case SendReceive:   6
            case Compress:      7
            case Encrypt:       8
            case Quota:         9
            case Reflink:       10
            case Atime:         11
            case Xattr:         12
            case Acl:           13
            case CaseFold:      14
            case Hardlinks:     15
            case SparseFiles:   16
            case LargeFiles:    17
            case UnicodeNames:  18
            case CaseSensitive: 19
            case PosixCompat:   20
            case AsyncIo:       21
            case DirectIo:      22

# CapabilitySet — u32 bitmask; 23 bits used, 9 reserved.

struct CapabilitySet:
    """Bitmask of supported filesystem capabilities.

    bits: u32 — bit N is set iff the capability with bit_index() == N is present.
    Use has(), with(), union() for safe manipulation.
    """
    bits: u32

impl CapabilitySet:
    static fn empty() -> CapabilitySet:
        CapabilitySet(bits: 0)

    static fn of(cap: Capability) -> CapabilitySet:
        CapabilitySet(bits: 1 << cap.bit_index())

    fn has(cap: Capability) -> bool:
        """Return true if this set includes cap."""
        (self.bits >> cap.bit_index()) & 1 == 1

    fn with(cap: Capability) -> CapabilitySet:
        """Return a new set with cap added."""
        CapabilitySet(bits: self.bits | (1 << cap.bit_index()))

    fn union(other: CapabilitySet) -> CapabilitySet:
        """Return the union of this set and other."""
        CapabilitySet(bits: self.bits | other.bits)

    fn intersect(other: CapabilitySet) -> CapabilitySet:
        """Return the intersection of this set and other."""
        CapabilitySet(bits: self.bits & other.bits)

    fn is_empty() -> bool:
        self.bits == 0
