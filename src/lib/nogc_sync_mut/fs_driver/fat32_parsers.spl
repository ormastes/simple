# FAT32 — 8.3 directory entry parsing helpers (module-level utilities).

use common.string_core.{str_char_at, char_from_code}

fn _to_lower_byte(b: u8) -> u8:
    if b >= 0x41 and b <= 0x5A:
        return b + 32
    b

fn _read_u32_le(buf: [u8], off: i32) -> u32:
    (buf[off + 3].to_u32() << 24) |
    (buf[off + 2].to_u32() << 16) |
    (buf[off + 1].to_u32() << 8) |
    buf[off].to_u32()

fn _read_u16_le(buf: [u8], off: i32) -> u16:
    (buf[off + 1].to_u16() << 8) | buf[off].to_u16()

fn _parse_short_name(entry: [u8], offset: i32) -> text:
    var name_parts: [u8] = []
    var i = 0
    while i < 8:
        val ch = entry[offset + i]
        if ch != 0x20:
            name_parts.push(ch)
        i = i + 1
    var ext_parts: [u8] = []
    i = 0
    while i < 3:
        val ch = entry[offset + 8 + i]
        if ch != 0x20:
            ext_parts.push(ch)
        i = i + 1
    var result = ""
    i = 0
    while i < name_parts.len():
        val lower = _to_lower_byte(name_parts[i])
        result = result + char_from_code(lower.to_i64())
        i = i + 1
    if ext_parts.len() > 0:
        result = result + "."
        i = 0
        while i < ext_parts.len():
            val lower = _to_lower_byte(ext_parts[i])
            result = result + char_from_code(lower.to_i64())
            i = i + 1
    result

fn _decode_lfn_code_unit(entry: [u8], offset: i32) -> text:
    val lo = entry[offset]
    val hi = entry[offset + 1]
    if hi == 0x00u8 and lo == 0x00u8:
        return ""
    if hi == 0xFFu8 and lo == 0xFFu8:
        return ""
    if hi != 0x00u8:
        return "?"
    char_from_code(lo.to_i64())

fn _parse_lfn_slot(entry: [u8], offset: i32) -> text:
    var name = ""
    val c1 = _decode_lfn_code_unit(entry, offset + 1)
    if c1 != "":
        name = name + c1
    val c2 = _decode_lfn_code_unit(entry, offset + 3)
    if c2 != "":
        name = name + c2
    val c3 = _decode_lfn_code_unit(entry, offset + 5)
    if c3 != "":
        name = name + c3
    val c4 = _decode_lfn_code_unit(entry, offset + 7)
    if c4 != "":
        name = name + c4
    val c5 = _decode_lfn_code_unit(entry, offset + 9)
    if c5 != "":
        name = name + c5
    val c6 = _decode_lfn_code_unit(entry, offset + 14)
    if c6 != "":
        name = name + c6
    val c7 = _decode_lfn_code_unit(entry, offset + 16)
    if c7 != "":
        name = name + c7
    val c8 = _decode_lfn_code_unit(entry, offset + 18)
    if c8 != "":
        name = name + c8
    val c9 = _decode_lfn_code_unit(entry, offset + 20)
    if c9 != "":
        name = name + c9
    val c10 = _decode_lfn_code_unit(entry, offset + 22)
    if c10 != "":
        name = name + c10
    val c11 = _decode_lfn_code_unit(entry, offset + 24)
    if c11 != "":
        name = name + c11
    val c12 = _decode_lfn_code_unit(entry, offset + 28)
    if c12 != "":
        name = name + c12
    val c13 = _decode_lfn_code_unit(entry, offset + 30)
    if c13 != "":
        name = name + c13
    name

fn _lower_text(s: text) -> text:
    var result = ""
    var i: i64 = 0
    while i < s.len():
        var b: u8 = s.char_at(i) as u8
        if b >= 0x41 and b <= 0x5A:
            b = b + 32
        result = result + char_from_code(b.to_i64())
        i = i + 1
    result

fn _split_path(path: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var i: i64 = 0
    while i < path.len():
        val ch = str_char_at(path, i)
        if ch == "/":
            if current != "":
                parts.push(current)
                current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        parts.push(current)
    parts
