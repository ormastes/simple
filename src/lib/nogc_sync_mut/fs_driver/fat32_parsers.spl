# FAT32 — 8.3 directory entry parsing helpers (module-level utilities).

use common.string_core.{str_char_at, char_from_code}

fn _to_lower_byte(b: u8) -> u8:
    if b >= 0x41 and b <= 0x5A:
        return b + 32
    b

fn _read_u32_le(buf: [u8], off: i32) -> u32:
    (buf[off + 3].to_u32() << 24) |
    (buf[off + 2].to_u32() << 16) |
    (buf[off + 1].to_u32() << 8) |
    buf[off].to_u32()

fn _read_u16_le(buf: [u8], off: i32) -> u16:
    (buf[off + 1].to_u16() << 8) | buf[off].to_u16()

fn _parse_short_name(entry: [u8], offset: i32) -> text:
    var name_parts: [u8] = []
    var i = 0
    while i < 8:
        val ch = entry[offset + i]
        if ch != 0x20:
            name_parts.push(ch)
        i = i + 1
    var ext_parts: [u8] = []
    i = 0
    while i < 3:
        val ch = entry[offset + 8 + i]
        if ch != 0x20:
            ext_parts.push(ch)
        i = i + 1
    var result = ""
    i = 0
    while i < name_parts.len():
        val lower = _to_lower_byte(name_parts[i])
        result = result + char_from_code(lower.to_i64())
        i = i + 1
    if ext_parts.len() > 0:
        result = result + "."
        i = 0
        while i < ext_parts.len():
            val lower = _to_lower_byte(ext_parts[i])
            result = result + char_from_code(lower.to_i64())
            i = i + 1
    result

fn _decode_lfn_code_unit(entry: [u8], offset: i32) -> text:
    val lo = entry[offset]
    val hi = entry[offset + 1]
    if hi == 0x00u8 and lo == 0x00u8:
        return ""
    if hi == 0xFFu8 and lo == 0xFFu8:
        return ""
    if hi != 0x00u8:
        return "?"
    char_from_code(lo.to_i64())

fn _parse_lfn_slot(entry: [u8], offset: i32) -> text:
    var name = ""
    val char_offsets: [i32] = [1, 3, 5, 7, 9, 14, 16, 18, 20, 22, 24, 28, 30]
    var i = 0
    while i < char_offsets.len():
        val ch = _decode_lfn_code_unit(entry, offset + char_offsets[i])
        if ch == "":
            return name
        name = name + ch
        i = i + 1
    name

fn _lfn_slot_metadata_valid(entry: [u8], offset: i32) -> bool:
    val sequence = entry[offset]
    val ordinal = sequence & 0x1Fu8
    if not (ordinal > 0u8 and ordinal <= 20u8 and
        (sequence & 0xA0u8) == 0u8 and
        entry[offset + 11] == 0x0Fu8 and
        entry[offset + 12] == 0u8 and
        entry[offset + 26] == 0u8 and
        entry[offset + 27] == 0u8):
        return false
    val allow_padding = (sequence & 0x40u8) != 0u8
    val char_offsets: [i32] = [1, 3, 5, 7, 9, 14, 16, 18, 20, 22, 24, 28, 30]
    var ended = false
    var has_character = false
    var i = 0
    while i < char_offsets.len():
        val char_offset = offset + char_offsets[i]
        val lo = entry[char_offset]
        val hi = entry[char_offset + 1]
        if ended:
            if lo != 0xFFu8 or hi != 0xFFu8:
                return false
        else:
            if lo == 0u8 and hi == 0u8:
                if not allow_padding:
                    return false
                ended = true
            else:
                if lo == 0xFFu8 and hi == 0xFFu8:
                    return false
                if (hi != 0u8 or lo < 0x20u8 or lo >= 0x7Fu8 or
                        lo == 0x22u8 or lo == 0x2Au8 or lo == 0x2Fu8 or
                        lo == 0x3Au8 or lo == 0x3Cu8 or lo == 0x3Eu8 or
                        lo == 0x3Fu8 or lo == 0x5Cu8 or lo == 0x7Cu8):
                    return false
                has_character = true
        i = i + 1
    has_character

fn _lfn_short_name_checksum(entry: [u8], offset: i32) -> u8:
    var sum: u32 = 0u32
    var i = 0
    while i < 11:
        val carry: u32 = if (sum & 1u32) != 0u32: 0x80u32 else: 0u32
        sum = (carry + (sum >> 1) + entry[offset + i].to_u32()) & 0xFFu32
        i = i + 1
    sum.to_u8()

fn _lower_text(s: text) -> text:
    var result = ""
    var i: i64 = 0
    while i < s.len():
        var b: u8 = s.char_at(i) as u8
        if b >= 0x41 and b <= 0x5A:
            b = b + 32
        result = result + char_from_code(b.to_i64())
        i = i + 1
    result

fn _split_path(path: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var i: i64 = 0
    while i < path.len():
        val ch = str_char_at(path, i)
        if ch == "/":
            if current != "":
                parts.push(current)
                current = ""
        else:
            current = current + ch
        i = i + 1
    if current != "":
        parts.push(current)
    parts
