# MountTable — tracks active filesystem mounts.
#
# MountEntry associates a mount point path with a DriverInstance.
# MountTable provides mount/unmount/lookup/resolve operations.
# Longest-prefix match is used for path resolution.
#
# Source: doc/05_design/fs_driver_interface.md §3, §8.

use std.fs_driver.types.{Path, MountOptions, StatInfo, FileHandle, DirHandle, DirEntry, OpenFlags}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.error.{FsError}
use std.fs_driver.capability.{CapabilitySet}
use common.string_core.{str_char_at}

struct MountId:
    """Opaque mount table index. Assigned sequentially; not reused after unmount."""
    id: u32

    static fn null() -> MountId:
        MountId(id: 0)

    fn is_null() -> bool:
        self.id == 0

struct MountEntry:
    """Single active mount.

    id           — unique mount table slot index.
    mount_point  — absolute path string at which this filesystem is mounted.
    driver       — concrete driver wrapped in DriverInstance.
    opts         — options negotiated at mount time.
    active_caps  — capabilities active after mount-time negotiation.
    """
    id:          MountId
    mount_point: text
    driver:      DriverInstance
    opts:        MountOptions
    active_caps: u32   # CapabilitySet.bits after negotiation

struct MountTable:
    """Registry of active mounts.

    mounts       — ordered list of MountEntry; lookup uses longest-prefix match.
    next_id      — next MountId to assign (monotonically increasing).

    Thread safety: callers are responsible for holding an appropriate lock
    before calling mutating methods (mount, unmount). Reads (lookup, resolve)
    may race only if the caller guarantees no concurrent mounts/unmounts.
    """
    mounts:  [MountEntry]
    next_id: u32

impl MountTable:
    static fn new() -> MountTable:
        MountTable(mounts: [], next_id: 1)

    me fn mount(path: text, driver: DriverInstance, opts: MountOptions) -> Result<MountId, FsError>:
        """Add a new mount at path.

        Fails with AlreadyExists if path is already a mount point.
        Assigns a fresh MountId and appends the entry.
        """
        for entry in self.mounts:
            if entry.mount_point == path:
                return Err(FsError.AlreadyExists)

        val id = MountId(id: self.next_id)
        self.next_id = self.next_id + 1
        val want = opts.want_caps
        val active = want   # full negotiation done in vfs_mount; stub passes through
        val entry = MountEntry(
            id: id,
            mount_point: path,
            driver: driver,
            opts: opts,
            active_caps: active
        )
        self.mounts.push(entry)
        Ok(id)

    me fn unmount(path: text) -> Result<(), FsError>:
        """Remove the mount at path.

        Fails with NotFound if no mount exists at exactly that path.
        Callers must ensure no open handles before calling unmount.
        """
        var idx: i64 = -1
        var i: i64 = 0
        while i < self.mounts.len() as i64:
            if self.mounts[i as i32].mount_point == path:
                idx = i
            i = i + 1
        if idx < 0:
            return Err(FsError.NotFound)
        self.mounts.remove(idx as i32)
        Ok(())

    fn lookup_text(path: text) -> MountEntry?:
        """Return the MountEntry whose mount_point is the longest prefix of path."""
        var best_len: i64 = -1
        var best_idx: i32 = -1
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val mp = self.mounts[i].mount_point
            if path.starts_with(mp):
                val mp_len = mp.len()
                if mp_len > best_len:
                    best_len = mp_len
                    best_idx = i
            i = i + 1
        if best_idx < 0:
            nil
        else:
            Some(self.mounts[best_idx])

    fn lookup(path: Path) -> MountEntry?:
        """Return the MountEntry whose mount_point is the longest prefix of path."""
        self.lookup_text(path.raw)

    fn resolve(path: Path) -> Result<(MountId, Path), FsError>:
        """Resolve path to (mount_id, relpath_within_mount).

        relpath is the suffix of path after stripping the mount point prefix.
        Fails with NotFound if no mount covers path.
        """
        val entry_opt = self.lookup_text(path.raw)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                val mp_len = entry.mount_point.len()
                # FR-STORAGE-0004: do NOT use path.raw.slice() — broken in baremetal
                # Cranelift codegen. Build relpath by indexed char-copy instead.
                var rel_raw: text = ""
                var ci: i64 = mp_len
                while ci < path.raw.len():
                    rel_raw = rel_raw + str_char_at(path.raw, ci)
                    ci = ci + 1
                val relpath = Path(raw: rel_raw)
                Ok((entry.id, relpath))

    fn resolve_driver(path: text) -> Result<DriverInstance, FsError>:
        """Return the DriverInstance whose mount point best covers path."""
        val entry_opt = self.lookup_text(path)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                Ok(entry.driver)

    fn stat(path: text) -> Result<StatInfo, FsError>:
        """Stat path via the appropriate mounted driver."""
        val resolved = self.resolve(Path(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.0
                val relpath = pair.1
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return self.mounts[i].driver.stat_path(relpath)
                    i = i + 1
                Err(FsError.NotFound)

    fn open(path: text, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Open path for I/O via the appropriate mounted driver."""
        val resolved = self.resolve(Path(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.0
                val relpath = pair.1
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return self.mounts[i].driver.open_path(relpath, flags)
                    i = i + 1
                Err(FsError.NotFound)

    fn opendir(path: text) -> Result<DirHandle, FsError>:
        """Open directory via the appropriate mounted driver."""
        val resolved = self.resolve(Path(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.0
                val relpath = pair.1
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return self.mounts[i].driver.opendir_path(relpath)
                    i = i + 1
                Err(FsError.NotFound)

    fn readdir(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """Read directory entries via the driver that owns the handle (probe each mount)."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.readdir_handle(handle)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn read(handle: FileHandle, length: i64) -> Result<text, FsError>:
        """Read up to length bytes; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.read_handle(handle, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn mkdir(path: text, mode: u32) -> Result<(), FsError>:
        """Create directory at path via the appropriate mounted driver."""
        val resolved = self.resolve(Path(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.0
                val relpath = pair.1
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return self.mounts[i].driver.mkdir_path(relpath.raw, mode)
                    i = i + 1
                Err(FsError.NotFound)

    fn block_device_for(path: text) -> Result<text, FsError>:
        """Return a text tag identifying the block device for the mount at path."""
        val entry_opt = self.lookup_text(path)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                Ok(entry.driver.driver_name())

    fn write(handle: FileHandle, content: text) -> Result<(), FsError>:
        """Write text content to an open file handle; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.write_text_handle(handle, content)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn pwrite(handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
        """Write text patch at offset; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.pwrite_text_handle(handle, patch, offset)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn pread(handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
        """Read length chars at offset; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.pread_text_handle(handle, offset, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn close(handle: FileHandle) -> Result<(), FsError>:
        """Close an open file handle; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.close_handle(handle)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn unlink(path: text) -> Result<(), FsError>:
        """Remove a file from the filesystem."""
        val resolved = self.resolve(Path(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.0
                val relpath = pair.1
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return self.mounts[i].driver.unlink_path_text(relpath.raw)
                    i = i + 1
                Err(FsError.NotFound)

    fn rename(old_path: text, new_path: text) -> Result<(), FsError>:
        """Rename a file or directory."""
        val old_resolved = self.resolve(Path(raw: old_path))
        match old_resolved:
            case Err(e):
                Err(e)
            case Ok(old_pair):
                val new_resolved = self.resolve(Path(raw: new_path))
                match new_resolved:
                    case Err(e):
                        Err(e)
                    case Ok(new_pair):
                        if old_pair.0.id != new_pair.0.id:
                            return Err(FsError.InvalidArg)
                        var i: i32 = 0
                        while i < self.mounts.len() as i32:
                            if self.mounts[i].id == old_pair.0:
                                return self.mounts[i].driver.rename_path_text(old_pair.1.raw, new_pair.1.raw)
                            i = i + 1
                        Err(FsError.NotFound)

    fn ftruncate(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        """Truncate or extend an open file; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.ftruncate_handle(handle, new_size)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn mmap_shared_writable(handle: FileHandle, offset: i64, length: i64) -> Result<(), FsError>:
        """Shared writable mmap — always returns ENOTSUP (probes all mounts)."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = self.mounts[i].driver.mmap_shared_writable_handle(handle, offset, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    fn link(target: text, link_path: text) -> Result<(), FsError>:
        """Hard link — always returns ENOTSUP; uses path-based resolution."""
        val entry_opt = self.lookup_text(target)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                entry.driver.link_path_text(target, link_path)
