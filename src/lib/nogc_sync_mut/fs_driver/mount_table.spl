# MountTable — tracks active filesystem mounts.
#
# MountEntry associates a mount point path with a DriverInstance.
# MountTable provides mount/unmount/lookup/resolve operations.
# Longest-prefix match is used for path resolution.
#
# Source: doc/05_design/fs_driver_interface.md §3, §8.

use std.fs_driver.types.{Path as FsPath, MountOptions, StatInfo, FileHandle, DirHandle, DirEntry, OpenFlags}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.error.{FsError}
use std.fs_driver.capability.{CapabilitySet}
use common.string_core.{str_char_at}

fn _text_has_prefix(source: text, prefix: text) -> bool:
    if prefix.len() > source.len():
        return false
    var idx: i64 = 0
    while idx < prefix.len():
        if str_char_at(source, idx) != str_char_at(prefix, idx):
            return false
        idx = idx + 1
    true

fn _driver_name(driver: DriverInstance) -> text:
    match driver:
        case DriverInstance.Fat32(d):     d.name
        case DriverInstance.Nvfs(d):      d.name
        case DriverInstance.NvfsPosix(d): d.name
        case DriverInstance.RamFs(d):     d.name
        case DriverInstance.DbFs(d):      d.name

fn _driver_stat_path(driver: DriverInstance, path: FsPath) -> Result<StatInfo, FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.stat_path(path)
        case DriverInstance.Nvfs(d):      d.stat_path(path)
        case DriverInstance.NvfsPosix(d): d.stat_path(path)
        case DriverInstance.RamFs(d):     d.stat_path(path)
        case DriverInstance.DbFs(d):      d.stat_path(path)

fn _driver_open_path(driver: DriverInstance, path: FsPath, flags: OpenFlags) -> Result<FileHandle, FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.open_path(path, flags)
        case DriverInstance.Nvfs(d):      d.open_path(path, flags)
        case DriverInstance.NvfsPosix(d): d.open_path(path, flags)
        case DriverInstance.RamFs(d):     d.open_path(path, flags)
        case DriverInstance.DbFs(d):      d.open_path(path, flags)

fn _driver_opendir_path(driver: DriverInstance, path: FsPath) -> Result<DirHandle, FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.opendir_path(path)
        case DriverInstance.Nvfs(d):      d.opendir_path(path)
        case DriverInstance.NvfsPosix(d): d.opendir_path(path)
        case DriverInstance.RamFs(d):     d.opendir_path(path)
        case DriverInstance.DbFs(d):      d.opendir_path(path)

fn _driver_readdir_handle(driver: DriverInstance, handle: DirHandle) -> Result<[DirEntry], FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.readdir_handle(handle)
        case DriverInstance.Nvfs(d):      d.readdir_handle(handle)
        case DriverInstance.NvfsPosix(d): d.readdir_handle(handle)
        case DriverInstance.RamFs(d):     d.readdir_handle(handle)
        case DriverInstance.DbFs(d):      d.readdir_handle(handle)

fn _driver_read_handle(driver: DriverInstance, handle: FileHandle, length: i64) -> Result<text, FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.read_handle(handle, length)
        case DriverInstance.Nvfs(d):      d.read_handle(handle, length)
        case DriverInstance.NvfsPosix(d): d.read_handle(handle, length)
        case DriverInstance.RamFs(d):     d.read_handle(handle, length)
        case DriverInstance.DbFs(d):      d.read_handle(handle, length)

fn _driver_mkdir_path(driver: DriverInstance, path: text, mode: u32) -> Result<(), FsError>:
    match driver:
        case DriverInstance.Fat32(d):     d.mkdir_path(path, mode)
        case DriverInstance.Nvfs(d):      d.mkdir_path(path, mode)
        case DriverInstance.NvfsPosix(d): d.mkdir_path(path, mode)
        case DriverInstance.RamFs(d):     d.mkdir_path(path, mode)
        case DriverInstance.DbFs(d):      d.mkdir_path(path, mode)

fn _driver_write_text_handle(driver: DriverInstance, handle: FileHandle, content: text) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.write_handle(handle, content)
        case _:                      Err(FsError.Unsupported)

fn _driver_pwrite_text_handle(driver: DriverInstance, handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.pwrite_handle(handle, patch, offset)
        case _:                      Err(FsError.Unsupported)

fn _driver_pread_text_handle(driver: DriverInstance, handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.pread_handle(handle, offset, length)
        case _:                      Err(FsError.Unsupported)

fn _driver_close_handle(driver: DriverInstance, handle: FileHandle) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.close_handle(handle)
        case _:                      Ok(())

fn _driver_unlink_path_text(driver: DriverInstance, path: text) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.unlink_path(path)
        case _:                      Err(FsError.Unsupported)

fn _driver_rename_path_text(driver: DriverInstance, old_path: text, new_path: text) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.rename_path(old_path, new_path)
        case _:                      Err(FsError.Unsupported)

fn _driver_ftruncate_handle(driver: DriverInstance, handle: FileHandle, new_size: i64) -> Result<(), FsError>:
    match driver:
        case DriverInstance.DbFs(d): d.ftruncate_handle(handle, new_size)
        case _:                      Err(FsError.Unsupported)

fn _driver_mmap_shared_writable_handle(driver: DriverInstance, handle: FileHandle, offset: i64, length: i64) -> Result<(), FsError>:
    val _ = driver
    val _ = handle
    val _ = offset
    val _ = length
    Err(FsError.Unsupported)

fn _driver_link_path_text(driver: DriverInstance, target: text, link_path: text) -> Result<(), FsError>:
    val _ = target
    val _ = link_path
    match driver:
        case _: Err(FsError.Unsupported)

struct MountId:
    """Opaque mount table index. Assigned sequentially; not reused after unmount."""
    id: u32

    static fn null() -> MountId:
        MountId(id: 0)

    me fn is_null() -> bool:
        self.id == 0

struct MountEntry:
    """Single active mount.

    id           — unique mount table slot index.
    mount_point  — absolute path string at which this filesystem is mounted.
    driver       — concrete driver wrapped in DriverInstance.
    opts         — options negotiated at mount time.
    active_caps  — capabilities active after mount-time negotiation.
    """
    id:          MountId
    mount_point: text
    driver:      DriverInstance
    opts:        MountOptions
    active_caps: u32   # CapabilitySet.bits after negotiation

struct MountResolution:
    """Resolved mount id plus path relative to the mounted filesystem."""
    mount_id: MountId
    relpath:  FsPath

struct MountTable:
    """Registry of active mounts.

    mounts       — ordered list of MountEntry; lookup uses longest-prefix match.
    next_id      — next MountId to assign (monotonically increasing).

    Thread safety: callers are responsible for holding an appropriate lock
    before calling mutating methods (mount, unmount). Reads (lookup, resolve)
    may race only if the caller guarantees no concurrent mounts/unmounts.
    """
    mounts:  [MountEntry]
    next_id: u32

impl MountTable:
    static fn new() -> MountTable:
        MountTable(mounts: [], next_id: 1)

    me fn mount(path: text, driver: DriverInstance, opts: MountOptions) -> Result<MountId, FsError>:
        """Add a new mount at path.

        Fails with AlreadyExists if path is already a mount point.
        Assigns a fresh MountId and appends the entry.
        """
        for entry in self.mounts:
            if entry.mount_point == path:
                return Err(FsError.AlreadyExists)

        val id = MountId(id: self.next_id)
        self.next_id = self.next_id + 1
        val want = opts.want_caps
        val active = want   # full negotiation done in vfs_mount; stub passes through
        val entry = MountEntry(
            id: id,
            mount_point: path,
            driver: driver,
            opts: opts,
            active_caps: active
        )
        self.mounts = self.mounts.push(entry)
        Ok(id)

    me fn unmount(path: text) -> Result<(), FsError>:
        """Remove the mount at path.

        Fails with NotFound if no mount exists at exactly that path.
        Callers must ensure no open handles before calling unmount.
        """
        var idx: i64 = -1
        var i: i64 = 0
        while i < self.mounts.len() as i64:
            if self.mounts[i as i32].mount_point == path:
                idx = i
            i = i + 1
        if idx < 0:
            return Err(FsError.NotFound)
        self.mounts = self.mounts.remove(idx as i32)
        Ok(())

    me fn lookup_text(path: text) -> MountEntry?:
        """Return the MountEntry whose mount_point is the longest prefix of path."""
        var best_len: i64 = -1
        var best_idx: i32 = -1
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val mp = self.mounts[i].mount_point
            if _text_has_prefix(path, mp):
                val mp_len = mp.len()
                if mp_len > best_len:
                    best_len = mp_len
                    best_idx = i
            i = i + 1
        if best_idx < 0:
            nil
        else:
            Some(self.mounts[best_idx])

    me fn lookup(path: FsPath) -> MountEntry?:
        """Return the MountEntry whose mount_point is the longest prefix of path."""
        self.lookup_text(path.raw)

    me fn resolve(path: FsPath) -> Result<MountResolution, FsError>:
        """Resolve path to a mount id plus relpath within that mount.

        relpath is the suffix of path after stripping the mount point prefix.
        Fails with NotFound if no mount covers path.
        """
        val entry_opt = self.lookup_text(path.raw)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                val mp_len = entry.mount_point.len()
                # FR-STORAGE-0004: do NOT use path.raw.slice() — broken in baremetal
                # Cranelift codegen. Build relpath by indexed char-copy instead.
                var rel_raw: text = ""
                var ci: i64 = mp_len
                if ci < path.raw.len() and str_char_at(path.raw, ci) == "/":
                    ci = ci + 1
                while ci < path.raw.len():
                    rel_raw = rel_raw + str_char_at(path.raw, ci)
                    ci = ci + 1
                val relpath: FsPath = FsPath(raw: rel_raw)
                Ok(MountResolution(mount_id: entry.id, relpath: relpath))

    me fn resolve_driver(path: text) -> Result<DriverInstance, FsError>:
        """Return the DriverInstance whose mount point best covers path."""
        val entry_opt = self.lookup_text(path)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                Ok(entry.driver)

    me fn stat(path: text) -> Result<StatInfo, FsError>:
        """Stat path via the appropriate mounted driver."""
        val resolved = self.resolve(FsPath(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.mount_id
                val relpath = pair.relpath
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return _driver_stat_path(self.mounts[i].driver, relpath)
                    i = i + 1
                Err(FsError.NotFound)

    me fn open(path: text, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Open path for I/O via the appropriate mounted driver."""
        val resolved = self.resolve(FsPath(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.mount_id
                val relpath = pair.relpath
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return _driver_open_path(self.mounts[i].driver, relpath, flags)
                    i = i + 1
                Err(FsError.NotFound)

    me fn opendir(path: text) -> Result<DirHandle, FsError>:
        """Open directory via the appropriate mounted driver."""
        val resolved = self.resolve(FsPath(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.mount_id
                val relpath = pair.relpath
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return _driver_opendir_path(self.mounts[i].driver, relpath)
                    i = i + 1
                Err(FsError.NotFound)

    me fn readdir(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """Read directory entries via the driver that owns the handle (probe each mount)."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_readdir_handle(self.mounts[i].driver, handle)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn read(handle: FileHandle, length: i64) -> Result<text, FsError>:
        """Read up to length bytes; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_read_handle(self.mounts[i].driver, handle, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn mkdir(path: text, mode: u32) -> Result<(), FsError>:
        """Create directory at path via the appropriate mounted driver."""
        val resolved = self.resolve(FsPath(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.mount_id
                val relpath = pair.relpath
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return _driver_mkdir_path(self.mounts[i].driver, relpath.raw, mode)
                    i = i + 1
                Err(FsError.NotFound)

    me fn block_device_for(path: text) -> Result<text, FsError>:
        """Return a text tag identifying the block device for the mount at path."""
        val entry_opt = self.lookup_text(path)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                Ok(_driver_name(entry.driver))

    me fn write(handle: FileHandle, content: text) -> Result<(), FsError>:
        """Write text content to an open file handle; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_write_text_handle(self.mounts[i].driver, handle, content)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn pwrite(handle: FileHandle, patch: text, offset: i64) -> Result<(), FsError>:
        """Write text patch at offset; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_pwrite_text_handle(self.mounts[i].driver, handle, patch, offset)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn pread(handle: FileHandle, offset: i64, length: i64) -> Result<text, FsError>:
        """Read length chars at offset; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_pread_text_handle(self.mounts[i].driver, handle, offset, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn close(handle: FileHandle) -> Result<(), FsError>:
        """Close an open file handle; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_close_handle(self.mounts[i].driver, handle)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn unlink(path: text) -> Result<(), FsError>:
        """Remove a file from the filesystem."""
        val resolved = self.resolve(FsPath(raw: path))
        match resolved:
            case Err(e):
                Err(e)
            case Ok(pair):
                val mount_id = pair.mount_id
                val relpath = pair.relpath
                var i: i32 = 0
                while i < self.mounts.len() as i32:
                    if self.mounts[i].id == mount_id:
                        return _driver_unlink_path_text(self.mounts[i].driver, relpath.raw)
                    i = i + 1
                Err(FsError.NotFound)

    me fn rename(old_path: text, new_path: text) -> Result<(), FsError>:
        """Rename a file or directory."""
        val old_resolved = self.resolve(FsPath(raw: old_path))
        match old_resolved:
            case Err(e):
                Err(e)
            case Ok(old_pair):
                val new_resolved = self.resolve(FsPath(raw: new_path))
                match new_resolved:
                    case Err(e):
                        Err(e)
                    case Ok(new_pair):
                        if old_pair.mount_id.id != new_pair.mount_id.id:
                            return Err(FsError.InvalidArg)
                        var i: i32 = 0
                        while i < self.mounts.len() as i32:
                            if self.mounts[i].id == old_pair.mount_id:
                                return _driver_rename_path_text(self.mounts[i].driver, old_pair.relpath.raw, new_pair.relpath.raw)
                            i = i + 1
                        Err(FsError.NotFound)

    me fn ftruncate(handle: FileHandle, new_size: i64) -> Result<(), FsError>:
        """Truncate or extend an open file; probe each mount to find handle owner."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_ftruncate_handle(self.mounts[i].driver, handle, new_size)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn mmap_shared_writable(handle: FileHandle, offset: i64, length: i64) -> Result<(), FsError>:
        """Shared writable mmap — always returns ENOTSUP (probes all mounts)."""
        var i: i32 = 0
        while i < self.mounts.len() as i32:
            val r = _driver_mmap_shared_writable_handle(self.mounts[i].driver, handle, offset, length)
            if r.is_ok():
                return r
            i = i + 1
        Err(FsError.NotFound)

    me fn link(target: text, link_path: text) -> Result<(), FsError>:
        """Hard link — always returns ENOTSUP; uses path-based resolution."""
        val entry_opt = self.lookup_text(target)
        match entry_opt:
            case nil:
                Err(FsError.NotFound)
            case Some(entry):
                _driver_link_path_text(entry.driver, target, link_path)
