# DriverInstance — heterogeneous mount-table enum wrapping concrete drivers.
#
# Each variant holds a concrete driver struct. VFS dispatch is by exhaustive
# match on DriverInstance — no dyn, no vtable.
#
# Phase 9 B1: Fat32Driver (from fat32_stub.spl) and NvfsDriver (from
# examples/nvfs/src/driver/fs_driver_impl.spl) are wired in.
# Phase 9 B2: NvfsPosixDriver (from examples/nvfs/src/posix/fs_driver_impl.spl)
# is now wired in.
# Phase 9 ramfs: RamFsDriver (from ramfs.spl) replaces RamFsStub.
# RamFsStub is kept as a backward-compat alias for existing tests.
#
# Source: doc/05_design/fs_driver_interface.md §3.

use std.fs_driver.fat32_stub.{FsFat32Driver}
use examples.nvfs.src.driver.fs_driver_impl.{NvfsDriver}
use examples.nvfs.src.posix.fs_driver_impl.{NvfsPosixDriver}
use std.fs_driver.ramfs.{RamFsDriver}
use std.db.dbfs_driver.dbfs_driver.{DbFsDriver}
use std.fs_driver.types.{Path, StatInfo, FileHandle, DirHandle, DirEntry, OpenFlags}
use std.fs_driver.error.{FsError}

# --- Backward-compat alias for existing tests that construct RamFsStub ---

struct RamFsStub:
    """Backward-compat placeholder. Use RamFsDriver for new code.

    Existing tests that construct RamFsStub(name: "ramfs") for mount-table
    shape tests continue to compile. The DriverInstance.RamFs variant now
    holds a real RamFsDriver; use RamFsDriver.new() for actual I/O.
    """
    name: text

# --- DriverInstance enum ---

enum DriverInstance:
    """Heterogeneous driver variant used in the mount table.

    VFS operations dispatch via exhaustive match on this enum.
    Adding a new driver: add a variant here; the compiler flags all
    match arms that need updating.

    Example dispatch (from fs_driver_interface.md §3.1):
        match &mount.driver:
            case DriverInstance.Fat32(d):     d.open(path, flags)
            case DriverInstance.Nvfs(d):      d.open(path, flags)
            case DriverInstance.NvfsPosix(d): d.open(path, flags)
            case DriverInstance.RamFs(d):     d.open(path, flags)
    """
    Fat32(driver: FsFat32Driver)
    Nvfs(driver: NvfsDriver)
    NvfsPosix(driver: NvfsPosixDriver)
    RamFs(driver: RamFsDriver)
    DbFs(driver: DbFsDriver)

impl DriverInstance:
    fn driver_name() -> text:
        """Return a human-readable name for this driver variant."""
        match self:
            case Fat32(d):     d.name
            case Nvfs(d):      d.name
            case NvfsPosix(d): d.name
            case RamFs(d):     d.name
            case DbFs(d):      d.name

    fn stat_path(path: Path) -> Result<StatInfo, FsError>:
        """Dispatch stat_path to the concrete driver."""
        match self:
            case Fat32(d):     d.stat_path(path)
            case Nvfs(d):      d.stat_path(path)
            case NvfsPosix(d): d.stat_path(path)
            case RamFs(d):     d.stat_path(path)
            case DbFs(d):      d.stat_path(path)

    me fn open_path(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Dispatch open_path to the concrete driver."""
        match self:
            case Fat32(d):     d.open_path(path, flags)
            case Nvfs(d):      d.open_path(path, flags)
            case NvfsPosix(d): d.open_path(path, flags)
            case RamFs(d):     d.open_path(path, flags)
            case DbFs(d):      d.open_path(path, flags)

    me fn opendir_path(path: Path) -> Result<DirHandle, FsError>:
        """Dispatch opendir_path to the concrete driver."""
        match self:
            case Fat32(d):     d.opendir_path(path)
            case Nvfs(d):      d.opendir_path(path)
            case NvfsPosix(d): d.opendir_path(path)
            case RamFs(d):     d.opendir_path(path)
            case DbFs(d):      d.opendir_path(path)

    fn readdir_handle(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """Dispatch readdir_handle to the concrete driver."""
        match self:
            case Fat32(d):     d.readdir_handle(handle)
            case Nvfs(d):      d.readdir_handle(handle)
            case NvfsPosix(d): d.readdir_handle(handle)
            case RamFs(d):     d.readdir_handle(handle)
            case DbFs(d):      d.readdir_handle(handle)

    fn read_handle(handle: FileHandle, length: i64) -> Result<text, FsError>:
        """Dispatch read_handle to the concrete driver."""
        match self:
            case Fat32(d):     d.read_handle(handle, length)
            case Nvfs(d):      d.read_handle(handle, length)
            case NvfsPosix(d): d.read_handle(handle, length)
            case RamFs(d):     d.read_handle(handle, length)
            case DbFs(d):      d.read_handle(handle, length)

    me fn mkdir_path(path: text, mode: u32) -> Result<(), FsError>:
        """Dispatch mkdir_path to the concrete driver."""
        match self:
            case Fat32(d):     d.mkdir_path(path, mode)
            case Nvfs(d):      d.mkdir_path(path, mode)
            case NvfsPosix(d): d.mkdir_path(path, mode)
            case RamFs(d):     d.mkdir_path(path, mode)
            case DbFs(d):      d.mkdir_path(path, mode)
