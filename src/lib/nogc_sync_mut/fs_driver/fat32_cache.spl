# FAT32 cache layer — four caches used by Fat32Core.
#
# FatSectorCache:   caches raw sector buffers keyed on sector number (u64).
# ChainCache:       caches full cluster chains keyed on start_cluster (u32).
# PathCache:        caches resolved DirEntry values keyed on canonical path (text).
# ClusterDataCache: caches raw cluster data keyed on cluster number (u32).
#
# All use counter-based LRU eviction (FR-FS-CACHE-001).
# FatSectorCache and ClusterDataCache support dirty-key pinning to prevent
# evicting unflushed writes.

use std.fs_driver.types.{DirEntry}

# ============================================================================
# FatSectorCache — LRU with dirty-key pinning
# ============================================================================

class FatSectorCache:
    sectors: Dict<u64, [u8]>
    max_size: i32
    access_counter: i64
    access_time: Dict<u64, i64>
    pinned: Dict<u64, bool>

    static fn new(max_size: i32) -> FatSectorCache:
        FatSectorCache(
            sectors: {},
            max_size: max_size,
            access_counter: 0,
            access_time: {},
            pinned: {}
        )

    me fn get(sector: u64) -> [u8]?:
        val result = self.sectors.get(sector)
        if result.?:
            self.access_counter = self.access_counter + 1
            var at = self.access_time
            at.set(sector, self.access_counter)
            self.access_time = at
        result

    me fn put(sector: u64, data: [u8]):
        var s = self.sectors
        if s.keys().len() as i32 >= self.max_size:
            self._evict_one()
            s = self.sectors
        s.set(sector, data)
        self.sectors = s
        self.access_counter = self.access_counter + 1
        var at = self.access_time
        at.set(sector, self.access_counter)
        self.access_time = at

    me fn update(sector: u64, data: [u8]):
        var s = self.sectors
        s.set(sector, data)
        self.sectors = s
        self.access_counter = self.access_counter + 1
        var at = self.access_time
        at.set(sector, self.access_counter)
        self.access_time = at

    me fn invalidate(sector: u64):
        var s = self.sectors
        s.delete(sector)
        self.sectors = s
        var at = self.access_time
        at.delete(sector)
        self.access_time = at
        var p = self.pinned
        p.delete(sector)
        self.pinned = p

    me fn clear():
        self.sectors = {}
        self.access_time = {}
        self.pinned = {}
        self.access_counter = 0

    me fn mark_dirty(sector: u64):
        var p = self.pinned
        p.set(sector, true)
        self.pinned = p

    me fn mark_clean(sector: u64):
        var p = self.pinned
        p.delete(sector)
        self.pinned = p

    me fn mark_all_clean():
        self.pinned = {}

    me fn _evict_one():
        val ks = self.access_time.keys()
        var min_time: i64 = 9223372036854775807
        var min_key: u64 = 0
        var found = false
        var i = 0
        while i < ks.len():
            val k = ks[i]
            if not self.pinned.has(k):
                val t: i64 = self.access_time.get(k) ?? 0
                if t < min_time:
                    min_time = t
                    min_key = k
                    found = true
            i = i + 1
        if found:
            var s = self.sectors
            s.delete(min_key)
            self.sectors = s
            var at = self.access_time
            at.delete(min_key)
            self.access_time = at

# ============================================================================
# ChainCache — LRU with capacity bound
# ============================================================================

class ChainCache:
    chains: Dict<u32, [u32]>
    max_size: i32
    access_counter: i64
    access_time: Dict<u32, i64>

    static fn new(max_size: i32) -> ChainCache:
        ChainCache(
            chains: {},
            max_size: max_size,
            access_counter: 0,
            access_time: {}
        )

    me fn get_chain(start_cluster: u32) -> [u32]?:
        val result = self.chains.get(start_cluster)
        if result.?:
            self.access_counter = self.access_counter + 1
            var at = self.access_time
            at.set(start_cluster, self.access_counter)
            self.access_time = at
        result

    me fn put_chain(start_cluster: u32, chain: [u32]):
        var c = self.chains
        if c.keys().len() as i32 >= self.max_size:
            self._evict_one()
            c = self.chains
        c.set(start_cluster, chain)
        self.chains = c
        self.access_counter = self.access_counter + 1
        var at = self.access_time
        at.set(start_cluster, self.access_counter)
        self.access_time = at

    me fn invalidate(start_cluster: u32):
        var c = self.chains
        c.delete(start_cluster)
        self.chains = c
        var at = self.access_time
        at.delete(start_cluster)
        self.access_time = at

    me fn clear():
        self.chains = {}
        self.access_time = {}
        self.access_counter = 0

    me fn _evict_one():
        val ks = self.access_time.keys()
        var min_time: i64 = 9223372036854775807
        var min_key: u32 = 0
        var found = false
        var i = 0
        while i < ks.len():
            val k = ks[i]
            val t: i64 = self.access_time.get(k) ?? 0
            if t < min_time:
                min_time = t
                min_key = k
                found = true
            i = i + 1
        if found:
            var c = self.chains
            c.delete(min_key)
            self.chains = c
            var at = self.access_time
            at.delete(min_key)
            self.access_time = at

# ============================================================================
# PathCache — LRU with capacity bound
# ============================================================================

class PathCache:
    entries: Dict<text, DirEntry>
    max_size: i32
    access_counter: i64
    access_time: Dict<text, i64>

    static fn new(max_size: i32) -> PathCache:
        PathCache(
            entries: {},
            max_size: max_size,
            access_counter: 0,
            access_time: {}
        )

    me fn get(path: text) -> DirEntry?:
        val result = self.entries.get(path)
        if result.?:
            self.access_counter = self.access_counter + 1
            var at = self.access_time
            at.set(path, self.access_counter)
            self.access_time = at
        result

    me fn put(path: text, entry: DirEntry):
        var e = self.entries
        if e.keys().len() as i32 >= self.max_size:
            self._evict_one()
            e = self.entries
        e.set(path, entry)
        self.entries = e
        self.access_counter = self.access_counter + 1
        var at = self.access_time
        at.set(path, self.access_counter)
        self.access_time = at

    me fn invalidate_prefix(prefix: text):
        var e = self.entries
        var at = self.access_time
        val ks = e.keys()
        var i = 0
        while i < ks.len():
            val k = ks[i]
            if k.starts_with(prefix):
                e.delete(k)
                at.delete(k)
            i = i + 1
        self.entries = e
        self.access_time = at

    me fn clear():
        self.entries = {}
        self.access_time = {}
        self.access_counter = 0

    me fn _evict_one():
        val ks = self.access_time.keys()
        var min_time: i64 = 9223372036854775807
        var min_key: text = ""
        var found = false
        var i = 0
        while i < ks.len():
            val k = ks[i]
            val t: i64 = self.access_time.get(k) ?? 0
            if t < min_time:
                min_time = t
                min_key = k
                found = true
            i = i + 1
        if found:
            var e = self.entries
            e.delete(min_key)
            self.entries = e
            var at = self.access_time
            at.delete(min_key)
            self.access_time = at

# ============================================================================
# ClusterDataCache — LRU with dirty-key pinning
# ============================================================================

class ClusterDataCache:
    data: Dict<u32, [u8]>
    max_size: i32
    access_counter: i64
    access_time: Dict<u32, i64>
    pinned: Dict<u32, bool>

    static fn new(max_size: i32) -> ClusterDataCache:
        ClusterDataCache(
            data: {},
            max_size: max_size,
            access_counter: 0,
            access_time: {},
            pinned: {}
        )

    me fn get(cluster: u32) -> [u8]?:
        val result = self.data.get(cluster)
        if result.?:
            self.access_counter = self.access_counter + 1
            var at = self.access_time
            at.set(cluster, self.access_counter)
            self.access_time = at
        result

    me fn put(cluster: u32, buf: [u8]):
        var d = self.data
        if d.keys().len() as i32 >= self.max_size:
            self._evict_one()
            d = self.data
        d.set(cluster, buf)
        self.data = d
        self.access_counter = self.access_counter + 1
        var at = self.access_time
        at.set(cluster, self.access_counter)
        self.access_time = at

    me fn invalidate(cluster: u32):
        var d = self.data
        d.delete(cluster)
        self.data = d
        var at = self.access_time
        at.delete(cluster)
        self.access_time = at
        var p = self.pinned
        p.delete(cluster)
        self.pinned = p

    me fn clear():
        self.data = {}
        self.access_time = {}
        self.pinned = {}
        self.access_counter = 0

    me fn mark_dirty(cluster: u32):
        var p = self.pinned
        p.set(cluster, true)
        self.pinned = p

    me fn mark_clean(cluster: u32):
        var p = self.pinned
        p.delete(cluster)
        self.pinned = p

    me fn mark_all_clean():
        self.pinned = {}

    me fn _evict_one():
        val ks = self.access_time.keys()
        var min_time: i64 = 9223372036854775807
        var min_key: u32 = 0
        var found = false
        var i = 0
        while i < ks.len():
            val k = ks[i]
            if not self.pinned.has(k):
                val t: i64 = self.access_time.get(k) ?? 0
                if t < min_time:
                    min_time = t
                    min_key = k
                    found = true
            i = i + 1
        if found:
            var d = self.data
            d.delete(min_key)
            self.data = d
            var at = self.access_time
            at.delete(min_key)
            self.access_time = at
