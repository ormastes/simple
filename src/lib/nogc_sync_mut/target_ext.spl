# Target build-extension seam (variants/ platform overlay).
#
# CANONICAL (`default`) impl, in src: detects the HOST platform at runtime, so a
# `default`/`auto` build behaves exactly as before. The stable import is
# `nogc_sync_mut.target_ext`; when config selects an explicit platform variant
# (e.g. platform: windows|mac|linux), the resolver picks the mirrored file under
# variants/platform/<value>/nogc_sync_mut/target_ext.spl, which returns the
# fixed extension for that build target. Pure build-target properties; `auto`
# falls through to host detection here and never regresses.

use nogc_sync_mut.platform.{host_os}

pub fn target_lib_ext() -> text:
    """Dynamic-library extension for the build target (host when default/auto)."""
    val os = host_os()
    if os == "macos":
        ".dylib"
    elif os == "windows":
        ".dll"
    else:
        ".so"

pub fn target_exe_ext() -> text:
    """Executable extension for the build target (host when default/auto)."""
    if host_os() == "windows":
        ".exe"
    else:
        ""
