#![allow(primitive_api)]
# Font Loading FFI — TrueType font wrapper
#
# Loads TrueType fonts and renders glyph bitmaps.

extern fn rt_font_load(path: text) -> i64
extern fn rt_font_free(handle: i64)
extern fn rt_font_glyph_bitmap(handle: i64, codepoint: i64, size_px: i64) -> [i64]
extern fn rt_font_glyph_width(handle: i64, codepoint: i64, size_px: i64) -> i64
extern fn rt_font_glyph_height(handle: i64, codepoint: i64, size_px: i64) -> i64
extern fn rt_font_glyph_advance(handle: i64, codepoint: i64, size_px: i64) -> i64
extern fn rt_font_line_height(handle: i64, size_px: i64) -> i64

class FontHandle:
    handle: i64
    path: text

impl FontHandle:
    fn is_valid() -> bool:
        self.handle > 0

class GlyphMetrics:
    width: i64
    height: i64
    advance: i64
    codepoint: i64

class GlyphBitmap:
    width: i64
    height: i64
    pixels: [i64]    # Alpha values packed as i64 (0-255)
    metrics: GlyphMetrics

impl GlyphBitmap:
    fn is_valid() -> bool:
        self.width > 0 and self.height > 0

fn load_font(path: text) -> FontHandle?:
    val h = rt_font_load(path)
    if h <= 0:
        return nil
    FontHandle(handle: h, path: path)

fn free_font(font: FontHandle):
    if font.is_valid():
        rt_font_free(font.handle)

fn get_glyph(font: FontHandle, codepoint: i64, size_px: i64) -> GlyphBitmap?:
    if not font.is_valid():
        return nil
    val w = rt_font_glyph_width(font.handle, codepoint, size_px)
    val h = rt_font_glyph_height(font.handle, codepoint, size_px)
    val adv = rt_font_glyph_advance(font.handle, codepoint, size_px)
    val bitmap = rt_font_glyph_bitmap(font.handle, codepoint, size_px)
    val metrics = GlyphMetrics(width: w, height: h, advance: adv, codepoint: codepoint)
    GlyphBitmap(width: w, height: h, pixels: bitmap, metrics: metrics)

fn get_line_height(font: FontHandle, size_px: i64) -> i64:
    if not font.is_valid():
        return 0
    rt_font_line_height(font.handle, size_px)
