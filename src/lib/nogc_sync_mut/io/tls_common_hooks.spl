# TLS crypto and wire runtime hook owner for compatibility TLS helpers.

use os.crypto.aes128_gcm.{aes128_gcm_encrypt, aes128_gcm_decrypt, Aes128GcmResult}

extern fn rt_byte_char(v: i64) -> text
extern fn rt_rsa_decrypt(ciphertext: text, private_key: text) -> text
extern fn rt_wire_to_hex(wire: text, wire_len: i64) -> text
extern fn rt_hex_to_wire(hex_str: text) -> text
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn tls_hook_byte_char(v: i64) -> text:
    rt_byte_char(v)

fn tls_hook_rsa_decrypt(ciphertext: text, private_key: text) -> text:
    rt_rsa_decrypt(ciphertext, private_key)

fn tls_hook_aes_gcm_encrypt(key: text, iv: text, plaintext: text, aad: text) -> text:
    val key_hex = rt_wire_to_hex(key, len(key))
    val iv_hex = rt_wire_to_hex(iv, len(iv))
    val plaintext_hex = rt_wire_to_hex(plaintext, len(plaintext))
    val aad_hex = rt_wire_to_hex(aad, len(aad))
    rt_hex_to_wire(tls_hook_aes_gcm_encrypt_hex(key_hex, iv_hex, plaintext_hex, aad_hex))

fn tls_hook_aes_gcm_decrypt(key: text, iv: text, ciphertext: text, aad: text) -> text?:
    val key_hex = rt_wire_to_hex(key, len(key))
    val iv_hex = rt_wire_to_hex(iv, len(iv))
    val ciphertext_hex = rt_wire_to_hex(ciphertext, len(ciphertext))
    val aad_hex = rt_wire_to_hex(aad, len(aad))
    val plaintext_hex = tls_hook_aes_gcm_decrypt_hex(key_hex, iv_hex, ciphertext_hex, aad_hex)
    if plaintext_hex == nil:
        return nil
    rt_hex_to_wire(plaintext_hex)

fn tls_hook_aes_gcm_encrypt_hex(key_hex: text, iv_hex: text, plaintext_hex: text, aad_hex: text) -> text:
    val key = _tls_hex_to_bytes(key_hex)
    val nonce = _tls_hex_to_bytes(iv_hex)
    val plaintext = _tls_hex_to_bytes(plaintext_hex)
    val aad = _tls_hex_to_bytes(aad_hex)
    if key.len() != 16 or nonce.len() != 12:
        return ""
    _tls_bytes_to_hex(aes128_gcm_encrypt(key, nonce, plaintext, aad))

fn tls_hook_aes_gcm_decrypt_hex(key_hex: text, iv_hex: text, ciphertext_hex: text, aad_hex: text) -> text?:
    val key = _tls_hex_to_bytes(key_hex)
    val nonce = _tls_hex_to_bytes(iv_hex)
    val ciphertext_and_tag = _tls_hex_to_bytes(ciphertext_hex)
    val aad = _tls_hex_to_bytes(aad_hex)
    if key.len() != 16 or nonce.len() != 12 or ciphertext_and_tag.len() < 16:
        return nil
    val ct_len = ciphertext_and_tag.len() - 16
    var ciphertext: [u8] = rt_array_new_with_cap(ct_len.to_i64())
    var tag: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < ct_len:
        ciphertext.push(_tls_u8_at(ciphertext_and_tag, i))
        i = i + 1
    i = 0
    while i < 16:
        tag.push(_tls_u8_at(ciphertext_and_tag, ct_len + i))
        i = i + 1

    val result = aes128_gcm_decrypt(key, nonce, ciphertext, aad, tag)
    var plaintext_hex: text? = nil
    match result:
        Aes128GcmResult.Ok(data):
            plaintext_hex = _tls_bytes_to_hex(data)
        Aes128GcmResult.Err(msg):
            plaintext_hex = nil
    plaintext_hex

fn tls_hook_wire_to_hex(wire: text, wire_len: i64) -> text:
    rt_wire_to_hex(wire, wire_len)

fn tls_hook_hex_to_wire(hex_str: text) -> text:
    rt_hex_to_wire(hex_str)

fn _tls_u8_at(buf: [u8], idx: u64) -> u8:
    buf[idx]

fn _tls_hex_value(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "a": return 10
    if c == "A": return 10
    if c == "b": return 11
    if c == "B": return 11
    if c == "c": return 12
    if c == "C": return 12
    if c == "d": return 13
    if c == "D": return 13
    if c == "e": return 14
    if c == "E": return 14
    if c == "f": return 15
    if c == "F": return 15
    -1

fn _tls_hex_to_bytes(hex_str: text) -> [u8]:
    val hex_len = len(hex_str)
    if (hex_len % 2) != 0:
        return []
    var out: [u8] = rt_array_new_with_cap(hex_len / 2)
    var i: u64 = 0
    while i < hex_len.to_u64():
        val hi = _tls_hex_value(hex_str.char_at(i))
        val lo = _tls_hex_value(hex_str.char_at(i + 1))
        if hi < 0 or lo < 0:
            return []
        out.push(((hi << 4) | lo).to_u8())
        i = i + 2
    out

fn _tls_hex_digit(v: i64) -> text:
    if v == 0: return "0"
    if v == 1: return "1"
    if v == 2: return "2"
    if v == 3: return "3"
    if v == 4: return "4"
    if v == 5: return "5"
    if v == 6: return "6"
    if v == 7: return "7"
    if v == 8: return "8"
    if v == 9: return "9"
    if v == 10: return "a"
    if v == 11: return "b"
    if v == 12: return "c"
    if v == 13: return "d"
    if v == 14: return "e"
    "f"

fn _tls_bytes_to_hex(bytes: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < bytes.len():
        val b = _tls_u8_at(bytes, i).to_i64()
        out = out + _tls_hex_digit((b >> 4) & 15) + _tls_hex_digit(b & 15)
        i = i + 1
    out
