# TLS crypto and wire runtime hook owner for compatibility TLS helpers.

extern fn rt_byte_char(v: i64) -> text
extern fn rt_rsa_decrypt(ciphertext: text, private_key: text) -> text
extern fn rt_aes_gcm_encrypt(key: text, iv: text, plaintext: text, aad: text) -> text
extern fn rt_aes_gcm_decrypt(key: text, iv: text, ciphertext: text, aad: text) -> text
extern fn rt_aes_gcm_encrypt_hex(key_hex: text, iv_hex: text, plaintext_hex: text, aad_hex: text) -> text
extern fn rt_aes_gcm_decrypt_hex(key_hex: text, iv_hex: text, ciphertext_hex: text, aad_hex: text) -> text
extern fn rt_wire_to_hex(wire: text, wire_len: i64) -> text
extern fn rt_hex_to_wire(hex_str: text) -> text

fn tls_hook_byte_char(v: i64) -> text:
    rt_byte_char(v)

fn tls_hook_rsa_decrypt(ciphertext: text, private_key: text) -> text:
    rt_rsa_decrypt(ciphertext, private_key)

fn tls_hook_aes_gcm_encrypt(key: text, iv: text, plaintext: text, aad: text) -> text:
    rt_aes_gcm_encrypt(key, iv, plaintext, aad)

fn tls_hook_aes_gcm_decrypt(key: text, iv: text, ciphertext: text, aad: text) -> text:
    rt_aes_gcm_decrypt(key, iv, ciphertext, aad)

fn tls_hook_aes_gcm_encrypt_hex(key_hex: text, iv_hex: text, plaintext_hex: text, aad_hex: text) -> text:
    rt_aes_gcm_encrypt_hex(key_hex, iv_hex, plaintext_hex, aad_hex)

fn tls_hook_aes_gcm_decrypt_hex(key_hex: text, iv_hex: text, ciphertext_hex: text, aad_hex: text) -> text:
    rt_aes_gcm_decrypt_hex(key_hex, iv_hex, ciphertext_hex, aad_hex)

fn tls_hook_wire_to_hex(wire: text, wire_len: i64) -> text:
    rt_wire_to_hex(wire, wire_len)

fn tls_hook_hex_to_wire(hex_str: text) -> text:
    rt_hex_to_wire(hex_str)
