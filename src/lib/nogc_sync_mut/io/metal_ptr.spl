#[runtime_intrinsics]
@no_gc
"""Canonical pointer-based Metal readback helpers."""

extern fn rt_metal_buffer_download(data_ptr: i64, buffer: i64, size: i64) -> i64
# The selected runtime owner must construct this array in its own registry.
# simple-core provides the symbol directly; hosted runtimes provide the same
# ABI when they exclusively own arrays for the executable.
extern fn rt_u32s_from_raw(data_ptr: i64, count: i64) -> [u32]

pub fn metal_buffer_download_ptr(data_ptr: i64, buffer: i64, size: i64) -> i64:
    rt_metal_buffer_download(data_ptr, buffer, size)

pub fn metal_u32s_from_ptr(data_ptr: i64, count: i64) -> [u32]:
    rt_u32s_from_raw(data_ptr, count)
