#!/usr/bin/env simple
# Serial Proxy — bidirectional stdin ↔ serial relay
#
# Spawned by ssh as ProxyCommand for the native SSH-over-serial path:
#   ssh -o ProxyCommand="bin/simple serial-proxy DEVICE BAUD" USER@localhost
#
# Relays stdin ↔ serial simultaneously using poll(2).
# Runs until either end closes.

use std.nogc_sync_mut.io.serial_ffi.{serial_open, serial_close, serial_relay}

extern fn rt_cli_get_args() -> [text]
extern fn rt_write_stdout(data: text)

fn main():
    val args = rt_cli_get_args()
    if args.len() < 2:
        rt_write_stdout("usage: serial_proxy.spl DEVICE BAUD\n")
        return

    val device = args[0]
    val baud = args[1].to_int()

    val port = serial_open(device, baud)
    if not port.is_valid:
        rt_write_stdout("error: could not open " + device + "\n")
        return

    serial_relay(port)
    serial_close(port)

main()
