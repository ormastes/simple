#![allow(primitive_api)]
# Audio FFI — miniaudio backend
#
# SFFI bindings for the miniaudio-based C runtime (runtime_audio.c).
# Provides engine init/shutdown, sound loading, playback control, and volume.
#
# The C side uses a static global ma_engine. Sound handles and playback handles
# are ma_sound* pointers cast to i64.

# ============================================================================
# Tier 1: Extern Declarations (Raw FFI)
# ============================================================================

# --- Engine lifecycle ---
extern fn rt_audio_init() -> i64
extern fn rt_audio_shutdown()

# --- Sound loading ---
extern fn rt_audio_load_sound(path: text) -> i64
extern fn rt_audio_unload_sound(handle: i64)

# --- Playback ---
extern fn rt_audio_play(sound_handle: i64) -> i64
extern fn rt_audio_play_looped(sound_handle: i64) -> i64
extern fn rt_audio_stop(playback_handle: i64)
extern fn rt_audio_pause(playback_handle: i64)
extern fn rt_audio_resume(playback_handle: i64)

# --- Volume ---
extern fn rt_audio_set_volume(playback_handle: i64, volume: f64)
extern fn rt_audio_set_master_volume(volume: f64)
extern fn rt_audio_get_master_volume() -> f64

# --- Query ---
extern fn rt_audio_is_playing(playback_handle: i64) -> i64

# --- Spatial audio (3D positioning) ---
extern fn rt_audio_set_sound_position(handle: i64, x: f64, y: f64, z: f64)
extern fn rt_audio_set_spatialization_enabled(handle: i64, enabled: i64)
extern fn rt_audio_set_listener_position(x: f64, y: f64, z: f64)
extern fn rt_audio_set_listener_direction(x: f64, y: f64, z: f64)
extern fn rt_audio_set_listener_world_up(x: f64, y: f64, z: f64)
extern fn rt_audio_set_sound_min_distance(handle: i64, distance: f64)
extern fn rt_audio_set_sound_max_distance(handle: i64, distance: f64)

# ============================================================================
# Tier 2: Simple-Friendly Wrapper Functions
# ============================================================================

struct AudioEngine:
    handle: i64
    is_valid: bool

fn audio_init() -> AudioEngine:
    val result = rt_audio_init()
    AudioEngine(handle: result, is_valid: result != 0)

fn audio_shutdown(engine: AudioEngine):
    if engine.is_valid:
        rt_audio_shutdown()

struct AudioSource:
    handle: i64
    is_valid: bool

fn audio_load_sound(path: text) -> AudioSource:
    val h = rt_audio_load_sound(path)
    AudioSource(handle: h, is_valid: h != 0)

fn audio_unload_sound(source: AudioSource):
    if source.is_valid:
        rt_audio_unload_sound(source.handle)

struct AudioPlayback:
    handle: i64
    is_valid: bool

fn audio_play(source: AudioSource) -> AudioPlayback:
    if not source.is_valid:
        return AudioPlayback(handle: 0, is_valid: false)
    val h = rt_audio_play(source.handle)
    AudioPlayback(handle: h, is_valid: h != 0)

fn audio_play_looped(source: AudioSource) -> AudioPlayback:
    if not source.is_valid:
        return AudioPlayback(handle: 0, is_valid: false)
    val h = rt_audio_play_looped(source.handle)
    AudioPlayback(handle: h, is_valid: h != 0)

fn audio_stop(playback: AudioPlayback):
    if playback.is_valid:
        rt_audio_stop(playback.handle)

fn audio_pause(playback: AudioPlayback):
    if playback.is_valid:
        rt_audio_pause(playback.handle)

fn audio_resume(playback: AudioPlayback):
    if playback.is_valid:
        rt_audio_resume(playback.handle)

fn audio_set_volume(playback: AudioPlayback, volume: f64):
    if playback.is_valid:
        rt_audio_set_volume(playback.handle, volume)

fn audio_set_master_volume(volume: f64):
    rt_audio_set_master_volume(volume)

fn audio_get_master_volume() -> f64:
    rt_audio_get_master_volume()

fn audio_is_playing(playback: AudioPlayback) -> bool:
    if not playback.is_valid:
        return false
    rt_audio_is_playing(playback.handle) != 0

# --- Spatial wrappers ---

fn audio_set_sound_position(playback: AudioPlayback, x: f64, y: f64, z: f64):
    if playback.is_valid:
        rt_audio_set_sound_position(playback.handle, x, y, z)

fn audio_set_spatialization_enabled(playback: AudioPlayback, enabled: bool):
    if playback.is_valid:
        val flag: i64 = if enabled: 1 else: 0
        rt_audio_set_spatialization_enabled(playback.handle, flag)

fn audio_set_listener_position(x: f64, y: f64, z: f64):
    rt_audio_set_listener_position(x, y, z)

fn audio_set_listener_direction(x: f64, y: f64, z: f64):
    rt_audio_set_listener_direction(x, y, z)

fn audio_set_listener_world_up(x: f64, y: f64, z: f64):
    rt_audio_set_listener_world_up(x, y, z)

fn audio_set_sound_min_distance(playback: AudioPlayback, distance: f64):
    if playback.is_valid:
        rt_audio_set_sound_min_distance(playback.handle, distance)

fn audio_set_sound_max_distance(playback: AudioPlayback, distance: f64):
    if playback.is_valid:
        rt_audio_set_sound_max_distance(playback.handle, distance)
