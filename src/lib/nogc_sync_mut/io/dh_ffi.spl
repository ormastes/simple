@allow(primitive_api)
# Curve25519 DH Key Exchange FFI Wrapper
# Ephemeral X25519 ECDH for SSH KEX (RFC 5656 / RFC 8731)
# Dependencies: ring 0.17 (Rust runtime)

# ============================================================================
# Tier 1: Extern Function Declarations (Raw FFI)
# ============================================================================

# Generate ephemeral X25519 keypair; returns opaque handle (> 0) or -1 on error
extern fn rt_dh_curve25519_keypair() -> i64

# Return public key bytes ([u8; 32]) for the given handle
extern fn rt_dh_curve25519_public_key(handle: i64) -> [i64]

# Compute shared secret from our private key and peer's public key bytes.
# Consumes the private key (removes from store). Returns [u8; 32] or empty.
extern fn rt_dh_curve25519_shared_secret(handle: i64, their_pub: [i64]) -> [i64]

# Free the keypair for the given handle (no-op if already consumed or invalid)
extern fn rt_dh_curve25519_free(handle: i64)

# ============================================================================
# Tier 2: Simple-Friendly Wrapper Functions
# ============================================================================

fn dh_curve25519_keypair() -> i64:
    """Generate an ephemeral X25519 keypair.

    Returns: opaque handle (> 0) on success, -1 on failure.

    The handle must be freed with dh_curve25519_free() when no longer needed,
    or will be automatically consumed by dh_curve25519_shared_secret().
    """
    rt_dh_curve25519_keypair()

fn dh_curve25519_public_key(handle: i64) -> [i64]:
    """Return the 32-byte X25519 public key for the given handle.

    Args:
        handle: Handle returned by dh_curve25519_keypair()

    Returns: [u8; 32] as array of i64 (0-255 each), or empty array on error.
    """
    rt_dh_curve25519_public_key(handle)

fn dh_curve25519_shared_secret(handle: i64, their_pub: [i64]) -> [i64]:
    """Compute the 32-byte X25519 shared secret.

    Performs ECDH with the stored private key and the peer's public key bytes.
    The private key is consumed; subsequent calls with the same handle return
    an empty array.

    Args:
        handle:    Handle returned by dh_curve25519_keypair()
        their_pub: Peer's 32-byte public key as array of i64 (0-255 each)

    Returns: [u8; 32] shared secret as array of i64, or empty array on error.

    Example:
        handle = dh_curve25519_keypair()
        my_pub = dh_curve25519_public_key(handle)
        # ... exchange my_pub with peer, receive their_pub ...
        secret = dh_curve25519_shared_secret(handle, their_pub)
        dh_curve25519_free(handle)
    """
    rt_dh_curve25519_shared_secret(handle, their_pub)

fn dh_curve25519_free(handle: i64):
    """Free the keypair for the given handle.

    Safe to call after dh_curve25519_shared_secret() (already consumed)
    or with an invalid handle.
    """
    rt_dh_curve25519_free(handle)
