# Image FFI — test-friendly image data wrapper
#
# Provides ImageData with a pixel-array constructor for procedural/test use.
# For real image loading from disk, use image_sffi.spl instead.

# ============================================================================
# ImageData — image buffer (width × height × 4 channels RGBA)
# ============================================================================

class ImageData:
    width: i64
    height: i64
    channels: i64
    pixels: [i64]

impl ImageData:
    fn is_valid() -> bool:
        self.width > 0 and self.height > 0

    fn pixel_count() -> i64:
        self.width * self.height

    fn size_bytes() -> i64:
        self.width * self.height * self.channels

# ============================================================================
# Constructors
# ============================================================================

fn create_image_data(width: i64, height: i64, pixels: [i64]) -> ImageData:
    """Create an ImageData from dimensions and pixel data (RGBA, 4 channels)."""
    ImageData(width: width, height: height, channels: 4, pixels: pixels)
