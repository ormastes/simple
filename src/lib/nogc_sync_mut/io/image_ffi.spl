#![allow(primitive_api)]
# Image Loading FFI — stb_image wrapper
#
# Loads image files from disk into pixel arrays usable by the engine.
# Uses external C library (stb_image) via FFI.

# External FFI declarations (runtime-provided stubs for now)
extern fn rt_image_load(path: text) -> [i64]
extern fn rt_image_width(handle: [i64]) -> i64
extern fn rt_image_height(handle: [i64]) -> i64
extern fn rt_image_channels(handle: [i64]) -> i64
extern fn rt_image_free(handle: [i64])

# Image load result
class ImageData:
    width: i64
    height: i64
    channels: i64
    pixels: [i64]    # RGBA packed as i64

impl ImageData:
    fn is_valid() -> bool:
        self.width > 0 and self.height > 0

    fn pixel_count() -> i64:
        self.width * self.height

    fn size_bytes() -> i64:
        self.width * self.height * self.channels

# Load an image from disk. Returns nil on failure.
fn load_image(path: text) -> ImageData?:
    val raw = rt_image_load(path)
    if raw.len() == 0:
        return nil
    val w = rt_image_width(raw)
    val h = rt_image_height(raw)
    val ch = rt_image_channels(raw)
    val result = ImageData(width: w, height: h, channels: ch, pixels: raw)
    result

# Create an ImageData from raw pixel array (for testing/procedural generation)
fn create_image_data(width: i64, height: i64, pixels: [i64]) -> ImageData:
    ImageData(width: width, height: height, channels: 4, pixels: pixels)
