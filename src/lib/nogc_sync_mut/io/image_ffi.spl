@allow(primitive_api)
# Image Loading FFI — stb_image wrapper
#
# Loads image files from disk into pixel data usable by the engine.
# Uses external C library (stb_image) via FFI. Handles are i64 (opaque pointers).

# ============================================================================
# Tier 1: Extern Declarations (Raw FFI)
# ============================================================================

extern fn rt_image_load(path: text) -> i64
extern fn rt_image_free(handle: i64)
extern fn rt_image_width(handle: i64) -> i64
extern fn rt_image_height(handle: i64) -> i64
extern fn rt_image_channels(handle: i64) -> i64
extern fn rt_image_get_pixel(handle: i64, x: i64, y: i64) -> i64

# ============================================================================
# Tier 2: Simple-Friendly Wrapper
# ============================================================================

# Image load result
class ImageData:
    handle: i64
    width: i64
    height: i64
    channels: i64

impl ImageData:
    fn is_valid() -> bool:
        self.handle != 0

    fn pixel_count() -> i64:
        self.width * self.height

    fn size_bytes() -> i64:
        self.width * self.height * self.channels

    fn get_pixel(x: i64, y: i64) -> i64:
        if not self.is_valid():
            return 0
        rt_image_get_pixel(self.handle, x, y)

# Load an image from disk. Returns nil on failure.
fn load_image(path: text) -> ImageData?:
    val h = rt_image_load(path)
    if h == 0:
        return nil
    val w = rt_image_width(h)
    val ht = rt_image_height(h)
    val ch = rt_image_channels(h)
    ImageData(handle: h, width: w, height: ht, channels: ch)

# Free image resources
fn free_image(img: ImageData):
    if img.is_valid():
        rt_image_free(img.handle)

# Create an ImageData from dimensions (for testing/procedural generation)
fn create_image_data(width: i64, height: i64) -> ImageData:
    ImageData(handle: 0, width: width, height: height, channels: 4)
