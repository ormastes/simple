@allow(primitive_api)
# std.play — Playwright-compatible automation library
#
# Single entry point for `use std.play`.
#
# Mirrors Playwright's Electron API in interface:
#
#   use std.play
#
#   fn test_app_starts() =
#     let app = play.electron.launch({ args: ["."] })
#     let win = app.first_window()
#     expect(win).to_have_title(/My App/)
#     app.close()
#
# Backends (auto-selected by target type):
#   - cdp         Electron / VS Code / Chromium over Chrome DevTools Protocol
#   - sdl2        Simple OS env — native SDL2 apps via ui.test_api HTTP layer
#   - wm          Native OS windows via platform CLI shell-out
#   - orchestrator Phase 1 — shell out to npm/playwright/vscode-test
#
# Method names are snake_case to match Python Playwright and Simple's stdlib.
# Class names are PascalCase (ElectronApplication, Page, Locator, Keyboard,
# Mouse, expect).

# ============================================================================
# Public re-exports
# ============================================================================

use std.play.types.{
    LaunchOptions, default_launch_options,
    ClickOptions, default_click_options,
    FillOptions, default_fill_options,
    TypeOptions, default_type_options,
    PressOptions, default_press_options,
    ScreenshotOptions, default_screenshot_options,
    ExpectOptions, default_expect_options,
    WaitForOptions, default_wait_for_options,
    WindowInfo, empty_window_info,
    PlaySession, empty_play_session,
    PlayError, play_error, play_error_with_detail,
    LocatorSpec, locator_css, locator_xpath, locator_role, locator_text, locator_test_id,
    BACKEND_CDP, BACKEND_SDL2, BACKEND_WM, BACKEND_ORCHESTRATOR,
    STATE_READY, STATE_CLOSED, STATE_FAILED,
    DEFAULT_EXPECT_TIMEOUT_MS, DEFAULT_ACTION_TIMEOUT_MS, DEFAULT_LAUNCH_TIMEOUT_MS
}

use std.play.cdp.client.{CdpClient}
use std.play.cdp.session.{CdpSession}
use std.play.launcher.{launcher_launch, launcher_kill}
use std.play.page.{Page}
use std.play.locator.{Locator}
use std.play.keyboard.{Keyboard}
use std.play.mouse.{Mouse}
use std.play.electron_application.{ElectronApplication}
use std.play.expect.{
    expect_page, expect_locator, expect_page_with, expect_locator_with,
    PageExpect, LocatorExpect
}

# ============================================================================
# Namespace facades
#
# Simple doesn't have JS-style nested objects, so we provide static helpers
# on namespace classes to achieve `play.electron.launch(opts)` syntax.
# ============================================================================

class PlayElectronFacade:
    static fn launch(opts: LaunchOptions) -> Result<ElectronApplication, PlayError>:
        ElectronApplication.launch(opts)

    static fn launch_default(args: [text]) -> Result<ElectronApplication, PlayError>:
        var opts = default_launch_options()
        opts.args = args
        ElectronApplication.launch(opts)

# Top-level `play` namespace — users call `play.electron.launch(...)` by
# spelling `PlayElectronFacade.launch(...)` in Simple; we also provide
# `electron_launch(...)` as a simple function for ergonomics.

fn electron_launch(opts: LaunchOptions) -> Result<ElectronApplication, PlayError>:
    ElectronApplication.launch(opts)

fn electron_launch_args(args: [text]) -> Result<ElectronApplication, PlayError>:
    var opts = default_launch_options()
    opts.args = args
    ElectronApplication.launch(opts)

# ============================================================================
# expect() unified factory
#
# Playwright's expect() accepts either a Page or a Locator. Simple's type
# system prefers explicit overloads, so we provide expect_page / expect_locator.
# The unified `expect` helper can be used when the type is clear.
# ============================================================================

fn expect_for_page(page: Page) -> PageExpect:
    expect_page(page)

fn expect_for_locator(loc: Locator) -> LocatorExpect:
    expect_locator(loc)
