# std.play.wm — Native window manager backend (shell-out)
#
# Provides a Playwright-ish surface for driving arbitrary OS windows.
# Implementation shells out to platform CLIs via bounded process execution per the
# "no Rust rebuild" constraint:
#
#   macOS   — `screencapture` (screenshots), `osascript` (focus/click via UI
#             scripting), `cliclick` if available for more reliable input
#   Linux   — `import` (screenshots from ImageMagick), `xdotool` (window
#             enumeration, focus, click, type, key)
#   Windows — PowerShell scripts invoking System.Windows.Forms and
#             System.Drawing for SendKeys + BitBlt screenshots
#
# This is NOT a full Playwright API — the surface is the subset that makes
# sense for foreign windows:
#   wm.screenshot(path)           — full-desktop capture
#   wm.screenshot_window(id, p)   — per-window capture when supported
#   wm.list_windows()             — enumerate windows
#   wm.focus_window(id)           — raise/focus window
#   wm.click(x, y)                — desktop-coordinate click
#   wm.type_text(text)            — type into focused window
#   wm.press(key)                 — press key (platform key name)
#
# All functions return `Result<_, PlayError>` so they compose with the
# rest of std.play.

use std.play.types.{PlayError, play_error, WindowInfo, ERR_BACKEND_UNAVAILABLE, ERR_LAUNCH_FAILED, ERR_TIMEOUT}
use std.nogc_sync_mut.io_runtime.{time_now_unix_micros}
use std.base_encoding.base64.{base64_encode}

val WM_PROCESS_TIMEOUT_MS: i64 = 2000
val WM_LINUX_INVENTORY_SCRIPT = "printf 'ACTIVE=%s\\n' \"$(xdotool getactivewindow 2>/dev/null || true)\"; xdotool search --onlyvisible --name '.+' getwindowgeometry --shell %@ getwindowname %@"
val WM_MACOS_INVENTORY_SCRIPT = "set AppleScript's text item delimiters to linefeed\nset rows to {}\ntell application \"System Events\"\nrepeat with p in (every process whose visible is true)\nset processId to unix id of p\nrepeat with w in windows of p\nset windowNumber to \"\"\ntry\nset windowNumber to value of attribute \"AXWindowNumber\" of w as text\nend try\nif windowNumber is not \"\" then\nset windowTitle to name of w\nset isFocused to false\ntry\nset isFocused to value of attribute \"AXMain\" of w\nend try\nset end of rows to \"mac::\" & (processId as text) & \"::\" & windowNumber & tab & (isFocused as text) & tab & windowTitle\nend if\nend repeat\nend repeat\nend tell\nreturn rows as text"
val WM_LINUX_TARGET_TYPE_SCRIPT = "test \"$(xdotool getactivewindow)\" = \"$1\" || exit 3; exec xdotool type --window \"$1\" --delay 10 -- \"$2\""
val WM_MACOS_WINDOW_ACTION_SCRIPT = "on run argv\nset processId to (item 1 of argv) as integer\nset windowNumber to item 2 of argv\nset expectedTitle to item 3 of argv\nset requestedAction to item 4 of argv\nset literalText to item 5 of argv\ntell application \"System Events\"\nset matchingProcesses to every process whose unix id is processId\nif (count matchingProcesses) is not 1 then error \"target process changed\"\ntell item 1 of matchingProcesses\nset matchingWindows to {}\nrepeat with candidate in windows\ntry\nif (value of attribute \"AXWindowNumber\" of candidate as text) is windowNumber then set end of matchingWindows to candidate\nend try\nend repeat\nif (count matchingWindows) is not 1 then error \"target window changed\"\nset targetWindow to item 1 of matchingWindows\nif expectedTitle is not \"\" and (name of targetWindow as text) is not expectedTitle then error \"target title changed\"\nif requestedAction is \"focus\" then\nset frontmost to true\nperform action \"AXRaise\" of targetWindow\nelse if requestedAction is \"type_text\" then\nif not (value of attribute \"AXMain\" of targetWindow) then error \"target window is not focused\"\nset focusedElement to value of attribute \"AXFocusedUIElement\"\nset value of attribute \"AXSelectedText\" of focusedElement to literalText\nelse\nerror \"unsupported action\"\nend if\nend tell\nend tell\nend run"

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool

fn _wm_run(cmd: text, args: [text]) -> (text, text, i64):
    _wm_run_until(cmd, args, 0)

fn _wm_process_timeout(deadline_ms: i64, now_ms: i64) -> i64:
    if deadline_ms <= 0: return WM_PROCESS_TIMEOUT_MS
    val remaining_ms = deadline_ms - now_ms
    if remaining_ms <= 0: return 0
    if remaining_ms < WM_PROCESS_TIMEOUT_MS: return remaining_ms
    WM_PROCESS_TIMEOUT_MS

fn _wm_run_until(cmd: text, args: [text], deadline_ms: i64) -> (text, text, i64):
    val timeout_ms = _wm_process_timeout(deadline_ms, time_now_unix_micros() / 1000)
    if timeout_ms == 0: return ("", "TIMEOUT", -1)
    val result = rt_process_run_timeout(cmd, args, timeout_ms)
    (result.0, result.1, result.2.to_i64())

# ============================================================================
# Platform detection
# ============================================================================

fn wm_is_macos() -> bool:
    wm_platform() == "macos"

fn wm_is_linux() -> bool:
    wm_platform() == "linux"

fn wm_is_windows() -> bool:
    val os = rt_env_get("OS")
    if os == "" or os == nil: false else: os.lower().contains("windows")

fn wm_platform() -> text:
    _wm_platform_until(0)

fn _wm_platform_until(deadline_ms: i64) -> text:
    val r = _wm_run_until("uname", ["-s"], deadline_ms)
    val name = r.0.trim()
    if name == "Darwin": return "macos"
    if name == "Linux": return "linux"
    if r.1 == "TIMEOUT": return "timeout"
    if wm_is_windows(): return "windows"
    "unknown"

fn _have_cmd(cmd: text) -> bool:
    _have_cmd_until(cmd, 0)

fn _have_cmd_until(cmd: text, deadline_ms: i64) -> bool:
    val r = _wm_run_until("which", [cmd], deadline_ms)
    r.2 == 0 and r.0.trim() != ""

fn _wm_timeout_error(operation: text) -> PlayError:
    play_error(ERR_TIMEOUT, operation + ": TIMEOUT")

# ============================================================================
# Screenshots
# ============================================================================

fn wm_screenshot(path: text) -> Result<text, PlayError>:
    wm_screenshot_until(path, 0)

fn wm_screenshot_until(path: text, deadline_ms: i64) -> Result<text, PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("screenshot"))
    if platform == "macos":
        val r = _wm_run_until("screencapture", ["-x", path], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "screencapture failed: " + r.1))
        return Ok(path)
    if platform == "linux":
        if _have_cmd_until("import", deadline_ms):
            val r = _wm_run_until("import", ["-window", "root", path], deadline_ms)
            if r.2 != 0:
                return Err(play_error(ERR_BACKEND_UNAVAILABLE, "import failed: " + r.1))
            return Ok(path)
        if _have_cmd_until("scrot", deadline_ms):
            val r = _wm_run_until("scrot", [path], deadline_ms)
            if r.2 != 0:
                return Err(play_error(ERR_BACKEND_UNAVAILABLE, "scrot failed: " + r.1))
            return Ok(path)
        if _wm_process_timeout(deadline_ms, time_now_unix_micros() / 1000) == 0:
            return Err(_wm_timeout_error("screenshot"))
        return Err(play_error(ERR_BACKEND_UNAVAILABLE, "no screenshot tool (install imagemagick or scrot)"))
    if platform == "windows":
        val ps = "Add-Type -AssemblyName System.Windows.Forms,System.Drawing; $bmp = New-Object Drawing.Bitmap([Windows.Forms.SystemInformation]::VirtualScreen.Width, [Windows.Forms.SystemInformation]::VirtualScreen.Height); $g = [Drawing.Graphics]::FromImage($bmp); $g.CopyFromScreen(0, 0, 0, 0, $bmp.Size); $bmp.Save('" + path + "')"
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", ps], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell screenshot failed: " + r.1))
        return Ok(path)
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "unsupported platform: " + platform))

# ============================================================================
# Window enumeration
# ============================================================================

fn wm_list_windows() -> Result<[WindowInfo], PlayError>:
    wm_list_windows_until(0)

fn wm_list_windows_until(deadline_ms: i64) -> Result<[WindowInfo], PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("list_windows"))
    if platform == "linux":
        if not _have_cmd_until("xdotool", deadline_ms):
            if _wm_process_timeout(deadline_ms, time_now_unix_micros() / 1000) == 0:
                return Err(_wm_timeout_error("list_windows"))
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool not installed"))
        val r = _wm_run_until("sh", ["-c", WM_LINUX_INVENTORY_SCRIPT], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool inventory failed: " + r.1))
        return Ok(_wm_parse_linux_inventory(r.0))
    if platform == "macos":
        val r = _wm_run_until("osascript", ["-e", WM_MACOS_INVENTORY_SCRIPT], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "osascript failed: " + r.1))
        return Ok(_wm_parse_window_rows(r.0))
    if platform == "windows":
        val ps = "Add-Type -TypeDefinition 'using System; using System.Runtime.InteropServices; public static class WmNative { [DllImport(\"user32.dll\")] public static extern IntPtr GetForegroundWindow(); }'; $active=[WmNative]::GetForegroundWindow().ToInt64(); Get-Process | Where-Object {$_.MainWindowTitle -ne ''} | ForEach-Object { $handle=$_.MainWindowHandle.ToInt64(); $title=$_.MainWindowTitle -replace '[`t`r`n]',' '; $focused=($handle -eq $active).ToString().ToLower(); Write-Output (\"{0}`t{1}`t{2}\" -f $handle,$focused,$title) }"
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", ps], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell failed: " + r.1))
        return Ok(_wm_parse_window_rows(r.0))
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "list_windows: unsupported platform"))

fn _wm_parse_window_rows(raw: text) -> [WindowInfo]:
    var out: [WindowInfo] = []
    for line in raw.split("\n"):
        val parts = line.trim().split("\t")
        if parts.len() >= 3 and parts[0] != "":
            out = out.push(WindowInfo(
                window_id: parts[0],
                target_id: parts[0],
                title: parts[2],
                url: "",
                x: 0,
                y: 0,
                width: 0,
                height: 0,
                focused: parts[1].lower() == "true"
            ))
    out

fn _wm_parse_linux_inventory(raw: text) -> [WindowInfo]:
    var active = ""
    var ids: [text] = []
    var xs: [i64] = []
    var ys: [i64] = []
    var widths: [i64] = []
    var heights: [i64] = []
    var titles: [text] = []
    var title_phase = false
    for line in raw.split("\n"):
        val clean = line.trim()
        if clean.starts_with("ACTIVE="):
            active = clean.slice(7, clean.len())
        elif not title_phase and clean.starts_with("WINDOW="):
            ids.push(clean.slice(7, clean.len()))
            xs.push(0)
            ys.push(0)
            widths.push(0)
            heights.push(0)
        elif not title_phase and ids.len() > 0 and clean.starts_with("X="):
            xs[xs.len() - 1] = clean.slice(2, clean.len()).to_i64() ?? 0
        elif not title_phase and ids.len() > 0 and clean.starts_with("Y="):
            ys[ys.len() - 1] = clean.slice(2, clean.len()).to_i64() ?? 0
        elif not title_phase and ids.len() > 0 and clean.starts_with("WIDTH="):
            widths[widths.len() - 1] = clean.slice(6, clean.len()).to_i64() ?? 0
        elif not title_phase and ids.len() > 0 and clean.starts_with("HEIGHT="):
            heights[heights.len() - 1] = clean.slice(7, clean.len()).to_i64() ?? 0
        elif not title_phase and clean.starts_with("SCREEN="):
            ()
        else:
            title_phase = true
            if titles.len() < ids.len():
                titles.push(line.replace("\t", " ").replace("\r", " "))
    var out: [WindowInfo] = []
    var i: i64 = 0
    while i < ids.len() and i < titles.len():
        out.push(WindowInfo(
            window_id: ids[i],
            target_id: ids[i],
            title: titles[i],
            url: "",
            x: xs[i],
            y: ys[i],
            width: widths[i],
            height: heights[i],
            focused: ids[i] == active
        ))
        i = i + 1
    out

# ============================================================================
# Window focus
# ============================================================================

fn wm_focus_window(window_id: text) -> Result<(), PlayError>:
    wm_focus_window_until(window_id, 0)

fn wm_focus_window_until(window_id: text, deadline_ms: i64) -> Result<(), PlayError>:
    wm_focus_window_checked_until(window_id, "", deadline_ms)

fn wm_focus_window_checked_until(window_id: text, expected_title: text, deadline_ms: i64) -> Result<(), PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("focus_window"))
    if platform == "linux":
        val r = _wm_run_until("xdotool", ["windowactivate", "--sync", window_id], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool windowactivate: " + r.1))
        return Ok(())
    if platform == "macos":
        val args = match _wm_macos_window_action_args(window_id, expected_title, "focus", ""):
            Some(found): found
            nil: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "invalid or unverified macOS window identity"))
        val r = _wm_run_until("osascript", args, deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "osascript activate: " + r.1))
        return Ok(())
    if platform == "windows":
        if window_id.to_i64() == nil:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "invalid Windows window identity"))
        val ps = "Add-Type -TypeDefinition 'using System; using System.Runtime.InteropServices; public static class WmFocus { [DllImport(\"user32.dll\")] public static extern bool IsWindow(IntPtr h); [DllImport(\"user32.dll\")] public static extern bool SetForegroundWindow(IntPtr h); }'; $h=[IntPtr]::new(" + window_id + "); if (-not [WmFocus]::IsWindow($h) -or -not [WmFocus]::SetForegroundWindow($h)) { exit 3 }"
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", ps], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell activate: " + r.1))
        return Ok(())
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "focus_window: unsupported platform"))

# ============================================================================
# Input injection
# ============================================================================

fn wm_click(x: i64, y: i64) -> Result<(), PlayError>:
    wm_click_until(x, y, 0)

fn wm_click_until(x: i64, y: i64, deadline_ms: i64) -> Result<(), PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("click"))
    if platform == "linux":
        if not _have_cmd_until("xdotool", deadline_ms):
            if _wm_process_timeout(deadline_ms, time_now_unix_micros() / 1000) == 0:
                return Err(_wm_timeout_error("click"))
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool not installed"))
        val r1 = _wm_run_until("xdotool", ["mousemove", "{x}", "{y}"], deadline_ms)
        if r1.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool mousemove: " + r1.1))
        val r2 = _wm_run_until("xdotool", ["click", "1"], deadline_ms)
        if r2.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool click: " + r2.1))
        return Ok(())
    if platform == "macos":
        if _have_cmd_until("cliclick", deadline_ms):
            val r = _wm_run_until("cliclick", ["c:{x},{y}"], deadline_ms)
            if r.2 != 0:
                return Err(play_error(ERR_BACKEND_UNAVAILABLE, "cliclick: " + r.1))
            return Ok(())
        val script = "tell application \"System Events\" to click at {" + str(x) + ", " + str(y) + "}"
        val r = _wm_run_until("osascript", ["-e", script], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "osascript click (needs accessibility permission): " + r.1))
        return Ok(())
    if platform == "windows":
        val ps =
            "Add-Type -AssemblyName System.Windows.Forms; " +
            "[System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point(" + str(x) + ", " + str(y) + "); " +
            "Add-Type -MemberDefinition '[DllImport(\"user32.dll\")] public static extern void mouse_event(uint f, int dx, int dy, uint d, int i);' -Name U32 -Namespace W; " +
            "[W.U32]::mouse_event(2, 0, 0, 0, 0); [W.U32]::mouse_event(4, 0, 0, 0, 0)"
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", ps], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell click: " + r.1))
        return Ok(())
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "click: unsupported platform"))

fn wm_type_text(value: text) -> Result<(), PlayError>:
    wm_type_text_until(value, 0)

fn wm_type_text_until(value: text, deadline_ms: i64) -> Result<(), PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("type_text"))
    if platform == "linux":
        if not _have_cmd_until("xdotool", deadline_ms):
            if _wm_process_timeout(deadline_ms, time_now_unix_micros() / 1000) == 0:
                return Err(_wm_timeout_error("type_text"))
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool not installed"))
        val r = _wm_run_until("xdotool", ["type", "--delay", "10", value], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool type: " + r.1))
        return Ok(())
    if platform == "macos":
        if _have_cmd_until("cliclick", deadline_ms):
            val r = _wm_run_until("cliclick", ["t:" + value], deadline_ms)
            if r.2 != 0:
                return Err(play_error(ERR_BACKEND_UNAVAILABLE, "cliclick type: " + r.1))
            return Ok(())
        val script = "tell application \"System Events\" to keystroke \"" + value.replace("\"", "\\\"") + "\""
        val r = _wm_run_until("osascript", ["-e", script], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "osascript keystroke: " + r.1))
        return Ok(())
    if platform == "windows":
        val escaped = value.replace("'", "''")
        val ps = "Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.SendKeys]::SendWait('" + escaped + "')"
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", ps], deadline_ms)
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell SendKeys: " + r.1))
        return Ok(())
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "type_text: unsupported platform"))

fn _wm_linux_target_type_args(window_id: text, value: text) -> [text]:
    ["-c", WM_LINUX_TARGET_TYPE_SCRIPT, "wm-type", window_id, value]

fn _wm_macos_window_action_args(window_id: text, expected_title: text, action: text, value: text) -> [text]?:
    val parts = window_id.split("::")
    if parts.len() != 3 or parts[0] != "mac" or parts[1].to_i64() == nil or parts[2].to_i64() == nil: return nil
    ["-e", WM_MACOS_WINDOW_ACTION_SCRIPT, parts[1], parts[2], expected_title, action, value]

fn _wm_windows_target_type_script(window_id: text, value: text) -> text:
    val encoded = base64_encode(value)
    "Add-Type -TypeDefinition 'using System; using System.Runtime.InteropServices; public static class WmType { [StructLayout(LayoutKind.Sequential)] public struct RECT { public int left, top, right, bottom; } [StructLayout(LayoutKind.Sequential)] public struct GUITHREADINFO { public int cbSize; public uint flags; public IntPtr hwndActive, hwndFocus, hwndCapture, hwndMenuOwner, hwndMoveSize, hwndCaret; public RECT rcCaret; } [DllImport(\"user32.dll\")] public static extern bool IsWindow(IntPtr h); [DllImport(\"user32.dll\")] public static extern IntPtr GetForegroundWindow(); [DllImport(\"user32.dll\")] public static extern uint GetWindowThreadProcessId(IntPtr h, IntPtr p); [DllImport(\"user32.dll\")] public static extern bool GetGUIThreadInfo(uint id, ref GUITHREADINFO i); [DllImport(\"user32.dll\")] public static extern IntPtr GetAncestor(IntPtr h, uint f); [DllImport(\"user32.dll\", CharSet=CharSet.Unicode)] public static extern IntPtr SendMessage(IntPtr h, uint m, IntPtr w, IntPtr l); }'; $h=[IntPtr]::new(" + window_id + "); if (-not [WmType]::IsWindow($h) -or [WmType]::GetForegroundWindow() -ne $h) { exit 3 }; $i=New-Object WmType+GUITHREADINFO; $i.cbSize=[Runtime.InteropServices.Marshal]::SizeOf($i); $tid=[WmType]::GetWindowThreadProcessId($h,[IntPtr]::Zero); if (-not [WmType]::GetGUIThreadInfo($tid,[ref]$i) -or $i.hwndFocus -eq [IntPtr]::Zero -or [WmType]::GetAncestor($i.hwndFocus,2) -ne $h) { exit 4 }; $text=[Text.Encoding]::UTF8.GetString([Convert]::FromBase64String('" + encoded + "')); foreach ($c in $text.ToCharArray()) { [void][WmType]::SendMessage($i.hwndFocus,0x0102,[IntPtr][int]$c,[IntPtr]::Zero) }"

fn wm_type_text_window_until(window_id: text, value: text, deadline_ms: i64) -> Result<(), PlayError>:
    wm_type_text_window_checked_until(window_id, "", value, deadline_ms)

fn wm_type_text_window_checked_until(window_id: text, expected_title: text, value: text, deadline_ms: i64) -> Result<(), PlayError>:
    val platform = _wm_platform_until(deadline_ms)
    if platform == "timeout": return Err(_wm_timeout_error("type_text"))
    if platform == "linux":
        if not _have_cmd_until("xdotool", deadline_ms):
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool not installed"))
        val r = _wm_run_until("sh", _wm_linux_target_type_args(window_id, value), deadline_ms)
        if r.2 != 0: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "target-scoped xdotool type failed: " + r.1))
        return Ok(())
    if platform == "macos":
        val args = match _wm_macos_window_action_args(window_id, expected_title, "type_text", value):
            Some(found): found
            nil: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "invalid or unverified macOS window identity"))
        val r = _wm_run_until("osascript", args, deadline_ms)
        if r.2 != 0: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "target-scoped osascript type failed: " + r.1))
        return Ok(())
    if platform == "windows":
        if window_id.to_i64() == nil: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "invalid Windows window identity"))
        val r = _wm_run_until("powershell", ["-NoProfile", "-Command", _wm_windows_target_type_script(window_id, value)], deadline_ms)
        if r.2 != 0: return Err(play_error(ERR_BACKEND_UNAVAILABLE, "target-scoped Windows type failed: " + r.1))
        return Ok(())
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "type_text: unsupported platform"))

fn wm_press(key: text) -> Result<(), PlayError>:
    if wm_is_linux():
        val r = _wm_run("xdotool", ["key", key])
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "xdotool key: " + r.1))
        return Ok(())
    if wm_is_macos():
        val script = "tell application \"System Events\" to key code " + _macos_key_code(key)
        val r = _wm_run("osascript", ["-e", script])
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "osascript key code: " + r.1))
        return Ok(())
    if wm_is_windows():
        val ps = "Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.SendKeys]::SendWait('" + _windows_send_key(key) + "')"
        val r = _wm_run("powershell", ["-NoProfile", "-Command", ps])
        if r.2 != 0:
            return Err(play_error(ERR_BACKEND_UNAVAILABLE, "powershell press: " + r.1))
        return Ok(())
    Err(play_error(ERR_BACKEND_UNAVAILABLE, "press: unsupported platform"))

fn _macos_key_code(key: text) -> text:
    val k = key.lower()
    if k == "return" or k == "enter": return "36"
    if k == "tab": return "48"
    if k == "space": return "49"
    if k == "escape" or k == "esc": return "53"
    if k == "left": return "123"
    if k == "right": return "124"
    if k == "down": return "125"
    if k == "up": return "126"
    "36"

fn _windows_send_key(key: text) -> text:
    val k = key.lower()
    if k == "return" or k == "enter": return "\{ENTER\}"
    if k == "tab": return "\{TAB\}"
    if k == "escape" or k == "esc": return "\{ESC\}"
    if k == "left": return "\{LEFT\}"
    if k == "right": return "\{RIGHT\}"
    if k == "up": return "\{UP\}"
    if k == "down": return "\{DOWN\}"
    if k == "space": return " "
    key
