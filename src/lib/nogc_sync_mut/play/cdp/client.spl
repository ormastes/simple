@allow(primitive_api)
# std.play.cdp.client — Chrome DevTools Protocol client
#
# Self-contained WebSocket+CDP client layered directly over TcpStream.
# Does NOT depend on std.websocket (which requires List<i64> boxing). Instead
# we build and parse WebSocket frames using plain `[i64]` byte arrays so we
# can hand bytes straight to `tcp_stream_write` / `tcp_stream_read`.
#
# Usage:
#   val client = CdpClient.connect("ws://127.0.0.1:9222/devtools/browser/XYZ")?
#   val result = client.send("Target.getTargets", "{}", 5000)?
#   client.close()
#
# The client uses a polling read loop with a short TCP read timeout to
# interleave request/response correlation with event dispatch. This avoids
# the complexity of non-blocking mode's EAGAIN handling while still letting
# send() wait for its specific response id.

use std.net.tcp.{TcpStream}
use std.json.builder.{JsonBuilder, escape_json}
use std.json.parser.{json_parse}
use std.play.types.{
    PlayError, play_error, play_error_with_detail,
    ERR_CDP_PROTOCOL, ERR_CDP_TRANSPORT, ERR_TIMEOUT, ERR_INVALID_ARGUMENT
}

extern fn rt_time_now_unix_micros() -> i64
extern fn bytes_to_string(bytes: [u8]) -> text
extern fn rt_string_data(s: text) -> [u8]
extern fn rt_string_len(s: text) -> i64

# ============================================================================
# WebSocket frame constants (RFC 6455)
# ============================================================================

val WS_FIN = 0x80
val WS_MASK = 0x80
val WS_OP_CONT = 0x0
val WS_OP_TEXT = 0x1
val WS_OP_BINARY = 0x2
val WS_OP_CLOSE = 0x8
val WS_OP_PING = 0x9
val WS_OP_PONG = 0xA

# ============================================================================
# URL parsing
# ============================================================================

fn cdp_parse_ws_url(url: text) -> (text, i64, text, bool):
    """Parse a ws:// or wss:// URL into (host, port, path, is_secure).

    Returns ("", 0, "", false) on malformed input.
    """
    var rest = url
    var secure = false
    if rest.starts_with("wss://"):
        secure = true
        rest = rest.substring(6)
    else:
        if rest.starts_with("ws://"):
            rest = rest.substring(5)
        else:
            return ("", 0, "", false)

    var host_port = rest
    var path = "/"
    val slash_idx = rest.index_of("/")
    if slash_idx >= 0:
        host_port = rest.substring(0, slash_idx)
        path = rest.substring(slash_idx)

    var host = host_port
    var port = if secure: 443 else: 80
    val colon_idx = host_port.index_of(":")
    if colon_idx >= 0:
        host = host_port.substring(0, colon_idx)
        val port_str = host_port.substring(colon_idx + 1)
        port = int(port_str)

    (host, port, path, secure)

# ============================================================================
# Text ↔ byte helpers
# ============================================================================

fn cdp_text_to_bytes(s: text) -> [i64]:
    var out: [i64] = []
    val n = s.length()
    var i = 0
    while i < n:
        val b = s.char_at(i).byte_at(0)
        out.push(b)
        i = i + 1
    out

fn cdp_bytes_to_text(bytes: [i64]) -> text:
    var parts: [text] = []
    val n = bytes.length()
    var i = 0
    while i < n:
        val b = bytes[i] & 0xFF
        parts.push(String.from_byte(b))
        i = i + 1
    parts.join("")

fn cdp_i64_array_to_u8(bytes: [i64]) -> [u8]:
    """Convert [i64] byte values to [u8] for tcp_stream_write."""
    var out: [u8] = []
    val n = bytes.length()
    var i = 0
    while i < n:
        out.push((bytes[i] & 0xFF) as u8)
        i = i + 1
    out

fn cdp_u8_to_i64_array(bytes: [u8]) -> [i64]:
    var out: [i64] = []
    val n = bytes.length()
    var i = 0
    while i < n:
        out.push((bytes[i] as i64) & 0xFF)
        i = i + 1
    out

# ============================================================================
# WebSocket handshake key generation (RFC 6455 section 4.1)
#
# For a client, the 16-byte random nonce is base64-encoded and sent as
# Sec-WebSocket-Key. We reuse std.websocket.handshake's routines.
# ============================================================================

use std.websocket.handshake.{generate_websocket_key}

# ============================================================================
# Frame builders
# ============================================================================

fn cdp_make_mask_key() -> [i64]:
    val t = rt_time_now_unix_micros()
    var mk: [i64] = []
    mk.push(((t >> 0) & 0xFF) ^ 0x5A)
    mk.push(((t >> 8) & 0xFF) ^ 0xA5)
    mk.push(((t >> 16) & 0xFF) ^ 0x3C)
    mk.push(((t >> 24) & 0xFF) ^ 0xC3)
    mk

fn cdp_build_frame(opcode: i64, payload: [i64]) -> [i64]:
    """Build a MASKED client frame. Client frames MUST be masked per RFC 6455."""
    var out: [i64] = []
    val pl = payload.length()

    out.push(WS_FIN | (opcode & 0x0F))

    if pl < 126:
        out.push(WS_MASK | pl)
    else:
        if pl < 65536:
            out.push(WS_MASK | 126)
            out.push((pl >> 8) & 0xFF)
            out.push(pl & 0xFF)
        else:
            out.push(WS_MASK | 127)
            # 64-bit length — we push 4 zero bytes + 4 length bytes
            out.push(0)
            out.push(0)
            out.push(0)
            out.push(0)
            out.push((pl >> 24) & 0xFF)
            out.push((pl >> 16) & 0xFF)
            out.push((pl >> 8) & 0xFF)
            out.push(pl & 0xFF)

    val mk = cdp_make_mask_key()
    out.push(mk[0])
    out.push(mk[1])
    out.push(mk[2])
    out.push(mk[3])

    var i = 0
    while i < pl:
        out.push(payload[i] ^ mk[i % 4])
        i = i + 1

    out

fn cdp_build_text_frame(s: text) -> [i64]:
    cdp_build_frame(WS_OP_TEXT, cdp_text_to_bytes(s))

fn cdp_build_close_frame(code: i64) -> [i64]:
    var payload: [i64] = []
    payload.push((code >> 8) & 0xFF)
    payload.push(code & 0xFF)
    cdp_build_frame(WS_OP_CLOSE, payload)

fn cdp_build_pong_frame(data: [i64]) -> [i64]:
    cdp_build_frame(WS_OP_PONG, data)

# ============================================================================
# Frame parser
#
# Given a current buffer, try to extract one complete frame. Returns:
#   (parsed: bool, opcode: i64, payload: [i64], consumed: i64)
# If parsed == false, need more bytes (consumed=0).
# ============================================================================

struct CdpParsedFrame:
    parsed: bool
    fin: i64
    opcode: i64
    payload: [i64]
    consumed: i64

fn cdp_parse_frame(buf: [i64]) -> CdpParsedFrame:
    val n = buf.length()
    if n < 2:
        return CdpParsedFrame(parsed: false, fin: 0, opcode: 0, payload: [], consumed: 0)

    val b0 = buf[0]
    val b1 = buf[1]
    val fin = if (b0 & WS_FIN) != 0: 1 else: 0
    val opcode = b0 & 0x0F
    val masked = (b1 & WS_MASK) != 0
    var plen = b1 & 0x7F
    var header = 2

    if plen == 126:
        if n < 4: return CdpParsedFrame(parsed: false, fin: 0, opcode: 0, payload: [], consumed: 0)
        plen = (buf[2] << 8) | buf[3]
        header = 4
    else:
        if plen == 127:
            if n < 10: return CdpParsedFrame(parsed: false, fin: 0, opcode: 0, payload: [], consumed: 0)
            # We only support 32-bit sizes
            plen = (buf[6] << 24) | (buf[7] << 16) | (buf[8] << 8) | buf[9]
            header = 10

    var mask_key: [i64] = []
    if masked:
        if n < header + 4: return CdpParsedFrame(parsed: false, fin: 0, opcode: 0, payload: [], consumed: 0)
        mask_key.push(buf[header])
        mask_key.push(buf[header + 1])
        mask_key.push(buf[header + 2])
        mask_key.push(buf[header + 3])
        header = header + 4

    val total = header + plen
    if n < total:
        return CdpParsedFrame(parsed: false, fin: 0, opcode: 0, payload: [], consumed: 0)

    var payload: [i64] = []
    var i = 0
    while i < plen:
        var byte = buf[header + i]
        if masked:
            byte = byte ^ mask_key[i % 4]
        payload.push(byte)
        i = i + 1

    CdpParsedFrame(parsed: true, fin: fin, opcode: opcode, payload: payload, consumed: total)

fn cdp_buffer_drop_front(buf: [i64], n: i64) -> [i64]:
    var out: [i64] = []
    val total = buf.length()
    var i = n
    while i < total:
        out.push(buf[i])
        i = i + 1
    out

# ============================================================================
# CDP response / event records
# ============================================================================

struct CdpPending:
    id: i64
    body: text
    resolved: bool
    is_error: bool
    error_message: text

struct CdpEvent:
    method: text
    params_json: text
    session_id: text

# ============================================================================
# CdpClient class
# ============================================================================

class CdpClient:
    stream: TcpStream
    host: text
    port: i64
    path: text
    next_id: i64
    buffer: [i64]
    pending: [CdpPending]
    events: [CdpEvent]
    message_log: [text]
    closed: bool

    static fn connect(ws_url: text, timeout_ms: i64) -> Result<CdpClient, PlayError>:
        """Open a CDP WebSocket connection and perform the HTTP upgrade."""
        val (host, port, path, secure) = cdp_parse_ws_url(ws_url)
        if host == "":
            return Err(play_error(ERR_INVALID_ARGUMENT, "malformed ws url: {ws_url}"))
        if secure:
            return Err(play_error(ERR_CDP_TRANSPORT, "wss:// not supported by CdpClient (CDP uses plain ws)"))

        val addr = "{host}:{port}"
        val conn_timeout = if timeout_ms > 0: timeout_ms else: 10000
        val stream_res = tcp_stream_connect_timeout(addr, conn_timeout)
        var stream: TcpStream = match stream_res:
            case Ok(s): s
            case Err(e): return Err(play_error_with_detail(ERR_CDP_TRANSPORT, "tcp connect failed", addr))

        tcp_stream_set_read_timeout(stream, 200)
        tcp_stream_set_nodelay(stream, true)

        # Send HTTP upgrade
        val key = generate_websocket_key()
        val req =
            "GET {path} HTTP/1.1\r\n" +
            "Host: {host}:{port}\r\n" +
            "Upgrade: websocket\r\n" +
            "Connection: Upgrade\r\n" +
            "Sec-WebSocket-Key: {key}\r\n" +
            "Sec-WebSocket-Version: 13\r\n" +
            "\r\n"
        val req_bytes = cdp_i64_array_to_u8(cdp_text_to_bytes(req))
        match tcp_stream_write_all(stream, req_bytes):
            case Ok(_): pass_do_nothing
            case Err(e):
                tcp_stream_close(stream)
                return Err(play_error(ERR_CDP_TRANSPORT, "websocket handshake write failed"))

        # Read the upgrade response line-by-line until blank line
        var resp_text = ""
        var got_101 = false
        var header_done = false
        var iters = 0
        while not header_done and iters < 200:
            match tcp_stream_read_line(stream):
                case Ok(line):
                    resp_text = resp_text + line
                    if line == "\r\n" or line == "\n" or line == "":
                        header_done = true
                    if line.contains("101"):
                        got_101 = true
                case Err(e):
                    tcp_stream_close(stream)
                    return Err(play_error(ERR_CDP_TRANSPORT, "websocket handshake read failed"))
            iters = iters + 1

        if not got_101:
            tcp_stream_close(stream)
            return Err(play_error_with_detail(ERR_CDP_PROTOCOL, "expected 101 Switching Protocols", resp_text))

        val client = CdpClient(
            stream: stream,
            host: host,
            port: port,
            path: path,
            next_id: 1,
            buffer: [],
            pending: [],
            events: [],
            message_log: [],
            closed: false
        )
        Ok(client)

    me _pump_once() -> bool:
        """Read whatever is currently available, append to buffer, parse any
        complete frames. Returns true if any bytes were read."""
        if self.closed: return false
        val res = tcp_stream_read(self.stream, 8192)
        match res:
            case Ok(bytes):
                val n = bytes.length()
                if n == 0:
                    return false
                val extra = cdp_u8_to_i64_array(bytes)
                var i = 0
                while i < extra.length():
                    self.buffer.push(extra[i])
                    i = i + 1
                # Parse as many complete frames as possible
                var more = true
                while more:
                    val pf = cdp_parse_frame(self.buffer)
                    if not pf.parsed:
                        more = false
                    else:
                        self.buffer = cdp_buffer_drop_front(self.buffer, pf.consumed)
                        self._handle_frame(pf.opcode, pf.payload)
                true
            case Err(e):
                # Timeout or would-block — normal under polling
                false

    me _handle_frame(opcode: i64, payload: [i64]) -> bool:
        if opcode == WS_OP_TEXT:
            val msg = cdp_bytes_to_text(payload)
            self.message_log.push(msg)
            self._dispatch_json(msg)
            true
        else:
            if opcode == WS_OP_PING:
                val pong = cdp_build_pong_frame(payload)
                tcp_stream_write_all(self.stream, cdp_i64_array_to_u8(pong))
                true
            else:
                if opcode == WS_OP_CLOSE:
                    self.closed = true
                    true
                else:
                    # PONG, BINARY, CONT — ignore for CDP
                    false

    me _dispatch_json(msg: text) -> bool:
        """CDP messages are either {id,result} / {id,error} responses or
        {method,params,sessionId} events. Extract id or method via json_parse."""
        val parsed = json_parse(msg)
        if parsed == nil:
            return false

        # Simple's json_parse returns `any`. We use quick text scan as a
        # fallback that doesn't require typed dict access.
        val id_idx = msg.index_of("\"id\":")
        if id_idx >= 0:
            val id_val = _extract_int_after(msg, id_idx + 5)
            var is_error = msg.contains("\"error\":")
            var err_msg = ""
            if is_error:
                val e_idx = msg.index_of("\"message\":")
                if e_idx >= 0:
                    err_msg = _extract_string_after(msg, e_idx + 10)
            var updated = false
            var new_pending: [CdpPending] = []
            for p in self.pending:
                if p.id == id_val and not p.resolved:
                    new_pending.push(CdpPending(
                        id: p.id,
                        body: msg,
                        resolved: true,
                        is_error: is_error,
                        error_message: err_msg
                    ))
                    updated = true
                else:
                    new_pending.push(p)
            self.pending = new_pending
            return updated

        # Event path
        val m_idx = msg.index_of("\"method\":")
        if m_idx >= 0:
            val method = _extract_string_after(msg, m_idx + 9)
            var sid = ""
            val s_idx = msg.index_of("\"sessionId\":")
            if s_idx >= 0:
                sid = _extract_string_after(msg, s_idx + 12)
            self.events.push(CdpEvent(method: method, params_json: msg, session_id: sid))
            return true

        false

    me send(method: text, params_json: text, timeout_ms: i64) -> Result<text, PlayError>:
        """Send a CDP command and block until the matching response arrives."""
        if self.closed:
            return Err(play_error(ERR_CDP_TRANSPORT, "cdp client closed"))

        val id = self.next_id
        self.next_id = self.next_id + 1

        val params = if params_json == "": "{}" else: params_json
        val cmd = JsonBuilder.object()
            .field_int("id", id)
            .field("method", method)
            .field_raw("params", params)
            .build()

        val frame = cdp_build_text_frame(cmd)
        match tcp_stream_write_all(self.stream, cdp_i64_array_to_u8(frame)):
            case Ok(_): pass_do_nothing
            case Err(e):
                return Err(play_error(ERR_CDP_TRANSPORT, "cdp write failed"))

        self.pending.push(CdpPending(
            id: id, body: "", resolved: false, is_error: false, error_message: ""
        ))

        val deadline = rt_time_now_unix_micros() + (timeout_ms * 1000)
        while rt_time_now_unix_micros() < deadline:
            self._pump_once()
            for p in self.pending:
                if p.id == id and p.resolved:
                    if p.is_error:
                        return Err(play_error_with_detail(ERR_CDP_PROTOCOL, p.error_message, p.body))
                    return Ok(p.body)

        Err(play_error(ERR_TIMEOUT, "cdp send timed out after {timeout_ms}ms: {method}"))

    me send_on_session(session_id: text, method: text, params_json: text, timeout_ms: i64) -> Result<text, PlayError>:
        """Send a command scoped to a specific target (flatten mode)."""
        if self.closed:
            return Err(play_error(ERR_CDP_TRANSPORT, "cdp client closed"))

        val id = self.next_id
        self.next_id = self.next_id + 1

        val params = if params_json == "": "{}" else: params_json
        val cmd = JsonBuilder.object()
            .field_int("id", id)
            .field("method", method)
            .field_raw("params", params)
            .field("sessionId", session_id)
            .build()

        val frame = cdp_build_text_frame(cmd)
        match tcp_stream_write_all(self.stream, cdp_i64_array_to_u8(frame)):
            case Ok(_): pass_do_nothing
            case Err(e):
                return Err(play_error(ERR_CDP_TRANSPORT, "cdp write failed"))

        self.pending.push(CdpPending(
            id: id, body: "", resolved: false, is_error: false, error_message: ""
        ))

        val deadline = rt_time_now_unix_micros() + (timeout_ms * 1000)
        while rt_time_now_unix_micros() < deadline:
            self._pump_once()
            for p in self.pending:
                if p.id == id and p.resolved:
                    if p.is_error:
                        return Err(play_error_with_detail(ERR_CDP_PROTOCOL, p.error_message, p.body))
                    return Ok(p.body)

        Err(play_error(ERR_TIMEOUT, "cdp send timed out after {timeout_ms}ms: {method}"))

    me drain_events() -> [CdpEvent]:
        """Pump the read loop once and return any queued events."""
        self._pump_once()
        val out = self.events
        self.events = []
        out

    me wait_for_event(method: text, timeout_ms: i64) -> Result<CdpEvent, PlayError>:
        val deadline = rt_time_now_unix_micros() + (timeout_ms * 1000)
        while rt_time_now_unix_micros() < deadline:
            self._pump_once()
            var hit: CdpEvent = CdpEvent(method: "", params_json: "", session_id: "")
            var found = false
            var keep: [CdpEvent] = []
            for e in self.events:
                if not found and e.method == method:
                    hit = e
                    found = true
                else:
                    keep.push(e)
            if found:
                self.events = keep
                return Ok(hit)
        Err(play_error(ERR_TIMEOUT, "timed out waiting for event {method}"))

    me close() -> bool:
        if self.closed: return true
        val frame = cdp_build_close_frame(1000)
        tcp_stream_write_all(self.stream, cdp_i64_array_to_u8(frame))
        tcp_stream_close(self.stream)
        self.closed = true
        true

    me message_count() -> i64:
        self.message_log.length()

# ============================================================================
# Tiny JSON field extractors (text-mode, avoids typed dict access)
# ============================================================================

fn _extract_int_after(s: text, from: i64) -> i64:
    var i = from
    val n = s.length()
    while i < n and s.char_at(i) == " ":
        i = i + 1
    var negative = false
    if i < n and s.char_at(i) == "-":
        negative = true
        i = i + 1
    var val_acc: i64 = 0
    var seen = false
    while i < n:
        val c = s.char_at(i)
        val b = c.byte_at(0)
        if b >= 48 and b <= 57:
            val_acc = val_acc * 10 + (b - 48)
            seen = true
            i = i + 1
        else:
            i = n
    if not seen: 0 else: if negative: (0 - val_acc) else: val_acc

fn _extract_string_after(s: text, from: i64) -> text:
    var i = from
    val n = s.length()
    while i < n and s.char_at(i) != "\"":
        i = i + 1
    if i >= n: return ""
    i = i + 1
    var parts: [text] = []
    while i < n:
        val c = s.char_at(i)
        if c == "\"":
            return parts.join("")
        if c == "\\" and i + 1 < n:
            val nxt = s.char_at(i + 1)
            parts.push(nxt)
            i = i + 2
        else:
            parts.push(c)
            i = i + 1
    parts.join("")

# Re-export tcp functions that CdpClient depends on (so this file doesn't
# need std.net.ffi directly). They're already available via std.net.tcp.

extern fn tcp_stream_connect_timeout(addr: text, timeout_ms: i64) -> Result<TcpStream, SimpleError>
extern fn tcp_stream_read(stream: TcpStream, size: usize) -> Result<[u8], SimpleError>
extern fn tcp_stream_write_all(stream: TcpStream, data: [u8]) -> Result<(), SimpleError>
extern fn tcp_stream_read_line(stream: TcpStream) -> Result<text, SimpleError>
extern fn tcp_stream_set_read_timeout(stream: TcpStream, timeout_ms: i64?) -> bool
extern fn tcp_stream_set_nodelay(stream: TcpStream, nodelay: bool) -> bool
extern fn tcp_stream_close(stream: TcpStream)

use std.error.{SimpleError}
