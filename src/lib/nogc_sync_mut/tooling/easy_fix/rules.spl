@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# EasyFix Shared Rules Module
# Each rule: fn check_<rule>(source: String, file: String) -> [EasyFix]
#
# Rule IDs:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:spipe_missing_docstrings   — Add template docstring to describe/context
#   L:spipe_manual_assertions    — Replace manual if/fail with expect()
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:typo_suggestion            — Fix misspelled identifiers (Levenshtein)
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   E:type_mismatch_coercion     — Insert type coercion (.to_string() etc.)
#   L:deprecated_if_let          — Replace `if let` with `if val`
#   L:short_grammar_method_ref   — Replace `\x: x.method()` with `&:method`
#   L:short_grammar_placeholder  — Replace `\x: x * 2` with `_1 * 2`
#                                  Replace `\x: x.method() > 0` with `_1.method() > 0`
#
# Sub-modules:
#   rules_helpers.spl  — LineContext, line_contexts, byte offset helpers, parsing helpers
#   rules_lint.spl     — Rules 1, 3, 4, 5, 6 (lint rules)
#   rules_errors.spl   — Rules 7, 8, 9, 10 (error/deprecated rules)

# ============================================================================
# Data types imported from stdlib
# ============================================================================

use std.tooling.easy_fix.types.{EasyFix, FixConfidence, Replacement}
use std.tooling.easy_fix.rules_helpers.{
    LineContext, line_contexts,
    _split_top_level_csv, _find_top_level_colon, _find_matching_paren_on_line,
    _is_identifier_char, _is_digit_char
}
use std.tooling.easy_fix.rules_lint.{
    check_print_in_test_spec,
    check_resource_leak,
    check_spipe_missing_docstrings,
    check_spipe_manual_assertions,
    check_non_exhaustive_match
}
use std.tooling.easy_fix.rules_errors.{
    check_typo_suggestion,
    check_parser_contextual_keyword,
    check_type_mismatch_coercion,
    check_deprecated_if_let
}

struct DuplicateTypedArgSignature:
    name: text
    line_num: i64
    decl_paren_start: i64
    decl_paren_end: i64
    decl_column: i64
    arg_count: i64
    param_names: [text]
    new_params_text: text
    has_decl_rewrite: bool
    can_rewrite_calls: bool

struct ShortGrammarMethodRefCandidate:
    method: text
    end_offset: i64

struct ShortGrammarPlaceholderCandidate:
    new_text: text
    end_offset: i64

# ============================================================================
# Rule 2: unnamed_duplicate_typed_args
# Detects fn signatures with duplicate types that lack distinct names.
# Confidence: Uncertain
# ============================================================================

fn check_unnamed_duplicate_typed_args(source: String, file: String) -> [EasyFix]:
    val signatures = _collect_duplicate_typed_arg_signatures(source: source)
    var fixes: [EasyFix] = []

    for sig in signatures:
        var replacements: [Replacement] = []

        if sig.has_decl_rewrite:
            replacements.push(Replacement.create(
                file: file,
                start: sig.decl_paren_start,
                end: sig.decl_paren_end,
                line: sig.line_num,
                column: sig.decl_column,
                new_text: sig.new_params_text
            ))

        if sig.can_rewrite_calls and _is_unique_call_target(signatures: signatures, sig: sig):
            val call_replacements = _collect_call_replacements_for_signature(source: source, file: file, sig: sig)
            for rep in call_replacements:
                replacements.push(rep)

        if not replacements.is_empty():
            val description = if sig.has_decl_rewrite:
                "add distinct parameter names for duplicate types"
            else:
                "rewrite positional duplicate-typed arguments as named calls"
            var fix = EasyFix.create(
                id: "L:unnamed_duplicate_typed_args:{sig.line_num}",
                description: description,
                confidence: FixConfidence.Uncertain
            )
            for rep in replacements:
                fix.add_replacement(rep)
            fixes.push(fix)

    fixes

fn _collect_duplicate_typed_arg_signatures(source: text) -> [DuplicateTypedArgSignature]:
    var signatures: [DuplicateTypedArgSignature] = []
    for ctx in line_contexts(source):
        val sig = _parse_duplicate_typed_arg_signature(ctx)
        match sig:
            case Some(found):
                signatures.push(found)
            case nil:
                pass
    signatures

fn _parse_duplicate_typed_arg_signature(ctx: LineContext) -> Option<DuplicateTypedArgSignature>:
    if not _dup_is_fn_sig(trimmed: ctx.trimmed):
        return nil
    if not ctx.trimmed.contains("("):
        return nil

    val paren_start = _short_find_text_from(line: ctx.trimmed, needle: "(", search_from: 0)
    if paren_start < 0:
        return nil
    val paren_end = _find_matching_paren_on_line(text: ctx.trimmed, open_paren: paren_start)
    if paren_end <= paren_start:
        return nil

    val name = _extract_sig_name(trimmed: ctx.trimmed, paren_start: paren_start)
    if name == "":
        return nil

    val params_str = ctx.trimmed.slice(paren_start + 1, paren_end)
    val params = _split_top_level_csv(text: params_str)
    if params.is_empty():
        return nil

    var raw_names: [text] = []
    var raw_types: [text] = []
    var normalized_types: [text] = []
    var has_unnamed = false

    for param in params:
        val trimmed_param = param.trim()
        if trimmed_param == "":
            continue
        val colon_pos = _find_top_level_colon(text: trimmed_param)
        if colon_pos >= 0:
            raw_names.push(trimmed_param.slice(0, colon_pos).trim())
            raw_types.push(trimmed_param.slice(colon_pos + 1).trim())
        else:
            raw_names.push("")
            raw_types.push(trimmed_param)
            has_unnamed = true
        normalized_types.push(raw_types[raw_types.len() - 1].trim())

    if raw_types.len() < 2:
        return nil

    var type_counts: Dict<text, i64> = {}
    var has_duplicate_types = false
    for ty in normalized_types:
        val count = type_counts[ty] ?? 0
        type_counts[ty] = count + 1
        if count + 1 >= 2:
            has_duplicate_types = true
    if not has_duplicate_types:
        return nil

    var resolved_names: [text] = []
    var rewritten_params: [text] = []
    var generated_counts: Dict<text, i64> = {}
    var i = 0
    while i < raw_types.len():
        val param_name = raw_names[i]
        val param_type = raw_types[i]
        var resolved_name = param_name
        if resolved_name == "":
            val key = normalized_types[i]
            val next_count = (generated_counts[key] ?? 0) + 1
            generated_counts[key] = next_count
            resolved_name = "{_type_name_to_identifier(text: param_type)}{next_count}"
        rewritten_params.push("{resolved_name}: {param_type}")
        resolved_names.push(resolved_name)
        i = i + 1

    var stable_names = true
    var seen_names: Dict<text, bool> = {}
    i = 0
    while i < resolved_names.len():
        if type_counts[normalized_types[i]] >= 2:
            val name_i = resolved_names[i]
            if name_i == "" or name_i == "_" or name_i.starts_with("_"):
                stable_names = false
            elif seen_names.has(name_i):
                stable_names = false
            else:
                seen_names[name_i] = true
        i = i + 1

    Some(DuplicateTypedArgSignature(
        name: name,
        line_num: ctx.line_num,
        decl_paren_start: ctx.byte_offset + ctx.indent + paren_start + 1,
        decl_paren_end: ctx.byte_offset + ctx.indent + paren_end,
        decl_column: paren_start + 2,
        arg_count: resolved_names.len(),
        param_names: resolved_names,
        new_params_text: rewritten_params.join(", "),
        has_decl_rewrite: has_unnamed,
        can_rewrite_calls: stable_names
    ))

fn _collect_call_replacements_for_signature(source: text, file: text, sig: DuplicateTypedArgSignature) -> [Replacement]:
    var replacements: [Replacement] = []

    for ctx in line_contexts(source):
        val line_replacements = _collect_line_call_replacements(line: ctx.line, file: file, sig: sig, line_num: ctx.line_num, byte_offset: ctx.byte_offset)
        for rep in line_replacements:
            replacements.push(rep)

    replacements

fn _collect_line_call_replacements(line: text, file: text, sig: DuplicateTypedArgSignature, line_num: i64, byte_offset: i64) -> [Replacement]:
    var replacements: [Replacement] = []
    var i = 0
    while i < line.len():
        if not _matches_identifier_at(line: line, start: i, name: sig.name):
            i = i + 1
            continue
        if _is_definition_context(line: line, token_start: i):
            i = i + sig.name.len()
            continue
        val open_paren = _find_call_open_paren(line: line, start: i + sig.name.len())
        if open_paren < 0:
            i = i + sig.name.len()
            continue
        val close_paren = _find_matching_paren_on_line(text: line, open_paren: open_paren)
        if close_paren <= open_paren:
            i = i + sig.name.len()
            continue
        val args_str = line.slice(open_paren + 1, close_paren)
        val args = _split_top_level_csv(text: args_str)
        if args.len() != sig.arg_count or _args_have_named_entries(args: args):
            i = close_paren + 1
            continue
        var named_args: [text] = []
        var arg_index = 0
        while arg_index < args.len():
            named_args.push("{sig.param_names[arg_index]}: {args[arg_index].trim()}")
            arg_index = arg_index + 1
        replacements.push(Replacement.create(
            file: file,
            start: byte_offset + open_paren + 1,
            end: byte_offset + close_paren,
            line: line_num,
            column: open_paren + 2,
            new_text: named_args.join(", ")
        ))
        i = close_paren + 1
    replacements

fn _is_unique_call_target(signatures: [DuplicateTypedArgSignature], sig: DuplicateTypedArgSignature) -> bool:
    var matches = 0
    for candidate in signatures:
        if candidate.can_rewrite_calls and candidate.name == sig.name and candidate.arg_count == sig.arg_count:
            matches = matches + 1
    matches == 1

fn _dup_is_fn_sig(trimmed: text) -> bool:
    trimmed.starts_with("fn ")
        or trimmed.starts_with("me ")
        or trimmed.starts_with("static fn ")
        or trimmed.starts_with("pub fn ")
        or trimmed.starts_with("pub me ")
        or trimmed.starts_with("pub static fn ")

fn _extract_sig_name(trimmed: text, paren_start: i64) -> text:
    val before = trimmed.slice(0, paren_start).trim()
    val parts = before.split(" ")
    if parts.is_empty():
        return ""
    parts[parts.len() - 1].trim()

fn _type_name_to_identifier(text: text) -> text:
    var out = ""
    var prev_underscore = false
    var i = 0
    while i < text.len():
        val ch = text.slice(i, i + 1).lower()
        if _is_identifier_char(ch):
            out = out + ch
            prev_underscore = false
        elif not prev_underscore:
            out = out + "_"
            prev_underscore = true
        i = i + 1
    while out.starts_with("_"):
        out = out.slice(1)
    while out.ends_with("_"):
        out = out.slice(0, out.len() - 1)
    if out == "":
        return "arg"
    if _is_digit_char(out.slice(0, 1)):
        return "arg_{out}"
    out

fn _matches_identifier_at(line: text, start: i64, name: text) -> bool:
    if start < 0 or start + name.len() > line.len():
        return false
    if line.slice(start, start + name.len()) != name:
        return false
    if start > 0 and _is_identifier_char(line.slice(start - 1, start)):
        return false
    val end = start + name.len()
    if end < line.len() and _is_identifier_char(line.slice(end, end + 1)):
        return false
    true

fn _is_definition_context(line: text, token_start: i64) -> bool:
    val before = line.slice(0, token_start).trim()
    before.ends_with("fn") or before.ends_with("me")

fn _find_call_open_paren(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line.slice(i, i + 1)
        if ch == " " or ch == "\t":
            i = i + 1
            continue
        if ch == "(":
            return i
        return -1
    -1

fn _args_have_named_entries(args: [text]) -> bool:
    for arg in args:
        if _find_top_level_colon(text: arg.trim()) >= 0:
            return true
    false

# ============================================================================
# Rule 12: stub_impl (text-scanning)
# Detects function signatures followed by trivial body expressions.
# Confidence: Likely
# ============================================================================

fn _stub_trivial() -> [text]:
    ["0", "\"\"", "false", "nil", "[]", "()", "true",
     "return 0", "return \"\"", "return false", "return nil",
     "return []", "return ()", "return true",
     "Ok(nil)", "Ok(0)", "return Ok(nil)", "return Ok(0)"]

fn check_stub_impl_text(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    val lines = source.split("\n")

    for ctx in line_contexts(source):
        if _stub_is_fn(ctx.trimmed):
            val body = _stub_inline_body(ctx.trimmed)
            if body != "" and _stub_is_trivial(body) and _stub_has_params(ctx.trimmed):
                var fix = EasyFix.create(
                    id: "L:stub_impl:{ctx.line_num}",
                    description: "function with params returns trivial '{body}' — possible stub",
                    confidence: FixConfidence.Likely
                )
                fix.add_replacement(Replacement.create(
                    file: file, start: ctx.byte_offset, end: ctx.byte_offset + ctx.line.len(),
                    line: ctx.line_num, column: 1, new_text: ctx.line
                ))
                fixes.push(fix)

        if _stub_is_fn_header(ctx.trimmed) and _stub_has_params(ctx.trimmed):
            if ctx.line_num < lines.len():
                val nl = lines[ctx.line_num]
                val nt = nl.trim()
                val ni = nl.len() - nt.len()
                if ni > ctx.indent and _stub_is_trivial(nt):
                    var single = true
                    if ctx.line_num + 1 < lines.len():
                        val al = lines[ctx.line_num + 1]
                        val at = al.trim()
                        val ai = al.len() - at.len()
                        if at != "" and ai > ctx.indent:
                            single = false
                    if single:
                        var fix = EasyFix.create(
                            id: "L:stub_impl:{ctx.line_num}",
                            description: "function with params returns trivial '{nt}' — possible stub",
                            confidence: FixConfidence.Likely
                        )
                        fix.add_replacement(Replacement.create(
                            file: file, start: ctx.byte_offset, end: ctx.byte_offset + ctx.line.len(),
                            line: ctx.line_num, column: 1, new_text: ctx.line
                        ))
                        fixes.push(fix)

    fixes

fn _stub_is_fn(t: text) -> bool:
    t.starts_with("fn ") or t.starts_with("me ") or t.starts_with("static fn ")

fn _stub_is_fn_header(t: text) -> bool:
    _stub_is_fn(t) and t.ends_with(":")

fn _stub_has_params(t: text) -> bool:
    if not t.contains("(") or not t.contains(")"):
        return false
    val paren_parts = t.split("(")
    if paren_parts.len() < 2:
        return false
    val after_open = paren_parts[1]
    if not after_open.contains(")"):
        return false
    val close_parts = after_open.split(")")
    val inner = close_parts[0].trim()
    inner.len() > 0

fn _stub_inline_body(t: text) -> text:
    if not t.contains(")"):
        return ""
    val paren_parts = t.split(")")
    if paren_parts.len() < 2:
        return ""
    val after = paren_parts[1]
    if not after.contains(":"):
        return ""
    val colon_parts = after.split(":")
    if colon_parts.len() < 2:
        return ""
    val body_raw = colon_parts[1]
    body_raw.trim()

fn _stub_is_trivial(body: text) -> bool:
    if body.starts_with("pass_todo") or body.starts_with("pass_do_nothing") or body.starts_with("pass_dn"):
        return false
    for p in _stub_trivial():
        if body == p:
            return true
    body == "pass"

# ============================================================================
# Rule 13: short grammar refactors
# Rewrites simple lambdas to method-reference or numbered placeholder grammar.
# Confidence: Safe
# ============================================================================

fn check_short_grammar_refactor(source: text, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    for ctx in line_contexts(source):
        val line_fixes = _check_short_grammar_line(ctx: ctx, file: file)
        for fix in line_fixes:
            fixes.push(fix)
    fixes

fn _check_short_grammar_line(ctx: LineContext, file: text) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var search_from = 0
    while search_from < ctx.line.len():
        val lambda_start = _find_next_collection_lambda_start(line: ctx.line, search_from: search_from)
        if lambda_start < 0:
            return fixes
        if _short_line_has_functional_update_before(line: ctx.line, pos: lambda_start):
            search_from = lambda_start + 1
            continue
        val parsed = _parse_method_ref_candidate(line: ctx.line, lambda_start: lambda_start)
        match parsed:
            case Some(candidate):
                var fix = EasyFix.create(
                    id: "L:short_grammar_method_ref:{ctx.line_num}:{lambda_start + 1}",
                    description: "replace explicit lambda with method reference short grammar `&:{candidate.method}`",
                    confidence: FixConfidence.Safe
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: ctx.byte_offset + lambda_start,
                    end: ctx.byte_offset + candidate.end_offset,
                    line: ctx.line_num,
                    column: lambda_start + 1,
                    new_text: "&:{candidate.method}"
                ))
                fixes.push(fix)
                search_from = candidate.end_offset
            case nil:
                var placeholder = _parse_compact_placeholder_candidate(line: ctx.line, lambda_start: lambda_start)
                match placeholder:
                    case Some(_candidate):
                        pass
                    case nil:
                        placeholder = _parse_placeholder_candidate(line: ctx.line, lambda_start: lambda_start)
                match placeholder:
                    case Some(candidate):
                        var fix = EasyFix.create(
                            id: "L:short_grammar_placeholder:{ctx.line_num}:{lambda_start + 1}",
                            description: "replace explicit lambda with placeholder short grammar `{candidate.new_text}`",
                            confidence: FixConfidence.Safe
                        )
                        fix.add_replacement(Replacement.create(
                            file: file,
                            start: ctx.byte_offset + lambda_start,
                            end: ctx.byte_offset + candidate.end_offset,
                            line: ctx.line_num,
                            column: lambda_start + 1,
                            new_text: candidate.new_text
                        ))
                        fixes.push(fix)
                        search_from = candidate.end_offset
                    case nil:
                        search_from = lambda_start + 1
    fixes

fn _find_next_collection_lambda_start(line: text, search_from: i64) -> i64:
    val candidate = _short_find_text_from(line: line, needle: "\\", search_from: search_from)
    if candidate < 0:
        return -1
    if _short_line_has_comment_before(line: line, pos: candidate) or _short_position_is_inside_string(line: line, pos: candidate):
        return _find_next_collection_lambda_start(line: line, search_from: candidate + 1)
    if candidate + 1 >= line.len():
        return -1
    val next = line.slice(candidate + 1, candidate + 2)
    if _short_is_identifier_start(next) or next == "(":
        return candidate
    _find_next_collection_lambda_start(line: line, search_from: candidate + 1)

fn _short_line_has_comment_before(line: text, pos: i64) -> bool:
    var i = 0
    while i < pos:
        if line.slice(i, i + 1) == "#":
            return true
        i = i + 1
    false

fn _short_line_has_functional_update_before(line: text, pos: i64) -> bool:
    _short_find_text_from(line: line.slice(0, pos), needle: "->", search_from: 0) >= 0

fn _short_position_is_inside_string(line: text, pos: i64) -> bool:
    var i = 0
    var in_string = false
    while i < pos:
        val ch = line.slice(i, i + 1)
        if ch == "\"":
            in_string = not in_string
        i = i + 1
    in_string

fn _parse_method_ref_candidate(line: text, lambda_start: i64) -> Option<ShortGrammarMethodRefCandidate>:
    val colon_abs = _short_find_text_from(line: line, needle: ":", search_from: lambda_start)
    if colon_abs < 0:
        return nil
    val colon_rel = colon_abs - lambda_start

    val raw_param = line.slice(lambda_start, colon_abs).trim()
    if raw_param.len() < 2:
        return nil
    val introducer = raw_param.slice(0, 1)
    if _short_is_identifier_char(introducer):
        return nil
    val param = raw_param.slice(1, raw_param.len()).trim()
    if not _short_is_plain_identifier(param):
        return nil

    var body_start = lambda_start + colon_rel + 1
    while body_start < line.len() and line.slice(body_start, body_start + 1) == " ":
        body_start = body_start + 1

    val receiver_prefix = param + "."
    val body_tail = line.slice(body_start, line.len())
    if not body_tail.starts_with(receiver_prefix):
        return nil

    val method_start = body_start + receiver_prefix.len()
    val method_end = _short_scan_identifier_end(line: line, start: method_start)
    if method_end <= method_start:
        return nil

    val method = line.slice(method_start, method_end)
    if method.starts_with("_"):
        return nil

    val call_end = method_end + 2
    if call_end > line.len() or line.slice(method_end, call_end) != "()":
        return nil

    val suffix = line.slice(call_end, line.len()).trim()
    if suffix != "" and not suffix.starts_with(")") and not suffix.starts_with(","):
        return nil

    Some(ShortGrammarMethodRefCandidate(method: method, end_offset: call_end))

fn _parse_placeholder_candidate(line: text, lambda_start: i64) -> Option<ShortGrammarPlaceholderCandidate>:
    val colon_abs = _short_find_text_from(line: line, needle: ":", search_from: lambda_start)
    if colon_abs < 0:
        return nil
    val colon_rel = colon_abs - lambda_start

    val raw_param = line.slice(lambda_start, colon_abs).trim()
    if raw_param.len() < 2:
        return nil
    val tuple_candidate = _parse_tuple_placeholder_candidate(line: line, lambda_start: lambda_start, colon_abs: colon_abs)
    match tuple_candidate:
        case Some(candidate):
            return Some(candidate)
        case nil:
            pass
    val introducer = raw_param.slice(0, 1)
    if _short_is_identifier_char(introducer):
        return nil
    val param = raw_param.slice(1, raw_param.len()).trim()
    if not _short_is_plain_identifier(param):
        return nil

    var body_start = lambda_start + colon_rel + 1
    while body_start < line.len() and line.slice(body_start, body_start + 1) == " ":
        body_start = body_start + 1

    val expr_end = _short_scan_simple_lambda_expr_end(line: line, start: body_start)
    if expr_end <= body_start:
        return nil
    val expr = line.slice(body_start, expr_end).trim()
    val value_prefix = param + " "
    val member_prefix = param + "."
    if not expr.starts_with(value_prefix) and not expr.starts_with(member_prefix) and not _short_expr_contains_plain_identifier(expr: expr, param: param):
        return nil
    if not _short_placeholder_brackets_are_param_free(expr: expr, param: param):
        return nil
    if not _short_placeholder_quotes_are_safe(expr: expr, param: param):
        return nil
    if expr.contains("(") and not _short_placeholder_calls_are_safe(expr: expr, param: param):
        return nil
    val replacement = "_1"
    if _short_placeholder_expr_is_unary_not_safe(expr: expr, param: param):
        val unary_new_text = _short_replace_plain_identifier(expr: expr, param: param, replacement: replacement)
        if unary_new_text == expr:
            return nil
        return Some(ShortGrammarPlaceholderCandidate(new_text: unary_new_text, end_offset: expr_end))
    if _short_placeholder_expr_has_unsafe_direct_field_predicate(expr: expr, param: param):
        return nil
    if not _short_placeholder_expr_is_safe(expr) and not _short_placeholder_expr_is_single_param_call(expr: expr, param: param) and not _short_placeholder_expr_is_param_cast(expr: expr, param: param) and not _short_placeholder_expr_is_call_with_safe_args(expr: expr, param: param) and not _short_placeholder_expr_is_field_access(expr: expr, param: param) and not _short_placeholder_expr_is_unary_not_safe(expr: expr, param: param):
        return nil

    val new_text = _short_replace_plain_identifier(expr: expr, param: param, replacement: replacement)
    if new_text == expr:
        return nil
    Some(ShortGrammarPlaceholderCandidate(new_text: new_text, end_offset: expr_end))

fn _parse_compact_placeholder_candidate(line: text, lambda_start: i64) -> Option<ShortGrammarPlaceholderCandidate>:
    val colon_abs = _short_find_text_from(line: line, needle: ":", search_from: lambda_start)
    if colon_abs < 0:
        return nil
    val raw_param = line.slice(lambda_start, colon_abs).trim()
    if raw_param.len() < 2:
        return nil
    val introducer = raw_param.slice(0, 1)
    if _short_is_identifier_char(introducer):
        return nil
    val param = raw_param.slice(1, raw_param.len()).trim()
    if not _short_is_plain_identifier(param):
        return nil

    var body_start = colon_abs + 1
    while body_start < line.len() and line.slice(body_start, body_start + 1) == " ":
        body_start = body_start + 1
    val expr_end = _short_scan_simple_lambda_expr_end(line: line, start: body_start)
    if expr_end <= body_start:
        return nil
    val expr = line.slice(body_start, expr_end).trim()
    if not expr.starts_with(param):
        return nil
    val tail = expr.slice(param.len(), expr.len()).trim()
    if not _short_placeholder_tail_starts_with_operator(tail):
        return nil
    if not _short_placeholder_brackets_are_param_free(expr: expr, param: param):
        return nil
    if not _short_placeholder_quotes_are_safe(expr: expr, param: param):
        return nil
    val new_text = _short_replace_plain_identifier(expr: expr, param: param, replacement: "_1")
    if new_text == expr:
        return nil
    Some(ShortGrammarPlaceholderCandidate(new_text: new_text, end_offset: expr_end))

fn _short_placeholder_tail_starts_with_operator(tail: text) -> bool:
    if tail == "":
        return false
    val ch = tail.slice(0, 1)
    ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "%" or ch == ">" or ch == "<" or ch == "=" or ch == "!"

fn _parse_tuple_placeholder_candidate(line: text, lambda_start: i64, colon_abs: i64) -> Option<ShortGrammarPlaceholderCandidate>:
    val raw_param = line.slice(lambda_start, colon_abs).trim()
    if not raw_param.starts_with("\\(") or not raw_param.ends_with(")"):
        return nil
    val inner = raw_param.slice(2, raw_param.len() - 1).trim()
    if inner == "":
        return nil

    val params = inner.split(",")
    if params.len() < 2:
        return nil
    var clean_params: [text] = []
    for param in params:
        val clean = param.trim()
        if not _short_is_plain_identifier(clean):
            return nil
        clean_params.push(clean)

    var body_start = colon_abs + 1
    while body_start < line.len() and line.slice(body_start, body_start + 1) == " ":
        body_start = body_start + 1

    val expr_end = _short_scan_simple_lambda_expr_end(line: line, start: body_start)
    if expr_end <= body_start:
        return nil
    val expr = line.slice(body_start, expr_end).trim()
    if expr == "":
        return nil
    if expr.contains("\""):
        return nil

    var new_text = expr
    var replaced = false
    var idx = 0
    while idx < clean_params.len():
        val replacement = "_.{idx}"
        val updated = _short_replace_plain_identifier(expr: new_text, param: clean_params[idx], replacement: replacement)
        if updated != new_text:
            replaced = true
        new_text = updated
        idx = idx + 1

    if not replaced or new_text == expr:
        return nil
    if new_text.contains("\\(") or new_text.contains("\\)"):
        return nil
    Some(ShortGrammarPlaceholderCandidate(new_text: new_text, end_offset: expr_end))

fn _short_scan_simple_lambda_expr_end(line: text, start: i64) -> i64:
    var i = start
    var paren_depth = 0
    while i < line.len():
        val ch = line.slice(i, i + 1)
        if ch == "(":
            paren_depth = paren_depth + 1
        elif ch == ")":
            if paren_depth == 0:
                return i
            paren_depth = paren_depth - 1
        elif ch == "," and paren_depth == 0:
            return i
        i = i + 1
    i

fn _short_find_text_from(line: text, needle: text, search_from: i64) -> i64:
    if needle == "":
        return search_from
    var i = search_from
    while i + needle.len() <= line.len():
        if line.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn _short_placeholder_expr_is_safe(expr: text) -> bool:
    _short_placeholder_expr_has_binary_operator(expr)

fn _short_placeholder_expr_has_binary_operator(expr: text) -> bool:
    if expr.contains(" and ") or expr.contains(" or "):
        return true
    var i = 0
    while i < expr.len():
        val ch = expr.slice(i, i + 1)
        if ch == "+" or ch == "-" or ch == "*" or ch == "/" or ch == "%" or ch == ">" or ch == "<":
            return true
        if ch == "=" and i + 1 < expr.len() and expr.slice(i + 1, i + 2) == "=":
            return true
        if ch == "!" and i + 1 < expr.len() and expr.slice(i + 1, i + 2) == "=":
            return true
        i = i + 1
    false

fn _short_placeholder_calls_are_safe(expr: text, param: text) -> bool:
    var i = 0
    while i < expr.len():
        if expr.slice(i, i + 1) == "(":
            val close = _find_matching_paren_on_line(text: expr, open_paren: i)
            if close < 0:
                return false
            val inner = expr.slice(i + 1, close).trim()
            if inner != "" and not _short_placeholder_call_args_are_safe(inner: inner, param: param):
                return false
            i = close + 1
        else:
            i = i + 1
    true

fn _short_placeholder_call_args_are_safe(inner: text, param: text) -> bool:
    var start = 0
    while start <= inner.len():
        val comma = _short_find_text_from(line: inner, needle: ",", search_from: start)
        val end = if comma < 0: inner.len() else: comma
        val arg = inner.slice(start, end).trim()
        if not _short_placeholder_call_arg_is_safe(arg: arg, param: param):
            return false
        if comma < 0:
            return true
        start = comma + 1
    true

fn _short_placeholder_call_arg_is_safe(arg: text, param: text) -> bool:
    if not _short_expr_contains_plain_identifier(expr: arg, param: param):
        return true
    if arg == param:
        return true
    _short_placeholder_expr_is_safe(arg) or _short_placeholder_expr_is_single_param_call(expr: arg, param: param) or _short_placeholder_expr_is_param_cast(expr: arg, param: param) or _short_placeholder_expr_is_index_access(expr: arg, param: param) or _short_placeholder_expr_is_receiver_no_arg_method_call(expr: arg, param: param) or _short_placeholder_expr_is_call_with_safe_args(expr: arg, param: param) or _short_placeholder_expr_is_field_access(expr: arg, param: param) or _short_placeholder_expr_is_unary_not_safe(expr: arg, param: param)

fn _short_placeholder_brackets_are_param_free(expr: text, param: text) -> bool:
    var i = 0
    while i < expr.len():
        if expr.slice(i, i + 1) == "[":
            val close = _short_find_text_from(line: expr, needle: "]", search_from: i + 1)
            if close < 0:
                return false
            val inner = expr.slice(i + 1, close)
            if _short_expr_contains_plain_identifier(expr: inner, param: param):
                return false
            i = close + 1
        else:
            i = i + 1
    true

fn _short_placeholder_quotes_are_safe(expr: text, param: text) -> bool:
    if not expr.contains("\""):
        return true
    if expr == "\"{" + param + "}\"":
        return true
    if not expr.contains(param):
        return true
    if not expr.contains("\"" + param + "\"") and not expr.contains("{" + param + "}"):
        return true
    var i = 0
    while i < expr.len():
        if expr.slice(i, i + 1) == "\"" and not _short_placeholder_position_is_inside_brackets(expr: expr, pos: i):
            return false
        i = i + 1
    true

fn _short_placeholder_expr_is_field_access(expr: text, param: text) -> bool:
    val prefix = param + "."
    if not expr.starts_with(prefix):
        return false
    val field = expr.slice(prefix.len(), expr.len())
    _short_is_plain_identifier(field)

fn _short_placeholder_expr_is_index_access(expr: text, param: text) -> bool:
    val prefix = param + "["
    if not expr.starts_with(prefix):
        return false
    val close = _short_find_text_from(line: expr, needle: "]", search_from: prefix.len())
    close == expr.len() - 1

fn _short_placeholder_expr_is_receiver_no_arg_method_call(expr: text, param: text) -> bool:
    val prefix = param + "."
    if not expr.starts_with(prefix):
        return false
    if not expr.ends_with("()"):
        return false
    val method = expr.slice(prefix.len(), expr.len() - 2)
    _short_is_plain_identifier(method)

fn _short_placeholder_expr_is_param_cast(expr: text, param: text) -> bool:
    val prefix = param + " as "
    if not expr.starts_with(prefix):
        return false
    _short_is_simple_type_name(expr.slice(prefix.len(), expr.len()).trim())

fn _short_placeholder_expr_has_unsafe_direct_field_predicate(expr: text, param: text) -> bool:
    val prefix = param + "."
    if not expr.starts_with(prefix):
        return false
    val field_start = prefix.len()
    val field_end = _short_scan_identifier_end(line: expr, start: field_start)
    if field_end <= field_start:
        return false
    if field_end < expr.len() and expr.slice(field_end, field_end + 1) == "(":
        return false
    expr.slice(field_end, expr.len()).trim() != ""

fn _short_placeholder_expr_is_unary_not_safe(expr: text, param: text) -> bool:
    val prefix = "not "
    if not expr.starts_with(prefix):
        return false
    val inner = expr.slice(prefix.len(), expr.len()).trim()
    if inner == "":
        return false
    val field_prefix = param + "."
    if inner.starts_with(field_prefix):
        return _short_is_plain_identifier(inner.slice(field_prefix.len(), inner.len()))
    _short_placeholder_expr_is_safe(inner) or _short_placeholder_expr_is_single_param_call(expr: inner, param: param) or _short_placeholder_expr_is_receiver_no_arg_method_call(expr: inner, param: param) or _short_placeholder_expr_is_call_with_safe_args(expr: inner, param: param) or _short_placeholder_expr_is_field_access(expr: inner, param: param)

fn _short_placeholder_position_is_inside_brackets(expr: text, pos: i64) -> bool:
    var depth = 0
    var i = 0
    while i < pos:
        val ch = expr.slice(i, i + 1)
        if ch == "[":
            depth = depth + 1
        elif ch == "]" and depth > 0:
            depth = depth - 1
        i = i + 1
    depth > 0

fn _short_placeholder_expr_is_single_param_call(expr: text, param: text) -> bool:
    val open = _short_find_text_from(line: expr, needle: "(", search_from: 0)
    if open <= 0:
        return false
    val fn_name = expr.slice(0, open).trim()
    if not _short_is_plain_identifier(fn_name):
        return false
    val close = _find_matching_paren_on_line(text: expr, open_paren: open)
    if close != expr.len() - 1:
        return false
    expr.slice(open + 1, close).trim() == param

fn _short_placeholder_expr_is_call_with_safe_args(expr: text, param: text) -> bool:
    val open = _short_find_text_from(line: expr, needle: "(", search_from: 0)
    if open <= 0:
        return false
    val close = _find_matching_paren_on_line(text: expr, open_paren: open)
    if close != expr.len() - 1:
        return false
    _short_placeholder_call_args_are_safe(inner: expr.slice(open + 1, close).trim(), param: param)

fn _short_expr_contains_plain_identifier(expr: text, param: text) -> bool:
    _short_replace_plain_identifier(expr: expr, param: param, replacement: "_") != expr

fn _short_replace_plain_identifier(expr: text, param: text, replacement: text) -> text:
    var result = ""
    var i = 0
    while i < expr.len():
        if i + param.len() <= expr.len() and expr.slice(i, i + param.len()) == param:
            val before = if i == 0: "" else: expr.slice(i - 1, i)
            val after = if i + param.len() >= expr.len(): "" else: expr.slice(i + param.len(), i + param.len() + 1)
            if (before == "" or not _short_is_identifier_char(before)) and (after == "" or not _short_is_identifier_char(after)):
                result = result + replacement
                i = i + param.len()
            else:
                result = result + expr.slice(i, i + 1)
                i = i + 1
        else:
            result = result + expr.slice(i, i + 1)
            i = i + 1
    result

fn _short_scan_identifier_end(line: text, start: i64) -> i64:
    var i = start
    while i < line.len():
        val ch = line.slice(i, i + 1)
        if not _short_is_identifier_char(ch):
            return i
        i = i + 1
    i

fn _short_is_plain_identifier(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if i == 0:
            if not _short_is_identifier_start(ch):
                return false
        elif not _short_is_identifier_char(ch):
            return false
        i = i + 1
    true

fn _short_is_simple_type_name(value: text) -> bool:
    if value == "":
        return false
    var i = 0
    while i < value.len():
        val ch = value.slice(i, i + 1)
        if not _short_is_identifier_char(ch) and ch != ".":
            return false
        i = i + 1
    true

fn _short_is_identifier_start(ch: text) -> bool:
    "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_".contains(ch)

fn _short_is_identifier_char(ch: text) -> bool:
    _short_is_identifier_start(ch) or "0123456789".contains(ch)

# ============================================================================
# Master: run all text-scanning rules
# ============================================================================

fn check_all_rules(source: String, file: String) -> [EasyFix]:
    var all_fixes: [EasyFix] = []

    val fixes1 = check_print_in_test_spec(source: source, file: file)
    for f in fixes1:
        all_fixes.push(f)

    val fixes2 = check_unnamed_duplicate_typed_args(source: source, file: file)
    for f in fixes2:
        all_fixes.push(f)

    val fixes3 = check_resource_leak(source: source, file: file)
    for f in fixes3:
        all_fixes.push(f)

    val fixes4 = check_spipe_missing_docstrings(source: source, file: file)
    for f in fixes4:
        all_fixes.push(f)

    val fixes5 = check_spipe_manual_assertions(source: source, file: file)
    for f in fixes5:
        all_fixes.push(f)

    val fixes6 = check_non_exhaustive_match(source: source, file: file)
    for f in fixes6:
        all_fixes.push(f)

    val fixes7 = check_parser_contextual_keyword(source: source, file: file)
    for f in fixes7:
        all_fixes.push(f)

    val fixes8 = check_deprecated_if_let(source: source, file: file)
    for f in fixes8:
        all_fixes.push(f)

    val fixes9 = check_stub_impl_text(source: source, file: file)
    for f in fixes9:
        all_fixes.push(f)

    val fixes10 = check_short_grammar_refactor(source: source, file: file)
    for f in fixes10:
        all_fixes.push(f)

    # Rules 7 (typo) and 9 (type coercion) are no-ops in text-scanning mode.
    # They require compiler integration (Rust side).

    all_fixes
