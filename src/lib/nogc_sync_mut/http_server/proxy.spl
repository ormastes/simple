# codex-impl
# Worker-level reverse proxy helpers for the lightweight sync HTTP server.

use std.nogc_sync_mut.io.tcp.{TcpStream}
use std.nogc_sync_mut.http_server.types.{HttpRequest, HttpMethod, HttpStatus, http_method_to_text}
use std.nogc_sync_mut.http_server.router.{path_is_safe}

class ReverseProxyRoute:
    prefix: text
    upstream_addr: text
    connect_timeout_ms: i64
    io_timeout_ms: i64
    max_buffered_request_body_bytes: i64
    max_response_headers: i64
    max_response_header_line: i64
    max_response_bytes: i64

fn reverse_proxy_route(prefix: text, upstream_addr: text) -> ReverseProxyRoute:
    ReverseProxyRoute(
        prefix: prefix,
        upstream_addr: upstream_addr,
        connect_timeout_ms: 1000,
        io_timeout_ms: 5000,
        max_buffered_request_body_bytes: 1024 * 1024,
        max_response_headers: 100,
        max_response_header_line: 8192,
        max_response_bytes: 64 * 1024 * 1024
    )

fn reverse_proxy_route_with_limits(prefix: text, upstream_addr: text, connect_timeout_ms: i64,
                                   io_timeout_ms: i64, max_response_bytes: i64) -> ReverseProxyRoute:
    ReverseProxyRoute(
        prefix: prefix,
        upstream_addr: upstream_addr,
        connect_timeout_ms: connect_timeout_ms,
        io_timeout_ms: io_timeout_ms,
        max_buffered_request_body_bytes: 1024 * 1024,
        max_response_headers: 100,
        max_response_header_line: 8192,
        max_response_bytes: max_response_bytes
    )

fn reverse_proxy_route_with_response_limits(prefix: text, upstream_addr: text, connect_timeout_ms: i64,
                                            io_timeout_ms: i64, max_response_headers: i64,
                                            max_response_header_line: i64,
                                            max_response_bytes: i64) -> ReverseProxyRoute:
    ReverseProxyRoute(
        prefix: prefix,
        upstream_addr: upstream_addr,
        connect_timeout_ms: connect_timeout_ms,
        io_timeout_ms: io_timeout_ms,
        max_buffered_request_body_bytes: 1024 * 1024,
        max_response_headers: max_response_headers,
        max_response_header_line: max_response_header_line,
        max_response_bytes: max_response_bytes
    )

fn reverse_proxy_route_with_request_limits(prefix: text, upstream_addr: text, connect_timeout_ms: i64,
                                           io_timeout_ms: i64, max_buffered_request_body_bytes: i64,
                                           max_response_bytes: i64) -> ReverseProxyRoute:
    ReverseProxyRoute(
        prefix: prefix,
        upstream_addr: upstream_addr,
        connect_timeout_ms: connect_timeout_ms,
        io_timeout_ms: io_timeout_ms,
        max_buffered_request_body_bytes: max_buffered_request_body_bytes,
        max_response_headers: 100,
        max_response_header_line: 8192,
        max_response_bytes: max_response_bytes
    )

fn reverse_proxy_prefix_matches(route: ReverseProxyRoute, req: HttpRequest) -> bool:
    path_is_safe(req.path) and req.path.starts_with(route.prefix)

fn reverse_proxy_method_supported(method: HttpMethod) -> bool:
    match method:
        HttpMethod.Get: true
        HttpMethod.Head: true
        HttpMethod.Post: true
        HttpMethod.Put: true
        HttpMethod.Patch: true
        HttpMethod.Delete: true
        HttpMethod.Options: true

fn reverse_proxy_matches_request(route: ReverseProxyRoute, req: HttpRequest) -> bool:
    reverse_proxy_prefix_matches(route, req) and reverse_proxy_method_supported(req.method)

fn reverse_proxy_request_transfer_chunked(req: HttpRequest) -> bool:
    for h in req.headers:
        if h.0.to_lower() == "transfer-encoding":
            if h.1.to_lower().contains("chunked"):
                return true
    false

fn reverse_proxy_request_upgrade(req: HttpRequest) -> bool:
    var connection_upgrade = false
    var has_upgrade = false
    for h in req.headers:
        val name = h.0.to_lower()
        val value = h.1.to_lower()
        if name == "connection" and value.contains("upgrade"):
            connection_upgrade = true
        if name == "upgrade":
            has_upgrade = true
    connection_upgrade or has_upgrade

fn reverse_proxy_request_body_streaming_required(req: HttpRequest, route: ReverseProxyRoute) -> bool:
    if req.body == "":
        return false
    if route.max_buffered_request_body_bytes < 0:
        return false
    req.body.len() > route.max_buffered_request_body_bytes

fn reverse_proxy_drop_header(name: text) -> bool:
    val lower = name.to_lower()
    if lower == "connection":
        return true
    if lower == "keep-alive":
        return true
    if lower == "proxy-authenticate":
        return true
    if lower == "proxy-authorization":
        return true
    if lower == "te":
        return true
    if lower == "trailer":
        return true
    if lower == "transfer-encoding":
        return true
    if lower == "upgrade":
        return true
    if lower == "host":
        return true
    if lower == "content-length":
        return true
    false

fn reverse_proxy_drop_response_header(name: text) -> bool:
    val lower = name.to_lower()
    if lower == "connection":
        return true
    if lower == "keep-alive":
        return true
    if lower == "proxy-authenticate":
        return true
    if lower == "proxy-authorization":
        return true
    if lower == "te":
        return true
    if lower == "trailer":
        return true
    if lower == "transfer-encoding":
        return true
    if lower == "upgrade":
        return true
    false

fn reverse_proxy_target_path(req: HttpRequest) -> text:
    if req.query == "":
        return req.path
    "{req.path}?{req.query}"

fn reverse_proxy_status_line_valid(line: text) -> bool:
    val trimmed = line.trim()
    if not trimmed.starts_with("HTTP/1."):
        return false
    if trimmed.len() < 12:
        return false
    val code_text = trimmed.slice(9, 12)
    val first = code_text.slice(0, 1)
    val second = code_text.slice(1, 2)
    val third = code_text.slice(2, 3)
    val first_ok = first == "1" or first == "2" or first == "3" or first == "4" or first == "5"
    val second_ok = second >= "0" and second <= "9"
    val third_ok = third >= "0" and third <= "9"
    first_ok and second_ok and third_ok

fn reverse_proxy_serialize_request(req: HttpRequest, route: ReverseProxyRoute) -> text:
    val method_text = http_method_to_text(req.method)
    val target = reverse_proxy_target_path(req)
    var wire = "{method_text} {target} HTTP/1.1\r\n"
    wire = "{wire}Host: {route.upstream_addr}\r\n"
    wire = "{wire}Connection: close\r\n"
    if req.body != "":
        wire = "{wire}Content-Length: {req.body.len()}\r\n"
    if req.remote_addr != "":
        wire = "{wire}X-Forwarded-For: {req.remote_addr}\r\n"
    wire = "{wire}X-Forwarded-Proto: http\r\n"
    for h in req.headers:
        if not reverse_proxy_drop_header(h.0):
            wire = "{wire}{h.0}: {h.1}\r\n"
    wire = "{wire}\r\n"
    if req.body != "":
        wire = "{wire}{req.body}"
    wire

fn reverse_proxy_serialize_request_headers(req: HttpRequest, route: ReverseProxyRoute) -> text:
    val method_text = http_method_to_text(req.method)
    val target = reverse_proxy_target_path(req)
    var wire = "{method_text} {target} HTTP/1.1\r\n"
    wire = "{wire}Host: {route.upstream_addr}\r\n"
    wire = "{wire}Connection: close\r\n"
    if req.body != "":
        wire = "{wire}Content-Length: {req.body.len()}\r\n"
    if req.remote_addr != "":
        wire = "{wire}X-Forwarded-For: {req.remote_addr}\r\n"
    wire = "{wire}X-Forwarded-Proto: http\r\n"
    for h in req.headers:
        if not reverse_proxy_drop_header(h.0):
            wire = "{wire}{h.0}: {h.1}\r\n"
    "{wire}\r\n"

fn reverse_proxy_stream_request_chunk_size(route: ReverseProxyRoute) -> i64:
    if route.max_buffered_request_body_bytes > 0:
        return route.max_buffered_request_body_bytes
    8192

fn reverse_proxy_request_body_streaming_supported(req: HttpRequest, route: ReverseProxyRoute) -> bool:
    reverse_proxy_request_body_streaming_required(req, route) and
        not reverse_proxy_request_transfer_chunked(req) and
        not reverse_proxy_request_upgrade(req)

fn reverse_proxy_request_body_stream_chunk_count(req: HttpRequest, route: ReverseProxyRoute) -> i64:
    if req.body == "":
        return 0
    val chunk_size = reverse_proxy_stream_request_chunk_size(route)
    var count: i64 = 0
    var offset: i64 = 0
    while offset < req.body.len():
        count = count + 1
        offset = offset + chunk_size
    count

fn reverse_proxy_header_name(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    line.slice(0, colon).trim()

fn reverse_proxy_header_value(line: text) -> text:
    val colon = line.index_of(":")
    if colon <= 0:
        return ""
    line.slice(colon + 1, line.len()).trim()

fn reverse_proxy_content_length_from_header(line: text) -> i64:
    if reverse_proxy_header_name(line).to_lower() != "content-length":
        return -1
    val parsed = reverse_proxy_header_value(line).parse_int() ?? -1
    if parsed >= 0:
        return parsed
    -1

fn reverse_proxy_declared_response_too_large(line: text, route: ReverseProxyRoute) -> bool:
    val declared_length = reverse_proxy_content_length_from_header(line)
    declared_length > route.max_response_bytes

fn reverse_proxy_response_header_valid(line: text) -> bool:
    reverse_proxy_header_name(line) != ""

fn reverse_proxy_response_header_allowed(line: text, route: ReverseProxyRoute, header_count: i64) -> bool:
    if line.len() > route.max_response_header_line:
        return false
    if header_count > route.max_response_headers:
        return false
    true

fn reverse_proxy_write_response_headers(client: TcpStream, upstream: TcpStream, route: ReverseProxyRoute) -> HttpStatus:
    match upstream.read_line():
        Err(_):
            return HttpStatus.BadGateway
        Ok(status_line):
            val trimmed_status = status_line.trim()
            if trimmed_status == "":
                return HttpStatus.BadGateway
            if trimmed_status.len() > route.max_response_header_line:
                return HttpStatus.BadGateway
            if not reverse_proxy_status_line_valid(trimmed_status):
                return HttpStatus.BadGateway
            match client.write_text("{trimmed_status}\r\n"):
                Err(_):
                    return HttpStatus.BadGateway
                Ok(_):
                    pass_dn

    var header_count: i64 = 0
    loop:
        match upstream.read_line():
            Err(_):
                return HttpStatus.BadGateway
            Ok(header_line):
                val trimmed = header_line.trim()
                if trimmed == "":
                    break
                header_count = header_count + 1
                if not reverse_proxy_response_header_allowed(trimmed, route, header_count):
                    return HttpStatus.BadGateway
                val name = reverse_proxy_header_name(trimmed)
                if not reverse_proxy_response_header_valid(trimmed):
                    return HttpStatus.BadGateway
                if reverse_proxy_declared_response_too_large(trimmed, route):
                    return HttpStatus.BadGateway
                if name != "" and not reverse_proxy_drop_response_header(name):
                    match client.write_text("{trimmed}\r\n"):
                        Err(_):
                            return HttpStatus.BadGateway
                        Ok(_):
                            pass_dn

    match client.write_text("Connection: close\r\n\r\n"):
        Err(_):
            return HttpStatus.BadGateway
        Ok(_):
            HttpStatus.Ok

fn reverse_proxy_stream_response_body(client: TcpStream, upstream: TcpStream, route: ReverseProxyRoute) -> HttpStatus:
    var sent: i64 = 0
    loop:
        match upstream.read(8192):
            Err(_):
                return HttpStatus.BadGateway
            Ok(chunk):
                if chunk.len() == 0:
                    break
                sent = sent + chunk.len()
                if sent > route.max_response_bytes:
                    return HttpStatus.BadGateway
                match client.write_all(chunk):
                    Err(_):
                        return HttpStatus.BadGateway
                    Ok(_):
                        pass_dn
    HttpStatus.Ok

fn reverse_proxy_write_streaming_request(upstream: TcpStream, req: HttpRequest,
                                         route: ReverseProxyRoute) -> HttpStatus:
    match upstream.write_text(reverse_proxy_serialize_request_headers(req, route)):
        Err(_):
            return HttpStatus.BadGateway
        Ok(_):
            pass_dn
    val chunk_size = reverse_proxy_stream_request_chunk_size(route)
    var offset: i64 = 0
    while offset < req.body.len():
        var end = offset + chunk_size
        if end > req.body.len():
            end = req.body.len()
        match upstream.write_text(req.body.slice(offset, end)):
            Err(_):
                return HttpStatus.BadGateway
            Ok(_):
                pass_dn
        offset = end
    match upstream.flush():
        Err(_):
            return HttpStatus.BadGateway
        Ok(_):
            HttpStatus.Ok

fn reverse_proxy_stream(client: TcpStream, req: HttpRequest, route: ReverseProxyRoute) -> HttpStatus:
    if not reverse_proxy_prefix_matches(route, req):
        return HttpStatus.NotFound
    if not reverse_proxy_method_supported(req.method):
        return HttpStatus.MethodNotAllowed
    if reverse_proxy_request_upgrade(req):
        return HttpStatus.NotImplemented
    if reverse_proxy_request_transfer_chunked(req):
        return HttpStatus.NotImplemented

    match TcpStream.connect_timeout(route.upstream_addr, route.connect_timeout_ms):
        Err(_):
            return HttpStatus.GatewayTimeout
        Ok(upstream):
            val _read_timeout = upstream.set_read_timeout(route.io_timeout_ms)
            val _write_timeout = upstream.set_write_timeout(route.io_timeout_ms)
            if reverse_proxy_request_body_streaming_supported(req, route):
                val stream_status = reverse_proxy_write_streaming_request(upstream, req, route)
                if stream_status != HttpStatus.Ok:
                    val _ = upstream.close()
                    return stream_status
            else:
                val request_wire = reverse_proxy_serialize_request(req, route)
                match upstream.write_text(request_wire):
                    Err(_):
                        val _ = upstream.close()
                        return HttpStatus.BadGateway
                    Ok(_):
                        pass_dn
                val _flush = upstream.flush()
            val header_status = reverse_proxy_write_response_headers(client, upstream, route)
            if header_status != HttpStatus.Ok:
                val _ = upstream.close()
                return header_status
            val body_status = reverse_proxy_stream_response_body(client, upstream, route)
            if body_status != HttpStatus.Ok:
                val _ = upstream.close()
                return body_status
            val _close = upstream.close()
            HttpStatus.Ok
