# HTTP/3 Server — Frame/QPACK composition layer (RFC 9114)
#
# Part of std.nogc_sync_mut.http_server
# Design: doc/05_design/simple_web_server_lib_api.md
#
# HONEST GAP ASSESSMENT (2026-06-15):
#
# HTTP/3 runs over QUIC (RFC 9000), NOT over TCP.  The Simple runtime
# provides TcpStream (TCP-only).  There is no QuicStream or UDP datagram
# transport abstraction in the runtime.  Without QUIC, HTTP/3 cannot be
# wired end-to-end.
#
# What IS available and exercised here:
#   - h3_frame.spl: H3 frame emit/parse (variable-length integers, per-type
#     structs, SETTINGS encode/decode) — used below for pure framing logic
#   - h3_stream.spl: stream kind classification, state machine
#   - h3_conn.spl:   connection lifecycle state machine
#   - qpack_encoder.spl / qpack_decoder.spl: header compression
#
# What is MISSING:
#   GAP-H3-1: No QUIC-over-UDP transport in the Simple runtime.
#              HTTP/3 cannot accept connections or send/receive packets.
#              The server accept path is a documented stub.
#              Filed as: gap_h3_quic_transport_missing_2026-06-15.md
#
#   GAP-H3-2: No QUIC stream multiplexing — QUIC stream IDs, credit,
#              retransmission, congestion control are all absent.
#
#   GAP-H3-3: enum payload-carrying match bug (interp_enum_payload_match_crossmodule)
#              affects H3Frame dispatch too — same workaround as h2_server.spl
#              applies: dispatch on frame_type integer from h3_frame_parse,
#              extract payload bytes manually.
#
# This module provides:
#   - H3ServerGap — struct documenting why H3 cannot serve
#   - h3_server_gap() — returns the gap description (not a stub that pretends)
#   - h3_frame_encode_settings() — pure framing helper (testable without QUIC)
#   - h3_frame_encode_headers() — QPACK-encode headers for H3 HEADERS frame
#   - h3_frame_encode_data()    — encode a DATA frame payload
#   - h3_varint_encode/decode   — re-exported for callers
#   - H3SessionConfig           — future-use config when QUIC lands
# =============================================================================

use std.nogc_sync_mut.http.h3.h3_frame.{
    H3Frame, H3DataFrame, H3HeadersFrame, H3SettingsFrame, H3GoawayFrame,
    H3Setting, H3FrameOk, H3VarintOk, H3VarintResult, H3FrameResult,
    h3_frame_emit, h3_frame_parse, h3_write_frame,
    h3_varint_encode, h3_varint_decode,
    h3_settings_encode, h3_settings_decode
}
use std.nogc_sync_mut.http.h3.h3_conn.{H3ConnState, H3ConnEvent, h3_conn_transition}
use std.nogc_sync_mut.http.h3.h3_stream.{
    H3StreamKind, h3_stream_kind_from_type_byte,
    h3_stream_id_is_client_initiated, h3_stream_id_is_bidi
}
use std.nogc_sync_mut.http.h3.qpack_encoder.{qpack_encode_header_block, QpackHeader}
use std.nogc_sync_mut.http.h3.qpack_decoder.{qpack_decode_header_block}

# =============================================================================
# Gap documentation struct
# =============================================================================

class H3ServerGap:
    reason: text
    filed_bugs: [text]

fn h3_server_gap() -> H3ServerGap:
    H3ServerGap(
        reason: "HTTP/3 requires QUIC transport (RFC 9000) which is not available in the Simple runtime. HTTP/3 framing and QPACK compression layers are wired and tested; only the UDP/QUIC transport is absent.",
        filed_bugs: [
            "gap_h3_quic_transport_missing_2026-06-15.md",
            "gap_h3_quic_stream_mux_missing_2026-06-15.md",
            "interp_enum_payload_match_crossmodule_2026-06-15.md"
        ]
    )

# =============================================================================
# Pure framing helpers (testable without network / QUIC)
# =============================================================================

# Build an H3 SETTINGS frame payload encoding the given settings.
# Returns the raw bytes of the SETTINGS frame (type varint + length varint +
# payload).
fn h3_frame_encode_settings(settings: [H3Setting]) -> [u8]:
    val payload = h3_settings_encode(settings)
    val frame_type: i64 = 4  # H3_FRAME_SETTINGS = 0x04
    return h3_frame_emit(frame_type, payload)

# Encode a minimal server SETTINGS frame advertising no push.
fn h3_server_settings_bytes() -> [u8]:
    var settings: [H3Setting] = []
    settings.push(H3Setting(identifier: 1, value: 0))  # QPACK_MAX_TABLE_CAPACITY=0
    settings.push(H3Setting(identifier: 7, value: 0))  # QPACK_BLOCKED_STREAMS=0
    return h3_frame_encode_settings(settings)

# Build an H3 DATA frame wrapping `body_bytes`.
fn h3_frame_encode_data(body_bytes: [u8]) -> [u8]:
    val frame_type: i64 = 0  # H3_FRAME_DATA = 0x00
    return h3_frame_emit(frame_type, body_bytes)

# Build an H3 HEADERS frame for `name_value_pairs` using QPACK static-only
# encoding (no dynamic table, as QPACK encoder/decoder streams are absent).
# `name_value_pairs` is a list of (name, value) text tuples.
fn h3_frame_encode_headers(name_value_pairs: [(text, text)]) -> [u8]:
    var qpack_headers: [QpackHeader] = []
    for pair in name_value_pairs:
        qpack_headers.push(QpackHeader(name: pair.0, value: pair.1))
    val encoded = qpack_encode_header_block(qpack_headers)
    val frame_type: i64 = 1  # H3_FRAME_HEADERS = 0x01
    return h3_frame_emit(frame_type, encoded)

# Build a full H3 response (HEADERS + DATA) for the given status and body.
fn h3_encode_response(status_code: i64, body_bytes: [u8], extra_headers: [(text, text)]) -> [u8]:
    var pairs: [(text, text)] = []
    pairs.push((":status", "{status_code}"))
    val body_len = body_bytes.len()
    pairs.push(("content-length", "{body_len}"))
    for pair in extra_headers:
        pairs.push(pair)

    val headers_frame = h3_frame_encode_headers(pairs)
    val data_frame = h3_frame_encode_data(body_bytes)

    var out: [u8] = []
    for b in headers_frame:
        out.push(b)
    for b in data_frame:
        out.push(b)
    return out

# =============================================================================
# H3 session config (future use when QUIC lands)
# =============================================================================

class H3SessionConfig:
    # Maximum header table capacity to advertise (0 = static-only, safe default).
    qpack_max_table_capacity: i64
    # Maximum number of blocked streams (0 = no blocking).
    qpack_blocked_streams: i64
    # Maximum push ID (0 = no server push).
    max_push_id: i64

fn h3_session_config_default() -> H3SessionConfig:
    H3SessionConfig(
        qpack_max_table_capacity: 0,
        qpack_blocked_streams: 0,
        max_push_id: 0
    )

# =============================================================================
# Exports
# =============================================================================

export H3ServerGap, h3_server_gap
export H3SessionConfig, h3_session_config_default
export h3_frame_encode_settings, h3_server_settings_bytes
export h3_frame_encode_data, h3_frame_encode_headers
export h3_encode_response
