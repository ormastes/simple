# HTTP Server — Lightweight Embedded Web Server
#
# Part of std.nogc_sync_mut.http_server
# Full standalone example: examples/06_io/simple_web_server/
# Design: doc/05_design/simple_web_server_lib_api.md

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.nogc_sync_mut.http_server.types.{HttpRequest, HttpResponse, HttpStatus}
use std.nogc_sync_mut.http_server.parser.{parse_request, parse_request_with_limits, MAX_REQUEST_LINE, MAX_HEADER_COUNT, MAX_HEADER_LINE, MAX_BODY_SIZE}
use std.nogc_sync_mut.http_server.response.{write_response, write_error}
use std.nogc_sync_mut.http_server.router.{Router}
use std.concurrent.thread.{thread_spawn_with_args}

# Default maximum number of header read iterations before we consider the
# client too slow and abort.  Each iteration corresponds to one read_line call
# for a header.  At MAX_HEADER_COUNT (100) headers this gives headroom for
# normal requests while bounding worst-case handler occupation.
val DEFAULT_MAX_READ_ITERS: i32 = 200

class SimpleHttpServer:
    host: text
    port: i32
    router: Router
    running: bool

    static fn new(host: text, port: i32, router: Router) -> SimpleHttpServer:
        SimpleHttpServer(
            host: host,
            port: port,
            router: router,
            running: false
        )

    me start():
        self.running = true
        val addr = "{self.host}:{self.port}"
        match TcpListener.bind(addr):
            Err(e):
                print "Error: Failed to bind to {addr}: {e}"
                return
            Ok(listener):
                print "SimpleHttpServer listening on {addr}"
                self.serve_loop(listener)

    me start_with_callback(on_ready: fn(text, i32)):
        self.running = true
        val addr = "{self.host}:{self.port}"
        match TcpListener.bind(addr):
            Err(e):
                print "Error: Failed to bind to {addr}: {e}"
                return
            Ok(listener):
                on_ready(self.host, self.port)
                self.serve_loop(listener)

    me stop():
        self.running = false

    me serve_loop(listener: TcpListener):
        while self.running:
            match listener.accept():
                Ok(stream):
                    val handler = thread_spawn_with_args(stream, self, \conn_stream, server:
                        val srv: SimpleHttpServer = server
                        SimpleHttpServer.handle_connection_static(srv, conn_stream)
                    )
                    if handler.handle < 0:
                        SimpleHttpServer.handle_connection_static(self, stream)
                    else:
                        handler.free()
                Err(e):
                    if self.running:
                        print "Accept error: {e}"

    static fn handle_connection_static(server: SimpleHttpServer, stream: TcpStream):
        server.handle_connection(stream)

    me handle_connection(stream: TcpStream):
        match parse_request(stream):
            Ok(req):
                val resp = self.router.dispatch(req)
                if not write_response(stream, resp):
                    val _ = stream.close()
                    return
            Err(e):
                if not write_error(stream, HttpStatus.BadRequest, e):
                    val _ = stream.close()
                    return
        val _ = stream.close()
