# HTTP Types — Lightweight Embedded Web Server
#
# Part of std.nogc_sync_mut.http_server
# Full standalone example: examples/06_io/simple_web_server/
# Design: doc/05_design/simple_web_server_lib_api.md

# =============================================================================
# HTTP Method
# =============================================================================

enum HttpMethod:
    Get
    Post
    Put
    Delete
    Patch
    Head
    Options

fn http_method_from_text(s: text) -> HttpMethod:
    match s:
        "GET": HttpMethod.Get
        "POST": HttpMethod.Post
        "PUT": HttpMethod.Put
        "DELETE": HttpMethod.Delete
        "PATCH": HttpMethod.Patch
        "HEAD": HttpMethod.Head
        "OPTIONS": HttpMethod.Options
        _: HttpMethod.Get

fn http_method_to_text(m: HttpMethod) -> text:
    match m:
        HttpMethod.Get: "GET"
        HttpMethod.Post: "POST"
        HttpMethod.Put: "PUT"
        HttpMethod.Delete: "DELETE"
        HttpMethod.Patch: "PATCH"
        HttpMethod.Head: "HEAD"
        HttpMethod.Options: "OPTIONS"

fn is_method_safe(method: HttpMethod) -> bool:
    match method:
        HttpMethod.Get: true
        HttpMethod.Head: true
        HttpMethod.Options: true
        _: false

fn is_method_idempotent(method: HttpMethod) -> bool:
    match method:
        HttpMethod.Get: true
        HttpMethod.Head: true
        HttpMethod.Put: true
        HttpMethod.Delete: true
        HttpMethod.Options: true
        _: false

# =============================================================================
# HTTP Status
# =============================================================================

enum HttpStatus:
    Ok
    Created
    Accepted
    NoContent
    MovedPermanently
    Found
    SeeOther
    NotModified
    TemporaryRedirect
    BadRequest
    Unauthorized
    Forbidden
    NotFound
    MethodNotAllowed
    Conflict
    Gone
    PayloadTooLarge
    TooManyRequests
    InternalError
    NotImplemented
    BadGateway
    ServiceUnavailable
    GatewayTimeout

fn http_status_code(s: HttpStatus) -> i32:
    match s:
        HttpStatus.Ok: 200
        HttpStatus.Created: 201
        HttpStatus.Accepted: 202
        HttpStatus.NoContent: 204
        HttpStatus.MovedPermanently: 301
        HttpStatus.Found: 302
        HttpStatus.SeeOther: 303
        HttpStatus.NotModified: 304
        HttpStatus.TemporaryRedirect: 307
        HttpStatus.BadRequest: 400
        HttpStatus.Unauthorized: 401
        HttpStatus.Forbidden: 403
        HttpStatus.NotFound: 404
        HttpStatus.MethodNotAllowed: 405
        HttpStatus.Conflict: 409
        HttpStatus.Gone: 410
        HttpStatus.PayloadTooLarge: 413
        HttpStatus.TooManyRequests: 429
        HttpStatus.InternalError: 500
        HttpStatus.NotImplemented: 501
        HttpStatus.BadGateway: 502
        HttpStatus.ServiceUnavailable: 503
        HttpStatus.GatewayTimeout: 504

fn http_status_reason(s: HttpStatus) -> text:
    match s:
        HttpStatus.Ok: "OK"
        HttpStatus.Created: "Created"
        HttpStatus.Accepted: "Accepted"
        HttpStatus.NoContent: "No Content"
        HttpStatus.MovedPermanently: "Moved Permanently"
        HttpStatus.Found: "Found"
        HttpStatus.SeeOther: "See Other"
        HttpStatus.NotModified: "Not Modified"
        HttpStatus.TemporaryRedirect: "Temporary Redirect"
        HttpStatus.BadRequest: "Bad Request"
        HttpStatus.Unauthorized: "Unauthorized"
        HttpStatus.Forbidden: "Forbidden"
        HttpStatus.NotFound: "Not Found"
        HttpStatus.MethodNotAllowed: "Method Not Allowed"
        HttpStatus.Conflict: "Conflict"
        HttpStatus.Gone: "Gone"
        HttpStatus.PayloadTooLarge: "Payload Too Large"
        HttpStatus.TooManyRequests: "Too Many Requests"
        HttpStatus.InternalError: "Internal Server Error"
        HttpStatus.NotImplemented: "Not Implemented"
        HttpStatus.BadGateway: "Bad Gateway"
        HttpStatus.ServiceUnavailable: "Service Unavailable"
        HttpStatus.GatewayTimeout: "Gateway Timeout"

fn http_status_from_code(code: i32) -> HttpStatus:
    match code:
        200: HttpStatus.Ok
        201: HttpStatus.Created
        202: HttpStatus.Accepted
        204: HttpStatus.NoContent
        301: HttpStatus.MovedPermanently
        302: HttpStatus.Found
        303: HttpStatus.SeeOther
        304: HttpStatus.NotModified
        307: HttpStatus.TemporaryRedirect
        400: HttpStatus.BadRequest
        401: HttpStatus.Unauthorized
        403: HttpStatus.Forbidden
        404: HttpStatus.NotFound
        405: HttpStatus.MethodNotAllowed
        409: HttpStatus.Conflict
        410: HttpStatus.Gone
        413: HttpStatus.PayloadTooLarge
        429: HttpStatus.TooManyRequests
        500: HttpStatus.InternalError
        501: HttpStatus.NotImplemented
        502: HttpStatus.BadGateway
        503: HttpStatus.ServiceUnavailable
        504: HttpStatus.GatewayTimeout
        _: HttpStatus.InternalError

# =============================================================================
# MIME Types
# =============================================================================

fn mime_type_for_extension(path: text) -> text:
    if path.ends_with(".html") or path.ends_with(".htm"):
        return "text/html; charset=utf-8"
    if path.ends_with(".css"):
        return "text/css; charset=utf-8"
    if path.ends_with(".js"):
        return "application/javascript; charset=utf-8"
    if path.ends_with(".json"):
        return "application/json; charset=utf-8"
    if path.ends_with(".xml"):
        return "application/xml; charset=utf-8"
    if path.ends_with(".txt"):
        return "text/plain; charset=utf-8"
    if path.ends_with(".csv"):
        return "text/csv; charset=utf-8"
    if path.ends_with(".png"):
        return "image/png"
    if path.ends_with(".jpg") or path.ends_with(".jpeg"):
        return "image/jpeg"
    if path.ends_with(".gif"):
        return "image/gif"
    if path.ends_with(".svg"):
        return "image/svg+xml"
    if path.ends_with(".ico"):
        return "image/x-icon"
    if path.ends_with(".webp"):
        return "image/webp"
    if path.ends_with(".woff2"):
        return "font/woff2"
    if path.ends_with(".woff"):
        return "font/woff"
    if path.ends_with(".pdf"):
        return "application/pdf"
    if path.ends_with(".zip"):
        return "application/zip"
    if path.ends_with(".wasm"):
        return "application/wasm"
    return "application/octet-stream"

# =============================================================================
# HTTP Request
# =============================================================================

fn pure_text_to_i64(s: text) -> i64:
    val n = s.len()
    if n == 0:
        return 0
    val zero = "0".to_i64()
    var result: i64 = 0
    var i = 0
    if s.char_at(0) == "-":
        i = 1
    while i < n:
        val digit = s.char_at(i).to_i64() - zero
        if digit < 0 or digit > 9:
            return 0
        result = result * 10 + digit
        i = i + 1
    if s.char_at(0) == "-":
        result = 0 - result
    return result

class HttpRequest:
    method: HttpMethod
    path: text
    query: text
    version: text
    headers: [(text, text)]
    body: text
    remote_addr: text

    static fn new(method: HttpMethod, path: text) -> HttpRequest:
        HttpRequest(
            method: method,
            path: path,
            query: "",
            version: "HTTP/1.1",
            headers: [],
            body: "",
            remote_addr: ""
        )

    fn header(name: text) -> text:
        val lower_name = name.to_lower()
        for pair in self.headers:
            if pair.0.to_lower() == lower_name:
                return pair.1
        return ""

    fn has_header(name: text) -> bool:
        val lower_name = name.to_lower()
        for pair in self.headers:
            if pair.0.to_lower() == lower_name:
                return true
        return false

    fn content_type() -> text:
        self.header("Content-Type")

    fn content_length() -> i32:
        val val_str = self.header("Content-Length")
        if val_str == "":
            return 0
        val v = pure_text_to_i64(val_str.trim())
        if v == 0 and val_str.trim() != "0":
            return 0
        return v.to_i32()

    fn query_param(name: text) -> text:
        if self.query == "":
            return ""
        for part in self.query.split("&"):
            val kv = part.split("=")
            if kv.len() >= 2 and kv[0] == name:
                return kv[1]
        return ""

# =============================================================================
# HTTP Response
# =============================================================================

class HttpResponse:
    status: HttpStatus
    headers: [(text, text)]
    body: text

    static fn ok(body: text) -> HttpResponse:
        HttpResponse(
            status: HttpStatus.Ok,
            headers: [("Content-Type", "text/plain; charset=utf-8")],
            body: body
        )

    static fn json(body: text) -> HttpResponse:
        HttpResponse(
            status: HttpStatus.Ok,
            headers: [("Content-Type", "application/json; charset=utf-8")],
            body: body
        )

    static fn html(body: text) -> HttpResponse:
        HttpResponse(
            status: HttpStatus.Ok,
            headers: [("Content-Type", "text/html; charset=utf-8")],
            body: body
        )

    static fn redirect(url: text) -> HttpResponse:
        HttpResponse(
            status: HttpStatus.Found,
            headers: [("Location", url)],
            body: ""
        )

    static fn not_found() -> HttpResponse:
        HttpResponse(
            status: HttpStatus.NotFound,
            headers: [("Content-Type", "text/plain; charset=utf-8")],
            body: "404 Not Found"
        )

    static fn error(status: HttpStatus, message: text) -> HttpResponse:
        HttpResponse(
            status: status,
            headers: [("Content-Type", "text/plain; charset=utf-8")],
            body: message
        )

    fn with_header(name: text, value: text) -> HttpResponse:
        self.headers.push((name, value))
        return self

    fn with_content_type(ct: text) -> HttpResponse:
        var new_headers: [(text, text)] = []
        for pair in self.headers:
            if pair.0.to_lower() != "content-type":
                new_headers.push(pair)
        new_headers.push(("Content-Type", ct))
        self.headers = new_headers
        return self

    fn status_code() -> i32:
        http_status_code(self.status)
