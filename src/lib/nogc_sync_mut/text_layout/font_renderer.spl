# Hosted module initialization eagerly creates these facade mutexes before
# worker threads start. Freestanding native-builds leave function-call module
# initializers nil, so the same optional slots initialize on first use after the
# heap is ready; that path is single-core.
use std.skia.entity.font.{sk_font_new, sk_font_style_normal, sk_typeface_from_attached_font}
use std.skia.feature.glyph.ot_parser.{parse_offset_table}
use std.skia.feature.shaper.font_fallback.{fallback_chain_new}
use std.skia.feature.shaper.shaper.{shaped_run_to_font_glyph_run, shaper_new, shaper_shape_with_language, shaper_with_ot_face}
use std.skia.feature.shaper.script_detect.{Script, script_of}
export use std.nogc_sync_mut.text_layout.font_types.{
    CachedGlyph, FontCacheStats, FontGlyphRun, FontTextPayload, FontRenderQuad, FontRenderBatch,
    FontRenderConfig, FontExecutionPolicy, font_execution_plan, font_render_category_name,
    font_render_config_normalize, font_render_config_default_for_size
}

# Shared Font Renderer — unified buffer text for OS and browser.
# Backends are TrueType/OpenType, the small built-in vector face, then VGA
# bitmap fallback. The first available backend owns each glyph.
# This module has NO dependency on CompositorBackend, so it can be used
# by the OS compositor, browser engine, and game engine alike.

# ============================================================================
# Glyph Cache
# ============================================================================

class ResolvedFontMetrics:
    valid: bool
    family: text
    identity: text
    advances: [i32]
    width: i32
    line_height: i32
    reason: text
    glyph_run: DrawIrGlyphRunPayload
    shaping_required: bool

# ponytail: process-local 128-entry ring for pinned layout metrics; replace with
# per-document caches only when concurrent multi-face ownership lands.
val RESOLVED_FONT_METRICS_CACHE_LIMIT: i64 = 128
val RESOLVED_FONT_METRICS_CACHE_FAMILY_LIMIT: i64 = 1024
val RESOLVED_FONT_METRICS_CACHE_CONTENT_LIMIT: i64 = 4096
var _resolved_font_metric_keys: [text] = []
var _resolved_font_metric_values: [ResolvedFontMetrics] = []
var _resolved_font_metric_cursor: i64 = 0
var _resolved_font_metric_lock: Mutex? = mutex_new(0)

fn _font_mutex_acquire(current: Mutex?) -> Mutex:
    if val active = current:
        active.lock()
        return active
    val created = mutex_new(0)
    created.lock()
    created

fn _font_mutex_release(current: Mutex?):
    if val active = current:
        active.unlock(0)

fn _resolved_font_metric_lock_acquire():
    _resolved_font_metric_lock = _font_mutex_acquire(_resolved_font_metric_lock)

fn _resolved_font_metric_lock_release():
    _font_mutex_release(_resolved_font_metric_lock)

fn _resolved_font_metric_key(family: text, content: text, font_size: i32, identity: text) -> text:
    _resolved_font_metric_language_key(family, content, font_size, identity, "und")

fn _resolved_font_metric_language_key(family: text, content: text, font_size: i32, identity: text, language: text) -> text:
    _resolved_font_metric_language_config_key(
        family, content, font_size, identity, language,
        font_render_config_default_for_size(font_size).identity()
    )

fn _resolved_font_metric_language_config_key(family: text, content: text, font_size: i32,
                                             identity: text, language: text,
                                             render_config_identity: text) -> text:
    family.trim().lower() + "\n" + font_size.to_string() + "\n" + language.trim().lower() + "\n" +
        identity.len().to_string() + ":" + identity + "\n" +
        render_config_identity.len().to_string() + ":" + render_config_identity + "\n" + content

fn _resolved_font_metrics_cacheable(family: text, content: text) -> bool:
    family.len() <= RESOLVED_FONT_METRICS_CACHE_FAMILY_LIMIT and content.len() <= RESOLVED_FONT_METRICS_CACHE_CONTENT_LIMIT

fn _font_shaped_glyph_destination(pen_x: i32, pen_y: i32, glyph: CachedGlyph, ascent: i32) -> (bool, i32, i32):
    val x = pen_x.to_i64() + glyph.bearing_x.to_i64()
    val y = ascent.to_i64() + pen_y.to_i64() - glyph.bearing_y.to_i64() - glyph.height.to_i64()
    if x < -2147483648 or x > 2147483647 or y < -2147483648 or y > 2147483647:
        return (false, 0, 0)
    (true, x.to_i32(), y.to_i32())

fn _resolved_font_metric_cached(key: text) -> ResolvedFontMetrics?:
    _resolved_font_metric_lock_acquire()
    var found: ResolvedFontMetrics? = nil
    var index: i64 = 0
    while index < _resolved_font_metric_keys.len() and found == nil:
        if _resolved_font_metric_keys[index] == key:
            found = _resolved_font_metric_values[index]
        index = index + 1
    _resolved_font_metric_lock_release()
    found

fn _resolved_font_metric_store(key: text, metrics: ResolvedFontMetrics):
    _resolved_font_metric_lock_acquire()
    if _resolved_font_metric_keys.len() < RESOLVED_FONT_METRICS_CACHE_LIMIT:
        _resolved_font_metric_keys.push(key)
        _resolved_font_metric_values.push(metrics)
        _resolved_font_metric_lock_release()
        return
    _resolved_font_metric_keys[_resolved_font_metric_cursor] = key
    _resolved_font_metric_values[_resolved_font_metric_cursor] = metrics
    _resolved_font_metric_cursor = (_resolved_font_metric_cursor + 1) % RESOLVED_FONT_METRICS_CACHE_LIMIT
    _resolved_font_metric_lock_release()

# Loaded-default-font cache keyed by resolved family. browser_default_for_family
# does a real dlopen + TTF parse (the universal sans face is 17MB), so without
# reuse every #text node reparses the whole font — quadratic for a real page and
# the dominant web-render cost under the interpreter. Cached renderers are NEVER
# clear_ttf()'d (see _resolve_font_metrics_with_language_config's guarded calls)
# so the loaded face stays live for the next node of the same family.
var _browser_default_font_families: [text] = []
var _browser_default_font_renderers: [FontRenderer] = []
var _registered_selected_font_paths: [text] = []
var _registered_selected_font_blobs: [[u8]] = []
var _registered_selected_fonts_only: bool = false
var _browser_default_font_lock: Mutex? = mutex_new(0)

fn _browser_default_font_lock_acquire():
    _browser_default_font_lock = _font_mutex_acquire(_browser_default_font_lock)

fn _browser_default_font_lock_release():
    _font_mutex_release(_browser_default_font_lock)

fn _registered_selected_font_bytes(path: text) -> ([u8], bool):
    _browser_default_font_lock_acquire()
    var index: i64 = 0
    while index < _registered_selected_font_paths.len():
        if _registered_selected_font_paths[index] == path:
            val blob = _registered_selected_font_blobs[index]
            _browser_default_font_lock_release()
            return (blob, true)
        index = index + 1
    _browser_default_font_lock_release()
    ([], false)

fn font_renderer_registered_selected_bytes_only() -> bool:
    _browser_default_font_lock_acquire()
    val enabled = _registered_selected_fonts_only
    _browser_default_font_lock_release()
    enabled

fn font_renderer_use_registered_selected_bytes_only():
    """Keep freestanding consumers away from host-only file externs."""
    _browser_default_font_lock_acquire()
    _registered_selected_fonts_only = true
    for renderer in _browser_default_font_renderers:
        renderer.clear_ttf()
    _browser_default_font_families = []
    _browser_default_font_renderers = []
    _browser_default_font_lock_release()
    _resolved_font_metric_lock_acquire()
    _resolved_font_metric_keys = []
    _resolved_font_metric_values = []
    _resolved_font_metric_cursor = 0
    _resolved_font_metric_lock_release()

fn font_renderer_register_selected_bytes(path: text, blob: [u8]) -> bool:
    """Register exact pinned bytes for producer metrics and executor loading."""
    val candidate = selected_font_asset_candidate_for_path(path)
    if candidate == nil:
        return false
    var renderer = FontRenderer.new()
    if not renderer.try_load_selected_bytes(path, blob):
        return false
    val identity = renderer.current_font_identity()
    renderer.clear_ttf()
    if identity != selected_font_asset_identity(candidate.?):
        return false
    _browser_default_font_lock_acquire()
    for registered_path in _registered_selected_font_paths:
        if registered_path == path:
            _browser_default_font_lock_release()
            return true
    _registered_selected_font_paths.push(path)
    _registered_selected_font_blobs.push(blob)
    _browser_default_font_lock_release()
    true

fn _browser_default_for_family_cached(family: text) -> (FontRenderer, bool):
    _browser_default_font_lock_acquire()
    var index: i64 = 0
    while index < _browser_default_font_families.len():
        if _browser_default_font_families[index] == family:
            val hit = _browser_default_font_renderers[index]
            _browser_default_font_lock_release()
            return (hit, true)
        index = index + 1
    _browser_default_font_lock_release()
    val loaded = FontRenderer.browser_default_for_family(family)
    if loaded.has_sffi_ttf():
        _browser_default_font_lock_acquire()
        _browser_default_font_families.push(family)
        _browser_default_font_renderers.push(loaded)
        _browser_default_font_lock_release()
    (loaded, false)

val FONT_ATLAS_WIDTH: i32 = 1024
val FONT_ATLAS_HEIGHT: i32 = 1024
# The scalar stays literal-initialized for freestanding startup. Its dedicated
# facade mutex is eager on hosted builds and lazy on the single-core baremetal
# path, matching the cache locks above.
var _font_atlas_dependency_generation_counter: i64 = 0
var _font_atlas_dependency_generation_lock: Mutex? = mutex_new(0)

fn _font_render_batch_with_config(batch: FontRenderBatch, config: FontRenderConfig) -> FontRenderBatch:
    FontRenderBatch(
        program_version: batch.program_version, font_identity: batch.font_identity,
        face_generation: batch.face_generation, valid: batch.valid,
        atlas_width: batch.atlas_width, atlas_height: batch.atlas_height,
        atlas_pixels: batch.atlas_pixels, quads: batch.quads,
        atlas_generation: batch.atlas_generation, dirty_rects: batch.dirty_rects,
        render_config_identity: config.identity(), transform_identity: batch.transform_identity,
        execution_target: font_render_config_normalize(config.execution_target),
        execution_policy: config.execution_policy
    )

fn _font_render_config_default_selection(config: FontRenderConfig) -> bool:
    (font_render_config_normalize(config.family) == "auto" and
        font_render_category_name(config.category) == "auto" and
        font_render_config_normalize(config.language) == "und" and
        font_render_config_normalize(config.script) == "auto")

fn _font_render_config_candidate(config: FontRenderConfig) -> FontAssetCandidate?:
    if _font_render_config_default_selection(config):
        return nil
    val normalized_language = font_render_config_normalize(config.language)
    val language_parts = normalized_language.split("-")
    if language_parts.len() == 0 or language_parts[0] == "":
        return nil
    val language = language_parts[0]
    val category = font_render_category_name(config.category)
    if language == "und" or category == "auto":
        return nil
    val selected = selected_font_asset_for_language_category(language, category)
    if selected == nil:
        return nil
    val candidate = selected.?
    val family = font_render_config_normalize(config.family)
    if family != "auto" and family != candidate.family.lower():
        return nil
    var expected_script = ""
    for rank in selected_font_language_ranks():
        if rank.language == language:
            expected_script = rank.likely_script.lower()
    val script = font_render_config_normalize(config.script)
    if expected_script == "" or (script != "auto" and script != expected_script):
        return nil
    candidate

fn font_render_config_selection_supported(config: FontRenderConfig) -> bool:
    config.valid() and (_font_render_config_default_selection(config) or _font_render_config_candidate(config) != nil)

fn _font_atlas_dependency_generation_after(current: i64) -> i64:
    if current < 0 or current >= 9223372036854775807:
        return 0
    current + 1

fn _next_font_atlas_dependency_generation() -> i64:
    _font_atlas_dependency_generation_lock = _font_mutex_acquire(_font_atlas_dependency_generation_lock)
    val next = _font_atlas_dependency_generation_after(_font_atlas_dependency_generation_counter)
    _font_atlas_dependency_generation_counter = next
    _font_mutex_release(_font_atlas_dependency_generation_lock)
    next

class GlyphCache:
    entries: [CachedGlyph]
    max_entries: i32
    max_bytes: i64
    payload_bytes: i64
    hits: i64
    misses: i64
    rasterizations: i64
    evictions: i64
    observed_generation: i64
    observed_font_identity: text
    observed_render_config_identity: text

    static fn new(max_size: i32) -> GlyphCache:
        GlyphCache(entries: [], max_entries: max_size, max_bytes: 33554432, payload_bytes: 0, hits: 0, misses: 0, rasterizations: 0, evictions: 0, observed_generation: 0, observed_font_identity: "", observed_render_config_identity: "")

    me lookup(codepoint: i32, font_size: i32) -> CachedGlyph?:
        for entry in self.entries:
            if (entry.glyph_index < 0 and entry.codepoint == codepoint and entry.font_size == font_size and
                entry.render_config_identity == self.observed_render_config_identity):
                self.hits = self.hits + 1
                return entry
        self.misses = self.misses + 1
        nil

    me lookup_index(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32) -> CachedGlyph?:
        for entry in self.entries:
            if (entry.face_id == face_id and entry.face_generation == face_generation and
                entry.glyph_index == glyph_index and entry.font_size == font_size and
                entry.render_config_identity == self.observed_render_config_identity):
                self.hits = self.hits + 1
                return entry
        self.misses = self.misses + 1
        nil

    me record_rasterization():
        self.rasterizations = self.rasterizations + 1

    me insert(glyph: CachedGlyph) -> bool:
        val glyph_bytes = glyph.pixels.len().to_i64()
        if glyph_bytes > self.max_bytes:
            return false
        while self.entries.len() >= self.max_entries or self.payload_bytes + glyph_bytes > self.max_bytes:
            if self.entries.len() == 0:
                return false
            self.payload_bytes = self.payload_bytes - self.entries[0].pixels.len().to_i64()
            self.entries = self.entries.slice(1, self.entries.len())
            self.evictions = self.evictions + 1
        var entries = self.entries
        var configured = glyph
        configured.render_config_identity = self.observed_render_config_identity
        entries.push(configured)
        self.entries = entries
        self.payload_bytes = self.payload_bytes + glyph_bytes
        true

    me invalidate():
        self.entries = []
        self.payload_bytes = 0

    me sync_face_identity(generation: i64, identity: text):
        if generation != self.observed_generation or identity != self.observed_font_identity:
            self.invalidate()
            self.observed_generation = generation
            self.observed_font_identity = identity

    me sync_generation(generation: i64):
        self.sync_face_identity(generation, self.observed_font_identity)

    me sync_render_config_identity(identity: text):
        if identity != self.observed_render_config_identity:
            self.invalidate()
            self.observed_render_config_identity = identity

    me reset_stats():
        self.hits = 0
        self.misses = 0
        self.rasterizations = 0
        self.evictions = 0

    fn stats() -> FontCacheStats:
        FontCacheStats(entries: self.entries.len().to_i64(), bytes: self.payload_bytes, generation: self.observed_generation, font_identity: self.observed_font_identity, hits: self.hits, misses: self.misses, rasterizations: self.rasterizations, evictions: self.evictions, render_config_identity: self.observed_render_config_identity)

# ============================================================================
# Font Renderer
# ============================================================================

class FontRenderer:
    cache: GlyphCache
    ttf_handle: i64     # TrueType font handle (0 = not loaded)
    use_vector: bool     # enable vector font fallback
    use_bitmap: bool     # enable bitmap font fallback
    ttf_rasterizer: FontRasterizer?  # Phase 3b: SFFI spl_fonts TTF backend (nil = disabled)
    atlas_pixels: [u32]
    atlas_codepoints: [i32]
    atlas_face_ids: [i64]
    atlas_face_generations: [i64]
    atlas_glyph_indices: [i32]
    atlas_font_sizes: [i32]
    atlas_xs: [i32]
    atlas_ys: [i32]
    atlas_widths: [i32]
    atlas_heights: [i32]
    atlas_cursor_x: i32
    atlas_cursor_y: i32
    atlas_row_height: i32
    atlas_generation: i64
    atlas_face_generation: i64
    atlas_font_identity: text
    active_render_config_identity: text = ""

    static fn new() -> FontRenderer:
        val cache = GlyphCache.new(512)
        val renderer = FontRenderer(
            cache: cache,
            ttf_handle: 0,
            use_vector: true,
            use_bitmap: true,
            ttf_rasterizer: nil,
            atlas_pixels: [], atlas_codepoints: [], atlas_face_ids: [], atlas_face_generations: [], atlas_glyph_indices: [], atlas_font_sizes: [],
            atlas_xs: [], atlas_ys: [], atlas_widths: [], atlas_heights: [],
            atlas_cursor_x: 0, atlas_cursor_y: 0, atlas_row_height: 0,
            atlas_generation: 0, atlas_face_generation: -1, atlas_font_identity: ""
        )
        renderer

    static fn with_ttf(handle: i64) -> FontRenderer:
        val cache = GlyphCache.new(512)
        val renderer = FontRenderer(
            cache: cache,
            ttf_handle: handle,
            use_vector: true,
            use_bitmap: true,
            ttf_rasterizer: nil,
            atlas_pixels: [], atlas_codepoints: [], atlas_face_ids: [], atlas_face_generations: [], atlas_glyph_indices: [], atlas_font_sizes: [],
            atlas_xs: [], atlas_ys: [], atlas_widths: [], atlas_heights: [],
            atlas_cursor_x: 0, atlas_cursor_y: 0, atlas_row_height: 0,
            atlas_generation: 0, atlas_face_generation: -1, atlas_font_identity: ""
        )
        renderer

    static fn browser_serif_default() -> FontRenderer:
        FontRenderer.browser_default_for_family("serif")

    static fn browser_default_for_family(family: text) -> FontRenderer:
        val registered_only = font_renderer_registered_selected_bytes_only()
        val candidates = browser_font_candidates_for_family(family)
        for font_path in candidates:
            val registered = _registered_selected_font_bytes(font_path)
            val registered_blob = registered.0
            val has_registered_blob = registered_blob.len() > 0
            if has_registered_blob:
                var renderer = FontRenderer.new()
                if renderer.try_load_selected_bytes(font_path, registered_blob):
                    return renderer
            if not registered_only:
                var renderer = FontRenderer.new()
                if renderer.try_load_runtime_ttf(font_path):
                    return renderer
        FontRenderer.new()

    fn has_ttf() -> bool:
        self.ttf_handle > 0

    fn selected_face_has_glyph(codepoint: i32) -> bool:
        """True only when the active selected face maps this codepoint to a
        nonzero glyph. Bitmap/vector fallback and `.notdef` do not count."""
        val active = self.ttf_rasterizer
        active != nil and active.?.has_glyph(codepoint.to_i64())

    # -----------------------------------------------------------------------
    # Phase 3b: opt-in SFFI spl_fonts TrueType backend
    # -----------------------------------------------------------------------
    # Attempts to load `dylib_path` and initialize it with `ttf_path`. On
    # success the renderer will prefer the SFFI spl_fonts rasterizer for
    # glyphs (highest-priority backend). On any failure the renderer stays
    # in its default state and callers fall through to the vector/bitmap
    # paths unchanged. Caller opt-in only — default FontRenderer.new()
    # instances behave exactly as before.
    me _try_install_ttf(rasterizer: FontRasterizer?) -> bool:
        if rasterizer == nil:
            return false
        val old = self.ttf_rasterizer
        self.ttf_rasterizer = rasterizer
        if old != nil:
            old.close()
        var cache = self.cache
        cache.invalidate()
        self.cache = cache
        self.atlas_face_generation = -1
        true

    me try_enable_ttf(dylib_path: text, ttf_path: text) -> bool:
        val rasterizer = FontRasterizer.load(dylib_path, ttf_path)
        self._try_install_ttf(rasterizer)

    me try_load_runtime_ttf(ttf_path: text) -> bool:
        if ttf_path.trim() == "":
            return false
        val dylib_candidates = browser_font_dylib_candidates()
        for dylib_path in dylib_candidates:
            if self.try_enable_ttf(dylib_path, ttf_path):
                return true
        val selected_rasterizer = FontRasterizer.load_selected(ttf_path)
        self._try_install_ttf(selected_rasterizer)

    me try_load_selected_bytes(ttf_path: text, blob: [u8]) -> bool:
        val rasterizer = FontRasterizer.load_selected_bytes(ttf_path, blob)
        self._try_install_ttf(rasterizer)

    me try_load_registered_identity(identity: text) -> bool:
        val candidate = selected_font_asset_candidate_for_identity(identity)
        if candidate == nil:
            return false
        val registered = _registered_selected_font_bytes(candidate.?.local_path)
        registered.1 and self.try_load_selected_bytes(candidate.?.local_path, registered.0)

    me clear_ttf():
        val rast = self.ttf_rasterizer
        if rast != nil:
            rast.close()
        self.ttf_rasterizer = nil
        var cache = self.cache
        cache.sync_face_identity(0, "")
        self.cache = cache
        self.atlas_face_generation = -1

    fn cache_stats() -> FontCacheStats: self.cache.stats()
    me current_font_identity() -> text:
        val rasterizer = self.ttf_rasterizer
        if rasterizer == nil:
            return ""
        val snapshot = rasterizer.cache_identity_snapshot()
        var cache = self.cache
        cache.sync_face_identity(snapshot.0, snapshot.1)
        self.cache = cache
        snapshot.1

    me reset_cache_stats():
        var cache = self.cache
        cache.reset_stats()
        self.cache = cache

    me _activate_render_config(config: FontRenderConfig):
        val identity = config.identity()
        if identity != self.active_render_config_identity:
            var cache = self.cache
            cache.sync_render_config_identity(identity)
            self.cache = cache
            if self.active_render_config_identity != "":
                self._reset_font_atlas(self.atlas_face_generation, self.atlas_font_identity)
            self.active_render_config_identity = identity

    fn _invalid_config_batch(config: FontRenderConfig) -> FontRenderBatch:
        val stats = self.cache.stats()
        _font_render_batch_with_config(FontRenderBatch(
            program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION,
            font_identity: stats.font_identity, face_generation: stats.generation, valid: false,
            atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT,
            atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation,
            dirty_rects: []
        ), config)

    me _ensure_render_config_face(config: FontRenderConfig) -> bool:
        if _font_render_config_default_selection(config):
            return true
        val selected = _font_render_config_candidate(config)
        if selected == nil:
            return false
        val candidate = selected.?
        val expected_identity = selected_font_asset_identity(candidate)
        val active = self.ttf_rasterizer
        if active != nil:
            val snapshot = active.?.cache_identity_snapshot()
            if snapshot.1 == expected_identity:
                return true
        val loaded = FontRasterizer.load_selected(candidate.local_path)
        if loaded == nil:
            return false
        self.ttf_rasterizer = loaded
        self.current_font_identity() == expected_identity

    fn _render_config_matches_run(config: FontRenderConfig, run: FontGlyphRun) -> bool:
        if _font_render_config_default_selection(config):
            return true
        val selected = _font_render_config_candidate(config)
        selected != nil and font_face_identity(run.face_id, run.face_generation) == selected_font_asset_identity(selected.?)

    me try_enable_browser_serif_default() -> bool:
        for dylib_path in browser_font_dylib_candidates():
            for font_path in browser_serif_font_candidates():
                if self.try_enable_ttf(dylib_path, font_path):
                    return true
        false

    fn has_sffi_ttf() -> bool:
        val rasterizer = self.ttf_rasterizer
        if rasterizer == nil:
            return false
        rasterizer.is_current()

    me horizontal_kern(left_codepoint: i32, right_codepoint: i32, font_size: i32) -> i32:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.horizontal_kern(left_codepoint.to_i64(), right_codepoint.to_i64(), font_size.to_i64()).to_i32()
        0

    me horizontal_line_metric(font_size: i32, field: i32) -> i32:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.horizontal_line_metric(font_size.to_i64(), field.to_i64()).to_i32()
        0

    me layout_text(content: text, font_size: i32, max_width: i32) -> [LayoutGlyph]:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.layout_text(content, font_size.to_i64(), max_width.to_i64())
        []

    me rasterize_subpixel(codepoint: i32, font_size: i32) -> SubpixelGlyphBitmap?:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.rasterize_subpixel(codepoint.to_i64(), font_size.to_i64())
        nil

    # -----------------------------------------------------------------------
    # Get glyph (cached) — returns rasterized alpha bitmap
    # -----------------------------------------------------------------------
    fn glyph_with_cache(codepoint: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        if codepoint < 0 or codepoint > 1114111 or font_size <= 0 or font_size > 512:
            return (CachedGlyph.empty(codepoint, font_size), initial_cache)
        val active_rasterizer = self.ttf_rasterizer
        var cache = initial_cache
        if active_rasterizer != nil:
            val identity_snapshot = active_rasterizer.cache_identity_snapshot()
            cache.sync_face_identity(identity_snapshot.0, identity_snapshot.1)
        # Check cache first
        val cached = cache.lookup(codepoint, font_size)
        if cached != nil:
            return (cached, cache)

        # Rasterize
        cache.record_rasterization()
        var glyph = CachedGlyph.empty(codepoint, font_size)

        # Phase 3b: prefer SFFI spl_fonts TrueType backend when the caller
        # has opted in via try_enable_ttf(). Any failure falls through to
        # the existing vector/bitmap path unchanged. Under the interpreter,
        # static-fn Option<T> returns are typed as T directly, so we use
        # `!= nil` rather than `if val Some(x) =` destructuring.
        var handled = false
        val rast = active_rasterizer
        if rast != nil and rast.has_glyph(codepoint.to_i64()):
            val gb = rast.rasterize(codepoint.to_i64(), font_size.to_i64())
            if gb != nil:
                glyph = _sffi_glyph_to_cached(gb, codepoint, font_size)
                handled = true

        if not handled:
            if self.has_ttf():
                glyph = rasterize_ttf(self.ttf_handle, codepoint, font_size)
            else if self.use_vector:
                val vector_cmds = vf_glyph_commands(codepoint)
                if vector_cmds.len() > 0:
                    glyph = rasterize_vector(vector_cmds, codepoint, font_size)
                else if self.use_bitmap:
                    glyph = rasterize_bitmap(codepoint, font_size)
            else if self.use_bitmap:
                glyph = rasterize_bitmap(codepoint, font_size)

        val expected_pixels = glyph.width.to_i64() * glyph.height.to_i64()
        if glyph.advance > 0 and expected_pixels == glyph.pixels.len().to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me get_glyph(codepoint: i32, font_size: i32) -> CachedGlyph:
        val result = self.glyph_with_cache(codepoint, font_size, self.cache)
        self.cache = result.1
        result.0

    fn glyph_index_with_cache(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        var cache = initial_cache
        if not font_face_is_live(face_id, face_generation) or glyph_index < 0 or font_size <= 0 or font_size > 512:
            return (CachedGlyph(codepoint: -1, face_id: face_id, face_generation: face_generation, glyph_index: glyph_index, font_size: font_size, width: 0, height: 0, advance: 0, bearing_x: 0, bearing_y: 0, pixels: []), cache)
        val cached = cache.lookup_index(face_id, face_generation, glyph_index, font_size)
        if cached != nil:
            return (cached, cache)
        cache.record_rasterization()
        val glyph = rasterize_ttf_index(face_id, face_generation, glyph_index, font_size)
        val expected_pixels = glyph.width.to_i64() * glyph.height.to_i64()
        if glyph.advance > 0 and expected_pixels == glyph.pixels.len().to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me get_glyph_index(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32) -> CachedGlyph:
        val result = self.glyph_index_with_cache(face_id, face_generation, glyph_index, font_size, self.cache)
        self.cache = result.1
        result.0

    # -----------------------------------------------------------------------
    # Measure text width using actual glyph advances
    # -----------------------------------------------------------------------
    me measure_text_width(content: text, font_size: i32) -> i32:
        var total_w = 0
        var prev_cp = -1
        var cache = self.cache
        for ch in content:
            val cp = ch.char_code_at(0)
            if prev_cp >= 0:
                total_w = total_w + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            val glyph = result.0
            cache = result.1
            if glyph.advance > 0:
                total_w = total_w + glyph.advance
            else:
                # Fallback: approximate
                total_w = total_w + font_size * 55 / 100
            prev_cp = cp
        self.cache = cache
        total_w

    me measure_text_advances(content: text, font_size: i32) -> [i32]:
        var advances: [i32] = []
        var prev_cp = -1
        var cache = self.cache
        for ch in content:
            val cp = ch.char_code_at(0)
            if prev_cp >= 0:
                val previous = advances.len() - 1
                advances[previous] = advances[previous] + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            cache = result.1
            val glyph_advance = result.0.advance
            val advance = if glyph_advance > 0: glyph_advance else: font_size * 55 / 100
            advances.push(advance)
            prev_cp = cp
        self.cache = cache
        advances

    # -----------------------------------------------------------------------
    # Render text into a pixel buffer (ARGB u32)
    # -----------------------------------------------------------------------
    me render_text(buffer: [u32], buf_w: i32, buf_h: i32,
                   x: i32, y: i32, content: text,
                   color: u32, font_size: i32) -> [u32]:
        """Render text string into an ARGB pixel buffer with anti-aliased glyphs."""
        var out = buffer
        var cx = x
        var prev_cp = -1
        var cache = self.cache
        for ch in content:
            val cp = ch.char_code_at(0)
            if prev_cp >= 0:
                cx = cx + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            val glyph = result.0
            cache = result.1
            if glyph.width > 0 and glyph.height > 0:
                out = blit_glyph(out, buf_w, buf_h, cx, y, glyph, color)
            cx = cx + glyph.advance
            prev_cp = cp
        self.cache = cache
        out

    me render_text_payload(content: text, color: u32, font_size: i32) -> FontTextPayload:
        if font_size <= 0 or font_size > 512:
            return FontTextPayload(valid: false, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        if content == "":
            return FontTextPayload(valid: true, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        var layout = self.layout_text(content, font_size, 0)
        if layout.len() == 0 and (self.use_vector or self.use_bitmap):
            var fallback_x: i64 = 0
            var fallback_byte_offset: i64 = 0
            for ch in content:
                val codepoint = ch.char_code_at(0)
                val glyph = self.get_glyph(codepoint, font_size)
                layout.push(LayoutGlyph(
                    codepoint: codepoint.to_i64(), x: fallback_x, y: 0,
                    width: glyph.width.to_i64(), height: glyph.height.to_i64(),
                    byte_offset: fallback_byte_offset
                ))
                fallback_x = fallback_x + glyph.advance.to_i64()
                fallback_byte_offset = fallback_byte_offset + ch.len().to_i64()
        if layout.len() == 0:
            return FontTextPayload(valid: false, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        var glyphs: [CachedGlyph] = []
        var min_x = 2147483647
        var min_y = 2147483647
        var max_x = -2147483647
        var max_y = -2147483647
        var cache = self.cache
        var i = 0
        while i < layout.len():
            val positioned = layout[i]
            val result = self.glyph_with_cache(positioned.codepoint.to_i32(), font_size, cache)
            val glyph = result.0
            cache = result.1
            glyphs.push(glyph)
            if glyph.width > 0 and glyph.height > 0:
                val gx = positioned.x.to_i32()
                val gy = positioned.y.to_i32()
                if gx < min_x:
                    min_x = gx
                if gy < min_y:
                    min_y = gy
                if gx + glyph.width > max_x:
                    max_x = gx + glyph.width
                if gy + glyph.height > max_y:
                    max_y = gy + glyph.height
            i = i + 1
        self.cache = cache
        if max_x <= min_x or max_y <= min_y:
            return FontTextPayload(valid: true, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        val width = max_x - min_x
        val height = max_y - min_y
        var pixels: [u32] = [0u32; width * height]
        val rgb = color & 0x00FFFFFFu32
        val color_alpha = ((color >> 24) & 0xFF).to_i32()
        i = 0
        while i < layout.len():
            val positioned = layout[i]
            val glyph = glyphs[i]
            val dst_x = positioned.x.to_i32() - min_x
            val dst_y = positioned.y.to_i32() - min_y
            var row = 0
            while row < glyph.height:
                var col = 0
                while col < glyph.width:
                    val src_idx = row * glyph.width + col
                    if src_idx < glyph.pixels.len():
                        val src_a = glyph.pixels[src_idx].to_i32() * color_alpha / 255
                        if src_a > 0:
                            val dst_idx = (dst_y + row) * width + dst_x + col
                            if dst_idx >= 0 and dst_idx < pixels.len():
                                val dst_a = ((pixels[dst_idx] >> 24) & 0xFF).to_i32()
                                val out_a = src_a + dst_a * (255 - src_a) / 255
                                pixels[dst_idx] = (out_a.to_u32() << 24) | rgb
                    col = col + 1
                row = row + 1
            i = i + 1
        FontTextPayload(valid: true, width: width, height: height, offset_x: min_x, offset_y: min_y, pixels: pixels)

    me _reset_font_atlas(face_generation: i64, font_identity: text):
        self.atlas_pixels = [0u32; FONT_ATLAS_WIDTH * FONT_ATLAS_HEIGHT]
        self.atlas_codepoints = []
        self.atlas_face_ids = []
        self.atlas_face_generations = []
        self.atlas_glyph_indices = []
        self.atlas_font_sizes = []
        self.atlas_xs = []
        self.atlas_ys = []
        self.atlas_widths = []
        self.atlas_heights = []
        self.atlas_cursor_x = 0
        self.atlas_cursor_y = 0
        self.atlas_row_height = 0
        self.atlas_generation = _next_font_atlas_dependency_generation()
        self.atlas_face_generation = face_generation
        self.atlas_font_identity = font_identity

    fn _font_atlas_dependency_identity(face_id: i64, face_generation: i64) -> text:
        var identities: [text] = []
        var i = 0
        while i < self.atlas_face_ids.len():
            val identity = font_face_identity(self.atlas_face_ids[i], self.atlas_face_generations[i])
            if identity == "": return ""
            if not identities.contains(identity): identities.push(identity)
            i = i + 1
        val pending = font_face_identity(face_id, face_generation)
        if pending == "": return ""
        if not identities.contains(pending): identities.push(pending)
        if identities.len() == 1: return identities[0]
        var combined = "font-faces-v1"
        for identity in identities:
            combined = combined + "|" + identity.len().to_string() + ":" + identity
        combined

    fn _font_atlas_entry_index(face_id: i64, face_generation: i64, glyph_index: i32, codepoint: i32, font_size: i32) -> i32:
        # ponytail: bounded linear lookup; replace with a map only if 512-entry profiles require it.
        var i = 0
        while i < self.atlas_codepoints.len():
            if (self.atlas_face_ids[i] == face_id and
                self.atlas_face_generations[i] == face_generation and
                self.atlas_glyph_indices[i] == glyph_index and
                self.atlas_codepoints[i] == codepoint and
                self.atlas_font_sizes[i] == font_size):
                return i
            i = i + 1
        -1

    me _insert_font_atlas_glyph(glyph: CachedGlyph) -> i32:
        if glyph.width <= 0 or glyph.height <= 0 or glyph.width > FONT_ATLAS_WIDTH or glyph.height > FONT_ATLAS_HEIGHT:
            return -1
        if glyph.pixels.len() != glyph.width.to_i64() * glyph.height.to_i64():
            return -1
        val padded_width = glyph.width + 1
        val padded_height = glyph.height + 1
        var x = self.atlas_cursor_x
        var y = self.atlas_cursor_y
        var row_height = self.atlas_row_height
        if x + padded_width > FONT_ATLAS_WIDTH:
            x = 0
            y = y + row_height
            row_height = 0
        if y + padded_height > FONT_ATLAS_HEIGHT:
            return -1
        var row = 0
        while row < glyph.height:
            var col = 0
            while col < glyph.width:
                val alpha = glyph.pixels[row * glyph.width + col].to_u32()
                self.atlas_pixels[(y + row) * FONT_ATLAS_WIDTH + x + col] = (alpha << 24) | 0x00FFFFFFu32
                col = col + 1
            row = row + 1
        self.atlas_codepoints.push(glyph.codepoint)
        self.atlas_face_ids.push(glyph.face_id)
        self.atlas_face_generations.push(glyph.face_generation)
        self.atlas_glyph_indices.push(glyph.glyph_index)
        self.atlas_font_sizes.push(glyph.font_size)
        self.atlas_xs.push(x)
        self.atlas_ys.push(y)
        self.atlas_widths.push(glyph.width)
        self.atlas_heights.push(glyph.height)
        self.atlas_cursor_x = x + padded_width
        self.atlas_cursor_y = y
        self.atlas_row_height = if padded_height > row_height: padded_height else: row_height
        (self.atlas_codepoints.len() - 1).to_i32()

    me prepare_text(content: text, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_text_configured(content, color, font_render_config_default_for_size(font_size))

    me prepare_text_configured(content: text, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(self._prepare_text_active(content, color, config.size), config)

    me _prepare_text_active(content: text, color: u32, font_size: i32) -> FontRenderBatch:
        val cache_stats = self.cache.stats()
        var face_generation = cache_stats.generation
        var font_identity = cache_stats.font_identity
        val active_rasterizer = self.ttf_rasterizer
        if active_rasterizer != nil:
            val identity_snapshot = active_rasterizer.cache_identity_snapshot()
            face_generation = identity_snapshot.0
            font_identity = identity_snapshot.1
        if font_size <= 0 or font_size > 512:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if content == "":
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if self.atlas_face_generation != face_generation or self.atlas_font_identity != font_identity:
            self._reset_font_atlas(face_generation, font_identity)
        var layout = self.layout_text(content, font_size, 0)
        if layout.len() == 0 and (self.use_vector or self.use_bitmap):
            var fallback_x: i64 = 0
            var fallback_byte_offset: i64 = 0
            for ch in content:
                val codepoint = ch.char_code_at(0)
                val glyph = self.get_glyph(codepoint, font_size)
                layout.push(LayoutGlyph(
                    codepoint: codepoint.to_i64(), x: fallback_x, y: 0,
                    width: glyph.width.to_i64(), height: glyph.height.to_i64(),
                    byte_offset: fallback_byte_offset
                ))
                fallback_x = fallback_x + glyph.advance.to_i64()
                fallback_byte_offset = fallback_byte_offset + ch.len().to_i64()
        if layout.len() == 0:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i = 0
            while i < layout.len():
                val positioned = layout[i]
                val glyph = self.get_glyph(positioned.codepoint.to_i32(), font_size)
                if glyph.width > 0 and glyph.height > 0:
                    var atlas_index = self._font_atlas_entry_index(glyph.face_id, glyph.face_generation, glyph.glyph_index, glyph.codepoint, font_size)
                    var inserted = false
                    if atlas_index < 0:
                        atlas_index = self._insert_font_atlas_glyph(glyph)
                        inserted = atlas_index >= 0
                    if atlas_index < 0:
                        overflow = true
                    else:
                        val quad = FontRenderQuad(
                            codepoint: glyph.codepoint,
                            byte_offset: positioned.byte_offset,
                            dst_x: positioned.x.to_i32(), dst_y: positioned.y.to_i32(),
                            width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                            atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                            color: color
                        )
                        quads.push(quad)
                        if inserted:
                            dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val generation = _next_font_atlas_dependency_generation()
                    if generation == 0:
                        self._reset_font_atlas(face_generation, font_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = generation
                if quads.len() > 0:
                    val end_cache_stats = self.cache.stats()
                    var end_generation = end_cache_stats.generation
                    var end_identity = end_cache_stats.font_identity
                    if active_rasterizer != nil:
                        val end_snapshot = active_rasterizer.cache_identity_snapshot()
                        end_generation = end_snapshot.0
                        end_identity = end_snapshot.1
                    if end_generation != face_generation or end_identity != font_identity:
                        self._reset_font_atlas(end_generation, end_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: end_identity, face_generation: end_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: [], quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(face_generation, font_identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

    me prepare_text_with_advances(content: text, advance_widths: [i32], color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_text_with_advances_configured(
            content, advance_widths, color, font_render_config_default_for_size(font_size)
        )

    me prepare_text_with_advances_configured(content: text, advance_widths: [i32], color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        val natural_advances = self.measure_text_advances(content, config.size)
        _font_render_batch_with_config(
            font_batch_apply_advances(content, natural_advances, advance_widths,
                self._prepare_text_active(content, color, config.size)), config
        )

    fn _selected_glyph_index_with_cache(rasterizer: FontRasterizer, generation: i64, glyph_index: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        var cache = initial_cache
        val cached = cache.lookup_index(0, generation, glyph_index, font_size)
        if cached != nil:
            return (cached.?, cache)
        cache.record_rasterization()
        val bitmap = rasterizer.rasterize_glyph_index(glyph_index.to_i64(), font_size.to_i64())
        if bitmap == nil:
            return (CachedGlyph(codepoint: -1, face_id: 0, face_generation: generation,
                glyph_index: glyph_index, font_size: font_size, width: 0, height: 0,
                advance: 0, bearing_x: 0, bearing_y: 0, pixels: []), cache)
        val owned = bitmap.?
        val glyph = CachedGlyph(codepoint: -1, face_id: 0, face_generation: generation,
            glyph_index: glyph_index, font_size: font_size,
            width: owned.width.to_i32(), height: owned.height.to_i32(),
            advance: owned.advance.to_i32(), bearing_x: owned.bearing_x.to_i32(),
            bearing_y: owned.bearing_y.to_i32(), pixels: owned.pixels)
        if glyph.width > 0 and glyph.height > 0 and glyph.pixels.len() == glyph.width.to_i64() * glyph.height.to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me prepare_selected_glyph_run(payload: DrawIrGlyphRunPayload, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_selected_glyph_run_configured(
            payload, color, font_render_config_default_for_size(font_size)
        )

    me prepare_selected_glyph_run_configured(payload: DrawIrGlyphRunPayload, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(
            self._prepare_selected_glyph_run_active(payload, color, config.size), config
        )

    me _prepare_selected_glyph_run_active(payload: DrawIrGlyphRunPayload, color: u32, font_size: i32) -> FontRenderBatch:
        val active = self.ttf_rasterizer
        if active == nil:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: "", face_generation: 0, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        val rasterizer = active.?
        val snapshot = rasterizer.cache_identity_snapshot()
        val generation = snapshot.0
        val identity = snapshot.1
        val lengths_match = payload.glyph_ids.len() == payload.xs.len() and payload.glyph_ids.len() == payload.ys.len() and payload.glyph_ids.len() == payload.clusters.len()
        if (not payload.valid or not lengths_match or payload.glyph_ids.len() == 0 or
            generation <= 0 or identity == "" or font_size <= 0 or font_size > 512):
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var cache = self.cache
        cache.sync_face_identity(generation, identity)
        self.cache = cache
        if self.atlas_face_generation != generation or self.atlas_font_identity != identity:
            self._reset_font_atlas(generation, identity)
        val ascent = self.horizontal_line_metric(font_size, 0)
        if ascent <= 0:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i: i64 = 0
            while i < payload.glyph_ids.len():
                val raw_gid = payload.glyph_ids[i]
                if raw_gid == 0u32 or raw_gid > 2147483647u32 or payload.clusters[i] < 0:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                val glyph_id = raw_gid.to_i32()
                val selected = self._selected_glyph_index_with_cache(rasterizer, generation, glyph_id, font_size, self.cache)
                val glyph = selected.0
                self.cache = selected.1
                if glyph.width <= 0 or glyph.height <= 0:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                var atlas_index = self._font_atlas_entry_index(0, generation, glyph_id, -1, font_size)
                var inserted = false
                if atlas_index < 0:
                    atlas_index = self._insert_font_atlas_glyph(glyph)
                    inserted = atlas_index >= 0
                if atlas_index < 0:
                    overflow = true
                else:
                    val destination = _font_shaped_glyph_destination(payload.xs[i], payload.ys[i], glyph, ascent)
                    if not destination.0:
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                    val quad = FontRenderQuad(codepoint: -1, byte_offset: -1,
                        dst_x: destination.1, dst_y: destination.2,
                        width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                        atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                        color: color, cluster: payload.clusters[i])
                    quads.push(quad)
                    if inserted: dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val dependency_generation = _next_font_atlas_dependency_generation()
                    if dependency_generation == 0:
                        self._reset_font_atlas(generation, identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = dependency_generation
                val after = rasterizer.cache_identity_snapshot()
                if after.0 != generation or after.1 != identity:
                    self._reset_font_atlas(after.0, after.1)
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: after.1, face_generation: after.0, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: [], quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(generation, identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

    me prepare_glyph_run(run: FontGlyphRun, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_glyph_run_configured(run, color, font_render_config_default_for_size(font_size))

    me prepare_glyph_run_configured(run: FontGlyphRun, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._render_config_matches_run(config, run):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(self._prepare_glyph_run_active(run, color, config.size), config)

    me _prepare_glyph_run_active(run: FontGlyphRun, color: u32, font_size: i32) -> FontRenderBatch:
        val face_id = run.face_id
        var font_identity = font_face_identity(face_id, run.face_generation)
        val face_generation = run.face_generation
        var cluster_index: i64 = 0
        while cluster_index < run.clusters.len():
            if run.clusters[cluster_index] < 0:
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
            cluster_index = cluster_index + 1
        if (not run.valid or font_identity == "" or not font_face_is_live(face_id, run.face_generation) or
            font_size <= 0 or font_size > 512 or
            run.glyph_ids.len() != run.xs.len() or run.glyph_ids.len() != run.ys.len() or
            run.glyph_ids.len() != run.clusters.len()):
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if self.atlas_face_generation != -2:
            self._reset_font_atlas(-2, font_identity)
        else:
            val dependencies = self._font_atlas_dependency_identity(face_id, run.face_generation)
            if dependencies == "":
                self._reset_font_atlas(-2, font_identity)
            else:
                font_identity = dependencies
                self.atlas_font_identity = dependencies
        val ascent = font_face_ascent(face_id, run.face_generation, font_size)
        if ascent <= 0:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i = 0
            while i < run.glyph_ids.len():
                val raw_gid = run.glyph_ids[i]
                if raw_gid > 2147483647u32:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                val glyph_id = raw_gid.to_i32()
                val glyph = self.get_glyph_index(face_id, run.face_generation, glyph_id, font_size)
                if glyph.width > 0 and glyph.height > 0:
                    var atlas_index = self._font_atlas_entry_index(face_id, run.face_generation, glyph_id, -1, font_size)
                    var inserted = false
                    if atlas_index < 0:
                        atlas_index = self._insert_font_atlas_glyph(glyph)
                        inserted = atlas_index >= 0
                    if atlas_index < 0:
                        overflow = true
                    else:
                        val destination = _font_shaped_glyph_destination(run.xs[i], run.ys[i], glyph, ascent)
                        if not destination.0:
                            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                        val quad = FontRenderQuad(
                            codepoint: -1, byte_offset: -1, cluster: run.clusters[i],
                            dst_x: destination.1, dst_y: destination.2,
                            width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                            atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                            color: color
                        )
                        quads.push(quad)
                        if inserted:
                            dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val generation = _next_font_atlas_dependency_generation()
                    if generation == 0:
                        self._reset_font_atlas(-2, font_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = generation
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(-2, font_identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

class _ResolvedShapedGlyphRun:
    valid: bool
    payload: DrawIrGlyphRunPayload
    advances: [i32]
    width: i32

fn _resolved_font_language(language: text) -> text:
    # Split the trim/lower/split chain: the seed compiler cannot resolve
    # `.split(...)` on the erased receiver produced by `.trim().lower()`
    # in this nested position (erased-receiver method-resolution gap,
    # see bug web_font_provider_split_nested_call_resolution_2026-07-14).
    val normalized: text = language.trim().lower()
    val parts = normalized.split("-")
    if parts.len() == 0 or parts[0] == "":
        return "und"
    parts[0]

fn _resolved_font_complex_script(codepoints: [i64]) -> i32:
    var complex_script = 0
    for codepoint in codepoints:
        val script = script_of(codepoint as u32)
        val next = if script == Script.Arabic: 1 else if script == Script.Devanagari: 2 else: 0
        if next != 0:
            if complex_script != 0 and complex_script != next:
                return 3
            complex_script = next
    complex_script

fn _resolved_font_category(family: text) -> text:
    val normalized = family.trim().lower()
    for candidate in selected_font_asset_candidates():
        if candidate.family.lower() == normalized:
            return candidate.category
    if (normalized.contains("mono") or normalized.contains("courier") or
        normalized.contains("code") or normalized.contains("console")):
        return "mono"
    if normalized.contains("sans") or normalized.contains("arial") or normalized.contains("helvetica"):
        return "sans"
    if normalized.contains("serif") or normalized.contains("times") or normalized.contains("georgia"):
        return "serif"
    ""

fn _resolved_font_empty_shaped() -> _ResolvedShapedGlyphRun:
    _ResolvedShapedGlyphRun(valid: false, payload: draw_ir_empty_glyph_run_payload(), advances: [], width: 0)

# Producer-only shaping. The transient face is released before this semantic
# result leaves the resolver; Draw IR never owns a face handle or atlas data.
fn _resolve_selected_shaped_glyph_run(candidate: FontAssetCandidate, content: text, font_size: i32, language: text) -> _ResolvedShapedGlyphRun:
    if not selected_font_simple_tuple_accepted(candidate.family, language):
        return _resolved_font_empty_shaped()
    if font_renderer_registered_selected_bytes_only():
        return _resolved_font_empty_shaped()
    val decoded = text_codepoints(content)
    if decoded.len() == 0:
        return _resolved_font_empty_shaped()
    var codepoints: [u32] = []
    for codepoint in decoded:
        if codepoint < 0 or codepoint > 1114111:
            return _resolved_font_empty_shaped()
        codepoints.push(codepoint as u32)
    val font_path = selected_font_asset_physical_path(candidate.local_path)
    val parsed = parse_offset_table(file_read_bytes(font_path))
    if parsed == nil:
        return _resolved_font_empty_shaped()
    val loaded = load_font(font_path)
    if loaded == nil:
        return _resolved_font_empty_shaped()
    val face = loaded.?
    val font = sk_font_new(sk_typeface_from_attached_font(candidate.family, sk_font_style_normal(), font_path, face.handle), font_size.to_f64())
    val shaper = shaper_with_ot_face(shaper_new(fallback_chain_new(font)), face.handle, parsed.?)
    val runs = shaper_shape_with_language(shaper, codepoints, font, 0.0, 0.0, language)
    var glyph_ids: [u32] = []
    var xs: [i32] = []
    var ys: [i32] = []
    var clusters: [i64] = []
    var advances: [i32] = [0; codepoints.len()]
    var total_advance = 0.0
    var valid = runs.len() > 0
    for run in runs:
        val material = shaped_run_to_font_glyph_run(run)
        if not material.valid or material.face_id != face.handle or material.face_generation != face.generation:
            valid = false
        var i: i64 = 0
        while i < material.glyph_ids.len() and i < run.glyphs.len():
            glyph_ids.push(material.glyph_ids[i])
            xs.push(material.xs[i])
            ys.push(material.ys[i])
            clusters.push(material.clusters[i])
            val cluster = material.clusters[i]
            val before = total_advance.to_i32()
            total_advance = total_advance + run.glyphs[i].x_advance
            val after = total_advance.to_i32()
            if cluster < 0 or cluster >= advances.len():
                valid = false
            else:
                advances[cluster] = advances[cluster] + after - before
            i = i + 1
        if i != material.glyph_ids.len() or i != run.glyphs.len():
            valid = false
    free_font(face)
    val width = total_advance.to_i32()
    val payload = draw_ir_glyph_run_payload(glyph_ids, xs, ys, clusters, valid and width >= 0)
    _ResolvedShapedGlyphRun(valid: payload.valid, payload: payload, advances: if payload.valid: advances else: [], width: if payload.valid: width else: 0)

fn _resolve_font_metrics_with_language_config(family: text, content: text, font_size: i32,
                                              language: text, render_config_identity: text) -> ResolvedFontMetrics:
    if family.trim() == "" or font_size <= 0 or font_size > 512:
        return ResolvedFontMetrics(valid: false, family: family, identity: "", advances: [], width: 0, line_height: 0, reason: "invalid-font-request", glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    val normalized_language = _resolved_font_language(language)
    val codepoints = text_codepoints(content)
    val complex_script = _resolved_font_complex_script(codepoints)
    val category = _resolved_font_category(family)
    val selected_candidate = if normalized_language != "und" and category != "":
        selected_font_asset_for_language_category(normalized_language, category)
    else:
        nil
    val resolved_family = if selected_candidate != nil: selected_candidate.?.family else: family
    val cacheable = _resolved_font_metrics_cacheable(resolved_family, content)
    val expected_identity = if selected_candidate != nil: selected_font_asset_identity(selected_candidate.?) else: ""
    if cacheable and expected_identity != "":
        val expected_key = _resolved_font_metric_language_config_key(
            resolved_family, content, font_size, expected_identity, normalized_language, render_config_identity
        )
        if val cached = _resolved_font_metric_cached(expected_key):
            return cached
    # Shape first: the producer's short-lived font_sffi face must be gone before
    # the executor-facing selected rasterizer snapshots its identity/generation.
    val shaped = if complex_script != 0 and selected_candidate != nil:
        _resolve_selected_shaped_glyph_run(selected_candidate.?, content, font_size, normalized_language)
    else:
        _resolved_font_empty_shaped()
    val default_font = _browser_default_for_family_cached(resolved_family)
    var renderer = default_font.0
    val renderer_from_cache = default_font.1
    if not renderer.has_sffi_ttf():
        return ResolvedFontMetrics(valid: false, family: resolved_family, identity: "", advances: [], width: 0, line_height: 0, reason: "font-runtime-unavailable", glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: complex_script != 0)
    val identity = renderer.current_font_identity()
    val cache_key = if cacheable:
        _resolved_font_metric_language_config_key(
            resolved_family, content, font_size, identity, normalized_language, render_config_identity
        )
    else:
        ""
    if cacheable:
        if val cached = _resolved_font_metric_cached(cache_key):
            if not renderer_from_cache:
                renderer.clear_ttf()
            return cached
    val advances = if shaped.valid: shaped.advances else: renderer.measure_text_advances(content, font_size)
    var width = 0
    if shaped.valid:
        width = shaped.width
    else:
        for advance in advances:
            width = width + advance
    var line_height = renderer.horizontal_line_metric(font_size, 3)
    if line_height <= 0:
        line_height = font_size
    if not renderer_from_cache:
        renderer.clear_ttf()
    var character_count = 0
    for ch in content:
        character_count = character_count + 1
    val valid = identity != "" and advances.len() == character_count
    val resolved = ResolvedFontMetrics(
        valid: valid,
        family: resolved_family,
        identity: identity,
        advances: if valid: advances else: [],
        width: if valid: width else: 0,
        line_height: if valid: line_height else: 0,
        reason: if valid and (complex_script == 0 or shaped.valid): "resolved" else if valid: "font-shaping-unavailable" else: "font-identity-unavailable",
        glyph_run: shaped.payload,
        shaping_required: complex_script != 0
    )
    if resolved.valid and cacheable:
        _resolved_font_metric_store(cache_key, resolved)
    resolved

fn resolve_font_metrics_with_language(family: text, content: text, font_size: i32, language: text) -> ResolvedFontMetrics:
    val config = font_render_config_default_for_size(font_size)
    val config_identity = config.identity()
    val resolved = _resolve_font_metrics_with_language_config(family, content, font_size, language, config_identity)
    resolved

fn resolve_font_metrics_configured(config: FontRenderConfig, content: text) -> ResolvedFontMetrics:
    if not config.valid():
        return ResolvedFontMetrics(valid: false, family: config.family, identity: "", advances: [],
            width: 0, line_height: 0, reason: "invalid-font-config",
            glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    if _font_render_config_default_selection(config):
        return _resolve_font_metrics_with_language_config(
            "sans", content, config.size, config.language, config.identity()
        )
    val selected = _font_render_config_candidate(config)
    if selected == nil:
        return ResolvedFontMetrics(valid: false, family: config.family, identity: "", advances: [],
            width: 0, line_height: 0, reason: "font-config-unavailable",
            glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    _resolve_font_metrics_with_language_config(
        selected.?.family, content, config.size, config.language, config.identity()
    )

# Compatibility entry point for producers without language metadata.
fn resolve_font_metrics(family: text, content: text, font_size: i32) -> ResolvedFontMetrics:
    resolve_font_metrics_with_language(family, content, font_size, "und")
