    me prepare_text(content: text, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_text_configured(content, color, font_render_config_default_for_size(font_size))

    me prepare_text_configured(content: text, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(self._prepare_text_active(content, color, config.size), config)

    me _prepare_text_active(content: text, color: u32, font_size: i32) -> FontRenderBatch:
        val cache_stats = self.cache.stats()
        var face_generation = cache_stats.generation
        var font_identity = cache_stats.font_identity
        val active_rasterizer = self.ttf_rasterizer
        if active_rasterizer != nil:
            val identity_snapshot = active_rasterizer.cache_identity_snapshot()
            face_generation = identity_snapshot.0
            font_identity = identity_snapshot.1
        if font_size <= 0 or font_size > 512:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if content == "":
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if self.atlas_face_generation != face_generation or self.atlas_font_identity != font_identity:
            self._reset_font_atlas(face_generation, font_identity)
        var layout = self.layout_text(content, font_size, 0)
        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
            print("[vec-glyph-probe] active-after-layout_text layout_len={layout.len()} use_vector={self.use_vector} use_bitmap={self.use_bitmap} content_len={content.len()}")
        if layout.len() == 0 and (self.use_vector or self.use_bitmap):
            var fallback_x: i64 = 0
            var fallback_byte_offset: i64 = 0
            # GLYPH-FIX-3 (2026-07-19): NOT a fix -- diagnostic only. An
            # earlier attempt here read `content.bytes()[offset]` in place of
            # `ch.char_code_at(0)`, hoping to route around a suspected
            # char_code_at bug (cp printed as 0 for a command that can't
            # legitimately be U+0000). That "fix" is retracted: the raw byte
            # read back 11 while `glyph_with_cache` further downstream showed
            # the SAME logical value as 88 (11 << 3) -- i.e. char_code_at's 0
            # (88 & 7), bytes()'s 11 (88 >> 3), and 88 itself are three
            # tag-shifted views of one pervasive integer-boxing codegen
            # defect (matches the campaign's documented "BoxInt <<3 mangles
            # values through ANY/boxed channels" landmine), not independently
            # correct/incorrect reads. Patching this call site further would
            # only be choosing which shifted view happens to cancel out
            # downstream -- not a real fix. See doc/08_tracking/bug/ for the
            # writeup; the crash proven live in this function is unrelated to
            # this codepoint value (get_glyph returns a valid glyph either
            # way) and is timeboxed via the probes immediately below instead.
            # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
            var ci = 0
            val content_len = content.len()
            while ci < content_len:
                val codepoint = content.char_code_at(ci)
                if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                    _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                    print("[vec-glyph-probe] active-before-get_glyph cp={codepoint} font_size={font_size}")
                val glyph = self.get_glyph(codepoint, font_size)
                if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                    _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                    print("[vec-glyph-probe] active-after-get_glyph cp={codepoint} w={glyph.width} h={glyph.height} adv={glyph.advance} pixels_len={glyph.pixels.len()}")
                layout.push(LayoutGlyph(
                    codepoint: codepoint.to_i64(), x: fallback_x, y: 0,
                    width: glyph.width.to_i64(), height: glyph.height.to_i64(),
                    byte_offset: fallback_byte_offset
                ))
