            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i = 0
            while i < layout.len():
                val positioned = layout[i]
                val glyph = self.get_glyph(positioned.codepoint.to_i32(), font_size)
                if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                    _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                    print("[vec-glyph-probe] quadloop-after-reget i={i} cp={positioned.codepoint} w={glyph.width} h={glyph.height} face_id={glyph.face_id} face_gen={glyph.face_generation} glyph_index={glyph.glyph_index}")
                if glyph.width > 0 and glyph.height > 0:
                    var atlas_index = self._font_atlas_entry_index(glyph.face_id, glyph.face_generation, glyph.glyph_index, glyph.codepoint, font_size)
                    if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                        _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                        print("[vec-glyph-probe] quadloop-after-entry_index i={i} atlas_index={atlas_index}")
                    var inserted = false
                    if atlas_index < 0:
                        atlas_index = self._insert_font_atlas_glyph(glyph)
                        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                            print("[vec-glyph-probe] quadloop-after-insert i={i} atlas_index={atlas_index}")
                        inserted = atlas_index >= 0
                    if atlas_index < 0:
                        overflow = true
                    else:
                        val quad = FontRenderQuad(
                            codepoint: glyph.codepoint,
                            byte_offset: positioned.byte_offset,
                            dst_x: positioned.x.to_i32(), dst_y: positioned.y.to_i32(),
                            width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                            atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                            color: color
                        )
                        quads.push(quad)
                        if inserted:
                            dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val generation = _next_font_atlas_dependency_generation()
                    if generation == 0:
                        self._reset_font_atlas(face_generation, font_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = generation
                if quads.len() > 0:
                    val end_cache_stats = self.cache.stats()
                    var end_generation = end_cache_stats.generation
                    var end_identity = end_cache_stats.font_identity
                    if active_rasterizer != nil:
                        val end_snapshot = active_rasterizer.cache_identity_snapshot()
                        end_generation = end_snapshot.0
                        end_identity = end_snapshot.1
                    if end_generation != face_generation or end_identity != font_identity:
                        if _VEC_ATLAS_PROBE and _vec_atlas_probe_count < 8:
                            _vec_atlas_probe_count = _vec_atlas_probe_count + 1
                            print("[vec-atlas-probe] producer identity-mismatch-reset end_gen={end_generation} face_gen={face_generation} end_id_len={end_identity.len()} font_id_len={font_identity.len()}")
                        self._reset_font_atlas(end_generation, end_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: end_identity, face_generation: end_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: [], quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                if _VEC_ATLAS_PROBE and _vec_atlas_probe_count < 8:
                    _vec_atlas_probe_count = _vec_atlas_probe_count + 1
                    # GLYPH-FIX-5 (2026-07-19): ROOT CAUSE of the residual
                    # boot-time "field access on nil receiver" fault. This
                    # probe block is a SIBLING of `if quads.len() > 0:`
                    # above (same indent), not nested inside it, so `quads[0]`
                    # ran unconditionally whenever the probe budget allowed --
                    # including when `quads` is empty (every glyph in this
                    # run was degenerate/advance-only, e.g. no rasterized
                    # face). Empty-array index returns the nil sentinel;
                    # the very next field read (`fq.height`) is exactly the
                    # native "field access on nil receiver" panic seen at
                    # `_prepare_text_active`+0x360e. Guard on `quads.len()`
                    # so the probe never dereferences past an empty array,
                    # and log the empty case too so the len/overflow signal
                    # isn't lost (log retention: convert, don't delete).
                    if quads.len() > 0:
                        val fq = quads[0]
                        var nz = 0
                        var row = 0
                        while row < fq.height:
                            var col = 0
                            while col < fq.width:
                                val idx = (fq.atlas_y + row) * FONT_ATLAS_WIDTH + fq.atlas_x + col
                                if idx.to_i64() >= 0 and idx.to_i64() < self.atlas_pixels.len():
