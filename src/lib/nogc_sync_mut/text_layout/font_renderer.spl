                    else:
                        print("[vec-atlas-probe] producer-empty n_quads=0 overflow={overflow} content_len={content.len()}")
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(face_generation, font_identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

    me prepare_text_with_advances(content: text, advance_widths: [i32], color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_text_with_advances_configured(
            content, advance_widths, color, font_render_config_default_for_size(font_size)
        )

    me prepare_text_with_advances_configured(content: text, advance_widths: [i32], color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        val natural_advances = self.measure_text_advances(content, config.size)
        _font_render_batch_with_config(
            font_batch_apply_advances(content, natural_advances, advance_widths,
                self._prepare_text_active(content, color, config.size)), config
        )

    fn _selected_glyph_index_with_cache(rasterizer: FontRasterizer, generation: i64, glyph_index: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        var cache = initial_cache
        val cached = cache.lookup_index(0, generation, glyph_index, font_size)
        if cached != nil:
            return (cached.?, cache)
        cache.record_rasterization()
        val bitmap = rasterizer.rasterize_glyph_index(glyph_index.to_i64(), font_size.to_i64())
        if bitmap == nil:
            return (CachedGlyph(codepoint: -1, face_id: 0, face_generation: generation,
                glyph_index: glyph_index, font_size: font_size, width: 0, height: 0,
                advance: 0, bearing_x: 0, bearing_y: 0, pixels: []), cache)
        val owned = bitmap.?
        # `owned` is a GlyphBitmap crossing a module boundary (declared in
        # spl_fonts.spl); use its `gbm_*`-prefixed fields, not the ambiguous
        # `width`/`height`/`advance`/`bearing_x`/`bearing_y`/`pixels` names —
        # see the GlyphBitmap class doc comment (cross-module ambiguous-field
        # "most fields wins" mis-resolution).
        val glyph = CachedGlyph(codepoint: -1, face_id: 0, face_generation: generation,
            glyph_index: glyph_index, font_size: font_size,
            width: owned.gbm_width.to_i32(), height: owned.gbm_height.to_i32(),
            advance: owned.gbm_advance.to_i32(), bearing_x: owned.gbm_bearing_x.to_i32(),
            bearing_y: owned.gbm_bearing_y.to_i32(), pixels: owned.gbm_pixels)
        if glyph.width > 0 and glyph.height > 0 and glyph.pixels.len() == glyph.width.to_i64() * glyph.height.to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me prepare_selected_glyph_run(payload: DrawIrGlyphRunPayload, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_selected_glyph_run_configured(
            payload, color, font_render_config_default_for_size(font_size)
        )

    me prepare_selected_glyph_run_configured(payload: DrawIrGlyphRunPayload, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._ensure_render_config_face(config):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(
            self._prepare_selected_glyph_run_active(payload, color, config.size), config
        )

    me _prepare_selected_glyph_run_active(payload: DrawIrGlyphRunPayload, color: u32, font_size: i32) -> FontRenderBatch:
        val active = self.ttf_rasterizer
        if active == nil:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: "", face_generation: 0, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        val rasterizer = active.?
        val snapshot = rasterizer.cache_identity_snapshot()
        val generation = snapshot.0
        val identity = snapshot.1
        val lengths_match = payload.glyph_ids.len() == payload.xs.len() and payload.glyph_ids.len() == payload.ys.len() and payload.glyph_ids.len() == payload.clusters.len()
        if (not payload.valid or not lengths_match or payload.glyph_ids.len() == 0 or
            generation <= 0 or identity == "" or font_size <= 0 or font_size > 512):
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var cache = self.cache
        cache.sync_face_identity(generation, identity)
        self.cache = cache
        if self.atlas_face_generation != generation or self.atlas_font_identity != identity:
            self._reset_font_atlas(generation, identity)
        val ascent = self.horizontal_line_metric(font_size, 0)
        if ascent <= 0:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i: i64 = 0
            while i < payload.glyph_ids.len():
                val raw_gid = payload.glyph_ids[i]
                if raw_gid == 0u32 or raw_gid > 2147483647u32 or payload.clusters[i] < 0:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                val glyph_id = raw_gid.to_i32()
                val selected = self._selected_glyph_index_with_cache(rasterizer, generation, glyph_id, font_size, self.cache)
                val glyph = selected.0
                self.cache = selected.1
                if glyph.width <= 0 or glyph.height <= 0:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                var atlas_index = self._font_atlas_entry_index(0, generation, glyph_id, -1, font_size)
                var inserted = false
                if atlas_index < 0:
                    atlas_index = self._insert_font_atlas_glyph(glyph)
                    inserted = atlas_index >= 0
                if atlas_index < 0:
                    overflow = true
                else:
                    val destination = _font_shaped_glyph_destination(payload.xs[i], payload.ys[i], glyph, ascent)
                    if not destination.0:
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                    val quad = FontRenderQuad(codepoint: -1, byte_offset: -1,
                        dst_x: destination.1, dst_y: destination.2,
                        width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                        atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                        color: color, cluster: payload.clusters[i])
                    quads.push(quad)
                    if inserted: dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val dependency_generation = _next_font_atlas_dependency_generation()
                    if dependency_generation == 0:
                        self._reset_font_atlas(generation, identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = dependency_generation
                val after = rasterizer.cache_identity_snapshot()
                if after.0 != generation or after.1 != identity:
                    self._reset_font_atlas(after.0, after.1)
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: after.1, face_generation: after.0, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: [], quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(generation, identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: identity, face_generation: generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

    me prepare_glyph_run(run: FontGlyphRun, color: u32, font_size: i32) -> FontRenderBatch:
        self.prepare_glyph_run_configured(run, color, font_render_config_default_for_size(font_size))

    me prepare_glyph_run_configured(run: FontGlyphRun, color: u32, config: FontRenderConfig) -> FontRenderBatch:
        if not font_render_config_selection_supported(config) or not self._render_config_matches_run(config, run):
            return self._invalid_config_batch(config)
        self._activate_render_config(config)
        _font_render_batch_with_config(self._prepare_glyph_run_active(run, color, config.size), config)

    me _prepare_glyph_run_active(run: FontGlyphRun, color: u32, font_size: i32) -> FontRenderBatch:
        val face_id = run.face_id
        var font_identity = font_face_identity(face_id, run.face_generation)
        val face_generation = run.face_generation
        var cluster_index: i64 = 0
        while cluster_index < run.clusters.len():
            if run.clusters[cluster_index] < 0:
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
            cluster_index = cluster_index + 1
        if (not run.valid or font_identity == "" or not font_face_is_live(face_id, run.face_generation) or
            font_size <= 0 or font_size > 512 or
            run.glyph_ids.len() != run.xs.len() or run.glyph_ids.len() != run.ys.len() or
            run.glyph_ids.len() != run.clusters.len()):
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        if self.atlas_face_generation != -2:
            self._reset_font_atlas(-2, font_identity)
        else:
            val dependencies = self._font_atlas_dependency_identity(face_id, run.face_generation)
            if dependencies == "":
                self._reset_font_atlas(-2, font_identity)
            else:
                font_identity = dependencies
                self.atlas_font_identity = dependencies
        val ascent = font_face_ascent(face_id, run.face_generation, font_size)
        if ascent <= 0:
            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
        var attempt = 0
        while attempt < 2:
            var quads: [FontRenderQuad] = []
            var dirty: [FontRenderQuad] = []
            var overflow = false
            var i = 0
            while i < run.glyph_ids.len():
                val raw_gid = run.glyph_ids[i]
                if raw_gid > 2147483647u32:
                    return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                val glyph_id = raw_gid.to_i32()
                val glyph = self.get_glyph_index(face_id, run.face_generation, glyph_id, font_size)
                if glyph.width > 0 and glyph.height > 0:
                    var atlas_index = self._font_atlas_entry_index(face_id, run.face_generation, glyph_id, -1, font_size)
                    var inserted = false
                    if atlas_index < 0:
                        atlas_index = self._insert_font_atlas_glyph(glyph)
                        inserted = atlas_index >= 0
                    if atlas_index < 0:
                        overflow = true
                    else:
                        val destination = _font_shaped_glyph_destination(run.xs[i], run.ys[i], glyph, ascent)
                        if not destination.0:
                            return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])
                        val quad = FontRenderQuad(
                            codepoint: -1, byte_offset: -1, cluster: run.clusters[i],
                            dst_x: destination.1, dst_y: destination.2,
                            width: self.atlas_widths[atlas_index], height: self.atlas_heights[atlas_index],
                            atlas_x: self.atlas_xs[atlas_index], atlas_y: self.atlas_ys[atlas_index],
                            color: color
                        )
                        quads.push(quad)
                        if inserted:
                            dirty.push(quad)
                i = i + 1
            if not overflow:
                if dirty.len() > 0:
                    val generation = _next_font_atlas_dependency_generation()
                    if generation == 0:
                        self._reset_font_atlas(-2, font_identity)
                        return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: 0, dirty_rects: [])
                    self.atlas_generation = generation
                return FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: true, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: quads, atlas_generation: self.atlas_generation, dirty_rects: dirty)
            self._reset_font_atlas(-2, font_identity)
            attempt = attempt + 1
        FontRenderBatch(program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY, font_identity: font_identity, face_generation: face_generation, valid: false, atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT, atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation, dirty_rects: [])

class _ResolvedShapedGlyphRun:
    valid: bool
    payload: DrawIrGlyphRunPayload
    advances: [i32]
    width: i32

fn _resolved_font_language(language: text) -> text:
    # Split the trim/lower/split chain: the seed compiler cannot resolve
    # `.split(...)` on the erased receiver produced by `.trim().lower()`
    # in this nested position (erased-receiver method-resolution gap,
    # see bug web_font_provider_split_nested_call_resolution_2026-07-14).
    val normalized: text = language.trim().lower()
    val parts = normalized.split("-")
    if parts.len() == 0 or parts[0] == "":
        return "und"
    parts[0]

fn _resolved_font_complex_script(codepoints: [i64]) -> i32:
    var complex_script = 0
    for codepoint in codepoints:
        val script = script_of(codepoint as u32)
        val next = if script == Script.Arabic: 1 else if script == Script.Devanagari: 2 else: 0
        if next != 0:
            if complex_script != 0 and complex_script != next:
                return 3
            complex_script = next
    complex_script

fn _resolved_font_category(family: text) -> text:
    val normalized = family.trim().lower()
    for candidate in selected_font_asset_candidates():
        if candidate.family.lower() == normalized:
            return candidate.category
    if (normalized.contains("mono") or normalized.contains("courier") or
        normalized.contains("code") or normalized.contains("console")):
        return "mono"
    if normalized.contains("sans") or normalized.contains("arial") or normalized.contains("helvetica"):
        return "sans"
    if normalized.contains("serif") or normalized.contains("times") or normalized.contains("georgia"):
        return "serif"
    ""

fn _resolved_font_empty_shaped() -> _ResolvedShapedGlyphRun:
    _ResolvedShapedGlyphRun(valid: false, payload: draw_ir_empty_glyph_run_payload(), advances: [], width: 0)

# Producer-only shaping. The transient face is released before this semantic
# result leaves the resolver; Draw IR never owns a face handle or atlas data.
fn _resolve_selected_shaped_glyph_run(candidate: FontAssetCandidate, content: text, font_size: i32, language: text) -> _ResolvedShapedGlyphRun:
    if not selected_font_simple_tuple_accepted(candidate.family, language):
        return _resolved_font_empty_shaped()
    val registered_only = font_renderer_registered_selected_bytes_only()
    val decoded = text_codepoints(content)
    if decoded.len() == 0:
        return _resolved_font_empty_shaped()
    var codepoints: [u32] = []
    for codepoint in decoded:
        if codepoint < 0 or codepoint > 1114111:
            return _resolved_font_empty_shaped()
        codepoints.push(codepoint as u32)
    val font_path = if registered_only:
        candidate.local_path
    else:
        selected_font_asset_physical_path(candidate.local_path)
    val font_blob = if registered_only:
        val registered = _registered_selected_font_bytes(candidate.local_path)
        if not registered.1:
            return _resolved_font_empty_shaped()
        registered.0
    else:
        file_read_bytes(font_path)
    val parsed = parse_offset_table(font_blob)
    if parsed == nil:
        return _resolved_font_empty_shaped()
    val shaped = if registered_only:
        val font = sk_font_new(sk_typeface_from_attached_font(candidate.family, sk_font_style_normal(), font_path, 0), font_size.to_f64())
        val shaper = shaper_with_ot_font(shaper_new(fallback_chain_new(font)), parsed.?)
        (shaper_shape_with_language(shaper, codepoints, font, 0.0, 0.0, language), 0, 0)
    else:
        val loaded = load_font(font_path)
        if loaded == nil:
            return _resolved_font_empty_shaped()
        val face = loaded.?
        val font = sk_font_new(sk_typeface_from_attached_font(candidate.family, sk_font_style_normal(), font_path, face.handle), font_size.to_f64())
        val shaper = shaper_with_ot_face(shaper_new(fallback_chain_new(font)), face.handle, parsed.?)
        val result = (shaper_shape_with_language(shaper, codepoints, font, 0.0, 0.0, language), face.handle, face.generation)
        free_font(face)
        result
    val runs = shaped.0
    var glyph_ids: [u32] = []
    var xs: [i32] = []
    var ys: [i32] = []
    var clusters: [i64] = []
    var advances: [i32] = [0; codepoints.len()]
    var total_advance = 0.0
    var valid = runs.len() > 0
    for run in runs:
        val material = shaped_run_to_font_glyph_run(run)
        if not material.valid or material.face_id != shaped.1 or material.face_generation != shaped.2:
            valid = false
        var i: i64 = 0
        while i < material.glyph_ids.len() and i < run.glyphs.len():
            glyph_ids.push(material.glyph_ids[i])
            xs.push(material.xs[i])
            ys.push(material.ys[i])
            clusters.push(material.clusters[i])
            val cluster = material.clusters[i]
            val before = total_advance.to_i32()
            total_advance = total_advance + run.glyphs[i].x_advance
            val after = total_advance.to_i32()
            if cluster < 0 or cluster >= advances.len():
                valid = false
            else:
                advances[cluster] = advances[cluster] + after - before
            i = i + 1
        if i != material.glyph_ids.len() or i != run.glyphs.len():
            valid = false
    val width = total_advance.to_i32()
    val payload = draw_ir_glyph_run_payload(glyph_ids, xs, ys, clusters, valid and width >= 0)
    _ResolvedShapedGlyphRun(valid: payload.valid, payload: payload, advances: if payload.valid: advances else: [], width: if payload.valid: width else: 0)

fn _resolve_font_metrics_with_language_config(family: text, content: text, font_size: i32,
                                              language: text, render_config_identity: text) -> ResolvedFontMetrics:
    if family.trim() == "" or font_size <= 0 or font_size > 512:
        return ResolvedFontMetrics(valid: false, family: family, identity: "", advances: [], width: 0, line_height: 0, reason: "invalid-font-request", glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    val normalized_language = _resolved_font_language(language)
    val codepoints = text_codepoints(content)
    val complex_script = _resolved_font_complex_script(codepoints)
    val category = _resolved_font_category(family)
    val selected_candidate = if normalized_language != "und" and category != "":
        selected_font_asset_for_language_category(normalized_language, category)
    else:
        nil
    val resolved_family = if selected_candidate != nil: selected_candidate.?.family else: family
    val cacheable = _resolved_font_metrics_cacheable(resolved_family, content)
    val expected_identity = if selected_candidate != nil: selected_font_asset_identity(selected_candidate.?) else: ""
    if cacheable and expected_identity != "":
        val expected_key = _resolved_font_metric_language_config_key(
            resolved_family, content, font_size, expected_identity, normalized_language, render_config_identity
        )
        if val cached = _resolved_font_metric_cached(expected_key):
            return cached
    # Shape first. Hosted producers use a short-lived font_sffi face; registered-
    # only producers bind the already-validated OpenType blob without a host ABI.
    val shaped = if complex_script != 0 and selected_candidate != nil:
        _resolve_selected_shaped_glyph_run(selected_candidate.?, content, font_size, normalized_language)
    else:
        _resolved_font_empty_shaped()
    val default_font = _browser_default_for_family_cached(resolved_family)
    var renderer = default_font.0
    val renderer_from_cache = default_font.1
    if not renderer.has_sffi_ttf():
        return ResolvedFontMetrics(valid: false, family: resolved_family, identity: "", advances: [], width: 0, line_height: 0, reason: "font-runtime-unavailable", glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: complex_script != 0)
    val identity = renderer.current_font_identity()
    val cache_key = if cacheable:
        _resolved_font_metric_language_config_key(
            resolved_family, content, font_size, identity, normalized_language, render_config_identity
        )
    else:
        ""
    if cacheable:
        if val cached = _resolved_font_metric_cached(cache_key):
            if not renderer_from_cache:
                renderer.clear_ttf()
            return cached
    val advances = if shaped.valid: shaped.advances else: renderer.measure_text_advances(content, font_size)
    var width = 0
    if shaped.valid:
        width = shaped.width
    else:
        for advance in advances:
            width = width + advance
    var line_height = renderer.horizontal_line_metric(font_size, 3)
    if line_height <= 0:
        line_height = font_size
    if not renderer_from_cache:
        renderer.clear_ttf()
    # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
    val character_count = content.len()
    val valid = identity != "" and advances.len() == character_count
    val resolved = ResolvedFontMetrics(
        valid: valid,
        family: resolved_family,
        identity: identity,
        advances: if valid: advances else: [],
        width: if valid: width else: 0,
        line_height: if valid: line_height else: 0,
        reason: if valid and (complex_script == 0 or shaped.valid): "resolved" else if valid: "font-shaping-unavailable" else: "font-identity-unavailable",
        glyph_run: shaped.payload,
        shaping_required: complex_script != 0
    )
    if resolved.valid and cacheable:
        _resolved_font_metric_store(cache_key, resolved)
    resolved

fn resolve_font_metrics_with_language(family: text, content: text, font_size: i32, language: text) -> ResolvedFontMetrics:
    val config = font_render_config_default_for_size(font_size)
    val config_identity = font_render_config_identity(config)
    val resolved = _resolve_font_metrics_with_language_config(family, content, font_size, language, config_identity)
    resolved

fn resolve_font_metrics_configured(config: FontRenderConfig, content: text) -> ResolvedFontMetrics:
    if not font_render_config_valid(config):
        return ResolvedFontMetrics(valid: false, family: config.family, identity: "", advances: [],
            width: 0, line_height: 0, reason: "invalid-font-config",
            glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    if _font_render_config_default_selection(config):
        return _resolve_font_metrics_with_language_config(
            "sans", content, config.size, config.language, font_render_config_identity(config)
        )
    val selected = _font_render_config_candidate(config)
    if selected == nil:
        return ResolvedFontMetrics(valid: false, family: config.family, identity: "", advances: [],
            width: 0, line_height: 0, reason: "font-config-unavailable",
            glyph_run: draw_ir_empty_glyph_run_payload(), shaping_required: false)
    _resolve_font_metrics_with_language_config(
        selected.?.family, content, config.size, config.language, font_render_config_identity(config)
    )

# Compatibility entry point for producers without language metadata.
fn resolve_font_metrics(family: text, content: text, font_size: i32) -> ResolvedFontMetrics:
    resolve_font_metrics_with_language(family, content, font_size, "und")
