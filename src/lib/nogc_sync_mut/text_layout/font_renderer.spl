# Hosted module initialization eagerly creates these facade mutexes before
# worker threads start. Freestanding native-builds leave function-call module
# initializers nil, so the same optional slots initialize on first use after the
# heap is ready; that path is single-core.
use std.skia.entity.font.{sk_font_new, sk_font_style_normal, sk_typeface_from_attached_font}
use std.skia.feature.glyph.ot_parser.{parse_offset_table}
use std.skia.feature.shaper.font_fallback.{fallback_chain_new}
use std.skia.feature.shaper.shaper.{shaped_run_to_font_glyph_run, shaper_new, shaper_shape_with_language, shaper_with_ot_face, shaper_with_ot_font}
use std.skia.feature.shaper.script_detect.{Script, script_of}
export use std.nogc_sync_mut.text_layout.font_types.{
    CachedGlyph, FontCacheStats, FontGlyphRun, FontTextPayload, FontRenderQuad, FontRenderBatch,
    FontRenderConfig, FontExecutionPolicy, font_execution_plan, font_render_category_name,
    font_render_config_normalize, font_render_config_default_for_size,
    font_render_config_identity, font_render_config_valid
}

# Shared Font Renderer — unified buffer text for OS and browser.
# Backends are TrueType/OpenType, the small built-in vector face, then VGA
# bitmap fallback. The first available backend owns each glyph.
# This module has NO dependency on CompositorBackend, so it can be used
# by the OS compositor, browser engine, and game engine alike.

# ============================================================================
# Glyph Cache
# ============================================================================

class ResolvedFontMetrics:
    valid: bool
    family: text
    identity: text
    advances: [i32]
    width: i32
    line_height: i32
    reason: text
    glyph_run: DrawIrGlyphRunPayload
    shaping_required: bool

# ponytail: process-local 128-entry ring for pinned layout metrics; replace with
# per-document caches only when concurrent multi-face ownership lands.
val RESOLVED_FONT_METRICS_CACHE_LIMIT: i64 = 128
val RESOLVED_FONT_METRICS_CACHE_FAMILY_LIMIT: i64 = 1024
val RESOLVED_FONT_METRICS_CACHE_CONTENT_LIMIT: i64 = 4096
var _resolved_font_metric_keys: [text] = []
var _resolved_font_metric_values: [ResolvedFontMetrics] = []
var _resolved_font_metric_cursor: i64 = 0
var _resolved_font_metric_lock: Mutex? = mutex_new(0)

fn _font_mutex_acquire(current: Mutex?) -> Mutex:
    # No `if val` binding here: under freestanding/entry-closure/aggressive-opt
    # kernel builds, real Mutex.lock()/unlock() calls on these facade locks
    # fault (cr2=0x0) on their very first use during boot (verified: fault RIP
    # resolves inside Mutex.lock/unlock, backtrace through this function and
    # font_renderer_use_registered_selected_bytes_only -> spl_start). This
    # facade is only used single-threaded there (kernel boot / one browser
    # process — see font_renderer_use_registered_selected_bytes_only), so once
    # that mode is active we skip the real lock/unlock syscalls entirely.
    val active = current ?? mutex_new(0)
    if not _registered_selected_fonts_only:
        active.lock()
    active

fn _font_mutex_release(current: Mutex?):
    if current == nil:
        return
    val active = current ?? mutex_new(0)
    if not _registered_selected_fonts_only:
        active.unlock(0)

fn _resolved_font_metric_lock_acquire():
    _resolved_font_metric_lock = _font_mutex_acquire(_resolved_font_metric_lock)

fn _resolved_font_metric_lock_release():
    _font_mutex_release(_resolved_font_metric_lock)

fn _resolved_font_metric_key(family: text, content: text, font_size: i32, identity: text) -> text:
    _resolved_font_metric_language_key(family, content, font_size, identity, "und")

fn _resolved_font_metric_language_key(family: text, content: text, font_size: i32, identity: text, language: text) -> text:
    _resolved_font_metric_language_config_key(
        family, content, font_size, identity, language,
        font_render_config_identity(font_render_config_default_for_size(font_size))
    )

fn _resolved_font_metric_language_config_key(family: text, content: text, font_size: i32,
                                             identity: text, language: text,
                                             render_config_identity: text) -> text:
    family.trim().lower() + "\n" + font_size.to_string() + "\n" + language.trim().lower() + "\n" +
        identity.len().to_string() + ":" + identity + "\n" +
        render_config_identity.len().to_string() + ":" + render_config_identity + "\n" + content

fn _resolved_font_metrics_cacheable(family: text, content: text) -> bool:
    family.len() <= RESOLVED_FONT_METRICS_CACHE_FAMILY_LIMIT and content.len() <= RESOLVED_FONT_METRICS_CACHE_CONTENT_LIMIT

fn _font_shaped_glyph_destination(pen_x: i32, pen_y: i32, glyph: CachedGlyph, ascent: i32) -> (bool, i32, i32):
    val x = pen_x.to_i64() + glyph.bearing_x.to_i64()
    val y = ascent.to_i64() + pen_y.to_i64() - glyph.bearing_y.to_i64() - glyph.height.to_i64()
    if x < -2147483648 or x > 2147483647 or y < -2147483648 or y > 2147483647:
        return (false, 0, 0)
    (true, x.to_i32(), y.to_i32())

fn _resolved_font_metric_cached(key: text) -> ResolvedFontMetrics?:
    _resolved_font_metric_lock_acquire()
    var index: i64 = 0
    while index < _resolved_font_metric_keys.len():
        if _resolved_font_metric_keys[index] == key:
            val found = _resolved_font_metric_values[index]
            _resolved_font_metric_lock_release()
            return found
        index = index + 1
    _resolved_font_metric_lock_release()
    nil

fn _resolved_font_metric_store(key: text, metrics: ResolvedFontMetrics):
    _resolved_font_metric_lock_acquire()
    if _resolved_font_metric_keys.len() < RESOLVED_FONT_METRICS_CACHE_LIMIT:
        _resolved_font_metric_keys.push(key)
        _resolved_font_metric_values.push(metrics)
        _resolved_font_metric_lock_release()
        return
    _resolved_font_metric_keys[_resolved_font_metric_cursor] = key
    _resolved_font_metric_values[_resolved_font_metric_cursor] = metrics
    _resolved_font_metric_cursor = (_resolved_font_metric_cursor + 1) % RESOLVED_FONT_METRICS_CACHE_LIMIT
    _resolved_font_metric_lock_release()

# Loaded-default-font cache keyed by resolved family. browser_default_for_family
# does a real dlopen + TTF parse (the universal sans face is 17MB), so without
# reuse every #text node reparses the whole font — quadratic for a real page and
# the dominant web-render cost under the interpreter. Cached renderers are NEVER
# clear_ttf()'d (see _resolve_font_metrics_with_language_config's guarded calls)
# so the loaded face stays live for the next node of the same family.
var _browser_default_font_families: [text] = []
var _browser_default_font_renderers: [FontRenderer] = []
var _registered_selected_font_paths: [text] = []
var _registered_selected_font_blobs: [[u8]] = []
var _registered_selected_fonts_only: bool = false
var _browser_default_font_lock: Mutex? = mutex_new(0)

fn _browser_default_font_lock_acquire():
    _browser_default_font_lock = _font_mutex_acquire(_browser_default_font_lock)

fn _browser_default_font_lock_release():
    _font_mutex_release(_browser_default_font_lock)

fn _registered_selected_font_bytes(path: text) -> ([u8], bool):
    _browser_default_font_lock_acquire()
    var index: i64 = 0
    while index < _registered_selected_font_paths.len():
        if _registered_selected_font_paths[index] == path:
            val blob = _registered_selected_font_blobs[index]
            _browser_default_font_lock_release()
            return (blob, true)
        index = index + 1
    _browser_default_font_lock_release()
    ([], false)

fn font_renderer_registered_selected_bytes_only() -> bool:
    _browser_default_font_lock_acquire()
    val enabled = _registered_selected_fonts_only
    _browser_default_font_lock_release()
    enabled

fn font_renderer_use_registered_selected_bytes_only():
    """Keep freestanding consumers away from host-only file externs."""
    # Flip the flag BEFORE the first lock use: _font_mutex_acquire/_release
    # skip the real Mutex.lock()/unlock() once this is true (see their
    # comments) — the very first acquire below would otherwise fault before
    # the flag is observable.
    _registered_selected_fonts_only = true
    _browser_default_font_lock_acquire()
    for renderer in _browser_default_font_renderers:
        renderer.clear_ttf()
    _browser_default_font_families = []
    _browser_default_font_renderers = []
    _browser_default_font_lock_release()
    _resolved_font_metric_lock_acquire()
    _resolved_font_metric_keys = []
    _resolved_font_metric_values = []
    _resolved_font_metric_cursor = 0
    _resolved_font_metric_lock_release()

fn font_renderer_register_selected_bytes(path: text, blob: [u8]) -> bool:
    """Register exact pinned bytes for producer metrics and executor loading."""
    # Path-based identity instead of `candidate.?` + field access: unwrapping
    # the Option-returning candidate lookup and touching fields faults on
    # baremetal (cr2=0x0 class, 2026-07-18); "" doubles as the unmanaged gate.
    val expected_identity: text = selected_font_asset_identity_for_path(path)
    if expected_identity == "":
        return false
    var renderer = FontRenderer.new()
    if not renderer.try_load_selected_bytes(path, blob):
        return false
    val identity = renderer.current_font_identity()
    renderer.clear_ttf()
    if identity != expected_identity:
        return false
    _browser_default_font_lock_acquire()
    for registered_path in _registered_selected_font_paths:
        if registered_path == path:
            _browser_default_font_lock_release()
            return true
    _registered_selected_font_paths.push(path)
    _registered_selected_font_blobs.push(blob)
    _browser_default_font_lock_release()
    true

fn _browser_default_for_family_cached(family: text) -> (FontRenderer, bool):
    _browser_default_font_lock_acquire()
    var index: i64 = 0
    while index < _browser_default_font_families.len():
        if _browser_default_font_families[index] == family:
            val hit = _browser_default_font_renderers[index]
            _browser_default_font_lock_release()
            return (hit, true)
        index = index + 1
    _browser_default_font_lock_release()
    val loaded = FontRenderer.browser_default_for_family(family)
    if loaded.has_sffi_ttf():
        _browser_default_font_lock_acquire()
        _browser_default_font_families.push(family)
        _browser_default_font_renderers.push(loaded)
        _browser_default_font_lock_release()
    (loaded, false)

# GLYPH-FIX-3 (2026-07-19): gated producer-side atlas probe. Prints the
# nonzero-coverage-byte count for the first quad's atlas region right before
# the batch (containing atlas_pixels: [u32]) crosses the nogc_sync_mut ->
# gc_async_mut module/layer boundary into Engine2D. Compared against the
# mirrored consumer-side probe in engine.spl to localize whether atlas
# coverage is lost before or during that cross-layer struct transfer.
val _VEC_ATLAS_PROBE: bool = false
var _vec_atlas_probe_count: i32 = 0
var _vec_glyph_probe_count: i32 = 0

# See doc/08_tracking/bug/font_render_batch_transform_identity_default_not_applied_2026-07-19.md:
# FontRenderBatch.transform_identity's class-field default reads back empty
# on freestanding native-build, which fails material_supported() and blocks
# all glyph compositing. Every FontRenderBatch(...) construction site in this
# file sets transform_identity explicitly to this constant instead of relying
# on the (unreliable, on this target) class default; the class default itself
# is left in place in font_types.spl for hosted builds.
val FONT_RENDER_TRANSFORM_IDENTITY: text = "uniform-scale;translate-late"

val FONT_ATLAS_WIDTH: i32 = 1024
val FONT_ATLAS_HEIGHT: i32 = 1024
# The scalar stays literal-initialized for freestanding startup. Its dedicated
# facade mutex is eager on hosted builds and lazy on the single-core baremetal
# path, matching the cache locks above.
var _font_atlas_dependency_generation_counter: i64 = 0
var _font_atlas_dependency_generation_lock: Mutex? = mutex_new(0)

fn _font_render_batch_with_config(batch: FontRenderBatch, config: FontRenderConfig) -> FontRenderBatch:
    FontRenderBatch(
        program_version: batch.program_version, font_identity: batch.font_identity,
        face_generation: batch.face_generation, valid: batch.valid,
        atlas_width: batch.atlas_width, atlas_height: batch.atlas_height,
        atlas_pixels: batch.atlas_pixels, quads: batch.quads,
        atlas_generation: batch.atlas_generation, dirty_rects: batch.dirty_rects,
        render_config_identity: font_render_config_identity(config), transform_identity: FONT_RENDER_TRANSFORM_IDENTITY,
        execution_target: font_render_config_normalize(config.execution_target),
        execution_policy: config.execution_policy
    )

fn _font_render_config_default_selection(config: FontRenderConfig) -> bool:
    (font_render_config_normalize(config.family) == "auto" and
        font_render_category_name(config.category) == "auto" and
        font_render_config_normalize(config.language) == "und" and
        font_render_config_normalize(config.script) == "auto")

fn _font_render_config_candidate(config: FontRenderConfig) -> FontAssetCandidate?:
    if _font_render_config_default_selection(config):
        return nil
    val normalized_language = font_render_config_normalize(config.language)
    val language_parts = normalized_language.split("-")
    if language_parts.len() == 0 or language_parts[0] == "":
        return nil
    val language = language_parts[0]
    val category = font_render_category_name(config.category)
    if language == "und" or category == "auto":
        return nil
    val selected = selected_font_asset_for_language_category(language, category)
    if selected == nil:
        return nil
    val candidate = selected.?
    val family = font_render_config_normalize(config.family)
    if family != "auto" and family != candidate.family.lower():
        return nil
    var expected_script = ""
    for rank in selected_font_language_ranks():
        if rank.language == language:
            expected_script = rank.likely_script.lower()
    val script = font_render_config_normalize(config.script)
    if expected_script == "" or (script != "auto" and script != expected_script):
        return nil
    candidate

fn font_render_config_selection_supported(config: FontRenderConfig) -> bool:
    font_render_config_valid(config) and (_font_render_config_default_selection(config) or _font_render_config_candidate(config) != nil)

fn _font_atlas_dependency_generation_after(current: i64) -> i64:
    if current < 0 or current >= 9223372036854775807:
        return 0
    current + 1

fn _next_font_atlas_dependency_generation() -> i64:
    _font_atlas_dependency_generation_lock = _font_mutex_acquire(_font_atlas_dependency_generation_lock)
    val next = _font_atlas_dependency_generation_after(_font_atlas_dependency_generation_counter)
    _font_atlas_dependency_generation_counter = next
    _font_mutex_release(_font_atlas_dependency_generation_lock)
    next

class GlyphCache:
    entries: [CachedGlyph]
    max_entries: i32
    max_bytes: i64
    payload_bytes: i64
    hits: i64
    misses: i64
    rasterizations: i64
    evictions: i64
    observed_generation: i64
    observed_font_identity: text
    observed_render_config_identity: text

    static fn new(max_size: i32) -> GlyphCache:
        GlyphCache(entries: [], max_entries: max_size, max_bytes: 33554432, payload_bytes: 0, hits: 0, misses: 0, rasterizations: 0, evictions: 0, observed_generation: 0, observed_font_identity: "", observed_render_config_identity: "")

    me lookup(codepoint: i32, font_size: i32) -> CachedGlyph?:
        for entry in self.entries:
            if (entry.glyph_index < 0 and entry.codepoint == codepoint and entry.font_size == font_size and
                entry.render_config_identity == self.observed_render_config_identity):
                self.hits = self.hits + 1
                return entry
        self.misses = self.misses + 1
        nil

    me lookup_index(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32) -> CachedGlyph?:
        for entry in self.entries:
            if (entry.face_id == face_id and entry.face_generation == face_generation and
                entry.glyph_index == glyph_index and entry.font_size == font_size and
                entry.render_config_identity == self.observed_render_config_identity):
                self.hits = self.hits + 1
                return entry
        self.misses = self.misses + 1
        nil

    me record_rasterization():
        self.rasterizations = self.rasterizations + 1

    me insert(glyph: CachedGlyph) -> bool:
        val glyph_bytes = glyph.pixels.len().to_i64()
        if glyph_bytes > self.max_bytes:
            return false
        while self.entries.len() >= self.max_entries or self.payload_bytes + glyph_bytes > self.max_bytes:
            if self.entries.len() == 0:
                return false
            self.payload_bytes = self.payload_bytes - self.entries[0].pixels.len().to_i64()
            self.entries = self.entries.slice(1, self.entries.len())
            self.evictions = self.evictions + 1
        var entries = self.entries
        var configured = glyph
        configured.render_config_identity = self.observed_render_config_identity
        entries.push(configured)
        self.entries = entries
        self.payload_bytes = self.payload_bytes + glyph_bytes
        true

    me invalidate():
        self.entries = []
        self.payload_bytes = 0

    me sync_face_identity(generation: i64, identity: text):
        if generation != self.observed_generation or identity != self.observed_font_identity:
            self.invalidate()
            self.observed_generation = generation
            self.observed_font_identity = identity

    me sync_generation(generation: i64):
        self.sync_face_identity(generation, self.observed_font_identity)

    me sync_render_config_identity(identity: text):
        if identity != self.observed_render_config_identity:
            self.invalidate()
            self.observed_render_config_identity = identity

    me reset_stats():
        self.hits = 0
        self.misses = 0
        self.rasterizations = 0
        self.evictions = 0

    fn stats() -> FontCacheStats:
        FontCacheStats(entries: self.entries.len().to_i64(), bytes: self.payload_bytes, generation: self.observed_generation, font_identity: self.observed_font_identity, hits: self.hits, misses: self.misses, rasterizations: self.rasterizations, evictions: self.evictions, render_config_identity: self.observed_render_config_identity)

# ============================================================================
# Font Renderer
# ============================================================================

class FontRenderer:
    cache: GlyphCache
    ttf_handle: i64     # TrueType font handle (0 = not loaded)
    use_vector: bool     # enable vector font fallback
    use_bitmap: bool     # enable bitmap font fallback
    ttf_rasterizer: FontRasterizer?  # Phase 3b: SFFI spl_fonts TTF backend (nil = disabled)
    atlas_pixels: [u32]
    atlas_codepoints: [i32]
    atlas_face_ids: [i64]
    atlas_face_generations: [i64]
    atlas_glyph_indices: [i32]
    atlas_font_sizes: [i32]
    atlas_xs: [i32]
    atlas_ys: [i32]
    atlas_widths: [i32]
    atlas_heights: [i32]
    atlas_cursor_x: i32
    atlas_cursor_y: i32
    atlas_row_height: i32
    atlas_generation: i64
    atlas_face_generation: i64
    atlas_font_identity: text
    active_render_config_identity: text = ""

    static fn new() -> FontRenderer:
        val cache = GlyphCache.new(512)
        val renderer = FontRenderer(
            cache: cache,
            ttf_handle: 0,
            use_vector: true,
            use_bitmap: true,
            ttf_rasterizer: nil,
            atlas_pixels: [], atlas_codepoints: [], atlas_face_ids: [], atlas_face_generations: [], atlas_glyph_indices: [], atlas_font_sizes: [],
            atlas_xs: [], atlas_ys: [], atlas_widths: [], atlas_heights: [],
            atlas_cursor_x: 0, atlas_cursor_y: 0, atlas_row_height: 0,
            atlas_generation: 0, atlas_face_generation: -1, atlas_font_identity: ""
        )
        renderer

    static fn with_ttf(handle: i64) -> FontRenderer:
        val cache = GlyphCache.new(512)
        val renderer = FontRenderer(
            cache: cache,
            ttf_handle: handle,
            use_vector: true,
            use_bitmap: true,
            ttf_rasterizer: nil,
            atlas_pixels: [], atlas_codepoints: [], atlas_face_ids: [], atlas_face_generations: [], atlas_glyph_indices: [], atlas_font_sizes: [],
            atlas_xs: [], atlas_ys: [], atlas_widths: [], atlas_heights: [],
            atlas_cursor_x: 0, atlas_cursor_y: 0, atlas_row_height: 0,
            atlas_generation: 0, atlas_face_generation: -1, atlas_font_identity: ""
        )
        renderer

    static fn browser_serif_default() -> FontRenderer:
        FontRenderer.browser_default_for_family("serif")

    static fn browser_default_for_family(family: text) -> FontRenderer:
        val registered_only = font_renderer_registered_selected_bytes_only()
        val candidates = browser_font_candidates_for_family(family)
        for font_path in candidates:
            val registered = _registered_selected_font_bytes(font_path)
            val registered_blob = registered.0
            val has_registered_blob = registered_blob.len() > 0
            if has_registered_blob:
                var renderer = FontRenderer.new()
                if renderer.try_load_selected_bytes(font_path, registered_blob):
                    return renderer
            if not registered_only:
                var renderer = FontRenderer.new()
                if renderer.try_load_runtime_ttf(font_path):
                    return renderer
        FontRenderer.new()

    fn has_ttf() -> bool:
        self.ttf_handle > 0

    fn selected_face_has_glyph(codepoint: i32) -> bool:
        """True only when the active selected face maps this codepoint to a
        nonzero glyph. Bitmap/vector fallback and `.notdef` do not count."""
        val active = self.ttf_rasterizer
        if active == nil:
            return false
        active.has_glyph(codepoint as i64)

    # -----------------------------------------------------------------------
    # Phase 3b: opt-in SFFI spl_fonts TrueType backend
    # -----------------------------------------------------------------------
    # Attempts to load `dylib_path` and initialize it with `ttf_path`. On
    # success the renderer will prefer the SFFI spl_fonts rasterizer for
    # glyphs (highest-priority backend). On any failure the renderer stays
    # in its default state and callers fall through to the vector/bitmap
    # paths unchanged. Caller opt-in only — default FontRenderer.new()
    # instances behave exactly as before.
    me _try_install_ttf(rasterizer: FontRasterizer?) -> bool:
        if rasterizer == nil:
            return false
        val old = self.ttf_rasterizer
        self.ttf_rasterizer = rasterizer
        if old != nil:
            old.close()
        var cache = self.cache
        cache.invalidate()
        self.cache = cache
        self.atlas_face_generation = -1
        true

    me try_enable_ttf(dylib_path: text, ttf_path: text) -> bool:
        val rasterizer = FontRasterizer.load(dylib_path, ttf_path)
        self._try_install_ttf(rasterizer)

    me try_load_runtime_ttf(ttf_path: text) -> bool:
        if ttf_path.trim() == "":
            return false
        val dylib_candidates = browser_font_dylib_candidates()
        for dylib_path in dylib_candidates:
            if self.try_enable_ttf(dylib_path, ttf_path):
                return true
        val selected_rasterizer = FontRasterizer.load_selected(ttf_path)
        self._try_install_ttf(selected_rasterizer)

    me try_load_selected_bytes(ttf_path: text, blob: [u8]) -> bool:
        val rasterizer = FontRasterizer.load_selected_bytes(ttf_path, blob)
        self._try_install_ttf(rasterizer)

    me try_load_registered_identity(identity: text) -> bool:
        # Path-based helper instead of `candidate.?.local_path`: Option-unwrap
        # field access faults on baremetal (cr2=0x0 class, 2026-07-18).
        val local_path: text = selected_font_asset_local_path_for_identity(identity)
        if local_path == "":
            return false
        val registered = _registered_selected_font_bytes(local_path)
        registered.1 and self.try_load_selected_bytes(local_path, registered.0)

    me clear_ttf():
        val rast = self.ttf_rasterizer
        if rast != nil:
            rast.close()
        self.ttf_rasterizer = nil
        var cache = self.cache
        cache.sync_face_identity(0, "")
        self.cache = cache
        self.atlas_face_generation = -1

    fn cache_stats() -> FontCacheStats: self.cache.stats()
    me current_font_identity() -> text:
        val rasterizer = self.ttf_rasterizer
        if rasterizer == nil:
            return ""
        val snapshot = rasterizer.cache_identity_snapshot()
        var cache = self.cache
        cache.sync_face_identity(snapshot.0, snapshot.1)
        self.cache = cache
        snapshot.1

    me reset_cache_stats():
        var cache = self.cache
        cache.reset_stats()
        self.cache = cache

    me _activate_render_config(config: FontRenderConfig):
        val identity = font_render_config_identity(config)
        if identity != self.active_render_config_identity:
            var cache = self.cache
            cache.sync_render_config_identity(identity)
            self.cache = cache
            if self.active_render_config_identity != "":
                self._reset_font_atlas(self.atlas_face_generation, self.atlas_font_identity)
            self.active_render_config_identity = identity

    fn _invalid_config_batch(config: FontRenderConfig) -> FontRenderBatch:
        val stats = self.cache.stats()
        _font_render_batch_with_config(FontRenderBatch(
            program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, transform_identity: FONT_RENDER_TRANSFORM_IDENTITY,
            font_identity: stats.font_identity, face_generation: stats.generation, valid: false,
            atlas_width: FONT_ATLAS_WIDTH, atlas_height: FONT_ATLAS_HEIGHT,
            atlas_pixels: self.atlas_pixels, quads: [], atlas_generation: self.atlas_generation,
            dirty_rects: []
        ), config)

    me _ensure_render_config_face(config: FontRenderConfig) -> bool:
        if _font_render_config_default_selection(config):
            return true
        val selected = _font_render_config_candidate(config)
        if selected == nil:
            return false
        val candidate = selected.?
        val expected_identity = selected_font_asset_identity(candidate)
        val active = self.ttf_rasterizer
        if active != nil:
            val snapshot = active.?.cache_identity_snapshot()
            if snapshot.1 == expected_identity:
                return true
        val loaded = FontRasterizer.load_selected(candidate.local_path)
        if loaded == nil:
            return false
        self.ttf_rasterizer = loaded
        self.current_font_identity() == expected_identity

    fn _render_config_matches_run(config: FontRenderConfig, run: FontGlyphRun) -> bool:
        if _font_render_config_default_selection(config):
            return true
        val selected = _font_render_config_candidate(config)
        selected != nil and font_face_identity(run.face_id, run.face_generation) == selected_font_asset_identity(selected.?)

    me try_enable_browser_serif_default() -> bool:
        for dylib_path in browser_font_dylib_candidates():
            for font_path in browser_serif_font_candidates():
                if self.try_enable_ttf(dylib_path, font_path):
                    return true
        false

    fn has_sffi_ttf() -> bool:
        val rasterizer = self.ttf_rasterizer
        if rasterizer == nil:
            return false
        rasterizer.is_current()

    me horizontal_kern(left_codepoint: i32, right_codepoint: i32, font_size: i32) -> i32:
        val rast = self.ttf_rasterizer
        if rast != nil:
            # Typed intermediate + `as i32`: bare `.to_i32()` on an erased
            # method-call result misdispatches to the lone user method
            # Px.to_i32 on the native lane (a06bc1d5 class; guest fault at
            # Px.to_i32 from this frame, 2026-07-18).
            val kern_value: i64 = rast.horizontal_kern(left_codepoint as i64, right_codepoint as i64, font_size as i64)
            return kern_value as i32
        0

    me horizontal_line_metric(font_size: i32, field: i32) -> i32:
        val rast = self.ttf_rasterizer
        if rast != nil:
            # Same erased-result `.to_i32()` misdispatch class as horizontal_kern.
            val metric_value: i64 = rast.horizontal_line_metric(font_size as i64, field as i64)
            return metric_value as i32
        0

    me layout_text(content: text, font_size: i32, max_width: i32) -> [LayoutGlyph]:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.layout_text(content, font_size.to_i64(), max_width.to_i64())
        []

    me rasterize_subpixel(codepoint: i32, font_size: i32) -> SubpixelGlyphBitmap?:
        val rast = self.ttf_rasterizer
        if rast != nil:
            return rast.rasterize_subpixel(codepoint.to_i64(), font_size.to_i64())
        nil

    # -----------------------------------------------------------------------
    # Get glyph (cached) — returns rasterized alpha bitmap
    # -----------------------------------------------------------------------
    fn glyph_with_cache(codepoint: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        # GLYPH-FIX-4 diagnostic: cache state on entry, printed before any
        # other call in this function (the safest possible read -- a first
        # touch of the `initial_cache` parameter, not a re-read after an
        # intervening call). Discriminates whether a same-codepoint second
        # call re-rasterizes because the cache is genuinely empty (miss is
        # legitimate/expected) or because it holds a stale entry that
        # lookup() rejects (a cache-key bug, fixable without touching the
        # rasterize path at all).
        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
            print("[vec-glyph-probe] gwc-entry cp={codepoint} font_size={font_size} cache_entries={initial_cache.entries.len()} cache_rcfg_id_len={initial_cache.observed_render_config_identity.len()}")
        if codepoint < 0 or codepoint > 1114111 or font_size <= 0 or font_size > 512:
            return (CachedGlyph.empty(codepoint, font_size), initial_cache)
        val active_rasterizer = self.ttf_rasterizer
        var cache = initial_cache
        if active_rasterizer != nil:
            val identity_snapshot = active_rasterizer.cache_identity_snapshot()
            cache.sync_face_identity(identity_snapshot.0, identity_snapshot.1)
        # Check cache first
        val cached = cache.lookup(codepoint, font_size)
        if cached != nil:
            return (cached, cache)

        # Rasterize
        cache.record_rasterization()
        var glyph = CachedGlyph.empty(codepoint, font_size)

        # Phase 3b: prefer SFFI spl_fonts TrueType backend when the caller
        # has opted in via try_enable_ttf(). Any failure falls through to
        # the existing vector/bitmap path unchanged. Under the interpreter,
        # static-fn Option<T> returns are typed as T directly, so we use
        # `!= nil` rather than `if val Some(x) =` destructuring.
        var handled = false
        val rast = active_rasterizer
        val rast_has_glyph = rast != nil and rast.has_glyph(codepoint.to_i64())
        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
            print("[vec-glyph-probe] gwc-pre-rasterize cp={codepoint} rast_nil={rast == nil} has_glyph={rast_has_glyph}")
        if rast_has_glyph:
            val gb = rast.rasterize(codepoint.to_i64(), font_size.to_i64())
            val gb_is_nil = gb == nil
            if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                print("[vec-glyph-probe] gwc-post-rasterize cp={codepoint} gb_nil={gb_is_nil}")
            if not gb_is_nil:
                val raw_glyph = _sffi_glyph_to_cached(gb, codepoint, font_size)
                # ROOT CAUSE (GLYPH-FIX-4, 2026-07-19): raw_glyph was built in
                # font_rasterizer.spl (a different module) and crosses back
                # into this module on return. Boot serial (build/os/_wkheap/
                # serial-ovmf.log, cr2=0 null deref) shows the fault lands
                # AFTER this call's own first-read probe below succeeds but
                # BEFORE the next get_glyph probe -- i.e. inside the OLD tail
                # of this function, which re-read glyph.width/glyph.height/
                # glyph.pixels.len() a SECOND time (once here for the probe,
                # again down in the expected_pixels/cache.insert block) after
                # the print() call had already run in between. That is the
                # exact "field read after an intervening call resolves to
                # unrelated heap memory" landmine already fixed once in
                # spl_fonts.spl's _rasterize_selected_outline (see the
                # `val gadv = metrics[2]`-style snapshot-to-locals comment
                # there, 2026-07-19). Fix: read every field exactly ONCE,
                # immediately, before any further call, into locals -- then
                # rebuild `glyph` as a fresh same-module struct literal and
                # never touch raw_glyph again.
                val gw = raw_glyph.width
                val gh = raw_glyph.height
                val gadv_raw = raw_glyph.advance
                val gbx = raw_glyph.bearing_x
                val gby = raw_glyph.bearing_y
                val gpixels = raw_glyph.pixels
                val gplen = gpixels.len()
                val gadv = if gadv_raw > 0: gadv_raw else: gw + 1
                if gw <= 0 or gh <= 0:
                    # Degenerate (0x0) glyph: cache an advance-only entry.
                    # Use a fresh empty literal (not gpixels) so no
                    # pixel-buffer deref or atlas insert is even reachable
                    # for this entry downstream.
                    glyph = CachedGlyph(codepoint: codepoint, face_id: 0, face_generation: 0, glyph_index: -1, font_size: font_size, width: 0, height: 0, advance: gadv, bearing_x: gbx, bearing_y: gby, pixels: [])
                else if gplen == gw.to_i64() * gh.to_i64():
                    glyph = CachedGlyph(codepoint: codepoint, face_id: 0, face_generation: 0, glyph_index: -1, font_size: font_size, width: gw, height: gh, advance: gadv, bearing_x: gbx, bearing_y: gby, pixels: gpixels)
                else:
                    glyph = CachedGlyph.empty(codepoint, font_size)
                if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
                    _vec_glyph_probe_count = _vec_glyph_probe_count + 1
                    print("[vec-glyph-probe] gwc-post-to_cached cp={codepoint} w={gw} h={gh} pixels_len={gplen}")
                handled = true

        if not handled:
            if self.has_ttf():
                glyph = rasterize_ttf(self.ttf_handle, codepoint, font_size)
            else if self.use_vector:
                val vector_cmds = vf_glyph_commands(codepoint)
                if vector_cmds.len() > 0:
                    glyph = rasterize_vector(vector_cmds, codepoint, font_size)
                else if self.use_bitmap:
                    glyph = rasterize_bitmap(codepoint, font_size)
            else if self.use_bitmap:
                glyph = rasterize_bitmap(codepoint, font_size)

        # GLYPH-FIX-4 checkpoint probe: last print before cache.insert(glyph)
        # / the (glyph, cache) tuple return / get_glyph's unpack. `glyph`
        # here is a same-module local (freshly reconstructed above for the
        # SFFI path, or freshly returned by rasterize_ttf/vector/bitmap for
        # the fallback path) so this read is not expected to hit the
        # cross-module landmine above -- if the fault still reproduces AFTER
        # this probe prints, it names cache.insert/the tuple return/
        # get_glyph's unpack as the real site instead.
        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
            print("[vec-glyph-probe] gwc-pre-insert cp={codepoint} w={glyph.width} h={glyph.height} adv={glyph.advance} plen={glyph.pixels.len()}")
        val expected_pixels = glyph.width.to_i64() * glyph.height.to_i64()
        if glyph.advance > 0 and expected_pixels == glyph.pixels.len().to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me get_glyph(codepoint: i32, font_size: i32) -> CachedGlyph:
        val result = self.glyph_with_cache(codepoint, font_size, self.cache)
        self.cache = result.1
        result.0

    fn glyph_index_with_cache(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32, initial_cache: GlyphCache) -> (CachedGlyph, GlyphCache):
        var cache = initial_cache
        if not font_face_is_live(face_id, face_generation) or glyph_index < 0 or font_size <= 0 or font_size > 512:
            return (CachedGlyph(codepoint: -1, face_id: face_id, face_generation: face_generation, glyph_index: glyph_index, font_size: font_size, width: 0, height: 0, advance: 0, bearing_x: 0, bearing_y: 0, pixels: []), cache)
        val cached = cache.lookup_index(face_id, face_generation, glyph_index, font_size)
        if cached != nil:
            return (cached, cache)
        cache.record_rasterization()
        val glyph = rasterize_ttf_index(face_id, face_generation, glyph_index, font_size)
        val expected_pixels = glyph.width.to_i64() * glyph.height.to_i64()
        if glyph.advance > 0 and expected_pixels == glyph.pixels.len().to_i64():
            cache.insert(glyph)
        (glyph, cache)

    me get_glyph_index(face_id: i64, face_generation: i64, glyph_index: i32, font_size: i32) -> CachedGlyph:
        val result = self.glyph_index_with_cache(face_id, face_generation, glyph_index, font_size, self.cache)
        self.cache = result.1
        result.0

    # -----------------------------------------------------------------------
    # Measure text width using actual glyph advances
    # -----------------------------------------------------------------------
    me measure_text_width(content: text, font_size: i32) -> i32:
        var total_w = 0
        var prev_cp = -1
        var cache = self.cache
        # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
        var ci = 0
        val content_len = content.len()
        while ci < content_len:
            val cp = content.char_code_at(ci)
            if prev_cp >= 0:
                total_w = total_w + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            val glyph = result.0
            cache = result.1
            if glyph.advance > 0:
                total_w = total_w + glyph.advance
            else:
                # Fallback: approximate
                total_w = total_w + font_size * 55 / 100
            prev_cp = cp
            ci = ci + 1
        self.cache = cache
        total_w

    me measure_text_advances(content: text, font_size: i32) -> [i32]:
        var advances: [i32] = []
        var prev_cp = -1
        var cache = self.cache
        # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
        var ci = 0
        val content_len = content.len()
        while ci < content_len:
            val cp = content.char_code_at(ci)
            if prev_cp >= 0:
                val previous = advances.len() - 1
                advances[previous] = advances[previous] + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            cache = result.1
            val glyph_advance = result.0.advance
            val advance = if glyph_advance > 0: glyph_advance else: font_size * 55 / 100
            advances.push(advance)
            prev_cp = cp
            ci = ci + 1
        self.cache = cache
        advances

    # -----------------------------------------------------------------------
    # Render text into a pixel buffer (ARGB u32)
    # -----------------------------------------------------------------------
    me render_text(buffer: [u32], buf_w: i32, buf_h: i32,
                   x: i32, y: i32, content: text,
                   color: u32, font_size: i32) -> [u32]:
        """Render text string into an ARGB pixel buffer with anti-aliased glyphs."""
        var out = buffer
        var cx = x
        var prev_cp = -1
        var cache = self.cache
        # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
        var ci = 0
        val content_len = content.len()
        while ci < content_len:
            val cp = content.char_code_at(ci)
            if prev_cp >= 0:
                cx = cx + self.horizontal_kern(prev_cp, cp, font_size)
            val result = self.glyph_with_cache(cp, font_size, cache)
            val glyph = result.0
            cache = result.1
            if glyph.width > 0 and glyph.height > 0:
                out = blit_glyph(out, buf_w, buf_h, cx, y, glyph, color)
            cx = cx + glyph.advance
            prev_cp = cp
            ci = ci + 1
        self.cache = cache
        out

    me render_text_payload(content: text, color: u32, font_size: i32) -> FontTextPayload:
        if font_size <= 0 or font_size > 512:
            return FontTextPayload(valid: false, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        if content == "":
            return FontTextPayload(valid: true, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        var layout = self.layout_text(content, font_size, 0)
        if layout.len() == 0 and (self.use_vector or self.use_bitmap):
            var fallback_x: i64 = 0
            var fallback_byte_offset: i64 = 0
            # indexed loop: for-in over text yields corrupted bindings (doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md)
            var ci = 0
            val content_len = content.len()
            while ci < content_len:
                val codepoint = content.char_code_at(ci)
                val glyph = self.get_glyph(codepoint, font_size)
                layout.push(LayoutGlyph(
                    codepoint: codepoint.to_i64(), x: fallback_x, y: 0,
                    width: glyph.width.to_i64(), height: glyph.height.to_i64(),
                    byte_offset: fallback_byte_offset
                ))
                fallback_x = fallback_x + glyph.advance.to_i64()
                fallback_byte_offset = fallback_byte_offset + 1
                ci = ci + 1
        if layout.len() == 0:
            return FontTextPayload(valid: false, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        var glyphs: [CachedGlyph] = []
        var min_x = 2147483647
        var min_y = 2147483647
        var max_x = -2147483647
        var max_y = -2147483647
        var cache = self.cache
        var i = 0
        while i < layout.len():
            val positioned = layout[i]
            val result = self.glyph_with_cache(positioned.codepoint.to_i32(), font_size, cache)
            val glyph = result.0
            cache = result.1
            glyphs.push(glyph)
            if glyph.width > 0 and glyph.height > 0:
                val gx = positioned.x.to_i32()
                val gy = positioned.y.to_i32()
                if gx < min_x:
                    min_x = gx
                if gy < min_y:
                    min_y = gy
                if gx + glyph.width > max_x:
                    max_x = gx + glyph.width
                if gy + glyph.height > max_y:
                    max_y = gy + glyph.height
            i = i + 1
        self.cache = cache
        if max_x <= min_x or max_y <= min_y:
            return FontTextPayload(valid: true, width: 0, height: 0, offset_x: 0, offset_y: 0, pixels: [])
        val width = max_x - min_x
        val height = max_y - min_y
        var pixels: [u32] = [0u32; width * height]
        val rgb = color & 0x00FFFFFFu32
        val color_alpha = ((color >> 24) & 0xFF).to_i32()
        i = 0
        while i < layout.len():
            val positioned = layout[i]
            val glyph = glyphs[i]
            val dst_x = positioned.x.to_i32() - min_x
            val dst_y = positioned.y.to_i32() - min_y
            var row = 0
            while row < glyph.height:
                var col = 0
                while col < glyph.width:
                    val src_idx = row * glyph.width + col
                    if src_idx < glyph.pixels.len():
                        val src_a = glyph.pixels[src_idx].to_i32() * color_alpha / 255
                        if src_a > 0:
                            val dst_idx = (dst_y + row) * width + dst_x + col
                            if dst_idx >= 0 and dst_idx < pixels.len():
                                val dst_a = ((pixels[dst_idx] >> 24) & 0xFF).to_i32()
                                val out_a = src_a + dst_a * (255 - src_a) / 255
                                pixels[dst_idx] = (out_a.to_u32() << 24) | rgb
                    col = col + 1
                row = row + 1
            i = i + 1
        FontTextPayload(valid: true, width: width, height: height, offset_x: min_x, offset_y: min_y, pixels: pixels)

    me _reset_font_atlas(face_generation: i64, font_identity: text):
        self.atlas_pixels = [0u32; FONT_ATLAS_WIDTH * FONT_ATLAS_HEIGHT]
        self.atlas_codepoints = []
        self.atlas_face_ids = []
        self.atlas_face_generations = []
        self.atlas_glyph_indices = []
        self.atlas_font_sizes = []
        self.atlas_xs = []
        self.atlas_ys = []
        self.atlas_widths = []
        self.atlas_heights = []
        self.atlas_cursor_x = 0
        self.atlas_cursor_y = 0
        self.atlas_row_height = 0
        self.atlas_generation = _next_font_atlas_dependency_generation()
        self.atlas_face_generation = face_generation
        self.atlas_font_identity = font_identity

    fn _font_atlas_dependency_identity(face_id: i64, face_generation: i64) -> text:
        var identities: [text] = []
        var i = 0
        while i < self.atlas_face_ids.len():
            val identity = font_face_identity(self.atlas_face_ids[i], self.atlas_face_generations[i])
            if identity == "": return ""
            if not identities.contains(identity): identities.push(identity)
            i = i + 1
        val pending = font_face_identity(face_id, face_generation)
        if pending == "": return ""
        if not identities.contains(pending): identities.push(pending)
        if identities.len() == 1: return identities[0]
        var combined = "font-faces-v1"
        for identity in identities:
            combined = combined + "|" + identity.len().to_string() + ":" + identity
        combined

    fn _font_atlas_entry_index(face_id: i64, face_generation: i64, glyph_index: i32, codepoint: i32, font_size: i32) -> i32:
        # ponytail: bounded linear lookup; replace with a map only if 512-entry profiles require it.
        var i = 0
        while i < self.atlas_codepoints.len():
            if (self.atlas_face_ids[i] == face_id and
                self.atlas_face_generations[i] == face_generation and
                self.atlas_glyph_indices[i] == glyph_index and
                self.atlas_codepoints[i] == codepoint and
                self.atlas_font_sizes[i] == font_size):
                return i
            i = i + 1
        -1

    me _insert_font_atlas_glyph(glyph: CachedGlyph) -> i32:
        if glyph.width <= 0 or glyph.height <= 0 or glyph.width > FONT_ATLAS_WIDTH or glyph.height > FONT_ATLAS_HEIGHT:
            return -1
        if glyph.pixels.len() != glyph.width.to_i64() * glyph.height.to_i64():
            return -1
        val padded_width = glyph.width + 1
        val padded_height = glyph.height + 1
        var x = self.atlas_cursor_x
        var y = self.atlas_cursor_y
        var row_height = self.atlas_row_height
        if x + padded_width > FONT_ATLAS_WIDTH:
            x = 0
            y = y + row_height
            row_height = 0
        if y + padded_height > FONT_ATLAS_HEIGHT:
            return -1
        var row = 0
        var _probe_glyph_nz = 0
        while row < glyph.height:
            var col = 0
            while col < glyph.width:
                val alpha = glyph.pixels[row * glyph.width + col].to_u32()
                if alpha > 0u32:
                    _probe_glyph_nz = _probe_glyph_nz + 1
                self.atlas_pixels[(y + row) * FONT_ATLAS_WIDTH + x + col] = (alpha << 24) | 0x00FFFFFFu32
                col = col + 1
            row = row + 1
        if _VEC_ATLAS_PROBE and _vec_glyph_probe_count < 8:
            _vec_glyph_probe_count = _vec_glyph_probe_count + 1
            print("[vec-glyph-probe] insert cp={glyph.codepoint} w={glyph.width} h={glyph.height} src_pixels_len={glyph.pixels.len()} src_nz={_probe_glyph_nz} ax={x} ay={y}")
        self.atlas_codepoints.push(glyph.codepoint)
        self.atlas_face_ids.push(glyph.face_id)
        self.atlas_face_generations.push(glyph.face_generation)
        self.atlas_glyph_indices.push(glyph.glyph_index)
        self.atlas_font_sizes.push(glyph.font_size)
        self.atlas_xs.push(x)
        self.atlas_ys.push(y)
        self.atlas_widths.push(glyph.width)
        self.atlas_heights.push(glyph.height)
        self.atlas_cursor_x = x + padded_width
        self.atlas_cursor_y = y
        self.atlas_row_height = if padded_height > row_height: padded_height else: row_height
