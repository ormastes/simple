# Font Vector Data — outline command tables for the built-in vector font.
#
# Design space: 24 units tall. Each glyph is a flat [i32] array of triplets
# [cmd, x, y, ...] where cmd: 0=MOVE 1=LINE 2=CLOSE 3=END.
#
# Used by rasterize_vector() in font_rasterizer.spl.

# ===========================================================================
# System default font — single source of truth for the SimpleOS default
# monospace face. Set to Fira Code Nerd Font Mono so terminal + GUI text
# surfaces pick up the Starship-compatible glyph coverage (powerline,
# devicons, etc.). The kernel fb console stays on the 8x16 bitmap — TTF
# can't load before the memory manager is up.
# ===========================================================================

val SYSTEM_DEFAULT_MONO_FONT_PATH: text =
    "examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf"

val SYSTEM_DEFAULT_MONO_FONT_NAME: text = "Fira Code Nerd Font Mono"

fn default_mono_font_path() -> text:
    """Return the path to the SimpleOS default monospace font file."""
    SYSTEM_DEFAULT_MONO_FONT_PATH

fn default_mono_font_name() -> text:
    """Return the human-readable name of the default monospace font."""
    SYSTEM_DEFAULT_MONO_FONT_NAME

# ============================================================================
# Dispatch tables
# ============================================================================

fn vf_glyph_commands(codepoint: i32) -> [i32]:
    """Return vector outline commands for a codepoint, or empty if not available."""
    if codepoint == 65: return _vf_A()
    if codepoint == 66: return _vf_B()
    if codepoint == 67: return _vf_C()
    if codepoint == 68: return _vf_D()
    if codepoint == 69: return _vf_E()
    if codepoint == 70: return _vf_F()
    if codepoint == 72: return _vf_H()
    if codepoint == 73: return _vf_I()
    if codepoint == 76: return _vf_L()
    if codepoint == 77: return _vf_M()
    if codepoint == 78: return _vf_N()
    if codepoint == 79: return _vf_O()
    if codepoint == 80: return _vf_P()
    if codepoint == 82: return _vf_R()
    if codepoint == 83: return _vf_S()
    if codepoint == 84: return _vf_T()
    if codepoint == 87: return _vf_W()
    # Lowercase
    if codepoint == 97: return _vf_a()
    if codepoint == 101: return _vf_e()
    if codepoint == 105: return _vf_i()
    if codepoint == 108: return _vf_l()
    if codepoint == 110: return _vf_n()
    if codepoint == 111: return _vf_o()
    if codepoint == 114: return _vf_r()
    if codepoint == 115: return _vf_s()
    if codepoint == 116: return _vf_t()
    []

fn vf_glyph_width(codepoint: i32) -> i32:
    """Return design-space width for a vector glyph (24 units = full height)."""
    if codepoint == 65: return 11    # A
    if codepoint == 66: return 10    # B
    if codepoint == 67: return 10    # C
    if codepoint == 68: return 10    # D
    if codepoint == 69: return 9     # E
    if codepoint == 70: return 9     # F
    if codepoint == 72: return 10    # H
    if codepoint == 73: return 4     # I
    if codepoint == 76: return 9     # L
    if codepoint == 77: return 12    # M
    if codepoint == 78: return 10    # N
    if codepoint == 79: return 11    # O
    if codepoint == 80: return 10    # P
    if codepoint == 82: return 10    # R
    if codepoint == 83: return 10    # S
    if codepoint == 84: return 10    # T
    if codepoint == 87: return 14    # W
    if codepoint == 97: return 9     # a
    if codepoint == 101: return 9    # e
    if codepoint == 105: return 4    # i
    if codepoint == 108: return 4    # l
    if codepoint == 110: return 9    # n
    if codepoint == 111: return 9    # o
    if codepoint == 114: return 7    # r
    if codepoint == 115: return 8    # s
    if codepoint == 116: return 7    # t
    8  # default

# ============================================================================
# Vector glyph outlines — each glyph is [cmd, x, y, ...] triplets
# cmd: 0=MOVE, 1=LINE, 2=CLOSE, 3=END
# ============================================================================

fn _vf_A() -> [i32]: [0,0,24, 1,5,0, 1,6,0, 1,11,24, 1,9,24, 1,7,16, 1,4,16, 1,2,24, 2,0,0, 0,4,14, 1,5,8, 1,6,8, 1,7,14, 2,0,0, 3,0,0]
fn _vf_B() -> [i32]: [0,0,0, 1,0,24, 1,7,24, 1,9,22, 1,9,18, 1,7,16, 1,0,16, 0,7,16, 1,10,14, 1,10,2, 1,7,0, 1,0,0, 2,0,0, 0,2,2, 1,7,2, 1,8,4, 1,8,14, 1,7,14, 1,2,14, 2,0,0, 0,2,18, 1,7,18, 1,7,22, 1,2,22, 2,0,0, 3,0,0]
fn _vf_C() -> [i32]: [0,10,4, 1,8,1, 1,3,1, 1,1,4, 1,1,20, 1,3,23, 1,8,23, 1,10,20, 0,3,3, 1,3,21, 1,5,23, 1,8,23, 0,8,1, 1,5,1, 1,3,3, 2,0,0, 3,0,0]
fn _vf_D() -> [i32]: [0,0,0, 1,0,24, 1,6,24, 1,10,20, 1,10,4, 1,6,0, 2,0,0, 0,2,2, 1,6,2, 1,8,5, 1,8,19, 1,6,22, 1,2,22, 2,0,0, 3,0,0]
fn _vf_E() -> [i32]: [0,0,0, 1,0,24, 1,9,24, 1,9,22, 1,2,22, 1,2,13, 1,7,13, 1,7,11, 1,2,11, 1,2,2, 1,9,2, 1,9,0, 2,0,0, 3,0,0]
fn _vf_F() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,13, 1,7,13, 1,7,11, 1,2,11, 1,2,2, 1,9,2, 1,9,0, 2,0,0, 3,0,0]
fn _vf_H() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,13, 1,8,13, 1,8,24, 1,10,24, 1,10,0, 1,8,0, 1,8,11, 1,2,11, 1,2,0, 2,0,0, 3,0,0]
fn _vf_I() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,0, 2,0,0, 3,0,0]
fn _vf_L() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,2, 1,9,2, 1,9,0, 2,0,0, 3,0,0]
fn _vf_M() -> [i32]: [0,0,24, 1,0,0, 1,2,0, 1,6,8, 1,10,0, 1,12,0, 1,12,24, 1,10,24, 1,10,6, 1,6,14, 1,2,6, 1,2,24, 2,0,0, 3,0,0]
fn _vf_N() -> [i32]: [0,0,24, 1,0,0, 1,2,0, 1,8,18, 1,8,0, 1,10,0, 1,10,24, 1,8,24, 1,2,6, 1,2,24, 2,0,0, 3,0,0]
fn _vf_O() -> [i32]: [0,3,0, 1,1,3, 1,1,21, 1,3,24, 1,8,24, 1,10,21, 1,10,3, 1,8,0, 2,0,0, 0,3,2, 1,3,22, 1,5,24, 1,6,24, 1,8,22, 1,8,2, 1,6,0, 1,5,0, 2,0,0, 3,0,0]
fn _vf_P() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,13, 1,7,13, 1,9,11, 1,9,2, 1,7,0, 2,0,0, 0,2,2, 1,7,2, 1,7,11, 1,2,11, 2,0,0, 3,0,0]
fn _vf_R() -> [i32]: [0,0,0, 1,0,24, 1,2,24, 1,2,13, 1,6,13, 1,10,24, 1,8,24, 1,5,14, 1,7,14, 1,9,12, 1,9,2, 1,7,0, 2,0,0, 0,2,2, 1,7,2, 1,7,12, 1,2,12, 2,0,0, 3,0,0]
fn _vf_S() -> [i32]: [0,9,3, 1,7,1, 1,3,1, 1,1,3, 1,1,10, 1,3,12, 1,7,12, 1,9,14, 1,9,21, 1,7,23, 1,3,23, 1,1,21, 0,3,3, 1,3,10, 1,7,10, 1,7,3, 2,0,0, 0,3,14, 1,3,21, 1,7,21, 1,7,14, 2,0,0, 3,0,0]
fn _vf_T() -> [i32]: [0,0,0, 1,10,0, 1,10,2, 1,6,2, 1,6,24, 1,4,24, 1,4,2, 1,0,2, 2,0,0, 3,0,0]
fn _vf_W() -> [i32]: [0,0,0, 1,2,0, 1,3,16, 1,7,6, 1,11,16, 1,12,0, 1,14,0, 1,11,24, 1,9,24, 1,7,12, 1,5,24, 1,3,24, 2,0,0, 3,0,0]

# Lowercase
fn _vf_a() -> [i32]: [0,1,8, 1,3,6, 1,7,6, 1,9,8, 1,9,24, 1,7,24, 1,7,20, 1,3,24, 1,1,22, 1,1,14, 1,3,12, 1,7,12, 0,3,14, 1,3,22, 1,7,18, 2,0,0, 3,0,0]
