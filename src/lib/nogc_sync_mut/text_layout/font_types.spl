# Shared font-rendering values. Kept separate so renderer and rasterizer do not
# depend on each other's partially resolved module shape.

class CachedGlyph:
    codepoint: i32
    font_size: i32
    width: i32
    height: i32
    advance: i32
    bearing_x: i32
    bearing_y: i32
    pixels: [u8]

    static fn empty(cp: i32, fs: i32) -> CachedGlyph:
        CachedGlyph(codepoint: cp, font_size: fs, width: 0, height: 0, advance: 0, bearing_x: 0, bearing_y: 0, pixels: [])

class FontCacheStats:
    entries: i64
    bytes: i64
    generation: i64
    hits: i64
    misses: i64
    rasterizations: i64
    evictions: i64

class FontTextPayload:
    valid: bool
    width: i32
    height: i32
    offset_x: i32
    offset_y: i32
    pixels: [u32]

    fn is_empty() -> bool:
        self.width <= 0 or self.height <= 0 or self.pixels.len() == 0
