# Shared font-rendering values. Kept separate so renderer and rasterizer do not
# depend on each other's partially resolved module shape.

class CachedGlyph:
    codepoint: i32
    face_id: i64
    face_generation: i64
    glyph_index: i32
    font_size: i32
    width: i32
    height: i32
    advance: i32
    bearing_x: i32
    bearing_y: i32
    pixels: [u8]

    static fn empty(cp: i32, fs: i32) -> CachedGlyph:
        CachedGlyph(codepoint: cp, face_id: 0, face_generation: 0, glyph_index: -1, font_size: fs, width: 0, height: 0, advance: 0, bearing_x: 0, bearing_y: 0, pixels: [])

class FontGlyphRun:
    valid: bool
    face_generation: i64
    glyph_ids: [u32]
    xs: [i32]
    ys: [i32]

class FontCacheStats:
    entries: i64
    bytes: i64
    generation: i64
    hits: i64
    misses: i64
    rasterizations: i64
    evictions: i64

class FontTextPayload:
    valid: bool
    width: i32
    height: i32
    offset_x: i32
    offset_y: i32
    pixels: [u32]

    fn is_empty() -> bool:
        self.width <= 0 or self.height <= 0 or self.pixels.len() == 0

class FontRenderQuad:
    codepoint: i32
    byte_offset: i64
    dst_x: i32
    dst_y: i32
    width: i32
    height: i32
    atlas_x: i32
    atlas_y: i32
    color: u32

class FontRenderBatch:
    valid: bool
    atlas_width: i32
    atlas_height: i32
    atlas_pixels: [u32]
    quads: [FontRenderQuad]
    atlas_generation: i64
    dirty_rects: [FontRenderQuad]

    fn is_empty() -> bool:
        self.quads.len() == 0 or self.atlas_pixels.len() == 0
