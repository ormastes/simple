"""
# OIDC ID Token Validation

Parses and validates OpenID Connect ID tokens (JWTs). Checks issuer,
audience, and expiration claims. Signature verification delegates to
`std.common.jwt.verify` which is currently a stub -- callers will get
an explicit error until the JWT library gains real JWKS-based verification.

## Usage

```simple
use std.nogc_sync_mut.oidc.id_token.{IdTokenValidator}

val validator = IdTokenValidator.new("https://accounts.google.com", "my-client-id")
val claims = validator.validate(token_string, jwks_json)?
```
"""

use std.common.jwt.decode.{split_token, json_parse_object}
use std.common.jwt.claims.{get_claim}
use std.common.jwt.verify.{verify_signature}

# ============================================================================
# IdTokenClaims
# ============================================================================

struct IdTokenClaims:
    """Parsed OIDC ID token claims."""
    issuer: text
    subject: text
    audience: text
    expiry: i64
    issued_at: i64
    nonce: text
    email: text
    name: text

    static fn from_jwt_claims(claims_json: text) -> Result<IdTokenClaims, text>:
        """Parse JWT claims JSON into IdTokenClaims struct."""
        val pairs = json_parse_object(claims_json)
        if pairs.length() == 0:
            return Err("empty or invalid claims JSON")

        val iss = get_claim(pairs, "iss")
        val sub = get_claim(pairs, "sub")
        val aud = get_claim(pairs, "aud")
        val exp_str = get_claim(pairs, "exp")
        val iat_str = get_claim(pairs, "iat")
        val nonce_val = get_claim(pairs, "nonce")
        val email_val = get_claim(pairs, "email")
        val name_val = get_claim(pairs, "name")

        if iss == "":
            return Err("missing required claim: iss")
        if sub == "":
            return Err("missing required claim: sub")

        val exp_val = parse_i64_safe(exp_str)
        val iat_val = parse_i64_safe(iat_str)

        Ok(IdTokenClaims(
            issuer: iss,
            subject: sub,
            audience: aud,
            expiry: exp_val,
            issued_at: iat_val,
            nonce: nonce_val,
            email: email_val,
            name: name_val
        ))

# ============================================================================
# IdTokenValidator
# ============================================================================

class IdTokenValidator:
    """Validates OIDC ID tokens against expected issuer/audience."""
    expected_issuer: text
    expected_audience: text
    clock_skew_seconds: i64

    static fn new(issuer: text, audience: text) -> IdTokenValidator:
        """Create a validator with 60-second default clock skew tolerance."""
        IdTokenValidator(
            expected_issuer: issuer,
            expected_audience: audience,
            clock_skew_seconds: 60
        )

impl IdTokenValidator:
    fn validate(token: text, jwks_json: text) -> Result<IdTokenClaims, text>:
        """Verify JWT signature using JWKS, then validate claims.

        NOTE: Signature verification currently returns an error because
        the underlying jwt.verify module is a stub. This will succeed
        once jwt.verify gains real JWKS-based RS256 verification.
        """
        val sig_ok = verify_signature(token, jwks_json, "RS256")
        if not sig_ok:
            return Err("JWT signature verification failed (jwt.verify is not yet implemented for JWKS)")

        val parts = split_token(token)
        if parts.length() != 3:
            return Err("malformed JWT: expected 3 dot-separated parts")

        val payload_b64 = parts.at(1)
        val payload_json = rt_base64url_decode(payload_b64)
        if payload_json == "":
            return Err("failed to decode JWT payload")

        val claims = IdTokenClaims.from_jwt_claims(payload_json)?
        self.validate_claims(claims)?
        Ok(claims)

    fn validate_claims(claims: IdTokenClaims) -> Result<(), text>:
        """Check issuer, audience, and expiration."""
        if claims.issuer != self.expected_issuer:
            return Err("issuer mismatch: expected {self.expected_issuer}, got {claims.issuer}")

        if claims.audience != self.expected_audience:
            if claims.audience != "":
                return Err("audience mismatch: expected {self.expected_audience}, got {claims.audience}")

        if claims.expiry > 0:
            val now = rt_time_now_seconds()
            val deadline = claims.expiry + self.clock_skew_seconds
            if now > deadline:
                return Err("token expired at {claims.expiry}, current time {now}")

        Ok(())

# ============================================================================
# Helpers
# ============================================================================

fn parse_i64_safe(s: text) -> i64:
    """Parse a numeric string to i64, returning 0 on failure."""
    if s == "":
        return 0
    var result = 0
    var i = 0
    val len = s.length()
    while i < len:
        val c = s.char_at(i)
        val code = c.byte_at(0)
        if code >= 48 and code <= 57:
            result = result * 10 + (code - 48)
        i = i + 1
    result

# ============================================================================
# SFFI
# ============================================================================

extern fn rt_time_now_seconds() -> i64
extern fn rt_base64url_decode(encoded: text) -> text
