"""
Capability registry: derives NumericCaps facts from a TargetPreset-like record.

Keeps the surface architecture-neutral; encodes x86 runtime-probe requirements
explicitly instead of assuming AVX from the generic preset.
"""

# ============================================================================
# TargetSpec — minimal subset of TargetPreset fields needed for cap derivation
# ============================================================================

"""
Minimal target specification used by the capability registry.
Mirrors the fields of TargetPreset that affect numeric capability derivation.
"""
struct TargetSpec:
    arch: text
    os: text
    pointer_width: int
    float_support: bool
    vector_support: bool
    is_baremetal: bool

impl TargetSpec:
    static fn linux_x86_64() -> TargetSpec:
        """Standard Linux x86_64 target with SSE2 baseline, AVX2 requires runtime probe."""
        TargetSpec(arch: "x86_64", os: "linux", pointer_width: 64, float_support: true, vector_support: true, is_baremetal: false)

    static fn riscv64_linux() -> TargetSpec:
        """RISC-V 64-bit Linux with FD extensions."""
        TargetSpec(arch: "riscv64", os: "linux", pointer_width: 64, float_support: true, vector_support: false, is_baremetal: false)

    static fn riscv32_baremetal() -> TargetSpec:
        """RISC-V 32-bit bare-metal integer-only."""
        TargetSpec(arch: "riscv32", os: "none", pointer_width: 32, float_support: false, vector_support: false, is_baremetal: true)

    static fn scalar_riscv64() -> TargetSpec:
        """RISC-V 64-bit Linux without vector extensions (scalar-only)."""
        TargetSpec(arch: "riscv64", os: "linux", pointer_width: 64, float_support: true, vector_support: false, is_baremetal: false)

# ============================================================================
# CapRegistryEntry — cached capability record
# ============================================================================

"""Registry entry mapping a TargetSpec to derived NumericCaps."""
struct CapRegistryEntry:
    arch: text
    os: text
    pointer_width: int
    has_hw_float: bool
    has_simd_128: bool
    has_simd_256: bool
    has_int_simd: bool
    has_fma: bool
    simd_needs_probe: bool
    diagnostic: text

impl CapRegistryEntry:
    static fn derive(spec: TargetSpec) -> CapRegistryEntry:
        """Derive a capability registry entry from a TargetSpec."""
        val is_x86 = spec.arch == "x86_64" or spec.arch == "x86_32"
        val is_rv = spec.arch == "riscv64" or spec.arch == "riscv32"

        # x86: SSE2 is baseline for x86_64; AVX2 requires runtime CPUID probe
        val s128 = if is_x86 == true and spec.float_support == true: true
                   elif spec.vector_support == true: true
                   else: false

        val s256 = if is_x86 == true and spec.float_support == true: false  # conservative: needs probe
                   else: false

        val probe = if is_x86 == true and spec.vector_support == true: true else: false

        val int_simd = if is_x86 == true and spec.float_support == true: true
                       elif spec.vector_support == true: true
                       else: false

        val fma = if is_x86 == true and spec.float_support == true: false  # needs probe
                  elif spec.arch == "aarch64": true
                  else: false

        val diag = if spec.float_support == false and is_rv == true:
                       "riscv integer-only: no FP or SIMD"
                   elif probe == true:
                       "x86 AVX2/AVX512 availability requires CPUID probe at runtime"
                   else:
                       "ok"

        CapRegistryEntry(arch: spec.arch, os: spec.os, pointer_width: spec.pointer_width, has_hw_float: spec.float_support, has_simd_128: s128, has_simd_256: s256, has_int_simd: int_simd, has_fma: fma, simd_needs_probe: probe, diagnostic: diag)

    fn is_ok() -> bool:
        """True if no capability warnings were emitted."""
        self.diagnostic == "ok"

    fn describe() -> text:
        """Return arch + diagnostic summary."""
        return self.arch + "/" + self.os + ": " + self.diagnostic
