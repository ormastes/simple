# ScalableVec<T> — Runtime-lane SIMD vector (SVE/RVV style)
#
# C2 §1.3: ScalableVec additional methods on top of the Vector trait.
# C2 §4:   lanes() is a RUNTIME query; min_lanes() is compile-time const.
# C2 §7:   Interpreter mode uses a [T] slice with runtime-known length.
#
# @tag:stdlib
# @tag:simd

use std.simd.vector.{Vector, SimdElementType, LaneIter}
use std.simd.mask.{Mask}
use std.simd.fixed.{FixedVec}

# ============================================================================
# ScalableVec<T> — with Vector trait (C2 §1.1 + §1.3)
# ============================================================================

class ScalableVec<T: SimdElementType> with Vector:
    """Runtime-lane SIMD vector (models SVE/RVV vscale semantics).

    Interpreter backing: a plain [T] slice whose length is determined at
    construction time.

    lanes() is a runtime call (C2 §4.1).
    min_lanes() returns 4 (matches SVE/RVV @ VLEN=128 for f32).

    C2 §4.5: PTX/CUDA does NOT support ScalableVec.
    """
    elements: [T]

    # — Associated types —
    type Elem = T
    type Mask = Mask<ScalableVec<T>>

    # — Construction (C2 §1.3) —

    static fn splat(val: T) -> Self:
        ScalableVec<T>.splat_n(val, ScalableVec<T>.min_lanes())

    static fn splat_n(val: T, n: usize) -> Self:
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(val)
            i = i + 1
        ScalableVec(elements: out)

    static fn zero() -> Self:
        ScalableVec<T>.splat(0 as T)

    # C2 §4.2: min_lanes() — compile-time architectural minimum
    # In interpreter: returns 4 (matches SVE/RVV @ VLEN=128 for f32)
    static fn min_lanes() -> usize:
        4

    # C2 §4.4: from_fixed
    static fn from_fixed(v: FixedVec<T>) -> Self:
        var out: [T] = []
        var i = 0
        while i < v.lanes:
            out.push(v.elements[i as usize])
            i = i + 1
        ScalableVec(elements: out)

    # C2 §4.4: try_to_fixed — runtime check
    fn try_to_fixed(self, n: i32) -> Option<FixedVec<T>>:
        if self.elements.len() != n as usize:
            None
        else:
            var out: [T] = []
            var i = 0
            while i < n:
                out.push(self.elements[i as usize])
                i = i + 1
            Some(FixedVec(elements: out, lanes: n))

    # C2 §1.3: Load / store (stride-aware)
    static fn load_strided(ptr: *T, stride: usize, n: usize) -> Self:
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(rt_ptr_load(ptr, i * stride))
            i = i + 1
        ScalableVec(elements: out)

    fn store_strided(self, ptr: *T, stride: usize):
        val n = self.elements.len()
        var i = 0
        while i < n:
            rt_ptr_store(ptr, i * stride, self.elements[i])
            i = i + 1

    # — Vector trait: lane count — (C2 §4.1)

    fn lanes(self) -> usize:
        self.elements.len()

    fn len(self) -> usize:
        self.elements.len()

    # — Vector trait: lane access — (C2 §1.1)

    fn lane(self, i: usize) -> T:
        if i >= self.elements.len():
            panic("E_SIMD_LANE_OOB: lane index {i} >= {self.elements.len()}")
        self.elements[i]

    fn set_lane(self, i: usize, v: T) -> Self:
        val n = self.elements.len()
        if i >= n:
            panic("E_SIMD_LANE_OOB: lane index {i} >= {n}")
        var new_elems: [T] = []
        var j = 0
        while j < n:
            if j == i:
                new_elems.push(v)
            else:
                new_elems.push(self.elements[j])
            j = j + 1
        ScalableVec(elements: new_elems)

    # — Vector trait: Arithmetic — (C2 §1.1)

    fn add(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] + rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn sub(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] - rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn mul(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] * rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn div(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] / rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn neg(self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(-self.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn min(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            val a = self.elements[i]
            val b = rhs.elements[i]
            if a < b:
                out.push(a)
            else:
                out.push(b)
            i = i + 1
        ScalableVec(elements: out)

    fn max(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            val a = self.elements[i]
            val b = rhs.elements[i]
            if a > b:
                out.push(a)
            else:
                out.push(b)
            i = i + 1
        ScalableVec(elements: out)

    # — Vector trait: Float-only arithmetic — (C2 §1.1)

    fn fma(self, b: Self, c: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] * b.elements[i] + c.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn fnmadd(self, b: Self, c: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(-(self.elements[i] * b.elements[i]) + c.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn abs(self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            val v = self.elements[i]
            if v < 0 as T:
                out.push(-v)
            else:
                out.push(v)
            i = i + 1
        ScalableVec(elements: out)

    fn recip(self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(1 as T / self.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn sqrt(self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(rt_sqrt(self.elements[i]))
            i = i + 1
        ScalableVec(elements: out)

    fn recip_sqrt(self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(1 as T / rt_sqrt(self.elements[i]))
            i = i + 1
        ScalableVec(elements: out)

    # — Vector trait: Integer-only bitwise — (C2 §1.1)

    fn and(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] & rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn or(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] | rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn xor(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] ^ rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn andnot(self, rhs: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push((~self.elements[i]) & rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn shl(self, count: u32) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] << count)
            i = i + 1
        ScalableVec(elements: out)

    fn shr_logical(self, count: u32) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] >> count)
            i = i + 1
        ScalableVec(elements: out)

    fn shr_arith(self, count: u32) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(self.elements[i] >> count)
            i = i + 1
        ScalableVec(elements: out)

    # — Vector trait: Comparison → Mask — (C2 §1.1)

    fn cmp_eq(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] == rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    fn cmp_ne(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] != rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    fn cmp_lt(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] < rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    fn cmp_le(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] <= rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    fn cmp_gt(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] > rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    fn cmp_ge(self, rhs: Self) -> Mask<ScalableVec<T>>:
        val n = self.elements.len()
        var bits: u64 = 0
        var i = 0
        while i < n:
            if self.elements[i] >= rhs.elements[i]:
                bits = bits | (1 as u64 << i)
            i = i + 1
        Mask(bits: bits, lane_count: n)

    # — Vector trait: Selection / blend — (C2 §1.1)

    fn mask_select(mask: Mask<ScalableVec<T>>, t: Self, f: Self) -> Self:
        val n = t.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            if mask.lane_active(i):
                out.push(t.elements[i])
            else:
                out.push(f.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    # — Vector trait: Reductions — (C2 §1.1)

    fn reduce_sum(self) -> T:
        val n = self.elements.len()
        var acc = self.elements[0]
        var i = 1
        while i < n:
            acc = acc + self.elements[i]
            i = i + 1
        acc

    fn reduce_min(self) -> T:
        val n = self.elements.len()
        var acc = self.elements[0]
        var i = 1
        while i < n:
            val v = self.elements[i]
            if v < acc:
                acc = v
            i = i + 1
        acc

    fn reduce_max(self) -> T:
        val n = self.elements.len()
        var acc = self.elements[0]
        var i = 1
        while i < n:
            val v = self.elements[i]
            if v > acc:
                acc = v
            i = i + 1
        acc

    fn reduce_and(self) -> T:
        val n = self.elements.len()
        var acc = self.elements[0]
        var i = 1
        while i < n:
            acc = acc & self.elements[i]
            i = i + 1
        acc

    fn reduce_or(self) -> T:
        val n = self.elements.len()
        var acc = self.elements[0]
        var i = 1
        while i < n:
            acc = acc | self.elements[i]
            i = i + 1
        acc

    # — Vector trait: Permutation / shuffle — (C2 §1.1)

    fn shuffle(self, indices: Self) -> Self:
        val n = self.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            val idx = indices.elements[i] as usize
            if idx >= n:
                panic("E_SIMD_LANE_OOB: shuffle index {idx} >= {n}")
            out.push(self.elements[idx])
            i = i + 1
        ScalableVec(elements: out)

    fn permute(self, ctrl: Self) -> Self:
        self.shuffle(ctrl)

    fn broadcast_lane(self, lane: u32) -> Self:
        val n = self.elements.len()
        val idx = lane as usize
        if idx >= n:
            panic("E_SIMD_LANE_OOB: broadcast_lane {lane} >= {n}")
        val v = self.elements[idx]
        ScalableVec<T>.splat_n(v, n)

    fn interleave_lo(self, rhs: Self) -> Self:
        val n = self.elements.len()
        val half = n / 2
        var out: [T] = []
        var i = 0
        while i < half:
            out.push(self.elements[i])
            out.push(rhs.elements[i])
            i = i + 1
        ScalableVec(elements: out)

    fn interleave_hi(self, rhs: Self) -> Self:
        val n = self.elements.len()
        val half = n / 2
        var out: [T] = []
        var i = 0
        while i < half:
            out.push(self.elements[half + i])
            out.push(rhs.elements[half + i])
            i = i + 1
        ScalableVec(elements: out)

    # — Vector trait: Memory — (C2 §1.1)

    fn load_unaligned(ptr: *T) -> Self:
        val n = ScalableVec<T>.min_lanes()
        var out: [T] = []
        var i = 0
        while i < n:
            out.push(rt_ptr_load(ptr, i))
            i = i + 1
        ScalableVec(elements: out)

    fn store_unaligned(self, ptr: *mut T):
        val n = self.elements.len()
        var i = 0
        while i < n:
            rt_ptr_store(ptr, i, self.elements[i])
            i = i + 1

    fn load_aligned(ptr: *T) -> Self:
        ScalableVec<T>.load_unaligned(ptr)

    fn store_aligned(self, ptr: *mut T):
        self.store_unaligned(ptr)

    fn gather(base: *T, indices: Self) -> Self:
        val n = indices.elements.len()
        var out: [T] = []
        var i = 0
        while i < n:
            val idx = indices.elements[i] as usize
            out.push(rt_ptr_load(base, idx))
            i = i + 1
        ScalableVec(elements: out)

    fn scatter(self, base: *mut T, indices: Self):
        val n = self.elements.len()
        var i = 0
        while i < n:
            val idx = indices.elements[i] as usize
            rt_ptr_store(base, idx, self.elements[i])
            i = i + 1

    # — Vector trait: Conversion — (C2 §1.1)

    fn from_array(arr: [T]) -> Self:
        ScalableVec(elements: arr)

    fn to_array(self) -> [T]:
        self.elements

    # — Vector trait: Debug / iteration — (C2 §1.1)

    fn fmt(self) -> text:
        val n = self.elements.len()
        var s = "ScalableVec["
        var i = 0
        while i < n:
            if i > 0:
                s = s + ", "
            s = s + "{self.elements[i]}"
            i = i + 1
        s + "]"

    fn to_string(self) -> text:
        self.fmt()

    fn iter(self) -> LaneIter<T>:
        LaneIter.new(self.elements)
