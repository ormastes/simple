# VLen — hardware vector-length descriptor for scalable targets
#
# Encodes the runtime VLEN as a multiplier of a fixed base.
# SVE base = 128-bit (16 bytes); RISC-V V base = 64-bit (8 bytes).
#
# @tag:stdlib
# @tag:simd

class VLen:
    base_bits: i32
    multiplier: i32

impl VLen:
    # SVE VLEN(n): base=128, multiplier=n (e.g. n=1 => 128-bit)
    static fn sve(multiplier: i32) -> VLen:
        VLen(base_bits: 128, multiplier: multiplier)

    # RISC-V V VLEN(n): base=64, multiplier=n (e.g. n=1 => 64-bit)
    static fn riscv_v(multiplier: i32) -> VLen:
        VLen(base_bits: 64, multiplier: multiplier)

    # Generic VLEN from explicit bit count
    static fn from_bits(bits: i32) -> VLen:
        VLen(base_bits: bits, multiplier: 1)

    fn total_bits(self) -> i32:
        self.base_bits * self.multiplier

    fn f32_lanes(self) -> i32:
        self.total_bits() / 32

    fn f64_lanes(self) -> i32:
        self.total_bits() / 64

    fn i32_lanes(self) -> i32:
        self.total_bits() / 32

    fn i64_lanes(self) -> i32:
        self.total_bits() / 64

    fn is_power_of_two_lanes(self, elem_bits: i32) -> bool:
        val n = self.total_bits() / elem_bits
        if n <= 0:
            return false
        n != 0 and (n & (n - 1)) == 0

    fn fmt(self) -> text:
        "VLen(base=" + self.base_bits.to_string() + ",x" + self.multiplier.to_string() + ")"
