# SIMD Module — Standard Library SIMD Facade
#
# Entry point: use std.simd.*
#
# Public API follows C2 §11.2:
#   Vector trait, FixedVec<T,N>, ScalableVec<T>, Mask<V>, and back-compat aliases.
#
# @tag:stdlib
# @tag:simd

import vector
import fixed
import scalable
import mask
import aliases

# — Core trait —
export Vector

# — Concrete vector types —
export FixedVec
export ScalableVec

# — Mask type —
export Mask

# — Element-type marker traits —
export Numeric
export Float
export Integer
export SignedInt
export SimdElementType

# — Back-compat aliases (C2 §11.3) —
export Vec2f, Vec4f, Vec8f, Vec16f
export Vec2d, Vec4d, Vec8d
export Vec4i, Vec8i, Vec16i
export Vec4u, Vec8u
