# SIMD Back-Compat Type Aliases
#
# C2 §11.3 / B1 §8: Migration aliases from the hardcoded scalar structs in
# src/compiler/30.types/simd_vector_types.spl to the new parameterized types.
#
# Existing callers of Vec4f, Vec8f, Vec2d, Vec4d continue to compile.
# NOTE: The concrete struct fields (x, y, z, w, e0..e7) from the old structs
# do NOT carry over.  Use .lane(0), .lane(1), etc. or .to_array() / .from_array().
#
# @tag:stdlib
# @tag:simd
# @tag:back-compat

use std.simd.fixed.{FixedVec}

# — f32 aliases (C2 §11.3) —
type Vec2f  = FixedVec<f32, 2>
type Vec4f  = FixedVec<f32, 4>
type Vec8f  = FixedVec<f32, 8>
type Vec16f = FixedVec<f32, 16>

# — f64 aliases (C2 §11.3) —
type Vec2d  = FixedVec<f64, 2>
type Vec4d  = FixedVec<f64, 4>
type Vec8d  = FixedVec<f64, 8>

# — i32 aliases (C2 §11.3) —
type Vec4i  = FixedVec<i32, 4>
type Vec8i  = FixedVec<i32, 8>
type Vec16i = FixedVec<i32, 16>

# — u32 aliases (C2 §11.3) —
type Vec4u  = FixedVec<u32, 4>
type Vec8u  = FixedVec<u32, 8>
