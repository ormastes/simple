# SIMD Back-Compat Type Aliases
#
# C2 §11.3 / B1 §8: Migration aliases from the hardcoded scalar structs in
# src/compiler/30.types/simd_vector_types.spl to the new parameterized types.
#
# NOTE: The concrete struct fields (x, y, z, w, e0..e7) from the old structs
# do NOT carry over.  Use .lane(0), .lane(1), etc. or .to_array() / .from_array().
#
# Type aliases (F2 §1 — added 2026-05-02):
#   `type VecXy = FixedVec<T>` declarations appear below.  The parser
#   accepts the `type X = Y` syntax but currently discards the binding
#   (parser_decls.spl:1086 "Type alias: type X = Y -- skip it").  These
#   declarations are inert until D3/E2 lands type-alias expansion in the
#   resolver and interpreter.  They are placed here now so:
#     (a) `use std.simd.{Vec4f}` will resolve once E2 raises the import
#         priority of aliases.spl above the legacy struct in simd_vector_types.spl
#     (b) the correct future-facing syntax is established and no const-N
#         is required (FixedVec<T> uses a runtime `lanes` field — see fixed.spl)
#
# Construction (works today, interpreter mode):
#   val v = vec4f_splat(1.0)         # function wrapper — always works
#   val v = fixedvec_splat(1.0, 4)   # direct FixedVec construction
#
# Construction (requires D3 + E2 + F1 parser fix):
#   val v = Vec4f.splat(1.0)         # type-alias form — inert until D3/E2 land
#
# @tag:stdlib
# @tag:simd
# @tag:back-compat

use std.simd.fixed.{FixedVec, fixedvec_splat, fixedvec_from_slice}

# — F2: type aliases (C2 §11.3) — parser accepts, resolver not yet wired —

# f32 aliases
type Vec2f  = FixedVec<f32>
type Vec4f  = FixedVec<f32>
type Vec8f  = FixedVec<f32>
type Vec16f = FixedVec<f32>

# f64 aliases
type Vec2d  = FixedVec<f64>
type Vec4d  = FixedVec<f64>
type Vec8d  = FixedVec<f64>

# i32 aliases
type Vec4i  = FixedVec<i32>
type Vec8i  = FixedVec<i32>
type Vec16i = FixedVec<i32>

# u32 aliases
type Vec4u  = FixedVec<u32>
type Vec8u  = FixedVec<u32>

# — f32 aliases (C2 §11.3) —

fn vec2f_splat(v: f32) -> FixedVec<f32>:
    fixedvec_splat(v, 2)

fn vec4f_splat(v: f32) -> FixedVec<f32>:
    fixedvec_splat(v, 4)

fn vec8f_splat(v: f32) -> FixedVec<f32>:
    fixedvec_splat(v, 8)

fn vec16f_splat(v: f32) -> FixedVec<f32>:
    fixedvec_splat(v, 16)

fn vec2f_from_array(arr: [f32]) -> FixedVec<f32>:
    fixedvec_from_slice(arr, 2)

fn vec4f_from_array(arr: [f32]) -> FixedVec<f32>:
    fixedvec_from_slice(arr, 4)

fn vec8f_from_array(arr: [f32]) -> FixedVec<f32>:
    fixedvec_from_slice(arr, 8)

fn vec16f_from_array(arr: [f32]) -> FixedVec<f32>:
    fixedvec_from_slice(arr, 16)

# — f64 aliases (C2 §11.3) —

fn vec2d_splat(v: f64) -> FixedVec<f64>:
    fixedvec_splat(v, 2)

fn vec4d_splat(v: f64) -> FixedVec<f64>:
    fixedvec_splat(v, 4)

fn vec8d_splat(v: f64) -> FixedVec<f64>:
    fixedvec_splat(v, 8)

fn vec2d_from_array(arr: [f64]) -> FixedVec<f64>:
    fixedvec_from_slice(arr, 2)

fn vec4d_from_array(arr: [f64]) -> FixedVec<f64>:
    fixedvec_from_slice(arr, 4)

fn vec8d_from_array(arr: [f64]) -> FixedVec<f64>:
    fixedvec_from_slice(arr, 8)

# — i32 aliases (C2 §11.3) —

fn vec4i_splat(v: i32) -> FixedVec<i32>:
    fixedvec_splat(v, 4)

fn vec8i_splat(v: i32) -> FixedVec<i32>:
    fixedvec_splat(v, 8)

fn vec16i_splat(v: i32) -> FixedVec<i32>:
    fixedvec_splat(v, 16)

fn vec4i_from_array(arr: [i32]) -> FixedVec<i32>:
    fixedvec_from_slice(arr, 4)

fn vec8i_from_array(arr: [i32]) -> FixedVec<i32>:
    fixedvec_from_slice(arr, 8)

# — u32 aliases (C2 §11.3) —

fn vec4u_splat(v: u32) -> FixedVec<u32>:
    fixedvec_splat(v, 4)

fn vec8u_splat(v: u32) -> FixedVec<u32>:
    fixedvec_splat(v, 8)

fn vec4u_from_array(arr: [u32]) -> FixedVec<u32>:
    fixedvec_from_slice(arr, 4)

fn vec8u_from_array(arr: [u32]) -> FixedVec<u32>:
    fixedvec_from_slice(arr, 8)
