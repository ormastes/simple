extern fn rt_simd_has_sse() -> bool
extern fn rt_simd_has_avx() -> bool
extern fn rt_simd_has_avx2() -> bool
extern fn rt_simd_has_neon() -> bool
extern fn rt_simd_has_rvv() -> bool
extern fn rt_simd_detect_profile() -> i64
extern fn rt_simd_profile_name() -> text

enum SimdTier:
    scalar
    x86_64_sse2
    x86_64_avx2
    x86_64_avx512
    aarch64_neon
    aarch64_sve
    aarch64_sve2
    riscv64_rvv
    wasm128

fn detect_profile() -> SimdTier:
    match rt_simd_detect_profile():
        case 0: SimdTier.scalar
        case 1: SimdTier.x86_64_sse2
        case 2: SimdTier.x86_64_avx2
        case 3: SimdTier.x86_64_avx512
        case 4: SimdTier.aarch64_neon
        case 5: SimdTier.aarch64_sve
        case 6: SimdTier.aarch64_sve2
        case 7: SimdTier.riscv64_rvv
        case 8: SimdTier.wasm128
        case _: SimdTier.scalar

fn profile_name() -> text:
    rt_simd_profile_name()

fn has_sse() -> bool:
    rt_simd_has_sse()

fn has_avx() -> bool:
    rt_simd_has_avx()

fn has_avx2() -> bool:
    rt_simd_has_avx2()

fn has_neon() -> bool:
    rt_simd_has_neon()

fn has_rvv() -> bool:
    rt_simd_has_rvv()

fn simd_width() -> i64:
    match detect_profile():
        case SimdTier.x86_64_avx512: 512
        case SimdTier.x86_64_avx2: 256
        case SimdTier.x86_64_sse2: 128
        case SimdTier.aarch64_neon: 128
        case SimdTier.aarch64_sve: 128
        case SimdTier.aarch64_sve2: 128
        case SimdTier.riscv64_rvv: 128
        case SimdTier.wasm128: 128
        case SimdTier.scalar:
            if has_avx2():
                256
            elif has_avx():
                256
            elif has_sse():
                128
            elif has_neon():
                128
            elif has_rvv():
                128
            else:
                0
