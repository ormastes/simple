class VariantProbe:
    base_name: text
    tier_suffix: text
    full_path: text
    found: bool

    static fn attempt(base_name: text, tier_suffix: text) -> VariantProbe:
        var path = base_name + "_" + tier_suffix + ".so"
        VariantProbe(base_name: base_name, tier_suffix: tier_suffix, full_path: path, found: false)

    static fn base_only(base_name: text) -> VariantProbe:
        var path = base_name + ".so"
        VariantProbe(base_name: base_name, tier_suffix: "", full_path: path, found: false)

    me is_found() -> bool:
        self.found

    me mark_found() -> VariantProbe:
        VariantProbe(base_name: self.base_name, tier_suffix: self.tier_suffix, full_path: self.full_path, found: true)

    me summary() -> text:
        var status = "not_found"
        if self.found:
            status = "found"
        var suffix_part = ""
        if self.tier_suffix == "":
            suffix_part = "(base)"
        else:
            suffix_part = "(tier=" + self.tier_suffix + ")"
        self.full_path + " " + suffix_part + " [" + status + "]"


class ProbeSequence:
    base_name: text
    probe_count: i32
    p0_suffix: text
    p1_suffix: text
    p2_suffix: text
    p3_suffix: text
    p4_suffix: text
    p5_suffix: text
    p0_found: bool
    p1_found: bool
    p2_found: bool
    p3_found: bool
    p4_found: bool
    p5_found: bool

    static fn for_x86(base_name: text, preferred: text) -> ProbeSequence:
        ProbeSequence(
            base_name: base_name,
            probe_count: 6,
            p0_suffix: preferred,
            p1_suffix: "x86_64_avx512",
            p2_suffix: "x86_64_avx2",
            p3_suffix: "x86_64_sse2",
            p4_suffix: "scalar",
            p5_suffix: "",
            p0_found: false,
            p1_found: false,
            p2_found: false,
            p3_found: false,
            p4_found: false,
            p5_found: false
        )

    static fn for_arm(base_name: text, preferred: text) -> ProbeSequence:
        ProbeSequence(
            base_name: base_name,
            probe_count: 6,
            p0_suffix: preferred,
            p1_suffix: "aarch64_sve2",
            p2_suffix: "aarch64_sve",
            p3_suffix: "aarch64_neon",
            p4_suffix: "scalar",
            p5_suffix: "",
            p0_found: false,
            p1_found: false,
            p2_found: false,
            p3_found: false,
            p4_found: false,
            p5_found: false
        )

    me first_found() -> text:
        if self.p0_found:
            self.p0_suffix
        elif self.p1_found:
            self.p1_suffix
        elif self.p2_found:
            self.p2_suffix
        elif self.p3_found:
            self.p3_suffix
        elif self.p4_found:
            self.p4_suffix
        elif self.p5_found:
            self.p5_suffix
        else:
            ""

    me mark_slot_found(idx: i32) -> ProbeSequence:
        if idx == 0:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: true, p1_found: self.p1_found,
                p2_found: self.p2_found, p3_found: self.p3_found,
                p4_found: self.p4_found, p5_found: self.p5_found
            )
        elif idx == 1:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: self.p0_found, p1_found: true,
                p2_found: self.p2_found, p3_found: self.p3_found,
                p4_found: self.p4_found, p5_found: self.p5_found
            )
        elif idx == 2:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: self.p0_found, p1_found: self.p1_found,
                p2_found: true, p3_found: self.p3_found,
                p4_found: self.p4_found, p5_found: self.p5_found
            )
        elif idx == 3:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: self.p0_found, p1_found: self.p1_found,
                p2_found: self.p2_found, p3_found: true,
                p4_found: self.p4_found, p5_found: self.p5_found
            )
        elif idx == 4:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: self.p0_found, p1_found: self.p1_found,
                p2_found: self.p2_found, p3_found: self.p3_found,
                p4_found: true, p5_found: self.p5_found
            )
        else:
            ProbeSequence(
                base_name: self.base_name, probe_count: self.probe_count,
                p0_suffix: self.p0_suffix, p1_suffix: self.p1_suffix,
                p2_suffix: self.p2_suffix, p3_suffix: self.p3_suffix,
                p4_suffix: self.p4_suffix, p5_suffix: self.p5_suffix,
                p0_found: self.p0_found, p1_found: self.p1_found,
                p2_found: self.p2_found, p3_found: self.p3_found,
                p4_found: self.p4_found, p5_found: true
            )

    me summary() -> text:
        var winner = self.first_found()
        if winner == "":
            self.base_name + ": no variant found"
        else:
            self.base_name + ": resolved tier=" + winner


class VariantResolver:
    base_name: text
    resolved_path: text
    resolved_tier: text
    used_fallback: bool

    static fn resolved(base_name: text, path: text, tier: text) -> VariantResolver:
        VariantResolver(base_name: base_name, resolved_path: path, resolved_tier: tier, used_fallback: false)

    static fn fallback(base_name: text, path: text) -> VariantResolver:
        VariantResolver(base_name: base_name, resolved_path: path, resolved_tier: "", used_fallback: true)

    static fn not_found(base_name: text) -> VariantResolver:
        VariantResolver(base_name: base_name, resolved_path: "", resolved_tier: "", used_fallback: false)

    me is_resolved() -> bool:
        if self.resolved_path == "":
            false
        else:
            true

    me is_fallback() -> bool:
        self.used_fallback

    me summary() -> text:
        if self.resolved_path == "":
            self.base_name + ": not_found"
        elif self.used_fallback:
            self.base_name + ": fallback path=" + self.resolved_path
        else:
            self.base_name + ": resolved tier=" + self.resolved_tier + " path=" + self.resolved_path


class LoaderProbeConfig:
    search_dir: text
    prefer_tier: text
    probe_siblings: bool
    max_probes: i32

    static fn standard(search_dir: text, prefer_tier: text) -> LoaderProbeConfig:
        LoaderProbeConfig(search_dir: search_dir, prefer_tier: prefer_tier, probe_siblings: true, max_probes: 6)

    static fn no_variants(search_dir: text) -> LoaderProbeConfig:
        LoaderProbeConfig(search_dir: search_dir, prefer_tier: "", probe_siblings: false, max_probes: 1)

    me should_probe_variants() -> bool:
        self.probe_siblings

    me summary() -> text:
        var mode = "single"
        if self.probe_siblings:
            mode = "multi"
        self.search_dir + " prefer=" + self.prefer_tier + " mode=" + mode + " max=" + self.max_probes.to_text()
