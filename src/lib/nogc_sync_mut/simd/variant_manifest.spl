# variant_manifest.spl — AC-8 & AC-9: multi-variant package manifest + round-trip
#
# AC-8: VariantEntry + VariantManifest — structured storage for per-platform
#       per-tier binary paths with flat 8-slot layout (no heap collections).
# AC-9: ManifestParser round-trip — serialize → parse_entry produces equivalent entry.
#
# @tag:stdlib
# @tag:simd

# ============================================================================
# VariantEntry — one variant in a package (AC-8)
# ============================================================================

class VariantEntry:
    """One platform+tier variant entry in a package manifest.

    Identifies a single binary artifact by platform, SIMD tier, path,
    size, and whether it is the package default.
    """
    platform: text
    tier: text
    path: text
    size_bytes: i64
    is_default: bool

impl VariantEntry:

    static fn create(platform: text, tier: text, path: text, size_bytes: i64, is_default: bool) -> VariantEntry:
        """Construct a VariantEntry with all fields."""
        VariantEntry(
            platform: platform,
            tier: tier,
            path: path,
            size_bytes: size_bytes,
            is_default: is_default
        )

    fn matches(self, platform: text, tier: text) -> bool:
        """True when this entry matches the requested platform and tier."""
        self.platform == platform and self.tier == tier

    fn serialize(self) -> text:
        """Serialize to 'platform:tier:path:size:default' colon-delimited format."""
        var default_str = "false"
        if self.is_default:
            default_str = "true"
        self.platform + ":" + self.tier + ":" + self.path + ":" + self.size_bytes.to_text() + ":" + default_str

    fn summary(self) -> text:
        """Human-readable one-line summary of this entry."""
        var default_tag = ""
        if self.is_default:
            default_tag = " [default]"
        self.platform + "/" + self.tier + " -> " + self.path + " (" + self.size_bytes.to_text() + " bytes)" + default_tag

# ============================================================================
# VariantManifest — collection of up to 8 variants (AC-8)
# ============================================================================

class VariantManifest:
    """Flat 8-slot multi-variant manifest for a package.

    Stores up to 8 platform+tier variants without heap allocation.
    Slots are filled in insertion order; unused slots have empty platform.
    """
    package_name: text
    version: text
    entry_count: i32
    v0_platform: text
    v0_tier: text
    v0_path: text
    v0_size: i64
    v0_default: bool
    v1_platform: text
    v1_tier: text
    v1_path: text
    v1_size: i64
    v1_default: bool
    v2_platform: text
    v2_tier: text
    v2_path: text
    v2_size: i64
    v2_default: bool
    v3_platform: text
    v3_tier: text
    v3_path: text
    v3_size: i64
    v3_default: bool
    v4_platform: text
    v4_tier: text
    v4_path: text
    v4_size: i64
    v4_default: bool
    v5_platform: text
    v5_tier: text
    v5_path: text
    v5_size: i64
    v5_default: bool
    v6_platform: text
    v6_tier: text
    v6_path: text
    v6_size: i64
    v6_default: bool
    v7_platform: text
    v7_tier: text
    v7_path: text
    v7_size: i64
    v7_default: bool

impl VariantManifest:

    static fn create(package_name: text, version: text) -> VariantManifest:
        """Create an empty manifest for the given package and version."""
        VariantManifest(
            package_name: package_name,
            version: version,
            entry_count: 0,
            v0_platform: "", v0_tier: "", v0_path: "", v0_size: 0, v0_default: false,
            v1_platform: "", v1_tier: "", v1_path: "", v1_size: 0, v1_default: false,
            v2_platform: "", v2_tier: "", v2_path: "", v2_size: 0, v2_default: false,
            v3_platform: "", v3_tier: "", v3_path: "", v3_size: 0, v3_default: false,
            v4_platform: "", v4_tier: "", v4_path: "", v4_size: 0, v4_default: false,
            v5_platform: "", v5_tier: "", v5_path: "", v5_size: 0, v5_default: false,
            v6_platform: "", v6_tier: "", v6_path: "", v6_size: 0, v6_default: false,
            v7_platform: "", v7_tier: "", v7_path: "", v7_size: 0, v7_default: false
        )

    fn add(self, entry: VariantEntry) -> bool:
        """Add a variant entry. Returns false if all 8 slots are full."""
        if self.entry_count == 0:
            self.v0_platform = entry.platform
            self.v0_tier = entry.tier
            self.v0_path = entry.path
            self.v0_size = entry.size_bytes
            self.v0_default = entry.is_default
            self.entry_count = 1
            true
        elif self.entry_count == 1:
            self.v1_platform = entry.platform
            self.v1_tier = entry.tier
            self.v1_path = entry.path
            self.v1_size = entry.size_bytes
            self.v1_default = entry.is_default
            self.entry_count = 2
            true
        elif self.entry_count == 2:
            self.v2_platform = entry.platform
            self.v2_tier = entry.tier
            self.v2_path = entry.path
            self.v2_size = entry.size_bytes
            self.v2_default = entry.is_default
            self.entry_count = 3
            true
        elif self.entry_count == 3:
            self.v3_platform = entry.platform
            self.v3_tier = entry.tier
            self.v3_path = entry.path
            self.v3_size = entry.size_bytes
            self.v3_default = entry.is_default
            self.entry_count = 4
            true
        elif self.entry_count == 4:
            self.v4_platform = entry.platform
            self.v4_tier = entry.tier
            self.v4_path = entry.path
            self.v4_size = entry.size_bytes
            self.v4_default = entry.is_default
            self.entry_count = 5
            true
        elif self.entry_count == 5:
            self.v5_platform = entry.platform
            self.v5_tier = entry.tier
            self.v5_path = entry.path
            self.v5_size = entry.size_bytes
            self.v5_default = entry.is_default
            self.entry_count = 6
            true
        elif self.entry_count == 6:
            self.v6_platform = entry.platform
            self.v6_tier = entry.tier
            self.v6_path = entry.path
            self.v6_size = entry.size_bytes
            self.v6_default = entry.is_default
            self.entry_count = 7
            true
        elif self.entry_count == 7:
            self.v7_platform = entry.platform
            self.v7_tier = entry.tier
            self.v7_path = entry.path
            self.v7_size = entry.size_bytes
            self.v7_default = entry.is_default
            self.entry_count = 8
            true
        else:
            false

    fn find_best(self, platform: text, tier: text) -> text:
        """Return the path of the first entry matching platform+tier, or '' if none."""
        if self.v0_platform == platform and self.v0_tier == tier:
            self.v0_path
        elif self.v1_platform == platform and self.v1_tier == tier:
            self.v1_path
        elif self.v2_platform == platform and self.v2_tier == tier:
            self.v2_path
        elif self.v3_platform == platform and self.v3_tier == tier:
            self.v3_path
        elif self.v4_platform == platform and self.v4_tier == tier:
            self.v4_path
        elif self.v5_platform == platform and self.v5_tier == tier:
            self.v5_path
        elif self.v6_platform == platform and self.v6_tier == tier:
            self.v6_path
        elif self.v7_platform == platform and self.v7_tier == tier:
            self.v7_path
        else:
            ""

    fn default_path(self) -> text:
        """Return the path of the first entry marked is_default, or '' if none."""
        if self.v0_default:
            self.v0_path
        elif self.v1_default:
            self.v1_path
        elif self.v2_default:
            self.v2_path
        elif self.v3_default:
            self.v3_path
        elif self.v4_default:
            self.v4_path
        elif self.v5_default:
            self.v5_path
        elif self.v6_default:
            self.v6_path
        elif self.v7_default:
            self.v7_path
        else:
            ""

    fn total_size(self) -> i64:
        """Sum of size_bytes across all filled slots."""
        var total: i64 = 0
        if self.entry_count > 0:
            total = total + self.v0_size
        if self.entry_count > 1:
            total = total + self.v1_size
        if self.entry_count > 2:
            total = total + self.v2_size
        if self.entry_count > 3:
            total = total + self.v3_size
        if self.entry_count > 4:
            total = total + self.v4_size
        if self.entry_count > 5:
            total = total + self.v5_size
        if self.entry_count > 6:
            total = total + self.v6_size
        if self.entry_count > 7:
            total = total + self.v7_size
        total

    fn serialize(self) -> text:
        """Serialize the full manifest as structured text (AC-9 round-trip source)."""
        var out = "package:" + self.package_name + "\nversion:" + self.version + "\nentries:" + self.entry_count.to_text()
        if self.entry_count > 0:
            var e0 = VariantEntry.create(self.v0_platform, self.v0_tier, self.v0_path, self.v0_size, self.v0_default)
            out = out + "\n" + e0.serialize()
        if self.entry_count > 1:
            var e1 = VariantEntry.create(self.v1_platform, self.v1_tier, self.v1_path, self.v1_size, self.v1_default)
            out = out + "\n" + e1.serialize()
        if self.entry_count > 2:
            var e2 = VariantEntry.create(self.v2_platform, self.v2_tier, self.v2_path, self.v2_size, self.v2_default)
            out = out + "\n" + e2.serialize()
        if self.entry_count > 3:
            var e3 = VariantEntry.create(self.v3_platform, self.v3_tier, self.v3_path, self.v3_size, self.v3_default)
            out = out + "\n" + e3.serialize()
        if self.entry_count > 4:
            var e4 = VariantEntry.create(self.v4_platform, self.v4_tier, self.v4_path, self.v4_size, self.v4_default)
            out = out + "\n" + e4.serialize()
        if self.entry_count > 5:
            var e5 = VariantEntry.create(self.v5_platform, self.v5_tier, self.v5_path, self.v5_size, self.v5_default)
            out = out + "\n" + e5.serialize()
        if self.entry_count > 6:
            var e6 = VariantEntry.create(self.v6_platform, self.v6_tier, self.v6_path, self.v6_size, self.v6_default)
            out = out + "\n" + e6.serialize()
        if self.entry_count > 7:
            var e7 = VariantEntry.create(self.v7_platform, self.v7_tier, self.v7_path, self.v7_size, self.v7_default)
            out = out + "\n" + e7.serialize()
        out

    fn summary(self) -> text:
        """Human-readable manifest summary."""
        self.package_name + " v" + self.version + " (" + self.entry_count.to_text() + " variants, " + self.total_size().to_text() + " bytes total)"

# ============================================================================
# ManifestParser — deserialize manifest entries (AC-9)
# ============================================================================

class ManifestParser:
    """Stateless parser for manifest entry lines."""
    _unused: bool

impl ManifestParser:

    static fn parse_entry(line: text) -> VariantEntry:
        """Parse 'platform:tier:path:size:default' into a VariantEntry.

        Fields are colon-delimited. The path field must not contain colons.
        On malformed input the platform field will be 'PARSE_ERROR'.
        """
        var platform = ""
        var tier = ""
        var path = ""
        var size_bytes: i64 = 0
        var is_default = false
        var pos = 0
        var field = 0
        var seg = ""
        var len = line.len()
        while pos <= len:
            var ch = ""
            if pos < len:
                ch = line.char_at(pos)
            if ch == ":" or pos == len:
                if field == 0:
                    platform = seg
                elif field == 1:
                    tier = seg
                elif field == 2:
                    path = seg
                elif field == 3:
                    size_bytes = seg.to_i64()
                elif field == 4:
                    is_default = seg == "true"
                seg = ""
                field = field + 1
            else:
                seg = seg + ch
            pos = pos + 1
        if platform == "":
            platform = "PARSE_ERROR"
        VariantEntry.create(platform, tier, path, size_bytes, is_default)

    static fn validate_entry(line: text) -> text:
        """Returns '' if line is a valid entry, or an error description if not."""
        var colon_count = 0
        var pos = 0
        var len = line.len()
        while pos < len:
            if line.char_at(pos) == ":":
                colon_count = colon_count + 1
            pos = pos + 1
        if colon_count != 4:
            "expected 4 colons (platform:tier:path:size:default), found " + colon_count.to_text()
        else:
            ""

# ============================================================================
# VariantSelector — picks best variant from a manifest (AC-8/AC-9)
# ============================================================================

class VariantSelector:
    """Selects the best available variant for a given platform and preferred tier.

    After select(), query is_exact_match()/is_fallback() to understand
    whether the preferred tier was satisfied or a scalar fallback was used.
    """
    platform: text
    preferred_tier: text
    selected_path: text
    selected_tier: text

impl VariantSelector:

    static fn select(platform: text, preferred_tier: text, manifest: VariantManifest) -> VariantSelector:
        """Pick the best variant from manifest for platform+preferred_tier.

        Strategy: exact match first, then scalar fallback for same platform,
        then manifest default, then empty path (no match).
        """
        var best_path = manifest.find_best(platform, preferred_tier)
        var best_tier = preferred_tier
        if best_path == "":
            best_path = manifest.find_best(platform, "scalar")
            best_tier = "scalar"
        if best_path == "":
            best_path = manifest.default_path()
            best_tier = "default"
        VariantSelector(
            platform: platform,
            preferred_tier: preferred_tier,
            selected_path: best_path,
            selected_tier: best_tier
        )

    fn is_exact_match(self) -> bool:
        """True when the selected tier equals the preferred tier."""
        self.selected_tier == self.preferred_tier

    fn is_fallback(self) -> bool:
        """True when a fallback tier was selected instead of the preferred one."""
        self.selected_tier != self.preferred_tier

    fn summary(self) -> text:
        """Human-readable selection result."""
        var match_type = "exact"
        if self.is_fallback():
            match_type = "fallback"
        self.platform + "/" + self.preferred_tier + " -> " + self.selected_path + " [" + self.selected_tier + ", " + match_type + "]"
