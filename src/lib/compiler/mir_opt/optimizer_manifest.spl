# Stub for std.compiler.mir_opt.optimizer_manifest
# Provides the minimal surface needed by test specs (D-5).
# Full-featured dynamic pass loading uses the canonical compiler.mir_opt.optimizer_manifest.

use compiler.mir_opt.mir_opt.mod.{PassScope}
use compiler.mir_opt.optimizer_manifest.{ManifestError}

# Lightweight descriptor used in specs — carries the 3 fields needed by tests.
struct DynamicPassDescriptor:
    name: text
    scope: PassScope
    capability_requires: [text]

# Session-scoped registry for lightweight spec-surface descriptors.
struct DynamicPassRegistry:
    descriptors: [DynamicPassDescriptor]

impl DynamicPassRegistry:
    static fn new() -> DynamicPassRegistry:
        DynamicPassRegistry(descriptors: [])

    fn register(desc: DynamicPassDescriptor) -> Result<DynamicPassRegistry, ManifestError>:
        """Register a single lightweight descriptor."""
        for existing in self.descriptors:
            if existing.name == desc.name:
                return Err(ManifestError.StableNameConflict(desc.name))
        Ok(DynamicPassRegistry(descriptors: self.descriptors.push(desc)))

export DynamicPassDescriptor
export DynamicPassRegistry
export use compiler.mir_opt.optimizer_manifest.{
    ManifestError, manifest_error_message,
    ManifestSchemaVersion, manifest_schema_version_from_int, manifest_schema_version_to_int,
    ManifestPassContract, manifest_pass_contract_default,
    ManifestPassEntry, OptimizerManifest,
    load_manifest_v1, load_manifest_v1_from_parsed,
    validate_manifest, validate_manifest_pass
}
