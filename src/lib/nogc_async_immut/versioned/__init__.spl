# Versioned Snapshot — Multi-Version Concurrency Control (MVCC)
#
# Maintains a history of versioned values so readers can access consistent
# historical snapshots while writers add new versions. Each update creates
# a new version entry; old versions are retained up to a configurable
# maximum history depth and then trimmed from the front.
#
# Architecture:
#   - _versions is an array of [version_number, value] pairs
#   - _current_version is a monotonically increasing i64 counter
#   - _max_history caps the retained history (default 64)
#   - snapshot() returns a frozen Snapshot (version + value pair)
#
# Usage:
#   val vs = VersionedSnapshot__new(100)
#   vs.update(200)
#   vs.update(300)
#   val snap = vs.snapshot()          # Snapshot at version 2, value 300
#   val old = vs.at_version(0)        # 100
#   val hist = vs.history_since(1)    # [[1, 200], [2, 300]]

# ============================================================================
# Snapshot Class
# ============================================================================

# A frozen point-in-time capture of a version number and its value.
# Snapshots are immutable once created.
class Snapshot:
    version: i64
    value

    fn get():
        # Return the snapshot value.
        self.value

    fn get_version() -> i64:
        # Return the snapshot version number.
        self.version

# ============================================================================
# VersionedSnapshot Class
# ============================================================================

# Versioned container that keeps a bounded history of [version, value] pairs.
# Supports MVCC-style reads at any retained version.
class VersionedSnapshot:
    _versions: []        # Array of [version_number, value] entries
    _current_version: i64
    _max_history: i64    # Max number of historical versions to retain

    # ========================================================================
    # Read Operations (immutable -- fn)
    # ========================================================================

    fn current():
        # Return the latest value, or nil if no versions exist.
        val n = self._versions.len()
        if n == 0:
            return nil
        val entry = self._versions[n - 1]
        entry[1]

    fn version() -> i64:
        # Return the current version number.
        self._current_version

    fn at_version(v: i64):
        # Return the value at a specific version, or nil if not found.
        # Linear scan from newest to oldest for typical access patterns.
        var i = self._versions.len() - 1
        while i >= 0:
            val entry = self._versions[i]
            if entry[0] == v:
                return entry[1]
            i = i - 1
        nil

    fn snapshot() -> Snapshot:
        # Return a frozen Snapshot of the current version and value.
        val n = self._versions.len()
        if n == 0:
            return Snapshot(version: self._current_version, value: nil)
        val entry = self._versions[n - 1]
        Snapshot(version: entry[0], value: entry[1])

    fn history():
        # Return a copy of all [version, value] pairs.
        var result = []
        var i = 0
        val n = self._versions.len()
        while i < n:
            result.push(self._versions[i])
            i = i + 1
        result

    fn history_since(v: i64):
        # Return entries with version greater than or equal to v.
        var result = []
        var i = 0
        val n = self._versions.len()
        while i < n:
            val entry = self._versions[i]
            if entry[0] >= v:
                result.push(entry)
            i = i + 1
        result

    fn has_version(v: i64) -> bool:
        # Check if a specific version exists in the retained history.
        var i = 0
        val n = self._versions.len()
        while i < n:
            if self._versions[i][0] == v:
                return true
            i = i + 1
        false

    fn version_count() -> i64:
        # Return the number of stored version entries.
        self._versions.len()

    # ========================================================================
    # Write Operations (mutable -- me)
    # ========================================================================

    me update(new_value):
        # Add a new versioned entry. Increments version, trims old history
        # if it exceeds _max_history.
        self._current_version = self._current_version + 1
        self._versions.push([self._current_version, new_value])
        self._trim()

    me update_with(f):
        # Apply f to the current value and store the result as a new version.
        val cur = self.current()
        val new_value = f(cur)
        self.update(new_value)

    me _trim():
        # Remove oldest entries if history exceeds _max_history.
        while self._versions.len() > self._max_history:
            self._versions.remove(0)

# ============================================================================
# Factory Functions
# ============================================================================

# Create a VersionedSnapshot with an initial value at version 0.
# Uses default max_history of 64.
fn VersionedSnapshot__new(initial) -> VersionedSnapshot:
    VersionedSnapshot(
        _versions: [[0, initial]],
        _current_version: 0,
        _max_history: 64
    )

# Create a VersionedSnapshot with a custom history size.
fn VersionedSnapshot__with_history(initial, max_history: i64) -> VersionedSnapshot:
    VersionedSnapshot(
        _versions: [[0, initial]],
        _current_version: 0,
        _max_history: max_history
    )

# Create a Snapshot directly from a version and value.
fn Snapshot__new(version: i64, value) -> Snapshot:
    Snapshot(version: version, value: value)

# ============================================================================
# Exports
# ============================================================================

export VersionedSnapshot, Snapshot
export VersionedSnapshot__new, VersionedSnapshot__with_history, Snapshot__new
