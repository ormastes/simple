# Persistent List (Cons List)
#
# Immutable singly-linked list using structural sharing.
# - O(1) prepend (cons)
# - O(n) access by index
# - O(1) head/tail
# - All operations return new list — original unchanged.

class PersistentList:
    _node    # nil = empty, [head, tail] = cons cell
    _len: i64

    fn len() -> i64:
        self._len

    fn is_empty() -> bool:
        self._len == 0

    fn head():
        # First element, or nil if empty
        if self._node == nil:
            return nil
        self._node[0]

    fn tail() -> PersistentList:
        # Rest of list without head, or empty if empty
        if self._node == nil:
            return PersistentList(_node: nil, _len: 0)
        PersistentList(_node: self._node[1], _len: self._len - 1)

    fn prepend(value) -> PersistentList:
        # O(1) — add to front
        PersistentList(_node: [value, self._node], _len: self._len + 1)

    fn get(index: i64):
        # O(n) — traverse to index
        if index < 0:
            return nil
        if index >= self._len:
            return nil
        var current = self._node
        var i = 0
        while i < index:
            current = current[1]
            i = i + 1
        current[0]

    fn contains(value) -> bool:
        var current = self._node
        while current != nil:
            if current[0] == value:
                return true
            current = current[1]
        false

    fn reverse() -> PersistentList:
        var result_node = nil
        var current = self._node
        var count = 0
        while current != nil:
            result_node = [current[0], result_node]
            current = current[1]
            count = count + 1
        PersistentList(_node: result_node, _len: count)

    fn map(f: fn()) -> PersistentList:
        # Apply f to each element, return new list (preserves order)
        var items = []
        var current = self._node
        while current != nil:
            items.push(f(current[0]))
            current = current[1]
        PersistentList.from_array(items)

    fn filter(pred: fn()) -> PersistentList:
        var items = []
        var current = self._node
        while current != nil:
            if pred(current[0]):
                items.push(current[0])
            current = current[1]
        PersistentList.from_array(items)

    fn fold(init, f: fn()):
        # Left fold: f(f(f(init, a), b), c)
        var acc = init
        var current = self._node
        while current != nil:
            acc = f(acc, current[0])
            current = current[1]
        acc

    fn to_array():
        var result = []
        var current = self._node
        while current != nil:
            result.push(current[0])
            current = current[1]
        result

    fn concat(other: PersistentList) -> PersistentList:
        # Concatenate: this ++ other
        # Reverse self, then prepend each to other
        val reversed = self.reverse()
        var result = other
        var current = reversed._node
        while current != nil:
            result = result.prepend(current[0])
            current = current[1]
        result

    static fn from_array(arr) -> PersistentList:
        var node = nil
        val n = arr.len()
        var i = n - 1
        while i >= 0:
            node = [arr[i], node]
            i = i - 1
        PersistentList(_node: node, _len: n)

    static fn of(values) -> PersistentList:
        PersistentList.from_array(values)

    static fn empty() -> PersistentList:
        PersistentList(_node: nil, _len: 0)

export PersistentList, PersistentList.empty, PersistentList.of, PersistentList.from_array
