# PersistentMap Builder (Transient)
#
# @tag:api
#
# Mutable batch construction for PersistentMap.
# Use set/set_all to add entries, then .build() to freeze
# into an immutable collection.
#
# Builder methods use `me` (mutable self) for in-place mutation
# during the construction phase. After .build() is called, the
# builder is frozen and further mutations are silently ignored.
#
# Internally uses parallel arrays (_keys and _values) for simplicity.
# The builder avoids circular dependency with PersistentMap by
# returning an array of [key, value] pairs from .build(). The caller
# passes this to PersistentMap.from_entries() to obtain the final
# immutable HAMT-backed map.
#
# Usage:
#   use std.persistent_map.transient.{PersistentMapBuilder, PersistentMapBuilder.new}
#
#   var b = PersistentMapBuilder.new()
#   b.set("name", "Alice")
#   b.set("age", 30)
#   val entries = b.build()
#   # Pass entries to PersistentMap.from_entries(entries) to get immutable map

# ============================================================================
# PersistentMapBuilder
# ============================================================================

class PersistentMapBuilder:
    _keys: []        # Accumulated keys (parallel with _values)
    _values: []      # Accumulated values (parallel with _keys)
    _frozen: bool    # True after build() has been called

    # ------------------------------------------------------------------
    # Mutation (me methods — mutable self)
    # ------------------------------------------------------------------

    # Insert or update a key-value pair.
    # If the key already exists, its value is replaced.
    # Returns self for chaining. No-op if frozen.
    me set(key, value):
        if self._frozen:
            return self
        # Check if key already exists — update in place
        var i = 0
        while i < self._keys.len():
            if self._keys[i] == key:
                self._values[i] = value
                return self
            i = i + 1
        # Key not found — append new entry
        self._keys.push(key)
        self._values.push(value)
        self

    # Add all entries from an array of [key, value] pairs.
    # Returns self for chaining. No-op if frozen.
    me set_all(entries):
        if self._frozen:
            return self
        var i = 0
        while i < entries.len():
            val entry = entries[i]
            self.set(entry[0], entry[1])
            i = i + 1
        self

    # Remove the entry for `key`.
    # Rebuilds internal arrays without that key.
    # Returns self for chaining. No-op if frozen.
    me remove(key):
        if self._frozen:
            return self
        var new_keys = []
        var new_values = []
        var i = 0
        while i < self._keys.len():
            if self._keys[i] != key:
                new_keys.push(self._keys[i])
                new_values.push(self._values[i])
            i = i + 1
        self._keys = new_keys
        self._values = new_values
        self

    # Remove all entries. No-op if frozen.
    me clear():
        if self._frozen:
            return self
        self._keys = []
        self._values = []
        self

    # ------------------------------------------------------------------
    # Read Operations (fn methods — immutable self)
    # ------------------------------------------------------------------

    # Return the number of key-value pairs.
    fn len() -> i64:
        self._keys.len()

    # Return true if no entries have been added.
    fn is_empty() -> bool:
        self._keys.len() == 0

    # Return true if build() has been called.
    fn is_frozen() -> bool:
        self._frozen

    # Check whether `key` exists in the builder.
    fn contains(key) -> bool:
        var i = 0
        while i < self._keys.len():
            if self._keys[i] == key:
                return true
            i = i + 1
        false

    # Get the value for `key`, or nil if not present.
    fn get(key):
        var i = 0
        while i < self._keys.len():
            if self._keys[i] == key:
                return self._values[i]
            i = i + 1
        nil

    # Return an array of all keys (without freezing).
    fn keys():
        var result = []
        var i = 0
        while i < self._keys.len():
            result.push(self._keys[i])
            i = i + 1
        result

    # Return an array of all values (without freezing).
    fn values():
        var result = []
        var i = 0
        while i < self._values.len():
            result.push(self._values[i])
            i = i + 1
        result

    # ------------------------------------------------------------------
    # Freeze / Build
    # ------------------------------------------------------------------

    # Freeze the builder and return entries as an array of [key, value] pairs.
    # The caller should pass this to PersistentMap.from_entries()
    # to get an immutable PersistentMap.
    # After this call, all mutation methods become no-ops.
    me build():
        self._frozen = true
        var entries = []
        var i = 0
        while i < self._keys.len():
            entries.push([self._keys[i], self._values[i]])
            i = i + 1
        entries

    # Return current entries as [key, value] pairs without freezing.
    # Useful for intermediate snapshots during construction.
    fn to_entries():
        var entries = []
        var i = 0
        while i < self._keys.len():
            entries.push([self._keys[i], self._values[i]])
            i = i + 1
        entries

    static fn from_entries(entries) -> PersistentMapBuilder:
        var builder = PersistentMapBuilder.new()
        var i = 0
        while i < entries.len():
            val entry = entries[i]
            builder.set(entry[0], entry[1])
            i = i + 1
        builder

    static fn new() -> PersistentMapBuilder:
        PersistentMapBuilder(_keys: [], _values: [], _frozen: false)

