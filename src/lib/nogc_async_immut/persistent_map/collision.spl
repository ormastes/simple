# Hash Collision Handling for HAMT
#
# When two distinct keys hash to the same 64-bit value, they are stored in a
# collision node — an array of [key, value] pairs sharing the same hash.
# All operations return NEW arrays (no mutation), preserving immutability.
#
# Collision nodes are rare in practice (birthday-paradox probability for
# 64-bit hashes), but correct handling is required for a sound HAMT.

# Get the value associated with `key` in a collision entries array.
# Returns the value if found, nil otherwise.
#
# `entries` is an array of [key, value] pairs.
fn collision_get(entries, key):
    var i = 0
    val n = entries.len()
    while i < n:
        val pair = entries[i]
        if pair[0] == key:
            return pair[1]
        i = i + 1
    nil

# Set or update `key` to `value` in the collision entries array.
# Returns a NEW entries array. If the key exists, its value is replaced.
# If the key is new, it is appended.
fn collision_set(entries, key, value):
    var result = []
    var found = false
    var i = 0
    val n = entries.len()
    while i < n:
        val pair = entries[i]
        if pair[0] == key:
            result.push([key, value])
            found = true
        else:
            result.push(pair)
        i = i + 1
    if not found:
        result.push([key, value])
    result

# Remove `key` from the collision entries array.
# Returns a NEW entries array without the matching pair.
# If the key is not present, returns a copy of the original entries.
fn collision_remove(entries, key):
    var result = []
    var i = 0
    val n = entries.len()
    while i < n:
        val pair = entries[i]
        if pair[0] != key:
            result.push(pair)
        i = i + 1
    result

# Return the number of entries in the collision array.
fn collision_len(entries) -> i64:
    entries.len()

# Check if a key exists in the collision entries array.
fn collision_contains(entries, key) -> bool:
    var i = 0
    val n = entries.len()
    while i < n:
        if entries[i][0] == key:
            return true
        i = i + 1
    false

export collision_get, collision_set, collision_remove, collision_len, collision_contains

