# Pipeline — Composable Transformation Pipeline
#
# @tag:api
#
# A Pipeline accumulates a sequence of transformation steps (map, filter,
# take, drop, flat_map, distinct, chunk) and applies them lazily when
# `run(items)` is called. Every builder method returns a NEW Pipeline
# (immutable — `fn` methods, no `me`), so pipelines are safe to share
# and reuse.
#
# Usage:
#   use std.combinators.pipeline.{Pipeline, Pipeline.new}
#
#   val p = Pipeline.new().filter(\x: x > 0).map(\x: x * 2).take(5)
#   val result = p.run([3, -1, 4, -1, 5, 9, 2, 6])
#   # result == [6, 8, 10, 18, 4]

use std.combinators.{pmap, pfilter, pflat_map, pdistinct, pchunk}

# ============================================================================
# Pipeline Class
# ============================================================================

class Pipeline:
    _steps: []    # Array of [tag, arg] entries

    # ------------------------------------------------------------------
    # Builder methods (each returns a new Pipeline)
    # ------------------------------------------------------------------

    # Add a map step: apply `f` to every element.
    fn map(f) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["map", f])
        Pipeline(_steps: new_steps)

    # Add a filter step: keep items where `pred(item)` is true.
    fn filter(pred) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["filter", pred])
        Pipeline(_steps: new_steps)

    # Add a take step: keep only the first `n` elements.
    fn take(n: i64) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["take", n])
        Pipeline(_steps: new_steps)

    # Add a drop step: skip the first `n` elements.
    fn drop(n: i64) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["drop", n])
        Pipeline(_steps: new_steps)

    # Add a flat_map step: map then flatten.
    fn flat_map(f) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["flat_map", f])
        Pipeline(_steps: new_steps)

    # Add a distinct step: remove duplicates.
    fn distinct() -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["distinct", nil])
        Pipeline(_steps: new_steps)

    # Add a chunk step: split into groups of `size`.
    fn chunk(size: i64) -> Pipeline:
        val new_steps = _pipeline_append(self._steps, ["chunk", size])
        Pipeline(_steps: new_steps)

    # ------------------------------------------------------------------
    # Execution
    # ------------------------------------------------------------------

    # Execute all accumulated steps on `items` and return the result array.
    fn run(items):
        _pipeline_execute(self._steps, items)

    # Execute on `[key, value]` entries (convenience for map `.entries()`).
    fn run_on_entries(items):
        _pipeline_execute(self._steps, items)

    # ------------------------------------------------------------------
    # Inspection
    # ------------------------------------------------------------------

    # Return the number of steps in this pipeline.
    fn len() -> i64:
        self._steps.len()

    # Return true if the pipeline has no steps.
    fn is_empty() -> bool:
        self._steps.len() == 0

    static fn of(steps) -> Pipeline:
        Pipeline(_steps: steps)

    static fn new() -> Pipeline:
        Pipeline(_steps: [])

# ============================================================================
# Internal Helpers
# ============================================================================

# Copy an array and append one element (immutable append).
fn _pipeline_append(arr, item):
    var result = []
    val n = arr.len()
    var i = 0
    while i < n:
        result.push(arr[i])
        i = i + 1
    result.push(item)
    result

# Execute a sequence of steps on input data.
fn _pipeline_execute(steps, items):
    var current = items
    val n = steps.len()
    var i = 0
    while i < n:
        val step = steps[i]
        val tag = step[0]
        val arg = step[1]
        current = _pipeline_apply_step(tag, arg, current)
        i = i + 1
    current

# Apply a single step to the current data.
fn _pipeline_apply_step(tag, arg, data):
    if tag == "map":
        return pmap(data, arg)
    if tag == "filter":
        return pfilter(data, arg)
    if tag == "take":
        return _pipeline_take(data, arg)
    if tag == "drop":
        return _pipeline_drop(data, arg)
    if tag == "flat_map":
        return pflat_map(data, arg)
    if tag == "distinct":
        return pdistinct(data)
    if tag == "chunk":
        return pchunk(data, arg)
    # Unknown tag — pass through unchanged
    data

# Take the first `n` elements from an array.
fn _pipeline_take(items, n: i64):
    val total = items.len()
    var limit = n
    if limit > total:
        limit = total
    if limit <= 0:
        return []
    var result = []
    var i = 0
    while i < limit:
        result.push(items[i])
        i = i + 1
    result

# Drop the first `n` elements from an array.
fn _pipeline_drop(items, n: i64):
    val total = items.len()
    if n >= total:
        return []
    if n <= 0:
        return items
    var result = []
    var i = n
    while i < total:
        result.push(items[i])
        i = i + 1
    result

# ============================================================================
# Factory Functions
# ============================================================================

# ============================================================================
# Exports
# ============================================================================

export Pipeline
export Pipeline__new, Pipeline__of
