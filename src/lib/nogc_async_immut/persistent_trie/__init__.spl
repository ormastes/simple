# Persistent Trie — Immutable Prefix Tree for Text-Keyed Maps
#
# @tag:api
#
# An immutable, persistent trie (prefix tree) optimized for text keys.
# Every mutation (set, remove, filter) returns a NEW trie — the original
# is never modified.
#
# Structural sharing means updates copy only O(L) nodes where L is the
# key length. All other subtrees are shared with the original. This makes
# immutable updates very efficient while providing snapshot consistency.
#
# The trie also supports prefix-based queries — find all keys starting with
# a prefix, or the longest key that is a prefix of a query — in O(P) time
# where P is the prefix length, much faster than scanning all keys.
#
# Thread-safe by construction: immutable values need no locks.
#
# Usage:
#   use std.persistent_trie.{PersistentTrie, PersistentTrie.empty}
#
#   val t0 = PersistentTrie.empty()
#   val t1 = t0.set("apple", 1)
#   val t2 = t1.set("app", 2)
#   val t3 = t2.set("application", 3)
#   print t3.get("app")                   # 2
#   print t3.keys_with_prefix("app")      # ["app", "apple", "application"]
#   print t3.longest_prefix("applesauce") # "apple"
#   print t0.len()                         # 0 (original unchanged)
#   print t3.len()                         # 3

use std.persistent_trie.trie_node.{trie_empty_node, trie_get, trie_set, trie_remove, trie_contains, trie_count, trie_collect_entries, trie_keys_with_prefix, trie_longest_prefix}

# ============================================================================
# PersistentTrie
# ============================================================================

class PersistentTrie:
    root      # Trie node: [value_or_nil, children_dict] or nil
    size: i64

    # ------------------------------------------------------------------
    # Lookup
    # ------------------------------------------------------------------

    # Get the value associated with `key`, or nil if not present.
    fn get(key: text):
        trie_get(self.root, key, 0)

    # Get the value associated with `key`, or `default_val` if not present.
    fn get_or(key: text, default_val):
        val result = trie_get(self.root, key, 0)
        if result != nil:
            return result
        default_val

    # Check whether `key` exists in the trie.
    fn contains(key: text) -> bool:
        trie_contains(self.root, key, 0)

    # ------------------------------------------------------------------
    # Mutation (returns new trie)
    # ------------------------------------------------------------------

    # Insert or update `key` with `value`. Returns a NEW trie.
    fn set(key: text, value) -> PersistentTrie:
        val new_root = trie_set(self.root, key, value, 0)
        # Determine new size: if the key was already present, size stays the same
        val old_val = trie_get(self.root, key, 0)
        var new_size = self.size
        if old_val == nil:
            new_size = self.size + 1
        PersistentTrie(root: new_root, size: new_size)

    # Remove `key` from the trie. Returns a NEW trie.
    # If the key is not present, returns this trie unchanged.
    fn remove(key: text) -> PersistentTrie:
        val old_val = trie_get(self.root, key, 0)
        if old_val == nil:
            # Key not present — no change
            return self
        val new_root = trie_remove(self.root, key, 0)
        PersistentTrie(root: new_root, size: self.size - 1)

    # ------------------------------------------------------------------
    # Size queries
    # ------------------------------------------------------------------

    # Return the number of key-value pairs.
    fn len() -> i64:
        self.size

    # Return true if the trie is empty.
    fn is_empty() -> bool:
        self.size == 0

    # ------------------------------------------------------------------
    # Prefix operations
    # ------------------------------------------------------------------

    # Return an array of all keys that start with the given prefix.
    fn keys_with_prefix(prefix: text):
        var result = []
        trie_keys_with_prefix(self.root, prefix, 0, prefix, result)
        result

    # Return the longest key in the trie that is a prefix of `query`.
    # Returns nil if no key is a prefix of the query.
    fn longest_prefix(query: text):
        trie_longest_prefix(self.root, query, 0, nil)

    # ------------------------------------------------------------------
    # Higher-order operations
    # ------------------------------------------------------------------

    # Return a new trie containing only entries where `pred(key, value)` is true.
    fn filter(pred: fn()) -> PersistentTrie:
        var result = PersistentTrie.empty()
        val all_entries = self.entries()
        var i = 0
        val n = all_entries.len()
        while i < n:
            val pair = all_entries[i]
            if pred(pair[0], pair[1]):
                result = result.set(pair[0], pair[1])
            i = i + 1
        result

    # Fold (reduce) over all entries.
    # `f(accumulator, key, value)` is called for each entry.
    fn fold(init, f: fn()):
        var acc = init
        val all_entries = self.entries()
        var i = 0
        val n = all_entries.len()
        while i < n:
            val pair = all_entries[i]
            acc = f(acc, pair[0], pair[1])
            i = i + 1
        acc

    # Return a new trie with all values transformed by `f(key, value)`.
    fn map_values(f: fn()) -> PersistentTrie:
        var result = PersistentTrie.empty()
        val all_entries = self.entries()
        var i = 0
        val n = all_entries.len()
        while i < n:
            val pair = all_entries[i]
            result = result.set(pair[0], f(pair[1]))
            i = i + 1
        result

    # Update a single key by applying `f(current_value)`.
    # If the key does not exist, `f(nil)` is called.
    fn update(key: text, f: fn()) -> PersistentTrie:
        val current = self.get(key)
        val new_val = f(current)
        self.set(key, new_val)

    # ------------------------------------------------------------------
    # Iteration / conversion
    # ------------------------------------------------------------------

    # Return an array of all keys.
    fn keys():
        val all_entries = self.entries()
        var result = []
        var i = 0
        val n = all_entries.len()
        while i < n:
            result.push(all_entries[i][0])
            i = i + 1
        result

    # Return an array of all values.
    fn values():
        val all_entries = self.entries()
        var result = []
        var i = 0
        val n = all_entries.len()
        while i < n:
            result.push(all_entries[i][1])
            i = i + 1
        result

    # Return an array of [key, value] pairs.
    fn entries():
        var result = []
        trie_collect_entries(self.root, "", result)
        result

    # Convert to a mutable dict (built-in hash map).
    fn to_dict():
        var result = {}
        val all_entries = self.entries()
        var i = 0
        val n = all_entries.len()
        while i < n:
            val pair = all_entries[i]
            result[pair[0]] = pair[1]
            i = i + 1
        result

    # Return a copy (identity for immutable structures, provided for
    # API compatibility).
    fn copy() -> PersistentTrie:
        PersistentTrie(root: self.root, size: self.size)

    static fn from_dict(d) -> PersistentTrie:
        var result = PersistentTrie.empty()
        for k in d:
            result = result.set(k, d[k])
        result

    static fn from_entries(entries) -> PersistentTrie:
        var result = PersistentTrie.empty()
        var i = 0
        val n = entries.len()
        while i < n:
            val pair = entries[i]
            result = result.set(pair[0], pair[1])
            i = i + 1
        result

    static fn empty() -> PersistentTrie:
        PersistentTrie(root: nil, size: 0)

# ============================================================================
# Factory Functions
# ============================================================================

# ============================================================================
# Exports
# ============================================================================

export PersistentTrie
export PersistentTrie.empty, PersistentTrie.from_entries, PersistentTrie.from_dict

# Re-exported from trie_node.spl
export trie_empty_node
export trie_copy_dict
export trie_get, trie_set, trie_remove
export trie_contains, trie_count
export trie_collect_entries, trie_keys_with_prefix, trie_collect_keys
export trie_longest_prefix
export trie_dict_has_keys, trie_dict_without
