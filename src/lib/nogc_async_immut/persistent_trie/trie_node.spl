# Trie Node Operations — Persistent Prefix Tree
#
# Core operations for a persistent (immutable) trie keyed by text strings.
# Every mutation returns a NEW node tree with structural sharing — the
# original is never modified.
#
# Node representation (tag-based arrays):
#   EMPTY = nil
#   NODE  = [value_or_nil, children]
#     - value_or_nil: nil if no value stored at this prefix, otherwise the value
#     - children: array of [single_character_text, child_node] pairs
#
# The trie walks one character at a time. For a key of length L, lookup and
# insertion are O(L). Structural sharing means only O(L) nodes are copied on
# update — all other subtrees are shared with the original.

# ============================================================================
# Node Constructor
# ============================================================================

# Create a new empty trie node (no value, no children).
pub fn trie_empty_node():
    [nil, []]

# ============================================================================
# Children Helpers
# ============================================================================

# Copy children for path-copy persistence.
pub fn trie_copy_dict(children: []) -> []:
    var result = []
    var i = 0
    val n = children.len()
    while i < n:
        val pair = children[i]
        result.push([pair[0], pair[1]])
        i = i + 1
    result

fn trie_child_get(children: [], ch):
    var i = 0
    val n = children.len()
    while i < n:
        val pair = children[i]
        if pair[0] == ch:
            return pair[1]
        i = i + 1
    nil

fn trie_child_set(children: [], ch, child) -> []:
    var result = []
    var replaced = false
    var i = 0
    val n = children.len()
    while i < n:
        val pair = children[i]
        if pair[0] == ch:
            result.push([ch, child])
            replaced = true
        else:
            result.push([pair[0], pair[1]])
        i = i + 1
    if not replaced:
        result.push([ch, child])
    result

# Convert a text key once before recursive trie walks. Compiled native BDD
# currently miscompiles recursive calls that carry text parameters.
fn trie_key_chars(key: text) -> []:
    var chars: [text] = []
    var i = 0
    val n = key.len()
    while i < n:
        chars.push(key[i])
        i = i + 1
    chars

# ============================================================================
# Core Operations
# ============================================================================

# Look up a key in the trie.
# Returns the associated value, or nil if the key is not present.
#
# Parameters:
#   node  — the current trie node (nil or [value, children])
#   key   — the text key to search for
#   depth — current character index (0 at root)
pub fn trie_get(node, key: text, depth: i64):
    val chars = trie_key_chars(key)
    trie_get_chars(node, chars, depth)

fn trie_get_chars(node, chars, depth: i64):
    if node == nil:
        return nil
    val key_len = chars.len()
    if depth == key_len:
        return node[0]
    val ch = chars[depth]
    val children = node[1]
    val child = trie_child_get(children, ch)
    if child == nil:
        return nil
    trie_get_chars(child, chars, depth + 1)

# Insert or update a key-value pair in the trie.
# Returns a NEW node tree (structural sharing with the original).
#
# Parameters:
#   node  — the current trie node (nil or [value, children])
#   key   — the text key to insert/update
#   value — the value to associate
#   depth — current character index (0 at root)
pub fn trie_set(node, key: text, value, depth: i64):
    val chars = trie_key_chars(key)
    trie_set_chars(node, chars, value, depth)

fn trie_set_chars(node, chars, value, depth: i64):
    val key_len = chars.len()
    if node == nil:
        # Build new path from here to the end of the key
        if depth == key_len:
            return [value, []]
        val ch = chars[depth]
        val child = trie_set_chars(nil, chars, value, depth + 1)
        var children = []
        children.push([ch, child])
        return [nil, children]
    if depth == key_len:
        # Set value at this node, preserve children
        return [value, node[1]]
    val ch = chars[depth]
    val children = node[1]
    val existing = trie_child_get(children, ch)
    val new_child = trie_set_chars(existing, chars, value, depth + 1)
    # Path-copy: copy the children and update the one child.
    val new_children = trie_child_set(children, ch, new_child)
    [node[0], new_children]

# Remove a key from the trie.
# Returns a NEW node tree with the key's value removed.
# Prunes empty subtrees to avoid waste.
# Returns nil if the entire subtree becomes empty.
#
# Parameters:
#   node  — the current trie node
#   key   — the text key to remove
#   depth — current character index (0 at root)
pub fn trie_remove(node, key: text, depth: i64):
    val chars = trie_key_chars(key)
    trie_remove_chars(node, chars, depth)

fn trie_remove_chars(node, chars, depth: i64):
    if node == nil:
        return nil
    val key_len = chars.len()
    if depth == key_len:
        # Remove value at this node
        val children = node[1]
        # Check if children dict is empty
        val has_children = trie_dict_has_keys(children)
        if not has_children:
            # No value and no children — prune this node entirely
            return nil
        # Keep node alive for children, just remove value
        return [nil, children]
    val ch = chars[depth]
    val children = node[1]
    val child = trie_child_get(children, ch)
    if child == nil:
        # Key not in trie — return unchanged
        return node
    val new_child = trie_remove_chars(child, chars, depth + 1)
    if new_child == child:
        # Nothing changed
        return node
    var new_children = trie_copy_dict(children)
    if new_child == nil:
        # Child was pruned — remove it from children
        new_children = trie_dict_without(children, ch)
    else:
        new_children = trie_child_set(children, ch, new_child)
    # Check if this node is now empty (no value, no children)
    val has_remaining = trie_dict_has_keys(new_children)
    if node[0] == nil:
        if not has_remaining:
            return nil
    [node[0], new_children]

# Check whether a key exists in the trie (has a non-nil value).
#
# Parameters:
#   node  — the current trie node
#   key   — the text key to check
#   depth — current character index (0 at root)
pub fn trie_contains(node, key: text, depth: i64) -> bool:
    val chars = trie_key_chars(key)
    trie_contains_chars(node, chars, depth)

fn trie_contains_chars(node, chars, depth: i64) -> bool:
    if node == nil:
        return false
    val key_len = chars.len()
    if depth == key_len:
        return node[0] != nil
    val ch = chars[depth]
    val children = node[1]
    val child = trie_child_get(children, ch)
    if child == nil:
        return false
    trie_contains_chars(child, chars, depth + 1)

# Count all stored values in the trie (DFS traversal).
pub fn trie_count(node) -> i64:
    if node == nil:
        return 0
    var total = 0
    if node[0] != nil:
        total = 1
    val children = node[1]
    var i = 0
    val n = children.len()
    while i < n:
        total = total + trie_count(children[i][1])
        i = i + 1
    total

# ============================================================================
# Traversal / Collection
# ============================================================================

# Collect all [key, value] pairs from the trie via DFS.
# Returns an array of [key, value] pairs.
#
# Parameters:
#   node   — the current trie node
#   prefix — the key built so far (characters traversed)
pub fn trie_collect_entries(node, prefix: text):
    if node == nil:
        return []
    var result = []
    if node[0] != nil:
        result.push([prefix, node[0]])
    val children = node[1]
    var child_index = 0
    val child_count = children.len()
    while child_index < child_count:
        val pair = children[child_index]
        val child_entries = trie_collect_entries(pair[1], prefix + pair[0])
        var i = 0
        val n = child_entries.len()
        while i < n:
            result.push(child_entries[i])
            i = i + 1
        child_index = child_index + 1
    result

# Find all keys that start with the given prefix.
# Navigates to the prefix node, then collects all keys below it.
# Returns an array of matching keys.
#
# Parameters:
#   node         — the current trie node
#   prefix       — the prefix text to search for
#   prefix_depth — current character index into the prefix
#   full_prefix  — the original full prefix string (for building result keys)
pub fn trie_keys_with_prefix(node, prefix: text, prefix_depth: i64, full_prefix: text):
    val chars = trie_key_chars(prefix)
    trie_keys_with_prefix_chars(node, chars, prefix_depth, full_prefix)

fn trie_keys_with_prefix_chars(node, chars, prefix_depth: i64, full_prefix: text):
    if node == nil:
        return []
    val prefix_len = chars.len()
    if prefix_depth == prefix_len:
        # Reached the prefix node — collect all keys below
        return trie_collect_keys(node, full_prefix)
    val ch = chars[prefix_depth]
    val children = node[1]
    val child = trie_child_get(children, ch)
    if child == nil:
        return []
    trie_keys_with_prefix_chars(child, chars, prefix_depth + 1, full_prefix)

# Collect all keys from a subtree. Used after navigating to a prefix node.
# Returns an array of keys.
pub fn trie_collect_keys(node, prefix: text):
    if node == nil:
        return []
    var result = []
    if node[0] != nil:
        result.push(prefix)
    val children = node[1]
    var child_index = 0
    val child_count = children.len()
    while child_index < child_count:
        val pair = children[child_index]
        val child_keys = trie_collect_keys(pair[1], prefix + pair[0])
        var i = 0
        val n = child_keys.len()
        while i < n:
            result.push(child_keys[i])
            i = i + 1
        child_index = child_index + 1
    result

# Find the longest key in the trie that is a prefix of the given query string.
# Returns the longest matching prefix text, or nil if no prefix matches.
#
# Parameters:
#   node  — the current trie node
#   query — the query text to find prefixes of
#   depth — current character index (0 at root)
#   last_match — the longest prefix found so far (nil or text)
pub fn trie_longest_prefix(node, query: text, depth: i64, last_match):
    val chars = trie_key_chars(query)
    trie_longest_prefix_chars(node, chars, depth, last_match)

fn trie_longest_prefix_chars(node, chars, depth: i64, last_match):
    if node == nil:
        return last_match
    var current_match = last_match
    if node[0] != nil:
        # This node's prefix is a valid key — record it
        val prefix_len = depth
        var prefix_chars: [text] = []
        var j = 0
        while j < prefix_len:
            prefix_chars.push(chars[j])
            j = j + 1
        current_match = prefix_chars.join("")
    val query_len = chars.len()
    if depth == query_len:
        return current_match
    val ch = chars[depth]
    val children = node[1]
    val child = trie_child_get(children, ch)
    if child == nil:
        return current_match
    trie_longest_prefix_chars(child, chars, depth + 1, current_match)

# ============================================================================
# Dict Helpers
# ============================================================================

# Check if a children array has any entries.
fn trie_dict_has_keys(children: []) -> bool:
    children.len() > 0

# Return a copy of children with key `skip_key` removed.
fn trie_dict_without(children: [], skip_key) -> []:
    var result = []
    var i = 0
    val n = children.len()
    while i < n:
        val pair = children[i]
        if pair[0] != skip_key:
            result.push([pair[0], pair[1]])
        i = i + 1
    result

# ============================================================================
# Exports
# ============================================================================

export trie_empty_node
export trie_copy_dict
export trie_get, trie_set, trie_remove
export trie_contains, trie_count
export trie_collect_entries, trie_keys_with_prefix, trie_collect_keys
export trie_longest_prefix
export trie_dict_has_keys, trie_dict_without
