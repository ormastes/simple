#![allow(unnamed_duplicate_typed_args)]
# Trie Node Operations — Persistent Prefix Tree
#
# Core operations for a persistent (immutable) trie keyed by text strings.
# Every mutation returns a NEW node tree with structural sharing — the
# original is never modified.
#
# Node representation (tag-based arrays):
#   EMPTY = nil
#   NODE  = [value_or_nil, children_dict]
#     - value_or_nil: nil if no value stored at this prefix, otherwise the value
#     - children_dict: a dict {} mapping single-character keys to child nodes
#
# The trie walks one character at a time. For a key of length L, lookup and
# insertion are O(L). Structural sharing means only O(L) nodes are copied on
# update — all other subtrees are shared with the original.

# ============================================================================
# Node Constructor
# ============================================================================

# Create a new empty trie node (no value, no children).
fn trie_empty_node():
    [nil, {}]

# ============================================================================
# Dict Copy Helper
# ============================================================================

# Copy a dict for path-copy persistence.
# Simple dicts are mutable, so we must copy before mutating to avoid
# modifying the original trie.
fn trie_copy_dict(d):
    var result = {}
    for k in d:
        result[k] = d[k]
    result

# ============================================================================
# Core Operations
# ============================================================================

# Look up a key in the trie.
# Returns the associated value, or nil if the key is not present.
#
# Parameters:
#   node  — the current trie node (nil or [value, children])
#   key   — the text key to search for
#   depth — current character index (0 at root)
fn trie_get(node, key: text, depth: i64):
    if node == nil:
        return nil
    val key_len = key.len()
    if depth == key_len:
        return node[0]
    val ch = key[depth]
    val children = node[1]
    val child = children[ch]
    if child == nil:
        return nil
    trie_get(child, key, depth + 1)

# Insert or update a key-value pair in the trie.
# Returns a NEW node tree (structural sharing with the original).
#
# Parameters:
#   node  — the current trie node (nil or [value, children])
#   key   — the text key to insert/update
#   value — the value to associate
#   depth — current character index (0 at root)
fn trie_set(node, key: text, value, depth: i64):
    val key_len = key.len()
    if node == nil:
        # Build new path from here to the end of the key
        if depth == key_len:
            return [value, {}]
        val ch = key[depth]
        val child = trie_set(nil, key, value, depth + 1)
        var children = {}
        children[ch] = child
        return [nil, children]
    if depth == key_len:
        # Set value at this node, preserve children
        return [value, node[1]]
    val ch = key[depth]
    val children = node[1]
    val existing = children[ch]
    val new_child = trie_set(existing, key, value, depth + 1)
    # Path-copy: copy the children dict and update the one child
    var new_children = trie_copy_dict(children)
    new_children[ch] = new_child
    [node[0], new_children]

# Remove a key from the trie.
# Returns a NEW node tree with the key's value removed.
# Prunes empty subtrees to avoid waste.
# Returns nil if the entire subtree becomes empty.
#
# Parameters:
#   node  — the current trie node
#   key   — the text key to remove
#   depth — current character index (0 at root)
fn trie_remove(node, key: text, depth: i64):
    if node == nil:
        return nil
    val key_len = key.len()
    if depth == key_len:
        # Remove value at this node
        val children = node[1]
        # Check if children dict is empty
        val has_children = trie_dict_has_keys(children)
        if not has_children:
            # No value and no children — prune this node entirely
            return nil
        # Keep node alive for children, just remove value
        return [nil, children]
    val ch = key[depth]
    val children = node[1]
    val child = children[ch]
    if child == nil:
        # Key not in trie — return unchanged
        return node
    val new_child = trie_remove(child, key, depth + 1)
    if new_child == child:
        # Nothing changed
        return node
    var new_children = trie_copy_dict(children)
    if new_child == nil:
        # Child was pruned — remove it from dict
        new_children = trie_dict_without(children, ch)
    else:
        new_children[ch] = new_child
    # Check if this node is now empty (no value, no children)
    val has_remaining = trie_dict_has_keys(new_children)
    if node[0] == nil:
        if not has_remaining:
            return nil
    [node[0], new_children]

# Check whether a key exists in the trie (has a non-nil value).
#
# Parameters:
#   node  — the current trie node
#   key   — the text key to check
#   depth — current character index (0 at root)
fn trie_contains(node, key: text, depth: i64) -> bool:
    if node == nil:
        return false
    val key_len = key.len()
    if depth == key_len:
        return node[0] != nil
    val ch = key[depth]
    val children = node[1]
    val child = children[ch]
    if child == nil:
        return false
    trie_contains(child, key, depth + 1)

# Count all stored values in the trie (DFS traversal).
fn trie_count(node) -> i64:
    if node == nil:
        return 0
    var total = 0
    if node[0] != nil:
        total = 1
    val children = node[1]
    for ch in children:
        total = total + trie_count(children[ch])
    total

# ============================================================================
# Traversal / Collection
# ============================================================================

# Collect all [key, value] pairs from the trie via DFS.
# Returns an array of [key, value] pairs.
#
# Parameters:
#   node   — the current trie node
#   prefix — the key built so far (characters traversed)
fn trie_collect_entries(node, prefix: text):
    if node == nil:
        return []
    var result = []
    if node[0] != nil:
        result.push([prefix, node[0]])
    val children = node[1]
    for ch in children:
        val child_entries = trie_collect_entries(children[ch], prefix + ch)
        var i = 0
        val n = child_entries.len()
        while i < n:
            result.push(child_entries[i])
            i = i + 1
    result

# Find all keys that start with the given prefix.
# Navigates to the prefix node, then collects all keys below it.
# Returns an array of matching keys.
#
# Parameters:
#   node         — the current trie node
#   prefix       — the prefix text to search for
#   prefix_depth — current character index into the prefix
#   full_prefix  — the original full prefix string (for building result keys)
fn trie_keys_with_prefix(node, prefix: text, prefix_depth: i64, full_prefix: text):
    if node == nil:
        return []
    val prefix_len = prefix.len()
    if prefix_depth == prefix_len:
        # Reached the prefix node — collect all keys below
        return trie_collect_keys(node, full_prefix)
    val ch = prefix[prefix_depth]
    val children = node[1]
    val child = children[ch]
    if child == nil:
        return []
    trie_keys_with_prefix(child, prefix, prefix_depth + 1, full_prefix)

# Collect all keys from a subtree. Used after navigating to a prefix node.
# Returns an array of keys.
fn trie_collect_keys(node, prefix: text):
    if node == nil:
        return []
    var result = []
    if node[0] != nil:
        result.push(prefix)
    val children = node[1]
    for ch in children:
        val child_keys = trie_collect_keys(children[ch], prefix + ch)
        var i = 0
        val n = child_keys.len()
        while i < n:
            result.push(child_keys[i])
            i = i + 1
    result

# Find the longest key in the trie that is a prefix of the given query string.
# Returns the longest matching prefix text, or nil if no prefix matches.
#
# Parameters:
#   node  — the current trie node
#   query — the query text to find prefixes of
#   depth — current character index (0 at root)
#   last_match — the longest prefix found so far (nil or text)
fn trie_longest_prefix(node, query: text, depth: i64, last_match):
    if node == nil:
        return last_match
    var current_match = last_match
    if node[0] != nil:
        # This node's prefix is a valid key — record it
        val prefix_len = depth
        var prefix_text = ""
        var j = 0
        while j < prefix_len:
            prefix_text = prefix_text + query[j]
            j = j + 1
        current_match = prefix_text
    val query_len = query.len()
    if depth == query_len:
        return current_match
    val ch = query[depth]
    val children = node[1]
    val child = children[ch]
    if child == nil:
        return current_match
    trie_longest_prefix(child, query, depth + 1, current_match)

# ============================================================================
# Dict Helpers
# ============================================================================

# Check if a dict has any keys.
fn trie_dict_has_keys(d) -> bool:
    for k in d:
        return true
    false

# Return a copy of dict `d` with key `skip_key` removed.
fn trie_dict_without(d, skip_key):
    var result = {}
    for k in d:
        if k != skip_key:
            result[k] = d[k]
    result

# ============================================================================
# Exports
# ============================================================================

export trie_empty_node
export trie_copy_dict
export trie_get, trie_set, trie_remove
export trie_contains, trie_count
export trie_collect_entries, trie_keys_with_prefix, trie_collect_keys
export trie_longest_prefix
export trie_dict_has_keys, trie_dict_without

