#![allow(unknown_attribute)]
@no_gc

# nogc_async_immut — Immutable Persistent Data Structures for Lock-Free Concurrency
#
# This library variant provides persistent data structures with structural sharing
# and lock-free coordination primitives for concurrent programming.
#
# Architecture:
#   Data Structures:
#   - PersistentMap: HAMT-based immutable hash map (O(log32 n) ops)
#   - PersistentSet: Set wrapper over PersistentMap
#   - PersistentVec: RRB-tree backed immutable vector (amortized O(1) push)
#   - PersistentList: Cons list with O(1) prepend
#   - PersistentSortedMap: LLRB red-black tree for sorted keys
#   - PersistentTrie: Prefix tree for text-keyed maps
#
#   Coordination:
#   - Atom: CAS-based mutable reference to immutable value
#   - Ref: Validated Atom with state transition guards
#   - VersionedSnapshot: MVCC version-stamped reads with history
#   - ActorSnapshot: Zero-copy persistent message snapshots
#
#   Functional:
#   - Combinators: pmap, pfilter, pfold, pzip, etc.
#   - Pipeline: Composable transformation chains
#
#   Builders:
#   - PersistentVecBuilder: Mutable batch construction for vectors
#   - PersistentMapBuilder: Mutable batch construction for maps
#
# Design principles:
#   - No var, no me methods on data structures (everything returns new version)
#   - Atom, Ref, VersionedSnapshot, ActorState use `me` for coordinated mutation
#   - Structural sharing (O(log n) updates, not O(n) copies)
#   - Lock-free coordination via CAS atoms

fn nogc_async_immut_version() -> text:
    "0.1.0"

export nogc_async_immut_version
