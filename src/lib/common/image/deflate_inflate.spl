#![allow(unnamed_duplicate_typed_args)]
# DEFLATE Inflate — Minimal DEFLATE decompression
#
# Handles uncompressed (stored) blocks, fixed Huffman blocks with LZ77,
# and falls back to fixed Huffman for dynamic Huffman blocks.
#
# Adapted from examples/browser/feature/paint/image_decode.spl:373-640
# with type conversion from [i64] to [u8] input.
#
# DEFLATE format reference: RFC 1951

# ============================================================================
# Public API
# ============================================================================

fn deflate_inflate(compressed: [u8], skip_bytes: i32) -> [u8]:
    """Inflate DEFLATE-compressed data.

    Args:
        compressed: Compressed byte array (may include zlib/gzip header)
        skip_bytes: Number of header bytes to skip before DEFLATE stream

    Returns:
        Decompressed byte array
    """
    if compressed.len().to_i32() <= skip_bytes:
        return []

    var output: [u8] = []
    var bit_pos: i64 = skip_bytes.to_i64() * 8
    val total_bits: i64 = compressed.len().to_i64() * 8

    var done = false
    while not done:
        if bit_pos + 3 > total_bits:
            done = true
        else:
            val bfinal = read_bits(compressed, bit_pos, 1)
            bit_pos = bit_pos + 1
            val btype = read_bits(compressed, bit_pos, 2)
            bit_pos = bit_pos + 2

            if btype == 0:
                # Stored block (uncompressed)
                # Align to byte boundary
                val byte_aligned = ((bit_pos + 7) / 8) * 8
                bit_pos = byte_aligned
                val byte_off = bit_pos / 8
                val block_len = get_byte(compressed, byte_off) + get_byte(compressed, byte_off + 1) * 256
                bit_pos = bit_pos + 32  # skip LEN and NLEN
                var i: i64 = 0
                while i < block_len:
                    val b = get_byte(compressed, bit_pos / 8)
                    output = output + [b.to_u8()]
                    bit_pos = bit_pos + 8
                    i = i + 1
            else if btype == 1:
                # Fixed Huffman codes
                val inflate_result = inflate_fixed_huffman(compressed, bit_pos, output)
                bit_pos = inflate_result.first
                output = inflate_result.second
            else if btype == 2:
                # Dynamic Huffman codes — fall back to fixed for simplicity
                val inflate_result = inflate_fixed_huffman(compressed, bit_pos, output)
                bit_pos = inflate_result.first
                output = inflate_result.second
            else:
                done = true  # Invalid block type

            if bfinal == 1:
                done = true

    output

# ============================================================================
# Fixed Huffman Inflate
# ============================================================================

fn inflate_fixed_huffman(data: [u8], start_bit: i64, output: [u8]) -> Pair<i64, [u8]>:
    """Inflate a fixed Huffman block.

    Returns (new_bit_pos, output_data).
    """
    var bit_pos = start_bit
    var out = output
    val total_bits: i64 = data.len().to_i64() * 8

    var block_done = false
    while not block_done:
        if bit_pos + 7 > total_bits:
            block_done = true
        else:
            # Decode a fixed Huffman literal/length symbol
            val symbol_result = decode_fixed_lit(data, bit_pos)
            val symbol = symbol_result.first
            bit_pos = symbol_result.second

            if symbol < 256:
                # Literal byte
                out = out + [symbol.to_u8()]
            else if symbol == 256:
                # End of block
                block_done = true
            else:
                # Length-distance pair (LZ77 back-reference)
                val length = decode_length(symbol, data, bit_pos)
                bit_pos = bit_pos + length_extra_bits(symbol)

                # Decode distance (5-bit fixed code, reversed)
                val dist_code = read_bits_rev(data, bit_pos, 5)
                bit_pos = bit_pos + 5
                val distance = decode_distance(dist_code, data, bit_pos)
                bit_pos = bit_pos + distance_extra_bits(dist_code)

                # Copy from sliding window
                var i: i64 = 0
                while i < length:
                    val src_idx = out.len().to_i64() - distance
                    if src_idx >= 0 and src_idx < out.len().to_i64():
                        out = out + [out[src_idx.to_i32()]]
                    else:
                        out = out + [0]
                    i = i + 1

    Pair(first: bit_pos, second: out)

# ============================================================================
# Fixed Huffman Literal/Length Decoder
# ============================================================================

fn decode_fixed_lit(data: [u8], bit_pos: i64) -> Pair<i64, i64>:
    """Decode a fixed Huffman literal/length code.

    Returns (symbol, new_bit_pos).
    Fixed Huffman code table:
      0-143:   8-bit codes 00110000-10111111
      144-255: 9-bit codes 110010000-111111111
      256-279: 7-bit codes 0000000-0010111
      280-287: 8-bit codes 11000000-11000111
    """
    # Try 7-bit code first (256-279)
    val code7 = read_bits_rev(data, bit_pos, 7)
    if code7 >= 0 and code7 <= 23:
        return Pair(first: 256 + code7, second: bit_pos + 7)

    # Try 8-bit code (0-143 or 280-287)
    val code8 = read_bits_rev(data, bit_pos, 8)
    if code8 >= 48 and code8 <= 191:
        return Pair(first: code8 - 48, second: bit_pos + 8)
    if code8 >= 192 and code8 <= 199:
        return Pair(first: 280 + (code8 - 192), second: bit_pos + 8)

    # Try 9-bit code (144-255)
    val code9 = read_bits_rev(data, bit_pos, 9)
    if code9 >= 400 and code9 <= 511:
        return Pair(first: 144 + (code9 - 400), second: bit_pos + 9)

    # Fallback: treat as end of block
    Pair(first: 256, second: bit_pos + 7)

# ============================================================================
# Bit-Level I/O
# ============================================================================

fn read_bits(data: [u8], bit_pos: i64, count: i64) -> i64:
    """Read N bits from byte array at bit offset (LSB first)."""
    var result: i64 = 0
    var i: i64 = 0
    while i < count:
        val byte_idx = (bit_pos + i) / 8
        val bit_idx = (bit_pos + i) % 8
        val byte_val = get_byte(data, byte_idx)
        val bit_val = (byte_val / pow2(bit_idx)) % 2
        result = result + bit_val * pow2(i)
        i = i + 1
    result

fn read_bits_rev(data: [u8], bit_pos: i64, count: i64) -> i64:
    """Read N bits in reverse order (MSB first, for Huffman codes)."""
    var result: i64 = 0
    var i: i64 = 0
    while i < count:
        val byte_idx = (bit_pos + i) / 8
        val bit_idx = (bit_pos + i) % 8
        val byte_val = get_byte(data, byte_idx)
        val bit_val = (byte_val / pow2(bit_idx)) % 2
        result = result * 2 + bit_val
        i = i + 1
    result

fn get_byte(data: [u8], idx: i64) -> i64:
    """Safely get a byte from array, returning 0 for out-of-bounds."""
    if idx >= 0 and idx < data.len().to_i64():
        return data[idx.to_i32()].to_i64()
    0

fn pow2(n: i64) -> i64:
    """Power of 2 lookup."""
    if n <= 0: return 1
    if n == 1: return 2
    if n == 2: return 4
    if n == 3: return 8
    if n == 4: return 16
    if n == 5: return 32
    if n == 6: return 64
    if n == 7: return 128
    if n == 8: return 256
    if n == 9: return 512
    if n == 10: return 1024
    if n == 11: return 2048
    if n == 12: return 4096
    if n == 13: return 8192
    if n == 14: return 16384
    if n == 15: return 32768
    # Compute iteratively for larger values
    var result: i64 = 1
    var i: i64 = 0
    while i < n:
        result = result * 2
        i = i + 1
    result

# ============================================================================
# Length/Distance Tables (DEFLATE RFC 1951)
# ============================================================================

fn decode_length(code: i64, data: [u8], bit_pos: i64) -> i64:
    """Decode length from a length code (257-285)."""
    if code <= 264: return code - 257 + 3
    if code == 285: return 258
    val extra = length_extra_bits(code)
    val base_len = length_base(code)
    val extra_val = read_bits(data, bit_pos, extra)
    base_len + extra_val

fn length_extra_bits(code: i64) -> i64:
    """Get number of extra bits for a length code."""
    if code <= 264: return 0
    if code == 285: return 0
    val group = (code - 265) / 4 + 1
    if group > 5: return 5
    group

fn length_base(code: i64) -> i64:
    """Get the base length for a length code."""
    if code == 265: return 11
    if code == 266: return 13
    if code == 267: return 15
    if code == 268: return 17
    if code == 269: return 19
    if code == 270: return 23
    if code == 271: return 27
    if code == 272: return 31
    if code == 273: return 35
    if code == 274: return 43
    if code == 275: return 51
    if code == 276: return 59
    if code == 277: return 67
    if code == 278: return 83
    if code == 279: return 99
    if code == 280: return 115
    if code == 281: return 131
    if code == 282: return 163
    if code == 283: return 195
    if code == 284: return 227
    3

fn decode_distance(code: i64, data: [u8], bit_pos: i64) -> i64:
    """Decode distance from a distance code (0-29)."""
    if code <= 3: return code + 1
    val extra = distance_extra_bits(code)
    val base_dist = distance_base(code)
    val extra_val = read_bits(data, bit_pos, extra)
    base_dist + extra_val

fn distance_extra_bits(code: i64) -> i64:
    """Get number of extra bits for a distance code."""
    if code <= 3: return 0
    val group = (code - 4) / 2 + 1
    if group > 13: return 13
    group

fn distance_base(code: i64) -> i64:
    """Get the base distance for a distance code."""
    if code == 4: return 5
    if code == 5: return 7
    if code == 6: return 9
    if code == 7: return 13
    if code == 8: return 17
    if code == 9: return 25
    if code == 10: return 33
    if code == 11: return 49
    if code == 12: return 65
    if code == 13: return 97
    if code == 14: return 129
    if code == 15: return 193
    if code == 16: return 257
    if code == 17: return 385
    if code == 18: return 513
    if code == 19: return 769
    if code == 20: return 1025
    if code == 21: return 1537
    if code == 22: return 2049
    if code == 23: return 3073
    if code == 24: return 4097
    if code == 25: return 6145
    if code == 26: return 8193
    if code == 27: return 12289
    if code == 28: return 16385
    if code == 29: return 24577
    1
