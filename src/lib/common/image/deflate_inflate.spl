# DEFLATE inflate wrapper for image/PNG use.
#
# Provides deflate_inflate(data, skip_bytes) which skips a leading header
# (e.g. 2-byte zlib CMF+FLG) then decompresses the raw DEFLATE stream.
# Returns an empty array on any error or if input is too short.

use std.nogc_sync_mut.compression.gzip.inflate.{inflate}

pub fn deflate_inflate(data: [u8], skip_bytes: i32) -> [u8]:
    """Decompress a DEFLATE stream, skipping `skip_bytes` header bytes.

    skip_bytes=2 for zlib-wrapped streams (CMF+FLG header).
    skip_bytes=0 for raw DEFLATE.
    Returns empty array on error or if data is shorter than skip_bytes.
    """
    val n = data.len().to_i32()
    if n <= skip_bytes:
        return []
    var payload: [u8] = []
    var i = skip_bytes
    while i < n:
        payload = payload + [data[i]]
        i = i + 1
    match inflate(payload):
        Some(out): out
        None: []
