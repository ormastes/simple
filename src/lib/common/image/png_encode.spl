# PNG Encode — Minimal ARGB [u32] to PNG bytes encoder
#
# Counterpart to png_decode.spl. Supports 8-bit RGB (color type 2) and
# RGBA (color type 6), single IDAT chunk, all scanlines filter type 0 (None).
# The IDAT payload is a valid zlib stream: 2-byte CMF/FLG header, stored
# (BTYPE=00, uncompressed) DEFLATE blocks via the existing deflate_stored
# codec, and a big-endian Adler-32 trailer.
#
# ponytail: stored blocks = zero compression, output ~= raw pixels + 11 bytes
# per 64KB block. Upgrade path: swap deflate_stored for deflate_fixed /
# LZ77 in src/lib/common/compress/typed/deflate_typed.spl if exported PNG
# size ever becomes a measured problem (image_object_design_plan.md,
# "Deferred" section).

use std.common.bytes.span.{ByteSpan}
use std.common.compress.gzip.{gzip_crc32}
use std.common.hash.adler32.{adler32}
use std.common.compress.typed.deflate_typed.{deflate_stored}

# ============================================================================
# Public API
# ============================================================================

pub fn encode_argb_to_png(pixels: [u32], width: i32, height: i32) -> [u8]:
    """Encode ARGB [u32] pixels as an 8-bit RGBA PNG (color type 6).

    Pixel layout: A in bits 24-31, R in 16-23, G in 8-15, B in 0-7 —
    the exact format decode_png_to_argb produces, so encode/decode round-trip.
    """
    _encode_png(pixels, width, height, 6)

pub fn encode_argb_to_png_rgb(pixels: [u32], width: i32, height: i32) -> [u8]:
    """Encode ARGB [u32] pixels as an 8-bit RGB PNG (color type 2).

    Alpha bits are dropped; decode_png_to_argb restores them as 255.
    """
    _encode_png(pixels, width, height, 2)

# ============================================================================
# Internals
# ============================================================================

fn _encode_png(pixels: [u32], width: i32, height: i32, color_type: i64) -> [u8]:
    val raw = _filtered_scanlines(pixels, width, height, color_type)
    val idat = _zlib_store(raw)

    # IHDR data: width BE, height BE, bit depth 8, color type, 0, 0, 0
    var ihdr: [u8] = []
    ihdr = _extend(ihdr, _u32_be(width.to_i64()))
    ihdr = _extend(ihdr, _u32_be(height.to_i64()))
    ihdr.push(8u8)                  # bit depth
    ihdr.push((color_type & 0xFF).to_u8())
    ihdr.push(0u8)                  # compression method
    ihdr.push(0u8)                  # filter method
    ihdr.push(0u8)                  # interlace method

    # Signature + chunks
    var out: [u8] = [137u8, 80u8, 78u8, 71u8, 13u8, 10u8, 26u8, 10u8]
    out = _extend(out, _chunk("IHDR", ihdr))
    out = _extend(out, _chunk("IDAT", idat))
    var no_data: [u8] = []
    out = _extend(out, _chunk("IEND", no_data))
    out

fn _filtered_scanlines(pixels: [u32], width: i32, height: i32, color_type: i64) -> [u8]:
    """Serialize pixels as scanlines, each prefixed with filter byte 0 (None)."""
    var out: [u8] = []
    var y: i32 = 0
    while y < height:
        out.push(0u8)  # filter type: None
        var x: i32 = 0
        while x < width:
            val px = pixels[y * width + x].to_i64()
            out.push(((px >> 16) & 0xFF).to_u8())      # R
            out.push(((px >> 8) & 0xFF).to_u8())       # G
            out.push((px & 0xFF).to_u8())              # B
            if color_type == 6:
                out.push(((px >> 24) & 0xFF).to_u8())  # A
            x = x + 1
        y = y + 1
    out

fn _zlib_store(data: [u8]) -> [u8]:
    """Wrap data in a zlib stream using stored DEFLATE blocks.

    0x78 0x01 = CM 8 (deflate), 32K window, no dict, FCHECK valid.
    """
    var out: [u8] = [0x78u8, 0x01u8]
    var deflated = deflate_stored(ByteSpan.new(data))
    out = _extend(out, deflated.buf)
    out = _extend(out, _u32_be(adler32(data)))
    out

fn _chunk(type_name: text, data: [u8]) -> [u8]:
    """Build a PNG chunk: length BE, 4-byte type, data, CRC-32(type + data) BE.

    CRC is computed over one flat [u8] via the gzip_crc32 free function, NOT
    the incremental Crc32+ByteSpan pair: the cross-module ByteSpan misreads
    small heap-built arrays on the deployed interpreter (every chunk CRC came
    out wrong; see bug doc byte_span_cross_module_misread_2026-07-19), and
    flat-array free functions are the documented safe cross-module shape.
    """
    val type_bytes = type_name.bytes()
    var out = _u32_be(data.len())
    out = _extend(out, type_bytes)
    out = _extend(out, data)
    var crc_input = _extend([], type_bytes)
    crc_input = _extend(crc_input, data)
    out = _extend(out, _u32_be(gzip_crc32(crc_input).to_i64()))
    out

fn _u32_be(v: i64) -> [u8]:
    [
        ((v >> 24) & 0xFF).to_u8(),
        ((v >> 16) & 0xFF).to_u8(),
        ((v >> 8) & 0xFF).to_u8(),
        (v & 0xFF).to_u8()
    ]

fn _extend(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    for b in src:
        out.push(b)
    out
