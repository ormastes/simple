# PPM image decoder — supports P6 (binary RGB) format.
#
# Consumers import:
#   decode_ppm_to_argb(data: [u8]) -> Result<PpmImage, text>
#   PpmImage  (struct with width, height, pixels: [u32])
#
# The decoder is more lenient than the strict PPM spec: it skips comment
# lines beginning with '#' and handles \r\n line endings.

pub struct PpmImage:
    """Decoded PPM image with ARGB pixel data."""
    width: i32
    height: i32
    # Pixel buffer in row-major order: pixel[y*width+x] = 0xAARRGGBB
    pixels: [u32]

# ============================================================================
# Internal helpers
# ============================================================================

fn _ppm_is_whitespace(b: u8) -> bool:
    b == 32 or b == 9 or b == 10 or b == 13

fn _ppm_skip_whitespace_and_comments(data: [u8], pos: i64) -> i64:
    """Advance `pos` past whitespace and comment lines."""
    var p = pos
    val n = data.len()
    while p < n:
        val b = data[p]
        if _ppm_is_whitespace(b):
            p = p + 1
        else if b == 35:  # '#'
            while p < n and data[p] != 10:
                p = p + 1
        else:
            return p
    p

fn _ppm_read_int(data: [u8], pos: i64) -> (i64, i64):
    """Read a decimal integer starting at pos; return (value, new_pos)."""
    var p = _ppm_skip_whitespace_and_comments(data, pos)
    var v: i64 = 0
    val n = data.len()
    while p < n:
        val b = data[p] as i64
        if b >= 48 and b <= 57:  # '0'..'9'
            v = v * 10 + (b - 48)
            p = p + 1
        else:
            return (v, p)
    (v, p)

# ============================================================================
# Public API
# ============================================================================

pub fn decode_ppm_to_argb(data: [u8]) -> Result<PpmImage, text>:
    """Decode a P6 (binary PPM) byte buffer into an ARGB pixel array.

    Returns Ok(PpmImage) on success, Err(message) on parse failure.
    Only supports maxval <= 255 (8-bit channels).
    """
    val n = data.len()
    if n < 7:
        return Err("PPM data too short")
    # Magic: "P6"
    if data[0] != 80 or data[1] != 54:  # 'P' == 80, '6' == 54
        return Err("PPM: not a P6 file (expected magic 'P6')")
    var pos: i64 = 2
    val (width_i64, p1) = _ppm_read_int(data, pos)
    pos = p1
    val (height_i64, p2) = _ppm_read_int(data, pos)
    pos = p2
    val (maxval, p3) = _ppm_read_int(data, pos)
    pos = p3
    if width_i64 <= 0 or height_i64 <= 0:
        return Err("PPM: invalid dimensions {width_i64}x{height_i64}")
    if maxval <= 0 or maxval > 255:
        return Err("PPM: unsupported maxval {maxval} (only 1-255 supported)")
    # After maxval there is exactly one whitespace byte before the pixel data
    if pos >= n:
        return Err("PPM: truncated before pixel data")
    pos = pos + 1  # consume the single whitespace separator
    val width = width_i64 as i32
    val height = height_i64 as i32
    val pixel_count = width_i64 * height_i64
    val byte_count = pixel_count * 3
    if pos + byte_count > n:
        return Err("PPM: pixel data truncated (need {byte_count} bytes, have {n - pos})")
    var pixels: [u32] = [0u32; pixel_count]
    var i: i64 = 0
    while i < pixel_count:
        val base = pos + i * 3
        val r = data[base] as i64
        val g = data[base + 1] as i64
        val b = data[base + 2] as i64
        # Scale if maxval != 255
        val rs = if maxval == 255: r else: (r * 255) / maxval
        val gs = if maxval == 255: g else: (g * 255) / maxval
        val bs = if maxval == 255: b else: (b * 255) / maxval
        # Pack as 0xAARRGGBB (fully opaque)
        val argb = (0xFF000000 as i64) | (rs << 16) | (gs << 8) | bs
        pixels[i] = argb as u32
        i = i + 1
    Ok(PpmImage(width: width, height: height, pixels: pixels))

pub fn encode_ppm_p6(width: u32, height: u32, pixels: [u32]) -> [u8]:
    """Encode an ARGB pixel buffer to P6 PPM bytes.

    Alpha is discarded; channels are written as 8-bit RGB triplets.
    """
    var out: [u8] = []
    # Push plain integer values (not `expr as u8`): an explicit `as u8` cast on a
    # pushed element produces a u8-tagged value that the [u8]->extern marshalling
    # drops, so the resulting buffer reaches rt_file_write_bytes / socket writes
    # as empty. Masked integers store and marshal correctly.
    # Header: "P6\n<width> <height>\n255\n"
    val header = "P6\n{width} {height}\n255\n"
    var hi = 0
    while hi < header.len():
        out = out.push(header.char_at(hi) as i64)
        hi = hi + 1
    val count = (width as i64) * (height as i64)
    var i: i64 = 0
    while i < count:
        val argb = pixels[i] as i64
        val r = (argb >> 16) & 0xFF
        val g = (argb >> 8) & 0xFF
        val b = argb & 0xFF
        out = out.push(r)
        out = out.push(g)
        out = out.push(b)
        i = i + 1
    out
