"""SimpleOS executable-environment gate for Wine compatibility claims."""

pub fn wine_simpleos_exec_env_required_evidence() -> [text]:
    [
        "simpleos-qemu-vm",
        "simpleos-full-os-boot",
        "simpleos-kernel-syscall-abi",
        "simpleos-kernel-scheduler",
        "simpleos-kernel-vfs-service",
        "simpleos-user-process",
        "simpleos-vmspace",
        "simpleos-filesystem",
        "simpleos-window-system",
        "simpleos-network",
        "simpleos-container-namespace",
        "simpleos-container-pid-namespace",
        "simpleos-container-fs-namespace",
        "simpleos-container-ipc-namespace",
        "simpleos-container-net-namespace",
        "simpleos-container-capability-boundary",
        "simpleos-container-rootfs",
        "simpleos-container-rootfs-nvfs",
        "simpleos-mdsoc-capsule",
        "simpleos-mdsoc-public-port",
        "simpleos-mdsoc-resident-state-owner"
    ]

pub fn wine_simpleos_exec_env_gate(evidence: text) -> text:
    for item in wine_simpleos_exec_env_required_evidence():
        if not evidence.contains(item):
            return "missing-" + item
    "ready"

fn _append_evidence(evidence: text, item: text) -> text:
    if evidence.contains(item):
        return evidence
    if evidence == "":
        return item
    evidence + " " + item

pub fn wine_simpleos_exec_env_evidence_from_serial_log(serial_log: text) -> text:
    var evidence = ""
    if serial_log.contains("QEMU") or serial_log.contains("qemu") or serial_log.contains("TEST PASSED"):
        evidence = _append_evidence(evidence, "simpleos-qemu-vm")
    if serial_log.contains("TEST PASSED") or serial_log.contains("[phase-3-mount] fat32 ok") or serial_log.contains("[desktop-e2e]"):
        evidence = _append_evidence(evidence, "simpleos-full-os-boot")
    if serial_log.contains("[kernel] syscall-abi:ok") or serial_log.contains("[desktop-e2e] syscall-abi:ok"):
        evidence = _append_evidence(evidence, "simpleos-kernel-syscall-abi")
    if serial_log.contains("[kernel] scheduler:ok") or serial_log.contains("[desktop-e2e] scheduler:ok"):
        evidence = _append_evidence(evidence, "simpleos-kernel-scheduler")
    if serial_log.contains("[kernel] vfs-service:ok") or serial_log.contains("[desktop-e2e] vfs-service:ok"):
        evidence = _append_evidence(evidence, "simpleos-kernel-vfs-service")
    if serial_log.contains("[desktop-e2e] process-backed:ok app="):
        evidence = _append_evidence(evidence, "simpleos-user-process")
    if serial_log.contains("[fs-exec] spawn:image") or serial_log.contains("[desktop-e2e] vmspace:ok") or serial_log.contains("os-address-space"):
        evidence = _append_evidence(evidence, "simpleos-vmspace")
    if serial_log.contains("[vfs] mounted") or serial_log.contains("[phase-3-mount] fat32 ok") or serial_log.contains("[desktop-e2e] vfs-app-read:ok"):
        evidence = _append_evidence(evidence, "simpleos-filesystem")
    if serial_log.contains("[desktop-e2e] wm:ok") or serial_log.contains("[desktop-e2e] wm-owner:ok") or serial_log.contains("[simple_browser] page_rendered"):
        evidence = _append_evidence(evidence, "simpleos-window-system")
    if serial_log.contains("[desktop-e2e] network-smoke:bounded ok") or serial_log.contains("[desktop-e2e] virtio-net:"):
        evidence = _append_evidence(evidence, "simpleos-network")
    if serial_log.contains("[desktop-e2e] container-namespace:ok"):
        evidence = _append_evidence(evidence, "simpleos-container-namespace")
        if serial_log.contains("container-namespace:ok pid") or serial_log.contains("container-namespace:ok fs pid") or serial_log.contains("container-namespace:ok ipc pid") or serial_log.contains("container-namespace:ok net pid"):
            evidence = _append_evidence(evidence, "simpleos-container-pid-namespace")
        if serial_log.contains("container-namespace:ok pid fs") or serial_log.contains("container-namespace:ok fs") or serial_log.contains("container-namespace:ok ipc fs") or serial_log.contains("container-namespace:ok net fs"):
            evidence = _append_evidence(evidence, "simpleos-container-fs-namespace")
        if serial_log.contains("container-namespace:ok pid fs ipc") or serial_log.contains("container-namespace:ok ipc") or serial_log.contains("container-namespace:ok fs ipc"):
            evidence = _append_evidence(evidence, "simpleos-container-ipc-namespace")
        if serial_log.contains("container-namespace:ok pid fs ipc net") or serial_log.contains("container-namespace:ok net") or serial_log.contains("container-namespace:ok ipc net"):
            evidence = _append_evidence(evidence, "simpleos-container-net-namespace")
        if serial_log.contains("container-namespace:ok pid fs ipc net capability") or serial_log.contains("container-namespace:ok capability") or serial_log.contains("container-namespace:ok net capability"):
            evidence = _append_evidence(evidence, "simpleos-container-capability-boundary")
    if serial_log.contains("[desktop-e2e] container-rootfs:ok") or serial_log.contains("rootfs_backend="):
        evidence = _append_evidence(evidence, "simpleos-container-rootfs")
    if serial_log.contains("rootfs_backend=nvfs"):
        evidence = _append_evidence(evidence, "simpleos-container-rootfs-nvfs")
    if serial_log.contains("[desktop-e2e] mdsoc-capsule:ok"):
        evidence = _append_evidence(evidence, "simpleos-mdsoc-capsule")
    if serial_log.contains("[desktop-e2e] mdsoc-public-port:ok"):
        evidence = _append_evidence(evidence, "simpleos-mdsoc-public-port")
    if serial_log.contains("[desktop-e2e] mdsoc-resident-state-owner:ok"):
        evidence = _append_evidence(evidence, "simpleos-mdsoc-resident-state-owner")
    evidence

pub fn wine_simpleos_exec_env_gate_from_serial_log(serial_log: text) -> text:
    wine_simpleos_exec_env_gate(wine_simpleos_exec_env_evidence_from_serial_log(serial_log))

pub fn wine_simpleos_exec_env_fixture_evidence() -> text:
        "simpleos-qemu-vm simpleos-full-os-boot " +
        "simpleos-kernel-syscall-abi simpleos-kernel-scheduler simpleos-kernel-vfs-service " +
        "simpleos-user-process simpleos-vmspace " +
        "simpleos-filesystem simpleos-window-system simpleos-network " +
        "simpleos-container-namespace simpleos-container-pid-namespace simpleos-container-fs-namespace " +
        "simpleos-container-ipc-namespace simpleos-container-net-namespace simpleos-container-capability-boundary " +
        "simpleos-container-rootfs simpleos-container-rootfs-nvfs " +
        "simpleos-mdsoc-capsule simpleos-mdsoc-public-port simpleos-mdsoc-resident-state-owner"

pub fn wine_simpleos_exec_env_fixture_serial_log() -> text:
    "QEMU x86_64 desktop lane\n" +
        "[phase-3-mount] fat32 ok\n" +
        "[kernel] syscall-abi:ok arch=x86_64\n" +
        "[kernel] scheduler:ok runqueue=user\n" +
        "[kernel] vfs-service:ok root=/\n" +
        "[vfs] mounted fat32 device=nvme0 volume=simpleos\n" +
        "[fs-exec] spawn:image path=/sys/apps/wine_hello entry=0 segments=1 stub_bytes=128 argv_count=1 env_count=0\n" +
        "[desktop-e2e] process-backed:ok app=wine_hello pid=42\n" +
        "[desktop-e2e] wm:ok pid=42 wid=1001\n" +
        "[desktop-e2e] network-smoke:bounded ok packets=1\n" +
        "[desktop-e2e] container-namespace:ok pid fs ipc net capability\n" +
        "[desktop-e2e] container-rootfs:ok rootfs=/containers/wine rootfs_backend=nvfs\n" +
        "[desktop-e2e] mdsoc-capsule:ok owner=process-container-wm\n" +
        "[desktop-e2e] mdsoc-public-port:ok facade=exec-env\n" +
        "[desktop-e2e] mdsoc-resident-state-owner:ok ecs=wm,process,container\n" +
        "TEST PASSED"
