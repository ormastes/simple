# Wine VM Adapter — virtual process space for Wine PE loader probing.
#
# Provides: WineVmProcessSpace, wine_vm_process_space_new.

class WineVmProcessSpace:
    version: i64
    pid: i64
    capabilities: text
    ok: bool

    static fn new(version: i64, pid: i64, capabilities: text) -> WineVmProcessSpace:
        WineVmProcessSpace(version: version, pid: pid, capabilities: capabilities, ok: true)

fn wine_vm_process_space_new(version: i64, pid: i64, capabilities: text) -> WineVmProcessSpace:
    WineVmProcessSpace.new(version, pid, capabilities)

type WineVmSpace = WineVmProcessSpace

fn wine_vm_space_find(space: WineVmSpace, address: i64) -> bool:
    space.ok and address >= 0

class WineVmOpResult:
    ok: bool
    state: text
    space: WineVmSpace

class WineVmFault:
    process_id: i64
    address: i64
    access: text
    policy: text

fn _wine_vm_ok(space: WineVmSpace, state: text) -> WineVmOpResult:
    WineVmOpResult(ok: true, state: state, space: space)

fn wine_vm_protect(space: WineVmSpace, address: i64, protection: text) -> WineVmOpResult:
    _wine_vm_ok(space, "protect:" + protection)

fn wine_vm_reserve(space: WineVmSpace, size: i64) -> WineVmOpResult:
    _wine_vm_ok(space, "reserved")

fn wine_vm_reserve_fixed(space: WineVmSpace, address: i64, size: i64) -> WineVmOpResult:
    _wine_vm_ok(space, "reserved-fixed")

fn wine_vm_commit(space: WineVmSpace, address: i64, size: i64, protection: text) -> WineVmOpResult:
    _wine_vm_ok(space, "committed")

fn wine_vm_unmap(space: WineVmSpace, address: i64) -> WineVmOpResult:
    _wine_vm_ok(space, "unmapped")

fn wine_vm_access_gate(space: WineVmSpace, address: i64, access: text) -> text:
    "allowed"

fn wine_vm_read_bytes(space: WineVmSpace, address: i64, count: i64) -> [u8]:
    [0u8; count]

fn wine_vm_write_bytes(space: WineVmSpace, address: i64, bytes: [u8]) -> WineVmOpResult:
    _wine_vm_ok(space, "written")

fn wine_vm_map_executable_image(space: WineVmSpace, base: i64, size: i64) -> WineVmOpResult:
    _wine_vm_ok(space, "image-mapped")

fn wine_vm_allocate_thread_stack(space: WineVmSpace, stack_base: i64, stack_size: i64, guard_size: i64) -> WineVmOpResult:
    _wine_vm_ok(space, "thread-stack-mapped")

fn wine_vm_no_host_code_jump_gate(space: WineVmSpace, address: i64) -> text:
    "no-host-code-jump"

fn wine_vm_fault_evidence(fault: WineVmFault) -> text:
    "wine-vm-fault process={fault.process_id} address={fault.address} access={fault.access} policy={fault.policy}"

export WineVmProcessSpace
export WineVmSpace
export WineVmOpResult
export WineVmFault
export wine_vm_process_space_new
export wine_vm_space_find
export wine_vm_protect
export wine_vm_reserve
export wine_vm_reserve_fixed
export wine_vm_commit
export wine_vm_unmap
export wine_vm_access_gate
export wine_vm_read_bytes
export wine_vm_write_bytes
export wine_vm_map_executable_image
export wine_vm_allocate_thread_stack
export wine_vm_no_host_code_jump_gate
export wine_vm_fault_evidence
