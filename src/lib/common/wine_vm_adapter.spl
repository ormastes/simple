# Wine VM Adapter — virtual process space for Wine PE loader probing.
#
# Provides: WineVmProcessSpace, wine_vm_process_space_new.

class WineVmProcessSpace:
    version: i64
    pid: i64
    capabilities: text
    ok: bool

    static fn new(version: i64, pid: i64, capabilities: text) -> WineVmProcessSpace:
        WineVmProcessSpace(version: version, pid: pid, capabilities: capabilities, ok: true)

fn wine_vm_process_space_new(version: i64, pid: i64, capabilities: text) -> WineVmProcessSpace:
    WineVmProcessSpace.new(version, pid, capabilities)
