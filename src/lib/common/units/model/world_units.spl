# World unit catalog model.
#
# SDN stores catalog data; this module stores semantic enums used by importers,
# normalizers, formatters, and lint/type-checking code.

enum QuantityDomain:
    Physical
    Chemistry
    Calendar
    Finance
    Trade
    Information
    ProcedureDefined

enum UnitClass:
    Linear
    Affine
    Logarithmic
    Count
    Currency
    Calendar
    ProcedureDefined

struct ExactRatio:
    numerator: i64
    denominator: i64

fn exact_ratio(num: i64, den: i64) -> ExactRatio:
    ExactRatio(numerator: num, denominator: den)

fn exact_ratio_normalize(ratio: ExactRatio) -> ExactRatio:
    if ratio.denominator == 0:
        return ratio
    var num = ratio.numerator
    var den = ratio.denominator
    if den < 0:
        num = 0 - num
        den = 0 - den
    val divisor = gcd_i64(abs_i64(num), abs_i64(den))
    if divisor <= 1:
        return ExactRatio(numerator: num, denominator: den)
    ExactRatio(numerator: num / divisor, denominator: den / divisor)

fn exact_ratio_mul(left: ExactRatio, right: ExactRatio) -> ExactRatio:
    exact_ratio_normalize(ExactRatio(
        numerator: left.numerator * right.numerator,
        denominator: left.denominator * right.denominator
    ))

fn exact_ratio_div(left: ExactRatio, right: ExactRatio) -> ExactRatio:
    exact_ratio_normalize(ExactRatio(
        numerator: left.numerator * right.denominator,
        denominator: left.denominator * right.numerator
    ))

fn abs_i64(value: i64) -> i64:
    if value < 0:
        return 0 - value
    value

fn gcd_i64(left: i64, right: i64) -> i64:
    var a = left
    var b = right
    while b != 0:
        val next = a % b
        a = b
        b = next
    if a == 0:
        return 1
    a

struct QuantityKind:
    id: text
    domain: QuantityDomain
    dimension: text

struct UnitIdentity:
    id: text
    class_: UnitClass
    kind_id: text
    canonical_symbol: text

struct UnitAlias:
    target_id: text
    alias: text
    scope: text

fn is_prefix_blocked(unit_symbol: text) -> bool:
    match unit_symbol:
        case "min" | "h" | "d" | "a" | "a_j" | "a_g" | "a_t": true
        case _: false

fn kilometre_per_hour_factor_to_metre_per_second() -> ExactRatio:
    exact_ratio(5, 18)

fn catalog_has_required_world_units(catalog: text) -> bool:
    catalog.contains("derived_unit kilometre_per_hour") and
    catalog.contains("exact_factor: \"5/18 m/s\"") and
    catalog.contains("currency USD") and
    catalog.contains("iso4217: \"USD\"") and
    catalog.contains("canonical_symbol: \"a_g\"") and
    catalog.contains("unece_rec20: \"DZN\"") and
    catalog.contains("canonical_symbol: \"KiB\"")
