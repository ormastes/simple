# World unit catalog model.
#
# SDN stores catalog data; this module stores semantic enums used by importers,
# normalizers, formatters, and lint/type-checking code.

enum QuantityDomain:
    Physical
    Chemistry
    Calendar
    Finance
    Trade
    Information
    ProcedureDefined

enum UnitClass:
    Linear
    Affine
    Logarithmic
    Count
    Currency
    Calendar
    ProcedureDefined

struct ExactRatio:
    numerator: i64
    denominator: i64

fn exact_ratio(num: i64, den: i64) -> ExactRatio:
    ExactRatio(numerator: num, denominator: den)

struct QuantityKind:
    id: text
    domain: QuantityDomain
    dimension: text

struct UnitIdentity:
    id: text
    class_: UnitClass
    kind_id: text
    canonical_symbol: text

struct UnitAlias:
    target_id: text
    alias: text
    scope: text

fn is_prefix_blocked(unit_symbol: text) -> bool:
    match unit_symbol:
        case "min" | "h" | "d" | "a" | "a_j" | "a_g" | "a_t": true
        case _: false

fn kilometre_per_hour_factor_to_metre_per_second() -> ExactRatio:
    exact_ratio(5, 18)
