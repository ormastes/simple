# Standards-backed seed importers for the world-units catalog.
#
# These functions produce normalized catalog rows from pinned source snapshots.
# Network fetching and standards-file refresh are intentionally out of hot paths;
# generated SDN is committed separately.

struct ImportedUnitRow:
    id: text
    source: text
    kind: text
    class_: text
    canonical_symbol: text
    code: text
    exact_factor: text

fn imported_unit_row(id: text, source: text, kind: text, class_: text, canonical_symbol: text, code: text, exact_factor: text) -> ImportedUnitRow:
    ImportedUnitRow(
        id: id,
        source: source,
        kind: kind,
        class_: class_,
        canonical_symbol: canonical_symbol,
        code: code,
        exact_factor: exact_factor
    )

fn import_ucum_calendar_seed() -> [ImportedUnitRow]:
    [
        imported_unit_row("julian_year", "UCUM", "CalendarDuration", "calendar", "a_j", "a_j", ""),
        imported_unit_row("gregorian_year", "UCUM", "CalendarDuration", "calendar", "a_g", "a_g", ""),
        imported_unit_row("tropical_year", "UCUM", "CalendarDuration", "calendar", "a_t", "a_t", "")
    ]

fn import_iso4217_currency_seed() -> [ImportedUnitRow]:
    [
        imported_unit_row("USD", "ISO 4217/SIX", "CurrencyAmount", "currency", "USD", "840", "minor=2")
    ]

fn import_unece_rec20_count_seed() -> [ImportedUnitRow]:
    [
        imported_unit_row("piece", "UNECE Rec 20", "Count", "count", "piece", "H87", ""),
        imported_unit_row("dozen", "UNECE Rec 20", "Count", "count", "dozen", "DZN", ""),
        imported_unit_row("set", "UNECE Rec 20", "Count", "count", "set", "SET", "")
    ]

fn import_iupac_chemistry_seed() -> [ImportedUnitRow]:
    [
        imported_unit_row("mole_per_litre", "IUPAC Gold Book", "AmountOfSubstanceConcentration", "linear", "mol/L", "M", "mol/L")
    ]

fn import_iec80000_information_seed() -> [ImportedUnitRow]:
    [
        imported_unit_row("byte", "IEC 80000-13", "Information", "linear", "B", "B", "8 bit"),
        imported_unit_row("kibibyte", "IEC 80000-13", "Information", "linear", "KiB", "KiB", "1024 B")
    ]

fn import_all_world_unit_seed_rows() -> [ImportedUnitRow]:
    var rows: [ImportedUnitRow] = []
    for row in import_ucum_calendar_seed():
        rows.push(row)
    for row in import_iso4217_currency_seed():
        rows.push(row)
    for row in import_unece_rec20_count_seed():
        rows.push(row)
    for row in import_iupac_chemistry_seed():
        rows.push(row)
    for row in import_iec80000_information_seed():
        rows.push(row)
    rows

fn imported_rows_have_unique_ids(rows: [ImportedUnitRow]) -> bool:
    var seen: [text] = []
    for row in rows:
        for existing in seen:
            if existing == row.id:
                return false
        seen.push(row.id)
    true

fn imported_rows_to_sdn(rows: [ImportedUnitRow]) -> text:
    var out = "imported_world_units:\n"
    for row in rows:
        out = out + "    row { id: \"{row.id}\", source: \"{row.source}\", kind: \"{row.kind}\", class: \"{row.class_}\", symbol: \"{row.canonical_symbol}\", code: \"{row.code}\", exact_factor: \"{row.exact_factor}\" }\n"
    out
