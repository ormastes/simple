use std.common.units.model.world_units.{UnitExpression, exact_ratio, hour_expression, kilometre_expression, kilometre_per_hour_expression, litre_expression, mole_per_litre_expression, unit_expression, unit_expression_div, unit_expression_equivalent, unit_expression_factor_exponent, unit_expression_from_base}

struct UnitExpressionParseResult:
    ok: bool
    expression: UnitExpression
    error: text

fn unit_expression_parse_ok(expression: UnitExpression) -> UnitExpressionParseResult:
    UnitExpressionParseResult(ok: true, expression: expression, error: "")

fn unit_expression_parse_error(message: text) -> UnitExpressionParseResult:
    UnitExpressionParseResult(ok: false, expression: unit_expression(exact_ratio(1, 1), []), error: message)

fn parse_unit_expression(source: text) -> UnitExpressionParseResult:
    val trimmed = source.trim()
    match trimmed:
        case "m": unit_expression_parse_ok(unit_expression_from_base("metre"))
        case "s": unit_expression_parse_ok(unit_expression_from_base("second"))
        case "mol": unit_expression_parse_ok(unit_expression_from_base("mole"))
        case "km": unit_expression_parse_ok(kilometre_expression())
        case "h": unit_expression_parse_ok(hour_expression())
        case "L" | "l": unit_expression_parse_ok(litre_expression())
        case "km/h" | "kmph": unit_expression_parse_ok(kilometre_per_hour_expression())
        case "mol/L" | "mol l^-1" | "M": unit_expression_parse_ok(mole_per_litre_expression())
        case _: parse_simple_division_expression(trimmed)

fn parse_simple_division_expression(source: text) -> UnitExpressionParseResult:
    val parts = source.split("/")
    if parts.len() != 2:
        return unit_expression_parse_error("unknown unit expression: {source}")
    val left = parse_unit_expression(parts[0])
    if not left.ok:
        return left
    val right = parse_unit_expression(parts[1])
    if not right.ok:
        return right
    unit_expression_parse_ok(unit_expression_div(left.expression, right.expression))

fn format_unit_expression(expression: UnitExpression) -> text:
    if unit_expression_equivalent(expression, kilometre_per_hour_expression()):
        return "km/h"
    if unit_expression_equivalent(expression, mole_per_litre_expression()):
        return "mol/L"
    if unit_expression_equivalent(expression, kilometre_expression()):
        return "km"
    if unit_expression_equivalent(expression, hour_expression()):
        return "h"
    if unit_expression_equivalent(expression, litre_expression()):
        return "L"
    if unit_expression_factor_exponent(expression, "metre") == 1:
        return "m"
    if unit_expression_factor_exponent(expression, "second") == 1:
        return "s"
    if unit_expression_factor_exponent(expression, "mole") == 1:
        return "mol"
    "<unit-expression>"
