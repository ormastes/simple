# Minimal bim{} and city{} standards binding model.
#
# Raw bim{}/city{} domain blocks are preserved by the compiler carrier. This
# module provides the pure Simple typed binding layer and fixture-backed export
# checks for the first standards slice.

class BimPropertySet:
    name: text
    bsdd_id: text

class BimModel:
    building: text
    ifc_building_id: text
    level: text
    space: text
    wall: text
    material: text
    property_sets: [BimPropertySet]

class CityObject:
    identity: text
    lod: text
    citygml_target: text

class CityModel:
    name: text
    objects: [CityObject]

fn bim_property_set(name: text, bsdd_id: text) -> BimPropertySet:
    BimPropertySet(name: name, bsdd_id: bsdd_id)

fn bim_model(building: text, ifc_building_id: text) -> BimModel:
    BimModel(
        building: building,
        ifc_building_id: ifc_building_id,
        level: "",
        space: "",
        wall: "",
        material: "",
        property_sets: []
    )

fn bim_model_with_level(model: BimModel, level: text) -> BimModel:
    BimModel(building: model.building, ifc_building_id: model.ifc_building_id, level: level, space: model.space, wall: model.wall, material: model.material, property_sets: model.property_sets)

fn bim_model_with_space(model: BimModel, space: text) -> BimModel:
    BimModel(building: model.building, ifc_building_id: model.ifc_building_id, level: model.level, space: space, wall: model.wall, material: model.material, property_sets: model.property_sets)

fn bim_model_with_wall(model: BimModel, wall: text) -> BimModel:
    BimModel(building: model.building, ifc_building_id: model.ifc_building_id, level: model.level, space: model.space, wall: wall, material: model.material, property_sets: model.property_sets)

fn bim_model_with_material(model: BimModel, material: text) -> BimModel:
    BimModel(building: model.building, ifc_building_id: model.ifc_building_id, level: model.level, space: model.space, wall: model.wall, material: material, property_sets: model.property_sets)

fn bim_model_add_property_set(model: BimModel, property_set: BimPropertySet) -> BimModel:
    BimModel(building: model.building, ifc_building_id: model.ifc_building_id, level: model.level, space: model.space, wall: model.wall, material: model.material, property_sets: model.property_sets.push(property_set))

fn bim_model_complete(model: BimModel) -> bool:
    model.building != "" and model.ifc_building_id != "" and model.level != "" and model.space != "" and model.wall != "" and model.material != "" and model.property_sets.len() > 0

fn bim_validate_fixture_ids(model: BimModel) -> bool:
    if not _bim_fixture_ifc_id(model.ifc_building_id):
        return false
    for pset in model.property_sets:
        if not _bim_fixture_bsdd_id(pset.bsdd_id):
            return false
    true

fn bim_to_gbxml_fixture(model: BimModel) -> text:
    var xml = "<gbXML version=\"7.03\">\n"
    xml = "{xml}  <Campus id=\"campus-{_xml_id(model.building)}\">\n"
    xml = "{xml}    <Building id=\"{model.ifc_building_id}\" buildingType=\"Unknown\">\n"
    xml = "{xml}      <Name>{_xml_escape(model.building)}</Name>\n"
    xml = "{xml}      <BuildingStorey id=\"{_xml_id(model.level)}\" />\n"
    xml = "{xml}      <Space id=\"{_xml_id(model.space)}\" />\n"
    xml = "{xml}      <Surface id=\"{_xml_id(model.wall)}\" surfaceType=\"ExteriorWall\" constructionIdRef=\"{_xml_id(model.material)}\" />\n"
    xml = "{xml}    </Building>\n"
    xml = "{xml}  </Campus>\n"
    xml = "{xml}</gbXML>\n"
    xml

fn gbxml_fixture_valid(xml: text) -> bool:
    xml.contains("<gbXML version=\"7.03\"") and xml.contains("<Building id=\"") and xml.contains("<Space id=\"") and xml.contains("<Surface id=\"")

fn city_object(identity: text, lod: text, citygml_target: text) -> CityObject:
    CityObject(identity: identity, lod: lod, citygml_target: citygml_target)

fn city_model(name: text) -> CityModel:
    CityModel(name: name, objects: [])

fn city_model_add_object(model: CityModel, object: CityObject) -> CityModel:
    CityModel(name: model.name, objects: model.objects.push(object))

fn city_validate_fixture(model: CityModel) -> bool:
    if model.name == "" or model.objects.len() == 0:
        return false
    for obj in model.objects:
        if obj.identity == "" or obj.lod == "" or not obj.citygml_target.starts_with("bldg:"):
            return false
    true

fn city_to_citygml_fixture(model: CityModel) -> text:
    var xml = "<core:CityModel version=\"3.0\" name=\"{_xml_escape(model.name)}\">\n"
    for obj in model.objects:
        xml = "{xml}  <{obj.citygml_target} gml:id=\"{_xml_id(obj.identity)}\">\n"
        xml = "{xml}    <core:lod>{_xml_escape(obj.lod)}</core:lod>\n"
        xml = "{xml}  </{obj.citygml_target}>\n"
    xml = "{xml}</core:CityModel>\n"
    xml

fn citygml_fixture_valid(xml: text) -> bool:
    xml.contains("<core:CityModel version=\"3.0\"") and xml.contains("gml:id=") and xml.contains("<core:lod>")

fn _bim_fixture_ifc_id(id: text) -> bool:
    id == "IfcBuilding" or id == "IfcBuildingStorey" or id == "IfcSpace" or id == "IfcWall" or id == "IfcMaterial"

fn _bim_fixture_bsdd_id(id: text) -> bool:
    id.starts_with("bsdd:") and id.len() > 5

fn _xml_id(value: text) -> text:
    var out = value.trim()
    out = out.replace(" ", "_")
    out = out.replace("#", "_")
    out

fn _xml_escape(value: text) -> text:
    var out = value.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out
