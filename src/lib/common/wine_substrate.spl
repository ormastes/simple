"""Wine substrate readiness gates for SimpleOS compatibility work."""

use common.ui.x11_backend_gate.{x11_backend_gate}
use common.wine_vm_gate.{wine_vm_gate}
use common.wine_host_gate.{wine_host_gate}
use common.wine_pe_gate.{wine_pe_gate, wine_pe_gate_from_image}
use common.wine_async_gate.{wine_async_gate}
use common.wine_simpleos_exec_env_gate.{
    wine_simpleos_exec_env_gate,
    wine_simpleos_exec_env_gate_from_serial_log
}

class WineSubstrateCapabilityRow:
    capability: text
    state: text
    implementation_path: text
    evidence_command: text
    notes: text

fn _capability_row(capability: text, state: text, implementation_path: text, evidence_command: text, notes: text) -> WineSubstrateCapabilityRow:
    WineSubstrateCapabilityRow(capability: capability, state: state, implementation_path: implementation_path, evidence_command: evidence_command, notes: notes)

fn _verified_gate(gates: text, capability: text) -> bool:
    gates.contains(capability + "=verified")

fn _capability_path(capability: text) -> text:
    if capability == "process":
        return "src/lib/common/wine_substrate.spl"
    if capability == "exec_env":
        return "src/lib/common/wine_simpleos_exec_env_gate.spl"
    if capability == "vm":
        return "src/lib/common/wine_vm_adapter.spl"
    if capability == "renderer2d" or capability == "wm_backend":
        return "src/lib/common/ui/wine_x11_adapter.spl"
    if capability == "posix_fd":
        return "src/lib/common/wine_posix_adapter.spl"
    if capability == "fs_semantics":
        return "src/lib/common/wine_posix_adapter.spl"
    if capability == "ipc_wait":
        return "src/lib/common/wine_service_adapter.spl"
    if capability == "pthread":
        return "src/lib/common/wine_thread_adapter.spl"
    if capability == "dynload":
        return "src/lib/common/wine_dynload_adapter.spl"
    if capability == "audio":
        return "src/lib/common/wine_service_adapter.spl"
    if capability == "fonts":
        return "src/lib/common/wine_service_adapter.spl"
    if capability == "input":
        return "src/lib/common/wine_service_adapter.spl"
    if capability == "async":
        return "src/lib/common/wine_async_gate.spl"
    if capability == "pe_loader":
        return "src/lib/common/pe_coff_header.spl"
    if capability == "nt_bridge":
        return "src/lib/common/wine_nt_bridge.spl"
    if capability == "hello_exe":
        return "src/app/wine_hello/main.spl"
    "doc/02_requirements/feature/simpleos_wine_substrate.md"

fn _capability_evidence(capability: text) -> text:
    if capability == "hello_exe":
        return "bin/simple run src/app/wine_hello/main.spl"
    if capability == "nt_bridge":
        return "bin/simple test test/lib/common/wine_nt_bridge_spec.spl --mode=interpreter --clean"
    if capability == "exec_env":
        return "bin/simple test test/lib/common/wine_simpleos_exec_env_gate_spec.spl --mode=interpreter --clean"
    if capability == "pe_loader":
        return "bin/simple test test/lib/common/wine_pe_gate_spec.spl test/lib/common/pe_coff_header_spec.spl test/lib/common/wine_pe_loader_runtime_spec.spl --mode=interpreter --clean"
    if capability == "dynload":
        return "bin/simple test test/lib/common/wine_dynload_adapter_spec.spl test/lib/common/wine_ntdll_loader_spec.spl --mode=interpreter --clean"
    if capability == "pthread":
        return "bin/simple test test/lib/common/wine_thread_adapter_spec.spl test/lib/common/wine_nt_thread_wait_spec.spl --mode=interpreter --clean"
    if capability == "audio" or capability == "fonts" or capability == "input":
        return "bin/simple test test/lib/common/wine_service_adapter_spec.spl --mode=interpreter --clean"
    if capability == "ipc_wait":
        return "bin/simple test test/lib/common/wine_service_adapter_spec.spl test/lib/common/wine_advapi32_service_spec.spl --mode=interpreter --clean"
    if capability == "fs_semantics" or capability == "posix_fd":
        return "bin/simple test test/lib/common/wine_posix_adapter_spec.spl test/lib/common/wine_kernel32_file_io_spec.spl --mode=interpreter --clean"
    "bin/simple test test/lib/common/wine_substrate_spec.spl --mode=interpreter --clean"

pub fn wine_substrate_capability_state(capability: text) -> text:
    if capability == "research":
        return "verified"
    if capability == "process":
        return "partial"
    if capability == "exec_env":
        return "partial"
    if capability == "vm":
        return "partial"
    if capability == "posix_fd":
        return "partial"
    if capability == "fs_semantics":
        return "partial"
    if capability == "ipc_wait":
        return "partial"
    if capability == "renderer2d":
        return "partial"
    if capability == "wm_backend":
        return "partial"
    if capability == "audio":
        return "missing"
    if capability == "fonts":
        return "missing"
    if capability == "input":
        return "missing"
    if capability == "pthread":
        return "partial"
    if capability == "dynload":
        return "partial"
    if capability == "pe_loader":
        return "partial"
    if capability == "async":
        return "partial"
    if capability == "hello_exe":
        return "blocked"
    return "missing"

pub fn wine_substrate_capability_state_from_gates(capability: text, gates: text) -> text:
    if capability == "research":
        return "verified"
    if capability == "renderer2d" or capability == "wm_backend":
        if _verified_gate(gates, "renderer"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "posix_fd":
        if _verified_gate(gates, "posix"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "fs_semantics":
        if _verified_gate(gates, "posix"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "ipc_wait":
        if _verified_gate(gates, "host"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "audio":
        if _verified_gate(gates, "audio"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "fonts":
        if _verified_gate(gates, "fonts"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "input":
        if _verified_gate(gates, "input"):
            return "verified"
        return wine_substrate_capability_state(capability)
    if capability == "hello_exe":
        if wine_substrate_hello_exe_gate(gates) == "ready":
            return "verified"
        return wine_substrate_capability_state(capability)
    if _verified_gate(gates, capability):
        return "verified"
    wine_substrate_capability_state(capability)

pub fn wine_substrate_capability_row(capability: text, gates: text) -> WineSubstrateCapabilityRow:
    val state = wine_substrate_capability_state_from_gates(capability, gates)
    val notes = if state == "verified":
        "verified by modeled Wine precondition evidence"
    else:
        "default capability state without complete gate evidence"
    _capability_row(capability, state, _capability_path(capability), _capability_evidence(capability), notes)

pub fn wine_substrate_capability_matrix(gates: text) -> [WineSubstrateCapabilityRow]:
    [
        wine_substrate_capability_row("process", gates),
        wine_substrate_capability_row("exec_env", gates),
        wine_substrate_capability_row("vm", gates),
        wine_substrate_capability_row("renderer2d", gates),
        wine_substrate_capability_row("wm_backend", gates),
        wine_substrate_capability_row("posix_fd", gates),
        wine_substrate_capability_row("fs_semantics", gates),
        wine_substrate_capability_row("ipc_wait", gates),
        wine_substrate_capability_row("pthread", gates),
        wine_substrate_capability_row("dynload", gates),
        wine_substrate_capability_row("audio", gates),
        wine_substrate_capability_row("fonts", gates),
        wine_substrate_capability_row("input", gates),
        wine_substrate_capability_row("async", gates),
        wine_substrate_capability_row("pe_loader", gates),
        wine_substrate_capability_row("nt_bridge", gates),
        wine_substrate_capability_row("hello_exe", gates)
    ]

pub fn wine_substrate_verify_capability(capability: text, evidence_path: text) -> text:
    val current = wine_substrate_capability_state(capability)
    if evidence_path == "":
        return current
    if capability == "research":
        return "verified"
    return current

pub fn wine_substrate_check_process_evidence(serial_log: text) -> text:
    if serial_log.contains("[desktop-e2e] process-backed:resident"):
        return "resident-fallback"
    if serial_log.contains("[desktop-e2e] process-backed:ok app=browser_demo") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=hello_world") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=editor") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=terminal") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=file_manager"):
        return "process-backed"
    return "insufficient-evidence"

pub fn wine_substrate_vm_gate(features: text) -> text:
    return wine_vm_gate(features)

pub fn wine_substrate_exec_env_gate(evidence: text) -> text:
    return wine_simpleos_exec_env_gate(evidence)

pub fn wine_substrate_exec_env_gate_from_serial_log(serial_log: text) -> text:
    return wine_simpleos_exec_env_gate_from_serial_log(serial_log)

pub fn wine_substrate_renderer_gate(features: text) -> text:
    return x11_backend_gate(features)

pub fn wine_substrate_hello_exe_gate(gates: text) -> text:
    if not gates.contains("process=verified"):
        return "blocked"
    if not gates.contains("exec_env=verified"):
        return "blocked"
    if not gates.contains("vm=verified"):
        return "blocked"
    if not gates.contains("host=verified"):
        return "blocked"
    if not gates.contains("posix=verified"):
        return "blocked"
    if not gates.contains("pthread=verified"):
        return "blocked"
    if not gates.contains("dynload=verified"):
        return "blocked"
    if not gates.contains("pe_loader=verified"):
        return "blocked"
    if not gates.contains("async=verified"):
        return "blocked"
    if not gates.contains("nt_bridge=verified"):
        return "blocked"
    return "ready"

pub fn wine_substrate_host_gate(features: text) -> text:
    return wine_host_gate(features)

pub fn wine_substrate_pe_gate(features: text) -> text:
    return wine_pe_gate(features)

pub fn wine_substrate_pe_gate_from_image(data: [u8], dynload_apis: text, policy_evidence: text) -> text:
    return wine_pe_gate_from_image(data, dynload_apis, policy_evidence)

pub fn wine_substrate_async_gate(features: text) -> text:
    return wine_async_gate(features)
