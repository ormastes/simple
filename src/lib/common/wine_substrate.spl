"""Wine substrate readiness gates for SimpleOS compatibility work."""

use common.ui.x11_backend_gate.{x11_backend_gate}
use common.wine_vm_gate.{wine_vm_gate}
use common.wine_host_gate.{wine_host_gate}
use common.wine_pe_gate.{wine_pe_gate}
use common.wine_async_gate.{wine_async_gate}

pub fn wine_substrate_capability_state(capability: text) -> text:
    if capability == "research":
        return "verified"
    if capability == "process":
        return "partial"
    if capability == "vm":
        return "partial"
    if capability == "posix_fd":
        return "partial"
    if capability == "renderer2d":
        return "partial"
    if capability == "wm_backend":
        return "partial"
    if capability == "pthread":
        return "missing"
    if capability == "dynload":
        return "missing"
    if capability == "pe_loader":
        return "missing"
    if capability == "async":
        return "partial"
    if capability == "hello_exe":
        return "blocked"
    return "missing"

pub fn wine_substrate_verify_capability(capability: text, evidence_path: text) -> text:
    val current = wine_substrate_capability_state(capability)
    if evidence_path == "":
        return current
    if capability == "research":
        return "verified"
    return current

pub fn wine_substrate_check_process_evidence(serial_log: text) -> text:
    if serial_log.contains("[desktop-e2e] process-backed:resident"):
        return "resident-fallback"
    if serial_log.contains("[desktop-e2e] process-backed:ok app=browser_demo") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=hello_world") and
       serial_log.contains("[desktop-e2e] process-backed:ok app=editor"):
        return "process-backed"
    return "insufficient-evidence"

pub fn wine_substrate_vm_gate(features: text) -> text:
    return wine_vm_gate(features)

pub fn wine_substrate_renderer_gate(features: text) -> text:
    return x11_backend_gate(features)

pub fn wine_substrate_hello_exe_gate(gates: text) -> text:
    if not gates.contains("process=verified"):
        return "blocked"
    if not gates.contains("vm=verified"):
        return "blocked"
    if not gates.contains("host=verified"):
        return "blocked"
    if not gates.contains("posix=verified"):
        return "blocked"
    if not gates.contains("pthread=verified"):
        return "blocked"
    if not gates.contains("dynload=verified"):
        return "blocked"
    if not gates.contains("pe_loader=verified"):
        return "blocked"
    if not gates.contains("async=verified"):
        return "blocked"
    return "ready"

pub fn wine_substrate_host_gate(features: text) -> text:
    return wine_host_gate(features)

pub fn wine_substrate_pe_gate(features: text) -> text:
    return wine_pe_gate(features)

pub fn wine_substrate_async_gate(features: text) -> text:
    return wine_async_gate(features)
