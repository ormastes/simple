# Template Engine Filters Module
# Text operations and formatting filters


import template.utilities

# ============================================================================
# FILTERS - Additional Text Operations
# ============================================================================

fn filter_strip_html(s: text) -> text:
    var result = ""
    var in_tag = false
    var i = 0
    while i < s.len():
        val c = s[i:i+1]
        if c == "<":
            in_tag = true
        else:
            if c == ">":
                in_tag = false
            else:
                if not in_tag:
                    result = result + c
        i = i + 1
    result

fn filter_slug(s: text) -> text:
    var result = str_to_lower(s)
    result = str_replace_all(result, " ", "-")
    result = str_replace_all(result, "_", "-")
    # Remove non-alphanumeric except dash
    var clean = ""
    var i = 0
    while i < result.len():
        val c = result[i:i+1]
        val is_valid = is_alnum_char(c) or c == "-"
        if is_valid:
            clean = clean + c
        i = i + 1
    clean

fn filter_word_count(s: text) -> text:
    val words = str_split(str_trim(s), " ")
    var count = 0
    for word in words:
        if str_trim(word).len() > 0:
            count = count + 1
    int_to_str(count)

fn filter_line_count(s: text) -> text:
    val lines = str_split(s, "\n")
    int_to_str(lines.len())

fn filter_char_count(s: text) -> text:
    int_to_str(s.len())

fn filter_first_line(s: text) -> text:
    val lines = str_split(s, "\n")
    if lines.len() > 0:
        return lines[0]
    ""

fn filter_last_line(s: text) -> text:
    val lines = str_split(s, "\n")
    if lines.len() > 0:
        return lines[lines.len() - 1]
    ""

fn filter_indent(s: text, spaces: i64) -> text:
    val lines = str_split(s, "\n")
    val indent = str_repeat(" ", spaces)
    var result: [text] = []
    for line in lines:
        result.push(indent + line)
    join_strs(result, "\n")

fn filter_dedent(s: text) -> text:
    val lines = str_split(s, "\n")
    # Find minimum indent
    var min_indent = 9999
    for line in lines:
        if str_trim(line).len() > 0:
            var spaces = 0
            var i = 0
            while i < line.len() and line[i:i+1] == " ":
                spaces = spaces + 1
                i = i + 1
            if spaces < min_indent:
                min_indent = spaces
    # Remove min indent from all lines
    var result: [text] = []
    for line in lines:
        if line.len() >= min_indent:
            result.push(line[min_indent:])
        else:
            result.push(line)
    join_strs(result, "\n")

fn filter_quote(s: text) -> text:
    "\"" + s + "\""

fn filter_unquote(s: text) -> text:
    if s.len() >= 2:
        val first = s[0:1]
        val last = s[s.len()-1:s.len()]
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return s[1:s.len()-1]
    s

# ============================================================================
# FILTERS - Number Formatting
# ============================================================================

fn filter_abs(s: text) -> text:
    if s.len() > 0 and s[0:1] == "-":
        return s[1:]
    s

fn filter_format_bytes(bytes: i64) -> text:
    if bytes < 1024:
        return int_to_str(bytes) + " B"
    val kb = bytes / 1024
    if kb < 1024:
        return int_to_str(kb) + " KB"
    val mb = kb / 1024
    if mb < 1024:
        return int_to_str(mb) + " MB"
    val gb = mb / 1024
    int_to_str(gb) + " GB"

fn filter_ordinal(n: i64) -> text:
    val num_str = int_to_str(n)
    val last_digit = n % 10
    val last_two = n % 100
    if last_two >= 11 and last_two <= 13:
        return num_str + "th"
    if last_digit == 1:
        return num_str + "st"
    if last_digit == 2:
        return num_str + "nd"
    if last_digit == 3:
        return num_str + "rd"
    num_str + "th"

fn filter_percentage(n: i64, decimals: i64) -> text:
    int_to_str(n) + "%"

# ============================================================================
# FILTERS - Array/List Operations
# ============================================================================

fn filter_join_list(items: [text], sep: text) -> text:
    join_strs(items, sep)

fn filter_first_item(items: [text]) -> text:
    if items.len() > 0:
        return items[0]
    ""

fn filter_last_item(items: [text]) -> text:
    if items.len() > 0:
        return items[items.len() - 1]
    ""

fn filter_list_length(items: [text]) -> text:
    int_to_str(items.len())

fn filter_sort_list(items: [text]) -> [text]:
    # Simple bubble sort
    var result: [text] = []
    for item in items:
        result.push(item)
    var n = result.len()
    var swapped = true
    while swapped:
        swapped = false
        var i = 1
        while i < n:
            if result[i-1] > result[i]:
                val temp = result[i-1]
                result[i-1] = result[i]
                result[i] = temp
                swapped = true
            i = i + 1
        n = n - 1
    result

fn filter_reverse_list(items: [text]) -> [text]:
    var result: [text] = []
    var i = items.len() - 1
    while i >= 0:
        result.push(items[i])
        i = i - 1
    result

fn filter_unique_list(items: [text]) -> [text]:
    var result: [text] = []
    var seen: [text] = []
    for item in items:
        var found = false
        for s in seen:
            if s == item:
                found = true
        if not found:
            result.push(item)
            seen.push(item)
    result

# ============================================================================
# FILTERS - Web-Specific
# ============================================================================

fn filter_upper(s: text) -> text:
    """Convert string to uppercase."""
    str_to_upper(s)

fn filter_lower(s: text) -> text:
    """Convert string to lowercase."""
    str_to_lower(s)

fn filter_truncate(s: text, len: i64) -> text:
    """Truncate string to len characters, appending '...' if truncated."""
    if s.len() <= len:
        return s
    if len <= 3:
        return s[0:len]
    str_truncate(s, len - 3) + "..."

fn filter_date_format(s: text, fmt: text) -> text:
    """Format a date string according to a format pattern.

    Simple formatting: replaces %Y, %m, %d, %H, %M, %S placeholders.
    Input expected as ISO-like "YYYY-MM-DD HH:MM:SS" or "YYYY-MM-DD".

    Args:
        s: Date string
        fmt: Format string with placeholders

    Returns:
        Formatted date string
    """
    # Parse date parts from ISO format
    var year = ""
    var month = ""
    var day = ""
    var hour = "00"
    var minute = "00"
    var second = "00"

    val parts = str_split(s, " ")
    if parts.len() >= 1:
        val date_parts = str_split(parts[0], "-")
        if date_parts.len() >= 3:
            year = date_parts[0]
            month = date_parts[1]
            day = date_parts[2]

    if parts.len() >= 2:
        val time_parts = str_split(parts[1], ":")
        if time_parts.len() >= 1:
            hour = time_parts[0]
        if time_parts.len() >= 2:
            minute = time_parts[1]
        if time_parts.len() >= 3:
            second = time_parts[2]

    var result = fmt
    result = str_replace_all(result, "%Y", year)
    result = str_replace_all(result, "%m", month)
    result = str_replace_all(result, "%d", day)
    result = str_replace_all(result, "%H", hour)
    result = str_replace_all(result, "%M", minute)
    result = str_replace_all(result, "%S", second)
    result

fn filter_number_format(s: text) -> text:
    """Format a number string with thousand separators.

    e.g., "1234567" -> "1,234,567"

    Args:
        s: Numeric string

    Returns:
        Formatted number with commas
    """
    val trimmed = str_trim(s)
    if trimmed.len() == 0:
        return "0"

    # Handle negative numbers
    var is_negative = false
    var digits = trimmed
    if digits[0:1] == "-":
        is_negative = true
        digits = digits[1:]

    # Split at decimal point
    val dot_parts = str_split(digits, ".")
    var integer_part = dot_parts[0]
    var decimal_part = ""
    if dot_parts.len() > 1:
        decimal_part = dot_parts[1]

    # Insert commas in integer part (from right)
    var result: [text] = []
    var count = 0
    var i = integer_part.len() - 1
    while i >= 0:
        if count > 0 and count % 3 == 0:
            result.push(",")
        result.push(integer_part[i:i + 1])
        count = count + 1
        i = i - 1

    # Reverse
    var formatted = ""
    var j = result.len() - 1
    while j >= 0:
        formatted = formatted + result[j]
        j = j - 1

    if decimal_part.len() > 0:
        formatted = formatted + "." + decimal_part

    if is_negative:
        formatted = "-" + formatted

    formatted

fn filter_url_encode(s: text) -> text:
    """URL-encode a string (percent-encoding)."""
    var parts: [text] = []
    var i = 0
    while i < s.len():
        val c = s[i:i+1]
        val is_safe = is_alnum_char(c) or c == "-" or c == "_" or c == "." or c == "~"
        if is_safe:
            parts.push(c)
        else:
            if c == " ":
                parts.push("+")
            else:
                # Simple percent encoding for common chars
                parts.push("%")
                parts.push(int_to_hex_upper(char_code_val(c)))
        i = i + 1
    join_strs(parts, "")

fn filter_default(s: text, default: text) -> text:
    """Return default value if s is empty.

    Args:
        s: Input string
        default: Default value to use if s is empty

    Returns:
        s if non-empty, default otherwise
    """
    if s.len() == 0:
        return default
    s

# Helpers for url_encode filter
fn char_code_val(c: text) -> i64:
    """Get ASCII code of single character."""
    if c.len() == 0:
        return 0
    # Delegate to runtime
    0

fn int_to_hex_upper(n: i64) -> text:
    """Convert byte to two-char uppercase hex."""
    val hi = n / 16
    val lo = n % 16
    val chars = "0123456789ABCDEF"
    if hi < 16 and lo < 16:
        return chars[hi:hi+1] + chars[lo:lo+1]
    "00"

