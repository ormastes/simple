@allow(unnamed_duplicate_typed_args)
# Template Engine Renderer Module
# Template rendering and execution

import template.types
import template.parse
import template.utilities
import template.context

# ============================================================================
# RENDERER
# ============================================================================

fn render_nodes(nodes: [[text]], ctx: [[text]], registry: [[text]]) -> text:
    var parts: [text] = []
    var i = 0

    while i < nodes.len():
        val node = nodes[i]
        val ntype = node_type(node)

        if ntype == "TEXT":
            parts.push(node_data1(node))
            i = i + 1
        else:
            if ntype == "VAR":
                val var_name = node_data1(node)
                val value = resolve_var(ctx, var_name)
                parts.push(html_escape(value))
                i = i + 1
            else:
                if ntype == "RAW_VAR":
                    val var_name = node_data1(node)
                    val value = resolve_var(ctx, var_name)
                    parts.push(value)
                    i = i + 1
                else:
                    if ntype == "PARTIAL":
                        val partial_name = node_data1(node)
                        val partial_opt = reg_get(registry, partial_name)
                        if partial_opt != nil:
                            val p_nodes = compile_template(partial_opt)
                            parts.push(render_nodes(p_nodes, ctx, registry))
                        i = i + 1
                    else:
                        if ntype == "BLOCK":
                            val block_type = node_data1(node)
                            val block_arg = node_data2(node)

                            if block_type == "if":
                                # Find matching {{/if}}
                                var j = i + 1
                                var depth = 1
                                var if_body: [[text]] = []
                                var else_body: [[text]] = []
                                var in_else = false

                                while j < nodes.len() and depth > 0:
                                    val n = nodes[j]
                                    val nt = node_type(n)

                                    if nt == "BLOCK":
                                        if node_data1(n) == "if":
                                            depth = depth + 1
                                        if node_data1(n) == "else":
                                            if depth == 1:
                                                in_else = true
                                                j = j + 1
                                    if nt == "END_BLOCK":
                                        if node_data1(n) == "if":
                                            depth = depth - 1
                                            if depth == 0:
                                                j = nodes.len()

                                    if depth > 0:
                                        if in_else:
                                            else_body.push(n)
                                        else:
                                            if_body.push(n)
                                    j = j + 1

                                # Evaluate condition
                                val cond_val = resolve_var(ctx, block_arg)
                                if is_truthy(cond_val):
                                    parts.push(render_nodes(if_body, ctx, registry))
                                else:
                                    parts.push(render_nodes(else_body, ctx, registry))

                                i = j
                            else:
                                if block_type == "each":
                                    # Find matching {{/each}}
                                    var j = i + 1
                                    var depth = 1
                                    var loop_body: [[text]] = []

                                    while j < nodes.len() and depth > 0:
                                        val n = nodes[j]
                                        val nt = node_type(n)

                                        if nt == "BLOCK":
                                            if node_data1(n) == "each":
                                                depth = depth + 1
                                        if nt == "END_BLOCK":
                                            if node_data1(n) == "each":
                                                depth = depth - 1
                                                if depth == 0:
                                                    j = nodes.len()

                                        if depth > 0:
                                            loop_body.push(n)
                                        j = j + 1

                                    # Get array from context
                                    # For now, simple implementation - assume comma-separated values
                                    val items_str = resolve_var(ctx, block_arg)
                                    val items = str_split(items_str, ",")

                                    var idx = 0
                                    for item in items:
                                        var loop_ctx = ctx_clone(ctx)
                                        loop_ctx = ctx_set(loop_ctx, "this", str_trim(item))
                                        loop_ctx = ctx_set(loop_ctx, "@index", int_to_str(idx))
                                        loop_ctx = ctx_set(loop_ctx, "@first", if idx == 0: "true" else: "false")
                                        loop_ctx = ctx_set(loop_ctx, "@last", if idx == items.len() - 1: "true" else: "false")
                                        loop_ctx = ctx_set(loop_ctx, "@key", int_to_str(idx))

                                        parts.push(render_nodes(loop_body, loop_ctx, registry))
                                        idx = idx + 1

                                    i = j
                                else:
                                    if block_type == "with":
                                        # Find matching {{/with}}
                                        var j = i + 1
                                        var depth = 1
                                        var with_body: [[text]] = []

                                        while j < nodes.len() and depth > 0:
                                            val n = nodes[j]
                                            val nt = node_type(n)

                                            if nt == "BLOCK":
                                                if node_data1(n) == "with":
                                                    depth = depth + 1
                                            if nt == "END_BLOCK":
                                                if node_data1(n) == "with":
                                                    depth = depth - 1
                                                    if depth == 0:
                                                        j = nodes.len()

                                            if depth > 0:
                                                with_body.push(n)
                                            j = j + 1

                                        # Create new context with variable
                                        var with_ctx = ctx_clone(ctx)
                                        val with_val = resolve_var(ctx, block_arg)
                                        with_ctx = ctx_set(with_ctx, "this", with_val)

                                        parts.push(render_nodes(with_body, with_ctx, registry))
                                        i = j
                                    else:
                                        if block_type == "layout":
                                            # Find matching {{/layout}}
                                            var j = i + 1
                                            var depth = 1
                                            var layout_body: [[text]] = []

                                            while j < nodes.len() and depth > 0:
                                                val n = nodes[j]
                                                val nt = node_type(n)

                                                if nt == "BLOCK":
                                                    if node_data1(n) == "layout":
                                                        depth = depth + 1
                                                if nt == "END_BLOCK":
                                                    if node_data1(n) == "layout":
                                                        depth = depth - 1
                                                        if depth == 0:
                                                            j = nodes.len()

                                                if depth > 0:
                                                    layout_body.push(n)
                                                j = j + 1

                                            # Render the inner content first
                                            val inner_html = render_nodes(layout_body, ctx, registry)

                                            # Look up the layout template by name
                                            val layout_name = block_arg
                                            val layout_opt = reg_get(registry, layout_name)
                                            if layout_opt != nil:
                                                val layout_tmpl = layout_opt
                                                val layout_nodes = compile_template(layout_tmpl)
                                                # Set "body" in context so the layout can use {{{body}}}
                                                var layout_ctx = ctx_clone(ctx)
                                                layout_ctx = ctx_set(layout_ctx, "body", inner_html)
                                                parts.push(render_nodes(layout_nodes, layout_ctx, registry))
                                            else:
                                                # No layout found, just render the inner content
                                                parts.push(inner_html)

                                            i = j
                                        else:
                                            # Unknown block type
                                            i = i + 1
                        else:
                            # Unknown node type or END_BLOCK
                            i = i + 1

    parts.join("")

fn render_template(template: text, ctx: [[text]], registry: [[text]]) -> text:
    val nodes = compile_template(template)
    render_nodes(nodes, ctx, registry)

# ============================================================================
# EXPORTS
# ============================================================================

