use lib.json.parser.{json_parse_with_error}

fn jsonl_is_valid(content: text) -> bool:
    if content == "":
        return false
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line == "":
            if i != lines.len() - 1:
                return false
        elif json_parse_with_error(line).1 != "":
            return false
        i = i + 1
    true

fn jsonl_content_is_valid(content: text?) -> bool:
    if content == nil:
        return false
    jsonl_is_valid(content)
