# C Parser Types
#
# Data types for representing parsed C header elements:
# structs, unions, classes, enums, typedefs, and #define constants.

struct CField:
    name: text
    c_type: text
    bit_width: i32
    is_pointer: bool
    array_size: i32

fn c_field(name: text, c_type: text) -> CField:
    CField(name: name, c_type: c_type, bit_width: -1, is_pointer: false, array_size: -1)

fn c_field_pointer(name: text, c_type: text) -> CField:
    CField(name: name, c_type: c_type, bit_width: -1, is_pointer: true, array_size: -1)

fn c_field_bitfield(name: text, c_type: text, width: i32) -> CField:
    CField(name: name, c_type: c_type, bit_width: width, is_pointer: false, array_size: -1)

fn c_field_array(name: text, c_type: text, size: i32) -> CField:
    CField(name: name, c_type: c_type, bit_width: -1, is_pointer: false, array_size: size)

struct CStruct:
    name: text
    fields: [CField]
    is_union: bool
    is_class: bool

fn c_struct(name: text, fields: [CField]) -> CStruct:
    CStruct(name: name, fields: fields, is_union: false, is_class: false)

fn c_union(name: text, fields: [CField]) -> CStruct:
    CStruct(name: name, fields: fields, is_union: true, is_class: false)

fn c_class(name: text, fields: [CField]) -> CStruct:
    CStruct(name: name, fields: fields, is_union: false, is_class: true)

struct CEnumValue:
    name: text
    value: i64

struct CEnum:
    name: text
    values: [CEnumValue]

fn c_enum(name: text, values: [CEnumValue]) -> CEnum:
    CEnum(name: name, values: values)

struct CTypedef:
    name: text
    target_type: text

fn c_typedef(name: text, target_type: text) -> CTypedef:
    CTypedef(name: name, target_type: target_type)

struct CDefine:
    name: text
    value: text
    is_integer: bool
    int_value: i64

fn c_define(name: text, value: text) -> CDefine:
    CDefine(name: name, value: value, is_integer: false, int_value: 0)

fn c_define_int(name: text, value: text, int_val: i64) -> CDefine:
    CDefine(name: name, value: value, is_integer: true, int_value: int_val)

struct CParseResult:
    structs: [CStruct]
    enums: [CEnum]
    typedefs: [CTypedef]
    defines: [CDefine]
    errors: [text]

fn c_parse_result_empty() -> CParseResult:
    CParseResult(structs: [], enums: [], typedefs: [], defines: [], errors: [])

struct CToken:
    kind: text
    value: text
    line: i32
    col: i32

fn c_token(kind: text, value: text, line: i32, col: i32) -> CToken:
    CToken(kind: kind, value: value, line: line, col: col)
