# C Parser Library
#
# Pure-Simple C/C++ header parser for import_c.
# Extracts struct/union/class/enum definitions and #define constants.

# Re-exported from c_types.spl
export CField
export CStruct
export CEnumValue, CEnum
export CTypedef
export CDefine
export CParseResult
export CToken
export c_field, c_field_pointer, c_field_bitfield, c_field_array
export c_struct, c_union, c_class, c_enum, c_typedef
export c_define, c_define_int, c_parse_result_empty, c_token

# Re-exported from c_lexer.spl
export c_tokenize, c_keyword_kind
export is_c_digit, is_c_alpha, is_c_alnum, is_c_whitespace

# Re-exported from c_preprocessor.spl
export c_preprocess, c_preprocess_with_include_root

# Re-exported from c_struct_parser.spl
export c_parse_all
export parse_struct_or_union, parse_field, parse_enum, parse_typedef

# Re-exported from c_name_match.spl
export normalize_c_name, c_names_match, c_names_match_strict
export c_find_matching_field, c_find_matching_struct

fn parse_c_header(source: text) -> CParseResult:
    parse_c_header_with_defines(source, {})

fn parse_c_header_with_defines(source: text, defines: {text: text}) -> CParseResult:
    val pp_result = c_preprocess(source, defines)
    val preprocessed = pp_result.0
    val pp_defines = pp_result.1
    val tokens = c_tokenize(preprocessed)
    var result = c_parse_all(tokens)
    for d in pp_defines:
        result.defines.push(d)
    result
