# Win FS ACL — access control check for the /win filesystem tree.
#
# Provides: AclDecision, acl_check.

enum AclDecision:
    Allow
    Deny(reason: text)

# Check whether a caller identified by caller_id_path may access a resource
# guarded by acl_id_path. Returns Allow if acl_id_path is empty (public) or
# if caller_id_path has acl_id_path as a prefix.
fn acl_check(caller_id_path: text, acl_id_path: text) -> AclDecision:
    if acl_id_path == "":
        return AclDecision.Allow
    if caller_id_path == acl_id_path:
        return AclDecision.Allow
    if caller_id_path.starts_with(acl_id_path):
        return AclDecision.Allow
    AclDecision.Deny(reason: "caller {caller_id_path} not in acl {acl_id_path}")
