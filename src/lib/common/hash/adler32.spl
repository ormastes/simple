# Adler-32 & Fletcher-32 Checksums
#
# Adler-32: RFC 1950 section 9 — used in zlib/gzip.
# Fletcher-32: lightweight checksum over 16-bit words.
#
# Both are NON-cryptographic; suitable for integrity checks only.


# ============================================================================
# Adler-32 (RFC 1950 section 9)
# ============================================================================

fn adler32(data: [u8]) -> i64:
    """Compute Adler-32 checksum per RFC 1950.

    A = 1 + sum of all bytes (mod 65521)
    B = sum of running A values (mod 65521)
    Result = (B << 16) | A

    Example:
        adler32([])          # 1
        adler32([97])        # 0x00620062
        adler32([97,98,99])  # 0x024D0127
    """
    var a: i64 = 1
    var b: i64 = 0
    var mod_val: i64 = 65521
    var i: i64 = 0
    while i < data.len():
        var byte_val: i64 = data[i].to_i64()
        a = (a + byte_val) % mod_val
        b = (b + a) % mod_val
        i = i + 1
    (b << 16) | a


# ============================================================================
# Fletcher-32
# ============================================================================

fn fletcher32(data: [u8]) -> i64:
    """Compute Fletcher-32 checksum over 16-bit little-endian words.

    If data has odd length, the final byte is padded with a zero high byte.

    sum1 = sum2 = 0
    For each 16-bit word w (LE pairs):
        sum1 = (sum1 + w) % 65535
        sum2 = (sum2 + sum1) % 65535
    Result = (sum2 << 16) | sum1

    Example:
        fletcher32([97, 98, 99, 100])  # pairs: 0x6261, 0x6463
    """
    var sum1: i64 = 0
    var sum2: i64 = 0
    var mod_val: i64 = 65535
    var length: i64 = data.len()
    var i: i64 = 0
    while i < length:
        var lo: i64 = data[i].to_i64()
        var hi: i64 = 0
        if i + 1 < length:
            hi = data[i + 1].to_i64()
        var word: i64 = lo | (hi << 8)
        sum1 = (sum1 + word) % mod_val
        sum2 = (sum2 + sum1) % mod_val
        i = i + 2
    (sum2 << 16) | sum1
