"""Proton readiness gate layered above the SimpleOS Wine substrate."""

use common.wine_substrate.{wine_substrate_full_wine_gate}

pub fn wine_proton_required_features() -> [text]:
    [
        "steam-runtime",
        "pressure-vessel-container",
        "proton-launcher",
        "wine-full",
        "vulkan-loader",
        "vulkan-device",
        "dxvk",
        "vkd3d-proton",
        "steamworks-bridge",
        "controller-input",
        "shader-cache",
        "esync-or-fsync"
    ]

pub fn wine_proton_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in wine_proton_required_features():
        if not features.contains(feature):
            missing.push(feature)
    missing

pub fn wine_proton_feature_gate(features: text) -> text:
    val missing = wine_proton_missing_features(features)
    if missing.len() == 0:
        return "ready"
    "missing-" + missing[0]

pub fn wine_proton_readiness_gate(wine_gates: text, proton_features: text) -> text:
    val wine_state = wine_substrate_full_wine_gate(wine_gates)
    if wine_state != "ready":
        return "blocked-wine-" + wine_state
    val proton_state = wine_proton_feature_gate(proton_features)
    if proton_state != "ready":
        return proton_state
    "ready"

pub fn wine_proton_fixture_features() -> text:
    "steam-runtime pressure-vessel-container proton-launcher wine-full " +
        "vulkan-loader vulkan-device dxvk vkd3d-proton steamworks-bridge " +
        "controller-input shader-cache esync-or-fsync"

pub fn wine_proton_fixture_wine_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified " +
        "user32=verified gdi32=verified kernel32_core=verified host=verified " +
        "posix=verified registry=verified pthread=verified dynload=verified " +
        "audio=verified fonts=verified input=verified pe_loader=verified " +
        "async=verified nt_bridge=verified"
