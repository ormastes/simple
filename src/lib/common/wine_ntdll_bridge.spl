    val dispatch_state = wine_nt_api_ntdll_file_io_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 1:
        return "ntdll-file-io-sequence-count-mismatch"
    if symbols[0] != "NtQueryAttributesFile":
        return "ntdll-file-io-sequence-expected:NtQueryAttributesFile"
    "ready"

fn _ntdll_directory_create_sequence_gate(symbols: [text]) -> text:
    val dispatch_state = wine_nt_api_ntdll_file_io_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 1:
