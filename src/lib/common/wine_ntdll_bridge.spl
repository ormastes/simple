"""Modeled ntdll/Rtl precondition wrappers over the NT bridge contracts."""

use common.wine_nt_api_catalog.{wine_nt_api_ntdll_file_io_dispatch_gate, wine_nt_api_ntdll_virtual_memory_dispatch_gate, wine_nt_api_rtl_heap_dispatch_gate}
use common.wine_nt_file_io.{
    WineNtFileIoResult,
    WineNtFileMetadataResult,
    WineNtFileTable,
    wine_nt_file_close,
    wine_nt_file_create_directory_w,
    wine_nt_file_create_w,
    wine_nt_file_delete_w,
    wine_nt_file_get_attributes_w,
    wine_nt_file_get_information_by_handle,
    wine_nt_file_read,
    wine_nt_file_remove_directory_w,
    wine_nt_file_write
}
use common.wine_nt_heap.{WineNtHeap, WineNtHeapResult, wine_nt_heap_alloc, wine_nt_heap_free}
use common.wine_nt_virtual_memory.{
    WineNtVirtualMemoryResult,
    wine_nt_virtual_memory_alloc,
    wine_nt_virtual_memory_free,
    wine_nt_virtual_memory_protect
}
use common.wine_vm_adapter.{WineVmSpace}

class WineNtdllVirtualMemorySequenceResult:
    ok: bool
    error: text
    space: WineVmSpace
    base: i64
    size: i64
    old_perms: text
    operations: text

class WineNtdllFileIoSequenceResult:
    ok: bool
    error: text
    table: WineNtFileTable
    handle: i64
    data: text
    bytes_read: i64
    operations: text

class WineRtlHeapSequenceResult:
    ok: bool
    error: text
    heap: WineNtHeap
    ptr: i64
    size: i64
    operations: text

fn _vm_sequence_result(ok: bool, error: text, space: WineVmSpace, base: i64, size: i64, old_perms: text, operations: text) -> WineNtdllVirtualMemorySequenceResult:
    WineNtdllVirtualMemorySequenceResult(ok: ok, error: error, space: space, base: base, size: size, old_perms: old_perms, operations: operations)

fn _file_sequence_result(ok: bool, error: text, table: WineNtFileTable, handle: i64, data: text, bytes_read: i64, operations: text) -> WineNtdllFileIoSequenceResult:
    WineNtdllFileIoSequenceResult(ok: ok, error: error, table: table, handle: handle, data: data, bytes_read: bytes_read, operations: operations)

fn _heap_sequence_result(ok: bool, error: text, heap: WineNtHeap, ptr: i64, size: i64, operations: text) -> WineRtlHeapSequenceResult:
    WineRtlHeapSequenceResult(ok: ok, error: error, heap: heap, ptr: ptr, size: size, operations: operations)

fn _ntdll_vm_sequence_gate(symbols: [text]) -> text:
    val dispatch_state = wine_nt_api_ntdll_virtual_memory_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 3:
        return "ntdll-virtual-memory-sequence-count-mismatch"
    if symbols[0] != "NtAllocateVirtualMemory":
        return "ntdll-virtual-memory-sequence-expected:NtAllocateVirtualMemory"
    if symbols[1] != "NtProtectVirtualMemory":
        return "ntdll-virtual-memory-sequence-expected:NtProtectVirtualMemory"
    if symbols[2] != "NtFreeVirtualMemory":
        return "ntdll-virtual-memory-sequence-expected:NtFreeVirtualMemory"
    "ready"

fn _ntdll_vm_failure(symbol: text, step: WineNtVirtualMemoryResult, operations: text) -> WineNtdllVirtualMemorySequenceResult:
    _vm_sequence_result(false, symbol + ":" + step.state, step.space, step.base, step.size, step.old_perms, operations)

fn _ntdll_file_sequence_gate(symbols: [text]) -> text:
    val dispatch_state = wine_nt_api_ntdll_file_io_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 3:
        return "ntdll-file-io-sequence-count-mismatch"
    if symbols[0] != "NtCreateFile":
        return "ntdll-file-io-sequence-expected:NtCreateFile"
    if symbols[1] != "NtReadFile":
        return "ntdll-file-io-sequence-expected:NtReadFile"
    if symbols[2] != "NtClose":
        return "ntdll-file-io-sequence-expected:NtClose"
    "ready"

