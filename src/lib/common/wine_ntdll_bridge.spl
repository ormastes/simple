    if symbols.len() != 3:
        return "ntdll-file-io-sequence-count-mismatch"
    if symbols[0] != "NtCreateFile":
        return "ntdll-file-io-sequence-expected:NtCreateFile"
    if symbols[1] != "NtWriteFile":
        return "ntdll-file-io-sequence-expected:NtWriteFile"
    if symbols[2] != "NtClose":
        return "ntdll-file-io-sequence-expected:NtClose"
    "ready"

