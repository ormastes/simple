    val created = wine_ntdll_create_directory(table, path)
    if not created.ok:
        return _ntdll_file_failure("NtCreateFile", created, "")

    _file_sequence_result(true, "", created.table, 0, "", 0, "NtCreateFile")

pub fn wine_ntdll_execute_directory_remove(symbols: [text], table: WineNtFileTable, path: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_directory_remove_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val removed = wine_ntdll_remove_directory(table, path)
    if not removed.ok:
        return _ntdll_file_failure("NtSetInformationFile", removed, "")

    _file_sequence_result(true, "", removed.table, 0, "", 0, "NtSetInformationFile")

pub fn wine_ntdll_execute_file_delete(symbols: [text], table: WineNtFileTable, path: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_file_delete_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val deleted = wine_ntdll_delete_file(table, path)
    if not deleted.ok:
        return _ntdll_file_failure("NtSetInformationFile", deleted, "")

    _file_sequence_result(true, "", deleted.table, 0, "", 0, "NtSetInformationFile")

pub fn wine_rtl_allocate_heap(heap: WineNtHeap, handle: i64, size: i64) -> WineNtHeapResult:
    wine_nt_heap_alloc(heap, handle, size)

pub fn wine_rtl_free_heap(heap: WineNtHeap, handle: i64, ptr: i64) -> WineNtHeapResult:
    wine_nt_heap_free(heap, handle, ptr)

pub fn wine_rtl_execute_heap(symbols: [text], heap: WineNtHeap, handle: i64, size: i64) -> WineRtlHeapSequenceResult:
    val sequence_state = _rtl_heap_sequence_gate(symbols)
    if sequence_state != "ready":
        return _heap_sequence_result(false, sequence_state, heap, 0, 0, "")

    val allocated = wine_rtl_allocate_heap(heap, handle, size)
    if not allocated.ok:
        return _rtl_heap_failure("RtlAllocateHeap", allocated, "")

    val freed = wine_rtl_free_heap(allocated.heap, handle, allocated.ptr)
    if not freed.ok:
        return _rtl_heap_failure("RtlFreeHeap", freed, "RtlAllocateHeap")

    _heap_sequence_result(true, "", freed.heap, allocated.ptr, allocated.size, "RtlAllocateHeap RtlFreeHeap")
