fn _ntdll_file_failure(symbol: text, step: WineNtFileIoResult, operations: text) -> WineNtdllFileIoSequenceResult:
    _file_sequence_result(false, symbol + ":" + step.state, step.table, step.handle, step.data, step.bytes_read, operations)

fn _ntdll_file_metadata_failure(symbol: text, step: WineNtFileMetadataResult, operations: text) -> WineNtdllFileIoSequenceResult:
    _file_sequence_result(false, symbol + ":" + step.state, step.table, step.handle, "", step.value, operations)

fn _rtl_heap_sequence_gate(symbols: [text]) -> text:
    val dispatch_state = wine_nt_api_rtl_heap_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 2:
        return "rtl-heap-sequence-count-mismatch"
    if symbols[0] != "RtlAllocateHeap":
        return "rtl-heap-sequence-expected:RtlAllocateHeap"
    if symbols[1] != "RtlFreeHeap":
        return "rtl-heap-sequence-expected:RtlFreeHeap"
    "ready"

fn _rtl_heap_failure(symbol: text, step: WineNtHeapResult, operations: text) -> WineRtlHeapSequenceResult:
    _heap_sequence_result(false, symbol + ":" + step.state, step.heap, step.ptr, step.size, operations)

pub fn wine_ntdll_required_calls() -> [text]:
    [
        "NtAllocateVirtualMemory",
        "NtProtectVirtualMemory",
        "NtFreeVirtualMemory",
        "NtCreateFile",
        "NtReadFile",
        "NtWriteFile",
        "NtClose",
        "NtQueryInformationFile",
        "NtQueryAttributesFile",
        "NtSetInformationFile",
        "RtlAllocateHeap",
        "RtlFreeHeap"
    ]

pub fn wine_ntdll_allocate_virtual_memory(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineNtVirtualMemoryResult:
    wine_nt_virtual_memory_alloc(space, base, size, perms)

pub fn wine_ntdll_protect_virtual_memory(space: WineVmSpace, base: i64, perms: text) -> WineNtVirtualMemoryResult:
    wine_nt_virtual_memory_protect(space, base, perms)

pub fn wine_ntdll_free_virtual_memory(space: WineVmSpace, base: i64) -> WineNtVirtualMemoryResult:
    wine_nt_virtual_memory_free(space, base)

pub fn wine_ntdll_execute_virtual_memory(symbols: [text], space: WineVmSpace, base: i64, size: i64, alloc_perms: text, protect_perms: text) -> WineNtdllVirtualMemorySequenceResult:
    val sequence_state = _ntdll_vm_sequence_gate(symbols)
    if sequence_state != "ready":
        return _vm_sequence_result(false, sequence_state, space, 0, 0, "", "")

    val allocated = wine_ntdll_allocate_virtual_memory(space, base, size, alloc_perms)
    if not allocated.ok:
        return _ntdll_vm_failure("NtAllocateVirtualMemory", allocated, "")

    val protected = wine_ntdll_protect_virtual_memory(allocated.space, allocated.base, protect_perms)
    if not protected.ok:
        return _ntdll_vm_failure("NtProtectVirtualMemory", protected, "NtAllocateVirtualMemory")

    val freed = wine_ntdll_free_virtual_memory(protected.space, protected.base)
    if not freed.ok:
        return _ntdll_vm_failure("NtFreeVirtualMemory", freed, "NtAllocateVirtualMemory NtProtectVirtualMemory")

    _vm_sequence_result(true, "", freed.space, freed.base, freed.size, protected.old_perms, "NtAllocateVirtualMemory NtProtectVirtualMemory NtFreeVirtualMemory")

pub fn wine_ntdll_create_file(table: WineNtFileTable, path: text) -> WineNtFileIoResult:
    wine_nt_file_create_w(table, path)

pub fn wine_ntdll_create_directory(table: WineNtFileTable, path: text) -> WineNtFileIoResult:
    wine_nt_file_create_directory_w(table, path)

pub fn wine_ntdll_remove_directory(table: WineNtFileTable, path: text) -> WineNtFileIoResult:
    wine_nt_file_remove_directory_w(table, path)

pub fn wine_ntdll_delete_file(table: WineNtFileTable, path: text) -> WineNtFileIoResult:
    wine_nt_file_delete_w(table, path)

pub fn wine_ntdll_query_information_file(table: WineNtFileTable, handle: i64) -> WineNtFileMetadataResult:
    wine_nt_file_get_information_by_handle(table, handle)

pub fn wine_ntdll_query_attributes_file(table: WineNtFileTable, path: text) -> WineNtFileMetadataResult:
    wine_nt_file_get_attributes_w(table, path)

pub fn wine_ntdll_read_file(table: WineNtFileTable, handle: i64, requested_len: i64) -> WineNtFileIoResult:
    wine_nt_file_read(table, handle, requested_len)

pub fn wine_ntdll_write_file(table: WineNtFileTable, handle: i64, data: text) -> WineNtFileIoResult:
    wine_nt_file_write(table, handle, data)

pub fn wine_ntdll_close(table: WineNtFileTable, handle: i64) -> WineNtFileIoResult:
    wine_nt_file_close(table, handle)

pub fn wine_ntdll_execute_file_io(symbols: [text], table: WineNtFileTable, path: text, requested_len: i64) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_file_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val opened = wine_ntdll_create_file(table, path)
    if not opened.ok:
        return _ntdll_file_failure("NtCreateFile", opened, "")

    val read = wine_ntdll_read_file(opened.table, opened.handle, requested_len)
    if not read.ok:
        return _ntdll_file_failure("NtReadFile", read, "NtCreateFile")

    val closed = wine_ntdll_close(read.table, opened.handle)
    if not closed.ok:
        return _ntdll_file_failure("NtClose", closed, "NtCreateFile NtReadFile")

    _file_sequence_result(true, "", closed.table, opened.handle, read.data, read.bytes_read, "NtCreateFile NtReadFile NtClose")

pub fn wine_ntdll_execute_file_write(symbols: [text], table: WineNtFileTable, path: text, data: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_file_write_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val opened = wine_ntdll_create_file(table, path)
    if not opened.ok:
        return _ntdll_file_failure("NtCreateFile", opened, "")

    val written = wine_ntdll_write_file(opened.table, opened.handle, data)
    if not written.ok:
        return _ntdll_file_failure("NtWriteFile", written, "NtCreateFile")

    val closed = wine_ntdll_close(written.table, opened.handle)
    if not closed.ok:
        return _ntdll_file_failure("NtClose", closed, "NtCreateFile NtWriteFile")

    _file_sequence_result(true, "", closed.table, opened.handle, written.data, written.bytes_read, "NtCreateFile NtWriteFile NtClose")

pub fn wine_ntdll_execute_file_information(symbols: [text], table: WineNtFileTable, path: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_file_information_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val opened = wine_ntdll_create_file(table, path)
    if not opened.ok:
        return _ntdll_file_failure("NtCreateFile", opened, "")

    val info = wine_ntdll_query_information_file(opened.table, opened.handle)
    if not info.ok:
        return _ntdll_file_metadata_failure("NtQueryInformationFile", info, "NtCreateFile")

    val closed = wine_ntdll_close(info.table, opened.handle)
    if not closed.ok:
        return _ntdll_file_failure("NtClose", closed, "NtCreateFile NtQueryInformationFile")

    _file_sequence_result(true, "", closed.table, opened.handle, "", info.value, "NtCreateFile NtQueryInformationFile NtClose")

pub fn wine_ntdll_execute_file_attributes(symbols: [text], table: WineNtFileTable, path: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_file_attributes_sequence_gate(symbols)
    if sequence_state != "ready":
        return _file_sequence_result(false, sequence_state, table, 0, "", 0, "")

    val attributes = wine_ntdll_query_attributes_file(table, path)
    if not attributes.ok:
        return _ntdll_file_metadata_failure("NtQueryAttributesFile", attributes, "")

    _file_sequence_result(true, "", attributes.table, 0, "", attributes.value, "NtQueryAttributesFile")

pub fn wine_ntdll_execute_directory_create(symbols: [text], table: WineNtFileTable, path: text) -> WineNtdllFileIoSequenceResult:
    val sequence_state = _ntdll_directory_create_sequence_gate(symbols)
    if sequence_state != "ready":
