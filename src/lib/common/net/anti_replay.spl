# ============================================================================
# common/net/anti_replay.spl — shared replay-protection value types (ipsec)
# ============================================================================

struct SecurityParameterIndex:
    """32-bit SPI selecting the security association (RFC 4303 §2.1)."""
    value: u32

impl SecurityParameterIndex:
    static fn new(v: u32) -> SecurityParameterIndex:
        SecurityParameterIndex(value: v)

export SecurityParameterIndex
