# ============================================================================
# common/net/routing.spl — shared routing-protocol value types (bgp consumer)
# ============================================================================

use std.common.net.addr.{IpAddr}

struct RouterId:
    """4-octet router identifier (dotted-quad on the wire)."""
    octets: [u8]

impl RouterId:
    static fn from_bytes(bytes: [u8]) -> Result<RouterId, text>:
        if bytes.len() != 4:
            return Err("RouterId.from_bytes: need 4 bytes, got {bytes.len()}")
        Ok(RouterId(octets: bytes))

    fn to_bytes() -> [u8]:
        self.octets

struct RoutePrefix:
    """CIDR route prefix: address + significant-bit count."""
    addr: IpAddr
    prefix_len: u8

fn route_prefix(addr: IpAddr, prefix_len: u8) -> RoutePrefix:
    RoutePrefix(addr: addr, prefix_len: prefix_len)

struct RoutingMetric:
    """Generic route preference metric (e.g. BGP MED / local-pref)."""
    value: u32

fn routing_metric(v: u32) -> RoutingMetric:
    RoutingMetric(value: v)

export RouterId, RoutePrefix, RoutingMetric
export route_prefix, routing_metric
