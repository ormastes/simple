# AES-128-GCM and AES-256-GCM — Pure Simple Common Library Port
#
# Ported from:
#   src/lib/nogc_async_mut_noalloc/tls/aes128_gcm.spl  (AES-128 scalar path)
#   src/os/crypto/aes256_gcm.spl                       (AES-256 key expansion)
#
# CRITICAL DIFFERENCES from source files:
#   - NO rt_tls13_* fast-path externs: this file is the KAT test target
#   - NO SIMD: AES-256 block uses the same scalar round loop as AES-128,
#     just 14 rounds with a 240-byte schedule instead of 10 rounds / 176 bytes
#   - ALL word-assembly shifts done in i64 to avoid Cranelift u32 miscompiles
#     (documented in aes256_gcm.spl comments and MEMORY.md f64 pitfall pattern)
#
# Reference: FIPS 197 (AES)
# Reference: NIST SP 800-38D (GCM)

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# AES S-Box (FIPS 197, Section 5.1.1) — inline table, no SFFI
# ============================================================================

fn _aes_sbox_table() -> [u8]:
    """Pre-computed AES S-box (256 entries)."""
    var t: [u8] = []
    # Row 0
    t.push(0x63) t.push(0x7c) t.push(0x77) t.push(0x7b)
    t.push(0xf2) t.push(0x6b) t.push(0x6f) t.push(0xc5)
    t.push(0x30) t.push(0x01) t.push(0x67) t.push(0x2b)
    t.push(0xfe) t.push(0xd7) t.push(0xab) t.push(0x76)
    # Row 1
    t.push(0xca) t.push(0x82) t.push(0xc9) t.push(0x7d)
    t.push(0xfa) t.push(0x59) t.push(0x47) t.push(0xf0)
    t.push(0xad) t.push(0xd4) t.push(0xa2) t.push(0xaf)
    t.push(0x9c) t.push(0xa4) t.push(0x72) t.push(0xc0)
    # Row 2
    t.push(0xb7) t.push(0xfd) t.push(0x93) t.push(0x26)
    t.push(0x36) t.push(0x3f) t.push(0xf7) t.push(0xcc)
    t.push(0x34) t.push(0xa5) t.push(0xe5) t.push(0xf1)
    t.push(0x71) t.push(0xd8) t.push(0x31) t.push(0x15)
    # Row 3
    t.push(0x04) t.push(0xc7) t.push(0x23) t.push(0xc3)
    t.push(0x18) t.push(0x96) t.push(0x05) t.push(0x9a)
    t.push(0x07) t.push(0x12) t.push(0x80) t.push(0xe2)
    t.push(0xeb) t.push(0x27) t.push(0xb2) t.push(0x75)
    # Row 4
    t.push(0x09) t.push(0x83) t.push(0x2c) t.push(0x1a)
    t.push(0x1b) t.push(0x6e) t.push(0x5a) t.push(0xa0)
    t.push(0x52) t.push(0x3b) t.push(0xd6) t.push(0xb3)
    t.push(0x29) t.push(0xe3) t.push(0x2f) t.push(0x84)
    # Row 5
    t.push(0x53) t.push(0xd1) t.push(0x00) t.push(0xed)
    t.push(0x20) t.push(0xfc) t.push(0xb1) t.push(0x5b)
    t.push(0x6a) t.push(0xcb) t.push(0xbe) t.push(0x39)
    t.push(0x4a) t.push(0x4c) t.push(0x58) t.push(0xcf)
    # Row 6
    t.push(0xd0) t.push(0xef) t.push(0xaa) t.push(0xfb)
    t.push(0x43) t.push(0x4d) t.push(0x33) t.push(0x85)
    t.push(0x45) t.push(0xf9) t.push(0x02) t.push(0x7f)
    t.push(0x50) t.push(0x3c) t.push(0x9f) t.push(0xa8)
    # Row 7
    t.push(0x51) t.push(0xa3) t.push(0x40) t.push(0x8f)
    t.push(0x92) t.push(0x9d) t.push(0x38) t.push(0xf5)
    t.push(0xbc) t.push(0xb6) t.push(0xda) t.push(0x21)
    t.push(0x10) t.push(0xff) t.push(0xf3) t.push(0xd2)
    # Row 8
    t.push(0xcd) t.push(0x0c) t.push(0x13) t.push(0xec)
    t.push(0x5f) t.push(0x97) t.push(0x44) t.push(0x17)
    t.push(0xc4) t.push(0xa7) t.push(0x7e) t.push(0x3d)
    t.push(0x64) t.push(0x5d) t.push(0x19) t.push(0x73)
    # Row 9
    t.push(0x60) t.push(0x81) t.push(0x4f) t.push(0xdc)
    t.push(0x22) t.push(0x2a) t.push(0x90) t.push(0x88)
    t.push(0x46) t.push(0xee) t.push(0xb8) t.push(0x14)
    t.push(0xde) t.push(0x5e) t.push(0x0b) t.push(0xdb)
    # Row A
    t.push(0xe0) t.push(0x32) t.push(0x3a) t.push(0x0a)
    t.push(0x49) t.push(0x06) t.push(0x24) t.push(0x5c)
    t.push(0xc2) t.push(0xd3) t.push(0xac) t.push(0x62)
    t.push(0x91) t.push(0x95) t.push(0xe4) t.push(0x79)
    # Row B
    t.push(0xe7) t.push(0xc8) t.push(0x37) t.push(0x6d)
    t.push(0x8d) t.push(0xd5) t.push(0x4e) t.push(0xa9)
    t.push(0x6c) t.push(0x56) t.push(0xf4) t.push(0xea)
    t.push(0x65) t.push(0x7a) t.push(0xae) t.push(0x08)
    # Row C
    t.push(0xba) t.push(0x78) t.push(0x25) t.push(0x2e)
    t.push(0x1c) t.push(0xa6) t.push(0xb4) t.push(0xc6)
    t.push(0xe8) t.push(0xdd) t.push(0x74) t.push(0x1f)
    t.push(0x4b) t.push(0xbd) t.push(0x8b) t.push(0x8a)
    # Row D
    t.push(0x70) t.push(0x3e) t.push(0xb5) t.push(0x66)
    t.push(0x48) t.push(0x03) t.push(0xf6) t.push(0x0e)
    t.push(0x61) t.push(0x35) t.push(0x57) t.push(0xb9)
    t.push(0x86) t.push(0xc1) t.push(0x1d) t.push(0x9e)
    # Row E
    t.push(0xe1) t.push(0xf8) t.push(0x98) t.push(0x11)
    t.push(0x69) t.push(0xd9) t.push(0x8e) t.push(0x94)
    t.push(0x9b) t.push(0x1e) t.push(0x87) t.push(0xe9)
    t.push(0xce) t.push(0x55) t.push(0x28) t.push(0xdf)
    # Row F
    t.push(0x8c) t.push(0xa1) t.push(0x89) t.push(0x0d)
    t.push(0xbf) t.push(0xe6) t.push(0x42) t.push(0x68)
    t.push(0x41) t.push(0x99) t.push(0x2d) t.push(0x0f)
    t.push(0xb0) t.push(0x54) t.push(0xbb) t.push(0x16)
    t

fn _aes_sbox(index: i64) -> u8:
    """Look up a byte in the AES S-box table."""
    val tbl = _aes_sbox_table()
    _u8_at(tbl, (index & 0xFF).to_u64())

# AES Round Constants (RCON)
fn _aes_rcon_table() -> [u8]:
    """AES RCON byte values for rounds 1..10."""
    var t: [u8] = []
    t.push(0x01) t.push(0x02) t.push(0x04) t.push(0x08)
    t.push(0x10) t.push(0x20) t.push(0x40) t.push(0x80)
    t.push(0x1b) t.push(0x36)
    t

fn _aes_rcon_byte(index: i64) -> i64:
    """Return RCON byte for round (index+1) as i64 (the top byte of the Rcon word)."""
    val tbl = _aes_rcon_table()
    _u8_at(tbl, index.to_u64()).to_i64() & 0xFF

# ============================================================================
# Result Type for Decryption (shared for both AES-128 and AES-256)
# ============================================================================

enum AesGcmResult:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# AES Core Helpers (round-count agnostic — used for both 128 and 256)
# ============================================================================

fn _aes_sub_word_bytes(b0: u8, b1: u8, b2: u8, b3: u8) -> [u8]:
    """Apply S-box to four bytes; return as [b0', b1', b2', b3']."""
    var r: [u8] = []
    r.push(_aes_sbox(b0.to_i64()))
    r.push(_aes_sbox(b1.to_i64()))
    r.push(_aes_sbox(b2.to_i64()))
    r.push(_aes_sbox(b3.to_i64()))
    r

fn _aes_sub_bytes(state: [u8]) -> [u8]:
    """Apply S-box substitution to each byte of the 16-byte state."""
    var result: [u8] = []
    var i: u64 = 0
    while i < 16:
        result.push(_aes_sbox(_u8_at(state, i).to_i64()))
        i = i + 1
    result

fn _aes_shift_rows(state: [u8]) -> [u8]:
    """Cyclically shift rows left: row k shifted by k positions."""
    var r: [u8] = []
    r.push(_u8_at(state, 0))
    r.push(_u8_at(state, 5))
    r.push(_u8_at(state, 10))
    r.push(_u8_at(state, 15))
    r.push(_u8_at(state, 4))
    r.push(_u8_at(state, 9))
    r.push(_u8_at(state, 14))
    r.push(_u8_at(state, 3))
    r.push(_u8_at(state, 8))
    r.push(_u8_at(state, 13))
    r.push(_u8_at(state, 2))
    r.push(_u8_at(state, 7))
    r.push(_u8_at(state, 12))
    r.push(_u8_at(state, 1))
    r.push(_u8_at(state, 6))
    r.push(_u8_at(state, 11))
    r

fn _aes_xtime(b: u8) -> u8:
    """Multiply by x (0x02) in GF(2^8) with reduction polynomial 0x1b."""
    val shifted = (b.to_i64() << 1) & 0xFF
    if (b & 0x80) != 0:
        (shifted ^ 0x1b).to_u8()
    else:
        shifted.to_u8()

fn _aes_gf_mul(a: u8, b: u8) -> u8:
    """Multiply two bytes in GF(2^8)."""
    var result: u8 = 0x00
    var aa = a
    var bb = b
    var i: u64 = 0
    while i < 8:
        if (bb & 0x01) != 0:
            result = result ^ aa
        aa = _aes_xtime(aa)
        bb = (bb >> 1).to_u8()
        i = i + 1
    result

fn _aes_mix_columns(state: [u8]) -> [u8]:
    """Mix columns using GF(2^8) matrix multiplication."""
    var r: [u8] = []
    var c: u64 = 0
    while c < 4:
        val base = c * 4
        val s0 = _u8_at(state, base)
        val s1 = _u8_at(state, base + 1)
        val s2 = _u8_at(state, base + 2)
        val s3 = _u8_at(state, base + 3)
        r.push(_aes_gf_mul(0x02, s0) ^ _aes_gf_mul(0x03, s1) ^ s2 ^ s3)
        r.push(s0 ^ _aes_gf_mul(0x02, s1) ^ _aes_gf_mul(0x03, s2) ^ s3)
        r.push(s0 ^ s1 ^ _aes_gf_mul(0x02, s2) ^ _aes_gf_mul(0x03, s3))
        r.push(_aes_gf_mul(0x03, s0) ^ s1 ^ s2 ^ _aes_gf_mul(0x02, s3))
        c = c + 1
    r

fn _aes_add_round_key(state: [u8], round_keys: [u8], round: u64) -> [u8]:
    """XOR state with the 16-byte round key for the given round."""
    var result: [u8] = []
    val base = round * 16
    var i: u64 = 0
    while i < 16:
        result.push(_u8_at(state, i) ^ _u8_at(round_keys, base + i))
        i = i + 1
    result

# ============================================================================
# AES-128 Key Expansion (FIPS 197, Section 5.2)
# Nk=4, Nr=10, total_words=44
# ============================================================================

fn aes128_key_expansion(key: [u8]) -> [u8]:
    """Expand 16-byte AES-128 key into 176 round-key bytes."""
    val nk: u64 = 4
    val total_words: u64 = 44

    var expanded: [u8] = []

    var i: u64 = 0
    while i < 16:
        expanded.push(_u8_at(key, i))
        i = i + 1

    var word_idx: u64 = nk
    while word_idx < total_words:
        val prev_base = (word_idx - 1) * 4
        var t0 = _u8_at(expanded, prev_base)
        var t1 = _u8_at(expanded, prev_base + 1)
        var t2 = _u8_at(expanded, prev_base + 2)
        var t3 = _u8_at(expanded, prev_base + 3)

        if (word_idx % nk) == 0:
            # RotWord + SubWord + Rcon
            # RotWord: [t0,t1,t2,t3] -> [t1,t2,t3,t0]
            val r0 = _aes_sbox(t1.to_i64())
            val r1 = _aes_sbox(t2.to_i64())
            val r2 = _aes_sbox(t3.to_i64())
            val r3 = _aes_sbox(t0.to_i64())
            # XOR Rcon into first byte only (Rcon word = [rcon_byte, 0, 0, 0])
            val rcon_b: i64 = _aes_rcon_byte(((word_idx / nk) - 1).to_i64())
            t0 = (r0.to_i64() ^ rcon_b).to_u8()
            t1 = r1
            t2 = r2
            t3 = r3

        val prev_word_base = (word_idx - nk) * 4
        expanded.push(_u8_at(expanded, prev_word_base) ^ t0)
        expanded.push(_u8_at(expanded, prev_word_base + 1) ^ t1)
        expanded.push(_u8_at(expanded, prev_word_base + 2) ^ t2)
        expanded.push(_u8_at(expanded, prev_word_base + 3) ^ t3)
        word_idx = word_idx + 1

    expanded

# ============================================================================
# AES-256 Key Expansion (FIPS 197, Section 5.2)
# Nk=8, Nr=14, total_words=60
#   word_idx % 8 == 0: RotWord + SubWord + Rcon
#   word_idx % 8 == 4: SubWord ONLY (no RotWord, no Rcon)
#   otherwise: normal XOR
# ============================================================================

fn aes256_key_expansion(key: [u8]) -> [u8]:
    """Expand 32-byte AES-256 key into 240 round-key bytes (15 round keys)."""
    val nk: u64 = 8
    val total_words: u64 = 60

    var expanded: [u8] = []

    var i: u64 = 0
    while i < 32:
        expanded.push(_u8_at(key, i))
        i = i + 1

    var word_idx: u64 = nk
    while word_idx < total_words:
        val prev_base = (word_idx - 1) * 4
        var t0 = _u8_at(expanded, prev_base)
        var t1 = _u8_at(expanded, prev_base + 1)
        var t2 = _u8_at(expanded, prev_base + 2)
        var t3 = _u8_at(expanded, prev_base + 3)

        val m = word_idx % nk
        if m == 0:
            # RotWord + SubWord + Rcon
            val r0 = _aes_sbox(t1.to_i64())
            val r1 = _aes_sbox(t2.to_i64())
            val r2 = _aes_sbox(t3.to_i64())
            val r3 = _aes_sbox(t0.to_i64())
            val rcon_b: i64 = _aes_rcon_byte(((word_idx / nk) - 1).to_i64())
            t0 = (r0.to_i64() ^ rcon_b).to_u8()
            t1 = r1
            t2 = r2
            t3 = r3
        else:
            if m == 4:
                # AES-256-only: SubWord without RotWord, no Rcon
                t0 = _aes_sbox(t0.to_i64())
                t1 = _aes_sbox(t1.to_i64())
                t2 = _aes_sbox(t2.to_i64())
                t3 = _aes_sbox(t3.to_i64())

        val prev_word_base = (word_idx - nk) * 4
        expanded.push(_u8_at(expanded, prev_word_base) ^ t0)
        expanded.push(_u8_at(expanded, prev_word_base + 1) ^ t1)
        expanded.push(_u8_at(expanded, prev_word_base + 2) ^ t2)
        expanded.push(_u8_at(expanded, prev_word_base + 3) ^ t3)
        word_idx = word_idx + 1

    expanded

# ============================================================================
# AES Block Encryption (scalar, round-count parametric)
#
# AES-128: pass round_keys from aes128_key_expansion (176 bytes), num_rounds=10
# AES-256: pass round_keys from aes256_key_expansion (240 bytes), num_rounds=14
# ============================================================================

fn _aes_encrypt_block(plaintext: [u8], round_keys: [u8], num_rounds: u64) -> [u8]:
    """Encrypt one 16-byte block with the given round schedule and round count."""
    var state = _aes_add_round_key(plaintext, round_keys, 0)

    var round: u64 = 1
    while round < num_rounds:
        state = _aes_sub_bytes(state)
        state = _aes_shift_rows(state)
        state = _aes_mix_columns(state)
        state = _aes_add_round_key(state, round_keys, round)
        round = round + 1

    state = _aes_sub_bytes(state)
    state = _aes_shift_rows(state)
    _aes_add_round_key(state, round_keys, num_rounds)

fn aes128_encrypt_block(plaintext: [u8], round_keys: [u8]) -> [u8]:
    """Encrypt one 16-byte block with AES-128 (pre-expanded 176-byte schedule)."""
    _aes_encrypt_block(plaintext, round_keys, 10)

fn aes256_encrypt_block(plaintext: [u8], round_keys: [u8]) -> [u8]:
    """Encrypt one 16-byte block with AES-256 (pre-expanded 240-byte schedule)."""
    _aes_encrypt_block(plaintext, round_keys, 14)

# ============================================================================
# GF(2^128) Multiplication for GHASH
# Polynomial: x^128 + x^7 + x^2 + x + 1  (R = 0xE1000000...)
# ============================================================================

fn gf128_mul(x: [u8], y: [u8]) -> [u8]:
    """Multiply two 128-bit elements in GF(2^128)."""
    var z: [u8] = []
    var i: u64 = 0
    while i < 16:
        z.push(0x00u8)
        i = i + 1

    var v: [u8] = []
    i = 0
    while i < 16:
        v.push(_u8_at(y, i))
        i = i + 1

    i = 0
    while i < 128:
        val byte_idx = i / 8
        val bit_idx = 7 - (i % 8)

        if ((_u8_at(x, byte_idx) >> bit_idx) & 0x01) != 0:
            var z_next: [u8] = []
            var j: u64 = 0
            while j < 16:
                z_next.push(_u8_at(z, j) ^ _u8_at(v, j))
                j = j + 1
            z = z_next

        val lsb = _u8_at(v, 15) & 0x01
        var v_next: [u8] = []
        var first = (_u8_at(v, 0).to_i64() >> 1) & 0x7F
        if lsb != 0:
            first = first ^ 0xE1
        v_next.push(first.to_u8())
        var j: u64 = 1
        while j < 16:
            val cur: i64 = _u8_at(v, j).to_i64() & 0xFF
            val prev: i64 = _u8_at(v, j - 1).to_i64() & 0xFF
            v_next.push((((cur >> 1) | ((prev & 0x01) << 7)) & 0xFF).to_u8())
            j = j + 1
        v = v_next
        i = i + 1

    z

# ============================================================================
# GHASH (NIST SP 800-38D, Section 6.4)
# Processes: pad(AAD) || pad(ciphertext) || len(A)||len(C)
# ============================================================================

fn _ghash_block(h: [u8], y: [u8], x_block: [u8]) -> [u8]:
    """Process one 16-byte block: Y_i = (Y_{i-1} XOR X_i) * H."""
    var xored: [u8] = []
    var i: u64 = 0
    while i < 16:
        xored.push(_u8_at(y, i) ^ _u8_at(x_block, i))
        i = i + 1
    gf128_mul(xored, h)

fn _pad_to_16(data: [u8]) -> [u8]:
    """Pad data to a multiple of 16 bytes with zeros."""
    var result: [u8] = []
    var i: u64 = 0
    while i < data.len().to_u64():
        result.push(_u8_at(data, i))
        i = i + 1
    while (result.len() % 16) != 0:
        result.push(0x00u8)
    result

fn _aesgcm_append_bytes(a: [u8], b: [u8]) -> [u8]:
    """Concatenate two byte arrays."""
    var out: [u8] = []
    var i: u64 = 0
    while i < a.len().to_u64():
        out.push(_u8_at(a, i))
        i = i + 1
    i = 0
    while i < b.len().to_u64():
        out.push(_u8_at(b, i))
        i = i + 1
    out

fn ghash(h: [u8], aad: [u8], ciphertext: [u8]) -> [u8]:
    """Compute GHASH for GCM: pad(A) || pad(C) || len(A)||len(C)."""
    var y: [u8] = []
    var i: u64 = 0
    while i < 16:
        y.push(0x00u8)
        i = i + 1

    # Process padded AAD blocks
    val padded_aad = _pad_to_16(aad)
    i = 0
    while i < padded_aad.len().to_u64():
        var block: [u8] = []
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_aad, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    # Process padded ciphertext blocks
    val padded_ct = _pad_to_16(ciphertext)
    i = 0
    while i < padded_ct.len().to_u64():
        var block: [u8] = []
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_ct, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    # Final block: len(A) || len(C) in bits, each as 64-bit big-endian
    # Use i64 for shifts to avoid Cranelift u32/u64 miscompile on wide shifts
    val aad_bits: i64 = aad.len().to_i64() * 8
    val ct_bits: i64 = ciphertext.len().to_i64() * 8

    var len_block: [u8] = []
    len_block.push(((aad_bits >> 56) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 48) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 40) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 32) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 24) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 16) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 8) & 0xFF).to_u8())
    len_block.push((aad_bits & 0xFF).to_u8())
    len_block.push(((ct_bits >> 56) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 48) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 40) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 32) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 24) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 16) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 8) & 0xFF).to_u8())
    len_block.push((ct_bits & 0xFF).to_u8())

    _ghash_block(h, y, len_block)

# ============================================================================
# GCTR — AES-CTR with Incrementing Counter (NIST SP 800-38D, Section 6.5)
# ============================================================================

fn _inc32(counter: [u8]) -> [u8]:
    """Increment the rightmost 32 bits of a 16-byte counter block.

    All arithmetic done in i64 to avoid Cranelift u32 miscompile on shifts.
    """
    val b12: i64 = _u8_at(counter, 12).to_i64() & 0xFF
    val b13: i64 = _u8_at(counter, 13).to_i64() & 0xFF
    val b14: i64 = _u8_at(counter, 14).to_i64() & 0xFF
    val b15: i64 = _u8_at(counter, 15).to_i64() & 0xFF
    val c: i64 = (b12 << 24) | (b13 << 16) | (b14 << 8) | b15
    val c_inc: i64 = (c + 1) & 0xFFFFFFFF

    var result: [u8] = []
    var i: u64 = 0
    while i < 12:
        result.push(_u8_at(counter, i))
        i = i + 1
    result.push(((c_inc >> 24) & 0xFF).to_u8())
    result.push(((c_inc >> 16) & 0xFF).to_u8())
    result.push(((c_inc >> 8) & 0xFF).to_u8())
    result.push((c_inc & 0xFF).to_u8())
    result

fn _gctr(round_keys: [u8], icb: [u8], input: [u8], num_rounds: u64) -> [u8]:
    """AES-CTR mode: encrypts each block by XORing with AES_K(counter).

    num_rounds controls which AES variant is used (10=AES-128, 14=AES-256).
    """
    if input.len() == 0:
        return []

    var output: [u8] = []
    var cb = icb
    val num_full_blocks = input.len().to_u64() / 16

    var i: u64 = 0
    while i < num_full_blocks:
        val enc_cb = _aes_encrypt_block(cb, round_keys, num_rounds)
        val offset = i * 16
        var j: u64 = 0
        while j < 16:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1
        cb = _inc32(cb)
        i = i + 1

    val remaining = input.len().to_u64() % 16
    if remaining > 0:
        val enc_cb = _aes_encrypt_block(cb, round_keys, num_rounds)
        val offset = num_full_blocks * 16
        var j: u64 = 0
        while j < remaining:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1

    output

# ============================================================================
# J0 Construction (common to both AES-128 and AES-256 GCM)
# ============================================================================

fn _make_j0(nonce: [u8]) -> [u8]:
    """Construct J0 = nonce || 0x00000001 from a 12-byte nonce."""
    var j0: [u8] = []
    var i: u64 = 0
    while i < 12:
        j0.push(_u8_at(nonce, i))
        i = i + 1
    j0.push(0x00u8)
    j0.push(0x00u8)
    j0.push(0x00u8)
    j0.push(0x01u8)
    j0

# ============================================================================
# AES-128-GCM Encryption / Decryption
# ============================================================================

fn aes128_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """AES-128-GCM authenticated encryption.

    Returns ciphertext || 16-byte authentication tag.
    """
    val round_keys = aes128_key_expansion(key)

    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00u8)
        i = i + 1
    val h = aes128_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val icb = _inc32(j0)
    val ciphertext = _gctr(round_keys, icb, plaintext, 10)
    val s = ghash(h, aad, ciphertext)
    val tag = _gctr(round_keys, j0, s, 10)

    _aesgcm_append_bytes(ciphertext, tag)

fn aes128_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> AesGcmResult:
    """AES-128-GCM authenticated decryption with constant-time tag comparison.

    Returns AesGcmResult.Ok(plaintext) or AesGcmResult.Err on tag mismatch.
    """
    val round_keys = aes128_key_expansion(key)

    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00u8)
        i = i + 1
    val h = aes128_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val s = ghash(h, aad, ciphertext)
    val expected_tag = _gctr(round_keys, j0, s, 10)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    i = 0
    while i < 16:
        diff = diff | (_u8_at(expected_tag, i) ^ _u8_at(tag, i))
        i = i + 1

    if diff != 0:
        return AesGcmResult.Err("authentication tag mismatch")

    val icb = _inc32(j0)
    AesGcmResult.Ok(data: _gctr(round_keys, icb, ciphertext, 10))

# ============================================================================
# AES-256-GCM Encryption / Decryption
# ============================================================================

fn aes256_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """AES-256-GCM authenticated encryption.

    Returns ciphertext || 16-byte authentication tag.
    AES-256 block encryption uses pure scalar 14-round loop (no SIMD).
    """
    val round_keys = aes256_key_expansion(key)

    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00u8)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val icb = _inc32(j0)
    val ciphertext = _gctr(round_keys, icb, plaintext, 14)
    val s = ghash(h, aad, ciphertext)
    val tag = _gctr(round_keys, j0, s, 14)

    _aesgcm_append_bytes(ciphertext, tag)

fn aes256_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> AesGcmResult:
    """AES-256-GCM authenticated decryption with constant-time tag comparison.

    Returns AesGcmResult.Ok(plaintext) or AesGcmResult.Err on tag mismatch.
    AES-256 block encryption uses pure scalar 14-round loop (no SIMD).
    """
    val round_keys = aes256_key_expansion(key)

    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00u8)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val s = ghash(h, aad, ciphertext)
    val expected_tag = _gctr(round_keys, j0, s, 14)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    var i2: u64 = 0
    while i2 < 16:
        diff = diff | (_u8_at(expected_tag, i2) ^ _u8_at(tag, i2))
        i2 = i2 + 1

    if diff != 0:
        return AesGcmResult.Err("authentication tag mismatch")

    val icb = _inc32(j0)
    AesGcmResult.Ok(data: _gctr(round_keys, icb, ciphertext, 14))

# ============================================================================
# Exports
# ============================================================================

export AesGcmResult
export ghash
export gf128_mul
export aes128_key_expansion
export aes128_encrypt_block
export aes128_gcm_encrypt
export aes128_gcm_decrypt
export aes256_key_expansion
export aes256_encrypt_block
export aes256_gcm_encrypt
export aes256_gcm_decrypt
