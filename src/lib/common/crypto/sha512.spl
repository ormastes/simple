        val big_s0_72 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_72 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_72 = _wadd64(big_s0_72, maj_72)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_72)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_72, temp2_72)

        val big_s1_73 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_73 = (e & (f ^ g)) ^ g
        val temp1_73 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_73), ch_73), k[73]), w[73])
        val big_s0_73 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_73 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_73 = _wadd64(big_s0_73, maj_73)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_73)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_73, temp2_73)

        val big_s1_74 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_74 = (e & (f ^ g)) ^ g
        val temp1_74 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_74), ch_74), k[74]), w[74])
        val big_s0_74 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_74 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_74 = _wadd64(big_s0_74, maj_74)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_74)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_74, temp2_74)

        val big_s1_75 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_75 = (e & (f ^ g)) ^ g
        val temp1_75 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_75), ch_75), k[75]), w[75])
        val big_s0_75 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_75 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_75 = _wadd64(big_s0_75, maj_75)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_75)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_75, temp2_75)

        val big_s1_76 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_76 = (e & (f ^ g)) ^ g
        val temp1_76 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_76), ch_76), k[76]), w[76])
        val big_s0_76 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_76 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_76 = _wadd64(big_s0_76, maj_76)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_76)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_76, temp2_76)

        val big_s1_77 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_77 = (e & (f ^ g)) ^ g
        val temp1_77 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_77), ch_77), k[77]), w[77])
        val big_s0_77 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_77 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_77 = _wadd64(big_s0_77, maj_77)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_77)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_77, temp2_77)

        val big_s1_78 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_78 = (e & (f ^ g)) ^ g
        val temp1_78 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_78), ch_78), k[78]), w[78])
        val big_s0_78 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_78 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_78 = _wadd64(big_s0_78, maj_78)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_78)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_78, temp2_78)

        val big_s1_79 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_79 = (e & (f ^ g)) ^ g
        val temp1_79 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_79), ch_79), k[79]), w[79])
        val big_s0_79 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_79 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_79 = _wadd64(big_s0_79, maj_79)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_79)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_79, temp2_79)

        h0 = _wadd64(h0, a)
        h1 = _wadd64(h1, b)
        h2 = _wadd64(h2, c)
        h3 = _wadd64(h3, d)
        h4 = _wadd64(h4, e)
        h5 = _wadd64(h5, f)
        h6 = _wadd64(h6, g)
        h7 = _wadd64(h7, hh)
        block_offset = block_offset + 128

    # Produce 64-byte result — caller slices as needed.
    var result: [i64] = []
    val words = [h0, h1, h2, h3, h4, h5, h6, h7]
    var wi2 = 0
    while wi2 < 8:
        val wd = words[wi2]
        result.push(_lshr64(wd, 56) & 255)
        result.push(_lshr64(wd, 48) & 255)
        result.push(_lshr64(wd, 40) & 255)
        result.push(_lshr64(wd, 32) & 255)
        result.push(_lshr64(wd, 24) & 255)
        result.push(_lshr64(wd, 16) & 255)
        result.push(_lshr64(wd,  8) & 255)
        result.push( wd              & 255)
        wi2 = wi2 + 1
    result

# SHA-512 of a byte list. Returns 64-byte list.
fn sha512_bytes(data: [i64]) -> [i64]:
    _sha512_core(data, _sha512_init())

# SHA-512/256 of a byte list. Returns first 32 bytes of SHA-512 with distinct IV.
fn sha512_256_bytes(data: [i64]) -> [i64]:
    val full = _sha512_core(data, _sha512_256_init())
    var result: [i64] = []
    var i = 0
    while i < 32:
        result.push(full[i])
        i = i + 1
    result

# SHA-512 of text input. Returns 128-char lowercase hex string.
fn sha512_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_bytes(text_to_bytes(data)))

# SHA-512/256 of text input. Returns 64-char lowercase hex string.
fn sha512_256_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_256_bytes(text_to_bytes(data)))

# ============================================================================
# SHA-384 (FIPS 180-4 §5.3.4) — SHA-512 with distinct IV, first 48 bytes.
# ============================================================================

fn _sha384_init() -> [i64]:
    [
        -3766243637369397544,  # h0 — 0xCBBB9D5DC1059ED8
         7105036623409894663,  # h1 — 0x629A292A367CD507
        -7973340178411365097,  # h2 — 0x9159015A3070DD17
         1526699215303891257,  # h3 — 0x152FECD8F70E5939
         7436329637833083697,  # h4 — 0x67332667FFC00B31
        -8163818279084223215,  # h5 — 0x8EB44A8768581511
        -2662702644619276377,  # h6 — 0xDB0C2E0D64F98FA7
         5167115440072839076   # h7 — 0x47B5481DBEFA4FA4
    ]

# SHA-384 of a byte list. Returns 48-byte list (first 6 of 8 hash words).
fn sha384_bytes(data: [i64]) -> [i64]:
    val full = _sha512_core(data, _sha384_init())
    var result: [i64] = []
    var i = 0
    while i < 48:
        result.push(full[i])
        i = i + 1
    result

# SHA-384 of text input. Returns 96-char lowercase hex string.
fn sha384_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha384_bytes(text_to_bytes(data)))

# SHA-512 round function — used by the MIR optimizer pattern recogniser.
fn sha512_round(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, hh: i64, k: i64, w: i64) -> (i64, i64):
    val big_s1 = _rotr64(e, 14) ^ _rotr64(e, 18) ^ _rotr64(e, 41)
    val ch     = (e & f) ^ ((e ^ -1) & g)
    val temp1  = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1), ch), k), w)
    val big_s0 = _rotr64(a, 28) ^ _rotr64(a, 34) ^ _rotr64(a, 39)
    val maj    = (a & b) ^ (a & c) ^ (b & c)
    val temp2  = _wadd64(big_s0, maj)
    (_wadd64(temp1, temp2), _wadd64(d, temp1))

# Message schedule sigma_0 — used by MIR optimizer.
fn sha512_msg_schedule_1(w: i64) -> i64:
    _rotr64(w, 1) ^ _rotr64(w, 8) ^ _lshr64(w, 7)

# Message schedule sigma_1 — used by MIR optimizer.
fn sha512_msg_schedule_2(w: i64) -> i64:
    _rotr64(w, 19) ^ _rotr64(w, 61) ^ _lshr64(w, 6)
