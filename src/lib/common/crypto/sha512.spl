# SHA-512 hash implementation per FIPS 180-4.
# Provides sha512_bytes (bytes -> bytes) and sha512_text (text -> hex).
# Also provides sha512_256_bytes and sha384_bytes variants.
#
# Interpreter workarounds:
# 1. >> on i64 is arithmetic (sign-extending). Use _lshr64 helpers for logical shifts.
#    See: doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md
# 2. + on i64 panics on overflow (not wrapping). Use _wadd64 for all 64-bit additions.
#    See: doc/08_tracking/bug/interpreter_i64_add_overflow_not_wrapping_2026-06-15.md


# Logical right-shift of a 64-bit signed i64 by n bits (1..63).
# The interpreter's >> on i64 is arithmetic (sign-extending for negative values).
# This helper strips the sign bit, shifts the lower 63 bits, then adds back
# the contribution of the original bit-63.
fn _lshr64(x: i64, n: i64) -> i64:
    if n <= 0:
        return x
    if n >= 64:
        return 0
    # Shift the lower 63 bits (always logical for non-negative values).
    val low63 = (x & 9223372036854775807) >> n
    if x < 0:
        # Bit 63 was set; after logical right-shift by n it contributes bit (63-n).
        low63 | (1 << (63 - n))
    else:
        low63

# Rotate-right 64-bit value by n bits using logical shift for the right half.
fn _rotr64(x: i64, n: i64) -> i64:
    val s = n & 63
    if s == 0:
        return x
    _lshr64(x, s) | (x << (64 - s))

fn _lshr64_6(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 6
    if x < 0: low63 | (1 << 57) else: low63

fn _lshr64_7(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 7
    if x < 0: low63 | (1 << 56) else: low63

fn _lshr64_1(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 1
    if x < 0: low63 | (1 << 62) else: low63

fn _lshr64_8(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 8
    if x < 0: low63 | (1 << 55) else: low63

fn _lshr64_19(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 19
    if x < 0: low63 | (1 << 44) else: low63

fn _lshr64_61(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 61
    if x < 0: low63 | (1 << 2) else: low63

fn _rotr64_1(x: i64) -> i64:
    _lshr64_1(x) | (x << 63)

fn _rotr64_8(x: i64) -> i64:
    _lshr64_8(x) | (x << 56)

fn _rotr64_19(x: i64) -> i64:
    _lshr64_19(x) | (x << 45)

fn _rotr64_61(x: i64) -> i64:
    _lshr64_61(x) | (x << 3)

fn _lshr64_14(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 14
    if x < 0: low63 | (1 << 49) else: low63

fn _lshr64_18(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 18
    if x < 0: low63 | (1 << 45) else: low63

fn _lshr64_41(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 41
    if x < 0: low63 | (1 << 22) else: low63

fn _rotr64_14(x: i64) -> i64:
    _lshr64_14(x) | (x << 50)

fn _rotr64_18(x: i64) -> i64:
    _lshr64_18(x) | (x << 46)

fn _rotr64_41(x: i64) -> i64:
    _lshr64_41(x) | (x << 23)

fn _lshr64_28(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 28
    if x < 0: low63 | (1 << 35) else: low63

fn _lshr64_34(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 34
    if x < 0: low63 | (1 << 29) else: low63

fn _lshr64_39(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 39
    if x < 0: low63 | (1 << 24) else: low63

fn _rotr64_28(x: i64) -> i64:
    _lshr64_28(x) | (x << 36)

fn _rotr64_34(x: i64) -> i64:
    _lshr64_34(x) | (x << 30)

fn _rotr64_39(x: i64) -> i64:
    _lshr64_39(x) | (x << 25)

fn _sha512_schedule_word(wm16: i64, wm15: i64, wm7: i64, wm2: i64) -> i64:
    val s0 = _rotr64_1(wm15) ^ _rotr64_8(wm15) ^ _lshr64_7(wm15)
    val s1 = _rotr64_19(wm2) ^ _rotr64_61(wm2) ^ _lshr64_6(wm2)
    _wadd64(_wadd64(_wadd64(wm16, s0), wm7), s1)

# _wadd64: wrapping 64-bit addition workaround for the interpreter.
# The interpreter panics on i64 overflow (ops.rs:99 uses left+right not wrapping_add).
# This splits into 32-bit halves to avoid overflow, then recombines.
# See bug: doc/08_tracking/bug/interpreter_i64_add_overflow_not_wrapping_2026-06-15.md
fn _lshr64_32(x: i64) -> i64:
    val low63 = (x & 9223372036854775807) >> 32
    if x < 0: low63 | (1 << 31) else: low63

fn _wadd64(a: i64, b: i64) -> i64:
    val lo = (a & 4294967295) + (b & 4294967295)
    val hi = _lshr64_32(a) + _lshr64_32(b) + _lshr64_32(lo)
    (hi << 32) | (lo & 4294967295)

# Legacy no-op for MIR optimizer pattern recogniser (sha512_round).
fn _mask64(x: i64) -> i64:
    x

var _sha512_k_words: [i64] = [
           4794697086780616226,     8158064640168781261,
          -5349999486874862801,    -1606136188198331460,
           4131703408338449720,     6480981068601479193,
