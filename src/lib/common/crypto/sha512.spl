fn _sha512_k() -> [i64]:
    # FIPS 180-4 §4.2.3 — 80 round constants (fractional cube roots of primes 2..409)
    # Stored as signed i64 (two's-complement of the unsigned 64-bit value).
    _sha512_k_words

# SHA-512 initial hash values (FIPS 180-4 §5.3.5 — fractional sqrt of primes 2..19).
fn _sha512_init() -> [i64]:
    [
         7640891576956012808,  # h0 — 0x6a09e667f3bcc908
        -4942790177534073029,  # h1 — 0xbb67ae8584caa73b
         4354685564936845355,  # h2 — 0x3c6ef372fe94f82b
        -6534734903238641935,  # h3 — 0xa54ff53a5f1d36f1
         5840696475078001361,  # h4 — 0x510e527fade682d1
        -7276294671716946913,  # h5 — 0x9b05688c2b3e6c1f
         2270897969802886507,  # h6 — 0x1f83d9abfb41bd6b
         6620516959819538809   # h7 — 0x5be0cd19137e2179
    ]

# SHA-512/256 initial hash values (distinct IV per FIPS 180-4 §5.3.6.2).
fn _sha512_256_init() -> [i64]:
    [
         2463787394917988140,  # h0 — 0x22312194fc2bf72c
        -6965556091613846334,  # h1 — 0x9f555fa3c84c64c2
         2563595384472711505,  # h2 — 0x2393b86b6f53b151
        -7622211418569250115,  # h3 — 0x963877195940eabd
        -7626776825740460061,  # h4 — 0x96283ee2a88effe3
        -4729309413028513390,  # h5 — 0xbe5e1e2553863992
         3098927326965381290,  # h6 — 0x2b0199fc2c85b8aa
         1060366662362279074   # h7 — 0x0eb72ddc81c52ca2
    ]

fn _sha512_core(data: [i64], init: [i64]) -> [i64]:
    val k = _sha512_k()
    var h0 = init[0]
    var h1 = init[1]
    var h2 = init[2]
    var h3 = init[3]
    var h4 = init[4]
    var h5 = init[5]
    var h6 = init[6]
    var h7 = init[7]

    # Pre-processing: pad message.
    val data_len = data.len()
    var padded = data
    var pi = 0
    while pi < data_len:
        padded[pi] = padded[pi] & 255
        pi = pi + 1

    # Append 0x80 byte.
    padded.push(128)

    # Pad with zeros until length ≡ 112 mod 128.
    val rem = padded.len() % 128
    val zero_pad_count = if rem <= 112: 112 - rem else: 240 - rem
    var zero_i = 0
    while zero_i < zero_pad_count:
        padded.push(0)
        zero_i = zero_i + 1

    # Append 128-bit bit-length (big-endian). High 64 bits are zero for any
    # message shorter than 2^64 / 8 bytes (more than enough).
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    val bit_len = data_len * 8
    padded.push((bit_len >> 56) & 255)
    padded.push((bit_len >> 48) & 255)
    padded.push((bit_len >> 40) & 255)
    padded.push((bit_len >> 32) & 255)
    padded.push((bit_len >> 24) & 255)
    padded.push((bit_len >> 16) & 255)
    padded.push((bit_len >>  8) & 255)
    padded.push( bit_len              & 255)

    # Process each 128-byte block.
    val total_len = padded.len()
    var block_offset = 0
    while block_offset < total_len:
        # Build message schedule w[0..79].
        var w: [i64] = []
        var wi = 0
        while wi < 16:
            val base = block_offset + wi * 8
            var word = 0
            var bi = 0
            while bi < 8:
                word = _mask64((word << 8) | (padded[base + bi] & 255))
                bi = bi + 1
            w.push(word)
            wi = wi + 1

        w.push(_sha512_schedule_word(w[0], w[1], w[9], w[14]))
        w.push(_sha512_schedule_word(w[1], w[2], w[10], w[15]))
        w.push(_sha512_schedule_word(w[2], w[3], w[11], w[16]))
        w.push(_sha512_schedule_word(w[3], w[4], w[12], w[17]))
        w.push(_sha512_schedule_word(w[4], w[5], w[13], w[18]))
        w.push(_sha512_schedule_word(w[5], w[6], w[14], w[19]))
        w.push(_sha512_schedule_word(w[6], w[7], w[15], w[20]))
        w.push(_sha512_schedule_word(w[7], w[8], w[16], w[21]))

        w.push(_sha512_schedule_word(w[8], w[9], w[17], w[22]))
        w.push(_sha512_schedule_word(w[9], w[10], w[18], w[23]))
        w.push(_sha512_schedule_word(w[10], w[11], w[19], w[24]))
        w.push(_sha512_schedule_word(w[11], w[12], w[20], w[25]))
        w.push(_sha512_schedule_word(w[12], w[13], w[21], w[26]))
        w.push(_sha512_schedule_word(w[13], w[14], w[22], w[27]))
        w.push(_sha512_schedule_word(w[14], w[15], w[23], w[28]))
        w.push(_sha512_schedule_word(w[15], w[16], w[24], w[29]))

        w.push(_sha512_schedule_word(w[16], w[17], w[25], w[30]))
        w.push(_sha512_schedule_word(w[17], w[18], w[26], w[31]))
        w.push(_sha512_schedule_word(w[18], w[19], w[27], w[32]))
        w.push(_sha512_schedule_word(w[19], w[20], w[28], w[33]))
        w.push(_sha512_schedule_word(w[20], w[21], w[29], w[34]))
        w.push(_sha512_schedule_word(w[21], w[22], w[30], w[35]))
        w.push(_sha512_schedule_word(w[22], w[23], w[31], w[36]))
        w.push(_sha512_schedule_word(w[23], w[24], w[32], w[37]))

        w.push(_sha512_schedule_word(w[24], w[25], w[33], w[38]))
        w.push(_sha512_schedule_word(w[25], w[26], w[34], w[39]))
        w.push(_sha512_schedule_word(w[26], w[27], w[35], w[40]))
        w.push(_sha512_schedule_word(w[27], w[28], w[36], w[41]))
        w.push(_sha512_schedule_word(w[28], w[29], w[37], w[42]))
        w.push(_sha512_schedule_word(w[29], w[30], w[38], w[43]))
        w.push(_sha512_schedule_word(w[30], w[31], w[39], w[44]))
        w.push(_sha512_schedule_word(w[31], w[32], w[40], w[45]))

        w.push(_sha512_schedule_word(w[32], w[33], w[41], w[46]))
        w.push(_sha512_schedule_word(w[33], w[34], w[42], w[47]))
        w.push(_sha512_schedule_word(w[34], w[35], w[43], w[48]))
        w.push(_sha512_schedule_word(w[35], w[36], w[44], w[49]))
        w.push(_sha512_schedule_word(w[36], w[37], w[45], w[50]))
        w.push(_sha512_schedule_word(w[37], w[38], w[46], w[51]))
        w.push(_sha512_schedule_word(w[38], w[39], w[47], w[52]))
        w.push(_sha512_schedule_word(w[39], w[40], w[48], w[53]))

        w.push(_sha512_schedule_word(w[40], w[41], w[49], w[54]))
        w.push(_sha512_schedule_word(w[41], w[42], w[50], w[55]))
        w.push(_sha512_schedule_word(w[42], w[43], w[51], w[56]))
        w.push(_sha512_schedule_word(w[43], w[44], w[52], w[57]))
        w.push(_sha512_schedule_word(w[44], w[45], w[53], w[58]))
        w.push(_sha512_schedule_word(w[45], w[46], w[54], w[59]))
        w.push(_sha512_schedule_word(w[46], w[47], w[55], w[60]))
        w.push(_sha512_schedule_word(w[47], w[48], w[56], w[61]))

        w.push(_sha512_schedule_word(w[48], w[49], w[57], w[62]))
        w.push(_sha512_schedule_word(w[49], w[50], w[58], w[63]))
        w.push(_sha512_schedule_word(w[50], w[51], w[59], w[64]))
        w.push(_sha512_schedule_word(w[51], w[52], w[60], w[65]))
        w.push(_sha512_schedule_word(w[52], w[53], w[61], w[66]))
        w.push(_sha512_schedule_word(w[53], w[54], w[62], w[67]))
        w.push(_sha512_schedule_word(w[54], w[55], w[63], w[68]))
        w.push(_sha512_schedule_word(w[55], w[56], w[64], w[69]))

        w.push(_sha512_schedule_word(w[56], w[57], w[65], w[70]))
        w.push(_sha512_schedule_word(w[57], w[58], w[66], w[71]))
        w.push(_sha512_schedule_word(w[58], w[59], w[67], w[72]))
        w.push(_sha512_schedule_word(w[59], w[60], w[68], w[73]))
        w.push(_sha512_schedule_word(w[60], w[61], w[69], w[74]))
        w.push(_sha512_schedule_word(w[61], w[62], w[70], w[75]))
        w.push(_sha512_schedule_word(w[62], w[63], w[71], w[76]))
        w.push(_sha512_schedule_word(w[63], w[64], w[72], w[77]))

        var a  = h0
        var b  = h1
        var c  = h2
        var d  = h3
        var e  = h4
        var f  = h5
        var g  = h6
        var hh = h7

        var ri = 0
        while ri < 8:
            val big_s1_r14 = _rotr64_14(e)
            val big_s1_r18 = _rotr64_18(e)
            val big_s1_r41 = _rotr64_41(e)
            val big_s1 = big_s1_r14 ^ big_s1_r18 ^ big_s1_r41
            val ch     = (e & (f ^ g)) ^ g
            val temp1  = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1), ch), k[ri]), w[ri])
            val big_s0 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
            val maj    = (a & b) ^ (a & c) ^ (b & c)
            val temp2  = _wadd64(big_s0, maj)

            hh = g
            g  = f
            f  = e
            e  = _wadd64(d, temp1)
            d  = c
            c  = b
            b  = a
            a  = _wadd64(temp1, temp2)
            ri = ri + 1

        val big_s1_8 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_8 = (e & (f ^ g)) ^ g
        val temp1_8 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_8), ch_8), k[8]), w[8])
        val big_s0_8 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_8 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_8 = _wadd64(big_s0_8, maj_8)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_8)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_8, temp2_8)

        val big_s1_9 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_9 = (e & (f ^ g)) ^ g
        val temp1_9 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_9), ch_9), k[9]), w[9])
        val big_s0_9 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_9 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_9 = _wadd64(big_s0_9, maj_9)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_9)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_9, temp2_9)

        val big_s1_10 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_10 = (e & (f ^ g)) ^ g
        val temp1_10 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_10), ch_10), k[10]), w[10])
        val big_s0_10 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_10 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_10 = _wadd64(big_s0_10, maj_10)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_10)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_10, temp2_10)

        val big_s1_11 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_11 = (e & (f ^ g)) ^ g
        val temp1_11 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_11), ch_11), k[11]), w[11])
        val big_s0_11 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_11 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_11 = _wadd64(big_s0_11, maj_11)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_11)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_11, temp2_11)

        val big_s1_12 = _rotr64_14(e) ^ _rotr64_18(e) ^ _rotr64_41(e)
        val ch_12 = (e & (f ^ g)) ^ g
        val temp1_12 = _wadd64(_wadd64(_wadd64(_wadd64(hh, big_s1_12), ch_12), k[12]), w[12])
        val big_s0_12 = _rotr64_28(a) ^ _rotr64_34(a) ^ _rotr64_39(a)
        val maj_12 = (a & b) ^ (a & c) ^ (b & c)
        val temp2_12 = _wadd64(big_s0_12, maj_12)
        hh = g
        g  = f
        f  = e
        e  = _wadd64(d, temp1_12)
        d  = c
        c  = b
        b  = a
        a  = _wadd64(temp1_12, temp2_12)

