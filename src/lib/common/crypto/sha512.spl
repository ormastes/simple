# SHA-512 hash implementation per FIPS 180-4.
# Provides sha512_bytes (bytes -> bytes) and sha512_text (text -> hex).
# Also provides sha512_256_bytes and sha384_bytes variants.
#
# NOTE: The interpreter's >> on i64 is arithmetic (sign-extending).
# All right-shifts of 64-bit words use _lshr64 (logical) to avoid
# corrupting negative (high-bit-set) values. See bug doc:
#   doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md

# Logical right-shift of a 64-bit signed i64 by n bits (1..63).
# The interpreter's >> on i64 is arithmetic (sign-extending for negative values).
# This helper strips the sign bit, shifts the lower 63 bits, then adds back
# the contribution of the original bit-63.
fn _lshr64(x: i64, n: i64) -> i64:
    if n <= 0:
        return x
    if n >= 64:
        return 0
    # Shift the lower 63 bits (always logical for non-negative values).
    val low63 = (x & 9223372036854775807) >> n
    if x < 0:
        # Bit 63 was set; after logical right-shift by n it contributes bit (63-n).
        low63 | (1 << (63 - n))
    else:
        low63

# Rotate-right 64-bit value by n bits using logical shift for the right half.
fn _rotr64(x: i64, n: i64) -> i64:
    val s = n & 63
    if s == 0:
        return x
    _lshr64(x, s) | (x << (64 - s))

# i64 addition wraps naturally in the interpreter (two's-complement).
# _mask64 is a no-op kept for documentation clarity.
fn _mask64(x: i64) -> i64:
    x

fn _sha512_k() -> [i64]:
    # FIPS 180-4 §4.2.3 — 80 round constants (fractional cube roots of primes 2..409)
    # Stored as signed i64 (two's-complement of the unsigned 64-bit value).
    [
           4794697086780616226,     8158064640168781261,
          -5349999486874862801,    -1606136188198331460,
           4131703408338449720,     6480981068601479193,
          -7908458776815382629,    -6116909921290321640,
          -2880145864133508542,     1334009975649890238,
           2608012711638119052,     6128411473006802146,
           8268148722764581231,    -9160688886553864527,
          -7215885187991268811,    -4495734319001033068,
          -1973867731355612462,    -1171420211273849373,
           1135362057144423861,     2597628984639134821,
           3308224258029322869,     5365058923640841347,
           6679025012923562964,     8573033837759648693,
          -7476448914759557205,    -6327057829258317296,
          -5763719355590565569,    -4658551843659510044,
          -4116276920077217854,    -3051310485924567259,
            489312712824947311,     1452737877330783856,
           2861767655752347644,     3322285676063803686,
           5560940570517711597,     5996557281743188959,
           7280758554555802590,     8532644243296465576,
          -9096487096722542874,    -7894198246740708037,
          -6719396339535248540,    -6333637450476146687,
          -4446306890439682159,    -4076793802049405392,
          -3345356375505022440,    -2983346525034927856,
           -860691631967231958,     1182934255886127544,
           1847814050463011016,     2177327727835720531,
           2830643537854262169,     3796741975233480872,
           4115178125766777443,     5681478168544905931,
           6601373596472566643,     7507060721942968483,
           8399075790359081724,     8693463985226723168,
          -8878714635349349518,    -8302665154208450068,
          -8016688836872298968,    -6606660893046293015,
          -4685533653050689259,    -4147400797238176981,
          -3880063495543823972,    -3348786107499101689,
          -1523767162380948706,     -757361751448694408,
            500013540394364858,      748580250866718886,
           1242879168328830382,     1977374033974150939,
           2944078676154940804,     3659926193048069267,
           4368137639120453308,     4836135668995329356,
           5532061633213252278,     6448918945643986474,
           6902733635092675308,     7801388544844847127
    ]

# SHA-512 initial hash values (FIPS 180-4 §5.3.5 — fractional sqrt of primes 2..19).
fn _sha512_init() -> [i64]:
    [
         7640891576956012808,  # h0 — 0x6a09e667f3bcc908
        -4942790177534073029,  # h1 — 0xbb67ae8584caa73b
         4354685564936845355,  # h2 — 0x3c6ef372fe94f82b
        -6534734903238641935,  # h3 — 0xa54ff53a5f1d36f1
         5840696475078001361,  # h4 — 0x510e527fade682d1
        -7276294671716946913,  # h5 — 0x9b05688c2b3e6c1f
         2270897969802886507,  # h6 — 0x1f83d9abfb41bd6b
         6620516959819538809   # h7 — 0x5be0cd19137e2179
    ]

# SHA-512/256 initial hash values (distinct IV per FIPS 180-4 §5.3.6.2).
fn _sha512_256_init() -> [i64]:
    [
         2463787394917988140,  # h0 — 0x22312194fc2bf72c
        -6965556091613846334,  # h1 — 0x9f555fa3c84c64c2
         2563595384472711505,  # h2 — 0x2393b86b6f53b151
        -7622211418569250115,  # h3 — 0x963877195940eabd
        -7626776825740460061,  # h4 — 0x96283ee2a88effe3
        -4729309413028513390,  # h5 — 0xbe5e1e2553863992
         3098927326965381290,  # h6 — 0x2b0199fc2c85b8aa
         1060366662362279074   # h7 — 0x0eb72ddc81c52ca2
    ]

fn _sha512_core(data: [i64], init: [i64]) -> [i64]:
    val k = _sha512_k()
    var h0 = init[0]
    var h1 = init[1]
    var h2 = init[2]
    var h3 = init[3]
    var h4 = init[4]
    var h5 = init[5]
    var h6 = init[6]
    var h7 = init[7]

    # Pre-processing: pad message.
    val data_len = data.len()
    var padded: [i64] = []
    var pi = 0
    while pi < data_len:
        padded.push(data[pi] & 255)
        pi = pi + 1

    # Append 0x80 byte.
    padded.push(128)

    # Pad with zeros until length ≡ 112 mod 128.
    while padded.len() % 128 != 112:
        padded.push(0)

    # Append 128-bit bit-length (big-endian). High 64 bits are zero for any
    # message shorter than 2^64 / 8 bytes (more than enough).
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    val bit_len = data_len * 8
    padded.push(_lshr64(bit_len, 56) & 255)
    padded.push(_lshr64(bit_len, 48) & 255)
    padded.push(_lshr64(bit_len, 40) & 255)
    padded.push(_lshr64(bit_len, 32) & 255)
    padded.push(_lshr64(bit_len, 24) & 255)
    padded.push(_lshr64(bit_len, 16) & 255)
    padded.push(_lshr64(bit_len,  8) & 255)
    padded.push( bit_len              & 255)

    # Process each 128-byte block.
    val total_len = padded.len()
    var block_offset = 0
    while block_offset < total_len:
        # Build message schedule w[0..79].
        var w: [i64] = []
        var wi = 0
        while wi < 16:
            val base = block_offset + wi * 8
            var word = 0
            var bi = 0
            while bi < 8:
                word = _mask64((word << 8) | (padded[base + bi] & 255))
                bi = bi + 1
            w.push(word)
            wi = wi + 1

        wi = 16
        while wi < 80:
            val w15 = w[wi - 15]
            val w2  = w[wi - 2]
            val s0  = _rotr64(w15, 1) ^ _rotr64(w15,  8) ^ _lshr64(w15, 7)
            val s1  = _rotr64(w2,  19) ^ _rotr64(w2,  61) ^ _lshr64(w2,  6)
            w.push(_mask64(w[wi - 16] + s0 + w[wi - 7] + s1))
            wi = wi + 1

        var a  = h0
        var b  = h1
        var c  = h2
        var d  = h3
        var e  = h4
        var f  = h5
        var g  = h6
        var hh = h7

        var ri = 0
        while ri < 80:
            val big_s1 = _rotr64(e, 14) ^ _rotr64(e, 18) ^ _rotr64(e, 41)
            val ch     = (e & f) ^ ((e ^ -1) & g)
            val temp1  = _mask64(hh + big_s1 + ch + k[ri] + w[ri])
            val big_s0 = _rotr64(a, 28) ^ _rotr64(a, 34) ^ _rotr64(a, 39)
            val maj    = (a & b) ^ (a & c) ^ (b & c)
            val temp2  = _mask64(big_s0 + maj)

            hh = g
            g  = f
            f  = e
            e  = _mask64(d + temp1)
            d  = c
            c  = b
            b  = a
            a  = _mask64(temp1 + temp2)
            ri = ri + 1

        h0 = _mask64(h0 + a)
        h1 = _mask64(h1 + b)
        h2 = _mask64(h2 + c)
        h3 = _mask64(h3 + d)
        h4 = _mask64(h4 + e)
        h5 = _mask64(h5 + f)
        h6 = _mask64(h6 + g)
        h7 = _mask64(h7 + hh)
        block_offset = block_offset + 128

    # Produce 64-byte result — caller slices as needed.
    var result: [i64] = []
    val words = [h0, h1, h2, h3, h4, h5, h6, h7]
    var wi2 = 0
    while wi2 < 8:
        val wd = words[wi2]
        result.push(_lshr64(wd, 56) & 255)
        result.push(_lshr64(wd, 48) & 255)
        result.push(_lshr64(wd, 40) & 255)
        result.push(_lshr64(wd, 32) & 255)
        result.push(_lshr64(wd, 24) & 255)
        result.push(_lshr64(wd, 16) & 255)
        result.push(_lshr64(wd,  8) & 255)
        result.push( wd              & 255)
        wi2 = wi2 + 1
    result

# SHA-512 of a byte list. Returns 64-byte list.
fn sha512_bytes(data: [i64]) -> [i64]:
    _sha512_core(data, _sha512_init())

# SHA-512/256 of a byte list. Returns first 32 bytes of SHA-512 with distinct IV.
fn sha512_256_bytes(data: [i64]) -> [i64]:
    val full = _sha512_core(data, _sha512_256_init())
    var result: [i64] = []
    var i = 0
    while i < 32:
        result.push(full[i])
        i = i + 1
    result

# SHA-512 of text input. Returns 128-char lowercase hex string.
fn sha512_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_bytes(text_to_bytes(data)))

# SHA-512/256 of text input. Returns 64-char lowercase hex string.
fn sha512_256_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_256_bytes(text_to_bytes(data)))

# ============================================================================
# SHA-384 (FIPS 180-4 §5.3.4) — SHA-512 with distinct IV, first 48 bytes.
# ============================================================================

fn _sha384_init() -> [i64]:
    [
        -3766243637369397544,  # h0 — 0xCBBB9D5DC1059ED8
         7105036623409894663,  # h1 — 0x629A292A367CD507
        -7973340178411365097,  # h2 — 0x9159015A3070DD17
         1526699215303891257,  # h3 — 0x152FECD8F70E5939
         7436329637833083697,  # h4 — 0x67332667FFC00B31
        -8163818279084223215,  # h5 — 0x8EB44A8768581511
        -2662702644619276377,  # h6 — 0xDB0C2E0D64F98FA7
         5167115440072839076   # h7 — 0x47B5481DBEFA4FA4
    ]

# SHA-384 of a byte list. Returns 48-byte list (first 6 of 8 hash words).
fn sha384_bytes(data: [i64]) -> [i64]:
    val full = _sha512_core(data, _sha384_init())
    var result: [i64] = []
    var i = 0
    while i < 48:
        result.push(full[i])
        i = i + 1
    result

# SHA-384 of text input. Returns 96-char lowercase hex string.
fn sha384_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha384_bytes(text_to_bytes(data)))

# SHA-512 round function — used by the MIR optimizer pattern recogniser.
fn sha512_round(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, hh: i64, k: i64, w: i64) -> (i64, i64):
    val big_s1 = _rotr64(e, 14) ^ _rotr64(e, 18) ^ _rotr64(e, 41)
    val ch     = (e & f) ^ ((e ^ -1) & g)
    val temp1  = _mask64(hh + big_s1 + ch + k + w)
    val big_s0 = _rotr64(a, 28) ^ _rotr64(a, 34) ^ _rotr64(a, 39)
    val maj    = (a & b) ^ (a & c) ^ (b & c)
    val temp2  = _mask64(big_s0 + maj)
    (_mask64(temp1 + temp2), _mask64(d + temp1))

# Message schedule sigma_0 — used by MIR optimizer.
fn sha512_msg_schedule_1(w: i64) -> i64:
    _rotr64(w, 1) ^ _rotr64(w, 8) ^ _lshr64(w, 7)

# Message schedule sigma_1 — used by MIR optimizer.
fn sha512_msg_schedule_2(w: i64) -> i64:
    _rotr64(w, 19) ^ _rotr64(w, 61) ^ _lshr64(w, 6)
