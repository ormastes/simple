# SHA-512 hash implementation per FIPS 180-4.
# Provides sha512_bytes (bytes -> bytes) and sha512_text (text -> hex).
# Also provides sha512_256_bytes for the SHA-512/256 truncated variant.

use std.common.crypto.types.{rotr64}

fn _sha512_k() -> [i64]:
    [
        -4860131910654869457,  -3765271213870928751,
        -3358684886829493543,   6033498682106468051,
        -1939499636742929359,  -3442798267661807677,
        -3082178679286694619,  -1091578453987022766,
        -3133996822823165286,    782263612083447968,
        1165898338511432769,   1853615725798618998,
        2344308837590404888,   2695827814460289836,
        3264490405339792478,   3403342560557417190,
        4052590843046778476,   4295640609849048049,
        -5029756987661416588,  -4723478553614914747,
        -4518969802624613519,  -3853618665014047817,
        -3630818867753959234,  -2891427943382898563,
        -2780638885499935174,  -2690880884942441617,
        -1659684929049124798,  -1524153041028674478,
        -1401441386565949887,  -1224233019963793481,
        -1165445609572671820,  -1093174155073078849,
         -799023891266981337,   -774388826478929011,
         -580671671697979453,   -526547985680218490,
         -256782476219779804,   -180423060427697285,
          -18765390015849397,     37912432504913344,
          225474613471958888,    544028379780219791,
          617617888427302547,    862489346706088066,
         1067027127060490481,   1166399397820935832,
         1210244765978490788,   1292020064620869444,
         1504947632729052818,   1657812806588285556,
         2066882408289060741,   2115736038380571060,
         2197024862700611786,   2327143090893099672,
         2539361228571748597,   2679700516673700007,
         2806985438701949773,   3217264137592979543,
         3234906787614467018,   3366386073454682680,
         3472841397949684090,   3543537088019921827,
         3642547706099064261,   3791964021012780736,
         3827745622393534593,   3909225720219879977,
         3992856697987200093,   4028774785009293880
    ]

# SHA-512 initial hash values (square roots of primes 1-8).
fn _sha512_init() -> [i64]:
    [
        -7642067888397714487,  # h0
         7105036623409557960,  # h1
         4385272521111709739,  # h2
         6876975876408769150,  # h3
         5326159188479475174,  # h4
        -3741748158063851760,  # h5
         4771910459557716661,  # h6
         3104278802374573697   # h7
    ]

# SHA-512/256 initial hash values (distinct IV per FIPS 180-4 §5.3.6.2).
fn _sha512_256_init() -> [i64]:
    [
        2463787394917988140,   # h0
         -1119749091999781742,  # h1
         3490208391782332773,   # h2
         -3933217789782255174,  # h3
         1088416944426796042,   # h4
        -7999606841994335396,   # h5
        -3618866483543523889,   # h6
        -4110127895562938713    # h7
    ]

fn _sha512_core(data: [i64], init: [i64]) -> [i64]:
    val k = _sha512_k()
    var h0 = init[0]
    var h1 = init[1]
    var h2 = init[2]
    var h3 = init[3]
    var h4 = init[4]
    var h5 = init[5]
    var h6 = init[6]
    var h7 = init[7]

    # Pre-processing: pad message.
    val data_len = data.len()
    var padded: [i64] = []
    var pi = 0
    while pi < data_len:
        padded.push(data[pi])
        pi = pi + 1

    # Append 0x80 byte.
    padded.push(128)

    # Pad with zeros until length ≡ 112 mod 128.
    while padded.len() % 128 != 112:
        padded.push(0)

    # Append 128-bit bit-length (big-endian). High 64 bits are zero for any
    # message shorter than 2^64 / 8 bytes (more than enough).
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    val bit_len = data_len * 8
    padded.push((bit_len >> 56) & 255)
    padded.push((bit_len >> 48) & 255)
    padded.push((bit_len >> 40) & 255)
    padded.push((bit_len >> 32) & 255)
    padded.push((bit_len >> 24) & 255)
    padded.push((bit_len >> 16) & 255)
    padded.push((bit_len >>  8) & 255)
    padded.push( bit_len        & 255)

    # Process each 128-byte block.
    val total_len = padded.len()
    var block_offset = 0
    while block_offset < total_len:
        # Build message schedule w[0..79].
        var w: [i64] = []
        var wi = 0
        while wi < 16:
            val base = block_offset + wi * 8
            var word = 0
            var bi = 0
            while bi < 8:
                word = (word << 8) | (padded[base + bi] & 255)
                bi = bi + 1
            w.push(word)
            wi = wi + 1

        wi = 16
        while wi < 80:
            val w15 = w[wi - 15]
            val w2  = w[wi - 2]
            val s0  = rotr64(w15, 1) ^ rotr64(w15,  8) ^ (w15 >> 7)
            val s1  = rotr64(w2,  19) ^ rotr64(w2,  61) ^ (w2  >> 6)
            w.push(w[wi - 16] + s0 + w[wi - 7] + s1)
            wi = wi + 1

        var a  = h0
        var b  = h1
        var c  = h2
        var d  = h3
        var e  = h4
        var f  = h5
        var g  = h6
        var hh = h7

        var ri = 0
        while ri < 80:
            val big_s1 = rotr64(e, 14) ^ rotr64(e, 18) ^ rotr64(e, 41)
            val ch     = (e & f) ^ ((e ^ -1) & g)
            val temp1  = hh + big_s1 + ch + k[ri] + w[ri]
            val big_s0 = rotr64(a, 28) ^ rotr64(a, 34) ^ rotr64(a, 39)
            val maj    = (a & b) ^ (a & c) ^ (b & c)
            val temp2  = big_s0 + maj

            hh = g
            g  = f
            f  = e
            e  = d + temp1
            d  = c
            c  = b
            b  = a
            a  = temp1 + temp2
            ri = ri + 1

        h0 = h0 + a
        h1 = h1 + b
        h2 = h2 + c
        h3 = h3 + d
        h4 = h4 + e
        h5 = h5 + f
        h6 = h6 + g
        h7 = h7 + hh
        block_offset = block_offset + 128

    # Produce 64-byte (or 32-byte for truncated) hash.
    var result: [i64] = []
    val words = [h0, h1, h2, h3, h4, h5, h6, h7]
    var wi2 = 0
    while wi2 < 8:
        val wd = words[wi2]
        result.push((wd >> 56) & 255)
        result.push((wd >> 48) & 255)
        result.push((wd >> 40) & 255)
        result.push((wd >> 32) & 255)
        result.push((wd >> 24) & 255)
        result.push((wd >> 16) & 255)
        result.push((wd >>  8) & 255)
        result.push( wd        & 255)
        wi2 = wi2 + 1
    result

# SHA-512 of a byte list. Returns 64-byte list.
fn sha512_bytes(data: [i64]) -> [i64]:
    _sha512_core(data, _sha512_init())

# SHA-512/256 of a byte list. Returns first 32 bytes of SHA-512 with distinct IV.
fn sha512_256_bytes(data: [i64]) -> [i64]:
    val full = _sha512_core(data, _sha512_256_init())
    var result: [i64] = []
    var i = 0
    while i < 32:
        result.push(full[i])
        i = i + 1
    result

# SHA-512 of text input. Returns 128-char lowercase hex string.
fn sha512_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_bytes(text_to_bytes(data)))

# SHA-512/256 of text input. Returns 64-char lowercase hex string.
fn sha512_256_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha512_256_bytes(text_to_bytes(data)))

# SHA-512 round function — used by the MIR optimizer pattern recogniser.
fn sha512_round(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, hh: i64, k: i64, w: i64) -> (i64, i64):
    val big_s1 = rotr64(e, 14) ^ rotr64(e, 18) ^ rotr64(e, 41)
    val ch     = (e & f) ^ ((e ^ -1) & g)
    val temp1  = hh + big_s1 + ch + k + w
    val big_s0 = rotr64(a, 28) ^ rotr64(a, 34) ^ rotr64(a, 39)
    val maj    = (a & b) ^ (a & c) ^ (b & c)
    val temp2  = big_s0 + maj
    (temp1 + temp2, d + temp1)

# Message schedule sigma_0 — used by MIR optimizer.
fn sha512_msg_schedule_1(w: i64) -> i64:
    rotr64(w, 1) ^ rotr64(w, 8) ^ (w >> 7)

# Message schedule sigma_1 — used by MIR optimizer.
fn sha512_msg_schedule_2(w: i64) -> i64:
    rotr64(w, 19) ^ rotr64(w, 61) ^ (w >> 6)
