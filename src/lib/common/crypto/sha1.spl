# SHA-1 Hash Implementation
#
# Secure Hash Algorithm 1 — 160-bit output, 64-byte block.
# Pure-Simple implementation following FIPS 180-4 §6.1 and RFC 3174.
#
# WARNING: SHA-1 is cryptographically broken for collision resistance.
# Use ONLY for legacy interop (TLS 1.2 PRF, HOTP/TOTP, PBKDF2-HMAC-SHA-1
# RFC 6070 vectors, RFC 5869 §A.4-§A.6 HKDF test cases). DO NOT use for
# new signature schemes, certificate pinning, or content addressing.
#
# History (2026-05-01): Moved out of legacy_hash.spl into a dedicated
# module so HMAC-SHA-1 / HKDF-SHA-1 / PBKDF2-HMAC-SHA-1 can import a
# named SHA-1 module without dragging in MD5. Streaming
# `create_sha1_context` / `sha1_update` / `sha1_finalize` API mirrors
# SHA-256/SHA-512 conventions; `sha1_init` / `sha1_final` are aliases
# matching the FIPS 180-4 spec wording.

mod crypto.types

# =============================================================================
# SHA-1 Constants and Initial Values
# =============================================================================

# SHA-1 initial hash values (FIPS 180-4 §5.3.1)
fn sha1_initial_hash() -> list:
    [0x67452301, 0xEFCDAB89, 0x98BADCFE, 0x10325476, 0xC3D2E1F0]

# =============================================================================
# SHA-1 Round Functions (FIPS 180-4 §4.1.1)
# =============================================================================

# SHA-1 round selector f_t(b, c, d) per t in 0..79
# reason: positional crypto sha1 API
fn sha1_f(t: i64, b: i64, c: i64, d: i64) -> i64:
    if t < 20:
        # Ch: (b AND c) OR ((NOT b) AND d)
        (b & c) | ((~b) & d)
    else:
        if t < 40:
            # Parity: b XOR c XOR d
            b ^ c ^ d
        else:
            if t < 60:
                # Maj: (b AND c) OR (b AND d) OR (c AND d)
                (b & c) | (b & d) | (c & d)
            else:
                # Parity again
                b ^ c ^ d

# SHA-1 K_t constant per t in 0..79 (FIPS 180-4 §4.2.1)
fn sha1_k(t: i64) -> i64:
    if t < 20:
        0x5A827999
    else:
        if t < 40:
            0x6ED9EBA1
        else:
            if t < 60:
                0x8F1BBCDC
            else:
                0xCA62C1D6

# =============================================================================
# SHA-1 Padding (FIPS 180-4 §5.1.1)
# =============================================================================

# Pad message: append 0x80, zero-pad to 56 mod 64, append 64-bit big-endian length.
fn sha1_pad_message(bytes: list) -> list:
    var padded = []
    var i = 0

    while i < bytes.len():
        padded.push(bytes.get(i))
        i = i + 1

    val original_len = bytes.len()
    val original_bit_len = original_len * 8

    # Append 0x80
    padded.push(0x80)

    # Zero-pad until length ≡ 56 (mod 64) — equivalently target_len - 8
    val target_len = ((original_len + 8) / 64 + 1) * 64
    while padded.len() < target_len - 8:
        padded.push(0)

    # Append 64-bit big-endian length (assume fits in 32 bits — pure-Simple list ceiling)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push((original_bit_len >> 24) & 0xFF)
    padded.push((original_bit_len >> 16) & 0xFF)
    padded.push((original_bit_len >> 8) & 0xFF)
    padded.push(original_bit_len & 0xFF)

    padded

# =============================================================================
# SHA-1 Compression Function (FIPS 180-4 §6.1.2)
# =============================================================================

# Process one 512-bit block, return updated 5-word hash state.
# reason: positional crypto sha1 API
fn sha1_process_block(h: list, block: list) -> list:
    # Prepare 80-word message schedule
    var w = []
    var i = 0

    # First 16 words from block (big-endian)
    while i < 16:
        val idx = i * 4
        val b0 = block.get(idx)
        val b1 = block.get(idx + 1)
        val b2 = block.get(idx + 2)
        val b3 = block.get(idx + 3)
        val word = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        w.push(word)
        i = i + 1

    # Extend to 80 words: W[t] = ROTL1(W[t-3] XOR W[t-8] XOR W[t-14] XOR W[t-16])
    while i < 80:
        val w3 = w.get(i - 3)
        val w8 = w.get(i - 8)
        val w14 = w.get(i - 14)
        val w16 = w.get(i - 16)
        val word = rotl32(w3 ^ w8 ^ w14 ^ w16, 1)
        w.push(word)
        i = i + 1

    # Initialize working variables a..e
    var a = h.get(0)
    var b = h.get(1)
    var c = h.get(2)
    var d = h.get(3)
    var e = h.get(4)

    # 80 rounds (FIPS 180-4 §6.1.2 step 3)
    i = 0
    while i < 80:
        val f = sha1_f(i, b, c, d)
        val k = sha1_k(i)
        val rotated_a = rotl32(a, 5)
        val temp_sum1 = add_mod32(rotated_a, f)
        val temp_sum2 = add_mod32(temp_sum1, e)
        val temp_sum3 = add_mod32(temp_sum2, k)
        val temp = add_mod32(temp_sum3, w.get(i))

        e = d
        d = c
        c = rotl32(b, 30)
        b = a
        a = temp

        i = i + 1

    # Compute new state H[i] = H[i] + working[i] mod 2^32
    var new_h = []
    new_h.push(add_mod32(h.get(0), a))
    new_h.push(add_mod32(h.get(1), b))
    new_h.push(add_mod32(h.get(2), c))
    new_h.push(add_mod32(h.get(3), d))
    new_h.push(add_mod32(h.get(4), e))

    new_h

# =============================================================================
# Streaming API — mirrors SHA-256/SHA-512 conventions
# =============================================================================

# Create SHA-1 context for incremental hashing.
# Returns tuple (h: list[5], data: list, datalen: i64, bitlen: i64).
fn create_sha1_context() -> tuple:
    val h = sha1_initial_hash()
    val data = []
    (h, data, 0, 0)

# Alias matching FIPS 180-4 wording.
fn sha1_init() -> tuple:
    create_sha1_context()

# Append data to the context. Returns new context tuple.
fn sha1_update(ctx: tuple, data: list) -> tuple:
    val h = ctx.get(0)
    val existing_data = ctx.get(1)
    val datalen = ctx.get(2)
    val bitlen = ctx.get(3)

    var updated_data = []
    var i = 0
    while i < existing_data.len():
        updated_data.push(existing_data.get(i))
        i = i + 1

    i = 0
    while i < data.len():
        updated_data.push(data.get(i))
        i = i + 1

    val new_datalen = datalen + data.len()
    val new_bitlen = bitlen + (data.len() * 8)

    (h, updated_data, new_datalen, new_bitlen)

# Finalize SHA-1 hash — emits 20-byte big-endian digest.
fn sha1_finalize(ctx: tuple) -> list:
    val h = ctx.get(0)
    val data = ctx.get(1)

    val padded = sha1_pad_message(data)

    var current_h = h
    var i = 0
    while i < padded.len():
        var block = []
        var j = 0
        while j < 64:
            block.push(padded.get(i + j))
            j = j + 1

        current_h = sha1_process_block(current_h, block)
        i = i + 64

    # Convert 5 32-bit words to 20 bytes (big-endian)
    var result = []
    i = 0
    while i < 5:
        val h_val = current_h.get(i)
        result.push((h_val >> 24) & 0xFF)
        result.push((h_val >> 16) & 0xFF)
        result.push((h_val >> 8) & 0xFF)
        result.push(h_val & 0xFF)
        i = i + 1

    result

# Alias matching FIPS 180-4 wording.
fn sha1_final(ctx: tuple) -> list:
    sha1_finalize(ctx)

# Reset (returns a fresh context).
fn sha1_reset(ctx: tuple) -> tuple:
    create_sha1_context()

# =============================================================================
# Public one-shot API
# =============================================================================

# SHA-1 hash of byte list (returns 20-byte list).
fn sha1_bytes(bytes: list) -> list:
    val ctx = create_sha1_context()
    val updated_ctx = sha1_update(ctx, bytes)
    sha1_finalize(updated_ctx)

# SHA-1 hash of text (returns 20-byte list).
fn sha1(text: text) -> list:
    val bytes = text_to_bytes(text)
    sha1_bytes(bytes)

# SHA-1 hash of text (returns lowercase hex string).
fn sha1_hex(text: text) -> text:
    val hash = sha1(text)
    bytes_to_hex(hash)

# SHA-1 hash with uppercase hex output.
fn sha1_hex_upper(text: text) -> text:
    val hash = sha1(text)
    hash_to_upper_hex(hash)
