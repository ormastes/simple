# SHA-3 Hash Family Implementation
#
# Secure Hash Algorithm 3 — FIPS PUB 202 (August 2015), based on the
# Keccak-f[1600] sponge construction (winner of the 2007-2012 NIST hash
# competition). Produces fixed-length digests:
#
#   SHA3-256 — 32-byte digest, rate=1088 bits (136 bytes), capacity=512 bits
#   SHA3-384 — 48-byte digest, rate=832  bits (104 bytes), capacity=768 bits
#   SHA3-512 — 64-byte digest, rate=576  bits ( 72 bytes), capacity=1024 bits
#
# The state is 5×5 = 25 lanes of 64 bits each = 1600 bits total. Each absorbed
# block XORs `rate` bytes into the state (little-endian lane packing) followed
# by a single Keccak-f[1600] permutation (24 rounds of θ ρ π χ ι). After all
# input is absorbed with FIPS 202 multi-rate padding (`0x06 ... 0x80`), the
# digest is squeezed out as the leftmost `output` bytes of the state.
#
# SHA-3 complements the SHA-2 family: it is a structurally different design
# (sponge, not Merkle-Damgård) and is *not* susceptible to length-extension
# attacks. Use SHA-3 when belt-and-suspenders algorithm diversity matters
# (TLS 1.3 and Ed448 ecosystems standardize SHA-3 alongside SHA-2). For new
# code with no specific requirement, SHA-2 (SHA-256/SHA-512) remains the
# default; SHA-3 *complements*, does not replace, SHA-2.
#
# History (2026-05-01): Pure-Simple SHA-3 family added to complete the
# SHA-1 / SHA-2 / SHA-3 hash trio (`feedback_no_coverups.md` — full coverage,
# not a stub). HMAC-SHA3-* and HKDF-SHA3-* added in the same change set.
#
# References:
#   FIPS PUB 202 — SHA-3 Standard: Permutation-Based Hash and
#                  Extendable-Output Functions (2015-08).
#   https://csrc.nist.gov/publications/detail/fips/202/final
#   Keccak Reference v3.0 (Bertoni, Daemen, Peeters, Van Assche — 2011-01).

mod crypto.types

use std.crypto.types.{rotl64}

# =============================================================================
# Keccak-f[1600] Round Constants (FIPS 202 §3.2.5)
# =============================================================================
#
# RC[i] is the round-constant lane XOR'd into state[0,0] during the ι-step of
# round i (i in 0..23). Generated by the LFSR (x^8 + x^6 + x^5 + x^4 + 1)
# stepping bits at positions 2^j - 1; equivalently the published table.

fn keccak_round_constants() -> list:
    [
        0x0000000000000001,
        0x0000000000008082,
        0x800000000000808a,
        0x8000000080008000,
        0x000000000000808b,
        0x0000000080000001,
        0x8000000080008081,
        0x8000000000008009,
        0x000000000000008a,
        0x0000000000000088,
        0x0000000080008009,
        0x000000008000000a,
        0x000000008000808b,
        0x800000000000008b,
        0x8000000000008089,
        0x8000000000008003,
        0x8000000000008002,
        0x8000000000000080,
        0x000000000000800a,
        0x800000008000000a,
        0x8000000080008081,
        0x8000000000008080,
        0x0000000080000001,
        0x8000000080008008
    ]

# Rotation offsets r[x,y] for the ρ-step, indexed lane = x + 5*y
# (FIPS 202 §3.2.2 Table 2). All 25 lanes; r[0,0]=0.
fn keccak_rotation_offsets() -> list:
    [
         0,  1, 62, 28, 27,
        36, 44,  6, 55, 20,
         3, 10, 43, 25, 39,
        41, 45, 15, 21,  8,
        18,  2, 61, 56, 14
    ]

# =============================================================================
# Lane index helper
# =============================================================================
#
# State is laid out as a flat 25-element list with lane[x,y] at index x+5*y.

fn _lane_idx(x: i64, y: i64) -> i64:
    x + 5 * y

# =============================================================================
# Keccak-f[1600] Permutation
# =============================================================================
#
# Apply 24 rounds of θ ρ π χ ι to a 25-lane state list. Returns a new list;
# does not mutate the input.

fn keccak_f1600(state_in: list) -> list:
    val rc = keccak_round_constants()
    val rho = keccak_rotation_offsets()

    # Copy state into a mutable list so we can update lane-by-lane.
    var s = []
    var idx = 0
    while idx < 25:
        s.push(state_in.get(idx))
        idx = idx + 1

    var round_idx = 0
    while round_idx < 24:
        # ----- θ-step -----
        # C[x] = s[x,0] ^ s[x,1] ^ s[x,2] ^ s[x,3] ^ s[x,4]
        # D[x] = C[x-1] ^ rotl64(C[x+1], 1)
        # s[x,y] ^= D[x]
        var c = []
        var x = 0
        while x < 5:
            val v = s.get(_lane_idx(x, 0)) ^ s.get(_lane_idx(x, 1)) ^ s.get(_lane_idx(x, 2)) ^ s.get(_lane_idx(x, 3)) ^ s.get(_lane_idx(x, 4))
            c.push(v)
            x = x + 1

        var d = []
        x = 0
        while x < 5:
            val xm1 = (x + 4) % 5
            val xp1 = (x + 1) % 5
            d.push(c.get(xm1) ^ rotl64(c.get(xp1), 1))
            x = x + 1

        x = 0
        while x < 5:
            var y = 0
            while y < 5:
                val li = _lane_idx(x, y)
                s[li] = s.get(li) ^ d.get(x)
                y = y + 1
            x = x + 1

        # ----- ρ + π combined into B[y, 2x+3y] = rotl64(s[x,y], r[x,y]) -----
        # FIPS 202 §3.2.3: A'[x,y] = rotl(A[x,y], r[x,y]); permute via π.
        var b = []
        var bi = 0
        while bi < 25:
            b.push(0)
            bi = bi + 1

        x = 0
        while x < 5:
            var y = 0
            while y < 5:
                val src = _lane_idx(x, y)
                val r = rho.get(src)
                val rotated = rotl64(s.get(src), r)
                # π: lane (x,y) moves to position (y, (2x+3y) mod 5)
                val nx = y
                val ny = (2 * x + 3 * y) % 5
                b[_lane_idx(nx, ny)] = rotated
                y = y + 1
            x = x + 1

        # ----- χ-step -----
        # s[x,y] = B[x,y] ^ ((~B[x+1,y]) & B[x+2,y])
        var y = 0
        while y < 5:
            x = 0
            while x < 5:
                val xp1 = (x + 1) % 5
                val xp2 = (x + 2) % 5
                val a = b.get(_lane_idx(x,   y))
                val b1 = b.get(_lane_idx(xp1, y))
                val b2 = b.get(_lane_idx(xp2, y))
                # NOT in 64-bit lane = XOR with all-ones
                val not_b1 = b1 ^ -1
                s[_lane_idx(x, y)] = a ^ (not_b1 & b2)
                x = x + 1
            y = y + 1

        # ----- ι-step -----
        s[0] = s.get(0) ^ rc.get(round_idx)

        round_idx = round_idx + 1
    s

# =============================================================================
# Lane <-> Bytes (little-endian per FIPS 202)
# =============================================================================

# Read 8 little-endian bytes starting at offset `off` from `bytes` into a u64
# lane. Caller guarantees the slice is in range.
fn _bytes_to_lane_le(bytes: list, off: i64) -> i64:
    var lane = 0
    var i = 0
    while i < 8:
        val b = bytes.get(off + i) & 0xFF
        # b << (8*i): for i=7 the shift is 56; b max 0xFF so no sign-bit hit.
        lane = lane | (b << (8 * i))
        i = i + 1
    lane

# Append the low 8 bytes of `lane` (little-endian) onto `dest`.
fn _lane_to_bytes_le(dest: list, lane: i64):
    var i = 0
    while i < 8:
        dest.push((lane >> (8 * i)) & 0xFF)
        i = i + 1

# =============================================================================
# Sponge Construction (Absorb + Squeeze)
# =============================================================================
#
# Streaming context shape: (state, buffer, buffer_len, rate_bytes)
#   state       — 25 i64 lanes (flat list)
#   buffer      — pending input bytes (< rate_bytes when not full)
#   buffer_len  — current size of buffer (kept for clarity even though
#                 list.len() == buffer_len always)
#   rate_bytes  — sponge rate r/8 (136 / 104 / 72 for SHA3-256/384/512)
#
# Domain separator for SHA-3 hash mode is the 4-bit suffix `01` followed by
# the multi-rate `1...1` pad — the byte-level encoding is `0x06` first byte
# and `0x80` MSB of the last rate-byte (FIPS 202 §B.2).

# Build a fresh 25-lane zero state.
fn _empty_state() -> list:
    var s = []
    var i = 0
    while i < 25:
        s.push(0)
        i = i + 1
    s

# Absorb one full rate-byte block into state and run Keccak-f.
fn _absorb_block(state: list, block: list, rate_bytes: i64) -> list:
    # Lane count = rate_bytes / 8 (always integral: 136/8=17, 104/8=13, 72/8=9).
    val lane_count = rate_bytes / 8
    var s = []
    var i = 0
    while i < 25:
        s.push(state.get(i))
        i = i + 1

    var lane_i = 0
    while lane_i < lane_count:
        val lane = _bytes_to_lane_le(block, lane_i * 8)
        s[lane_i] = s.get(lane_i) ^ lane
        lane_i = lane_i + 1

    keccak_f1600(s)

# Create a SHA-3 streaming context for the given rate (in bytes).
fn create_sha3_context(rate_bytes: i64) -> tuple:
    (_empty_state(), [], 0, rate_bytes)

fn create_sha3_256_context() -> tuple:
    create_sha3_context(136)

fn create_sha3_384_context() -> tuple:
    create_sha3_context(104)

fn create_sha3_512_context() -> tuple:
    create_sha3_context(72)

# Append data to the context; absorbs full blocks as they fill up. Returns
# updated context tuple.
fn sha3_update(ctx: tuple, data: list) -> tuple:
    var state = ctx[0]
    var buffer = ctx[1]
    var buffer_len = ctx[2]
    val rate_bytes = ctx[3]

    var i = 0
    while i < data.len():
        buffer.push(data.get(i))
        buffer_len = buffer_len + 1
        if buffer_len == rate_bytes:
            state = _absorb_block(state, buffer, rate_bytes)
            buffer = []
            buffer_len = 0
        i = i + 1
    (state, buffer, buffer_len, rate_bytes)

# Finalize: pad with FIPS 202 `0x06 ... 0x80`, absorb, then squeeze the
# requested `output_bytes`. For fixed-length SHA3-256/384/512, output_bytes
# never exceeds rate_bytes, so a single squeeze suffices — we still loop in
# case future SHAKE-style callers pass a longer length.
fn sha3_finalize(ctx: tuple, output_bytes: i64) -> list:
    var state = ctx[0]
    var buffer = ctx[1]
    var buffer_len = ctx[2]
    val rate_bytes = ctx[3]

    # Multi-rate padding: domain byte 0x06 followed by zero bytes; final byte
    # has 0x80 OR'd into its MSB. When buffer_len == rate_bytes - 1, the same
    # byte carries both → 0x86 (handled by OR'ing 0x80 onto whichever byte
    # ends up at index rate_bytes - 1).
    buffer.push(0x06)
    buffer_len = buffer_len + 1
    while buffer_len < rate_bytes:
        buffer.push(0)
        buffer_len = buffer_len + 1
    # OR 0x80 into the last byte.
    val last = buffer.get(rate_bytes - 1)
    buffer[rate_bytes - 1] = last | 0x80
    state = _absorb_block(state, buffer, rate_bytes)

    # Squeeze.
    var out = []
    var produced = 0
    while produced < output_bytes:
        # Emit lanes from state up to rate_bytes or until output_bytes is met.
        val lane_count = rate_bytes / 8
        var lane_i = 0
        while lane_i < lane_count and produced < output_bytes:
            var tmp = []
            _lane_to_bytes_le(tmp, state.get(lane_i))
            var k = 0
            while k < 8 and produced < output_bytes:
                out.push(tmp.get(k))
                produced = produced + 1
                k = k + 1
            lane_i = lane_i + 1
        # If more output is needed, run another permutation.
        if produced < output_bytes:
            state = keccak_f1600(state)
    out

# Aliases matching FIPS 202 wording.
fn sha3_init(rate_bytes: i64) -> tuple:
    create_sha3_context(rate_bytes)

fn sha3_final(ctx: tuple, output_bytes: i64) -> list:
    sha3_finalize(ctx, output_bytes)

# =============================================================================
# Public one-shot API — SHA3-256 / SHA3-384 / SHA3-512
# =============================================================================

# SHA3-256 of byte list (returns 32-byte list).
fn sha3_256_bytes(data: list) -> list:
    val ctx = create_sha3_256_context()
    val updated = sha3_update(ctx, data)
    sha3_finalize(updated, 32)

# SHA3-384 of byte list (returns 48-byte list).
fn sha3_384_bytes(data: list) -> list:
    val ctx = create_sha3_384_context()
    val updated = sha3_update(ctx, data)
    sha3_finalize(updated, 48)

# SHA3-512 of byte list (returns 64-byte list).
fn sha3_512_bytes(data: list) -> list:
    val ctx = create_sha3_512_context()
    val updated = sha3_update(ctx, data)
    sha3_finalize(updated, 64)

# Streaming convenience: feed `chunks` (list of lists of bytes) and finalize.
fn sha3_256_stream(chunks: list) -> list:
    var ctx = create_sha3_256_context()
    var i = 0
    while i < chunks.len():
        ctx = sha3_update(ctx, chunks.get(i))
        i = i + 1
    sha3_finalize(ctx, 32)

fn sha3_384_stream(chunks: list) -> list:
    var ctx = create_sha3_384_context()
    var i = 0
    while i < chunks.len():
        ctx = sha3_update(ctx, chunks.get(i))
        i = i + 1
    sha3_finalize(ctx, 48)

fn sha3_512_stream(chunks: list) -> list:
    var ctx = create_sha3_512_context()
    var i = 0
    while i < chunks.len():
        ctx = sha3_update(ctx, chunks.get(i))
        i = i + 1
    sha3_finalize(ctx, 64)
