# Ed25519 — Pure Simple Digital Signatures (RFC 8032)
#
# Combined single-file implementation inlining:
#   - Fe25519 field arithmetic (from os/crypto/curve25519.spl)
#   - 10-limb smalllimb ops (from os/crypto/curve25519_smalllimb.spl)
#   - Extended point operations (from os/crypto/ed25519_ops.spl)
#   - Scalar arithmetic mod L (from os/crypto/ed25519_scalar.spl)
#   - Ed25519 keypair/sign/verify/self-test
#
# No SFFI/Rust externs — pure Simple language, suitable for any tier.
# SHA-512 via std.common.crypto.sha512 (sha512_bytes: [i64] -> [i64]).
#
# NOTE: std.common.crypto.sha512 exports sha512_bytes([i64])->[i64], not
#       sha512([u8])->[u8]. The _sha512_u8 wrapper below bridges the types.
#
# Public API:
#   x25519(scalar, u_coord) -> [u8]                        (re-exported)
#   ed25519_keypair_from_seed(seed) -> ([u8], [u8])
#   ed25519_sign(private_seed, public_key, message) -> [u8]
#   ed25519_verify(public_key, message, signature) -> bool
#   ed25519_self_test() -> Result<bool, text>

use std.common.crypto.sha512.{sha512_bytes}

# ============================================================================
# SHA-512 bridge: [u8] -> [u8]  (common/crypto uses [i64] internally)
# ============================================================================

fn _sha512_u8(data: [u8]) -> [u8]:
    """SHA-512 over [u8] input, returning [u8].

    Bridges the common/crypto sha512_bytes([i64])->[i64] API.
    Each input byte is widened to i64; each output i64 is masked to u8.
    """
    var i64_data: [i64] = []
    var i: u64 = 0
    while i < data.len():
        i64_data.push(data[i].to_i64())
        i = i + 1
    val result = sha512_bytes(i64_data)
    var u8_result: [u8] = []
    i = 0
    while i < result.len():
        u8_result.push((result[i] & 0xFF).to_u8())
        i = i + 1
    u8_result

# ============================================================================
# 10-limb smalllimb field arithmetic (interpreter-safe u64 carries)
# ============================================================================
# These mirror os/crypto/curve25519_smalllimb.spl but are inlined here
# so this file has zero cross-module dependencies outside std.common.

val _ED_MASK26: u64 = 0x3FFFFFF
val _ED_MASK25: u64 = 0x1FFFFFF
val _ED_BASE26: u64 = 0x4000000
val _ED_BASE25: u64 = 0x2000000

fn _x25519_fe_zero() -> [u64]:
    [0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]

fn _x25519_fe_one() -> [u64]:
    [1u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64,0u64]

fn _x25519_fe_carry(a: [u64]) -> [u64]:
    var h0 = a[0]
    var h1 = a[1]
    var h2 = a[2]
    var h3 = a[3]
    var h4 = a[4]
    var h5 = a[5]
    var h6 = a[6]
    var h7 = a[7]
    var h8 = a[8]
    var h9 = a[9]

    var c: u64 = 0
    c = h0 / _ED_BASE26
    h0 = h0 & _ED_MASK26
    h1 = h1 + c
    c = h1 / _ED_BASE25
    h1 = h1 & _ED_MASK25
    h2 = h2 + c
    c = h2 / _ED_BASE26
    h2 = h2 & _ED_MASK26
    h3 = h3 + c
    c = h3 / _ED_BASE25
    h3 = h3 & _ED_MASK25
    h4 = h4 + c
    c = h4 / _ED_BASE26
    h4 = h4 & _ED_MASK26
    h5 = h5 + c
    c = h5 / _ED_BASE25
    h5 = h5 & _ED_MASK25
    h6 = h6 + c
    c = h6 / _ED_BASE26
    h6 = h6 & _ED_MASK26
    h7 = h7 + c
    c = h7 / _ED_BASE25
    h7 = h7 & _ED_MASK25
    h8 = h8 + c
    c = h8 / _ED_BASE26
    h8 = h8 & _ED_MASK26
    h9 = h9 + c
    c = h9 / _ED_BASE25
    h9 = h9 & _ED_MASK25
    h0 = h0 + c * 19
    c = h0 / _ED_BASE26
    h0 = h0 & _ED_MASK26
    h1 = h1 + c
    c = h1 / _ED_BASE25
    h1 = h1 & _ED_MASK25
    h2 = h2 + c
    c = h2 / _ED_BASE26
    h2 = h2 & _ED_MASK26
    h3 = h3 + c
    c = h3 / _ED_BASE25
    h3 = h3 & _ED_MASK25
    h4 = h4 + c
    c = h4 / _ED_BASE26
    h4 = h4 & _ED_MASK26
    h5 = h5 + c
    c = h5 / _ED_BASE25
    h5 = h5 & _ED_MASK25
    h6 = h6 + c
    c = h6 / _ED_BASE26
    h6 = h6 & _ED_MASK26
    h7 = h7 + c
    c = h7 / _ED_BASE25
    h7 = h7 & _ED_MASK25
    h8 = h8 + c
    c = h8 / _ED_BASE26
    h8 = h8 & _ED_MASK26
    h9 = h9 + c
    c = h9 / _ED_BASE25
    h9 = h9 & _ED_MASK25
    h0 = h0 + c * 19
    c = h0 / _ED_BASE26
    h0 = h0 & _ED_MASK26
    h1 = h1 + c
    [h0, h1, h2, h3, h4, h5, h6, h7, h8, h9]

fn _x25519_fe_add(a: [u64], b: [u64]) -> [u64]:
    _x25519_fe_carry([
        a[0]+b[0], a[1]+b[1], a[2]+b[2], a[3]+b[3], a[4]+b[4],
        a[5]+b[5], a[6]+b[6], a[7]+b[7], a[8]+b[8], a[9]+b[9]
    ])

fn _x25519_fe_add_raw(a: [u64], b: [u64]) -> [u64]:
    [
        a[0]+b[0], a[1]+b[1], a[2]+b[2], a[3]+b[3], a[4]+b[4],
        a[5]+b[5], a[6]+b[6], a[7]+b[7], a[8]+b[8], a[9]+b[9]
    ]

fn _x25519_fe_sub(a: [u64], b: [u64]) -> [u64]:
    _x25519_fe_carry([
        a[0]+134217690-b[0], a[1]+67108862-b[1], a[2]+134217726-b[2],
        a[3]+67108862-b[3], a[4]+134217726-b[4], a[5]+67108862-b[5],
        a[6]+134217726-b[6], a[7]+67108862-b[7], a[8]+134217726-b[8],
        a[9]+67108862-b[9]
    ])

fn _x25519_fe_sub_raw(a: [u64], b: [u64]) -> [u64]:
    [
        a[0]+134217690-b[0], a[1]+67108862-b[1], a[2]+134217726-b[2],
        a[3]+67108862-b[3], a[4]+134217726-b[4], a[5]+67108862-b[5],
        a[6]+134217726-b[6], a[7]+67108862-b[7], a[8]+134217726-b[8],
        a[9]+67108862-b[9]
    ]

fn _x25519_fe_neg(a: [u64]) -> [u64]:
    _x25519_fe_sub(_x25519_fe_zero(), a)

fn _x25519_fe_mul(a: [u64], b: [u64]) -> [u64]:
    val f0 = a[0]
    val f1 = a[1]
    val f2 = a[2]
    val f3 = a[3]
    val f4 = a[4]
    val f5 = a[5]
    val f6 = a[6]
    val f7 = a[7]
    val f8 = a[8]
    val f9 = a[9]
    val g0 = b[0]
    val g1 = b[1]
    val g2 = b[2]
    val g3 = b[3]
    val g4 = b[4]
    val g5 = b[5]
    val g6 = b[6]
    val g7 = b[7]
    val g8 = b[8]
    val g9 = b[9]
    val f1_2 = f1 * 2
    val f3_2 = f3 * 2
    val f5_2 = f5 * 2
    val f7_2 = f7 * 2
    val f9_2 = f9 * 2
    val g1_19 = g1 * 19
    val g2_19 = g2 * 19
    val g3_19 = g3 * 19
    val g4_19 = g4 * 19
    val g5_19 = g5 * 19
    val g6_19 = g6 * 19
    val g7_19 = g7 * 19
    val g8_19 = g8 * 19
    val g9_19 = g9 * 19
    val h0 = f0*g0 + f1_2*g9_19 + f2*g8_19 + f3_2*g7_19 + f4*g6_19 + f5_2*g5_19 + f6*g4_19 + f7_2*g3_19 + f8*g2_19 + f9_2*g1_19
    val h1 = f0*g1 + f1*g0 + f2*g9_19 + f3*g8_19 + f4*g7_19 + f5*g6_19 + f6*g5_19 + f7*g4_19 + f8*g3_19 + f9*g2_19
    val h2 = f0*g2 + f1_2*g1 + f2*g0 + f3_2*g9_19 + f4*g8_19 + f5_2*g7_19 + f6*g6_19 + f7_2*g5_19 + f8*g4_19 + f9_2*g3_19
    val h3 = f0*g3 + f1*g2 + f2*g1 + f3*g0 + f4*g9_19 + f5*g8_19 + f6*g7_19 + f7*g6_19 + f8*g5_19 + f9*g4_19
    val h4 = f0*g4 + f1_2*g3 + f2*g2 + f3_2*g1 + f4*g0 + f5_2*g9_19 + f6*g8_19 + f7_2*g7_19 + f8*g6_19 + f9_2*g5_19
    val h5 = f0*g5 + f1*g4 + f2*g3 + f3*g2 + f4*g1 + f5*g0 + f6*g9_19 + f7*g8_19 + f8*g7_19 + f9*g6_19
    val h6 = f0*g6 + f1_2*g5 + f2*g4 + f3_2*g3 + f4*g2 + f5_2*g1 + f6*g0 + f7_2*g9_19 + f8*g8_19 + f9_2*g7_19
    val h7 = f0*g7 + f1*g6 + f2*g5 + f3*g4 + f4*g3 + f5*g2 + f6*g1 + f7*g0 + f8*g9_19 + f9*g8_19
    val h8 = f0*g8 + f1_2*g7 + f2*g6 + f3_2*g5 + f4*g4 + f5_2*g3 + f6*g2 + f7_2*g1 + f8*g0 + f9_2*g9_19
    val h9 = f0*g9 + f1*g8 + f2*g7 + f3*g6 + f4*g5 + f5*g4 + f6*g3 + f7*g2 + f8*g1 + f9*g0
    var r0 = h0
    var r1 = h1
    var r2 = h2
    var r3 = h3
    var r4 = h4
    var r5 = h5
    var r6 = h6
    var r7 = h7
    var r8 = h8
    var r9 = h9
    var c: u64 = 0
    c = r0 / _ED_BASE26
    r0 = r0 & _ED_MASK26
    r1 = r1 + c
    c = r1 / _ED_BASE25
    r1 = r1 & _ED_MASK25
    r2 = r2 + c
    c = r2 / _ED_BASE26
    r2 = r2 & _ED_MASK26
    r3 = r3 + c
    c = r3 / _ED_BASE25
    r3 = r3 & _ED_MASK25
    r4 = r4 + c
    c = r4 / _ED_BASE26
    r4 = r4 & _ED_MASK26
    r5 = r5 + c
    c = r5 / _ED_BASE25
    r5 = r5 & _ED_MASK25
    r6 = r6 + c
    c = r6 / _ED_BASE26
    r6 = r6 & _ED_MASK26
    r7 = r7 + c
    c = r7 / _ED_BASE25
    r7 = r7 & _ED_MASK25
    r8 = r8 + c
    c = r8 / _ED_BASE26
    r8 = r8 & _ED_MASK26
    r9 = r9 + c
    c = r9 / _ED_BASE25
    r9 = r9 & _ED_MASK25
    r0 = r0 + c * 19
    c = r0 / _ED_BASE26
    r0 = r0 & _ED_MASK26
    r1 = r1 + c
    c = r1 / _ED_BASE25
    r1 = r1 & _ED_MASK25
    r2 = r2 + c
    c = r2 / _ED_BASE26
    r2 = r2 & _ED_MASK26
    r3 = r3 + c
    c = r3 / _ED_BASE25
    r3 = r3 & _ED_MASK25
    r4 = r4 + c
    c = r4 / _ED_BASE26
    r4 = r4 & _ED_MASK26
    r5 = r5 + c
    c = r5 / _ED_BASE25
    r5 = r5 & _ED_MASK25
    r6 = r6 + c
    c = r6 / _ED_BASE26
    r6 = r6 & _ED_MASK26
    r7 = r7 + c
    c = r7 / _ED_BASE25
    r7 = r7 & _ED_MASK25
    r8 = r8 + c
    c = r8 / _ED_BASE26
    r8 = r8 & _ED_MASK26
    r9 = r9 + c
    c = r9 / _ED_BASE25
    r9 = r9 & _ED_MASK25
    r0 = r0 + c * 19
    c = r0 / _ED_BASE26
    r0 = r0 & _ED_MASK26
    r1 = r1 + c
    [r0, r1, r2, r3, r4, r5, r6, r7, r8, r9]

fn _x25519_fe_sq(a: [u64]) -> [u64]:
    _x25519_fe_mul(a, a)

# ============================================================================
# Fe25519 — 5-limb 51-bit field element (used for Ed25519 extended coords)
# ============================================================================

val _FE_P_LIMB_MASK: u64 = 0x7FFFFFFFFFFFF   # 2^51 - 1

struct Fe25519:
    """Field element in GF(2^255-19), represented as 5 limbs of ~51 bits."""
    l0: u64
    l1: u64
    l2: u64
    l3: u64
    l4: u64

fn _fe_to_smalllimb(a: Fe25519) -> [u64]:
    """Convert 5x51-bit limbs to 10-limb smalllimb backend."""
    [
        a.l0 & 67108863, a.l0 / 67108864,
        a.l1 & 67108863, a.l1 / 67108864,
        a.l2 & 67108863, a.l2 / 67108864,
        a.l3 & 67108863, a.l3 / 67108864,
        a.l4 & 67108863, a.l4 / 67108864
    ]

fn _smalllimb_to_fe(a: [u64]) -> Fe25519:
    """Convert 10-limb smalllimb output back to 5x51-bit limbs."""
    val h = _x25519_fe_carry(a)
    Fe25519(
        l0: h[0] + h[1] * 67108864,
        l1: h[2] + h[3] * 67108864,
        l2: h[4] + h[5] * 67108864,
        l3: h[6] + h[7] * 67108864,
        l4: h[8] + h[9] * 67108864
    )

fn fe_zero() -> Fe25519:
    Fe25519(l0: 0, l1: 0, l2: 0, l3: 0, l4: 0)

fn fe_one() -> Fe25519:
    Fe25519(l0: 1, l1: 0, l2: 0, l3: 0, l4: 0)

fn fe_add(a: Fe25519, b: Fe25519) -> Fe25519:
    Fe25519(
        l0: a.l0+b.l0, l1: a.l1+b.l1, l2: a.l2+b.l2,
        l3: a.l3+b.l3, l4: a.l4+b.l4
    )

fn fe_sub(a: Fe25519, b: Fe25519) -> Fe25519:
    Fe25519(
        l0: (a.l0 + 0xFFFFFFFFFFFDA) - b.l0,
        l1: (a.l1 + 0xFFFFFFFFFFFFE) - b.l1,
        l2: (a.l2 + 0xFFFFFFFFFFFFE) - b.l2,
        l3: (a.l3 + 0xFFFFFFFFFFFFE) - b.l3,
        l4: (a.l4 + 0xFFFFFFFFFFFFE) - b.l4
    )

fn _fe51_carry(t: Fe25519) -> Fe25519:
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4
    var c: u64 = l0 >> 51
    l0 = l0 & _FE_P_LIMB_MASK
    l1 = l1 + c
    c = l1 >> 51
    l1 = l1 & _FE_P_LIMB_MASK
    l2 = l2 + c
    c = l2 >> 51
    l2 = l2 & _FE_P_LIMB_MASK
    l3 = l3 + c
    c = l3 >> 51
    l3 = l3 & _FE_P_LIMB_MASK
    l4 = l4 + c
    c = l4 >> 51
    l4 = l4 & _FE_P_LIMB_MASK
    l0 = l0 + c * 19
    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn fe_mul(a: Fe25519, b: Fe25519) -> Fe25519:
    _smalllimb_to_fe(_x25519_fe_mul(_fe_to_smalllimb(a), _fe_to_smalllimb(b)))

fn fe_sq(a: Fe25519) -> Fe25519:
    _smalllimb_to_fe(_x25519_fe_sq(_fe_to_smalllimb(a)))

fn fe_mul_scalar(a: Fe25519, s: u128) -> Fe25519:
    val a0: u128 = a.l0
    val a1: u128 = a.l1
    val a2: u128 = a.l2
    val a3: u128 = a.l3
    val a4: u128 = a.l4
    val mask: u128 = _FE_P_LIMB_MASK
    var c: u128 = (a0 * s) >> 51
    var n0 = (a0 * s) & mask
    var n1 = (a1 * s) + c
    c = n1 >> 51
    n1 = n1 & mask
    var n2 = (a2 * s) + c
    c = n2 >> 51
    n2 = n2 & mask
    var n3 = (a3 * s) + c
    c = n3 >> 51
    n3 = n3 & mask
    var n4 = (a4 * s) + c
    c = n4 >> 51
    n4 = n4 & mask
    n0 = n0 + c * 19
    c = n0 >> 51
    n0 = n0 & mask
    n1 = n1 + c
    Fe25519(
        l0: n0.to_u64(),
        l1: n1.to_u64(),
        l2: n2.to_u64(),
        l3: n3.to_u64(),
        l4: n4.to_u64()
    )

fn fe_reduce(a: Fe25519) -> Fe25519:
    var t = _fe51_carry(a)
    t = _fe51_carry(t)
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4
    var c: u64 = (l0 + 19) >> 51
    c = (l1 + c) >> 51
    c = (l2 + c) >> 51
    c = (l3 + c) >> 51
    c = (l4 + c) >> 51
    l0 = l0 + 19 * c
    c = l0 >> 51
    l0 = l0 & _FE_P_LIMB_MASK
    l1 = l1 + c
    c = l1 >> 51
    l1 = l1 & _FE_P_LIMB_MASK
    l2 = l2 + c
    c = l2 >> 51
    l2 = l2 & _FE_P_LIMB_MASK
    l3 = l3 + c
    c = l3 >> 51
    l3 = l3 & _FE_P_LIMB_MASK
    l4 = l4 + c
    l4 = l4 & _FE_P_LIMB_MASK
    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn _fe_load_le_u64(b: [u8], offset: u64) -> u64:
    var result: u64 = 0
    var i: u64 = 0
    while i < 8:
        if (offset + i) < b.len():
            result = result | (b[offset + i].to_u64() << (i * 8))
        i = i + 1
    result

fn fe_from_bytes(b: [u8]) -> Fe25519:
    val l0 = _fe_load_le_u64(b, 0) & _FE_P_LIMB_MASK
    val l1 = (_fe_load_le_u64(b, 6) >> 3) & _FE_P_LIMB_MASK
    val l2 = (_fe_load_le_u64(b, 12) >> 6) & _FE_P_LIMB_MASK
    val l3 = (_fe_load_le_u64(b, 19) >> 1) & _FE_P_LIMB_MASK
    val l4 = (_fe_load_le_u64(b, 24) >> 12) & _FE_P_LIMB_MASK
    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn fe_to_bytes(a: Fe25519) -> [u8]:
    val t = _fe51_carry(_fe51_carry(a))
    val l0 = t.l0
    val l1 = t.l1
    val l2 = t.l2
    val l3 = t.l3
    val l4 = t.l4
    var s: [u8] = []
    s.push((((l0 / 1) & 255) & 0xFF).to_u8())
    s.push((((l0 / 256) & 255) & 0xFF).to_u8())
    s.push((((l0 / 65536) & 255) & 0xFF).to_u8())
    s.push((((l0 / 16777216) & 255) & 0xFF).to_u8())
    s.push((((l0 / 4294967296) & 255) & 0xFF).to_u8())
    s.push((((l0 / 1099511627776) & 255) & 0xFF).to_u8())
    s.push(((((l0 / 281474976710656) & 7) | (((l1 / 1) & 31) * 8)) & 0xFF).to_u8())
    s.push((((l1 / 32) & 255) & 0xFF).to_u8())
    s.push((((l1 / 8192) & 255) & 0xFF).to_u8())
    s.push((((l1 / 2097152) & 255) & 0xFF).to_u8())
    s.push((((l1 / 536870912) & 255) & 0xFF).to_u8())
    s.push((((l1 / 137438953472) & 255) & 0xFF).to_u8())
    s.push(((((l1 / 35184372088832) & 63) | (((l2 / 1) & 3) * 64)) & 0xFF).to_u8())
    s.push((((l2 / 4) & 255) & 0xFF).to_u8())
    s.push((((l2 / 1024) & 255) & 0xFF).to_u8())
    s.push((((l2 / 262144) & 255) & 0xFF).to_u8())
    s.push((((l2 / 67108864) & 255) & 0xFF).to_u8())
    s.push((((l2 / 17179869184) & 255) & 0xFF).to_u8())
    s.push((((l2 / 4398046511104) & 255) & 0xFF).to_u8())
    s.push(((((l2 / 1125899906842624) & 1) | (((l3 / 1) & 127) * 2)) & 0xFF).to_u8())
    s.push((((l3 / 128) & 255) & 0xFF).to_u8())
    s.push((((l3 / 32768) & 255) & 0xFF).to_u8())
    s.push((((l3 / 8388608) & 255) & 0xFF).to_u8())
    s.push((((l3 / 2147483648) & 255) & 0xFF).to_u8())
    s.push((((l3 / 549755813888) & 255) & 0xFF).to_u8())
    s.push(((((l3 / 140737488355328) & 15) | (((l4 / 1) & 15) * 16)) & 0xFF).to_u8())
    s.push((((l4 / 16) & 255) & 0xFF).to_u8())
    s.push((((l4 / 4096) & 255) & 0xFF).to_u8())
    s.push((((l4 / 1048576) & 255) & 0xFF).to_u8())
    s.push((((l4 / 268435456) & 255) & 0xFF).to_u8())
    s.push((((l4 / 68719476736) & 255) & 0xFF).to_u8())
    s.push((((l4 / 17592186044416) & 127) & 0xFF).to_u8())
    s

fn fe_invert(z: Fe25519) -> Fe25519:
    _smalllimb_to_fe(_fe_invert_small(_fe_to_smalllimb(z)))

fn _fe_invert_small(z: [u64]) -> [u64]:
    var t = _x25519_fe_sq(z)
    t = _x25519_fe_sq(t)
    t = _x25519_fe_sq(t)
    val z9 = _x25519_fe_mul(t, z)
    val z11 = _x25519_fe_mul(z9, _x25519_fe_sq(z))
    t = _x25519_fe_sq(z11)
    val z_2_5_0 = _x25519_fe_mul(t, z9)
    t = _x25519_fe_sq(z_2_5_0)
    var i: i64 = 1
    while i < 5:
        t = _x25519_fe_sq(t)
        i = i + 1
    val z_2_10_0 = _x25519_fe_mul(t, z_2_5_0)
    t = _x25519_fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = _x25519_fe_sq(t)
        i = i + 1
    val z_2_20_0 = _x25519_fe_mul(t, z_2_10_0)
    t = _x25519_fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = _x25519_fe_sq(t)
        i = i + 1
    t = _x25519_fe_mul(t, z_2_20_0)
    i = 0
    while i < 10:
        t = _x25519_fe_sq(t)
        i = i + 1
    val z_2_50_0 = _x25519_fe_mul(t, z_2_10_0)
    t = _x25519_fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = _x25519_fe_sq(t)
        i = i + 1
    val z_2_100_0 = _x25519_fe_mul(t, z_2_50_0)
    t = _x25519_fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = _x25519_fe_sq(t)
        i = i + 1
    t = _x25519_fe_mul(t, z_2_100_0)
    i = 0
    while i < 50:
        t = _x25519_fe_sq(t)
        i = i + 1
    t = _x25519_fe_mul(t, z_2_50_0)
    t = _x25519_fe_sq(t)
    t = _x25519_fe_sq(t)
    t = _x25519_fe_sq(t)
    t = _x25519_fe_sq(t)
    t = _x25519_fe_sq(t)
    _x25519_fe_mul(t, z11)

# ============================================================================
# Fe25519 field helpers (supplementing above)
# ============================================================================

fn fe_neg(a: Fe25519) -> Fe25519:
    fe_sub(a: fe_zero(), b: a)

fn fe_is_negative(a: Fe25519) -> bool:
    val bytes = fe_to_bytes(a)
    (bytes[0] & 1) == 1

fn fe_pow2252m3(u: Fe25519) -> Fe25519:
    """Compute u^(2^252 - 3) mod p."""
    var z2 = fe_sq(u)
    var t = fe_sq(z2)
    t = fe_sq(t)
    var z9 = fe_mul(t, u)
    var z11 = fe_mul(z9, z2)
    t = fe_sq(z11)
    var z_2_5_0 = fe_mul(t, z9)
    t = fe_sq(z_2_5_0)
    var i: u64 = 1
    while i < 5:
        t = fe_sq(t)
        i = i + 1
    var z_2_10_0 = fe_mul(t, z_2_5_0)
    t = fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_20_0 = fe_mul(t, z_2_10_0)
    t = fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_20_0)
    i = 0
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_50_0 = fe_mul(t, z_2_10_0)
    t = fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    var z_2_100_0 = fe_mul(t, z_2_50_0)
    t = fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_100_0)
    i = 0
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_50_0)
    t = fe_sq(t)
    t = fe_sq(t)
    fe_mul(t, u)

fn _fe_sqrt_m1() -> Fe25519:
    """sqrt(-1) mod p = 2^((p-1)/4) mod p (precomputed)."""
    var bytes: [u8] = [
        0xb0, 0xa0, 0x0e, 0x4a, 0x27, 0x1b, 0xee, 0xc4,
        0x78, 0xe4, 0x2f, 0xad, 0x06, 0x18, 0x43, 0x2f,
        0xa7, 0xd7, 0xfb, 0x3d, 0x99, 0x00, 0x4d, 0x2b,
        0x0b, 0xdf, 0xc1, 0x4f, 0x80, 0x24, 0x83, 0x2b
    ]
    fe_from_bytes(bytes)

# ============================================================================
# Curve constants
# ============================================================================

fn _ed25519_d() -> Fe25519:
    """d = -121665/121666 mod p"""
    Fe25519(
        l0: 929955233495203,
        l1: 466365720129213,
        l2: 1662059464998953,
        l3: 2033849074728123,
        l4: 1442794654840575
    )

fn _ed25519_2d() -> Fe25519:
    val d = _ed25519_d()
    fe_add(d, d)

# ============================================================================
# Extended Point Structs
# ============================================================================

struct EdPoint:
    """Point on the Ed25519 Edwards curve in extended coordinates (X, Y, Z, T)."""
    x: Fe25519
    y: Fe25519
    z: Fe25519
    t: Fe25519

struct SmallEdPoint:
    x: [u64]
    y: [u64]
    z: [u64]
    t: [u64]

struct SmallEdCached:
    yplusx: [u64]
    yminusx: [u64]
    z2: [u64]
    t2d: [u64]

struct SmallEdCachedPair:
    first: SmallEdCached
    second: SmallEdCached

# ============================================================================
# Ed25519 Base Point
# ============================================================================

fn _ed25519_base_point() -> EdPoint:
    val bx = Fe25519(
        l0: 0x62d608f25d51a,
        l1: 0x412a4b4f6592a,
        l2: 0x75b7171a4b31d,
        l3: 0x1ff60527118fe,
        l4: 0x216936d3cd6e5
    )
    val by = Fe25519(
        l0: 0x6666666666658,
        l1: 0x4cccccccccccc,
        l2: 0x1999999999999,
        l3: 0x3333333333333,
        l4: 0x6666666666666
    )
    EdPoint(x: bx, y: by, z: fe_one(), t: fe_mul(bx, by))

# ============================================================================
# Point Operations
# ============================================================================

fn ed_point_identity() -> EdPoint:
    EdPoint(x: fe_zero(), y: fe_one(), z: fe_one(), t: fe_zero())

fn _small_ed_point_identity() -> SmallEdPoint:
    SmallEdPoint(
        x: _fe_to_smalllimb(fe_zero()),
        y: _fe_to_smalllimb(fe_one()),
        z: _fe_to_smalllimb(fe_one()),
        t: _fe_to_smalllimb(fe_zero())
    )

fn _ed_point_to_small(p: EdPoint) -> SmallEdPoint:
    SmallEdPoint(
        x: _fe_to_smalllimb(p.x),
        y: _fe_to_smalllimb(p.y),
        z: _fe_to_smalllimb(p.z),
        t: _fe_to_smalllimb(p.t)
    )

fn _small_ed_point_to_ed(p: SmallEdPoint) -> EdPoint:
    EdPoint(
        x: _smalllimb_to_fe(p.x),
        y: _smalllimb_to_fe(p.y),
        z: _smalllimb_to_fe(p.z),
        t: _smalllimb_to_fe(p.t)
    )

fn _small_ed_point_to_cached(p: SmallEdPoint, two_d_small: [u64]) -> SmallEdCached:
    SmallEdCached(
        yplusx: _x25519_fe_add(p.y, p.x),
        yminusx: _x25519_fe_sub(p.y, p.x),
        z2: _x25519_fe_add(p.z, p.z),
        t2d: _x25519_fe_mul(p.t, two_d_small)
    )

fn _ed_point_add_small_with_2d_small(p1: SmallEdPoint, p2: SmallEdPoint, two_d_small: [u64]) -> SmallEdPoint:
    val x1 = p1.x
    val y1 = p1.y
    val z1 = p1.z
    val t1 = p1.t
    val x2 = p2.x
    val y2 = p2.y
    val z2 = p2.z
    val t2 = p2.t
    val a = _x25519_fe_mul(_x25519_fe_sub(y1, x1), _x25519_fe_sub(y2, x2))
    val b = _x25519_fe_mul(_x25519_fe_add(y1, x1), _x25519_fe_add(y2, x2))
    val c = _x25519_fe_mul(_x25519_fe_mul(t1, t2), two_d_small)
    val z_prod = _x25519_fe_mul(z1, z2)
    val dd = _x25519_fe_add(z_prod, z_prod)
    val e = _x25519_fe_sub(b, a)
    val f = _x25519_fe_sub(dd, c)
    val g = _x25519_fe_add(dd, c)
    val h = _x25519_fe_add(b, a)
    SmallEdPoint(
        x: _x25519_fe_mul(e, f),
        y: _x25519_fe_mul(g, h),
        z: _x25519_fe_mul(f, g),
        t: _x25519_fe_mul(e, h)
    )

fn _ed_point_add_small_cached(p1: SmallEdPoint, p2: SmallEdCached) -> SmallEdPoint:
    val tr_x = _x25519_fe_add_raw(p1.y, p1.x)
    val tr_y = _x25519_fe_sub_raw(p1.y, p1.x)
    val tr_z = _x25519_fe_mul(tr_x, p2.yplusx)
    val tr_y2 = _x25519_fe_mul(tr_y, p2.yminusx)
    val tr_t = _x25519_fe_mul(p2.t2d, p1.t)
    val dd = _x25519_fe_mul(p1.z, p2.z2)
    val x = _x25519_fe_sub_raw(tr_z, tr_y2)
    val y = _x25519_fe_add_raw(tr_z, tr_y2)
    val z = _x25519_fe_add_raw(dd, tr_t)
    val t = _x25519_fe_sub_raw(dd, tr_t)
    SmallEdPoint(
        x: _x25519_fe_mul(x, t),
        y: _x25519_fe_mul(y, z),
        z: _x25519_fe_mul(t, z),
        t: _x25519_fe_mul(x, y)
    )

fn ed_point_add(p1: EdPoint, p2: EdPoint) -> EdPoint:
    _small_ed_point_to_ed(
        _ed_point_add_small_with_2d_small(
            _ed_point_to_small(p1),
            _ed_point_to_small(p2),
            _fe_to_smalllimb(_ed25519_2d())
        )
    )

fn ed_point_double(p1: EdPoint) -> EdPoint:
    ed_point_add(p1, p1)

fn _ed_point_double_small(p1: SmallEdPoint) -> SmallEdPoint:
    val x = p1.x
    val y = p1.y
    val z = p1.z
    val a = _x25519_fe_sq(x)
    val b = _x25519_fe_sq(y)
    val z_sq = _x25519_fe_sq(z)
    val c = _x25519_fe_add_raw(z_sq, z_sq)
    val d = _x25519_fe_neg(a)
    val x_plus_y = _x25519_fe_add_raw(x, y)
    val e = _x25519_fe_sub_raw(_x25519_fe_sub_raw(_x25519_fe_sq(x_plus_y), a), b)
    val g = _x25519_fe_add_raw(d, b)
    val f = _x25519_fe_sub_raw(g, c)
    val h = _x25519_fe_sub_raw(b, d)
    SmallEdPoint(
        x: _x25519_fe_mul(e, f),
        y: _x25519_fe_mul(g, h),
        z: _x25519_fe_mul(f, g),
        t: _x25519_fe_mul(e, h)
    )

fn ed_point_cselect(p0: EdPoint, p1: EdPoint, choose_p1: u64) -> EdPoint:
    """Constant-time point select: returns p1 if choose_p1=1, else p0.

    Uses XOR-mask pattern: out = a ^ (mask & (a ^ b))
    where mask = 0 - choose_p1. No data-dependent branch on choose_p1.
    """
    val mask: u64 = 0 - choose_p1
    EdPoint(
        x: Fe25519(
            l0: p0.x.l0 ^ (mask & (p0.x.l0 ^ p1.x.l0)),
            l1: p0.x.l1 ^ (mask & (p0.x.l1 ^ p1.x.l1)),
            l2: p0.x.l2 ^ (mask & (p0.x.l2 ^ p1.x.l2)),
            l3: p0.x.l3 ^ (mask & (p0.x.l3 ^ p1.x.l3)),
            l4: p0.x.l4 ^ (mask & (p0.x.l4 ^ p1.x.l4))
        ),
        y: Fe25519(
            l0: p0.y.l0 ^ (mask & (p0.y.l0 ^ p1.y.l0)),
            l1: p0.y.l1 ^ (mask & (p0.y.l1 ^ p1.y.l1)),
            l2: p0.y.l2 ^ (mask & (p0.y.l2 ^ p1.y.l2)),
            l3: p0.y.l3 ^ (mask & (p0.y.l3 ^ p1.y.l3)),
            l4: p0.y.l4 ^ (mask & (p0.y.l4 ^ p1.y.l4))
        ),
        z: Fe25519(
            l0: p0.z.l0 ^ (mask & (p0.z.l0 ^ p1.z.l0)),
            l1: p0.z.l1 ^ (mask & (p0.z.l1 ^ p1.z.l1)),
            l2: p0.z.l2 ^ (mask & (p0.z.l2 ^ p1.z.l2)),
            l3: p0.z.l3 ^ (mask & (p0.z.l3 ^ p1.z.l3)),
            l4: p0.z.l4 ^ (mask & (p0.z.l4 ^ p1.z.l4))
        ),
        t: Fe25519(
            l0: p0.t.l0 ^ (mask & (p0.t.l0 ^ p1.t.l0)),
            l1: p0.t.l1 ^ (mask & (p0.t.l1 ^ p1.t.l1)),
            l2: p0.t.l2 ^ (mask & (p0.t.l2 ^ p1.t.l2)),
            l3: p0.t.l3 ^ (mask & (p0.t.l3 ^ p1.t.l3)),
            l4: p0.t.l4 ^ (mask & (p0.t.l4 ^ p1.t.l4))
        )
    )

fn _small_ed_point_cselect(p0: SmallEdPoint, p1: SmallEdPoint, choose_p1: u64) -> SmallEdPoint:
    val mask: u64 = 0 - choose_p1
    SmallEdPoint(
        x: [
            p0.x[0]^(mask&(p0.x[0]^p1.x[0])), p0.x[1]^(mask&(p0.x[1]^p1.x[1])),
            p0.x[2]^(mask&(p0.x[2]^p1.x[2])), p0.x[3]^(mask&(p0.x[3]^p1.x[3])),
            p0.x[4]^(mask&(p0.x[4]^p1.x[4])), p0.x[5]^(mask&(p0.x[5]^p1.x[5])),
            p0.x[6]^(mask&(p0.x[6]^p1.x[6])), p0.x[7]^(mask&(p0.x[7]^p1.x[7])),
            p0.x[8]^(mask&(p0.x[8]^p1.x[8])), p0.x[9]^(mask&(p0.x[9]^p1.x[9]))
        ],
        y: [
            p0.y[0]^(mask&(p0.y[0]^p1.y[0])), p0.y[1]^(mask&(p0.y[1]^p1.y[1])),
            p0.y[2]^(mask&(p0.y[2]^p1.y[2])), p0.y[3]^(mask&(p0.y[3]^p1.y[3])),
            p0.y[4]^(mask&(p0.y[4]^p1.y[4])), p0.y[5]^(mask&(p0.y[5]^p1.y[5])),
            p0.y[6]^(mask&(p0.y[6]^p1.y[6])), p0.y[7]^(mask&(p0.y[7]^p1.y[7])),
            p0.y[8]^(mask&(p0.y[8]^p1.y[8])), p0.y[9]^(mask&(p0.y[9]^p1.y[9]))
        ],
        z: [
            p0.z[0]^(mask&(p0.z[0]^p1.z[0])), p0.z[1]^(mask&(p0.z[1]^p1.z[1])),
            p0.z[2]^(mask&(p0.z[2]^p1.z[2])), p0.z[3]^(mask&(p0.z[3]^p1.z[3])),
            p0.z[4]^(mask&(p0.z[4]^p1.z[4])), p0.z[5]^(mask&(p0.z[5]^p1.z[5])),
            p0.z[6]^(mask&(p0.z[6]^p1.z[6])), p0.z[7]^(mask&(p0.z[7]^p1.z[7])),
            p0.z[8]^(mask&(p0.z[8]^p1.z[8])), p0.z[9]^(mask&(p0.z[9]^p1.z[9]))
        ],
        t: [
            p0.t[0]^(mask&(p0.t[0]^p1.t[0])), p0.t[1]^(mask&(p0.t[1]^p1.t[1])),
            p0.t[2]^(mask&(p0.t[2]^p1.t[2])), p0.t[3]^(mask&(p0.t[3]^p1.t[3])),
            p0.t[4]^(mask&(p0.t[4]^p1.t[4])), p0.t[5]^(mask&(p0.t[5]^p1.t[5])),
            p0.t[6]^(mask&(p0.t[6]^p1.t[6])), p0.t[7]^(mask&(p0.t[7]^p1.t[7])),
            p0.t[8]^(mask&(p0.t[8]^p1.t[8])), p0.t[9]^(mask&(p0.t[9]^p1.t[9]))
        ]
    )

fn _small_ed_point_double4(p: SmallEdPoint) -> SmallEdPoint:
    var out = _ed_point_double_small(p)
    out = _ed_point_double_small(out)
    out = _ed_point_double_small(out)
    _ed_point_double_small(out)

fn _ct_eq_u64_small(a: u64, b: u64) -> u64:
    val diff = a ^ b
    ((diff - 1u64) >> 63) & 1u64

fn _small_ed_cached_select_16_direct(table: [SmallEdCached], digit: u64) -> SmallEdCached:
    if digit == 0: return table[0]
    if digit == 1: return table[1]
    if digit == 2: return table[2]
    if digit == 3: return table[3]
    if digit == 4: return table[4]
    if digit == 5: return table[5]
    if digit == 6: return table[6]
    if digit == 7: return table[7]
    if digit == 8: return table[8]
    if digit == 9: return table[9]
    if digit == 10: return table[10]
    if digit == 11: return table[11]
    if digit == 12: return table[12]
    if digit == 13: return table[13]
    if digit == 14: return table[14]
    table[15]

fn _small_ed_point_select_16_direct(table: [SmallEdPoint], digit: u64) -> SmallEdPoint:
    if digit == 0: return table[0]
    if digit == 1: return table[1]
    if digit == 2: return table[2]
    if digit == 3: return table[3]
    if digit == 4: return table[4]
    if digit == 5: return table[5]
    if digit == 6: return table[6]
    if digit == 7: return table[7]
    if digit == 8: return table[8]
    if digit == 9: return table[9]
    if digit == 10: return table[10]
    if digit == 11: return table[11]
    if digit == 12: return table[12]
    if digit == 13: return table[13]
    if digit == 14: return table[14]
    table[15]

fn _small_ed_cached_select_16_pair(table: [SmallEdCached], digit_a: u64, digit_b: u64) -> SmallEdCachedPair:
    SmallEdCachedPair(
        first: _small_ed_cached_select_16_direct(table, digit_a),
        second: _small_ed_cached_select_16_direct(table, digit_b)
    )

fn _small_ed_point_table_16(base: SmallEdPoint, two_d_small: [u64]) -> [SmallEdPoint]:
    var table: [SmallEdPoint] = []
    table.push(_small_ed_point_identity())
    var current = base
    table.push(current)
    var idx: u64 = 2
    while idx < 16:
        current = _ed_point_add_small_with_2d_small(p1: current, p2: base, two_d_small: two_d_small)
        table.push(current)
        idx = idx + 1
    table

fn _small_ed_cached_table_16(base: SmallEdPoint, two_d_small: [u64]) -> [SmallEdCached]:
    val points = _small_ed_point_table_16(base, two_d_small)
    var out: [SmallEdCached] = []
    var idx: u64 = 0
    while idx < points.len():
        out.push(_small_ed_point_to_cached(points[idx], two_d_small))
        idx = idx + 1
    out

fn _ed25519_base_point_small() -> SmallEdPoint:
    _ed_point_to_small(_ed25519_base_point())

fn _ed_scalar_bit(scalar: [u8], bit_idx: u64) -> u64:
    val byte_idx = bit_idx / 8
    val bit_in_byte = bit_idx - byte_idx * 8
    (scalar[byte_idx].to_u64() >> bit_in_byte) & 1

fn ed_scalar_mul(scalar: [u8], p: EdPoint) -> EdPoint:
    """Constant-time scalar multiplication: scalar * P."""
    var result = ed_point_identity()
    var base = p
    var seen_nonzero = false
    var bit_idx: u64 = 0
    while bit_idx < 256:
        if _ed_scalar_bit(scalar, bit_idx) == 1:
            if seen_nonzero:
                result = ed_point_add(result, base)
            else:
                result = base
                seen_nonzero = true
        base = ed_point_double(base)
        bit_idx = bit_idx + 1
    result

fn ed_scalar_mul_basepoint(scalar: [u8]) -> EdPoint:
    var result = ed_point_identity()
    var base = _ed25519_base_point()
    var seen_nonzero = false
    var bit_idx: u64 = 0
    while bit_idx < 256:
        if _ed_scalar_bit(scalar, bit_idx) == 1:
            if seen_nonzero:
                result = ed_point_add(result, base)
            else:
                result = base
                seen_nonzero = true
        base = ed_point_double(base)
        bit_idx = bit_idx + 1
    result

# ============================================================================
# Point Encoding / Decoding (RFC 8032 §5.1.2 / §5.1.3)
# ============================================================================

fn ed_point_encode(p: EdPoint) -> [u8]:
    val z_inv = fe_invert(p.z)
    val x = fe_mul(p.x, z_inv)
    val y = fe_mul(p.y, z_inv)
    var sign_bit: u8 = 0
    if fe_is_negative(x):
        sign_bit = (128).to_u8()
    val y_bytes = fe_to_bytes(y)
    var encoded: [u8] = []
    var i: u64 = 0
    while i < 32:
        if i == 31:
            encoded.push(y_bytes[i] | sign_bit)
        else:
            encoded.push(y_bytes[i])
        i = i + 1
    encoded

fn ed_point_decode(bytes: [u8]) -> EdPoint:
    val x_sign: u64 = (bytes[31].to_u64() >> 7) & 1
    var y_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        y_bytes.push(bytes[i])
        i = i + 1
    y_bytes[31] = y_bytes[31] & 0x7F
    val y = fe_from_bytes(y_bytes)
    val y_sq = fe_sq(y)
    val d = _ed25519_d()
    val u = fe_sub(y_sq, fe_one())
    val v = fe_add(fe_mul(d, y_sq), fe_one())
    val v_sq = fe_sq(v)
    val v_cubed = fe_mul(v_sq, v)
    val v4 = fe_sq(v_sq)
    val v7 = fe_mul(v4, v_cubed)
    val uv7 = fe_mul(u, v7)
    val uv7_pow = fe_pow2252m3(uv7)
    var x = fe_mul(fe_mul(u, v_cubed), uv7_pow)
    val vx2 = fe_mul(v, fe_sq(x))
    val check = fe_reduce(fe_sub(vx2, u))
    if check.l0 != 0:
        val sqrt_m1 = _fe_sqrt_m1()
        x = fe_mul(x, sqrt_m1)
    else:
        if check.l1 != 0:
            val sqrt_m1 = _fe_sqrt_m1()
            x = fe_mul(x, sqrt_m1)
        else:
            if check.l2 != 0:
                val sqrt_m1 = _fe_sqrt_m1()
                x = fe_mul(x, sqrt_m1)
            else:
                if check.l3 != 0:
                    val sqrt_m1 = _fe_sqrt_m1()
                    x = fe_mul(x, sqrt_m1)
                else:
                    if check.l4 != 0:
                        val sqrt_m1 = _fe_sqrt_m1()
                        x = fe_mul(x, sqrt_m1)
    if fe_is_negative(x) != (x_sign == 1):
        x = fe_neg(x)
    val t = fe_mul(x, y)
    EdPoint(x: x, y: y, z: fe_one(), t: t)

# ============================================================================
# Scalar Arithmetic mod L  (ed25519_scalar.spl inlined)
# ============================================================================

fn _sc_L() -> [u32]:
    """Group order L as 8 u32 limbs (little-endian)."""
    var l: [u32] = []
    l.push(0x5cf5d3ed)
    l.push(0x5812631a)
    l.push(0xa2f79cd6)
    l.push(0x14def9de)
    l.push(0x00000000)
    l.push(0x00000000)
    l.push(0x00000000)
    l.push(0x10000000)
    l

fn _bytes_to_limbs32(b: [u8], count: u64) -> [u32]:
    var limbs: [u32] = []
    var i: u64 = 0
    while i < count:
        val idx = i * 4
        var val_u32: u32 = 0
        if idx < b.len():
            val_u32 = val_u32 | b[idx].to_u32()
        if (idx + 1) < b.len():
            val_u32 = val_u32 | (b[idx + 1].to_u32() << 8)
        if (idx + 2) < b.len():
            val_u32 = val_u32 | (b[idx + 2].to_u32() << 16)
        if (idx + 3) < b.len():
            val_u32 = val_u32 | (b[idx + 3].to_u32() << 24)
        limbs.push(val_u32)
        i = i + 1
    limbs

fn _limbs32_to_bytes(limbs: [u32], byte_count: u64) -> [u8]:
    var result: [u8] = []
    var i: u64 = 0
    while i < byte_count:
        val limb_idx = i / 4
        val byte_idx = i % 4
        var byte_val: u8 = 0
        if limb_idx < limbs.len():
            byte_val = ((limbs[limb_idx].to_u64() >> (byte_idx * 8)) & 0xFF).to_u8()
        result.push(byte_val)
        i = i + 1
    result

fn _sc_sub_L(a: [u32]) -> [u32]:
    """Subtract L from a (8 limbs). Returns 9 limbs, limb[8] = borrow."""
    val l = _sc_L()
    var result: [u32] = []
    var borrow: u64 = 0
    var i: u64 = 0
    while i < 8:
        val ai: u64 = a[i].to_u64()
        val li: u64 = l[i].to_u64()
        val diff: u64 = ai - li - borrow
        result.push((diff & 0xFFFFFFFF).to_u32())
        if ai < (li + borrow):
            borrow = 1
        else:
            borrow = 0
        i = i + 1
    result.push(borrow.to_u32())
    result

fn _sc_get_bit_bytes(s: [u8], bit_idx: u64) -> u64:
    val byte_idx = bit_idx / 8
    if byte_idx >= s.len():
        return 0
    val bit_in_byte = bit_idx - byte_idx * 8
    (s[byte_idx].to_u64() >> bit_in_byte) & 1

fn _sc_shift_left1_add_bit(a: [u32], bit: u64) -> [u32]:
    var result: [u32] = []
    var carry = bit
    var i: u64 = 0
    while i < 8:
        val v = a[i].to_u64() * 2 + carry
        result.push((v & 0xFFFFFFFF).to_u32())
        carry = v >> 32
        i = i + 1
    result

fn _sc_ge_L(a: [u32]) -> bool:
    val l = _sc_L()
    var i: i64 = 7
    while i >= 0:
        val idx = i as u64
        val ai = a[idx].to_u64()
        val li = l[idx].to_u64()
        if ai > li:
            return true
        if ai < li:
            return false
        i = i - 1
    true

fn _sc_sub_L8(a: [u32]) -> [u32]:
    val sub = _sc_sub_L(a)
    var result: [u32] = []
    var i: u64 = 0
    while i < 8:
        result.push(sub[i])
        i = i + 1
    result

fn _sc_reduce_bits(s: [u8], max_bit_idx: i64) -> [u32]:
    var rem: [u32] = [0,0,0,0,0,0,0,0]
    var bit_idx = max_bit_idx
    while bit_idx >= 0:
        rem = _sc_shift_left1_add_bit(rem, _sc_get_bit_bytes(s, bit_idx as u64))
        if _sc_ge_L(rem):
            rem = _sc_sub_L8(rem)
        bit_idx = bit_idx - 1
    rem

fn _sc_add_mod(a: [u32], b: [u32]) -> [u32]:
    var result: [u32] = []
    var carry: u64 = 0
    var i: u64 = 0
    while i < 8:
        val sum = a[i].to_u64() + b[i].to_u64() + carry
        result.push((sum & 0xFFFFFFFF).to_u32())
        carry = sum >> 32
        i = i + 1
    if carry > 0 or _sc_ge_L(result):
        result = _sc_sub_L8(result)
    if _sc_ge_L(result):
        result = _sc_sub_L8(result)
    result

fn _sc_mul_mod(a: [u32], b: [u32]) -> [u32]:
    var result: [u32] = [0,0,0,0,0,0,0,0]
    var addend = a
    var bit_idx: u64 = 0
    while bit_idx < 256:
        val limb_idx = bit_idx / 32
        val bit_in_limb = bit_idx - limb_idx * 32
        val bit = (b[limb_idx].to_u64() >> bit_in_limb) & 1
        if bit == 1:
            result = _sc_add_mod(result, addend)
        addend = _sc_add_mod(addend, addend)
        bit_idx = bit_idx + 1
    result

fn sc_reduce(s: [u8]) -> [u8]:
    """Reduce a 64-byte scalar modulo L to 32 bytes."""
    val rem = _sc_reduce_bits(s, 511)
    _limbs32_to_bytes(rem, 32)

fn sc_muladd(a_bytes: [u8], b_bytes: [u8], c_bytes: [u8]) -> [u8]:
    """Compute (a * b + c) mod L, where a, b, c are 32-byte scalars."""
    val a = _sc_reduce_bits(a_bytes, 255)
    val b = _sc_reduce_bits(b_bytes, 255)
    val c = _sc_reduce_bits(c_bytes, 255)
    val product = _sc_mul_mod(a, b)
    _limbs32_to_bytes(_sc_add_mod(product, c), 32)

# ============================================================================
# SHA-512 mod L helper
# ============================================================================

fn _sha512_modl(data: [u8]) -> [u8]:
    val hash = _sha512_u8(data)
    sc_reduce(hash)

# ============================================================================
# Ed25519 Scalar Clamping
# ============================================================================

fn _ed25519_clamp(h: [u8]) -> [u8]:
    """Clamp the lower 32 bytes of SHA-512 output per Ed25519 spec."""
    var clamped: [u8] = []
    var i: u64 = 0
    while i < 32:
        var byte = h[i]
        if i == 0:
            byte = byte & 0xF8
        if i == 31:
            byte = (byte & 0x7F) | 0x40
        clamped.push(byte)
        i = i + 1
    clamped

fn _ed25519_reduce_32_to_scalar(s: [u8]) -> [u8]:
    var wide: [u8] = []
    var i: u64 = 0
    while i < 64:
        if i < s.len():
            wide.push(s[i])
        else:
            wide.push(0)
        i = i + 1
    sc_reduce(wide)

# ============================================================================
# Internal helpers
# ============================================================================

fn _sc_is_geq_L(s: [u8]) -> bool:
    """Check if 32-byte scalar s >= L (used to reject non-canonical S in verify)."""
    val limbs = _bytes_to_limbs32(s, 8)
    val sub = _sc_sub_L(limbs)
    sub[8] == 0

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time byte array comparison."""
    if a.len() != b.len():
        return false
    var diff: u8 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (a[i] ^ b[i])
        i = i + 1
    diff == 0

# ============================================================================
# Public API — RFC 8032 §5.1 conformant
# ============================================================================

fn ed25519_keypair_from_seed(seed: [u8]) -> ([u8], [u8]):
    """Derive (private_seed, public_key) from a 32-byte seed.

    Per RFC 8032 §5.1.5:
      h = SHA-512(seed)
      a = clamp(h[0..32])
      A = a * B
      encode A as 32 bytes
    """
    val h = _sha512_u8(seed)
    val a = _ed25519_clamp(h)
    val big_a = ed_scalar_mul_basepoint(_ed25519_reduce_32_to_scalar(a))
    val pk = ed_point_encode(big_a)
    (seed, pk)

fn ed25519_pubkey(seed: [u8]) -> [u8]:
    """Derive the Ed25519 public key from a 32-byte seed.

    Convenience wrapper: returns only the public key from
    ed25519_keypair_from_seed.
    """
    val h = _sha512_u8(seed)
    val a = _ed25519_clamp(h)
    val big_a = ed_scalar_mul_basepoint(_ed25519_reduce_32_to_scalar(a))
    ed_point_encode(big_a)

fn ed25519_sign(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    """Sign a message with Ed25519. Returns a 64-byte signature (R || S).

    Per RFC 8032 §5.1.6:
      h = SHA-512(seed)
      a = clamp(h[0..32]); prefix = h[32..64]
      r = SHA-512(prefix || M) mod L
      R = r * B
      k = SHA-512(encode(R) || A || M) mod L
      S = (r + k * a) mod L
      signature = encode(R) || S
    """
    val h = _sha512_u8(private_seed)
    val a = _ed25519_clamp(h)

    var prefix: [u8] = []
    var i: u64 = 32
    while i < 64:
        prefix.push(h[i])
        i = i + 1

    var prefix_msg: [u8] = []
    i = 0
    while i < prefix.len():
        prefix_msg.push(prefix[i])
        i = i + 1
    i = 0
    while i < message.len():
        prefix_msg.push(message[i])
        i = i + 1
    val r = _sha512_modl(prefix_msg)

    val big_r = ed_scalar_mul_basepoint(r)
    val r_enc = ed_point_encode(big_r)

    var k_input: [u8] = []
    i = 0
    while i < r_enc.len():
        k_input.push(r_enc[i])
        i = i + 1
    i = 0
    while i < public_key.len():
        k_input.push(public_key[i])
        i = i + 1
    i = 0
    while i < message.len():
        k_input.push(message[i])
        i = i + 1
    val k = _sha512_modl(k_input)

    val s = sc_muladd(k, a, r)

    var sig: [u8] = []
    i = 0
    while i < 64:
        if i < 32:
            sig.push(r_enc[i])
        else:
            sig.push(s[i - 32])
        i = i + 1
    sig

fn ed25519_verify(public_key: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an Ed25519 signature. Returns true on success.

    Per RFC 8032 §5.1.7:
      parse R = signature[0..32], S = signature[32..64]
      reject if S >= L
      A = decode(public_key); R = decode(R_bytes)
      k = SHA-512(R || A || M) mod L
      check  S * B  ==  R + k * A
    """
    if signature.len() != 64:
        return false
    if public_key.len() != 32:
        return false

    var r_bytes: [u8] = []
    var s_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        r_bytes.push(signature[i])
        i = i + 1
    while i < 64:
        s_bytes.push(signature[i])
        i = i + 1

    if _sc_is_geq_L(s_bytes):
        return false

    val big_a = ed_point_decode(public_key)
    val big_r = ed_point_decode(r_bytes)

    var k_input: [u8] = []
    i = 0
    while i < r_bytes.len():
        k_input.push(r_bytes[i])
        i = i + 1
    i = 0
    while i < public_key.len():
        k_input.push(public_key[i])
        i = i + 1
    i = 0
    while i < message.len():
        k_input.push(message[i])
        i = i + 1
    val k = _sha512_modl(k_input)

    val sb = ed_scalar_mul_basepoint(s_bytes)
    val ka = ed_scalar_mul(k, big_a)
    val rhs = ed_point_add(p1: big_r, p2: ka)

    val sb_enc = ed_point_encode(sb)
    val rhs_enc = ed_point_encode(rhs)
    _bytes_equal(a: sb_enc, b: rhs_enc)

# ============================================================================
# Self-Test — RFC 8032 Section 7.1 Test Vectors
# ============================================================================

fn ed25519_self_test() -> Result<bool, text>:
    """Run Ed25519 against RFC 8032 §7.1 test vectors."""
    _ed25519_self_test_pure()

fn _ed25519_self_test_pure() -> Result<bool, text>:
    # --- Test Vector 1 (RFC 8032 §7.1, TEST 1) ---
    val seed1: [u8] = [
        0x9d, 0x61, 0xb1, 0x9d, 0xef, 0xfd, 0x5a, 0x60,
        0xba, 0x84, 0x4a, 0xf4, 0x92, 0xec, 0x2c, 0xc4,
        0x44, 0x49, 0xc5, 0x69, 0x7b, 0x32, 0x69, 0x19,
        0x70, 0x3b, 0xac, 0x03, 0x1c, 0xae, 0x7f, 0x60
    ]
    val expected_pub1: [u8] = [
        0xd7, 0x5a, 0x98, 0x01, 0x82, 0xb1, 0x0a, 0xb7,
        0xd5, 0x4b, 0xfe, 0xd3, 0xc9, 0x64, 0x07, 0x3a,
        0x0e, 0xe1, 0x72, 0xf3, 0xda, 0xa6, 0x23, 0x25,
        0xaf, 0x02, 0x1a, 0x68, 0xf7, 0x07, 0x51, 0x1a
    ]
    val expected_sig1: [u8] = [
        0xe5, 0x56, 0x43, 0x00, 0xc3, 0x60, 0xac, 0x72,
        0x90, 0x86, 0xe2, 0xcc, 0x80, 0x6e, 0x82, 0x8a,
        0x84, 0x87, 0x7f, 0x1e, 0xb8, 0xe5, 0xd9, 0x74,
        0xd8, 0x73, 0xe0, 0x65, 0x22, 0x49, 0x01, 0x55,
        0x5f, 0xb8, 0x82, 0x15, 0x90, 0xa3, 0x3b, 0xac,
        0xc6, 0x1e, 0x39, 0x70, 0x1c, 0xf9, 0xb4, 0x6b,
        0xd2, 0x5b, 0xf5, 0xf0, 0x59, 0x5b, 0xbe, 0x24,
        0x65, 0x51, 0x41, 0x43, 0x8e, 0x7a, 0x10, 0x0b
    ]
    val msg1: [u8] = []

    val kp1 = ed25519_keypair_from_seed(seed1)
    val pub1 = kp1.1
    if not _bytes_equal(a: pub1, b: expected_pub1):
        return Err("Ed25519 self-test FAIL: test vector 1 public key mismatch")

    val sig1 = ed25519_sign(private_seed: seed1, public_key: pub1, message: msg1)
    if not _bytes_equal(a: sig1, b: expected_sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 signature mismatch")

    if not ed25519_verify(public_key: pub1, message: msg1, signature: sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 verify rejected valid signature")

    var bad_sig1: [u8] = []
    var bsi: u64 = 0
    while bsi < sig1.len():
        bad_sig1.push(sig1[bsi])
        bsi = bsi + 1
    bad_sig1[0] = bad_sig1[0] ^ 0x01
    if ed25519_verify(public_key: pub1, message: msg1, signature: bad_sig1):
        return Err("Ed25519 self-test FAIL: verify accepted corrupted signature")

    # --- Test Vector 2 (RFC 8032 §7.1, TEST 2) ---
    val seed2: [u8] = [
        0x4c, 0xcd, 0x08, 0x9b, 0x28, 0xff, 0x96, 0xda,
        0x9d, 0xb6, 0xc3, 0x46, 0xec, 0x11, 0x4e, 0x0f,
        0x5b, 0x8a, 0x31, 0x9f, 0x35, 0xab, 0xa6, 0x24,
        0xda, 0x8c, 0xf6, 0xed, 0x4f, 0xb8, 0xa6, 0xfb
    ]
    val expected_pub2: [u8] = [
        0x3d, 0x40, 0x17, 0xc3, 0xe8, 0x43, 0x89, 0x5a,
        0x92, 0xb7, 0x0a, 0xa7, 0x4d, 0x1b, 0x7e, 0xbc,
        0x9c, 0x98, 0x2c, 0xcf, 0x2e, 0xc4, 0x96, 0x8c,
        0xc0, 0xcd, 0x55, 0xf1, 0x2a, 0xf4, 0x66, 0x0c
    ]
    val expected_sig2: [u8] = [
        0x92, 0xa0, 0x09, 0xa9, 0xf0, 0xd4, 0xca, 0xb8,
        0x72, 0x0e, 0x82, 0x0b, 0x5f, 0x64, 0x25, 0x40,
        0xa2, 0xb2, 0x7b, 0x54, 0x16, 0x50, 0x3f, 0x8f,
        0xb3, 0x76, 0x22, 0x23, 0xeb, 0xdb, 0x69, 0xda,
        0x08, 0x5a, 0xc1, 0xe4, 0x3e, 0x15, 0x9c, 0x7e,
        0x94, 0xb2, 0xba, 0x95, 0xc9, 0xee, 0x6f, 0x5f,
        0x6d, 0x90, 0xbd, 0x3e, 0x0d, 0xfd, 0x0e, 0x2e,
        0x78, 0xe1, 0x88, 0xcc, 0x7e, 0x00, 0xd5, 0xb2
    ]
    val msg2: [u8] = [0x72]

    val kp2 = ed25519_keypair_from_seed(seed2)
    val pub2 = kp2.1
    if not _bytes_equal(a: pub2, b: expected_pub2):
        return Err("Ed25519 self-test FAIL: test vector 2 public key mismatch")

    val sig2 = ed25519_sign(private_seed: seed2, public_key: pub2, message: msg2)
    if not _bytes_equal(a: sig2, b: expected_sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 signature mismatch")

    if not ed25519_verify(public_key: pub2, message: msg2, signature: sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 verify rejected valid signature")

    Ok(true)
