# Argon2id — Pure Simple Implementation (RFC 9106)
#
# Argon2id is the hybrid of Argon2i (data-independent indexing) and Argon2d
# (data-dependent indexing), recommended by RFC 9106 §4 for password hashing.
#
# This is a port of src/os/crypto/argon2.spl that uses [i64] byte lists
# (values 0-255) matching the std.common.crypto API, and imports BLAKE2b from
# std.common.crypto.blake2 instead of os.crypto.blake2b.
#
# Public API:
#   argon2id_bytes(password, salt, t_cost, m_cost, parallelism, tag_len) -> [i64]
#   argon2id_bytes_ks(password, salt, key, assoc_data, t_cost, m_cost, parallelism, tag_len) -> [i64]
#
# Parameters (RFC 9106 §3.1):
#   t_cost      — number of passes (>= 1)
#   m_cost      — desired memory in KiB (>= 8 * parallelism)
#   parallelism — number of lanes (>= 1)
#   tag_len     — output length in bytes (>= 4)
#
# BLAKE2b integration:
#   blake2b_512_bytes  — 64-byte (512-bit) hash; used for H' T=64 and block init
#   blake2b_256_bytes  — 32-byte (256-bit) hash; used for H' T=32 (final tag)
#   For H'(input, T) where T is not 32 or 64: calls blake2b_512_bytes and
#   slices to T bytes (valid for T in [1,64]; all internal uses are 64).
#   H'(data, 1024) uses the long-output chain: 31 rounds of 64-byte BLAKE2b.
#
# WORD ARITHMETIC NOTE
#   The G compression function requires modular 64-bit arithmetic. All word
#   arrays use u64 (not i64) so that + and * wrap rather than panic.
#   Byte buffers use [i64] (values 0-255). Conversion at boundary only.
#
# INTERPRETER PERFORMANCE
#   Argon2id is memory-hard by design. RFC 9106 §5.3 uses m=32 KiB / t=3 / p=4
#   (~384 G-compressions, each touching 1024 bytes). In interpreter mode the
#   per-G overhead far exceeds the 60 s test-runner watchdog. Smaller parameters
#   (t=1, m=8 KiB, p=1) do finish in interpreter; full RFC §5.3 KAT is
#   documented red per: doc/08_tracking/bug/argon2id_interpreter_timeout_2026-06-15.md
#
# References:
#   RFC 9106 §3.2 — H_0 initial 64-byte hash from parameters and inputs
#   RFC 9106 §3.3 — H' variable-length BLAKE2b-based hash
#   RFC 9106 §3.4 — Argon2id mode
#   RFC 9106 §3.5 — G compression
#   RFC 9106 §3.6 — Permutation P (one BLAKE2b round)
#   RFC 9106 Appendix B.4 — Argon2id test vector

use std.common.crypto.blake2.{blake2b_512_bytes, blake2b_256_bytes, _blake2b_core}

# ============================================================================
# Argon2id type constant and version
# ============================================================================

fn _a2_type_id() -> i64:
    # RFC 9106 §3.1: y = 2 for Argon2id
    2

fn _a2_version() -> i64:
    # RFC 9106 §3.1: v = 0x13 = 19
    19

# ============================================================================
# Endianness helpers — RFC 9106 uses little-endian throughout
# ============================================================================

fn _a2_le32(x: i64) -> [i64]:
    """Encode the low 32 bits of x as 4 little-endian bytes."""
    var out: [i64] = []
    out.push(x & 255)
    out.push((x >> 8) & 255)
    out.push((x >> 16) & 255)
    out.push((x >> 24) & 255)
    out

fn _a2_read_u64_le(buf: [i64], off: i64) -> u64:
    """Read 8 little-endian bytes from buf[off..off+8] as u64."""
    var w: u64 = 0
    var i: i64 = 0
    while i < 8:
        w = w | (buf[off + i].to_u64() << (i.to_u64() * 8))
        i = i + 1
    w

fn _a2_write_u64_le(buf: [i64], off: i64, x: u64) -> [i64]:
    """Write u64 to buf[off..off+8] little-endian (returns updated buf)."""
    var b = buf
    var i: i64 = 0
    while i < 8:
        b[off + i] = ((x >> (i.to_u64() * 8)) & 0xFF).to_i64()
        i = i + 1
    b

fn _a2_append(dst: [i64], src: [i64]) -> [i64]:
    """Append src bytes to dst, returning new list."""
    var out = dst
    var i: i64 = 0
    val n = src.len()
    while i < n:
        out.push(src[i])
        i = i + 1
    out

# ============================================================================
# H' — variable-length BLAKE2b-based hash (RFC 9106 §3.3)
#
# H'^T(A):
#   if T <= 64: BLAKE2b-T(LE32(T) || A)  — dispatch to 32 or 64 byte variant
#   else:
#     r = ceil(T/32) - 2
#     V_1 = BLAKE2b-64(LE32(T) || A)
#     V_{k+1} = BLAKE2b-64(V_k)           k = 1..r-1
#     V_{r+1} = BLAKE2b-(T-32r)(V_r)      final chunk
#     output = V_1[0:32] || V_2[0:32] || ... || V_r[0:32] || V_{r+1}
#
# Internal notes on T values encountered:
#   - T = 32  (final tag)  → blake2b_256_bytes(prefixed)
#   - T = 64  (block init, V_k chain) → blake2b_512_bytes(prefixed)
#   - T = 1024 (block init) → long-output path, all internal calls 64-byte
#     r = ceil(1024/32) - 2 = 32 - 2 = 30; final_len = 1024 - 32*30 = 64
#     so all calls are 64-byte blake2b_512_bytes — no other variant needed.
# ============================================================================

fn _a2_blake2b_n(data: [i64], out_len: i64) -> [i64]:
    """BLAKE2b with output length out_len (1..64).

    Dispatches to the correct BLAKE2b variant — each digest_length is
    mixed into the IV (parameter block h[0] byte 0), so truncation of a
    longer hash gives WRONG bytes. Use _blake2b_core for T not in {32,64}.
    For out_len == 64: blake2b_512_bytes (= _blake2b_core(data, 64)).
    For out_len == 32: blake2b_256_bytes (= _blake2b_core(data, 32)).
    For other T in [1..64]: _blake2b_core(data, out_len) directly.
    """
    if out_len == 64:
        return blake2b_512_bytes(data)
    if out_len == 32:
        return blake2b_256_bytes(data)
    # General T in [1..64]: use _blake2b_core with the correct digest_length.
    # This correctly sets the BLAKE2b parameter block digest_length = T.
    _blake2b_core(data, out_len)

fn _a2_h_prime(input: [i64], t_len: i64) -> [i64]:
    """Variable-length hash H'^T(A) per RFC 9106 §3.3."""
    # Prepend LE32(T) to input
    var prefixed: [i64] = []
    prefixed = _a2_append(prefixed, _a2_le32(t_len))
    prefixed = _a2_append(prefixed, input)

    if t_len <= 64:
        return _a2_blake2b_n(prefixed, t_len)

    # Long-output path: r = ceil(T/32) - 2; final_len = T - 32*r
    val r: i64 = (t_len + 31) / 32 - 2
    var out: [i64] = []
    var v = blake2b_512_bytes(prefixed)

    # Take first 32 bytes of V_1
    var i: i64 = 0
    while i < 32:
        out.push(v[i])
        i = i + 1

    var k: i64 = 1
    while k < r:
        v = blake2b_512_bytes(v)
        i = 0
        while i < 32:
            out.push(v[i])
            i = i + 1
        k = k + 1

    # Final V_{r+1}: length T - 32*r
    val final_len = t_len - 32 * r
    val v_final = _a2_blake2b_n(v, final_len)
    i = 0
    while i < final_len:
        out.push(v_final[i])
        i = i + 1
    out

# ============================================================================
# H_0 — initial 64-byte hash (RFC 9106 §3.2)
#
# H_0 = BLAKE2b-64(
#   LE32(p) || LE32(T) || LE32(m) || LE32(t) || LE32(v) || LE32(y)
#   || LE32(|P|) || P || LE32(|S|) || S || LE32(|K|) || K || LE32(|X|) || X
# )
# ============================================================================

fn _a2_h0(parallelism: i64, tag_len: i64, m_cost: i64, t_cost: i64,
          password: [i64], salt: [i64], key: [i64], assoc: [i64]) -> [i64]:
    var buf: [i64] = []
    buf = _a2_append(buf, _a2_le32(parallelism))
    buf = _a2_append(buf, _a2_le32(tag_len))
    buf = _a2_append(buf, _a2_le32(m_cost))
    buf = _a2_append(buf, _a2_le32(t_cost))
    buf = _a2_append(buf, _a2_le32(_a2_version()))
    buf = _a2_append(buf, _a2_le32(_a2_type_id()))
    buf = _a2_append(buf, _a2_le32(password.len()))
    buf = _a2_append(buf, password)
    buf = _a2_append(buf, _a2_le32(salt.len()))
    buf = _a2_append(buf, salt)
    buf = _a2_append(buf, _a2_le32(key.len()))
    buf = _a2_append(buf, key)
    buf = _a2_append(buf, _a2_le32(assoc.len()))
    buf = _a2_append(buf, assoc)
    blake2b_512_bytes(buf)

# ============================================================================
# Permutation P — one full BLAKE2b round (RFC 9106 §3.6)
#
# Word arithmetic uses u64 throughout for wrapping semantics.
# Operates on a 16-word (128-byte) register array.
# ============================================================================

fn _a2_rotr64(x: u64, n: u64) -> u64:
    ((x >> n) | (x << (64 - n))) & 0xFFFFFFFFFFFFFFFF

fn _a2_p_g(v: [u64], a: i64, b: i64, c: i64, d: i64) -> [u64]:
    """Argon2 GB mixing function (RFC 9106 §3.6).

    a = a + b + 2 * trunc32(a) * trunc32(b)  (mod 2^64)
    d = (d XOR a) >>> 32
    c = c + d + 2 * trunc32(c) * trunc32(d)  (mod 2^64)
    b = (b XOR c) >>> 24
    ... second half
    """
    var s = v
    var va = s[a]
    var vb = s[b]
    var vc = s[c]
    var vd = s[d]
    val mask: u64 = 0xFFFFFFFFFFFFFFFF
    val low32: u64 = 0xFFFFFFFF

    var ta = va & low32
    var tb = vb & low32
    va = (va + vb + ((2 * ta * tb) & mask)) & mask
    vd = _a2_rotr64(vd ^ va, 32)
    var tc = vc & low32
    var td = vd & low32
    vc = (vc + vd + ((2 * tc * td) & mask)) & mask
    vb = _a2_rotr64(vb ^ vc, 24)

    ta = va & low32
    tb = vb & low32
    va = (va + vb + ((2 * ta * tb) & mask)) & mask
    vd = _a2_rotr64(vd ^ va, 16)
    tc = vc & low32
    td = vd & low32
    vc = (vc + vd + ((2 * tc * td) & mask)) & mask
    vb = _a2_rotr64(vb ^ vc, 63)

    s[a] = va
    s[b] = vb
    s[c] = vc
    s[d] = vd
    s

fn _a2_permute_p(v: [u64]) -> [u64]:
    """Apply one BLAKE2b round to a 16-word register array (RFC 9106 §3.6)."""
    var s = v
    # Columns
    s = _a2_p_g(s, 0, 4, 8, 12)
    s = _a2_p_g(s, 1, 5, 9, 13)
    s = _a2_p_g(s, 2, 6, 10, 14)
    s = _a2_p_g(s, 3, 7, 11, 15)
    # Diagonals
    s = _a2_p_g(s, 0, 5, 10, 15)
    s = _a2_p_g(s, 1, 6, 11, 12)
    s = _a2_p_g(s, 2, 7, 8, 13)
    s = _a2_p_g(s, 3, 4, 9, 14)
    s

# ============================================================================
# G — compression of two 1024-byte blocks (RFC 9106 §3.5)
#
# Block layout: 128 u64 words = 1024 bytes.
# G(X, Y):
#   R = X XOR Y
#   Q = P applied to each of 8 rows of R   (16 words per row)
#   Z = P applied to each of 8 col-pairs of Q
#   Output = Z XOR R
# ============================================================================

fn _a2_block_xor(x: [u64], y: [u64]) -> [u64]:
    var out: [u64] = []
    var i: i64 = 0
    while i < 128:
        out.push(x[i] ^ y[i])
        i = i + 1
    out

fn _a2_g_compress(x: [u64], y: [u64]) -> [u64]:
    """G(X, Y) = (P_columns composed P_rows)(X XOR Y) XOR (X XOR Y)."""
    val r = _a2_block_xor(x, y)

    # Apply P to each of 8 rows (16 words each)
    var q: [u64] = []
    var i: i64 = 0
    while i < 128:
        q.push(r[i])
        i = i + 1
    var row: i64 = 0
    while row < 8:
        var rv: [u64] = []
        var k: i64 = 0
        while k < 16:
            rv.push(q[row * 16 + k])
            k = k + 1
        rv = _a2_permute_p(rv)
        k = 0
        while k < 16:
            q[row * 16 + k] = rv[k]
            k = k + 1
        row = row + 1

    # Apply P to each of 8 column-pairs (RFC §3.5 column layout)
    var z: [u64] = []
    i = 0
    while i < 128:
        z.push(q[i])
        i = i + 1
    var col_pair: i64 = 0
    while col_pair < 8:
        val c = 2 * col_pair
        var rv: [u64] = []
        var k: i64 = 0
        while k < 8:
            rv.push(z[k * 16 + c])
            rv.push(z[k * 16 + c + 1])
            k = k + 1
        rv = _a2_permute_p(rv)
        k = 0
        while k < 8:
            z[k * 16 + c]     = rv[2 * k]
            z[k * 16 + c + 1] = rv[2 * k + 1]
            k = k + 1
        col_pair = col_pair + 1

    _a2_block_xor(z, r)

# ============================================================================
# Block <-> bytes conversion
# ============================================================================

fn _a2_bytes_to_block(buf: [i64]) -> [u64]:
    """1024 bytes (little-endian) -> 128 u64 words."""
    var out: [u64] = []
    var i: i64 = 0
    while i < 128:
        out.push(_a2_read_u64_le(buf, i * 8))
        i = i + 1
    out

fn _a2_block_to_bytes(blk: [u64]) -> [i64]:
    """128 u64 words -> 1024 bytes (little-endian)."""
    var out: [i64] = []
    var i: i64 = 0
    while i < 1024:
        out.push(0)
        i = i + 1
    var k: i64 = 0
    while k < 128:
        out = _a2_write_u64_le(out, k * 8, blk[k])
        k = k + 1
    out

fn _a2_zero_block() -> [u64]:
    var b: [u64] = []
    var i: i64 = 0
    while i < 128:
        b.push(0)
        i = i + 1
    b

# ============================================================================
# Argon2i pseudo-random seed block (RFC 9106 §3.4.1.2)
# ============================================================================

fn _a2_argon2i_seed(pass_idx: u64, lane: u64, slice: u64, total_blocks: u64,
                    total_passes: u64, ytype: u64, counter: u64) -> [u64]:
    """Build the 1024-byte Argon2i seed input block for index generation."""
    var b = _a2_zero_block()
    b[0] = pass_idx
    b[1] = lane
    b[2] = slice
    b[3] = total_blocks
    b[4] = total_passes
    b[5] = ytype
    b[6] = counter
    b

# ============================================================================
# Argon2id main routine (with explicit key/ad support)
# ============================================================================

fn argon2id_bytes_ks(password: [i64], salt: [i64], key: [i64], assoc_data: [i64],
                     t_cost: i64, m_cost: i64, parallelism: i64,
                     tag_len: i64) -> [i64]:
    """Argon2id key derivation with optional key and associated data (RFC 9106 §3.4).

    Args:
      password    — secret octet string
      salt        — salt (at least 8 bytes per RFC §3.1)
      key         — optional secret value (may be empty)
      assoc_data  — optional associated data (may be empty)
      t_cost      — passes (>= 1)
      m_cost      — memory in KiB (>= 8 * parallelism)
      parallelism — lanes (>= 1)
      tag_len     — output length in bytes (>= 4)

    Returns: tag_len-byte derived key as [i64] list (values 0-255).
    """
    # Step 2: m' = floor(m / (4*p)) * 4*p
    val p = parallelism
    val four_p = 4 * p
    val m_prime = (m_cost / four_p) * four_p
    val q = m_prime / p          # blocks per lane
    val sl = q / 4               # segment length (4 slices per lane)

    # Step 1: H_0
    val h0_bytes = _a2_h0(p, tag_len, m_cost, t_cost, password, salt, key, assoc_data)

    # Step 3: Initialize B[i][0] and B[i][1] for each lane
    # Layout: blocks[i * q + j] = B[i][j]
    var blocks: [[u64]] = []
    var idx: i64 = 0
    while idx < m_prime:
        blocks.push(_a2_zero_block())
        idx = idx + 1

    var lane: i64 = 0
    while lane < p:
        # B[lane][0] = H'(H_0 || LE32(0) || LE32(lane), 1024)
        var seed0: [i64] = []
        seed0 = _a2_append(seed0, h0_bytes)
        seed0 = _a2_append(seed0, _a2_le32(0))
        seed0 = _a2_append(seed0, _a2_le32(lane))
        val b0 = _a2_h_prime(seed0, 1024)
        blocks[lane * q + 0] = _a2_bytes_to_block(b0)

        # B[lane][1] = H'(H_0 || LE32(1) || LE32(lane), 1024)
        var seed1: [i64] = []
        seed1 = _a2_append(seed1, h0_bytes)
        seed1 = _a2_append(seed1, _a2_le32(1))
        seed1 = _a2_append(seed1, _a2_le32(lane))
        val b1 = _a2_h_prime(seed1, 1024)
        blocks[lane * q + 1] = _a2_bytes_to_block(b1)
        lane = lane + 1

    # Step 4: Passes
    var pass_r: i64 = 0
    while pass_r < t_cost:
        var slice_s: i64 = 0
        while slice_s < 4:
            # Argon2id: data-independent indexing during pass 0, slices 0 and 1
            val use_argon2i: bool = (pass_r == 0) and (slice_s < 2)

            var ln: i64 = 0
            while ln < p:
                # Pre-generate Argon2i index blocks if needed
                var i_blocks: [[u64]] = []
                if use_argon2i:
                    val needed: i64 = (sl + 127) / 128
                    var c: i64 = 1
                    while c <= needed:
                        val seed = _a2_argon2i_seed(pass_r.to_u64(), ln.to_u64(),
                                                    slice_s.to_u64(),
                                                    m_prime.to_u64(),
                                                    t_cost.to_u64(),
                                                    _a2_type_id().to_u64(),
                                                    c.to_u64())
                        val zero = _a2_zero_block()
                        val z1 = _a2_g_compress(zero, seed)
                        val z2 = _a2_g_compress(zero, z1)
                        i_blocks.push(z2)
                        c = c + 1

                # Iterate columns in this lane segment
                var col_in_seg: i64 = 0
                while col_in_seg < sl:
                    val j: i64 = slice_s * sl + col_in_seg

                    # Skip first two columns of lane during pass 0 (already filled)
                    if (pass_r == 0) and (j < 2):
                        col_in_seg = col_in_seg + 1
                        continue

                    val prev_j = if j == 0: q - 1 else: j - 1
                    val prev_block = blocks[ln * q + prev_j]

                    # Determine J1, J2 for reference block selection
                    var j1: u64 = 0
                    var j2: u64 = 0
                    if use_argon2i:
                        val pair_block_idx = col_in_seg / 128
                        val pair_in_block = col_in_seg % 128
                        val src = i_blocks[pair_block_idx]
                        val word = src[pair_in_block]
                        j1 = word & 0xFFFFFFFF
                        j2 = (word >> 32) & 0xFFFFFFFF
                    else:
                        val word = prev_block[0]
                        j1 = word & 0xFFFFFFFF
                        j2 = (word >> 32) & 0xFFFFFFFF

                    # Map (J1, J2) to reference lane and column (RFC §3.4.1.2)
                    var ref_lane: i64 = 0
                    if (pass_r == 0) and (slice_s == 0):
                        ref_lane = ln
                    else:
                        ref_lane = (j2 % p.to_u64()).to_i64()

                    # Reference set size W (RFC §3.4.1.2)
                    var w_size: i64 = 0
                    if pass_r == 0:
                        if slice_s == 0 or ref_lane == ln:
                            w_size = slice_s * sl + col_in_seg - 1
                        else:
                            w_size = slice_s * sl
                            if col_in_seg == 0:
                                w_size = w_size - 1
                    else:
                        if ref_lane == ln:
                            w_size = q - sl + col_in_seg - 1
                        else:
                            w_size = q - sl
                            if col_in_seg == 0:
                                w_size = w_size - 1

                    # x = (J1^2) >> 32; y = (W * x) >> 32; z = W - 1 - y
                    val x = (j1 * j1) >> 32
                    val y_term = (w_size.to_u64() * x) >> 32
                    val z = w_size.to_u64() - 1 - y_term

                    # Starting position in reference lane
                    var start_pos: i64 = 0
                    if pass_r != 0:
                        start_pos = ((slice_s + 1) * sl) % q
                    val ref_j: i64 = (start_pos + z.to_i64()) % q

                    val ref_block = blocks[ref_lane * q + ref_j]
                    val new_block = _a2_g_compress(prev_block, ref_block)

                    if pass_r == 0:
                        blocks[ln * q + j] = new_block
                    else:
                        val old = blocks[ln * q + j]
                        blocks[ln * q + j] = _a2_block_xor(new_block, old)

                    col_in_seg = col_in_seg + 1
                ln = ln + 1
            slice_s = slice_s + 1
        pass_r = pass_r + 1

    # Step 5: C = XOR of all B[i][q-1]
    var c_block = blocks[0 * q + (q - 1)]
    var li: i64 = 1
    while li < p:
        c_block = _a2_block_xor(c_block, blocks[li * q + (q - 1)])
        li = li + 1

    # Step 6: Tag = H'(C, tag_len)
    val c_bytes = _a2_block_to_bytes(c_block)
    _a2_h_prime(c_bytes, tag_len)

fn argon2id_bytes(password: [i64], salt: [i64], t_cost: i64, m_cost: i64,
                  parallelism: i64, tag_len: i64) -> [i64]:
    """Argon2id key derivation (RFC 9106 §3.4) — no secret key or associated data.

    Args:
      password    — secret octet string
      salt        — salt (at least 8 bytes per RFC §3.1)
      t_cost      — passes (>= 1)
      m_cost      — memory in KiB (>= 8 * parallelism)
      parallelism — lanes (>= 1)
      tag_len     — output length in bytes (>= 4)

    Returns: tag_len-byte derived key as [i64] list (values 0-255).
    """
    val empty: [i64] = []
    argon2id_bytes_ks(password, salt, empty, empty, t_cost, m_cost, parallelism, tag_len)
