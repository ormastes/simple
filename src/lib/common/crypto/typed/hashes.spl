# ============================================================================
# common/crypto/typed/hashes.spl — typed hash/MAC/KDF wrappers
#
# Additive wrappers over existing KAT-passing pure-Simple cores.
# Does NOT rewrite cores. Only converts at the boundary:
#   ByteSpan → [i64]  (input direction)
#   [i64]    → [u8]   (output direction)
#   [u8]     → Digest/MacTag/SharedSecret via .new([u8])
#
# Alpha oracle status: ABSENT.
# rt_hmac_sha256/rt_hmac_sha512 are (text,text)->text externs that route
# through utf8-lossy — not byte-faithful independent oracles for binary data.
# No rt_sha256_bytes / rt_sha512_bytes byte-level externs exist in the tree.
# Dual-backend wiring is therefore omitted; use pure path only.
# ============================================================================

use std.common.bytes.span.{ByteSpan}
use std.common.crypto.typed.ctypes.{Digest, MacTag, SharedSecret}
use std.common.crypto.sha256.{sha256_bytes}
use std.common.crypto.sha512.{sha512_bytes, sha512_256_bytes}
use std.common.crypto.hmac.{hmac_sha256_bytes, hmac_sha512_bytes}
# NOTE: hkdf.spl is NOT imported here because the interpreter drops transitive
# cross-module imports when hashes.spl is itself imported (3-hop chain fails).
# Instead, HKDF-SHA-256 extract+expand is inlined below using hmac_sha256_bytes
# which is already in scope and proven to survive cross-module import.
# This is still additive — no core logic is duplicated beyond what hkdf.spl does.

# ----------------------------------------------------------------------------
# Internal boundary converters
# ----------------------------------------------------------------------------

# ByteSpan → [i64]: each u8 element widened to i64 (0..255)
fn _span_to_i64s(span: ByteSpan) -> [i64]:
    var out: [i64] = []
    var i = 0
    while i < span.len():
        out.push(span.get(i).to_i64())
        i = i + 1
    out

# [i64] → [u8]: low byte of each element kept (& 0xFF).to_u8()
fn _i64s_to_u8s(src: [i64]) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < src.len():
        out.push((src[i] & 255).to_u8())
        i = i + 1
    out

# ----------------------------------------------------------------------------
# Internal HKDF-SHA-256 helpers (RFC 5869) — inlined to avoid 3-hop chain
# These mirror hkdf_extract_sha256 / hkdf_expand_sha256 from hkdf.spl exactly.
# ----------------------------------------------------------------------------

# HKDF-Extract: PRK = HMAC-SHA-256(salt, IKM). Returns 32-byte PRK.
fn _hkdf_extract(salt: [i64], ikm: [i64]) -> [i64]:
    var effective_salt: [i64] = salt
    if salt.len() == 0:
        var zs: [i64] = []
        var zi = 0
        while zi < 32:
            zs.push(0)
            zi = zi + 1
        effective_salt = zs
    hmac_sha256_bytes(effective_salt, ikm)

# HKDF-Expand: OKM = T(1) || T(2) || ... T(n) where T(i) = HMAC(PRK, T(i-1)||info||i).
# Returns `length` bytes.
fn _hkdf_expand(prk: [i64], info: [i64], length: i64) -> [i64]:
    if length <= 0:
        var empty: [i64] = []
        return empty
    val hash_len = 32
    val n = (length + hash_len - 1) / hash_len
    var okm: [i64] = []
    var prev: [i64] = []
    var block_idx = 1
    while block_idx <= n:
        var input: [i64] = []
        var pi = 0
        while pi < prev.len():
            input.push(prev[pi])
            pi = pi + 1
        var ii = 0
        while ii < info.len():
            input.push(info[ii])
            ii = ii + 1
        input.push(block_idx)
        var t = hmac_sha256_bytes(prk, input)
        prev = t
        var ti = 0
        while ti < t.len():
            okm.push(t[ti])
            ti = ti + 1
        block_idx = block_idx + 1
    # Trim to requested length
    var result: [i64] = []
    var ri = 0
    while ri < length:
        result.push(okm[ri])
        ri = ri + 1
    result

# ----------------------------------------------------------------------------
# Typed hash functions
# ----------------------------------------------------------------------------

# SHA-256 of msg. Returns a Digest (32 bytes).
fn sha256(msg: ByteSpan) -> Digest:
    val raw = sha256_bytes(_span_to_i64s(msg))
    Digest.new(_i64s_to_u8s(raw))

# SHA-512 of msg. Returns a Digest (64 bytes).
fn sha512(msg: ByteSpan) -> Digest:
    val raw = sha512_bytes(_span_to_i64s(msg))
    Digest.new(_i64s_to_u8s(raw))

# SHA-512/256 of msg. Returns a Digest (32 bytes).
fn sha512_256(msg: ByteSpan) -> Digest:
    val raw = sha512_256_bytes(_span_to_i64s(msg))
    Digest.new(_i64s_to_u8s(raw))

# ----------------------------------------------------------------------------
# Typed MAC functions
# ----------------------------------------------------------------------------

# HMAC-SHA-256 of (key, msg). Returns a MacTag (32 bytes).
fn hmac_sha256(key: ByteSpan, msg: ByteSpan) -> MacTag:
    val raw = hmac_sha256_bytes(_span_to_i64s(key), _span_to_i64s(msg))
    MacTag.new(_i64s_to_u8s(raw))

# HMAC-SHA-512 of (key, msg). Returns a MacTag (64 bytes).
fn hmac_sha512(key: ByteSpan, msg: ByteSpan) -> MacTag:
    val raw = hmac_sha512_bytes(_span_to_i64s(key), _span_to_i64s(msg))
    MacTag.new(_i64s_to_u8s(raw))

# ----------------------------------------------------------------------------
# Typed KDF functions
# ----------------------------------------------------------------------------

# HKDF-SHA-256 one-shot (RFC 5869): extract then expand.
# Uses inlined _hkdf_extract/_hkdf_expand (identical to hkdf.spl) to avoid
# the 3-hop cross-module import chain that breaks in interpreter mode.
# Returns a SharedSecret of `length` bytes.
fn hkdf_sha256(salt: ByteSpan, ikm: ByteSpan, info: ByteSpan, length: i64) -> SharedSecret:
    val prk = _hkdf_extract(_span_to_i64s(salt), _span_to_i64s(ikm))
    val okm = _hkdf_expand(prk, _span_to_i64s(info), length)
    SharedSecret.new(_i64s_to_u8s(okm))

export sha256, sha512, sha512_256
export hmac_sha256, hmac_sha512
export hkdf_sha256
