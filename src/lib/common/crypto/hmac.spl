# HMAC-SHA256 and HMAC-SHA512 implementations per RFC 2104.
# Delegates to the runtime FFI externs for efficiency.

extern fn rt_hmac_sha256(key: text, data: text) -> text
extern fn rt_hmac_sha512(key: text, data: text) -> text

# HMAC-SHA256 of (key, data). Both are text (UTF-8). Returns lowercase hex.
fn hmac_sha256(key: text, data: text) -> text:
    rt_hmac_sha256(key, data)

# HMAC-SHA512 of (key, data). Both are text (UTF-8). Returns lowercase hex.
fn hmac_sha512(key: text, data: text) -> text:
    rt_hmac_sha512(key, data)

# Default HMAC (SHA-256). Returns lowercase hex.
fn hmac(key: text, data: text) -> text:
    hmac_sha256(key, data)
