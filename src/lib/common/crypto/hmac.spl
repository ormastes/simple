        outer_input.push(o_key_pad.get(i))
        i = i + 1
    i = 0
    while i < inner_hash.len():
        outer_input.push(inner_hash.get(i))
        i = i + 1

    sha1_bytes(outer_input)

# =============================================================================
# HMAC-SHA3-256 (FIPS 198-1 + FIPS 202)
#
# SHA3-256 has a 32-byte output and a 136-byte rate (block size). HMAC block
# size = sponge rate, smaller than SHA-2's 64/128 bytes. Long keys are
# pre-hashed with SHA3-256 to fit within block_size before XOR-padding.
# =============================================================================

# HMAC-SHA3-256
# reason: positional crypto hmac API
fn hmac_sha3_256(key: text, message: text) -> list:
    val key_bytes = text_to_bytes(key)
    val message_bytes = text_to_bytes(message)
    hmac_sha3_256_bytes(key_bytes, message_bytes)

# HMAC-SHA3-256 with byte inputs
# reason: positional crypto hmac API
fn hmac_sha3_256_bytes(key_bytes: list, message_bytes: list) -> list:
    val block_size = 136  # SHA3-256 sponge rate

    # Prepare key
    var k = []
    if key_bytes.len() > block_size:
        k = sha3_256_bytes(key_bytes)
    else:
        var i = 0
        while i < key_bytes.len():
            k.push(key_bytes.get(i))
            i = i + 1

    # Pad key to block size
    while k.len() < block_size:
        k.push(0)

    # Create inner and outer padded keys
    var i_key_pad = []
    var o_key_pad = []
    var i = 0
    while i < block_size:
        val k_byte = k.get(i)
        i_key_pad.push(k_byte ^ 0x36)
        o_key_pad.push(k_byte ^ 0x5c)
        i = i + 1

    # Inner hash
    var inner_input = []
    i = 0
    while i < i_key_pad.len():
        inner_input.push(i_key_pad.get(i))
        i = i + 1
    i = 0
    while i < message_bytes.len():
        inner_input.push(message_bytes.get(i))
        i = i + 1

    val inner_hash = sha3_256_bytes(inner_input)

    # Outer hash
    var outer_input = []
    i = 0
    while i < o_key_pad.len():
        outer_input.push(o_key_pad.get(i))
        i = i + 1
    i = 0
    while i < inner_hash.len():
        outer_input.push(inner_hash.get(i))
        i = i + 1

    sha3_256_bytes(outer_input)

