        v15 = _rotr64_32(v15 ^ v3)
        v11 = _wadd64(v11, v15)
        v7 = _rotr64_24(v7 ^ v11)
        v3 = _wadd64(_wadd64(v3, v7), m7)
        v15 = _rotr64_16(v15 ^ v3)
        v11 = _wadd64(v11, v15)
        v7 = _rotr64_63(v7 ^ v11)
        v0 = _wadd64(_wadd64(v0, v5), m8)
        v15 = _rotr64_32(v15 ^ v0)
        v10 = _wadd64(v10, v15)
        v5 = _rotr64_24(v5 ^ v10)
        v0 = _wadd64(_wadd64(v0, v5), m9)
        v15 = _rotr64_16(v15 ^ v0)
        v10 = _wadd64(v10, v15)
        v5 = _rotr64_63(v5 ^ v10)
        v1 = _wadd64(_wadd64(v1, v6), m10)
        v12 = _rotr64_32(v12 ^ v1)
        v11 = _wadd64(v11, v12)
        v6 = _rotr64_24(v6 ^ v11)
        v1 = _wadd64(_wadd64(v1, v6), m11)
        v12 = _rotr64_16(v12 ^ v1)
        v11 = _wadd64(v11, v12)
        v6 = _rotr64_63(v6 ^ v11)
        v2 = _wadd64(_wadd64(v2, v7), m12)
        v13 = _rotr64_32(v13 ^ v2)
        v8 = _wadd64(v8, v13)
        v7 = _rotr64_24(v7 ^ v8)
        v2 = _wadd64(_wadd64(v2, v7), m13)
        v13 = _rotr64_16(v13 ^ v2)
        v8 = _wadd64(v8, v13)
        v7 = _rotr64_63(v7 ^ v8)
        v3 = _wadd64(_wadd64(v3, v4), m14)
        v14 = _rotr64_32(v14 ^ v3)
        v9 = _wadd64(v9, v14)
        v4 = _rotr64_24(v4 ^ v9)
        v3 = _wadd64(_wadd64(v3, v4), m15)
        v14 = _rotr64_16(v14 ^ v3)
        v9 = _wadd64(v9, v14)
        v4 = _rotr64_63(v4 ^ v9)

        # Round 11 — sigma row: [14,10,4,8,9,15,13,6,1,12,0,2,11,7,5,3]
        v0 = _wadd64(_wadd64(v0, v4), m14)
        v12 = _rotr64_32(v12 ^ v0)
        v8 = _wadd64(v8, v12)
        v4 = _rotr64_24(v4 ^ v8)
        v0 = _wadd64(_wadd64(v0, v4), m10)
        v12 = _rotr64_16(v12 ^ v0)
        v8 = _wadd64(v8, v12)
        v4 = _rotr64_63(v4 ^ v8)
        v1 = _wadd64(_wadd64(v1, v5), m4)
        v13 = _rotr64_32(v13 ^ v1)
        v9 = _wadd64(v9, v13)
        v5 = _rotr64_24(v5 ^ v9)
        v1 = _wadd64(_wadd64(v1, v5), m8)
        v13 = _rotr64_16(v13 ^ v1)
        v9 = _wadd64(v9, v13)
        v5 = _rotr64_63(v5 ^ v9)
        v2 = _wadd64(_wadd64(v2, v6), m9)
        v14 = _rotr64_32(v14 ^ v2)
        v10 = _wadd64(v10, v14)
        v6 = _rotr64_24(v6 ^ v10)
        v2 = _wadd64(_wadd64(v2, v6), m15)
        v14 = _rotr64_16(v14 ^ v2)
        v10 = _wadd64(v10, v14)
        v6 = _rotr64_63(v6 ^ v10)
        v3 = _wadd64(_wadd64(v3, v7), m13)
        v15 = _rotr64_32(v15 ^ v3)
        v11 = _wadd64(v11, v15)
        v7 = _rotr64_24(v7 ^ v11)
        v3 = _wadd64(_wadd64(v3, v7), m6)
        v15 = _rotr64_16(v15 ^ v3)
        v11 = _wadd64(v11, v15)
        v7 = _rotr64_63(v7 ^ v11)
        v0 = _wadd64(_wadd64(v0, v5), m1)
        v15 = _rotr64_32(v15 ^ v0)
        v10 = _wadd64(v10, v15)
        v5 = _rotr64_24(v5 ^ v10)
        v0 = _wadd64(_wadd64(v0, v5), m12)
        v15 = _rotr64_16(v15 ^ v0)
        v10 = _wadd64(v10, v15)
        v5 = _rotr64_63(v5 ^ v10)
        v1 = _wadd64(_wadd64(v1, v6), m0)
        v12 = _rotr64_32(v12 ^ v1)
        v11 = _wadd64(v11, v12)
        v6 = _rotr64_24(v6 ^ v11)
        v1 = _wadd64(_wadd64(v1, v6), m2)
        v12 = _rotr64_16(v12 ^ v1)
        v11 = _wadd64(v11, v12)
        v6 = _rotr64_63(v6 ^ v11)
        v2 = _wadd64(_wadd64(v2, v7), m11)
        v13 = _rotr64_32(v13 ^ v2)
        v8 = _wadd64(v8, v13)
        v7 = _rotr64_24(v7 ^ v8)
        v2 = _wadd64(_wadd64(v2, v7), m7)
        v13 = _rotr64_16(v13 ^ v2)
        v8 = _wadd64(v8, v13)
        v7 = _rotr64_63(v7 ^ v8)
        v3 = _wadd64(_wadd64(v3, v4), m5)
        v14 = _rotr64_32(v14 ^ v3)
        v9 = _wadd64(v9, v14)
        v4 = _rotr64_24(v4 ^ v9)
        v3 = _wadd64(_wadd64(v3, v4), m3)
        v14 = _rotr64_16(v14 ^ v3)
        v9 = _wadd64(v9, v14)
        v4 = _rotr64_63(v4 ^ v9)

        # Finalize: h[i] ^= v[i] ^ v[i+8]
        h0 = h0 ^ v0  ^ v8
        h1 = h1 ^ v1  ^ v9
        h2 = h2 ^ v2  ^ v10
        h3 = h3 ^ v3  ^ v11
        h4 = h4 ^ v4  ^ v12
        h5 = h5 ^ v5  ^ v13
        h6 = h6 ^ v6  ^ v14
        h7 = h7 ^ v7  ^ v15

        block_idx = block_idx + 1

    # Serialize h[0..word_count] as little-endian bytes
    val word_count = digest_size / 8
    var result: [i64] = []
    var wi = 0
    while wi < word_count:
        val wd = if wi == 0: h0 elif wi == 1: h1 elif wi == 2: h2 elif wi == 3: h3
                 elif wi == 4: h4 elif wi == 5: h5 elif wi == 6: h6 else: h7
        result.push(wd & 255)
        result.push((wd >> 8) & 255)
        result.push((wd >> 16) & 255)
        result.push((wd >> 24) & 255)
        result.push(_lshr64_32(wd) & 255)
        result.push(_lshr64_40(wd) & 255)
        result.push(_lshr64_48(wd) & 255)
        result.push(_lshr64_56(wd) & 255)
        wi = wi + 1
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

# BLAKE2b-512 of a byte list. Returns 64-byte list.
fn blake2b_512_bytes(data: [i64]) -> [i64]:
    _blake2b_core(data, 64)

# BLAKE2b-256 of a byte list. Returns 32-byte list.
fn blake2b_256_bytes(data: [i64]) -> [i64]:
    _blake2b_core(data, 32)

# BLAKE2b-512 of text input. Returns 128-char lowercase hex string.
fn blake2b_512_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(blake2b_512_bytes(text_to_bytes(data)))

# BLAKE2b-256 of text input. Returns 64-char lowercase hex string.
fn blake2b_256_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(blake2b_256_bytes(text_to_bytes(data)))
