# ECDSA-P256-SHA-256 Common Crypto Wrapper Spec
#
# Tests src/lib/common/crypto/ecdsa_p256.spl — the thin common-layer wrapper
# around the rt_ecdsa_p256_sign / rt_ecdsa_p256_verify interpreter externs.
#
# Test lanes:
#   Path B — Round-trip sign + verify (non-deterministic; uses hardcoded PKCS#8 test key)
#   Path C — Verify-only with NIST CAVP SigVer P-256 SHA-256 vector
#
# Key material: same test vectors as test/unit/lib/crypto/ecdsa_p256_spec.spl
# (which tests the OS-layer wrapper). Reused here to cross-validate the
# common-layer wrapper produces identical results from the same externs.
#
# NOTE: Signing is non-deterministic (random nonce). Byte-exact signature
# match is not possible; sign+verify round-trip is used instead.

use std.spipe.*
use std.common.crypto.ecdsa_p256.{ecdsa_p256_sign, ecdsa_p256_verify}

# ============================================================================
# Key material helpers — module-level fns to avoid the it-block var-mutation
# interpreter quirk (feedback_it_block_var_mutation.md).
#
# PKCS#8 DER private key (135 bytes), P-256:
#   Qx = fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8
#   Qy = a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd
#
# SPKI DER public key = standard P-256 SPKI prefix (26 bytes) || 0x04 || Qx || Qy
# ============================================================================

