fn _cavp_sig() -> [u8]:
    # R || S — 64 bytes fixed-width
    val b: [u8] = [
        0xbfu8, 0x96u8, 0xb9u8, 0x9au8, 0xa4u8, 0x9cu8, 0x70u8, 0x5cu8,
        0x91u8, 0x0bu8, 0xe3u8, 0x31u8, 0x42u8, 0x01u8, 0x7cu8, 0x64u8,
        0x2fu8, 0xf5u8, 0x40u8, 0xc7u8, 0x63u8, 0x49u8, 0xb9u8, 0xdau8,
        0xb7u8, 0x2fu8, 0x98u8, 0x1fu8, 0xd9u8, 0x34u8, 0x7fu8, 0x4fu8,
        0x17u8, 0xc5u8, 0x50u8, 0x95u8, 0x81u8, 0x90u8, 0x89u8, 0xc2u8,
        0xe0u8, 0x3bu8, 0x9cu8, 0xd4u8, 0x15u8, 0xabu8, 0xdfu8, 0x12u8,
        0x44u8, 0x4eu8, 0x32u8, 0x30u8, 0x75u8, 0xd9u8, 0x8fu8, 0x31u8,
        0x92u8, 0x0bu8, 0x9eu8, 0x0fu8, 0x57u8, 0xecu8, 0x87u8, 0x1cu8
    ]
    b

fn _hello_msg() -> [u8]:
    # "hello" in ASCII
    val b: [u8] = [0x68u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8]
    b

# ============================================================================
# Path B — Round-trip sign + verify (non-deterministic, fixed PKCS#8 test key)
# ============================================================================

describe "ECDSA-P256-SHA-256 common wrapper — round-trip sign+verify":

    it "sign returns a 64-byte signature for empty message":
        val sig = ecdsa_p256_sign(_pkcs8_bytes(), [])
        expect(sig.len()).to_equal(64)

    it "sign returns a 64-byte signature for short message":
        val sig = ecdsa_p256_sign(_pkcs8_bytes(), _hello_msg())
        expect(sig.len()).to_equal(64)

    it "signs and verifies an empty message":
        val sig = ecdsa_p256_sign(_pkcs8_bytes(), [])
        val ok = ecdsa_p256_verify(_spki_bytes(), [], sig)
        expect(ok).to_equal(true)

    it "signs and verifies a short ASCII message":
        val sig = ecdsa_p256_sign(_pkcs8_bytes(), _hello_msg())
        val ok = ecdsa_p256_verify(_spki_bytes(), _hello_msg(), sig)
        expect(ok).to_equal(true)

    it "signature is rejected under a different public key":
        val sig = ecdsa_p256_sign(_pkcs8_bytes(), _hello_msg())
        val ok = ecdsa_p256_verify(_cavp_spki(), _hello_msg(), sig)
        expect(ok).to_equal(false)

    it "returns empty for invalid (empty) private key":
        val sig = ecdsa_p256_sign([], _hello_msg())
        expect(sig.len()).to_equal(0)

# ============================================================================
# Path C — Verify-only with NIST CAVP SigVer P-256 SHA-256 vector
# ============================================================================

describe "ECDSA-P256-SHA-256 common wrapper — NIST CAVP SigVer":

    it "NIST CAVP P-256 SHA-256 vector verifies (Result = P)":
        val ok = ecdsa_p256_verify(_cavp_spki(), _cavp_msg(), _cavp_sig())
        expect(ok).to_equal(true)

    it "verify returns false for empty public key":
        val ok = ecdsa_p256_verify([], _cavp_msg(), _cavp_sig())
        expect(ok).to_equal(false)

    it "verify returns false for empty signature":
        val ok = ecdsa_p256_verify(_cavp_spki(), _cavp_msg(), [])
        expect(ok).to_equal(false)
