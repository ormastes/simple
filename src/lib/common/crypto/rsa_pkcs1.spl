# RSA PKCS#1 v1.5 — Pure Simple implementation.
#
# MDSOC: feature dimension, crypto layer.
# RFC 8017 §7.2 (RSAES-PKCS1-v1_5) + §8.2 (RSASSA-PKCS1-v1_5).
#
# Exports:
#   rsa_pkcs1_public_encrypt(n_bytes, e_bytes, plaintext)  -> [u8]  (type-2 pad)
#   rsa_pkcs1_verify_sha256(n_bytes, e_bytes, msg, sig)    -> bool  (type-1)
#   rsa_pkcs1_raw_modexp(base_bytes, exp_bytes, mod_bytes) -> [u8]  (raw RSAEP)
#
# Big-integer arithmetic uses 30-bit limbs (little-endian limb order) stored as
# `list` (untyped, matches rsa_fallback.spl convention).
#
# Duplication of limb code from rsa_fallback.spl is intentional:
# underscore-prefixed names are module-private and cannot be imported.
# See doc/04_architecture/lib/crypto/rsa_x509.md §D2.
#
# BUG(rsa_pkcs1_modexp_2048_interp_timeout_2026-06-15): RSA-2048 modexp
# times out in interpreter.  KAT specs use tiny keys (n=3233, 12-bit).
#
# BUG(rsa_pkcs1_encrypt_deterministic_padding_2026-06-15): type-2 PS uses
# 0xFF bytes; real TLS MUST use CSPRNG.  See bug doc for fix plan.
#
# tag: crypto, rsa, pkcs1

use std.common.crypto.sha256.{sha256_bytes}

# ============================================================================
# 30-bit limb big-integer (little-endian limb order)
# list = untyped array; each element is i64 in [0, 2^30)
# ============================================================================

val _PKCS_BASE: i64 = 1073741824      # 2^30
val _PKCS_BITS: i64 = 30

fn _p_zero() -> list:
    [0]

fn _p_one() -> list:
    [1]

fn _p_from_i64(n: i64) -> list:
    if n == 0:
        return [0]
    var result = []
    var v = n
    while v > 0:
        result.push(v % _PKCS_BASE)
        v = v / _PKCS_BASE
    result

fn _p_normalize(a: list) -> list:
    var len = a.len().to_i64()
    while len > 1:
        if a[len - 1] != 0:
            break
        len = len - 1
    if len == a.len().to_i64():
        return a
    var r = []
    var i: i64 = 0
    while i < len:
        r.push(a[i])
        i = i + 1
    r

fn _p_is_zero(a: list) -> bool:
    val n = _p_normalize(a)
    n.len().to_i64() == 1 and n[0] == 0

fn _p_compare(a: list, b: list) -> i64:
    val na = _p_normalize(a)
    val nb = _p_normalize(b)
    if na.len() > nb.len(): return 1
    if na.len() < nb.len(): return -1
    var i: i64 = na.len().to_i64() - 1
    while i >= 0:
        if na[i] > nb[i]: return 1
        if na[i] < nb[i]: return -1
        i = i - 1
    0

fn _p_add(a: list, b: list) -> list:
    var result = []
    var carry: i64 = 0
    var i: i64 = 0
    val max_len: i64 = if a.len().to_i64() > b.len().to_i64() { a.len().to_i64() } else { b.len().to_i64() }
    while i < max_len or carry != 0:
        var sum = carry
        if i < a.len().to_i64():
            sum = sum + a[i]
        if i < b.len().to_i64():
            sum = sum + b[i]
        result.push(sum % _PKCS_BASE)
        carry = sum / _PKCS_BASE
        i = i + 1
    _p_normalize(result)

fn _p_sub(a: list, b: list) -> list:
    # Precondition: a >= b
    var result = []
    var borrow: i64 = 0
    var i: i64 = 0
    while i < a.len().to_i64():
        var limb_a = a[i] - borrow
        var limb_b: i64 = 0
        if i < b.len().to_i64():
            limb_b = b[i]
        if limb_a < limb_b:
            limb_a = limb_a + _PKCS_BASE
            borrow = 1
        else:
            borrow = 0
        result.push(limb_a - limb_b)
        i = i + 1
    _p_normalize(result)

fn _p_mul(a: list, b: list) -> list:
    if _p_is_zero(a): return _p_zero()
    if _p_is_zero(b): return _p_zero()
    val len_a = a.len().to_i64()
    val len_b = b.len().to_i64()
    var result = []
    var i: i64 = 0
    while i < len_a + len_b:
        result.push(0)
        i = i + 1
    var ia: i64 = 0
    while ia < len_a:
        var carry: i64 = 0
        var ib: i64 = 0
        while ib < len_b:
            val prod = result[ia + ib] + a[ia] * b[ib] + carry
            result[ia + ib] = prod % _PKCS_BASE
            carry = prod / _PKCS_BASE
            ib = ib + 1
        result[ia + len_b] = result[ia + len_b] + carry
        ia = ia + 1
    _p_normalize(result)

fn _p_mul_i64(a: list, n: i64) -> list:
    var result = []
    var carry: i64 = 0
    var i: i64 = 0
    while i < a.len().to_i64():
        val prod = a[i] * n + carry
        result.push(prod % _PKCS_BASE)
        carry = prod / _PKCS_BASE
        i = i + 1
    if carry > 0:
        result.push(carry)
    _p_normalize(result)

# Returns array: [quotient_limb0, ..., quotient_limbN, remainder]
# Remainder is the LAST element; quotient limbs are all but the last.
fn _p_divmod_i64(a: list, n: i64) -> list:
    var rem: i64 = 0
    val len = a.len().to_i64()
    var quot = []
    var i: i64 = 0
    while i < len:
        quot.push(0)
        i = i + 1
    var idx: i64 = len - 1
    while idx >= 0:
        val cur = rem * _PKCS_BASE + a[idx]
        quot[idx] = cur / n
        rem = cur % n
        idx = idx - 1
    var result = []
    var j: i64 = 0
    while j < len:
        result.push(quot[j])
        j = j + 1
    result.push(rem)
    result

fn _p_bit_length(a: list) -> i64:
    val na = _p_normalize(a)
    if na.len().to_i64() == 1 and na[0] == 0:
        return 0
    val top = na[na.len().to_i64() - 1]
    var bits: i64 = (na.len().to_i64() - 1) * _PKCS_BITS
    var tmp = top
    while tmp > 0:
        bits = bits + 1
        tmp = tmp / 2
    bits

fn _p_get_bit(a: list, idx: i64) -> i64:
    val limb_idx = idx / _PKCS_BITS
    val bit_idx = idx % _PKCS_BITS
    if limb_idx >= a.len().to_i64(): return 0
    val mask: i64 = 1 << bit_idx
    (a[limb_idx] / mask) % 2

fn _p_shift_left_one(a: list) -> list:
    var result = []
    var carry: i64 = 0
    var i: i64 = 0
    while i < a.len().to_i64():
        val cur = a[i] * 2 + carry
        result.push(cur % _PKCS_BASE)
        carry = cur / _PKCS_BASE
        i = i + 1
    if carry > 0:
        result.push(carry)
    result

fn _p_mod(a: list, b: list) -> list:
    if _p_compare(a, b) < 0:
        return a
    var shifted = _p_normalize(b)
    var k: i64 = 0
    while _p_compare(shifted, a) <= 0:
        shifted = _p_shift_left_one(shifted)
        k = k + 1
    var result = a
    while k > 0:
        k = k - 1
        # shift `shifted` right by one bit
        var d2 = []
        var di: i64 = 0
        while di < shifted.len().to_i64():
            d2.push(0)
            di = di + 1
        var carry2: i64 = 0
        var si: i64 = shifted.len().to_i64() - 1
        while si >= 0:
            val cur2 = carry2 * _PKCS_BASE + shifted[si]
            d2[si] = cur2 / 2
            carry2 = cur2 % 2
            si = si - 1
        shifted = _p_normalize(d2)
        if _p_compare(result, shifted) >= 0:
            result = _p_sub(result, shifted)
    _p_normalize(result)

# 4-bit sliding window modular exponentiation
fn _p_mod_exp(base: list, exp: list, modulus: list) -> list:
    if _p_is_zero(modulus):
        return _p_zero()
    # Precompute powers[0..16]: powers[i] = base^i mod modulus
    # Use separate named slots to avoid [[list]] 2D array type issue
    var powers = []
    powers.push(_p_zero())               # slot 0 (unused)
    powers.push(_p_mod(base, modulus))   # slot 1 = base^1
    var pi: i64 = 2
    while pi <= 16:
        powers.push(_p_mod(_p_mul(powers[pi - 1], powers[1]), modulus))
        pi = pi + 1
    var result = _p_one()
    val bits = _p_bit_length(exp)
    var i: i64 = bits - 1
    while i >= 0:
        result = _p_mod(_p_mul(result, result), modulus)
        if i >= 3:
            val b3 = _p_get_bit(exp, i)
            val b2 = _p_get_bit(exp, i - 1)
            val b1 = _p_get_bit(exp, i - 2)
            val b0 = _p_get_bit(exp, i - 3)
            val win: i64 = b3 * 8 + b2 * 4 + b1 * 2 + b0
            if win > 0:
                result = _p_mod(_p_mul(result, result), modulus)
                result = _p_mod(_p_mul(result, result), modulus)
                result = _p_mod(_p_mul(result, result), modulus)
                result = _p_mod(_p_mul(result, powers[win]), modulus)
                i = i - 4
            else:
                i = i - 1
        else:
            if _p_get_bit(exp, i) == 1:
                result = _p_mod(_p_mul(result, powers[1]), modulus)
            i = i - 1
    result

# ============================================================================
# Byte ↔ bigint conversion (big-endian byte arrays)
# ============================================================================

fn _bytes_to_bigint(bytes: [u8]) -> list:
    if bytes.len() == 0:
        return _p_zero()
    var result = _p_zero()
    var i: u64 = 0
    while i < bytes.len():
        result = _p_mul_i64(result, 256)
        result = _p_add(result, _p_from_i64(bytes[i].to_i64()))
        i = i + 1
    _p_normalize(result)

fn _bigint_to_bytes(n: list, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length:
        out.push(0)
        i = i + 1
    var temp = n
    var pos: u64 = length
    while pos > 0:
        val dm = _p_divmod_i64(temp, 256)
        val dm_len = dm.len().to_i64()
        val rem = dm[dm_len - 1]
        # quotient = dm[0..dm_len-2]
        var quot = []
        var qi: i64 = 0
        while qi < dm_len - 1:
            quot.push(dm[qi])
            qi = qi + 1
        temp = _p_normalize(quot)
        pos = pos - 1
        out[pos] = rem.to_u8()
    out

fn _append_u8(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    var i: u64 = 0
    while i < src.len():
        out.push(src[i])
        i = i + 1
    out

# ============================================================================
# PKCS#1 v1.5 type-2 padding (encryption) — RFC 8017 §7.2.1
# WARNING: PS uses 0xFF (deterministic placeholder).
# Real TLS MUST use CSPRNG bytes for PS.
# See doc/08_tracking/bug/rsa_pkcs1_encrypt_deterministic_padding_2026-06-15.md
# ============================================================================

fn _pkcs1_v15_pad_type2(plaintext: [u8], key_len: u64) -> [u8]:
    val t_len = plaintext.len()
    if key_len < t_len + 11:
        return []
    var out: [u8] = [0x00u8, 0x02]
    val pad_len = key_len - t_len - 3
    var pi: u64 = 0
    while pi < pad_len:
        out.push(0xFF)
        pi = pi + 1
    out.push(0x00)
    _append_u8(out, plaintext)

# ============================================================================
# EMSA-PKCS1-v1_5 (type-1 padding for signatures) — RFC 8017 §9.2
# SHA-256 DigestInfo prefix (19 bytes, DER-encoded):
#   30 31 30 0d 06 09 60 86 48 01 65 03 04 02 01 05 00 04 20
# ============================================================================

fn _sha256_digest_info_prefix() -> [u8]:
    [
        0x30u8, 0x31, 0x30, 0x0d, 0x06, 0x09, 0x60, 0x86,
        0x48, 0x01, 0x65, 0x03, 0x04, 0x02, 0x01, 0x05,
        0x00, 0x04, 0x20
    ]

fn _emsa_pkcs1_v15_sha256(digest: [u8], key_bytes: u64) -> [u8]:
    val prefix = _sha256_digest_info_prefix()
    val t_len: u64 = prefix.len() + digest.len()
    if key_bytes < t_len + 11:
        return []
    var out: [u8] = [0x00u8, 0x01]
    val pad_len = key_bytes - t_len - 3
    var pi: u64 = 0
    while pi < pad_len:
        out.push(0xFF)
        pi = pi + 1
    out.push(0x00)
    out = _append_u8(out, prefix)
    _append_u8(out, digest)

# ============================================================================
# Public API
# ============================================================================

# Raw modular exponentiation: result = base^exp mod mod_val.
# Returns big-endian [u8] of length mod_bytes.len().
# KAT: base=42, exp=17, mod=3233 → result=2557 (textbook RSA n=3233 e=17)
fn rsa_pkcs1_raw_modexp(base_bytes: [u8], exp_bytes: [u8], mod_bytes: [u8]) -> [u8]:
    val m = _bytes_to_bigint(base_bytes)
    val e = _bytes_to_bigint(exp_bytes)
    val n = _bytes_to_bigint(mod_bytes)
    val result = _p_mod_exp(m, e, n)
    _bigint_to_bytes(result, mod_bytes.len())

# RSAES-PKCS1-v1_5 encrypt — RFC 8017 §7.2.1.
# WARNING: deterministic padding (see bug doc).
fn rsa_pkcs1_public_encrypt(n_bytes: [u8], e_bytes: [u8], plaintext: [u8]) -> [u8]:
    val key_len = n_bytes.len()
    val em = _pkcs1_v15_pad_type2(plaintext, key_len)
    if em.len() == 0:
        return []
    rsa_pkcs1_raw_modexp(em, e_bytes, n_bytes)

# RSASSA-PKCS1-v1_5 verify with SHA-256 — RFC 8017 §8.2.2.
# n_bytes, e_bytes: raw bigint bytes (leading zero stripped from DER INTEGER).
fn rsa_pkcs1_verify_sha256(n_bytes: [u8], e_bytes: [u8], msg: [u8], sig: [u8]) -> bool:
    val key_len = n_bytes.len()
    if sig.len() != key_len:
        return false
    val em_prime = rsa_pkcs1_raw_modexp(sig, e_bytes, n_bytes)
    val digest = sha256_bytes(msg)
    val em = _emsa_pkcs1_v15_sha256(digest, key_len)
    if em.len() != em_prime.len():
        return false
    var diff: i64 = 0
    var i: u64 = 0
    while i < em.len():
        diff = diff | (em[i].to_i64() ^ em_prime[i].to_i64())
        i = i + 1
    diff == 0

export rsa_pkcs1_raw_modexp, rsa_pkcs1_public_encrypt, rsa_pkcs1_verify_sha256
