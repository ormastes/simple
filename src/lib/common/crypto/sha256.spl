# SHA-256 hash implementation per FIPS 180-4.
# Provides sha256_bytes (bytes -> bytes) and sha256_text (text -> hex).

use std.common.crypto.types.{rotr32}
use std.common.crypto.sha256_core.{sha256_initial_hash, sha256_pad_message, sha256_process_block}

# SHA-256 round constants (first 32 bits of fractional parts of cube roots of first 64 primes).
fn _sha256_k() -> [i64]:
    [
        1116352408, 1899447441, 3049323471, 3921009573,
         961987163, 1508970993, 2453635748, 2870763221,
        3624381080,  310598401,  607225278, 1426881987,
        1925078388, 2162078206, 2614888103, 3248222580,
        3835390401, 4022224774,  264347078,  604807628,
         770255983, 1249150122, 1555081692, 1996064986,
        2554220882, 2821834349, 2952996808, 3210313671,
        3336571891, 3584528711,  113926993,  338241895,
         666307205,  773529912, 1294757372, 1396182291,
        1695183700, 1986661051, 2177026350, 2456956037,
        2730485921, 2820302411, 3259730800, 3345764771,
        3516065817, 3600352804, 4094571909,  275423344,
         430227734,  506948616,  659060556,  883997877,
         958139571, 1322822218, 1537002063, 1747873779,
        1955562222, 2024104815, 2227730452, 2361852424,
        2428436474, 2756734187, 3204031479, 3329325298
    ]

# SHA-256 of a byte list. Returns 32-byte list (raw hash bytes).
fn sha256_bytes(data: [i64]) -> [i64]:
    val mask32 = 4294967295  # 0xFFFFFFFF
    val k = _sha256_k()

    # Initial hash values (square roots of first 8 primes).
    var h0 = 1779033703
    var h1 = 3144134277
    var h2 = 1013904242
    var h3 = 2773480762
    var h4 = 1359893119
    var h5 = 2600822924
    var h6 =  528734635
    var h7 = 1541459225

    # Pre-processing: copy data then pad.
    val data_len = data.len()
    var padded: [i64] = []
    var pi = 0
    while pi < data_len:
        padded.push(data[pi])
        pi = pi + 1

    # Append 0x80 byte.
    padded.push(128)

    # Pad with zeros until length ≡ 56 mod 64.
    while padded.len() % 64 != 56:
        padded.push(0)

    # Append original bit-length as 8-byte big-endian.
    val bit_len = data_len * 8
    padded.push((bit_len >> 56) & 255)
    padded.push((bit_len >> 48) & 255)
    padded.push((bit_len >> 40) & 255)
    padded.push((bit_len >> 32) & 255)
    padded.push((bit_len >> 24) & 255)
    padded.push((bit_len >> 16) & 255)
    padded.push((bit_len >>  8) & 255)
    padded.push( bit_len        & 255)

    # Process each 64-byte block.
    val total_len = padded.len()
    var block_offset = 0
    while block_offset < total_len:
        # Build message schedule w[0..63].
        var w: [i64] = []
        var wi = 0
        while wi < 16:
            val base = block_offset + wi * 4
            val word = (
                ((padded[base    ] & 255) << 24) |
                ((padded[base + 1] & 255) << 16) |
                ((padded[base + 2] & 255) <<  8) |
                 (padded[base + 3] & 255)
            ) & mask32
            w.push(word)
            wi = wi + 1

        wi = 16
        while wi < 64:
            val w15 = w[wi - 15]
            val w2  = w[wi - 2]
            val s0 = (rotr32(w15, 7) ^ rotr32(w15, 18) ^ (w15 >> 3)) & mask32
            val s1 = (rotr32(w2, 17) ^ rotr32(w2,  19) ^ (w2  >> 10)) & mask32
            w.push((w[wi - 16] + s0 + w[wi - 7] + s1) & mask32)
            wi = wi + 1

        # Working variables.
        var a = h0
        var b = h1
        var c = h2
        var d = h3
        var e = h4
        var f = h5
        var g = h6
        var hh = h7

        var ri = 0
        while ri < 64:
            val big_s1 = (rotr32(e, 6) ^ rotr32(e, 11) ^ rotr32(e, 25)) & mask32
            val ch     = ((e & f) ^ ((e ^ mask32) & g)) & mask32
            val temp1  = (hh + big_s1 + ch + k[ri] + w[ri]) & mask32
            val big_s0 = (rotr32(a, 2) ^ rotr32(a, 13) ^ rotr32(a, 22)) & mask32
            val maj    = ((a & b) ^ (a & c) ^ (b & c)) & mask32
            val temp2  = (big_s0 + maj) & mask32

            hh = g
            g  = f
            f  = e
            e  = (d + temp1) & mask32
            d  = c
            c  = b
            b  = a
            a  = (temp1 + temp2) & mask32
            ri = ri + 1

        h0 = (h0 + a) & mask32
        h1 = (h1 + b) & mask32
        h2 = (h2 + c) & mask32
        h3 = (h3 + d) & mask32
        h4 = (h4 + e) & mask32
        h5 = (h5 + f) & mask32
        h6 = (h6 + g) & mask32
        h7 = (h7 + hh) & mask32
        block_offset = block_offset + 64

    # Produce 32-byte result.
    var result: [i64] = []
    val words = [h0, h1, h2, h3, h4, h5, h6, h7]
    var wi2 = 0
    while wi2 < 8:
        val w = words[wi2]
        result.push((w >> 24) & 255)
        result.push((w >> 16) & 255)
        result.push((w >>  8) & 255)
        result.push( w        & 255)
        wi2 = wi2 + 1
    result

# SHA-256 of text input. Returns 64-char lowercase hex string.
fn sha256_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(sha256_bytes(text_to_bytes(data)))

# Virtual byte j of the SHA-256 padded message for `data` (padding computed,
# never materialized): data bytes, then 0x80, zeros, and the 8-byte big-endian
# bit length occupying [total_len-8, total_len).
fn _sha256_padded_byte(data: [u8], data_len: i64, total_len: i64, j: i64) -> i64:
    if j < data_len:
        return data[j] as i64
    if j == data_len:
        return 128
    if j >= total_len - 8:
        # Big-endian 64-bit bit length; byte_from_lsb 0 is the last byte.
        val byte_from_lsb = total_len - 1 - j
        # bit length = data_len * 8 = data_len << 3; shift the needed byte
        # down first so the <<3 cannot overflow for any real input size.
        if byte_from_lsb == 0:
            return (data_len << 3) & 255
        return (data_len >> (byte_from_lsb * 8 - 3)) & 255
    0

# SHA-256 of native bytes without copying the payload into an i64 list.
#
# ALLOCATION-LIGHT REWRITE (SimpleOS baremetal bump heap, no GC): the previous
# version allocated a fresh 64-entry block list per 64-byte block, and
# sha256_process_block allocated a fresh dynamic `w` schedule list, a fresh
# 64-entry K constants list, and a fresh h list PER BLOCK -- for a 1.7MB font
# that is 26,694 blocks and burned the remaining ~50MB of the 192MiB
# bump heap in one hash (live: `[PANIC] heap exhausted heap_off=0xbffff80`).
# Now: ONE reused [i64] w[64] schedule (index-assigned in place), ONE K list,
# hash state in 8 scalar locals, words assembled by direct indexing into the
# input, and padding synthesized virtually for the final block(s) only.
# Total allocations per call: 2 small arrays + the 64-char hex build,
# independent of input size.
fn sha256_u8_hex(data: [u8]) -> text:
    val mask32 = 4294967295  # 0xFFFFFFFF
    val k = _sha256_k()
    var w: [i64] = []
    var zi = 0
    while zi < 64:
        w.push(0)
        zi = zi + 1

    var h0 = 1779033703
    var h1 = 3144134277
    var h2 = 1013904242
    var h3 = 2773480762
    var h4 = 1359893119
    var h5 = 2600822924
    var h6 =  528734635
    var h7 = 1541459225

    val data_len = data.len()
    # Padded length: data + 0x80 + zero pad + 8 length bytes, multiple of 64.
    val total_len = ((data_len + 8) / 64 + 1) * 64
    var block_offset = 0
    while block_offset < total_len:
        var wi = 0
        if block_offset + 64 <= data_len:
            # Fast path: whole block inside data. Named intermediates with
            # `+`/`*` combine (NOT a fused shift/or chain): the freestanding
            # cranelift aggressive build has dropped high-byte terms of fused
            # multi-byte combines before (see vfs_boot_init.spl helpers);
            # `as` casts, not bare .to_i64(), per the C7 erased-receiver
            # conversion defect.
            while wi < 16:
                val base = block_offset + wi * 4
                val b0 = data[base] as i64
                val b1 = data[base + 1] as i64
                val b2 = data[base + 2] as i64
                val b3 = data[base + 3] as i64
                w[wi] = (b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3
                wi = wi + 1
        else:
            # Tail block(s): read through the virtual padded message.
            while wi < 16:
                val base = block_offset + wi * 4
                val b0 = _sha256_padded_byte(data, data_len, total_len, base)
                val b1 = _sha256_padded_byte(data, data_len, total_len, base + 1)
                val b2 = _sha256_padded_byte(data, data_len, total_len, base + 2)
                val b3 = _sha256_padded_byte(data, data_len, total_len, base + 3)
                w[wi] = (b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3
                wi = wi + 1

        wi = 16
        while wi < 64:
            val w15 = w[wi - 15]
            val w2  = w[wi - 2]
            val s0 = (rotr32(w15, 7) ^ rotr32(w15, 18) ^ (w15 >> 3)) & mask32
            val s1 = (rotr32(w2, 17) ^ rotr32(w2,  19) ^ (w2  >> 10)) & mask32
            w[wi] = (w[wi - 16] + s0 + w[wi - 7] + s1) & mask32
            wi = wi + 1

        var a = h0
        var b = h1
        var c = h2
        var d = h3
        var e = h4
        var f = h5
        var g = h6
        var hh = h7

        var ri = 0
        while ri < 64:
            val big_s1 = (rotr32(e, 6) ^ rotr32(e, 11) ^ rotr32(e, 25)) & mask32
            val ch     = ((e & f) ^ ((e ^ mask32) & g)) & mask32
            val temp1  = (hh + big_s1 + ch + k[ri] + w[ri]) & mask32
            val big_s0 = (rotr32(a, 2) ^ rotr32(a, 13) ^ rotr32(a, 22)) & mask32
            val maj    = ((a & b) ^ (a & c) ^ (b & c)) & mask32
            val temp2  = (big_s0 + maj) & mask32

            hh = g
            g  = f
            f  = e
            e  = (d + temp1) & mask32
            d  = c
            c  = b
            b  = a
            a  = (temp1 + temp2) & mask32
            ri = ri + 1

        h0 = (h0 + a) & mask32
        h1 = (h1 + b) & mask32
        h2 = (h2 + c) & mask32
        h3 = (h3 + d) & mask32
        h4 = (h4 + e) & mask32
        h5 = (h5 + f) & mask32
        h6 = (h6 + g) & mask32
        h7 = (h7 + hh) & mask32
        block_offset = block_offset + 64

    val digits = "0123456789abcdef"
    var result = ""
    val words = [h0, h1, h2, h3, h4, h5, h6, h7]
    var out_i = 0
    while out_i < 8:
        val word = words[out_i]
        var shift = 28
        while shift >= 0:
            val nibble = (word >> shift) & 15
            result = result + digits[nibble:nibble + 1]
            shift = shift - 4
        out_i = out_i + 1
    result

# ============================================================================
# MIR optimizer pattern-recognition hooks
# Symbol names must match the strings in rules_crypto.spl exactly.
# ============================================================================

# Sigma_0 message schedule expansion (w[i-15]).
fn msg_schedule1(w: i64) -> i64:
    val mask32 = 4294967295
    (rotr32(w, 7) ^ rotr32(w, 18) ^ (w >> 3)) & mask32

# Sigma_1 message schedule expansion (w[i-2]).
fn msg_schedule2(w: i64) -> i64:
    val mask32 = 4294967295
    (rotr32(w, 17) ^ rotr32(w, 19) ^ (w >> 10)) & mask32

# SHA-256 scalar reference path — routes through sha256_core block processor.
# Parity target for sha256_simd_parity_spec: sha256_bytes uses inline code,
# sha256_bytes_scalar uses sha256_core (different constants + add_mod32 path).
fn sha256_bytes_scalar(data: [i64]) -> [i64]:
    val padded = sha256_pad_message(data)
    var h = sha256_initial_hash()
    var offset = 0
    val total = padded.len()
    while offset < total:
        var block: [i64] = []
        var bi = 0
        while bi < 64:
            block.push(padded.get(offset + bi))
            bi = bi + 1
        h = sha256_process_block(h, block)
        offset = offset + 64
    var result: [i64] = []
    var wi = 0
    while wi < 8:
        val w = h.get(wi)
        result.push((w >> 24) & 255)
        result.push((w >> 16) & 255)
        result.push((w >>  8) & 255)
        result.push( w        & 255)
        wi = wi + 1
    result

# One SHA-256 compression round. Returns (new_a, new_e).
fn compress_block(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, hh: i64, k: i64, w: i64) -> (i64, i64):
    val mask32 = 4294967295
    val big_s1 = (rotr32(e, 6) ^ rotr32(e, 11) ^ rotr32(e, 25)) & mask32
    val ch     = ((e & f) ^ ((e ^ mask32) & g)) & mask32
    val temp1  = (hh + big_s1 + ch + k + w) & mask32
    val big_s0 = (rotr32(a, 2) ^ rotr32(a, 13) ^ rotr32(a, 22)) & mask32
    val maj    = ((a & b) ^ (a & c) ^ (b & c)) & mask32
    val temp2  = (big_s0 + maj) & mask32
    ((temp1 + temp2) & mask32, (d + temp1) & mask32)
