# SHA-256 Hash Implementation
#
# Secure Hash Algorithm 256-bit
# Pure Simple implementation following FIPS 180-4 specification
#
# Recommended for most cryptographic applications
#
# Vectorization (2026-05-01): Message-schedule small-sigma0 is computed 4-at-a-time
# via std.simd Phase-1 int intrinsics (xor + logical shifts). Round function and the
# `+= add_mod32` chain stay scalar — round dependency makes vector parallelism
# unprofitable, and SIMD `add_i32x4` is not yet wired in interpreter mode. See
# `doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md`.

mod crypto.types

use std.simd.{Vec4i, simd_xor_i32x4, simd_shl_i32x4, simd_shr_i32x4, simd_or_i32x4}

# =============================================================================
# SHA-256 Constants and Initial Values
# =============================================================================

# SHA-256 constants (first 32 bits of fractional parts of cube roots of first 64 primes)
fn sha256_k_constants() -> list:
    [
        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
        0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
        0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
        0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
        0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
        0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
        0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
        0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    ]

# SHA-256 initial hash values (first 32 bits of fractional parts of square roots of first 8 primes)
fn sha256_initial_hash() -> list:
    [
        0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
        0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19
    ]

# =============================================================================
# SHA-256 Functions
# =============================================================================

# SHA-256 choice function
# reason: positional crypto sha256 API
fn sha256_ch(x: i64, y: i64, z: i64) -> i64:
    (x & y) ^ ((~x) & z)

# SHA-256 majority function
# reason: positional crypto sha256 API
fn sha256_maj(x: i64, y: i64, z: i64) -> i64:
    (x & y) ^ (x & z) ^ (y & z)

# SHA-256 Sigma0 function
fn sha256_sigma0(x: i64) -> i64:
    val r2 = rotr32(x, 2)
    val r13 = rotr32(x, 13)
    val r22 = rotr32(x, 22)
    r2 ^ r13 ^ r22

# SHA-256 Sigma1 function
fn sha256_sigma1(x: i64) -> i64:
    val r6 = rotr32(x, 6)
    val r11 = rotr32(x, 11)
    val r25 = rotr32(x, 25)
    r6 ^ r11 ^ r25

# SHA-256 sigma0 function (lowercase)
fn sha256_little_sigma0(x: i64) -> i64:
    val r7 = rotr32(x, 7)
    val r18 = rotr32(x, 18)
    val s3 = shr32(x, 3)
    r7 ^ r18 ^ s3

# SHA-256 sigma1 function (lowercase)
fn sha256_little_sigma1(x: i64) -> i64:
    val r17 = rotr32(x, 17)
    val r19 = rotr32(x, 19)
    val s10 = shr32(x, 10)
    r17 ^ r19 ^ s10

# =============================================================================
# SHA-256 Vectorized small-sigma0 (Phase 1 SIMD: xor + logical shifts only)
# =============================================================================

# Compute sha256_little_sigma0 on 4 words in parallel.
#   σ0(x) = ROTR(x,7) ^ ROTR(x,18) ^ SHR(x,3)
# Implemented via simd_xor / simd_shl / simd_shr only — no SIMD add needed.
# The shift count is masked to 0..31 by the runtime; bit-width is 32 per lane.
fn sha256_little_sigma0_x4(v: Vec4i) -> Vec4i:
    # ROTR(x,7) = (x >> 7) | (x << 25)
    val r7_lo = simd_shr_i32x4(v, 7)
    val r7_hi = simd_shl_i32x4(v, 25)
    val r7 = simd_or_i32x4(r7_lo, r7_hi)

    # ROTR(x,18) = (x >> 18) | (x << 14)
    val r18_lo = simd_shr_i32x4(v, 18)
    val r18_hi = simd_shl_i32x4(v, 14)
    val r18 = simd_or_i32x4(r18_lo, r18_hi)

    # SHR(x,3) (logical)
    val s3 = simd_shr_i32x4(v, 3)

    val xor1 = simd_xor_i32x4(r7, r18)
    simd_xor_i32x4(xor1, s3)

# Pack four scalar i64 SHA-256 words (already masked to 32 bits) into a Vec4i.
# i64 values whose 32-bit pattern has the top bit set become negative i32 — that
# is fine because all subsequent SIMD ops are bit-pattern preserving.
fn _pack_v4i_words(w0: i64, w1: i64, w2: i64, w3: i64) -> Vec4i:
    Vec4i(x: w0.to_i32(), y: w1.to_i32(), z: w2.to_i32(), w: w3.to_i32())

# Unpack a Vec4i lane as a non-negative i64 word in [0, 2^32).
fn _v4i_lane_u32(lane: i32) -> i64:
    lane.to_i64() & 0xFFFFFFFF

# =============================================================================
# SHA-256 Core Operations
# =============================================================================

# Create SHA-256 context for incremental hashing
# Returns tuple: (h: list[8], data: list, datalen: i64, bitlen: i64)
fn create_sha256_context() -> tuple:
    val h = sha256_initial_hash()
    val data = []
    (h, data, 0, 0)

# Pad message for SHA-256 (512-bit blocks)
fn sha256_pad_message(bytes: list) -> list:
    var padded = []
    var i = 0

    # Copy original bytes
    while i < bytes.len():
        padded.push(bytes.get(i))
        i = i + 1

    val original_len = bytes.len()
    val original_bit_len = original_len * 8

    # Append 1 bit (0x80)
    padded.push(0x80)

    # Append 0 bits until length ≡ 448 (mod 512)
    val target_len = ((original_len + 8) / 64 + 1) * 64
    while padded.len() < target_len - 8:
        padded.push(0)

    # Append length as 64-bit big-endian
    # For simplicity, assume length fits in 32 bits
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push((original_bit_len >> 24) & 0xFF)
    padded.push((original_bit_len >> 16) & 0xFF)
    padded.push((original_bit_len >> 8) & 0xFF)
    padded.push(original_bit_len & 0xFF)

    padded

# Process one 512-bit block for SHA-256
# reason: positional crypto sha256 API
fn sha256_process_block(h: list, block: list) -> list:
    # Prepare message schedule (64 entries)
    var w = []
    var i = 0

    # First 16 words from block (big-endian)
    while i < 16:
        val idx = i * 4
        val b0 = block.get(idx)
        val b1 = block.get(idx + 1)
        val b2 = block.get(idx + 2)
        val b3 = block.get(idx + 3)
        val word = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        w.push(word)
        i = i + 1

    # Extend to 64 words
    while i < 64:
        val w15 = w.get(i - 15)
        val w2 = w.get(i - 2)
        val w16 = w.get(i - 16)
        val w7 = w.get(i - 7)

        val s0 = sha256_little_sigma0(w15)
        val s1 = sha256_little_sigma1(w2)

        val word = add_mod32(add_mod32(add_mod32(s1, w7), s0), w16)
        w.push(word)
        i = i + 1

    # Initialize working variables
    var a = h.get(0)
    var b = h.get(1)
    var c = h.get(2)
    var d = h.get(3)
    var e = h.get(4)
    var f = h.get(5)
    var g = h.get(6)
    var h_var = h.get(7)

    val k = sha256_k_constants()

    # 64 rounds
    i = 0
    while i < 64:
        val S1 = sha256_sigma1(e)
        val ch = sha256_ch(e, f, g)
        val temp1_part1 = add_mod32(h_var, S1)
        val temp1_part2 = add_mod32(ch, k.get(i))
        val temp1_part3 = add_mod32(temp1_part2, w.get(i))
        val temp1 = add_mod32(temp1_part1, temp1_part3)

        val S0 = sha256_sigma0(a)
        val maj = sha256_maj(a, b, c)
        val temp2 = add_mod32(S0, maj)

        h_var = g
        g = f
        f = e
        e = add_mod32(d, temp1)
        d = c
        c = b
        b = a
        a = add_mod32(temp1, temp2)

        i = i + 1

    # Add compressed chunk to current hash value
    var new_h = []
    new_h.push(add_mod32(h.get(0), a))
    new_h.push(add_mod32(h.get(1), b))
    new_h.push(add_mod32(h.get(2), c))
    new_h.push(add_mod32(h.get(3), d))
    new_h.push(add_mod32(h.get(4), e))
    new_h.push(add_mod32(h.get(5), f))
    new_h.push(add_mod32(h.get(6), g))
    new_h.push(add_mod32(h.get(7), h_var))

    new_h

# =============================================================================
# SHA-256 Vectorized message-schedule block processor (2026-05-01)
# =============================================================================
# Identical to sha256_process_block byte-for-byte, but the message-schedule
# expansion W[16..63] computes σ0 four-at-a-time via Vec4i. σ1 stays scalar
# because W[i]=σ1(W[i-2])+... has a tight dependency chain on previously
# computed W[i-1]/W[i] inside any 4-wide chunk. The round function and final
# add-back to h[0..7] also stay scalar (no SIMD add wired in Phase 1).
fn sha256_process_block_simd(h: list, block: list) -> list:
    # Prepare message schedule (64 entries)
    var w = []
    var i = 0

    # First 16 words from block (big-endian)
    while i < 16:
        val idx = i * 4
        val b0 = block.get(idx)
        val b1 = block.get(idx + 1)
        val b2 = block.get(idx + 2)
        val b3 = block.get(idx + 3)
        val word = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        w.push(word)
        i = i + 1

    # Vectorized σ0 expansion. We compute σ0 on a Vec4i of {W[i-15..i-12]} per
    # 4-word chunk so that 4 σ0 values are produced in one extern dispatch.
    # σ1 remains scalar (W[i-2] dependency inside the chunk).
    #
    # i ranges over 16..64 in steps of 4. For each chunk:
    #   sigma0_pack = σ0_x4(W[i-15], W[i-14], W[i-13], W[i-12])
    #   For each lane k in 0..3 (sequentially, because σ1 depends on W[i+k-2]):
    #       W[i+k] = σ1(W[i+k-2]) + W[i+k-7] + sigma0_pack.lane(k) + W[i+k-16]
    while i < 64:
        # i is the first lane of this 4-wide chunk. i in {16, 20, ..., 60}.
        val v_in = _pack_v4i_words(
            w.get(i - 15),
            w.get(i - 14),
            w.get(i - 13),
            w.get(i - 12)
        )
        val s0_v = sha256_little_sigma0_x4(v_in)
        val s0_0 = _v4i_lane_u32(s0_v.x)
        val s0_1 = _v4i_lane_u32(s0_v.y)
        val s0_2 = _v4i_lane_u32(s0_v.z)
        val s0_3 = _v4i_lane_u32(s0_v.w)

        # Lane 0
        val w0 = add_mod32(
            add_mod32(add_mod32(sha256_little_sigma1(w.get(i - 2)), w.get(i - 7)), s0_0),
            w.get(i - 16)
        )
        w.push(w0)

        # Lane 1 (uses freshly produced W[i] = w0 if i+1-2 == i-1; otherwise
        # references a prior W. Indexing is unchanged.)
        val w1 = add_mod32(
            add_mod32(add_mod32(sha256_little_sigma1(w.get(i + 1 - 2)), w.get(i + 1 - 7)), s0_1),
            w.get(i + 1 - 16)
        )
        w.push(w1)

        # Lane 2
        val w2 = add_mod32(
            add_mod32(add_mod32(sha256_little_sigma1(w.get(i + 2 - 2)), w.get(i + 2 - 7)), s0_2),
            w.get(i + 2 - 16)
        )
        w.push(w2)

        # Lane 3
        val w3 = add_mod32(
            add_mod32(add_mod32(sha256_little_sigma1(w.get(i + 3 - 2)), w.get(i + 3 - 7)), s0_3),
            w.get(i + 3 - 16)
        )
        w.push(w3)

        i = i + 4

    # Initialize working variables
    var a = h.get(0)
    var b = h.get(1)
    var c = h.get(2)
    var d = h.get(3)
    var e = h.get(4)
    var f = h.get(5)
    var g = h.get(6)
    var h_var = h.get(7)

    val k = sha256_k_constants()

    # 64 rounds (scalar — round function dependency chain prevents SIMD wins)
    i = 0
    while i < 64:
        val S1 = sha256_sigma1(e)
        val ch = sha256_ch(e, f, g)
        val temp1_part1 = add_mod32(h_var, S1)
        val temp1_part2 = add_mod32(ch, k.get(i))
        val temp1_part3 = add_mod32(temp1_part2, w.get(i))
        val temp1 = add_mod32(temp1_part1, temp1_part3)

        val S0 = sha256_sigma0(a)
        val maj = sha256_maj(a, b, c)
        val temp2 = add_mod32(S0, maj)

        h_var = g
        g = f
        f = e
        e = add_mod32(d, temp1)
        d = c
        c = b
        b = a
        a = add_mod32(temp1, temp2)

        i = i + 1

    var new_h = []
    new_h.push(add_mod32(h.get(0), a))
    new_h.push(add_mod32(h.get(1), b))
    new_h.push(add_mod32(h.get(2), c))
    new_h.push(add_mod32(h.get(3), d))
    new_h.push(add_mod32(h.get(4), e))
    new_h.push(add_mod32(h.get(5), f))
    new_h.push(add_mod32(h.get(6), g))
    new_h.push(add_mod32(h.get(7), h_var))

    new_h

# Update SHA-256 context with new data
fn sha256_update(ctx: tuple, data: list) -> tuple:
    val h = ctx.get(0)
    val existing_data = ctx.get(1)
    val datalen = ctx.get(2)
    val bitlen = ctx.get(3)

    # Append new data
    var updated_data = []
    var i = 0
    while i < existing_data.len():
        updated_data.push(existing_data.get(i))
        i = i + 1

    i = 0
    while i < data.len():
        updated_data.push(data.get(i))
        i = i + 1

    val new_datalen = datalen + data.len()
    val new_bitlen = bitlen + (data.len() * 8)

    (h, updated_data, new_datalen, new_bitlen)

# Finalize SHA-256 hash (SIMD message-schedule path — public default).
fn sha256_finalize(ctx: tuple) -> list:
    val h = ctx.get(0)
    val data = ctx.get(1)

    # Pad the data
    val padded = sha256_pad_message(data)

    # Process all blocks via SIMD message-schedule path.
    var current_h = h
    var i = 0
    while i < padded.len():
        var block = []
        var j = 0
        while j < 64:
            block.push(padded.get(i + j))
            j = j + 1

        current_h = sha256_process_block_simd(current_h, block)
        i = i + 64

    # Convert hash values to bytes (big-endian)
    var result = []
    i = 0
    while i < 8:
        val h_val = current_h.get(i)
        result.push((h_val >> 24) & 0xFF)
        result.push((h_val >> 16) & 0xFF)
        result.push((h_val >> 8) & 0xFF)
        result.push(h_val & 0xFF)
        i = i + 1

    result

# Scalar finalize — kept callable for parity testing / fallback.
fn sha256_finalize_scalar(ctx: tuple) -> list:
    val h = ctx.get(0)
    val data = ctx.get(1)

    val padded = sha256_pad_message(data)

    var current_h = h
    var i = 0
    while i < padded.len():
        var block = []
        var j = 0
        while j < 64:
            block.push(padded.get(i + j))
            j = j + 1

        current_h = sha256_process_block(current_h, block)
        i = i + 64

    var result = []
    i = 0
    while i < 8:
        val h_val = current_h.get(i)
        result.push((h_val >> 24) & 0xFF)
        result.push((h_val >> 16) & 0xFF)
        result.push((h_val >> 8) & 0xFF)
        result.push(h_val & 0xFF)
        i = i + 1

    result

# Reset SHA-256 context
fn sha256_reset(ctx: tuple) -> tuple:
    create_sha256_context()

# =============================================================================
# Public API
# =============================================================================

# SHA-256 hash of byte list (returns byte list) — SIMD message-schedule path.
fn sha256_bytes(bytes: list) -> list:
    val ctx = create_sha256_context()
    val updated_ctx = sha256_update(ctx, bytes)
    sha256_finalize(updated_ctx)

# SHA-256 hash of byte list — pure scalar path (parity reference / fallback).
fn sha256_bytes_scalar(bytes: list) -> list:
    val ctx = create_sha256_context()
    val updated_ctx = sha256_update(ctx, bytes)
    sha256_finalize_scalar(updated_ctx)

# SHA-256 hash of text (returns byte list)
fn sha256(text: text) -> list:
    val bytes = text_to_bytes(text)
    sha256_bytes(bytes)

# SHA-256 hash of text (returns hex string)
fn sha256_hex(text: text) -> text:
    val hash = sha256(text)
    bytes_to_hex(hash)

# SHA-256 hash with uppercase hex output
fn sha256_hex_upper(text: text) -> text:
    val hash = sha256(text)
    hash_to_upper_hex(hash)

# Double hash (hash of hash - used in some applications)
fn double_sha256(text: text) -> list:
    val first_hash = sha256(text)
    sha256_bytes(first_hash)

# Double hash hex
fn double_sha256_hex(text: text) -> text:
    val hash = double_sha256(text)
    bytes_to_hex(hash)

# Hash streaming data (incremental)
fn hash_stream_sha256(chunks: list) -> text:
    var ctx = create_sha256_context()
    var i = 0

    while i < chunks.len():
        val chunk = chunks.get(i)
        val chunk_bytes = text_to_bytes(chunk)
        ctx = sha256_update(ctx, chunk_bytes)
        i = i + 1

    val hash = sha256_finalize(ctx)
    bytes_to_hex(hash)
