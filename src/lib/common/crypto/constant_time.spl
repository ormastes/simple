#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Constant-time comparison for cryptographic values.
#
# Prevents timing side-channel attacks when comparing HMACs, tokens, or hashes.

extern fn rt_constant_time_compare(a: text, b: text) -> i64

fn constant_time_compare(a: text, b: text) -> bool:
    return rt_constant_time_compare(a, b) == 1
