#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Constant-time comparison for cryptographic values.
#
# Prevents timing side-channel attacks when comparing HMACs, tokens, or hashes.

extern fn rt_constant_time_compare(a: text, b: text) -> i64
extern fn rt_black_box(x: i64) -> i64

fn constant_time_compare(a: text, b: text) -> bool:
    return rt_constant_time_compare(a, b) == 1

# Identity function the optimizer must not see through (B6,
# compiler_bugs_for_crypto_2026-04-25.md). Wrap the accumulator at the end
# of an XOR-accumulate compare to prevent Cranelift / future optimizers
# from rewriting the loop into an early-exit branch on `diff != 0`.
# Required before §3 (ML-KEM rejection sampling) and §5.4 (PQ TLS conditional
# swap) per the crypto-rollout plan.
fn black_box(x: i64) -> i64:
    return rt_black_box(x)
