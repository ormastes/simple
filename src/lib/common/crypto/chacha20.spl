# ChaCha20 Stream Cipher — Pure Simple stdlib implementation (RFC 7539)
#
# ChaCha20 is an ARX (add-rotate-xor) stream cipher designed by D. J. Bernstein.
# This module implements the IETF variant (RFC 7539) with a 96-bit nonce and
# 32-bit counter.
#
# SIMD strategy (Phase 1 Vec4i int intrinsics, 2026-05-01):
#   VERTICAL 4-block parallel layout.
#   Each Vec4i lane holds the same word position from four independent blocks
#   (counter, counter+1, counter+2, counter+3). The column and diagonal rounds
#   map to identical operations on every lane — no inter-lane shuffles needed.
#
#   Op map:
#     XOR / shl / shr / or -> simd_xor_i32x4 / simd_shl_i32x4 /
#                             simd_shr_i32x4 / simd_or_i32x4
#     mod-2^32 add         -> Vec4i struct field arithmetic (i32 wraps mod 2^32
#                             in Simple — rt_simd_add_i32x4 is declared but
#                             UNWIRED in Phase 1; struct add is bit-exact)
#
# Reference: RFC 7539 §2.1–§2.5
#   https://datatracker.ietf.org/doc/html/rfc7539
#
# Public API:
#   chacha20_block(key, counter, nonce)  -> [u32]   (single 64-byte block)
#   chacha20_keystream(key, counter, nonce, len) -> [u8]
#   chacha20_encrypt(key, counter, nonce, plaintext) -> [u8]

mod crypto.chacha20

use std.simd.{Vec4i, simd_xor_i32x4, simd_shl_i32x4, simd_shr_i32x4, simd_or_i32x4}

# ============================================================================
# SIMD helpers
# ============================================================================

fn _vadd(a: Vec4i, b: Vec4i) -> Vec4i:
    """4-lane wrapping i32 add. Relies on Simple's i32 overflow wrapping mod 2^32."""
    Vec4i(x: a.x + b.x, y: a.y + b.y, z: a.z + b.z, w: a.w + b.w)

fn _vrotl16(v: Vec4i) -> Vec4i:
    """Rotate-left 16 on all 4 i32 lanes."""
    simd_or_i32x4(simd_shl_i32x4(v, 16), simd_shr_i32x4(v, 16))

fn _vrotl12(v: Vec4i) -> Vec4i:
    """Rotate-left 12 on all 4 i32 lanes."""
    simd_or_i32x4(simd_shl_i32x4(v, 12), simd_shr_i32x4(v, 20))

fn _vrotl8(v: Vec4i) -> Vec4i:
    """Rotate-left 8 on all 4 i32 lanes."""
    simd_or_i32x4(simd_shl_i32x4(v, 8), simd_shr_i32x4(v, 24))

fn _vrotl7(v: Vec4i) -> Vec4i:
    """Rotate-left 7 on all 4 i32 lanes."""
    simd_or_i32x4(simd_shl_i32x4(v, 7), simd_shr_i32x4(v, 25))

# ============================================================================
# Scalar helpers
# ============================================================================

fn _u32_mask(x: u32) -> u32:
    """Mask to 32 bits (identity for u32; explicit for clarity)."""
    x & 0xFFFFFFFFu32

fn _u32_to_i32(x: u32) -> i32:
    """Reinterpret u32 bit pattern as i32 (via i64 round-trip)."""
    val signed = x.to_i64()
    if signed >= 2147483648:
        (signed - 4294967296).to_i32()
    else:
        signed.to_i32()

fn _i32_to_u32(x: i32) -> u32:
    """Reinterpret i32 bit pattern as u32."""
    x.to_u32()

fn _rotl32(x: u32, n: u32) -> u32:
    """32-bit left rotation (scalar)."""
    _u32_mask((x << n) | (x >> (32u32 - n)))

# ============================================================================
# Scalar quarter-round (RFC 7539 §2.1) — used by single-block path
# ============================================================================

fn _quarter_round(state: [u32], a: u64, b: u64, c: u64, d: u64):
    """ChaCha20 quarter-round mutating state in place.

    RFC 7539 §2.1.1:
        a += b; d ^= a; d <<<= 16
        c += d; b ^= c; b <<<= 12
        a += b; d ^= a; d <<<= 8
        c += d; b ^= c; b <<<= 7
    """
    state[a] = _u32_mask(state[a] + state[b])
    state[d] = _rotl32(state[d] ^ state[a], 16u32)

    state[c] = _u32_mask(state[c] + state[d])
    state[b] = _rotl32(state[b] ^ state[c], 12u32)

    state[a] = _u32_mask(state[a] + state[b])
    state[d] = _rotl32(state[d] ^ state[a], 8u32)

    state[c] = _u32_mask(state[c] + state[d])
    state[b] = _rotl32(state[b] ^ state[c], 7u32)

# ============================================================================
# Single-block function (RFC 7539 §2.3) — scalar, bit-exact reference
# ============================================================================

fn chacha20_block(key: [u32], counter: u32, nonce: [u32]) -> [u32]:
    """Generate one 64-byte ChaCha20 keystream block (RFC 7539 §2.3).

    State layout (16 × u32):
      [0..3]   = "expand 32-byte k" constants
      [4..11]  = 256-bit key (8 words, little-endian)
      [12]     = 32-bit counter
      [13..15] = 96-bit nonce (3 words, little-endian)

    Args:
        key:     8 u32 words (32-byte key, pre-parsed little-endian).
        counter: Block counter (starts at 1 for encryption per RFC 7539 §2.4).
        nonce:   3 u32 words (12-byte nonce, pre-parsed little-endian).

    Returns: 16 u32 words = 64 bytes of keystream.

    Example:
        val ks = chacha20_block(key_words, 1u32, nonce_words)
    """
    var state: [u32] = []
    state.push(0x61707865u32)
    state.push(0x3320646eu32)
    state.push(0x79622d32u32)
    state.push(0x6b206574u32)

    var i: u64 = 0
    while i < 8:
        state.push(key[i])
        i = i + 1

    state.push(counter)

    i = 0
    while i < 3:
        state.push(nonce[i])
        i = i + 1

    var working: [u32] = []
    i = 0
    while i < 16:
        working.push(state[i])
        i = i + 1

    # 20 rounds = 10 double-rounds (column + diagonal)
    var round: u64 = 0
    while round < 10:
        # Column rounds
        _quarter_round(working, 0, 4, 8, 12)
        _quarter_round(working, 1, 5, 9, 13)
        _quarter_round(working, 2, 6, 10, 14)
        _quarter_round(working, 3, 7, 11, 15)
        # Diagonal rounds
        _quarter_round(working, 0, 5, 10, 15)
        _quarter_round(working, 1, 6, 11, 12)
        _quarter_round(working, 2, 7, 8, 13)
        _quarter_round(working, 3, 4, 9, 14)
        round = round + 1

    var result: [u32] = []
    i = 0
    while i < 16:
        result.push(_u32_mask(working[i] + state[i]))
        i = i + 1

    result

# ============================================================================
# 4-block SIMD function (RFC 7539 §2.3 — vertical 4-block parallel)
# ============================================================================

fn _chacha20_block4_simd(key: [u32], counter: u32, nonce: [u32]) -> [u8]:
    """Generate four 64-byte keystream blocks in parallel via Vec4i SIMD.

    Each Vec4i lane holds one block: lane 0 = counter, lane 1 = counter+1, etc.
    Returns 256 bytes (4 × 64).
    """
    val s0  = Vec4i.splat(_u32_to_i32(0x61707865u32))
    val s1  = Vec4i.splat(_u32_to_i32(0x3320646eu32))
    val s2  = Vec4i.splat(_u32_to_i32(0x79622d32u32))
    val s3  = Vec4i.splat(_u32_to_i32(0x6b206574u32))
    val s4  = Vec4i.splat(_u32_to_i32(key[0]))
    val s5  = Vec4i.splat(_u32_to_i32(key[1]))
    val s6  = Vec4i.splat(_u32_to_i32(key[2]))
    val s7  = Vec4i.splat(_u32_to_i32(key[3]))
    val s8  = Vec4i.splat(_u32_to_i32(key[4]))
    val s9  = Vec4i.splat(_u32_to_i32(key[5]))
    val s10 = Vec4i.splat(_u32_to_i32(key[6]))
    val s11 = Vec4i.splat(_u32_to_i32(key[7]))
    val s12 = Vec4i(
        x: _u32_to_i32(_u32_mask(counter + 0u32)),
        y: _u32_to_i32(_u32_mask(counter + 1u32)),
        z: _u32_to_i32(_u32_mask(counter + 2u32)),
        w: _u32_to_i32(_u32_mask(counter + 3u32)))
    val s13 = Vec4i.splat(_u32_to_i32(nonce[0]))
    val s14 = Vec4i.splat(_u32_to_i32(nonce[1]))
    val s15 = Vec4i.splat(_u32_to_i32(nonce[2]))

    var w0  = s0
    var w1  = s1
    var w2  = s2
    var w3  = s3
    var w4  = s4
    var w5  = s5
    var w6  = s6
    var w7  = s7
    var w8  = s8
    var w9  = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0
    while round < 10:
        # Column round: QR(0,4,8,12)
        w0  = _vadd(w0, w4)
        w12 = _vrotl16(simd_xor_i32x4(w12, w0))
        w8  = _vadd(w8, w12)
        w4  = _vrotl12(simd_xor_i32x4(w4, w8))
        w0  = _vadd(w0, w4)
        w12 = _vrotl8(simd_xor_i32x4(w12, w0))
        w8  = _vadd(w8, w12)
        w4  = _vrotl7(simd_xor_i32x4(w4, w8))
        # Column round: QR(1,5,9,13)
        w1  = _vadd(w1, w5)
        w13 = _vrotl16(simd_xor_i32x4(w13, w1))
        w9  = _vadd(w9, w13)
        w5  = _vrotl12(simd_xor_i32x4(w5, w9))
        w1  = _vadd(w1, w5)
        w13 = _vrotl8(simd_xor_i32x4(w13, w1))
        w9  = _vadd(w9, w13)
        w5  = _vrotl7(simd_xor_i32x4(w5, w9))
        # Column round: QR(2,6,10,14)
        w2  = _vadd(w2, w6)
        w14 = _vrotl16(simd_xor_i32x4(w14, w2))
        w10 = _vadd(w10, w14)
        w6  = _vrotl12(simd_xor_i32x4(w6, w10))
        w2  = _vadd(w2, w6)
        w14 = _vrotl8(simd_xor_i32x4(w14, w2))
        w10 = _vadd(w10, w14)
        w6  = _vrotl7(simd_xor_i32x4(w6, w10))
        # Column round: QR(3,7,11,15)
        w3  = _vadd(w3, w7)
        w15 = _vrotl16(simd_xor_i32x4(w15, w3))
        w11 = _vadd(w11, w15)
        w7  = _vrotl12(simd_xor_i32x4(w7, w11))
        w3  = _vadd(w3, w7)
        w15 = _vrotl8(simd_xor_i32x4(w15, w3))
        w11 = _vadd(w11, w15)
        w7  = _vrotl7(simd_xor_i32x4(w7, w11))
        # Diagonal round: QR(0,5,10,15)
        w0  = _vadd(w0, w5)
        w15 = _vrotl16(simd_xor_i32x4(w15, w0))
        w10 = _vadd(w10, w15)
        w5  = _vrotl12(simd_xor_i32x4(w5, w10))
        w0  = _vadd(w0, w5)
        w15 = _vrotl8(simd_xor_i32x4(w15, w0))
        w10 = _vadd(w10, w15)
        w5  = _vrotl7(simd_xor_i32x4(w5, w10))
        # Diagonal round: QR(1,6,11,12)
        w1  = _vadd(w1, w6)
        w12 = _vrotl16(simd_xor_i32x4(w12, w1))
        w11 = _vadd(w11, w12)
        w6  = _vrotl12(simd_xor_i32x4(w6, w11))
        w1  = _vadd(w1, w6)
        w12 = _vrotl8(simd_xor_i32x4(w12, w1))
        w11 = _vadd(w11, w12)
        w6  = _vrotl7(simd_xor_i32x4(w6, w11))
        # Diagonal round: QR(2,7,8,13)
        w2  = _vadd(w2, w7)
        w13 = _vrotl16(simd_xor_i32x4(w13, w2))
        w8  = _vadd(w8, w13)
        w7  = _vrotl12(simd_xor_i32x4(w7, w8))
        w2  = _vadd(w2, w7)
        w13 = _vrotl8(simd_xor_i32x4(w13, w2))
        w8  = _vadd(w8, w13)
        w7  = _vrotl7(simd_xor_i32x4(w7, w8))
        # Diagonal round: QR(3,4,9,14)
        w3  = _vadd(w3, w4)
        w14 = _vrotl16(simd_xor_i32x4(w14, w3))
        w9  = _vadd(w9, w14)
        w4  = _vrotl12(simd_xor_i32x4(w4, w9))
        w3  = _vadd(w3, w4)
        w14 = _vrotl8(simd_xor_i32x4(w14, w3))
        w9  = _vadd(w9, w14)
        w4  = _vrotl7(simd_xor_i32x4(w4, w9))
        round = round + 1

    # Add initial state
    val o0  = _vadd(w0,  s0)
    val o1  = _vadd(w1,  s1)
    val o2  = _vadd(w2,  s2)
    val o3  = _vadd(w3,  s3)
    val o4  = _vadd(w4,  s4)
    val o5  = _vadd(w5,  s5)
    val o6  = _vadd(w6,  s6)
    val o7  = _vadd(w7,  s7)
    val o8  = _vadd(w8,  s8)
    val o9  = _vadd(w9,  s9)
    val o10 = _vadd(w10, s10)
    val o11 = _vadd(w11, s11)
    val o12 = _vadd(w12, s12)
    val o13 = _vadd(w13, s13)
    val o14 = _vadd(w14, s14)
    val o15 = _vadd(w15, s15)

    # Serialize: [block0(64B) | block1(64B) | block2(64B) | block3(64B)]
    var out: [u8] = []
    var lane: u64 = 0
    while lane < 4:
        var k: u64 = 0
        while k < 16:
            var word_i32: i32 = 0
            if k == 0:
                if lane == 0: word_i32 = o0.x
                if lane == 1: word_i32 = o0.y
                if lane == 2: word_i32 = o0.z
                if lane == 3: word_i32 = o0.w
            if k == 1:
                if lane == 0: word_i32 = o1.x
                if lane == 1: word_i32 = o1.y
                if lane == 2: word_i32 = o1.z
                if lane == 3: word_i32 = o1.w
            if k == 2:
                if lane == 0: word_i32 = o2.x
                if lane == 1: word_i32 = o2.y
                if lane == 2: word_i32 = o2.z
                if lane == 3: word_i32 = o2.w
            if k == 3:
                if lane == 0: word_i32 = o3.x
                if lane == 1: word_i32 = o3.y
                if lane == 2: word_i32 = o3.z
                if lane == 3: word_i32 = o3.w
            if k == 4:
                if lane == 0: word_i32 = o4.x
                if lane == 1: word_i32 = o4.y
                if lane == 2: word_i32 = o4.z
                if lane == 3: word_i32 = o4.w
            if k == 5:
                if lane == 0: word_i32 = o5.x
                if lane == 1: word_i32 = o5.y
                if lane == 2: word_i32 = o5.z
                if lane == 3: word_i32 = o5.w
            if k == 6:
                if lane == 0: word_i32 = o6.x
                if lane == 1: word_i32 = o6.y
                if lane == 2: word_i32 = o6.z
                if lane == 3: word_i32 = o6.w
            if k == 7:
                if lane == 0: word_i32 = o7.x
                if lane == 1: word_i32 = o7.y
                if lane == 2: word_i32 = o7.z
                if lane == 3: word_i32 = o7.w
            if k == 8:
                if lane == 0: word_i32 = o8.x
                if lane == 1: word_i32 = o8.y
                if lane == 2: word_i32 = o8.z
                if lane == 3: word_i32 = o8.w
            if k == 9:
                if lane == 0: word_i32 = o9.x
                if lane == 1: word_i32 = o9.y
                if lane == 2: word_i32 = o9.z
                if lane == 3: word_i32 = o9.w
            if k == 10:
                if lane == 0: word_i32 = o10.x
                if lane == 1: word_i32 = o10.y
                if lane == 2: word_i32 = o10.z
                if lane == 3: word_i32 = o10.w
            if k == 11:
                if lane == 0: word_i32 = o11.x
                if lane == 1: word_i32 = o11.y
                if lane == 2: word_i32 = o11.z
                if lane == 3: word_i32 = o11.w
            if k == 12:
                if lane == 0: word_i32 = o12.x
                if lane == 1: word_i32 = o12.y
                if lane == 2: word_i32 = o12.z
                if lane == 3: word_i32 = o12.w
            if k == 13:
                if lane == 0: word_i32 = o13.x
                if lane == 1: word_i32 = o13.y
                if lane == 2: word_i32 = o13.z
                if lane == 3: word_i32 = o13.w
            if k == 14:
                if lane == 0: word_i32 = o14.x
                if lane == 1: word_i32 = o14.y
                if lane == 2: word_i32 = o14.z
                if lane == 3: word_i32 = o14.w
            if k == 15:
                if lane == 0: word_i32 = o15.x
                if lane == 1: word_i32 = o15.y
                if lane == 2: word_i32 = o15.z
                if lane == 3: word_i32 = o15.w
            val word = _i32_to_u32(word_i32)
            out.push((word & 0xFFu32).to_u8())
            out.push(((word >> 8u32) & 0xFFu32).to_u8())
            out.push(((word >> 16u32) & 0xFFu32).to_u8())
            out.push(((word >> 24u32) & 0xFFu32).to_u8())
            k = k + 1
        lane = lane + 1

    out

# ============================================================================
# Byte-parsing helpers
# ============================================================================

fn _parse_key_words(key: [u8]) -> [u32]:
    """Parse 32-byte key into 8 u32 words (little-endian)."""
    var words: [u32] = []
    var i: u64 = 0
    while i < 8:
        val base = i * 4
        val word = key[base].to_u32() |
                   (key[base + 1].to_u32() << 8u32) |
                   (key[base + 2].to_u32() << 16u32) |
                   (key[base + 3].to_u32() << 24u32)
        words.push(word)
        i = i + 1
    words

fn _parse_nonce_words(nonce: [u8]) -> [u32]:
    """Parse 12-byte nonce into 3 u32 words (little-endian)."""
    var words: [u32] = []
    var i: u64 = 0
    while i < 3:
        val base = i * 4
        val word = nonce[base].to_u32() |
                   (nonce[base + 1].to_u32() << 8u32) |
                   (nonce[base + 2].to_u32() << 16u32) |
                   (nonce[base + 3].to_u32() << 24u32)
        words.push(word)
        i = i + 1
    words

# ============================================================================
# Keystream generator (RFC 7539 §2.4)
# ============================================================================

fn chacha20_keystream(key: [u8], counter: u32, nonce: [u8], length: u64) -> [u8]:
    """Generate `length` bytes of ChaCha20 keystream (RFC 7539 §2.4).

    Uses 4-block SIMD path for 256-byte aligned bulk, scalar single-block
    fallback for the remainder.

    Args:
        key:     32-byte key.
        counter: Initial block counter (typically 1 for AEAD; 0 for key-gen).
        nonce:   12-byte nonce.
        length:  Number of keystream bytes to return.

    Returns: `length` keystream bytes.

    Example:
        val ks = chacha20_keystream(key, 1u32, nonce, 64u64)
    """
    val key_words   = _parse_key_words(key)
    val nonce_words = _parse_nonce_words(nonce)

    var out: [u8] = []
    var block_counter = counter
    var pos: u64 = 0

    # Bulk: 4 blocks at a time (256 bytes)
    while pos + 256 <= length:
        val ks = _chacha20_block4_simd(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 256:
            out.push(ks[j])
            j = j + 1
        pos = pos + 256
        block_counter = _u32_mask(block_counter + 4u32)

    # Tail: one block at a time
    while pos < length:
        val block = chacha20_block(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 16 and pos < length:
            val word = block[j]
            var b: u64 = 0
            while b < 4 and pos < length:
                out.push(((word >> (b * 8)) & 0xFF).to_u8())
                pos = pos + 1
                b = b + 1
            j = j + 1
        block_counter = _u32_mask(block_counter + 1u32)

    out

# ============================================================================
# Encryption / decryption (RFC 7539 §2.5)
# ============================================================================

fn chacha20_encrypt(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt (or decrypt) data using ChaCha20 (RFC 7539 §2.5).

    ChaCha20 is a stream cipher — encryption and decryption are the same
    operation (XOR with keystream). Call with ciphertext to decrypt.

    Args:
        key:       32-byte key.
        counter:   Initial block counter (1 for AEAD per RFC 7539 §2.4).
        nonce:     12-byte nonce.
        plaintext: Input bytes (plaintext to encrypt, or ciphertext to decrypt).

    Returns: Output bytes of the same length as plaintext.

    Example:
        val ct = chacha20_encrypt(key, 1u32, nonce, pt)
        val pt2 = chacha20_encrypt(key, 1u32, nonce, ct)
        # pt2 == pt
    """
    val key_words   = _parse_key_words(key)
    val nonce_words = _parse_nonce_words(nonce)
    val total       = plaintext.len()

    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0

    # Bulk: 4 blocks = 256 bytes at a time
    while pos + 256 <= total:
        val ks = _chacha20_block4_simd(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 256:
            output.push(plaintext[pos + j] ^ ks[j])
            j = j + 1
        pos = pos + 256
        block_counter = _u32_mask(block_counter + 4u32)

    # Tail: single block
    while pos < total:
        val block = chacha20_block(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 16 and pos < total:
            val word = block[j]
            var b: u64 = 0
            while b < 4 and pos < total:
                val ks_byte = ((word >> (b * 8)) & 0xFF).to_u8()
                output.push(plaintext[pos] ^ ks_byte)
                pos = pos + 1
                b = b + 1
            j = j + 1
        block_counter = _u32_mask(block_counter + 1u32)

    output
