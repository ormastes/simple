# LLM Output Gate — byte-level filter applied to LLM-generated output.
#
# Provides: OutputGate, ScanDecision, GateDecision, scan_and_gate,
#           filter_response_body, test_notify_sink_size, test_audit_sink_size.

use std.common.privilege.authority_token.{AuthorityToken}

struct ScanDecision:
    kind: text
    reasons: [text]

enum GateDecision:
    Pass
    Hold
    Block
    Redact

struct FilteredBody:
    decision: GateDecision
    body: [u8]

class OutputGate:
    enabled: bool
    max_bytes: i64
    notify_count: i64
    audit_count: i64

impl OutputGate:
    static fn default() -> OutputGate:
        OutputGate(enabled: true, max_bytes: 1048576, notify_count: 0, audit_count: 0)

    static fn default_for_test() -> OutputGate:
        OutputGate(enabled: true, max_bytes: 1048576, notify_count: 0, audit_count: 0)

    me fn scan_and_gate(body: [u8], token: AuthorityToken) -> ScanDecision:
        _scan_body(body)

    me fn filter_response_body(body: [u8], token: AuthorityToken) -> [u8]:
        val scan = _scan_body(body)
        if scan.kind == "Hold":
            me.notify_count = me.notify_count + 1
            me.audit_count = me.audit_count + 1
            return []
        body

fn _byte_at(body: [u8], i: i64) -> i64:
    body[i].to_i64()

fn _is_digit(body: [u8], i: i64) -> bool:
    val v = _byte_at(body, i)
    v >= 48 and v <= 57

fn _has_aws_key(body: [u8]) -> bool:
    # Look for "AKIA" = bytes [65, 75, 73, 65]
    val n = body.len()
    var i = 0
    while (i + 3) < n:
        if (_byte_at(body, i) == 65 and _byte_at(body, i + 1) == 75 and
            _byte_at(body, i + 2) == 73 and _byte_at(body, i + 3) == 65):
            return true
        i = i + 1
    false

fn _has_email(body: [u8]) -> bool:
    # Look for '@' = 64
    val n = body.len()
    var i = 0
    while i < n:
        if _byte_at(body, i) == 64:
            return true
        i = i + 1
    false

fn _has_phone(body: [u8]) -> bool:
    # Look for NNN-NNN-NNNN pattern ('-' = 45)
    val n = body.len()
    var i = 0
    while (i + 11) < n:
        if (_is_digit(body, i) and _is_digit(body, i + 1) and _is_digit(body, i + 2) and
            _byte_at(body, i + 3) == 45 and
            _is_digit(body, i + 4) and _is_digit(body, i + 5) and _is_digit(body, i + 6) and
            _byte_at(body, i + 7) == 45 and
            _is_digit(body, i + 8) and _is_digit(body, i + 9) and _is_digit(body, i + 10) and
            _is_digit(body, i + 11)):
            return true
        i = i + 1
    false

fn _scan_body(body: [u8]) -> ScanDecision:
    var reasons: [text] = []
    if _has_aws_key(body):
        reasons.append("aws-key")
    if _has_email(body):
        reasons.append("email-pii")
    if _has_phone(body):
        reasons.append("phone-pii")
    if reasons.len() > 0:
        ScanDecision(kind: "Hold", reasons: reasons)
    else:
        ScanDecision(kind: "Pass", reasons: [])

# Module-level wrappers (also callable as methods via instance dispatch).
fn scan_and_gate(gate: OutputGate, body: [u8], token: AuthorityToken) -> ScanDecision:
    gate.scan_and_gate(body, token)

fn filter_response_body(gate: OutputGate, body: [u8], token: AuthorityToken) -> [u8]:
    gate.filter_response_body(body, token)

fn test_notify_sink_size(gate: OutputGate) -> i64:
    gate.notify_count

fn test_audit_sink_size(gate: OutputGate) -> i64:
    gate.audit_count

export OutputGate, ScanDecision, FilteredBody, GateDecision
export scan_and_gate, filter_response_body, test_notify_sink_size, test_audit_sink_size
