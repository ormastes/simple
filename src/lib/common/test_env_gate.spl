# Test Environment Gate — reusable env-gating for hardware/qemu/network tests.
#
# Usage pattern in a spec:
#   use std.common.test_env_gate.{test_env_require, test_env_hardware_available}
#
#   it "BLOCKED: AC-4: opens serial port":
#       if test_env_hardware_available():
#           val port = serial_open("/dev/ttyUSB0", 115200)
#           expect(port.is_valid).to_equal(true)
#       else:
#           expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

extern fn rt_env_get(key: text) -> text

pub fn test_env_available(env_name: text) -> bool:
    """Return true if the named env var is set to exactly "1"."""
    val v = rt_env_get(env_name)
    if v == nil:
        false
    else:
        v == "1"

pub fn test_env_require(env_name: text) -> text:
    """Return "ready" when env var is "1", otherwise "blocked:ENV_NAME"."""
    if test_env_available(env_name):
        "ready"
    else:
        "blocked:" + env_name

pub fn test_env_hardware_available() -> bool:
    """True when SIMPLE_HW_TEST=1 (real hardware devices permitted)."""
    test_env_available("SIMPLE_HW_TEST")

pub fn test_env_qemu_available() -> bool:
    """True when SIMPLE_QEMU_TEST=1 (QEMU-backed tests permitted)."""
    test_env_available("SIMPLE_QEMU_TEST")

pub fn test_env_network_available() -> bool:
    """True when SIMPLE_NET_TEST=1 (network-touching tests permitted)."""
    test_env_available("SIMPLE_NET_TEST")

pub fn test_env_gate_reason(env_name: text) -> text:
    """Human-readable skip reason when env gate is not open."""
    "Skipped: set " + env_name + "=1 to enable this test"
