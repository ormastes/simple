# Render Scene — shared display-list abstraction for 2D rendering.
#
# Provides a list of SceneCommands that describe what to draw, plus
# a software rasterizer (execute_scene_to_buffer) that renders them
# into a flat u32 pixel buffer.  Used by widget toolkit, browser
# rendering engine, and compositor.

use common.render_scene.scene
use common.render_scene.engine_trait
use common.render_scene.engine_int
use common.render_scene.engine_float
use common.render_scene.executor
