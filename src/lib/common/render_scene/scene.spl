#![allow(unnamed_duplicate_typed_args)]
# Render Scene — scene command types and constructor helpers.
#
# A RenderScene is an ordered list of SceneCommands describing 2D drawing
# primitives.  Commands are created via the `scene_*` factory functions
# and collected into a RenderScene for execution by a backend
# (software rasterizer, GPU, etc.).

# ============================================================================
# Domain wrapper types
# ============================================================================

class PixelInt:
    """A pixel-space integer (coordinate, size, radius, or stroke width in pixels)."""
    value: i32

class ArgbColor:
    """A packed ARGB color value (0xAARRGGBB)."""
    value: u32

# ============================================================================
# Scene command
# ============================================================================

class SceneCommand:
    """A single 2D drawing primitive in a render scene.

    `kind` selects the operation:
      fill_rect, stroke_rect, text, line, circle, circle_filled,
      rounded_rect, gradient_rect, image, clip_push, clip_pop
    """
    kind: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: u32          # ARGB packed
    text_val: text
    font_size: i32
    border_radius: i32
    stroke_width: i32
    stroke_color: u32
    color2: u32         # second color for gradients
    opacity: f32
    pixels: [u32]       # pixel data for image commands
    pixel_width: i32
    pixel_height: i32

# ============================================================================
# Render scene container
# ============================================================================

class RenderScene:
    """Ordered list of SceneCommands with a target size."""
    commands: [SceneCommand]
    width: i32
    height: i32

pub fn scene_command_get_kind(cmd: SceneCommand) -> text:
    cmd.kind

pub fn scene_command_get_x(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.x)

pub fn scene_command_get_y(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.y)

pub fn scene_command_get_width(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.width)

pub fn scene_command_get_height(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.height)

pub fn scene_command_get_color(cmd: SceneCommand) -> ArgbColor:
    ArgbColor(value: cmd.color)

pub fn scene_command_get_text(cmd: SceneCommand) -> text:
    cmd.text_val

pub fn scene_command_get_font_size(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.font_size)

pub fn scene_command_get_border_radius(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.border_radius)

pub fn scene_command_get_stroke_width(cmd: SceneCommand) -> PixelInt:
    PixelInt(value: cmd.stroke_width)

pub fn scene_command_get_color2(cmd: SceneCommand) -> ArgbColor:
    ArgbColor(value: cmd.color2)

pub fn render_scene_get_commands(scene: RenderScene) -> [SceneCommand]:
    scene.commands

pub fn render_scene_get_width(scene: RenderScene) -> PixelInt:
    PixelInt(value: scene.width)

pub fn render_scene_get_height(scene: RenderScene) -> PixelInt:
    PixelInt(value: scene.height)

# ============================================================================
# Internal: default SceneCommand with all fields zeroed
# ============================================================================

fn default_command(kind: text) -> SceneCommand:
    """Create a SceneCommand with the given kind and zeroed fields."""
    SceneCommand(
        kind: kind, x: 0, y: 0, width: 0, height: 0,
        color: 0, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

# ============================================================================
# Factory functions
# ============================================================================

fn scene_fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32) -> SceneCommand:
    """Create a filled rectangle command."""
    SceneCommand(
        kind: "fill_rect", x: x, y: y, width: w, height: h,
        color: color, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_stroke_rect(x: i32, y: i32, w: i32, h: i32, color: u32, stroke_w: i32) -> SceneCommand:
    """Create a stroked (outline) rectangle command."""
    SceneCommand(
        kind: "stroke_rect", x: x, y: y, width: w, height: h,
        color: color, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: stroke_w, stroke_color: color, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> SceneCommand:
    """Create a text drawing command."""
    SceneCommand(
        kind: "text", x: x, y: y, width: 0, height: 0,
        color: color, text_val: text_val, font_size: font_size, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, stroke_w: i32) -> SceneCommand:
    """Create a line command.  x/y = start, width/height = end point."""
    SceneCommand(
        kind: "line", x: x1, y: y1, width: x2, height: y2,
        color: color, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: stroke_w, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_circle(cx: i32, cy: i32, r: i32, color: u32) -> SceneCommand:
    """Create an outlined circle command (center + radius)."""
    SceneCommand(
        kind: "circle", x: cx, y: cy, width: r, height: 0,
        color: color, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 1, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_circle_filled(cx: i32, cy: i32, r: i32, color: u32) -> SceneCommand:
    """Create a filled circle command (center + radius)."""
    SceneCommand(
        kind: "circle_filled", x: cx, y: cy, width: r, height: 0,
        color: color, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_rounded_rect(x: i32, y: i32, w: i32, h: i32, color: u32, radius: i32) -> SceneCommand:
    """Create a rounded rectangle command."""
    SceneCommand(
        kind: "rounded_rect", x: x, y: y, width: w, height: h,
        color: color, text_val: "", font_size: 0, border_radius: radius,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_gradient_rect(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32) -> SceneCommand:
    """Create a horizontal linear gradient rectangle."""
    SceneCommand(
        kind: "gradient_rect", x: x, y: y, width: w, height: h,
        color: color1, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: color2, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_blur_rect(x: i32, y: i32, w: i32, h: i32, blur_radius: i32, radius: i32) -> SceneCommand:
    """Create a blur rectangle command (backdrop-filter: blur)."""
    SceneCommand(
        kind: "blur_rect", x: x, y: y, width: w, height: h,
        color: 0, text_val: "", font_size: blur_radius, border_radius: radius,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32], pw: i32, ph: i32) -> SceneCommand:
    """Create an image blit command.  `pixels` is a flat ARGB array of pw*ph pixels."""
    SceneCommand(
        kind: "image", x: x, y: y, width: w, height: h,
        color: 0, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: pixels, pixel_width: pw, pixel_height: ph
    )

fn scene_clip_push(x: i32, y: i32, w: i32, h: i32) -> SceneCommand:
    """Push a clip rectangle onto the clip stack."""
    SceneCommand(
        kind: "clip_push", x: x, y: y, width: w, height: h,
        color: 0, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

fn scene_clip_pop() -> SceneCommand:
    """Pop the top clip rectangle from the clip stack."""
    SceneCommand(
        kind: "clip_pop", x: 0, y: 0, width: 0, height: 0,
        color: 0, text_val: "", font_size: 0, border_radius: 0,
        stroke_width: 0, stroke_color: 0, color2: 0, opacity: 1.0,
        pixels: [], pixel_width: 0, pixel_height: 0
    )

# ============================================================================
# Scene constructor
# ============================================================================

fn render_scene(commands: [SceneCommand], w: i32, h: i32) -> RenderScene:
    """Create a RenderScene from a list of commands and a target size."""
    RenderScene(commands: commands, width: w, height: h)

# ============================================================================
# Color helpers
# ============================================================================

fn argb(a: u32, r: u32, g: u32, b: u32) -> u32:
    """Pack 8-bit ARGB components into a single u32."""
    ((a & 0xFF) << 24) | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)

fn rgb(r: u32, g: u32, b: u32) -> u32:
    """Pack RGB into ARGB with full opacity (alpha=255)."""
    argb(255, r, g, b)

fn rgba_to_argb(rgba: u32) -> u32:
    """Convert RGBA packed u32 to ARGB layout."""
    val r = (rgba >> 24) & 0xFF
    val g = (rgba >> 16) & 0xFF
    val b = (rgba >> 8) & 0xFF
    val a = rgba & 0xFF
    argb(a, r, g, b)

fn argb_to_rgba(argb_val: u32) -> u32:
    """Convert ARGB packed u32 to RGBA layout."""
    val a = (argb_val >> 24) & 0xFF
    val r = (argb_val >> 16) & 0xFF
    val g = (argb_val >> 8) & 0xFF
    val b = argb_val & 0xFF
    (r << 24) | (g << 16) | (b << 8) | a

fn argb_alpha(c: u32) -> u32:
    """Extract alpha channel from ARGB color."""
    (c >> 24) & 0xFF

fn argb_red(c: u32) -> u32:
    """Extract red channel from ARGB color."""
    (c >> 16) & 0xFF

fn argb_green(c: u32) -> u32:
    """Extract green channel from ARGB color."""
    (c >> 8) & 0xFF

fn argb_blue(c: u32) -> u32:
    """Extract blue channel from ARGB color."""
    c & 0xFF
