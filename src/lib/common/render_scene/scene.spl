# Render Scene — the top-level scene graph consumed by GPU and software renderers.
#
# Provides: RenderScene, SceneCommand.

# A single draw command in a render scene.
# kind: "fill_rect" | "stroke_rect" | "text" | "line" | "circle" | "image"
class SceneCommand:
    kind: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: i32
    text_val: text
    font_size: i32
    stroke_width: i32

impl SceneCommand:
    static fn fill_rect(x: i32, y: i32, w: i32, h: i32, color: i32) -> SceneCommand:
        SceneCommand(kind: "fill_rect", x: x, y: y, width: w, height: h,
                     color: color, text_val: "", font_size: 0, stroke_width: 0)

    static fn stroke_rect(x: i32, y: i32, w: i32, h: i32, color: i32, sw: i32) -> SceneCommand:
        SceneCommand(kind: "stroke_rect", x: x, y: y, width: w, height: h,
                     color: color, text_val: "", font_size: 0, stroke_width: sw)

    static fn text(x: i32, y: i32, t: text, font_size: i32, color: i32) -> SceneCommand:
        SceneCommand(kind: "text", x: x, y: y, width: 0, height: 0,
                     color: color, text_val: t, font_size: font_size, stroke_width: 0)

    static fn line(x: i32, y: i32, x2: i32, y2: i32, color: i32, sw: i32) -> SceneCommand:
        SceneCommand(kind: "line", x: x, y: y, width: x2, height: y2,
                     color: color, text_val: "", font_size: 0, stroke_width: sw)

    static fn circle(x: i32, y: i32, radius: i32, color: i32) -> SceneCommand:
        SceneCommand(kind: "circle", x: x, y: y, width: radius, height: 0,
                     color: color, text_val: "", font_size: 0, stroke_width: 0)

# An ordered list of draw commands that make up a complete rendered frame.
class RenderScene:
    commands: [SceneCommand]
    viewport_w: i32
    viewport_h: i32

impl RenderScene:
    static fn new(w: i32, h: i32) -> RenderScene:
        RenderScene(commands: [], viewport_w: w, viewport_h: h)

    fn push(self, cmd: SceneCommand) -> RenderScene:
        val new_cmds = self.commands.push(cmd)
        RenderScene(commands: new_cmds, viewport_w: self.viewport_w, viewport_h: self.viewport_h)
