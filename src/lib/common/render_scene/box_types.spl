# Render Scene Box Types — CSS box model layout structures.
#
# Provides: LayoutBox, BoxKind, BoxModel.

# Identifies how a box participates in layout.
enum BoxKind:
    Block
    Inline
    InlineBlock
    Flex
    Grid
    None

# The four-sided spacing model for a single box (margin/border/padding/content).
struct EdgeSizes:
    top: f64
    right: f64
    bottom: f64
    left: f64

# Full CSS box model for one element.
struct BoxModel:
    content_x: f64
    content_y: f64
    content_w: f64
    content_h: f64
    padding: EdgeSizes
    border: EdgeSizes
    margin: EdgeSizes

impl BoxModel:
    static fn zero() -> BoxModel:
        val e = EdgeSizes(top: 0.0, right: 0.0, bottom: 0.0, left: 0.0)
        BoxModel(content_x: 0.0, content_y: 0.0, content_w: 0.0, content_h: 0.0,
                 padding: e, border: e, margin: e)

# A positioned layout box associated with a DOM node.
class LayoutBox:
    node_id: i64
    kind: BoxKind
    box_model: BoxModel
    children: [LayoutBox]

impl LayoutBox:
    static fn create(node_id: i64, kind: BoxKind) -> LayoutBox:
        LayoutBox(node_id: node_id, kind: kind,
                  box_model: BoxModel.zero(), children: [])
