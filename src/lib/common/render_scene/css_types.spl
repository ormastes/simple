# Render Scene CSS Types — CSS rule, selector, declaration, and value types.
#
# Provides: CSSRule, CSSDeclaration, CSSValue, Selector, SelectorPart.

use std.common.color.types.{Color}

# A single CSS property + value pair.
struct CSSDeclaration:
    property: text
    value: CSSValue

# A parsed CSS value.
enum CSSValue:
    # Numeric length: value in px/em/etc, unit string
    Length(v: f64, unit: text)
    # Named keyword: "auto", "block", "flex", etc.
    Keyword(v: text)
    # Color value
    Color(c: Color)
    # Percentage
    Percent(v: f64)
    # Unparsed raw string
    Raw(v: text)

# One part of a CSS selector.
enum SelectorPart:
    Type(name: text)
    Class(name: text)
    Id(name: text)
    Universal

# A CSS selector (list of parts — all must match, i.e. compound selector).
struct Selector:
    parts: [SelectorPart]

# A complete CSS rule: selector list + declarations.
struct CSSRule:
    selectors: [Selector]
    declarations: [CSSDeclaration]
