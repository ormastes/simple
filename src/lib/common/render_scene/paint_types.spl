# Render Scene Paint Types — display list operations for browser rendering.
#
# Provides: PaintOp, DisplayList, DisplayItem.

use std.common.color.types.{Color}

# A single paint operation in a display list.
enum PaintOp:
    FillRect(x: f64, y: f64, w: f64, h: f64, color: Color)
    DrawBorder(x: f64, y: f64, w: f64, h: f64, widths: [f64], colors: [Color])
    DrawText(x: f64, y: f64, text_content: text, font_size: f64, color: Color)
    DrawImage(x: f64, y: f64, w: f64, h: f64, src: text)
    Clip(x: f64, y: f64, w: f64, h: f64)
    PopClip

# An ordered list of paint operations.
class DisplayList:
    ops: [PaintOp]

impl DisplayList:
    static fn empty() -> DisplayList:
        DisplayList(ops: [])

    fn len(self) -> i64:
        self.ops.len()

# A typed wrapper around a PaintOp — used when display items carry metadata.
struct DisplayItem:
    op: PaintOp
    z_index: i64
