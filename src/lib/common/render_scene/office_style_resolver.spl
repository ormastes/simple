# Office Style Resolver — the shared style substrate for the office suite.
#
# Maps office / markdown element tags (the `WidgetNode` style tags that
# `src/app/office/{word,slides,sheets}/render.spl` already emit, e.g.
# "heading_1", "paragraph", "code_block") plus utility classes to resolved CSS
# declarations, and projects those to two surfaces:
#   - GUI / HTML : a `prop: value;` style string
#   - TUI        : an SGR parameter string (e.g. "1;3" for bold+italic) that a
#                  terminal renderer wraps as ESC[ ... m
#
# A single default theme therefore drives both the terminal and graphical
# office surfaces, which is the "CSS for md and TUI" spine of the LibreOffice
# suite program (see .spipe/libreoffice-suite/state.md).
#
# Values are kept as CSS value STRINGS (the serialized form) rather than the
# f64-bearing `CSSValue` in `css_types.spl`, so a resolved style is verifiable
# on the interpreter/runner path without tripping the f64 nested-payload
# toolchain bug (doc/08_tracking/bug/interp_f64_nested_struct_payload_zero_2026-06-14.md).
# A later slice can back this cascade with the blink/css_parser engine.

# A single resolved property + serialized value.
struct StyleDecl:
    property: text
    value: text

# A resolved declaration block for one element.
struct ResolvedStyle:
    decls: [StyleDecl]

# Accessors are free functions (not methods) so the generic names `get`/`has`
# do not pollute bare-method resolution — adding them as methods collided with
# ThemeRegistry.get when the UI tree is loaded (CODEGEN-AMBIGUOUS-METHOD).

fn style_value(style: ResolvedStyle, property: text) -> text:
    """Return the resolved value for a property, or "" when unset."""
    for d in style.decls:
        if d.property == property:
            return d.value
    ""

fn style_has(style: ResolvedStyle, property: text) -> bool:
    """Whether the property is present in the resolved block."""
    for d in style.decls:
        if d.property == property:
            return true
    false

fn _decl(property: text, value: text) -> StyleDecl:
    StyleDecl(property: property, value: value)

# =========================================================================
# Default theme — Word-level defaults for the office/markdown element tags.
# =========================================================================

fn default_style_for(tag: text) -> [StyleDecl]:
    """Default CSS declarations for an office/markdown element tag."""
    match tag:
        "heading_1":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "2em"), _decl("font-weight", "bold"),
                    _decl("line-height", "1.2"), _decl("margin-top", "0.67em"),
                    _decl("margin-bottom", "0.67em")]
        "heading_2":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "1.5em"), _decl("font-weight", "bold"),
                    _decl("line-height", "1.25"), _decl("margin-top", "0.75em"),
                    _decl("margin-bottom", "0.75em")]
        "heading_3":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "1.17em"), _decl("font-weight", "bold"),
                    _decl("line-height", "1.3"), _decl("margin-top", "0.83em"),
                    _decl("margin-bottom", "0.83em")]
        "heading_4":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "1em"), _decl("font-weight", "bold"),
                    _decl("margin-top", "1.12em"), _decl("margin-bottom", "1.12em")]
        "heading_5":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "0.83em"), _decl("font-weight", "bold"),
                    _decl("margin-top", "1.5em"), _decl("margin-bottom", "1.5em")]
        "heading_6":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "0.75em"), _decl("font-weight", "bold"),
                    _decl("margin-top", "1.67em"), _decl("margin-bottom", "1.67em")]
        "paragraph":
            return [_decl("font-family", "\"Fira Code\", \"Liberation Mono\", monospace"),
                    _decl("font-size", "1em"), _decl("line-height", "1.5"),
                    _decl("margin-bottom", "1em")]
        "bullet_list":
            return [_decl("margin-left", "1.5em"), _decl("list-style", "disc")]
        "numbered_list":
            return [_decl("margin-left", "1.5em"), _decl("list-style", "decimal")]
        "code_block":
            return [_decl("font-family", "monospace"),
                    _decl("background-color", "#f5f5f5"), _decl("padding", "0.5em"),
                    _decl("white-space", "pre")]
        "quote":
            return [_decl("border-left", "4px solid #cccccc"),
                    _decl("padding-left", "1em"), _decl("font-style", "italic"),
                    _decl("color", "#555555")]
        "horizontal_rule":
            return [_decl("border-top", "1px solid #cccccc"),
                    _decl("margin-top", "1em"), _decl("margin-bottom", "1em")]
        "image":
            return [_decl("display", "block"), _decl("max-width", "100%")]
        "slide_title":
            return [_decl("font-size", "2.5em"), _decl("font-weight", "bold"),
                    _decl("text-align", "center"), _decl("margin-bottom", "0.5em"),
                    _decl("color", "#1a1a1a")]
        "slide_subtitle":
            return [_decl("font-size", "1.5em"), _decl("text-align", "center"),
                    _decl("color", "#555555"), _decl("margin-bottom", "1em")]
        "slide_body":
            return [_decl("font-size", "1.2em"), _decl("line-height", "1.4"),
                    _decl("margin-bottom", "0.5em")]
        "slide_bullet":
            return [_decl("font-size", "1.2em"), _decl("margin-left", "1.5em"),
                    _decl("list-style", "disc"), _decl("line-height", "1.4")]
        _:
            return []

# Utility classes that override / extend the base element style.
fn _class_style(cls: text) -> [StyleDecl]:
    match cls:
        "bold":
            return [_decl("font-weight", "bold")]
        "italic":
            return [_decl("font-style", "italic")]
        "underline":
            return [_decl("text-decoration", "underline")]
        "center":
            return [_decl("text-align", "center")]
        "right":
            return [_decl("text-align", "right")]
        "muted":
            return [_decl("color", "#888888")]
        _:
            return []

# =========================================================================
# Resolution + cascade
# =========================================================================

fn _upsert(decls: [StyleDecl], decl: StyleDecl) -> [StyleDecl]:
    """Replace an existing property of the same name, else append (last wins)."""
    var out: [StyleDecl] = []
    var replaced = false
    for d in decls:
        if d.property == decl.property:
            out.push(decl)
            replaced = true
        else:
            out.push(d)
    if not replaced:
        out.push(decl)
    out

fn resolve_style(tag: text, classes: [text]) -> ResolvedStyle:
    """Resolve an element's style: default theme for the tag, then class
    overrides applied in order (later classes win)."""
    var decls = default_style_for(tag)
    for cls in classes:
        val extra = _class_style(cls)
        for d in extra:
            decls = _upsert(decls, d)
    ResolvedStyle(decls: decls)

# =========================================================================
# Surface projections
# =========================================================================

fn style_to_css_text(style: ResolvedStyle) -> text:
    """Project a resolved style to a GUI/HTML `prop: value;` declaration string."""
    var out = ""
    for d in style.decls:
        out = "{out}{d.property}: {d.value}; "
    out.trim()

fn style_to_sgr(style: ResolvedStyle) -> text:
    """Project a resolved style to a terminal SGR parameter string (e.g. "1;3").

    A TUI renderer wraps the result as ESC[ <result> m. Returns "" when the
    style implies no terminal attributes."""
    var codes: [text] = []
    if style_value(style, "font-weight") == "bold":
        codes.push("1")
    if style_value(style, "font-style") == "italic":
        codes.push("3")
    if style_value(style, "text-decoration") == "underline":
        codes.push("4")
    var out = ""
    var first = true
    for c in codes:
        if first:
            out = c
            first = false
        else:
            out = "{out};{c}"
    out
