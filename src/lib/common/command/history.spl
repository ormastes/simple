# Command History — undo/redo stack for command-pattern editors.
#
# Provides: CommandHistory.

class CommandHistory:
    past: [text]
    future: [text]
    max_size: i64

    static fn new(max_size: i64) -> CommandHistory:
        CommandHistory(past: [], future: [], max_size: max_size)

    static fn with_defaults() -> CommandHistory:
        CommandHistory(past: [], future: [], max_size: 100)

    me push_command(label: text):
        me.future = []
        me.past.push(label)
        if me.past.len() > me.max_size:
            var trimmed: [text] = []
            var i = me.past.len() - me.max_size
            while i < me.past.len():
                trimmed.push(me.past[i])
                i = i + 1
            me.past = trimmed

    me undo() -> text:
        if me.past.len() == 0:
            return ""
        val label = me.past[me.past.len() - 1]
        var new_past: [text] = []
        var i = 0
        while i < me.past.len() - 1:
            new_past.push(me.past[i])
            i = i + 1
        me.past = new_past
        me.future.push(label)
        label

    me redo() -> text:
        if me.future.len() == 0:
            return ""
        val label = me.future[me.future.len() - 1]
        var new_future: [text] = []
        var i = 0
        while i < me.future.len() - 1:
            new_future.push(me.future[i])
            i = i + 1
        me.future = new_future
        me.past.push(label)
        label

    fn can_undo() -> bool:
        me.past.len() > 0

    fn can_redo() -> bool:
        me.future.len() > 0
