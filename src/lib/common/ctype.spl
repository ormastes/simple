# Pure Simple ASCII character classification functions.
# Replaces the C runtime wrappers in src/runtime/runtime_ctype.c
# with portable range-check implementations.
#
# Canonical names use predicate form (digit, upper, lower, …).
# The is_* names are kept as compatibility aliases.

fn digit(ch: i64) -> bool:
    """Return true if ch is an ASCII digit (0-9)."""
    ch >= 48 and ch <= 57

fn upper(ch: i64) -> bool:
    """Return true if ch is an ASCII uppercase letter (A-Z)."""
    ch >= 65 and ch <= 90

fn lower(ch: i64) -> bool:
    """Return true if ch is an ASCII lowercase letter (a-z)."""
    ch >= 97 and ch <= 122

fn alpha(ch: i64) -> bool:
    """Return true if ch is an ASCII letter (a-z, A-Z)."""
    upper(ch) or lower(ch)

fn alnum(ch: i64) -> bool:
    """Return true if ch is an ASCII letter or digit."""
    alpha(ch) or digit(ch)

fn xdigit(ch: i64) -> bool:
    """Return true if ch is a hexadecimal digit (0-9, a-f, A-F)."""
    digit(ch) or (ch >= 65 and ch <= 70) or (ch >= 97 and ch <= 102)

fn space(ch: i64) -> bool:
    """Return true if ch is ASCII whitespace."""
    ch == 32 or ch == 9 or ch == 10 or ch == 13 or ch == 11 or ch == 12

# ---- Compatibility aliases (is_* form) — forward to canonical names --------

fn is_digit(ch: i64) -> bool:
    digit(ch)

fn is_upper(ch: i64) -> bool:
    upper(ch)

fn is_lower(ch: i64) -> bool:
    lower(ch)

fn is_alpha(ch: i64) -> bool:
    alpha(ch)

fn is_alnum(ch: i64) -> bool:
    alnum(ch)

fn is_xdigit(ch: i64) -> bool:
    xdigit(ch)

fn is_space(ch: i64) -> bool:
    space(ch)

# ---- Conversion functions ---------------------------------------------------

fn to_lower(ch: i64) -> i64:
    if upper(ch):
        ch + 32
    else:
        ch

fn to_upper(ch: i64) -> i64:
    if lower(ch):
        ch - 32
    else:
        ch
