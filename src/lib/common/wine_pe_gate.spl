"""PE/COFF loader readiness gate for the non-GUI hello.exe milestone."""

pub fn wine_pe_required_features() -> [text]:
    [
        "mz",
        "pe-signature",
        "machine-x86_64",
        "pe32plus",
        "section-bounds",
        "console-subsystem",
        "imports",
        "relocations",
        "tls-directory",
        "structured-errors",
        "safe-map",
        "no-exec-before-gates"
    ]

pub fn wine_pe_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in wine_pe_required_features():
        if not features.contains(feature):
            missing.push(feature)
    return missing

pub fn wine_pe_gate(features: text) -> text:
    val missing = wine_pe_missing_features(features)
    if missing.len() == 0:
        return "ready"
    return "missing-" + missing[0]

pub fn wine_pe_header_gate(header: text) -> text:
    if not header.contains("MZ"):
        return "bad-mz"
    if not header.contains("PE"):
        return "bad-pe-signature"
    if not header.contains("x86_64"):
        return "unsupported-machine"
    if not header.contains("PE32+"):
        return "unsupported-optional-header"
    if not header.contains("console"):
        return "unsupported-subsystem"
    return "ready"

pub fn wine_pe_execution_gate(gates: text) -> text:
    if not gates.contains("process=verified"):
        return "blocked-process"
    if not gates.contains("vm=verified"):
        return "blocked-vm"
    if not gates.contains("host=verified"):
        return "blocked-host"
    if not gates.contains("posix=verified"):
        return "blocked-posix"
    if not gates.contains("pthread=verified"):
        return "blocked-pthread"
    if not gates.contains("dynload=verified"):
        return "blocked-dynload"
    if not gates.contains("async=verified"):
        return "blocked-async"
    if not gates.contains("pe=verified"):
        return "blocked-pe"
    return "ready"
