# List<T> - Generic list wrapper around native arrays
#
# Provides a mutable list class with push/pop and index access.
# This enables `List<f32>()` syntax used in GPU examples.

class List<T>:
    _items: [T]

    static fn new() -> List<T>:
        List(_items: [])

    me push(item: T):
        self._items = self._items + [item]

    fn len() -> i64:
        self._items.len()

    fn __getitem__(index: i64) -> T:
        self._items[index]

    me __setitem__(index: i64, value: T):
        self._items[index] = value

    fn is_empty() -> bool:
        self._items.len() == 0

    fn data_ptr() -> i64:
        self._items.data_ptr()

    fn ptr() -> i64:
        self._items.ptr()

    fn to_text() -> text:
        var result = "["
        for i in 0..self._items.len():
            if i > 0:
                result = result + ", "
            result = result + "{self._items[i]}"
        result = result + "]"
        result

export List
