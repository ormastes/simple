# System Config Model
#
# Minimal configurable desktop/system profile for SimpleOS primary apps.

struct SystemConfigProfile:
    theme: text
    font: text
    terminal: text
    notification_daemon: text
    clipboard_bridge: text
    service_manager: text
    bootloader: text
    standard_library: text

fn default_system_config_profile() -> SystemConfigProfile:
    SystemConfigProfile(
        theme: "dark_glass",
        font: "JetBrains Mono",
        terminal: "simple-terminal",
        notification_daemon: "mako-compatible",
        clipboard_bridge: "wl-copy",
        service_manager: "OpenRC",
        bootloader: "Limine",
        standard_library: "musl"
    )

fn system_config_sections() -> [text]:
    ["Appearance", "Input", "Services", "Boot", "Packages", "Security"]

fn system_config_update(profile: SystemConfigProfile, key: text, value: text) -> SystemConfigProfile:
    if key == "theme":
        return SystemConfigProfile(theme: value, font: profile.font, terminal: profile.terminal, notification_daemon: profile.notification_daemon, clipboard_bridge: profile.clipboard_bridge, service_manager: profile.service_manager, bootloader: profile.bootloader, standard_library: profile.standard_library)
    if key == "font":
        return SystemConfigProfile(theme: profile.theme, font: value, terminal: profile.terminal, notification_daemon: profile.notification_daemon, clipboard_bridge: profile.clipboard_bridge, service_manager: profile.service_manager, bootloader: profile.bootloader, standard_library: profile.standard_library)
    if key == "service_manager":
        return SystemConfigProfile(theme: profile.theme, font: profile.font, terminal: profile.terminal, notification_daemon: profile.notification_daemon, clipboard_bridge: profile.clipboard_bridge, service_manager: value, bootloader: profile.bootloader, standard_library: profile.standard_library)
    if key == "bootloader":
        return SystemConfigProfile(theme: profile.theme, font: profile.font, terminal: profile.terminal, notification_daemon: profile.notification_daemon, clipboard_bridge: profile.clipboard_bridge, service_manager: profile.service_manager, bootloader: value, standard_library: profile.standard_library)
    profile

fn system_config_validate(profile: SystemConfigProfile) -> bool:
    profile.theme != "" and profile.font != "" and profile.service_manager != "" and profile.bootloader != "" and profile.standard_library != ""

fn system_config_summary(profile: SystemConfigProfile) -> text:
    "theme={profile.theme} font={profile.font} services={profile.service_manager} boot={profile.bootloader} libc={profile.standard_library}"
