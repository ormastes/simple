# ============================================================================
# Binary ops / type conversion
# ============================================================================

extern fn rt_torch_torchtensor_binary_op(a: i64, b: i64, op: i64) -> i64
extern fn rt_torch_torchtensor_to_float(handle: i64) -> i64

fn dyn_torch_tensor_binary_op(a: i64, b: i64, op: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_binary_op(a, b, op)

fn dyn_torch_tensor_to_float(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_to_float(handle)

# ============================================================================
# Exports
# ============================================================================

export DynTorchValueCopyResult
export dyn_torch_tensor_from_values_1d, dyn_torch_tensor_from_values_2d, dyn_torch_tensor_copy_values
export dyn_torch_tensor_from_values_1d_result, dyn_torch_tensor_from_values_2d_result, dyn_torch_tensor_copy_values_result
export dyn_torch_tensor_sin, dyn_torch_tensor_cos, dyn_torch_tensor_tan
export dyn_torch_tensor_asin, dyn_torch_tensor_acos, dyn_torch_tensor_atan2
export dyn_torch_tensor_reshape_1d, dyn_torch_tensor_reshape_2d, dyn_torch_tensor_reshape_3d, dyn_torch_tensor_reshape_4d
export dyn_torch_tensor_permute_2d, dyn_torch_tensor_permute_3d, dyn_torch_tensor_permute_4d
export dyn_torch_tensor_cat_2, dyn_torch_tensor_cat_3, dyn_torch_tensor_cat_4
export dyn_torch_tensor_stack_2, dyn_torch_tensor_stack_3, dyn_torch_tensor_stack_4
export dyn_torch_tensor_binary_op, dyn_torch_tensor_to_float
