"""
Dynamic PyTorch SFFI — Tensor Construction and Value I/O

Runtime-optional tensor construction: create tensors from Simple values
and read values back out, without requiring a statically-linked libtorch.

Consumed by:
  - std.nogc_async_mut.linalg.backend_ops
    (dyn_torch_tensor_from_values_1d, dyn_torch_tensor_from_values_2d,
     dyn_torch_tensor_copy_values)
  - All torch variant shims via std.common.torch.dyn_sffi
"""

use std.common.torch.dyn_sffi_ops.{_ensure_loaded}

# ============================================================================
# Tensor construction from Simple values
# ============================================================================

fn dyn_torch_tensor_from_values_1d(values: [f64]) -> i64:
    """Construct a 1-D tensor from a Simple f64 array.

    Returns 0 if libtorch is not available.
    """
    if not _ensure_loaded():
        return 0
    val dims: [i64] = [values.len().to_i64()]
    rt_torch_tensor_from_data(values, dims)

fn dyn_torch_tensor_from_values_2d(values: [f64], rows: i64, cols: i64) -> i64:
    """Construct a 2-D tensor from a flat row-major f64 array.

    values must have rows * cols elements.
    Returns 0 if libtorch is not available.
    """
    if not _ensure_loaded():
        return 0
    val dims: [i64] = [rows, cols]
    rt_torch_tensor_from_data(values, dims)

fn dyn_torch_tensor_copy_values(handle: i64) -> [f64]:
    """Copy a tensor's data back to a Simple f64 array (1-D or flattened).

    Returns an empty array if libtorch is not available or handle is 0.
    """
    if not _ensure_loaded() or handle == 0:
        return []
    rt_torch_tensor_to_values(handle)

# ============================================================================
# Runtime externs
# ============================================================================

extern fn rt_torch_tensor_from_data(data: [f64], dims: [i64]) -> i64
extern fn rt_torch_tensor_to_values(handle: i64) -> [f64]
