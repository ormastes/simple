"""
Dynamic PyTorch SFFI — Tensor Construction and Value I/O

Runtime-optional tensor construction: create tensors from Simple values
and read values back out, without requiring a statically-linked libtorch.

Consumed by:
  - std.nogc_async_mut.linalg.backend_ops
    (dyn_torch_tensor_from_values_1d, dyn_torch_tensor_from_values_2d,
     dyn_torch_tensor_copy_values)
  - All torch variant shims via std.common.torch.dyn_sffi
"""

use std.common.torch.dyn_sffi_ops.{DynTorchTensorResult, dyn_torch_available}
use std.nogc_sync_mut.ptr.raw.{rt_alloc, rt_free, rt_ptr_read_i32}

struct DynTorchValueCopyResult:
    status: text
    reason: text
    values: [f64]

fn _dyn_torch_tensor_result(status: text, reason: text, handle: i64) -> DynTorchTensorResult:
    DynTorchTensorResult(status: status, reason: reason, handle: handle)

fn _dyn_torch_value_copy_result(status: text, reason: text, values: [f64]) -> DynTorchValueCopyResult:
    DynTorchValueCopyResult(status: status, reason: reason, values: values)

# ============================================================================
# Tensor construction from Simple values
# ============================================================================

fn dyn_torch_tensor_from_values_1d(values: [f64]) -> i64:
    """Construct a 1-D tensor from a Simple f64 array.

    Returns 0 if libtorch is not available.
    """
    dyn_torch_tensor_from_values_1d_result(values).handle

fn dyn_torch_tensor_from_values_1d_result(values: [f64]) -> DynTorchTensorResult:
    """Construct a 1-D tensor with explicit dynamic Torch status."""
    if not dyn_torch_available():
        return _dyn_torch_tensor_result("unavailable", "libtorch_unavailable", 0)
    val dims: [i64] = [values.len().to_i64()]
    val handle = rt_ps_torch_tensor_from_data(values, dims)
    if handle <= 0:
        return _dyn_torch_tensor_result("error", "runtime_returned_null_handle", 0)
    _dyn_torch_tensor_result("ready", "ok", handle)

fn dyn_torch_tensor_from_values_2d(values: [f64], rows: i64, cols: i64) -> i64:
    """Construct a 2-D tensor from a flat row-major f64 array.

    values must have rows * cols elements.
    Returns 0 if libtorch is not available.
    """
    dyn_torch_tensor_from_values_2d_result(values, rows, cols).handle

fn dyn_torch_tensor_from_values_2d_result(values: [f64], rows: i64, cols: i64) -> DynTorchTensorResult:
    """Construct a 2-D tensor with explicit dynamic Torch status."""
    if not dyn_torch_available():
        return _dyn_torch_tensor_result("unavailable", "libtorch_unavailable", 0)
    if rows <= 0 or cols <= 0 or values.len().to_i64() != rows * cols:
        return _dyn_torch_tensor_result("invalid", "invalid_shape", 0)
    val dims: [i64] = [rows, cols]
    val handle = rt_ps_torch_tensor_from_data(values, dims)
    if handle <= 0:
        return _dyn_torch_tensor_result("error", "runtime_returned_null_handle", 0)
    _dyn_torch_tensor_result("ready", "ok", handle)

fn dyn_torch_tensor_copy_values(handle: i64, expected_n: i64) -> [f64]:
    """Copy a tensor's data back to a Simple f64 array (1-D or flattened).

    Uses rt_torch_copy_data_to_cpu to extract f32 elements via a raw buffer.
    rt_torch_copy_data_to_cpu writes float32 (4 bytes/element); buffer_size is
    the element count, not the byte count.  Each f32 value is read back via
    rt_ptr_read_i32 + f32_from_bits and widened to f64.
    expected_n is a hint for the number of elements; the actual numel is used.
    Returns an empty array if libtorch is not available or handle is invalid.
    """
    dyn_torch_tensor_copy_values_result(handle, expected_n).values

fn dyn_torch_tensor_copy_values_result(handle: i64, expected_n: i64) -> DynTorchValueCopyResult:
    """Copy tensor data with explicit dynamic Torch status."""
    if not dyn_torch_available():
        return _dyn_torch_value_copy_result("unavailable", "libtorch_unavailable", [])
    if handle <= 0:
        return _dyn_torch_value_copy_result("invalid", "invalid_handle", [])
    val n = rt_torch_torchtensor_numel(handle)
    if n <= 0:
        return _dyn_torch_value_copy_result("invalid", "empty_or_invalid_tensor", [])
    val byte_count = n * 4
    val buf = rt_alloc(byte_count)
    if buf == 0:
        return _dyn_torch_value_copy_result("error", "buffer_allocation_failed", [])
    val copied = rt_torch_copy_data_to_cpu(handle, buf, n)
    var out: [f64] = []
    if copied > 0:
        var i = 0
        while i < n:
            val bits = rt_ptr_read_i32(buf, i * 4)
            out.push(f32_from_bits(bits as u32) as f64)
            i = i + 1
    rt_free(buf, byte_count)
    if copied <= 0:
        return _dyn_torch_value_copy_result("error", "runtime_copy_failed", [])
    _dyn_torch_value_copy_result("ready", "ok", out)

# ============================================================================
# Runtime externs (all confirmed in src/lib/nogc_sync_mut/torch/sffi.spl)
# ============================================================================

extern fn rt_ps_torch_tensor_from_data(data: [f64], dims: [i64]) -> i64
extern fn rt_torch_torchtensor_numel(handle: i64) -> i64
# buffer_size is element count; runtime writes float32 (4 bytes/element)
extern fn rt_torch_copy_data_to_cpu(handle: i64, buffer_ptr: i64, buffer_size: i64) -> i64
extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
extern fn f32_from_bits(bits: u32) -> f32

# ============================================================================
# Trig functions
# ============================================================================

extern fn rt_torch_torchtensor_sin(handle: i64) -> i64
extern fn rt_torch_torchtensor_cos(handle: i64) -> i64
extern fn rt_torch_torchtensor_tan(handle: i64) -> i64
extern fn rt_torch_torchtensor_asin(handle: i64) -> i64
extern fn rt_torch_torchtensor_acos(handle: i64) -> i64
extern fn rt_torch_torchtensor_atan2(a: i64, b: i64) -> i64

fn dyn_torch_tensor_sin(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_sin(handle)

fn dyn_torch_tensor_cos(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_cos(handle)

fn dyn_torch_tensor_tan(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_tan(handle)

fn dyn_torch_tensor_asin(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_asin(handle)

fn dyn_torch_tensor_acos(handle: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_acos(handle)

fn dyn_torch_tensor_atan2(a: i64, b: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_atan2(a, b)

# ============================================================================
# Shape manipulation
# ============================================================================

