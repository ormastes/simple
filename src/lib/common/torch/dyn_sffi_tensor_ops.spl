extern fn rt_torch_torchtensor_reshape_2d(handle: i64, d0: i64, d1: i64) -> i64
extern fn rt_torch_torchtensor_reshape_3d(handle: i64, d0: i64, d1: i64, d2: i64) -> i64
extern fn rt_torch_torchtensor_reshape_4d(handle: i64, d0: i64, d1: i64, d2: i64, d3: i64) -> i64
extern fn rt_torch_torchtensor_permute_2d(handle: i64, d0: i64, d1: i64) -> i64
extern fn rt_torch_torchtensor_permute_3d(handle: i64, d0: i64, d1: i64, d2: i64) -> i64
extern fn rt_torch_torchtensor_permute_4d(handle: i64, d0: i64, d1: i64, d2: i64, d3: i64) -> i64

fn dyn_torch_tensor_reshape_1d(handle: i64, d0: i64) -> i64:
    if not dyn_torch_available(): return 0
    rt_torch_torchtensor_reshape_1d(handle, d0)

