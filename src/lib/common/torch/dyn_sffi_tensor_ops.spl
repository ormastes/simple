extern fn rt_torch_torchtensor_cat_3(a: i64, b: i64, c: i64, dim: i64) -> i64
extern fn rt_torch_torchtensor_cat_4(a: i64, b: i64, c: i64, d: i64, dim: i64) -> i64
extern fn rt_torch_torchtensor_stack_2(a: i64, b: i64, dim: i64) -> i64
extern fn rt_torch_torchtensor_stack_3(a: i64, b: i64, c: i64, dim: i64) -> i64
extern fn rt_torch_torchtensor_stack_4(a: i64, b: i64, c: i64, d: i64, dim: i64) -> i64

