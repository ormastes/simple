# Dynamic PyTorch SFFI — common root re-export
#
# This is the canonical implementation referenced by variant shims:
#   - std.nogc_sync_mut.torch.dyn_sffi
#   - std.nogc_async_mut.torch.dyn_sffi
#   - std.gc_async_mut.torch.dyn_sffi
#
# The actual implementations live in:
#   - std.common.torch.dyn_sffi_ops        (availability, ops, algebra)
#   - std.common.torch.dyn_sffi_tensor_ops (tensor construction, value I/O)
#
# Consumers should import from the variant-specific path, not directly here.

export use std.common.torch.dyn_sffi_ops.*
export use std.common.torch.dyn_sffi_tensor_ops.*
