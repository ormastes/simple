    argv: [text]
    working_directory: text

class WineProcessSessionPlan:
    ok: bool
    error: text
    executable_path: text
    command: text
    readiness: text
    status: text

class WineProcessLaunchHandoff:
    ok: bool
    error: text
    command: text
    substrate_readiness: text
    status: text

class WineProcessExecutionResult:
    ok: bool
    error: text
    command: text
    stdout: text
    exit_code: i64
    status: text

class WineProcessImageValidationResult:
    ok: bool
    error: text
    command: text
    machine: text
    subsystem: text
    status: text

class WineProcessImportInspectionResult:
    ok: bool
    error: text
    command: text
    dll_name: text
    symbol_count: i64
    symbols: [text]
    status: text

class WineProcessImportBindingResult:
    ok: bool
    error: text
    command: text
    dll_name: text
    call_sequence: text
    binding_count: i64
    status: text

class WineProcessThunkPatchPlanResult:
    ok: bool
    error: text
    command: text
    dll_name: text
    patch_count: i64
    evidence: text
    status: text

