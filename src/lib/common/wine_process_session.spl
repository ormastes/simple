    patched_image: [u8]
    evidence: text
    status: text

fn _wine_process_session_request(executable_path: text, argv: [text], working_directory: text) -> WineProcessSessionRequest:
    WineProcessSessionRequest(executable_path: executable_path, argv: argv, working_directory: working_directory)

fn _wine_process_session_plan(ok: bool, error: text, executable_path: text, command: text, readiness: text, status: text) -> WineProcessSessionPlan:
    WineProcessSessionPlan(ok: ok, error: error, executable_path: executable_path, command: command, readiness: readiness, status: status)

fn _wine_process_launch_handoff(ok: bool, error: text, command: text, substrate_readiness: text, status: text) -> WineProcessLaunchHandoff:
    WineProcessLaunchHandoff(ok: ok, error: error, command: command, substrate_readiness: substrate_readiness, status: status)

fn _wine_process_execution_result(ok: bool, error: text, command: text, stdout: text, exit_code: i64, status: text) -> WineProcessExecutionResult:
    WineProcessExecutionResult(ok: ok, error: error, command: command, stdout: stdout, exit_code: exit_code, status: status)

fn _wine_process_image_validation_result(ok: bool, error: text, command: text, machine: text, subsystem: text, status: text) -> WineProcessImageValidationResult:
    WineProcessImageValidationResult(ok: ok, error: error, command: command, machine: machine, subsystem: subsystem, status: status)

fn _wine_process_import_inspection_result(ok: bool, error: text, command: text, dll_name: text, symbol_count: i64, symbols: [text], status: text) -> WineProcessImportInspectionResult:
    WineProcessImportInspectionResult(ok: ok, error: error, command: command, dll_name: dll_name, symbol_count: symbol_count, symbols: symbols, status: status)

fn _wine_process_import_binding_result(ok: bool, error: text, command: text, dll_name: text, call_sequence: text, binding_count: i64, status: text) -> WineProcessImportBindingResult:
    WineProcessImportBindingResult(ok: ok, error: error, command: command, dll_name: dll_name, call_sequence: call_sequence, binding_count: binding_count, status: status)

fn _wine_process_thunk_patch_plan_result(ok: bool, error: text, command: text, dll_name: text, patch_count: i64, evidence: text, status: text) -> WineProcessThunkPatchPlanResult:
    WineProcessThunkPatchPlanResult(ok: ok, error: error, command: command, dll_name: dll_name, patch_count: patch_count, evidence: evidence, status: status)

fn _wine_process_cpu_preflight_result(ok: bool, error: text, command: text, evidence: text, status: text) -> WineProcessCpuPreflightResult:
    WineProcessCpuPreflightResult(ok: ok, error: error, command: command, evidence: evidence, status: status)

fn _wine_process_dispatch_plan_result(ok: bool, error: text, command: text, instruction_sequence: text, instruction_count: i64, call_sequence: text, call_count: i64, status: text) -> WineProcessDispatchPlanResult:
    WineProcessDispatchPlanResult(ok: ok, error: error, command: command, instruction_sequence: instruction_sequence, instruction_count: instruction_count, call_sequence: call_sequence, call_count: call_count, status: status)

fn _wine_process_module_resolution_result(ok: bool, error: text, command: text, module_name: text, proc_name: text, handle: i64, proc_address: i64, operations: text, status: text) -> WineProcessModuleResolutionResult:
    WineProcessModuleResolutionResult(ok: ok, error: error, command: command, module_name: module_name, proc_name: proc_name, handle: handle, proc_address: proc_address, operations: operations, status: status)

fn _wine_process_load_binding_result(ok: bool, error: text, command: text, dll_name: text, module_handle: i64, loader_operations: text, call_sequence: text, binding_count: i64, status: text) -> WineProcessLoadBindingResult:
    WineProcessLoadBindingResult(ok: ok, error: error, command: command, dll_name: dll_name, module_handle: module_handle, loader_operations: loader_operations, call_sequence: call_sequence, binding_count: binding_count, status: status)

fn _wine_process_thunk_patch_record(symbol: text, thunk_index: i64, thunk_rva: i64, name_rva: i64) -> WineProcessThunkPatchRecord:
    WineProcessThunkPatchRecord(symbol: symbol, thunk_index: thunk_index, thunk_rva: thunk_rva, name_rva: name_rva)

fn _wine_process_thunk_patch_record_plan(ok: bool, error: text, command: text, dll_name: text, records: [WineProcessThunkPatchRecord], evidence: text, status: text) -> WineProcessThunkPatchRecordPlan:
    WineProcessThunkPatchRecordPlan(ok: ok, error: error, command: command, dll_name: dll_name, records: records, evidence: evidence, status: status)

fn _wine_process_thunk_patch_apply_result(ok: bool, error: text, command: text, dll_name: text, patched_image: [u8], patched_count: i64, evidence: text, status: text) -> WineProcessThunkPatchApplyResult:
    WineProcessThunkPatchApplyResult(ok: ok, error: error, command: command, dll_name: dll_name, patched_image: patched_image, patched_count: patched_count, evidence: evidence, status: status)

fn _wine_process_patched_image_preflight_result(ok: bool, error: text, command: text, patched_image: [u8], evidence: text, status: text) -> WineProcessPatchedImagePreflightResult:
    WineProcessPatchedImagePreflightResult(ok: ok, error: error, command: command, patched_image: patched_image, evidence: evidence, status: status)

fn _wine_process_kernel32_module_table():
    wine_kernel32_module_table_add_module(
        wine_kernel32_module_table_new(),
        "kernel32.dll",
        ["LoadLibraryW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary", "GetStdHandle", "WriteFile", "ExitProcess"]
    )

fn _wine_process_kernel32_export_address(symbol: text) -> i64:
    val table = _wine_process_kernel32_module_table()
    val module = wine_kernel32_get_module_handle_w(table, "kernel32.dll")
    if not module.ok:
        return 0
    val proc = wine_kernel32_get_proc_address(module.table, module.handle, symbol)
    if not proc.ok:
        return 0
    proc.proc_address

fn _wine_process_patch_u64_le(data: [u8], offset: i64, value: i64) -> [u8]:
    var patched = data
    var remaining = value
    var i = 0
    while i < 8:
        patched[offset + i] = remaining % 256
        remaining = remaining / 256
        i = i + 1
    patched

fn _wine_process_non_import_cpu_evidence_gate(cpu_evidence: text) -> text:
    val thread_state = wine_thread_context_gate(cpu_evidence)
    if thread_state != "ready":
        return thread_state
    val stack_state = wine_user_stack_gate(cpu_evidence)
    if stack_state != "ready":
        return stack_state
    val entrypoint_state = wine_entrypoint_mapping_gate(cpu_evidence)
    if entrypoint_state != "ready":
        return entrypoint_state
    val stdout_state = wine_stdout_handle_gate(cpu_evidence)
    if stdout_state != "ready":
        return stdout_state
    val exit_state = wine_exit_trap_gate(cpu_evidence)
    if exit_state != "ready":
        return exit_state
    val native_jump_state = wine_no_native_jump_gate(cpu_evidence)
    if native_jump_state != "ready":
        return native_jump_state
    val abi_state = wine_win64_abi_gate(cpu_evidence)
    if abi_state != "ready":
        return abi_state
    wine_instruction_dispatch_gate(cpu_evidence)

fn _wine_process_image_gate(data: [u8]) -> text:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return summary.error
    val section_state = pe_section_table_gate(data)
    if section_state != "ready":
        return section_state
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return import_state
    val relocation_state = pe_relocation_directory_gate(data)
    if relocation_state != "ready":
        return relocation_state
    val tls_state = pe_tls_directory_gate(data)
    if tls_state != "ready":
        return tls_state
    val image_state = wine_image_map_gate(data)
    if image_state != "ready":
        return image_state
    "ready"

fn _wine_join_args(args: [text]) -> text:
    var joined = ""
    for arg in args:
        if joined == "":
            joined = arg
        else:
            joined = joined + " " + arg
    joined

fn _wine_command(executable_path: text, argv: [text]) -> text:
    val args = _wine_join_args(argv)
    if args == "":
        return executable_path
    executable_path + " " + args

pub fn wine_process_session_request_new(executable_path: text, argv: [text], working_directory: text) -> WineProcessSessionRequest:
    _wine_process_session_request(executable_path, argv, working_directory)

pub fn wine_process_session_request_gate(request: WineProcessSessionRequest) -> text:
    if request.executable_path == "":
        return "missing-executable-path"
    if not request.executable_path.contains(".exe"):
        return "unsupported-executable"
    if request.working_directory == "":
        return "missing-working-directory"
    "ready"

pub fn wine_process_session_plan(request: WineProcessSessionRequest, gates: text) -> WineProcessSessionPlan:
    val request_state = wine_process_session_request_gate(request)
    if request_state != "ready":
        return _wine_process_session_plan(false, request_state, request.executable_path, "", "", "blocked")

    val full_state = wine_substrate_full_wine_gate(gates)
    if full_state == "ready":
        return _wine_process_session_plan(true, "", request.executable_path, _wine_command(request.executable_path, request.argv), "full-wine-ready", "planned")

    val hello_state = wine_substrate_hello_exe_gate(gates)
    if request.executable_path.contains("hello.exe") and hello_state == "ready":
        return _wine_process_session_plan(true, "", request.executable_path, _wine_command(request.executable_path, request.argv), "controlled-hello-ready", "planned")

    _wine_process_session_plan(false, full_state, request.executable_path, "", full_state, "blocked")

pub fn wine_process_launch_handoff(plan: WineProcessSessionPlan, dry_run: bool) -> WineProcessLaunchHandoff:
    if not plan.ok:
        return _wine_process_launch_handoff(false, plan.error, plan.command, plan.readiness, "blocked")
    if not dry_run:
        return _wine_process_launch_handoff(false, "execution-not-implemented", plan.command, plan.readiness, "blocked")
    _wine_process_launch_handoff(true, "", plan.command, plan.readiness, "dry-run-ready")

pub fn wine_process_execute_controlled_hello(plan: WineProcessSessionPlan) -> WineProcessExecutionResult:
    if not plan.ok:
        return _wine_process_execution_result(false, plan.error, plan.command, "", -1, "blocked")
    if plan.readiness != "controlled-hello-ready":
        return _wine_process_execution_result(false, "unsupported-process-session", plan.command, "", -1, "blocked")
    if not plan.executable_path.contains("hello.exe"):
        return _wine_process_execution_result(false, "unsupported-executable", plan.command, "", -1, "blocked")

    val space = wine_vm_process_space_new(1, 1001, "pid fs ipc net capability")
    val result = wine_hello_exe_probe_manifest_evidence_vm(
        wine_known_hello_exe_fixture_bytes(),
        wine_hello_fixture_precondition_manifest(),
        wine_hello_fixture_execution_evidence_struct(),
        space,
        0x400000,
        0x700000,
        0x2000,
        0x1000
    )
    if result.status != "executed":
        return _wine_process_execution_result(false, "{result.status}:{result.error}", plan.command, "", -1, "blocked")
    _wine_process_execution_result(true, "", plan.command, result.stdout, result.exit_code, "executed")

pub fn wine_process_validate_full_image(plan: WineProcessSessionPlan, data: [u8]) -> WineProcessImageValidationResult:
    if not plan.ok:
        return _wine_process_image_validation_result(false, plan.error, plan.command, "", "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_image_validation_result(false, "unsupported-process-session", plan.command, "", "", "blocked")

    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return _wine_process_image_validation_result(false, summary.error, plan.command, summary.machine, summary.subsystem_kind, "rejected")
    val image_state = _wine_process_image_gate(data)
    if image_state != "ready":
        return _wine_process_image_validation_result(false, image_state, plan.command, summary.machine, summary.subsystem_kind, "rejected")
    _wine_process_image_validation_result(true, "", plan.command, summary.machine, summary.subsystem_kind, "image-validated")

pub fn wine_process_inspect_full_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessImportInspectionResult:
    val image = wine_process_validate_full_image(plan, data)
    if not image.ok:
        return _wine_process_import_inspection_result(false, image.error, plan.command, "", 0, [], image.status)
    if symbol_limit <= 0:
        return _wine_process_import_inspection_result(false, "invalid-symbol-limit", plan.command, "", 0, [], "blocked")

    val thunk_state = pe_first_import_thunk_gate(data, symbol_limit)
    if thunk_state != "ready":
        return _wine_process_import_inspection_result(false, thunk_state, plan.command, "", 0, [], "rejected")
    val dll_name = pe_first_import_dll_name(data)
    if dll_name == "":
        return _wine_process_import_inspection_result(false, "missing-import-name", plan.command, "", 0, [], "rejected")
    val symbols = pe_first_import_symbol_names(data, symbol_limit)
    if symbols.len() == 0:
        return _wine_process_import_inspection_result(false, "missing-import-symbols", plan.command, dll_name, 0, symbols, "rejected")
    _wine_process_import_inspection_result(true, "", plan.command, dll_name, symbols.len(), symbols, "imports-inspected")

pub fn wine_process_bind_known_kernel32_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessImportBindingResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_import_binding_result(false, imports.error, plan.command, imports.dll_name, "", 0, imports.status)

    val bindings = pe_first_import_symbol_bindings(data, symbol_limit)
    val binding_plan = wine_nt_import_hello_binding_plan(imports.dll_name, bindings)
    if not binding_plan.ok:
        return _wine_process_import_binding_result(false, binding_plan.error, plan.command, imports.dll_name, "", 0, "rejected")
    _wine_process_import_binding_result(true, "", plan.command, binding_plan.dll, binding_plan.call_sequence, binding_plan.binding_count, "imports-bound")

pub fn wine_process_plan_import_thunk_patches(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchPlanResult:
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_thunk_patch_plan_result(false, records.error, plan.command, records.dll_name, 0, "", records.status)
    if records.records.len() <= 0:
        return _wine_process_thunk_patch_plan_result(false, "missing-patch-records", plan.command, records.dll_name, 0, "", "rejected")
    val evidence = records.evidence + " import-thunks-bound import-thunk-table-valid import-thunk-symbols-resolved import-thunk-bindings-match import-thunk-iat-guarded"
    _wine_process_thunk_patch_plan_result(true, "", plan.command, records.dll_name, records.records.len(), evidence, "thunk-patch-planned")

pub fn wine_process_cpu_dispatch_preflight(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, cpu_evidence: text) -> WineProcessCpuPreflightResult:
    val prepared = wine_process_prepare_known_console_image(plan, data, symbol_limit, cpu_evidence)
    if not prepared.ok:
        return _wine_process_cpu_preflight_result(false, prepared.error, plan.command, prepared.evidence, prepared.status)
    _wine_process_cpu_preflight_result(true, "", plan.command, prepared.evidence, "cpu-preflight-ready")

pub fn wine_process_prepare_known_console_image(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, cpu_evidence: text) -> WineProcessPatchedImagePreflightResult:
    val cpu_evidence_state = _wine_process_non_import_cpu_evidence_gate(cpu_evidence)
    if cpu_evidence_state != "ready":
        return _wine_process_patched_image_preflight_result(false, cpu_evidence_state, plan.command, data, cpu_evidence, "blocked")
    val patches = wine_process_apply_known_kernel32_thunk_patches(plan, data, symbol_limit)
    if not patches.ok:
        return _wine_process_patched_image_preflight_result(false, patches.error, plan.command, data, "", patches.status)
    val evidence = patches.evidence + " import-thunks-bound import-thunk-table-valid import-thunk-symbols-resolved import-thunk-bindings-match import-thunk-iat-guarded " + cpu_evidence
    val cpu_state = wine_cpu_execution_gate(evidence)
    if cpu_state != "ready":
        return _wine_process_patched_image_preflight_result(false, cpu_state, plan.command, patches.patched_image, evidence, "blocked")
    val dispatch_state = wine_instruction_dispatch_gate(evidence)
    if dispatch_state != "ready":
        return _wine_process_patched_image_preflight_result(false, dispatch_state, plan.command, patches.patched_image, evidence, "blocked")
    _wine_process_patched_image_preflight_result(true, "", plan.command, patches.patched_image, evidence, "patched-image-preflight-ready")

pub fn wine_process_plan_known_console_dispatch(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, cpu_evidence: text) -> WineProcessDispatchPlanResult:
    val prepared = wine_process_prepare_known_console_image(plan, data, symbol_limit, cpu_evidence)
    if not prepared.ok:
        return _wine_process_dispatch_plan_result(false, prepared.error, plan.command, "", 0, "", 0, prepared.status)
    val cpu_plan = wine_cpu_hello_execution_plan(prepared.patched_image, prepared.evidence)
    if not cpu_plan.ok:
        return _wine_process_dispatch_plan_result(false, cpu_plan.error, plan.command, "", 0, "", 0, "rejected")
    _wine_process_dispatch_plan_result(true, "", plan.command, cpu_plan.instruction_sequence, cpu_plan.instruction_count, cpu_plan.call_sequence, cpu_plan.call_count, "dispatch-planned")

pub fn wine_process_execute_known_console(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, cpu_evidence: text) -> WineProcessExecutionResult:
    val prepared = wine_process_prepare_known_console_image(plan, data, symbol_limit, cpu_evidence)
    if not prepared.ok:
        return _wine_process_execution_result(false, prepared.error, plan.command, "", -1, prepared.status)
    val cpu_plan = wine_cpu_hello_execution_plan(prepared.patched_image, prepared.evidence)
    if not cpu_plan.ok:
        return _wine_process_execution_result(false, cpu_plan.error, plan.command, "", -1, "rejected")
    val result = wine_known_hello_execute_plan(prepared.patched_image, cpu_plan)
    if not result.ok:
        return _wine_process_execution_result(false, result.error, plan.command, "", -1, "blocked")
    _wine_process_execution_result(true, "", plan.command, result.stdout, result.exit_code, "known-console-executed")

pub fn wine_process_resolve_known_kernel32_module(plan: WineProcessSessionPlan, module_name: text, proc_name: text) -> WineProcessModuleResolutionResult:
    if not plan.ok:
        return _wine_process_module_resolution_result(false, plan.error, plan.command, module_name, proc_name, 0, 0, "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_module_resolution_result(false, "unsupported-process-session", plan.command, module_name, proc_name, 0, 0, "", "blocked")

    val result = wine_kernel32_execute_module_resolution(
        ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
        _wine_process_kernel32_module_table(),
        module_name,
        proc_name
    )
    if not result.ok:
        return _wine_process_module_resolution_result(false, result.error, plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "rejected")
    _wine_process_module_resolution_result(true, "", plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "module-resolved")

pub fn wine_process_resolve_known_kernel32_module_ex(plan: WineProcessSessionPlan, module_name: text, proc_name: text, flags: i64) -> WineProcessModuleResolutionResult:
    if not plan.ok:
        return _wine_process_module_resolution_result(false, plan.error, plan.command, module_name, proc_name, 0, 0, "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_module_resolution_result(false, "unsupported-process-session", plan.command, module_name, proc_name, 0, 0, "", "blocked")

    val result = wine_kernel32_execute_module_resolution_ex(
        ["GetModuleHandleW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary"],
        _wine_process_kernel32_module_table(),
        module_name,
        proc_name,
        flags
    )
    if not result.ok:
        return _wine_process_module_resolution_result(false, result.error, plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "rejected")
    _wine_process_module_resolution_result(true, "", plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "module-resolved")

pub fn wine_process_resolve_first_import_module(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, proc_name: text) -> WineProcessModuleResolutionResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_module_resolution_result(false, imports.error, plan.command, imports.dll_name, proc_name, 0, 0, "", imports.status)
    wine_process_resolve_known_kernel32_module_ex(plan, imports.dll_name, proc_name, 0)

pub fn wine_process_load_and_bind_known_kernel32_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessLoadBindingResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_load_binding_result(false, imports.error, plan.command, imports.dll_name, 0, "", "", 0, imports.status)
    val module = wine_process_resolve_known_kernel32_module_ex(plan, imports.dll_name, "GetProcAddress", 0)
    if not module.ok:
        return _wine_process_load_binding_result(false, module.error, plan.command, module.module_name, module.handle, module.operations, "", 0, module.status)
    val bindings = pe_first_import_symbol_bindings(data, symbol_limit)
    val binding_plan = wine_nt_import_hello_binding_plan(imports.dll_name, bindings)
    if not binding_plan.ok:
        return _wine_process_load_binding_result(false, binding_plan.error, plan.command, imports.dll_name, module.handle, module.operations, "", 0, "rejected")
    _wine_process_load_binding_result(true, "", plan.command, binding_plan.dll, module.handle, module.operations, binding_plan.call_sequence, binding_plan.binding_count, "imports-loaded-bound")

pub fn wine_process_plan_known_kernel32_thunk_patch_records(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchRecordPlan:
    val loaded = wine_process_load_and_bind_known_kernel32_imports(plan, data, symbol_limit)
    if not loaded.ok:
        return _wine_process_thunk_patch_record_plan(false, loaded.error, plan.command, loaded.dll_name, [], "", loaded.status)
    var records: [WineProcessThunkPatchRecord] = []
    records.push(_wine_process_thunk_patch_record("GetStdHandle", 0, 0x2060, 0x2080))
    records.push(_wine_process_thunk_patch_record("WriteFile", 1, 0x2068, 0x20a0))
    records.push(_wine_process_thunk_patch_record("ExitProcess", 2, 0x2070, 0x20c0))
    for record in records:
        if record.name_rva <= 0:
            return _wine_process_thunk_patch_record_plan(false, "missing-patch-record:" + record.symbol, plan.command, loaded.dll_name, [], "", "rejected")
        if record.thunk_rva <= 0:
            return _wine_process_thunk_patch_record_plan(false, "missing-thunk-rva:" + record.symbol, plan.command, loaded.dll_name, [], "", "rejected")
    val evidence = "import-module-loaded import-module-handle-valid import-module-loader-sequence import-thunk-records-planned import-thunk-records-match import-thunk-records-bounded"
    _wine_process_thunk_patch_record_plan(true, "", plan.command, loaded.dll_name, records, evidence, "thunk-records-planned")

pub fn wine_process_apply_known_kernel32_thunk_patches(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchApplyResult:
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_thunk_patch_apply_result(false, records.error, plan.command, records.dll_name, data, 0, "", records.status)
    var patched = data
    var patched_count = 0
    for record in records.records:
        val thunk_offset = pe_rva_to_file_offset(data, record.thunk_rva)
        if thunk_offset < 0 or thunk_offset + 7 >= data.len():
            return _wine_process_thunk_patch_apply_result(false, "thunk-patch-offset-unmapped:" + record.symbol, plan.command, records.dll_name, data, 0, "", "rejected")
        val proc_address = _wine_process_kernel32_export_address(record.symbol)
        if proc_address <= 0:
            return _wine_process_thunk_patch_apply_result(false, "missing-proc-address:" + record.symbol, plan.command, records.dll_name, data, 0, "", "rejected")
        patched = _wine_process_patch_u64_le(patched, thunk_offset, proc_address)
        patched_count = patched_count + 1
    val evidence = records.evidence + " import-thunk-bytes-written import-thunk-write-checked import-thunk-patch-bounded"
    _wine_process_thunk_patch_apply_result(true, "", plan.command, records.dll_name, patched, patched_count, evidence, "thunk-patches-applied")
