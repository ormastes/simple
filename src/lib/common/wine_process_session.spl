    val mapped = wine_process_map_known_console_image(plan, data, symbol_limit, cpu_evidence)
    _wine_process_cpu_dispatch_preflight_from_mapped(plan, mapped)

pub fn wine_process_cpu_dispatch_preflight_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, symbol_limit: i64, cpu_evidence: text, vm_writes: WinePebTebVmWriteResult) -> WineProcessCpuPreflightResult:
    val mapped = wine_process_map_known_console_image_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, symbol_limit, cpu_evidence, vm_writes)
