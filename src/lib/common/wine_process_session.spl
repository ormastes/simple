    command: text
    evidence: text
    status: text

class WineProcessDispatchPlanResult:
    ok: bool
    error: text
    command: text
    instruction_sequence: text
    instruction_count: i64
    call_sequence: text
    call_count: i64
    status: text

class WineProcessModuleResolutionResult:
    ok: bool
    error: text
    command: text
    module_name: text
    proc_name: text
    handle: i64
    proc_address: i64
    operations: text
    status: text

class WineProcessLoadBindingResult:
    ok: bool
    error: text
    command: text
    dll_name: text
    module_handle: i64
    loader_operations: text
    call_sequence: text
    binding_count: i64
    status: text

class WineProcessThunkPatchRecord:
    symbol: text
