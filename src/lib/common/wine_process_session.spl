fn _wine_process_kernel32_module_table():
    wine_kernel32_module_table_add_module(
        wine_kernel32_module_table_new(),
        "kernel32.dll",
        ["LoadLibraryW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary", "GetStdHandle", "WriteFile", "ExitProcess"]
    )

fn _wine_process_known_import_module_table():
    var table = _wine_process_kernel32_module_table()
    table = wine_kernel32_module_table_add_module(
        table,
        "user32.dll",
        ["CreateWindowExW", "ShowWindow", "UpdateWindow", "DefWindowProcW", "GetMessageW", "MessageBoxW"]
    )
    wine_kernel32_module_table_add_module(
        table,
        "gdi32.dll",
        ["CreateCompatibleDC", "TextOutW", "BitBlt", "DeleteDC"]
    )

fn _wine_process_kernel32_export_address(symbol: text) -> i64:
    val table = _wine_process_kernel32_module_table()
    val module = wine_kernel32_get_module_handle_w(table, "kernel32.dll")
    if not module.ok:
        return 0
    val proc = wine_kernel32_get_proc_address(module.table, module.handle, symbol)
    if not proc.ok:
        return 0
    proc.proc_address

fn _wine_process_import_dependency_supported(module_name: text) -> bool:
    val normalized = module_name.lower()
    normalized == "kernel32.dll" or normalized == "user32.dll" or normalized == "gdi32.dll"

fn _wine_process_text_seen(items: [text], value: text) -> bool:
    val normalized = value.lower()
    for item in items:
        if item.lower() == normalized:
            return true
    false

fn _wine_process_max_module_ref_count(table: WineKernel32ModuleTable) -> i64:
    var max_ref_count = 0
    for module in table.modules:
        if module.ref_count > max_ref_count:
            max_ref_count = module.ref_count
    max_ref_count

fn _wine_process_patch_u64_le(data: [u8], offset: i64, value: i64) -> [u8]:
    var patched = data
    var remaining = value
    var i = 0
    while i < 8:
        patched[offset + i] = remaining % 256
        remaining = remaining / 256
        i = i + 1
    patched

fn _wine_process_read_u64_le(data: [u8], offset: i64) -> i64:
    if offset + 7 >= data.len():
        return 0
    var value = 0
    var shift = 0
    var i = 0
    while i < 8:
        value = value | ((data[offset + i] as i64) << shift)
        shift = shift + 8
        i = i + 1
    value

fn _wine_process_non_import_cpu_evidence_gate(cpu_evidence: text) -> text:
    val thread_state = wine_thread_context_gate(cpu_evidence)
    if thread_state != "ready":
        return thread_state
    val stack_state = wine_user_stack_gate(cpu_evidence)
    if stack_state != "ready":
        return stack_state
    val entrypoint_state = wine_entrypoint_mapping_gate(cpu_evidence)
    if entrypoint_state != "ready":
        return entrypoint_state
    val stdout_state = wine_stdout_handle_gate(cpu_evidence)
    if stdout_state != "ready":
        return stdout_state
    val exit_state = wine_exit_trap_gate(cpu_evidence)
    if exit_state != "ready":
        return exit_state
    val native_jump_state = wine_no_native_jump_gate(cpu_evidence)
    if native_jump_state != "ready":
        return native_jump_state
    val abi_state = wine_win64_abi_gate(cpu_evidence)
    if abi_state != "ready":
        return abi_state
    wine_instruction_dispatch_gate(cpu_evidence)

fn _wine_process_image_gate(data: [u8]) -> text:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return summary.error
    val section_state = pe_section_table_gate(data)
    if section_state != "ready":
        return section_state
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    val import_state = pe_import_descriptor_table_gate(data, 16, 128)
    if import_state != "ready":
        return import_state
    val relocation_state = pe_relocation_directory_gate(data)
    if relocation_state != "ready":
        return relocation_state
    val tls_state = pe_tls_directory_gate(data)
    if tls_state != "ready":
        return tls_state
    val image_state = wine_image_map_gate(data)
    if image_state != "ready":
        return image_state
    "ready"

fn _wine_process_entry_fault(entry_address: i64) -> WineVmFault:
    WineVmFault(process_id: 1, thread_id: 1, address: entry_address, access: "execute", policy: "deliver-seh")

fn _wine_join_args(args: [text]) -> text:
    var joined = ""
    for arg in args:
        if joined == "":
            joined = arg
        else:
            joined = joined + " " + arg
    joined

fn _wine_command(executable_path: text, argv: [text]) -> text:
    val args = _wine_join_args(argv)
    if args == "":
        return executable_path
    executable_path + " " + args

pub fn wine_process_session_request_new(executable_path: text, argv: [text], working_directory: text) -> WineProcessSessionRequest:
    _wine_process_session_request(executable_path, argv, working_directory)

pub fn wine_process_session_request_gate(request: WineProcessSessionRequest) -> text:
    if request.executable_path == "":
        return "missing-executable-path"
    if not request.executable_path.contains(".exe"):
        return "unsupported-executable"
    if request.working_directory == "":
        return "missing-working-directory"
    "ready"

pub fn wine_process_session_plan(request: WineProcessSessionRequest, gates: text) -> WineProcessSessionPlan:
    val request_state = wine_process_session_request_gate(request)
    if request_state != "ready":
        return _wine_process_session_plan(false, request_state, request.executable_path, "", "", "blocked")

    val full_state = wine_substrate_full_wine_gate(gates)
    if full_state == "ready":
        return _wine_process_session_plan(true, "", request.executable_path, _wine_command(request.executable_path, request.argv), "full-wine-ready", "planned")

    val hello_state = wine_substrate_hello_exe_gate(gates)
    if request.executable_path.contains("hello.exe") and hello_state == "ready":
        return _wine_process_session_plan(true, "", request.executable_path, _wine_command(request.executable_path, request.argv), "controlled-hello-ready", "planned")

    _wine_process_session_plan(false, full_state, request.executable_path, "", full_state, "blocked")

pub fn wine_process_launch_handoff(plan: WineProcessSessionPlan, dry_run: bool) -> WineProcessLaunchHandoff:
    if not plan.ok:
        return _wine_process_launch_handoff(false, plan.error, plan.command, plan.readiness, "blocked")
    if not dry_run:
        return _wine_process_launch_handoff(false, "execution-not-implemented", plan.command, plan.readiness, "blocked")
    _wine_process_launch_handoff(true, "", plan.command, plan.readiness, "dry-run-ready")

pub fn wine_process_execute_controlled_hello(plan: WineProcessSessionPlan) -> WineProcessExecutionResult:
    if not plan.ok:
        return _wine_process_execution_result(false, plan.error, plan.command, "", -1, "blocked")
    if plan.readiness != "controlled-hello-ready":
        return _wine_process_execution_result(false, "unsupported-process-session", plan.command, "", -1, "blocked")
    if not plan.executable_path.contains("hello.exe"):
        return _wine_process_execution_result(false, "unsupported-executable", plan.command, "", -1, "blocked")

    val space = wine_vm_process_space_new(1, 1001, "pid fs ipc net capability")
    val result = wine_hello_exe_probe_manifest_evidence_vm(
        wine_known_hello_exe_fixture_bytes(),
        wine_hello_fixture_precondition_manifest(),
        wine_hello_fixture_execution_evidence_struct(),
        space,
        0x400000,
        0x700000,
        0x2000,
        0x1000
    )
    if result.status != "executed":
        return _wine_process_execution_result(false, "{result.status}:{result.error}", plan.command, "", -1, "blocked")
    _wine_process_execution_result(true, "", plan.command, result.stdout, result.exit_code, "executed")

pub fn wine_process_validate_full_image(plan: WineProcessSessionPlan, data: [u8]) -> WineProcessImageValidationResult:
    if not plan.ok:
        return _wine_process_image_validation_result(false, plan.error, plan.command, "", "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_image_validation_result(false, "unsupported-process-session", plan.command, "", "", "blocked")

    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return _wine_process_image_validation_result(false, summary.error, plan.command, summary.machine, summary.subsystem_kind, "rejected")
    val image_state = _wine_process_image_gate(data)
    if image_state != "ready":
        return _wine_process_image_validation_result(false, image_state, plan.command, summary.machine, summary.subsystem_kind, "rejected")
    _wine_process_image_validation_result(true, "", plan.command, summary.machine, summary.subsystem_kind, "image-validated")

pub fn wine_process_prepare_full_image_handoff(plan: WineProcessSessionPlan, data: [u8]) -> WineProcessFullImageHandoff:
    val image = wine_process_validate_full_image(plan, data)
    if not image.ok:
        return _wine_process_full_image_handoff(false, image.error, plan.command, 0, 0, 0, "", image.status)
    val image_size = pe_size_of_image(data)
    if image_size <= 0:
        return _wine_process_full_image_handoff(false, "missing-image-size", plan.command, 0, 0, 0, "", "rejected")
    val mapped_base = 0x400000
    val mapped = wine_image_map_into_vm_process(
        data,
        wine_vm_process_space_new(1, 1, "pid fs ipc net capability"),
        mapped_base,
        0x700000,
        0x2000,
        0x1000
    )
    if not mapped.ok:
        return _wine_process_full_image_handoff(false, mapped.state, plan.command, mapped_base, image_size, mapped.entry_address, "", "blocked")
    val production_state = wine_vm_production_gate(mapped.space, _wine_process_entry_fault(mapped.entry_address))
    if production_state != "ready":
        return _wine_process_full_image_handoff(false, production_state, plan.command, mapped_base, image_size, mapped.entry_address, "", "blocked")
    val evidence = "full-image-validated arbitrary-process-image-handoff process-image-mapped os-process os-address-space os-vma image-map thread-stack guard-page stack-growth exec-perm no-host-code-jump"
    _wine_process_full_image_handoff(true, "", plan.command, mapped_base, image_size, mapped.entry_address, evidence, "full-image-handoff-ready")

pub fn wine_process_prepare_full_image_handoff_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], vm_writes: WinePebTebVmWriteResult) -> WineProcessFullImageHandoff:
    val vm_evidence = _wine_process_full_image_peb_teb_vm_write_evidence(vm_writes)
    if vm_evidence == "":
        return _wine_process_full_image_handoff(false, _wine_process_full_image_peb_teb_vm_write_error(vm_writes), plan.command, 0, 0, 0, vm_writes.operations + " full-image-handoff-blocked no-arbitrary-execution", "rejected")
    val handoff = wine_process_prepare_full_image_handoff(plan, data)
    if not handoff.ok:
        return handoff
    handoff.evidence = vm_evidence + " " + handoff.evidence
    handoff

fn _wine_process_plan_full_image_loader_runtime_from_handoff(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, handoff: WineProcessFullImageHandoff) -> WineProcessFullImageLoaderRuntimePlan:
    if not handoff.ok:
        return _wine_process_full_image_loader_runtime_plan(false, handoff.error, plan.command, 0, 0, handoff.evidence, handoff.status)
    val relocated = wine_pe_apply_relocation_plan(data, preferred_base, load_base)
    if not relocated.ok:
        return _wine_process_full_image_loader_runtime_plan(false, "relocation:" + relocated.error, plan.command, relocated.relocation_count, 0, handoff.evidence + " " + relocated.operations, "rejected")
    val tls = wine_pe_tls_callback_plan(data, dynload_apis)
    if not tls.ok:
        return _wine_process_full_image_loader_runtime_plan(false, "tls:" + tls.error, plan.command, relocated.relocation_count, tls.callback_count, handoff.evidence + " " + relocated.operations + " " + tls.operations, "rejected")
    val evidence = handoff.evidence + " " + relocated.operations + " " + tls.operations + " full-image-loader-runtime-planned relocation-runtime-planned tls-runtime-planned no-arbitrary-execution"
    _wine_process_full_image_loader_runtime_plan(true, "", plan.command, relocated.relocation_count, tls.callback_count, evidence, "full-image-loader-runtime-planned")

pub fn wine_process_plan_full_image_loader_runtime(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text) -> WineProcessFullImageLoaderRuntimePlan:
    val handoff = wine_process_prepare_full_image_handoff(plan, data)
    _wine_process_plan_full_image_loader_runtime_from_handoff(plan, data, preferred_base, load_base, dynload_apis, handoff)

pub fn wine_process_plan_full_image_loader_runtime_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, vm_writes: WinePebTebVmWriteResult) -> WineProcessFullImageLoaderRuntimePlan:
    val handoff = wine_process_prepare_full_image_handoff_with_peb_teb_vm_writes(plan, data, vm_writes)
    _wine_process_plan_full_image_loader_runtime_from_handoff(plan, data, preferred_base, load_base, dynload_apis, handoff)

fn _wine_process_apply_loader_relocations_in_vma_from_runtime(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, runtime: WineProcessFullImageLoaderRuntimePlan) -> WineProcessVmaRelocationApplyResult:
    if not runtime.ok:
        return _wine_process_vma_relocation_apply_result(false, runtime.error, plan.command, data, 0, 0, runtime.relocation_count, 0, runtime.evidence, runtime.status)
    val image_size = pe_size_of_image(data)
    if image_size <= 0:
        return _wine_process_vma_relocation_apply_result(false, "missing-image-size", plan.command, data, 0, 0, 0, 0, runtime.evidence, "rejected")
    val mapped = wine_vm_map_executable_image(wine_vm_process_space_new(1, 1, "pid fs ipc net capability"), load_base, image_size)
    if not mapped.ok:
        return _wine_process_vma_relocation_apply_result(false, "process-image-map:" + mapped.state, plan.command, data, 0, 0, runtime.relocation_count, 0, runtime.evidence, "blocked")
    val writeable = wine_vm_protect(mapped.space, mapped.region.base, "rw")
    if not writeable.ok:
        return _wine_process_vma_relocation_apply_result(false, "process-image-write-window:" + writeable.state, plan.command, data, mapped.region.base, mapped.region.size, runtime.relocation_count, 0, runtime.evidence, "blocked")

    var patched = data
    var target_rva = 0
    if runtime.relocation_count > 0:
        val relocation = wine_pe_apply_relocation_plan(data, preferred_base, load_base)
        target_rva = relocation.target_rva
        val target_offset = pe_rva_to_file_offset(data, target_rva)
        if target_offset < 0 or target_offset + 7 >= data.len():
            val restored = wine_vm_protect(writeable.space, mapped.region.base, "rx")
            if not restored.ok:
                return _wine_process_vma_relocation_apply_result(false, "process-image-rx-restore:" + restored.state, plan.command, data, mapped.region.base, mapped.region.size, runtime.relocation_count, target_rva, runtime.evidence, "blocked")
            return _wine_process_vma_relocation_apply_result(false, "relocation-target-offset-unmapped", plan.command, data, mapped.region.base, mapped.region.size, runtime.relocation_count, target_rva, runtime.evidence + " process-vma-rx-restored", "rejected")
        val original = _wine_process_read_u64_le(data, target_offset)
        patched = _wine_process_patch_u64_le(patched, target_offset, original + relocation.delta)

    val executable = wine_vm_protect(writeable.space, mapped.region.base, "rx")
    if not executable.ok:
        return _wine_process_vma_relocation_apply_result(false, "process-image-rx-restore:" + executable.state, plan.command, patched, mapped.region.base, mapped.region.size, runtime.relocation_count, target_rva, runtime.evidence, "blocked")
    val entry_rva = pe_entry_point_rva(patched)
    val host_jump_state = wine_vm_no_host_code_jump_gate(executable.space, mapped.region.base + entry_rva)
    if host_jump_state != "ready":
        return _wine_process_vma_relocation_apply_result(false, host_jump_state, plan.command, patched, mapped.region.base, mapped.region.size, runtime.relocation_count, target_rva, runtime.evidence, "blocked")
    val evidence = runtime.evidence + " loader-relocations-vma-applied process-image-mapped os-process os-address-space os-vma image-map process-vma-write-window process-vma-write-enabled process-vma-rx-restored exec-perm no-host-code-jump no-arbitrary-execution"
    _wine_process_vma_relocation_apply_result(true, "", plan.command, patched, mapped.region.base, mapped.region.size, runtime.relocation_count, target_rva, evidence, "loader-relocations-vma-applied")

pub fn wine_process_apply_loader_relocations_in_vma(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text) -> WineProcessVmaRelocationApplyResult:
    val runtime = wine_process_plan_full_image_loader_runtime(plan, data, preferred_base, load_base, dynload_apis)
    _wine_process_apply_loader_relocations_in_vma_from_runtime(plan, data, preferred_base, load_base, runtime)

pub fn wine_process_apply_loader_relocations_in_vma_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, vm_writes: WinePebTebVmWriteResult) -> WineProcessVmaRelocationApplyResult:
    val runtime = wine_process_plan_full_image_loader_runtime_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, vm_writes)
    _wine_process_apply_loader_relocations_in_vma_from_runtime(plan, data, preferred_base, load_base, runtime)

fn _wine_process_record_tls_callback_dispatch_from_relocated(plan: WineProcessSessionPlan, dynload_apis: text, relocated: WineProcessVmaRelocationApplyResult) -> WineProcessTlsCallbackDispatchResult:
    if not relocated.ok:
        return _wine_process_tls_callback_dispatch_result(false, relocated.error, plan.command, relocated.mapped_base, 0, 0, 0, relocated.evidence, relocated.status)
    val tls = wine_pe_tls_callback_plan(relocated.patched_image, dynload_apis)
    if not tls.ok:
        return _wine_process_tls_callback_dispatch_result(false, "tls:" + tls.error, plan.command, relocated.mapped_base, tls.callback_count, tls.first_callback_rva, 0, relocated.evidence + " " + tls.operations, "rejected")
    if tls.callback_count == 0:
        val empty_evidence = relocated.evidence + " " + tls.operations + " tls-callback-dispatch-empty no-arbitrary-execution"
        return _wine_process_tls_callback_dispatch_result(true, "", plan.command, relocated.mapped_base, 0, 0, 0, empty_evidence, "tls-callback-dispatch-empty")
    if tls.first_callback_rva <= 0 or tls.first_callback_rva >= relocated.mapped_size:
        return _wine_process_tls_callback_dispatch_result(false, "tls-callback-target-out-of-image", plan.command, relocated.mapped_base, tls.callback_count, tls.first_callback_rva, 0, relocated.evidence + " " + tls.operations, "rejected")
    val evidence = relocated.evidence + " " + tls.operations + " tls-callback-target-mapped tls-callback-dispatch-recorded loader-tls-callback-dispatch-owned no-arbitrary-execution"
    _wine_process_tls_callback_dispatch_result(true, "", plan.command, relocated.mapped_base, tls.callback_count, tls.first_callback_rva, tls.callback_count, evidence, "tls-callback-dispatch-recorded")

pub fn wine_process_record_tls_callback_dispatch(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text) -> WineProcessTlsCallbackDispatchResult:
    val relocated = wine_process_apply_loader_relocations_in_vma(plan, data, preferred_base, load_base, dynload_apis)
    _wine_process_record_tls_callback_dispatch_from_relocated(plan, dynload_apis, relocated)

pub fn wine_process_record_tls_callback_dispatch_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, vm_writes: WinePebTebVmWriteResult) -> WineProcessTlsCallbackDispatchResult:
    val relocated = wine_process_apply_loader_relocations_in_vma_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, vm_writes)
    _wine_process_record_tls_callback_dispatch_from_relocated(plan, dynload_apis, relocated)

pub fn wine_process_inspect_full_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessImportInspectionResult:
    val image = wine_process_validate_full_image(plan, data)
    if not image.ok:
        return _wine_process_import_inspection_result(false, image.error, plan.command, "", 0, [], image.status)
    if symbol_limit <= 0:
        return _wine_process_import_inspection_result(false, "invalid-symbol-limit", plan.command, "", 0, [], "blocked")

    val thunk_state = pe_first_import_thunk_gate(data, symbol_limit)
    if thunk_state != "ready":
        return _wine_process_import_inspection_result(false, thunk_state, plan.command, "", 0, [], "rejected")
    val dll_name = pe_first_import_dll_name(data)
    if dll_name == "":
        return _wine_process_import_inspection_result(false, "missing-import-name", plan.command, "", 0, [], "rejected")
    val symbols = pe_first_import_symbol_names(data, symbol_limit)
    if symbols.len() == 0:
        return _wine_process_import_inspection_result(false, "missing-import-symbols", plan.command, dll_name, 0, symbols, "rejected")
    _wine_process_import_inspection_result(true, "", plan.command, dll_name, symbols.len(), symbols, "imports-inspected")

pub fn wine_process_inspect_import_descriptor_table(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportDescriptorTableResult:
    val image = wine_process_validate_full_image(plan, data)
    if not image.ok:
        return _wine_process_import_descriptor_table_result(false, image.error, plan.command, 0, [], 0, "", image.status)
    if descriptor_limit <= 0:
        return _wine_process_import_descriptor_table_result(false, "invalid-import-descriptor-limit", plan.command, 0, [], 0, "", "blocked")
    if symbol_limit <= 0:
        return _wine_process_import_descriptor_table_result(false, "invalid-import-symbol-limit", plan.command, 0, [], 0, "", "blocked")
    val table_state = pe_import_descriptor_table_gate(data, descriptor_limit, symbol_limit)
    if table_state != "ready":
        return _wine_process_import_descriptor_table_result(false, table_state, plan.command, 0, [], 0, "", "rejected")
    val summaries = pe_import_descriptor_summaries(data, descriptor_limit, symbol_limit)
    if summaries.len() <= 0:
        return _wine_process_import_descriptor_table_result(false, "missing-import-descriptors", plan.command, 0, [], 0, "", "rejected")
    var dll_names: [text] = []
    var import_count = 0
    for summary in summaries:
        dll_names.push(summary.dll_name)
        import_count = import_count + summary.symbol_count
    val evidence = "full-image-validated import-descriptor-table-valid import-descriptor-table-bounded import-dll-names-resolved import-thunk-tables-bounded import-symbol-counts-bounded"
    _wine_process_import_descriptor_table_result(true, "", plan.command, summaries.len(), dll_names, import_count, evidence, "import-descriptor-table-inspected")

pub fn wine_process_inventory_import_descriptor_thunks(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportDescriptorThunkInventoryResult:
    val table = wine_process_inspect_import_descriptor_table(plan, data, descriptor_limit, symbol_limit)
    if not table.ok:
        return _wine_process_import_descriptor_thunk_inventory_result(false, table.error, plan.command, 0, [], [], table.evidence, table.status)
    val bindings = pe_import_descriptor_thunk_bindings(data, descriptor_limit, symbol_limit)
    if bindings.len() != table.import_count:
        return _wine_process_import_descriptor_thunk_inventory_result(false, "import-descriptor-thunk-count-mismatch", plan.command, bindings.len(), table.dll_names, [], table.evidence, "rejected")
    var dll_names: [text] = []
    var symbols: [text] = []
    for binding in bindings:
        dll_names.push(binding.dll_name)
        symbols.push(binding.symbol)
    val evidence = table.evidence + " import-descriptor-thunk-bindings-data-backed import-descriptor-thunk-rvas-recorded import-descriptor-symbol-names-recorded"
    _wine_process_import_descriptor_thunk_inventory_result(true, "", plan.command, bindings.len(), dll_names, symbols, evidence, "import-descriptor-thunks-inventoried")

pub fn wine_process_plan_import_dependencies(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportDependencyPlanResult:
    val table = wine_process_inspect_import_descriptor_table(plan, data, descriptor_limit, symbol_limit)
    if not table.ok:
        return _wine_process_import_dependency_plan_result(false, table.error, plan.command, 0, 0, 0, [], [], table.evidence, table.status)
    var modules: [text] = []
    var unsupported_modules: [text] = []
    for dll_name in table.dll_names:
        if not _wine_process_text_seen(modules, dll_name):
            modules.push(dll_name)
            if not _wine_process_import_dependency_supported(dll_name):
                unsupported_modules.push(dll_name)
    if unsupported_modules.len() > 0:
        return _wine_process_import_dependency_plan_result(false, "unsupported-import-module:" + unsupported_modules[0], plan.command, modules.len(), modules.len() - unsupported_modules.len(), unsupported_modules.len(), modules, unsupported_modules, table.evidence + " import-dependency-modules-enumerated import-dependency-unsupported-blocked", "rejected")
    val evidence = table.evidence + " import-dependency-modules-enumerated import-dependency-modules-supported import-dependency-plan-bounded no-dll-loaded no-import-bound"
    _wine_process_import_dependency_plan_result(true, "", plan.command, modules.len(), modules.len(), 0, modules, [], evidence, "import-dependencies-planned")

pub fn wine_process_plan_import_resolution(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportResolutionPlanResult:
    val dependencies = wine_process_plan_import_dependencies(plan, data, descriptor_limit, symbol_limit)
    if not dependencies.ok:
        return _wine_process_import_resolution_plan_result(false, dependencies.error, plan.command, dependencies.module_count, 0, dependencies.evidence, dependencies.status)
    val inventory = wine_process_inventory_import_descriptor_thunks(plan, data, descriptor_limit, symbol_limit)
    if not inventory.ok:
        return _wine_process_import_resolution_plan_result(false, inventory.error, plan.command, dependencies.module_count, 0, inventory.evidence, inventory.status)
    var table = _wine_process_known_import_module_table()
    for module_name in dependencies.modules:
        val loaded = wine_kernel32_load_library_ex_w(table, module_name, 0)
        if not loaded.ok:
            return _wine_process_import_resolution_plan_result(false, "import-module-load:" + module_name + ":" + loaded.error, plan.command, dependencies.module_count, 0, dependencies.evidence, "rejected")
        table = loaded.table
    var resolved_count = 0
    var i = 0
    while i < inventory.binding_count:
        val module = wine_kernel32_get_module_handle_w(table, inventory.dll_names[i])
        if not module.ok:
            return _wine_process_import_resolution_plan_result(false, "import-module-handle:" + inventory.dll_names[i] + ":" + module.error, plan.command, dependencies.module_count, resolved_count, dependencies.evidence, "rejected")
        val proc = wine_kernel32_get_proc_address(module.table, module.handle, inventory.symbols[i])
        if not proc.ok:
            return _wine_process_import_resolution_plan_result(false, "import-proc-address:" + inventory.dll_names[i] + "!" + inventory.symbols[i] + ":" + proc.error, plan.command, dependencies.module_count, resolved_count, dependencies.evidence, "rejected")
        resolved_count = resolved_count + 1
        i = i + 1
    val evidence = inventory.evidence + " import-dependencies-planned import-modules-modeled-loaded import-module-handles-modeled import-proc-addresses-modeled no-real-dll-loaded no-iat-patched no-arbitrary-execution"
    _wine_process_import_resolution_plan_result(true, "", plan.command, dependencies.module_count, resolved_count, evidence, "import-resolution-planned")

pub fn wine_process_plan_import_loader_state(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportLoaderStateResult:
    val dependencies = wine_process_plan_import_dependencies(plan, data, descriptor_limit, symbol_limit)
    if not dependencies.ok:
        return _wine_process_import_loader_state_result(false, dependencies.error, plan.command, dependencies.module_count, 0, 0, 0, 0, dependencies.evidence, dependencies.status)
    val inventory = wine_process_inventory_import_descriptor_thunks(plan, data, descriptor_limit, symbol_limit)
    if not inventory.ok:
        return _wine_process_import_loader_state_result(false, inventory.error, plan.command, dependencies.module_count, 0, 0, 0, 0, inventory.evidence, inventory.status)

    var table = _wine_process_known_import_module_table()
    var handles: [i64] = []
    var loaded_count = 0
    var max_ref_count = _wine_process_max_module_ref_count(table)
    for module_name in dependencies.modules:
        val loaded = wine_kernel32_load_library_ex_w(table, module_name, 0)
        if not loaded.ok:
            var rollback_count = 0
            for handle in handles:
                val freed = wine_kernel32_free_library(table, handle)
                if freed.ok:
                    table = freed.table
                    rollback_count = rollback_count + 1
            if _wine_process_max_module_ref_count(table) != 1:
                val evidence = dependencies.evidence + " import-loader-state-planned import-loader-rollback-incomplete no-real-dll-loaded no-arbitrary-execution"
                return _wine_process_import_loader_state_result(false, "import-loader-refcount-restore-failed", plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
            val evidence = dependencies.evidence + " import-loader-state-planned import-loader-rollback-complete import-loader-refcounts-restored no-real-dll-loaded no-arbitrary-execution"
            return _wine_process_import_loader_state_result(false, "import-module-load:" + module_name + ":" + loaded.error, plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
        table = loaded.table
        handles.push(loaded.handle)
        loaded_count = loaded_count + 1
        max_ref_count = _wine_process_max_module_ref_count(table)

    var resolved_count = 0
    var i = 0
    while i < inventory.binding_count:
        val module = wine_kernel32_get_module_handle_w(table, inventory.dll_names[i])
        if not module.ok:
            var rollback_count = 0
            for handle in handles:
                val freed = wine_kernel32_free_library(table, handle)
                if freed.ok:
                    table = freed.table
                    rollback_count = rollback_count + 1
            if _wine_process_max_module_ref_count(table) != 1:
                val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-rollback-incomplete no-real-dll-loaded no-arbitrary-execution"
                return _wine_process_import_loader_state_result(false, "import-loader-refcount-restore-failed", plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
            val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-rollback-complete import-loader-refcounts-restored no-real-dll-loaded no-arbitrary-execution"
            return _wine_process_import_loader_state_result(false, "import-module-handle:" + inventory.dll_names[i] + ":" + module.error, plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
        val proc = wine_kernel32_get_proc_address(module.table, module.handle, inventory.symbols[i])
        if not proc.ok:
            var rollback_count = 0
            for handle in handles:
                val freed = wine_kernel32_free_library(table, handle)
                if freed.ok:
                    table = freed.table
                    rollback_count = rollback_count + 1
            if _wine_process_max_module_ref_count(table) != 1:
                val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-rollback-incomplete no-real-dll-loaded no-arbitrary-execution"
                return _wine_process_import_loader_state_result(false, "import-loader-refcount-restore-failed", plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
            val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-rollback-complete import-loader-refcounts-restored no-real-dll-loaded no-arbitrary-execution"
            return _wine_process_import_loader_state_result(false, "import-proc-address:" + inventory.dll_names[i] + "!" + inventory.symbols[i] + ":" + proc.error, plan.command, dependencies.module_count, loaded_count, 0, rollback_count, max_ref_count, evidence, "rejected")
        resolved_count = resolved_count + 1
        i = i + 1

    var released_count = 0
    for handle in handles:
        val freed = wine_kernel32_free_library(table, handle)
        if not freed.ok:
            val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-release-failed no-real-dll-loaded no-arbitrary-execution"
            return _wine_process_import_loader_state_result(false, "import-module-release:" + freed.error, plan.command, dependencies.module_count, loaded_count, released_count, 0, max_ref_count, evidence, "rejected")
        table = freed.table
        released_count = released_count + 1
    if _wine_process_max_module_ref_count(table) != 1:
        val evidence = inventory.evidence + " import-loader-state-planned import-loader-modules-loaded import-loader-modules-released import-loader-refcounts-unrestored no-real-dll-loaded no-arbitrary-execution"
        return _wine_process_import_loader_state_result(false, "import-loader-refcount-restore-failed", plan.command, dependencies.module_count, loaded_count, released_count, 0, max_ref_count, evidence, "rejected")
    val evidence = inventory.evidence + " import-loader-state-planned import-loader-refcounts-tracked import-loader-modules-loaded import-loader-modules-released import-loader-refcounts-restored no-real-dll-loaded no-arbitrary-execution"
    _wine_process_import_loader_state_result(true, "", plan.command, dependencies.module_count, loaded_count, released_count, 0, max_ref_count, evidence, "import-loader-state-planned")

pub fn wine_process_plan_import_descriptor_thunk_patch_records(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportDescriptorPatchRecordPlan:
    val resolution = wine_process_plan_import_resolution(plan, data, descriptor_limit, symbol_limit)
    if not resolution.ok:
        return _wine_process_import_descriptor_patch_record_plan(false, resolution.error, plan.command, [], resolution.evidence, resolution.status)
    val bindings = pe_import_descriptor_thunk_bindings(data, descriptor_limit, symbol_limit)
    if bindings.len() != resolution.resolved_count:
        return _wine_process_import_descriptor_patch_record_plan(false, "import-descriptor-patch-record-count-mismatch", plan.command, [], resolution.evidence, "rejected")
    var table = _wine_process_known_import_module_table()
    val dependencies = wine_process_plan_import_dependencies(plan, data, descriptor_limit, symbol_limit)
    for module_name in dependencies.modules:
        val loaded = wine_kernel32_load_library_ex_w(table, module_name, 0)
        if not loaded.ok:
            return _wine_process_import_descriptor_patch_record_plan(false, "import-module-load:" + module_name + ":" + loaded.error, plan.command, [], resolution.evidence, "rejected")
        table = loaded.table
    var records: [WineProcessImportDescriptorPatchRecord] = []
    for binding in bindings:
        val module = wine_kernel32_get_module_handle_w(table, binding.dll_name)
        if not module.ok:
            return _wine_process_import_descriptor_patch_record_plan(false, "import-module-handle:" + binding.dll_name + ":" + module.error, plan.command, [], resolution.evidence, "rejected")
        val proc = wine_kernel32_get_proc_address(module.table, module.handle, binding.symbol)
        if not proc.ok:
            return _wine_process_import_descriptor_patch_record_plan(false, "import-proc-address:" + binding.dll_name + "!" + binding.symbol + ":" + proc.error, plan.command, [], resolution.evidence, "rejected")
        records.push(_wine_process_import_descriptor_patch_record(binding.dll_name, binding.symbol, binding.descriptor_index, binding.thunk_index, binding.thunk_rva, binding.iat_rva, binding.name_rva, proc.proc_address))
    val evidence = resolution.evidence + " import-descriptor-patch-records-planned import-descriptor-patch-records-data-backed import-descriptor-proc-addresses-recorded import-descriptor-iat-rvas-recorded no-iat-written no-vma-written"
    _wine_process_import_descriptor_patch_record_plan(true, "", plan.command, records, evidence, "import-descriptor-patch-records-planned")

pub fn wine_process_bind_known_kernel32_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessImportBindingResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_import_binding_result(false, imports.error, plan.command, imports.dll_name, "", 0, imports.status)

    val bindings = pe_first_import_symbol_bindings(data, symbol_limit)
    val binding_plan = wine_nt_import_hello_binding_plan(imports.dll_name, bindings)
    if not binding_plan.ok:
        return _wine_process_import_binding_result(false, binding_plan.error, plan.command, imports.dll_name, "", 0, "rejected")
    _wine_process_import_binding_result(true, "", plan.command, binding_plan.dll, binding_plan.call_sequence, binding_plan.binding_count, "imports-bound")

pub fn wine_process_plan_import_thunk_patches(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchPlanResult:
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_thunk_patch_plan_result(false, records.error, plan.command, records.dll_name, 0, "", records.status)
    if records.records.len() <= 0:
        return _wine_process_thunk_patch_plan_result(false, "missing-patch-records", plan.command, records.dll_name, 0, "", "rejected")
    val evidence = records.evidence + " import-thunks-bound import-thunk-table-valid import-thunk-symbols-resolved import-thunk-bindings-match import-thunk-iat-guarded"
    _wine_process_thunk_patch_plan_result(true, "", plan.command, records.dll_name, records.records.len(), evidence, "thunk-patch-planned")

pub fn wine_process_plan_import_thunk_patches_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, symbol_limit: i64, vm_writes: WinePebTebVmWriteResult) -> WineProcessThunkPatchPlanResult:
    val tls = wine_process_record_tls_callback_dispatch_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, vm_writes)
    if not tls.ok:
        return _wine_process_thunk_patch_plan_result(false, tls.error, plan.command, "", 0, tls.evidence, tls.status)
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_thunk_patch_plan_result(false, records.error, plan.command, records.dll_name, 0, tls.evidence + " " + records.evidence, records.status)
    if records.records.len() <= 0:
        return _wine_process_thunk_patch_plan_result(false, "missing-patch-records", plan.command, records.dll_name, 0, tls.evidence + " " + records.evidence, "rejected")
    val evidence = tls.evidence + " " + records.evidence + " import-thunks-bound import-thunk-table-valid import-thunk-symbols-resolved import-thunk-bindings-match import-thunk-iat-guarded"
    _wine_process_thunk_patch_plan_result(true, "", plan.command, records.dll_name, records.records.len(), evidence, "thunk-patch-planned")

