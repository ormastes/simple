fn _wine_process_plan_known_console_dispatch_from_mapped(plan: WineProcessSessionPlan, mapped: WineProcessMappedImagePreflightResult) -> WineProcessDispatchPlanResult:
    if not mapped.ok:
        return _wine_process_dispatch_plan_result(false, mapped.error, plan.command, "", 0, "", 0, mapped.status)
    val cpu_plan = wine_cpu_hello_execution_plan(mapped.mapped_image, mapped.evidence)
    if not cpu_plan.ok:
        return _wine_process_dispatch_plan_result(false, cpu_plan.error, plan.command, "", 0, "", 0, "rejected")
    _wine_process_dispatch_plan_result(true, "", plan.command, cpu_plan.instruction_sequence, cpu_plan.instruction_count, cpu_plan.call_sequence, cpu_plan.call_count, "dispatch-planned")

pub fn wine_process_execute_known_console(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, cpu_evidence: text) -> WineProcessExecutionResult:
    val mapped = wine_process_map_known_console_image(plan, data, symbol_limit, cpu_evidence)
    _wine_process_execute_known_console_from_mapped(plan, mapped)

pub fn wine_process_execute_known_console_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, symbol_limit: i64, cpu_evidence: text, vm_writes: WinePebTebVmWriteResult) -> WineProcessExecutionResult:
