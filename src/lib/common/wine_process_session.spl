    _wine_process_execute_known_console_from_mapped(plan, mapped)

fn _wine_process_execute_known_console_from_mapped(plan: WineProcessSessionPlan, mapped: WineProcessMappedImagePreflightResult) -> WineProcessExecutionResult:
    if not mapped.ok:
        return _wine_process_execution_result(false, mapped.error, plan.command, "", -1, mapped.status)
    val cpu_plan = wine_cpu_hello_execution_plan(mapped.mapped_image, mapped.evidence)
    if not cpu_plan.ok:
        return _wine_process_execution_result(false, cpu_plan.error, plan.command, "", -1, "rejected")
    val result = wine_known_hello_execute_plan(mapped.mapped_image, cpu_plan)
    if not result.ok:
        return _wine_process_execution_result(false, result.error, plan.command, "", -1, "blocked")
    _wine_process_execution_result(true, "", plan.command, result.stdout, result.exit_code, "known-console-executed")

pub fn wine_process_resolve_known_kernel32_module(plan: WineProcessSessionPlan, module_name: text, proc_name: text) -> WineProcessModuleResolutionResult:
    if not plan.ok:
        return _wine_process_module_resolution_result(false, plan.error, plan.command, module_name, proc_name, 0, 0, "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_module_resolution_result(false, "unsupported-process-session", plan.command, module_name, proc_name, 0, 0, "", "blocked")

    val result = wine_kernel32_execute_module_resolution(
        ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
        _wine_process_kernel32_module_table(),
        module_name,
        proc_name
    )
    if not result.ok:
        return _wine_process_module_resolution_result(false, result.error, plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "rejected")
    _wine_process_module_resolution_result(true, "", plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "module-resolved")

pub fn wine_process_resolve_known_kernel32_module_ex(plan: WineProcessSessionPlan, module_name: text, proc_name: text, flags: i64) -> WineProcessModuleResolutionResult:
    if not plan.ok:
        return _wine_process_module_resolution_result(false, plan.error, plan.command, module_name, proc_name, 0, 0, "", "blocked")
    if plan.readiness != "full-wine-ready":
        return _wine_process_module_resolution_result(false, "unsupported-process-session", plan.command, module_name, proc_name, 0, 0, "", "blocked")

    val result = wine_kernel32_execute_module_resolution_ex(
        ["GetModuleHandleW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary"],
        _wine_process_kernel32_module_table(),
        module_name,
        proc_name,
        flags
    )
    if not result.ok:
        return _wine_process_module_resolution_result(false, result.error, plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "rejected")
    _wine_process_module_resolution_result(true, "", plan.command, module_name, proc_name, result.handle, result.proc_address, result.operations, "module-resolved")

pub fn wine_process_resolve_first_import_module(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64, proc_name: text) -> WineProcessModuleResolutionResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_module_resolution_result(false, imports.error, plan.command, imports.dll_name, proc_name, 0, 0, "", imports.status)
    wine_process_resolve_known_kernel32_module_ex(plan, imports.dll_name, proc_name, 0)

pub fn wine_process_load_and_bind_known_kernel32_imports(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessLoadBindingResult:
    val imports = wine_process_inspect_full_imports(plan, data, symbol_limit)
    if not imports.ok:
        return _wine_process_load_binding_result(false, imports.error, plan.command, imports.dll_name, 0, "", "", 0, imports.status)
    val module = wine_process_resolve_known_kernel32_module_ex(plan, imports.dll_name, "GetProcAddress", 0)
    if not module.ok:
        return _wine_process_load_binding_result(false, module.error, plan.command, module.module_name, module.handle, module.operations, "", 0, module.status)
    val bindings = pe_first_import_symbol_bindings(data, symbol_limit)
    val binding_plan = wine_nt_import_hello_binding_plan(imports.dll_name, bindings)
    if not binding_plan.ok:
        return _wine_process_load_binding_result(false, binding_plan.error, plan.command, imports.dll_name, module.handle, module.operations, "", 0, "rejected")
    _wine_process_load_binding_result(true, "", plan.command, binding_plan.dll, module.handle, module.operations, binding_plan.call_sequence, binding_plan.binding_count, "imports-loaded-bound")

pub fn wine_process_plan_known_kernel32_thunk_patch_records(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchRecordPlan:
    val loaded = wine_process_load_and_bind_known_kernel32_imports(plan, data, symbol_limit)
    if not loaded.ok:
        return _wine_process_thunk_patch_record_plan(false, loaded.error, plan.command, loaded.dll_name, [], "", loaded.status)
    val thunk_bindings = pe_first_import_thunk_bindings(data, symbol_limit)
    if thunk_bindings.len() != loaded.binding_count:
        return _wine_process_thunk_patch_record_plan(false, "import-thunk-record-count-mismatch", plan.command, loaded.dll_name, [], "", "rejected")
    var records: [WineProcessThunkPatchRecord] = []
    for binding in thunk_bindings:
        records.push(_wine_process_thunk_patch_record(binding.symbol, binding.thunk_index, binding.thunk_rva, binding.name_rva))
    var get_std_handle_seen = false
    var write_file_seen = false
    var exit_process_seen = false
    for record in records:
        if record.name_rva <= 0:
            return _wine_process_thunk_patch_record_plan(false, "missing-patch-record:" + record.symbol, plan.command, loaded.dll_name, [], "", "rejected")
        if record.thunk_rva <= 0:
            return _wine_process_thunk_patch_record_plan(false, "missing-thunk-rva:" + record.symbol, plan.command, loaded.dll_name, [], "", "rejected")
        if record.symbol == "GetStdHandle":
            get_std_handle_seen = true
        elif record.symbol == "WriteFile":
            write_file_seen = true
        elif record.symbol == "ExitProcess":
            exit_process_seen = true
        else:
            return _wine_process_thunk_patch_record_plan(false, "unsupported-thunk-record:" + record.symbol, plan.command, loaded.dll_name, [], "", "rejected")
    if not get_std_handle_seen:
        return _wine_process_thunk_patch_record_plan(false, "missing-thunk-record:GetStdHandle", plan.command, loaded.dll_name, [], "", "rejected")
    if not write_file_seen:
        return _wine_process_thunk_patch_record_plan(false, "missing-thunk-record:WriteFile", plan.command, loaded.dll_name, [], "", "rejected")
    if not exit_process_seen:
        return _wine_process_thunk_patch_record_plan(false, "missing-thunk-record:ExitProcess", plan.command, loaded.dll_name, [], "", "rejected")
    val evidence = "import-module-loaded import-module-handle-valid import-module-loader-sequence import-thunk-records-planned import-thunk-records-data-backed import-thunk-records-match import-thunk-records-bounded"
    _wine_process_thunk_patch_record_plan(true, "", plan.command, loaded.dll_name, records, evidence, "thunk-records-planned")

pub fn wine_process_apply_known_kernel32_thunk_patches(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessThunkPatchApplyResult:
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_thunk_patch_apply_result(false, records.error, plan.command, records.dll_name, data, 0, "", records.status)
    _wine_process_apply_known_kernel32_thunk_patch_records(plan.command, records.dll_name, data, records.records, records.evidence)

fn _wine_process_apply_known_kernel32_thunk_patch_records(command: text, dll_name: text, data: [u8], records: [WineProcessThunkPatchRecord], record_evidence: text) -> WineProcessThunkPatchApplyResult:
    var patched = data
    var patched_count = 0
    for record in records:
        val thunk_offset = pe_rva_to_file_offset(data, record.thunk_rva)
        if thunk_offset < 0 or thunk_offset + 7 >= data.len():
            return _wine_process_thunk_patch_apply_result(false, "thunk-patch-offset-unmapped:" + record.symbol, command, dll_name, data, 0, "", "rejected")
        val proc_address = _wine_process_kernel32_export_address(record.symbol)
        if proc_address <= 0:
            return _wine_process_thunk_patch_apply_result(false, "missing-proc-address:" + record.symbol, command, dll_name, data, 0, "", "rejected")
        patched = _wine_process_patch_u64_le(patched, thunk_offset, proc_address)
        patched_count = patched_count + 1
    val evidence = record_evidence + " import-thunk-bytes-written import-thunk-write-checked import-thunk-patch-bounded"
    _wine_process_thunk_patch_apply_result(true, "", command, dll_name, patched, patched_count, evidence, "thunk-patches-applied")

fn _wine_process_apply_import_descriptor_thunk_patch_records(command: text, data: [u8], records: [WineProcessImportDescriptorPatchRecord], record_evidence: text) -> WineProcessImportDescriptorVmaPatchResult:
    var patched = data
    var patched_count = 0
    for record in records:
        val thunk_offset = pe_rva_to_file_offset(data, record.iat_rva)
        if thunk_offset < 0 or thunk_offset + 7 >= data.len():
            return _wine_process_import_descriptor_vma_patch_result(false, "import-descriptor-thunk-patch-offset-unmapped:" + record.dll_name + "!" + record.symbol, command, data, 0, 0, 0, record_evidence + " process-vma-write-rollback", "rejected")
        if record.proc_address <= 0:
            return _wine_process_import_descriptor_vma_patch_result(false, "missing-import-descriptor-proc-address:" + record.dll_name + "!" + record.symbol, command, data, 0, 0, 0, record_evidence + " process-vma-write-rollback", "rejected")
        patched = _wine_process_patch_u64_le(patched, thunk_offset, record.proc_address)
        patched_count = patched_count + 1
    val evidence = record_evidence + " import-descriptor-thunk-bytes-written import-descriptor-thunk-write-checked import-descriptor-thunk-patch-bounded"
    _wine_process_import_descriptor_vma_patch_result(true, "", command, patched, 0, 0, patched_count, evidence, "import-descriptor-thunk-patches-applied")

pub fn wine_process_apply_known_kernel32_thunk_patches_in_vma(plan: WineProcessSessionPlan, data: [u8], symbol_limit: i64) -> WineProcessVmaThunkPatchResult:
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_vma_thunk_patch_result(false, records.error, plan.command, records.dll_name, data, 0, 0, 0, "", records.status)
    _wine_process_apply_known_kernel32_thunk_patches_in_vma_from_records(plan, data, records, "")

pub fn wine_process_apply_known_kernel32_thunk_patches_in_vma_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, symbol_limit: i64, vm_writes: WinePebTebVmWriteResult) -> WineProcessVmaThunkPatchResult:
    val tls = wine_process_record_tls_callback_dispatch_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, vm_writes)
    if not tls.ok:
        return _wine_process_vma_thunk_patch_result(false, tls.error, plan.command, "", data, 0, 0, 0, tls.evidence, tls.status)
    val records = wine_process_plan_known_kernel32_thunk_patch_records(plan, data, symbol_limit)
    if not records.ok:
        return _wine_process_vma_thunk_patch_result(false, records.error, plan.command, records.dll_name, data, 0, 0, 0, tls.evidence + " " + records.evidence, records.status)
    _wine_process_apply_known_kernel32_thunk_patches_in_vma_from_records(plan, data, records, tls.evidence)

fn _wine_process_apply_known_kernel32_thunk_patches_in_vma_from_records(plan: WineProcessSessionPlan, data: [u8], records: WineProcessThunkPatchRecordPlan, preflight_evidence: text) -> WineProcessVmaThunkPatchResult:
    var record_evidence = records.evidence
    if preflight_evidence != "":
        record_evidence = preflight_evidence + " " + records.evidence
    val image_size = pe_size_of_image(data)
    if image_size <= 0:
        return _wine_process_vma_thunk_patch_result(false, "missing-image-size", plan.command, records.dll_name, data, 0, 0, 0, record_evidence, "rejected")
    val mapped_base = 0x400000
    val mapped = wine_vm_map_executable_image(wine_vm_process_space_new(1, 1, "pid fs ipc net capability"), mapped_base, image_size)
    if not mapped.ok:
        return _wine_process_vma_thunk_patch_result(false, "process-image-map:" + mapped.state, plan.command, records.dll_name, data, 0, 0, 0, record_evidence, "blocked")
    val writeable = wine_vm_protect(mapped.space, mapped.region.base, "rw")
    if not writeable.ok:
        return _wine_process_vma_thunk_patch_result(false, "process-image-write-window:" + writeable.state, plan.command, records.dll_name, data, mapped.region.base, mapped.region.size, 0, record_evidence, "blocked")
    val patched = _wine_process_apply_known_kernel32_thunk_patch_records(plan.command, records.dll_name, data, records.records, record_evidence)
    if not patched.ok:
        return _wine_process_vma_thunk_patch_result(false, patched.error, plan.command, records.dll_name, data, mapped.region.base, mapped.region.size, 0, record_evidence, patched.status)
    val executable = wine_vm_protect(writeable.space, mapped.region.base, "rx")
    if not executable.ok:
        return _wine_process_vma_thunk_patch_result(false, "process-image-rx-restore:" + executable.state, plan.command, records.dll_name, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, patched.evidence, "blocked")
    val entry_rva = pe_entry_point_rva(patched.patched_image)
    val host_jump_state = wine_vm_no_host_code_jump_gate(executable.space, mapped.region.base + entry_rva)
    if host_jump_state != "ready":
        return _wine_process_vma_thunk_patch_result(false, host_jump_state, plan.command, records.dll_name, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, patched.evidence, "blocked")
    val evidence = patched.evidence + " process-image-mapped os-process os-address-space os-vma image-map process-vma-write-window process-vma-write-enabled process-vma-rx-restored exec-perm no-host-code-jump"
    _wine_process_vma_thunk_patch_result(true, "", plan.command, records.dll_name, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, evidence, "vma-thunk-patches-applied")

pub fn wine_process_apply_import_descriptor_thunk_patches_in_vma(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportDescriptorVmaPatchResult:
    val records = wine_process_plan_import_descriptor_thunk_patch_records(plan, data, descriptor_limit, symbol_limit)
    if not records.ok:
        return _wine_process_import_descriptor_vma_patch_result(false, records.error, plan.command, data, 0, 0, 0, records.evidence, records.status)
    _wine_process_apply_import_descriptor_thunk_patches_in_vma_from_records(plan, data, records, "")

pub fn wine_process_apply_import_descriptor_thunk_patches_in_vma_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, descriptor_limit: i64, symbol_limit: i64, vm_writes: WinePebTebVmWriteResult) -> WineProcessImportDescriptorVmaPatchResult:
    val vm_evidence = _wine_process_import_descriptor_peb_teb_vm_write_evidence(vm_writes)
    if vm_evidence == "":
        return _wine_process_import_descriptor_vma_patch_result(false, _wine_process_import_descriptor_peb_teb_vm_write_error(vm_writes), plan.command, [], 0, 0, 0, vm_writes.operations + " import-descriptor-vma-thunk-patches-blocked no-vma-thunk-written no-arbitrary-execution", "rejected")
    val records = wine_process_plan_import_descriptor_thunk_patch_records(plan, data, descriptor_limit, symbol_limit)
    if not records.ok:
        return _wine_process_import_descriptor_vma_patch_result(false, records.error, plan.command, [], 0, 0, 0, vm_evidence + " " + records.evidence + " import-descriptor-vma-thunk-patches-blocked no-vma-thunk-written no-arbitrary-execution", records.status)
    _wine_process_apply_import_descriptor_thunk_patches_in_vma_from_records(plan, data, records, vm_evidence)

fn _wine_process_import_descriptor_peb_teb_vm_write_evidence(vm_writes: WinePebTebVmWriteResult) -> text:
    if not vm_writes.ok:
        return ""
    if vm_writes.write_count != 6:
        return ""
    if vm_writes.byte_count != 48:
        return ""
    vm_writes.operations + " peb-teb-vm-writes-ready"

fn _wine_process_import_descriptor_peb_teb_vm_write_error(vm_writes: WinePebTebVmWriteResult) -> text:
    if not vm_writes.ok:
        return "peb-teb-vm-write:" + vm_writes.state
    if vm_writes.write_count != 6:
        return "peb-teb-vm-write-count-mismatch"
    if vm_writes.byte_count != 48:
        return "peb-teb-vm-byte-count-mismatch"
    "peb-teb-vm-write:unknown"

fn _wine_process_apply_import_descriptor_thunk_patches_in_vma_from_records(plan: WineProcessSessionPlan, data: [u8], records: WineProcessImportDescriptorPatchRecordPlan, preflight_evidence: text) -> WineProcessImportDescriptorVmaPatchResult:
    var record_evidence = records.evidence
    if preflight_evidence != "":
        record_evidence = preflight_evidence + " " + records.evidence
    val image_size = pe_size_of_image(data)
    if image_size <= 0:
        return _wine_process_import_descriptor_vma_patch_result(false, "missing-image-size", plan.command, data, 0, 0, 0, record_evidence, "rejected")
    val mapped_base = 0x400000
    val mapped = wine_vm_map_executable_image(wine_vm_process_space_new(1, 1, "pid fs ipc net capability"), mapped_base, image_size)
    if not mapped.ok:
        return _wine_process_import_descriptor_vma_patch_result(false, "process-image-map:" + mapped.state, plan.command, data, 0, 0, 0, record_evidence, "blocked")
    val writeable = wine_vm_protect(mapped.space, mapped.region.base, "rw")
    if not writeable.ok:
        return _wine_process_import_descriptor_vma_patch_result(false, "process-image-write-window:" + writeable.state, plan.command, data, mapped.region.base, mapped.region.size, 0, record_evidence, "blocked")
    val patched = _wine_process_apply_import_descriptor_thunk_patch_records(plan.command, data, records.records, record_evidence)
    if not patched.ok:
        val restored = wine_vm_protect(writeable.space, mapped.region.base, "rx")
        if not restored.ok:
            return _wine_process_import_descriptor_vma_patch_result(false, "process-image-rx-restore:" + restored.state, plan.command, data, mapped.region.base, mapped.region.size, 0, patched.evidence, "blocked")
        return _wine_process_import_descriptor_vma_patch_result(false, patched.error, plan.command, data, mapped.region.base, mapped.region.size, 0, patched.evidence + " process-vma-rx-restored", patched.status)
    val executable = wine_vm_protect(writeable.space, mapped.region.base, "rx")
    if not executable.ok:
        return _wine_process_import_descriptor_vma_patch_result(false, "process-image-rx-restore:" + executable.state, plan.command, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, patched.evidence, "blocked")
    val entry_rva = pe_entry_point_rva(patched.patched_image)
    val host_jump_state = wine_vm_no_host_code_jump_gate(executable.space, mapped.region.base + entry_rva)
    if host_jump_state != "ready":
        return _wine_process_import_descriptor_vma_patch_result(false, host_jump_state, plan.command, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, patched.evidence, "blocked")
    val evidence = patched.evidence + " process-image-mapped os-process os-address-space os-vma image-map process-vma-write-window process-vma-write-enabled process-vma-rx-restored exec-perm no-host-code-jump multi-dll-import-thunks-applied no-real-dll-loaded no-arbitrary-execution"
    _wine_process_import_descriptor_vma_patch_result(true, "", plan.command, patched.patched_image, mapped.region.base, mapped.region.size, patched.patched_count, evidence, "import-descriptor-vma-thunk-patches-applied")

pub fn wine_process_apply_import_loader_transaction_in_vma(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportLoaderVmaPatchTransactionResult:
    val loader = wine_process_plan_import_loader_state(plan, data, descriptor_limit, symbol_limit)
    if not loader.ok:
        val evidence = loader.evidence + " import-loader-vma-transaction-aborted no-vma-thunk-written no-real-dll-loaded no-arbitrary-execution"
        return _wine_process_import_loader_vma_patch_transaction_result(false, loader.error, plan.command, [], 0, 0, loader.module_count, loader.loaded_count, loader.released_count, loader.rollback_count, 0, evidence, loader.status)
    val patched = wine_process_apply_import_descriptor_thunk_patches_in_vma(plan, data, descriptor_limit, symbol_limit)
    _wine_process_apply_import_loader_transaction_from_patched(plan, data, loader, patched)

pub fn wine_process_apply_import_loader_transaction_in_vma_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], preferred_base: i64, load_base: i64, dynload_apis: text, descriptor_limit: i64, symbol_limit: i64, vm_writes: WinePebTebVmWriteResult) -> WineProcessImportLoaderVmaPatchTransactionResult:
    val loader = wine_process_plan_import_loader_state(plan, data, descriptor_limit, symbol_limit)
    if not loader.ok:
        val evidence = loader.evidence + " import-loader-vma-transaction-aborted no-vma-thunk-written no-real-dll-loaded no-arbitrary-execution"
        return _wine_process_import_loader_vma_patch_transaction_result(false, loader.error, plan.command, [], 0, 0, loader.module_count, loader.loaded_count, loader.released_count, loader.rollback_count, 0, evidence, loader.status)
    val patched = wine_process_apply_import_descriptor_thunk_patches_in_vma_with_peb_teb_vm_writes(plan, data, preferred_base, load_base, dynload_apis, descriptor_limit, symbol_limit, vm_writes)
    _wine_process_apply_import_loader_transaction_from_patched(plan, data, loader, patched)

fn _wine_process_apply_import_loader_transaction_from_patched(plan: WineProcessSessionPlan, data: [u8], loader: WineProcessImportLoaderStateResult, patched: WineProcessImportDescriptorVmaPatchResult) -> WineProcessImportLoaderVmaPatchTransactionResult:
    if not patched.ok:
        val evidence = loader.evidence + " " + patched.evidence + " import-loader-state-before-vma-patch import-loader-vma-transaction-aborted no-real-dll-loaded no-arbitrary-execution"
        return _wine_process_import_loader_vma_patch_transaction_result(false, patched.error, plan.command, patched.patched_image, patched.mapped_base, patched.mapped_size, loader.module_count, loader.loaded_count, loader.released_count, loader.rollback_count, patched.patched_count, evidence, patched.status)
    val evidence = loader.evidence + " " + patched.evidence + " import-loader-state-before-vma-patch import-loader-vma-transaction-complete no-real-dll-loaded no-arbitrary-execution"
    _wine_process_import_loader_vma_patch_transaction_result(true, "", plan.command, patched.patched_image, patched.mapped_base, patched.mapped_size, loader.module_count, loader.loaded_count, loader.released_count, loader.rollback_count, patched.patched_count, evidence, "import-loader-vma-transaction-complete")

pub fn wine_process_prepare_imported_entrypoint_handoff(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64) -> WineProcessImportedEntrypointHandoff:
    val transaction = wine_process_apply_import_loader_transaction_in_vma(plan, data, descriptor_limit, symbol_limit)
    _wine_process_prepare_imported_entrypoint_handoff_from_transaction(plan, transaction)

pub fn wine_process_prepare_imported_entrypoint_handoff_with_peb_teb_vm_writes(plan: WineProcessSessionPlan, data: [u8], descriptor_limit: i64, symbol_limit: i64, vm_writes: WinePebTebVmWriteResult) -> WineProcessImportedEntrypointHandoff:
    val transaction = wine_process_apply_import_loader_transaction_in_vma_with_peb_teb_vm_writes(plan, data, 0x400000, 0x400000, "native-module-open tls-callback", descriptor_limit, symbol_limit, vm_writes)
    _wine_process_prepare_imported_entrypoint_handoff_from_transaction(plan, transaction)

fn _wine_process_prepare_imported_entrypoint_handoff_from_transaction(plan: WineProcessSessionPlan, transaction: WineProcessImportLoaderVmaPatchTransactionResult) -> WineProcessImportedEntrypointHandoff:
    if not transaction.ok:
        return _wine_process_imported_entrypoint_handoff(false, transaction.error, plan.command, transaction.patched_image, transaction.mapped_base, transaction.mapped_size, 0, transaction.module_count, transaction.patched_count, transaction.evidence, transaction.status)
    val window_state = wine_image_entry_window_gate(transaction.patched_image, 1)
    if window_state != "ready":
        return _wine_process_imported_entrypoint_handoff(false, window_state, plan.command, transaction.patched_image, transaction.mapped_base, transaction.mapped_size, 0, transaction.module_count, transaction.patched_count, transaction.evidence, "rejected")
    val entry_rva = pe_entry_point_rva(transaction.patched_image)
    if entry_rva <= 0:
        return _wine_process_imported_entrypoint_handoff(false, "missing-entrypoint", plan.command, transaction.patched_image, transaction.mapped_base, transaction.mapped_size, 0, transaction.module_count, transaction.patched_count, transaction.evidence, "rejected")
    if entry_rva >= transaction.mapped_size:
        return _wine_process_imported_entrypoint_handoff(false, "entrypoint-unmapped", plan.command, transaction.patched_image, transaction.mapped_base, transaction.mapped_size, 0, transaction.module_count, transaction.patched_count, transaction.evidence, "rejected")
    val entry_address = transaction.mapped_base + entry_rva
    val evidence = transaction.evidence + " imported-entrypoint-handoff-ready entrypoint-mapped entrypoint-rva-valid entrypoint-section-executable entrypoint-window-readable no-host-code-jump no-arbitrary-execution"
    _wine_process_imported_entrypoint_handoff(true, "", plan.command, transaction.patched_image, transaction.mapped_base, transaction.mapped_size, entry_address, transaction.module_count, transaction.patched_count, evidence, "imported-entrypoint-handoff-ready")
