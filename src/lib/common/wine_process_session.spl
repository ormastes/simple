fn _wine_process_full_image_peb_teb_vm_write_evidence(vm_writes: WinePebTebVmWriteResult) -> text:
    if not vm_writes.ok:
        return ""
    if vm_writes.write_count != 6:
        return ""
    if vm_writes.byte_count != 48:
        return ""
    vm_writes.operations + " peb-teb-vm-writes-ready"

fn _wine_process_full_image_peb_teb_vm_write_error(vm_writes: WinePebTebVmWriteResult) -> text:
    if not vm_writes.ok:
        return "peb-teb-vm-write:" + vm_writes.state
    if vm_writes.write_count != 6:
        return "peb-teb-vm-write-count-mismatch"
    if vm_writes.byte_count != 48:
        return "peb-teb-vm-byte-count-mismatch"
    "peb-teb-vm-write:unknown"

