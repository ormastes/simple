# EasyFix Shared Rules Module - Orchestrator
#
# Re-exports all rule functions and runs them via check_all_rules().
#
# Rule IDs:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:sspec_missing_docstrings   — Add template docstring to describe/context
#   L:sspec_manual_assertions    — Replace manual if/fail with expect()
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:typo_suggestion            — Fix misspelled identifiers (Levenshtein)
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   E:type_mismatch_coercion     — Insert type coercion (.to_string() etc.)
#   L:deprecated_if_let          — Replace `if let` with `if val`

# ============================================================================
# Imports from sub-modules
# ============================================================================

use std.common.tooling.easy_fix.types.*
use std.common.tooling.easy_fix.rules_helpers.*
use std.common.tooling.easy_fix.rules_lint.*
use std.common.tooling.easy_fix.rules_structural.*
use std.common.tooling.easy_fix.rules_compiler.*

# ============================================================================
# Master: run all text-scanning rules
# ============================================================================

fn check_all_rules(source: String, file: String) -> [EasyFix]:
    # Split source ONCE and cache for all rule functions to reuse
    set_line_cache(source)

    var all_fixes: [EasyFix] = []

    var fixes1: [EasyFix] = []
    fixes1 = check_print_in_test_spec(source, file)
    for f in fixes1:
        all_fixes.push(f)

    var fixes2: [EasyFix] = []
    fixes2 = check_unnamed_duplicate_typed_args(source, file)
    for f in fixes2:
        all_fixes.push(f)

    var fixes3: [EasyFix] = []
    fixes3 = check_resource_leak(source, file)
    for f in fixes3:
        all_fixes.push(f)

    var fixes4: [EasyFix] = []
    fixes4 = check_sspec_missing_docstrings(source, file)
    for f in fixes4:
        all_fixes.push(f)

    var fixes5: [EasyFix] = []
    fixes5 = check_sspec_manual_assertions(source, file)
    for f in fixes5:
        all_fixes.push(f)

    var fixes6: [EasyFix] = []
    fixes6 = check_non_exhaustive_match(source, file)
    for f in fixes6:
        all_fixes.push(f)

    var fixes7: [EasyFix] = []
    fixes7 = check_parser_contextual_keyword(source, file)
    for f in fixes7:
        all_fixes.push(f)

    var fixes8: [EasyFix] = []
    fixes8 = check_deprecated_if_let(source, file)
    for f in fixes8:
        all_fixes.push(f)

    var fixes9: [EasyFix] = []
    fixes9 = check_stub_impl_text(source, file)
    for f in fixes9:
        all_fixes.push(f)

    # Rules 7 (typo) and 9 (type coercion) are no-ops in text-scanning mode.
    # They require compiler integration (Rust side).

    # Clear cache to avoid holding reference to large source string
    clear_line_cache()

    all_fixes

