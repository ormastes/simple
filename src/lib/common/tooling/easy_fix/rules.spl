#![allow(unnamed_duplicate_typed_args)]
@allow(star_import) # facade aggregator: imports submodule symbols for re-export
# EasyFix Shared Rules Module - Orchestrator
#
# Re-exports all rule functions and runs them via check_all_rules().
#
# Rule IDs:
#   L:print_in_test_spec         — Replace print() with expect() in test specs
#   L:unnamed_duplicate_typed_args — Add distinct param names for duplicate types
#   L:resource_leak              — Wrap resource in `with` block
#   L:sspec_missing_docstrings   — Add template docstring to describe/context
#   L:sspec_manual_assertions    — Replace manual if/fail with expect()
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:typo_suggestion            — Fix misspelled identifiers (Levenshtein)
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   E:type_mismatch_coercion     — Insert type coercion (.to_string() etc.)
#   L:deprecated_if_let          — Replace `if let` with `if val`

# ============================================================================
# Imports from sub-modules
# ============================================================================

use std.common.tooling.easy_fix.types.{EasyFix}
use std.common.tooling.easy_fix.rules_helpers.{clear_line_cache, set_line_cache}
use std.common.tooling.easy_fix.rules_lint.{check_print_in_test_spec, check_resource_leak, check_sspec_manual_assertions, check_sspec_missing_docstrings, check_stub_impl_text, check_unnamed_duplicate_typed_args}
use std.common.tooling.easy_fix.rules_structural.{check_deprecated_if_let, check_non_exhaustive_match, check_parser_contextual_keyword}
use std.common.tooling.easy_fix.rules_compiler.*

# ============================================================================
# Master: run all text-scanning rules
# ============================================================================

# Workaround: the compiler has a codegen bug where the 2nd+ sequential
# `for f in src: dst.push(f)` loops in a single function emit `mov x1, #0x0`
# instead of `mov x1, x0` (the actual element). Only the first such loop
# compiles correctly. Extracting into a helper ensures each loop is the first
# (and only) such loop in its function scope.
fn _extend_fixes(dst: [EasyFix], src: [EasyFix]):
    for f in src:
        dst.push(f)

fn check_all_rules(source: String, file: String) -> [EasyFix]:
    set_line_cache(source)

    var all_fixes: [EasyFix] = []

    _extend_fixes(all_fixes, check_print_in_test_spec(source, file))
    _extend_fixes(all_fixes, check_unnamed_duplicate_typed_args(source, file))
    _extend_fixes(all_fixes, check_resource_leak(source, file))
    _extend_fixes(all_fixes, check_sspec_missing_docstrings(source, file))
    _extend_fixes(all_fixes, check_sspec_manual_assertions(source, file))
    _extend_fixes(all_fixes, check_non_exhaustive_match(source, file))
    _extend_fixes(all_fixes, check_parser_contextual_keyword(source, file))
    _extend_fixes(all_fixes, check_deprecated_if_let(source, file))
    _extend_fixes(all_fixes, check_stub_impl_text(source, file))

    # Rules 7 (typo) and 9 (type coercion) are no-ops in text-scanning mode.
    # They require compiler integration (Rust side).

    # Clear cache to avoid holding reference to large source string
    clear_line_cache()

    all_fixes

