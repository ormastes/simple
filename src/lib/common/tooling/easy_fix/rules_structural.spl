@allow(unnamed_duplicate_typed_args)
# EasyFix Rules - Structural Rules
#
# Rules that check code structure and syntax patterns:
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   L:deprecated_if_let          — Replace `if let` with `if val`

use std.common.tooling.easy_fix.types.{EasyFix, FixConfidence, Replacement}

# ============================================================================
# Rule 6: non_exhaustive_match
# Detects match blocks without a catch-all `case _:` arm.
# Confidence: Safe
# ============================================================================

fn check_non_exhaustive_match(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var in_match = false
    var match_indent = 0
    var has_catch_all = false
    var match_end_line = 0
    var match_end_offset = 0
    var last_case_indent = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        if trimmed.starts_with("match ") and trimmed.ends_with(":"):
            # Start of match block
            if in_match and not has_catch_all:
                # Previous match was non-exhaustive — emit fix
                val prev_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
                fixes.push(prev_fix)
            in_match = true
            match_indent = indent
            has_catch_all = false
            match_end_line = line_num
            match_end_offset = byte_offset + line.len()

        if in_match and trimmed.starts_with("case "):
            last_case_indent = indent
            match_end_line = line_num
            match_end_offset = byte_offset + line.len()

            if trimmed.starts_with("case _:") or trimmed.starts_with("case _"):
                has_catch_all = true

        # Detect end of match block (dedent)
        if in_match and line.len() > 0 and indent <= match_indent and not trimmed.starts_with("match ") and not trimmed.starts_with("case "):
            if not has_catch_all:
                val dedent_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
                fixes.push(dedent_fix)
            in_match = false

        byte_offset = byte_offset + line.len() + 1

    # Handle match at end of file
    if in_match and not has_catch_all:
        val eof_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
        fixes.push(eof_fix)

    fixes

fn _create_non_exhaustive_fix(file: String, after_line: Int, after_offset: Int, case_indent: Int) -> EasyFix:
    val spaces = " ".repeat(case_indent)
    val inner_spaces = " ".repeat(case_indent + 4)
    val new_arm = "\n{spaces}case _:\n{inner_spaces}todo(\"handle remaining cases\")"
    var fix = EasyFix.create(
        id: "L:non_exhaustive_match:{after_line}",
        description: "add missing catch-all arm with todo()",
        confidence: FixConfidence.Safe
    )
    fix.add_replacement(Replacement.create(
        file: file,
        start: after_offset,
        end: after_offset,
        line: after_line,
        column: 1,
        new_text: new_arm
    ))
    fix

# ============================================================================
# Rule 8: parser_contextual_keyword (E0013)
# Detects common parser errors with contextual keywords.
# Confidence: Safe
# ============================================================================

fn check_parser_contextual_keyword(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        if trimmed.starts_with("async static fn "):
            val start = byte_offset + indent
            val end = start + 16
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{line_num}",
                description: "reorder keywords: `static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: line_num,
                column: indent + 1,
                new_text: "static async fn "
            ))
            fixes.push(fix)

        if trimmed.starts_with("static pub fn "):
            val start = byte_offset + indent
            val end = start + 14
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{line_num}",
                description: "reorder keywords: `pub static fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: line_num,
                column: indent + 1,
                new_text: "pub static fn "
            ))
            fixes.push(fix)

        if trimmed.starts_with("pub async static fn "):
            val start = byte_offset + indent
            val end = start + 20
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{line_num}",
                description: "reorder keywords: `pub static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: line_num,
                column: indent + 1,
                new_text: "pub static async fn "
            ))
            fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

# ============================================================================
# Rule 10: deprecated_if_let
# Detects `if let`, `while let`, `elif let` and replaces `let` with `val`.
# Confidence: Safe
# ============================================================================

fn check_deprecated_if_let(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        val idx_if = trimmed.find("if let ")
        if idx_if >= 0:
            val keyword_prefix_len = 3  # "if " is 3 chars
            val let_start = byte_offset + indent + idx_if + keyword_prefix_len
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: line_num,
                column: indent + idx_if + keyword_prefix_len + 1,
                new_text: "val"
            ))
            fixes.push(fix)

        val idx_while = trimmed.find("while let ")
        if idx_while >= 0:
            val keyword_prefix_len = 6  # "while " is 6 chars
            val let_start = byte_offset + indent + idx_while + keyword_prefix_len
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: line_num,
                column: indent + idx_while + keyword_prefix_len + 1,
                new_text: "val"
            ))
            fixes.push(fix)

        val idx_elif = trimmed.find("elif let ")
        if idx_elif >= 0:
            val keyword_prefix_len = 5  # "elif " is 5 chars
            val let_start = byte_offset + indent + idx_elif + keyword_prefix_len
            val let_end = let_start + 3
            var fix = EasyFix.create(
                id: "L:deprecated_if_let:{line_num}",
                description: "replace deprecated `let` with `val` in pattern binding",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: let_start,
                end: let_end,
                line: line_num,
                column: indent + idx_elif + keyword_prefix_len + 1,
                new_text: "val"
            ))
            fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    fixes

