#![allow(unnamed_duplicate_typed_args)]
# EasyFix Rules - Structural Rules
#
# Rules that check code structure and syntax patterns:
#   L:non_exhaustive_match       — Add missing match arms with todo()
#   E:parser_contextual_keyword  — Fix contextual keyword syntax
#   L:deprecated_if_let          — Replace `if let` with `if val`

use std.common.tooling.easy_fix.types.*
use std.common.tooling.easy_fix.rules_helpers.*

# ============================================================================
# Rule 6: non_exhaustive_match
# Detects match blocks without a catch-all `case _:` arm.
# Confidence: Safe
# ============================================================================

fn check_non_exhaustive_match(source: String, file: String) -> [EasyFix]:
    var fixes: [EasyFix] = []
    var lines: [text] = []
    val ne_cached_src = get_cached_source()
    val ne_cached_ln = get_cached_lines()
    val ne_cached_ln_len = ne_cached_ln.len()
    if source == ne_cached_src and ne_cached_ln_len > 0:
        lines = ne_cached_ln
    else:
        lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var in_match = false
    var match_indent = 0
    var has_catch_all = false
    var match_end_line = 0
    var match_end_offset = 0
    var last_case_indent = 0

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val trimmed2 = line.trim()
        val trimmed3 = line.trim()
        val trimmed4 = line.trim()
        val trimmed5 = line.trim()
        val trimmed6 = line.trim()
        val indent = line.len() - trimmed.len()

        val is_match_start = trimmed2.starts_with("match ")
        val is_match_colon = trimmed3.ends_with(":")
        if is_match_start and is_match_colon:
            # Start of match block
            if in_match and not has_catch_all:
                # Previous match was non-exhaustive — emit fix
                val prev_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
                fixes.push(prev_fix)
            in_match = true
            match_indent = indent
            has_catch_all = false
            match_end_line = line_num
            match_end_offset = byte_offset + line.len()

        val is_case = trimmed4.starts_with("case ")
        if in_match and is_case:
            last_case_indent = indent
            match_end_line = line_num
            match_end_offset = byte_offset + line.len()

            val is_case_wildcard = trimmed5.starts_with("case _:")
            val is_case_wild2 = trimmed6.starts_with("case _")
            if is_case_wildcard or is_case_wild2:
                has_catch_all = true

        # Detect end of match block (dedent)
        if in_match and line.len() > 0 and indent <= match_indent and not is_match_start and not is_case:
            if not has_catch_all:
                val dedent_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
                fixes.push(dedent_fix)
            in_match = false

        byte_offset = byte_offset + line.len() + 1

    # Handle match at end of file
    if in_match and not has_catch_all:
        val eof_fix = _create_non_exhaustive_fix(file, match_end_line, match_end_offset, last_case_indent)
        fixes.push(eof_fix)

    fixes

fn _create_non_exhaustive_fix(file: String, after_line: Int, after_offset: Int, case_indent: Int) -> EasyFix:
    val spaces = " ".repeat(case_indent)
    val inner_spaces = " ".repeat(case_indent + 4)
    val new_arm = "\n{spaces}case _:\n{inner_spaces}todo(\"handle remaining cases\")"
    var fix = EasyFix.create(
        id: "L:non_exhaustive_match:{after_line}",
        description: "add missing catch-all arm with todo()",
        confidence: FixConfidence.Safe
    )
    fix.add_replacement(Replacement.create(
        file: file,
        start: after_offset,
        end: after_offset,
        line: after_line,
        column: 1,
        new_text: new_arm
    ))
    fix

# ============================================================================
# Rule 8: parser_contextual_keyword (E0013)
# Detects common parser errors with contextual keywords.
# Confidence: Safe
# ============================================================================

fn check_parser_contextual_keyword(source: String, file: String) -> [EasyFix]:
    for_each_line(source, \ctx:
        var line_fixes = _empty_fixes()

        # Detect common misuses:
        # "async static fn" should be "static async fn"
        # "static pub fn" should be "pub static fn"
        # "pub async static fn" should be "pub static async fn"

        val tr = ctx.trimmed
        val tr2 = ctx.trimmed
        val tr3 = ctx.trimmed
        val is_async_static = tr.starts_with("async static fn ")
        val is_static_pub = tr2.starts_with("static pub fn ")
        val is_pub_async_static = tr3.starts_with("pub async static fn ")

        if is_async_static:
            val c_indent = ctx.indent
            val start = ctx.byte_offset + c_indent
            val end = start + 16  # len("async static fn ")
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: c_indent + 1,
                new_text: "static async fn "
            ))
            line_fixes = line_fixes + [fix]

        if is_static_pub:
            val c_indent = ctx.indent
            val start = ctx.byte_offset + c_indent
            val end = start + 14  # len("static pub fn ")
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `pub static fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: c_indent + 1,
                new_text: "pub static fn "
            ))
            line_fixes = line_fixes + [fix]

        if is_pub_async_static:
            val c_indent = ctx.indent
            val start = ctx.byte_offset + c_indent
            val end = start + 20  # len("pub async static fn ")
            var fix = EasyFix.create(
                id: "E:parser_contextual_keyword:{ctx.line_num}",
                description: "reorder keywords: `pub static async fn`",
                confidence: FixConfidence.Safe
            )
            fix.add_replacement(Replacement.create(
                file: file,
                start: start,
                end: end,
                line: ctx.line_num,
                column: c_indent + 1,
                new_text: "pub static async fn "
            ))
            line_fixes = line_fixes + [fix]

        line_fixes
    )

# ============================================================================
# Rule 10: deprecated_if_let
# Detects `if let`, `while let`, `elif let` and replaces `let` with `val`.
# Confidence: Safe
# ============================================================================

fn check_deprecated_if_let(source: String, file: String) -> [EasyFix]:
    for_each_line(source, \ctx:
        var line_fixes = _empty_fixes()

        val tr_let = ctx.trimmed
        for keyword in ["if let ", "while let ", "elif let "]:
            val idx = tr_let.find(keyword)
            if idx.? :
                val pos = idx.unwrap()
                # Calculate byte position of "let" within the keyword match
                val keyword_prefix_len = keyword.len() - 4  # length before "let "
                val let_start = ctx.byte_offset + ctx.indent + pos + keyword_prefix_len
                val let_end = let_start + 3  # "let" is 3 chars

                var fix = EasyFix.create(
                    id: "L:deprecated_if_let:{ctx.line_num}",
                    description: "replace deprecated `let` with `val` in pattern binding",
                    confidence: FixConfidence.Safe
                )
                fix.add_replacement(Replacement.create(
                    file: file,
                    start: let_start,
                    end: let_end,
                    line: ctx.line_num,
                    column: ctx.indent + pos + keyword_prefix_len + 1,
                    new_text: "val"
                ))
                line_fixes = line_fixes + [fix]

        line_fixes
    )

