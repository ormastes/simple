#![allow(unnamed_duplicate_typed_args)]
# EasyFix Rules - Shared Helpers
#
# Line iteration utilities, byte offset computation, and cached line splitting.
# Used by all rule sub-modules to avoid duplicating line-processing logic.

use std.common.tooling.easy_fix.types.*

# ============================================================================
# Data type: Line context for per-line rule callbacks
# ============================================================================

struct LineContext:
    """Context information for processing a source line."""
    line: text
    line_num: i64
    byte_offset: i64
    trimmed: text
    indent: i64

# Module-level cache for pre-split lines. Set by check_all_rules() to
# avoid re-splitting the same source 8+ times.
var _cached_lines: [text] = ["__init__"]
var _cached_source = ""

fn for_each_line(source: text, callback: fn(LineContext) -> [EasyFix]) -> [EasyFix]:
    """
    Iterate over source lines and collect fixes from callback.

    Handles the common pattern of splitting source, tracking line numbers/offsets,
    and collecting fixes. Reduces duplication in rule implementations.
    """
    var lines: [text] = []
    val cached_src = _cached_source
    val cached_ln = _cached_lines
    val cached_ln_len = cached_ln.len()
    if source == cached_src and cached_ln_len > 0:
        val cl_first = cached_ln[0]
        if cl_first != "__init__":
            lines = cached_ln
    val lines_len = lines.len()
    if lines_len == 0:
        lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var all_fixes: [EasyFix] = []

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        val context = LineContext(
            line: line,
            line_num: line_num,
            byte_offset: byte_offset,
            trimmed: trimmed,
            indent: indent
        )

        val line_fixes = callback(context)
        for fix in line_fixes:
            all_fixes = all_fixes + [fix]

        byte_offset = byte_offset + line.len() + 1

    all_fixes

# ============================================================================
# Helper: compute byte offset for a given line/column (1-based)
# ============================================================================

fn byte_offset_of(source: String, target_line: Int, target_col: Int) -> Int:
    var lines: [text] = []
    val bo_cached_src = _cached_source
    val bo_cached_ln = _cached_lines
    val bo_cached_ln_len = bo_cached_ln.len()
    if source == bo_cached_src and bo_cached_ln_len > 0:
        lines = bo_cached_ln
    else:
        lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + target_col - 1
        offset = offset + line.len() + 1  # +1 for \n
        line_num = line_num + 1
    offset

fn line_start_offset(source: String, target_line: Int) -> Int:
    byte_offset_of(source, target_line, 1)

fn line_end_offset(source: String, target_line: Int) -> Int:
    var lines: [text] = []
    val le_cached_src = _cached_source
    val le_cached_ln = _cached_lines
    val le_cached_ln_len = le_cached_ln.len()
    if source == le_cached_src and le_cached_ln_len > 0:
        lines = le_cached_ln
    else:
        lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + line.len()
        offset = offset + line.len() + 1
        line_num = line_num + 1
    offset

# ============================================================================
# Cache management functions (called by check_all_rules orchestrator)
# ============================================================================

fn set_line_cache(source: text):
    _cached_source = source
    _cached_lines = source.split("\n")

fn clear_line_cache():
    _cached_source = ""
    _cached_lines = ["__init__"]

fn get_cached_lines() -> [text]:
    _cached_lines

fn get_cached_source() -> text:
    _cached_source

fn _empty_fixes() -> [EasyFix]:
    """Create an empty EasyFix list (workaround for typed array in lambda/closure)."""
    var result: [EasyFix] = []
    result

