#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# EasyFix Rules - Shared Helpers
#
# Line iteration utilities, byte offset computation, and cached line splitting.
# Used by all rule sub-modules to avoid duplicating line-processing logic.

use std.common.tooling.easy_fix.types.{EasyFix}

# ============================================================================
# Data type: Line context for per-line rule callbacks
# ============================================================================

struct LineContext:
    """Context information for processing a source line."""
    line: text
    line_num: i64
    byte_offset: i64
    trimmed: text
    indent: i64

fn for_each_line(source: text, callback: fn(LineContext) -> [EasyFix]) -> [EasyFix]:
    """
    Iterate over source lines and collect fixes from callback.

    Handles the common pattern of splitting source, tracking line numbers/offsets,
    and collecting fixes. Reduces duplication in rule implementations.
    """
    var lines = source.split("\n")
    var line_num = 0
    var byte_offset = 0
    var all_fixes: [EasyFix] = []

    for line in lines:
        line_num = line_num + 1
        val trimmed = line.trim()
        val indent = line.len() - trimmed.len()

        val context = LineContext(
            line: line,
            line_num: line_num,
            byte_offset: byte_offset,
            trimmed: trimmed,
            indent: indent
        )

        val line_fixes = callback(context)
        for fix in line_fixes:
            all_fixes.push(fix)

        byte_offset = byte_offset + line.len() + 1

    all_fixes

# ============================================================================
# Helper: compute byte offset for a given line/column (1-based)
# ============================================================================

fn byte_offset_of(source: String, target_line: Int, target_col: Int) -> Int:
    var lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + target_col - 1
        offset = offset + line.len() + 1  # +1 for \n
        line_num = line_num + 1
    offset

fn line_start_offset(source: String, target_line: Int) -> Int:
    byte_offset_of(source, target_line, 1)

fn line_end_offset(source: String, target_line: Int) -> Int:
    var lines = source.split("\n")
    var offset = 0
    var line_num = 1
    for line in lines:
        if line_num == target_line:
            return offset + line.len()
        offset = offset + line.len() + 1
        line_num = line_num + 1
    offset

# ============================================================================
# Cache management functions — now no-ops (globals removed to fix NULL-data crash)
# ============================================================================

fn set_line_cache(source: text):
    val _ = source

fn clear_line_cache():
    val _ = 0

fn get_cached_lines() -> [text]:
    []

fn get_cached_source() -> text:
    ""

