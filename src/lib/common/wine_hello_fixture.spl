# Wine Hello Fixture — known-good fixture data for Wine hello.exe probe tests.
#
# Provides: wine_known_hello_exe_fixture_bytes,
#           wine_hello_fixture_precondition_manifest,
#           wine_hello_fixture_execution_evidence_struct.

# Returns the canonical minimal PE bytes for the hello.exe fixture.
fn wine_known_hello_exe_fixture_bytes() -> [u8]:
    # MZ DOS stub header magic bytes for a minimal PE fixture.
    [0x4D as u8, 0x5A as u8, 0x90 as u8, 0x00 as u8]

# Returns the precondition manifest for the hello.exe fixture.
fn wine_hello_fixture_precondition_manifest() -> text:
    "os=simpleos arch=x86_64 loader=pe-loader posix=verified pthread=verified " +
        "dynload=verified nt_bridge=verified pe_image=hello.exe"

# Returns the execution evidence struct for the hello.exe fixture.
fn wine_hello_fixture_execution_evidence_struct() -> text:
    "stdout=Hello from SimpleOS Wine\n exit_code=0 x11_display=:0 " +
        "window_title=SimpleOS Wine GUI Hello window_text=Hello from SimpleOS Wine\n " +
        "framebuffer_checksum=crc32:fixture"
