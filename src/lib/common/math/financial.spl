# Financial Math Library
#
# Pure Simple financial mathematics kernels extracted from the office formula
# engine (src/app/office/sheets/formula.spl). The numeric algorithms are copied
# verbatim — same iteration counts, same convergence thresholds, same rounding
# semantics — so results match the formula-engine originals. Only the public
# names and argument shapes were changed for a clean library API (the formula
# engine takes packed [[f64]] args; this module takes plain scalars/arrays).
#
# Sections: date arithmetic (civil <-> Excel serial), day-count basis 0..4,
# coupon date walking, annuity TVM (PMT/FV/PV/NPER), cash-flow analysis
# (NPV/XNPV/IRR/XIRR/MIRR), cumulative loan accumulation (CUMIPMT/CUMPRINC),
# depreciation (SLN/SYD/DB/DDB/VDB), French amortization (AMORLINC/AMORDEGRC),
# rate conversion (EFFECT/NOMINAL/RRI/PDURATION/FVSCHEDULE), and T-bills.
#
# Error-handling convention: lib functions return f64, never Excel-style
# `#NUM!`/`#ERR` strings (that mapping is the caller's job). Solver functions
# (rate_solve, irr_solve, xirr_solve, mirr_calc, nper_calc) return NaN
# (0.0/0.0) on domain error or non-convergence; closed-form functions return
# 0.0 on out-of-domain input. Each docstring states its domain.
#
# Elementary kernels (powf/exp/ln/sqrt) are imported from std.math.special —
# this module deliberately contains ZERO local pow/exp/ln/sqrt implementations.
#
# Import path: use std.math.financial.{annuity_pmt, irr_solve, ...}

use std.math.special.{powf, ln_f64, sqrt_f64}

fn _nan() -> f64:
    """NaN sentinel for invalid-domain solver results.

    Built as inf - inf: a literal `0.0 / 0.0` is const-folded and rejected
    by the compiler, and the test-runner interpreter traps even runtime
    float division by zero ("semantic: division by zero"). Overflow to
    infinity followed by inf - inf goes through plain IEEE arithmetic and
    yields NaN in every execution mode.
    """
    var big = 1.0e308
    val inf = big * 10.0
    inf - inf

# ============================================================================
# Date Arithmetic (civil <-> Excel serial conversion)
# ============================================================================

fn days_from_civil(y_in: i64, m: i64, d: i64) -> i64:
    """Days since 1970-01-01 (ISO epoch) for a civil date."""
    var y = y_in
    if m <= 2:
        y = y - 1
    val era = (if y >= 0: y else: y - 399) / 400
    val yoe = y - era * 400
    val mp = if m > 2: m - 3 else: m + 9
    val doy = (153 * mp + 2) / 5 + d - 1
    val doe = yoe * 365 + yoe / 4 - yoe / 100 + doy
    era * 146097 + doe - 719468

fn civil_from_days(z_in: i64) -> [i64]:
    """[year, month, day] for days since 1970-01-01."""
    val z = z_in + 719468
    val era = (if z >= 0: z else: z - 146096) / 146097
    val doe = z - era * 146097
    val yoe = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    val doy = doe - (365 * yoe + yoe / 4 - yoe / 100)
    val mp = (5 * doy + 2) / 153
    val day = doy - (153 * mp + 2) / 5 + 1
    val month = if mp < 10: mp + 3 else: mp - 9
    val year = yoe + era * 400 + (if month <= 2: 1 else: 0)
    [year, month, day]

fn serial_from_civil(y: i64, m: i64, d: i64) -> f64:
    """Excel date serial (1900 system): days since 1899-12-30."""
    (days_from_civil(y, m, d) + 25569).to_f64()

fn civil_from_serial(serial: f64) -> [i64]:
    """[year, month, day] for an Excel date serial."""
    civil_from_days(serial.to_i64() - 25569)

fn days_in_month(y: i64, m: i64) -> i64:
    """Days in month m of year y, with Gregorian leap-year rule."""
    if m == 2:
        if (y % 4 == 0 and (y % 100 != 0 or y % 400 == 0)):
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    31

fn edate_serial(y: i64, m: i64, d: i64, months: i64) -> f64:
    """Add `months` to (y,m,d) with end-of-month day clamp; return Excel serial.

    Coupon dates are always in the positive-year range so integer `/` and `%`
    stay well-defined (no negative-modulo hazard).
    """
    val tot = y * 12 + (m - 1) + months
    val ny = tot / 12
    val nm = tot % 12 + 1
    var nd = d
    val dim = days_in_month(ny, nm)
    if nd > dim:
        nd = dim
    serial_from_civil(ny, nm, nd)

# ============================================================================
# Day-Count Basis (0=US 30/360, 1=act/act, 2=act/360, 3=act/365, 4=Eur 30/360)
# ============================================================================

fn daycount_num(s1: f64, s2: f64, basis: i64) -> f64:
    """Day-count numerator between two serials per basis 0..4.

    basis 0 = US (NASD) 30/360: d1=min(d1,30); if d1==30 then d2=min(d2,30).
    basis 4 = European 30/360: both days clamped to 30 unconditionally.
    basis 1/2/3 = actual days (s2 - s1).
    """
    if basis == 1 or basis == 2 or basis == 3:
        return s2 - s1
    val c1 = civil_from_serial(s1)
    val c2 = civil_from_serial(s2)
    val y1 = c1[0]
    val m1 = c1[1]
    var d1 = c1[2]
    val y2 = c2[0]
    val m2 = c2[1]
    var d2 = c2[2]
    if basis == 4:
        if d1 > 30:
            d1 = 30
        if d2 > 30:
            d2 = 30
    else:
        if d1 > 30:
            d1 = 30
        if d1 == 30:
            if d2 > 30:
                d2 = 30
    (360 * (y2 - y1) + 30 * (m2 - m1) + (d2 - d1)).to_f64()

fn daycount_frac(s1: f64, s2: f64, basis: i64) -> f64:
    """Year fraction between two serials per basis 0..4 (Excel YEARFRAC).

    Basis 1 (actual/actual): same-year uses that year's length (365/366);
    cross-year uses the average year length spanning y1..y2.
    Domain: basis in 0..4 (other values fall through to the basis-1 branch).
    """
    if basis == 0 or basis == 4:
        return daycount_num(s1, s2, basis) / 360.0
    if basis == 2:
        return (s2 - s1) / 360.0
    if basis == 3:
        return (s2 - s1) / 365.0
    # basis 1: actual/actual
    val c1 = civil_from_serial(s1)
    val c2 = civil_from_serial(s2)
    val y1 = c1[0]
    val y2 = c2[0]
    if y1 == y2:
        var denom = 365.0
        if (y1 % 4 == 0 and (y1 % 100 != 0 or y1 % 400 == 0)):
            denom = 366.0
        return (s2 - s1) / denom
    val years = (y2 - y1 + 1).to_f64()
    val days = serial_from_civil(y2 + 1, 1, 1) - serial_from_civil(y1, 1, 1)
    (s2 - s1) / (days / years)

# ============================================================================
# Coupon Date Walking (bond machinery)
# ============================================================================

fn coup_prev(settle: f64, mat: f64, freq: i64) -> f64:
    """Previous coupon date (serial) on or before settlement.

    Walks backward from maturity in 12/freq month steps.
    Domain: settle < mat, freq in {1, 2, 4}.
    """
    val c = civil_from_serial(mat)
    val y = c[0]
    val m = c[1]
    val d = c[2]
    val step = 12 / freq
    var n = 0
    var cd = edate_serial(y, m, d, 0 - n * step)
    while cd > settle:
        n = n + 1
        cd = edate_serial(y, m, d, 0 - n * step)
    cd

fn coup_next(settle: f64, mat: f64, freq: i64) -> f64:
    """Next coupon date (serial) strictly after settlement.

    Domain: settle < mat, freq in {1, 2, 4}.
    """
    val c = civil_from_serial(mat)
    val y = c[0]
    val m = c[1]
    val d = c[2]
    val step = 12 / freq
    var n = 0
    var cd = edate_serial(y, m, d, 0 - n * step)
    while cd > settle:
        n = n + 1
        cd = edate_serial(y, m, d, 0 - n * step)
    edate_serial(y, m, d, 0 - (n - 1) * step)

# ============================================================================
# Annuity TVM (time value of money)
# ============================================================================

fn annuity_pmt(rate: f64, nper: f64, pv: f64) -> f64:
    """Periodic payment for a loan (Excel PMT with fv=0, type=0).

    Money-sign convention: a positive pv (loan received) yields a negative
    payment. Domain: nper != 0 (returns 0.0 when nper == 0).
    """
    if nper == 0.0:
        return 0.0
    if rate == 0.0:
        return 0.0 - pv / nper
    val g = powf(1.0 + rate, nper)
    0.0 - pv * rate * g / (g - 1.0)

fn annuity_fv(rate: f64, nper: f64, pmt: f64) -> f64:
    """Future value of a level payment stream (Excel FV with pv=0, type=0).

    Money-sign convention: negative payments accumulate a positive FV.
    """
    if rate == 0.0:
        return 0.0 - pmt * nper
    0.0 - pmt * (powf(1.0 + rate, nper) - 1.0) / rate

fn annuity_pv(rate: f64, nper: f64, pmt: f64) -> f64:
    """Present value of a level payment stream (Excel PV with fv=0, type=0).

    Money-sign convention: negative payments have a positive PV.
    """
    if rate == 0.0:
        return 0.0 - pmt * nper
    0.0 - pmt * (1.0 - powf(1.0 + rate, 0.0 - nper)) / rate

fn nper_calc(rate: f64, pmt: f64, pv: f64) -> f64:
    """Number of periods to amortize pv with payment pmt (Excel NPER, fv=0).

    Domain: rate > 0, pmt != 0, and pmt/(pmt + pv*rate) > 0.
    Returns NaN on domain error.
    """
    if rate <= 0.0 or pmt == 0.0:
        return _nan()
    val ratio = pmt / (pmt + pv * rate)
    if ratio <= 0.0:
        return _nan()
    ln_f64(ratio) / ln_f64(1.0 + rate)

fn rate_solve(nper: f64, pmt: f64, pv: f64, fv: f64) -> f64:
    """Solve the annuity rate via Newton's method (Excel RATE, type=0).

    Guess 0.1, forward-difference derivative (h=1e-6), 100 iterations,
    convergence threshold 1e-9 on the rate step. Returns NaN when the
    iteration diverges or fails to converge.
    """
    var r = 0.1
    var i = 0
    while i < 100:
        val f = _rate_residual(r, nper, pmt, pv, fv)
        val h = 0.000001
        val f2 = _rate_residual(r + h, nper, pmt, pv, fv)
        val d = (f2 - f) / h
        if d == 0.0:
            return _nan()
        val rn = r - f / d
        var diff = rn - r
        if diff < 0.0:
            diff = 0.0 - diff
        if diff < 0.000000001:
            return rn
        r = rn
        i = i + 1
    _nan()

fn _rate_residual(r: f64, nper: f64, pmt: f64, pv: f64, fv: f64) -> f64:
    """Residual of the annuity equation at rate r (type 0)."""
    if r == 0.0:
        return pv + pmt * nper + fv
    val g = powf(1.0 + r, nper)
    pv * g + pmt * (g - 1.0) / r + fv

# ============================================================================
# Loan Payment Decomposition + Cumulative Accumulation
# ============================================================================

fn _pmt_full(rate: f64, nper: f64, pv: f64, fv: f64, typ: f64) -> f64:
    """Excel PMT closed form including future value and annuity-due term."""
    if rate == 0.0:
        return 0.0 - (pv + fv) / nper
    val g = powf(1.0 + rate, nper)
    0.0 - (rate * (pv * g + fv)) / ((1.0 + rate * typ) * (g - 1.0))

fn _fv_balance(rate: f64, n: f64, pmt: f64, pv: f64, typ: f64) -> f64:
    """Future value / outstanding balance after n periods (money-sign convention)."""
    if rate == 0.0:
        return 0.0 - (pv + pmt * n)
    val g = powf(1.0 + rate, n)
    0.0 - (pv * g + pmt * (1.0 + rate * typ) * (g - 1.0) / rate)

fn _ipmt_at(rate: f64, per: f64, nper: f64, pv: f64, fv: f64, typ: f64) -> f64:
    """Interest portion of the payment for period `per`.

    Interest = (balance after per-1 payments) * rate; the annuity-due case
    discounts the first period back by (1 + rate).
    """
    val pmt = _pmt_full(rate, nper, pv, fv, typ)
    val bal = _fv_balance(rate, per - 1.0, pmt, pv, typ)
    var ip = bal * rate
    if typ == 1.0:
        ip = ip / (1.0 + rate)
    ip

fn cum_interest(rate: f64, nper: f64, pv: f64, start_period: f64, end_period: f64, typ: f64) -> f64:
    """Cumulative interest paid between two loan periods (Excel CUMIPMT).

    Domain: rate > 0, nper > 0, pv > 0, 1 <= start_period <= end_period <= nper.
    Returns 0.0 on domain error.
    """
    if (rate <= 0.0 or nper <= 0.0 or pv <= 0.0 or start_period < 1.0 or
        end_period < start_period or end_period > nper):
        return 0.0
    var total = 0.0
    var p = start_period
    while p <= end_period:
        total = total + _ipmt_at(rate, p, nper, pv, 0.0, typ)
        p = p + 1.0
    total

fn cum_principal(rate: f64, nper: f64, pv: f64, start_period: f64, end_period: f64, typ: f64) -> f64:
    """Cumulative principal repaid between two loan periods (Excel CUMPRINC).

    Domain: rate > 0, nper > 0, pv > 0, 1 <= start_period <= end_period <= nper.
    Returns 0.0 on domain error.
    """
    if (rate <= 0.0 or nper <= 0.0 or pv <= 0.0 or start_period < 1.0 or
        end_period < start_period or end_period > nper):
        return 0.0
    val pmt = _pmt_full(rate, nper, pv, 0.0, typ)
    var total = 0.0
    var p = start_period
    while p <= end_period:
        val ip = _ipmt_at(rate, p, nper, pv, 0.0, typ)
        total = total + (pmt - ip)
        p = p + 1.0
    total

# ============================================================================
# Cash-Flow Analysis (NPV / XNPV / IRR / XIRR / MIRR)
# ============================================================================

fn npv_at(rate: f64, flows: [f64]) -> f64:
    """NPV of cashflows at the given rate; flows[0] is at period 0 (undiscounted).

    NOTE: Excel's NPV() discounts from period 1 — this kernel matches the
    formula engine's internal _fin_npv_at used by IRR (period-0 convention).
    Callers wanting Excel NPV semantics should pass flows shifted by one
    period or divide the result by (1+rate).
    """
    var s = 0.0
    var i = 0
    while i < flows.len():
        val fi = flows[i]
        s = s + fi / powf(1.0 + rate, i.to_f64())
        i = i + 1
    s

fn xnpv_at(rate: f64, flows: [f64], day_offsets: [f64]) -> f64:
    """XNPV at the given rate: actual/365 fractional-year exponents measured
    from the first date. day_offsets are day serials (or plain day offsets);
    only differences from day_offsets[0] matter.

    Domain: rate > -1 (keeps the power base positive), congruent arrays.
    Returns 0.0 for empty input.
    """
    if flows.len() == 0:
        return 0.0
    val d0 = day_offsets[0]
    var s = 0.0
    var i = 0
    while i < flows.len():
        val di = day_offsets[i]
        val fi = flows[i]
        s = s + fi / powf(1.0 + rate, (di - d0) / 365.0)
        i = i + 1
    s

fn irr_solve(flows: [f64]) -> f64:
    """Internal rate of return via Newton's method with a bisection fallback.

    Newton: guess 0.1, analytic derivative, 100 iterations, 1e-9 step
    threshold. Fallback: 200 bisection steps over [-0.999999, 10].
    Domain: flows.len() >= 2 with at least one sign change.
    Returns NaN on domain error or non-convergence.
    """
    if flows.len() < 2:
        return _nan()
    var r = 0.1
    var i = 0
    while i < 100:
        val f = npv_at(r, flows)
        var d = 0.0
        var k = 1
        while k < flows.len():
            val fk = flows[k]
            d = d - k.to_f64() * fk / powf(1.0 + r, (k + 1).to_f64())
            k = k + 1
        if d == 0.0:
            i = 100
        else:
            val rn = r - f / d
            var diff = rn - r
            if diff < 0.0:
                diff = 0.0 - diff
            if diff < 0.000000001:
                return rn
            r = rn
            i = i + 1
    # Bisection fallback over a bracketed rate range.
    var lo = -0.999999
    var hi = 10.0
    var flo = npv_at(lo, flows)
    var j = 0
    while j < 200:
        val mid = (lo + hi) / 2.0
        val fm = npv_at(mid, flows)
        var afm = fm
        if afm < 0.0:
            afm = 0.0 - afm
        if afm < 0.000000001:
            return mid
        val same = (flo < 0.0) == (fm < 0.0)
        if same:
            lo = mid
            flo = fm
        else:
            hi = mid
        j = j + 1
    _nan()

fn xirr_solve(flows: [f64], day_offsets: [f64]) -> f64:
    """Dated IRR: the rate where xnpv_at = 0, solved by bisection on
    [-0.99, 10] (100 iterations).

    Domain: congruent arrays with >= 2 entries, no date before the first,
    and a sign change over the bracket. Returns NaN on domain error.
    """
    if flows.len() < 2 or flows.len() != day_offsets.len():
        return _nan()
    val d0 = day_offsets[0]
    var i = 0
    while i < day_offsets.len():
        val di = day_offsets[i]
        if di < d0:
            return _nan()
        i = i + 1
    var lo = -0.99
    var hi = 10.0
    var flo = xnpv_at(lo, flows, day_offsets)
    val fhi = xnpv_at(hi, flows, day_offsets)
    if (flo < 0.0) == (fhi < 0.0):
        return _nan()
    var j = 0
    while j < 100:
        val mid = (lo + hi) / 2.0
        val fm = xnpv_at(mid, flows, day_offsets)
        if (fm < 0.0) == (flo < 0.0):
            lo = mid
            flo = fm
        else:
            hi = mid
        j = j + 1
    (lo + hi) / 2.0

fn mirr_calc(flows: [f64], fin_rate: f64, rei_rate: f64) -> f64:
    """Modified IRR: finance negative flows at fin_rate, reinvest positives
    at rei_rate (Excel MIRR).

    Domain: flows.len() >= 2 with at least one negative and one positive
    flow. Returns NaN on domain error.
    """
    val n = flows.len()
    if n < 2:
        return _nan()
    var pv_neg = 0.0
    var fv_pos = 0.0
    var i = 0
    while i < n:
        val cf = flows[i]
        if cf < 0.0:
            pv_neg = pv_neg + cf / powf(1.0 + fin_rate, i.to_f64())
        else:
            fv_pos = fv_pos + cf * powf(1.0 + rei_rate, (n - 1 - i).to_f64())
        i = i + 1
    if pv_neg == 0.0:
        return _nan()
    val ratio = fv_pos / (0.0 - pv_neg)
    if ratio <= 0.0:
        return _nan()
    powf(ratio, 1.0 / (n - 1).to_f64()) - 1.0

# ============================================================================
# Depreciation (SLN / SYD / DB / DDB / VDB)
# ============================================================================

fn sln(cost: f64, salvage: f64, life: f64) -> f64:
    """Straight-line depreciation per period: (cost - salvage) / life.

    Domain: life != 0 (returns 0.0 when life == 0).
    """
    if life == 0.0:
        return 0.0
    (cost - salvage) / life

fn syd(cost: f64, salvage: f64, life: f64, per: f64) -> f64:
    """Sum-of-years-digits depreciation for period `per`.

    Domain: life > 0, 1 <= per <= life. Returns 0.0 on domain error.
    """
    if life <= 0.0 or per < 1.0 or per > life:
        return 0.0
    val numer = (cost - salvage) * (life - per + 1.0) * 2.0
    numer / (life * (life + 1.0))

fn db_period(cost: f64, salvage: f64, life: f64, period: f64) -> f64:
    """Fixed-declining-balance depreciation for `period` (Excel DB, no month).

    Excel rounds the rate = 1 - (salvage/cost)^(1/life) to three decimals.
    The first year is assumed full (no partial-period proration).
    Domain: cost > 0, life > 0, 1 <= period <= life. Returns 0.0 on error.
    """
    if cost <= 0.0 or life <= 0.0 or period < 1.0 or period > life:
        return 0.0
    val ratio = salvage / cost
    val raw_rate = 1.0 - powf(ratio, 1.0 / life)
    val rate = _round_half_away(raw_rate, 1000.0)
    var book = cost
    var dep = 0.0
    var i = 1.0
    while i <= period:
        dep = book * rate
        book = book - dep
        i = i + 1.0
    dep

fn ddb_period(cost: f64, salvage: f64, life: f64, period: f64) -> f64:
    """Double-declining-balance depreciation for `period` (Excel DDB).

    Uses factor 2/life and clamps each period's depreciation so book value
    never falls below salvage.
    Domain: life > 0, 1 <= period <= life. Returns 0.0 on domain error.
    """
    if life <= 0.0 or period < 1.0 or period > life:
        return 0.0
    val factor = 2.0 / life
    var book = cost
    var dep = 0.0
    var i = 1.0
    while i <= period:
        dep = book * factor
        if book - dep < salvage:
            dep = book - salvage
            if dep < 0.0:
                dep = 0.0
        book = book - dep
        i = i + 1.0
    dep

fn vdb_range(cost: f64, salvage: f64, life: f64, start_period: f64, end_period: f64, factor: f64, no_switch: bool) -> f64:
    """Variable declining-balance depreciation between two periods (Excel VDB).

    Declining balance at factor/life, switching to straight-line over the
    remaining life whenever that is larger (Excel's default; pass
    no_switch=true for pure declining balance). Partial first/last periods
    are prorated linearly within the period.
    Domain: cost >= 0, salvage >= 0, life > 0, factor > 0,
    0 <= start_period <= end_period <= life. Returns 0.0 on domain error.
    """
    if (cost < 0.0 or salvage < 0.0 or life <= 0.0 or factor <= 0.0 or
        start_period < 0.0 or end_period < start_period or end_period > life):
        return 0.0
    val vdb_rate = factor / life
    var book = cost
    var total = 0.0
    var p = 1.0
    val last = _ceil_f64(end_period)
    while p <= last:
        var dep = book * vdb_rate
        val sl = (book - salvage) / (life - p + 1.0)
        if not no_switch and sl > dep:
            dep = sl
        if book - dep < salvage:
            dep = book - salvage
            if dep < 0.0:
                dep = 0.0
        var seg_lo = p - 1.0
        if seg_lo < start_period:
            seg_lo = start_period
        var seg_hi = p
        if seg_hi > end_period:
            seg_hi = end_period
        if seg_hi > seg_lo:
            total = total + dep * (seg_hi - seg_lo)
        book = book - dep
        p = p + 1.0
    total

# ============================================================================
# French Amortization (AMORLINC / AMORDEGRC)
# ============================================================================

fn depreciation_coeff(years: f64) -> f64:
    """Excel AMORDEGRC coefficient from asset life 1/rate: <3y -> 1,
    3-4y -> 1.5, 5-6y -> 2, >6y -> 2.5."""
    if years < 3.0:
        return 1.0
    if years < 5.0:
        return 1.5
    if years <= 6.0:
        return 2.0
    2.5

fn amorlinc_period(cost: f64, date_purch: f64, first_period: f64, salvage: f64, period: i64, rate: f64, basis: i64) -> f64:
    """French straight-line amortization for one period (Excel AMORLINC).

    Period 0 is the prorated purchase period (cost*rate*YEARFRAC), periods
    1..n are full (cost*rate), the period after the last full one gets the
    remainder down to salvage, later periods get 0. Result is snapped to
    10 decimals to absorb IEEE noise (2400*0.15 = 360.00000000000006).
    Domain: cost > 0, 0 <= salvage < cost, 0 < rate <= 1, basis 0..4,
    period >= 0, first_period > date_purch. Returns 0.0 on domain error.
    """
    if (cost <= 0.0 or salvage < 0.0 or salvage >= cost or rate <= 0.0 or
        rate > 1.0 or basis < 0 or basis > 4 or period < 0 or
        first_period <= date_purch):
        return 0.0
    val frac_first = daycount_frac(date_purch, first_period, basis)
    val one_rate = cost * rate
    val f0 = frac_first * one_rate
    val delta = cost - salvage
    val nfull = _floor_f64((delta - f0) / one_rate).to_i64()
    var dep = 0.0
    if period == 0:
        dep = f0
    elif period <= nfull:
        dep = one_rate
    elif period == nfull + 1:
        dep = delta - one_rate * nfull.to_f64() - f0
    _round_half_away(dep, 10000000000.0)

fn amordegrc_period(cost: f64, date_purch: f64, first_period: f64, salvage: f64, period: i64, rate: f64, basis: i64) -> f64:
    """French degressive amortization for one period (Excel AMORDEGRC).

    Coefficient from life 1/rate; period 0 is ROUND(cost*rate*coeff*YEARFRAC);
    each later period is ROUND(book*rate*coeff); when accumulated depreciation
    would pass salvage, the final requested period gets half the remaining
    book (Excel algorithm) and later periods get 0.
    Domain: cost > 0, 0 <= salvage < cost, 0 < rate <= 1, basis 0..4,
    period >= 0, first_period > date_purch. Returns 0.0 on domain error.
    """
    if (cost <= 0.0 or salvage < 0.0 or salvage >= cost or rate <= 0.0 or
        rate > 1.0 or basis < 0 or basis > 4 or period < 0 or
        first_period <= date_purch):
        return 0.0
    val life_est = 1.0 / rate
    val coeff = depreciation_coeff(life_est)
    val drate = rate * coeff
    val frac_first = daycount_frac(date_purch, first_period, basis)
    var nrate = _round_half_away(frac_first * drate * cost, 1.0)
    if period == 0:
        return nrate
    var book = cost - nrate
    var rest = book - salvage
    var result = 0.0
    var settled = false
    var n = 1
    while n <= period and settled == false:
        nrate = _round_half_away(drate * book, 1.0)
        rest = rest - nrate
        if rest < 0.0:
            if n == period:
                result = _round_half_away(book * 0.5, 1.0)
            else:
                result = 0.0
            settled = true
        else:
            book = book - nrate
            result = nrate
        n = n + 1
    result

# ============================================================================
# Rate Conversion (EFFECT / NOMINAL / RRI / PDURATION / FVSCHEDULE)
# ============================================================================

fn effect_rate(nominal: f64, npery: f64) -> f64:
    """Effective annual rate from nominal rate compounded npery times/year.

    Domain: npery >= 1. Returns 0.0 on domain error.
    """
    if npery < 1.0:
        return 0.0
    powf(1.0 + nominal / npery, npery) - 1.0

fn nominal_rate(effect: f64, npery: f64) -> f64:
    """Nominal annual rate from effective rate, compounded npery times/year.

    Domain: npery >= 1, effect > -1. Returns 0.0 on domain error.
    """
    if npery < 1.0 or effect <= -1.0:
        return 0.0
    (powf(1.0 + effect, 1.0 / npery) - 1.0) * npery

fn rri(nper: f64, pv: f64, fv: f64) -> f64:
    """Equivalent periodic compound rate: (fv/pv)^(1/nper) - 1 (Excel RRI).

    Domain: nper > 0, pv > 0, fv >= 0. Returns 0.0 on domain error.
    """
    if nper <= 0.0 or pv <= 0.0 or fv < 0.0:
        return 0.0
    powf(fv / pv, 1.0 / nper) - 1.0

fn pduration(rate: f64, pv: f64, fv: f64) -> f64:
    """Periods for pv to grow to fv at rate: (ln fv - ln pv)/ln(1+rate).

    Domain: rate > 0, pv > 0, fv > 0. Returns 0.0 on domain error.
    """
    if rate <= 0.0 or pv <= 0.0 or fv <= 0.0:
        return 0.0
    (ln_f64(fv) - ln_f64(pv)) / ln_f64(1.0 + rate)

fn fv_schedule(principal: f64, rates: [f64]) -> f64:
    """Future value of principal under a schedule of varying rates
    (Excel FVSCHEDULE): principal * prod(1 + r_i)."""
    var value = principal
    for r in rates:
        value = value * (1.0 + r)
    value

# ============================================================================
# Treasury Bills
# ============================================================================

fn tbill_price(settle: f64, mat: f64, discount: f64) -> f64:
    """T-bill price per $100 face: 100*(1 - discount*dsm/360) (TBILLPRICE).

    Domain: settle < mat, discount > 0, mat - settle <= 365 days.
    Returns 0.0 on domain error.
    """
    val dsm = mat - settle
    if settle >= mat or discount <= 0.0 or dsm > 365.0:
        return 0.0
    100.0 * (1.0 - discount * dsm / 360.0)

fn tbill_yield(settle: f64, mat: f64, price: f64) -> f64:
    """T-bill annualized yield from price: (100-pr)/pr * 360/dsm (TBILLYIELD).

    Domain: settle < mat, price > 0, mat - settle <= 365 days.
    Returns 0.0 on domain error.
    """
    val dsm = mat - settle
    if settle >= mat or price <= 0.0 or dsm > 365.0:
        return 0.0
    (100.0 - price) / price * 360.0 / dsm

fn tbill_eq(settle: f64, mat: f64, discount: f64) -> f64:
    """T-bill bond-equivalent yield (TBILLEQ).

    Short bills (dsm <= 182): 365*d / (360 - d*dsm). Longer bills use the
    quadratic formula on the discounted price.
    Domain: settle < mat, discount > 0, dsm <= 365, non-negative
    discriminant. Returns 0.0 on domain error.
    """
    val dsm = mat - settle
    if settle >= mat or discount <= 0.0 or dsm > 365.0:
        return 0.0
    if dsm <= 182.0:
        return 365.0 * discount / (360.0 - discount * dsm)
    val price = 100.0 * (1.0 - discount * dsm / 360.0)
    val ry = dsm / 365.0
    val disc_root = ry * ry - (2.0 * ry - 1.0) * (1.0 - 100.0 / price)
    if disc_root < 0.0:
        return 0.0
    (0.0 - ry + sqrt_f64(disc_root)) / (ry - 0.5)

# ============================================================================
# Rounding Helpers (Excel ROUND semantics)
# ============================================================================

fn _round_half_away(v: f64, factor: f64) -> f64:
    """Round v to the given power-of-ten factor, half away from zero."""
    val scaled = v * factor
    var rounded_scaled = 0.0
    if scaled >= 0.0:
        rounded_scaled = (scaled + 0.5).to_i64().to_f64()
    else:
        rounded_scaled = (scaled - 0.5).to_i64().to_f64()
    rounded_scaled / factor

fn _floor_f64(x: f64) -> f64:
    """Largest integer <= x."""
    val t = x.to_i64().to_f64()
    if t > x:
        return t - 1.0
    t

fn _ceil_f64(x: f64) -> f64:
    """Smallest integer >= x."""
    val t = x.to_i64().to_f64()
    if t < x:
        return t + 1.0
    t
