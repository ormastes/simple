# Statistics module — pure function implementations for descriptive stats and regression.
# All functions take [f64] arrays as value types (copying is fine—no mutation).
# Invalid inputs return 0.0 or NaN as documented; no exceptions or error codes.
#
# Usage: use std.common.math.statistics.{mean, median, stdev_sample, ...}

use std.common.math.special.{exp_f64, ln_f64, sqrt_f64}

# =============================================================================
# Floor Helper (integer math; special.spl has no floor wrapper)
# =============================================================================

fn _floor_f64(x: f64) -> f64:
    """Largest integer <= x."""
    val t = x.to_i64().to_f64()
    if t > x:
        return t - 1.0
    t

# =============================================================================
# Sorting and Array Manipulation (Helper)
# =============================================================================

fn _sorted_asc_internal(values: [f64]) -> [f64]:
    """Insertion-sorted copy, ascending. O(n²) but acceptable for typical use."""
    var out: [f64] = []
    for v in values:
        var inserted = false
        var result: [f64] = []
        for existing in out:
            if not inserted and v < existing:
                result.push(v)
                inserted = true
            result.push(existing)
        if not inserted:
            result.push(v)
        out = result
    out

# =============================================================================
# Basic Descriptive Statistics
# =============================================================================

pub fn mean(values: [f64]) -> f64:
    """Arithmetic mean. Returns 0.0 for empty array."""
    if values.len() == 0:
        return 0.0
    var sum = 0.0
    for v in values:
        sum = sum + v
    sum / values.len().to_f64()

pub fn median(values: [f64]) -> f64:
    """Median of values. Returns 0.0 for empty array.

    For odd-length arrays: middle element.
    For even-length arrays: average of two middle elements."""
    if values.len() == 0:
        return 0.0
    val sorted = _sorted_asc_internal(values)
    val n = sorted.len()
    if n % 2 == 1:
        return sorted[n / 2]
    (sorted[n / 2 - 1] + sorted[n / 2]) / 2.0

pub fn mode_single(values: [f64]) -> f64:
    """Most frequently occurring value. Returns 0.0 for empty array.

    Returns the value with the highest frequency. Ties are broken by first occurrence."""
    if values.len() == 0:
        return 0.0
    var best = values[0]
    var best_count = 0
    for candidate in values:
        var count = 0
        for v in values:
            if v == candidate:
                count = count + 1
        if count > best_count:
            best_count = count
            best = candidate
    best

pub fn avedev(values: [f64]) -> f64:
    """Average absolute deviation from mean. Returns 0.0 for empty array."""
    if values.len() == 0:
        return 0.0
    val m = mean(values)
    var dev_sum = 0.0
    for v in values:
        val d = v - m
        dev_sum = dev_sum + (if d < 0.0: 0.0 - d else: d)
    dev_sum / values.len().to_f64()

pub fn devsq(values: [f64]) -> f64:
    """Sum of squared deviations from mean. Returns 0.0 for empty array."""
    if values.len() == 0:
        return 0.0
    val m = mean(values)
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    sq

# =============================================================================
# Variance and Standard Deviation
# =============================================================================

pub fn var_pop(values: [f64]) -> f64:
    """Population variance (dividing by n). Returns 0.0 for empty array."""
    if values.len() == 0:
        return 0.0
    val m = mean(values)
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    sq / values.len().to_f64()

pub fn var_sample(values: [f64]) -> f64:
    """Sample variance (dividing by n-1). Returns 0.0 for arrays with < 2 elements."""
    if values.len() < 2:
        return 0.0
    val n = values.len()
    var sum = 0.0
    for v in values:
        sum = sum + v
    val m = sum / n.to_f64()
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    sq / (n - 1).to_f64()

pub fn stdev_pop(values: [f64]) -> f64:
    """Population standard deviation. Returns 0.0 for empty array."""
    if values.len() == 0:
        return 0.0
    sqrt_f64(var_pop(values))

pub fn stdev_sample(values: [f64]) -> f64:
    """Sample standard deviation. Returns 0.0 for arrays with < 2 elements."""
    if values.len() < 2:
        return 0.0
    sqrt_f64(var_sample(values))

pub fn standardize(x: f64, mean_val: f64, stdev_val: f64) -> f64:
    """Z-score: (x - mean) / stdev. Returns 0.0 if stdev ≤ 0."""
    if stdev_val <= 0.0:
        return 0.0
    (x - mean_val) / stdev_val

# =============================================================================
# Distribution Moments (Skewness and Kurtosis)
# =============================================================================

pub fn skew(values: [f64]) -> f64:
    """Sample skewness (3rd moment). Returns 0.0 if < 3 values or zero stdev.

    Positive: right-skewed; negative: left-skewed; ~0: symmetric."""
    if values.len() < 3:
        return 0.0
    val n = values.len()
    var sum = 0.0
    for v in values:
        sum = sum + v
    val m = sum / n.to_f64()
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    val sd = sqrt_f64(sq / (n - 1).to_f64())
    if sd == 0.0:
        return 0.0
    var s3 = 0.0
    for v in values:
        val z = (v - m) / sd
        s3 = s3 + z * z * z
    val coef = n.to_f64() / ((n - 1).to_f64() * (n - 2).to_f64())
    coef * s3

pub fn kurt(values: [f64]) -> f64:
    """Sample kurtosis (excess; 0 for normal). Returns 0.0 if < 4 values or zero stdev.

    Positive: heavier tails; negative: lighter tails."""
    if values.len() < 4:
        return 0.0
    val n = values.len()
    var sum = 0.0
    for v in values:
        sum = sum + v
    val m = sum / n.to_f64()
    var sq = 0.0
    for v in values:
        val d = v - m
        sq = sq + d * d
    val sd = sqrt_f64(sq / (n - 1).to_f64())
    if sd == 0.0:
        return 0.0
    var s4 = 0.0
    for v in values:
        val z = (v - m) / sd
        s4 = s4 + z * z * z * z
    val nn = n.to_f64()
    val a = nn * (nn + 1.0) / ((nn - 1.0) * (nn - 2.0) * (nn - 3.0))
    val b = 3.0 * (nn - 1.0) * (nn - 1.0) / ((nn - 2.0) * (nn - 3.0))
    a * s4 - b

# =============================================================================
# Quantiles and Percentiles (Excel-compatible INC versions)
# =============================================================================

pub fn percentile_inc(values: [f64], p: f64) -> f64:
    """Percentile (p ∈ [0,1]). Returns 0.0 if empty or p out of range.

    Uses Excel PERCENTILE.INC method: linear interpolation between order statistics."""
    if values.len() == 0 or p < 0.0 or p > 1.0:
        return 0.0
    val sorted = _sorted_asc_internal(values)
    val pos = p * (sorted.len() - 1).to_f64()
    val lo = _floor_f64(pos).to_i64().to_i32()
    val frac = pos - lo.to_f64()
    if lo + 1 >= sorted.len():
        return sorted[sorted.len() - 1]
    sorted[lo] + frac * (sorted[lo + 1] - sorted[lo])

pub fn quartile_inc(values: [f64], q: f64) -> f64:
    """Quartile (q ∈ [0,4]; 0=min, 1=Q1, 2=median, 3=Q3, 4=max).
    Returns 0.0 if empty or q out of range.

    Uses Excel QUARTILE.INC method."""
    if values.len() == 0 or q < 0.0 or q > 4.0:
        return 0.0
    val sorted = _sorted_asc_internal(values)
    val posq = q / 4.0 * (sorted.len() - 1).to_f64()
    val loq = _floor_f64(posq).to_i64().to_i32()
    val fracq = posq - loq.to_f64()
    if loq + 1 >= sorted.len():
        return sorted[sorted.len() - 1]
    sorted[loq] + fracq * (sorted[loq + 1] - sorted[loq])

pub fn percentrank_inc(values: [f64], x: f64) -> f64:
    """Percentile rank of x (position as ∈ [0,1]). Returns 0.0 if empty or x out of bounds.

    Uses Excel PERCENTRANK.INC method: linear interpolation, truncated to 3 sig figs."""
    if values.len() == 0:
        return 0.0
    val sorted = _sorted_asc_internal(values)
    val n = sorted.len()
    if x < sorted[0] or x > sorted[n - 1]:
        return 0.0
    var idx = 0
    while idx < n and sorted[idx] < x:
        idx = idx + 1
    var rank = 0.0
    if idx < n and sorted[idx] == x:
        rank = idx.to_f64() / (n - 1).to_f64()
    else:
        val lo = sorted[idx - 1]
        val hi = sorted[idx]
        val frac = (x - lo) / (hi - lo)
        rank = ((idx - 1).to_f64() + frac) / (n - 1).to_f64()
    _truncate_sig3(rank)

fn _truncate_sig3(v: f64) -> f64:
    """Truncate a non-negative fraction to 3 significant digits (Excel PERCENTRANK)."""
    if v <= 0.0:
        return 0.0
    var t = v
    var scale = 1.0
    while t < 100.0:
        t = t * 10.0
        scale = scale * 10.0
    while t >= 1000.0:
        t = t / 10.0
        scale = scale / 10.0
    _floor_f64(t) / scale

pub fn trimmean(values: [f64], trim_percent: f64) -> f64:
    """Mean after trimming trim_percent from each tail. Returns 0.0 if empty or % out of range.

    trim_percent ∈ [0, 1). Trims floor(n * trim_percent / 2) from each end."""
    if values.len() == 0 or trim_percent < 0.0 or trim_percent >= 1.0:
        return 0.0
    val sorted = _sorted_asc_internal(values)
    val n = sorted.len()
    val trim = _floor_f64(n.to_f64() * trim_percent / 2.0).to_i64().to_i32()
    if 2 * trim >= n:
        return 0.0
    var sum = 0.0
    var i = trim
    while i < n - trim:
        sum = sum + sorted[i]
        i = i + 1
    sum / (n - 2 * trim).to_f64()

# =============================================================================
# Means (Geometric and Harmonic)
# =============================================================================

pub fn geomean(values: [f64]) -> f64:
    """Geometric mean. Returns 0.0 if empty, non-positive, or n=0.

    All values must be > 0. Computed as exp(mean(ln(values)))."""
    if values.len() == 0:
        return 0.0
    var ln_sum = 0.0
    for v in values:
        if v <= 0.0:
            return 0.0
        ln_sum = ln_sum + ln_f64(v)
    exp_f64(ln_sum / values.len().to_f64())

pub fn harmean(values: [f64]) -> f64:
    """Harmonic mean. Returns 0.0 if empty, contains zero, or n=0.

    Computed as n / sum(1/x). All values must be nonzero."""
    if values.len() == 0:
        return 0.0
    var inv_sum = 0.0
    for v in values:
        if v == 0.0:
            return 0.0
        inv_sum = inv_sum + 1.0 / v
    values.len().to_f64() / inv_sum

# =============================================================================
# Covariance and Correlation
# =============================================================================

pub fn covar_pop(ys: [f64], xs: [f64]) -> f64:
    """Population covariance of two equal-length series. Returns 0.0 on mismatch or empty.

    Covariance = mean((y - mean(y)) * (x - mean(x)))."""
    if ys.len() != xs.len() or ys.len() == 0:
        return 0.0
    val my = mean(ys)
    val mx = mean(xs)
    var sum = 0.0
    var i = 0
    while i < ys.len():
        sum = sum + (ys[i] - my) * (xs[i] - mx)
        i = i + 1
    sum / ys.len().to_f64()

pub fn covar_sample(ys: [f64], xs: [f64]) -> f64:
    """Sample covariance (dividing by n-1). Returns 0.0 on mismatch or < 2 pairs."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val n = ys.len()
    val my = mean(ys)
    val mx = mean(xs)
    var sum = 0.0
    var i = 0
    while i < n:
        sum = sum + (ys[i] - my) * (xs[i] - mx)
        i = i + 1
    sum / (n - 1).to_f64()

pub fn correl(ys: [f64], xs: [f64]) -> f64:
    """Pearson correlation coefficient ([-1,1]). Returns 0.0 on mismatch, < 2 pairs, or zero variance.

    Same as CORREL()/PEARSON() in Excel."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val v_num = covar_pop(ys, xs)
    val denom = sqrt_f64(var_pop(ys) * var_pop(xs))
    if denom == 0.0:
        return 0.0
    v_num / denom

pub fn rsq(ys: [f64], xs: [f64]) -> f64:
    """R² coefficient of determination. Returns 0.0 on mismatch, < 2 pairs, or zero variance."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val r = correl(ys, xs)
    r * r

# =============================================================================
# Linear Regression (Slope, Intercept, Forecast)
# =============================================================================

pub fn linfit(ys: [f64], xs: [f64]) -> [f64]:
    """Least-squares linear fit: returns [slope, intercept] or [0.0, 0.0] on error.

    Fits y = slope*x + intercept.
    Requires: |xs| >= 2, Σ(x-x̄)² > 0 (non-zero x-variance)."""
    if ys.len() < 2 or xs.len() != ys.len():
        return [0.0, 0.0]
    var x_sum = 0.0
    var y_sum = 0.0
    var i = 0
    while i < xs.len():
        x_sum = x_sum + xs[i]
        y_sum = y_sum + ys[i]
        i = i + 1
    val n = ys.len().to_f64()
    val x_mean = x_sum / n
    val y_mean = y_sum / n
    var xy_dev = 0.0
    var xx_dev = 0.0
    var j = 0
    while j < xs.len():
        val dx = xs[j] - x_mean
        val dy = ys[j] - y_mean
        xy_dev = xy_dev + dx * dy
        xx_dev = xx_dev + dx * dx
        j = j + 1
    if xx_dev == 0.0:
        return [0.0, 0.0]
    val slope = xy_dev / xx_dev
    val intercept = y_mean - slope * x_mean
    [slope, intercept]

pub fn slope(ys: [f64], xs: [f64]) -> f64:
    """Slope of linear regression (y vs x). Returns 0.0 on error or zero x-variance."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val fit = linfit(ys, xs)
    fit[0]

pub fn intercept(ys: [f64], xs: [f64]) -> f64:
    """Intercept of linear regression. Returns 0.0 on error or zero x-variance."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val fit = linfit(ys, xs)
    fit[1]

pub fn forecast_linear(x: f64, ys: [f64], xs: [f64]) -> f64:
    """Linear prediction: intercept + slope*x. Returns 0.0 on error or zero x-variance."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val fit = linfit(ys, xs)
    fit[1] + fit[0] * x

pub fn steyx(ys: [f64], xs: [f64]) -> f64:
    """Standard error of estimate (regression residual std dev).
    Returns 0.0 on mismatch, < 2 pairs, or zero x-variance.

    Computed as sqrt(Σ(residual²) / (n-2))."""
    if ys.len() != xs.len() or ys.len() < 2:
        return 0.0
    val fit = linfit(ys, xs)
    if fit[0] == 0.0 and fit[1] == 0.0 and ys.len() < 2:
        return 0.0
    var sum_sq_residuals = 0.0
    var i = 0
    while i < ys.len():
        val y_pred = fit[1] + fit[0] * xs[i]
        val residual = ys[i] - y_pred
        sum_sq_residuals = sum_sq_residuals + residual * residual
        i = i + 1
    sqrt_f64(sum_sq_residuals / (ys.len() - 2).to_f64())

# =============================================================================
# Exponential Growth Prediction
# =============================================================================

pub fn growth_predict(x: f64, ys: [f64], xs: [f64]) -> f64:
    """Exponential prediction: exp(intercept + slope*x) via log-linear fit.
    Returns 0.0 on error, non-positive y, or zero x-variance.

    Fits ln(y) = slope*x + intercept, then predicts exp(...)."""
    if ys.len() < 2 or xs.len() != ys.len():
        return 0.0
    var i = 0
    while i < ys.len():
        if ys[i] <= 0.0:
            return 0.0
        i = i + 1
    var log_ys: [f64] = []
    var j = 0
    while j < ys.len():
        log_ys.push(ln_f64(ys[j]))
        j = j + 1
    val fit = linfit(log_ys, xs)
    if fit[0] == 0.0 and fit[1] == 0.0 and ys.len() < 2:
        return 0.0
    val log_y_pred = fit[0] * x + fit[1]
    exp_f64(log_y_pred)

# =============================================================================
# Ranking and Order Statistics
# =============================================================================

pub fn rank_value(v: f64, values: [f64], ascending: bool) -> f64:
    """Rank of value v in array. Returns 1.0 for highest (ascending=false) or lowest (ascending=true).
    Returns 0.0 if array is empty.

    Descending rank (default Excel): larger values get lower ranks."""
    if values.len() == 0:
        return 0.0
    var rank = 1
    for item in values:
        if ascending:
            if item < v:
                rank = rank + 1
        else:
            if item > v:
                rank = rank + 1
    rank.to_f64()

pub fn large(values: [f64], k: i32) -> f64:
    """k-th largest value (k=1 is max). Returns 0.0 if k out of range or empty."""
    if values.len() == 0 or k < 1 or k > values.len():
        return 0.0
    val sorted = _sorted_asc_internal(values)
    sorted[sorted.len() - k]

pub fn small(values: [f64], k: i32) -> f64:
    """k-th smallest value (k=1 is min). Returns 0.0 if k out of range or empty."""
    if values.len() == 0 or k < 1 or k > values.len():
        return 0.0
    val sorted = _sorted_asc_internal(values)
    sorted[k - 1]

# =============================================================================
# Fisher Transformation
# =============================================================================

pub fn fisher(x: f64) -> f64:
    """Fisher Z-transform: 0.5*ln((1+x)/(1-x)). Returns 0.0 if x outside (-1, 1)."""
    if x <= -1.0 or x >= 1.0:
        return 0.0
    0.5 * ln_f64((1.0 + x) / (1.0 - x))

pub fn fisher_inv(z: f64) -> f64:
    """Inverse Fisher transform: (exp(2z) - 1) / (exp(2z) + 1)."""
    val e2 = exp_f64(2.0 * z)
    (e2 - 1.0) / (e2 + 1.0)

# =============================================================================

