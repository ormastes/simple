# Math transcendental wrappers — SFFI bridge for libm functions
#
# Covers rt_math_* symbols from runtime_math.c not already in
# src/lib/nogc_sync_mut/io/math.spl.
# (log, log2, log10, asin, acos, atan, atan2, sinh, cosh, tanh, ceil, floor
#  are already in io/math.spl — do not redeclare here.)
#
# Import path: use std.math.math.{math_sin, math_cos, ...}
#
# Notes:
# - rt_math_sqrt and rt_math_pow are known to the interpreter.
# - rt_math_floor and rt_math_ceil are known (declared in io/math.spl),
#   re-declared here to support pure-Simple abs/trunc/round implementations.
# - rt_math_sin, rt_math_cos, rt_math_tan, rt_math_exp, rt_math_cbrt,
#   rt_math_hypot, rt_math_fma require bootstrap rebuild for interpreter mode.

# --- Known-to-interpreter externs (also in io/math.spl or distance.spl) ---
extern fn rt_math_sqrt(x: f64) -> f64
extern fn rt_math_pow(base: f64, exp: f64) -> f64
extern fn rt_math_floor(x: f64) -> f64
extern fn rt_math_ceil(x: f64) -> f64

# --- Externs for native builds ---
extern fn rt_math_sin(x: f64) -> f64
extern fn rt_math_cos(x: f64) -> f64
extern fn rt_math_tan(x: f64) -> f64
extern fn rt_math_exp(x: f64) -> f64
extern fn rt_math_cbrt(x: f64) -> f64
extern fn rt_math_hypot(x: f64, y: f64) -> f64
extern fn rt_math_fma(x: f64, y: f64, z: f64) -> f64

pub fn math_sin(x: f64) -> f64:
    """Sine of x (radians, SFFI)."""
    rt_math_sin(x)

pub fn math_cos(x: f64) -> f64:
    """Cosine of x (radians, SFFI)."""
    rt_math_cos(x)

pub fn math_tan(x: f64) -> f64:
    """Tangent of x (radians, SFFI)."""
    rt_math_tan(x)

pub fn math_pow(base: f64, exp: f64) -> f64:
    """base raised to exp (SFFI)."""
    rt_math_pow(base, exp)

pub fn math_exp(x: f64) -> f64:
    """e raised to x (SFFI)."""
    rt_math_exp(x)

pub fn math_sqrt(x: f64) -> f64:
    """Square root (SFFI)."""
    rt_math_sqrt(x)

pub fn math_cbrt(x: f64) -> f64:
    """Cube root (SFFI)."""
    rt_math_cbrt(x)

pub fn math_hypot(x: f64, y: f64) -> f64:
    """Hypotenuse sqrt(x*x + y*y) (SFFI)."""
    rt_math_hypot(x, y)

pub fn math_fma(x: f64, y: f64, z: f64) -> f64:
    """Fused multiply-add: x*y+z with single rounding (SFFI)."""
    rt_math_fma(x, y, z)

# --- Mathematical constants ---

pub val MATH_PI: f64 = 3.141592653589793
pub val MATH_E: f64 = 2.718281828459045
pub val MATH_TAU: f64 = 6.283185307179586
pub val MATH_INF: f64 = 1.7976931348623157e+308

# --- Pure-Simple implementations (interpreter-safe, use floor/ceil externs) ---

pub fn math_abs(x: f64) -> f64:
    """Absolute value of f64."""
    if x < 0.0: 0.0 - x else: x

pub fn math_trunc(x: f64) -> f64:
    """Truncate f64 toward zero."""
    if x >= 0.0:
        rt_math_floor(x)
    else:
        rt_math_ceil(x)

pub fn math_round(x: f64) -> f64:
    """Round f64 to nearest integer, half away from zero."""
    if x >= 0.0:
        rt_math_floor(x + 0.5)
    else:
        rt_math_ceil(x - 0.5)

pub fn math_min(a: f64, b: f64) -> f64:
    """Minimum of two f64 values."""
    if a < b: a else: b

pub fn math_max(a: f64, b: f64) -> f64:
    """Maximum of two f64 values."""
    if a > b: a else: b

pub fn math_clamp(x: f64, lo: f64, hi: f64) -> f64:
    """Clamp x to [lo, hi]."""
    if x < lo: lo elif x > hi: hi else: x

pub fn math_lerp(a: f64, b: f64, t: f64) -> f64:
    """Linear interpolation: a + t*(b-a)."""
    a + t * (b - a)
