# Probability distribution kernels — pure functions.
#
# Extracted from the inline probability-distribution kernels in
# src/app/office/sheets/formula.spl (NORM.DIST/INV, T.DIST/INV, CHISQ.DIST/INV,
# F.DIST/INV, BETA.DIST/INV, GAMMA.DIST/INV, BINOM.DIST, POISSON.DIST,
# EXPON.DIST, HYPGEOM.DIST, NEGBINOM.DIST, WEIBULL.DIST, LOGNORM.DIST/INV).
# formula.spl is left untouched (read-only reference); this module is the
# reusable stdlib home for the same kernels.
#
# Import path: use std.math.distributions.{norm_cdf, norm_inv, ...}
#
# Convention: pure f64 in/out, no Excel #ERR strings. Invalid domain input
# returns NaN (via 0.0 / 0.0) for probability/parameter violations, matching
# the internal fallback style formula.spl itself uses (0.0 at pdf boundaries,
# CellValue.ErrorVal for hard domain errors — since there is no CellValue
# here, NaN stands in for the latter and 0.0 is kept where formula.spl
# returns 0.0, e.g. sub-support pdf/pmf points).
#
# Private-helper note: `special.spl` (owned by another agent) is slated to
# become the shared home for `_gammaln` / `_betainc` / `_gammainc_p` and
# friends. Until that lands, this file duplicates the small numeric kernels
# it needs (`_gammaln`, `_erf`, `_betainc`, `_betacf`, `_gammainc_p`,
# `_gammainc_series`, `_gammainc_cf`, `_betainc_inv`, `_gammainc_inv`,
# `_norm_inv_std`, plus the interpreter-safe `_exp_f64`/`_ln_f64`/`_sqrt_f64`/
# `_pow_f64` primitives) as file-local `_`-prefixed functions, copied verbatim
# in numerical behavior from formula.spl. A later rewiring pass should
# de-duplicate against `special.spl` once it exists.

val _PI: f64 = 3.141592653589793
val _LN2: f64 = 0.6931471805599453

fn _nan() -> f64:
    """NaN sentinel for invalid-domain results (0.0 / 0.0 is a true IEEE NaN
    under this runtime — verified: (0.0/0.0) != (0.0/0.0) is true)."""
    0.0 / 0.0

# --- Interpreter-safe primitives (verbatim algorithms from formula.spl) ---

fn _exp_f64(x: f64) -> f64:
    """e^x via argument halving + Taylor series, squared back up."""
    var v = x
    var squarings = 0
    while v > 0.5 or v < -0.5:
        v = v / 2.0
        squarings = squarings + 1
    var term = 1.0
    var sum = 1.0
    var n = 1
    while n <= 18:
        term = term * v / n.to_f64()
        sum = sum + term
        n = n + 1
    while squarings > 0:
        sum = sum * sum
        squarings = squarings - 1
    sum

fn _ln_f64(x: f64) -> f64:
    """Natural log via binary normalization + atanh series. x must be > 0."""
    var m = x
    var e = 0
    while m >= 2.0:
        m = m / 2.0
        e = e + 1
    while m < 1.0:
        m = m * 2.0
        e = e - 1
    val z = (m - 1.0) / (m + 1.0)
    val z2 = z * z
    var term = z
    var sum = 0.0
    var k = 1
    while k <= 30:
        sum = sum + term / k.to_f64()
        term = term * z2
        k = k + 2
    e.to_f64() * _LN2 + 2.0 * sum

fn _sqrt_f64(x: f64) -> f64:
    """Square root via Newton's method. Assumes x >= 0."""
    if x == 0.0:
        return 0.0
    var g = x
    var i = 0
    while i < 40:
        g = 0.5 * (g + (x / g))
        i = i + 1
    g

fn _fabs(x: f64) -> f64:
    """Absolute value of an f64."""
    if x < 0.0:
        return 0.0 - x
    x

fn _pow_f64(base: f64, exp: f64) -> f64:
    """Power function for integer exponents (base may be any sign)."""
    val int_exp = exp.to_i64()
    if int_exp == 0:
        return 1.0
    var result = 1.0
    var neg = false
    var e = int_exp
    if e < 0:
        neg = true
        e = 0 - e
    var i: i64 = 0
    while i < e:
        result = result * base
        i = i + 1
    if neg:
        return 1.0 / result
    result

fn _fact_i64(n: i64) -> f64:
    """n! as f64 (n >= 0)."""
    var out = 1.0
    var i: i64 = 2
    while i <= n:
        out = out * i.to_f64()
        i = i + 1
    out

# --- Special-function kernels (verbatim algorithms from formula.spl) ---

fn _erf(x: f64) -> f64:
    """Error function via Abramowitz-Stegun 7.1.26 (|err| < 1.5e-7)."""
    val ax = if x < 0.0: 0.0 - x else: x
    val t = 1.0 / (1.0 + 0.3275911 * ax)
    val poly = t * (0.254829592 + t * (-0.284496736 + t * (1.421413741 + t * (-1.453152027 + t * 1.061405429))))
    val e = 1.0 - poly * _exp_f64(0.0 - ax * ax)
    if x < 0.0:
        return 0.0 - e
    e

fn _norm_cdf_std(z: f64) -> f64:
    """Standard normal CDF via Abramowitz-Stegun 7.1.26 (|err| < 1.5e-7)."""
    val x = if z < 0.0: 0.0 - z else: z
    val cdf = 0.5 * (1.0 + _erf(x / 1.4142135623730951))
    if z < 0.0:
        return 1.0 - cdf
    cdf

fn _gammaln(x: f64) -> f64:
    """Natural log of the gamma function via the Lanczos g=7 approximation (x > 0)."""
    val xx = x - 1.0
    var a = 0.99999999999980993
    a = a + 676.5203681218851 / (xx + 1.0)
    a = a - 1259.1392167224028 / (xx + 2.0)
    a = a + 771.32342877765313 / (xx + 3.0)
    a = a - 176.61502916214059 / (xx + 4.0)
    a = a + 12.507343278686905 / (xx + 5.0)
    a = a - 0.13857109526572012 / (xx + 6.0)
    a = a + 9.9843695780195716e-6 / (xx + 7.0)
    a = a + 1.5056327351493116e-7 / (xx + 8.0)
    val t = xx + 7.5
    0.5 * _ln_f64(2.0 * _PI) + (xx + 0.5) * _ln_f64(t) - t + _ln_f64(a)

fn _norm_inv_std(p: f64) -> f64:
    """Inverse standard normal CDF via Acklam's rational approximation (0 < p < 1)."""
    val plow = 0.02425
    val phigh = 1.0 - plow
    if p < plow:
        val q = _sqrt_f64(0.0 - 2.0 * _ln_f64(p))
        val num = ((((-7.784894002430293e-03 * q - 3.223964580411365e-01) * q - 2.400758277161838e+00) * q - 2.549732539343734e+00) * q + 4.374664141464968e+00) * q + 2.938163982698783e+00
        val den = (((7.784695709041462e-03 * q + 3.224671290700398e-01) * q + 2.445134137142996e+00) * q + 3.754408661907416e+00) * q + 1.0
        return num / den
    if p <= phigh:
        val q = p - 0.5
        val r = q * q
        val num = (((((-3.969683028665376e+01 * r + 2.209460984245205e+02) * r - 2.759285104469687e+02) * r + 1.383577518672690e+02) * r - 3.066479806614716e+01) * r + 2.506628277459239e+00) * q
        val den = ((((-5.447609879822406e+01 * r + 1.615858368580409e+02) * r - 1.556989798598866e+02) * r + 6.680131188771972e+01) * r - 1.328068155288572e+01) * r + 1.0
        return num / den
    val qh = _sqrt_f64(0.0 - 2.0 * _ln_f64(1.0 - p))
    val numh = ((((-7.784894002430293e-03 * qh - 3.223964580411365e-01) * qh - 2.400758277161838e+00) * qh - 2.549732539343734e+00) * qh + 4.374664141464968e+00) * qh + 2.938163982698783e+00
    val denh = (((7.784695709041462e-03 * qh + 3.224671290700398e-01) * qh + 2.445134137142996e+00) * qh + 3.754408661907416e+00) * qh + 1.0
    0.0 - numh / denh

fn _betacf(a: f64, b: f64, x: f64) -> f64:
    """Continued fraction for the incomplete beta function via Lentz (NR §6.4)."""
    val fpmin = 1e-30
    val eps = 3e-14
    val qab = a + b
    val qap = a + 1.0
    val qam = a - 1.0
    var c = 1.0
    var d = 1.0 - qab * x / qap
    if _fabs(d) < fpmin:
        d = fpmin
    d = 1.0 / d
    var h = d
    var m = 1
    while m <= 100:
        val fm = m.to_f64()
        val m2 = 2.0 * fm
        var aa = fm * (b - fm) * x / ((qam + m2) * (a + m2))
        d = 1.0 + aa * d
        if _fabs(d) < fpmin:
            d = fpmin
        c = 1.0 + aa / c
        if _fabs(c) < fpmin:
            c = fpmin
        d = 1.0 / d
        h = h * d * c
        aa = 0.0 - (a + fm) * (qab + fm) * x / ((a + m2) * (qap + m2))
        d = 1.0 + aa * d
        if _fabs(d) < fpmin:
            d = fpmin
        c = 1.0 + aa / c
        if _fabs(c) < fpmin:
            c = fpmin
        d = 1.0 / d
        val del = d * c
        h = h * del
        if _fabs(del - 1.0) < eps:
            break
        m = m + 1
    h

fn _betainc(x: f64, a: f64, b: f64) -> f64:
    """Regularized incomplete beta I_x(a,b) via Lentz continued fractions (NR §6.4)."""
    if x <= 0.0:
        return 0.0
    if x >= 1.0:
        return 1.0
    val bt = _exp_f64(_gammaln(a + b) - _gammaln(a) - _gammaln(b) + a * _ln_f64(x) + b * _ln_f64(1.0 - x))
    if x < (a + 1.0) / (a + b + 2.0):
        return bt * _betacf(a, b, x) / a
    1.0 - bt * _betacf(b, a, 1.0 - x) / b

fn _gammainc_series(a: f64, x: f64) -> f64:
    """Lower regularized incomplete gamma P(a,x) via series (NR §6.2), for x < a+1."""
    val eps = 3e-14
    val gln = _gammaln(a)
    var ap = a
    var sum = 1.0 / a
    var del = sum
    var n = 1
    while n <= 300:
        ap = ap + 1.0
        del = del * x / ap
        sum = sum + del
        if _fabs(del) < _fabs(sum) * eps:
            break
        n = n + 1
    sum * _exp_f64(0.0 - x + a * _ln_f64(x) - gln)

fn _gammainc_cf(a: f64, x: f64) -> f64:
    """Upper regularized incomplete gamma Q(a,x) via continued fraction (NR §6.2), x >= a+1."""
    val fpmin = 1e-30
    val eps = 3e-14
    val gln = _gammaln(a)
    var b = x + 1.0 - a
    var c = 1.0 / fpmin
    var d = 1.0 / b
    var h = d
    var i = 1
    while i <= 300:
        val fi = i.to_f64()
        val an = 0.0 - fi * (fi - a)
        b = b + 2.0
        d = an * d + b
        if _fabs(d) < fpmin:
            d = fpmin
        c = b + an / c
        if _fabs(c) < fpmin:
            c = fpmin
        d = 1.0 / d
        val del = d * c
        h = h * del
        if _fabs(del - 1.0) < eps:
            break
        i = i + 1
    _exp_f64(0.0 - x + a * _ln_f64(x) - gln) * h

fn _gammainc_p(a: f64, x: f64) -> f64:
    """Regularized lower incomplete gamma P(a,x): series for x<a+1, CF otherwise (NR §6.2)."""
    if x <= 0.0:
        return 0.0
    if x < a + 1.0:
        return _gammainc_series(a, x)
    1.0 - _gammainc_cf(a, x)

fn _betainc_inv(p: f64, a: f64, b: f64) -> f64:
    """Inverse of I_x(a,b) in x by bisection on [0,1], 60 iterations."""
    var lo = 0.0
    var hi = 1.0
    var it = 0
    while it < 60:
        val mid = (lo + hi) / 2.0
        if _betainc(mid, a, b) > p:
            hi = mid
        else:
            lo = mid
        it = it + 1
    (lo + hi) / 2.0

fn _gammainc_inv(p: f64, a: f64) -> f64:
    """Inverse of P(a,x) in x by bracket-expand then bisection, 60 iterations."""
    var hi = 1.0
    var guard = 0
    while _gammainc_p(a, hi) < p and guard < 200:
        hi = hi * 2.0
        guard = guard + 1
    var lo = 0.0
    var it = 0
    while it < 60:
        val mid = (lo + hi) / 2.0
        if _gammainc_p(a, mid) > p:
            hi = mid
        else:
            lo = mid
        it = it + 1
    (lo + hi) / 2.0

fn _t_2t_area(x: f64, df: f64) -> f64:
    """Two-tailed Student-t area P(|T|>x) = I_{df/(df+x^2)}(df/2, 1/2)."""
    _betainc(df / (df + x * x), df / 2.0, 0.5)

fn _t_inv_2t(alpha: f64, df: f64) -> f64:
    """Inverse two-tailed t: x>0 s.t. _t_2t_area(x,df)=alpha (area decreases in x)."""
    var lo = 0.0
    var hi = 1.0
    var guard = 0
    while _t_2t_area(hi, df) > alpha and guard < 200:
        hi = hi * 2.0
        guard = guard + 1
    var it = 0
    while it < 60:
        val mid = (lo + hi) / 2.0
        if _t_2t_area(mid, df) > alpha:
            lo = mid
        else:
            hi = mid
        it = it + 1
    (lo + hi) / 2.0

fn _f_cdf_left(x: f64, d1: f64, d2: f64) -> f64:
    """Snedecor F left-tail CDF = I_{d1*x/(d1*x+d2)}(d1/2, d2/2)."""
    _betainc(d1 * x / (d1 * x + d2), d1 / 2.0, d2 / 2.0)

fn _f_inv_left(p: f64, d1: f64, d2: f64) -> f64:
    """Inverse of the F left-tail CDF by bracket-expand then bisection, 60 iterations."""
    var hi = 1.0
    var guard = 0
    while _f_cdf_left(hi, d1, d2) < p and guard < 200:
        hi = hi * 2.0
        guard = guard + 1
    var lo = 0.0
    var it = 0
    while it < 60:
        val mid = (lo + hi) / 2.0
        if _f_cdf_left(mid, d1, d2) > p:
            hi = mid
        else:
            lo = mid
        it = it + 1
    (lo + hi) / 2.0

fn _binom_pmf_i64(k: i64, n: i64, p: f64) -> f64:
    val c = _fact_i64(n) / (_fact_i64(k) * _fact_i64(n - k))
    c * _pow_f64(p, k.to_f64()) * _pow_f64(1.0 - p, (n - k).to_f64())

# =====================================================================
# Public API
# =====================================================================

# --- Normal ---

pub fn norm_pdf(x: f64, mean: f64, sd: f64) -> f64:
    """Normal density at x. Domain: sd > 0, else NaN."""
    if sd <= 0.0:
        return _nan()
    val z = (x - mean) / sd
    _exp_f64(0.0 - z * z / 2.0) / (sd * _sqrt_f64(2.0 * _PI))

pub fn norm_cdf(x: f64, mean: f64, sd: f64) -> f64:
    """Normal CDF at x. Domain: sd > 0, else NaN."""
    if sd <= 0.0:
        return _nan()
    _norm_cdf_std((x - mean) / sd)

pub fn norm_inv(p: f64, mean: f64, sd: f64) -> f64:
    """Inverse normal CDF. Domain: sd > 0, 0 < p < 1, else NaN."""
    if sd <= 0.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    mean + sd * _norm_inv_std(p)

# --- Student's t ---

pub fn t_cdf(x: f64, df: f64) -> f64:
    """Student-t left-tail CDF. Domain: df >= 1, else NaN."""
    if df < 1.0:
        return _nan()
    val ib = _t_2t_area(x, df)
    if x >= 0.0: 1.0 - 0.5 * ib else: 0.5 * ib

pub fn t_cdf_2t(x: f64, df: f64) -> f64:
    """Two-tailed Student-t area P(|T|>x) (the `tails` helper the inline code uses). Domain: df >= 1, x >= 0, else NaN."""
    if df < 1.0 or x < 0.0:
        return _nan()
    _t_2t_area(x, df)

pub fn t_inv(p: f64, df: f64) -> f64:
    """Inverse Student-t left-tail CDF. Domain: df >= 1, 0 < p < 1, else NaN."""
    if df < 1.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    if p == 0.5:
        return 0.0
    val q = if p > 0.5: 1.0 - p else: p
    val tm = _t_inv_2t(2.0 * q, df)
    if p > 0.5: tm else: 0.0 - tm

# --- Chi-squared ---

pub fn chisq_cdf(x: f64, df: f64) -> f64:
    """Chi-squared left-tail CDF. Domain: df >= 1, x >= 0, else NaN."""
    if df < 1.0 or x < 0.0:
        return _nan()
    _gammainc_p(df / 2.0, x / 2.0)

pub fn chisq_inv(p: f64, df: f64) -> f64:
    """Inverse chi-squared left-tail CDF. Domain: df >= 1, 0 < p < 1, else NaN."""
    if df < 1.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    2.0 * _gammainc_inv(p, df / 2.0)

# --- F distribution ---

pub fn f_cdf(x: f64, d1: f64, d2: f64) -> f64:
    """Snedecor F left-tail CDF. Domain: d1 >= 1, d2 >= 1, x >= 0, else NaN."""
    if d1 < 1.0 or d2 < 1.0 or x < 0.0:
        return _nan()
    _f_cdf_left(x, d1, d2)

pub fn f_inv(p: f64, d1: f64, d2: f64) -> f64:
    """Inverse Snedecor F left-tail CDF. Domain: d1 >= 1, d2 >= 1, 0 < p < 1, else NaN."""
    if d1 < 1.0 or d2 < 1.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    _f_inv_left(p, d1, d2)

# --- Beta ---

pub fn beta_cdf(x: f64, a: f64, b: f64) -> f64:
    """Beta CDF on [0,1] (standard beta, no lo/hi rescale). Domain: a>0, b>0, else NaN."""
    if a <= 0.0 or b <= 0.0:
        return _nan()
    _betainc(x, a, b)

pub fn beta_inv(p: f64, a: f64, b: f64) -> f64:
    """Inverse beta CDF on [0,1]. Domain: a>0, b>0, 0<p<1, else NaN."""
    if a <= 0.0 or b <= 0.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    _betainc_inv(p, a, b)

# --- Gamma ---

pub fn gamma_cdf(x: f64, shape: f64, scale: f64) -> f64:
    """Gamma CDF (shape/scale parameterization). Domain: shape>0, scale>0, x>=0, else NaN."""
    if shape <= 0.0 or scale <= 0.0 or x < 0.0:
        return _nan()
    _gammainc_p(shape, x / scale)

pub fn gamma_inv(p: f64, shape: f64, scale: f64) -> f64:
    """Inverse gamma CDF. Domain: shape>0, scale>0, 0<p<1, else NaN."""
    if shape <= 0.0 or scale <= 0.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    scale * _gammainc_inv(p, shape)

# --- Binomial ---

pub fn binom_pmf(k: i64, n: i64, p: f64) -> f64:
    """Binomial pmf P(X=k). Domain: 0<=k<=n<=170, 0<=p<=1, else NaN."""
    if k < 0 or n < 0 or k > n or n > 170 or p < 0.0 or p > 1.0:
        return _nan()
    _binom_pmf_i64(k, n, p)

pub fn binom_cdf(k: i64, n: i64, p: f64) -> f64:
    """Binomial CDF P(X<=k). Domain: 0<=k<=n<=170, 0<=p<=1, else NaN."""
    if k < 0 or n < 0 or k > n or n > 170 or p < 0.0 or p > 1.0:
        return _nan()
    var cdf = 0.0
    var kk: i64 = 0
    while kk <= k:
        cdf = cdf + _binom_pmf_i64(kk, n, p)
        kk = kk + 1
    cdf

# --- Poisson ---

pub fn poisson_pmf(k: i64, lambda: f64) -> f64:
    """Poisson pmf P(X=k). Domain: k>=0, 0<=lambda, k<=170, else NaN."""
    if k < 0 or lambda < 0.0 or k > 170:
        return _nan()
    _exp_f64(0.0 - lambda) * _pow_f64(lambda, k.to_f64()) / _fact_i64(k)

pub fn poisson_cdf(k: i64, lambda: f64) -> f64:
    """Poisson CDF P(X<=k). Domain: k>=0, 0<=lambda, k<=170, else NaN."""
    if k < 0 or lambda < 0.0 or k > 170:
        return _nan()
    var cdf = 0.0
    var kk: i64 = 0
    while kk <= k:
        cdf = cdf + _exp_f64(0.0 - lambda) * _pow_f64(lambda, kk.to_f64()) / _fact_i64(kk)
        kk = kk + 1
    cdf

# --- Exponential ---

pub fn expon_cdf(x: f64, lambda: f64) -> f64:
    """Exponential CDF. Domain: lambda>0, x>=0, else NaN."""
    if lambda <= 0.0 or x < 0.0:
        return _nan()
    1.0 - _exp_f64(0.0 - lambda * x)

# --- Hypergeometric ---

pub fn hypgeom_pmf(k: i64, draws: i64, success: i64, pop: i64) -> f64:
    """Hypergeometric pmf P(X=k): k successes in `draws` draws from `pop` items
    with `success` total successes. Domain matches HYPGEOMDIST's bounds
    (0<=k<=draws<=pop, 0<=success<=pop, draws-k<=pop-success, pop<=170), else NaN."""
    if (k < 0 or draws < 0 or success < 0 or pop < 0 or k > draws or k > success or
        draws > pop or success > pop or draws - k > pop - success or pop > 170):
        return _nan()
    val c1 = _fact_i64(success) / (_fact_i64(k) * _fact_i64(success - k))
    val c2 = _fact_i64(pop - success) / (_fact_i64(draws - k) * _fact_i64(pop - success - (draws - k)))
    val c3 = _fact_i64(pop) / (_fact_i64(draws) * _fact_i64(pop - draws))
    c1 * c2 / c3

# --- Negative binomial ---

pub fn negbinom_pmf(f: i64, s: i64, p: f64) -> f64:
    """Negative binomial pmf P(F=f) for s successes with per-trial probability p.
    Domain: f>=0, s>=1, 0<=p<=1, f+s-1<=170, else NaN."""
    if f < 0 or s < 1 or p < 0.0 or p > 1.0 or f + s - 1 > 170:
        return _nan()
    val c = _fact_i64(f + s - 1) / (_fact_i64(f) * _fact_i64(s - 1))
    c * _pow_f64(p, s.to_f64()) * _pow_f64(1.0 - p, f.to_f64())

# --- Weibull ---

pub fn weibull_cdf(x: f64, shape: f64, scale: f64) -> f64:
    """Weibull CDF. Domain: shape>0, scale>0, x>=0, else NaN."""
    if shape <= 0.0 or scale <= 0.0 or x < 0.0:
        return _nan()
    val ratio = x / scale
    val powa = if x == 0.0: 0.0 else: _exp_f64(shape * _ln_f64(ratio))
    1.0 - _exp_f64(0.0 - powa)

# --- Log-normal ---

pub fn lognorm_cdf(x: f64, mean: f64, sd: f64) -> f64:
    """Log-normal CDF. Domain: sd>0, x>0, else NaN."""
    if sd <= 0.0 or x <= 0.0:
        return _nan()
    _norm_cdf_std((_ln_f64(x) - mean) / sd)

pub fn lognorm_inv(p: f64, mean: f64, sd: f64) -> f64:
    """Inverse log-normal CDF. NOTE: formula.spl has no LOGNORM.INV/LOGNORMINV
    case (gap — not found during extraction); this is derived compositionally
    from the standard identity LOGNORM.INV(p) = exp(mean + sd*NORM.S.INV(p)),
    reusing the existing _norm_inv_std kernel rather than copied from an
    inline implementation. Domain: sd>0, 0<p<1, else NaN."""
    if sd <= 0.0 or p <= 0.0 or p >= 1.0:
        return _nan()
    _exp_f64(mean + sd * _norm_inv_std(p))
