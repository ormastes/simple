# Math module — re-exports all public symbols from math.spl.
#
# Import path: use std.common.math.{MATH_PI, math_sqrt, math_abs, ...}

export use std.common.math.math.{
    MATH_PI, MATH_E, MATH_TAU, MATH_INF,
    math_sin, math_cos, math_tan,
    math_sqrt, math_cbrt, math_hypot,
    math_pow, math_exp, math_fma,
    math_abs, math_trunc, math_round,
    math_min, math_max, math_clamp, math_lerp
}
