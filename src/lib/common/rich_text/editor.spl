# Rich Text Editor — cursor and edit operations over a RichDocument.
#
# Provides: TextCursor, RichTextEditor.

use std.common.rich_text.attributed_text.{
    RichDocument, DocBlock, TextSpan, InlineStyle, BlockKind,
    block_to_plain_text
}

struct TextCursor:
    block_index: i64
    char_offset: i64

class RichTextEditor:
    doc: RichDocument
    cursor: TextCursor

    static fn new(doc: RichDocument) -> RichTextEditor:
        RichTextEditor(doc: doc, cursor: TextCursor(block_index: 0, char_offset: 0))

    me move_to(block_index: i64, char_offset: i64):
        me.cursor = TextCursor(block_index: block_index, char_offset: char_offset)

    me insert_text(text_to_insert: text):
        if me.doc.blocks.len() == 0:
            val span = TextSpan(text: text_to_insert, style: InlineStyle.Normal, link_url: "", footnote_id: "", comment_id: "", revision_id: "")
            val block = DocBlock(kind: BlockKind.Paragraph, spans: [span])
            me.doc.blocks.push(block)
            return
        val bi = me.cursor.block_index
        if bi < 0 or bi >= me.doc.blocks.len():
            return
        val block = me.doc.blocks[bi]
        val span = TextSpan(text: text_to_insert, style: InlineStyle.Normal, link_url: "", footnote_id: "", comment_id: "", revision_id: "")
        block.spans.push(span)

    me apply_style_to_block(style: InlineStyle):
        val bi = me.cursor.block_index
        if bi < 0 or bi >= me.doc.blocks.len():
            return
        val block = me.doc.blocks[bi]
        var new_spans: [TextSpan] = []
        for s in block.spans:
            new_spans.push(TextSpan(text: s.text, style: style, link_url: s.link_url, footnote_id: s.footnote_id, comment_id: s.comment_id, revision_id: s.revision_id))
        me.doc.blocks[bi] = DocBlock(kind: block.kind, spans: new_spans)

    me insert_block(kind: BlockKind):
        val block = DocBlock(kind: kind, spans: [])
        me.doc.blocks.push(block)
        me.cursor = TextCursor(
            block_index: me.doc.blocks.len() - 1,
            char_offset: 0
        )

    fn current_block_text() -> text:
        val bi = me.cursor.block_index
        if bi < 0 or bi >= me.doc.blocks.len():
            return ""
        block_to_plain_text(me.doc.blocks[bi])

    fn block_count() -> i64:
        me.doc.blocks.len()
