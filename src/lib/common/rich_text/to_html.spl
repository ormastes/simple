# Rich Text to HTML
#
# Render RichDocument to HTML for web display.

use std.rich_text.attributed_text (
    InlineStyle, TextSpan, DocBlock, RichDocument,
    spans_to_plain_text
)

# =========================================================================
# Document to HTML
# =========================================================================

fn document_to_html(doc: RichDocument) -> text:
    """Convert a RichDocument to a complete HTML string."""
    var parts: [text] = []
    parts = parts.push("<!DOCTYPE html>")
    parts = parts.push("<html>")
    parts = parts.push("<head>")
    parts = parts.push("  <meta charset=\"utf-8\">")
    parts = parts.push("  <title>{_escape_html(doc.title)}</title>")
    parts = parts.push("</head>")
    parts = parts.push("<body>")
    for block in doc.blocks:
        parts = parts.push(block_to_html(block))
    parts = parts.push("</body>")
    parts = parts.push("</html>")
    return parts.join("\n")

# =========================================================================
# Block to HTML
# =========================================================================

fn block_to_html(block: DocBlock) -> text:
    """Convert a single DocBlock to an HTML string."""
    match block:
        case DocBlock.Paragraph(spans):
            return "<p>{spans_to_html(spans)}</p>"
        case DocBlock.Heading(level, spans):
            val tag = _heading_tag(level)
            return "<{tag}>{spans_to_html(spans)}</{tag}>"
        case DocBlock.BulletList(items):
            var lines: [text] = []
            lines = lines.push("<ul>")
            for item in items:
                lines = lines.push("  <li>{spans_to_html(item)}</li>")
            lines = lines.push("</ul>")
            return lines.join("\n")
        case DocBlock.NumberedList(items, start):
            var lines: [text] = []
            if start == 1:
                lines = lines.push("<ol>")
            else:
                lines = lines.push("<ol start=\"{start}\">")
            for item in items:
                lines = lines.push("  <li>{spans_to_html(item)}</li>")
            lines = lines.push("</ol>")
            return lines.join("\n")
        case DocBlock.CodeBlock(language, code):
            if language != "":
                return "<pre><code class=\"language-{_escape_html(language)}\">{_escape_html(code)}</code></pre>"
            return "<pre><code>{_escape_html(code)}</code></pre>"
        case DocBlock.Quote(blocks):
            var inner: [text] = []
            for b in blocks:
                inner = inner.push(block_to_html(b))
            return "<blockquote>\n{inner.join("\n")}\n</blockquote>"
        case DocBlock.HorizontalRule:
            return "<hr>"
        case DocBlock.Image(src, alt):
            return "<img src=\"{_escape_html(src)}\" alt=\"{_escape_html(alt)}\">"
    return ""

# =========================================================================
# Spans to HTML
# =========================================================================

fn spans_to_html(spans: [TextSpan]) -> text:
    """Convert a list of styled spans to HTML inline elements."""
    var result = ""
    for span in spans:
        result = "{result}{span_to_html(span)}"
    return result

fn span_to_html(span: TextSpan) -> text:
    """Convert a single span to HTML, nesting style tags around the content."""
    var content = _escape_html(span.content)
    # Apply styles from innermost to outermost
    for style in span.styles:
        match style:
            case InlineStyle.Bold:
                content = "<strong>{content}</strong>"
            case InlineStyle.Italic:
                content = "<em>{content}</em>"
            case InlineStyle.Underline:
                content = "<u>{content}</u>"
            case InlineStyle.Code:
                content = "<code>{content}</code>"
            case InlineStyle.Strikethrough:
                content = "<s>{content}</s>"
            case InlineStyle.Link(url):
                content = "<a href=\"{_escape_html(url)}\">{content}</a>"
            _:
                pass_do_nothing
    return content

# =========================================================================
# Internal Helpers
# =========================================================================

fn _heading_tag(level: i32) -> text:
    """Return the HTML heading tag for the given level (clamped to h1-h6)."""
    if level <= 1:
        return "h1"
    if level == 2:
        return "h2"
    if level == 3:
        return "h3"
    if level == 4:
        return "h4"
    if level == 5:
        return "h5"
    return "h6"

fn _escape_html(s: text) -> text:
    """Escape HTML special characters."""
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        match ch:
            "&" => result = "{result}&amp;"
            "<" => result = "{result}&lt;"
            ">" => result = "{result}&gt;"
            "\"" => result = "{result}&quot;"
            _ => result = "{result}{ch}"
        i = i + 1
    return result
