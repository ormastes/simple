# Attributed Text — rich document model with inline styles.
#
# Provides: InlineStyle, TextSpan, DocBlock, RichDocument,
#           empty_document, document_word_count, document_headings,
#           block_to_plain_text, spans_to_plain_text.

enum InlineStyle:
    Normal
    Bold
    Italic
    Underline
    Code
    Strike

enum BlockKind:
    Paragraph
    Heading1
    Heading2
    Heading3
    BulletItem
    CodeBlock
    Quote

struct TextSpan:
    text: text
    style: InlineStyle

struct DocBlock:
    kind: BlockKind
    spans: [TextSpan]

class RichDocument:
    title: text
    blocks: [DocBlock]

    static fn new(title: text) -> RichDocument:
        RichDocument(title: title, blocks: [])

fn empty_document(title: text) -> RichDocument:
    RichDocument.new(title)

fn spans_to_plain_text(spans: [TextSpan]) -> text:
    var out = ""
    for s in spans:
        out = out + s.text
    out

fn block_to_plain_text(block: DocBlock) -> text:
    spans_to_plain_text(block.spans)

fn document_word_count(doc: RichDocument) -> i64:
    var count: i64 = 0
    for block in doc.blocks:
        val plain = block_to_plain_text(block)
        val words = plain.split(" ")
        for w in words:
            if w.trim().len() > 0:
                count = count + 1
    count

fn document_headings(doc: RichDocument) -> [DocBlock]:
    var headings: [DocBlock] = []
    for block in doc.blocks:
        match block.kind:
            case Heading1: headings.push(block)
            case Heading2: headings.push(block)
            case Heading3: headings.push(block)
            case _: pass_do_nothing
    headings
