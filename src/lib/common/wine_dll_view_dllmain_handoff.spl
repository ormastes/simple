"""Non-executing DllMain handoff for retained Wine DLL views."""

use common.pe_coff_header.{pe_entry_point_rva, pe_rva_to_file_offset}
use common.wine_dll_file_probe.{WineDllProbeFile}
use common.wine_dll_view_import_binding.{wine_dll_bind_file_view_imports}
use common.wine_pe_loader_runtime.{wine_pe_tls_callback_plan}
use common.wine_vm_adapter.{wine_vm_no_host_code_jump_gate}

class WineDllViewDllMainHandoffResult:
    ok: bool
    error: text
    dll_name: text
    selected_path: text
    mapped_base: i64
    mapped_size: i64
    entrypoint_rva: i64
    entrypoint_address: i64
    callback_count: i64
    dispatch_count: i64
    evidence: text
    status: text

fn _result(ok: bool, error: text, dll_name: text, selected_path: text, mapped_base: i64, mapped_size: i64, entrypoint_rva: i64, entrypoint_address: i64, callback_count: i64, dispatch_count: i64, evidence: text, status: text) -> WineDllViewDllMainHandoffResult:
    WineDllViewDllMainHandoffResult(ok: ok, error: error, dll_name: dll_name.lower(), selected_path: selected_path, mapped_base: mapped_base, mapped_size: mapped_size, entrypoint_rva: entrypoint_rva, entrypoint_address: entrypoint_address, callback_count: callback_count, dispatch_count: dispatch_count, evidence: evidence, status: status)

pub fn wine_dll_prepare_file_view_dllmain_handoff(dll_name: text, application_directory: text, working_directory: text, path_dirs: [text], known_dlls: [text], files: [WineDllProbeFile], data: [u8], preferred_base: i64, load_base: i64, process_id: i64, address_space_id: i64, container_evidence: text, descriptor_limit: i64, symbol_limit: i64, dynload_apis: text, allow_execution: bool) -> WineDllViewDllMainHandoffResult:
    val bound = wine_dll_bind_file_view_imports(dll_name, application_directory, working_directory, path_dirs, known_dlls, files, data, preferred_base, load_base, process_id, address_space_id, container_evidence, descriptor_limit, symbol_limit)
    if not bound.ok:
        return _result(false, "dll-view-import-binding:" + bound.error, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, 0, 0, bound.evidence, bound.status)

    val tls = wine_pe_tls_callback_plan(bound.patched_image, dynload_apis)
    if not tls.ok:
        return _result(false, "dll-tls:" + tls.error, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, tls.callback_count, 0, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-tls-callback-executed no-dllmain-executed", "rejected")

    var dispatch_count = 0
    if tls.callback_count > 0:
        if pe_rva_to_file_offset(bound.patched_image, tls.first_callback_rva) < 0:
            return _result(false, "dll-tls-callback-unmapped", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, tls.callback_count, 0, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-tls-callback-executed no-dllmain-executed", "rejected")
        dispatch_count = 1

    val entry_rva = pe_entry_point_rva(bound.patched_image)
    if entry_rva <= 0:
        return _result(false, "missing-dll-entrypoint", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, 0, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "rejected")
    if pe_rva_to_file_offset(bound.patched_image, entry_rva) < 0:
        return _result(false, "dll-entrypoint-unmapped", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, 0, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "rejected")
    val entry_address = bound.mapped_base + entry_rva
    val host_jump_state = wine_vm_no_host_code_jump_gate(bound.space, entry_address)
    if host_jump_state != "ready":
        return _result(false, host_jump_state, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "blocked")
    if allow_execution:
        return _result(false, "dllmain-execution-not-implemented", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-execution-requested loader-lock-required tls-before-dllmain-required no-dllmain-executed", "blocked")

    val evidence = bound.evidence + " " + tls.operations + " dll-tls-callback-dispatch-recorded loader-lock-held tls-before-dllmain dll-entrypoint-mapped dllmain-process-attach-planned dllmain-handoff-ready no-host-code-jump no-tls-callback-executed no-dllmain-executed no-arbitrary-execution"
    _result(true, "", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, evidence, "dllmain-handoff-ready")
