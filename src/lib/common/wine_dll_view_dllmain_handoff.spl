"""Non-executing DllMain handoff for retained Wine DLL views."""

use common.pe_coff_header.{pe_entry_point_rva, pe_rva_to_file_offset}
use common.wine_dll_file_probe.{WineDllProbeFile}
use common.wine_dll_view_import_binding.{wine_dll_bind_file_view_imports}
use common.wine_peb_teb.{WinePebTebLayoutWritePlan, WinePebTebMemoryWriteResult, WinePebTebVmWriteResult}
use common.wine_pe_loader_runtime.{wine_pe_tls_callback_plan}
use common.wine_vm_adapter.{wine_vm_no_host_code_jump_gate}

class WineDllViewDllMainHandoffResult:
    ok: bool
    error: text
    dll_name: text
    selected_path: text
    mapped_base: i64
    mapped_size: i64
    entrypoint_rva: i64
    entrypoint_address: i64
    callback_count: i64
    dispatch_count: i64
    evidence: text
    status: text

fn _dllmain_handoff_result(ok: bool, error: text, dll_name: text, selected_path: text, mapped_base: i64, mapped_size: i64, entrypoint_rva: i64, entrypoint_address: i64, callback_count: i64, dispatch_count: i64, evidence: text, status: text) -> WineDllViewDllMainHandoffResult:
    WineDllViewDllMainHandoffResult(ok: ok, error: error, dll_name: dll_name.lower(), selected_path: selected_path, mapped_base: mapped_base, mapped_size: mapped_size, entrypoint_rva: entrypoint_rva, entrypoint_address: entrypoint_address, callback_count: callback_count, dispatch_count: dispatch_count, evidence: evidence, status: status)

pub fn wine_dll_prepare_file_view_dllmain_handoff(dll_name: text, application_directory: text, working_directory: text, path_dirs: [text], known_dlls: [text], files: [WineDllProbeFile], data: [u8], preferred_base: i64, load_base: i64, process_id: i64, address_space_id: i64, container_evidence: text, descriptor_limit: i64, symbol_limit: i64, dynload_apis: text, allow_execution: bool) -> WineDllViewDllMainHandoffResult:
    val bound = wine_dll_bind_file_view_imports(dll_name, application_directory, working_directory, path_dirs, known_dlls, files, data, preferred_base, load_base, process_id, address_space_id, container_evidence, descriptor_limit, symbol_limit)
    if not bound.ok:
        return _dllmain_handoff_result(false, "dll-view-import-binding:" + bound.error, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, 0, 0, bound.evidence, bound.status)

    val tls = wine_pe_tls_callback_plan(bound.patched_image, dynload_apis)
    if not tls.ok:
        return _dllmain_handoff_result(false, "dll-tls:" + tls.error, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, tls.callback_count, 0, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-tls-callback-executed no-dllmain-executed", "rejected")

    var dispatch_count = 0
    if tls.callback_count > 0:
        if pe_rva_to_file_offset(bound.patched_image, tls.first_callback_rva) < 0:
            return _dllmain_handoff_result(false, "dll-tls-callback-unmapped", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, 0, 0, tls.callback_count, 0, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-tls-callback-executed no-dllmain-executed", "rejected")
        dispatch_count = 1

    val entry_rva = pe_entry_point_rva(bound.patched_image)
    if entry_rva <= 0:
        return _dllmain_handoff_result(false, "missing-dll-entrypoint", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, 0, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "rejected")
    if pe_rva_to_file_offset(bound.patched_image, entry_rva) < 0:
        return _dllmain_handoff_result(false, "dll-entrypoint-unmapped", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, 0, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "rejected")
    val entry_address = bound.mapped_base + entry_rva
    val host_jump_state = wine_vm_no_host_code_jump_gate(bound.space, entry_address)
    if host_jump_state != "ready":
        return _dllmain_handoff_result(false, host_jump_state, bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-handoff-blocked no-dllmain-executed", "blocked")
    if allow_execution:
        return _dllmain_handoff_result(false, "dllmain-execution-not-implemented", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, bound.evidence + " " + tls.operations + " dllmain-execution-requested loader-lock-required tls-before-dllmain-required no-dllmain-executed", "blocked")

    val evidence = bound.evidence + " " + tls.operations + " dll-tls-callback-dispatch-recorded loader-lock-held tls-before-dllmain dll-entrypoint-mapped dllmain-process-attach-planned dllmain-handoff-ready no-host-code-jump no-tls-callback-executed no-dllmain-executed no-arbitrary-execution"
    _dllmain_handoff_result(true, "", bound.dll_name, bound.selected_path, bound.mapped_base, bound.mapped_size, entry_rva, entry_address, tls.callback_count, dispatch_count, evidence, "dllmain-handoff-ready")

pub fn wine_dll_prepare_file_view_dllmain_handoff_with_peb_teb_vm_writes(dll_name: text, application_directory: text, working_directory: text, path_dirs: [text], known_dlls: [text], files: [WineDllProbeFile], data: [u8], preferred_base: i64, load_base: i64, process_id: i64, address_space_id: i64, container_evidence: text, descriptor_limit: i64, symbol_limit: i64, dynload_apis: text, allow_execution: bool, startup_ok: bool, startup_state: text, startup_operations: text, vm_writes: WinePebTebVmWriteResult) -> WineDllViewDllMainHandoffResult:
    val handoff = wine_dll_prepare_file_view_dllmain_handoff(dll_name, application_directory, working_directory, path_dirs, known_dlls, files, data, preferred_base, load_base, process_id, address_space_id, container_evidence, descriptor_limit, symbol_limit, dynload_apis, allow_execution)
    wine_dllmain_handoff_require_peb_teb_vm_writes(handoff, startup_ok, startup_state, startup_operations, vm_writes)

pub fn wine_dllmain_handoff_require_peb_teb_loader_lock(handoff: WineDllViewDllMainHandoffResult, startup_ok: bool, startup_state: text, startup_operations: text) -> WineDllViewDllMainHandoffResult:
    if not startup_ok:
        handoff.ok = false
        handoff.error = "peb-teb-loader-lock:" + startup_state
        handoff.evidence = startup_operations + " dllmain-handoff-blocked"
        handoff.status = "rejected"
        return handoff

    handoff.evidence = startup_operations + " peb-teb-loader-lock-ready " + handoff.evidence
    handoff

pub fn wine_dllmain_handoff_require_peb_teb_writes(handoff: WineDllViewDllMainHandoffResult, startup_ok: bool, startup_state: text, startup_operations: text, writes: WinePebTebMemoryWriteResult) -> WineDllViewDllMainHandoffResult:
    val locked = wine_dllmain_handoff_require_peb_teb_loader_lock(handoff, startup_ok, startup_state, startup_operations)
    if not locked.ok:
        return locked
    if not writes.ok:
        locked.ok = false
        locked.error = "peb-teb-write:" + writes.state
        locked.evidence = writes.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked
    if writes.write_count != 4:
        locked.ok = false
        locked.error = "peb-teb-write-count-mismatch"
        locked.evidence = writes.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked

    locked.evidence = writes.operations + " peb-teb-writes-ready " + locked.evidence
    locked

pub fn wine_dllmain_handoff_require_peb_teb_layout(handoff: WineDllViewDllMainHandoffResult, startup_ok: bool, startup_state: text, startup_operations: text, layout: WinePebTebLayoutWritePlan) -> WineDllViewDllMainHandoffResult:
    val locked = wine_dllmain_handoff_require_peb_teb_loader_lock(handoff, startup_ok, startup_state, startup_operations)
    if not locked.ok:
        return locked
    if not layout.ok:
        locked.ok = false
        locked.error = "peb-teb-layout:" + layout.state
        locked.evidence = layout.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked
    if layout.record_count != 6:
        locked.ok = false
        locked.error = "peb-teb-layout-count-mismatch"
        locked.evidence = layout.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked

    locked.evidence = layout.operations + " peb-teb-layout-ready " + locked.evidence
    locked

pub fn wine_dllmain_handoff_require_peb_teb_vm_writes(handoff: WineDllViewDllMainHandoffResult, startup_ok: bool, startup_state: text, startup_operations: text, vm_writes: WinePebTebVmWriteResult) -> WineDllViewDllMainHandoffResult:
    val locked = wine_dllmain_handoff_require_peb_teb_loader_lock(handoff, startup_ok, startup_state, startup_operations)
    if not locked.ok:
        return locked
    if not vm_writes.ok:
        locked.ok = false
        locked.error = "peb-teb-vm-write:" + vm_writes.state
        locked.evidence = vm_writes.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked
    if vm_writes.write_count != 6:
        locked.ok = false
        locked.error = "peb-teb-vm-write-count-mismatch"
        locked.evidence = vm_writes.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked
    if vm_writes.byte_count != 48:
        locked.ok = false
        locked.error = "peb-teb-vm-byte-count-mismatch"
        locked.evidence = vm_writes.operations + " dllmain-handoff-blocked"
        locked.status = "rejected"
        return locked

    locked.evidence = vm_writes.operations + " peb-teb-vm-writes-ready " + locked.evidence
    locked
