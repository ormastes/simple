# HPACK N-bit prefix integer codec (RFC 7541 §5.1).
#
# HPACK encodes most integer fields using a "prefix integer" form: an
# integer that may share a byte with other flag bits. The number of bits
# available in the prefix byte (`n`) varies per field — 7, 6, 5, or 4
# bits depending on the representation type.
#
# Encoding (RFC 7541 §5.1):
#
#   if I < 2^N - 1:
#       single-byte form: prefix bits = I
#   else:
#       prefix bits = 2^N - 1
#       I = I - (2^N - 1)
#       while I >= 128:
#           emit (I mod 128) | 128
#           I = I / 128
#       emit I
#
# Decoding is the inverse. The continuation bytes use the high bit as a
# "more bytes follow" flag and the low 7 bits as data.
#
# This module is pure: no IO, no allocations besides the output byte array.
# It is consumed by the HPACK encoder/decoder layered above it.

# Encode integer `value` with `prefix_bits` bits available in the first
# byte. `flags` is the value of the bits above the prefix in the first
# byte (e.g. for an Indexed Header Field, flags = 0x80 and prefix_bits =
# 7). Returns the encoded byte sequence.
#
# Preconditions:
#   - prefix_bits in 1..8
#   - value >= 0
#   - flags fits in the high (8 - prefix_bits) bits
#
# These are the caller's contract; bad input produces undefined output.
fn encode_prefix_int(value: i64, prefix_bits: i64, flags: u8) -> [u8]:
    val mask = _prefix_mask(prefix_bits)
    var out: [u8] = []
    if value < mask:
        # Fits entirely in the prefix.
        val first = (flags.to_i64() | value).to_u8()
        out.push(first)
        return out
    # Prefix is all 1s; remainder goes in continuation bytes.
    val first = (flags.to_i64() | mask).to_u8()
    out.push(first)
    var remaining = value - mask
    while remaining >= 128:
        val byte = ((remaining % 128) | 128).to_u8()
        out.push(byte)
        remaining = remaining / 128
    out.push(remaining.to_u8())
    out

# Decode a prefix integer starting at `bytes[offset]`. Returns
# `(value, bytes_consumed)`. Caller masks off the high flag bits before
# inspecting the value if needed.
#
# Errors (returned as Err):
#   - input runs out before the integer terminates
#   - integer would exceed i64 range (continuation overflow)
fn decode_prefix_int(bytes: [u8], offset: i64, prefix_bits: i64) -> Result<(i64, i64), text>:
    if offset < 0 or offset >= bytes.len():
        return Err("decode_prefix_int: offset out of range")
    val mask = _prefix_mask(prefix_bits)
    val first = bytes[offset].to_i64()
    val prefix_value = first & mask
    if prefix_value < mask:
        return Ok((prefix_value, 1))
    # Continuation bytes.
    var value: i64 = mask
    var multiplier: i64 = 1
    var consumed: i64 = 1
    var i = offset + 1
    var done = false
    while not done:
        if i >= bytes.len():
            return Err("decode_prefix_int: truncated continuation")
        # Guard against pathological encodings: cap continuation length
        # at 10 bytes (more than enough for any 64-bit value with 7-bit
        # continuations).
        if consumed > 10:
            return Err("decode_prefix_int: integer overflow (>10 continuation bytes)")
        val byte = bytes[i].to_i64()
        val low7 = byte & 0x7F
        # Overflow check: value + low7 * multiplier must fit in i64.
        # Since multiplier doubles by 128 each step and we cap at 10
        # bytes, we cannot exceed 2^63 - 1 unless input is malicious;
        # the consumed-byte cap above handles that case.
        value = value + low7 * multiplier
        consumed = consumed + 1
        i = i + 1
        if (byte & 0x80) == 0:
            done = true
        else:
            multiplier = multiplier * 128
    Ok((value, consumed))

# ----------------------------------------------------------------------------
# Internal helpers
# ----------------------------------------------------------------------------

# Returns 2^prefix_bits - 1 for prefix_bits in 1..8.
fn _prefix_mask(prefix_bits: i64) -> i64:
    if prefix_bits == 8: return 255
    if prefix_bits == 7: return 127
    if prefix_bits == 6: return 63
    if prefix_bits == 5: return 31
    if prefix_bits == 4: return 15
    if prefix_bits == 3: return 7
    if prefix_bits == 2: return 3
    if prefix_bits == 1: return 1
    0
