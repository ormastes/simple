# HPACK Huffman codec (RFC 7541 Appendix B + §5.2).
#
# Encodes/decodes byte payloads using the RFC 7541 static Huffman code.
# The code is fixed (not adaptive): every implementation uses the same
# 257-symbol table (symbols 0x00–0xFF plus the EOS marker at index 256).
#
# Encoding (§5.2):
#   Each byte of input is replaced by its Huffman bit-pattern from the
#   table.  The resulting bit string is padded to the next byte boundary
#   using the most-significant bits of the EOS code (all 1s).
#
# Decoding (§5.2):
#   Read bits MSB-first, walking a decision tree until a leaf is reached.
#   A complete EOS code (30 bits, all 1s) as a symbol is an error.
#   Padding exceeding 7 bits is an error.
#   Padding that is not a prefix of EOS (i.e. not all 1s) is an error.
#
# This module is pure: no IO, no FFI, no rt_* externs.

# One entry in the static Huffman table.
class HuffEntry:
    code: i64   # bit pattern (MSB is the first bit to emit)
    bits: i64   # number of valid bits in `code`

# RFC 7541 Appendix B — full 257-entry static Huffman table.
# Index 0..255 = symbol value; index 256 = EOS.
fn huffman_table() -> [HuffEntry]:
    [
        HuffEntry(code: 0x1ff8, bits: 13),       # 0x00
        HuffEntry(code: 0x7fffd8, bits: 23),     # 0x01
        HuffEntry(code: 0xfffffe2, bits: 28),    # 0x02
        HuffEntry(code: 0xfffffe3, bits: 28),    # 0x03
        HuffEntry(code: 0xfffffe4, bits: 28),    # 0x04
        HuffEntry(code: 0xfffffe5, bits: 28),    # 0x05
        HuffEntry(code: 0xfffffe6, bits: 28),    # 0x06
        HuffEntry(code: 0xfffffe7, bits: 28),    # 0x07
        HuffEntry(code: 0xfffffe8, bits: 28),    # 0x08
        HuffEntry(code: 0xffffea, bits: 24),     # 0x09
        HuffEntry(code: 0x3ffffffc, bits: 30),   # 0x0a
        HuffEntry(code: 0xfffffe9, bits: 28),    # 0x0b
        HuffEntry(code: 0xfffffea, bits: 28),    # 0x0c
        HuffEntry(code: 0x3ffffffd, bits: 30),   # 0x0d
        HuffEntry(code: 0xfffffeb, bits: 28),    # 0x0e
        HuffEntry(code: 0xfffffec, bits: 28),    # 0x0f
        HuffEntry(code: 0xfffffed, bits: 28),    # 0x10
        HuffEntry(code: 0xfffffee, bits: 28),    # 0x11
        HuffEntry(code: 0xfffffef, bits: 28),    # 0x12
        HuffEntry(code: 0xffffff0, bits: 28),    # 0x13
        HuffEntry(code: 0xffffff1, bits: 28),    # 0x14
        HuffEntry(code: 0xffffff2, bits: 28),    # 0x15
        HuffEntry(code: 0x3ffffffe, bits: 30),   # 0x16
        HuffEntry(code: 0xffffff3, bits: 28),    # 0x17
        HuffEntry(code: 0xffffff4, bits: 28),    # 0x18
        HuffEntry(code: 0xffffff5, bits: 28),    # 0x19
        HuffEntry(code: 0xffffff6, bits: 28),    # 0x1a
        HuffEntry(code: 0xffffff7, bits: 28),    # 0x1b
        HuffEntry(code: 0xffffff8, bits: 28),    # 0x1c
        HuffEntry(code: 0xffffff9, bits: 28),    # 0x1d
        HuffEntry(code: 0xffffffa, bits: 28),    # 0x1e
        HuffEntry(code: 0xffffffb, bits: 28),    # 0x1f
        HuffEntry(code: 0x14, bits: 6),          # 0x20 ' '
        HuffEntry(code: 0x3f8, bits: 10),        # 0x21 '!'
        HuffEntry(code: 0x3f9, bits: 10),        # 0x22 '"'
        HuffEntry(code: 0xffa, bits: 12),        # 0x23 '#'
        HuffEntry(code: 0x1ff9, bits: 13),       # 0x24 '$'
        HuffEntry(code: 0x15, bits: 6),          # 0x25 '%'
        HuffEntry(code: 0xf8, bits: 8),          # 0x26 '&'
        HuffEntry(code: 0x7fa, bits: 11),        # 0x27 '\''
