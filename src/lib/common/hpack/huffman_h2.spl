# Encode `payload` bytes as a Huffman-coded bit stream, padded to a byte
# boundary using the high bits of EOS (all 1s per §5.2).
fn hpack_huffman_encode(payload: [u8]) -> [u8]:
    val table = huffman_table()
    # Accumulate bits in a 64-bit buffer; flush bytes as they fill.
    var bit_buf: i64 = 0
    var bit_count: i64 = 0
    var out: [u8] = []
    var i: i64 = 0
    while i < payload.len():
        val sym = payload[i].to_i64()
        val entry = table[sym]
        val code = entry.code
        val nbits = entry.bits
        # Shift code into MSB position of a 30-bit window, then merge.
        # We maintain bit_buf as an i64 where bits are packed MSB-first
        # in the low (bit_count + nbits) bits.
        bit_buf = (bit_buf * _pow2(nbits)) + code
        bit_count = bit_count + nbits
        # Flush complete bytes.
        while bit_count >= 8:
            bit_count = bit_count - 8
            val byte = (bit_buf / _pow2(bit_count)) & 0xFF
            out.push(byte.to_u8())
            bit_buf = bit_buf & (_pow2(bit_count) - 1)
        i = i + 1
    # Pad remaining bits with 1s (high bits of EOS).
    if bit_count > 0:
        val pad_bits = 8 - bit_count
        val padded = ((bit_buf * _pow2(pad_bits)) | (_pow2(pad_bits) - 1)) & 0xFF
        out.push(padded.to_u8())
    out

# Decode `length` Huffman-coded bytes starting at `bytes[offset]`.
# Returns the decoded byte payload or an error.
#
# Errors:
#   - offset or length out of range
#   - EOS symbol encountered as an actual coded value (not just padding)
#   - padding longer than 7 bits
#   - padding bits are not all 1s (not a prefix of EOS)
fn hpack_huffman_decode(bytes: [u8], offset: i64, length: i64) -> Result<[u8], text>:
    if offset < 0 or length < 0:
        return Err("hpack_huffman_decode: negative offset or length")
    if offset + length > bytes.len():
        return Err("hpack_huffman_decode: range out of bounds")
    val table = huffman_table()
    # Build a decode tree from the table.
    val tree = _build_decode_tree(table)
    var out: [u8] = []
    var node: i64 = 0       # current tree node index (0 = root)
    var partial: i64 = 0    # bits consumed in current (incomplete) code
    var i: i64 = 0
    while i < length:
        val byte = bytes[offset + i].to_i64()
        var bit: i64 = 7
        while bit >= 0:
            val b = (byte / _pow2(bit)) & 1
            partial = partial + 1
            val child_res = _tree_child(tree, node, b)
            if child_res.is_err():
                return Err("hpack_huffman_decode: invalid code sequence")
            node = child_res.unwrap()
            val sym_res = _tree_symbol(tree, node)
            if sym_res.is_ok():
                val sym = sym_res.unwrap()
                if sym == 256:
                    return Err("hpack_huffman_decode: EOS symbol in stream")
                out.push(sym.to_u8())
                node = 0     # back to root
                partial = 0  # reset partial counter
            bit = bit - 1
        i = i + 1
    # After all bytes: node must be root (clean boundary) or mid-tree (padding).
    # If mid-tree: the partial bits must be <= 7 and all 1s (EOS prefix).
    if node != 0:
        # `partial` = number of bits consumed since the last decoded symbol.
        # These are all padding bits. Requirement: <= 7 and all 1s.
        if partial > 7:
            return Err("hpack_huffman_decode: padding exceeds 7 bits")
        # Verify the current node equals the node we'd reach from root by
        # following `partial` '1' bits (i.e. it's a prefix of EOS).
        val valid = _is_eos_prefix_node(tree, node, partial)
        if not valid:
            return Err("hpack_huffman_decode: invalid padding (not EOS prefix)")
    Ok(out)

# ----------------------------------------------------------------------------
# Decode tree implementation
# ----------------------------------------------------------------------------
#
# We build a flat binary trie. Each node is stored as three consecutive
# i64 values in a flat array:
#   [3*n + 0] = left child index  (bit=0), or -1 if no child
#   [3*n + 1] = right child index (bit=1), or -1 if no child
#   [3*n + 2] = symbol value (0..256), or -1 if not a leaf
#
# Node 0 is always the root. We pre-allocate conservatively.

fn _build_decode_tree(table: [HuffEntry]) -> [i64]:
    # Start with 1 node (root). Nodes grow as we insert.
    # 3 slots per node; initial capacity = 600 nodes = 1800 slots.
    # (The actual tree has ~512 leaves + internal nodes, well under 600.)
    var tree: [i64] = []
    # Initialize root node (node 0).
    var k: i64 = 0
    while k < 3:
        val neg1: [i64] = [-1]
        tree = tree + neg1
        k = k + 1
    var next_node: i64 = 1
    var sym: i64 = 0
    while sym <= 256:
        val entry = table[sym]
        val code = entry.code
        val nbits = entry.bits
        # Insert this symbol into the tree.
        var node: i64 = 0
        var bit_pos: i64 = nbits - 1
        while bit_pos >= 0:
            val b = (code / _pow2(bit_pos)) & 1
            val slot = node * 3 + b
            if tree[slot] == -1:
                # Create new child node.
                tree[slot] = next_node
                val neg1a: [i64] = [-1]
                val neg1b: [i64] = [-1]
                val neg1c: [i64] = [-1]
                tree = tree + neg1a + neg1b + neg1c
                next_node = next_node + 1
            node = tree[slot]
            bit_pos = bit_pos - 1
        # Mark node as leaf.
        tree[node * 3 + 2] = sym
        sym = sym + 1
    tree

fn _tree_child(tree: [i64], node: i64, bit: i64) -> Result<i64, text>:
    val slot = node * 3 + bit
    if slot < 0 or slot >= tree.len():
        return Err("_tree_child: slot out of range")
    val child = tree[slot]
    if child == -1:
        return Err("_tree_child: no child for bit")
    Ok(child)

fn _tree_symbol(tree: [i64], node: i64) -> Result<i64, text>:
    val slot = node * 3 + 2
    if slot < 0 or slot >= tree.len():
        return Err("_tree_symbol: slot out of range")
    val sym = tree[slot]
    if sym == -1:
        return Err("_tree_symbol: not a leaf")
    Ok(sym)

# Returns true if `node` is the node reached by following `count` '1' bits
# from root. Used to validate EOS padding.
fn _is_eos_prefix_node(tree: [i64], node: i64, count: i64) -> bool:
    var cur: i64 = 0
    var i: i64 = 0
    while i < count:
        val slot = cur * 3 + 1  # bit=1
        if slot >= tree.len():
            return false
        val child = tree[slot]
        if child == -1:
            return false
        cur = child
        i = i + 1
    cur == node

# ----------------------------------------------------------------------------
# Internal math helpers
# ----------------------------------------------------------------------------

# Returns 2^n for n in 0..62. Used instead of bit-shift operators since
# the Simple compiler's shift operator can be unreliable on some targets.
fn _pow2(n: i64) -> i64:
    if n == 0: return 1
    if n == 1: return 2
    if n == 2: return 4
    if n == 3: return 8
    if n == 4: return 16
    if n == 5: return 32
    if n == 6: return 64
    if n == 7: return 128
    if n == 8: return 256
    if n == 9: return 512
    if n == 10: return 1024
    if n == 11: return 2048
    if n == 12: return 4096
    if n == 13: return 8192
    if n == 14: return 16384
    if n == 15: return 32768
    if n == 16: return 65536
    if n == 17: return 131072
    if n == 18: return 262144
    if n == 19: return 524288
    if n == 20: return 1048576
    if n == 21: return 2097152
    if n == 22: return 4194304
    if n == 23: return 8388608
    if n == 24: return 16777216
    if n == 25: return 33554432
    if n == 26: return 67108864
    if n == 27: return 134217728
    if n == 28: return 268435456
    if n == 29: return 536870912
    if n == 30: return 1073741824
    if n == 31: return 2147483648
    if n == 32: return 4294967296
    2147483648
