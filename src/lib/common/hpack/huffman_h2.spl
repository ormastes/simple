        HuffEntry(code: 0x1e, bits: 6),          # 0x38 '8'
        HuffEntry(code: 0x1f, bits: 6),          # 0x39 '9'
        HuffEntry(code: 0x5c, bits: 7),          # 0x3a ':'
        HuffEntry(code: 0xfb, bits: 8),          # 0x3b ';'
