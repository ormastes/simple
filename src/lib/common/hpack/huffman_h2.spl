        HuffEntry(code: 0x3fb, bits: 10),        # 0x29 ')'
        HuffEntry(code: 0xf9, bits: 8),          # 0x2a '*'
        HuffEntry(code: 0x7fb, bits: 11),        # 0x2b '+'
        HuffEntry(code: 0xfa, bits: 8),          # 0x2c ','
        HuffEntry(code: 0x16, bits: 6),          # 0x2d '-'
        HuffEntry(code: 0x17, bits: 6),          # 0x2e '.'
        HuffEntry(code: 0x18, bits: 6),          # 0x2f '/'
        HuffEntry(code: 0x0, bits: 5),           # 0x30 '0'
        HuffEntry(code: 0x1, bits: 5),           # 0x31 '1'
        HuffEntry(code: 0x2, bits: 5),           # 0x32 '2'
        HuffEntry(code: 0x19, bits: 6),          # 0x33 '3'
        HuffEntry(code: 0x1a, bits: 6),          # 0x34 '4'
        HuffEntry(code: 0x1b, bits: 6),          # 0x35 '5'
        HuffEntry(code: 0x1c, bits: 6),          # 0x36 '6'
