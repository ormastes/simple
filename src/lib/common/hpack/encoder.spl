# HPACK encoder (RFC 7541 §6).
#
# Encodes a list of HpackHeader values to a byte sequence using the HPACK
# binary format. Manages the dynamic table for incremental indexing.
#
# Types (also used by decoder):
#   HpackHeader       — a single name+value pair with a sensitive flag
#   HpackEncoderState — mutable encoder state (dynamic table + huffman pref)
#   HpackDecoderState — mutable decoder state (dynamic table only)
#
# Encoding strategy (per header, in priority order):
#   1. sensitive=true  → Literal Never Indexed (§6.2.3), never insert
#   2. full (name+value) match in static or dynamic table
#                      → Indexed Header Field (§6.1); prefer static (lower index)
#   3. name-only match → Literal w/ Incremental Indexing (§6.2.1), name index
#   4. no match        → Literal w/ Incremental Indexing, literal name (index 0)
#
# String literals use Huffman when huffman==true AND the Huffman-coded form is
# shorter than the raw form.

use std.common.hpack.varint.{encode_prefix_int, decode_prefix_int}
use std.common.hpack.static_table.{hpack_static_find, hpack_static_lookup, hpack_static_table_size}
use std.common.hpack.dynamic_table.{DynamicTable, DynamicEntry, dynamic_table_new, dynamic_table_insert, dynamic_table_find, dynamic_table_lookup, dynamic_table_resize}
use std.common.hpack.huffman_h2.{hpack_huffman_encode, hpack_huffman_decode}

# A single HTTP/2 header field.
class HpackHeader:
    name: text    # MUST be lowercase per RFC 7541 §3.2.1 before encoding
    value: text
    sensitive: bool  # if true, encode as Literal Never Indexed (§6.2.3)

# Encoder state.
class HpackEncoderState:
    table: DynamicTable
    huffman: bool  # true → prefer Huffman-coded literals when shorter

# Decoder state.
class HpackDecoderState:
    table: DynamicTable

# Create a fresh encoder state.
fn hpack_encoder_new(max_table_size: i64, huffman: bool) -> HpackEncoderState:
    HpackEncoderState(table: dynamic_table_new(max_table_size), huffman: huffman)

# Create a fresh decoder state.
fn hpack_decoder_new(max_table_size: i64) -> HpackDecoderState:
    HpackDecoderState(table: dynamic_table_new(max_table_size))

# ----------------------------------------------------------------------------
# Module-level helpers
# ----------------------------------------------------------------------------

# Convert text to [u8] using ASCII (7-bit clean — HPACK header names/values
# are required to be lowercase ASCII per RFC 7541 §8.1.2 / RFC 7230 §3.2.4).
fn _text_to_u8(s: text) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < s.len():
        val code = s.char_code_at(i)
        out = out + [code.to_u8()]
        i = i + 1
    out

# Convert [u8] to text (ASCII round-trip; safe for 7-bit HPACK header bytes).
fn _u8_to_text(bytes: [u8]) -> text:
    var out = ""
    var i: i64 = 0
    while i < bytes.len():
        val code = bytes[i].to_i64()
        out = out + char_from_code_inline(code)
        i = i + 1
    out

# Append all bytes from `src` into `dst` and return the new array.
fn _append_bytes(dst: [u8], src: [u8]) -> [u8]:
    var result = dst
    var i: i64 = 0
    while i < src.len():
        result = result + [src[i]]
        i = i + 1
    result

# Encode a literal string payload as HPACK string (H=0 or H=1 as chosen).
# When huffman_enabled=true, encodes both ways and emits the shorter form.
# Returns the header byte(s) (length varint with H bit) + payload bytes.
fn _encode_string(payload_text: text, huffman_enabled: bool) -> [u8]:
    val payload_raw = _text_to_u8(payload_text)
    if not huffman_enabled:
        val header = encode_prefix_int(payload_raw.len(), 7, 0x00u8)
        return _append_bytes(header, payload_raw)
    # Try Huffman
    val payload_huff = hpack_huffman_encode(payload_raw)
    if payload_huff.len() < payload_raw.len():
        # Huffman is shorter: emit H=1
        val header = encode_prefix_int(payload_huff.len(), 7, 0x80u8)
        return _append_bytes(header, payload_huff)
    # Raw is shorter or equal: emit H=0
    val header = encode_prefix_int(payload_raw.len(), 7, 0x00u8)
    _append_bytes(header, payload_raw)

# Unified HPACK index lookup: searches static table first (lower indices win),
# then dynamic table.
#
# Returns (unified_index, full_match) where:
#   unified_index > 0  → found at this combined HPACK index
#   unified_index == -1 → no name match
#   full_match == true  → both name and value matched
fn _unified_find(dtable: DynamicTable, name: text, value: text) -> (i64, bool):
    val st = hpack_static_find(name, value)
    val static_idx = st.0
    val static_full = st.1
    val dt = dynamic_table_find(dtable, name, value)
    val dyn_rel = dt.0
    val dyn_full = dt.1
    val dyn_unified: i64 = if dyn_rel > 0: dyn_rel + 61 else -1

    if static_full:
        # Static full match — prefer (lower index)
        return (static_idx, true)
    if dyn_full:
        # Dynamic full match
        if static_idx > 0:
            # Static name-only also exists; dynamic full match wins for indexing
            return (dyn_unified, true)
        return (dyn_unified, true)
    # No full match — return best name-only
    if static_idx > 0:
        return (static_idx, false)
    if dyn_unified > 0:
        return (dyn_unified, false)
    (-1, false)

# Encode a single header field and return (bytes, updated_table).
fn _encode_one(h: HpackHeader, state: HpackEncoderState) -> ([u8], HpackEncoderState):
    val huff = state.huffman
    if h.sensitive:
        # §6.2.3 Literal Never Indexed: prefix 0001xxxx
        val found = _unified_find(state.table, h.name, h.value)
        val idx = found.0
        var out: [u8] = []
        if idx > 0:
            # Name already in a table — reference by index
            val prefix_byte = encode_prefix_int(idx, 4, 0x10u8)
            out = _append_bytes(out, prefix_byte)
        else:
            # Literal name
            val prefix_byte: [u8] = [0x10u8]
            out = _append_bytes(out, prefix_byte)
            out = _append_bytes(out, _encode_string(h.name, huff))
        out = _append_bytes(out, _encode_string(h.value, huff))
        # Never insert into dynamic table (§6.2.3)
        return (out, state)

    val found = _unified_find(state.table, h.name, h.value)
    val idx = found.0
    val full = found.1

    if full and idx > 0:
        # §6.1 Indexed Header Field: prefix 1xxxxxxx
        val enc = encode_prefix_int(idx, 7, 0x80u8)
        return (enc, state)

    if idx > 0:
        # §6.2.1 Literal w/ Incremental Indexing, name index
        var out: [u8] = []
        val prefix_byte = encode_prefix_int(idx, 6, 0x40u8)
        out = _append_bytes(out, prefix_byte)
        out = _append_bytes(out, _encode_string(h.value, huff))
        val new_table = dynamic_table_insert(state.table, h.name, h.value)
        val new_state = HpackEncoderState(table: new_table, huffman: huff)
        return (out, new_state)

    # §6.2.1 Literal w/ Incremental Indexing, literal name (index 0)
    var out: [u8] = []
    val prefix_byte: [u8] = [0x40u8]
    out = _append_bytes(out, prefix_byte)
    out = _append_bytes(out, _encode_string(h.name, huff))
    out = _append_bytes(out, _encode_string(h.value, huff))
    val new_table = dynamic_table_insert(state.table, h.name, h.value)
    val new_state = HpackEncoderState(table: new_table, huffman: huff)
    (out, new_state)

# ----------------------------------------------------------------------------
# Public API
# ----------------------------------------------------------------------------

# Encode a list of headers using HPACK. Returns (encoded_bytes, new_state).
fn hpack_encode(headers: [HpackHeader], state: HpackEncoderState) -> ([u8], HpackEncoderState):
    var out: [u8] = []
    var cur_state = state
    var i: i64 = 0
    while i < headers.len():
        val h = headers[i]
        val result = _encode_one(h, cur_state)
        out = _append_bytes(out, result.0)
        cur_state = result.1
        i = i + 1
    (out, cur_state)
