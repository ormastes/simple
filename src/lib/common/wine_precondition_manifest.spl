"""Composed Wine precondition manifest for the hello.exe milestone."""

use common.wine_substrate.{wine_substrate_check_process_evidence, wine_substrate_hello_exe_gate}

class WinePreconditionManifest:
    ready: bool
    state: text
    gates: text

fn _manifest(ready: bool, state: text, gates: text) -> WinePreconditionManifest:
    WinePreconditionManifest(ready: ready, state: state, gates: gates)

pub fn wine_precondition_manifest(
    process_log: text,
    vm_state: text,
    renderer_state: text,
    host_state: text,
    posix_state: text,
    pthread_state: text,
    dynload_state: text,
    async_state: text,
    pe_loader_state: text,
    nt_bridge_state: text
) -> WinePreconditionManifest:
    val process_state = wine_substrate_check_process_evidence(process_log)
    if process_state != "process-backed":
        return _manifest(false, "blocked-process:" + process_state, "")
    if vm_state != "ready":
        return _manifest(false, "blocked-vm:" + vm_state, "process=verified")
    if renderer_state != "ready":
        return _manifest(false, "blocked-renderer:" + renderer_state, "process=verified vm=verified")
    if host_state != "ready":
        return _manifest(false, "blocked-host:" + host_state, "process=verified vm=verified renderer=verified")
    if posix_state != "ready":
        return _manifest(false, "blocked-posix:" + posix_state, "process=verified vm=verified renderer=verified host=verified")
    if pthread_state != "ready":
        return _manifest(false, "blocked-pthread:" + pthread_state, "process=verified vm=verified renderer=verified host=verified posix=verified")
    if dynload_state != "ready":
        return _manifest(false, "blocked-dynload:" + dynload_state, "process=verified vm=verified renderer=verified host=verified posix=verified pthread=verified")
    if async_state != "ready":
        return _manifest(false, "blocked-async:" + async_state, "process=verified vm=verified renderer=verified host=verified posix=verified pthread=verified dynload=verified")
    if pe_loader_state != "ready":
        return _manifest(false, "blocked-pe-loader:" + pe_loader_state, "process=verified vm=verified renderer=verified host=verified posix=verified pthread=verified dynload=verified async=verified")
    if nt_bridge_state != "ready":
        return _manifest(false, "blocked-nt-bridge:" + nt_bridge_state, "process=verified vm=verified renderer=verified host=verified posix=verified pthread=verified dynload=verified async=verified pe_loader=verified")

    val gates = "process=verified vm=verified renderer=verified host=verified posix=verified pthread=verified dynload=verified async=verified pe_loader=verified nt_bridge=verified"
    val hello_state = wine_substrate_hello_exe_gate(gates)
    if hello_state != "ready":
        return _manifest(false, "blocked-hello:" + hello_state, gates)
    _manifest(true, "ready", gates)

pub fn wine_precondition_required_process_log() -> text:
    "[desktop-e2e] process-backed:ok app=browser_demo pid=1\n" +
        "[desktop-e2e] process-backed:ok app=hello_world pid=2\n" +
        "[desktop-e2e] process-backed:ok app=editor pid=3\n" +
        "[desktop-e2e] process-backed:ok app=terminal pid=4\n" +
        "[desktop-e2e] process-backed:ok app=file_manager pid=5"
