# ============================================================================
# common/search/simd_scan.spl — first-byte / memchr-style scan (AC-5)
#
# A SIMD SEAM. The point of this file is parity infrastructure, not raw speed:
#
#   scan_byte_scalar  — the ORACLE. A plain, obviously-correct byte loop.
#   scan_byte         — the DISPATCH entry. Today it forwards to the scalar
#                       oracle; tomorrow it picks an AVX2/NEON specialization.
#                       ANY future SIMD path MUST be byte-for-byte equal to the
#                       scalar oracle (proven in simd_scan_spec.spl).
#
# Why a seam now? memchr-style scans are the hottest inner loop in search
# (first-byte filtering for substring search, candidate generation). When the
# SIMD specialization lands it must not change observable results — only speed.
# Locking the dispatch == oracle contract today makes that future swap safe.
#
# Foundation: src/lib/common/bytes/ (ByteSpan) and common/search/types.spl
# (Haystack, MatchPos). Operates on the behavior-carrying types, never bare [u8].
#
# KNOWN BUG designed around: `for x in <custom struct>` silently iterates zero
# times (doc/08_tracking/bug/for_in_custom_struct_no_iterator_protocol_2026-06-15.md).
# This file iterates via index loops with `span.get(i)`, never for-in over a
# custom struct.
#
# Plan: doc/03_plan/lib/search/custom_type_alpha_search_team_plan_2026-06-15.md
# ============================================================================

use std.common.search.types.{Haystack, MatchPos}
use std.common.bytes.span.{ByteSpan}

# ----------------------------------------------------------------------------
# SimdTier — names the backend the dispatcher would select.
# ----------------------------------------------------------------------------
# A behavior-carrying tag so callers and tests can talk about "which path"
# without raw ints. Today only Scalar is wired; Avx2/Neon are reserved names
# the future specialization fills in. `is_scalar()` lets a test assert the
# dispatcher is honestly reporting the scalar fallback while no SIMD exists.
struct SimdTier:
    """Which scan backend the dispatcher selects. raw: 0=Scalar, 1=Avx2,
    2=Neon. Only Scalar is implemented this phase; the others are reserved
    seam names with no intrinsics behind them yet."""
    raw: i64

impl SimdTier:
    static fn scalar() -> SimdTier:
        SimdTier(raw: 0)

    static fn avx2() -> SimdTier:
        SimdTier(raw: 1)

    static fn neon() -> SimdTier:
        SimdTier(raw: 2)

    fn is_scalar() -> bool:
        self.raw == 0

    fn equals(other: SimdTier) -> bool:
        self.raw == other.raw

# ----------------------------------------------------------------------------
# active_tier — the dispatch seam's backend selector.
# ----------------------------------------------------------------------------
# FUTURE SIMD HOOK: when AVX2/NEON specializations land, this is the single
# place that probes CPU features (or a build flag) and returns Avx2/Neon.
# Until then it always returns Scalar, so `scan_byte` == `scan_byte_scalar`.
# Tests pin this to Scalar so the parity claim is honest for the shipped code.
fn active_tier() -> SimdTier:
    SimdTier.scalar()

# ----------------------------------------------------------------------------
# scan_byte_scalar — the ORACLE: a plain byte loop over the span.
# ----------------------------------------------------------------------------
fn scan_byte_scalar(span: ByteSpan, byte: u8) -> [MatchPos]:
    """Reference implementation: every index i where span.get(i) == byte,
    in ascending order, as typed MatchPos. Obviously correct; the byte-for-byte
    oracle every backend must match."""
    var out: [MatchPos] = []
    var i = 0
    val n = span.len()
    while i < n:
        if span.get(i) == byte:
            out.push(MatchPos.at(i))
        i = i + 1
    out

# ----------------------------------------------------------------------------
# scan_byte — the DISPATCH entry (future SIMD selection point).
# ----------------------------------------------------------------------------
fn scan_byte(span: ByteSpan, byte: u8) -> [MatchPos]:
    """memchr-style scan dispatch. Picks a backend via active_tier() and runs
    it. CONTRACT: the result is byte-for-byte identical to scan_byte_scalar for
    every input, on every backend. Today the only backend is scalar.

    FUTURE: when active_tier() returns Avx2/Neon, add the corresponding
    `scan_byte_avx2` / `scan_byte_neon` specialization here. It must produce the
    exact same [MatchPos] sequence as scan_byte_scalar (proven by the parity
    seam in simd_scan_spec.spl)."""
    val tier = active_tier()
    # Dispatch seam: scalar is the only wired path. The future SIMD branches
    # slot in here (e.g. `if tier.equals(SimdTier.avx2()): return scan_byte_avx2(...)`).
    if tier.is_scalar():
        return scan_byte_scalar(span, byte)
    # No SIMD backend wired yet; fail safe to the oracle so results never differ.
    scan_byte_scalar(span, byte)

# ----------------------------------------------------------------------------
# scan_byte_haystack — convenience: scan over a Haystack instead of a raw span.
# ----------------------------------------------------------------------------
fn scan_byte_haystack(hay: Haystack, byte: u8) -> [MatchPos]:
    """Scan a behavior-carrying Haystack. Forwards to the dispatch entry so it
    inherits the oracle-parity contract."""
    scan_byte(hay.span, byte)

# ----------------------------------------------------------------------------
# first_last_byte_filter — cheap substring prefilter (first AND last byte).
# ----------------------------------------------------------------------------
# A classic memchr-based substring prefilter: a needle of length L can only
# occur starting at position i if span[i] == needle[0] AND span[i+L-1] ==
# needle[last]. This cheaply rejects most positions before the (expensive)
# full verify, and never drops a true match (no false negatives) — the verify
# step downstream confirms the survivors.
fn first_last_byte_filter(span: ByteSpan, first: u8, last: u8, needle_len: i64) -> [MatchPos]:
    """Candidate start positions where BOTH the first byte (span[i]==first) and
    the last byte (span[i+needle_len-1]==last) of the needle align. Returns
    typed MatchPos starts in ascending order.

    Guarantee: a true occurrence of a needle whose first byte is `first` and
    last byte is `last` is ALWAYS in the output (no false negatives). False
    positives are expected and removed by the downstream verify step."""
    var out: [MatchPos] = []
    if needle_len <= 0:
        return out
    val n = span.len()
    # Last valid start is n - needle_len; beyond it the needle can't fit.
    var i = 0
    val last_start = n - needle_len
    while i <= last_start:
        if span.get(i) == first:
            if span.get(i + needle_len - 1) == last:
                out.push(MatchPos.at(i))
        i = i + 1
    out

# ----------------------------------------------------------------------------
# scalar oracle for first_last_byte_filter — for the parity seam.
# ----------------------------------------------------------------------------
fn first_last_byte_filter_scalar(span: ByteSpan, first: u8, last: u8, needle_len: i64) -> [MatchPos]:
    """Forced-scalar reference for first_last_byte_filter. Identical logic; the
    dispatch entry above is the future SIMD specialization point. Kept separate
    so the spec can assert dispatch == oracle byte-for-byte."""
    var out: [MatchPos] = []
    if needle_len <= 0:
        return out
    val n = span.len()
    var i = 0
    val last_start = n - needle_len
    while i <= last_start:
        if span.get(i) == first:
            if span.get(i + needle_len - 1) == last:
                out.push(MatchPos.at(i))
        i = i + 1
    out

# ----------------------------------------------------------------------------
# pos_list_equals — byte-for-byte comparison of two [MatchPos] (parity helper).
# ----------------------------------------------------------------------------
fn pos_list_equals(a: [MatchPos], b: [MatchPos]) -> bool:
    """True iff a and b are the same length and equal index-by-index. The
    primitive the parity seam uses to prove dispatch == oracle."""
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i].value() != b[i].value():
            return false
        i = i + 1
    true
