use std.ndarray.*

enum LinalgError:
    DimensionMismatch
    Singular

fn vector_from(values: [Float64]) -> NDArray:
    array(values)

fn matrix_from_rows(rows: [[Float64]]) -> NDArray:
    val row_count = rows.len()
    val col_count = if row_count == 0: 0 else: rows[0].len()
    var flat: [Float64] = []
    var r = 0
    while r < row_count:
        var c = 0
        while c < col_count:
            flat.push(rows[r][c])
            c = c + 1
        r = r + 1
    make_f64_array(flat, Shape.new([Index.new(row_count), Index.new(col_count)]))

fn zeros_matrix(rows: Index, cols: Index) -> NDArray:
    zeros(Shape.new([rows, cols]))

fn full_matrix(rows: Index, cols: Index, fill: Float64) -> NDArray:
    full(Shape.new([rows, cols]), fill)

fn eye_matrix(size: Index) -> NDArray:
    eye(size)

fn axpy(alpha: Float64, x: NDArray, y: NDArray) -> NDArray:
    try_axpy(alpha, x, y).unwrap()

fn try_axpy(alpha: Float64, x: NDArray, y: NDArray) -> Result<NDArray, LinalgError>:
    if x.shape != y.shape:
        return Err(LinalgError.DimensionMismatch)
    var out: [Float64] = []
    var i = 0
    while i < x.data_f64.len():
        out.push(Float64.new(x.data_f64[i].value * alpha.value + y.data_f64[i].value))
        i = i + 1
    Ok(array(out))

fn gemm(alpha: Float64, a: NDArray, b: NDArray, beta: Float64, c_in: NDArray) -> NDArray:
    var rows_out: [[Float64]] = []
    var row = 0
    while row < a.rows().value:
        var row_result = row_vector_f64(c_in, row).mul_scalar(beta)
        var k = 0
        while k < a.cols().value:
            val coeff = Float64.new(alpha.value * a.get_f64_at([Index.new(row), Index.new(k)]).value)
            row_result = axpy(coeff, row_vector_f64(b, k), row_result)
            k = k + 1
        rows_out.push(row_result.to_f64_values())
        row = row + 1
    matrix_from_rows(rows_out)

fn try_gemm(alpha: Float64, a: NDArray, b: NDArray, beta: Float64, c_in: NDArray) -> Result<NDArray, LinalgError>:
    if a.cols().value != b.rows().value:
        return Err(LinalgError.DimensionMismatch)
    if c_in.rows().value != a.rows().value or c_in.cols().value != b.cols().value:
        return Err(LinalgError.DimensionMismatch)
    val result = gemm(alpha, a, b, beta, c_in)
    Ok(result)

fn solve(a: NDArray, b: NDArray) -> Result<NDArray, LinalgError>:
    val n = a.rows().value
    if a.rows().value != a.cols().value:
        return Err(LinalgError.DimensionMismatch)
    if b.len().value != n:
        return Err(LinalgError.DimensionMismatch)
    var mat: [[Float64]] = []
    var row = 0
    while row < n:
        var current: [Float64] = []
        var col = 0
        while col < n:
            current.push(a.get_f64_at([Index.new(row), Index.new(col)]))
            col = col + 1
        mat.push(current)
        row = row + 1
    var rhs: [Float64] = []
    row = 0
    while row < n:
        rhs.push(b.get_f64(Index.new(row)))
        row = row + 1
    var pivot = 0
    while pivot < n:
        if mat[pivot][pivot].value == 0.0:
            return Err(LinalgError.Singular)
        var lower = pivot + 1
        while lower < n:
            val factor = mat[lower][pivot].value / mat[pivot][pivot].value
            var col = pivot
            while col < n:
                mat[lower][col] = Float64.new(mat[lower][col].value - factor * mat[pivot][col].value)
                col = col + 1
            rhs[lower] = Float64.new(rhs[lower].value - factor * rhs[pivot].value)
            lower = lower + 1
        pivot = pivot + 1
    var x: [Float64] = []
    var i = 0
    while i < n:
        x.push(Float64.new(0.0))
        i = i + 1
    i = n - 1
    while i >= 0:
        var sum = rhs[i].value
        var col = i + 1
        while col < n:
            sum = sum - mat[i][col].value * x[col].value
            col = col + 1
        if mat[i][i].value == 0.0:
            return Err(LinalgError.Singular)
        x[i] = Float64.new(sum / mat[i][i].value)
        i = i - 1
    Ok(array(x))

fn row_vector_f64(array_value: NDArray, row: i64) -> NDArray:
    var out: [Float64] = []
    var col = 0
    while col < array_value.cols().value:
        out.push(array_value.get_f64_at([Index.new(row), Index.new(col)]))
        col = col + 1
    array(out)

fn basis_vector_f64(length: i64, index: i64) -> NDArray:
    var out: [Float64] = []
    var i = 0
    while i < length:
        if i == index:
            out.push(Float64.new(1.0))
        else:
            out.push(Float64.new(0.0))
        i = i + 1
    array(out)
