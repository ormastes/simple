"""Small PE/COFF header classifier used before any Wine execution path."""

class PeHeaderSummary:
    ok: bool
    error: text
    machine: text
    optional_header: text
    subsystem_kind: text
    section_count: i64
    pe_offset: i64

class PeImportSymbolBinding:
    symbol: text
    name_rva: i64

class PeImportThunkBinding:
    symbol: text
    thunk_index: i64
    thunk_rva: i64
    name_rva: i64

class PeImportDescriptorSummary:
    dll_name: text
    descriptor_index: i64
    lookup_thunk_rva: i64
    first_thunk_rva: i64
    symbol_count: i64

fn _read_u16_le(data: [u8], offset: i64) -> i64:
    if offset + 1 >= data.len():
        return 0
    val lo = data[offset] as i64
    val hi = data[offset + 1] as i64
    lo | (hi << 8)

fn _read_u32_le(data: [u8], offset: i64) -> i64:
    if offset + 3 >= data.len():
        return 0
    val b0 = data[offset] as i64
    val b1 = data[offset + 1] as i64
    val b2 = data[offset + 2] as i64
    val b3 = data[offset + 3] as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn _summary_error(code: text) -> PeHeaderSummary:
    PeHeaderSummary(ok: false, error: code, machine: "", optional_header: "", subsystem_kind: "", section_count: 0, pe_offset: 0)

fn _machine_name(machine: i64) -> text:
    if machine == 0x8664:
        return "x86_64"
    if machine == 0x014c:
        return "x86"
    return "unsupported"

fn _optional_header_name(magic: i64) -> text:
    if magic == 0x20b:
        return "PE32+"
    if magic == 0x10b:
        return "PE32"
    return "unsupported"

fn _subsystem_name(subsystem: i64) -> text:
    if subsystem == 3:
        return "console"
    if subsystem == 2:
        return "gui"
    return "unsupported"

pub fn parse_pe_header_summary(data: [u8]) -> PeHeaderSummary:
    if data.len() < 0x40:
        return _summary_error("too-small")
    if data[0] != 0x4d or data[1] != 0x5a:
        return _summary_error("bad-mz")
    val pe_offset = _read_u32_le(data, 0x3c)
    if pe_offset <= 0 or pe_offset + 0x5c >= data.len():
        return _summary_error("bad-pe-offset")
    if data[pe_offset] != 0x50 or data[pe_offset + 1] != 0x45 or data[pe_offset + 2] != 0 or data[pe_offset + 3] != 0:
        return _summary_error("bad-pe-signature")
    val machine_raw = _read_u16_le(data, pe_offset + 4)
    val section_count = _read_u16_le(data, pe_offset + 6)
    val optional_size = _read_u16_le(data, pe_offset + 20)
    val optional_offset = pe_offset + 24
    if optional_size < 0x5e:
        return _summary_error("optional-header-too-small")
    if optional_offset + optional_size > data.len():
        return _summary_error("optional-header-out-of-bounds")
    val optional_magic = _read_u16_le(data, optional_offset)
    val subsystem_raw = _read_u16_le(data, optional_offset + 0x5c)
    val machine = _machine_name(machine_raw)
    val optional_header = _optional_header_name(optional_magic)
    val subsystem = _subsystem_name(subsystem_raw)
    if machine != "x86_64":
        return PeHeaderSummary(ok: false, error: "unsupported-machine", machine: machine, optional_header: optional_header, subsystem_kind: subsystem, section_count: section_count, pe_offset: pe_offset)
    if optional_header != "PE32+":
        return PeHeaderSummary(ok: false, error: "unsupported-optional-header", machine: machine, optional_header: optional_header, subsystem_kind: subsystem, section_count: section_count, pe_offset: pe_offset)
    if subsystem != "console":
        return PeHeaderSummary(ok: false, error: "unsupported-subsystem", machine: machine, optional_header: optional_header, subsystem_kind: subsystem, section_count: section_count, pe_offset: pe_offset)
    PeHeaderSummary(ok: true, error: "", machine: machine, optional_header: optional_header, subsystem_kind: subsystem, section_count: section_count, pe_offset: pe_offset)

pub fn pe_section_table_gate(data: [u8]) -> text:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return summary.error
    val optional_size = _read_u16_le(data, summary.pe_offset + 20)
    val section_count = _read_u16_le(data, summary.pe_offset + 6)
    if section_count <= 0:
        return "missing-section-table"
    val section_table_offset = summary.pe_offset + 24 + optional_size
    val section_table_size = section_count * 40
    if section_table_offset + section_table_size > data.len():
        return "section-table-out-of-bounds"
    return "ready"

pub fn pe_section_bounds_gate(data: [u8]) -> text:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return summary.error
    val table_state = pe_section_table_gate(data)
    if table_state != "ready":
        return table_state
    val headers_size = pe_size_of_headers(data)
    val image_size = pe_size_of_image(data)
    if headers_size <= 0:
        return "missing-headers-size"
    if image_size <= headers_size:
        return "bad-image-size"
    val section_table_offset = _section_table_offset(data, summary.pe_offset)
    var i = 0
    while i < summary.section_count:
        val section_offset = section_table_offset + (i * 40)
        val virtual_size = _read_u32_le(data, section_offset + 8)
        val virtual_address = _read_u32_le(data, section_offset + 12)
        val raw_size = _read_u32_le(data, section_offset + 16)
        val raw_pointer = _read_u32_le(data, section_offset + 20)
        var mapped_size = virtual_size
        if raw_size > mapped_size:
            mapped_size = raw_size
        if virtual_address < headers_size:
            return "section-overlaps-headers"
        if mapped_size <= 0:
            return "section-empty"
        if virtual_address + mapped_size > image_size:
            return "section-virtual-out-of-image"
        if raw_size <= 0:
            return "section-raw-empty"
        if raw_pointer < headers_size:
            return "section-raw-overlaps-headers"
        if raw_pointer + raw_size > data.len():
            return "section-raw-out-of-bounds"
        i = i + 1
    "ready"

fn _data_directory_pair_nonzero(data: [u8], optional_offset: i64, index: i64) -> bool:
    val dir_offset = optional_offset + 0x70 + (index * 8)
    if dir_offset + 7 >= data.len():
        return false
    val rva = _read_u32_le(data, dir_offset)
    val size = _read_u32_le(data, dir_offset + 4)
    rva != 0 and size != 0

pub fn pe_data_directory_gate(data: [u8]) -> text:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return summary.error
    val optional_offset = summary.pe_offset + 24
    val optional_size = _read_u16_le(data, summary.pe_offset + 20)
    if optional_size < 0xf0:
        return "data-directories-out-of-bounds"
    val dir_count = _read_u32_le(data, optional_offset + 0x6c)
    if dir_count < 10:
        return "missing-data-directories"
    if not _data_directory_pair_nonzero(data, optional_offset, 1):
        return "missing-import-directory"
    if not _data_directory_pair_nonzero(data, optional_offset, 5):
        return "missing-relocation-directory"
    if not _data_directory_pair_nonzero(data, optional_offset, 9):
        return "missing-tls-directory"
    return "ready"

pub fn pe_entry_point_rva(data: [u8]) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return 0
    _read_u32_le(data, summary.pe_offset + 24 + 0x10)

pub fn pe_size_of_image(data: [u8]) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return 0
    _read_u32_le(data, summary.pe_offset + 24 + 0x38)

pub fn pe_size_of_headers(data: [u8]) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return 0
    _read_u32_le(data, summary.pe_offset + 24 + 0x3c)

fn _section_table_offset(data: [u8], pe_offset: i64) -> i64:
    val optional_size = _read_u16_le(data, pe_offset + 20)
    pe_offset + 24 + optional_size

pub fn pe_rva_to_file_offset(data: [u8], rva: i64) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return -1
    val section_table_offset = _section_table_offset(data, summary.pe_offset)
    var i = 0
    while i < summary.section_count:
        val section_offset = section_table_offset + (i * 40)
        if section_offset + 39 >= data.len():
            return -1
        val virtual_size = _read_u32_le(data, section_offset + 8)
        val virtual_address = _read_u32_le(data, section_offset + 12)
        val raw_size = _read_u32_le(data, section_offset + 16)
        val raw_pointer = _read_u32_le(data, section_offset + 20)
        var mapped_size = virtual_size
        if raw_size > mapped_size:
            mapped_size = raw_size
        if mapped_size > 0 and rva >= virtual_address and rva < virtual_address + mapped_size:
            val file_offset = raw_pointer + (rva - virtual_address)
            if file_offset >= 0 and file_offset < data.len():
                return file_offset
            return -1
        i = i + 1
    -1

pub fn pe_entry_section_executable_gate(data: [u8]) -> text:
    val bounds_state = pe_section_bounds_gate(data)
    if bounds_state != "ready":
        return bounds_state
    val summary = parse_pe_header_summary(data)
    val entry_rva = pe_entry_point_rva(data)
    if entry_rva <= 0:
        return "missing-entrypoint"
    val section_table_offset = _section_table_offset(data, summary.pe_offset)
    var i = 0
    while i < summary.section_count:
        val section_offset = section_table_offset + (i * 40)
        val virtual_size = _read_u32_le(data, section_offset + 8)
        val virtual_address = _read_u32_le(data, section_offset + 12)
        val raw_size = _read_u32_le(data, section_offset + 16)
        val characteristics = _read_u32_le(data, section_offset + 36)
        var mapped_size = virtual_size
        if raw_size > mapped_size:
            mapped_size = raw_size
        if mapped_size > 0 and entry_rva >= virtual_address and entry_rva < virtual_address + mapped_size:
            if (characteristics & 0x20000000) == 0:
                return "entry-section-not-executable"
            return "ready"
        i = i + 1
    "entrypoint-unmapped"

fn _read_ascii_z(data: [u8], offset: i64, limit: i64) -> text:
    if offset < 0 or offset >= data.len():
        return ""
    var out = ""
    var i = offset
    var count = 0
    while i < data.len() and count < limit:
        val byte = data[i] as i64
        if byte == 0:
            return out
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        val idx = byte - 32
        if idx < 0 or idx >= chars.len():
            return ""
        out = out + chars[idx:idx + 1]
        i = i + 1
        count = count + 1
    ""

fn _import_descriptor_is_zero(data: [u8], offset: i64) -> bool:
    if offset < 0 or offset + 19 >= data.len():
        return false
    _read_u32_le(data, offset) == 0 and
       _read_u32_le(data, offset + 4) == 0 and
       _read_u32_le(data, offset + 8) == 0 and
       _read_u32_le(data, offset + 12) == 0 and
       _read_u32_le(data, offset + 16) == 0

fn _import_directory_offset(data: [u8]) -> i64:
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return -1
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    pe_rva_to_file_offset(data, import_rva)

fn _import_descriptor_thunk_gate(data: [u8], descriptor_offset: i64, limit: i64) -> text:
    if limit <= 0:
        return "invalid-import-symbol-limit"
    var thunk_rva = _read_u32_le(data, descriptor_offset)
    if thunk_rva == 0:
        thunk_rva = _read_u32_le(data, descriptor_offset + 16)
    if thunk_rva == 0:
        return "missing-import-thunk"
    var i = 0
    var symbol_count = 0
    while i < limit:
        val entry_rva = thunk_rva + (i * 8)
        val entry_offset = pe_rva_to_file_offset(data, entry_rva)
        if entry_offset < 0 or entry_offset + 7 >= data.len():
            return "import-thunk-entry-unmapped"
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            if symbol_count == 0:
                return "import-thunk-empty"
            return "ready"
        if entry_high != 0:
            return "import-thunk-ordinal-unsupported"
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        if name_offset < 0 or name_offset + 2 >= data.len():
            return "import-symbol-name-unmapped"
        val symbol = _read_ascii_z(data, name_offset + 2, 128)
        if symbol == "":
            return "import-symbol-name-invalid"
        symbol_count = symbol_count + 1
        i = i + 1
    "import-thunk-limit-exceeded"

fn _import_descriptor_symbol_count(data: [u8], descriptor_offset: i64, limit: i64) -> i64:
    var thunk_rva = _read_u32_le(data, descriptor_offset)
    if thunk_rva == 0:
        thunk_rva = _read_u32_le(data, descriptor_offset + 16)
    if thunk_rva == 0 or limit <= 0:
        return 0
    var i = 0
    while i < limit:
        val entry_offset = pe_rva_to_file_offset(data, thunk_rva + (i * 8))
        if entry_offset < 0 or entry_offset + 7 >= data.len():
            return i
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            return i
        if entry_high != 0:
            return i
        i = i + 1
    i

pub fn pe_import_directory_gate(data: [u8]) -> text:
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    if import_offset < 0 or import_offset + 19 >= data.len():
        return "import-directory-out-of-bounds"
    if import_offset + 39 >= data.len():
        return "import-descriptor-terminator-out-of-bounds"
    val name_rva = _read_u32_le(data, import_offset + 12)
    if name_rva == 0:
        return "missing-import-name"
    val name_offset = pe_rva_to_file_offset(data, name_rva)
    val name = _read_ascii_z(data, name_offset, 128)
    if name == "":
        return "import-name-out-of-bounds"
    val next_descriptor_offset = import_offset + 20
    if _read_u32_le(data, next_descriptor_offset) != 0 or
       _read_u32_le(data, next_descriptor_offset + 4) != 0 or
       _read_u32_le(data, next_descriptor_offset + 8) != 0 or
       _read_u32_le(data, next_descriptor_offset + 12) != 0 or
       _read_u32_le(data, next_descriptor_offset + 16) != 0:
        return "import-descriptor-unterminated"
    return "ready"

pub fn pe_import_descriptor_table_gate(data: [u8], descriptor_limit: i64, symbol_limit: i64) -> text:
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    if descriptor_limit <= 0:
        return "invalid-import-descriptor-limit"
    if symbol_limit <= 0:
        return "invalid-import-symbol-limit"
    val import_offset = _import_directory_offset(data)
    if import_offset < 0 or import_offset + 19 >= data.len():
        return "import-directory-out-of-bounds"
    var i = 0
    while i < descriptor_limit:
        val descriptor_offset = import_offset + (i * 20)
        if descriptor_offset + 19 >= data.len():
            return "import-descriptor-out-of-bounds"
        if _import_descriptor_is_zero(data, descriptor_offset):
            if i == 0:
                return "missing-import-descriptor"
            return "ready"
        val name_rva = _read_u32_le(data, descriptor_offset + 12)
        if name_rva == 0:
            return "missing-import-name"
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        val name = _read_ascii_z(data, name_offset, 128)
        if name == "":
            return "import-name-out-of-bounds"
        val thunk_state = _import_descriptor_thunk_gate(data, descriptor_offset, symbol_limit)
        if thunk_state != "ready":
            return thunk_state
        i = i + 1
    "import-descriptor-limit-exceeded"

pub fn pe_import_descriptor_summaries(data: [u8], descriptor_limit: i64, symbol_limit: i64) -> [PeImportDescriptorSummary]:
    var summaries: [PeImportDescriptorSummary] = []
    val table_state = pe_import_descriptor_table_gate(data, descriptor_limit, symbol_limit)
    if table_state != "ready":
        return summaries
    val import_offset = _import_directory_offset(data)
    var i = 0
    while i < descriptor_limit:
        val descriptor_offset = import_offset + (i * 20)
        if _import_descriptor_is_zero(data, descriptor_offset):
            return summaries
        val name_rva = _read_u32_le(data, descriptor_offset + 12)
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        val dll_name = _read_ascii_z(data, name_offset, 128)
        var lookup_thunk_rva = _read_u32_le(data, descriptor_offset)
        val first_thunk_rva = _read_u32_le(data, descriptor_offset + 16)
        if lookup_thunk_rva == 0:
            lookup_thunk_rva = first_thunk_rva
        val symbol_count = _import_descriptor_symbol_count(data, descriptor_offset, symbol_limit)
        summaries.push(PeImportDescriptorSummary(dll_name: dll_name, descriptor_index: i, lookup_thunk_rva: lookup_thunk_rva, first_thunk_rva: first_thunk_rva, symbol_count: symbol_count))
        i = i + 1
    summaries

fn _directory_rva(data: [u8], index: i64) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return 0
    val optional_offset = summary.pe_offset + 24
    _read_u32_le(data, optional_offset + 0x70 + (index * 8))

fn _directory_size(data: [u8], index: i64) -> i64:
    val summary = parse_pe_header_summary(data)
    if not summary.ok:
        return 0
    val optional_offset = summary.pe_offset + 24
    _read_u32_le(data, optional_offset + 0x70 + (index * 8) + 4)

pub fn pe_relocation_directory_rva(data: [u8]) -> i64:
    _directory_rva(data, 5)

pub fn pe_relocation_directory_size(data: [u8]) -> i64:
    _directory_size(data, 5)

pub fn pe_tls_directory_rva(data: [u8]) -> i64:
    _directory_rva(data, 9)

pub fn pe_tls_directory_size(data: [u8]) -> i64:
    _directory_size(data, 9)

pub fn pe_relocation_directory_gate(data: [u8]) -> text:
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    val reloc_rva = _directory_rva(data, 5)
    val reloc_size = _directory_size(data, 5)
    val reloc_offset = pe_rva_to_file_offset(data, reloc_rva)
    if reloc_offset < 0:
        return "relocation-directory-unmapped"
    if reloc_size < 8 or reloc_offset + reloc_size > data.len():
        return "relocation-directory-out-of-bounds"
    val block_size = _read_u32_le(data, reloc_offset + 4)
    if block_size < 8 or block_size > reloc_size:
        return "relocation-block-invalid"
    if reloc_offset + block_size > data.len():
        return "relocation-block-out-of-bounds"
    "ready"

pub fn pe_tls_directory_gate(data: [u8]) -> text:
    val directory_state = pe_data_directory_gate(data)
    if directory_state != "ready":
        return directory_state
    val tls_rva = _directory_rva(data, 9)
    val tls_size = _directory_size(data, 9)
    val tls_offset = pe_rva_to_file_offset(data, tls_rva)
    if tls_offset < 0:
        return "tls-directory-unmapped"
    if tls_size < 0x18 or tls_offset + tls_size > data.len():
        return "tls-directory-out-of-bounds"
    "ready"

pub fn pe_first_import_dll_name(data: [u8]) -> text:
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return ""
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    val name_rva = _read_u32_le(data, import_offset + 12)
    val name_offset = pe_rva_to_file_offset(data, name_rva)
    _read_ascii_z(data, name_offset, 128)

pub fn pe_first_import_symbol_names(data: [u8], limit: i64) -> [text]:
    var names: [text] = []
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return names
    if limit <= 0:
        return names
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    var thunk_rva = _read_u32_le(data, import_offset)
    if thunk_rva == 0:
        thunk_rva = _read_u32_le(data, import_offset + 16)
    val thunk_offset = pe_rva_to_file_offset(data, thunk_rva)
    if thunk_offset < 0:
        return names
    var i = 0
    while i < limit:
        val entry_offset = thunk_offset + (i * 8)
        if entry_offset + 7 >= data.len():
            return names
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            return names
        if entry_high != 0:
            return names
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        if name_offset < 0 or name_offset + 2 >= data.len():
            return names
        val symbol = _read_ascii_z(data, name_offset + 2, 128)
        if symbol == "":
            return names
        names.push(symbol)
        i = i + 1
    names

pub fn pe_first_import_thunk_gate(data: [u8], limit: i64) -> text:
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return import_state
    if limit <= 0:
        return "invalid-import-thunk-limit"
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    var thunk_rva = _read_u32_le(data, import_offset)
    if thunk_rva == 0:
        thunk_rva = _read_u32_le(data, import_offset + 16)
    if thunk_rva == 0:
        return "missing-import-thunk"
    var i = 0
    var symbol_count = 0
    while i < limit:
        val entry_rva = thunk_rva + (i * 8)
        val entry_offset = pe_rva_to_file_offset(data, entry_rva)
        if entry_offset < 0 or entry_offset + 7 >= data.len():
            return "import-thunk-entry-unmapped"
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            if symbol_count == 0:
                return "import-thunk-empty"
            return "ready"
        if entry_high != 0:
            return "import-thunk-ordinal-unsupported"
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        if name_offset < 0 or name_offset + 2 >= data.len():
            return "import-symbol-name-unmapped"
        val symbol = _read_ascii_z(data, name_offset + 2, 128)
        if symbol == "":
            return "import-symbol-name-invalid"
        symbol_count = symbol_count + 1
        i = i + 1
    "import-thunk-limit-exceeded"

pub fn pe_first_import_symbol_bindings(data: [u8], limit: i64) -> [PeImportSymbolBinding]:
    var bindings: [PeImportSymbolBinding] = []
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return bindings
    if limit <= 0:
        return bindings
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    var thunk_rva = _read_u32_le(data, import_offset)
    if thunk_rva == 0:
        thunk_rva = _read_u32_le(data, import_offset + 16)
    val thunk_offset = pe_rva_to_file_offset(data, thunk_rva)
    if thunk_offset < 0:
        return bindings
    var i = 0
    while i < limit:
        val entry_offset = thunk_offset + (i * 8)
        if entry_offset + 7 >= data.len():
            return bindings
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            return bindings
        if entry_high != 0:
            return bindings
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        if name_offset < 0 or name_offset + 2 >= data.len():
            return bindings
        val symbol = _read_ascii_z(data, name_offset + 2, 128)
        if symbol == "":
            return bindings
        bindings.push(PeImportSymbolBinding(symbol: symbol, name_rva: name_rva))
        i = i + 1
    bindings

pub fn pe_first_import_thunk_bindings(data: [u8], limit: i64) -> [PeImportThunkBinding]:
    var bindings: [PeImportThunkBinding] = []
    val import_state = pe_import_directory_gate(data)
    if import_state != "ready":
        return bindings
    if limit <= 0:
        return bindings
    val summary = parse_pe_header_summary(data)
    val optional_offset = summary.pe_offset + 24
    val import_rva = _read_u32_le(data, optional_offset + 0x70 + 8)
    val import_offset = pe_rva_to_file_offset(data, import_rva)
    var lookup_thunk_rva = _read_u32_le(data, import_offset)
    if lookup_thunk_rva == 0:
        lookup_thunk_rva = _read_u32_le(data, import_offset + 16)
    val lookup_thunk_offset = pe_rva_to_file_offset(data, lookup_thunk_rva)
    if lookup_thunk_offset < 0:
        return bindings
    var i = 0
    while i < limit:
        val entry_offset = lookup_thunk_offset + (i * 8)
        if entry_offset + 7 >= data.len():
            return bindings
        val name_rva = _read_u32_le(data, entry_offset)
        val entry_high = _read_u32_le(data, entry_offset + 4)
        if name_rva == 0 and entry_high == 0:
            return bindings
        if entry_high != 0:
            return bindings
        val name_offset = pe_rva_to_file_offset(data, name_rva)
        if name_offset < 0 or name_offset + 2 >= data.len():
            return bindings
        val symbol = _read_ascii_z(data, name_offset + 2, 128)
        if symbol == "":
            return bindings
        bindings.push(PeImportThunkBinding(symbol: symbol, thunk_index: i, thunk_rva: lookup_thunk_rva + (i * 8), name_rva: name_rva))
        i = i + 1
    bindings
