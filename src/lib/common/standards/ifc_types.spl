# IFC Types
#
# Core entity type definitions for IFC 4.3 / ISO 16739-1:2024 BIM interchange.
# Covers building elements, spatial structure, materials, and property sets.
#
# Standard: IFC 4.3 (buildingSMART)
# Related: FR-COMPILER-009

# ============================================================
# Root Object
# ============================================================

struct IfcRoot:
    """Base identity shared by all IFC entities."""
    global_id: text
    name: text?
    description: text?

# ============================================================
# Geometry Reference
# ============================================================

struct IfcCartesianPoint:
    x: f64
    y: f64
    z: f64

struct IfcDirection:
    x: f64
    y: f64
    z: f64

struct IfcAxis2Placement3D:
    location: IfcCartesianPoint
    axis: IfcDirection?
    ref_direction: IfcDirection?

struct IfcLocalPlacement:
    relative_to: text?
    placement: IfcAxis2Placement3D

# ============================================================
# Spatial Structure
# ============================================================

struct IfcSite:
    """IFC site entity — top of the spatial hierarchy."""
    root: IfcRoot
    ref_latitude: f64?
    ref_longitude: f64?
    ref_elevation: f64?

struct IfcBuilding:
    """IFC building entity."""
    root: IfcRoot
    elevation_of_ref_height: f64?
    elevation_of_terrain: f64?

struct IfcBuildingStorey:
    """A single floor/storey in a building."""
    root: IfcRoot
    elevation: f64?

struct IfcSpace:
    """A defined spatial zone (room, zone, etc.)."""
    root: IfcRoot
    predefined_type: text?
    elevation_with_flooring: f64?

# ============================================================
# Building Elements
# ============================================================

enum IfcWallTypeEnum:
    Standard
    Polygonal
    Shear
    ElementedWall
    PlumbingWall
    Movable
    Parapet
    PartitioningWall
    FireWall
    SolidWall
    UserDefined
    NotDefined

struct IfcWall:
    """IFC wall entity."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    predefined_type: IfcWallTypeEnum

enum IfcSlabTypeEnum:
    Floor
    Roof
    Landing
    Baseslab
    Approach
    Paving
    Wearing
    Notdefined

struct IfcSlab:
    """IFC slab entity (floor, roof, etc.)."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    predefined_type: IfcSlabTypeEnum

enum IfcBeamTypeEnum:
    Beam
    Joist
    Hollowcore
    Lintel
    Spandrel
    TBeam
    Userdefined
    Notdefined

struct IfcBeam:
    """IFC beam entity."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    predefined_type: IfcBeamTypeEnum

enum IfcColumnTypeEnum:
    Column
    Pilaster
    Userdefined
    Notdefined

struct IfcColumn:
    """IFC column entity."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    predefined_type: IfcColumnTypeEnum

struct IfcDoor:
    """IFC door entity."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    overall_height: f64?
    overall_width: f64?

struct IfcWindow:
    """IFC window entity."""
    root: IfcRoot
    placement: IfcLocalPlacement?
    overall_height: f64?
    overall_width: f64?

# ============================================================
# Material
# ============================================================

struct IfcMaterial:
    """A named material with optional description and category."""
    name: text
    description: text?
    category: text?

struct IfcMaterialLayer:
    material: IfcMaterial?
    layer_thickness: f64
    is_ventilated: bool

struct IfcMaterialLayerSet:
    material_layers: [IfcMaterialLayer]
    layer_set_name: text?

# ============================================================
# Property Set
# ============================================================

struct IfcPropertySingleValue:
    name: text
    description: text?
    nominal_value: text

struct IfcPropertySet:
    """A named collection of properties attached to an IFC object."""
    root: IfcRoot
    properties: [IfcPropertySingleValue]
