# MusicXML Types
#
# Core type definitions for MusicXML 4.0 interchange.
# Covers pitch, duration, note, measure, staff, and score metadata.
#
# Standard: MusicXML 4.0 (W3C MusicXML)
# Related: FR-COMPILER-008

# ============================================================
# Pitch
# ============================================================

enum PitchStep:
    C
    D
    E
    F
    G
    A
    B

struct Pitch:
    """A MusicXML pitch with step, optional alter (semitone adjustment), and octave."""
    step: PitchStep
    alter: f64?
    octave: i32

# ============================================================
# Duration and Note Type
# ============================================================

enum NoteTypeValue:
    N1024th
    N512th
    N256th
    N128th
    N64th
    N32nd
    N16th
    Eighth
    Quarter
    Half
    Whole
    Breve
    Long
    Maxima

struct Duration:
    """Rhythmic duration expressed as divisions of a quarter note."""
    divisions: i32
    dots: i32

# ============================================================
# Notations and Articulations
# ============================================================

enum Accidental:
    Sharp
    Natural
    Flat
    DoubleSharp
    DoubleFlat
    SharpSharp
    FlatFlat

enum Stem:
    Up
    Down
    Double
    None_

enum NoteHead:
    Normal
    X
    Circle
    Diamond
    Square
    Triangle
    Slash

struct Tie:
    is_start: bool

# ============================================================
# Note
# ============================================================

struct Note:
    """A single notated pitch or rest."""
    pitch: Pitch?
    is_rest: bool
    duration: Duration
    note_type: NoteTypeValue
    accidental: Accidental?
    stem: Stem?
    head: NoteHead?
    staff: i32
    voice: i32
    ties: [Tie]
    dynamics: f64?

# ============================================================
# Measure
# ============================================================

struct TimeSignature:
    beats: i32
    beat_type: i32

struct KeySignature:
    fifths: i32
    mode: text

struct Clef:
    sign: text
    line: i32

struct MeasureAttributes:
    divisions: i32?
    key: KeySignature?
    time_sig: TimeSignature?
    clef: Clef?

struct Measure:
    """A single measure (bar) in a part."""
    number: i32
    attributes: MeasureAttributes?
    notes: [Note]

# ============================================================
# Part and Score
# ============================================================

struct PartInfo:
    id: text
    name: text
    abbreviation: text?

struct Part:
    """A single instrument/voice part."""
    info: PartInfo
    measures: [Measure]

struct ScoreIdentification:
    title: text
    composer: text?
    lyricist: text?
    rights: text?

struct Score:
    """Top-level MusicXML score document."""
    identification: ScoreIdentification
    parts: [Part]
    version: text
