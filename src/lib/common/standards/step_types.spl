# STEP AP242 Types
#
# Core geometry and topology type definitions for STEP AP242
# (ISO 10303-242) CAD/CAM/CAE interchange.
#
# Standard: STEP AP242 (ISO 10303-242)
# Related: FR-COMPILER-010

# ============================================================
# Geometry Primitives
# ============================================================

struct Point3D:
    """Cartesian point in 3D space."""
    x: f64
    y: f64
    z: f64

struct Vector3D:
    """Direction vector with optional magnitude."""
    x: f64
    y: f64
    z: f64
    magnitude: f64?

struct Axis2Placement3D:
    """Coordinate system defined by location, axis, and reference direction."""
    location: Point3D
    axis: Vector3D?
    ref_direction: Vector3D?

struct BoundingBox:
    min_corner: Point3D
    max_corner: Point3D

# ============================================================
# Curves
# ============================================================

struct Line:
    point: Point3D
    direction: Vector3D

struct Circle:
    center: Axis2Placement3D
    radius: f64

struct Ellipse:
    center: Axis2Placement3D
    semi_axis_1: f64
    semi_axis_2: f64

struct BSplineCurve:
    degree: i32
    control_points: [Point3D]
    knots: [f64]
    multiplicities: [i32]
    is_closed: bool

# ============================================================
# Surfaces
# ============================================================

struct Plane:
    position: Axis2Placement3D

struct CylindricalSurface:
    position: Axis2Placement3D
    radius: f64

struct ConicalSurface:
    position: Axis2Placement3D
    radius: f64
    semi_angle: f64

struct SphericalSurface:
    position: Axis2Placement3D
    radius: f64

struct BSplineSurface:
    u_degree: i32
    v_degree: i32
    control_points: [[Point3D]]
    u_knots: [f64]
    v_knots: [f64]

# ============================================================
# Topology
# ============================================================

struct Vertex:
    """Topological vertex referencing a 3D point."""
    id: i32
    point: Point3D

struct EdgeCurve:
    """A bounded curve between two vertices."""
    id: i32
    start_vertex: Vertex
    end_vertex: Vertex
    same_sense: bool

struct FaceBound:
    """Boundary loop of a face."""
    edge_ids: [i32]
    orientation: bool

struct Face:
    """A bounded surface patch."""
    id: i32
    bounds: [FaceBound]

struct Shell:
    """A connected set of faces."""
    id: i32
    face_ids: [i32]
    is_closed: bool

struct Solid:
    """A closed shell representing a 3D solid."""
    id: i32
    shell: Shell

# ============================================================
# Assembly and Product
# ============================================================

struct ProductDefinition:
    """A defined product or part."""
    id: text
    name: text
    description: text?

struct ProductDefinitionShape:
    product_id: text
    name: text?
    description: text?

struct NextAssemblyUsageOccurrence:
    """Assembly relationship between parent and component."""
    id: text
    name: text
    relating_product_id: text
    related_product_id: text
    reference_designator: text?

# ============================================================
# Tolerances / PMI
# ============================================================

struct DimensionalConstraint:
    """A dimensional tolerance or annotation."""
    id: text
    nominal_value: f64
    lower_limit: f64?
    upper_limit: f64?
    unit: text
