@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Text Advanced — Character Helpers
#
# Shared private helpers for character classification and word splitting.
# Used by text_advanced_case.spl, text_advanced_lines.spl, and text_advanced_search.spl.
#
# NOTE: Do NOT import from lib.common.text here — that creates a circular
# dependency. Import from string_core instead.
use std.string_core.{char_code, is_whitespace_char}

# Inlined character helpers (originally from text.spl) to break circular dep
fn _is_alpha(ch: text) -> bool:
    val code = char_code(ch)
    (code >= 65 and code <= 90) or (code >= 97 and code <= 122)

fn _is_alphanumeric(ch: text) -> bool:
    _is_alpha(ch) or (ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9")

fn _is_uppercase_char(ch: text) -> bool:
    if ch.len() != 1: return false
    val code = ch[0]
    code >= 'A' and code <= 'Z'

fn _is_lowercase_char(ch: text) -> bool:
    if ch.len() != 1: return false
    val code = ch[0]
    code >= 'a' and code <= 'z'

# ============================================================================
# Word Splitting (shared helper for case conversions)
# ============================================================================

fn _split_words(s: text) -> [text]:
    """Split text into words at separators and camelCase boundaries.

    Handles underscores, hyphens, spaces, camelCase, PascalCase, SCREAMING_SNAKE,
    and acronym boundaries (e.g. XMLParser -> [XML, Parser]).
    """
    if s.len() == 0:
        return []

    var words: [text] = []
    var current: [text] = []
    var i = 0

    while i < s.len():
        val ch = s[i]

        if ch == "_" or ch == "-" or is_whitespace_char(ch):
            if current.len() > 0:
                words.push(current.join(""))
                current = []
        elif _is_uppercase_char(ch) and current.len() > 0:
            val prev = current[current.len() - 1]
            if _is_lowercase_char(prev):
                # camelCase boundary: lowercase -> Uppercase
                words.push(current.join(""))
                current = []
            elif (_is_uppercase_char(prev) and i + 1 < s.len() and _is_lowercase_char(s[i + 1])):
                # Acronym boundary: XMLParser -> XML | Parser
                words.push(current.join(""))
                current = []
            current.push(ch)
        else:
            current.push(ch)

        i = i + 1

    if current.len() > 0:
        words.push(current.join(""))

    words
