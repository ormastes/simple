# Engine Rect2 — Axis-aligned 2D rectangle
#
# Defined by position (x, y) of top-left corner and size (width, height).
#
# Usage:
#   val r = Rect2.new(10.0, 20.0, 100.0, 50.0)
#   r.contains_point(15.0, 25.0)  # true
#   val merged = r.merge(other)

use std.common.math.{math_min, math_max}
use std.common.engine.math2d.{Vec2}

# ============================================================================
# Rect2
# ============================================================================

class Rect2:
    x: f64
    y: f64
    width: f64
    height: f64

    # --- Static constructors ---

    static fn new(x: f64, y: f64, width: f64, height: f64) -> Rect2:
        Rect2(x: x, y: y, width: width, height: height)

    static fn from_center(cx: f64, cy: f64, width: f64, height: f64) -> Rect2:
        """Create a rect centered at (cx, cy)."""
        val half_w = width / 2.0
        val half_h = height / 2.0
        Rect2(x: cx - half_w, y: cy - half_h, width: width, height: height)

    # --- Edge accessors ---

    fn left() -> f64:
        self.x

    fn right() -> f64:
        self.x + self.width

    fn top() -> f64:
        self.y

    fn bottom() -> f64:
        self.y + self.height

    # --- Derived properties ---

    fn center() -> Vec2:
        val cx = self.x + self.width / 2.0
        val cy = self.y + self.height / 2.0
        Vec2(x: cx, y: cy)

    fn size() -> Vec2:
        Vec2(x: self.width, y: self.height)

    # --- Queries ---

    fn contains_point(px: f64, py: f64) -> bool:
        val in_x = px >= self.x and px <= self.right()
        val in_y = py >= self.y and py <= self.bottom()
        in_x and in_y

    fn intersects(other: Rect2) -> bool:
        val no_overlap_x = self.right() <= other.left() or other.right() <= self.left()
        val no_overlap_y = self.bottom() <= other.top() or other.bottom() <= self.top()
        val no_overlap = no_overlap_x or no_overlap_y
        not no_overlap

    fn intersection(other: Rect2) -> Option<Rect2>:
        """Return the overlapping rectangle, or nil if no overlap."""
        val ix = math_max(self.x, other.x)
        val iy = math_max(self.y, other.y)
        val ir = math_min(self.right(), other.right())
        val ib = math_min(self.bottom(), other.bottom())
        val iw = ir - ix
        val ih = ib - iy
        if iw <= 0.0 or ih <= 0.0:
            return nil
        Rect2(x: ix, y: iy, width: iw, height: ih)

    fn merge(other: Rect2) -> Rect2:
        """Return the bounding rect that contains both rects."""
        val min_x = math_min(self.x, other.x)
        val min_y = math_min(self.y, other.y)
        val max_r = math_max(self.right(), other.right())
        val max_b = math_max(self.bottom(), other.bottom())
        Rect2(x: min_x, y: min_y, width: max_r - min_x, height: max_b - min_y)

    fn expand(margin: f64) -> Rect2:
        """Expand rect outward by margin on all sides."""
        val double_m = margin * 2.0
        Rect2(
            x: self.x - margin,
            y: self.y - margin,
            width: self.width + double_m,
            height: self.height + double_m
        )

    fn eq(other: Rect2) -> bool:
        val eps = 0.0000000001
        val x_ok = _rect_abs(self.x - other.x) < eps
        val y_ok = _rect_abs(self.y - other.y) < eps
        val w_ok = _rect_abs(self.width - other.width) < eps
        val h_ok = _rect_abs(self.height - other.height) < eps
        val xy = x_ok and y_ok
        val wh = w_ok and h_ok
        xy and wh

# ============================================================================
# Internal helper
# ============================================================================

fn _rect_abs(x: f64) -> f64:
    if x < 0.0:
        return -x
    x
