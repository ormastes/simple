# Engine Rectangle Type
#
# Rect2: axis-aligned 2D rectangle defined by origin (x, y) plus dimensions (width, height).

pub class Rect2:
    """Axis-aligned 2D rectangle."""
    x: f64
    y: f64
    width: f64
    height: f64

    static fn zero() -> Rect2:
        Rect2(x: 0.0, y: 0.0, width: 0.0, height: 0.0)

impl Rect2:
    fn right() -> f64:
        self.x + self.width

    fn bottom() -> f64:
        self.y + self.height

    fn contains_point(px: f64, py: f64) -> bool:
        px >= self.x and px < self.right() and py >= self.y and py < self.bottom()

    fn intersects(other: Rect2) -> bool:
        not (other.x >= self.right() or
             other.right() <= self.x or
             other.y >= self.bottom() or
             other.bottom() <= self.y)

    fn is_empty() -> bool:
        self.width <= 0.0 or self.height <= 0.0

    fn to_string() -> text:
        "Rect2({self.x}, {self.y}, {self.width}x{self.height})"
