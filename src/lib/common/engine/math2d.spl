# Engine 2D Math — Vec2, Transform2D
#
# Core 2D math types for the game engine.
# All angles in radians. Column-major where applicable.
#
# Usage:
#   val pos = Vec2(x: 3.0, y: 4.0)
#   val len = pos.length()           # 5.0
#   val norm = pos.normalize()
#   val t = Transform2D.identity()
#   val world_pos = t.transform_point(pos)

use std.common.math.{MATH_PI, math_abs, math_lerp, math_clamp}
use std.common.engine.units.{Angle}

# ============================================================================
# Pure math helpers (no SFFI — suitable for common/ module)
# ============================================================================

val _EPSILON = 0.0000000001

fn _sqrt(x: f64) -> f64:
    """Newton's method square root."""
    if x < 0.0:
        return 0.0
    if x < _EPSILON:
        return 0.0
    var guess = x
    if x > 1.0:
        guess = x / 2.0
    # 20 iterations for good convergence
    var i = 0
    while i < 20:
        guess = (guess + x / guess) / 2.0
        i = i + 1
    guess

fn _sin(x: f64) -> f64:
    """Taylor series sine approximation. Normalize to [-PI, PI]."""
    var a = x
    # Reduce to [-PI, PI]
    val two_pi = MATH_PI * 2.0
    while a > MATH_PI:
        a = a - two_pi
    while a < -MATH_PI:
        a = a + two_pi
    # Taylor series: x - x^3/6 + x^5/120 - x^7/5040 + x^9/362880 - x^11/39916800
    val x2 = a * a
    val x3 = a * x2
    val x5 = x3 * x2
    val x7 = x5 * x2
    val x9 = x7 * x2
    val x11 = x9 * x2
    val x13 = x11 * x2
    a - x3 / 6.0 + x5 / 120.0 - x7 / 5040.0 + x9 / 362880.0 - x11 / 39916800.0 + x13 / 6227020800.0

fn _cos(x: f64) -> f64:
    """Cosine via sine shift."""
    _sin(x + MATH_PI / 2.0)

fn _atan2(y: f64, x: f64) -> f64:
    """Approximation of atan2(y, x)."""
    if math_abs(x) < _EPSILON:
        if y > 0.0:
            return MATH_PI / 2.0
        if y < 0.0:
            return -MATH_PI / 2.0
        return 0.0
    val ratio = y / x
    # Polynomial approximation for atan in [-1, 1]
    val abs_ratio = math_abs(ratio)
    var atan_val = 0.0
    if abs_ratio <= 1.0:
        # atan(r) ~ r - r^3/3 + r^5/5 - r^7/7 + r^9/9
        val r2 = ratio * ratio
        val r3 = ratio * r2
        val r5 = r3 * r2
        val r7 = r5 * r2
        val r9 = r7 * r2
        atan_val = ratio - r3 / 3.0 + r5 / 5.0 - r7 / 7.0 + r9 / 9.0
    else:
        # For |ratio| > 1: atan(r) = sign(r)*PI/2 - atan(1/r)
        val inv = 1.0 / ratio
        val inv2 = inv * inv
        val inv3 = inv * inv2
        val inv5 = inv3 * inv2
        val inv7 = inv5 * inv2
        val inv9 = inv7 * inv2
        val atan_inv = inv - inv3 / 3.0 + inv5 / 5.0 - inv7 / 7.0 + inv9 / 9.0
        if ratio > 0.0:
            atan_val = MATH_PI / 2.0 - atan_inv
        else:
            atan_val = -MATH_PI / 2.0 - atan_inv
    # Adjust quadrant
    if x < 0.0:
        if y >= 0.0:
            return atan_val + MATH_PI
        else:
            return atan_val - MATH_PI
    atan_val

# ============================================================================
# Vec2
# ============================================================================

class Vec2:
    x: f64
    y: f64

    # --- Static constructors ---

    static fn zero() -> Vec2:
        Vec2(x: 0.0, y: 0.0)

    static fn one() -> Vec2:
        Vec2(x: 1.0, y: 1.0)

    static fn up() -> Vec2:
        Vec2(x: 0.0, y: 1.0)

    static fn right() -> Vec2:
        Vec2(x: 1.0, y: 0.0)

    # --- Arithmetic ---

    fn add(other: Vec2) -> Vec2:
        Vec2(x: self.x + other.x, y: self.y + other.y)

    fn sub(other: Vec2) -> Vec2:
        Vec2(x: self.x - other.x, y: self.y - other.y)

    fn mul_scalar(s: f64) -> Vec2:
        Vec2(x: self.x * s, y: self.y * s)

    fn div_scalar(s: f64) -> Vec2:
        Vec2(x: self.x / s, y: self.y / s)

    # --- Products ---

    fn dot(other: Vec2) -> f64:
        self.x * other.x + self.y * other.y

    fn cross(other: Vec2) -> f64:
        """2D cross product — returns scalar (z-component of 3D cross)."""
        self.x * other.y - self.y * other.x

    # --- Length ---

    fn length_squared() -> f64:
        self.x * self.x + self.y * self.y

    fn length() -> f64:
        _sqrt(self.length_squared())

    fn normalize() -> Vec2:
        val len = self.length()
        if len < _EPSILON:
            return Vec2.zero()
        Vec2(x: self.x / len, y: self.y / len)

    fn distance_to(other: Vec2) -> f64:
        val diff = self.sub(other)
        diff.length()

    # --- Interpolation ---

    fn lerp(other: Vec2, t: f64) -> Vec2:
        val lx = math_lerp(self.x, other.x, t)
        val ly = math_lerp(self.y, other.y, t)
        Vec2(x: lx, y: ly)

    # --- Rotation ---

    fn rotate(angle: Angle) -> Vec2:
        """Rotate this vector by angle around origin."""
        val cos_a = _cos(angle.radians)
        val sin_a = _sin(angle.radians)
        val rx = self.x * cos_a - self.y * sin_a
        val ry = self.x * sin_a + self.y * cos_a
        Vec2(x: rx, y: ry)

    # --- Comparison ---

    fn eq(other: Vec2) -> bool:
        val dx = math_abs(self.x - other.x)
        val dy = math_abs(self.y - other.y)
        val x_eq = dx < _EPSILON
        val y_eq = dy < _EPSILON
        x_eq and y_eq

# ============================================================================
# Transform2D
# ============================================================================

class Transform2D:
    position: Vec2
    rotation: Angle
    scale: Vec2

    static fn identity() -> Transform2D:
        Transform2D(
            position: Vec2.zero(),
            rotation: Angle(radians: 0.0),
            scale: Vec2.one()
        )

    fn transform_point(point: Vec2) -> Vec2:
        """Apply scale, rotation, then translation to a point."""
        # 1. Scale
        val scaled = Vec2(x: point.x * self.scale.x, y: point.y * self.scale.y)
        # 2. Rotate
        val rotated = scaled.rotate(self.rotation)
        # 3. Translate
        rotated.add(self.position)

    fn inverse() -> Transform2D:
        """Compute the inverse transform."""
        val inv_scale_x = 1.0 / self.scale.x
        val inv_scale_y = 1.0 / self.scale.y
        val inv_scale = Vec2(x: inv_scale_x, y: inv_scale_y)
        val inv_rotation = Angle(radians: -self.rotation.radians)
        # Inverse position: un-rotate and un-scale the negated position
        val neg_pos = self.position.mul_scalar(-1.0)
        val unrotated = neg_pos.rotate(inv_rotation)
        val inv_pos = Vec2(x: unrotated.x * inv_scale_x, y: unrotated.y * inv_scale_y)
        Transform2D(
            position: inv_pos,
            rotation: inv_rotation,
            scale: inv_scale
        )

    fn compose(child: Transform2D) -> Transform2D:
        """Compose parent (self) with child: parent * child.

        Result transforms a point as: parent(child(point)).
        """
        # Combined scale
        val new_sx = self.scale.x * child.scale.x
        val new_sy = self.scale.y * child.scale.y
        val new_scale = Vec2(x: new_sx, y: new_sy)
        # Combined rotation
        val new_rotation = Angle(radians: self.rotation.radians + child.rotation.radians)
        # Combined position: transform child's position through parent
        val child_pos = self.transform_point(child.position)
        Transform2D(
            position: child_pos,
            rotation: new_rotation,
            scale: new_scale
        )

    fn forward() -> Vec2:
        """Direction vector from rotation (unit vector pointing in rotation direction)."""
        Vec2(x: _cos(self.rotation.radians), y: _sin(self.rotation.radians))

    fn right() -> Vec2:
        """Right-perpendicular direction vector."""
        Vec2(x: _cos(self.rotation.radians - MATH_PI / 2.0), y: _sin(self.rotation.radians - MATH_PI / 2.0))
