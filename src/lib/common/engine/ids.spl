#![allow(primitive_api)]
# Engine ID System — Generational Index Handles
#
# Type-safe IDs that prevent dangling references.
# Each handle type is distinct — cannot mix NodeId with TextureId.
#
# Usage:
#   val node = NodeId.invalid()
#   val tex = TextureId(raw: RawHandle.new(0, 1))
#   node.is_valid()  # false
#   tex.is_valid()   # true

# ============================================================================
# Generation
# ============================================================================

class Generation:
    value: i64

    fn eq(other: Generation) -> bool:
        self.value == other.value

# ============================================================================
# RawHandle — core generational index
# ============================================================================

class RawHandle:
    index: i64
    generation: Generation

    fn is_valid() -> bool:
        if self.index < 0:
            return false
        if self.generation == nil:
            return false
        self.generation.value > 0

    static fn invalid() -> RawHandle:
        RawHandle(index: -1, generation: Generation(value: -1))

    static fn new(index: i64, generation: i64) -> RawHandle:
        RawHandle(index: index, generation: Generation(value: generation))

    fn to_index() -> i64:
        self.index

    fn eq(other: RawHandle) -> bool:
        val idx_eq = self.index == other.index
        val gen_eq = self.generation.eq(other.generation)
        idx_eq and gen_eq

# ============================================================================
# NodeId
# ============================================================================

class NodeId:
    raw: RawHandle

    fn is_valid() -> bool:
        self.raw.is_valid()

    static fn invalid() -> NodeId:
        NodeId(raw: RawHandle.invalid())

    fn to_index() -> i64:
        self.raw.to_index()

    fn eq(other: NodeId) -> bool:
        self.raw.eq(other.raw)

