# Engine Foundation — IDs, Math, Color, Rect
#
# Core types for the Simple 2D game engine.
# All types are pure (no I/O, no SFFI) — suitable for common/ module.

# Re-exported from ids.spl
export Generation, RawHandle
export NodeId, ComponentId, TextureId, SpriteId, AudioClipId, SceneId

# Re-exported from math2d.spl
export Vec2, Transform2D

# Re-exported from math3d.spl
export Vec3, Vec4, Mat4, Quaternion, Transform3D

# Re-exported from color.spl
export EngineColor

# Re-exported from units.spl
export Seconds, Angle, Volume, ZIndex
export KeyCode, MouseButtonId, GamepadButtonId
export Distance, ZoomLevel
export TileCoord, PixelSize, TileIndex, FrameIndex
export Speed, Tolerance, RGBA8

# Re-exported from rect.spl
export Rect2
