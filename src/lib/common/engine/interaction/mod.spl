# mod.spl — Unified 2D interaction core (Phase 1 of
# doc/03_plan/ui/unified_2d_engine/unified_2d_interaction_2026-07-20.md):
# ordered hit stack, capture/target/bubble event routing, pointer capture,
# and PointerPolicy, shared by GUI widgets, the browser DOM and
# Engine2D/game nodes so paint order == hit order and every surface
# dispatches through one contract. Widget/browser/WM adapters are a LATER
# lane (slice item 6) -- this package ships only the surface-agnostic
# primitives.
#
# Usage:
#   use std.common.engine.interaction.{PointerEvent2D, HitProxy2D,
#     hit_stack, EventListener2D, dispatch, PointerRouter, hover_diff}
# or per-file, e.g.:
#   use std.common.engine.interaction.hit_test.{hit_stack, HitTestResult}

export use pointer_event.*
export use hit_proxy.*
export use hit_test.*
export use event_route.*
export use pointer_capture.*
