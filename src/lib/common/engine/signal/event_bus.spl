# Signal/Event System - Event Bus
#
# Global event bus for cross-system communication in the 2D game engine.
# Provides a centralized registry of named signals that different systems
# can publish to and subscribe from without direct coupling.
#
# Example:
#     var bus = EventBus.create()
#     bus.register("player_hit")
#     val conn = bus.connect("player_hit", \data: print "Hit! {data}")
#     bus.emit("player_hit", "damage=25")

use std.common.engine.signal.signal.*
use std.common.engine.signal.types.*

# ============================================================================
# Event Bus Class
# ============================================================================

class EventBus:
    signals: Dict<text, Signal>

impl EventBus:
    static fn create() -> EventBus:
        EventBus(signals: {})

    # ------------------------------------------------------------------
    # Register a named signal. No-op if the signal already exists.
    # ------------------------------------------------------------------
    me register(signal_name: text):
        if not self.signals.has(signal_name):
            self.signals[signal_name] = Signal.create(signal_name)

    # ------------------------------------------------------------------
    # Connect a callback to a named signal. Auto-registers the signal
    # if it does not already exist.
    # ------------------------------------------------------------------
    me connect(signal_name: text, callback: fn(text)) -> SignalConnectionId:
        if not self.signals.has(signal_name):
            self.signals[signal_name] = Signal.create(signal_name)
        var sig = self.signals[signal_name]
        val conn_id = sig.connect(callback)
        self.signals[signal_name] = sig
        conn_id

    # ------------------------------------------------------------------
    # Emit data on a named signal. No-op if the signal is not registered.
    # ------------------------------------------------------------------
    me emit(signal_name: text, data: text):
        if self.signals.has(signal_name):
            var sig = self.signals[signal_name]
            sig.emit(data)
            self.signals[signal_name] = sig

    # ------------------------------------------------------------------
    # Disconnect a specific callback from a named signal.
    # Returns false if the signal does not exist or the ID was not found.
    # ------------------------------------------------------------------
    me disconnect(signal_name: text, conn_id: SignalConnectionId) -> bool:
        if not self.signals.has(signal_name):
            return false
        var sig = self.signals[signal_name]
        val result = sig.disconnect(conn_id)
        self.signals[signal_name] = sig
        result

    # ------------------------------------------------------------------
    # Disconnect all callbacks from a named signal.
    # ------------------------------------------------------------------
    me disconnect_all(signal_name: text):
        if self.signals.has(signal_name):
            var sig = self.signals[signal_name]
            sig.disconnect_all()
            self.signals[signal_name] = sig

    # ------------------------------------------------------------------
    # Check if a named signal is registered.
    # ------------------------------------------------------------------
    fn has_signal(signal_name: text) -> bool:
        self.signals.has(signal_name)

    # ------------------------------------------------------------------
    # Return the number of connections on a named signal.
    # Returns 0 if the signal does not exist.
    # ------------------------------------------------------------------
    fn connection_count(signal_name: text) -> i64:
        if self.signals.has(signal_name):
            val sig = self.signals[signal_name]
            return sig.connection_count()
        0
