# Engine Color Type
#
# EngineColor: RGBA color with f64 components in [0.0, 1.0].
# Rgba8: packed byte representation for GPU/rasterizer output (r,g,b,a: i64 in [0,255]).

pub class Rgba8:
    """Packed byte RGBA (each channel 0–255)."""
    r: i64
    g: i64
    b: i64
    a: i64

pub class EngineColor:
    """RGBA float color with components in [0.0, 1.0]."""
    r: f64
    g: f64
    b: f64
    a: f64

    static fn white() -> EngineColor:
        EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0)

    static fn black() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 1.0)

    static fn red() -> EngineColor:
        EngineColor(r: 1.0, g: 0.0, b: 0.0, a: 1.0)

    static fn green() -> EngineColor:
        EngineColor(r: 0.0, g: 1.0, b: 0.0, a: 1.0)

    static fn blue() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 1.0, a: 1.0)

    static fn transparent() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 0.0)

impl EngineColor:
    fn to_rgba8() -> Rgba8:
        """Convert float [0.0,1.0] channels to byte [0,255] channels."""
        fn clamp_f(v: f64) -> i64:
            val i = (v * 255.0).to_i64()
            if i < 0:
                return 0
            if i > 255:
                return 255
            i
        Rgba8(r: clamp_f(self.r), g: clamp_f(self.g), b: clamp_f(self.b), a: clamp_f(self.a))

    fn with_alpha(a: f64) -> EngineColor:
        EngineColor(r: self.r, g: self.g, b: self.b, a: a)

    fn to_string() -> text:
        "EngineColor({self.r}, {self.g}, {self.b}, {self.a})"
