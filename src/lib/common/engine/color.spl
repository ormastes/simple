#![allow(primitive_api)]
# Engine Color — RGBA color with f64 components (0.0 - 1.0)
#
# Normalized floating-point color for rendering.
# Components are in [0.0, 1.0] range.
#
# Usage:
#   val c = Color.rgb(1.0, 0.0, 0.0)          # red
#   val hex_c = Color.from_hex(0xFF8800)       # orange
#   val faded = c.with_alpha(0.5)
#   val blend = c.lerp(Color.blue(), 0.5)

use std.common.math.{math_lerp, math_clamp}
use std.common.engine.units.{RGBA8}

# ============================================================================
# Color
# ============================================================================

class EngineColor:
    r: f64
    g: f64
    b: f64
    a: f64

    # --- Static constructors ---

    static fn rgba(r: f64, g: f64, b: f64, a: f64) -> EngineColor:
        EngineColor(r: r, g: g, b: b, a: a)

    static fn rgb(r: f64, g: f64, b: f64) -> EngineColor:
        EngineColor(r: r, g: g, b: b, a: 1.0)

    static fn from_hex(hex: i64) -> EngineColor:
        """Create from 0xRRGGBB integer."""
        val r_int = (hex / 65536) % 256
        val g_int = (hex / 256) % 256
        val b_int = hex % 256
        val r_f = r_int / 255.0
        val g_f = g_int / 255.0
        val b_f = b_int / 255.0
        EngineColor(r: r_f, g: g_f, b: b_f, a: 1.0)

    static fn from_hex_alpha(hex: i64) -> EngineColor:
        """Create from 0xRRGGBBAA integer."""
        val r_int = (hex / 16777216) % 256
        val g_int = (hex / 65536) % 256
        val b_int = (hex / 256) % 256
        val a_int = hex % 256
        val r_f = r_int / 255.0
        val g_f = g_int / 255.0
        val b_f = b_int / 255.0
        val a_f = a_int / 255.0
        EngineColor(r: r_f, g: g_f, b: b_f, a: a_f)

    # --- Presets ---

    static fn white() -> EngineColor:
        EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0)

    static fn black() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 1.0)

    static fn red() -> EngineColor:
        EngineColor(r: 1.0, g: 0.0, b: 0.0, a: 1.0)

    static fn green() -> EngineColor:
        EngineColor(r: 0.0, g: 1.0, b: 0.0, a: 1.0)

    static fn blue() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 1.0, a: 1.0)

    static fn yellow() -> EngineColor:
        EngineColor(r: 1.0, g: 1.0, b: 0.0, a: 1.0)

    static fn cyan() -> EngineColor:
        EngineColor(r: 0.0, g: 1.0, b: 1.0, a: 1.0)

    static fn magenta() -> EngineColor:
        EngineColor(r: 1.0, g: 0.0, b: 1.0, a: 1.0)

    static fn transparent() -> EngineColor:
        EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 0.0)

    # --- Operations ---

    fn lerp(other: EngineColor, t: f64) -> EngineColor:
        """Linearly interpolate between this color and other."""
        val lr = math_lerp(self.r, other.r, t)
        val lg = math_lerp(self.g, other.g, t)
        val lb = math_lerp(self.b, other.b, t)
        val la = math_lerp(self.a, other.a, t)
        EngineColor(r: lr, g: lg, b: lb, a: la)

    fn with_alpha(a: f64) -> EngineColor:
        """Return a copy with the given alpha value."""
        EngineColor(r: self.r, g: self.g, b: self.b, a: a)

    fn to_rgba8() -> RGBA8:
        """Convert to 0-255 integer RGBA."""
        val ri = _to_byte(self.r)
        val gi = _to_byte(self.g)
        val bi = _to_byte(self.b)
        val ai = _to_byte(self.a)
        RGBA8(r: ri, g: gi, b: bi, a: ai)

    fn eq(other: EngineColor) -> bool:
        val eps = 0.001
        val r_ok = _abs(self.r - other.r) < eps
        val g_ok = _abs(self.g - other.g) < eps
        val b_ok = _abs(self.b - other.b) < eps
        val a_ok = _abs(self.a - other.a) < eps
        val rg = r_ok and g_ok
        val ba = b_ok and a_ok
        rg and ba

# ============================================================================
# Internal helpers
# ============================================================================

fn _abs(x: f64) -> f64:
    if x < 0.0:
        return -x
    x

fn _to_byte(x: f64) -> i64:
    """Clamp f64 [0.0, 1.0] to i64 [0, 255]."""
    val clamped = math_clamp(x, 0.0, 1.0)
    val scaled = clamped * 255.0 + 0.5
    # Truncate to integer
    var result = 0
    if scaled >= 255.0:
        result = 255
    else:
        # Simple truncation — f64 to i64
        result = scaled
    result
