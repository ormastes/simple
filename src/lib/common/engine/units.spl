#![allow(primitive_api)]
# Engine Units — Domain-specific custom types
#
# Strongly-typed wrappers for primitive values used throughout the engine.
# Prevents accidental mixing of angles with distances, seconds with speeds, etc.
#
# Usage:
#   val t = Seconds(value: 1.5)
#   val a = Angle(radians: 3.14159)
#   val deg = a.to_degrees()       # ~180.0
#   val vol = Volume(value: 0.8)

# ============================================================================
# Time
# ============================================================================

class Seconds:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Seconds) -> Seconds: Seconds(value: self.value + other.value)
    fn sub(other: Seconds) -> Seconds: Seconds(value: self.value - other.value)

# ============================================================================
# Angle (always radians internally)
# ============================================================================

class Angle:
    radians: f64

    fn to_radians() -> f64: self.radians
    fn to_degrees() -> f64: self.radians * 57.2957795131
    fn add(other: Angle) -> Angle: Angle(radians: self.radians + other.radians)

    static fn zero() -> Angle: Angle(radians: 0.0)

# ============================================================================
# Volume (0.0 to 1.0)
# ============================================================================

class Volume:
    value: f64

    fn to_f64() -> f64: self.value

    static fn full() -> Volume: Volume(value: 1.0)
    static fn mute_vol() -> Volume: Volume(value: 0.0)

# ============================================================================
# Z-Index
# ============================================================================

class ZIndex:
    value: i64

    fn to_i64() -> i64: self.value

    static fn zero() -> ZIndex: ZIndex(value: 0)

# ============================================================================
# Input
# ============================================================================

class KeyCode:
    code: i64

    fn to_i64() -> i64: self.code
    fn eq(other: KeyCode) -> bool: self.code == other.code

class MouseButtonId:
    code: i64

    fn to_i64() -> i64: self.code

class GamepadButtonId:
    code: i64

# ============================================================================
# Spatial
# ============================================================================

class Distance:
    value: f64

    fn to_f64() -> f64: self.value

class ZoomLevel:
    value: f64

    fn to_f64() -> f64: self.value

    static fn default_zoom() -> ZoomLevel: ZoomLevel(value: 1.0)

# ============================================================================
# Grid
# ============================================================================

class TileCoord:
    col: i64
    row: i64

class PixelSize:
    width: i64
    height: i64

class TileIndex:
    value: i64

    fn to_i64() -> i64: self.value

    static fn empty() -> TileIndex: TileIndex(value: -1)

class FrameIndex:
    value: i64

    fn to_i64() -> i64: self.value

# ============================================================================
# Physics / Motion
# ============================================================================

class Speed:
    value: f64

    fn to_f64() -> f64: self.value

class Tolerance:
    value: f64

    fn to_f64() -> f64: self.value

# ============================================================================
# Color (8-bit RGBA)
# ============================================================================

class RGBA8:
    r: i64
    g: i64
    b: i64
    a: i64
