# Engine Unit Types
#
# Typed wrappers around numeric values to prevent unit mix-ups.
# Pattern: each unit class has a single `value` or domain-specific field.

pub class Angle:
    """Angle in radians."""
    radians: f64

    static fn zero() -> Angle:
        Angle(radians: 0.0)

    static fn from_degrees(deg: f64) -> Angle:
        Angle(radians: deg * 3.141592653589793 / 180.0)

    fn to_degrees() -> f64:
        self.radians * 180.0 / 3.141592653589793

pub class Seconds:
    """Duration in seconds."""
    value: f64

    static fn zero() -> Seconds:
        Seconds(value: 0.0)

pub class Distance:
    """Scalar distance (world units)."""
    value: f64

    static fn zero() -> Distance:
        Distance(value: 0.0)

pub class Speed:
    """Speed in world units per second."""
    value: f64

    static fn zero() -> Speed:
        Speed(value: 0.0)

pub class ZIndex:
    """Draw order z-index (higher = drawn on top)."""
    value: i64

    static fn zero() -> ZIndex:
        ZIndex(value: 0)

pub class ZoomLevel:
    """Camera zoom multiplier (1.0 = no zoom)."""
    value: f64

    static fn default_zoom() -> ZoomLevel:
        ZoomLevel(value: 1.0)

pub class Volume:
    """Audio volume in [0.0, 1.0]."""
    value: f64

    static fn full() -> Volume:
        Volume(value: 1.0)

    static fn silent() -> Volume:
        Volume(value: 0.0)

pub class Tolerance:
    """Geometric tolerance for path/curve operations."""
    value: f64

    static fn default_tolerance() -> Tolerance:
        Tolerance(value: 0.25)

pub class KeyCode:
    """Platform-independent keyboard key code (integer scancode)."""
    code: i64

    static fn unknown() -> KeyCode:
        KeyCode(code: 0)

pub class MouseButtonId:
    """Mouse button identifier (0=left, 1=right, 2=middle)."""
    code: i64

    static fn left() -> MouseButtonId:
        MouseButtonId(code: 0)

    static fn right() -> MouseButtonId:
        MouseButtonId(code: 1)

    static fn middle() -> MouseButtonId:
        MouseButtonId(code: 2)
