# ZIP Archive — pure-Simple reader and (stored) writer
#
# Reader: parses the End-of-Central-Directory + central directory, extracts
# entries compressed as stored (method 0) or deflate (method 8, via the
# existing pure inflater). Enough to open .odt/.ods/.docx/.xlsx containers.
#
# Writer: `zip_write` compresses each entry with DEFLATE (method 8) when the
# compressed payload is smaller than the original, otherwise falls back to
# stored (method 0) — matching how Office/LibreOffice size their zip parts.
# `zip_write_stored` remains available for callers that want stored-only
# output; both produce valid zips that LibreOffice/Word open.
#
# ponytail: no zip64, no encryption, no data-descriptor streaming entries;
# these formats don't need them for office documents.

use std.common.image.deflate_inflate.{deflate_inflate}
use std.common.compress.deflate.{deflate_compress}
use std.common.string_core.{char_from_code}

struct ZipEntry:
    name: text
    method: i32
    comp_size: i32
    uncomp_size: i32
    local_offset: i32

struct ZipFile:
    name: text
    data: [u8]

# =========================================================================
# Little-endian readers
# =========================================================================

fn _u16(b: [u8], i: i32) -> i32:
    (b[i].to_i64() | (b[i + 1].to_i64() << 8)).to_i32()

fn _u32(b: [u8], i: i32) -> i64:
    b[i].to_i64() | (b[i + 1].to_i64() << 8) | (b[i + 2].to_i64() << 16) | (b[i + 3].to_i64() << 24)

fn _bytes_to_ascii(b: [u8], start: i32, len: i32) -> text:
    var out = ""
    var i = start
    while i < start + len:
        out = "{out}{char_from_code(b[i].to_i64())}"
        i = i + 1
    out

fn _ascii_to_bytes(s: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < s.len():
        val c = s.char_at(i)
        out.push(c.char_code_at(0).to_u8())
        i = i + 1
    out

# =========================================================================
# Reader
# =========================================================================

fn _find_eocd(b: [u8]) -> i32:
    """Scan backwards for the EOCD signature PK\\x05\\x06. -1 if absent."""
    var i = b.len() - 22
    while i >= 0:
        if b[i].to_i64() == 0x50 and b[i + 1].to_i64() == 0x4b and b[i + 2].to_i64() == 0x05 and b[i + 3].to_i64() == 0x06:
            return i
        i = i - 1
    -1

fn zip_entries(b: [u8]) -> [ZipEntry]:
    """Parse the central directory into entries. Empty on malformed input."""
    var entries: [ZipEntry] = []
    val eocd = _find_eocd(b)
    if eocd < 0:
        return entries
    val count = _u16(b, eocd + 10)
    var pos = _u32(b, eocd + 16).to_i32()
    var n = 0
    while n < count:
        if pos + 46 > b.len() or _u32(b, pos) != 0x02014b50:
            return entries
        val method = _u16(b, pos + 10)
        val comp_size = _u32(b, pos + 20).to_i32()
        val uncomp_size = _u32(b, pos + 24).to_i32()
        val name_len = _u16(b, pos + 28)
        val extra_len = _u16(b, pos + 30)
        val comment_len = _u16(b, pos + 32)
        val local_offset = _u32(b, pos + 42).to_i32()
        val name = _bytes_to_ascii(b, pos + 46, name_len)
        entries.push(ZipEntry(name: name, method: method, comp_size: comp_size, uncomp_size: uncomp_size, local_offset: local_offset))
        pos = pos + 46 + name_len + extra_len + comment_len
        n = n + 1
    entries

fn zip_extract(b: [u8], name: text) -> [u8]?:
    """Extract one entry's bytes by name (stored or deflate), or nil."""
    for entry in zip_entries(b):
        if entry.name == name:
            val lh = entry.local_offset
            if lh + 30 > b.len() or _u32(b, lh) != 0x04034b50:
                return nil
            val name_len = _u16(b, lh + 26)
            val extra_len = _u16(b, lh + 28)
            val data_start = lh + 30 + name_len + extra_len
            if data_start + entry.comp_size > b.len():
                return nil
            var comp: [u8] = []
            var i = data_start
            while i < data_start + entry.comp_size:
                comp.push(b[i])
                i = i + 1
            if entry.method == 0:
                return Some(comp)
            if entry.method == 8:
                return Some(deflate_inflate(comp, 0))
            return nil
    nil

fn zip_extract_text(b: [u8], name: text) -> text:
    """Extract an entry as text (ASCII/UTF-8 bytes passed through). "" if absent."""
    val data = zip_extract(b, name)
    if data == nil:
        return ""
    _bytes_to_ascii(data, 0, data.len())

# =========================================================================
# Writer
# =========================================================================

fn _crc32(data: [u8]) -> i64:
    """Standard reflected CRC-32 (poly 0xEDB88320), bitwise."""
    var crc: i64 = 0xffffffff
    for byte in data:
        crc = crc ^ byte.to_i64()
        var k = 0
        while k < 8:
            if (crc & 1) == 1:
                crc = (crc >> 1) ^ 0xedb88320
            else:
                crc = crc >> 1
            k = k + 1
    (crc ^ 0xffffffff) & 0xffffffff

fn _push_u16(out: [u8], v: i32) -> [u8]:
    var b = out
    b.push((v & 0xff).to_u8())
    b.push(((v >> 8) & 0xff).to_u8())
    b

fn _push_u32(out: [u8], v: i64) -> [u8]:
    var b = out
    b.push((v & 0xff).to_u8())
    b.push(((v >> 8) & 0xff).to_u8())
    b.push(((v >> 16) & 0xff).to_u8())
    b.push(((v >> 24) & 0xff).to_u8())
    b

fn _push_all(out: [u8], data: [u8]) -> [u8]:
    var b = out
    for byte in data:
        b.push(byte)
    b

fn zip_write_stored(files: [ZipFile]) -> [u8]:
    """Build a zip archive with all entries stored (method 0)."""
    var out: [u8] = []
    var offsets: [i32] = []
    var crcs: [i64] = []
    for f in files:
        offsets.push(out.len())
        val crc = _crc32(f.data)
        crcs.push(crc)
        val name_b = _ascii_to_bytes(f.name)
        out = _push_u32(out, 0x04034b50)
        out = _push_u16(out, 20)          # version needed
        out = _push_u16(out, 0)           # flags
        out = _push_u16(out, 0)           # method: stored
        out = _push_u16(out, 0)           # mod time
        out = _push_u16(out, 0)           # mod date
        out = _push_u32(out, crc)
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u16(out, name_b.len())
        out = _push_u16(out, 0)           # extra len
        out = _push_all(out, name_b)
        out = _push_all(out, f.data)
    val cd_start = out.len()
    var idx = 0
    for f in files:
        val name_b = _ascii_to_bytes(f.name)
        out = _push_u32(out, 0x02014b50)
        out = _push_u16(out, 20)          # version made by
        out = _push_u16(out, 20)          # version needed
        out = _push_u16(out, 0)           # flags
        out = _push_u16(out, 0)           # method
        out = _push_u16(out, 0)           # time
        out = _push_u16(out, 0)           # date
        out = _push_u32(out, crcs[idx])
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u16(out, name_b.len())
        out = _push_u16(out, 0)           # extra
        out = _push_u16(out, 0)           # comment
        out = _push_u16(out, 0)           # disk
        out = _push_u16(out, 0)           # internal attrs
        out = _push_u32(out, 0)           # external attrs
        out = _push_u32(out, offsets[idx].to_i64())
        out = _push_all(out, name_b)
        idx = idx + 1
    val cd_size = out.len() - cd_start
    out = _push_u32(out, 0x06054b50)
    out = _push_u16(out, 0)               # disk
    out = _push_u16(out, 0)               # cd disk
    out = _push_u16(out, files.len())
    out = _push_u16(out, files.len())
    out = _push_u32(out, cd_size.to_i64())
    out = _push_u32(out, cd_start.to_i64())
    out = _push_u16(out, 0)               # comment len
    out

fn zip_write(files: [ZipFile]) -> [u8]:
    """Build a zip archive, compressing each entry with DEFLATE (method 8)
    when that shrinks the payload, otherwise storing it (method 0).

    CRC-32 is always computed over the UNCOMPRESSED data, per the zip spec.
    """
    var out: [u8] = []
    var offsets: [i32] = []
    var crcs: [i64] = []
    var methods: [i32] = []
    var comp_sizes: [i32] = []
    for f in files:
        offsets.push(out.len())
        val crc = _crc32(f.data)
        crcs.push(crc)
        val name_b = _ascii_to_bytes(f.name)

        val deflated = deflate_compress(f.data)
        var method = 0
        var payload = f.data
        if deflated.len() < f.data.len():
            method = 8
            payload = deflated
        methods.push(method)
        comp_sizes.push(payload.len())

        out = _push_u32(out, 0x04034b50)
        out = _push_u16(out, 20)          # version needed
        out = _push_u16(out, 0)           # flags
        out = _push_u16(out, method)      # method: 0 stored / 8 deflate
        out = _push_u16(out, 0)           # mod time
        out = _push_u16(out, 0)           # mod date
        out = _push_u32(out, crc)
        out = _push_u32(out, payload.len().to_i64())
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u16(out, name_b.len())
        out = _push_u16(out, 0)           # extra len
        out = _push_all(out, name_b)
        out = _push_all(out, payload)
    val cd_start = out.len()
    var idx = 0
    for f in files:
        val name_b = _ascii_to_bytes(f.name)
        out = _push_u32(out, 0x02014b50)
        out = _push_u16(out, 20)          # version made by
        out = _push_u16(out, 20)          # version needed
        out = _push_u16(out, 0)           # flags
        out = _push_u16(out, methods[idx])
        out = _push_u16(out, 0)           # time
        out = _push_u16(out, 0)           # date
        out = _push_u32(out, crcs[idx])
        out = _push_u32(out, comp_sizes[idx].to_i64())
        out = _push_u32(out, f.data.len().to_i64())
        out = _push_u16(out, name_b.len())
        out = _push_u16(out, 0)           # extra
        out = _push_u16(out, 0)           # comment
        out = _push_u16(out, 0)           # disk
        out = _push_u16(out, 0)           # internal attrs
        out = _push_u32(out, 0)           # external attrs
        out = _push_u32(out, offsets[idx].to_i64())
        out = _push_all(out, name_b)
        idx = idx + 1
    val cd_size = out.len() - cd_start
    out = _push_u32(out, 0x06054b50)
    out = _push_u16(out, 0)               # disk
    out = _push_u16(out, 0)               # cd disk
    out = _push_u16(out, files.len())
    out = _push_u16(out, files.len())
    out = _push_u32(out, cd_size.to_i64())
    out = _push_u32(out, cd_start.to_i64())
    out = _push_u16(out, 0)               # comment len
    out

fn zip_text_file(name: text, content: text) -> ZipFile:
    """Convenience: a ZipFile from a text payload."""
    ZipFile(name: name, data: _ascii_to_bytes(content))
