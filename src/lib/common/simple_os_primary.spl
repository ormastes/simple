struct PrimaryApp:
    name: text
    category: text
    launch_path: text

struct MarkdownNote:
    path: text
    title: text
    source: text
    wiki_links: [text]

struct DrawerState:
    query: text
    selected_index: u64
    apps: [PrimaryApp]

struct SystemConfigProfile:
    theme: text
    font: text
    service_manager: text
    bootloader: text
    standard_library: text

struct SimpleOsHostConfig:
    name: text
    machine: text
    arch: text
    serial_console: bool
    network_services: [text]
    gui_backend: text
    wm_modes: [text]
    binary_launch: text
    optimization_profile: text
    filesystem_binary_paths: [text]
    check_commands: [text]

struct CliCommand:
    name: text
    executable: text
    capability: text

struct PackagePlan:
    action: text
    package_name: text
    dry_run: bool

struct TmuxSession:
    name: text
    windows: [text]
    active_window: u64

fn primary_apps() -> [PrimaryApp]:
    [
        PrimaryApp(name: "Terminal", category: "System", launch_path: "/sys/apps/terminal"),
        PrimaryApp(name: "Shell", category: "System", launch_path: "/sys/apps/shell"),
        PrimaryApp(name: "Markdown Editor", category: "Utilities", launch_path: "/sys/apps/editor"),
        PrimaryApp(name: "File Explorer", category: "Utilities", launch_path: "/sys/apps/file_explorer"),
        PrimaryApp(name: "Settings", category: "Settings", launch_path: "/sys/apps/settings"),
        PrimaryApp(name: "Drawer", category: "System", launch_path: "/sys/apps/drawer"),
        PrimaryApp(name: "Minesweeper", category: "Games", launch_path: "/sys/apps/minesweeper"),
        PrimaryApp(name: "Browser", category: "Network", launch_path: "/sys/apps/browser"),
        PrimaryApp(name: "Image Viewer", category: "Utilities", launch_path: "/sys/apps/image_viewer"),
        PrimaryApp(name: "PDF Viewer", category: "Utilities", launch_path: "/sys/apps/pdf_viewer"),
        PrimaryApp(name: "Window Manager", category: "System", launch_path: "/usr/bin/desktop")
    ]

fn markdown_note(path: text, source: text) -> MarkdownNote:
    MarkdownNote(path: path, title: markdown_title(path, source), source: source, wiki_links: markdown_wiki_links(source))

fn markdown_title(path: text, source: text) -> text:
    for line in source.split("\n"):
        if line.starts_with("# "):
            return line.slice(2, line.len())
    _basename_without_markdown(path)

fn markdown_wiki_links(source: text) -> [text]:
    var links: [text] = []
    var current = ""
    var in_link = false
    var previous = ""
    for ch in source:
        if previous == "[" and ch == "[":
            in_link = true
            current = ""
            previous = ""
        elif in_link and previous == "]" and ch == "]":
            links = links.push(current.slice(0, current.len() - 1))
            current = ""
            in_link = false
            previous = ""
        else:
            if in_link:
                current = current + ch
            previous = ch
    links

fn drawer_state() -> DrawerState:
    DrawerState(query: "", selected_index: 0, apps: primary_apps())

fn drawer_query(state: DrawerState, query: text) -> DrawerState:
    DrawerState(query: query, selected_index: 0, apps: state.apps)

fn drawer_visible(state: DrawerState) -> [PrimaryApp]:
    if state.query == "":
        return state.apps
    var out: [PrimaryApp] = []
    val q = state.query.lower()
    for app in state.apps:
        if app.name.lower().contains(q) or app.category.lower().contains(q):
            out = out.push(app)
    out

fn drawer_selected_path(state: DrawerState) -> text:
    val visible = drawer_visible(state)
    if visible.len() == 0:
        return ""
    val index = if state.selected_index >= visible.len(): visible.len() - 1 else: state.selected_index
    visible[index].launch_path

fn default_system_config() -> SystemConfigProfile:
    SystemConfigProfile(theme: "dark_glass", font: "JetBrains Mono", service_manager: "OpenRC", bootloader: "Limine", standard_library: "musl")

fn simpleos_host_configs() -> [SimpleOsHostConfig]:
    [
        SimpleOsHostConfig(
            name: "fpga-serial",
            machine: "fpga",
            arch: "riscv64",
            serial_console: true,
            network_services: [],
            gui_backend: "none",
            wm_modes: [],
            binary_launch: "base-filesystem",
            optimization_profile: "simpleos-host-aggressive",
            filesystem_binary_paths: ["/usr/bin/simple", "/usr/bin/simple.smf", "/SYS/APPS/SIMPLSTC.SMF"],
            check_commands: ["sh scripts/fpga/check_kv260_telnet_serial_system.shs"]
        ),
        SimpleOsHostConfig(
            name: "qemu-network-gui",
            machine: "qemu",
            arch: "riscv64",
            serial_console: true,
            network_services: ["ssh", "web", "db"],
            gui_backend: "vulkan",
            wm_modes: ["full"],
            binary_launch: "base-filesystem",
            optimization_profile: "simpleos-host-aggressive",
            filesystem_binary_paths: ["/usr/bin/simple", "/usr/bin/simple.smf", "/SYS/APPS/SIMPLSTC.SMF"],
            check_commands: [
                "bin/simple-interp os test-scenario rv64-ssh",
                "sh scripts/qemu/qemu_rv64_http_test.shs --expect-http-only --with-display --with-storage",
                "sh scripts/qemu/check_simpleos_rv64_db_server.shs --artifacts <dir>",
                "SIMPLEOS_DESKTOP_QMP_TARGET=wm-simple-web bin/simple-interp run src/app/test/simpleos_desktop_qmp_launch.spl"
            ]
        ),
        SimpleOsHostConfig(
            name: "fpga-network",
            machine: "fpga",
            arch: "riscv64",
            serial_console: true,
            network_services: ["ssh", "web", "db"],
            gui_backend: "none",
            wm_modes: [],
            binary_launch: "base-filesystem",
            optimization_profile: "simpleos-host-aggressive",
            filesystem_binary_paths: ["/usr/bin/simple", "/usr/bin/simple.smf", "/SYS/APPS/SIMPLSTC.SMF"],
            check_commands: ["sh scripts/fpga/check_kv260_simple_rv64_network.shs --artifacts <dir>"]
        )
    ]

fn simpleos_host_config(name: text) -> Result<SimpleOsHostConfig, text>:
    for config in simpleos_host_configs():
        if config.name == name:
            return Ok(config)
    Err("unknown SimpleOS host config: {name}")

fn wm_modes_for_host(host_os: text) -> [text]:
    if host_os == "simpleos":
        return ["full"]
    if host_os == "windows" or host_os == "macos" or host_os == "linux":
        return ["full", "window"]
    []

pub fn wm_mode_allowed_for_host(host_os: text, wm_mode: text) -> bool:
    if wm_mode == "":
        return true
    val effective_host = if host_os == "": "linux" else: host_os
    wm_modes_for_host(effective_host).contains(wm_mode)

pub fn wm_mode_validation_error(host_os: text, wm_mode: text) -> text:
    if wm_mode_allowed_for_host(host_os, wm_mode):
        return ""
    val effective_host = if host_os == "": "linux" else: host_os
    "wm mode '{wm_mode}' is not available on host '{effective_host}'"

fn primary_cli_commands() -> [CliCommand]:
    [
        CliCommand(name: "shell", executable: "/bin/shell", capability: "interactive"),
        CliCommand(name: "tmux", executable: "/usr/bin/tmux", capability: "terminal"),
        CliCommand(name: "ssh", executable: "/usr/bin/ssh", capability: "network"),
        CliCommand(name: "ls", executable: "/bin/ls", capability: "read"),
        CliCommand(name: "mkdir", executable: "/bin/mkdir", capability: "write"),
        CliCommand(name: "chmod", executable: "/bin/chmod", capability: "write"),
        CliCommand(name: "sudo", executable: "/usr/bin/sudo", capability: "privilege"),
        CliCommand(name: "pkg", executable: "/usr/sbin/pkg", capability: "package"),
        CliCommand(name: "git", executable: "/usr/bin/git", capability: "version-control"),
        CliCommand(name: "rg", executable: "/usr/bin/rg", capability: "search"),
        CliCommand(name: "fd", executable: "/usr/bin/fd", capability: "search"),
        CliCommand(name: "btop", executable: "/usr/bin/btop", capability: "monitor"),
        CliCommand(name: "curl", executable: "/usr/bin/curl", capability: "network"),
        CliCommand(name: "man", executable: "/usr/bin/man", capability: "manual"),
        CliCommand(name: "gdb", executable: "/usr/bin/gdb", capability: "debug"),
        CliCommand(name: "xxd", executable: "/usr/bin/xxd", capability: "binary"),
        CliCommand(name: "picocom", executable: "/usr/bin/picocom", capability: "serial"),
        CliCommand(name: "zig", executable: "/usr/bin/zig", capability: "build")
    ]

fn package_plan(args: [text]) -> Result<PackagePlan, text>:
    if args.len() == 0:
        return Err("pkg: action required")
    val action = args[0]
    if action != "install" and action != "remove" and action != "list" and action != "update":
        return Err("pkg: unsupported action")
    val name = if args.len() > 1: args[1] else: ""
    if (action == "install" or action == "remove") and name == "":
        return Err("pkg: package name required")
    Ok(PackagePlan(action: action, package_name: name, dry_run: false))

fn tmux_session(name: text) -> TmuxSession:
    TmuxSession(name: name, windows: ["/bin/shell"], active_window: 0)

fn tmux_add_window(session: TmuxSession, command: text) -> TmuxSession:
    var windows = session.windows
    windows = windows.push(command)
    TmuxSession(name: session.name, windows: windows, active_window: windows.len() - 1)

fn _basename_without_markdown(path: text) -> text:
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    val name = if last_slash >= 0: path.slice(last_slash + 1, path.len()) else: path
    if name.ends_with(".md"):
        return name.slice(0, name.len() - 3)
    if name.ends_with(".markdown"):
        return name.slice(0, name.len() - 9)
    name
