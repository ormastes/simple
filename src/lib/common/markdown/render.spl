# Minimal Markdown render helpers.

use std.common.markdown.inline.{markdown_escape_html}
use std.common.markdown.utilities.{markdown_heading_level, markdown_strip_heading_marker}
use std.common.render_scene.office_style_resolver.{resolve_style, style_to_css_text}

fn render_markdown_line_html(line: text) -> text:
    val level = markdown_heading_level(line)
    if level > 0:
        val text_value = markdown_escape_html(markdown_strip_heading_marker(line))
        return "<h{level}>{text_value}</h{level}>"
    if _markdown_is_task_line(line):
        return _render_markdown_task_line(line, "")
    "<p>" + markdown_escape_html(line) + "</p>"

fn render_markdown_line_styled_html(line: text) -> text:
    """Render a markdown line to HTML with an inline CSS `style` attribute drawn
    from the shared office style resolver, so the markdown WYSIWYG view and the
    Word/PPT surfaces share one Word-level default theme."""
    val level = markdown_heading_level(line)
    if level > 0:
        val text_value = markdown_escape_html(markdown_strip_heading_marker(line))
        val style = resolve_style("heading_{level}", [])
        val css = style_to_css_text(style)
        return "<h{level} style=\"{css}\">{text_value}</h{level}>"
    val pstyle = resolve_style("paragraph", [])
    val pcss = style_to_css_text(pstyle)
    if _markdown_is_task_line(line):
        return _render_markdown_task_line(line, " style=\"{pcss}\"")
    "<p style=\"{pcss}\">" + markdown_escape_html(line) + "</p>"

fn render_markdown_code_line_styled_html(line: text) -> text:
    """Render one source line *inside* a fenced code block: monospace and
    preformatted (white-space: pre) via the shared `code_block` style, preserving
    the line's leading indentation. No heading or inline-markdown parsing is
    applied, so e.g. a leading `#` stays code, not a heading."""
    val style = resolve_style("code_block", [])
    val css = style_to_css_text(style)
    "<pre style=\"{css}; margin: 0;\">" + markdown_escape_html(line) + "</pre>"

fn _markdown_is_task_line(line: text) -> bool:
    line.starts_with("- [ ] ") or line.starts_with("- [x] ") or line.starts_with("- [X] ")

fn _render_markdown_task_line(line: text, style_attr: text) -> text:
    val checked = if line.starts_with("- [ ] ") then "" else: " checked"
    val checked_value = if checked == "" then "false" else: "true"
    val label = markdown_escape_html(line.slice(6, line.len()))
    "<p class=\"markdown-task\" data-task=\"true\" data-checked=\"" + checked_value + "\"" + style_attr + "><input type=\"checkbox\" disabled" + checked + "> " + label + "</p>"
