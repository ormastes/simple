# Minimal Markdown render helpers.

use std.common.markdown.inline.{markdown_escape_html}
use std.common.markdown.utilities.{markdown_heading_level, markdown_strip_heading_marker}
use std.common.render_scene.office_style_resolver.{resolve_style, style_to_css_text}

fn render_markdown_line_html(line: text) -> text:
    val level = markdown_heading_level(line)
    if level > 0:
        val text_value = markdown_escape_html(markdown_strip_heading_marker(line))
        return "<h{level}>{text_value}</h{level}>"
    "<p>" + markdown_escape_html(line) + "</p>"

fn render_markdown_line_styled_html(line: text) -> text:
    """Render a markdown line to HTML with an inline CSS `style` attribute drawn
    from the shared office style resolver, so the markdown WYSIWYG view and the
    Word/PPT surfaces share one Word-level default theme."""
    val level = markdown_heading_level(line)
    if level > 0:
        val text_value = markdown_escape_html(markdown_strip_heading_marker(line))
        val style = resolve_style("heading_{level}", [])
        val css = style_to_css_text(style)
        return "<h{level} style=\"{css}\">{text_value}</h{level}>"
    val pstyle = resolve_style("paragraph", [])
    val pcss = style_to_css_text(pstyle)
    "<p style=\"{pcss}\">" + markdown_escape_html(line) + "</p>"
