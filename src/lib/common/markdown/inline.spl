# Common Markdown inline helpers.

# Single-pass inline scanner: handles **bold**, *italic*, ~~strike~~, `code`,
# [links](href), escaped markers, and unbalanced markers (treated as literal text).
# Code spans protect their content from further interpretation.
fn markdown_inline_text(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = ""
    var i = 0
    val n = value.len()
    while i < n:
        val ch = value.char_at(i)
        # Escaped character: backslash before * or `
        if ch == "\\" and i + 1 < n:
            val next = value.char_at(i + 1)
            if next == "*" or next == "`" or next == "~" or next == "[" or next == "]" or next == "(" or next == ")" or next == "\\":
                out = out + markdown_escape_html(next)
                i = i + 2
            else:
                out = out + markdown_escape_html(ch)
                i = i + 1
        # Code span: find closing backtick, protect interior
        elif ch == "`":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "`":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 1, j)
                out = out + "<code>" + markdown_escape_html(interior) + "</code>"
                i = j + 1
            else:
                # Unbalanced backtick — emit as literal
                out = out + markdown_escape_html(ch)
                i = i + 1
        # Link: [text](href)
        elif ch == "[":
            var label_end = i + 1
            var found_label = false
            while label_end < n:
                if value.char_at(label_end) == "]":
                    found_label = true
                    break
                label_end = label_end + 1
            if found_label and label_end + 1 < n and value.char_at(label_end + 1) == "(":
                var href_end = label_end + 2
                var found_href = false
                while href_end < n:
                    if value.char_at(href_end) == ")":
                        found_href = true
                        break
                    href_end = href_end + 1
                if found_href:
                    val label = value.slice(i + 1, label_end)
                    val href = _markdown_link_href(value.slice(label_end + 2, href_end))
                    out = out + "<a href=\"" + markdown_escape_html(href) + "\">" + markdown_escape_html(label) + "</a>"
                    i = href_end + 1
                else:
                    out = out + markdown_escape_html(ch)
                    i = i + 1
            else:
                out = out + markdown_escape_html(ch)
                i = i + 1
        # Bold: **text**
        elif ch == "*" and i + 1 < n and value.char_at(i + 1) == "*":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "*" and value.char_at(j + 1) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 2, j)
                out = out + "<strong>" + markdown_escape_html(interior) + "</strong>"
                i = j + 2
            else:
                # Unbalanced ** — emit as literal
                out = out + "**"
                i = i + 2
        # Strikethrough: ~~text~~
        elif ch == "~" and i + 1 < n and value.char_at(i + 1) == "~":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "~" and value.char_at(j + 1) == "~":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 2, j)
                out = out + "<del>" + markdown_escape_html(interior) + "</del>"
                i = j + 2
            else:
                # Unbalanced ~~ — emit as literal
                out = out + "~~"
                i = i + 2
        # Italic: *text*
        elif ch == "*":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                val interior = value.slice(i + 1, j)
                out = out + "<em>" + markdown_escape_html(interior) + "</em>"
                i = j + 1
            else:
                # Unbalanced * — emit as literal
                out = out + ch
                i = i + 1
        else:
            out = out + markdown_escape_html(ch)
            i = i + 1
    out

# Escape HTML special characters including quote chars for attribute-context safety.
fn markdown_escape_html(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = value.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out.replace("'", "&#39;")

# Strip inline markers to produce plain text (for TOC, alt-text, etc.).
# Uses the single-pass scanner so code spans protect their content.
fn markdown_plain_inline(value: text) -> text:
    if value.len() == 0:
        return ""
    var out = ""
    var i = 0
    val n = value.len()
    while i < n:
        val ch = value.char_at(i)
        # Escaped marker: skip the backslash, keep the char
        if ch == "\\" and i + 1 < n:
            val next = value.char_at(i + 1)
            if next == "*" or next == "`" or next == "~" or next == "[" or next == "]" or next == "(" or next == ")" or next == "\\":
                out = out + next
                i = i + 2
            else:
                out = out + ch
                i = i + 1
        # Code span: keep interior, skip backticks
        elif ch == "`":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "`":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 1, j)
                i = j + 1
            else:
                # Unbalanced — drop the lone backtick
                i = i + 1
        # Link: keep the label, skip the href
        elif ch == "[":
            var label_end = i + 1
            var found_label = false
            while label_end < n:
                if value.char_at(label_end) == "]":
                    found_label = true
                    break
                label_end = label_end + 1
            if found_label and label_end + 1 < n and value.char_at(label_end + 1) == "(":
                var href_end = label_end + 2
                var found_href = false
                while href_end < n:
                    if value.char_at(href_end) == ")":
                        found_href = true
                        break
                    href_end = href_end + 1
                if found_href:
                    out = out + value.slice(i + 1, label_end)
                    i = href_end + 1
                else:
                    out = out + ch
                    i = i + 1
            else:
                out = out + ch
                i = i + 1
        # Bold **
        elif ch == "*" and i + 1 < n and value.char_at(i + 1) == "*":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "*" and value.char_at(j + 1) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 2, j)
                i = j + 2
            else:
                # Unbalanced — drop the **
                i = i + 2
        # Strikethrough ~~
        elif ch == "~" and i + 1 < n and value.char_at(i + 1) == "~":
            var j = i + 2
            var found_close = false
            while j + 1 < n:
                if value.char_at(j) == "~" and value.char_at(j + 1) == "~":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 2, j)
                i = j + 2
            else:
                # Unbalanced — drop the ~~
                i = i + 2
        # Italic *
        elif ch == "*":
            var j = i + 1
            var found_close = false
            while j < n:
                if value.char_at(j) == "*":
                    found_close = true
                    break
                j = j + 1
            if found_close:
                out = out + value.slice(i + 1, j)
                i = j + 1
            else:
                # Unbalanced — drop the lone *
                i = i + 1
        else:
            out = out + ch
            i = i + 1
    out

fn _markdown_link_href(href: text) -> text:
    val clean = href.trim()
    val lower = clean.lower()
    if lower.starts_with("javascript:") or lower.starts_with("data:"):
        return "#"
    clean
