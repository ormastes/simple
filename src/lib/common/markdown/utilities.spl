# Common Markdown utility helpers.

fn markdown_trim(value: text) -> text:
    value.trim()

fn markdown_is_blank(line: text) -> bool:
    line.trim() == ""

fn markdown_is_heading(line: text) -> bool:
    line.trim_start().starts_with("#")

fn markdown_heading_level(line: text) -> i64:
    val trimmed = line.trim_start()
    var level = 0
    while level < trimmed.len() and trimmed.char_at(level) == "#":
        level = level + 1
    if level > 0 and level <= 6:
        return level
    0

fn markdown_strip_heading_marker(line: text) -> text:
    val level = markdown_heading_level(line)
    if level == 0:
        return line.trim()
    line.trim_start().slice(level, line.trim_start().len()).trim()

fn markdown_slugify(value: text) -> text:
    val lower = value.trim().to_lower()
    var result = ""
    var i = 0
    while i < lower.len():
        val ch = lower.char_at(i)
        if ch == " ":
            result = result + "-"
        else:
            result = result + ch
        i = i + 1
    result

fn markdown_is_code_fence(line: text) -> bool:
    line.trim_start().starts_with("```")

fn markdown_is_css_fence(line: text) -> bool:
    val trimmed = line.trim()
    trimmed == "```css" or trimmed == "```style"
