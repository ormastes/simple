# Common Markdown utility helpers.

fn markdown_trim(value: text) -> text:
    value.trim()

fn markdown_is_blank(line: text) -> bool:
    line.trim() == ""

fn markdown_is_heading(line: text) -> bool:
    line.trim_start().starts_with("#")

fn markdown_heading_level(line: text) -> i64:
    val trimmed = line.trim_start()
    var level = 0
    while level < trimmed.len() and trimmed.char_at(level) == "#":
        level = level + 1
    if level > 0 and level <= 6:
        return level
    0

fn markdown_strip_heading_marker(line: text) -> text:
    val level = markdown_heading_level(line)
    if level == 0:
        return line.trim()
    line.trim_start().slice(level, line.trim_start().len()).trim()

fn markdown_slugify(value: text) -> text:
    if value.trim().len() == 0:
        return "section"
    val lower = value.trim().to_lower()
    var raw = ""
    var i = 0
    while i < lower.len():
        val ch = lower.char_at(i)
        if ch == " " or ch == "-" or ch == "_":
            raw = raw + "-"
        elif (ch >= "a" and ch <= "z") or (ch >= "0" and ch <= "9"):
            raw = raw + ch
        # Skip unicode and other punctuation (treat as separator dash)
        else:
            raw = raw + "-"
        i = i + 1
    # Collapse consecutive dashes
    var result = ""
    var prev_dash = false
    var k = 0
    while k < raw.len():
        val ch = raw.char_at(k)
        if ch == "-":
            if not prev_dash:
                result = result + "-"
            prev_dash = true
        else:
            result = result + ch
            prev_dash = false
        k = k + 1
    # Trim leading/trailing dashes
    var start = 0
    while start < result.len() and result.char_at(start) == "-":
        start = start + 1
    var end = result.len()
    while end > start and result.char_at(end - 1) == "-":
        end = end - 1
    val trimmed = result.slice(start, end)
    if trimmed.len() == 0:
        return "section"
    trimmed

fn markdown_is_code_fence(line: text) -> bool:
    line.trim_start().starts_with("```")

fn markdown_is_css_fence(line: text) -> bool:
    val trimmed = line.trim()
    trimmed == "```css" or trimmed == "```style"
