# Lightweight Markdown parsing compatibility surface.

use std.common.markdown.block.{MarkdownBlock, markdown_block, markdown_block_kind}
use std.common.markdown.utilities.{markdown_is_code_fence, markdown_is_blank}

fn parse_markdown_blocks(content: text) -> [MarkdownBlock]:
    if content.len() == 0:
        return []
    var blocks: [MarkdownBlock] = []
    val lines = content.split("\n")
    var i = 0
    var in_fence = false
    while i < lines.len():
        val line = lines[i]
        # Track code fences so we don't misclassify interior lines
        if markdown_is_code_fence(line):
            if in_fence:
                # Closing fence: record as code, exit fence mode
                blocks = blocks.push(markdown_block("code", line, i, i))
                in_fence = false
                i = i + 1
            else:
                # Opening fence
                blocks = blocks.push(markdown_block("code", line, i, i))
                in_fence = true
                i = i + 1
        elif in_fence:
            # Interior of fence — always "code", never blank-skipped
            blocks = blocks.push(markdown_block("code", line, i, i))
            i = i + 1
        elif not markdown_is_blank(line):
            blocks = blocks.push(markdown_block(markdown_block_kind(line), line, i, i))
            i = i + 1
        else:
            i = i + 1
    # Unclosed fence at EOF: blocks already recorded with kind "code" — no crash
    blocks

fn parse_markdown(content: text) -> [MarkdownBlock]:
    parse_markdown_blocks(content)
