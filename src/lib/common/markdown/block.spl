# Common Markdown block helpers.

use std.common.markdown.utilities.{markdown_heading_level, markdown_is_code_fence}

struct MarkdownBlock:
    kind: text
    content: text
    from_line: i64
    to_line: i64

# A separator row looks like: | --- | :---: | etc.
# All non-pipe, non-colon, non-dash, non-space chars disqualify it.
fn _markdown_is_separator_row(trimmed: text) -> bool:
    if not trimmed.contains("|"):
        return false
    var i = 0
    val n = trimmed.len()
    while i < n:
        val ch = trimmed.char_at(i)
        if ch != "|" and ch != "-" and ch != ":" and ch != " ":
            return false
        i = i + 1
    true

fn markdown_block(kind: text, content: text, from_line: i64, to_line: i64) -> MarkdownBlock:
    MarkdownBlock(kind: kind, content: content, from_line: from_line, to_line: to_line)

fn markdown_block_kind(line: text) -> text:
    val trimmed = line.trim_start()
    if markdown_heading_level(line) > 0:
        return "heading"
    if markdown_is_code_fence(line):
        return "code"
    if trimmed.starts_with(">"):
        return "blockquote"
    if trimmed.starts_with("- ") or trimmed.starts_with("* "):
        return "list"
    if trimmed.starts_with("|") or _markdown_is_separator_row(trimmed):
        return "table"
    "paragraph"
