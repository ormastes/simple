# Markdown Folding Ranges
#
# Computes fold ranges from a ranged AST produced by parse_blocks_with_ranges.
# Each entry in the ranged_ast is a tuple: (block, from_line, to_line).
#
# Produces FoldRange entries for:
#   - Heading sections (from heading line to next same-or-higher-level heading or EOF)
#   - Code blocks
#   - Blockquotes
#   - Lists (unordered and ordered)

struct FoldRange:
    from_line: i64
    to_line: i64
    kind: text

fn compute_folding_ranges(ranged_ast: array) -> [FoldRange]:
    var ranges: [FoldRange] = []
    val count = ranged_ast.length()

    # First pass: emit ranges for code blocks, blockquotes, lists.
    var i = 0
    while i < count:
        val entry = ranged_ast.get(i)
        val block = entry.0
        val from = entry.1
        val to = entry.2
        val btype = block.0
        if btype == "code_block":
            if to > from:
                ranges.push(FoldRange(from_line: from, to_line: to, kind: "code"))
        if btype == "blockquote":
            if to > from:
                ranges.push(FoldRange(from_line: from, to_line: to, kind: "blockquote"))
        if btype == "unordered_list":
            if to > from:
                ranges.push(FoldRange(from_line: from, to_line: to, kind: "list"))
        if btype == "ordered_list":
            if to > from:
                ranges.push(FoldRange(from_line: from, to_line: to, kind: "list"))
        i = i + 1

    # Second pass: compute heading section ranges.
    # For each heading, find the next heading of same or higher level (lower or equal level number).
    var h = 0
    while h < count:
        val entry = ranged_ast.get(h)
        val block = entry.0
        val btype = block.0
        if btype == "heading":
            val heading_level = block.1
            val heading_from = entry.1
            # Look ahead for next heading at same or higher level.
            var section_to = _fr_last_line(ranged_ast)
            var k = h + 1
            while k < count:
                val next_entry = ranged_ast.get(k)
                val next_block = next_entry.0
                val next_btype = next_block.0
                if next_btype == "heading":
                    val next_level = next_block.1
                    if next_level <= heading_level:
                        val next_from = next_entry.1
                        section_to = next_from - 1
                        k = count
                    else:
                        k = k + 1
                else:
                    k = k + 1
            if section_to > heading_from:
                ranges.push(FoldRange(from_line: heading_from, to_line: section_to, kind: "section"))
        h = h + 1

    ranges

# Return the to_line of the last entry, or 0 if empty.
fn _fr_last_line(ranged_ast: array) -> i64:
    val count = ranged_ast.length()
    if count == 0:
        return 0
    val last = ranged_ast.get(count - 1)
    last.2
