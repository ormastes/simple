@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Collection Helpers — Sorting and Ranking

# ============================================================================
# Sorting by Key (#COLL-P1-001)
# ============================================================================

fn sort_by_key(arr, key_fn):
    """Sort array by extracted key using selection sort.

    Returns a NEW sorted array.  Original is unchanged.

    sdoctest:
        val result = sort_by_key(["banana", "apple", "cherry"], &:len)
        expect(result[0]).to_equal("apple")
    """
    if arr.len() <= 1:
        return arr

    # Copy to mutable array
    var sorted = []
    for item in arr:
        sorted.push(item)

    # Selection sort by key
    var i = 0
    while i < sorted.len() - 1:
        var min_idx = i
        var min_key = key_fn(sorted[i])
        var j = i + 1
        while j < sorted.len():
            val k = key_fn(sorted[j])
            if k < min_key:
                min_idx = j
                min_key = k
            j = j + 1

        if min_idx != i:
            val temp = sorted[i]
            sorted[i] = sorted[min_idx]
            sorted[min_idx] = temp

        i = i + 1

    sorted

# ============================================================================
# Min/Max by Key (#COLL-P1-004, #COLL-P1-005)
# ============================================================================

fn min_by_key(arr, key_fn):
    """Return element with the smallest key, or nil for empty arrays.

    sdoctest:
        expect(min_by_key(["banana", "apple", "cherry"], &:len)).to_equal("apple")
        expect(min_by_key([], &:len)).to_be_nil()
    """
    if arr.len() == 0:
        return nil

    var best = arr[0]
    var best_key = key_fn(arr[0])
    var i = 1
    while i < arr.len():
        val k = key_fn(arr[i])
        if k < best_key:
            best = arr[i]
            best_key = k
        i = i + 1

    best

fn max_by_key(arr, key_fn):
    """Return element with the largest key, or nil for empty arrays.

    sdoctest:
        expect(max_by_key(["banana", "apple", "cherry"], &:len)).to_equal("cherry")
        expect(max_by_key([], &:len)).to_be_nil()
    """
    if arr.len() == 0:
        return nil

    var best = arr[0]
    var best_key = key_fn(arr[0])
    var i = 1
    while i < arr.len():
        val k = key_fn(arr[i])
        if k > best_key:
            best = arr[i]
            best_key = k
        i = i + 1

    best

# ============================================================================
# Top N / Bottom N (#COLL-P1-044, #COLL-P1-045)
# ============================================================================

fn top_n(arr, n: i64):
    """Return the n largest elements (sorted descending).

    sdoctest:
        val result = top_n([3, 1, 4, 1, 5, 9], 3)
        expect(result[0]).to_equal(9)
        expect(result[1]).to_equal(5)
        expect(result[2]).to_equal(4)
    """
    if n <= 0 or arr.len() == 0:
        return []

    # Copy and sort descending via selection sort
    var sorted = []
    for item in arr:
        sorted.push(item)

    var i = 0
    val limit = if n < sorted.len(): n else: sorted.len()
    while i < limit:
        var max_idx = i
        var j = i + 1
        while j < sorted.len():
            if sorted[j] > sorted[max_idx]:
                max_idx = j
            j = j + 1

        if max_idx != i:
            val temp = sorted[i]
            sorted[i] = sorted[max_idx]
            sorted[max_idx] = temp

        i = i + 1

    var result = []
    i = 0
    while i < limit:
        result.push(sorted[i])
        i = i + 1

    result

fn bottom_n(arr, n: i64):
    """Return the n smallest elements (sorted ascending).

    sdoctest:
        val result = bottom_n([3, 1, 4, 1, 5, 9], 3)
        expect(result[0]).to_equal(1)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(3)
    """
    if n <= 0 or arr.len() == 0:
        return []

    # Copy and sort ascending via selection sort
    var sorted = []
    for item in arr:
        sorted.push(item)

    var i = 0
    val limit = if n < sorted.len(): n else: sorted.len()
    while i < limit:
        var min_idx = i
        var j = i + 1
        while j < sorted.len():
            if sorted[j] < sorted[min_idx]:
                min_idx = j
            j = j + 1

        if min_idx != i:
            val temp = sorted[i]
            sorted[i] = sorted[min_idx]
            sorted[min_idx] = temp

        i = i + 1

    var result = []
    i = 0
    while i < limit:
        result.push(sorted[i])
        i = i + 1

    result
