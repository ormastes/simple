# Math Expression Symbols — Greek letters, super/subscript chars, unicode formatting, pretty/latex primitives

fn greek(name: text) -> text:
    if name == "alpha": return "α"
    if name == "beta": return "β"
    if name == "gamma": return "γ"
    if name == "delta": return "δ"
    if name == "epsilon": return "ε"
    if name == "zeta": return "ζ"
    if name == "eta": return "η"
    if name == "theta": return "θ"
    if name == "iota": return "ι"
    if name == "kappa": return "κ"
    if name == "lambda": return "λ"
    if name == "mu": return "μ"
    if name == "nu": return "ν"
    if name == "xi": return "ξ"
    if name == "omicron": return "ο"
    if name == "pi": return "π"
    if name == "rho": return "ρ"
    if name == "sigma": return "σ"
    if name == "tau": return "τ"
    if name == "upsilon": return "υ"
    if name == "phi": return "φ"
    if name == "chi": return "χ"
    if name == "psi": return "ψ"
    if name == "omega": return "ω"
    if name == "varepsilon": return "ϵ"
    if name == "vartheta": return "ϑ"
    if name == "varphi": return "ϕ"
    if name == "varrho": return "ϱ"
    if name == "varpi": return "ϖ"
    if name == "varkappa": return "ϰ"
    if name == "partial": return "∂"
    if name == "nabla": return "∇"
    name

fn greek_upper(name: text) -> text:
    if name == "Gamma": return "Γ"
    if name == "Delta": return "Δ"
    if name == "Theta": return "Θ"
    if name == "Lambda": return "Λ"
    if name == "Xi": return "Ξ"
    if name == "Pi": return "Π"
    if name == "Sigma": return "Σ"
    if name == "Upsilon": return "Υ"
    if name == "Phi": return "Φ"
    if name == "Psi": return "Ψ"
    if name == "Omega": return "Ω"
    name

fn superscript_char(ch: text) -> text:
    if ch == "0": return "⁰"
    if ch == "1": return "¹"
    if ch == "2": return "²"
    if ch == "3": return "³"
    if ch == "4": return "⁴"
    if ch == "5": return "⁵"
    if ch == "6": return "⁶"
    if ch == "7": return "⁷"
    if ch == "8": return "⁸"
    if ch == "9": return "⁹"
    if ch == "+": return "⁺"
    if ch == "-": return "⁻"
    if ch == "=": return "⁼"
    if ch == "(": return "⁽"
    if ch == ")": return "⁾"
    if ch == "n": return "ⁿ"
    if ch == "i": return "ⁱ"
    if ch == "x": return "ˣ"
    ch

fn subscript_char(ch: text) -> text:
    if ch == "0": return "₀"
    if ch == "1": return "₁"
    if ch == "2": return "₂"
    if ch == "3": return "₃"
    if ch == "4": return "₄"
    if ch == "5": return "₅"
    if ch == "6": return "₆"
    if ch == "7": return "₇"
    if ch == "8": return "₈"
    if ch == "9": return "₉"
    if ch == "+": return "₊"
    if ch == "-": return "₋"
    if ch == "=": return "₌"
    if ch == "(": return "₍"
    if ch == ")": return "₎"
    if ch == "a": return "ₐ"
    if ch == "e": return "ₑ"
    if ch == "o": return "ₒ"
    if ch == "x": return "ₓ"
    if ch == "h": return "ₕ"
    if ch == "k": return "ₖ"
    if ch == "l": return "ₗ"
    if ch == "m": return "ₘ"
    if ch == "n": return "ₙ"
    if ch == "p": return "ₚ"
    if ch == "s": return "ₛ"
    if ch == "t": return "ₜ"
    if ch == "i": return "ᵢ"
    if ch == "j": return "ⱼ"
    if ch == "r": return "ᵣ"
    ch

fn superscript(s: text) -> text:
    var parts: [text] = []
    for i in 0..s.len():
        parts.push(superscript_char(_char_at(s, i)))
    parts.join("")

fn subscript(s: text) -> text:
    var parts: [text] = []
    for i in 0..s.len():
        parts.push(subscript_char(_char_at(s, i)))
    parts.join("")

fn _text_pad_center(s: text, width: i64) -> text:
    if s.len() >= width:
        return s
    val left_pad_count = (width - s.len()) / 2
    var pad_parts: [text] = []
    for _ in 0..left_pad_count:
        pad_parts.push(" ")
    pad_parts.join("") + s

fn hline(width: i64) -> text:
    var parts: [text] = []
    for _ in 0..width:
        parts.push("─")
    parts.join("")

# reason: positional math_repr API
fn pretty_fraction(num: text, den: text) -> text:
    "(" + num + ")/(" + den + ")"

# reason: positional math_repr API
fn pretty_power(base: text, exp: text) -> text:
    base + superscript(exp)

# reason: positional math_repr API
fn pretty_sub(base: text, idx: text) -> text:
    base + subscript(idx)

fn pretty_sqrt(expr: text) -> text:
    "√(" + expr + ")"

# reason: positional math_repr API
fn pretty_sum(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "∑(" + var_name + "=" + from_val + ".." + to_val + ") " + expr

# reason: positional math_repr API
fn pretty_integral(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "∫(" + var_name + "=" + from_val + ".." + to_val + ") " + expr

# reason: positional math_repr API
fn latex_fraction(num: text, den: text) -> text:
    "\\frac{" + num + "}{" + den + "}"

# reason: positional math_repr API
fn latex_power(base: text, exp: text) -> text:
    if exp.len() == 1:
        return base + "^" + exp
    base + "^{" + exp + "}"

# reason: positional math_repr API
fn latex_sub(base: text, idx: text) -> text:
    if idx.len() == 1:
        return base + "_" + idx
    base + "_{" + idx + "}"

fn latex_sqrt(expr: text) -> text:
    "\\sqrt{" + expr + "}"

# reason: positional math_repr API
fn latex_sum(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "\\sum_{" + var_name + "=" + from_val + "}^{" + to_val + "} " + expr

# reason: positional math_repr API
fn latex_integral(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "\\int_{" + from_val + "}^{" + to_val + "} " + expr + " \\, d" + var_name
