# JWT Module — Public API
#
# JWS Compact Serialization (RFC 7515) for HS256, RS256, ES256.
#
# HS256: HMAC-SHA256 (symmetric shared secret).
# RS256: RSASSA-PKCS1-v1_5 with SHA-256 (RSA asymmetric, 2048-bit+).
# ES256: ECDSA P-256 with SHA-256 (EC asymmetric).
#
# Key formats (raw bytes, DER-encoded):
#   Signing:      PKCS#8 v1 DER-encoded private key
#   Verification: SubjectPublicKeyInfo (SPKI) DER-encoded public key
#
# References: RFC 7515 (JWS), RFC 7517 (JWK), RFC 7518 (JWA)

mod common.jwt.types
mod common.jwt.encode
mod common.jwt.decode
mod common.jwt.claims
mod common.jwt.sign
mod common.jwt.verify
mod common.jwt.utilities

use common.jwt.sign.{
    jwt_sign_hs256,
    jwt_sign_hs256_bytes,
    jwt_verify_hs256,
    jwt_sign_rs256,
    jwt_verify_rs256,
    jwt_sign_es256,
    jwt_verify_es256
}

use common.jwt.encode.{
    base64url_encode,
    base64url_decode,
    base64url_encode_bytes,
    base64url_decode_to_bytes
}
