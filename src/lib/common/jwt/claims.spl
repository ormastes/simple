# JWT Claims — helpers for inspecting a decoded JWT claims list.
#
# Provides: get_claim, has_claim, current_timestamp.

extern fn rt_time_now_seconds() -> i64

# Return the Unix timestamp in seconds (used for exp/iat validation).
fn current_timestamp() -> i64:
    rt_time_now_seconds()

# Look up a claim by key in the decoded pairs list.
# Returns the claim value as text, or "" if not found.
fn get_claim(claims: [(text, text)], key: text) -> text:
    var i = 0
    while i < claims.len():
        val pair = claims[i]
        if pair.0 == key:
            return pair.1
        i = i + 1
    ""

# Return true if the claims list contains the given key.
fn has_claim(claims: [(text, text)], key: text) -> bool:
    get_claim(claims, key).len() > 0
