# JWT Verify — signature verification for JWT tokens.
#
# Currently only provides the function signature used by oidc/id_token.spl.
# Full JWKS-based RS256 verification is a future milestone; callers that
# invoke verify_signature should handle the false return gracefully.

# Verify the JWT signature against a JWKS JSON document.
# alg: signing algorithm string, e.g. "RS256".
# Returns false until JWKS-based verification is implemented.
fn verify_signature(token: text, jwks_json: text, alg: text) -> bool:
    false
