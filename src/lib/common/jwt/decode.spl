# JWT Decode — split a JWT token and decode its JSON payload.
#
# Provides: split_token, json_decode, json_parse_object.

# Split a JWT token string into its three dot-separated parts.
# Returns [header_b64, payload_b64, signature_b64].
fn split_token(token: text) -> [text]:
    token.split(".")

# Parse a shallow JSON object string into (key, value) text pairs.
# Nested values are returned as their raw JSON substring.
fn json_parse_object(json: text) -> [(text, text)]:
    var pairs: [(text, text)] = []
    val s = json.trim()
    if not s.starts_with("{"):
        return pairs
    val inner = s.slice(1, s.len() - 1).trim()
    if inner.len() == 0:
        return pairs
    var i = 0
    val n = inner.len()
    while i < n:
        while i < n and inner[i] == ' ':
            i = i + 1
        if i >= n:
            break
        if inner[i] != '"':
            i = i + 1
            continue
        i = i + 1
        var key = ""
        while i < n and inner[i] != '"':
            key = key + inner[i]
            i = i + 1
        i = i + 1
        while i < n and (inner[i] == ' ' or inner[i] == ':'):
            i = i + 1
        var value = ""
        if i < n and inner[i] == '"':
            i = i + 1
            while i < n and inner[i] != '"':
                value = value + inner[i]
                i = i + 1
            i = i + 1
        else:
            while i < n and inner[i] != ',' and inner[i] != '}':
                value = value + inner[i]
                i = i + 1
            value = value.trim()
        pairs.push((key, value))
        while i < n and (inner[i] == ' ' or inner[i] == ','):
            i = i + 1
    pairs

# Alias for json_parse_object — used by auth_middleware.
fn json_decode(json: text) -> [(text, text)]:
    json_parse_object(json)
