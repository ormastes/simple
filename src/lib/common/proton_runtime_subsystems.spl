"""Non-Wine Proton runtime subsystem evidence."""

class ProtonNonWineRuntimeEvidence:
    steam_runtime: text
    pressure_vessel: text
    graphics: text
    steam_integration: text
    sync: text

fn _proton_non_wine_evidence(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> ProtonNonWineRuntimeEvidence:
    ProtonNonWineRuntimeEvidence(steam_runtime: steam_runtime, pressure_vessel: pressure_vessel, graphics: graphics, steam_integration: steam_integration, sync: sync)

fn _proton_require(evidence: text, item: text) -> text:
    if _proton_has_token(evidence, item):
        return "ready"
    "missing-" + item

fn _proton_has_token(evidence: text, item: text) -> bool:
    if evidence == item:
        return true
    evidence.starts_with(item + " ") or evidence.ends_with(" " + item) or evidence.contains(" " + item + " ")

fn _proton_append_once(items: text, item: text) -> text:
    if _proton_has_token(items, item):
        return items
    if items == "":
        return item
    items + " " + item

pub fn proton_non_wine_runtime_evidence_new(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> ProtonNonWineRuntimeEvidence:
    _proton_non_wine_evidence(steam_runtime, pressure_vessel, graphics, steam_integration, sync)

pub fn proton_steam_runtime_gate(evidence: text) -> text:
    for item in ["steam-runtime", "abi-x86_64"]:
        val state = _proton_require(evidence, item)
        if state != "ready":
            return state
    if not evidence.contains("soldier") and not evidence.contains("sniper"):
        return "missing-steam-linux-runtime-generation"
    "ready"

pub fn proton_pressure_vessel_gate(evidence: text) -> text:
    for item in [
        "pressure-vessel-container",
        "container-rootfs",
        "container-rootfs-nvfs",
        "namespace-pid",
        "namespace-fs",
        "namespace-ipc",
        "namespace-net",
        "namespace-capability"
    ]:
        val state = _proton_require(evidence, item)
        if state != "ready":
            return state
    "ready"

pub fn proton_graphics_translation_gate(evidence: text) -> text:
    for item in ["vulkan-loader", "vulkan-device", "dxvk", "vkd3d-proton", "shader-cache"]:
        val state = _proton_require(evidence, item)
        if state != "ready":
            return state
    "ready"

pub fn proton_steam_integration_gate(evidence: text) -> text:
    for item in ["proton-launcher", "steamworks-bridge", "controller-input"]:
        val state = _proton_require(evidence, item)
        if state != "ready":
            return state
    "ready"

pub fn proton_sync_gate(evidence: text) -> text:
    _proton_require(evidence, "esync-or-fsync")

pub fn proton_non_wine_runtime_gate(evidence: ProtonNonWineRuntimeEvidence) -> text:
    val steam_state = proton_steam_runtime_gate(evidence.steam_runtime)
    if steam_state != "ready":
        return steam_state
    val vessel_state = proton_pressure_vessel_gate(evidence.pressure_vessel)
    if vessel_state != "ready":
        return vessel_state
    val graphics_state = proton_graphics_translation_gate(evidence.graphics)
    if graphics_state != "ready":
        return graphics_state
    val integration_state = proton_steam_integration_gate(evidence.steam_integration)
    if integration_state != "ready":
        return integration_state
    proton_sync_gate(evidence.sync)

pub fn proton_non_wine_feature_evidence(evidence: ProtonNonWineRuntimeEvidence) -> text:
    var features = ""
    for item in ["steam-runtime"]:
        if evidence.steam_runtime.contains(item):
            features = _proton_append_once(features, item)
    for item in ["pressure-vessel-container"]:
        if evidence.pressure_vessel.contains(item):
            features = _proton_append_once(features, item)
    for item in ["proton-launcher", "steamworks-bridge", "controller-input"]:
        if evidence.steam_integration.contains(item):
            features = _proton_append_once(features, item)
    for item in ["vulkan-loader", "vulkan-device", "dxvk", "vkd3d-proton", "shader-cache"]:
        if evidence.graphics.contains(item):
            features = _proton_append_once(features, item)
    if evidence.sync.contains("esync-or-fsync"):
        features = _proton_append_once(features, "esync-or-fsync")
    features

pub fn proton_fixture_non_wine_runtime_evidence() -> ProtonNonWineRuntimeEvidence:
    proton_non_wine_runtime_evidence_new(
        "steam-runtime abi-x86_64 soldier",
        "pressure-vessel-container container-rootfs container-rootfs-nvfs " +
            "namespace-pid namespace-fs namespace-ipc namespace-net namespace-capability",
        "vulkan-loader vulkan-device dxvk vkd3d-proton shader-cache",
        "proton-launcher steamworks-bridge controller-input",
        "esync-or-fsync"
    )
