"""Safe PE image mapping readiness checks before any CPU execution."""

use common.pe_coff_header.{
    pe_section_table_gate,
    pe_section_bounds_gate,
    pe_entry_section_executable_gate,
    pe_entry_point_rva,
    pe_size_of_image,
    pe_size_of_headers,
    pe_rva_to_file_offset
}

pub fn wine_image_map_gate(data: [u8]) -> text:
    val section_state = pe_section_table_gate(data)
    if section_state != "ready":
        return section_state
    val bounds_state = pe_section_bounds_gate(data)
    if bounds_state != "ready":
        return bounds_state
    val entry_rva = pe_entry_point_rva(data)
    if entry_rva <= 0:
        return "missing-entrypoint"
    if pe_rva_to_file_offset(data, entry_rva) < 0:
        return "entrypoint-unmapped"
    val entry_exec_state = pe_entry_section_executable_gate(data)
    if entry_exec_state != "ready":
        return entry_exec_state
    val headers_size = pe_size_of_headers(data)
    val image_size = pe_size_of_image(data)
    if headers_size <= 0:
        return "missing-headers-size"
    if image_size <= headers_size:
        return "bad-image-size"
    "ready"

pub fn wine_image_entry_window_gate(data: [u8], max_bytes: i64) -> text:
    val image_state = wine_image_map_gate(data)
    if image_state != "ready":
        return image_state
    if max_bytes <= 0:
        return "invalid-entry-window"
    val entry_rva = pe_entry_point_rva(data)
    val first_offset = pe_rva_to_file_offset(data, entry_rva)
    val last_offset = pe_rva_to_file_offset(data, entry_rva + max_bytes - 1)
    if first_offset < 0 or last_offset < 0:
        return "entry-window-unmapped"
    if last_offset - first_offset + 1 != max_bytes:
        return "entry-window-not-contiguous"
    if first_offset + max_bytes > data.len():
        return "entry-window-out-of-bounds"
    "ready"
