# Iterator creation functions

class Iterator<T>:
    state: T
    next_fn: fn(T) -> Option<T>

fn iter_from_function<T>(initial: T, step_fn: fn(T) -> Option<T>) -> Iterator<T>:
    """Create an iterator from an initial state and a step function."""
    Iterator(state: initial, next_fn: step_fn)

export Iterator, iter_from_function
