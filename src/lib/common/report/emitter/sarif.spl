# SARIF Emitter
#
# Static Analysis Results Interchange Format (SARIF) v2.1.0 output.
# Provides standardized output for static analysis tools.
# See: https://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html

import ..level
import ..location
import ..report
import ..collector


# =============================================================================
# SarifConfig: Configuration for SARIF output
# =============================================================================

class SarifConfig:
    tool_name: text             # Name of the tool
    tool_version: text          # Tool version
    tool_uri: text?             # Tool information URI
    include_rules: bool         # Include rule definitions
    include_fixes: bool         # Include fix suggestions
    pretty: bool                # Pretty-print JSON

impl SarifConfig:
    static fn default_config() -> SarifConfig:
        SarifConfig(
            tool_name: "simple",
            tool_version: "0.4.0",
            tool_uri: Some("https://github.com/simple-lang/simple"),
            include_rules: true,
            include_fixes: true,
            pretty: false
        )

    static fn for_tool(name: text, version: text) -> SarifConfig:
        SarifConfig(
            tool_name: name,
            tool_version: version,
            tool_uri: nil,
            include_rules: true,
            include_fixes: true,
            pretty: false
        )

# =============================================================================
# SarifTool: Tool information for SARIF
# =============================================================================

struct SarifTool:
    name: text
    version: text
    information_uri: text?

# =============================================================================
# SarifRun: A single run in SARIF output
# =============================================================================

class SarifRun:
    tool: SarifTool
    results: [Report]
    rules: Dict<text, text>     # rule_id -> description

impl SarifRun:
    static fn create(tool: SarifTool) -> SarifRun:
        SarifRun(
            tool: tool,
            results: [],
            rules: {}
        )

    me add_result(report: Report):
        self.results.push(report)

        # Track rules
        if report.code.?:
            val code = report.code.unwrap()
            if not self.rules.has(code):
                self.rules[code] = report.message

    me add_rule(id: text, description: text):
        self.rules[id] = description

# =============================================================================
# SarifEmitter: Emits SARIF v2.1.0 output
# =============================================================================

class SarifEmitter:
    config: SarifConfig

impl SarifEmitter:
    static fn default_emitter() -> SarifEmitter:
        SarifEmitter(config: SarifConfig__default_config())

    static fn with_config(config: SarifConfig) -> SarifEmitter:
        SarifEmitter(config: config)

    # ==========================================================================
    # JSON encoding helpers
    # ==========================================================================

    fn escape_string(s: text) -> text:
        s.replace("\\", "\\\\")
         .replace("\"", "\\\"")
         .replace("\n", "\\n")
         .replace("\r", "\\r")
         .replace("\t", "\\t")

    fn encode_string(s: text) -> text:
        "\"{self.escape_string(s)}\""

    fn nl() -> text:
        if self.config.pretty: "\n" else: ""

    fn ind(level: i64) -> text:
        if self.config.pretty: "  ".repeat(level) else: ""

    # ==========================================================================
    # Level mapping
    # ==========================================================================

    fn level_to_sarif(level: ReportLevel) -> text:
        match level:
            case ReportLevel.Error: "error"
            case ReportLevel.Fatal: "error"
            case ReportLevel.Warning: "warning"
            case ReportLevel.Info: "note"
            case ReportLevel.Debug: "none"

    # ==========================================================================
    # Emit methods
    # ==========================================================================

    fn emit(reports: [Report]) -> text:
        val run = SarifRun__create(SarifTool(
            name: self.config.tool_name,
            version: self.config.tool_version,
            information_uri: self.config.tool_uri
        ))

        for report in reports:
            run.add_result(report)

        self.emit_sarif(run)

    fn emit_collector(collector: ReportCollector) -> text:
        self.emit(collector.filter_displayable())

    fn emit_sarif(run: SarifRun) -> text:
        val nl = self.nl()
        val i1 = self.ind(1)
        val i2 = self.ind(2)
        val i3 = self.ind(3)
        val i4 = self.ind(4)

        var parts: [text] = []
        parts.push("{{$nl}")
        parts.push("{i1}\"$schema\": \"https://json.schemastore.org/sarif-2.1.0.json\",{nl}")
        parts.push("{i1}\"version\": \"2.1.0\",{nl}")
        parts.push("{i1}\"runs\": [{{$nl}")

        # Tool
        parts.push("{i2}\"tool\": {{$nl}")
        parts.push("{i3}\"driver\": {{$nl}")
        parts.push("{i4}\"name\": {self.encode_string(run.tool.name)},{nl}")
        parts.push("{i4}\"version\": {self.encode_string(run.tool.version)}")

        if run.tool.information_uri.?:
            parts.push(",{nl}{i4}\"informationUri\": {self.encode_string(run.tool.information_uri.unwrap())}")

        # Rules
        if self.config.include_rules and not run.rules.is_empty():
            parts.push(",{nl}{i4}\"rules\": [{nl}")
            var first_rule = true
            for rule_id in run.rules.keys():
                if not first_rule:
                    parts.push(",{nl}")
                parts.push("{self.ind(5)}{{$nl}")
                parts.push("{self.ind(6)}\"id\": {self.encode_string(rule_id)},{nl}")
                parts.push("{self.ind(6)}\"shortDescription\": {{\"text\": {self.encode_string(run.rules[rule_id])}}}{nl}")
                parts.push("{self.ind(5)}}")
                first_rule = false
            parts.push("{nl}{i4}]")

        parts.push("{nl}{i3}}}{nl}")  # Close driver
        parts.push("{i2}}},{nl}")     # Close tool

        # Results
        parts.push("{i2}\"results\": [{nl}")
        var first_result = true
        for report in run.results:
            if not first_result:
                parts.push(",{nl}")
            parts.push(self.emit_result(report, 3))
            first_result = false
        parts.push("{nl}{i2}]{nl}")

        parts.push("{i1}}}]{nl}")     # Close runs
        parts.push("}}")              # Close root
        parts.join("")

    fn emit_result(report: Report, indent_level: i64) -> text:
        val nl = self.nl()
        val ind = self.ind(indent_level)
        val ind1 = self.ind(indent_level + 1)
        val ind2 = self.ind(indent_level + 2)

        var parts: [text] = []
        parts.push("{ind}{{$nl}")

        # Rule ID
        if report.code.?:
            parts.push("{ind1}\"ruleId\": {self.encode_string(report.code.unwrap())},{nl}")
        else:
            parts.push("{ind1}\"ruleId\": \"unknown\",{nl}")

        # Level
        parts.push("{ind1}\"level\": {self.encode_string(self.level_to_sarif(report.level))},{nl}")

        # Message
        parts.push("{ind1}\"message\": {{\"text\": {self.encode_string(report.message)}}}")

        # Locations
        if report.location.?:
            parts.push(",{nl}{ind1}\"locations\": [{nl}")
            parts.push(self.emit_physical_location(report.location.unwrap(), indent_level + 2))
            parts.push("{nl}{ind1}]")

        # Related locations (from labels)
        if not report.labels.is_empty():
            parts.push(",{nl}{ind1}\"relatedLocations\": [{nl}")
            var first_label = true
            for label in report.labels:
                if not first_label:
                    parts.push(",{nl}")
                parts.push("{ind2}{{$nl}")
                parts.push("{self.ind(indent_level + 3)}\"message\": {{\"text\": {self.encode_string(label.message)}}},{nl}")
                parts.push("{self.ind(indent_level + 3)}\"physicalLocation\": " + self.emit_physical_location_inline(label.location) + "{nl}")
                parts.push("{ind2}}")
                first_label = false
            parts.push("{nl}{ind1}]")

        # Fixes
        if self.config.include_fixes and not report.suggestions.is_empty():
            parts.push(",{nl}{ind1}\"fixes\": [{nl}")
            var first_fix = true
            for suggestion in report.suggestions:
                if not first_fix:
                    parts.push(",{nl}")
                parts.push(self.emit_fix(suggestion, indent_level + 2))
                first_fix = false
            parts.push("{nl}{ind1}]")

        parts.push("{nl}{ind}}}")
        parts.join("")

    fn emit_physical_location(location: SourceLocation, indent_level: i64) -> text:
        val nl = self.nl()
        val ind = self.ind(indent_level)
        val ind1 = self.ind(indent_level + 1)
        val ind2 = self.ind(indent_level + 2)

        var parts: [text] = []
        parts.push("{ind}{{$nl}")
        parts.push("{ind1}\"physicalLocation\": {{$nl}")
        parts.push("{ind2}\"artifactLocation\": {{\"uri\": {self.encode_string(location.file)}}},{nl}")
        parts.push("{ind2}\"region\": {{$nl}")
        parts.push("{self.ind(indent_level + 3)}\"startLine\": {location.line},{nl}")
        parts.push("{self.ind(indent_level + 3)}\"startColumn\": {location.column}")

        if location.end_line > 0:
            parts.push(",{nl}{self.ind(indent_level + 3)}\"endLine\": {location.end_line}")
        if location.end_column > 0:
            parts.push(",{nl}{self.ind(indent_level + 3)}\"endColumn\": {location.end_column}")

        parts.push("{nl}{ind2}}}{nl}")  # Close region
        parts.push("{ind1}}}{nl}")      # Close physicalLocation
        parts.push("{ind}}}")
        parts.join("")

    fn emit_physical_location_inline(location: SourceLocation) -> text:
        var parts: [text] = []
        parts.push("{\"artifactLocation\": {\"uri\": {self.encode_string(location.file)}}, ")
        parts.push("\"region\": {")
        parts.push("\"startLine\": {location.line}, ")
        parts.push("\"startColumn\": {location.column}")
        if location.end_line > 0:
            parts.push(", \"endLine\": {location.end_line}")
        if location.end_column > 0:
            parts.push(", \"endColumn\": {location.end_column}")
        parts.push("}}")
        parts.join("")

    fn emit_fix(suggestion: Suggestion, indent_level: i64) -> text:
        val nl = self.nl()
        val ind = self.ind(indent_level)
        val ind1 = self.ind(indent_level + 1)
        val ind2 = self.ind(indent_level + 2)

        var parts: [text] = []
        parts.push("{ind}{{$nl}")
        parts.push("{ind1}\"description\": {{\"text\": {self.encode_string(suggestion.message)}}},{nl}")
        parts.push("{ind1}\"artifactChanges\": [{{$nl}")
        parts.push("{ind2}\"artifactLocation\": {{\"uri\": {self.encode_string(suggestion.location.file)}}},{nl}")
        parts.push("{ind2}\"replacements\": [{{$nl}")
        parts.push("{self.ind(indent_level + 3)}\"deletedRegion\": {{$nl}")
        parts.push("{self.ind(indent_level + 4)}\"startLine\": {suggestion.location.line},{nl}")
        parts.push("{self.ind(indent_level + 4)}\"startColumn\": {suggestion.location.column}")
        if suggestion.location.end_line > 0:
            parts.push(",{nl}{self.ind(indent_level + 4)}\"endLine\": {suggestion.location.end_line}")
        if suggestion.location.end_column > 0:
            parts.push(",{nl}{self.ind(indent_level + 4)}\"endColumn\": {suggestion.location.end_column}")
        parts.push("{nl}{self.ind(indent_level + 3)}}},{nl}")
        parts.push("{self.ind(indent_level + 3)}\"insertedContent\": {{\"text\": {self.encode_string(suggestion.new_text)}}}{nl}")
        parts.push("{ind2}}}]{nl}")     # Close replacements
        parts.push("{ind1}}}]{nl}")     # Close artifactChanges
        parts.push("{ind}}}")
        parts.join("")
