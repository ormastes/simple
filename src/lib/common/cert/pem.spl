# PEM constants and base64 re-export for TLS certificate loading.
#
# Provides PEM_CERT_BEGIN, PEM_CERT_END, and base64_decode
# used by std.tls.certificate.

use std.base_encoding.base64.{base64_decode}

val PEM_CERT_BEGIN = "-----BEGIN CERTIFICATE-----"
val PEM_CERT_END = "-----END CERTIFICATE-----"

export use std.base_encoding.base64.{base64_decode}
export PEM_CERT_BEGIN, PEM_CERT_END
