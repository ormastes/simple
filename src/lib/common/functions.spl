"""
# Functional combinators (std.common.functions)

Currying and partial-application helpers. Restored minimal module: the prior
557-line facade depended on modules that no longer exist (std.array,
option_helpers, result_helpers); only these four combinators are used in-tree
(test/feature/usage/curry_partial_spec.spl).
"""

fn curry2(f):
    """Curry a 2-argument function: `curry2(add)(1)(2)` == `add(1, 2)`."""
    \a: \b: f(a, b)

fn curry3(f):
    """Curry a 3-argument function: `curry3(f)(a)(b)(c)` == `f(a, b, c)`."""
    \a: \b: \c: f(a, b, c)

fn partial1(f, a):
    """Partially apply first argument: `partial1(add, 1)(2)` == `add(1, 2)`."""
    \b: f(a, b)

fn partial2(f, a, b):
    """Partially apply first two arguments: `partial2(f, 1, 2)(3)` == `f(1, 2, 3)`."""
    \c: f(a, b, c)

export curry2, curry3, partial1, partial2
