# Base encoding facade — top-level re-exports and convenience helpers.
#
# Consumers that import from std.common.base_encoding directly (not a sub-module):
#   use std.common.base_encoding.{bytes_to_text}   (github.spl)
#
# Sub-module consumers import from:
#   std.common.base_encoding.base64.{base64_encode, base64_decode}
#   std.common.base_encoding.utilities.{text_to_bytes, line_wrap, line_unwrap}
#
# This file provides the top-level helpers only.  The sub-modules live in
# the base_encoding/ directory.

# ============================================================================
# Byte / text conversion helpers
# ============================================================================

fn bytes_to_text(data: [u8]) -> text:
    """Interpret a raw byte slice as UTF-8 text.

    Non-UTF-8 bytes are replaced with the Unicode replacement character U+FFFD.
    This mirrors Rust's String::from_utf8_lossy behaviour.
    """
    var result = ""
    var i = 0
    val n = data.len()
    while i < n:
        val b = data[i] as i64
        if b < 0x80:
            # ASCII fast path
            result = result + _char_from_code(b)
            i = i + 1
        else if b < 0xC0:
            # Unexpected continuation byte
            result = result + "�"
            i = i + 1
        else if b < 0xE0:
            # 2-byte sequence
            if i + 1 < n:
                val b2 = data[i + 1] as i64
                val cp = ((b & 0x1F) << 6) | (b2 & 0x3F)
                result = result + _char_from_code(cp)
                i = i + 2
            else:
                result = result + "�"
                i = i + 1
        else if b < 0xF0:
            # 3-byte sequence
            if i + 2 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val cp = ((b & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
                result = result + _char_from_code(cp)
                i = i + 3
            else:
                result = result + "�"
                i = i + 1
        else:
            # 4-byte sequence (supplementary plane)
            if i + 3 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val b4 = data[i + 3] as i64
                val cp = ((b & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
                result = result + _char_from_code(cp)
                i = i + 4
            else:
                result = result + "�"
                i = i + 1
    result

fn text_to_bytes(s: text) -> [u8]:
    """Encode a text value as a UTF-8 byte slice."""
    var out: [u8] = []
    var i = 0
    val n = s.len()
    while i < n:
        val cp = s.char_at(i) as i64
        if cp < 0x80:
            out = out.push(cp as u8)
        else if cp < 0x800:
            out = out.push(((cp >> 6) | 0xC0) as u8)
            out = out.push(((cp & 0x3F) | 0x80) as u8)
        else if cp < 0x10000:
            out = out.push(((cp >> 12) | 0xE0) as u8)
            out = out.push((((cp >> 6) & 0x3F) | 0x80) as u8)
            out = out.push(((cp & 0x3F) | 0x80) as u8)
        else:
            out = out.push(((cp >> 18) | 0xF0) as u8)
            out = out.push((((cp >> 12) & 0x3F) | 0x80) as u8)
            out = out.push((((cp >> 6) & 0x3F) | 0x80) as u8)
            out = out.push(((cp & 0x3F) | 0x80) as u8)
        i = i + 1
    out

fn _char_from_code(cp: i64) -> text:
    """Convert a Unicode code point to a single-character text.

    Uses the runtime string-from-char primitive.  Falls back to replacement
    character for values outside the valid Unicode range.
    """
    if cp < 0 or cp > 0x10FFFF or (cp >= 0xD800 and cp <= 0xDFFF):
        return "�"
    # The Simple runtime represents text as UTF-8; a single-char string
    # can be built via string interpolation of char_at / the chr built-in.
    # Use the runtime's char cast: text cast from i64 code point.
    # Approximation: build from the known ASCII range inline; for non-ASCII
    # rely on the platform chr() equivalent.  Simple provides `chr(i64)`
    # as a built-in when available; fall back to "\u{hex}" interpolation.
    cp.chr()
