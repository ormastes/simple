@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Collection Helpers — Index-based Access and Mutation

# ============================================================================
# Insert/Remove at Index (#COLL-P1-017, #COLL-P1-018)
# ============================================================================

fn insert_at(arr, idx: i64, item):
    """Return new array with item inserted at index.

    Index is clamped to valid range [0, len].

    sdoctest:
        val result = insert_at([1, 2, 3], 1, 99)
        expect(result.len()).to_equal(4)
        expect(result[1]).to_equal(99)
    """
    var actual_idx = idx
    if actual_idx < 0:
        actual_idx = 0
    if actual_idx > arr.len():
        actual_idx = arr.len()

    var result = []
    var i = 0
    while i < actual_idx:
        result.push(arr[i])
        i = i + 1

    result.push(item)

    while i < arr.len():
        result.push(arr[i])
        i = i + 1

    result

fn remove_at(arr, idx: i64):
    """Return new array with element at index removed.

    Returns the original array unchanged if index is out of bounds.

    sdoctest:
        val result = remove_at([10, 20, 30], 1)
        expect(result.len()).to_equal(2)
        expect(result[0]).to_equal(10)
        expect(result[1]).to_equal(30)
    """
    if idx < 0 or idx >= arr.len():
        return arr

    var result = []
    var i = 0
    while i < arr.len():
        if i != idx:
            result.push(arr[i])
        i = i + 1

    result

# ============================================================================
# Pop / Shift (#COLL-P1-023)
# ============================================================================

fn arr_pop(arr):
    """Remove and return the last element, or nil for empty arrays.

    Returns (remaining_array, popped_element) tuple.

    sdoctest:
        val (rest, last) = arr_pop([1, 2, 3])
        expect(last).to_equal(3)
        expect(rest.len()).to_equal(2)
    """
    if arr.len() == 0:
        return ([], nil)

    var result = []
    var i = 0
    while i < arr.len() - 1:
        result.push(arr[i])
        i = i + 1

    (result, arr[arr.len() - 1])

fn arr_shift(arr):
    """Remove and return the first element, or nil for empty arrays.

    Returns (remaining_array, shifted_element) tuple.

    sdoctest:
        val (rest, first) = arr_shift([1, 2, 3])
        expect(first).to_equal(1)
        expect(rest.len()).to_equal(2)
    """
    if arr.len() == 0:
        return ([], nil)

    var result = []
    var i = 1
    while i < arr.len():
        result.push(arr[i])
        i = i + 1

    (result, arr[0])

# ============================================================================
# Find Last / Find Last Index (#COLL-P1-034, #COLL-P1-035)
# ============================================================================

fn find_last(arr, pred):
    """Return the last element matching predicate, or nil.

    sdoctest:
        expect(find_last([1, 2, 3, 4], \x: x % 2 == 0)).to_equal(4)
        expect(find_last([1, 3, 5], \x: x % 2 == 0)).to_be_nil()
    """
    var i = arr.len() - 1
    while i >= 0:
        if pred(arr[i]):
            return arr[i]
        i = i - 1
    nil

fn find_last_index(arr, pred):
    """Return the index of the last matching element, or nil.

    sdoctest:
        expect(find_last_index([1, 2, 3, 2], \x: x == 2)).to_equal(3)
        expect(find_last_index([1, 3, 5], \x: x == 2)).to_be_nil()
    """
    var i = arr.len() - 1
    while i >= 0:
        if pred(arr[i]):
            return i
        i = i - 1
    nil

# ============================================================================
# At with Negative Index (#COLL-P1-036)
# ============================================================================

fn at(arr, idx: i64):
    """Get element at index, supporting negative indices.

    Negative indices count from the end: -1 is last element.
    Returns nil for out-of-bounds.

    sdoctest:
        expect(at([10, 20, 30], 0)).to_equal(10)
        expect(at([10, 20, 30], -1)).to_equal(30)
        expect(at([10, 20, 30], -2)).to_equal(20)
        expect(at([10, 20, 30], 5)).to_be_nil()
    """
    var actual = idx
    if actual < 0:
        actual = arr.len() + actual

    if actual < 0 or actual >= arr.len():
        return nil

    arr[actual]

# ============================================================================
# Clone (#COLL-P1-037)
# ============================================================================

fn arr_clone(arr):
    """Return a shallow copy of the array.

    sdoctest:
        val original = [1, 2, 3]
        val copy = arr_clone(original)
        expect(copy.len()).to_equal(3)
        expect(copy[0]).to_equal(1)
    """
    var result = []
    for item in arr:
        result.push(item)
    result

# ============================================================================
# Values At (#COLL-P1-019)
# ============================================================================

fn values_at(arr, indices):
    """Get multiple elements by their indices.

    Out-of-bounds indices produce nil entries.

    sdoctest:
        val result = values_at(["a", "b", "c", "d"], [0, 2, 3])
        expect(result.len()).to_equal(3)
        expect(result[0]).to_equal("a")
        expect(result[1]).to_equal("c")
    """
    var result = []
    for idx in indices:
        if idx >= 0 and idx < arr.len():
            result.push(arr[idx])
        else:
            result.push(nil)
    result

# ============================================================================
# Replace Range (#COLL-P1-040)
# ============================================================================

fn replace_range(arr, start: i64, end_idx: i64, items):
    """Replace elements in range [start, end_idx) with items.

    sdoctest:
        val result = replace_range([1, 2, 3, 4, 5], 1, 3, [20, 30, 40])
        expect(result.len()).to_equal(6)
        expect(result[1]).to_equal(20)
    """
    var result = []
    var i = 0
    while i < start and i < arr.len():
        result.push(arr[i])
        i = i + 1

    for item in items:
        result.push(item)

    i = end_idx
    while i < arr.len():
        result.push(arr[i])
        i = i + 1

    result
