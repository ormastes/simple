use compress.types.{CompressionError}
use compress.utilities.{read_u32_le, CompressionSimdTier}
use compress.zstd_types.{ZstdFrameHeader, ZSTD_MAGIC, ZSTD_XXH64_PRIME1, ZSTD_XXH64_PRIME2, ZSTD_XXH64_PRIME3, ZSTD_XXH64_PRIME4, ZSTD_XXH64_PRIME5}

fn _zstd_xxh64_rotl(value: u64, amount: u64) -> u64:
    (value << amount) | (value >> (64u64 - amount))

fn _zstd_xxh64_round(acc: u64, input: u64) -> u64:
    val mixed = (acc + input * ZSTD_XXH64_PRIME2)
    _zstd_xxh64_rotl(mixed, 31u64) * ZSTD_XXH64_PRIME1

fn _zstd_xxh64_merge_round(acc: u64, value: u64) -> u64:
    (acc ^ _zstd_xxh64_round(0u64, value)) * ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME4

fn _zstd_xxh64_avalanche(value: u64) -> u64:
    var acc = value
    acc = acc ^ (acc >> 33u64)
    acc = acc * ZSTD_XXH64_PRIME2
    acc = acc ^ (acc >> 29u64)
    acc = acc * ZSTD_XXH64_PRIME3
    acc ^ (acc >> 32u64)

fn _zstd_read_u64_local(data: [u8], pos: i64) -> Result<u64, CompressionError>:
    if pos < 0 or pos + 8 > data.len():
        return Err(CompressionError.TruncatedInput("zstd need 8 bytes"))
    var value: u64 = 0u64
    var idx = 0
    while idx < 8:
        value = value | (data[pos + idx].to_u64() << (idx * 8).to_u64())
        idx = idx + 1
    Ok(value)

fn _zstd_xxh64_bytes(data: [u8], seed: u64) -> u64:
    _zstd_xxh64_bytes_for_tier(data, seed, CompressionSimdTier.scalar)

fn _zstd_xxh64_bytes_for_tier(data: [u8], seed: u64, tier: CompressionSimdTier) -> u64:
    var idx = 0
    var hash: u64 = 0u64
    val chunk_width = 32  # xxHash64 stripe is always 4×8 bytes; tier drives inner-loop impl only
    if data.len() >= 32:
        var v1 = seed + ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME2
        var v2 = seed + ZSTD_XXH64_PRIME2
        var v3 = seed
        var v4 = seed - ZSTD_XXH64_PRIME1
        while idx + chunk_width <= data.len():
            val w1 = _zstd_read_u64_local(data, idx).unwrap()
            val w2 = _zstd_read_u64_local(data, idx + 8).unwrap()
            val w3 = _zstd_read_u64_local(data, idx + 16).unwrap()
            val w4 = _zstd_read_u64_local(data, idx + 24).unwrap()
            v1 = _zstd_xxh64_round(v1, w1)
            v2 = _zstd_xxh64_round(v2, w2)
            v3 = _zstd_xxh64_round(v3, w3)
            v4 = _zstd_xxh64_round(v4, w4)
            idx = idx + chunk_width
        hash = _zstd_xxh64_rotl(v1, 1u64) +
            _zstd_xxh64_rotl(v2, 7u64) +
            _zstd_xxh64_rotl(v3, 12u64) +
            _zstd_xxh64_rotl(v4, 18u64)
        hash = _zstd_xxh64_merge_round(hash, v1)
        hash = _zstd_xxh64_merge_round(hash, v2)
        hash = _zstd_xxh64_merge_round(hash, v3)
        hash = _zstd_xxh64_merge_round(hash, v4)
    else:
        hash = seed + ZSTD_XXH64_PRIME5
    hash = hash + data.len().to_u64()
    while idx + 8 <= data.len():
        val lane = _zstd_read_u64_local(data, idx).unwrap()
        hash = hash ^ _zstd_xxh64_round(0u64, lane)
        hash = _zstd_xxh64_rotl(hash, 27u64) * ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME4
        idx = idx + 8
    if idx + 4 <= data.len():
        val lane = data[idx].to_u64() |
            (data[idx + 1].to_u64() << 8u64) |
            (data[idx + 2].to_u64() << 16u64) |
            (data[idx + 3].to_u64() << 24u64)
        hash = _zstd_xxh64_rotl(hash ^ (lane * ZSTD_XXH64_PRIME1), 23u64) * ZSTD_XXH64_PRIME2 + ZSTD_XXH64_PRIME3
        idx = idx + 4
    while idx < data.len():
        hash = _zstd_xxh64_rotl(hash ^ (data[idx].to_u64() * ZSTD_XXH64_PRIME5), 11u64) * ZSTD_XXH64_PRIME1
        idx = idx + 1
    _zstd_xxh64_avalanche(hash)

fn _zstd_dictionary_id_field_size(code: i64) -> Result<i64, CompressionError>:
    if code < 0 or code > 3:
        return Err(CompressionError.CorruptStream("zstd dictionary id flag"))
    if code == 0:
        return Ok(0)
    if code == 1:
        return Ok(1)
    if code == 2:
        return Ok(2)
    Ok(4)

fn _zstd_frame_content_size_field_size(flag: i64, single_segment: bool) -> Result<i64, CompressionError>:
    if flag < 0 or flag > 3:
        return Err(CompressionError.CorruptStream("zstd frame content size flag"))
    if flag == 0:
        return Ok(if single_segment: 1 else: 0)
    if flag == 1:
        return Ok(2)
    if flag == 2:
        return Ok(4)
    Ok(8)

fn _zstd_parse_window_size(window_descriptor: i64) -> Result<i64, CompressionError>:
    if window_descriptor < 0 or window_descriptor > 255:
        return Err(CompressionError.CorruptStream("zstd window descriptor"))
    val exponent = window_descriptor >> 3
    val mantissa = window_descriptor & 0x07
    val window_log = 10 + exponent
    val window_base = 1 << window_log
    val window_add = (window_base / 8) * mantissa
    val window_size = window_base + window_add
    if window_size <= 0:
        return Err(CompressionError.CorruptStream("zstd window size"))
    Ok(window_size)

fn _zstd_parse_content_size(input: [u8], pos: i64, size_code: i64, single_segment: bool) -> Result<(i64?, i64), CompressionError>:
    val field_size_res = _zstd_frame_content_size_field_size(size_code, single_segment)
    if field_size_res.is_err():
        return Err(field_size_res.unwrap_err())
    val field_size = field_size_res.unwrap()
    if field_size == 0:
        return Ok((nil, 0))
    if pos + field_size > input.len():
        return Err(CompressionError.TruncatedInput("zstd frame content size"))
    if field_size == 1:
        return Ok((Some(input[pos].to_i64()), 1))
    if field_size == 2:
        return Ok((Some((input[pos].to_i64() | (input[pos + 1].to_i64() << 8)) + 256), 2))
    if field_size == 4:
        val size_res = read_u32_le(input, pos)
        if size_res.is_err():
            return Err(size_res.unwrap_err())
        return Ok((Some(size_res.unwrap().to_i64()), 4))
    val size_res = _zstd_read_u64_local(input, pos)
    if size_res.is_err():
        return Err(size_res.unwrap_err())
    val size = size_res.unwrap()
    if size > 0x7FFFFFFFFFFFFFFFu64:
        return Err(CompressionError.UnsupportedFeature("zstd frame content size exceeds i64"))
    Ok((Some(size.to_i64()), 8))

fn _zstd_parse_dictionary_id(input: [u8], pos: i64, size_code: i64) -> Result<(i64?, i64), CompressionError>:
    val field_size_res = _zstd_dictionary_id_field_size(size_code)
    if field_size_res.is_err():
        return Err(field_size_res.unwrap_err())
    val field_size = field_size_res.unwrap()
    if field_size == 0:
        return Ok((nil, 0))
    if pos + field_size > input.len():
        return Err(CompressionError.TruncatedInput("zstd dictionary id"))
    var value = 0
    if field_size == 1:
        value = input[pos].to_i64()
    elif field_size == 2:
        value = input[pos].to_i64() | (input[pos + 1].to_i64() << 8)
    else:
        value = input[pos].to_i64() |
            (input[pos + 1].to_i64() << 8) |
            (input[pos + 2].to_i64() << 16) |
            (input[pos + 3].to_i64() << 24)
    Ok((if value == 0: nil else: Some(value), field_size))

fn _zstd_parse_frame_header(input: [u8], frame_start: i64) -> Result<ZstdFrameHeader, CompressionError>:
    if frame_start + 5 > input.len():
        return Err(CompressionError.TruncatedInput("zstd frame header"))
    val magic_res = read_u32_le(input, frame_start)
    if magic_res.is_err():
        return Err(magic_res.unwrap_err())
    if magic_res.unwrap() != ZSTD_MAGIC:
        return Err(CompressionError.InvalidHeader("zstd frame magic"))
    val descriptor = input[frame_start + 4].to_i64()
    if ((descriptor >> 3) & 1) == 1:
        return Err(CompressionError.CorruptStream("zstd reserved frame header bit"))
    val single_segment = ((descriptor >> 5) & 1) == 1
    val checksum_flag = ((descriptor >> 2) & 1) == 1
    val dictionary_id_flag = descriptor & 0x03
    val content_size_flag = (descriptor >> 6) & 0x03
    var pos = frame_start + 5
    var window_size = 0
    if not single_segment:
        if pos >= input.len():
            return Err(CompressionError.TruncatedInput("zstd window descriptor"))
        val window_res = _zstd_parse_window_size(input[pos].to_i64())
        if window_res.is_err():
            return Err(window_res.unwrap_err())
        window_size = window_res.unwrap()
        pos = pos + 1
    val dictionary_res = _zstd_parse_dictionary_id(input, pos, dictionary_id_flag)
    if dictionary_res.is_err():
        return Err(dictionary_res.unwrap_err())
    val (dictionary_id, dictionary_used) = dictionary_res.unwrap()
    pos = pos + dictionary_used
    val content_size_res = _zstd_parse_content_size(input, pos, content_size_flag, single_segment)
    if content_size_res.is_err():
        return Err(content_size_res.unwrap_err())
    val (content_size, content_used) = content_size_res.unwrap()
    pos = pos + content_used
    if single_segment:
        window_size = content_size ?? 0
    Ok(ZstdFrameHeader(
        bytes_used: pos - frame_start,
        checksum_flag: checksum_flag,
        window_size: window_size,
        content_size: content_size,
        dictionary_id: dictionary_id
    ))
