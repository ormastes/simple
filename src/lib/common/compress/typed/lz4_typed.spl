# ============================================================================
# common/compress/typed/lz4_typed.spl — LZ4 block codec on LzToken
#
# Implements the LZ4 block format (raw block, no frame header/footer):
#   sequences of:
#     token_byte  (high nibble = literal-length code, low nibble = match-length code)
#     [extra literal-length bytes — 255-continuation when high nibble == 15]
#     literal bytes
#     [if not the last sequence: 2-byte LE offset + optional extra match-length bytes]
#
# Compressor: greedy backward scan on raw input bytes.
#   END_GUARD: no match may start within the last 12 bytes (LZ4 spec rule).
#   Consequently the last 5 bytes are always literals (LZ4 spec rule).
# Decompressor: parses the block format back to output bytes.
#
# LZ4 constants:
#   MIN_MATCH  = 4
#   END_GUARD  = 12   (match start must satisfy: i <= n - 12)
#   LAST_LITS  = 5    (final 5 bytes of input emitted as literals only)
#   MAX_DIST   = 65535
# ============================================================================

use lib.common.compress.typed.types.{LzToken}
use lib.common.bytes.span.{ByteSpan}
use lib.common.bytes.window.{RingWindow}

# ---------------------------------------------------------------------------
# lz4_compress — compress a ByteSpan to LZ4 block bytes
# ---------------------------------------------------------------------------

pub fn lz4_compress(input: ByteSpan) -> ByteSpan:
    """Compress `input` using the LZ4 block format (raw block, no frame).

    Empty input → single 0x00 token byte (zero literals, no match).
    Uses greedy backward scan for matches; matches capped so they cannot
    start within the last 12 bytes of input (LZ4 END_GUARD rule).
    """
    val n = input.len()
    if n == 0:
        var empty_block: [u8] = [0u8]
        return ByteSpan.new(empty_block)

    # Output accumulator
    var out: [u8] = []

    # Position in input
    var i = 0
    # Pending literal buffer
    var lit_buf: [u8] = []

    # The guard: no match may start at position > n - 12.
    # (Positions n-12 .. n-1 all become literals.)
    val safe_end = n - 12

    while i < n:
        # Attempt match only within the safe zone
        var best_len = 0
        var best_dist = 0
        if i <= safe_end:
            var d = 1
            val max_dist = if i < 65535: i else: 65535
            while d <= max_dist:
                # Match cannot extend into the last LAST_LITS=5 bytes
                val max_ml = n - 5 - i
                var ml = 0
                val base = i - d
                while ml < max_ml:
                    if (i + ml) >= n:
                        break
                    if (base + ml) >= i:
                        # Overlapping: the copied bytes will equal what we wrote earlier.
                        # For a pure forward scan comparing input to itself at offset d
                        # this still works: input[base+ml] is the already-scanned byte.
                        # break condition unchanged.
                        if input.get(base + ml) != input.get(i + ml):
                            break
                    else:
                        if input.get(base + ml) != input.get(i + ml):
                            break
                    ml = ml + 1
                if ml >= 4 and ml > best_len:
                    best_len = ml
                    best_dist = d
                d = d + 1

        if best_len >= 4:
            # Emit a sequence: current literal run + this match
            val ll = lit_buf.len()
            val ll_nib = if ll >= 15: 15 else: ll
            val ml_adj = best_len - 4
            val ml_nib = if ml_adj >= 15: 15 else: ml_adj

            # Token byte
            out.push(((ll_nib << 4) | ml_nib).to_u8())

            # Extra literal-length bytes (255-continuation)
            if ll >= 15:
                var rem = ll - 15
                while rem >= 255:
                    out.push(255u8)
                    rem = rem - 255
                out.push(rem.to_u8())

            # Literal bytes
            var li = 0
            while li < ll:
                out.push(lit_buf[li])
                li = li + 1

            # 2-byte LE offset (distance)
            out.push((best_dist & 0xFF).to_u8())
            out.push(((best_dist >> 8) & 0xFF).to_u8())

            # Extra match-length bytes (255-continuation)
            if ml_adj >= 15:
                var rem2 = ml_adj - 15
                while rem2 >= 255:
                    out.push(255u8)
                    rem2 = rem2 - 255
                out.push(rem2.to_u8())

            # Advance past the matched bytes
            i = i + best_len
            # Reset literal buffer
            lit_buf = []
        else:
            # Literal byte
            lit_buf.push(input.get(i))
            i = i + 1

    # Final sequence: remaining literals (no match follows — this is the last sequence)
    val ll = lit_buf.len()
    val ll_nib = if ll >= 15: 15 else: ll
    # Low nibble = 0 (no match length needed for final sequence)
    out.push(((ll_nib << 4) | 0).to_u8())

    if ll >= 15:
        var rem3 = ll - 15
        while rem3 >= 255:
            out.push(255u8)
            rem3 = rem3 - 255
        out.push(rem3.to_u8())

    var lf = 0
    while lf < ll:
        out.push(lit_buf[lf])
        lf = lf + 1

    ByteSpan.new(out)

# ---------------------------------------------------------------------------
# lz4_decompress — decompress LZ4 block bytes to output
# ---------------------------------------------------------------------------

pub fn lz4_decompress(input: ByteSpan, expected_len: i64) -> ByteSpan:
    """Decompress an LZ4 raw block.

    Reads sequences until output reaches `expected_len` bytes.
    Final sequence: token + extra-lit-len + literals only (no offset/match)
    — detected by output reaching expected_len after literal copy.
    """
    var out: [u8] = []
    var pos = 0

    while pos < input.len() and out.len() < expected_len:
        # --- Read token byte ---
        val token = input.get(pos).to_i64()
        pos = pos + 1
        val lit_nib = (token >> 4) & 0xF
        val mat_nib = token & 0xF

        # --- Decode literal length (255-continuation) ---
        var lit_len = lit_nib
        if lit_nib == 15:
            var cont = true
            while cont:
                if pos >= input.len():
                    cont = false
                else:
                    val extra = input.get(pos).to_i64()
                    pos = pos + 1
                    lit_len = lit_len + extra
                    if extra < 255:
                        cont = false

        # --- Copy literal bytes (stop if we reach expected_len) ---
        if pos + lit_len > input.len():
            return ByteSpan.empty()
        var li = 0
        while li < lit_len and out.len() < expected_len:
            if pos >= input.len():
                return ByteSpan.empty()
            out.push(input.get(pos))
            pos = pos + 1
            li = li + 1
        # Advance pos past any remaining literal bytes we skipped
        while li < lit_len:
            pos = pos + 1
            li = li + 1

        # --- Check if done (final sequence has no match) ---
        if out.len() >= expected_len:
            if mat_nib != 0:
                return ByteSpan.empty()
            break
        if pos >= input.len():
            return ByteSpan.empty()

        # --- Read 2-byte LE offset ---
        if pos + 2 > input.len():
            return ByteSpan.empty()
        val off_lo = input.get(pos).to_i64()
        pos = pos + 1
        val off_hi = input.get(pos).to_i64()
        pos = pos + 1
        val distance = off_lo | (off_hi << 8)
        if distance <= 0 or distance > out.len():
            return ByteSpan.empty()

        # --- Decode match length (base 4, plus nibble, plus 255-continuation) ---
        var match_len = mat_nib + 4
        var truncated_match_len = false
        if mat_nib == 15:
            var cont2 = true
            while cont2:
                if pos >= input.len():
                    truncated_match_len = true
                    cont2 = false
                else:
                    val extra2 = input.get(pos).to_i64()
                    pos = pos + 1
                    match_len = match_len + extra2
                    if extra2 < 255:
                        cont2 = false
        if truncated_match_len:
            return ByteSpan.empty()
        if out.len() + match_len > expected_len:
            return ByteSpan.empty()

        # --- Copy match (byte-by-byte, handles overlap correctly) ---
        var mi = 0
        while mi < match_len and out.len() < expected_len:
            val src_idx = out.len() - distance
            var mb = 0u8
            if src_idx >= 0:
                mb = out[src_idx]
            out.push(mb)
            mi = mi + 1

    if out.len() != expected_len:
        return ByteSpan.empty()
    if pos != input.len():
        return ByteSpan.empty()
    ByteSpan.new(out)
