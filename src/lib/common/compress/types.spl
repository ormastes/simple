# Compression shared types — error values and codec identifiers.

pub enum CompressionError:
    """Error returned by compress/decompress operations."""
    TruncatedInput(text)
    InvalidHeader(text)
    CorruptData(text)
    CorruptStream(text)
    Unsupported(text)
    UnsupportedFeature(text)
    OutputTooSmall(text)
    ChecksumMismatch(text)
    SizeLimitExceeded(i64)
    Other(text)

impl CompressionError:
    fn message(self) -> text:
        """Return the human-readable error message."""
        match self:
            case TruncatedInput(m): m
            case InvalidHeader(m): m
            case CorruptData(m): m
            case CorruptStream(m): m
            case Unsupported(m): m
            case UnsupportedFeature(m): m
            case OutputTooSmall(m): m
            case ChecksumMismatch(m): m
            case SizeLimitExceeded(limit): "size limit exceeded"
            case Other(m): m

pub enum CompressionCodec:
    """Identifies a compression algorithm."""
    zstd
    lz4
    deflate
    gzip
    brotli
    lzma2
    identity
