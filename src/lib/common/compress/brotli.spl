# Common brotli facade.
#
# Wraps the RFC 7932 decoder/encoder from:
#   src/lib/nogc_sync_mut/compression/brotli/
#
# Public API:
#   brotli_decompress(data: [u8]) -> [u8]   — returns [] on error
#   brotli_compress(data: [u8]) -> [u8]     — wraps brotli_encode_uncompressed
#   brotli_compress_uncompressed(data: [u8]) -> [u8]

use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.nogc_sync_mut.compression.brotli.encoder.{brotli_encode, brotli_encode_uncompressed}

fn brotli_decompress(data: [u8]) -> [u8]:
    """Decompress a brotli-encoded byte slice.  Returns [] on any error."""
    val result = brotli_decode(data)
    if result.is_err():
        return []
    result.unwrap()

fn brotli_compress(data: [u8]) -> [u8]:
    """Compress a byte slice with brotli (default encoder)."""
    brotli_encode(data)

fn brotli_compress_uncompressed(data: [u8]) -> [u8]:
    """Wrap raw bytes in a brotli uncompressed meta-block stream."""
    brotli_encode_uncompressed(data)
