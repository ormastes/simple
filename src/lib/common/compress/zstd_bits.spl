use compress.types.{CompressionError}

val ZSTD_BITS_MAX_PEEK: i64 = 32
val ZSTD_BITS_REFILL_LIMIT: i64 = 56

struct ZstdBackwardBits:
    data: [u8]
    start: i64
    byte_pos: i64
    reservoir: u64
    bits_in_reservoir: i64

fn zstd_read_u32_le(data: [u8], pos: i64) -> Result<u32, CompressionError>:
    if pos < 0 or pos + 4 > data.len():
        return Err(CompressionError.TruncatedInput("zstd need 4 bytes"))
    Ok(data[pos].to_u32() |
        (data[pos + 1].to_u32() << 8) |
        (data[pos + 2].to_u32() << 16) |
        (data[pos + 3].to_u32() << 24))

fn zstd_read_u64_le(data: [u8], pos: i64) -> Result<u64, CompressionError>:
    if pos < 0 or pos + 8 > data.len():
        return Err(CompressionError.TruncatedInput("zstd need 8 bytes"))
    var value: u64 = 0u64
    var shift: u64 = 0u64
    var idx = pos
    while shift < 64u64:
        value = value | (data[idx].to_u64() << shift)
        shift = shift + 8u64
        idx = idx + 1
    Ok(value)

fn _zstd_low_bits_mask(count: i64) -> u64:
    if count <= 0:
        return 0u64
    if count >= 64:
        return 0xFFFFFFFFFFFFFFFFu64
    (1u64 << count.to_u64()) - 1u64

fn _zstd_highbit_index(value: u8) -> i64:
    var idx = 0
    var probe = value.to_u64()
    while probe > 1u64:
        probe = probe >> 1u64
        idx = idx + 1
    idx

fn _zstd_validate_bit_count(count: i64) -> Result<(), CompressionError>:
    if count < 0:
        return Err(CompressionError.CorruptStream("zstd negative bit count"))
    if count > ZSTD_BITS_MAX_PEEK:
        return Err(CompressionError.UnsupportedFeature("zstd bit peek wider than 32 bits"))
    Ok(())

fn zstd_bits_init(data: [u8], start: i64, end: i64) -> Result<ZstdBackwardBits, CompressionError>:
    if start < 0 or end < start or end > data.len():
        return Err(CompressionError.CorruptStream("zstd bitstream range"))
    if start == end:
        return Err(CompressionError.TruncatedInput("zstd bitstream tail"))
    val tail = data[end - 1]
    if tail == 0u8:
        return Err(CompressionError.CorruptStream("zstd bitstream end mark"))
    val valid_bits = _zstd_highbit_index(tail)
    val reservoir = tail.to_u64() & _zstd_low_bits_mask(valid_bits)
    Ok(ZstdBackwardBits(
        data: data,
        start: start,
        byte_pos: end - 2,
        reservoir: reservoir,
        bits_in_reservoir: valid_bits
    ))

fn zstd_bits_refill(state: ZstdBackwardBits) -> ZstdBackwardBits:
    var next = state
    while next.byte_pos >= next.start and next.bits_in_reservoir <= ZSTD_BITS_REFILL_LIMIT:
        next.reservoir = next.reservoir | (next.data[next.byte_pos].to_u64() << next.bits_in_reservoir.to_u64())
        next.bits_in_reservoir = next.bits_in_reservoir + 8
        next.byte_pos = next.byte_pos - 1
    next

fn zstd_bits_remaining(state: ZstdBackwardBits) -> i64:
    var bytes_left = 0
    if state.byte_pos >= state.start:
        bytes_left = state.byte_pos - state.start + 1
    state.bits_in_reservoir + bytes_left * 8

fn zstd_bits_peek(state: ZstdBackwardBits, count: i64) -> Result<u32, CompressionError>:
    val count_ok = _zstd_validate_bit_count(count)
    if count_ok.is_err():
        return Err(count_ok.unwrap_err())
    val ready = zstd_bits_refill(state)
    if ready.bits_in_reservoir < count:
        return Err(CompressionError.TruncatedInput("zstd bitstream bits"))
    Ok((ready.reservoir & _zstd_low_bits_mask(count)).to_u32())

fn zstd_bits_consume(state: ZstdBackwardBits, count: i64) -> Result<ZstdBackwardBits, CompressionError>:
    val count_ok = _zstd_validate_bit_count(count)
    if count_ok.is_err():
        return Err(count_ok.unwrap_err())
    val ready = zstd_bits_refill(state)
    if ready.bits_in_reservoir < count:
        return Err(CompressionError.TruncatedInput("zstd bitstream bits"))
    Ok(ZstdBackwardBits(
        data: ready.data,
        start: ready.start,
        byte_pos: ready.byte_pos,
        reservoir: ready.reservoir >> count.to_u64(),
        bits_in_reservoir: ready.bits_in_reservoir - count
    ))

fn zstd_bits_read(state: ZstdBackwardBits, count: i64) -> Result<(u32, ZstdBackwardBits), CompressionError>:
    val peeked = zstd_bits_peek(state, count)
    if peeked.is_err():
        return Err(peeked.unwrap_err())
    val next = zstd_bits_consume(state, count)
    if next.is_err():
        return Err(next.unwrap_err())
    Ok((peeked.unwrap(), next.unwrap()))

# MSB-first backward bit reader, matching RFC 8478 Annex A: bytes are read
# from end to start, and within each byte from highest bit to lowest. Used for
# the FSE state stream of FSE-compressed Huffman tree descriptions and for any
# other consumer that has not been written to compensate for the LSB-first
# `ZstdBackwardBits` reader via `zstd_huf_reverse_bits`-style table mirroring.
struct ZstdMsbBackwardBits:
    data: [u8]
    start: i64
    byte_idx: i64
    next_bit: i64
    eof: bool

fn zstd_msb_bits_init(data: [u8], start: i64, end: i64) -> Result<ZstdMsbBackwardBits, CompressionError>:
    if start < 0 or end < start or end > data.len():
        return Err(CompressionError.CorruptStream("zstd msb bitstream range"))
    if start == end:
        return Err(CompressionError.TruncatedInput("zstd msb bitstream tail"))
    val tail = data[end - 1]
    if tail == 0u8:
        return Err(CompressionError.CorruptStream("zstd msb bitstream end mark"))
    val marker = _zstd_highbit_index(tail)
    var byte_idx = end - 1
    var next_bit = marker - 1
    var eof = false
    if next_bit < 0:
        byte_idx = byte_idx - 1
        next_bit = 7
        if byte_idx < start:
            eof = true
    Ok(ZstdMsbBackwardBits(
        data: data,
        start: start,
        byte_idx: byte_idx,
        next_bit: next_bit,
        eof: eof
    ))

fn zstd_msb_bits_remaining(state: ZstdMsbBackwardBits) -> i64:
    if state.eof:
        return 0
    val whole_bytes_left = state.byte_idx - state.start
    (state.next_bit + 1) + 8 * whole_bytes_left

# Read up to `count` bits MSB-first; if the stream ends mid-read, the partial
# value is left-aligned to `count` bits (missing low bits are zero) and `padded`
# is true. This mirrors zstd C's `BIT_reloadDStream`-driven overflow semantics
# without requiring an explicit refill-to-overflow probe.
fn zstd_msb_bits_read(state: ZstdMsbBackwardBits, count: i64) -> Result<(i64, ZstdMsbBackwardBits, bool), CompressionError>:
    if count < 0:
        return Err(CompressionError.CorruptStream("zstd msb negative bit count"))
    if count > 32:
        return Err(CompressionError.UnsupportedFeature("zstd msb bit read wider than 32 bits"))
    if count == 0:
        return Ok((0, state, false))
    var value: i64 = 0
    var consumed_real = 0
    var i = 0
    var byte_idx = state.byte_idx
    var next_bit = state.next_bit
    var eof = state.eof
    while i < count:
        if eof:
            value = value << 1
        else:
            val bit = ((state.data[byte_idx] >> next_bit.to_u8()) & 1u8).to_i64()
            value = (value << 1) | bit
            next_bit = next_bit - 1
            consumed_real = consumed_real + 1
            if next_bit < 0:
                byte_idx = byte_idx - 1
                next_bit = 7
                if byte_idx < state.start:
                    eof = true
        i = i + 1
    val advanced_state = ZstdMsbBackwardBits(
        data: state.data,
        start: state.start,
        byte_idx: byte_idx,
        next_bit: next_bit,
        eof: eof
    )
    val padded = consumed_real < count
    Ok((value, advanced_state, padded))

# MSB-first forward bit writer used by the FSE encoder. Bits are accumulated
# in a 64-bit reservoir and flushed to bytes in little-endian order whenever
# the reservoir reaches >= 8 bits. The final stream is terminated by writing
# a single `1` marker bit immediately after the last data bit (RFC 8478
# §4.1.1 / Annex A "padding"); the bit reader recovers the bit count by
# locating the high-bit of the last byte.
struct ZstdBitWriter:
    bytes: [u8]
    reservoir: u64
    bits_in_reservoir: i64

fn zstd_bit_writer_new() -> ZstdBitWriter:
    ZstdBitWriter(bytes: [], reservoir: 0u64, bits_in_reservoir: 0)

fn _zstd_bit_writer_flush_full_bytes(state: ZstdBitWriter) -> ZstdBitWriter:
    var next = state
    while next.bits_in_reservoir >= 8:
        next.bytes.push((next.reservoir & 0xFFu64).to_u8())
        next.reservoir = next.reservoir >> 8u64
        next.bits_in_reservoir = next.bits_in_reservoir - 8
    next

# Append `count` low bits of `value` to the stream. The low bit of `value`
# becomes the first bit emitted (LSB-first within each value, but the byte
# stream produced is consumed by the backward bit reader which reverses the
# byte order, so within each byte the high bit corresponds to the most
# recently written bit — matching `ZstdBackwardBits` semantics used by the
# Huffman literal stream). For the FSE state stream, callers must instead
# use `zstd_bit_writer_append_msb` so the matching MSB-first reader sees
# state bits in the right order.
fn zstd_bit_writer_append_lsb(state: ZstdBitWriter, value: u64, count: i64) -> Result<ZstdBitWriter, CompressionError>:
    if count < 0:
        return Err(CompressionError.CorruptStream("zstd bit writer negative count"))
    if count == 0:
        return Ok(state)
    if count > 32:
        return Err(CompressionError.UnsupportedFeature("zstd bit writer wider than 32 bits"))
    var next = state
    val mask = _zstd_low_bits_mask(count)
    next.reservoir = next.reservoir | ((value & mask) << next.bits_in_reservoir.to_u64())
    next.bits_in_reservoir = next.bits_in_reservoir + count
    Ok(_zstd_bit_writer_flush_full_bytes(next))

# Append `count` low bits of `value` MSB-first to a stream consumed by the
# `ZstdMsbBackwardBits` reader. The bit reader walks bytes end -> start and
# within each byte reads bit 7 then 6 ... 0; the writer therefore must place
# the most-significant data bit *first* in the byte that will be read first
# (i.e. the last byte written before the terminator) and run downward.
# Implementation: reverse the bit order of `value` over `count` bits and
# call the LSB-first append; the backward reader then sees the original
# ordering.
fn zstd_bit_writer_append_msb(state: ZstdBitWriter, value: u64, count: i64) -> Result<ZstdBitWriter, CompressionError>:
    if count < 0:
        return Err(CompressionError.CorruptStream("zstd bit writer negative count"))
    if count == 0:
        return Ok(state)
    if count > 32:
        return Err(CompressionError.UnsupportedFeature("zstd bit writer wider than 32 bits"))
    var reversed: u64 = 0u64
    var src = value
    var i = 0
    while i < count:
        reversed = (reversed << 1u64) | (src & 1u64)
        src = src >> 1u64
        i = i + 1
    zstd_bit_writer_append_lsb(state, reversed, count)

# Finalise the stream: append a `1` bit marker and pad to the next byte
# boundary with zeroes. The matching reader (`zstd_bits_init` /
# `zstd_msb_bits_init`) locates the marker via `_zstd_highbit_index` of the
# trailing byte, so a non-zero trailing byte is mandatory.
fn zstd_bit_writer_finish(state: ZstdBitWriter) -> Result<[u8], CompressionError>:
    var next = state
    next.reservoir = next.reservoir | (1u64 << next.bits_in_reservoir.to_u64())
    next.bits_in_reservoir = next.bits_in_reservoir + 1
    var flushed = _zstd_bit_writer_flush_full_bytes(next)
    if flushed.bits_in_reservoir > 0:
        flushed.bytes.push((flushed.reservoir & 0xFFu64).to_u8())
        flushed.reservoir = 0u64
        flushed.bits_in_reservoir = 0
    if flushed.bytes.len() == 0:
        return Err(CompressionError.CorruptStream("zstd bit writer produced empty stream"))
    Ok(flushed.bytes)

fn zstd_bit_writer_bits_used(state: ZstdBitWriter) -> i64:
    state.bytes.len() * 8 + state.bits_in_reservoir
