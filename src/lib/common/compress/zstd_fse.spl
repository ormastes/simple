use compress.types.{CompressionError}
use compress.zstd_bits.{ZstdBitWriter, zstd_bit_writer_new, zstd_bit_writer_append_msb, zstd_bit_writer_finish}

val ZSTD_FSE_MIN_TABLE_LOG: i64 = 5

struct ZstdFseNormalizedCounts:
    table_log: i64
    counts: [i64]
    max_symbol: i64
    bytes_used: i64

struct ZstdFseDecodeEntry:
    symbol: i64
    bits: i64
    baseline: i64

struct ZstdFseDecodeTable:
    table_log: i64
    entries: [ZstdFseDecodeEntry]

struct ZstdFseState:
    state: i64

struct ZstdFseForwardBits:
    data: [u8]
    start: i64
    limit: i64
    bit_pos: i64

fn _zstd_fse_highbit(value: i64) -> i64:
    var probe = value
    var bits = 0
    while probe > 1:
        probe = probe >> 1
        bits = bits + 1
    bits

fn _zstd_fse_abs(value: i64) -> i64:
    if value < 0:
        return -value
    value

fn zstd_fse_validate_table_log(table_log: i64, max_table_log: i64) -> Result<(), CompressionError>:
    if max_table_log < ZSTD_FSE_MIN_TABLE_LOG:
        return Err(CompressionError.CorruptStream("zstd fse max table log below minimum"))
    if table_log < ZSTD_FSE_MIN_TABLE_LOG:
        return Err(CompressionError.CorruptStream("zstd fse table log below minimum"))
    if table_log > max_table_log:
        return Err(CompressionError.CorruptStream("zstd fse table log exceeds caller maximum"))
    Ok(())

fn _zstd_fse_forward_bits_init(data: [u8], start: i64, limit: i64) -> Result<ZstdFseForwardBits, CompressionError>:
    if start < 0 or limit < start or limit > data.len():
        return Err(CompressionError.CorruptStream("zstd fse bitstream range"))
    if start >= limit:
        return Err(CompressionError.TruncatedInput("zstd fse bitstream"))
    Ok(ZstdFseForwardBits(data: data, start: start, limit: limit, bit_pos: 0))

fn _zstd_fse_forward_bits_read(state: ZstdFseForwardBits, count: i64) -> Result<(u32, ZstdFseForwardBits), CompressionError>:
    if count < 0 or count > 25:
        return Err(CompressionError.UnsupportedFeature("zstd fse bit read wider than 25 bits"))
    var value: u32 = 0u32
    var shift = 0
    var next = state
    while shift < count:
        val byte_idx = next.start + (next.bit_pos / 8)
        if byte_idx >= next.limit:
            return Err(CompressionError.TruncatedInput("zstd fse normalized counts"))
        val bit_idx = next.bit_pos % 8
        val bit = (next.data[byte_idx] >> bit_idx.to_u8()) & 1u8
        value = value | (bit.to_u32() << shift.to_u32())
        next.bit_pos = next.bit_pos + 1
        shift = shift + 1
    Ok((value, next))

fn _zstd_fse_push_zero_repeat(counts: [i64], repeats: i64, max_symbol: i64) -> Result<[i64], CompressionError>:
    if repeats < 0:
        return Err(CompressionError.CorruptStream("zstd fse negative zero repeat"))
    var result = counts
    var remaining = repeats
    while remaining > 0:
        if result.len() > max_symbol:
            return Err(CompressionError.CorruptStream("zstd fse symbol index exceeds caller maximum"))
        result.push(0)
        remaining = remaining - 1
    Ok(result)

fn zstd_fse_parse_normalized_counts(data: [u8], start: i64, limit: i64, max_table_log: i64, max_symbol: i64) -> Result<ZstdFseNormalizedCounts, CompressionError>:
    if max_symbol < 1:
        return Err(CompressionError.CorruptStream("zstd fse max symbol must allow at least two entries"))
    val init_res = _zstd_fse_forward_bits_init(data, start, limit)
    if init_res.is_err():
        return Err(init_res.unwrap_err())
    var bits = init_res.unwrap()
    val table_res = _zstd_fse_forward_bits_read(bits, 4)
    if table_res.is_err():
        return Err(table_res.unwrap_err())
    val (table_low, after_table) = table_res.unwrap()
    bits = after_table
    val table_log = table_low.to_i64() + ZSTD_FSE_MIN_TABLE_LOG
    val table_ok = zstd_fse_validate_table_log(table_log, max_table_log)
    if table_ok.is_err():
        return Err(table_ok.unwrap_err())

    val table_size = 1 << table_log
    var remaining = table_size + 1
    var threshold = table_size
    var nb_bits = table_log + 1
    var counts: [i64] = []

    while remaining > 1:
        if counts.len() > max_symbol:
            return Err(CompressionError.CorruptStream("zstd fse symbol index exceeds caller maximum"))
        val max_value = (threshold << 1) - 1 - remaining
        val low_res = _zstd_fse_forward_bits_read(bits, nb_bits - 1)
        if low_res.is_err():
            return Err(low_res.unwrap_err())
        val (low, after_low) = low_res.unwrap()
        bits = after_low
        var value = low.to_i64()
        if value >= max_value:
            val high_res = _zstd_fse_forward_bits_read(bits, 1)
            if high_res.is_err():
                return Err(high_res.unwrap_err())
            val (high, after_high) = high_res.unwrap()
            bits = after_high
            value = value | (high.to_i64() << (nb_bits - 1))
            if value >= threshold:
                value = value - max_value
        val count = value - 1
        if count < -1:
            return Err(CompressionError.CorruptStream("zstd fse normalized count below -1"))
        counts.push(count)
        remaining = remaining - _zstd_fse_abs(count)
        if remaining < 1:
            return Err(CompressionError.CorruptStream("zstd fse normalized counts oversubscribed"))
        if count == 0:
            var zero_total = 0
            while true:
                val repeat_res = _zstd_fse_forward_bits_read(bits, 2)
                if repeat_res.is_err():
                    return Err(repeat_res.unwrap_err())
                val (repeat, after_repeat) = repeat_res.unwrap()
                bits = after_repeat
                zero_total = zero_total + repeat.to_i64()
                if repeat != 3u32:
                    break
            val expanded_res = _zstd_fse_push_zero_repeat(counts, zero_total, max_symbol)
            if expanded_res.is_err():
                return Err(expanded_res.unwrap_err())
            counts = expanded_res.unwrap()
        while remaining < threshold:
            nb_bits = nb_bits - 1
            threshold = threshold >> 1
    if counts.len() < 2:
        return Err(CompressionError.CorruptStream("zstd fse needs at least two present symbols"))
    Ok(ZstdFseNormalizedCounts(
        table_log: table_log,
        counts: counts,
        max_symbol: counts.len() - 1,
        bytes_used: (bits.bit_pos + 7) / 8
    ))

fn zstd_fse_build_decode_table(table_log: i64, counts: [i64]) -> Result<ZstdFseDecodeTable, CompressionError>:
    val table_ok = zstd_fse_validate_table_log(table_log, table_log)
    if table_ok.is_err():
        return Err(table_ok.unwrap_err())
    if counts.len() < 2:
        return Err(CompressionError.CorruptStream("zstd fse needs at least two symbols"))

    val table_size = 1 << table_log
    var share_total = 0
    var present = 0
    var i = 0
    while i < counts.len():
        val count = counts[i]
        if count < -1:
            return Err(CompressionError.CorruptStream("zstd fse normalized count below -1"))
        if count != 0:
            present = present + 1
        share_total = share_total + _zstd_fse_abs(count)
        i = i + 1
    if present < 2:
        return Err(CompressionError.CorruptStream("zstd fse needs at least two present symbols"))
    if share_total != table_size:
        return Err(CompressionError.CorruptStream("zstd fse normalized counts must sum to table size"))

    val step = (table_size >> 1) + (table_size >> 3) + 3
    val mask = table_size - 1
    var entries: [ZstdFseDecodeEntry] = []
    var next_states: [i64] = []
    i = 0
    while i < table_size:
        entries.push(ZstdFseDecodeEntry(symbol: -1, bits: 0, baseline: 0))
        i = i + 1
    i = 0
    var high_threshold = table_size - 1
    while i < counts.len():
        val count = counts[i]
        if count == -1:
            entries[high_threshold] = ZstdFseDecodeEntry(symbol: i, bits: 0, baseline: 0)
            next_states.push(1)
            high_threshold = high_threshold - 1
        else:
            next_states.push(if count > 0: count else: 0)
        i = i + 1
    var position = 0
    i = 0
    while i < counts.len():
        val count = counts[i]
        if count > 0:
            var remaining = count
            while remaining > 0:
                while entries[position].symbol >= 0:
                    position = (position + step) & mask
                entries[position] = ZstdFseDecodeEntry(symbol: i, bits: 0, baseline: 0)
                position = (position + step) & mask
                remaining = remaining - 1
            while position > high_threshold and entries[position].symbol >= 0:
                position = (position + step) & mask
        i = i + 1
    i = 0
    while i < entries.len():
        if entries[i].symbol < 0:
            return Err(CompressionError.CorruptStream("zstd fse decode table incomplete"))
        val symbol = entries[i].symbol
        val next_state = next_states[symbol]
        if next_state <= 0:
            return Err(CompressionError.CorruptStream("zstd fse decode table next state"))
        val bits = table_log - _zstd_fse_highbit(next_state)
        val baseline = (next_state << bits) - table_size
        entries[i] = ZstdFseDecodeEntry(symbol: symbol, bits: bits, baseline: baseline)
        next_states[symbol] = next_state + 1
        i = i + 1
    Ok(ZstdFseDecodeTable(table_log: table_log, entries: entries))

fn zstd_fse_init_state(raw_state: i64, table: ZstdFseDecodeTable) -> Result<ZstdFseState, CompressionError>:
    if raw_state < 0 or raw_state >= table.entries.len():
        return Err(CompressionError.CorruptStream("zstd fse initial state"))
    Ok(ZstdFseState(state: raw_state))

fn zstd_fse_get_entry(table: ZstdFseDecodeTable, state: ZstdFseState) -> Result<ZstdFseDecodeEntry, CompressionError>:
    if state.state < 0 or state.state >= table.entries.len():
        return Err(CompressionError.CorruptStream("zstd fse state"))
    Ok(table.entries[state.state])

# ---------------------------------------------------------------------------
# FSE encoder primitives (pure-Simple, RFC 8478 §4.1.1).
#
# The encoder builds the *symbol*-indexed transition table from the same
# normalized counts the decoder uses, then encodes symbols in REVERSE order
# (an FSE encoder property: the decoder reads forward, so the encoder writes
# the bitstream LIFO and the consumer recovers it via a backward bit reader).
# ---------------------------------------------------------------------------

# Per-symbol entry of the encoder transition table. `delta_find_state` and
# `delta_nb_bits` follow the zstd reference encoder layout: given the
# in-flight `state`, the number of bits to flush is
# `(state + delta_nb_bits) >> 16`, and the next state is
# `state_table[(state >> nb_bits) + delta_find_state]`.
struct ZstdFseEncodeSymbolEntry:
    nb_bits: i64
    state_offset: i64
    base: i64
    has_count: bool

struct ZstdFseEncodeTable:
    table_log: i64
    counts: [i64]
    state_table: [i64]
    symbols: [ZstdFseEncodeSymbolEntry]

fn _zstd_fse_spread_positions(counts: [i64], table_log: i64) -> Result<[i64], CompressionError>:
    val table_size = 1 << table_log
    val mask = table_size - 1
    val step = (table_size >> 1) + (table_size >> 3) + 3
    var positions: [i64] = []
    var slot = 0
    while slot < table_size:
        positions.push(-1)
        slot = slot + 1
    var high_threshold = table_size - 1
    var i = 0
    # Symbols with normalized count == -1 (probability 1/table_size) take the
    # high slots, exactly mirroring the decoder.
    while i < counts.len():
        if counts[i] == -1:
            positions[high_threshold] = i
            high_threshold = high_threshold - 1
        i = i + 1
    var position = 0
    i = 0
    while i < counts.len():
        val count = counts[i]
        if count > 0:
            var remaining = count
            while remaining > 0:
                while positions[position] >= 0:
                    position = (position + step) & mask
                positions[position] = i
                position = (position + step) & mask
                remaining = remaining - 1
            while position > high_threshold and positions[position] >= 0:
                position = (position + step) & mask
        i = i + 1
    var slot2 = 0
    while slot2 < positions.len():
        if positions[slot2] < 0:
            return Err(CompressionError.CorruptStream("zstd fse encode spread incomplete"))
        slot2 = slot2 + 1
    Ok(positions)

# Build a symbol-indexed encoder table from normalized counts. The
# `state_table` maps "state >> nb_bits + delta_find_state" -> next state, and
# `symbols` records per-symbol nb_bits / state_offset so that
# `encode_symbol(state, sym) -> (bits_to_emit, nb_bits, next_state)` works
# without re-walking the spread table.
fn zstd_fse_build_encode_table(table_log: i64, counts: [i64]) -> Result<ZstdFseEncodeTable, CompressionError>:
    val table_ok = zstd_fse_validate_table_log(table_log, table_log)
    if table_ok.is_err():
        return Err(table_ok.unwrap_err())
    val table_size = 1 << table_log
    var share_total = 0
    var i = 0
    while i < counts.len():
        share_total = share_total + _zstd_fse_abs(counts[i])
        i = i + 1
    if share_total != table_size:
        return Err(CompressionError.CorruptStream("zstd fse encode counts must sum to table size"))
    val positions_res = _zstd_fse_spread_positions(counts, table_log)
    if positions_res.is_err():
        return Err(positions_res.unwrap_err())
    val positions = positions_res.unwrap()
    # cumulative[s] = first state-table slot for symbol s; symbols with
    # count == -1 occupy the top of the cumulative range (a single slot
    # each with nb_bits == table_log).
    var cumulative: [i64] = []
    var symbols: [ZstdFseEncodeSymbolEntry] = []
    var running = 0
    i = 0
    while i < counts.len():
        cumulative.push(running)
        val count = counts[i]
        var nb_bits = 0
        var state_offset = 0
        var has_count = count != 0
        if count > 0:
            val log = _zstd_fse_highbit(count)
            val sub_threshold = 1 << log
            nb_bits = if count == sub_threshold: log else: log + 1
            state_offset = (count << nb_bits) - table_size
            running = running + count
        elif count == -1:
            nb_bits = table_log
            state_offset = -1
            running = running + 1
        symbols.push(ZstdFseEncodeSymbolEntry(
            nb_bits: nb_bits,
            state_offset: state_offset,
            base: 0,
            has_count: has_count
        ))
        i = i + 1
    if running != table_size:
        return Err(CompressionError.CorruptStream("zstd fse encode running total mismatch"))
    var state_table: [i64] = []
    var slot = 0
    while slot < table_size:
        state_table.push(0)
        slot = slot + 1
    # For each spread slot, the slot's symbol records its assigned next
    # state at index `cumulative[symbol] + symbol_seen_count`. The next
    # state is `slot + table_size` so that after `nb_bits` are emitted the
    # state lies in [table_size, 2*table_size).
    var seen: [i64] = []
    i = 0
    while i < counts.len():
        seen.push(0)
        i = i + 1
    var p = 0
    while p < positions.len():
        val sym = positions[p]
        val idx = cumulative[sym] + seen[sym]
        state_table[idx] = p + table_size
        seen[sym] = seen[sym] + 1
        p = p + 1
    Ok(ZstdFseEncodeTable(
        table_log: table_log,
        counts: counts,
        state_table: state_table,
        symbols: symbols
    ))

fn _zstd_fse_pick_initial_state(table: ZstdFseEncodeTable) -> Result<i64, CompressionError>:
    var sym = 0
    while sym < table.symbols.len():
        if table.symbols[sym].has_count:
            val nb_bits = table.symbols[sym].nb_bits
            val s = (1 << nb_bits) + table.symbols[sym].state_offset
            if s >= 0 and s < table.state_table.len():
                return Ok(table.state_table[s] - (1 << table.table_log))
        sym = sym + 1
    Err(CompressionError.CorruptStream("zstd fse encode no present symbol"))

fn _zstd_fse_encode_one_symbol(table: ZstdFseEncodeTable, state: i64, symbol: i64, writer: ZstdBitWriter) -> Result<(i64, ZstdBitWriter), CompressionError>:
    if symbol < 0 or symbol >= table.symbols.len():
        return Err(CompressionError.CorruptStream("zstd fse encode symbol oor"))
    val entry = table.symbols[symbol]
    if not entry.has_count:
        return Err(CompressionError.CorruptStream("zstd fse encode symbol absent from table"))
    var nb_bits = entry.nb_bits
    if state + entry.state_offset >= 0 and ((state + entry.state_offset) >> table.table_log) > 0:
        nb_bits = entry.nb_bits - 1
    val emit_mask = (1 << nb_bits) - 1
    val emit_bits = state & emit_mask
    val out_writer_res = zstd_bit_writer_append_msb(writer, emit_bits.to_u64(), nb_bits)
    if out_writer_res.is_err():
        return Err(out_writer_res.unwrap_err())
    val next_writer = out_writer_res.unwrap()
    val table_size = 1 << table.table_log
    val cum_idx = (state >> nb_bits.to_u32()).to_i64()
    var sym_seen_idx = 0
    var idx_lookup_sym = 0
    while idx_lookup_sym < symbol:
        sym_seen_idx = sym_seen_idx + _zstd_fse_abs(table.counts[idx_lookup_sym])
        idx_lookup_sym = idx_lookup_sym + 1
    val target_idx = sym_seen_idx + cum_idx
    if target_idx < 0 or target_idx >= table.state_table.len():
        return Err(CompressionError.CorruptStream("zstd fse encode state index oor"))
    val next_state = table.state_table[target_idx] - table_size
    Ok((next_state, next_writer))

# Encode a full symbol stream. Symbols are processed in *reverse* order; the
# initial state is captured from the seed symbol per RFC 8478 §4.1.1. The
# returned bytes are the concatenation of zero or more flushed bytes plus a
# terminator byte; the matching reader is `ZstdMsbBackwardBits`.
fn zstd_fse_encode_symbols(table: ZstdFseEncodeTable, symbols: [i64]) -> Result<[u8], CompressionError>:
    if symbols.len() == 0:
        return Err(CompressionError.CorruptStream("zstd fse encode empty symbol stream"))
    val seed_state_res = _zstd_fse_pick_initial_state(table)
    if seed_state_res.is_err():
        return Err(seed_state_res.unwrap_err())
    var state = seed_state_res.unwrap()
    var writer = zstd_bit_writer_new()
    # Emit the table_log low bits of the initial state first; the decoder
    # reads them last (after consuming the symbol-emitting bits in reverse).
    val init_bits_res = zstd_bit_writer_append_msb(writer, state.to_u64(), table.table_log)
    if init_bits_res.is_err():
        return Err(init_bits_res.unwrap_err())
    writer = init_bits_res.unwrap()
    var idx = symbols.len() - 1
    while idx >= 0:
        val emit_res = _zstd_fse_encode_one_symbol(table, state, symbols[idx], writer)
        if emit_res.is_err():
            return Err(emit_res.unwrap_err())
        val (next_state, next_writer) = emit_res.unwrap()
        state = next_state
        writer = next_writer
        idx = idx - 1
    zstd_bit_writer_finish(writer)
