use compress.types.{CompressionOptions, CompressionError}
use compress.utilities.{write_u16_be, write_u32_le, read_u32_le, read_u64_le, CompressionSimdTier, compression_simd_tier_detect, crc32_bytes, crc32_bytes_for_tier, append_bytes, append_bytes_range}
use compress.lzma2_range_coder.{LzmaProperties, LzmaState, _lzma_parse_props_byte}
use compress.lzma2_chunk_decoder.{Lzma2ChunkState, Lzma2ChunkControl, Lzma2ChunkHeader, _parse_lzma2_chunk_header, _encode_lzma2_uncompressed_payload, _lzma_decode_chunk}
use compress.lzma2_encoder.{_encode_lzma2_payload}

val XZ_HEADER_MAGIC: [u8] = [0xFDu8, 0x37u8, 0x7Au8, 0x58u8, 0x5Au8, 0x00u8]
val XZ_FOOTER_MAGIC_0: u8 = 0x59u8
val XZ_FOOTER_MAGIC_1: u8 = 0x5Au8
val XZ_CHECK_NONE: u8 = 0x00u8
val XZ_CHECK_CRC32: u8 = 0x01u8
val XZ_CHECK_CRC64: u8 = 0x04u8
val XZ_CRC64_POLY_REV: u64 = 0xC96C5795D7870F42u64
val XZ_STREAM_FLAGS_0: u8 = 0x00u8
val XZ_BLOCK_MAX_UNCOMPRESSED: i64 = 65536
val XZ_LZMA2_FILTER_ID: u64 = 0x21u64

struct XzBlockRecord:
    unpadded_size: u64
    uncompressed_size: u64

struct XzBlockHeader:
    header_size: i64
    data_start: i64
    declared_compressed_size: i64?
    declared_uncompressed_size: i64?

struct XzDecodedBlock:
    decoded: [u8]
    next_pos: i64
    record: XzBlockRecord

fn _copy_bytes_range(input: [u8], start: i64, end_idx: i64) -> [u8]:
    append_bytes_range([], input, start, end_idx)

fn _vli_encode(value: u64) -> [u8]:
    var out: [u8] = []
    var v = value
    while true:
        var b = (v & 0x7Fu64).to_u8()
        v = v >> 7u64
        if v != 0u64:
            b = b | 0x80u8
        out.push(b)
        if v == 0u64:
            break
    out

fn _vli_decode(data: [u8], start: i64) -> Result<(u64, i64), CompressionError>:
    var value: u64 = 0u64
    var shift: u64 = 0u64
    var pos = start
    while true:
        if pos >= data.len():
            return Err(CompressionError.TruncatedInput("xz vli"))
        val b = data[pos]
        value = value | ((b & 0x7Fu8).to_u64() << shift)
        pos = pos + 1
        if (b & 0x80u8) == 0u8:
            return Ok((value, pos))
        shift = shift + 7u64
        if shift > 63u64:
            return Err(CompressionError.CorruptStream("xz vli too large"))
    Err(CompressionError.CorruptStream("xz vli"))

fn _vli_to_i64(value: u64, label: text) -> Result<i64, CompressionError>:
    if value > 9223372036854775807u64:
        return Err(CompressionError.SizeLimitExceeded(9223372036854775807))
    Ok(value.to_i64())

fn _lzma2_props_for_level(level: i64) -> u8:
    if level <= 1:
        0x0Au8
    elif level <= 3:
        0x10u8
    elif level <= 6:
        0x16u8
    else:
        0x18u8

fn _xz_check_size(check_type: u8) -> Result<i64, CompressionError>:
    if check_type == XZ_CHECK_NONE:
        return Ok(0)
    if check_type == XZ_CHECK_CRC32:
        return Ok(4)
    if check_type == XZ_CHECK_CRC64:
        return Ok(8)
    Err(CompressionError.UnsupportedFeature("only xz none/crc32/crc64 checks are supported"))

fn _crc64_update_byte(crc: u64, byte: u8) -> u64:
    var next = crc ^ byte.to_u64()
    var bit = 0
    while bit < 8:
        if (next & 1u64) == 1u64:
            next = (next >> 1u64) ^ XZ_CRC64_POLY_REV
        else:
            next = next >> 1u64
        bit = bit + 1
    next

fn _crc64_bytes_for_tier(data: [u8], tier: CompressionSimdTier) -> u64:
    var crc: u64 = 0xFFFFFFFFFFFFFFFFu64
    val chunk_width = match tier:
        CompressionSimdTier.avx2: 32
        CompressionSimdTier.neon: 16
        CompressionSimdTier.scalar: 1
    var idx = 0
    while idx + chunk_width <= data.len():
        var lane = 0
        while lane < chunk_width:
            crc = _crc64_update_byte(crc, data[idx + lane])
            lane = lane + 1
        idx = idx + chunk_width
    while idx < data.len():
        crc = _crc64_update_byte(crc, data[idx])
        idx = idx + 1
    crc ^ 0xFFFFFFFFFFFFFFFFu64

fn _consume_alignment_zeroes(data: [u8], start: i64, pos: i64, label: text) -> Result<i64, CompressionError>:
    var cursor = pos
    while (cursor - start) % 4 != 0:
        if cursor >= data.len():
            return Err(CompressionError.TruncatedInput(label))
        if data[cursor] != 0x00u8:
            return Err(CompressionError.CorruptStream(label))
        cursor = cursor + 1
    Ok(cursor)

fn _validate_lzma_range_decoder_init(data: [u8], pos: i64) -> Result<(), CompressionError>:
    if pos + 5 > data.len():
        return Err(CompressionError.TruncatedInput("lzma2 range decoder init"))
    if data[pos] != 0x00u8:
        return Err(CompressionError.CorruptStream("lzma2 range decoder init"))
    Ok(())

fn _encode_xz_block(input: [u8], props: u8, tier: CompressionSimdTier) -> ([u8], XzBlockRecord):
    val payload = _encode_lzma2_payload(input)
    var block: [u8] = []

    var block_header_body: [u8] = [0xC0u8]
    block_header_body = append_bytes(block_header_body, _vli_encode(payload.len().to_u64()))
    block_header_body = append_bytes(block_header_body, _vli_encode(input.len().to_u64()))
    block_header_body = append_bytes(block_header_body, _vli_encode(XZ_LZMA2_FILTER_ID))
    block_header_body = append_bytes(block_header_body, _vli_encode(1u64))
    block_header_body.push(props)
    while (block_header_body.len() + 1) % 4 != 0:
        block_header_body.push(0x00u8)

    val total_block_header_size = 1 + block_header_body.len() + 4
    val block_header_size = (total_block_header_size / 4).to_u8() - 1u8
    val block_header_start = block.len()
    block.push(block_header_size)
    block = append_bytes(block, block_header_body)
    block = write_u32_le(block, crc32_bytes_for_tier(_copy_bytes_range(block, block_header_start, block.len()), tier))

    block = append_bytes(block, payload)
    while payload.len() % 4 != 0 and (block.len() - total_block_header_size) % 4 != 0:
        block.push(0x00u8)
    block = write_u32_le(block, crc32_bytes_for_tier(input, tier))

    val record = XzBlockRecord(
        unpadded_size: (total_block_header_size + payload.len() + 4).to_u64(),
        uncompressed_size: input.len().to_u64()
    )
    (block, record)

fn _encode_xz_index(records: [XzBlockRecord], tier: CompressionSimdTier) -> [u8]:
    var out: [u8] = [0x00u8]
    out = append_bytes(out, _vli_encode(records.len().to_u64()))
    var i = 0
    while i < records.len():
        out = append_bytes(out, _vli_encode(records[i].unpadded_size))
        out = append_bytes(out, _vli_encode(records[i].uncompressed_size))
        i = i + 1
    while out.len() % 4 != 0:
        out.push(0x00u8)
    write_u32_le(out, crc32_bytes_for_tier(out, tier))

fn _encode_xz_footer(index_size: i64, tier: CompressionSimdTier) -> [u8]:
    val backward_size = (index_size / 4) - 1
    val footer_fields: [u8] = [
        (backward_size & 0xFF).to_u8(),
        ((backward_size >> 8) & 0xFF).to_u8(),
        ((backward_size >> 16) & 0xFF).to_u8(),
        ((backward_size >> 24) & 0xFF).to_u8(),
        XZ_STREAM_FLAGS_0,
        XZ_CHECK_CRC32
    ]
    var out: [u8] = []
    out = write_u32_le(out, crc32_bytes_for_tier(footer_fields, tier))
    out = append_bytes(out, footer_fields)
    out.push(XZ_FOOTER_MAGIC_0)
    out.push(XZ_FOOTER_MAGIC_1)
    out

fn _parse_block_header(input: [u8], block_start: i64, tier: CompressionSimdTier) -> Result<XzBlockHeader, CompressionError>:
    if block_start >= input.len():
        return Err(CompressionError.TruncatedInput("xz block header"))
    val header_size_byte = input[block_start]
    if header_size_byte == 0x00u8:
        return Err(CompressionError.CorruptStream("xz block header size"))
    val header_size = (header_size_byte.to_i64() + 1) * 4
    if block_start + header_size > input.len():
        return Err(CompressionError.TruncatedInput("xz block header"))
    val stored_crc_res = read_u32_le(input, block_start + header_size - 4)
    if stored_crc_res.is_err():
        return Err(stored_crc_res.unwrap_err())
    val actual_crc = crc32_bytes_for_tier(_copy_bytes_range(input, block_start, block_start + header_size - 4), tier)
    if stored_crc_res.unwrap() != actual_crc:
        return Err(CompressionError.ChecksumMismatch("xz block header crc32"))

    val flags = input[block_start + 1]
    if (flags & 0x3Cu8) != 0x00u8:
        return Err(CompressionError.CorruptStream("xz block flags"))
    if (flags & 0x03u8) != 0x00u8:
        return Err(CompressionError.UnsupportedFeature("only one xz filter is supported"))

    var pos = block_start + 2
    var declared_compressed_size: i64? = nil
    var declared_uncompressed_size: i64? = nil
    if (flags & 0x40u8) != 0x00u8:
        val decoded = _vli_decode(input, pos)
        if decoded.is_err():
            return Err(decoded.unwrap_err())
        val comp_size_res = _vli_to_i64(decoded.unwrap().0, "xz block compressed size")
        if comp_size_res.is_err():
            return Err(comp_size_res.unwrap_err())
        declared_compressed_size = comp_size_res.unwrap()
        pos = decoded.unwrap().1
    if (flags & 0x80u8) != 0x00u8:
        val decoded = _vli_decode(input, pos)
        if decoded.is_err():
            return Err(decoded.unwrap_err())
        val uncomp_size_res = _vli_to_i64(decoded.unwrap().0, "xz block uncompressed size")
        if uncomp_size_res.is_err():
            return Err(uncomp_size_res.unwrap_err())
        declared_uncompressed_size = uncomp_size_res.unwrap()
        pos = decoded.unwrap().1

    val filter_id_res = _vli_decode(input, pos)
    if filter_id_res.is_err():
        return Err(filter_id_res.unwrap_err())
    val filter_id = filter_id_res.unwrap().0
    pos = filter_id_res.unwrap().1
    if filter_id != XZ_LZMA2_FILTER_ID:
        return Err(CompressionError.UnsupportedFeature("only xz lzma2 filter chains are supported"))

    val props_size_res = _vli_decode(input, pos)
    if props_size_res.is_err():
        return Err(props_size_res.unwrap_err())
    val props_size = props_size_res.unwrap().0
    pos = props_size_res.unwrap().1
    if props_size != 1u64:
        return Err(CompressionError.UnsupportedFeature("only xz lzma2 single-byte properties are supported"))
    if pos >= block_start + header_size - 4:
        return Err(CompressionError.TruncatedInput("xz lzma2 properties"))
    if input[pos] > 40u8:
        return Err(CompressionError.CorruptStream("xz lzma2 properties"))
    pos = pos + 1

    while pos < block_start + header_size - 4:
        if input[pos] != 0x00u8:
            return Err(CompressionError.CorruptStream("xz block header padding"))
        pos = pos + 1

    Ok(XzBlockHeader(
        header_size: header_size,
        data_start: block_start + header_size,
        declared_compressed_size: declared_compressed_size,
        declared_uncompressed_size: declared_uncompressed_size
    ))

fn _decode_xz_block(input: [u8], block_start: i64, check_type: u8, tier: CompressionSimdTier) -> Result<XzDecodedBlock, CompressionError>:
    val header_res = _parse_block_header(input, block_start, tier)
    if header_res.is_err():
        return Err(header_res.unwrap_err())
    val header = header_res.unwrap()

    var pos = header.data_start
    val payload_start = pos
    val check_size_res = _xz_check_size(check_type)
    if check_size_res.is_err():
        return Err(check_size_res.unwrap_err())
    val check_size = check_size_res.unwrap()
    if header.declared_compressed_size != nil:
        val declared_payload_end = payload_start + (header.declared_compressed_size ?? 0)
        val declared_padded_pos_res = _consume_alignment_zeroes(input, payload_start, declared_payload_end, "xz block padding")
        if declared_padded_pos_res.is_err():
            return Err(declared_padded_pos_res.unwrap_err())
        if declared_padded_pos_res.unwrap() + check_size > input.len():
            return Err(CompressionError.TruncatedInput("xz block check"))
    var out: [u8] = []
    var lzma_st = LzmaState(state: 0, rep0: 0, rep1: 0, rep2: 0, rep3: 0)
    var lzma_probs: [u32] = []
    var lzma_props: u8 = 0u8
    var lzma_props_set = false
    var lzma_parsed_props = LzmaProperties(lc: 3, lp: 0, pb: 2)
    var state = Lzma2ChunkState(need_dict_reset: true, need_props: true)
    while true:
        if pos >= input.len():
            return Err(CompressionError.TruncatedInput("lzma2 control"))
        if input[pos] == 0x00u8:
            pos = pos + 1
            break
        val chunk_res = _parse_lzma2_chunk_header(input, pos, state)
        if chunk_res.is_err():
            return Err(chunk_res.unwrap_err())
        val chunk_pair = chunk_res.unwrap()
        val chunk = chunk_pair.0
        state = chunk_pair.1
        pos = chunk.body_end
        if chunk.control.is_uncompressed:
            out = append_bytes_range(out, input, chunk.body_start, chunk.body_end)
            if chunk.control.resets_dictionary:
                # Dictionary reset on uncompressed chunks zeroes LZMA state too;
                # rep distances are meaningless without surrounding state.
                lzma_st = LzmaState(state: 0, rep0: 0, rep1: 0, rep2: 0, rep3: 0)
            continue
        val range_init_res = _validate_lzma_range_decoder_init(input, chunk.body_start)
        if range_init_res.is_err():
            return Err(range_init_res.unwrap_err())
        if chunk.control.sets_props:
            val props_byte = chunk.props ?? 0u8
            val parsed_res = _lzma_parse_props_byte(props_byte)
            if parsed_res.is_err():
                return Err(parsed_res.unwrap_err())
            lzma_props = props_byte
            lzma_parsed_props = parsed_res.unwrap()
            lzma_props_set = true
        if not lzma_props_set:
            # No props yet -- only chunks 0xC0-0xFF set props, and the
            # _parse_lzma2_chunk_header guard on `need_props` should already
            # have rejected this. Defensive only.
            return Err(CompressionError.CorruptStream("lzma2 properties"))
        if chunk.control.resets_state:
            lzma_st = LzmaState(state: 0, rep0: 0, rep1: 0, rep2: 0, rep3: 0)
        # Reset prob tables on full-state-reset chunks (controls >= 0xA0); the
        # higher bits already imply state reset via `_decode_lzma2_chunk_control`.
        val reset_probs = chunk.control.resets_state or lzma_probs.len() == 0
        val decoded = _lzma_decode_chunk(
            input,
            chunk.body_start,
            chunk.body_end,
            chunk.uncompressed_size,
            out,
            lzma_st,
            lzma_probs,
            reset_probs,
            lzma_parsed_props
        )
        if decoded.is_err():
            return Err(decoded.unwrap_err())
        val triple = decoded.unwrap()
        out = triple.0
        lzma_st = triple.1
        lzma_probs = triple.2
    val payload_size = pos - payload_start

    if header.declared_compressed_size != nil and (header.declared_compressed_size ?? -1) != payload_size:
        return Err(CompressionError.CorruptStream("xz block compressed size"))
    if header.declared_uncompressed_size != nil and (header.declared_uncompressed_size ?? -1) != out.len():
        return Err(CompressionError.CorruptStream("xz block uncompressed size"))

    val padded_pos_res = _consume_alignment_zeroes(input, payload_start, pos, "xz block padding")
    if padded_pos_res.is_err():
        return Err(padded_pos_res.unwrap_err())
    pos = padded_pos_res.unwrap()

    if pos + check_size > input.len():
        return Err(CompressionError.TruncatedInput("xz block check"))
    if check_type == XZ_CHECK_CRC32:
        val stored_check_res = read_u32_le(input, pos)
        if stored_check_res.is_err():
            return Err(stored_check_res.unwrap_err())
        if stored_check_res.unwrap() != crc32_bytes_for_tier(out, tier):
            return Err(CompressionError.ChecksumMismatch("xz block crc32"))
    elif check_type == XZ_CHECK_CRC64:
        val stored_check_res = read_u64_le(input, pos)
        if stored_check_res.is_err():
            return Err(stored_check_res.unwrap_err())
        if stored_check_res.unwrap() != _crc64_bytes_for_tier(out, tier):
            return Err(CompressionError.ChecksumMismatch("xz block crc64"))

    Ok(XzDecodedBlock(
        decoded: out,
        next_pos: pos + check_size,
        record: XzBlockRecord(
            unpadded_size: (header.header_size + payload_size + check_size).to_u64(),
            uncompressed_size: out.len().to_u64()
        )
    ))

fn _parse_xz_index(input: [u8], index_start: i64, records: [XzBlockRecord], tier: CompressionSimdTier) -> Result<i64, CompressionError>:
    if index_start >= input.len():
        return Err(CompressionError.TruncatedInput("xz index"))
    if input[index_start] != 0x00u8:
        return Err(CompressionError.CorruptStream("xz index marker"))

    val record_count_res = _vli_decode(input, index_start + 1)
    if record_count_res.is_err():
        return Err(record_count_res.unwrap_err())
    if record_count_res.unwrap().0 != records.len().to_u64():
        return Err(CompressionError.CorruptStream("xz index record count"))

    var pos = record_count_res.unwrap().1
    var i = 0
    while i < records.len():
        val up_res = _vli_decode(input, pos)
        if up_res.is_err():
            return Err(up_res.unwrap_err())
        pos = up_res.unwrap().1
        val uc_res = _vli_decode(input, pos)
        if uc_res.is_err():
            return Err(uc_res.unwrap_err())
        pos = uc_res.unwrap().1
        if up_res.unwrap().0 != records[i].unpadded_size:
            return Err(CompressionError.CorruptStream("xz index unpadded size"))
        if uc_res.unwrap().0 != records[i].uncompressed_size:
            return Err(CompressionError.CorruptStream("xz index uncompressed size"))
        i = i + 1

    val padded_pos_res = _consume_alignment_zeroes(input, index_start, pos, "xz index padding")
    if padded_pos_res.is_err():
        return Err(padded_pos_res.unwrap_err())
    pos = padded_pos_res.unwrap()
    if pos + 4 > input.len():
        return Err(CompressionError.TruncatedInput("xz index crc32"))
    val stored_crc_res = read_u32_le(input, pos)
    if stored_crc_res.is_err():
        return Err(stored_crc_res.unwrap_err())
    if stored_crc_res.unwrap() != crc32_bytes_for_tier(_copy_bytes_range(input, index_start, pos), tier):
        return Err(CompressionError.ChecksumMismatch("xz index crc32"))
    Ok(pos + 4)

fn _decompress_xz_stream(input: [u8], start: i64, tier: CompressionSimdTier) -> Result<([u8], i64), CompressionError>:
    if start + 12 > input.len():
        return Err(CompressionError.TruncatedInput("xz stream"))
    var i = 0
    while i < XZ_HEADER_MAGIC.len():
        if input[start + i] != XZ_HEADER_MAGIC[i]:
            return Err(CompressionError.InvalidHeader("xz header magic"))
        i = i + 1
    val stream_flags_0 = input[start + 6]
    val stream_flags_1 = input[start + 7]
    if stream_flags_0 != XZ_STREAM_FLAGS_0:
        return Err(CompressionError.CorruptStream("xz stream flags"))
    val header_crc_res = read_u32_le(input, start + 8)
    if header_crc_res.is_err():
        return Err(header_crc_res.unwrap_err())
    val stream_flags: [u8] = [stream_flags_0, stream_flags_1]
    if header_crc_res.unwrap() != crc32_bytes_for_tier(stream_flags, tier):
        return Err(CompressionError.ChecksumMismatch("xz header crc32"))
    val check_size_res = _xz_check_size(stream_flags_1)
    if check_size_res.is_err():
        return Err(check_size_res.unwrap_err())

    var pos = start + 12
    var decoded: [u8] = []
    var records: [XzBlockRecord] = []
    while pos < input.len() and input[pos] != 0x00u8:
        val block_res = _decode_xz_block(input, pos, stream_flags_1, tier)
        if block_res.is_err():
            return Err(block_res.unwrap_err())
        decoded = append_bytes(decoded, block_res.unwrap().decoded)
        records.push(block_res.unwrap().record)
        pos = block_res.unwrap().next_pos
    if pos >= input.len():
        return Err(CompressionError.TruncatedInput("xz index"))

    val index_start = pos
    val footer_start_res = _parse_xz_index(input, index_start, records, tier)
    if footer_start_res.is_err():
        return Err(footer_start_res.unwrap_err())
    val footer_start = footer_start_res.unwrap()
    if footer_start + 12 > input.len():
        return Err(CompressionError.TruncatedInput("xz footer"))
    if input[footer_start + 10] != XZ_FOOTER_MAGIC_0 or input[footer_start + 11] != XZ_FOOTER_MAGIC_1:
        return Err(CompressionError.InvalidHeader("xz footer magic"))

    val footer_crc_res = read_u32_le(input, footer_start)
    if footer_crc_res.is_err():
        return Err(footer_crc_res.unwrap_err())
    val footer_fields = _copy_bytes_range(input, footer_start + 4, footer_start + 10)
    if footer_crc_res.unwrap() != crc32_bytes_for_tier(footer_fields, tier):
        return Err(CompressionError.ChecksumMismatch("xz footer crc32"))

    val backward_size_res = read_u32_le(input, footer_start + 4)
    if backward_size_res.is_err():
        return Err(backward_size_res.unwrap_err())
    val computed_index_size = footer_start - index_start
    if ((backward_size_res.unwrap().to_i64() + 1) * 4) != computed_index_size:
        return Err(CompressionError.CorruptStream("xz backward size"))

    if input[footer_start + 8] != stream_flags_0 or input[footer_start + 9] != stream_flags_1:
        return Err(CompressionError.CorruptStream("xz footer flags"))

    Ok((decoded, footer_start + 12))

fn lzma2_compress_xz(input: [u8], options: CompressionOptions) -> [u8]:
    lzma2_compress_xz_for_tier(input, options, compression_simd_tier_detect())

fn lzma2_compress_xz_for_tier(input: [u8], options: CompressionOptions, tier: CompressionSimdTier) -> [u8]:
    var out: [u8] = []
    out = append_bytes(out, XZ_HEADER_MAGIC)
    val stream_flags: [u8] = [XZ_STREAM_FLAGS_0, XZ_CHECK_CRC32]
    out = append_bytes(out, stream_flags)
    out = write_u32_le(out, crc32_bytes_for_tier(stream_flags, tier))

    val props = _lzma2_props_for_level(options.level.value)
    var records: [XzBlockRecord] = []
    var pos = 0
    while pos < input.len():
        val block_len = if input.len() - pos > XZ_BLOCK_MAX_UNCOMPRESSED: XZ_BLOCK_MAX_UNCOMPRESSED else: input.len() - pos
        val encoded = _encode_xz_block(_copy_bytes_range(input, pos, pos + block_len), props, tier)
        out = append_bytes(out, encoded.0)
        records.push(encoded.1)
        pos = pos + block_len

    val index = _encode_xz_index(records, tier)
    out = append_bytes(out, index)
    out = append_bytes(out, _encode_xz_footer(index.len(), tier))
    out

fn lzma2_decompress_xz(input: [u8]) -> Result<[u8], CompressionError>:
    lzma2_decompress_xz_for_tier(input, compression_simd_tier_detect())

fn lzma2_decompress_xz_for_tier(input: [u8], tier: CompressionSimdTier) -> Result<[u8], CompressionError>:
    if input.len() < 24:
        return Err(CompressionError.TruncatedInput("xz stream"))
    var pos = 0
    var out: [u8] = []
    while pos < input.len():
        if input[pos] == 0x00u8:
            var padding = 0
            while pos < input.len() and input[pos] == 0x00u8:
                pos = pos + 1
                padding = padding + 1
            if padding % 4 != 0:
                return Err(CompressionError.CorruptStream("xz stream padding"))
            continue
        val stream_res = _decompress_xz_stream(input, pos, tier)
        if stream_res.is_err():
            return Err(stream_res.unwrap_err())
        out = append_bytes(out, stream_res.unwrap().0)
        pos = stream_res.unwrap().1
    Ok(out)
