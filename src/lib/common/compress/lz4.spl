use compress.types.{CompressionOptions, CompressionError}
use compress.utilities.{write_u16_le, write_u32_le, write_u64_le, read_u16_le, read_u32_le, read_u64_le, CompressionSimdTier, compression_simd_tier_detect, xxhash32_bytes_for_tier, append_bytes, append_self_overlap_copy}

val LZ4_FRAME_MAGIC: u32 = 0x184D2204u32
val LZ4_MAX_OFFSET: i64 = 65535
val LZ4_MIN_MATCH: i64 = 4
val LZ4_FRAME_MAX_BLOCK_SIZE: i64 = 65536
val LZ4_HASH_LOG: i64 = 12
val LZ4_HASH_SIZE: i64 = 1 << LZ4_HASH_LOG

fn _lz4_search_depth(level: i64) -> i64:
    if level <= 1:
        return 0
    val scaled = 4 + ((level - 2) * 4)
    if scaled > 64: 64 else: scaled

fn _lz4_hash_sequence(input: [u8], pos: i64) -> i64:
    val b0 = input[pos].to_i64()
    val b1 = input[pos + 1].to_i64()
    val b2 = input[pos + 2].to_i64()
    val b3 = input[pos + 3].to_i64()
    ((b0 * 251) + (b1 * 509) + (b2 * 1021) + (b3 * 2039)) % LZ4_HASH_SIZE

fn _lz4_match_length(input: [u8], left: i64, right: i64) -> i64:
    var length = 0
    while right + length < input.len() and input[left + length] == input[right + length]:
        length = length + 1
    length

fn _lz4_repeat_i64(value: i64, count: i64) -> [i64]:
    var result: [i64] = []
    var idx = 0
    while idx < count:
        result.push(value)
        idx = idx + 1
    result

fn _lz4_empty_u8() -> [u8]:
    []

fn _lz4_emit_sequence(out: [u8], input: [u8], literal_start: i64, match_start: i64, offset: i64, match_len: i64) -> [u8]:
    var result = out
    val literal_len = match_start - literal_start
    val literal_nibble = if literal_len > 15: 15 else: literal_len
    val match_extra = match_len - LZ4_MIN_MATCH
    val match_nibble = if match_extra > 15: 15 else: match_extra
    result.push(((literal_nibble.to_u8() << 4) | match_nibble.to_u8()))
    if literal_len >= 15:
        result = _lz4_emit_length(result, literal_len - 15)
    result = append_bytes(result, input.slice(literal_start, match_start))
    result = write_u16_le(result, offset.to_u16())
    if match_extra >= 15:
        result = _lz4_emit_length(result, match_extra - 15)
    result

fn _lz4_emit_last_literals(out: [u8], input: [u8], literal_start: i64) -> [u8]:
    var result = out
    val tail_len = input.len() - literal_start
    val tail_nibble = if tail_len > 15: 15 else: tail_len
    result.push((tail_nibble.to_u8() << 4))
    if tail_len >= 15:
        result = _lz4_emit_length(result, tail_len - 15)
    append_bytes(result, input.slice(literal_start, input.len()))

fn _lz4_compress_block_greedy(input: [u8], level: i64) -> [u8]:
    if input.len() < LZ4_MIN_MATCH:
        return _lz4_emit_last_literals(_lz4_empty_u8(), input, 0)

    val search_depth = _lz4_search_depth(level)
    if search_depth == 0:
        return _lz4_emit_last_literals(_lz4_empty_u8(), input, 0)

    var head = _lz4_repeat_i64(-1, LZ4_HASH_SIZE)
    var prev = _lz4_repeat_i64(-1, input.len())
    var out: [u8] = []
    var literal_start = 0
    var pos = 0
    val last_match_start = input.len() - LZ4_MIN_MATCH

    while pos <= last_match_start:
        val hash = _lz4_hash_sequence(input, pos)
        prev[pos] = head[hash]
        head[hash] = pos

        var candidate = prev[pos]
        var attempts = 0
        var best_len = 0
        var best_offset = 0
        while candidate >= 0 and attempts < search_depth:
            val offset = pos - candidate
            if offset > LZ4_MAX_OFFSET:
                break
            val candidate_matches = input[candidate] == input[pos] and input[candidate + 1] == input[pos + 1] and input[candidate + 2] == input[pos + 2] and input[candidate + 3] == input[pos + 3]
            if candidate_matches:
                val match_len = _lz4_match_length(input, candidate, pos)
                if match_len > best_len:
                    best_len = match_len
                    best_offset = offset
            candidate = prev[candidate]
            attempts = attempts + 1

        if best_len >= LZ4_MIN_MATCH:
            out = _lz4_emit_sequence(out, input, literal_start, pos, best_offset, best_len)
            val next_pos = pos + best_len
            var insert = pos + 1
            while insert < next_pos and insert <= last_match_start:
                val insert_hash = _lz4_hash_sequence(input, insert)
                prev[insert] = head[insert_hash]
                head[insert_hash] = insert
                insert = insert + 1
            pos = next_pos
            literal_start = pos
        else:
            pos = pos + 1
    _lz4_emit_last_literals(out, input, literal_start)

fn _lz4_emit_length(out: [u8], value: i64) -> [u8]:
    var result = out
    var remaining = value
    while remaining >= 255:
        result.push(255u8)
        remaining = remaining - 255
    result.push(remaining.to_u8())
    result

fn _lz4_compress_block_with_level(input: [u8], level: i64) -> [u8]:
    if level < 0:
        return []
    _lz4_compress_block_greedy(input, level)

fn lz4_compress_block(input: [u8]) -> [u8]:
    _lz4_compress_block_with_level(input, 1)

fn lz4_compress_block_with_level(input: [u8], level: i64) -> [u8]:
    _lz4_compress_block_with_level(input, level)

fn lz4_decompress_block(input: [u8]) -> Result<[u8], CompressionError>:
    var out: [u8] = []
    var pos = 0
    while pos < input.len():
        val token = input[pos].to_i64()
        pos = pos + 1
        var literal_len = token >> 4
        if literal_len == 15:
            while true:
                if pos >= input.len():
                    return Err(CompressionError.TruncatedInput("lz4 literal extension"))
                val extra = input[pos].to_i64()
                pos = pos + 1
                literal_len = literal_len + extra
                if extra != 255:
                    break
        if pos + literal_len > input.len():
            return Err(CompressionError.TruncatedInput("lz4 literal body"))
        out = append_bytes(out, input.slice(pos, pos + literal_len))
        pos = pos + literal_len
        if pos >= input.len():
            break
        val offset_res = read_u16_le(input, pos)
        if offset_res.is_err():
            return Err(offset_res.unwrap_err())
        val offset = offset_res.unwrap().to_i64()
        if offset <= 0 or offset > out.len():
            return Err(CompressionError.CorruptStream("lz4 invalid match offset"))
        pos = pos + 2
        var match_len = (token & 0x0F) + LZ4_MIN_MATCH
        if (token & 0x0F) == 15:
            while true:
                if pos >= input.len():
                    return Err(CompressionError.TruncatedInput("lz4 match extension"))
                val extra = input[pos].to_i64()
                pos = pos + 1
                match_len = match_len + extra
                if extra != 255:
                    break
        val copy_res = append_self_overlap_copy(out, offset, match_len)
        if copy_res.is_err():
            return Err(copy_res.unwrap_err())
        out = copy_res.unwrap()
        if out.len() > 134217728:
            return Err(CompressionError.SizeLimitExceeded(134217728))
    Ok(out)

fn _lz4_frame_descriptor(options: CompressionOptions, input_len: i64) -> [u8]:
    var desc: [u8] = []
    var flg: u8 = 0x60u8
    flg = flg | 0x20u8
    if options.checksum:
        flg = flg | 0x10u8
        flg = flg | 0x04u8
    if options.content_size != nil:
        flg = flg | 0x08u8
    desc.push(flg)
    desc.push(0x40u8)
    if options.content_size != nil:
        desc = write_u64_le(desc, (options.content_size ?? input_len).to_u64())
    desc

fn _lz4_block_bytes(input: [u8], start: i64, limit: i64) -> [u8]:
    var result: [u8] = []
    val end = if start + limit > input.len(): input.len() else: start + limit
    var pos = start
    while pos < end:
        result.push(input[pos])
        pos = pos + 1
    result

fn lz4_compress_frame(input: [u8], options: CompressionOptions) -> [u8]:
    lz4_compress_frame_for_tier(input, options, compression_simd_tier_detect())

fn lz4_compress_frame_for_tier(input: [u8], options: CompressionOptions, tier: CompressionSimdTier) -> [u8]:
    var out: [u8] = []
    out = write_u32_le(out, LZ4_FRAME_MAGIC)
    val desc = _lz4_frame_descriptor(options, input.len())
    out = append_bytes(out, desc)
    val hc = ((xxhash32_bytes_for_tier(desc, 0u32, tier) >> 8u32) & 0xFFu32).to_u8()
    out.push(hc)

    val level = options.level.value
    var pos = 0
    while pos < input.len():
        val block = _lz4_block_bytes(input, pos, LZ4_FRAME_MAX_BLOCK_SIZE)
        val compressed = _lz4_compress_block_with_level(block, level)
        val stored = if compressed.len() >= block.len(): block else: compressed
        val is_raw = compressed.len() >= block.len()
        val size_word = if is_raw:
            0x80000000u32 | stored.len().to_u32()
        else:
            stored.len().to_u32()
        out = write_u32_le(out, size_word)
        out = append_bytes(out, stored)
        if options.checksum:
            out = write_u32_le(out, xxhash32_bytes_for_tier(stored, 0u32, tier))
        pos = pos + block.len()
    out = write_u32_le(out, 0u32)
    if options.checksum:
        out = write_u32_le(out, xxhash32_bytes_for_tier(input, 0u32, tier))
    out

fn _lz4_parse_max_block_size(bd: u8) -> Result<i64, CompressionError>:
    val code = (bd >> 4u8).to_i64()
    if (bd & 0x8Fu8) != 0u8:
        return Err(CompressionError.CorruptStream("lz4 reserved bd bits"))
    match code:
        4: Ok(65536)
        5: Ok(262144)
        6: Ok(1048576)
        7: Ok(4194304)
        _: Err(CompressionError.UnsupportedFeature("lz4 max block size code is not supported"))

fn _lz4_take_slice(input: [u8], start: i64, length: i64, label: text) -> Result<[u8], CompressionError>:
    if start + length > input.len():
        return Err(CompressionError.TruncatedInput(label))
    var result: [u8] = []
    var pos = start
    while pos < start + length:
        result.push(input[pos])
        pos = pos + 1
    Ok(result)

fn lz4_decompress_frame(input: [u8]) -> Result<[u8], CompressionError>:
    lz4_decompress_frame_for_tier(input, compression_simd_tier_detect())

fn lz4_decompress_frame_for_tier(input: [u8], tier: CompressionSimdTier) -> Result<[u8], CompressionError>:
    val magic_res = read_u32_le(input, 0)
    if magic_res.is_err():
        return Err(magic_res.unwrap_err())
    if magic_res.unwrap() != LZ4_FRAME_MAGIC:
        return Err(CompressionError.InvalidHeader("lz4 frame magic"))
    if input.len() < 7:
        return Err(CompressionError.TruncatedInput("lz4 frame header"))

    val flg = input[4]
    val bd = input[5]
    if (flg >> 6u8) != 0x01u8:
        return Err(CompressionError.InvalidHeader("lz4 frame version"))
    if (flg & 0x02u8) != 0u8:
        return Err(CompressionError.CorruptStream("lz4 reserved flg bit"))
    if (flg & 0x20u8) == 0u8:
        return Err(CompressionError.UnsupportedFeature("lz4 dependent blocks are not supported"))

    val has_block_checksum = (flg & 0x10u8) != 0u8
    val has_content_size = (flg & 0x08u8) != 0u8
    val has_content_checksum = (flg & 0x04u8) != 0u8
    val has_dict_id = (flg & 0x01u8) != 0u8
    val max_block_size_res = _lz4_parse_max_block_size(bd)
    if max_block_size_res.is_err():
        return Err(max_block_size_res.unwrap_err())
    val max_block_size = max_block_size_res.unwrap()

    var desc: [u8] = [flg, bd]
    var pos = 6
    var declared_content_size: i64? = nil
    if has_content_size:
        val size_res = read_u64_le(input, pos)
        if size_res.is_err():
            return Err(CompressionError.TruncatedInput("lz4 content size"))
        val size = size_res.unwrap().to_i64()
        declared_content_size = size
        desc = write_u64_le(desc, size.to_u64())
        pos = pos + 8
    if has_dict_id:
        val dict_res = read_u32_le(input, pos)
        if dict_res.is_err():
            return Err(CompressionError.TruncatedInput("lz4 dictionary id"))
        desc = write_u32_le(desc, dict_res.unwrap())
        pos = pos + 4
    if pos >= input.len():
        return Err(CompressionError.TruncatedInput("lz4 header checksum"))
    val expected_hc = ((xxhash32_bytes_for_tier(desc, 0u32, tier) >> 8u32) & 0xFFu32).to_u8()
    if input[pos] != expected_hc:
        return Err(CompressionError.ChecksumMismatch("lz4 header checksum"))
    pos = pos + 1
    if has_dict_id:
        return Err(CompressionError.UnsupportedFeature("lz4 dictionary frames are not supported"))

    var out: [u8] = []
    while true:
        val size_res = read_u32_le(input, pos)
        if size_res.is_err():
            return Err(size_res.unwrap_err())
        val size_word = size_res.unwrap()
        pos = pos + 4
        if size_word == 0u32:
            break
        val raw_block = (size_word & 0x80000000u32) != 0u32
        val block_len = (size_word & 0x7FFFFFFFu32).to_i64()
        if raw_block and block_len > max_block_size:
            return Err(CompressionError.CorruptStream("lz4 raw block exceeds descriptor size"))
        val block_res = _lz4_take_slice(input, pos, block_len, "lz4 block")
        if block_res.is_err():
            return Err(block_res.unwrap_err())
        val block = block_res.unwrap()
        pos = pos + block_len
        if has_block_checksum:
            val checksum_res = read_u32_le(input, pos)
            if checksum_res.is_err():
                return Err(CompressionError.TruncatedInput("lz4 block checksum"))
            if checksum_res.unwrap() != xxhash32_bytes_for_tier(block, 0u32, tier):
                return Err(CompressionError.ChecksumMismatch("lz4 block checksum"))
            pos = pos + 4
        if raw_block:
            out = append_bytes(out, block)
        else:
            val decoded = lz4_decompress_block(block)
            if decoded.is_err():
                return Err(decoded.unwrap_err())
            val bytes = decoded.unwrap()
            if bytes.len() > max_block_size:
                return Err(CompressionError.CorruptStream("lz4 decoded block exceeds descriptor size"))
            out = append_bytes(out, bytes)
        if out.len() > 268435456:
            return Err(CompressionError.SizeLimitExceeded(268435456))
    if has_content_checksum:
        val checksum_res = read_u32_le(input, pos)
        if checksum_res.is_err():
            return Err(CompressionError.TruncatedInput("lz4 content checksum"))
        if checksum_res.unwrap() != xxhash32_bytes_for_tier(out, 0u32, tier):
            return Err(CompressionError.ChecksumMismatch("lz4 content checksum"))
        pos = pos + 4
    if declared_content_size != nil and out.len() != (declared_content_size ?? out.len()):
        return Err(CompressionError.CorruptStream("lz4 content size mismatch"))
    if pos != input.len():
        return Err(CompressionError.CorruptStream("lz4 trailing bytes after frame"))
    Ok(out)
