use compress.types.{CompressionCodec, CompressionLevel, CompressionOptions, CompressionError, CompressionEncoderState, CompressionDecoderState}
use std.simd.{SimdTier, detect_profile}

val CRC32_POLY_REV: u32 = 0xEDB88320u32
val XXH_PRIME32_1: u32 = 0x9E3779B1u32
val XXH_PRIME32_2: u32 = 0x85EBCA77u32
val XXH_PRIME32_3: u32 = 0xC2B2AE3Du32
val XXH_PRIME32_4: u32 = 0x27D4EB2Fu32
val XXH_PRIME32_5: u32 = 0x165667B1u32

enum CompressionSimdTier:
    scalar
    avx2
    neon

fn compression_simd_tier_from_simd_profile(profile: SimdTier) -> CompressionSimdTier:
    match profile:
        case SimdTier.x86_64_avx2: CompressionSimdTier.avx2
        case SimdTier.aarch64_neon: CompressionSimdTier.neon
        case _: CompressionSimdTier.scalar

fn compression_simd_tier_detect() -> CompressionSimdTier:
    compression_simd_tier_from_simd_profile(detect_profile())

fn compression_simd_tier_name(tier: CompressionSimdTier) -> text:
    match tier:
        CompressionSimdTier.scalar: "scalar"
        CompressionSimdTier.avx2: "avx2"
        CompressionSimdTier.neon: "neon"

fn compression_level(codec: CompressionCodec, value: i64) -> Result<CompressionLevel, CompressionError>:
    if codec == CompressionCodec.lz4:
        if value < 0 or value > 16:
            return Err(CompressionError.UnsupportedFeature("lz4 level must be in 0..16"))
    elif codec == CompressionCodec.zstd:
        if value < 1 or value > 22:
            return Err(CompressionError.UnsupportedFeature("zstd level must be in 1..22"))
    else:
        if value < 0 or value > 9:
            return Err(CompressionError.UnsupportedFeature("lzma2 level must be in 0..9"))
    Ok(CompressionLevel(value: value))

fn default_compression_options(codec: CompressionCodec) -> CompressionOptions:
    val level = if codec == CompressionCodec.lz4:
        CompressionLevel(value: 1)
    elif codec == CompressionCodec.zstd:
        CompressionLevel(value: 3)
    else:
        CompressionLevel(value: 6)
    val checksum = if codec == CompressionCodec.lzma2: true else: false
    CompressionOptions(
        codec: codec,
        level: level,
        checksum: checksum,
        block_mode: "frame",
        dictionary_bytes: nil,
        dictionary_id: nil,
        content_size: nil
    )

fn new_encoder_state(options: CompressionOptions) -> CompressionEncoderState:
    CompressionEncoderState(options: options, pending: [])

fn new_decoder_state(codec_hint: CompressionCodec?) -> CompressionDecoderState:
    CompressionDecoderState(codec_hint: codec_hint, pending: [])

fn encoder_write(state: CompressionEncoderState, chunk: [u8]) -> CompressionEncoderState:
    var pending = state.pending
    var i = 0
    while i < chunk.len():
        pending.push(chunk[i])
        i = i + 1
    CompressionEncoderState(options: state.options, pending: pending)

fn decoder_write(state: CompressionDecoderState, chunk: [u8]) -> CompressionDecoderState:
    var pending = state.pending
    var i = 0
    while i < chunk.len():
        pending.push(chunk[i])
        i = i + 1
    CompressionDecoderState(codec_hint: state.codec_hint, pending: pending)

fn write_u16_le(out: [u8], value: u16) -> [u8]:
    var result = out
    result.push((value & 0xFFu16).to_u8())
    result.push(((value >> 8) & 0xFFu16).to_u8())
    result

fn write_u32_le(out: [u8], value: u32) -> [u8]:
    var result = out
    result.push((value & 0xFFu32).to_u8())
    result.push(((value >> 8) & 0xFFu32).to_u8())
    result.push(((value >> 16) & 0xFFu32).to_u8())
    result.push(((value >> 24) & 0xFFu32).to_u8())
    result

fn write_u64_le(out: [u8], value: u64) -> [u8]:
    var result = out
    var shift: u64 = 0
    while shift < 64u64:
        result.push(((value >> shift) & 0xFFu64).to_u8())
        shift = shift + 8u64
    result

fn write_u16_be(out: [u8], value: u16) -> [u8]:
    var result = out
    result.push(((value >> 8) & 0xFFu16).to_u8())
    result.push((value & 0xFFu16).to_u8())
    result

fn read_u16_le(data: [u8], pos: i64) -> Result<u16, CompressionError>:
    if pos + 2 > data.len():
        return Err(CompressionError.TruncatedInput("need 2 bytes"))
    Ok(data[pos].to_u16() | (data[pos + 1].to_u16() << 8))

fn read_u32_le(data: [u8], pos: i64) -> Result<u32, CompressionError>:
    if pos + 4 > data.len():
        return Err(CompressionError.TruncatedInput("need 4 bytes"))
    Ok(data[pos].to_u32() |
        (data[pos + 1].to_u32() << 8) |
        (data[pos + 2].to_u32() << 16) |
        (data[pos + 3].to_u32() << 24))

fn read_u64_le(data: [u8], pos: i64) -> Result<u64, CompressionError>:
    if pos + 8 > data.len():
        return Err(CompressionError.TruncatedInput("need 8 bytes"))
    var value: u64 = 0u64
    var shift: u64 = 0u64
    var idx = pos
    while shift < 64u64:
        value = value | (data[idx].to_u64() << shift)
        idx = idx + 1
        shift = shift + 8u64
    Ok(value)

fn push_many_byte(out: [u8], byte: u8, count: i64) -> [u8]:
    var result = out
    var i = 0
    while i < count:
        result.push(byte)
        i = i + 1
    result

fn append_bytes(out: [u8], bytes: [u8]) -> [u8]:
    var result = out
    var i = 0
    while i < bytes.len():
        result.push(bytes[i])
        i = i + 1
    result

fn append_bytes_range(out: [u8], bytes: [u8], start: i64, end: i64) -> [u8]:
    var result = out
    var i = start
    while i < end:
        result.push(bytes[i])
        i = i + 1
    result

fn append_self_overlap_copy(out: [u8], offset: i64, count: i64) -> Result<[u8], CompressionError>:
    if offset <= 0 or offset > out.len():
        return Err(CompressionError.CorruptStream("invalid overlap copy offset"))
    var result = out
    var i = 0
    while i < count:
        val src = result.len() - offset
        result.push(result[src])
        i = i + 1
    Ok(result)

fn _crc32_update_byte(crc: u32, byte: u8) -> u32:
    var next = crc ^ byte.to_u32()
    var bit = 0
    while bit < 8:
        if (next & 1u32) == 1u32:
            next = (next >> 1) ^ CRC32_POLY_REV
        else:
            next = next >> 1
        bit = bit + 1
    next

fn _compression_simd_chunk_width(tier: CompressionSimdTier) -> i64:
    match tier:
        CompressionSimdTier.avx2: 32
        CompressionSimdTier.neon: 16
        CompressionSimdTier.scalar: 1

fn crc32_bytes(data: [u8]) -> u32:
    crc32_bytes_for_tier(data, compression_simd_tier_detect())

fn crc32_bytes_for_tier(data: [u8], tier: CompressionSimdTier) -> u32:
    var crc: u32 = 0xFFFFFFFFu32
    val chunk_width = _compression_simd_chunk_width(tier)
    var idx = 0
    while idx + chunk_width <= data.len():
        var lane = 0
        while lane < chunk_width:
            crc = _crc32_update_byte(crc, data[idx + lane])
            lane = lane + 1
        idx = idx + chunk_width
    while idx < data.len():
        crc = _crc32_update_byte(crc, data[idx])
        idx = idx + 1
    crc ^ 0xFFFFFFFFu32

fn xxh32_rotl(x: u32, amount: u32) -> u32:
    (x << amount) | (x >> (32u32 - amount))

fn xxh32_round(acc: u32, input: u32) -> u32:
    val a = acc + input * XXH_PRIME32_2
    xxh32_rotl(a, 13u32) * XXH_PRIME32_1

fn xxh32_merge_round(acc: u32, val: u32) -> u32:
    (acc ^ xxh32_round(0u32, val)) * XXH_PRIME32_1 + XXH_PRIME32_4

fn _read_u32_lane_le(data: [u8], pos: i64) -> u32:
    data[pos].to_u32() |
        (data[pos + 1].to_u32() << 8) |
        (data[pos + 2].to_u32() << 16) |
        (data[pos + 3].to_u32() << 24)

fn _xxhash32_finalize_accumulators(v1: u32, v2: u32, v3: u32, v4: u32) -> u32:
    var hash = xxh32_rotl(v1, 1u32) + xxh32_rotl(v2, 7u32) + xxh32_rotl(v3, 12u32) + xxh32_rotl(v4, 18u32)
    hash = xxh32_merge_round(hash, v1)
    hash = xxh32_merge_round(hash, v2)
    hash = xxh32_merge_round(hash, v3)
    hash = xxh32_merge_round(hash, v4)
    hash

fn _xxhash32_process_chunk(data: [u8], idx: i64, v1: u32, v2: u32, v3: u32, v4: u32, chunk_width: i64) -> (u32, u32, u32, u32):
    var next1 = v1
    var next2 = v2
    var next3 = v3
    var next4 = v4
    var cursor = idx
    while cursor < idx + chunk_width:
        next1 = xxh32_round(next1, _read_u32_lane_le(data, cursor))
        next2 = xxh32_round(next2, _read_u32_lane_le(data, cursor + 4))
        next3 = xxh32_round(next3, _read_u32_lane_le(data, cursor + 8))
        next4 = xxh32_round(next4, _read_u32_lane_le(data, cursor + 12))
        cursor = cursor + 16
    (next1, next2, next3, next4)

fn xxhash32_bytes(data: [u8], seed: u32) -> u32:
    xxhash32_bytes_for_tier(data, seed, compression_simd_tier_detect())

fn xxhash32_bytes_for_tier(data: [u8], seed: u32, tier: CompressionSimdTier) -> u32:
    var idx = 0
    var hash: u32 = 0u32
    if data.len() >= 16:
        var v1 = seed + XXH_PRIME32_1 + XXH_PRIME32_2
        var v2 = seed + XXH_PRIME32_2
        var v3 = seed + 0u32
        var v4 = seed - XXH_PRIME32_1
        while idx + 16 <= data.len():
            val accs = _xxhash32_process_chunk(data, idx, v1, v2, v3, v4, 16)
            v1 = accs.0
            v2 = accs.1
            v3 = accs.2
            v4 = accs.3
            idx = idx + 16
        hash = _xxhash32_finalize_accumulators(v1, v2, v3, v4)
    else:
        hash = seed + XXH_PRIME32_5
    hash = hash + data.len().to_u32()
    while idx + 4 <= data.len():
        val w = _read_u32_lane_le(data, idx)
        hash = xxh32_rotl(hash + w * XXH_PRIME32_3, 17u32) * XXH_PRIME32_4
        idx = idx + 4
    while idx < data.len():
        hash = xxh32_rotl(hash + data[idx].to_u32() * XXH_PRIME32_5, 11u32) * XXH_PRIME32_1
        idx = idx + 1
    hash = hash ^ (hash >> 15)
    hash = hash * XXH_PRIME32_2
    hash = hash ^ (hash >> 13)
    hash = hash * XXH_PRIME32_3
    hash ^ (hash >> 16)

fn detect_codec(input: [u8], codec_hint: CompressionCodec?) -> Result<CompressionCodec, CompressionError>:
    if codec_hint != nil:
        return Ok(codec_hint ?? CompressionCodec.lz4)
    if input.len() >= 4:
        if input[0] == 0x04u8 and input[1] == 0x22u8 and input[2] == 0x4Du8 and input[3] == 0x18u8:
            return Ok(CompressionCodec.lz4)
        if input[0] == 0x28u8 and input[1] == 0xB5u8 and input[2] == 0x2Fu8 and input[3] == 0xFDu8:
            return Ok(CompressionCodec.zstd)
    if input.len() >= 6:
        if input[0] == 0xFDu8 and input[1] == 0x37u8 and input[2] == 0x7Au8 and input[3] == 0x58u8 and input[4] == 0x5Au8 and input[5] == 0x00u8:
            return Ok(CompressionCodec.lzma2)
    Err(CompressionError.InvalidHeader("codec auto-detect failed"))
