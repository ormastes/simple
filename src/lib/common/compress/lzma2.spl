# XZ/LZMA2 facade.
#
# This module owns the public `std.common.compress.lzma2` surface. It delegates
# XZ framing and LZMA2 range coding to the pure-Simple implementation in
# `lzma2_xz_format`, which performs fail-closed typed validation of malformed
# streams. The only host dependency is a narrow fallback for otherwise-valid
# streams that use a non-default LCLPPB tuple (see lzma2_xz_format); every other
# typed error is surfaced unchanged.

pub use std.common.compress.lzma2_xz_format.{
    lzma2_compress_xz,
    lzma2_compress_xz_for_tier,
    lzma2_decompress_xz,
    lzma2_decompress_xz_for_tier
}
