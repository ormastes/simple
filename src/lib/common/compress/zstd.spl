# Zstd compression facade.
#
# zstd_compress_frame wraps zstd data in the standard Zstandard skippable-frame
# format.  Since a full Zstd implementation is large, this module provides
# a minimal store-only skippable frame that is valid and decompressable by
# libzstd.  Consumers import zstd_compress_frame.

use std.common.compress.types.{CompressionError, CompressionCodec, CompressionSimdTier}
use std.common.compress.lz4.{CompressionOptions}
use std.nogc_sync_mut.compression.zstd.decoder.{zstd_decode}
use std.common.compress.zstd_dict.{_zstd_decompress_frame_for_tier_with_dictionary}
use std.common.compress.zstd_frame.{_zstd_xxh64_bytes_for_tier}

# Re-export test utilities for specs that import from std.common.compress.zstd
pub use std.common.compress.zstd_literals.{zstd_parse_fse_huffman_weights, zstd_huf_build_table_for_test, zstd_huf_decode_stream_for_test}
pub use std.common.compress.zstd_dict.{zstd_parse_dictionary_for_test}
pub use std.common.compress.zstd_seq.{zstd_execute_sequences_for_test}

# ============================================================================
# Zstd frame constants (RFC 8478)
# ============================================================================

val ZSTD_MAGIC: i64 = 0xFD2FB528          # Frame magic (LE)
val ZSTD_SKIP_MAGIC_BASE: i64 = 0x184D2A50 # Skippable frame magic range start

# ============================================================================
# Helpers
# ============================================================================

fn _zstd_write_le32(v: i64) -> [u8]:
    [
        (v & 0xFF) as u8,
        ((v >> 8) & 0xFF) as u8,
        ((v >> 16) & 0xFF) as u8,
        ((v >> 24) & 0xFF) as u8
    ]

fn _zstd_write_le64(v: i64) -> [u8]:
    [
        (v & 0xFF) as u8,
        ((v >> 8) & 0xFF) as u8,
        ((v >> 16) & 0xFF) as u8,
        ((v >> 24) & 0xFF) as u8,
        ((v >> 32) & 0xFF) as u8,
        ((v >> 40) & 0xFF) as u8,
        ((v >> 48) & 0xFF) as u8,
        ((v >> 56) & 0xFF) as u8
    ]

fn _zstd_append(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    var i = 0
    while i < src.len():
        out = out.push(src[i])
        i = i + 1
    out

fn _zstd_read_le32(data: [u8], off: i64) -> i64:
    if off < 0 or off + 4 > data.len():
        return 0
    (data[off] as i64) |
        ((data[off + 1] as i64) << 8) |
        ((data[off + 2] as i64) << 16) |
        ((data[off + 3] as i64) << 24)

# ============================================================================
# Public API
# ============================================================================

fn _zstd_single_segment_fhd(content_size: i64, has_checksum: bool) -> u8:
    # FCS field size: 0→1byte (<256), 1→2bytes (<65792), 2→4bytes (≤4G), 3→8bytes
    var fcs: u8 = 0u8
    if content_size >= 256 and content_size < 65792:
        fcs = 1u8
    elif content_size >= 65792 and content_size <= 0xFFFFFFFFi64:
        fcs = 2u8
    elif content_size > 0xFFFFFFFFi64:
        fcs = 3u8
    var fhd = 0x20u8 | (fcs << 6u8)  # Single_Segment=1 (bit5)
    if has_checksum:
        fhd = fhd | 0x04u8
    fhd

fn _zstd_append_content_size(out: [u8], content_size: i64) -> [u8]:
    if content_size < 256:
        return out.push(content_size as u8)
    if content_size < 65792:
        val encoded = (content_size - 256).to_u32()
        var next = out
        next = next.push((encoded & 0xFFu32).to_u8())
        next = next.push(((encoded >> 8u32) & 0xFFu32).to_u8())
        return next
    if content_size <= 0xFFFFFFFFi64:
        return _zstd_append(out, _zstd_write_le32(content_size))
    _zstd_append(out, _zstd_write_le64(content_size))

fn _zstd_all_same(data: [u8]) -> bool:
    if data.len() == 0:
        return true
    val first = data[0]
    var i = 1
    while i < data.len():
        if data[i] != first:
            return false
        i = i + 1
    true

pub fn zstd_compress_frame(data: [u8], opts: CompressionOptions) -> [u8]:
    """Compress `data` as a single-segment Zstd frame (raw or RLE block).

    Uses single-segment encoding so the content size fits in 1–4 bytes with
    no separate Window_Descriptor.  Chooses RLE block when all input bytes
    are identical, raw block otherwise.
    """
    var out: [u8] = []
    out = _zstd_append(out, _zstd_write_le32(ZSTD_MAGIC))
    val n = data.len()
    out = out.push(_zstd_single_segment_fhd(n, opts.checksum))
    out = _zstd_append_content_size(out, n)
    if n == 0:
        # Empty last block: Last=1, Type=Raw, Size=0
        out = out.push(0x01 as u8)
        out = out.push(0x00 as u8)
        out = out.push(0x00 as u8)
    else:
        val all_same = _zstd_all_same(data)
        val btype = if all_same: 1 else: 0
        # RLE block header size = regenerated count; raw block size = content length. Both = n.
        val hdr_val = 1 | (btype << 1) | (n << 3)
        out = out.push((hdr_val & 0xFF) as u8)
        out = out.push(((hdr_val >> 8) & 0xFF) as u8)
        out = out.push(((hdr_val >> 16) & 0xFF) as u8)
        if all_same:
            out = out.push(data[0])
        else:
            out = _zstd_append(out, data)
    if opts.checksum:
        val hash = _zstd_xxh64_bytes_for_tier(data, 0u64, CompressionSimdTier.scalar)
        val h32 = (hash & 0xFFFFFFFFu64).to_u32()
        out = out.push((h32 & 0xFFu32).to_u8())
        out = out.push(((h32 >> 8u32) & 0xFFu32).to_u8())
        out = out.push(((h32 >> 16u32) & 0xFFu32).to_u8())
        out = out.push(((h32 >> 24u32) & 0xFFu32).to_u8())
    out

pub fn zstd_compress_frame_for_tier(input: [u8], options: CompressionOptions, tier: CompressionSimdTier) -> [u8]:
    """Compress a Zstd frame using the given SIMD tier (tier ignored for store path)."""
    zstd_compress_frame(input, options)

pub fn zstd_decompress_frame_for_tier(input: [u8], tier: CompressionSimdTier) -> Result<[u8], CompressionError>:
    """Decompress a Zstd frame using the given tier."""
    _zstd_decompress_frame_for_tier_with_dictionary(input, tier, nil, nil)

pub fn zstd_decompress_frame_with_dictionary(input: [u8], dictionary_bytes: [u8], dictionary_id: i64) -> Result<[u8], CompressionError>:
    """Decompress a Zstd frame that was compressed with a dictionary."""
    _zstd_decompress_frame_for_tier_with_dictionary(input, CompressionSimdTier.scalar, Some(dictionary_bytes), Some(dictionary_id))

pub fn zstd_decompress(data: [u8]) -> [u8]:
    """Decompress a Zstd-encoded byte slice using the full RFC 8878 decoder.
    Returns [] on any error."""
    val result = zstd_decode(data)
    match result:
        case Ok(bytes): bytes
        case _: []

pub fn zstd_decompress_frame(data: [u8]) -> Result<[u8], CompressionError>:
    """Decompress a Zstd frame using the full RFC 8878 decoder (all block types)."""
    _zstd_decompress_frame_for_tier_with_dictionary(data, CompressionSimdTier.scalar, nil, nil)
