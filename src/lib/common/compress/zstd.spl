use compress.types.{CompressionOptions, CompressionError}
use compress.utilities.{write_u32_le, write_u64_le, CompressionSimdTier, compression_simd_tier_detect, append_bytes}
use compress.zstd_types.{ZSTD_MAGIC, ZSTD_XXH64_PRIME1, ZSTD_XXH64_PRIME2, ZSTD_XXH64_PRIME3, ZSTD_XXH64_PRIME4, ZSTD_XXH64_PRIME5}
use compress.zstd_frame.{_zstd_xxh64_bytes_for_tier}
use compress.zstd_dict.{_zstd_decompress_frame_for_tier_with_dictionary, ZstdDictionaryState}

# Re-exports for public API consumers
use compress.zstd_types.{ZstdHufTableState, ZstdSequenceTableHistory, ZstdRepeatOffsets, ZstdFrameHeader, ZstdLiteralsSection, ZstdSequence}
use compress.zstd_literals.{zstd_parse_fse_huffman_weights, zstd_huf_build_table_for_test, zstd_huf_decode_stream_for_test}
use compress.zstd_dict.{zstd_parse_dictionary_for_test}

fn zstd_compress_frame(input: [u8], options: CompressionOptions) -> [u8]:
    zstd_compress_frame_for_tier(input, options, compression_simd_tier_detect())

fn _zstd_single_segment_descriptor(content_size: i64, checksum: bool) -> u8:
    var descriptor: u8 = 0x20u8
    if content_size >= 256 and content_size < 65792:
        descriptor = 0x60u8
    elif content_size >= 65792 and content_size <= 0xFFFFFFFFi64:
        descriptor = 0xA0u8
    elif content_size > 0xFFFFFFFFi64:
        descriptor = 0xE0u8
    if checksum:
        descriptor = descriptor | 0x04u8
    descriptor

fn _zstd_append_single_segment_content_size(buf: [u8], content_size: i64) -> [u8]:
    if content_size < 256:
        var next = buf
        next.push(content_size.to_u8())
        return next
    if content_size < 65792:
        val encoded_size = (content_size - 256).to_u16()
        var next = buf
        next.push((encoded_size & 0xFFu16).to_u8())
        next.push(((encoded_size >> 8u16) & 0xFFu16).to_u8())
        return next
    if content_size <= 0xFFFFFFFFi64:
        return write_u32_le(buf, content_size.to_u32())
    write_u64_le(buf, content_size.to_u64())

fn _zstd_append_block_header(buf: [u8], last_block: bool, block_type: i64, block_size: i64) -> [u8]:
    val header = ((if last_block: 1 else: 0) | (block_type << 1) | (block_size << 3)).to_u32()
    var next = buf
    next.push((header & 0xFFu32).to_u8())
    next.push(((header >> 8u32) & 0xFFu32).to_u8())
    next.push(((header >> 16u32) & 0xFFu32).to_u8())
    next

fn zstd_compress_frame_for_tier(input: [u8], options: CompressionOptions, tier: CompressionSimdTier) -> [u8]:
    var out: [u8] = []
    out = write_u32_le(out, ZSTD_MAGIC)
    val content_size = options.content_size ?? input.len()
    out.push(_zstd_single_segment_descriptor(content_size, options.checksum))
    out = _zstd_append_single_segment_content_size(out, content_size)
    if input.len() == 0:
        out.push(1u8)
        out.push(0u8)
        out.push(0u8)
        if options.checksum:
            val checksum = (_zstd_xxh64_bytes_for_tier([], 0u64, tier) & 0xFFFFFFFFu64).to_u32()
            out = write_u32_le(out, checksum)
        return out
    val all_same = _zstd_all_same(input)
    if all_same:
        out = _zstd_append_block_header(out, true, 1, input.len())
        out.push(input[0])
    else:
        out = _zstd_append_block_header(out, true, 0, input.len())
        out = append_bytes(out, input)
    if options.checksum:
        val checksum = (_zstd_xxh64_bytes_for_tier(input, 0u64, tier) & 0xFFFFFFFFu64).to_u32()
        out = write_u32_le(out, checksum)
    out

fn _zstd_all_same(input: [u8]) -> bool:
    if input.len() <= 1:
        return true
    var i = 1
    while i < input.len():
        if input[i] != input[0]:
            return false
        i = i + 1
    true

fn zstd_decompress_frame(input: [u8]) -> Result<[u8], CompressionError>:
    zstd_decompress_frame_for_tier(input, compression_simd_tier_detect())

fn zstd_decompress_frame_with_dictionary(input: [u8], dictionary_bytes: [u8], dictionary_id: i64) -> Result<[u8], CompressionError>:
    zstd_decompress_frame_with_dictionary_for_tier(input, dictionary_bytes, dictionary_id, compression_simd_tier_detect())

fn zstd_decompress_frame_for_tier(input: [u8], tier: CompressionSimdTier) -> Result<[u8], CompressionError>:
    _zstd_decompress_frame_for_tier_with_dictionary(input, tier, nil, nil)

fn zstd_decompress_frame_with_dictionary_for_tier(input: [u8], dictionary_bytes: [u8], dictionary_id: i64, tier: CompressionSimdTier) -> Result<[u8], CompressionError>:
    _zstd_decompress_frame_for_tier_with_dictionary(input, tier, Some(dictionary_bytes), Some(dictionary_id))
