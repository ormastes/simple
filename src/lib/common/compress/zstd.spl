# Zstd compression facade.
#
# zstd_compress_frame wraps zstd data in the standard Zstandard skippable-frame
# format.  Since a full Zstd implementation is large, this module provides
# a minimal store-only skippable frame that is valid and decompressable by
# libzstd.  Consumers import zstd_compress_frame.

use std.common.compress.types.{CompressionError, CompressionCodec}
use std.common.compress.lz4.{CompressionOptions}
use std.nogc_sync_mut.compression.zstd.decoder.{zstd_decode}

# ============================================================================
# Zstd frame constants (RFC 8478)
# ============================================================================

val ZSTD_MAGIC: i64 = 0xFD2FB528          # Frame magic (LE)
val ZSTD_SKIP_MAGIC_BASE: i64 = 0x184D2A50 # Skippable frame magic range start

# ============================================================================
# Helpers
# ============================================================================

fn _zstd_write_le32(v: i64) -> [u8]:
    [
        (v & 0xFF) as u8,
        ((v >> 8) & 0xFF) as u8,
        ((v >> 16) & 0xFF) as u8,
        ((v >> 24) & 0xFF) as u8
    ]

fn _zstd_write_le64(v: i64) -> [u8]:
    [
        (v & 0xFF) as u8,
        ((v >> 8) & 0xFF) as u8,
        ((v >> 16) & 0xFF) as u8,
        ((v >> 24) & 0xFF) as u8,
        ((v >> 32) & 0xFF) as u8,
        ((v >> 40) & 0xFF) as u8,
        ((v >> 48) & 0xFF) as u8,
        ((v >> 56) & 0xFF) as u8
    ]

fn _zstd_append(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    var i = 0
    while i < src.len():
        out = out.push(src[i])
        i = i + 1
    out

fn _zstd_read_le32(data: [u8], off: i64) -> i64:
    if off + 4 > data.len():
        return 0
    (data[off] as i64) |
        ((data[off + 1] as i64) << 8) |
        ((data[off + 2] as i64) << 16) |
        ((data[off + 3] as i64) << 24)

# ============================================================================
# Public API
# ============================================================================

fn zstd_compress_frame(data: [u8], opts: CompressionOptions) -> [u8]:
    """Compress `data` as a single Zstd frame (store path).

    Produces a valid Zstd frame containing one uncompressed block so that
    standard libzstd can decompress it.  Block_Content_Size is recorded so
    streaming decoders know the output size.

    Frame layout:
      Magic(4) + FHD(1) + Window_Descriptor(1) +
      Content_Size(8) + Block_Header(3) + Block_Content(N) + Checksum?
    """
    var out: [u8] = []
    # Magic
    out = _zstd_append(out, _zstd_write_le32(ZSTD_MAGIC))
    # Frame_Header_Descriptor:
    #   FCS_Field_Size = 11 (8-byte content size), Single_Segment=0, Reserved=0
    #   Checksum=0, DID=0
    #   FHD = 0b11000000 = 0xC0
    out = out.push(0xC0 as u8)
    # Window_Descriptor: Mantissa=0, Exponent=0 => 1 KB window (smallest valid)
    out = out.push(0x00 as u8)
    # Content_Size (8 bytes LE)
    out = _zstd_append(out, _zstd_write_le64(data.len()))

    # Block_Header (3 bytes): Last_Block=1, Block_Type=00 (Raw), Block_Size=N
    # Header = Last(1b) | Type(2b) | Size(21b), packed LE in 3 bytes
    val btype_raw = 0   # Raw_Block
    val n = data.len()
    # Pack: bits [0]=Last, [2:1]=type, [23:3]=size
    val hdr_val = 1 | (btype_raw << 1) | (n << 3)
    out = out.push((hdr_val & 0xFF) as u8)
    out = out.push(((hdr_val >> 8) & 0xFF) as u8)
    out = out.push(((hdr_val >> 16) & 0xFF) as u8)

    # Block content (raw)
    out = _zstd_append(out, data)
    out

fn zstd_decompress(data: [u8]) -> [u8]:
    """Decompress a Zstd-encoded byte slice using the full RFC 8878 decoder.
    Returns [] on any error."""
    val result = zstd_decode(data)
    if result.is_err():
        return []
    result.unwrap()

fn zstd_decompress_frame(data: [u8]) -> Result<[u8], CompressionError>:
    """Decompress a Zstd frame produced by zstd_compress_frame (raw-block only).

    Supports only the store (Raw_Block) path used by zstd_compress_frame.
    For general Zstd decompression use libzstd via extern.
    """
    if data.len() < 4:
        return Err(CompressionError.TruncatedInput("zstd frame too short"))
    val magic = _zstd_read_le32(data, 0)
    if magic != ZSTD_MAGIC:
        return Err(CompressionError.InvalidHeader("zstd bad magic"))
    if data.len() < 4:
        return Err(CompressionError.TruncatedInput("zstd missing FHD"))
    val fhd = data[4] as i64
    val fcs_size_field = (fhd >> 6) & 0x3
    val single_segment = (fhd >> 5) & 0x1
    # Determine header size: 1 FHD + optional WD (1 if !single_segment) + FCS
    var pos = 5
    if single_segment == 0:
        pos = pos + 1  # Window_Descriptor
    # Skip content size field
    val fcs_bytes = if fcs_size_field == 0: 0 else: if fcs_size_field == 1: 2 else: if fcs_size_field == 2: 4 else: 8
    pos = pos + fcs_bytes
    # Read blocks
    var out: [u8] = []
    while pos + 3 <= data.len():
        val b0 = data[pos] as i64
        val b1 = data[pos + 1] as i64
        val b2 = data[pos + 2] as i64
        pos = pos + 3
        val is_last = b0 & 1
        val block_type = (b0 >> 1) & 0x3
        val block_size = ((b0 >> 3) & 0x1F) | (b1 << 5) | (b2 << 13)
        if block_type == 0:
            # Raw_Block: copy bytes
            if pos + block_size > data.len():
                return Err(CompressionError.TruncatedInput("zstd raw block overrun"))
            var i = 0
            while i < block_size:
                out = out.push(data[pos + i])
                i = i + 1
            pos = pos + block_size
        else:
            return Err(CompressionError.Unsupported("zstd block type {block_type} not supported"))
        if is_last == 1:
            return Ok(out)
    Err(CompressionError.TruncatedInput("zstd no last block found"))
