"""Bounded NTDLL event synchronization bridge for Wine startup probes."""

use common.wine_nt_api_catalog.{wine_nt_api_ntdll_sync_event_dispatch_gate}

class WineNtdllEvent:
    handle: i64
    name: text
    manual_reset: bool
    signaled: bool

class WineNtdllEventTable:
    events: [WineNtdllEvent]
    next_handle: i64

class WineNtdllEventResult:
    ok: bool
    error: text
    table: WineNtdllEventTable
    handle: i64
    wait_status: text
    operations: text

fn _event(handle: i64, name: text, manual_reset: bool, signaled: bool) -> WineNtdllEvent:
    WineNtdllEvent(handle: handle, name: name, manual_reset: manual_reset, signaled: signaled)

fn _table(events: [WineNtdllEvent], next_handle: i64) -> WineNtdllEventTable:
    WineNtdllEventTable(events: events, next_handle: next_handle)

fn _result(ok: bool, error: text, table: WineNtdllEventTable, handle: i64, wait_status: text, operations: text) -> WineNtdllEventResult:
    WineNtdllEventResult(ok: ok, error: error, table: table, handle: handle, wait_status: wait_status, operations: operations)

fn _find_event(table: WineNtdllEventTable, handle: i64) -> WineNtdllEvent:
    for event in table.events:
        if event.handle == handle:
            return event
    _event(0, "", false, false)

fn _replace_event(table: WineNtdllEventTable, replacement: WineNtdllEvent) -> WineNtdllEventTable:
    var events: [WineNtdllEvent] = []
    for event in table.events:
        if event.handle == replacement.handle:
            events.push(replacement)
        else:
            events.push(event)
    _table(events, table.next_handle)

fn _sequence_gate(symbols: [text]) -> text:
    val dispatch_state = wine_nt_api_ntdll_sync_event_dispatch_gate(symbols)
    if dispatch_state != "ready":
        return dispatch_state
    if symbols.len() != 4:
        return "ntdll-sync-event-sequence-count-mismatch"
    if symbols[0] != "NtCreateEvent":
        return "ntdll-sync-event-sequence-expected:NtCreateEvent"
    if symbols[1] != "NtSetEvent":
        return "ntdll-sync-event-sequence-expected:NtSetEvent"
    if symbols[2] != "NtWaitForSingleObject":
        return "ntdll-sync-event-sequence-expected:NtWaitForSingleObject"
    if symbols[3] != "NtResetEvent":
        return "ntdll-sync-event-sequence-expected:NtResetEvent"
    "ready"

pub fn wine_ntdll_event_table_new() -> WineNtdllEventTable:
    _table([], 0x300)

pub fn wine_ntdll_execute_event_sync(symbols: [text], table: WineNtdllEventTable, name: text, manual_reset: bool, initially_signaled: bool, timeout_ms: i64) -> WineNtdllEventResult:
    val sequence_state = _sequence_gate(symbols)
    if sequence_state != "ready":
        return _result(false, sequence_state, table, 0, "", "")
    if name == "":
        return _result(false, "NtCreateEvent:invalid-name", table, 0, "", "")
    val handle = table.next_handle
    var events = table.events
    events.push(_event(handle, name, manual_reset, initially_signaled))
    val created = _table(events, handle + 1)

    val event = _find_event(created, handle)
    if event.handle == 0:
        return _result(false, "NtSetEvent:invalid-handle", created, handle, "", "NtCreateEvent")
    val signaled = _replace_event(created, _event(event.handle, event.name, event.manual_reset, true))
    val wait_event = _find_event(signaled, handle)
    if not wait_event.signaled:
        if timeout_ms == 0:
            return _result(true, "", signaled, handle, "STATUS_TIMEOUT", "NtCreateEvent NtSetEvent NtWaitForSingleObject")
        return _result(false, "NtWaitForSingleObject:wait-pending", signaled, handle, "", "NtCreateEvent NtSetEvent")
    val reset = _replace_event(signaled, _event(wait_event.handle, wait_event.name, wait_event.manual_reset, false))
    _result(true, "", reset, handle, "STATUS_WAIT_0", "NtCreateEvent NtSetEvent NtWaitForSingleObject NtResetEvent")
