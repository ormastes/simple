"""Statistics — descriptive statistics scaffold.

Covers Phase 1 / compatibility-map from common/statistics into the new
science namespace: mean, variance, std_dev, median, min, max, range, sum, count.

Import path: use std.common.science_math.statistics.{stat_mean, ...}
"""

extern fn rt_math_sqrt(x: f64) -> f64

pub fn stat_sum(xs: [f64]) -> f64:
    """Sum of all values."""
    var s = 0.0
    var i = 0
    while i < xs.len():
        s = s + xs[i]
        i = i + 1
    s

pub fn stat_count(xs: [f64]) -> i64:
    """Number of elements."""
    xs.len()

pub fn stat_mean(xs: [f64]) -> f64:
    """Arithmetic mean."""
    val n = xs.len()
    if n == 0:
        return 0.0
    stat_sum(xs) / n.to_f64()

pub fn stat_variance(xs: [f64]) -> f64:
    """Population variance (divide by N)."""
    val n = xs.len()
    if n == 0:
        return 0.0
    val m = stat_mean(xs)
    var s = 0.0
    var i = 0
    while i < n:
        val d = xs[i] - m
        s = s + d * d
        i = i + 1
    s / n.to_f64()

pub fn stat_std_dev(xs: [f64]) -> f64:
    """Population standard deviation."""
    rt_math_sqrt(stat_variance(xs))

pub fn stat_min(xs: [f64]) -> f64:
    """Minimum value."""
    var m = xs[0]
    var i = 1
    while i < xs.len():
        if xs[i] < m:
            m = xs[i]
        i = i + 1
    m

pub fn stat_max(xs: [f64]) -> f64:
    """Maximum value."""
    var m = xs[0]
    var i = 1
    while i < xs.len():
        if xs[i] > m:
            m = xs[i]
        i = i + 1
    m

pub fn stat_range(xs: [f64]) -> f64:
    """Range: max - min."""
    stat_max(xs) - stat_min(xs)

pub fn stat_median(xs: [f64]) -> f64:
    """Median of a sorted slice (caller must sort)."""
    val n = xs.len()
    if n == 0:
        return 0.0
    val mid = n / 2
    if n % 2 == 1:
        xs[mid]
    else:
        (xs[mid - 1] + xs[mid]) / 2.0
