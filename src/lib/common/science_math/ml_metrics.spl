"""ML Evaluation Metrics — pure scalar implementations.

All metrics operate on plain [f64] or [int] slices.
No matrix solver, no NDArray.

Import path: use std.common.science_math.ml_metrics.{ml_accuracy, ml_mse_metric, ml_r2}
"""

extern fn rt_math_sqrt(x: f64) -> f64

# ---------------------------------------------------------------------------
# Regression metrics
# ---------------------------------------------------------------------------

pub fn ml_mse_metric(y_true: [f64], y_pred: [f64]) -> f64:
    """Mean Squared Error.

    mse = mean((y_true[i] - y_pred[i])^2)
    Returns 0.0 for empty inputs.
    """
    val n = y_true.len()
    if n == 0:
        return 0.0
    var s = 0.0
    var i = 0
    while i < n:
        val d = y_true[i] - y_pred[i]
        s = s + d * d
        i = i + 1
    s / n.to_f64()

pub fn ml_mae_metric(y_true: [f64], y_pred: [f64]) -> f64:
    """Mean Absolute Error.

    mae = mean(|y_true[i] - y_pred[i]|)
    Returns 0.0 for empty inputs.
    """
    val n = y_true.len()
    if n == 0:
        return 0.0
    var s = 0.0
    var i = 0
    while i < n:
        var d = y_true[i] - y_pred[i]
        if d < 0.0:
            d = 0.0 - d
        s = s + d
        i = i + 1
    s / n.to_f64()

pub fn ml_r2(y_true: [f64], y_pred: [f64]) -> f64:
    """R² (coefficient of determination).

    r2 = 1 - ss_res / ss_tot
    where ss_res = sum((y_true - y_pred)^2)
          ss_tot = sum((y_true - mean(y_true))^2)

    Returns 1.0 when perfect prediction.
    Returns 0.0 when ss_tot == 0 and predictions are not perfect.
    """
    val n = y_true.len()
    if n == 0:
        return 0.0

    # Compute mean of y_true
    var sum_t = 0.0
    var i = 0
    while i < n:
        sum_t = sum_t + y_true[i]
        i = i + 1
    val mean_t = sum_t / n.to_f64()

    # Compute ss_res and ss_tot
    var ss_res = 0.0
    var ss_tot = 0.0
    var j = 0
    while j < n:
        val res = y_true[j] - y_pred[j]
        val tot = y_true[j] - mean_t
        ss_res = ss_res + res * res
        ss_tot = ss_tot + tot * tot
        j = j + 1

    if ss_tot == 0.0:
        # All true values are identical
        if ss_res == 0.0:
            return 1.0
        else:
            return 0.0
    1.0 - ss_res / ss_tot

pub fn ml_rmse(y_true: [f64], y_pred: [f64]) -> f64:
    """Root Mean Squared Error."""
    rt_math_sqrt(ml_mse_metric(y_true, y_pred))

# ---------------------------------------------------------------------------
# Classification metrics (integer labels)
# ---------------------------------------------------------------------------

pub fn ml_accuracy_int(y_true: [int], y_pred: [int]) -> f64:
    """Accuracy for integer-labelled classification.

    accuracy = correct_count / total_count
    Returns 0.0 for empty inputs.
    """
    val n = y_true.len()
    if n == 0:
        return 0.0
    var correct = 0
    var i = 0
    while i < n:
        if y_true[i] == y_pred[i]:
            correct = correct + 1
        i = i + 1
    correct.to_f64() / n.to_f64()

pub fn ml_accuracy_float(y_true: [f64], y_pred: [f64]) -> f64:
    """Accuracy for float-labelled classification (exact equality).

    Typically used when labels are encoded as 0.0 / 1.0.
    """
    val n = y_true.len()
    if n == 0:
        return 0.0
    var correct = 0
    var i = 0
    while i < n:
        if y_true[i] == y_pred[i]:
            correct = correct + 1
        i = i + 1
    correct.to_f64() / n.to_f64()

# ---------------------------------------------------------------------------
# Confusion matrix (2-class, integer labels 0 and 1)
# ---------------------------------------------------------------------------

pub class ConfusionMatrix2:
    """2×2 confusion matrix for binary classification."""
    tp: int
    tn: int
    fp: int
    fn_count: int

    static fn compute(y_true: [int], y_pred: [int]) -> ConfusionMatrix2:
        """Build a 2×2 confusion matrix from integer label arrays."""
        var tp = 0
        var tn = 0
        var fp = 0
        var fn_c = 0
        var i = 0
        while i < y_true.len():
            val t = y_true[i]
            val p = y_pred[i]
            if t == 1 and p == 1:
                tp = tp + 1
            if t == 0 and p == 0:
                tn = tn + 1
            if t == 0 and p == 1:
                fp = fp + 1
            if t == 1 and p == 0:
                fn_c = fn_c + 1
            i = i + 1
        ConfusionMatrix2(tp: tp, tn: tn, fp: fp, fn_count: fn_c)

    fn precision() -> f64:
        """Precision = TP / (TP + FP)."""
        val denom = self.tp + self.fp
        if denom == 0:
            return 0.0
        self.tp.to_f64() / denom.to_f64()

    fn recall() -> f64:
        """Recall = TP / (TP + FN)."""
        val denom = self.tp + self.fn_count
        if denom == 0:
            return 0.0
        self.tp.to_f64() / denom.to_f64()

    fn f1() -> f64:
        """F1 = 2 * precision * recall / (precision + recall)."""
        val p = self.precision()
        val r = self.recall()
        val denom = p + r
        if denom == 0.0:
            return 0.0
        2.0 * p * r / denom
