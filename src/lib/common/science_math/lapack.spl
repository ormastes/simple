"""LAPACK Provider Boundary — Phase 4 types and mock provider.

Defines the typed error enum, lifecycle wrappers (LapackInfo, Pivot,
Workspace<T>), and a pure-Simple mock provider.

The MockLapackProvider is MANDATORY — it must produce correct small-N
results without any native LAPACK library.

Import path: use std.common.science_math.lapack.*

Layer structure (mirrors BLAS Phase 3):
  Layer A — raw extern primitives  (lapack_lapacke.spl)
  Layer B — typed wrappers, hides Pivot/Workspace  (this file + lapack_cpu.spl)
  Layer C — primitive-free public API  (nogc_async_mut/linalg/mod.spl callers)

Row-major external API; column-major at extern boundary via operand-swap
(OQ-C: (AB)^T = B^T A^T).  LP64 integer ABI only.

Backends (SIMPLE_BLAS_BACKEND env var):
  mock (MockLapackProvider)  — always available; computes correct values
  scalar (CpuLapackProvider) — pure-Simple GE, no native dep (lapack_cpu.spl)
  lapacke                    — SFFI boundary   (lapack_lapacke.spl)
"""

use std.common.science_math.ndarray.{Index, Shape}

# ============================================================
# LinalgError — 6 typed variants
# (parallel to std.linalg.LinalgError which has only 2 variants;
#  these are distinct types)
# ============================================================

pub enum LinalgError:
    # Singular matrix: pivot at this 0-based row is zero
    Singular(row: i64)
    # A bad argument was passed (1-based LAPACK arg index)
    BadArgument(arg: i64)
    # Iterative algorithm did not converge in this many iterations
    NotConverged(iterations: i64)
    # Shape mismatch between two operands
    DimensionMismatch
    # Unsupported element type for this operation
    UnsupportedDType
    # Workspace allocation or query failed
    WorkspaceError

# ============================================================
# LapackInfo — wraps raw LAPACK integer return code
# ============================================================

pub class LapackInfo:
    _raw: i64

    static fn new(raw: i64) -> LapackInfo:
        LapackInfo(_raw: raw)

    fn decode(self) -> Result<Unit, LinalgError>:
        if self._raw == 0:
            return Ok(Unit)
        if self._raw < 0:
            # Negative info: bad argument at position -info (1-based)
            var arg_idx = -self._raw
            return Err(LinalgError.BadArgument(arg: arg_idx))
        # Positive info: singular factor at diagonal self._raw (1-based → 0-based)
        var row_idx = self._raw - 1
        Err(LinalgError.Singular(row: row_idx))

# ============================================================
# Pivot — wraps Fortran 1-based pivot integer array
# Hides LP64 indexing; exposes 0-based Index to callers (T-LAPACK-07).
# The _data field is never pub.
# ============================================================

pub class Pivot:
    _data: [i64]
    _len: i64

    static fn new(data: [i64]) -> Pivot:
        Pivot(_data: data, _len: data.len())

    # Returns the 0-based swap target for pivot step i (0-based input).
    fn at(self, i: Index) -> Index:
        val raw = self._data[i.value]
        # Convert from 1-based Fortran to 0-based Simple
        Index.new(raw - 1)

    fn len(self) -> Index:
        Index.new(self._len)

# ============================================================
# Workspace<T> — lifecycle wrapper for LAPACK work buffers.
# Allocated after bufferSize query, dropped after compute call.
# Never visible at Layer C.
# PERF-SUGAR-001: rt_f64_array_alloc deferred; use push-loop allocation.
# ============================================================

pub class Workspace:
    _buf: [f64]
    _size: i64

    static fn alloc(size: i64) -> Workspace:
        var buf: [f64] = []
        var i = 0
        while i < size:
            buf.push(0.0)
            i = i + 1
        Workspace(_buf: buf, _size: size)

    fn size(self) -> i64:
        self._size

# ============================================================
# Internal sqrt helper (avoids importing from nogc tier)
# ============================================================

fn _lapack_sqrt_f64(value: f64) -> f64:
    if value <= 0.0:
        return 0.0
    var estimate = value
    if estimate < 1.0:
        estimate = 1.0
    var i = 0
    while i < 20:
        estimate = 0.5 * (estimate + value / estimate)
        i = i + 1
    estimate

# ============================================================
# Internal abs helper
# ============================================================

fn _lapack_abs_f64(value: f64) -> f64:
    if value < 0.0:
        return -value
    value

# ============================================================
# MockLapackProvider
#
# Mandatory pure-Simple GE implementation. Produces correct
# small-N results without any native LAPACK library.
# Backend selection: SIMPLE_BLAS_BACKEND=mock.
#
# Operations use flat row-major [f64] buffers:
#   mat[row * n + col]
# ============================================================

pub class MockLapackProvider:

    fn provider_name(self) -> text:
        "mock"

    # gesv: Solve A*x = b where A is n×n, b is length-n.
    # Returns solution vector [f64] of length n.
    # A_buf: flat row-major n×n; b_buf: length-n rhs.
    fn gesv(self, n: i64, a_buf: [f64], b_buf: [f64]) -> Result<[f64], LinalgError>:
        # Copy A and b so we can do in-place elimination
        var mat: [f64] = []
        var rhs: [f64] = []
        var row = 0
        while row < n:
            var col = 0
            while col < n:
                mat.push(a_buf[row * n + col])
                col = col + 1
            rhs.push(b_buf[row])
            row = row + 1

        # Pivoted Gaussian elimination
        var pivot = 0
        while pivot < n:
            var pivot_row = pivot
            var max_abs = _lapack_abs_f64(mat[pivot * n + pivot])
            var probe = pivot + 1
            while probe < n:
                val candidate_abs = _lapack_abs_f64(mat[probe * n + pivot])
                if candidate_abs > max_abs:
                    max_abs = candidate_abs
                    pivot_row = probe
                probe = probe + 1

            if max_abs == 0.0:
                return Err(LinalgError.Singular(row: pivot))

            if pivot_row != pivot:
                var swap_col = 0
                while swap_col < n:
                    val pidx = pivot * n + swap_col
                    val pridx = pivot_row * n + swap_col
                    val tmp = mat[pidx]
                    mat[pidx] = mat[pridx]
                    mat[pridx] = tmp
                    swap_col = swap_col + 1
                val rhs_tmp = rhs[pivot]
                rhs[pivot] = rhs[pivot_row]
                rhs[pivot_row] = rhs_tmp

            var lower = pivot + 1
            while lower < n:
                val factor = mat[lower * n + pivot] / mat[pivot * n + pivot]
                var col = pivot
                while col < n:
                    mat[lower * n + col] = mat[lower * n + col] - factor * mat[pivot * n + col]
                    col = col + 1
                rhs[lower] = rhs[lower] - factor * rhs[pivot]
                lower = lower + 1
            pivot = pivot + 1

        # Back substitution
        var x: [f64] = []
        var i = 0
        while i < n:
            x.push(0.0)
            i = i + 1
        i = n - 1
        while i >= 0:
            var total = rhs[i]
            var col = i + 1
            while col < n:
                total = total - mat[i * n + col] * x[col]
                col = col + 1
            val diag = mat[i * n + i]
            if diag == 0.0:
                return Err(LinalgError.Singular(row: i))
            x[i] = total / diag
            i = i - 1
        Ok(x)

    # getrf: LU factorization in-place. Returns factored mat + pivot array.
    # pivot array is 1-based (Fortran convention), wrapped in Pivot by callers.
    fn getrf(self, n: i64, a_buf: [f64]) -> Result<[f64], LinalgError>:
        var mat: [f64] = []
        var i = 0
        while i < n * n:
            mat.push(a_buf[i])
            i = i + 1

        var pivot = 0
        while pivot < n:
            var pivot_row = pivot
            var max_abs = _lapack_abs_f64(mat[pivot * n + pivot])
            var probe = pivot + 1
            while probe < n:
                val candidate_abs = _lapack_abs_f64(mat[probe * n + pivot])
                if candidate_abs > max_abs:
                    max_abs = candidate_abs
                    pivot_row = probe
                probe = probe + 1

            if max_abs == 0.0:
                return Err(LinalgError.Singular(row: pivot))

            if pivot_row != pivot:
                var swap_col = 0
                while swap_col < n:
                    val pidx = pivot * n + swap_col
                    val pridx = pivot_row * n + swap_col
                    val tmp = mat[pidx]
                    mat[pidx] = mat[pridx]
                    mat[pridx] = tmp
                    swap_col = swap_col + 1

            var lower = pivot + 1
            while lower < n:
                val factor = mat[lower * n + pivot] / mat[pivot * n + pivot]
                mat[lower * n + pivot] = factor
                var col = pivot + 1
                while col < n:
                    mat[lower * n + col] = mat[lower * n + col] - factor * mat[pivot * n + col]
                    col = col + 1
                lower = lower + 1
            pivot = pivot + 1
        Ok(mat)

    # inv: matrix inverse. Returns flat row-major n×n result.
    fn inv(self, n: i64, a_buf: [f64]) -> Result<[f64], LinalgError>:
        var out: [f64] = []
        var i = 0
        while i < n * n:
            out.push(0.0)
            i = i + 1

        var col = 0
        while col < n:
            var rhs_col: [f64] = []
            var row = 0
            while row < n:
                if row == col:
                    rhs_col.push(1.0)
                else:
                    rhs_col.push(0.0)
                row = row + 1

            val col_result = self.gesv(n, a_buf, rhs_col)?
            row = 0
            while row < n:
                out[row * n + col] = col_result[row]
                row = row + 1
            col = col + 1
        Ok(out)

    # det: scalar determinant.
    fn det(self, n: i64, a_buf: [f64]) -> Result<f64, LinalgError>:
        var mat: [f64] = []
        var i = 0
        while i < n * n:
            mat.push(a_buf[i])
            i = i + 1

        var sign = 1.0
        var product = 1.0
        var pivot = 0
        while pivot < n:
            var pivot_row = pivot
            var max_abs = _lapack_abs_f64(mat[pivot * n + pivot])
            var probe = pivot + 1
            while probe < n:
                val candidate_abs = _lapack_abs_f64(mat[probe * n + pivot])
                if candidate_abs > max_abs:
                    max_abs = candidate_abs
                    pivot_row = probe
                probe = probe + 1

            if max_abs == 0.0:
                return Ok(0.0)

            if pivot_row != pivot:
                var swap_col = 0
                while swap_col < n:
                    val pidx = pivot * n + swap_col
                    val pridx = pivot_row * n + swap_col
                    val tmp = mat[pidx]
                    mat[pidx] = mat[pridx]
                    mat[pridx] = tmp
                    swap_col = swap_col + 1
                sign = -sign

            val pivot_value = mat[pivot * n + pivot]
            product = product * pivot_value
            var lower = pivot + 1
            while lower < n:
                val factor = mat[lower * n + pivot] / pivot_value
                var col = pivot
                while col < n:
                    mat[lower * n + col] = mat[lower * n + col] - factor * mat[pivot * n + col]
                    col = col + 1
                lower = lower + 1
            pivot = pivot + 1
        Ok(sign * product)

    # nrm2: Euclidean norm of a vector
    fn nrm2(self, n: i64, x_buf: [f64]) -> f64:
        var sum_sq = 0.0
        var i = 0
        while i < n:
            sum_sq = sum_sq + x_buf[i] * x_buf[i]
            i = i + 1
        _lapack_sqrt_f64(sum_sq)
