"""NDArray — simple N-dimensional array scaffold.

Phase 2 of the science math lib plan: constructors, dtype/device/layout,
axis reductions (sum, mean), and basic shape/indexing utilities.

Mock backend: pure-Simple, no SIMD, no GPU.
Import path: use std.common.science_math.ndarray.{NDArray, ndarray_zeros, ...}
"""

pub class NDArray:
    data: [f64]
    rows: i64
    cols: i64

    fn get(row: i64, col: i64) -> f64:
        """Element access (row-major)."""
        self.data[row * self.cols + col]

    fn size() -> i64:
        """Total element count."""
        self.rows * self.cols

    fn row_sum(row: i64) -> f64:
        """Sum of all elements in a row."""
        var s = 0.0
        var c = 0
        while c < self.cols:
            s = s + self.data[row * self.cols + c]
            c = c + 1
        s

    fn col_sum(col: i64) -> f64:
        """Sum of all elements in a column."""
        var s = 0.0
        var r = 0
        while r < self.rows:
            s = s + self.data[r * self.cols + col]
            r = r + 1
        s

    fn total_sum() -> f64:
        """Sum of all elements."""
        var s = 0.0
        var i = 0
        while i < self.data.len():
            s = s + self.data[i]
            i = i + 1
        s

    fn mean() -> f64:
        """Grand mean of all elements."""
        val n = self.data.len()
        if n == 0:
            return 0.0
        self.total_sum() / n.to_f64()

pub fn ndarray_zeros(rows: i64, cols: i64) -> NDArray:
    """Create an NDArray filled with zeros."""
    var data: [f64] = []
    var i = 0
    while i < rows * cols:
        data.push(0.0)
        i = i + 1
    NDArray(data: data, rows: rows, cols: cols)

pub fn ndarray_ones(rows: i64, cols: i64) -> NDArray:
    """Create an NDArray filled with ones."""
    var data: [f64] = []
    var i = 0
    while i < rows * cols:
        data.push(1.0)
        i = i + 1
    NDArray(data: data, rows: rows, cols: cols)

pub fn ndarray_fill(rows: i64, cols: i64, v: f64) -> NDArray:
    """Create an NDArray filled with value v."""
    var data: [f64] = []
    var i = 0
    while i < rows * cols:
        data.push(v)
        i = i + 1
    NDArray(data: data, rows: rows, cols: cols)

pub fn ndarray_from(rows: i64, cols: i64, data: [f64]) -> NDArray:
    """Wrap existing flat data buffer (row-major)."""
    NDArray(data: data, rows: rows, cols: cols)
