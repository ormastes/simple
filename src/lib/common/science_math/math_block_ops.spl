"""Math block operation implementations — Phase 6 (scilib port).

Public wrappers over the dispatch functions in math_block.spl.
Provides named, documented entry points for each supported math-block
operation category.  Mock contracts:
  - matmul(I, I)   → I   (identity)
  - inv(I)         → I
  - solve(I, b)    → b
  - singular input → Err(MathBlockError.Singular)
  - unsupported    → Err(MathBlockError.UnsupportedForm)

Provider selection hierarchy (v1):
  1×1 inputs  → Scalar provider (no BLAS call)
  2×2 inputs  → MockLapack (Cramer's rule, no FFI)
  n×n inputs  → MockGemm / MockLapack (pure-Simple; BLAS/LAPACK FFI in v2)

Import path: use std.common.science_math.math_block_ops.*
"""

use std.common.science_math.math_block.*

# ---------------------------------------------------------------------------
# Matmul — mock GEMM dispatch
# ---------------------------------------------------------------------------

pub fn op_matmul(a: MbMatrix, b: MbMatrix) -> Result<MathBlockResult, MathBlockError>:
    """Matrix multiply A @ B via mock GEMM provider.

    Returns Err(ShapeMismatch) if a.cols != b.rows.
    Scalar path (1×1 inputs) returns Scalar provider, not MockGemm.
    """
    lower_matmul(a, b)

# ---------------------------------------------------------------------------
# Inv — mock LAPACK dispatch
# ---------------------------------------------------------------------------

pub fn op_inv(a: MbMatrix) -> Result<MathBlockResult, MathBlockError>:
    """Matrix inverse inv(A) via mock LAPACK provider.

    Returns:
      Err(NonSquare)  if A is not square.
      Err(Singular)   if A is singular (zero diagonal, or det=0 for 2×2).
      Ok(MathBlockResult) with provider=MockLapack (or Scalar for 1×1).
    """
    lower_inv(a)

# ---------------------------------------------------------------------------
# Solve — mock LAPACK dispatch
# ---------------------------------------------------------------------------

pub fn op_solve(a: MbMatrix, b: [f64]) -> Result<MathBlockResult, MathBlockError>:
    """Solve linear system A·x = b via mock LAPACK provider.

    Returns:
      Err(NonSquare)     if A is not square.
      Err(DimensionError) if b.len() != a.rows.
      Err(Singular)      if A is singular.
      Ok(MathBlockResult) with result.matrix holding x as n×1 column vector.
    """
    lower_solve(a, b)

# ---------------------------------------------------------------------------
# Scalar multiply — scalar fallback path
# ---------------------------------------------------------------------------

pub fn op_scalar_mul(a: MbMatrix, scalar: f64) -> Result<MathBlockResult, MathBlockError>:
    """Element-wise multiply by scalar — always uses Scalar provider."""
    var d: [f64] = []
    var i = 0
    while i < a.data.len():
        d.push(a.data[i] * scalar)
        i = i + 1
    val m = MbMatrix.new(a.rows, a.cols, d)
    Ok(MathBlockResult.new(m, MathBlockProvider.Scalar))

# ---------------------------------------------------------------------------
# Unsupported form — typed diagnostic
# ---------------------------------------------------------------------------

pub fn op_unsupported(form: text) -> Result<MathBlockResult, MathBlockError>:
    """Returns Err(UnsupportedForm) for any math-block expression not covered
    by v1 dispatch.  Used by lowering logic to surface typed diagnostics
    rather than silent fallbacks."""
    lower_unsupported(form)

# ---------------------------------------------------------------------------
# Convenience: classify an operation from a tag text
# ---------------------------------------------------------------------------

pub fn classify_op(tag: text) -> MathBlockOp:
    """Map a string tag to the MathBlockOp discriminant.

    Known tags: "matmul", "inv", "solve", "scalar_mul".
    Anything else maps to Unsupported.
    """
    if tag == "matmul":
        return MathBlockOp.MatMul
    if tag == "inv":
        return MathBlockOp.Inv
    if tag == "solve":
        return MathBlockOp.Solve
    if tag == "scalar_mul":
        return MathBlockOp.ScalarMul
    MathBlockOp.Unsupported
