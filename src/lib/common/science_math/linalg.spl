"""Linalg — linear algebra scaffold for the science math lib.

Phase 3 (BLAS Layer A subset): dot product, matrix multiply, transpose,
identity matrix, and Frobenius norm.  Mock backend: pure-Simple.

Import path: use std.common.science_math.linalg.{mat_mul, dot, ...}
"""

pub class Matrix:
    data: [f64]
    rows: i64
    cols: i64

    fn get(row: i64, col: i64) -> f64:
        self.data[row * self.cols + col]

    fn size() -> i64:
        self.rows * self.cols

pub fn mat_zeros(rows: i64, cols: i64) -> Matrix:
    """Zero matrix."""
    var data: [f64] = []
    var i = 0
    while i < rows * cols:
        data.push(0.0)
        i = i + 1
    Matrix(data: data, rows: rows, cols: cols)

pub fn mat_identity(n: i64) -> Matrix:
    """n×n identity matrix."""
    var data: [f64] = []
    var r = 0
    while r < n:
        var c = 0
        while c < n:
            if r == c:
                data.push(1.0)
            else:
                data.push(0.0)
            c = c + 1
        r = r + 1
    Matrix(data: data, rows: n, cols: n)

pub fn mat_from(rows: i64, cols: i64, data: [f64]) -> Matrix:
    """Wrap existing flat row-major buffer."""
    Matrix(data: data, rows: rows, cols: cols)

pub fn dot(a: [f64], b: [f64]) -> f64:
    """Inner product of two equal-length vectors."""
    var s = 0.0
    var i = 0
    while i < a.len():
        s = s + a[i] * b[i]
        i = i + 1
    s

pub fn mat_mul(a: Matrix, b: Matrix) -> Matrix:
    """Matrix multiply: C = A × B.  a.cols must equal b.rows."""
    var data: [f64] = []
    var r = 0
    while r < a.rows:
        var c = 0
        while c < b.cols:
            var s = 0.0
            var k = 0
            while k < a.cols:
                s = s + a.get(r, k) * b.get(k, c)
                k = k + 1
            data.push(s)
            c = c + 1
        r = r + 1
    Matrix(data: data, rows: a.rows, cols: b.cols)

pub fn mat_transpose(a: Matrix) -> Matrix:
    """Transpose of a matrix."""
    var data: [f64] = []
    var c = 0
    while c < a.cols:
        var r = 0
        while r < a.rows:
            data.push(a.get(r, c))
            r = r + 1
        c = c + 1
    Matrix(data: data, rows: a.cols, cols: a.rows)

pub fn frobenius_norm(a: Matrix) -> f64:
    """Frobenius norm: sqrt(sum of squared elements)."""
    var s = 0.0
    var i = 0
    while i < a.data.len():
        s = s + a.data[i] * a.data[i]
        i = i + 1
    rt_math_sqrt(s)

extern fn rt_math_sqrt(x: f64) -> f64
