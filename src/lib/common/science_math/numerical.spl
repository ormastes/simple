"""Numerical methods — root-finding and integration scaffold.

Covers compatibility map from common/numerical_methods into the new
science namespace: bisection, Newton-Raphson step, trapezoidal rule,
finite-difference derivative.

Import path: use std.common.science_math.numerical.{bisect, trap_integrate, ...}
"""

extern fn rt_math_sqrt(x: f64) -> f64

pub fn num_abs(x: f64) -> f64:
    """Absolute value."""
    if x < 0.0:
        return 0.0 - x
    x

pub fn bisect_root(lo: f64, hi: f64, target: f64, iters: i64) -> f64:
    """Bisection root-find for f(x) = target where f(x) = x*x (demo square-root).

    Returns approximate x in [lo, hi] such that x*x ≈ target.
    """
    var a = lo
    var b = hi
    var i = 0
    while i < iters:
        val mid = (a + b) / 2.0
        val fmid = mid * mid
        if fmid < target:
            a = mid
        else:
            b = mid
        i = i + 1
    (a + b) / 2.0

pub fn newton_step(x: f64, fx: f64, fpx: f64) -> f64:
    """Single Newton-Raphson step: x_new = x - f(x)/f'(x)."""
    if num_abs(fpx) < 1e-15:
        return x
    x - fx / fpx

pub fn trap_integrate(lo: f64, hi: f64, steps: i64) -> f64:
    """Trapezoidal integration of f(x) = x*x over [lo, hi] (demo parabola).

    Exact result: (hi^3 - lo^3) / 3
    """
    if steps <= 0:
        return 0.0
    val h = (hi - lo) / steps.to_f64()
    var s = 0.0
    var i = 0
    while i <= steps:
        val x = lo + i.to_f64() * h
        val fx = x * x
        if i == 0 or i == steps:
            s = s + fx
        else:
            s = s + 2.0 * fx
        i = i + 1
    s * h / 2.0

pub fn finite_diff(x: f64, h: f64) -> f64:
    """Central finite-difference derivative of f(x) = x*x: f'(x) ≈ 2x.

    Uses (f(x+h) - f(x-h)) / (2h).
    """
    val xph = x + h
    val xmh = x - h
    (xph * xph - xmh * xmh) / (2.0 * h)
