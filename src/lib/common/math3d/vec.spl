# 3D Math — Vec2, Vec3, Vec4
#
# Pure vector types for 3D math. No engine dependencies.
# All operations return new values (immutable style).
#
# Usage:
#   val a = Vec3(x: 1.0, y: 2.0, z: 3.0)
#   val b = Vec3(x: 4.0, y: 5.0, z: 6.0)
#   val c = a.add(b)
#   val d = a.cross(b)
#   val n = a.normalize()

use std.common.math.{math_abs, math_lerp}
use std.common.math3d.math_util.{sqrt3d}

val _EPSILON = 0.0000000001

# ============================================================================
# Vec2
# ============================================================================

class Vec2:
    x: f64
    y: f64

impl Vec2:
    # --- Static constructors ---

    static fn zero() -> Vec2:
        Vec2(x: 0.0, y: 0.0)

    static fn one() -> Vec2:
        Vec2(x: 1.0, y: 1.0)

    static fn up() -> Vec2:
        Vec2(x: 0.0, y: 1.0)

    static fn right() -> Vec2:
        Vec2(x: 1.0, y: 0.0)

    # --- Arithmetic ---

    fn add(other: Vec2) -> Vec2:
        Vec2(x: self.x + other.x, y: self.y + other.y)

    fn sub(other: Vec2) -> Vec2:
        Vec2(x: self.x - other.x, y: self.y - other.y)

    fn mul(s: f64) -> Vec2:
        Vec2(x: self.x * s, y: self.y * s)

    fn div(s: f64) -> Vec2:
        Vec2(x: self.x / s, y: self.y / s)

    fn negate() -> Vec2:
        Vec2(x: -self.x, y: -self.y)

    # --- Products ---

    fn dot(other: Vec2) -> f64:
        self.x * other.x + self.y * other.y

    # --- Length ---

    fn length_squared() -> f64:
        self.x * self.x + self.y * self.y

    fn length() -> f64:
        sqrt3d(self.length_squared())

    fn normalize() -> Vec2:
        val len = self.length()
        if len < _EPSILON:
            return Vec2.zero()
        Vec2(x: self.x / len, y: self.y / len)

    fn distance_to(other: Vec2) -> f64:
        val diff = self.sub(other)
        diff.length()

    # --- Interpolation ---

    fn lerp(other: Vec2, t: f64) -> Vec2:
        val lx = math_lerp(self.x, other.x, t)
        val ly = math_lerp(self.y, other.y, t)
        Vec2(x: lx, y: ly)

    # --- Comparison ---

    fn eq(other: Vec2) -> bool:
        val dx = math_abs(self.x - other.x)
        val dy = math_abs(self.y - other.y)
        val x_eq = dx < _EPSILON
        val y_eq = dy < _EPSILON
        x_eq and y_eq

# ============================================================================
# Vec3
# ============================================================================

class Vec3:
    x: f64
    y: f64
    z: f64

impl Vec3:
    # --- Static constructors ---

    static fn zero() -> Vec3:
        Vec3(x: 0.0, y: 0.0, z: 0.0)

    static fn one() -> Vec3:
        Vec3(x: 1.0, y: 1.0, z: 1.0)

    static fn up() -> Vec3:
        Vec3(x: 0.0, y: 1.0, z: 0.0)

    static fn right() -> Vec3:
        Vec3(x: 1.0, y: 0.0, z: 0.0)

    static fn forward() -> Vec3:
        Vec3(x: 0.0, y: 0.0, z: 1.0)

    # --- Arithmetic ---

    fn add(other: Vec3) -> Vec3:
        Vec3(x: self.x + other.x, y: self.y + other.y, z: self.z + other.z)

    fn sub(other: Vec3) -> Vec3:
        Vec3(x: self.x - other.x, y: self.y - other.y, z: self.z - other.z)

    fn mul(s: f64) -> Vec3:
        Vec3(x: self.x * s, y: self.y * s, z: self.z * s)

    fn div(s: f64) -> Vec3:
        Vec3(x: self.x / s, y: self.y / s, z: self.z / s)

    fn negate() -> Vec3:
        Vec3(x: -self.x, y: -self.y, z: -self.z)

    # --- Products ---

    fn dot(other: Vec3) -> f64:
        self.x * other.x + self.y * other.y + self.z * other.z

    fn cross(other: Vec3) -> Vec3:
        """3D cross product."""
        val cx = self.y * other.z - self.z * other.y
        val cy = self.z * other.x - self.x * other.z
        val cz = self.x * other.y - self.y * other.x
        Vec3(x: cx, y: cy, z: cz)

    # --- Length ---

    fn length_squared() -> f64:
        self.x * self.x + self.y * self.y + self.z * self.z

    fn length() -> f64:
        sqrt3d(self.length_squared())

    fn normalize() -> Vec3:
        val len = self.length()
        if len < _EPSILON:
            return Vec3.zero()
        Vec3(x: self.x / len, y: self.y / len, z: self.z / len)

    fn distance_to(other: Vec3) -> f64:
        val diff = self.sub(other)
        diff.length()

    # --- Interpolation ---

    fn lerp(other: Vec3, t: f64) -> Vec3:
        val lx = math_lerp(self.x, other.x, t)
        val ly = math_lerp(self.y, other.y, t)
        val lz = math_lerp(self.z, other.z, t)
        Vec3(x: lx, y: ly, z: lz)

    # --- Reflection ---

    fn reflect(normal: Vec3) -> Vec3:
        """Reflect this vector around a normal. normal should be normalized.
        Formula: v - 2 * dot(v, n) * n"""
        val d = self.dot(normal)
        val scaled = normal.mul(2.0 * d)
        self.sub(scaled)

    # --- Comparison ---

    fn eq(other: Vec3) -> bool:
        val dx = math_abs(self.x - other.x)
        val dy = math_abs(self.y - other.y)
        val dz = math_abs(self.z - other.z)
        val x_eq = dx < _EPSILON
        val y_eq = dy < _EPSILON
        val z_eq = dz < _EPSILON
        val xy = x_eq and y_eq
        xy and z_eq

# ============================================================================
# Vec4
# ============================================================================

class Vec4:
    x: f64
    y: f64
    z: f64
    w: f64

impl Vec4:
    static fn zero() -> Vec4:
        Vec4(x: 0.0, y: 0.0, z: 0.0, w: 0.0)

    static fn one() -> Vec4:
        Vec4(x: 1.0, y: 1.0, z: 1.0, w: 1.0)

    static fn from_vec3(v: Vec3, w: f64) -> Vec4:
        Vec4(x: v.x, y: v.y, z: v.z, w: w)

    # --- Arithmetic ---

    fn add(other: Vec4) -> Vec4:
        Vec4(x: self.x + other.x, y: self.y + other.y, z: self.z + other.z, w: self.w + other.w)

    fn sub(other: Vec4) -> Vec4:
        Vec4(x: self.x - other.x, y: self.y - other.y, z: self.z - other.z, w: self.w - other.w)

    fn mul(s: f64) -> Vec4:
        Vec4(x: self.x * s, y: self.y * s, z: self.z * s, w: self.w * s)

    fn div(s: f64) -> Vec4:
        Vec4(x: self.x / s, y: self.y / s, z: self.z / s, w: self.w / s)

    fn negate() -> Vec4:
        Vec4(x: -self.x, y: -self.y, z: -self.z, w: -self.w)

    # --- Products ---

    fn dot(other: Vec4) -> f64:
        self.x * other.x + self.y * other.y + self.z * other.z + self.w * other.w

    # --- Length ---

    fn length_squared() -> f64:
        self.x * self.x + self.y * self.y + self.z * self.z + self.w * self.w

    fn length() -> f64:
        sqrt3d(self.length_squared())

    fn normalize() -> Vec4:
        val len = self.length()
        if len < _EPSILON:
            return Vec4.zero()
        Vec4(x: self.x / len, y: self.y / len, z: self.z / len, w: self.w / len)

    # --- Conversions ---

    fn to_vec3() -> Vec3:
        Vec3(x: self.x, y: self.y, z: self.z)

    # --- Interpolation ---

    fn lerp(other: Vec4, t: f64) -> Vec4:
        val lx = math_lerp(self.x, other.x, t)
        val ly = math_lerp(self.y, other.y, t)
        val lz = math_lerp(self.z, other.z, t)
        val lw = math_lerp(self.w, other.w, t)
        Vec4(x: lx, y: ly, z: lz, w: lw)

    # --- Comparison ---

    fn eq(other: Vec4) -> bool:
        val dx = math_abs(self.x - other.x)
        val dy = math_abs(self.y - other.y)
        val dz = math_abs(self.z - other.z)
        val dw = math_abs(self.w - other.w)
        val x_eq = dx < _EPSILON
        val y_eq = dy < _EPSILON
        val z_eq = dz < _EPSILON
        val w_eq = dw < _EPSILON
        val xy = x_eq and y_eq
        val zw = z_eq and w_eq
        xy and zw
