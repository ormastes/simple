#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# 3D Math Utilities — shared pure math helpers
#
# These are used internally by vec.spl, mat.spl, quat.spl.
# Newton's method sqrt, Taylor series sin/cos, atan2, acos.

use std.common.math.{MATH_PI, math_abs, math_clamp}

val _EPSILON = 0.0000000001

fn sqrt3d(x: f64) -> f64:
    """Newton's method square root."""
    if x < 0.0:
        return 0.0
    if x < _EPSILON:
        return 0.0
    var guess = x
    if x > 1.0:
        guess = x / 2.0
    var i = 0
    while i < 20:
        guess = (guess + x / guess) / 2.0
        i = i + 1
    guess

fn sin3d(x: f64) -> f64:
    """Taylor series sine approximation. Normalize to [-PI, PI]."""
    var a = x
    val two_pi = MATH_PI * 2.0
    while a > MATH_PI:
        a = a - two_pi
    while a < -MATH_PI:
        a = a + two_pi
    val x2 = a * a
    val x3 = a * x2
    val x5 = x3 * x2
    val x7 = x5 * x2
    val x9 = x7 * x2
    val x11 = x9 * x2
    val x13 = x11 * x2
    a - x3 / 6.0 + x5 / 120.0 - x7 / 5040.0 + x9 / 362880.0 - x11 / 39916800.0 + x13 / 6227020800.0

fn cos3d(x: f64) -> f64:
    """Cosine via sine shift."""
    sin3d(x + MATH_PI / 2.0)

fn acos3d(x: f64) -> f64:
    """Approximation of acos(x) using atan2-based identity."""
    val clamped = math_clamp(x, -1.0, 1.0)
    val s = sqrt3d(1.0 - clamped * clamped)
    atan2_3d(s, clamped)

fn atan2_3d(y: f64, x: f64) -> f64:
    """Approximation of atan2(y, x)."""
    if math_abs(x) < _EPSILON:
        if y > 0.0:
            return MATH_PI / 2.0
        if y < 0.0:
            return -MATH_PI / 2.0
        return 0.0
    val ratio = y / x
    val abs_ratio = math_abs(ratio)
    var atan_val = 0.0
    if abs_ratio <= 1.0:
        val r2 = ratio * ratio
        val r3 = ratio * r2
        val r5 = r3 * r2
        val r7 = r5 * r2
        val r9 = r7 * r2
        atan_val = ratio - r3 / 3.0 + r5 / 5.0 - r7 / 7.0 + r9 / 9.0
    else:
        val inv = 1.0 / ratio
        val inv2 = inv * inv
        val inv3 = inv * inv2
        val inv5 = inv3 * inv2
        val inv7 = inv5 * inv2
        val inv9 = inv7 * inv2
        val atan_inv = inv - inv3 / 3.0 + inv5 / 5.0 - inv7 / 7.0 + inv9 / 9.0
        if ratio > 0.0:
            atan_val = MATH_PI / 2.0 - atan_inv
        else:
            atan_val = -MATH_PI / 2.0 - atan_inv
    if x < 0.0:
        if y >= 0.0:
            return atan_val + MATH_PI
        else:
            return atan_val - MATH_PI
    atan_val
