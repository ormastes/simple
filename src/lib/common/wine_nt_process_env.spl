"""Modeled NT process-environment bridge over the Wine POSIX adapter contract."""

use common.wine_posix_adapter.{wine_posix_adapter_gate}

class WineNtEnvVar:
    key: text
    value: text

class WineNtProcessEnv:
    ready: bool
    state: text
    argv: [text]
    env: [WineNtEnvVar]

class WineNtProcessEnvResult:
    ok: bool
    state: text
    command_line: text
    environment_block: text

fn _env_var(key: text, value: text) -> WineNtEnvVar:
    WineNtEnvVar(key: key, value: value)

fn _process_env(ready: bool, state: text, argv: [text], env: [WineNtEnvVar]) -> WineNtProcessEnv:
    WineNtProcessEnv(ready: ready, state: state, argv: argv, env: env)

fn _result(ok: bool, state: text, command_line: text, environment_block: text) -> WineNtProcessEnvResult:
    WineNtProcessEnvResult(ok: ok, state: state, command_line: command_line, environment_block: environment_block)

fn _quote_arg(arg: text) -> text:
    if arg.contains(" "):
        return "\"" + arg + "\""
    arg

pub fn wine_nt_process_env_required_calls() -> [text]:
    [
        "GetCommandLineW",
        "GetEnvironmentStringsW"
    ]

pub fn wine_nt_process_env_new(posix_apis: text, async_features: text, argv: [text]) -> WineNtProcessEnv:
    val gate = wine_posix_adapter_gate(posix_apis, async_features)
    if not gate.ready:
        return _process_env(false, gate.state, [], [])
    if argv.len() == 0:
        return _process_env(false, "missing-argv0", [], [])
    _process_env(true, "ready", argv, [])

pub fn wine_nt_process_env_add(env: WineNtProcessEnv, key: text, value: text) -> WineNtProcessEnv:
    var vars = env.env
    vars.push(_env_var(key, value))
    _process_env(env.ready, env.state, env.argv, vars)

pub fn wine_nt_get_command_line_w(env: WineNtProcessEnv) -> WineNtProcessEnvResult:
    if not env.ready:
        return _result(false, env.state, "", "")
    var out = ""
    var i = 0
    while i < env.argv.len():
        if i > 0:
            out = out + " "
        out = out + _quote_arg(env.argv[i])
        i = i + 1
    _result(true, "ready", out, "")

pub fn wine_nt_get_environment_strings_w(env: WineNtProcessEnv) -> WineNtProcessEnvResult:
    if not env.ready:
        return _result(false, env.state, "", "")
    var block = ""
    for item in env.env:
        if item.key == "":
            return _result(false, "invalid-env-key", "", "")
        block = block + item.key + "=" + item.value + "\n"
    _result(true, "ready", "", block)
