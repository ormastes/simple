"""user32.dll, gdi32.dll, and advapi32.dll symbol lists and gates for the Wine NT API catalog."""

use common.wine_nt_api_types.{WineNtApiCatalogEntry}

fn _user32_lookup(symbol: text) -> WineNtApiCatalogEntry:
    if symbol == "MessageBoxW":
        return WineNtApiCatalogEntry(dll: "user32.dll", symbol: symbol, category: "gui-dialog", state: "implemented")
    if symbol == "CreateWindowExW" or symbol == "ShowWindow" or symbol == "UpdateWindow" or symbol == "DefWindowProcW":
        return WineNtApiCatalogEntry(dll: "user32.dll", symbol: symbol, category: "window-lifecycle", state: "implemented")
    if symbol == "GetMessageW" or symbol == "TranslateMessage" or symbol == "DispatchMessageW" or symbol == "PeekMessageW":
        return WineNtApiCatalogEntry(dll: "user32.dll", symbol: symbol, category: "message-loop", state: "implemented")
    WineNtApiCatalogEntry(dll: "user32.dll", symbol: symbol, category: "unknown", state: "unsupported")

fn _gdi32_lookup(symbol: text) -> WineNtApiCatalogEntry:
    if symbol == "TextOutW" or symbol == "BitBlt" or symbol == "CreateCompatibleDC" or symbol == "DeleteDC":
        return WineNtApiCatalogEntry(dll: "gdi32.dll", symbol: symbol, category: "gdi-drawing", state: "implemented")
    WineNtApiCatalogEntry(dll: "gdi32.dll", symbol: symbol, category: "unknown", state: "unsupported")

fn _advapi32_lookup(symbol: text) -> WineNtApiCatalogEntry:
    if symbol == "RegCreateKeyExW" or symbol == "RegOpenKeyExW" or symbol == "RegSetValueExW" or symbol == "RegQueryValueExW" or symbol == "RegCloseKey":
        return WineNtApiCatalogEntry(dll: "advapi32.dll", symbol: symbol, category: "registry", state: "implemented")
    if symbol == "OpenSCManagerW" or symbol == "CreateServiceW" or symbol == "OpenServiceW" or symbol == "StartServiceW" or symbol == "CloseServiceHandle":
        return WineNtApiCatalogEntry(dll: "advapi32.dll", symbol: symbol, category: "service-control", state: "implemented")
    WineNtApiCatalogEntry(dll: "advapi32.dll", symbol: symbol, category: "unknown", state: "unsupported")

pub fn wine_nt_api_implemented_symbols_for_gui_hello() -> [text]:
    [
        "MessageBoxW"
    ]

pub fn wine_nt_api_implemented_user32_window_symbols() -> [text]:
    [
        "CreateWindowExW",
        "ShowWindow",
        "UpdateWindow",
        "DefWindowProcW"
    ]

pub fn wine_nt_api_implemented_user32_message_symbols() -> [text]:
    [
        "PeekMessageW",
        "GetMessageW",
        "TranslateMessage",
        "DispatchMessageW"
    ]

pub fn wine_nt_api_implemented_gdi32_drawing_symbols() -> [text]:
    [
        "CreateCompatibleDC",
        "TextOutW",
        "BitBlt",
        "DeleteDC"
    ]

pub fn wine_nt_api_implemented_advapi32_registry_symbols() -> [text]:
    [
        "RegCreateKeyExW",
        "RegOpenKeyExW",
        "RegSetValueExW",
        "RegQueryValueExW",
        "RegCloseKey"
    ]

pub fn wine_nt_api_implemented_advapi32_service_symbols() -> [text]:
    [
        "OpenSCManagerW",
        "CreateServiceW",
        "OpenServiceW",
        "StartServiceW",
        "CloseServiceHandle"
    ]

pub fn wine_nt_api_gui_import_gate(dll: text, symbols: [text]) -> text:
    if dll.lower() == "gdi32.dll":
        return wine_nt_api_gdi_import_gate(dll, symbols)
    if dll.lower() != "user32.dll":
        return "unsupported-dll:" + dll
    if symbols.len() == 0:
        return "missing-symbol:user32"
    for symbol in symbols:
        val entry = _user32_lookup(symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
    "ready"

pub fn wine_nt_api_gui_dispatch_gate(symbols: [text]) -> text:
    if symbols.len() == 0:
        return "bridge-missing:user32"
    for symbol in symbols:
        val entry = _user32_lookup(symbol)
        if entry.state != "implemented":
            return "bridge-unsupported:" + symbol
    "ready"

pub fn wine_nt_api_gdi_import_gate(dll: text, symbols: [text]) -> text:
    if dll.lower() != "gdi32.dll":
        return "unsupported-dll:" + dll
    if symbols.len() == 0:
        return "missing-symbol:gdi32"
    for symbol in symbols:
        val entry = _gdi32_lookup(symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
    "ready"

