#[allow(primitive_api)]
# Table (DataFrame) Module
#
# Provides DataFrame-like tabular data structure with:
# - Column-based storage
# - SQL-like operations (select, where, group_by)
# - Aggregation and statistical functions
# - Method chaining for fluent API
#
# Pure Simple implementation following std.array patterns.
# Uses struct + functions pattern (no classes with static methods).
#
# NOTE: All struct field accesses use intermediate variables to work around
# interpreter mode type corruption bug (self.field.method() corrupts field).

use std.array (array_sum, array_group_by, array_sort_by, array_min, array_max, array_all)

# ============================================================================
# Column - Single column of typed data
# ============================================================================

struct Column:
    name: text
    data: [any]

fn column_create(col_name: text, col_data: [any]) -> Column:
    """Create column from name and data."""
    Column(name: col_name, data: col_data)

fn column_len(col: Column) -> i64:
    """Get length of column."""
    val d = col.data
    d.len()

fn column_get(col: Column, idx: i64) -> any:
    """Get value at index."""
    val d = col.data
    d[idx]

fn column_sum(col: Column) -> f64:
    """Sum all values in column."""
    var total = 0.0
    val d = col.data
    for item in d:
        total = total + item
    total

fn column_mean(col: Column) -> f64:
    """Compute mean of column."""
    val d = col.data
    val dlen = d.len()
    if dlen == 0:
        return 0.0
    val s = column_sum(col)
    val d2 = col.data
    s / d2.len()

fn column_min(col: Column) -> any:
    """Find minimum value."""
    val d = col.data
    val dlen = d.len()
    if dlen == 0:
        return nil
    val d2 = col.data
    var best = d2[0]
    var i = 1
    val d3 = col.data
    val d3len = d3.len()
    while i < d3len:
        val d4 = col.data
        val cur = d4[i]
        if cur < best:
            best = cur
        i = i + 1
    best

fn column_max(col: Column) -> any:
    """Find maximum value."""
    val d = col.data
    val dlen = d.len()
    if dlen == 0:
        return nil
    val d2 = col.data
    var best = d2[0]
    var i = 1
    val d3 = col.data
    val d3len = d3.len()
    while i < d3len:
        val d4 = col.data
        val cur = d4[i]
        if cur > best:
            best = cur
        i = i + 1
    best

fn column_std_dev(col: Column) -> f64:
    """Compute standard deviation."""
    val d = col.data
    val dlen = d.len()
    if dlen == 0:
        return 0.0
    val avg = column_mean(col)
    var sum_sq_diff = 0.0
    val d2 = col.data
    for item in d2:
        val diff = item - avg
        sum_sq_diff = sum_sq_diff + (diff * diff)
    val d3 = col.data
    val variance = sum_sq_diff / d3.len()
    variance.sqrt()

fn column_unique(col: Column) -> [any]:
    """Get unique values."""
    var seen = {"__init__": true}
    var result = []
    val d = col.data
    for item in d:
        val key = "{item}"
        val s = seen
        if not s.contains_key(key):
            seen[key] = true
            result.push(item)
    result

fn column_value_counts(col: Column) -> Dict<any, i64>:
    """Count value occurrences."""
    var counts = {"__init__": 0}
    val d = col.data
    for item in d:
        val key = "{item}"
        val c = counts
        if c.contains_key(key):
            val c2 = counts
            counts[key] = c2[key] + 1
        else:
            counts[key] = 1
    counts

# ============================================================================
# Table - DataFrame-like structure
# ============================================================================

struct Table:
    columns: Dict<text, Column>
    column_names: [text]
    num_rows: i64

fn table_empty() -> Table:
    """Create empty table."""
    Table(columns: {"__init__": Column(name: "__init__", data: [])}, column_names: [], num_rows: 0)

fn table_from_columns(cols: [Column]) -> Table:
    """Create from list of columns."""
    var table_cols = {"__init__": Column(name: "__init__", data: [])}
    var names = []
    var rows = 0

    for col in cols:
        val cname = col.name
        table_cols[cname] = col
        names.push(cname)
        if rows == 0:
            val cd = col.data
            rows = cd.len()

    Table(columns: table_cols, column_names: names, num_rows: rows)

fn table_from_dict(data: Dict<text, [any]>) -> Table:
    """Create from dictionary of name -> array."""
    var cols = []
    for (name, values) in data:
        if name != "__init__":
            val col = Column(name: name, data: values)
            cols.push(col)
    table_from_columns(cols)

fn table_get(table: Table, col_name: text):
    """Get column by name. Returns nil if not found."""
    val tcols = table.columns
    if tcols.contains_key(col_name):
        val tcols2 = table.columns
        tcols2[col_name]
    else:
        nil

fn table_col_index(table: Table, col_name: text) -> i64:
    """Get column index."""
    var i = 0
    val cn = table.column_names
    val cn_len = cn.len()
    while i < cn_len:
        val cn2 = table.column_names
        if cn2[i] == col_name:
            return i
        i = i + 1
    -1

fn table_where(table: Table, predicate: fn(Dict<text, any>) -> bool) -> Table:
    """Filter rows by predicate."""
    var new_cols = []

    # Build row dicts and filter
    var keep_indices = []
    var row_idx = 0
    while row_idx < table.num_rows:
        var row = {"__init__": 0}
        val cn = table.column_names
        for col_name in cn:
            val tcols = table.columns
            val col = tcols[col_name]
            val cd = col.data
            row[col_name] = cd[row_idx]

        if predicate(row):
            keep_indices.push(row_idx)

        row_idx = row_idx + 1

    # Build filtered columns
    val cn2 = table.column_names
    for col_name in cn2:
        val tcols2 = table.columns
        val old_col = tcols2[col_name]
        var new_data = []
        for idx in keep_indices:
            val ocd = old_col.data
            new_data.push(ocd[idx])
        new_cols.push(Column(name: col_name, data: new_data))

    table_from_columns(new_cols)

fn table_select(table: Table, col_names: [text]) -> Table:
    """Select specific columns."""
    var new_cols = []
    for name in col_names:
        val tcols = table.columns
        if tcols.contains_key(name):
            val tcols2 = table.columns
            new_cols.push(tcols2[name])
    table_from_columns(new_cols)

fn table_drop(table: Table, col_names: [text]) -> Table:
    """Drop specific columns."""
    var keep_names = []
    val cn = table.column_names
    for name in cn:
        var should_keep = true
        for drop_name in col_names:
            if name == drop_name:
                should_keep = false
        if should_keep:
            keep_names.push(name)
    table_select(table, keep_names)

fn table_sort_by(table: Table, col_name: text, ascending: bool) -> Table:
    """Sort by column."""
    val tcols = table.columns
    if not tcols.contains_key(col_name):
        return table

    val tcols2 = table.columns
    val sort_col = tcols2[col_name]

    # Create index array
    var indices = []
    var i = 0
    while i < table.num_rows:
        indices.push(i)
        i = i + 1

    # Sort indices by column values
    val sort_data = sort_col.data
    var sorted_indices = array_sort_by(indices, fn(a_idx, b_idx):
        val a = sort_data[a_idx]
        val b = sort_data[b_idx]
        if ascending:
            if a < b:
                return -1
            elif a > b:
                return 1
            else:
                return 0
        else:
            if a > b:
                return -1
            elif a < b:
                return 1
            else:
                return 0
    )

    # Reorder all columns
    var new_cols = []
    val cn = table.column_names
    for col_name_iter in cn:
        val tcols3 = table.columns
        val old_col = tcols3[col_name_iter]
        val ocd = old_col.data
        var new_data = []
        for idx in sorted_indices:
            new_data.push(ocd[idx])
        new_cols.push(Column(name: col_name_iter, data: new_data))

    table_from_columns(new_cols)

fn table_group_by(table: Table, col_name: text, agg_col: text, agg_fn: text) -> Table:
    """Group by column and aggregate."""
    val tcols = table.columns
    if not tcols.contains_key(col_name):
        return table_empty()
    val tcols2 = table.columns
    if not tcols2.contains_key(agg_col):
        return table_empty()

    val tcols3 = table.columns
    val group_col = tcols3[col_name]
    val tcols4 = table.columns
    val value_col = tcols4[agg_col]

    # Group values by key
    var groups = {"__init__": [0]}
    var i = 0
    while i < table.num_rows:
        val gcd = group_col.data
        val key = "{gcd[i]}"
        val vcd = value_col.data
        val item = vcd[i]

        val g = groups
        if g.contains_key(key):
            val g2 = groups
            var group_vals = g2[key]
            group_vals.push(item)
            groups[key] = group_vals
        else:
            groups[key] = [item]

        i = i + 1

    # Compute aggregates
    var group_keys = []
    var group_results = []

    for (key, values) in groups:
        if key == "__init__":
            pass_do_nothing
        else:
            group_keys.push(key)

            if agg_fn == "sum":
                var total = 0.0
                for v in values:
                    total = total + v
                group_results.push(total)
            elif agg_fn == "mean":
                var total = 0.0
                for v in values:
                    total = total + v
                val vlen = values.len()
                group_results.push(total / vlen)
            elif agg_fn == "count":
                val vlen = values.len()
                group_results.push(vlen)
            elif agg_fn == "min":
                var best = values[0]
                for v in values:
                    if v < best:
                        best = v
                group_results.push(best)
            elif agg_fn == "max":
                var best = values[0]
                for v in values:
                    if v > best:
                        best = v
                group_results.push(best)
            else:
                group_results.push(nil)

    # Build result table
    var result_dict = {"__init__": []}
    result_dict[col_name] = group_keys
    result_dict["{agg_fn}_{agg_col}"] = group_results
    table_from_dict(result_dict)

fn table_with_column(table: Table, col_name: text, values: [any]) -> Table:
    """Add computed column."""
    val vlen = values.len()
    if vlen != table.num_rows:
        return table

    val cn = table.column_names
    var new_col_names = []
    for n in cn:
        new_col_names.push(n)
    new_col_names.push(col_name)

    var new_cols_dict = {"__init__": Column(name: "__init__", data: [])}
    val tcols = table.columns
    for (k, v) in tcols:
        new_cols_dict[k] = v
    new_cols_dict[col_name] = Column(name: col_name, data: values)

    Table(columns: new_cols_dict, column_names: new_col_names, num_rows: table.num_rows)

fn table_with_computed(table: Table, col_name: text, compute: fn(Dict<text, any>) -> any) -> Table:
    """Add computed column from function."""
    var new_values = []

    var row_idx = 0
    while row_idx < table.num_rows:
        var row = {"__init__": 0}
        val cn = table.column_names
        for name in cn:
            val tcols = table.columns
            val col = tcols[name]
            val cd = col.data
            row[name] = cd[row_idx]

        new_values.push(compute(row))
        row_idx = row_idx + 1

    table_with_column(table, col_name, new_values)

fn table_inner_join(table: Table, other: Table, on_col: text) -> Table:
    """Inner join on common column."""
    val tcols = table.columns
    if not tcols.contains_key(on_col):
        return table_empty()
    val ocols = other.columns
    if not ocols.contains_key(on_col):
        return table_empty()

    val tcols2 = table.columns
    val left_col = tcols2[on_col]
    val ocols2 = other.columns
    val right_col = ocols2[on_col]

    # Build lookup for right table
    var right_lookup = {"__init__": []}
    var j = 0
    while j < other.num_rows:
        val rcd = right_col.data
        val key = "{rcd[j]}"
        val rl = right_lookup
        if not rl.contains_key(key):
            right_lookup[key] = []
        val rl2 = right_lookup
        var indices = rl2[key]
        indices.push(j)
        right_lookup[key] = indices
        j = j + 1

    # Find matching rows
    var result_rows = []
    var i = 0
    while i < table.num_rows:
        val lcd = left_col.data
        val key = "{lcd[i]}"
        val rl3 = right_lookup
        if rl3.contains_key(key):
            val rl4 = right_lookup
            val right_indices = rl4[key]
            for right_idx in right_indices:
                var row = {"__init__": 0}
                # Add left columns
                val tcn = table.column_names
                for name in tcn:
                    val tc = table.columns
                    val col = tc[name]
                    val cd = col.data
                    row[name] = cd[i]
                # Add right columns (skip join column)
                val ocn = other.column_names
                for name in ocn:
                    if name != on_col:
                        val oc = other.columns
                        val col = oc[name]
                        val cd = col.data
                        row[name] = cd[right_idx]
                result_rows.push(row)
        i = i + 1

    # Convert rows to columns
    val rr_len = result_rows.len()
    if rr_len == 0:
        return table_empty()

    val first_row = result_rows[0]
    var all_col_names = []
    for (name, _val) in first_row:
        if name != "__init__":
            all_col_names.push(name)

    var result_dict = {"__init__": []}
    for name in all_col_names:
        var col_data = []
        for row in result_rows:
            col_data.push(row[name])
        result_dict[name] = col_data

    table_from_dict(result_dict)

# ============================================================================
# Exports
# ============================================================================

