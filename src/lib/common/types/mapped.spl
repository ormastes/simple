# Mapped type helpers — pure string utilities for TypeScript-style type names.

fn partial(t: text) -> text:
    "Partial<{t}>"

fn readonly_type(t: text) -> text:
    "Readonly<{t}>"

fn pick_type(t: text, fields: text) -> text:
    "Pick<{t}, {fields}>"

fn omit_type(t: text, field: text) -> text:
    "Omit<{t}, {field}>"

fn make_optional_field(field: text) -> text:
    "{field}?"

fn make_required_field(field: text) -> text:
    "{field}!"

fn mapped_result_get_type(t: text, kind: text) -> text:
    "{kind}<{t}>"

export partial, readonly_type, pick_type, omit_type, make_optional_field, make_required_field, mapped_result_get_type
