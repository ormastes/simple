# Office Clipboard
#
# Shared clipboard for copy/cut/paste across office apps.

# =========================================================================
# Clipboard Content Types
# =========================================================================

enum ClipboardContent:
    PlainText(value: text)
    RichContent(format: text, data: text)
    CellData(rows: text)

# =========================================================================
# Office Clipboard
# =========================================================================

class OfficeClipboard:
    content: ClipboardContent?
    source_app: text

    static fn new() -> OfficeClipboard:
        """Create an empty clipboard."""
        return OfficeClipboard(content: nil, source_app: "")

    me copy(content: ClipboardContent, source: text):
        """Copy content to the clipboard from a given source app."""
        self.content = content
        self.source_app = source

    me cut(content: ClipboardContent, source: text):
        """Cut content to the clipboard (same as copy; removal is caller's responsibility)."""
        self.content = content
        self.source_app = source

    fn paste() -> ClipboardContent?:
        """Return the current clipboard content, or nil if empty."""
        return self.content

    fn has_content() -> bool:
        """True if the clipboard has content."""
        return self.content != nil

    me clear():
        """Clear the clipboard."""
        self.content = nil
        self.source_app = ""
