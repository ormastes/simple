#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Math Expression Rendering

fn greek(name: text) -> text:
    if name == "alpha": return "α"
    if name == "beta": return "β"
    if name == "gamma": return "γ"
    if name == "delta": return "δ"
    if name == "epsilon": return "ε"
    if name == "zeta": return "ζ"
    if name == "eta": return "η"
    if name == "theta": return "θ"
    if name == "iota": return "ι"
    if name == "kappa": return "κ"
    if name == "lambda": return "λ"
    if name == "mu": return "μ"
    if name == "nu": return "ν"
    if name == "xi": return "ξ"
    if name == "omicron": return "ο"
    if name == "pi": return "π"
    if name == "rho": return "ρ"
    if name == "sigma": return "σ"
    if name == "tau": return "τ"
    if name == "upsilon": return "υ"
    if name == "phi": return "φ"
    if name == "chi": return "χ"
    if name == "psi": return "ψ"
    if name == "omega": return "ω"
    if name == "varepsilon": return "ϵ"
    if name == "vartheta": return "ϑ"
    if name == "varphi": return "ϕ"
    if name == "varrho": return "ϱ"
    if name == "varpi": return "ϖ"
    if name == "varkappa": return "ϰ"
    if name == "partial": return "∂"
    if name == "nabla": return "∇"
    name

fn greek_upper(name: text) -> text:
    if name == "Gamma": return "Γ"
    if name == "Delta": return "Δ"
    if name == "Theta": return "Θ"
    if name == "Lambda": return "Λ"
    if name == "Xi": return "Ξ"
    if name == "Pi": return "Π"
    if name == "Sigma": return "Σ"
    if name == "Upsilon": return "Υ"
    if name == "Phi": return "Φ"
    if name == "Psi": return "Ψ"
    if name == "Omega": return "Ω"
    name

fn superscript_char(ch: text) -> text:
    if ch == "0": return "⁰"
    if ch == "1": return "¹"
    if ch == "2": return "²"
    if ch == "3": return "³"
    if ch == "4": return "⁴"
    if ch == "5": return "⁵"
    if ch == "6": return "⁶"
    if ch == "7": return "⁷"
    if ch == "8": return "⁸"
    if ch == "9": return "⁹"
    if ch == "+": return "⁺"
    if ch == "-": return "⁻"
    if ch == "=": return "⁼"
    if ch == "(": return "⁽"
    if ch == ")": return "⁾"
    if ch == "n": return "ⁿ"
    if ch == "i": return "ⁱ"
    if ch == "x": return "ˣ"
    ch

fn subscript_char(ch: text) -> text:
    if ch == "0": return "₀"
    if ch == "1": return "₁"
    if ch == "2": return "₂"
    if ch == "3": return "₃"
    if ch == "4": return "₄"
    if ch == "5": return "₅"
    if ch == "6": return "₆"
    if ch == "7": return "₇"
    if ch == "8": return "₈"
    if ch == "9": return "₉"
    if ch == "+": return "₊"
    if ch == "-": return "₋"
    if ch == "=": return "₌"
    if ch == "(": return "₍"
    if ch == ")": return "₎"
    if ch == "a": return "ₐ"
    if ch == "e": return "ₑ"
    if ch == "o": return "ₒ"
    if ch == "x": return "ₓ"
    if ch == "h": return "ₕ"
    if ch == "k": return "ₖ"
    if ch == "l": return "ₗ"
    if ch == "m": return "ₘ"
    if ch == "n": return "ₙ"
    if ch == "p": return "ₚ"
    if ch == "s": return "ₛ"
    if ch == "t": return "ₜ"
    if ch == "i": return "ᵢ"
    if ch == "j": return "ⱼ"
    if ch == "r": return "ᵣ"
    ch

fn superscript(s: text) -> text:
    var parts: [text] = []
    for i in 0..s.len():
        parts.push(superscript_char(_char_at(s, i)))
    parts.join("")

fn subscript(s: text) -> text:
    var parts: [text] = []
    for i in 0..s.len():
        parts.push(subscript_char(_char_at(s, i)))
    parts.join("")

fn _text_pad_center(s: text, width: i64) -> text:
    if s.len() >= width:
        return s
    val left_pad_count = (width - s.len()) / 2
    var pad_parts: [text] = []
    for _ in 0..left_pad_count:
        pad_parts.push(" ")
    pad_parts.join("") + s

fn hline(width: i64) -> text:
    var parts: [text] = []
    for _ in 0..width:
        parts.push("─")
    parts.join("")

fn pretty_fraction(num: text, den: text) -> text:
    "(" + num + ")/(" + den + ")"

fn pretty_power(base: text, exp: text) -> text:
    base + superscript(exp)

fn pretty_sub(base: text, idx: text) -> text:
    base + subscript(idx)

fn pretty_sqrt(expr: text) -> text:
    "√(" + expr + ")"

fn pretty_sum(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "∑(" + var_name + "=" + from_val + ".." + to_val + ") " + expr

fn pretty_integral(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "∫(" + var_name + "=" + from_val + ".." + to_val + ") " + expr

fn latex_fraction(num: text, den: text) -> text:
    "\\frac{" + num + "}{" + den + "}"

fn latex_power(base: text, exp: text) -> text:
    if exp.len() == 1:
        return base + "^" + exp
    base + "^{" + exp + "}"

fn latex_sub(base: text, idx: text) -> text:
    if idx.len() == 1:
        return base + "_" + idx
    base + "_{" + idx + "}"

fn latex_sqrt(expr: text) -> text:
    "\\sqrt{" + expr + "}"

fn latex_sum(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "\\sum_{" + var_name + "=" + from_val + "}^{" + to_val + "} " + expr

fn latex_integral(expr: text, var_name: text, from_val: text, to_val: text) -> text:
    "\\int_{" + from_val + "}^{" + to_val + "} " + expr + " \\, d" + var_name

fn _is_digit(ch: text) -> bool:
    if ch == "0": return true
    if ch == "1": return true
    if ch == "2": return true
    if ch == "3": return true
    if ch == "4": return true
    if ch == "5": return true
    if ch == "6": return true
    if ch == "7": return true
    if ch == "8": return true
    if ch == "9": return true
    false

fn _is_alpha(ch: text) -> bool:
    if ch == "_": return true
    if ch == "a": return true
    if ch == "b": return true
    if ch == "c": return true
    if ch == "d": return true
    if ch == "e": return true
    if ch == "f": return true
    if ch == "g": return true
    if ch == "h": return true
    if ch == "i": return true
    if ch == "j": return true
    if ch == "k": return true
    if ch == "l": return true
    if ch == "m": return true
    if ch == "n": return true
    if ch == "o": return true
    if ch == "p": return true
    if ch == "q": return true
    if ch == "r": return true
    if ch == "s": return true
    if ch == "t": return true
    if ch == "u": return true
    if ch == "v": return true
    if ch == "w": return true
    if ch == "x": return true
    if ch == "y": return true
    if ch == "z": return true
    if ch == "A": return true
    if ch == "B": return true
    if ch == "C": return true
    if ch == "D": return true
    if ch == "E": return true
    if ch == "F": return true
    if ch == "G": return true
    if ch == "H": return true
    if ch == "I": return true
    if ch == "J": return true
    if ch == "K": return true
    if ch == "L": return true
    if ch == "M": return true
    if ch == "N": return true
    if ch == "O": return true
    if ch == "P": return true
    if ch == "Q": return true
    if ch == "R": return true
    if ch == "S": return true
    if ch == "T": return true
    if ch == "U": return true
    if ch == "V": return true
    if ch == "W": return true
    if ch == "X": return true
    if ch == "Y": return true
    if ch == "Z": return true
    false

fn _is_alnum(ch: text) -> bool:
    if _is_digit(ch): return true
    _is_alpha(ch)

fn _char_at(source: text, index: i64) -> text:
    source[index]

fn _resolve_greek(name: text) -> text:
    val g = greek(name)
    if g != name:
        return g
    val gu = greek_upper(name)
    if gu != name:
        return gu
    name

fn _is_known_fn(name: text) -> bool:
    if name == "sin": return true
    if name == "cos": return true
    if name == "tan": return true
    if name == "tanh": return true
    if name == "sinh": return true
    if name == "cosh": return true
    if name == "log": return true
    if name == "ln": return true
    if name == "exp": return true
    if name == "min": return true
    if name == "max": return true
    if name == "lim": return true
    false

fn _latex_greek(name: text) -> text:
    val g = greek(name)
    if g != name:
        return "\\" + name
    val gu = greek_upper(name)
    if gu != name:
        return "\\" + name
    name

fn _reset(
    tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]],
    tk_kinds: [text], tk_vals: [text], parse_state: [i64]
):
    tags.clear()
    vals.clear()
    lefts.clear()
    rights.clear()
    extras.clear()
    tk_kinds.clear()
    tk_vals.clear()
    parse_state[0] = 0
    parse_state[1] = -1

fn _mk(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tag: text, tval: text, left: i64, right: i64) -> i64:
    val idx = tags.len()
    tags.push(tag)
    vals.push(tval)
    lefts.push(left)
    rights.push(right)
    extras.push([])
    idx

fn _mk_call(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], name: text, args: [i64]) -> i64:
    val idx = tags.len()
    tags.push("call")
    vals.push(name)
    lefts.push(-1)
    rights.push(-1)
    extras.push(args)
    idx

fn _tokenize(source: text, tk_kinds: [text], tk_vals: [text]):
    tk_kinds.clear()
    tk_vals.clear()
    var i = 0
    val slen = source.len()
    for _loop in 0..10000:
        if i >= slen:
            break
        val ch = _char_at(source, i)
        if ch == " " or ch == "\t":
            i = i + 1
        elif _is_digit(ch):
            var num_parts: [text] = []
            for _inner in 0..1000:
                if i >= slen:
                    break
                val c2 = _char_at(source, i)
                if _is_digit(c2) or c2 == ".":
                    num_parts.push(c2)
                    i = i + 1
                else:
                    break
            tk_kinds.push("num")
            tk_vals.push(num_parts.join(""))
        elif _is_alpha(ch):
            var id_parts: [text] = []
            for _inner in 0..1000:
                if i >= slen:
                    break
                val c2 = _char_at(source, i)
                if _is_alnum(c2):
                    id_parts.push(c2)
                    i = i + 1
                else:
                    break
            tk_kinds.push("id")
            tk_vals.push(id_parts.join(""))
        elif ch == ".":
            if i + 1 < slen:
                val next = _char_at(source, i + 1)
                if next == ".":
                    tk_kinds.push("op")
                    tk_vals.push("..")
                    i = i + 2
                else:
                    tk_kinds.push("op")
                    tk_vals.push(".")
                    i = i + 1
            else:
                tk_kinds.push("op")
                tk_vals.push(".")
                i = i + 1
        elif ch == "+":
            tk_kinds.push("op")
            tk_vals.push("+")
            i = i + 1
        elif ch == "-":
            tk_kinds.push("op")
            tk_vals.push("-")
            i = i + 1
        elif ch == "*":
            tk_kinds.push("op")
            tk_vals.push("*")
            i = i + 1
        elif ch == "/":
            tk_kinds.push("op")
            tk_vals.push("/")
            i = i + 1
        elif ch == "^":
            tk_kinds.push("op")
            tk_vals.push("^")
            i = i + 1
        elif ch == "'":
            tk_kinds.push("op")
            tk_vals.push("'")
            i = i + 1
        elif ch == "(":
            tk_kinds.push("lparen")
            tk_vals.push("(")
            i = i + 1
        elif ch == ")":
            tk_kinds.push("rparen")
            tk_vals.push(")")
            i = i + 1
        elif ch == "[":
            tk_kinds.push("lbracket")
            tk_vals.push("[")
            i = i + 1
        elif ch == "]":
            tk_kinds.push("rbracket")
            tk_vals.push("]")
            i = i + 1
        elif ch == ",":
            tk_kinds.push("comma")
            tk_vals.push(",")
            i = i + 1
        else:
            i = i + 1
    tk_kinds.push("eof")
    tk_vals.push("")

fn _peek_kind(tk_kinds: [text], parse_state: [i64]) -> text:
    if parse_state[0] >= tk_kinds.len():
        return "eof"
    tk_kinds[parse_state[0]]

fn _peek_val(tk_vals: [text], parse_state: [i64]) -> text:
    if parse_state[0] >= tk_vals.len():
        return ""
    tk_vals[parse_state[0]]

fn _advance(parse_state: [i64]):
    parse_state[0] = parse_state[0] + 1

fn _can_start_expr(tk_kinds: [text], parse_state: [i64]) -> bool:
    val pk = _peek_kind(tk_kinds, parse_state)
    if pk == "num": return true
    if pk == "id": return true
    if pk == "lparen": return true
    false

fn _can_implicit_mul(tk_kinds: [text], parse_state: [i64]) -> bool:
    if not _can_start_expr(tk_kinds, parse_state):
        return false
    val pk = _peek_kind(tk_kinds, parse_state)
    if pk == "id": return true
    if pk == "lparen": return true
    false

fn _parse_expr(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    _parse_add(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)

fn _parse_add(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    var left = _parse_mul(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    for _loop in 0..1000:
        val pk = _peek_kind(tk_kinds, parse_state)
        val pv = _peek_val(tk_vals, parse_state)
        if pk == "op" and pv == "+":
            _advance(parse_state)
            val right = _parse_mul(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            left = _mk(tags, vals, lefts, rights, extras, "add", "+", left, right)
        elif pk == "op" and pv == "-":
            _advance(parse_state)
            val right = _parse_mul(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            left = _mk(tags, vals, lefts, rights, extras, "sub", "-", left, right)
        else:
            break
    left

fn _parse_mul(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    var left = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    for _loop in 0..1000:
        val pk = _peek_kind(tk_kinds, parse_state)
        val pv = _peek_val(tk_vals, parse_state)
        if pk == "op" and pv == "*":
            _advance(parse_state)
            val right = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            left = _mk(tags, vals, lefts, rights, extras, "mul", "*", left, right)
        elif pk == "op" and pv == "/":
            _advance(parse_state)
            val right = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            left = _mk(tags, vals, lefts, rights, extras, "div", "/", left, right)
        elif _can_implicit_mul(tk_kinds, parse_state):
            val right = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            left = _mk(tags, vals, lefts, rights, extras, "mul", "", left, right)
        else:
            break
    left

fn _parse_unary(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    val pk = _peek_kind(tk_kinds, parse_state)
    val pv = _peek_val(tk_vals, parse_state)
    if pk == "op" and pv == "-":
        _advance(parse_state)
        val operand = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
        return _mk(tags, vals, lefts, rights, extras, "neg", "-", operand, -1)
    _parse_pow(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)

fn _parse_pow(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    var base = _parse_postfix(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    val pk = _peek_kind(tk_kinds, parse_state)
    val pv = _peek_val(tk_vals, parse_state)
    if pk == "op" and pv == "^":
        _advance(parse_state)
        val exp = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
        base = _mk(tags, vals, lefts, rights, extras, "pow", "^", base, exp)
    base

fn _parse_postfix(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    var node = _parse_primary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    for _loop in 0..100:
        if _peek_kind(tk_kinds, parse_state) == "lbracket":
            _advance(parse_state)
            val idx = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
            if _peek_kind(tk_kinds, parse_state) == "rbracket":
                _advance(parse_state)
            node = _mk(tags, vals, lefts, rights, extras, "subscript", "", node, idx)
        elif _peek_kind(tk_kinds, parse_state) == "op" and _peek_val(tk_vals, parse_state) == "'":
            _advance(parse_state)
            node = _mk(tags, vals, lefts, rights, extras, "transpose", "'", node, -1)
        else:
            break
    node

fn _parse_primary(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    val pk = _peek_kind(tk_kinds, parse_state)
    val pv = _peek_val(tk_vals, parse_state)

    if pk == "num":
        _advance(parse_state)
        return _mk(tags, vals, lefts, rights, extras, "num", pv, -1, -1)

    if pk == "id":
        _advance(parse_state)
        val name = pv
        if name == "frac" and _peek_kind(tk_kinds, parse_state) == "lparen":
            return _parse_frac_call(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
        if name == "sum" and _peek_kind(tk_kinds, parse_state) == "lparen":
            return _parse_sum_call(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state, name)
        if name == "int" and _peek_kind(tk_kinds, parse_state) == "lparen":
            return _parse_sum_call(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state, name)
        if _peek_kind(tk_kinds, parse_state) == "lparen":
            _advance(parse_state)
            var args: [i64] = []
            if _peek_kind(tk_kinds, parse_state) != "rparen":
                args.push(_parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state))
                for _loop in 0..100:
                    if _peek_kind(tk_kinds, parse_state) == "comma":
                        _advance(parse_state)
                        args.push(_parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state))
                    else:
                        break
            if _peek_kind(tk_kinds, parse_state) == "rparen":
                _advance(parse_state)
            return _mk_call(tags, vals, lefts, rights, extras, name, args)
        return _mk(tags, vals, lefts, rights, extras, "id", name, -1, -1)

    if pk == "lparen":
        _advance(parse_state)
        val inner = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
        if _peek_kind(tk_kinds, parse_state) == "rparen":
            _advance(parse_state)
        return _mk(tags, vals, lefts, rights, extras, "group", "", inner, -1)

    _advance(parse_state)
    _mk(tags, vals, lefts, rights, extras, "id", "?", -1, -1)

fn _parse_frac_call(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]) -> i64:
    _advance(parse_state)
    val num = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if _peek_kind(tk_kinds, parse_state) == "comma":
        _advance(parse_state)
    val den = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if _peek_kind(tk_kinds, parse_state) == "rparen":
        _advance(parse_state)
    _mk(tags, vals, lefts, rights, extras, "frac", "frac", num, den)

fn _parse_sum_call(tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64], kind: text) -> i64:
    _advance(parse_state)
    val var_name = _peek_val(tk_vals, parse_state)
    _advance(parse_state)
    if _peek_kind(tk_kinds, parse_state) == "comma":
        _advance(parse_state)
    val from_val = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if _peek_kind(tk_kinds, parse_state) == "op" and _peek_val(tk_vals, parse_state) == "..":
        _advance(parse_state)
    val to_val = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if _peek_kind(tk_kinds, parse_state) == "rparen":
        _advance(parse_state)
    val body = _parse_unary(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    val idx = tags.len()
    var tag = "sum_expr"
    if kind == "int":
        tag = "int_expr"
    tags.push(tag)
    vals.push(var_name)
    lefts.push(body)
    rights.push(-1)
    extras.push([from_val, to_val])
    idx

fn _parse_source(source: text, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]], tk_kinds: [text], tk_vals: [text], parse_state: [i64]):
    _reset(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    _tokenize(source, tk_kinds, tk_vals)
    parse_state[0] = 0
    parse_state[1] = _parse_expr(tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)

fn _render_text(idx: i64, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]]) -> text:
    if idx < 0: return ""
    val tag = tags[idx]
    val tval = vals[idx]
    val left = lefts[idx]
    val right = rights[idx]
    if tag == "num": return tval
    if tag == "id": return tval
    if tag == "add": return _render_text(left, tags, vals, lefts, rights, extras) + " + " + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "sub": return _render_text(left, tags, vals, lefts, rights, extras) + " - " + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "mul":
        if tval == "":
            return _render_text(left, tags, vals, lefts, rights, extras) + _render_text(right, tags, vals, lefts, rights, extras)
        return _render_text(left, tags, vals, lefts, rights, extras) + " * " + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "div": return _render_text(left, tags, vals, lefts, rights, extras) + " / " + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "pow": return _render_text(left, tags, vals, lefts, rights, extras) + "^" + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "neg": return "-" + _render_text(left, tags, vals, lefts, rights, extras)
    if tag == "frac": return _render_text(left, tags, vals, lefts, rights, extras) + " / " + _render_text(right, tags, vals, lefts, rights, extras)
    if tag == "group": return "(" + _render_text(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "subscript": return _render_text(left, tags, vals, lefts, rights, extras) + "[" + _render_text(right, tags, vals, lefts, rights, extras) + "]"
    if tag == "transpose": return _render_text(left, tags, vals, lefts, rights, extras) + "'"
    if tag == "call":
        val args = extras[idx]
        var arg_parts: [text] = []
        for a in args:
            arg_parts.push(_render_text(a, tags, vals, lefts, rights, extras))
        return tval + "(" + arg_parts.join(", ") + ")"
    if tag == "sum_expr":
        val bounds = extras[idx]
        return "sum(" + tval + ", " + _render_text(bounds[0], tags, vals, lefts, rights, extras) + ".." + _render_text(bounds[1], tags, vals, lefts, rights, extras) + ") " + _render_text(left, tags, vals, lefts, rights, extras)
    if tag == "int_expr":
        val bounds = extras[idx]
        return "int(" + tval + ", " + _render_text(bounds[0], tags, vals, lefts, rights, extras) + ".." + _render_text(bounds[1], tags, vals, lefts, rights, extras) + ") " + _render_text(left, tags, vals, lefts, rights, extras)
    tval

fn _render_debug(idx: i64, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]]) -> text:
    if idx < 0: return ""
    val tag = tags[idx]
    val tval = vals[idx]
    val left = lefts[idx]
    val right = rights[idx]
    if tag == "num": return "Num(" + tval + ")"
    if tag == "id": return "Id(" + tval + ")"
    if tag == "add": return "Add(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "sub": return "Sub(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "mul": return "Mul(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "div": return "Div(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "pow": return "Pow(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "neg": return "Neg(" + _render_debug(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "frac": return "Frac(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "group": return "Group(" + _render_debug(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "subscript": return "Sub(" + _render_debug(left, tags, vals, lefts, rights, extras) + ", " + _render_debug(right, tags, vals, lefts, rights, extras) + ")"
    if tag == "transpose": return "Transpose(" + _render_debug(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "call":
        val args = extras[idx]
        var arg_parts: [text] = []
        for a in args:
            arg_parts.push(_render_debug(a, tags, vals, lefts, rights, extras))
        return "Call(" + tval + ", " + arg_parts.join(", ") + ")"
    if tag == "sum_expr":
        val bounds = extras[idx]
        return "Sum(" + tval + ", " + _render_debug(bounds[0], tags, vals, lefts, rights, extras) + ", " + _render_debug(bounds[1], tags, vals, lefts, rights, extras) + ", " + _render_debug(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "int_expr":
        val bounds = extras[idx]
        return "Int(" + tval + ", " + _render_debug(bounds[0], tags, vals, lefts, rights, extras) + ", " + _render_debug(bounds[1], tags, vals, lefts, rights, extras) + ", " + _render_debug(left, tags, vals, lefts, rights, extras) + ")"
    "Unknown(" + tag + ")"

fn _render_pretty(idx: i64, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]]) -> text:
    if idx < 0: return ""
    val tag = tags[idx]
    val tval = vals[idx]
    val left = lefts[idx]
    val right = rights[idx]
    if tag == "num": return tval
    if tag == "id": return _resolve_greek(tval)
    if tag == "add": return _render_pretty(left, tags, vals, lefts, rights, extras) + " + " + _render_pretty(right, tags, vals, lefts, rights, extras)
    if tag == "sub": return _render_pretty(left, tags, vals, lefts, rights, extras) + " - " + _render_pretty(right, tags, vals, lefts, rights, extras)
    if tag == "mul":
        if tval == "":
            return _render_pretty(left, tags, vals, lefts, rights, extras) + _render_pretty(right, tags, vals, lefts, rights, extras)
        return _render_pretty(left, tags, vals, lefts, rights, extras) + " * " + _render_pretty(right, tags, vals, lefts, rights, extras)
    if tag == "div": return _render_pretty(left, tags, vals, lefts, rights, extras) + " / " + _render_pretty(right, tags, vals, lefts, rights, extras)
    if tag == "pow": return pretty_power(_render_pretty(left, tags, vals, lefts, rights, extras), _render_pretty(right, tags, vals, lefts, rights, extras))
    if tag == "neg": return "-" + _render_pretty(left, tags, vals, lefts, rights, extras)
    if tag == "frac": return pretty_fraction(_render_pretty(left, tags, vals, lefts, rights, extras), _render_pretty(right, tags, vals, lefts, rights, extras))
    if tag == "group": return "(" + _render_pretty(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "subscript": return pretty_sub(_render_pretty(left, tags, vals, lefts, rights, extras), _render_pretty(right, tags, vals, lefts, rights, extras))
    if tag == "transpose": return _render_pretty(left, tags, vals, lefts, rights, extras) + "ᵀ"
    if tag == "call":
        val args = extras[idx]
        if tval == "sqrt" and args.len() == 1:
            return pretty_sqrt(_render_pretty(args[0], tags, vals, lefts, rights, extras))
        var arg_parts: [text] = []
        for a in args:
            arg_parts.push(_render_pretty(a, tags, vals, lefts, rights, extras))
        return tval + "(" + arg_parts.join(", ") + ")"
    if tag == "sum_expr":
        val bounds = extras[idx]
        return pretty_sum(_render_pretty(left, tags, vals, lefts, rights, extras), tval, _render_pretty(bounds[0], tags, vals, lefts, rights, extras), _render_pretty(bounds[1], tags, vals, lefts, rights, extras))
    if tag == "int_expr":
        val bounds = extras[idx]
        return pretty_integral(_render_pretty(left, tags, vals, lefts, rights, extras), tval, _render_pretty(bounds[0], tags, vals, lefts, rights, extras), _render_pretty(bounds[1], tags, vals, lefts, rights, extras))
    tval

fn _render_latex(idx: i64, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]]) -> text:
    if idx < 0: return ""
    val tag = tags[idx]
    val tval = vals[idx]
    val left = lefts[idx]
    val right = rights[idx]
    if tag == "num": return tval
    if tag == "id": return _latex_greek(tval)
    if tag == "add": return _render_latex(left, tags, vals, lefts, rights, extras) + " + " + _render_latex(right, tags, vals, lefts, rights, extras)
    if tag == "sub": return _render_latex(left, tags, vals, lefts, rights, extras) + " - " + _render_latex(right, tags, vals, lefts, rights, extras)
    if tag == "mul":
        if tval == "":
            return _render_latex(left, tags, vals, lefts, rights, extras) + " " + _render_latex(right, tags, vals, lefts, rights, extras)
        return _render_latex(left, tags, vals, lefts, rights, extras) + " \\cdot " + _render_latex(right, tags, vals, lefts, rights, extras)
    if tag == "div": return _render_latex(left, tags, vals, lefts, rights, extras) + " / " + _render_latex(right, tags, vals, lefts, rights, extras)
    if tag == "pow": return latex_power(_render_latex(left, tags, vals, lefts, rights, extras), _render_latex(right, tags, vals, lefts, rights, extras))
    if tag == "neg": return "-" + _render_latex(left, tags, vals, lefts, rights, extras)
    if tag == "frac": return latex_fraction(_render_latex(left, tags, vals, lefts, rights, extras), _render_latex(right, tags, vals, lefts, rights, extras))
    if tag == "group": return "(" + _render_latex(left, tags, vals, lefts, rights, extras) + ")"
    if tag == "subscript": return latex_sub(_render_latex(left, tags, vals, lefts, rights, extras), _render_latex(right, tags, vals, lefts, rights, extras))
    if tag == "transpose": return _render_latex(left, tags, vals, lefts, rights, extras) + r"^{T}"
    if tag == "call":
        val args = extras[idx]
        if tval == "sqrt" and args.len() == 1:
            return latex_sqrt(_render_latex(args[0], tags, vals, lefts, rights, extras))
        val is_known = _is_known_fn(tval)
        var fn_prefix = "\\operatorname{" + tval + "}"
        if is_known:
            fn_prefix = "\\" + tval
        var arg_parts: [text] = []
        for a in args:
            arg_parts.push(_render_latex(a, tags, vals, lefts, rights, extras))
        return fn_prefix + "(" + arg_parts.join(", ") + ")"
    if tag == "sum_expr":
        val bounds = extras[idx]
        return latex_sum(_render_latex(left, tags, vals, lefts, rights, extras), tval, _render_latex(bounds[0], tags, vals, lefts, rights, extras), _render_latex(bounds[1], tags, vals, lefts, rights, extras))
    if tag == "int_expr":
        val bounds = extras[idx]
        return latex_integral(_render_latex(left, tags, vals, lefts, rights, extras), tval, _render_latex(bounds[0], tags, vals, lefts, rights, extras), _render_latex(bounds[1], tags, vals, lefts, rights, extras))
    tval

fn _render_md(idx: i64, tags: [text], vals: [text], lefts: [i64], rights: [i64], extras: [[i64]]) -> text:
    "$" + _render_latex(idx, tags, vals, lefts, rights, extras) + "$"

pub fn to_text(source: text) -> text:
    var tags: [text] = []
    var vals: [text] = []
    var lefts: [i64] = []
    var rights: [i64] = []
    var extras: [[i64]] = []
    var tk_kinds: [text] = []
    var tk_vals: [text] = []
    var parse_state: [i64] = [0, -1]
    _parse_source(source, tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if tags.len() == 0 or parse_state[1] < 0:
        return source
    _render_text(parse_state[1], tags, vals, lefts, rights, extras)

pub fn to_debug(source: text) -> text:
    var tags: [text] = []
    var vals: [text] = []
    var lefts: [i64] = []
    var rights: [i64] = []
    var extras: [[i64]] = []
    var tk_kinds: [text] = []
    var tk_vals: [text] = []
    var parse_state: [i64] = [0, -1]
    _parse_source(source, tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if tags.len() == 0 or parse_state[1] < 0:
        return source
    _render_debug(parse_state[1], tags, vals, lefts, rights, extras)

pub fn to_pretty(source: text) -> text:
    var tags: [text] = []
    var vals: [text] = []
    var lefts: [i64] = []
    var rights: [i64] = []
    var extras: [[i64]] = []
    var tk_kinds: [text] = []
    var tk_vals: [text] = []
    var parse_state: [i64] = [0, -1]
    _parse_source(source, tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if tags.len() == 0 or parse_state[1] < 0:
        return source
    _render_pretty(parse_state[1], tags, vals, lefts, rights, extras)

pub fn to_md(source: text) -> text:
    var tags: [text] = []
    var vals: [text] = []
    var lefts: [i64] = []
    var rights: [i64] = []
    var extras: [[i64]] = []
    var tk_kinds: [text] = []
    var tk_vals: [text] = []
    var parse_state: [i64] = [0, -1]
    _parse_source(source, tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if tags.len() == 0 or parse_state[1] < 0:
        return "$" + source + "$"
    _render_md(parse_state[1], tags, vals, lefts, rights, extras)

pub fn render_latex_raw(source: text) -> text:
    var tags: [text] = []
    var vals: [text] = []
    var lefts: [i64] = []
    var rights: [i64] = []
    var extras: [[i64]] = []
    var tk_kinds: [text] = []
    var tk_vals: [text] = []
    var parse_state: [i64] = [0, -1]
    _parse_source(source, tags, vals, lefts, rights, extras, tk_kinds, tk_vals, parse_state)
    if tags.len() == 0 or parse_state[1] < 0:
        return source
    _render_latex(parse_state[1], tags, vals, lefts, rights, extras)
