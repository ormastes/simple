# Math Expression Rendering — public API hub

use std.common.math_repr_symbols
use std.common.math_repr_parser
use std.common.math_repr_legacy_parser
use std.common.math_repr_render

pub fn to_text(source: text) -> text:
    var parser = MathParser.create()
    parser.parse_source(source)
    if parser.tags.len() == 0 or parser.root < 0:
        return source
    _render_text(parser.root, parser.tags, parser.vals, parser.lefts, parser.rights, parser.extras)

pub fn to_debug(source: text) -> text:
    var parser = MathParser.create()
    parser.parse_source(source)
    if parser.tags.len() == 0 or parser.root < 0:
        return source
    _render_debug(parser.root, parser.tags, parser.vals, parser.lefts, parser.rights, parser.extras)

pub fn to_pretty(source: text) -> text:
    var parser = MathParser.create()
    parser.parse_source(source)
    if parser.tags.len() == 0 or parser.root < 0:
        return source
    _render_pretty(parser.root, parser.tags, parser.vals, parser.lefts, parser.rights, parser.extras)

pub fn to_md(source: text) -> text:
    var parser = MathParser.create()
    parser.parse_source(source)
    if parser.tags.len() == 0 or parser.root < 0:
        return "$" + source + "$"
    _render_md(parser.root, parser.tags, parser.vals, parser.lefts, parser.rights, parser.extras)

pub fn render_latex_raw(source: text) -> text:
    var parser = MathParser.create()
    parser.parse_source(source)
    if parser.tags.len() == 0 or parser.root < 0:
        return source
    _render_latex(parser.root, parser.tags, parser.vals, parser.lefts, parser.rights, parser.extras)
