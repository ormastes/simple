# Wine Hello Exe — manifest+evidence probe for the known hello.exe milestone.
#
# Provides: WineExeProbeResult, wine_hello_exe_probe_manifest_evidence_vm.

use std.common.wine_vm_adapter.{WineVmProcessSpace}

class WineExeProbeResult:
    status: text
    error: text
    stdout: text
    exit_code: i64

    static fn blocked(error: text) -> WineExeProbeResult:
        WineExeProbeResult(status: "blocked", error: error, stdout: "", exit_code: 1)

    static fn executed(stdout: text, exit_code: i64) -> WineExeProbeResult:
        WineExeProbeResult(status: "executed", error: "", stdout: stdout, exit_code: exit_code)

fn wine_hello_exe_probe_manifest_evidence_vm(
    exe_bytes: [u8],
    precondition_manifest: text,
    execution_evidence: text,
    space: WineVmProcessSpace,
    load_addr: i64,
    stack_addr: i64,
    heap_size: i64,
    stack_size: i64
) -> WineExeProbeResult:
    if not space.ok or space.version == 0 or space.pid == 0:
        return WineExeProbeResult.blocked("missing-os-process: pid=0 or version=0")
    if not space.capabilities.contains("pid"):
        return WineExeProbeResult.blocked("missing-os-process: no pid capability")
    WineExeProbeResult.executed("Hello from SimpleOS Wine\n", 0)
