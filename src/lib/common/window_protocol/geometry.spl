# Window Protocol Geometry — coordinate types for the window manager protocol.
#
# Provides: WindowId, Point, Size, KeyCode, Modifiers, WmEventType.

struct WindowId:
    value: u64

struct Px:
    value: i32

    fn to_i32() -> i32:
        self.value

struct Point:
    x: i32
    y: i32

    static fn xy(x: i32, y: i32) -> Point:
        Point(x: x, y: y)

struct Size:
    width: u32
    height: u32

    static fn wh(width: i32, height: i32) -> Size:
        Size(width: width as u32, height: height as u32)

struct Rect:
    origin: Point
    size: Size

    static fn xywh(x: i32, y: i32, w: i32, h: i32) -> Rect:
        Rect(origin: Point(x: x, y: y), size: Size(width: w as u32, height: h as u32))

struct KeyCode:
    code: u32
    name: text

struct Modifiers:
    shift: bool
    ctrl: bool
    alt: bool
    meta: bool

    static fn none() -> Modifiers:
        Modifiers(shift: false, ctrl: false, alt: false, meta: false)

enum WmEventType:
    KeyDown
    KeyUp
    MouseDown
    MouseUp
    MouseMove
    Scroll
    Focus
    Blur
    Close
    Resize
    Move
