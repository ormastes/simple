# Window Protocol Geometry — coordinate types for the window manager protocol.
#
# Provides: WindowId, Point, Size, KeyCode, Modifiers, WmEventType.

struct WindowId:
    value: u64

struct Point:
    x: i32
    y: i32

struct Size:
    width: u32
    height: u32

    static fn wh(width: i32, height: i32) -> Size:
        Size(width: width as u32, height: height as u32)

struct KeyCode:
    code: u32
    name: text

struct Modifiers:
    shift: bool
    ctrl: bool
    alt: bool
    meta: bool

    static fn none() -> Modifiers:
        Modifiers(shift: false, ctrl: false, alt: false, meta: false)

enum WmEventType:
    KeyDown
    KeyUp
    MouseDown
    MouseUp
    MouseMove
    Scroll
    Focus
    Blur
    Close
    Resize
    Move
