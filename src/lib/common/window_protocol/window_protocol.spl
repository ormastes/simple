# Window Protocol — WM input event and command types.
#
# Provides: WmInputEvent, WmCreateRequest, WmCloseRequest,
#           WmResizeRequest, WmMoveRequest, WM_EVENT_CLOSE.

use std.common.window_protocol.geometry.{WindowId, Point, Size, KeyCode, Modifiers, WmEventType}

val WM_EVENT_CLOSE = "wm_close"

class WmInputEvent:
    event_type: WmEventType
    window_id: WindowId
    point: Point
    key_code: KeyCode
    modifiers: Modifiers
    scroll_dx: f64
    scroll_dy: f64

    static fn key_down(window_id: WindowId, key_code: KeyCode, modifiers: Modifiers) -> WmInputEvent:
        WmInputEvent(
            event_type: WmEventType.KeyDown,
            window_id: window_id,
            point: Point(x: 0 as i32, y: 0 as i32),
            key_code: key_code,
            modifiers: modifiers,
            scroll_dx: 0.0,
            scroll_dy: 0.0
        )

    static fn mouse_move(window_id: WindowId, point: Point) -> WmInputEvent:
        WmInputEvent(
            event_type: WmEventType.MouseMove,
            window_id: window_id,
            point: point,
            key_code: KeyCode(code: 0 as u32, name: ""),
            modifiers: Modifiers.none(),
            scroll_dx: 0.0,
            scroll_dy: 0.0
        )

struct WmCreateRequest:
    title: text
    size: Size
    parent_id: WindowId

struct WmCloseRequest:
    window_id: WindowId

struct WmResizeRequest:
    window_id: WindowId
    size: Size

struct WmMoveRequest:
    window_id: WindowId
    point: Point
