# Window Protocol — shared types for window creation, input, and lifecycle.
#
# Defines the IPC message types exchanged between client applications and
# the compositor / window manager service.

# ============================================================================
# Constants — input event types
# ============================================================================

val WM_EVENT_KEY_PRESS: u32 = 1
val WM_EVENT_KEY_RELEASE: u32 = 2
val WM_EVENT_MOUSE_MOVE: u32 = 3
val WM_EVENT_MOUSE_CLICK: u32 = 4
val WM_EVENT_MOUSE_RELEASE: u32 = 5
val WM_EVENT_CLOSE: u32 = 6
val WM_EVENT_FOCUS: u32 = 7
val WM_EVENT_RESIZE: u32 = 8

# ============================================================================
# Constants — status codes
# ============================================================================

val WM_STATUS_OK: i32 = 0
val WM_STATUS_ERROR: i32 = 1
val WM_STATUS_NO_SPACE: i32 = 2

# ============================================================================
# Window creation
# ============================================================================

struct WmCreateRequest:
    """Client request to create a new window."""
    title: text
    x: i32
    y: i32
    width: i32
    height: i32

struct WmCreateResponse:
    """Compositor response to a window creation request."""
    window_id: u64
    status: i32

# ============================================================================
# Input events
# ============================================================================

struct WmInputEvent:
    """Keyboard or mouse event delivered to a window."""
    window_id: u64
    event_type: u32
    key_code: u32
    mouse_x: i32
    mouse_y: i32
    modifiers: u32

# ============================================================================
# Window lifecycle
# ============================================================================

struct WmCloseRequest:
    """Request to close a window."""
    window_id: u64

struct WmResizeRequest:
    """Request to resize a window."""
    window_id: u64
    width: i32
    height: i32

struct WmMoveRequest:
    """Request to move a window."""
    window_id: u64
    x: i32
    y: i32

struct WmFocusEvent:
    """Notification that a window gained or lost focus."""
    window_id: u64
    focused: bool

# ============================================================================
# Helper constructors
# ============================================================================

fn wm_create_request(title: text, x: i32, y: i32, w: i32, h: i32) -> WmCreateRequest:
    """Create a WmCreateRequest."""
    WmCreateRequest(title: title, x: x, y: y, width: w, height: h)

fn wm_create_response(wid: u64, status: i32) -> WmCreateResponse:
    """Create a WmCreateResponse."""
    WmCreateResponse(window_id: wid, status: status)

fn wm_input_event(wid: u64, etype: u32, key: u32, mx: i32, my: i32) -> WmInputEvent:
    """Create a WmInputEvent with no modifiers."""
    WmInputEvent(window_id: wid, event_type: etype, key_code: key,
                 mouse_x: mx, mouse_y: my, modifiers: 0)

fn wm_input_event_with_mods(wid: u64, etype: u32, key: u32, mx: i32, my: i32, mods: u32) -> WmInputEvent:
    """Create a WmInputEvent with explicit modifiers."""
    WmInputEvent(window_id: wid, event_type: etype, key_code: key,
                 mouse_x: mx, mouse_y: my, modifiers: mods)

fn wm_close_request(wid: u64) -> WmCloseRequest:
    """Create a WmCloseRequest."""
    WmCloseRequest(window_id: wid)

fn wm_resize_request(wid: u64, w: i32, h: i32) -> WmResizeRequest:
    """Create a WmResizeRequest."""
    WmResizeRequest(window_id: wid, width: w, height: h)

fn wm_move_request(wid: u64, x: i32, y: i32) -> WmMoveRequest:
    """Create a WmMoveRequest."""
    WmMoveRequest(window_id: wid, x: x, y: y)

fn wm_focus_event(wid: u64, focused: bool) -> WmFocusEvent:
    """Create a WmFocusEvent."""
    WmFocusEvent(window_id: wid, focused: focused)
