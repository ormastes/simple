# Window Protocol — shared types for window creation, input, and lifecycle.
#
# Defines the IPC message types exchanged between client applications and
# the compositor / window manager service. Public fields and constructors
# use the named wrappers from `common.window_protocol.geometry` so that
# no bare primitives cross the WM public boundary.

use common.window_protocol.geometry.{
    WindowId, ProcessId, AppId,
    Px, Point, Size,
    KeyCode, Modifiers,
    WmEventType, WmStatus
}

# ============================================================================
# Event type tags
# ============================================================================

val WM_EVENT_KEY_PRESS: WmEventType = WmEventType(value: 1)
val WM_EVENT_KEY_RELEASE: WmEventType = WmEventType(value: 2)
val WM_EVENT_MOUSE_MOVE: WmEventType = WmEventType(value: 3)
val WM_EVENT_MOUSE_CLICK: WmEventType = WmEventType(value: 4)
val WM_EVENT_MOUSE_RELEASE: WmEventType = WmEventType(value: 5)
val WM_EVENT_CLOSE: WmEventType = WmEventType(value: 6)
val WM_EVENT_FOCUS: WmEventType = WmEventType(value: 7)
val WM_EVENT_RESIZE: WmEventType = WmEventType(value: 8)

# ============================================================================
# Status codes
# ============================================================================

val WM_STATUS_OK: WmStatus = WmStatus(value: 0)
val WM_STATUS_ERROR: WmStatus = WmStatus(value: 1)
val WM_STATUS_NO_SPACE: WmStatus = WmStatus(value: 2)

# ============================================================================
# Window creation
# ============================================================================

struct WmCreateRequest:
    """Client request to create a new window."""
    title: text
    origin: Point
    size: Size
    process_id: ProcessId
    app_id: AppId

struct WmCreateResponse:
    """Compositor response to a window creation request."""
    window_id: WindowId
    status: WmStatus

# ============================================================================
# Input events
# ============================================================================

struct WmInputEvent:
    """Keyboard or mouse event delivered to a window."""
    window_id: WindowId
    event_type: WmEventType
    key_code: KeyCode
    mouse_pos: Point
    modifiers: Modifiers

# ============================================================================
# Window lifecycle
# ============================================================================

struct WmCloseRequest:
    """Request to close a window."""
    window_id: WindowId

struct WmResizeRequest:
    """Request to resize a window."""
    window_id: WindowId
    size: Size

struct WmMoveRequest:
    """Request to move a window."""
    window_id: WindowId
    origin: Point

struct WmFocusEvent:
    """Notification that a window gained or lost focus."""
    window_id: WindowId
    focused: bool

# ============================================================================
# Helper constructors
# ============================================================================

fn wm_create_request(title: text, origin: Point, size: Size) -> WmCreateRequest:
    """Create a WmCreateRequest with no process / app identity."""
    WmCreateRequest(
        title: title,
        origin: origin,
        size: size,
        process_id: ProcessId(value: 0),
        app_id: AppId(value: "")
    )

fn wm_create_request_with_identity(title: text, origin: Point, size: Size, process_id: ProcessId, app_id: AppId) -> WmCreateRequest:
    """Create a WmCreateRequest with explicit process/app identity metadata."""
    WmCreateRequest(title: title, origin: origin, size: size, process_id: process_id, app_id: app_id)

fn wm_create_response(wid: WindowId, status: WmStatus) -> WmCreateResponse:
    """Create a WmCreateResponse."""
    WmCreateResponse(window_id: wid, status: status)

fn wm_input_event(wid: WindowId, etype: WmEventType, key: KeyCode, pos: Point) -> WmInputEvent:
    """Create a WmInputEvent with no modifiers."""
    WmInputEvent(
        window_id: wid,
        event_type: etype,
        key_code: key,
        mouse_pos: pos,
        modifiers: Modifiers(value: 0)
    )

fn wm_input_event_with_mods(wid: WindowId, etype: WmEventType, key: KeyCode, pos: Point, mods: Modifiers) -> WmInputEvent:
    """Create a WmInputEvent with explicit modifiers."""
    WmInputEvent(
        window_id: wid,
        event_type: etype,
        key_code: key,
        mouse_pos: pos,
        modifiers: mods
    )

fn wm_close_request(wid: WindowId) -> WmCloseRequest:
    """Create a WmCloseRequest."""
    WmCloseRequest(window_id: wid)

fn wm_resize_request(wid: WindowId, size: Size) -> WmResizeRequest:
    """Create a WmResizeRequest."""
    WmResizeRequest(window_id: wid, size: size)

fn wm_move_request(wid: WindowId, origin: Point) -> WmMoveRequest:
    """Create a WmMoveRequest."""
    WmMoveRequest(window_id: wid, origin: origin)

fn wm_focus_event(wid: WindowId, focused: bool) -> WmFocusEvent:
    """Create a WmFocusEvent."""
    WmFocusEvent(window_id: wid, focused: focused)
