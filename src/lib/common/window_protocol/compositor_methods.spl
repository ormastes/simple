# Common compositor protocol method numbers shared by kernel, hosted, and user lanes.

val COMP_CREATE_WINDOW: u32 = 1
val COMP_DESTROY_WINDOW: u32 = 2
val COMP_UPDATE_TREE: u32 = 3
val COMP_FOCUS: u32 = 4
val COMP_RESIZE: u32 = 5
val COMP_MOVE: u32 = 6
val COMP_SET_TITLE: u32 = 7
val COMP_MINIMIZE: u32 = 8
val COMP_MAXIMIZE: u32 = 9
val COMP_RESTORE: u32 = 10
val COMP_CREATE_WEB_WINDOW: u32 = 14

export COMP_CREATE_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS
export COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE
export COMP_RESTORE, COMP_CREATE_WEB_WINDOW
