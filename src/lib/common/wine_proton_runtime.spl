"""Structured Proton runtime evidence layered above full Wine readiness."""

use common.proton_runtime_subsystems.{
    ProtonNonWineRuntimeEvidence,
    proton_non_wine_feature_evidence,
    proton_non_wine_runtime_evidence_new,
    proton_non_wine_runtime_gate
}
use common.wine_proton_gate.{wine_proton_readiness_gate}

class WineProtonRuntimeEvidence:
    steam_runtime: text
    pressure_vessel: text
    graphics: text
    steam_integration: text
    sync: text

fn _wine_proton_runtime_evidence(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> WineProtonRuntimeEvidence:
    WineProtonRuntimeEvidence(steam_runtime: steam_runtime, pressure_vessel: pressure_vessel, graphics: graphics, steam_integration: steam_integration, sync: sync)

fn _wine_proton_append_once(items: text, item: text) -> text:
    if items.contains(item):
        return items
    if items == "":
        return item
    items + " " + item

fn _wine_proton_non_wine_evidence(evidence: WineProtonRuntimeEvidence) -> ProtonNonWineRuntimeEvidence:
    proton_non_wine_runtime_evidence_new(evidence.steam_runtime, evidence.pressure_vessel, evidence.graphics, evidence.steam_integration, evidence.sync)

pub fn wine_proton_runtime_evidence_new(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> WineProtonRuntimeEvidence:
    _wine_proton_runtime_evidence(steam_runtime, pressure_vessel, graphics, steam_integration, sync)

pub fn wine_proton_runtime_gate(evidence: WineProtonRuntimeEvidence) -> text:
    proton_non_wine_runtime_gate(_wine_proton_non_wine_evidence(evidence))

pub fn wine_proton_runtime_feature_evidence(evidence: WineProtonRuntimeEvidence) -> text:
    _wine_proton_append_once(proton_non_wine_feature_evidence(_wine_proton_non_wine_evidence(evidence)), "wine-full")

pub fn wine_proton_runtime_readiness_gate(wine_gates: text, evidence: WineProtonRuntimeEvidence) -> text:
    val runtime_state = wine_proton_runtime_gate(evidence)
    if runtime_state != "ready":
        return runtime_state
    wine_proton_readiness_gate(wine_gates, wine_proton_runtime_feature_evidence(evidence))

pub fn wine_proton_fixture_runtime_evidence() -> WineProtonRuntimeEvidence:
    wine_proton_runtime_evidence_new(
        "steam-runtime abi-x86_64 soldier",
        "pressure-vessel-container container-rootfs pid fs ipc net capability",
        "vulkan-loader vulkan-device dxvk vkd3d-proton shader-cache",
        "proton-launcher steamworks-bridge controller-input",
        "esync-or-fsync"
    )
