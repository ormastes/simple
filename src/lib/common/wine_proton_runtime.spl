"""Structured Proton runtime evidence layered above full Wine readiness."""

use common.wine_proton_gate.{wine_proton_readiness_gate}

class WineProtonRuntimeEvidence:
    steam_runtime: text
    pressure_vessel: text
    graphics: text
    steam_integration: text
    sync: text

fn _wine_proton_runtime_evidence(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> WineProtonRuntimeEvidence:
    WineProtonRuntimeEvidence(steam_runtime: steam_runtime, pressure_vessel: pressure_vessel, graphics: graphics, steam_integration: steam_integration, sync: sync)

fn _wine_proton_append_once(items: text, item: text) -> text:
    if items.contains(item):
        return items
    if items == "":
        return item
    items + " " + item

fn _wine_proton_require(evidence: text, item: text) -> text:
    if evidence.contains(item):
        return "ready"
    "missing-" + item

pub fn wine_proton_runtime_evidence_new(steam_runtime: text, pressure_vessel: text, graphics: text, steam_integration: text, sync: text) -> WineProtonRuntimeEvidence:
    _wine_proton_runtime_evidence(steam_runtime, pressure_vessel, graphics, steam_integration, sync)

pub fn wine_proton_runtime_gate(evidence: WineProtonRuntimeEvidence) -> text:
    val steam_runtime = _wine_proton_require(evidence.steam_runtime, "steam-runtime")
    if steam_runtime != "ready":
        return steam_runtime
    val abi = _wine_proton_require(evidence.steam_runtime, "abi-x86_64")
    if abi != "ready":
        return abi
    if not evidence.steam_runtime.contains("soldier") and not evidence.steam_runtime.contains("sniper"):
        return "missing-steam-linux-runtime-generation"

    val vessel = _wine_proton_require(evidence.pressure_vessel, "pressure-vessel-container")
    if vessel != "ready":
        return vessel
    val rootfs = _wine_proton_require(evidence.pressure_vessel, "container-rootfs")
    if rootfs != "ready":
        return rootfs
    for facet in ["pid", "fs", "ipc", "net", "capability"]:
        val facet_state = _wine_proton_require(evidence.pressure_vessel, facet)
        if facet_state != "ready":
            return facet_state

    for item in ["vulkan-loader", "vulkan-device", "dxvk", "vkd3d-proton", "shader-cache"]:
        val graphics_state = _wine_proton_require(evidence.graphics, item)
        if graphics_state != "ready":
            return graphics_state

    for item in ["proton-launcher", "steamworks-bridge", "controller-input"]:
        val integration_state = _wine_proton_require(evidence.steam_integration, item)
        if integration_state != "ready":
            return integration_state

    val sync_state = _wine_proton_require(evidence.sync, "esync-or-fsync")
    if sync_state != "ready":
        return sync_state
    "ready"

pub fn wine_proton_runtime_feature_evidence(evidence: WineProtonRuntimeEvidence) -> text:
    var features = ""
    for item in ["steam-runtime", "pressure-vessel-container"]:
        if evidence.steam_runtime.contains(item) or evidence.pressure_vessel.contains(item):
            features = _wine_proton_append_once(features, item)
    for item in ["proton-launcher", "steamworks-bridge", "controller-input"]:
        if evidence.steam_integration.contains(item):
            features = _wine_proton_append_once(features, item)
    for item in ["wine-full"]:
        features = _wine_proton_append_once(features, item)
    for item in ["vulkan-loader", "vulkan-device", "dxvk", "vkd3d-proton", "shader-cache"]:
        if evidence.graphics.contains(item):
            features = _wine_proton_append_once(features, item)
    if evidence.sync.contains("esync-or-fsync"):
        features = _wine_proton_append_once(features, "esync-or-fsync")
    features

pub fn wine_proton_runtime_readiness_gate(wine_gates: text, evidence: WineProtonRuntimeEvidence) -> text:
    val runtime_state = wine_proton_runtime_gate(evidence)
    if runtime_state != "ready":
        return runtime_state
    wine_proton_readiness_gate(wine_gates, wine_proton_runtime_feature_evidence(evidence))

pub fn wine_proton_fixture_runtime_evidence() -> WineProtonRuntimeEvidence:
    wine_proton_runtime_evidence_new(
        "steam-runtime abi-x86_64 soldier",
        "pressure-vessel-container container-rootfs pid fs ipc net capability",
        "vulkan-loader vulkan-device dxvk vkd3d-proton shader-cache",
        "proton-launcher steamworks-bridge controller-input",
        "esync-or-fsync"
    )
