# Process-local widget registry helpers used by the hub widget module.

use common.ui.widget_kind.{WidgetKind, LayoutKind}

struct WidgetNode:
    id: text

struct WidgetRecord:
    id: text
    kind: text
    layout: text
    visible: bool
    focused: bool

struct WidgetProp:
    node_id: text
    key: text
    value: text

var _widget_registry: [WidgetRecord] = []
var _widget_props_store: [WidgetProp] = []
var _widget_registry_ready = false
var _widget_props_ready = false
var _widget_store_revision: i64 = 0

fn widget_store_revision() -> i64:
    _widget_store_revision

fn bump_widget_store_revision():
    _widget_store_revision = _widget_store_revision + 1

fn parse_widget_kind(name: text) -> WidgetKind:
    return WidgetKind.from_wire(name)

fn parse_layout_kind(name: text) -> LayoutKind:
    return LayoutKind.from_wire(name)

fn parse_semantic_prop(name: text) -> text:
    val key = name.to_lower()
    match key:
        "app-background" => return "app_background"
        "app-surface" => return "app_surface"
        "widget-radius" => return "widget_radius"
        "widget-shadow" => return "widget_shadow"
        "text-primary" => return "text_primary"
        "text-secondary" => return "text_secondary"
        "accent-color" => return "accent_color"
        "icon-id" => return "icon_id"
        _ => return key

fn default_widget_record(id: text, kind: text) -> WidgetRecord:
    return WidgetRecord(id: id, kind: parse_widget_kind(kind).to_wire(), layout: "vbox", visible: true, focused: false)

fn upsert_widget_record(record: WidgetRecord):
    val registry_len = _widget_registry.len()
    var replaced = false
    var scan_idx = 0
    while scan_idx < registry_len:
        if _widget_registry[scan_idx].id == record.id:
            replaced = true
            scan_idx = registry_len
        scan_idx = scan_idx + 1
    var updated_len = registry_len
    if not replaced:
        updated_len = registry_len + 1
    var updated: [WidgetRecord] = [record; updated_len]
    var write_idx = 0
    while write_idx < registry_len:
        val existing = _widget_registry[write_idx]
        if existing.id == record.id:
            updated[write_idx] = record
        else:
            updated[write_idx] = existing
        write_idx = write_idx + 1
    if not replaced:
        updated[registry_len] = record
    _widget_registry = updated
    _widget_registry_ready = true
    bump_widget_store_revision()

fn get_widget_record(id: text) -> WidgetRecord?:
    if not _widget_registry_ready:
        return nil
    for record in _widget_registry:
        if record.id == id:
            return record
    return nil

fn require_widget_record(id: text) -> WidgetRecord:
    val found = get_widget_record(id)
    if found != nil:
        return found
    val fallback = default_widget_record(id, "panel")
    upsert_widget_record(fallback)
    return fallback

fn get_widget(id: text) -> WidgetNode?:
    return WidgetNode(id: id)

fn get_widget_child_ids(id: text) -> [text]:
    return decode_child_ids(get_internal_prop(id, "ui_children"))

fn register_widget_child(parent_id: text, child_id: text):
    val existing = get_widget_child_ids(parent_id)
    for current_id in existing:
        if current_id == child_id:
            return
    val existing_len = existing.len()
    var updated: [text] = [child_id; existing_len + 1]
    var i = 0
    while i < existing_len:
        updated[i] = existing[i]
        i = i + 1
    updated[existing_len] = child_id
    set_internal_prop(parent_id, "ui_children", encode_child_ids(updated))

fn widget_props() -> [WidgetProp]:
    if not _widget_props_ready:
        return []
    return _widget_props_store

fn set_widget_props(props: [WidgetProp]):
    _widget_props_store = props
    _widget_props_ready = true
    bump_widget_store_revision()

fn get_internal_prop(node_id: text, key: text) -> text:
    if not _widget_props_ready:
        return ""
    for prop in _widget_props_store:
        if prop.node_id == node_id and prop.key == key:
            return prop.value
    return ""

fn set_internal_prop(node_id: text, key: text, value: text):
    val new_prop = WidgetProp(node_id: node_id, key: key, value: value)
    if not _widget_props_ready:
        _widget_props_store = [new_prop]
        _widget_props_ready = true
        bump_widget_store_revision()
        return
    val prop_len = _widget_props_store.len()
    var replaced = false
    var scan_idx = 0
    while scan_idx < prop_len:
        val prop = _widget_props_store[scan_idx]
        if prop.node_id == node_id and prop.key == key:
            replaced = true
            scan_idx = prop_len
        scan_idx = scan_idx + 1
    var updated_len = prop_len
    if not replaced:
        updated_len = prop_len + 1
    var props: [WidgetProp] = [new_prop; updated_len]
    var write_idx = 0
    while write_idx < prop_len:
        val prop = _widget_props_store[write_idx]
        if prop.node_id == node_id and prop.key == key:
            props[write_idx] = new_prop
        else:
            props[write_idx] = prop
        write_idx = write_idx + 1
    if not replaced:
        props[prop_len] = new_prop
    _widget_props_store = props
    bump_widget_store_revision()

fn encode_child_ids(ids: [text]) -> text:
    return ids.join(",")

fn decode_child_ids(blob: text) -> [text]:
    if blob == "":
        return []
    val parts = blob.split(",")
    var id_count = 0
    for part in parts:
        if part != "":
            id_count = id_count + 1
    if id_count == 0:
        return []
    var ids: [text] = [""; id_count]
    var write_idx = 0
    for part in parts:
        if part != "":
            ids[write_idx] = part
            write_idx = write_idx + 1
    return ids

impl WidgetNode:
    static fn new(id: text, kind: text) -> WidgetNode:
        val handle = WidgetNode(id: id)
        upsert_widget_record(default_widget_record(id, kind))
        return handle

    fn kind_name() -> text:
        return require_widget_record(self.id).kind

    fn layout_name() -> text:
        return require_widget_record(self.id).layout

    fn is_visible() -> bool:
        return require_widget_record(self.id).visible

    fn is_focused() -> bool:
        return require_widget_record(self.id).focused

    fn kind() -> text: self.kind_name()
    fn layout() -> text: self.layout_name()
    fn visible() -> bool: self.is_visible()
    fn focused() -> bool: self.is_focused()

    fn set_prop(key: text, value: text) -> WidgetNode:
        set_internal_prop(self.id, parse_semantic_prop(key), value)
        return self

    fn add_child(child: WidgetNode) -> WidgetNode:
        register_widget_child(self.id, child.id)
        return self

    fn set_layout(layout: text) -> WidgetNode:
        val record = require_widget_record(self.id)
        upsert_widget_record(WidgetRecord(id: self.id, kind: record.kind, layout: parse_layout_kind(layout).to_wire(), visible: record.visible, focused: record.focused))
        return self

    fn set_visible(visible: bool) -> WidgetNode:
        val record = require_widget_record(self.id)
        upsert_widget_record(WidgetRecord(id: self.id, kind: record.kind, layout: record.layout, visible: visible, focused: record.focused))
        return self

    fn get_prop(key: text) -> text:
        return get_internal_prop(self.id, parse_semantic_prop(key))

    fn has_prop(key: text) -> bool:
        return get_internal_prop(self.id, parse_semantic_prop(key)) != ""

    fn prop_keys() -> [text]:
        var key_count = 0
        for prop in _widget_props_store:
            if prop.node_id == self.id:
                key_count = key_count + 1
        if key_count == 0:
            return []
        var keys: [text] = [""; key_count]
        var write_idx = 0
        for prop in _widget_props_store:
            if prop.node_id == self.id:
                keys[write_idx] = prop.key
                write_idx = write_idx + 1
        return keys

    fn children() -> [WidgetNode]:
        val child_ids = get_widget_child_ids(self.id)
        var child_count = 0
        for id in child_ids:
            if get_widget(id) != nil:
                child_count = child_count + 1
        if child_count == 0:
            return []
        var result: [WidgetNode] = [WidgetNode(id: ""); child_count]
        var write_idx = 0
        for id in child_ids:
            val child = get_widget(id)
            if child != nil:
                result[write_idx] = child
                write_idx = write_idx + 1
        return result

    fn child_count() -> i32:
        var count: i32 = 0
        for id in get_widget_child_ids(self.id):
            count = count + 1
        return count

    fn child_at(index: i32) -> WidgetNode?:
        if index < 0:
            return nil
        var i: i32 = 0
        for id in get_widget_child_ids(self.id):
            if i == index:
                return get_widget(id)
            i = i + 1
        return nil

    fn find_by_id(target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children():
            val found = child.find_by_id(target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids() -> [text]:
        var ids: [text] = [self.id]
        for child in self.children():
            for cid in child.collect_ids():
                ids.push(cid)
        return ids

    fn widget_summary() -> text:
        return "{self.id} ({self.kind_name()})"
