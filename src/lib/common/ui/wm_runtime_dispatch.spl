# Shared WM runtime dispatch adapter.
#
# Converts backend-neutral SharedWmDispatchResult values into stable command
# names and payload text that host WM and SimpleOS WM runtimes can consume.

use common.ui.window_scene.{SharedWmDispatchResult}

struct WmRuntimeDispatchCommand:
    kind: text
    target_id: text
    app_id: text
    window_id: text
    payload: text
    handled: bool

struct WmRuntimeShellState:
    launched_apps: [text]
    focused_window_id: text
    dragging_surface_id: text
    command_lane_target: text
    background_click_count: i32
    last_command_kind: text
    closed_window_ids: [text]
    minimized_window_ids: [text]

fn wm_runtime_shell_state_empty() -> WmRuntimeShellState:
    WmRuntimeShellState(
        launched_apps: [],
        focused_window_id: "",
        dragging_surface_id: "",
        command_lane_target: "",
        background_click_count: 0,
        last_command_kind: "",
        closed_window_ids: [],
        minimized_window_ids: []
    )

fn _wm_runtime_state(launched_apps: [text], focused_window_id: text, dragging_surface_id: text, command_lane_target: text, background_click_count: i32, last_command_kind: text, closed_window_ids: [text], minimized_window_ids: [text]) -> WmRuntimeShellState:
    WmRuntimeShellState(
        launched_apps: launched_apps,
        focused_window_id: focused_window_id,
        dragging_surface_id: dragging_surface_id,
        command_lane_target: command_lane_target,
        background_click_count: background_click_count,
        last_command_kind: last_command_kind,
        closed_window_ids: closed_window_ids,
        minimized_window_ids: minimized_window_ids
    )

fn wm_runtime_dispatch_command(kind: text, target_id: text, app_id: text, window_id: text, payload: text, handled: bool) -> WmRuntimeDispatchCommand:
    WmRuntimeDispatchCommand(
        kind: kind,
        target_id: target_id,
        app_id: app_id,
        window_id: window_id,
        payload: payload,
        handled: handled
    )

fn wm_runtime_command_from_shared_dispatch(result: SharedWmDispatchResult) -> WmRuntimeDispatchCommand:
    if result.action == "launch_app":
        return wm_runtime_dispatch_command(
            "launcher_launch",
            result.target_id,
            result.app_id,
            "",
            "app_id={result.app_id}",
            true
        )
    if result.action == "focus_window":
        return wm_runtime_dispatch_command(
            "window_focus",
            result.target_id,
            result.app_id,
            result.window_id,
            "window_id={result.window_id};app_id={result.app_id}",
            true
        )
    if result.action == "begin_drag_window":
        return wm_runtime_dispatch_command(
            "window_drag_begin",
            result.target_id,
            result.app_id,
            result.window_id,
            "surface_id={result.target_id};window_id={result.window_id}",
            true
        )
    if result.action == "close_window":
        return wm_runtime_dispatch_command(
            "window_close",
            result.target_id,
            result.app_id,
            result.window_id,
            "surface_id={result.target_id};window_id={result.window_id}",
            true
        )
    if result.action == "minimize_window":
        return wm_runtime_dispatch_command(
            "window_minimize",
            result.target_id,
            result.app_id,
            result.window_id,
            "surface_id={result.target_id};window_id={result.window_id}",
            true
        )
    if result.action == "command_lane_clock":
        return wm_runtime_dispatch_command(
            "command_lane_clock",
            result.target_id,
            "",
            "",
            "target=clock",
            true
        )
    if result.action == "command_lane_icon":
        return wm_runtime_dispatch_command(
            "command_lane_icon",
            result.target_id,
            "",
            "",
            "target={result.target_id}",
            true
        )
    if result.action == "desktop_background":
        return wm_runtime_dispatch_command(
            "desktop_background",
            result.target_id,
            "",
            "",
            "target=background",
            true
        )
    if result.action == "command_lane":
        return wm_runtime_dispatch_command(
            "command_lane",
            result.target_id,
            "",
            "",
            "target=command_lane",
            true
        )
    wm_runtime_dispatch_command(
        "ignored",
        result.target_id,
        result.app_id,
        result.window_id,
        "",
        false
    )

fn wm_runtime_dispatch_wire(command: WmRuntimeDispatchCommand) -> text:
    var parts: [text] = [
        "kind=", command.kind,
        ";target=", command.target_id,
        ";app=", command.app_id,
        ";window=", command.window_id,
        ";handled=", "{command.handled}",
        ";payload=", command.payload
    ]
    parts.join("")

fn wm_runtime_apply_command(state: WmRuntimeShellState, command: WmRuntimeDispatchCommand) -> WmRuntimeShellState:
    if not command.handled:
        return _wm_runtime_state(state.launched_apps, state.focused_window_id, state.dragging_surface_id, state.command_lane_target, state.background_click_count, "ignored", state.closed_window_ids, state.minimized_window_ids)
    if command.kind == "launcher_launch":
        var launched = state.launched_apps
        launched = launched.push(command.app_id)
        return _wm_runtime_state(launched, state.focused_window_id, state.dragging_surface_id, state.command_lane_target, state.background_click_count, command.kind, state.closed_window_ids, state.minimized_window_ids)
    if command.kind == "window_focus":
        return _wm_runtime_state(state.launched_apps, command.window_id, "", state.command_lane_target, state.background_click_count, command.kind, state.closed_window_ids, state.minimized_window_ids)
    if command.kind == "window_drag_begin":
        return _wm_runtime_state(state.launched_apps, command.window_id, command.target_id, state.command_lane_target, state.background_click_count, command.kind, state.closed_window_ids, state.minimized_window_ids)
    if command.kind == "window_close":
        var closed = state.closed_window_ids
        closed = closed.push(command.window_id)
        val focus_after_close = if state.focused_window_id == command.window_id: "" else: state.focused_window_id
        val drag_after_close = if state.dragging_surface_id == command.target_id: "" else: state.dragging_surface_id
        return _wm_runtime_state(state.launched_apps, focus_after_close, drag_after_close, state.command_lane_target, state.background_click_count, command.kind, closed, state.minimized_window_ids)
    if command.kind == "window_minimize":
        var minimized = state.minimized_window_ids
        minimized = minimized.push(command.window_id)
        val focus_after_min = if state.focused_window_id == command.window_id: "" else: state.focused_window_id
        val drag_after_min = if state.dragging_surface_id == command.target_id: "" else: state.dragging_surface_id
        return _wm_runtime_state(state.launched_apps, focus_after_min, drag_after_min, state.command_lane_target, state.background_click_count, command.kind, state.closed_window_ids, minimized)
    if command.kind == "command_lane_clock" or command.kind == "command_lane_icon" or command.kind == "command_lane":
        return _wm_runtime_state(state.launched_apps, state.focused_window_id, state.dragging_surface_id, command.target_id, state.background_click_count, command.kind, state.closed_window_ids, state.minimized_window_ids)
    if command.kind == "desktop_background":
        return _wm_runtime_state(state.launched_apps, "", "", state.command_lane_target, state.background_click_count + 1, command.kind, state.closed_window_ids, state.minimized_window_ids)
    _wm_runtime_state(state.launched_apps, state.focused_window_id, state.dragging_surface_id, state.command_lane_target, state.background_click_count, "ignored", state.closed_window_ids, state.minimized_window_ids)

fn wm_runtime_apply_shared_dispatch(state: WmRuntimeShellState, result: SharedWmDispatchResult) -> WmRuntimeShellState:
    wm_runtime_apply_command(state, wm_runtime_command_from_shared_dispatch(result))
