# Generated-WASM hello GUI artifacts.
#
# Provides deterministic no-JavaScript hello-world GUI artifacts for mobile
# and WM targets while the real WASM compiler/linker path is being hardened.

use common.ui.web_render_api.{
    WEB_RENDER_TARGET_ANDROID_WASM,
    WEB_RENDER_TARGET_HOST_WM_WASM,
    WEB_RENDER_TARGET_IOS_WASM,
    WEB_RENDER_TARGET_SIMPLEOS_WM_WASM,
    WebRenderArtifact,
    WebRenderRequest,
    WebRenderWasmArtifactMetadata,
    web_render_generated_wasm_artifact,
    web_render_wasm_abi_for_target,
    web_render_wasm_no_js_validation_error
}

struct WasmHelloGuiArtifact:
    name: text
    request: WebRenderRequest
    metadata: WebRenderWasmArtifactMetadata
    artifact: WebRenderArtifact
    validation_error: text

struct WasmHelloGuiCompilePlan:
    target: text
    source_entry: text
    target_triple: text
    linker: text
    output_path: text
    abi: text
    ready: bool
    blocker: text

struct WasmHelloGuiCompileRequest:
    plan: WasmHelloGuiCompilePlan
    wasm_linker_path: text
    wasi_sysroot: text
    source_available: bool
    command_line: text

struct WasmHelloGuiCompileResult:
    target: text
    output_path: text
    status: text
    ready: bool
    diagnostic: text
    command_line: text

struct WasmHelloGuiTargetPackage:
    target: text
    name: text
    platform: text
    module_path: text
    launcher_entry: text
    shell_runtime: text
    no_javascript: bool
    event_contract: text
    render_contract: text
    ready: bool
    blocker: text

struct WasmHelloGuiCompiledArtifactEvidence:
    target: text
    output_path: text
    size_bytes: i64
    magic_hex: text
    version: i32
    has_smf_marker: bool
    has_spl_main: bool
    has_ui_exports: bool
    has_ui_strings: bool
    has_event_strings: bool
    status: text
    ready: bool
    diagnostic: text

fn _wasm_hello_target_name(target: text) -> text:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return "android"
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return "ios"
    if target == WEB_RENDER_TARGET_HOST_WM_WASM:
        return "host-wm"
    if target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM:
        return "simpleos-wm"
    "unknown"

fn _wasm_hello_viewport_w(target: text) -> i32:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return 412
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return 390
    800

fn _wasm_hello_viewport_h(target: text) -> i32:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return 915
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return 844
    600

fn _wasm_hello_platform(target: text) -> text:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return "android"
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return "ios"
    if target == WEB_RENDER_TARGET_HOST_WM_WASM:
        return "host-wm"
    if target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM:
        return "simpleos-wm"
    "unknown"

fn _wasm_hello_launcher_entry(target: text) -> text:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return "android-native-wasm-surface"
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return "ios-native-wasm-surface"
    if target == WEB_RENDER_TARGET_HOST_WM_WASM:
        return "host-wm-native-wasm-window"
    if target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM:
        return "simpleos-wm-native-wasm-window"
    "unknown"

fn _wasm_hello_shell_runtime(target: text) -> text:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return "android:no-js:wasm32-simple-ui"
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return "ios:no-js:wasm32-simple-ui"
    if target == WEB_RENDER_TARGET_HOST_WM_WASM:
        return "host-wm:no-js:wasm32-simple-ui"
    if target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM:
        return "simpleos-wm:no-js:wasm32-simple-ui"
    "unknown"

fn _wasm_hello_event_contract() -> text:
    "button:hello_button:click->hello_button:clicked;scroll:viewport->hello_scroll:accepted;text:hello_text->hello_text:accepted"

fn _wasm_hello_render_contract(target: text) -> text:
    "viewport={_wasm_hello_viewport_w(target)}x{_wasm_hello_viewport_h(target)};layout=column-gap-8-padding-16;button-min-height=44;dpi=target-native"

fn wasm_hello_gui_artifact_for_target(target: text) -> WasmHelloGuiArtifact:
    val name = _wasm_hello_target_name(target)
    val title = "Hello " + name
    val body = "<main data-simple-wasm='hello' data-target='" + name + "'><button id='hello_button'>Hello World</button><p id='hello_text'>Generated WASM UI</p></main>"
    val css = "main{display:flex;flex-direction:column;gap:8px;padding:16px;}button{min-height:44px;}"
    val request = WebRenderRequest.html(target, title, body, css, "", _wasm_hello_viewport_w(target), _wasm_hello_viewport_h(target))
    val module_path = "build/gui/" + name + "/hello.wasm"
    val metadata = WebRenderWasmArtifactMetadata.create(
        module_path,
        web_render_wasm_abi_for_target(target),
        4096,
        256,
        6
    )
    val artifact = web_render_generated_wasm_artifact(request, metadata)
    WasmHelloGuiArtifact(
        name: name,
        request: request,
        metadata: metadata,
        artifact: artifact,
        validation_error: web_render_wasm_no_js_validation_error(request, metadata)
    )

fn wasm_hello_gui_compile_plan_for_target(target: text) -> WasmHelloGuiCompilePlan:
    val hello = wasm_hello_gui_artifact_for_target(target)
    val ready = hello.validation_error == ""
    val blocker = if ready:
        ""
    else:
        hello.validation_error
    WasmHelloGuiCompilePlan(
        target: target,
        source_entry: "examples/ui/hello_wasm_gui.spl",
        target_triple: "wasm32-unknown-unknown",
        linker: "wasm-ld",
        output_path: hello.metadata.module_path,
        abi: hello.metadata.abi,
        ready: ready,
        blocker: blocker
    )

fn wasm_hello_gui_compile_plan_summary(plan: WasmHelloGuiCompilePlan) -> text:
    "target={plan.target};entry={plan.source_entry};triple={plan.target_triple};linker={plan.linker};output={plan.output_path};abi={plan.abi};ready={plan.ready};blocker={plan.blocker}"

fn wasm_hello_gui_compile_request(plan: WasmHelloGuiCompilePlan, wasm_linker_path: text, wasi_sysroot: text, source_available: bool) -> WasmHelloGuiCompileRequest:
    val linker = if wasm_linker_path == "":
        plan.linker
    else:
        wasm_linker_path
    val command_line = "simple build --target=wasm --entry " + plan.source_entry + " --triple " + plan.target_triple + " --linker " + linker + " --sysroot " + wasi_sysroot + " --output " + plan.output_path
    WasmHelloGuiCompileRequest(
        plan: plan,
        wasm_linker_path: wasm_linker_path,
        wasi_sysroot: wasi_sysroot,
        source_available: source_available,
        command_line: command_line
    )

fn wasm_hello_gui_compile_result_for_request(request: WasmHelloGuiCompileRequest, artifact_exists: bool) -> WasmHelloGuiCompileResult:
    if !request.plan.ready:
        return WasmHelloGuiCompileResult(
            target: request.plan.target,
            output_path: request.plan.output_path,
            status: "compile_plan_blocked",
            ready: false,
            diagnostic: request.plan.blocker,
            command_line: request.command_line
        )
    if request.wasm_linker_path == "":
        return WasmHelloGuiCompileResult(
            target: request.plan.target,
            output_path: request.plan.output_path,
            status: "missing_wasm_linker",
            ready: false,
            diagnostic: "wasm linker path is required before invoking " + request.plan.linker,
            command_line: request.command_line
        )
    if request.wasi_sysroot == "":
        return WasmHelloGuiCompileResult(
            target: request.plan.target,
            output_path: request.plan.output_path,
            status: "missing_wasi_sysroot",
            ready: false,
            diagnostic: "WASI sysroot is required for no-JavaScript GUI WASM linking",
            command_line: request.command_line
        )
    if !request.source_available:
        return WasmHelloGuiCompileResult(
            target: request.plan.target,
            output_path: request.plan.output_path,
            status: "missing_source_entry",
            ready: false,
            diagnostic: "source entry is not available: " + request.plan.source_entry,
            command_line: request.command_line
        )
    if artifact_exists:
        return WasmHelloGuiCompileResult(
            target: request.plan.target,
            output_path: request.plan.output_path,
            status: "compiled_artifact_available",
            ready: true,
            diagnostic: "",
            command_line: request.command_line
        )
    WasmHelloGuiCompileResult(
        target: request.plan.target,
        output_path: request.plan.output_path,
        status: "ready_to_invoke",
        ready: true,
        diagnostic: "",
        command_line: request.command_line
    )

fn wasm_hello_gui_compile_result_summary(result: WasmHelloGuiCompileResult) -> text:
    "target={result.target};output={result.output_path};status={result.status};ready={result.ready};diagnostic={result.diagnostic};command={result.command_line}"

fn wasm_hello_gui_target_package_for_target(target: text) -> WasmHelloGuiTargetPackage:
    val hello = wasm_hello_gui_artifact_for_target(target)
    val no_js = hello.request.js == "" and hello.artifact.ipc_json == "" and !hello.artifact.html.contains("<script")
    val ready = hello.validation_error == "" and no_js and hello.metadata.module_path != "" and hello.metadata.abi != ""
    var blocker = ""
    if hello.validation_error != "":
        blocker = hello.validation_error
    else:
        if !no_js:
            blocker = "javascript or host IPC bridge is present"
        else:
            if hello.metadata.module_path == "":
                blocker = "compiled module path is missing"
            else:
                if hello.metadata.abi == "":
                    blocker = "WASM ABI is missing"
    WasmHelloGuiTargetPackage(
        target: target,
        name: hello.name,
        platform: _wasm_hello_platform(target),
        module_path: hello.metadata.module_path,
        launcher_entry: _wasm_hello_launcher_entry(target),
        shell_runtime: _wasm_hello_shell_runtime(target),
        no_javascript: no_js,
        event_contract: _wasm_hello_event_contract(),
        render_contract: _wasm_hello_render_contract(target),
        ready: ready,
        blocker: blocker
    )

fn wasm_hello_gui_target_packages() -> [WasmHelloGuiTargetPackage]:
    [
        wasm_hello_gui_target_package_for_target(WEB_RENDER_TARGET_ANDROID_WASM),
        wasm_hello_gui_target_package_for_target(WEB_RENDER_TARGET_IOS_WASM),
        wasm_hello_gui_target_package_for_target(WEB_RENDER_TARGET_HOST_WM_WASM),
        wasm_hello_gui_target_package_for_target(WEB_RENDER_TARGET_SIMPLEOS_WM_WASM)
    ]

fn wasm_hello_gui_target_package_summary(package: WasmHelloGuiTargetPackage) -> text:
    "target={package.target};platform={package.platform};module={package.module_path};launcher={package.launcher_entry};runtime={package.shell_runtime};no_js={package.no_javascript};events={package.event_contract};render={package.render_contract};ready={package.ready};blocker={package.blocker}"

fn wasm_hello_gui_compiled_artifact_evidence(target: text, output_path: text, size_bytes: i64, magic_hex: text, version: i32, has_smf_marker: bool, has_spl_main: bool, has_ui_exports: bool, has_ui_strings: bool, has_event_strings: bool) -> WasmHelloGuiCompiledArtifactEvidence:
    var status = "compiled_wasm_verified"
    var diagnostic = ""
    var ready = true
    if size_bytes <= 0:
        status = "missing_or_empty_artifact"
        diagnostic = "compiled WASM artifact is missing or empty"
        ready = false
    else:
        if magic_hex != "0061736d":
            status = "invalid_wasm_magic"
            diagnostic = "compiled artifact does not start with WASM magic"
            ready = false
        else:
            if version != 1:
                status = "invalid_wasm_version"
                diagnostic = "compiled artifact is not WASM version 1"
                ready = false
            else:
                if has_smf_marker:
                    status = "smf_artifact_not_wasm"
                    diagnostic = "compiled artifact still contains the SMF marker"
                    ready = false
                else:
                    if !has_spl_main:
                        status = "missing_spl_main"
                        diagnostic = "compiled WASM artifact does not export or contain spl_main"
                        ready = false
                    else:
                        if !has_ui_exports:
                            status = "missing_ui_exports"
                            diagnostic = "compiled WASM artifact is missing hello GUI exports"
                            ready = false
                        else:
                            if !has_ui_strings:
                                status = "missing_ui_strings"
                                diagnostic = "compiled WASM artifact is missing hello GUI markup strings"
                                ready = false
                            else:
                                if !has_event_strings:
                                    status = "missing_event_strings"
                                    diagnostic = "compiled WASM artifact is missing button scroll text event strings"
                                    ready = false
    WasmHelloGuiCompiledArtifactEvidence(
        target: target,
        output_path: output_path,
        size_bytes: size_bytes,
        magic_hex: magic_hex,
        version: version,
        has_smf_marker: has_smf_marker,
        has_spl_main: has_spl_main,
        has_ui_exports: has_ui_exports,
        has_ui_strings: has_ui_strings,
        has_event_strings: has_event_strings,
        status: status,
        ready: ready,
        diagnostic: diagnostic
    )

fn wasm_hello_gui_compile_plans() -> [WasmHelloGuiCompilePlan]:
    [
        wasm_hello_gui_compile_plan_for_target(WEB_RENDER_TARGET_ANDROID_WASM),
        wasm_hello_gui_compile_plan_for_target(WEB_RENDER_TARGET_IOS_WASM),
        wasm_hello_gui_compile_plan_for_target(WEB_RENDER_TARGET_HOST_WM_WASM),
        wasm_hello_gui_compile_plan_for_target(WEB_RENDER_TARGET_SIMPLEOS_WM_WASM)
    ]

fn wasm_hello_gui_artifacts() -> [WasmHelloGuiArtifact]:
    [
        wasm_hello_gui_artifact_for_target(WEB_RENDER_TARGET_ANDROID_WASM),
        wasm_hello_gui_artifact_for_target(WEB_RENDER_TARGET_IOS_WASM),
        wasm_hello_gui_artifact_for_target(WEB_RENDER_TARGET_HOST_WM_WASM),
        wasm_hello_gui_artifact_for_target(WEB_RENDER_TARGET_SIMPLEOS_WM_WASM)
    ]
