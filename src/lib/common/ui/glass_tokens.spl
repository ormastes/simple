# =========================================================================
# designMd sidecar loader
# =========================================================================

extern fn rt_file_read_text(path: text) -> text

fn load_stitch_design_md() -> text:
    """Load the expanded designMd sidecar (140 lines, 22 sections) for Stitch push payloads."""
    val body = rt_file_read_text("src/lib/common/ui/stitch_design_md.sdn")
    return body

# =========================================================================
# Stitch Design System Metadata
# =========================================================================
# Mirrors the `theme` subobject of Stitch's design system JSON. Holds
# typography strategy (font enums), shape scale (roundness), and the
# color seed / colorVariant that feeds Stitch's dynamic color generator.
# This is the metadata Stitch stores alongside the color tokens.

class StitchMetadata:
    display_name: text
    color_mode: text           # "DARK" or "LIGHT"
    color_variant: text        # TONAL_SPOT | FIDELITY | VIBRANT | MONOCHROME | ...
    custom_color: text         # hex seed color
    roundness: text            # ROUND_FOUR | ROUND_EIGHT | ROUND_TWELVE | ROUND_FULL
    spacing_scale: i32         # integer scale factor (Obsidian uses 2)
    font: text                 # top-level font fallback
    headline_font: text        # Stitch font enum (e.g. SPACE_GROTESK)
    body_font: text
    label_font: text
    override_primary_color: text
    override_secondary_color: text
    override_tertiary_color: text
    override_neutral_color: text
    design_md: text              # expanded designMd body (140 lines) for Stitch push payloads

    static fn obsidian() -> StitchMetadata:
        return StitchMetadata(
            display_name: "SimpleOS Obsidian",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_EIGHT",
            spacing_scale: 2,
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "MANROPE",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612",
            design_md: load_stitch_design_md()
        )

    static fn glass() -> StitchMetadata:
        return StitchMetadata(
            display_name: "SimpleOS Glass",
            color_mode: "DARK",
            color_variant: "TONAL_SPOT",
            custom_color: "#0A84FF",
            roundness: "ROUND_TWELVE",
            spacing_scale: 1,
            font: "MANROPE",
            headline_font: "MANROPE",
            body_font: "INTER",
            label_font: "SPACE_GROTESK",
            override_primary_color: "#0A84FF",
            override_secondary_color: "#BB86FC",
            override_tertiary_color: "#30D158",
            override_neutral_color: "#1E1E23",
            design_md: load_stitch_design_md()
        )

    static fn celestial_ether() -> StitchMetadata:
        return StitchMetadata(
            display_name: "Celestial Ether",
            color_mode: "LIGHT",
            color_variant: "TONAL_SPOT",
            custom_color: "#C8B8E8",
            roundness: "ROUND_EIGHT",
            spacing_scale: 1,
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "SPACE_GROTESK",
            label_font: "SPACE_GROTESK",
            override_primary_color: "#7C69A3",
            override_secondary_color: "#C8B8E8",
            override_tertiary_color: "",
            override_neutral_color: "#F0ECF5",
            design_md: load_stitch_design_md()
        )

# =========================================================================
# Full Stitch Design System Bundle
# =========================================================================
# Composes MD3 named colors + Stitch metadata. This is the full shape that
# `mcp__stitch__update_design_system` expects (minus designMd which stays
# in the stitch skill as a text template).

class StitchDesignSystem:
    metadata: StitchMetadata
    md3: StitchMd3Colors

    static fn obsidian() -> StitchDesignSystem:
        return StitchDesignSystem(
            metadata: StitchMetadata.obsidian(),
            md3: StitchMd3Colors.obsidian()
        )

    static fn glass() -> StitchDesignSystem:
        # Glass uses TONAL_SPOT — MD3 named colors are computed at runtime
        # by Stitch from the seed + overrides, not stored explicitly.
        # We reuse Obsidian's MD3 set as a fallback for local consumers
        # that need a concrete color map; replace with a computed set once
        # the Stitch dynamic color algorithm is reimplemented locally.
        return StitchDesignSystem(
            metadata: StitchMetadata.glass(),
            md3: StitchMd3Colors.obsidian()
        )
