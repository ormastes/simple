# Glass Design Tokens
#
# Glassmorphism design tokens for macOS-inspired translucent UI.
# Uses backdrop-filter blur, semi-transparent surfaces, and subtle borders.
# No proprietary assets — pure CSS glassmorphism technique.
# Extends the existing theme system via composition.

use common.ui.design_tokens.{IOSTypographyScale, IOSRadiusTokens, IOSShadowTokens, IOSSpacingScale, IOSAnimationTokens, IOSOpacityTokens}

# =========================================================================
# Glass Color Tokens
# =========================================================================

class GlassColorTokens:
    # Surface colors (semi-transparent for blur effect)
    surface_primary: text
    surface_secondary: text
    surface_tertiary: text
    surface_elevated: text

    # Text colors
    text_primary: text
    text_secondary: text
    text_tertiary: text

    # Accent
    accent: text
    accent_hover: text

    # Semantic
    error: text
    warning: text
    success: text
    info: text

    # Borders (semi-transparent glass edge)
    border_subtle: text
    border_prominent: text

    # Separator
    separator: text

    static fn light() -> GlassColorTokens:
        return GlassColorTokens(
            surface_primary: "rgba(255,255,255,0.72)",
            surface_secondary: "rgba(255,255,255,0.52)",
            surface_tertiary: "rgba(255,255,255,0.36)",
            surface_elevated: "rgba(255,255,255,0.85)",
            text_primary: "#1D1D1F",
            text_secondary: "rgba(60,60,67,0.6)",
            text_tertiary: "rgba(60,60,67,0.3)",
            accent: "#007AFF",
            accent_hover: "#0056CC",
            error: "#FF3B30",
            warning: "#FF9500",
            success: "#34C759",
            info: "#5AC8FA",
            border_subtle: "rgba(0,0,0,0.08)",
            border_prominent: "rgba(0,0,0,0.15)",
            separator: "rgba(60,60,67,0.12)"
        )

    static fn dark() -> GlassColorTokens:
        return GlassColorTokens(
            surface_primary: "rgba(30,30,35,0.72)",
            surface_secondary: "rgba(40,40,48,0.52)",
            surface_tertiary: "rgba(50,50,58,0.36)",
            surface_elevated: "rgba(44,44,50,0.88)",
            text_primary: "#F5F5F7",
            text_secondary: "rgba(235,235,245,0.6)",
            text_tertiary: "rgba(235,235,245,0.3)",
            accent: "#0A84FF",
            accent_hover: "#409CFF",
            error: "#FF453A",
            warning: "#FF9F0A",
            success: "#30D158",
            info: "#64D2FF",
            border_subtle: "rgba(255,255,255,0.08)",
            border_prominent: "rgba(255,255,255,0.18)",
            separator: "rgba(84,84,88,0.36)"
        )

# =========================================================================
# Glass Blur Tokens
# =========================================================================

class GlassBlurTokens:
    surface_blur: i32
    elevated_blur: i32
    nav_blur: i32
    subtle_blur: i32

    static fn default_blur() -> GlassBlurTokens:
        return GlassBlurTokens(
            surface_blur: 20,
            elevated_blur: 40,
            nav_blur: 24,
            subtle_blur: 8
        )

# =========================================================================
# Composite Glass Design Tokens
# =========================================================================

class GlassDesignTokens:
    colors: GlassColorTokens
    blur: GlassBlurTokens
    typography: IOSTypographyScale
    radius: IOSRadiusTokens
    shadows: IOSShadowTokens
    spacing: IOSSpacingScale
    animation: IOSAnimationTokens
    opacity: IOSOpacityTokens

    static fn light() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.light(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )

    static fn dark() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.dark(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )
