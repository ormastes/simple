# Glass Design Tokens
#
# Glassmorphism design tokens for macOS-inspired translucent UI.
# Uses backdrop-filter blur, semi-transparent surfaces, and subtle borders.
# No proprietary assets — pure CSS glassmorphism technique.
# Extends the existing theme system via composition.

# Numeric equivalents (u64 hex values for baremetal rendering):
#   see glass_numeric_tokens.spl

use common.ui.design_tokens.{IOSTypographyScale, IOSRadiusTokens, IOSShadowTokens, IOSSpacingScale, IOSAnimationTokens, IOSOpacityTokens}

# =========================================================================
# Glass Color Tokens
# =========================================================================

class GlassColorTokens:
    # Surface colors (semi-transparent for blur effect)
    surface_primary: text
    surface_secondary: text
    surface_tertiary: text
    surface_elevated: text

    # Text colors
    text_primary: text
    text_secondary: text
    text_tertiary: text

    # Accent
    accent: text
    accent_hover: text

    # Semantic
    error: text
    warning: text
    success: text
    info: text

    # Borders (semi-transparent glass edge)
    border_subtle: text
    border_prominent: text

    # Separator
    separator: text

    # MD3 surface container tiers
    surface_container_lowest: text
    surface_container_low: text
    surface_container: text
    surface_container_high: text
    surface_container_highest: text

    # MD3 on_surface_variant (secondary text)
    on_surface_variant: text

    # 5-level surface hierarchy
    surface_level_0: text
    surface_level_1: text
    surface_level_2: text
    surface_level_3: text
    surface_level_4: text

