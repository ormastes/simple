    text_primary: text
    text_secondary: text
    text_tertiary: text

    # Accent
    accent: text
    accent_hover: text

    # Semantic
    error: text
    warning: text
    success: text
    info: text

    # Borders (semi-transparent glass edge)
    border_subtle: text
