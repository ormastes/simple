# =========================================================================
# Glass Blur Tokens
# =========================================================================

class GlassBlurTokens:
    surface_blur: i32
    elevated_blur: i32
    nav_blur: i32
    subtle_blur: i32

    static fn default_blur() -> GlassBlurTokens:
        return GlassBlurTokens(
            surface_blur: 20,
            elevated_blur: 40,
            nav_blur: 24,
            subtle_blur: 8
        )

# =========================================================================
# Composite Glass Design Tokens
# =========================================================================

class GlassDesignTokens:
    colors: GlassColorTokens
    blur: GlassBlurTokens
    typography: IOSTypographyScale
    radius: IOSRadiusTokens
    shadows: IOSShadowTokens
    spacing: IOSSpacingScale
    animation: IOSAnimationTokens
    opacity: IOSOpacityTokens

    static fn light() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.light(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )

    static fn dark() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.dark(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )

    static fn obsidian_dark() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.obsidian_dark(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )

    static fn obsidian_light() -> GlassDesignTokens:
        return GlassDesignTokens(
            colors: GlassColorTokens.obsidian_light(),
            blur: GlassBlurTokens.default_blur(),
            typography: IOSTypographyScale.default_scale(),
            radius: IOSRadiusTokens.default_radius(),
            shadows: IOSShadowTokens.default_shadows(),
            spacing: IOSSpacingScale.default_spacing(),
            animation: IOSAnimationTokens.default_animation(),
            opacity: IOSOpacityTokens.default_opacity()
        )

# =========================================================================
# Surface Level Hierarchy (5-level system)
# =========================================================================

class SurfaceLevel:
    level: i32
    name: text

    static fn bg() -> SurfaceLevel:
        SurfaceLevel(level: 0, name: "bg")

    static fn sidebar() -> SurfaceLevel:
        SurfaceLevel(level: 1, name: "sidebar")

    static fn card() -> SurfaceLevel:
        SurfaceLevel(level: 2, name: "card")

    static fn floating() -> SurfaceLevel:
        SurfaceLevel(level: 3, name: "floating")

    static fn modal() -> SurfaceLevel:
        SurfaceLevel(level: 4, name: "modal")

# =========================================================================
# Surface Level Helpers
# =========================================================================

fn surface_color_for_level(tokens: GlassColorTokens, level: i32) -> text:
    """Return the background color for a given surface level (0-4).
    Level 0 = solid bg, levels 1-4 = increasing white translucency.
    Values come from the tokens so light/dark/obsidian themes work."""
    if level == 0:
        return tokens.surface_level_0
    if level == 1:
        return tokens.surface_level_1
    if level == 2:
        return tokens.surface_level_2
    if level == 3:
        return tokens.surface_level_3
    if level == 4:
        return tokens.surface_level_4
    return tokens.surface_level_0

fn surface_blur_for_level(level: i32) -> i32:
    """Return the backdrop-filter blur radius (px) for a surface level."""
    if level == 0:
        return 0
    if level == 1:
        return 10
    if level == 2:
        return 12
    if level == 3:
        return 16
    if level == 4:
        return 20
    return 0

fn surface_shadow_for_level(level: i32) -> text:
    """Return the box-shadow CSS value for a surface level."""
    if level == 0:
        return "none"
    if level == 1:
        return "0 1px 3px rgba(0,0,0,0.12)"
    if level == 2:
        return "0 4px 12px rgba(0,0,0,0.18)"
    if level == 3:
        return "0 8px 24px rgba(0,0,0,0.24)"
    if level == 4:
        return "0 12px 40px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.10)"
    return "none"

