# Typed Action API (Phase 5 UI Typed Core RFC)
#
# Provides a typed layer over the wire action name string. The wire format
# (UIEvent.Action(name: text)) is always a single text field; typed actions
# are converted to text via into_wire_name() at the API boundary.
#
# Trait support: Simple supports trait/impl...for; IntoAction is defined as a
# trait so app-defined enums can implement it. For dispatching, callers convert
# to Action via into_action() before passing to with_on_typed_action().
#
# Match syntax used: `case Enum.Variant:` for fieldless; `Enum.Variant(field):`
# for variants with fields (consistent with widget.spl / os_executor.spl).

# =========================================================================
# CommonAction — built-in well-known action names
# =========================================================================

enum CommonAction:
    Save
    Cancel
    Confirm
    Dismiss
    Back
    Search
    ToggleSidebar

impl CommonAction:
    fn to_wire(self) -> text:
        """Return the canonical wire name string for this common action."""
        match self:
            case CommonAction.Save: return "save"
            case CommonAction.Cancel: return "cancel"
            case CommonAction.Confirm: return "confirm"
            case CommonAction.Dismiss: return "dismiss"
            case CommonAction.Back: return "back"
            case CommonAction.Search: return "search"
            case CommonAction.ToggleSidebar: return "toggle_sidebar"

# =========================================================================
# Action — public API enum wrapping CommonAction or app-defined text
# =========================================================================

enum Action:
    Builtin(action: CommonAction)
    Custom(name: text)

impl Action:
    fn into_wire_name(self) -> text:
        """Return the wire name string. Used at the IPC boundary."""
        match self:
            Action.Builtin(action):
                return action.to_wire()
            Action.Custom(name):
                return name

# =========================================================================
# IntoAction trait — app-defined enums implement this to participate
# =========================================================================

trait IntoAction:
    fn into_action(self) -> Action

impl IntoAction for CommonAction:
    fn into_action(self) -> Action:
        """Lift a CommonAction into Action.Builtin."""
        return Action.Builtin(action: self)

impl IntoAction for Action:
    fn into_action(self) -> Action:
        """Identity: Action is already an Action."""
        return self
