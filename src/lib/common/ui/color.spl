# Common UI color wrapper used by theme modules.

class UIColor:
    value: text

    static fn from_hex(hex: text) -> UIColor:
        return UIColor(value: hex)

    static fn transparent() -> UIColor:
        return UIColor(value: "transparent")

    static fn inherit() -> UIColor:
        return UIColor(value: "inherit")

    fn to_css(self) -> text:
        return self.value
