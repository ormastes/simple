# Glass Debug — Theme inspection and diagnostic functions
#
# Pure functions for debugging theme tokens, CSS output, and widget trees.
# Used by both MCP tools (debug_ui_*) and CLI subcommand (debug-ui).

use common.ui.glass_tokens.{GlassDesignTokens}
use common.ui.glass_theme.{glass_design_tokens, is_glass_theme}
use common.ui.glass_css.{generate_glass_css}

# =========================================================================
# Theme listing
# =========================================================================

fn list_glass_themes() -> List<text>:
    var themes: List<text> = []
    themes.push("glass_dark")
    themes.push("glass_light")
    themes.push("glass_obsidian_dark")
    return themes

# =========================================================================
# Token dump
# =========================================================================

fn debug_theme_tokens(theme_name: text) -> text:
    """Return all token values for a theme as formatted text.
    Used by both MCP tool and CLI subcommand."""
    if not is_glass_theme(theme_name):
        return "Error: unknown theme '{theme_name}'. Use list-themes for available themes."

    val tokens = glass_design_tokens(theme_name)
    val c = tokens.colors
    val b = tokens.blur
    val r = tokens.radius

    var out = "Theme: {theme_name}\n"
    out = "{out}========================================\n"
    out = "{out}\n"
    out = "{out}[Colors]\n"
    out = "{out}  surface_primary:             {c.surface_primary}\n"
    out = "{out}  surface_secondary:           {c.surface_secondary}\n"
    out = "{out}  surface_tertiary:            {c.surface_tertiary}\n"
    out = "{out}  surface_elevated:            {c.surface_elevated}\n"
    out = "{out}  surface_container_lowest:    {c.surface_container_lowest}\n"
    out = "{out}  surface_container_low:       {c.surface_container_low}\n"
    out = "{out}  surface_container:           {c.surface_container}\n"
    out = "{out}  surface_container_high:      {c.surface_container_high}\n"
    out = "{out}  surface_container_highest:   {c.surface_container_highest}\n"
    out = "{out}  text_primary:                {c.text_primary}\n"
    out = "{out}  text_secondary:              {c.text_secondary}\n"
    out = "{out}  text_tertiary:               {c.text_tertiary}\n"
    out = "{out}  on_surface_variant:          {c.on_surface_variant}\n"
    out = "{out}  accent:                      {c.accent}\n"
    out = "{out}  accent_hover:                {c.accent_hover}\n"
    out = "{out}  error:                       {c.error}\n"
    out = "{out}  warning:                     {c.warning}\n"
    out = "{out}  success:                     {c.success}\n"
    out = "{out}  info:                        {c.info}\n"
    out = "{out}  border_subtle:               {c.border_subtle}\n"
    out = "{out}  border_prominent:            {c.border_prominent}\n"
    out = "{out}  separator:                   {c.separator}\n"
    out = "{out}\n"
    out = "{out}[Blur]\n"
    out = "{out}  surface_blur:  {b.surface_blur}px\n"
    out = "{out}  elevated_blur: {b.elevated_blur}px\n"
    out = "{out}  nav_blur:      {b.nav_blur}px\n"
    out = "{out}  subtle_blur:   {b.subtle_blur}px\n"
    out = "{out}\n"
    out = "{out}[Radius]\n"
    out = "{out}  sm: {r.sm}px\n"
    out = "{out}  md: {r.md}px\n"
    out = "{out}  lg: {r.lg}px\n"
    out = "{out}  xl: {r.xl}px\n"
    return out

# =========================================================================
# CSS dump
# =========================================================================

fn debug_css_dump(theme_name: text) -> text:
    """Return full CSS output for a theme.
    Delegates to generate_glass_css()."""
    if not is_glass_theme(theme_name):
        return "Error: unknown theme '{theme_name}'. Use list-themes for available themes."
    return generate_glass_css(theme_name)

# =========================================================================
# Widget tree
# =========================================================================

fn debug_widget_tree(theme_name: text) -> text:
    """Return a text representation of the widget tree with
    theme token assignments. Shows which CSS variables each
    widget class consumes."""
    if not is_glass_theme(theme_name):
        return "Error: unknown theme '{theme_name}'. Use list-themes for available themes."

    var out = "Widget Tree — {theme_name}\n"
    out = "{out}========================================\n"
    out = "{out}\n"
    out = "{out}:root\n"
    out = "{out}  (all --glass-* custom properties)\n"
    out = "{out}\n"
    out = "{out}+-- .widget-panel\n"
    out = "{out}|   background:      --glass-surface-primary\n"
    out = "{out}|   backdrop-filter:  --glass-blur-surface\n"
    out = "{out}|   border:           --glass-border-subtle\n"
    out = "{out}|   border-radius:    --glass-radius-lg\n"
    out = "{out}|   box-shadow:       --glass-shadow-sm\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-card\n"
    out = "{out}|   background:      --glass-surface-secondary\n"
    out = "{out}|   backdrop-filter:  --glass-blur-surface\n"
    out = "{out}|   border:           --glass-border-subtle\n"
    out = "{out}|   border-radius:    --glass-radius-lg\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-button\n"
    out = "{out}|   background:      --glass-accent\n"
    out = "{out}|   color:            --glass-text-primary\n"
    out = "{out}|   border-radius:    --glass-radius-md\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-input\n"
    out = "{out}|   background:      --glass-surface-secondary\n"
    out = "{out}|   border:           --glass-border-subtle\n"
    out = "{out}|   color:            --glass-text-primary\n"
    out = "{out}|   border-radius:    --glass-radius-md\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-nav\n"
    out = "{out}|   background:      --glass-surface-elevated\n"
    out = "{out}|   backdrop-filter:  --glass-blur-nav\n"
    out = "{out}|   border:           --glass-border-subtle\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-sidebar\n"
    out = "{out}|   background:      --glass-surface-container-low\n"
    out = "{out}|   border:           --glass-border-subtle\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-modal\n"
    out = "{out}|   background:      --glass-surface-elevated\n"
    out = "{out}|   backdrop-filter:  --glass-blur-elevated\n"
    out = "{out}|   border:           --glass-border-prominent\n"
    out = "{out}|   box-shadow:       --glass-shadow-xl\n"
    out = "{out}|\n"
    out = "{out}+-- .widget-tooltip\n"
    out = "{out}    background:      --glass-surface-container-highest\n"
    out = "{out}    color:            --glass-on-surface-variant\n"
    out = "{out}    border-radius:    --glass-radius-sm\n"
    return out
