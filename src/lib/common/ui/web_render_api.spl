# Shared web render API for GUI backends and pure Simple web rendering.

use common.ui.capability.{Capability}
use common.ui.widget.{UIEvent}
use common.text_advanced.{escape_json}

val WEB_RENDER_TARGET_SIMPLE_WEB: text = "simple_web"
val WEB_RENDER_TARGET_ELECTRON: text = "electron"
val WEB_RENDER_TARGET_TAURI: text = "tauri"
val WEB_RENDER_TARGET_CHROME: text = "chrome"
val WEB_RENDER_TARGET_CHROMIUM: text = "chromium"
val WEB_RENDER_TARGET_PURE_SIMPLE: text = "pure_simple"
val WEB_RENDER_TARGET_TUI_WEB: text = "tui_web"
val WEB_RENDER_TARGET_HEADLESS: text = "headless"
val WEB_RENDER_TARGET_ANDROID_WASM: text = "android_wasm"
val WEB_RENDER_TARGET_IOS_WASM: text = "ios_wasm"
val WEB_RENDER_TARGET_HOST_WM_WASM: text = "host_wm_wasm"
val WEB_RENDER_TARGET_SIMPLEOS_WM_WASM: text = "simpleos_wm_wasm"
val WEB_RENDER_CACHE_SCHEMA_VERSION: text = "simple-web-cache-v1"
val WEB_RENDER_WASM_SCHEMA_VERSION: text = "simple-web-wasm-v1"
val WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED: text = "not_requested"
val WEB_RENDER_ENGINE2D_STATUS_RENDERED: text = "engine2d_rendered"
val WEB_RENDER_ENGINE2D_STATUS_COMPATIBILITY: text = "compatibility_renderer"
val WEB_RENDER_ENGINE2D_STATUS_UNAVAILABLE: text = "engine2d_unavailable"

class WebRenderRequest:
    target: text
    surface_id: text
    title: text
    body_html: text
    css: text
    js: text
    viewport_w: i32
    viewport_h: i32
    wants_pixels: bool

    static fn html(target: text, title: text, body_html: text, css: text, js: text, viewport_w: i32, viewport_h: i32) -> WebRenderRequest:
        WebRenderRequest(
            target: target,
            surface_id: "",
            title: title,
            body_html: body_html,
            css: css,
            js: js,
            viewport_w: viewport_w,
            viewport_h: viewport_h,
            wants_pixels: false
        )

    me with_surface(surface_id: text) -> WebRenderRequest:
        WebRenderRequest(
            target: self.target,
            surface_id: surface_id,
            title: self.title,
            body_html: self.body_html,
            css: self.css,
            js: self.js,
            viewport_w: self.viewport_w,
            viewport_h: self.viewport_h,
            wants_pixels: self.wants_pixels
        )

    me with_pixel_output() -> WebRenderRequest:
        WebRenderRequest(
            target: self.target,
            surface_id: self.surface_id,
            title: self.title,
            body_html: self.body_html,
            css: self.css,
            js: self.js,
            viewport_w: self.viewport_w,
            viewport_h: self.viewport_h,
            wants_pixels: true
        )

fn web_render_default_page_body_html(url: text) -> text:
    "<main class='simple-web-default'><h1>Simple Web</h1><p>" + url + "</p></main>"

fn web_render_url_request(target: text, url: text, viewport_w: i32, viewport_h: i32) -> WebRenderRequest:
    WebRenderRequest.html(target, "Simple Web", web_render_default_page_body_html(url), "", "", viewport_w, viewport_h)

fn web_render_adapter_request(target: text, surface_id: text, title: text, body_html: text, css: text, js: text, viewport_w: i32, viewport_h: i32) -> WebRenderRequest:
    WebRenderRequest.html(target, title, body_html, css, js, viewport_w, viewport_h).with_surface(surface_id)

class WebRenderArtifact:
    target: text
    html: text
    ipc_json: text
    pixels: [u32]
    viewport_w: i32
    viewport_h: i32
    capability_summary: text
    binary_schema: text
    binary_cache_key: text
    binary_cache_path: text
    binary_bytes: i32
    binary_layout_bytes: i32
    binary_command_count: i32
    engine2d_status: text
    engine2d_backend: text
    engine2d_reason: text

    static fn empty(target: text, viewport_w: i32, viewport_h: i32) -> WebRenderArtifact:
        WebRenderArtifact(
            target: target,
            html: "",
            ipc_json: "",
            pixels: [],
            viewport_w: viewport_w,
            viewport_h: viewport_h,
            capability_summary: "",
            binary_schema: "",
            binary_cache_key: "",
            binary_cache_path: "",
            binary_bytes: 0,
            binary_layout_bytes: 0,
            binary_command_count: 0,
            engine2d_status: WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED,
            engine2d_backend: "",
            engine2d_reason: "pixel output not requested"
        )

class WebRenderBinaryArtifactMetadata:
    schema: text
    cache_key: text
    cache_path: text
    encoded_bytes: i32
    layout_bytes: i32
    command_count: i32

    static fn none() -> WebRenderBinaryArtifactMetadata:
        WebRenderBinaryArtifactMetadata(
            schema: "",
            cache_key: "",
            cache_path: "",
            encoded_bytes: 0,
            layout_bytes: 0,
            command_count: 0
        )

class WebRenderWasmArtifactMetadata:
    schema: text
    module_path: text
    abi: text
    encoded_bytes: i32
    layout_bytes: i32
    command_count: i32

    static fn create(module_path: text, abi: text, encoded_bytes: i32, layout_bytes: i32, command_count: i32) -> WebRenderWasmArtifactMetadata:
        WebRenderWasmArtifactMetadata(
            schema: WEB_RENDER_WASM_SCHEMA_VERSION,
            module_path: module_path,
            abi: abi,
            encoded_bytes: encoded_bytes,
            layout_bytes: layout_bytes,
            command_count: command_count
        )

fn web_render_artifact_with_binary_metadata(artifact: WebRenderArtifact, meta: WebRenderBinaryArtifactMetadata) -> WebRenderArtifact:
    WebRenderArtifact(
        target: artifact.target,
        html: artifact.html,
        ipc_json: artifact.ipc_json,
        pixels: artifact.pixels,
        viewport_w: artifact.viewport_w,
        viewport_h: artifact.viewport_h,
        capability_summary: artifact.capability_summary,
        binary_schema: meta.schema,
        binary_cache_key: meta.cache_key,
        binary_cache_path: meta.cache_path,
        binary_bytes: meta.encoded_bytes,
        binary_layout_bytes: meta.layout_bytes,
        binary_command_count: meta.command_count,
        engine2d_status: artifact.engine2d_status,
        engine2d_backend: artifact.engine2d_backend,
        engine2d_reason: artifact.engine2d_reason
        )

fn web_render_artifact_with_engine2d_provenance(artifact: WebRenderArtifact, status: text, backend: text, reason: text) -> WebRenderArtifact:
    WebRenderArtifact(
        target: artifact.target,
        html: artifact.html,
        ipc_json: artifact.ipc_json,
        pixels: artifact.pixels,
        viewport_w: artifact.viewport_w,
        viewport_h: artifact.viewport_h,
        capability_summary: artifact.capability_summary,
        binary_schema: artifact.binary_schema,
        binary_cache_key: artifact.binary_cache_key,
        binary_cache_path: artifact.binary_cache_path,
        binary_bytes: artifact.binary_bytes,
        binary_layout_bytes: artifact.binary_layout_bytes,
        binary_command_count: artifact.binary_command_count,
        engine2d_status: status,
        engine2d_backend: backend,
        engine2d_reason: reason
    )

fn web_render_engine2d_rendered_artifact(artifact: WebRenderArtifact, backend: text) -> WebRenderArtifact:
    web_render_artifact_with_engine2d_provenance(artifact, WEB_RENDER_ENGINE2D_STATUS_RENDERED, backend, "rendered through Engine2D")

fn web_render_engine2d_compatibility_artifact(artifact: WebRenderArtifact, backend: text, reason: text) -> WebRenderArtifact:
    web_render_artifact_with_engine2d_provenance(artifact, WEB_RENDER_ENGINE2D_STATUS_COMPATIBILITY, backend, reason)

fn web_render_engine2d_unavailable_artifact(artifact: WebRenderArtifact, backend: text, reason: text) -> WebRenderArtifact:
    web_render_artifact_with_engine2d_provenance(artifact, WEB_RENDER_ENGINE2D_STATUS_UNAVAILABLE, backend, reason)

fn web_render_wasm_no_js_target(target: text) -> bool:
    target == WEB_RENDER_TARGET_ANDROID_WASM or
    target == WEB_RENDER_TARGET_IOS_WASM or
    target == WEB_RENDER_TARGET_HOST_WM_WASM or
    target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM

fn web_render_wasm_abi_for_target(target: text) -> text:
    if target == WEB_RENDER_TARGET_ANDROID_WASM:
        return "wasm32-simple-ui-android"
    if target == WEB_RENDER_TARGET_IOS_WASM:
        return "wasm32-simple-ui-ios"
    if target == WEB_RENDER_TARGET_HOST_WM_WASM:
        return "wasm32-simple-ui-host-wm"
    if target == WEB_RENDER_TARGET_SIMPLEOS_WM_WASM:
        return "wasm32-simple-ui-simpleos-wm"
    "wasm32-simple-ui"

fn web_render_wasm_no_js_validation_error(req: WebRenderRequest, meta: WebRenderWasmArtifactMetadata) -> text:
    if not web_render_wasm_no_js_target(req.target):
        return "target does not require generated wasm without javascript"
    if req.js != "":
        return "javascript is not allowed for generated wasm target"
    if meta.module_path == "":
        return "missing wasm module path"
    if meta.abi != web_render_wasm_abi_for_target(req.target):
        return "wasm abi does not match render target"
    if meta.encoded_bytes <= 0:
        return "missing wasm module bytes"
    ""

fn web_render_wasm_no_js_is_valid(req: WebRenderRequest, meta: WebRenderWasmArtifactMetadata) -> bool:
    web_render_wasm_no_js_validation_error(req, meta) == ""

fn web_render_generated_wasm_artifact(req: WebRenderRequest, meta: WebRenderWasmArtifactMetadata) -> WebRenderArtifact:
    val base = web_render_to_artifact(req)
    web_render_artifact_with_binary_metadata(base, WebRenderBinaryArtifactMetadata(
        schema: meta.schema,
        cache_key: web_render_cache_key(req) + "|wasm=" + meta.module_path + "|abi=" + meta.abi,
        cache_path: meta.module_path,
        encoded_bytes: meta.encoded_bytes,
        layout_bytes: meta.layout_bytes,
        command_count: meta.command_count
    ))

