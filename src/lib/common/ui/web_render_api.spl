class WebRenderGtkBenchmarkEvidence:
    scene_id: text
    simple_frame_us: i64
    gtk_frame_us: i64
    simple_text_us: i64
    gtk_text_us: i64
    simple_iterations: i64
    gtk_iterations: i64
    simple_trial_count: i64
    gtk_trial_count: i64
    min_iterations: i64
    min_trials: i64
    sample_confident: bool
    trial_confident: bool
    faster_than_gtk: bool
    status: text
    reason: text

    static fn create(scene_id: text, simple_frame_us: i64, gtk_frame_us: i64, simple_text_us: i64, gtk_text_us: i64, simple_iterations: i64, gtk_iterations: i64, simple_trial_count: i64, gtk_trial_count: i64) -> WebRenderGtkBenchmarkEvidence:
        val reason = web_render_gtk_benchmark_reason(scene_id, simple_frame_us, gtk_frame_us, simple_text_us, gtk_text_us, simple_iterations, gtk_iterations, simple_trial_count, gtk_trial_count)
        WebRenderGtkBenchmarkEvidence(
            scene_id: scene_id,
            simple_frame_us: simple_frame_us,
            gtk_frame_us: gtk_frame_us,
            simple_text_us: simple_text_us,
            gtk_text_us: gtk_text_us,
            simple_iterations: simple_iterations,
            gtk_iterations: gtk_iterations,
            simple_trial_count: simple_trial_count,
            gtk_trial_count: gtk_trial_count,
            min_iterations: web_render_gtk_benchmark_min_iterations(),
            min_trials: web_render_gtk_benchmark_min_trials(),
            sample_confident: web_render_gtk_benchmark_has_enough_samples(simple_iterations, gtk_iterations),
            trial_confident: web_render_gtk_benchmark_has_enough_trials(simple_trial_count, gtk_trial_count),
            faster_than_gtk: reason == "pass",
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderGtkBenchmarkEvidence[scene={self.scene_id} simple_frame_us={self.simple_frame_us} gtk_frame_us={self.gtk_frame_us} simple_text_us={self.simple_text_us} gtk_text_us={self.gtk_text_us} simple_iters={self.simple_iterations} gtk_iters={self.gtk_iterations} simple_trials={self.simple_trial_count} gtk_trials={self.gtk_trial_count} min_iters={self.min_iterations} min_trials={self.min_trials} sample_confident={self.sample_confident} trial_confident={self.trial_confident} status={self.status} reason={self.reason}]"

fn web_render_gtk_benchmark_min_iterations() -> i64:
    3

fn web_render_gtk_benchmark_min_trials() -> i64:
    3

fn web_render_gtk_benchmark_has_enough_samples(simple_iterations: i64, gtk_iterations: i64) -> bool:
    simple_iterations >= web_render_gtk_benchmark_min_iterations() and gtk_iterations >= web_render_gtk_benchmark_min_iterations()

fn web_render_gtk_benchmark_has_enough_trials(simple_trial_count: i64, gtk_trial_count: i64) -> bool:
    simple_trial_count >= web_render_gtk_benchmark_min_trials() and gtk_trial_count >= web_render_gtk_benchmark_min_trials()

fn web_render_gtk_benchmark_reason(scene_id: text, simple_frame_us: i64, gtk_frame_us: i64, simple_text_us: i64, gtk_text_us: i64, simple_iterations: i64, gtk_iterations: i64, simple_trial_count: i64, gtk_trial_count: i64) -> text:
    if scene_id == "":
        return "missing-scene"
    if simple_iterations <= 0 or gtk_iterations <= 0:
        return "missing-iterations"
    if simple_trial_count <= 0 or gtk_trial_count <= 0:
        return "missing-trials"
    if not web_render_gtk_benchmark_has_enough_samples(simple_iterations, gtk_iterations):
        return "sample-count-too-low"
    if not web_render_gtk_benchmark_has_enough_trials(simple_trial_count, gtk_trial_count):
        return "trial-count-too-low"
    if simple_frame_us <= 0 or gtk_frame_us <= 0 or simple_text_us <= 0 or gtk_text_us <= 0:
        return "missing-timings"
    if simple_frame_us >= gtk_frame_us:
        return "frame-not-faster"
    if simple_text_us >= gtk_text_us:
        return "text-not-faster"
    "pass"

fn web_render_gtk_benchmark_evidence(scene_id: text, simple_frame_us: i64, gtk_frame_us: i64, simple_text_us: i64, gtk_text_us: i64, simple_iterations: i64, gtk_iterations: i64) -> WebRenderGtkBenchmarkEvidence:
    WebRenderGtkBenchmarkEvidence.create(scene_id, simple_frame_us, gtk_frame_us, simple_text_us, gtk_text_us, simple_iterations, gtk_iterations, 1, 1)

fn web_render_gtk_benchmark_evidence_with_trials(scene_id: text, simple_frame_us: i64, gtk_frame_us: i64, simple_text_us: i64, gtk_text_us: i64, simple_iterations: i64, gtk_iterations: i64, simple_trial_count: i64, gtk_trial_count: i64) -> WebRenderGtkBenchmarkEvidence:
    WebRenderGtkBenchmarkEvidence.create(scene_id, simple_frame_us, gtk_frame_us, simple_text_us, gtk_text_us, simple_iterations, gtk_iterations, simple_trial_count, gtk_trial_count)

class WebRenderVectorFontBenchmarkEvidence:
    scene_id: text
    vector_text_us: i64
    glyph_pixels: i64
    ink_pixels: i64
    checksum: i64
    iterations: i64
    deterministic: bool
    status: text
    reason: text

    static fn create(scene_id: text, vector_text_us: i64, glyph_pixels: i64, ink_pixels: i64, checksum: i64, iterations: i64, deterministic: bool) -> WebRenderVectorFontBenchmarkEvidence:
        val reason = web_render_vector_font_benchmark_reason(scene_id, vector_text_us, glyph_pixels, ink_pixels, checksum, iterations, deterministic)
        WebRenderVectorFontBenchmarkEvidence(
            scene_id: scene_id,
            vector_text_us: vector_text_us,
            glyph_pixels: glyph_pixels,
            ink_pixels: ink_pixels,
            checksum: checksum,
            iterations: iterations,
            deterministic: deterministic,
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderVectorFontBenchmarkEvidence[scene={self.scene_id} vector_text_us={self.vector_text_us} glyph_pixels={self.glyph_pixels} ink_pixels={self.ink_pixels} checksum={self.checksum} iterations={self.iterations} deterministic={self.deterministic} status={self.status} reason={self.reason}]"

fn web_render_vector_font_benchmark_reason(scene_id: text, vector_text_us: i64, glyph_pixels: i64, ink_pixels: i64, checksum: i64, iterations: i64, deterministic: bool) -> text:
    if scene_id == "":
        return "missing-scene"
    if iterations <= 0:
        return "missing-iterations"
    if vector_text_us <= 0:
        return "missing-timing"
    if glyph_pixels <= 0:
        return "missing-glyph-pixels"
    if ink_pixels <= 0:
        return "empty-render-output"
    if checksum <= 0:
        return "missing-checksum"
    if not deterministic:
        return "nondeterministic-render-output"
    "pass"

fn web_render_vector_font_benchmark_evidence(scene_id: text, vector_text_us: i64, glyph_pixels: i64, ink_pixels: i64, checksum: i64, iterations: i64, deterministic: bool) -> WebRenderVectorFontBenchmarkEvidence:
    WebRenderVectorFontBenchmarkEvidence.create(scene_id, vector_text_us, glyph_pixels, ink_pixels, checksum, iterations, deterministic)

class WebRenderVectorFontComputeEvidence:
    scene_id: text
    cpu_checksum: i64
    cpu_ink_pixels: i64
    cuda_status: text
    cuda_reason: text
    cuda_checksum: i64
    opencl_status: text
    opencl_reason: text
    opencl_checksum: i64
    blur_or_tolerance_used: bool
    offload_status: text
    offload_reason: text
    gpu_glyph_returned: bool
    production_offload_ready: bool
    status: text
    reason: text

    static fn create(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> WebRenderVectorFontComputeEvidence:
        val reason = web_render_vector_font_compute_reason(scene_id, cpu_checksum, cpu_ink_pixels, cuda_status, cuda_reason, cuda_checksum, opencl_status, opencl_reason, opencl_checksum, blur_or_tolerance_used)
        val offload_status = web_render_vector_font_compute_offload_status(cuda_status, cuda_reason, opencl_status, opencl_reason)
        val offload_reason = web_render_vector_font_compute_offload_reason(cuda_status, cuda_reason, opencl_status, opencl_reason)
        WebRenderVectorFontComputeEvidence(
            scene_id: scene_id,
            cpu_checksum: cpu_checksum,
            cpu_ink_pixels: cpu_ink_pixels,
            cuda_status: cuda_status,
            cuda_reason: cuda_reason,
            cuda_checksum: cuda_checksum,
            opencl_status: opencl_status,
            opencl_reason: opencl_reason,
            opencl_checksum: opencl_checksum,
            blur_or_tolerance_used: blur_or_tolerance_used,
            offload_status: offload_status,
            offload_reason: offload_reason,
            gpu_glyph_returned: offload_status == "gpu-glyph-returned",
            production_offload_ready: offload_status == "gpu-glyph-returned",
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderVectorFontComputeEvidence[scene={self.scene_id} cpu_checksum={self.cpu_checksum} cpu_ink_pixels={self.cpu_ink_pixels} cuda_status={self.cuda_status} cuda_reason={self.cuda_reason} cuda_checksum={self.cuda_checksum} opencl_status={self.opencl_status} opencl_reason={self.opencl_reason} opencl_checksum={self.opencl_checksum} offload_status={self.offload_status} offload_reason={self.offload_reason} gpu_glyph_returned={self.gpu_glyph_returned.to_text()} production_offload_ready={self.production_offload_ready.to_text()} blur_or_tolerance_used={self.blur_or_tolerance_used} status={self.status} reason={self.reason}]"

fn web_render_vector_font_backend_returned_glyph_pixels(backend_status: text, backend_reason: text) -> bool:
    backend_status == "pass" and backend_reason.contains("glyph-pixels-returned")

fn web_render_vector_font_backend_proved_cpu_match(backend_status: text, backend_reason: text) -> bool:
    backend_status == "pass" and backend_reason.contains("matched-cpu")

fn web_render_vector_font_compute_offload_status(cuda_status: text, cuda_reason: text, opencl_status: text, opencl_reason: text) -> text:
    if web_render_vector_font_backend_returned_glyph_pixels(cuda_status, cuda_reason) or web_render_vector_font_backend_returned_glyph_pixels(opencl_status, opencl_reason):
        return "gpu-glyph-returned"
    if web_render_vector_font_backend_proved_cpu_match(cuda_status, cuda_reason) or web_render_vector_font_backend_proved_cpu_match(opencl_status, opencl_reason):
        return "gpu-proof-with-cpu-glyph"
    if cuda_status == "unavailable" and opencl_status == "unavailable":
        return "accelerator-unavailable"
    "not-proven"

fn web_render_vector_font_compute_offload_reason(cuda_status: text, cuda_reason: text, opencl_status: text, opencl_reason: text) -> text:
    if web_render_vector_font_backend_returned_glyph_pixels(cuda_status, cuda_reason):
        if web_render_vector_font_backend_returned_glyph_pixels(opencl_status, opencl_reason):
            return "cuda-opencl-vector-font-glyph-pixels-returned"
        return cuda_reason
    if web_render_vector_font_backend_returned_glyph_pixels(opencl_status, opencl_reason):
        return opencl_reason
    if web_render_vector_font_backend_proved_cpu_match(cuda_status, cuda_reason):
        return cuda_reason
    if web_render_vector_font_backend_proved_cpu_match(opencl_status, opencl_reason):
        return opencl_reason
    if cuda_status == "unavailable" and cuda_reason != "":
        return cuda_reason
    if opencl_status == "unavailable" and opencl_reason != "":
        return opencl_reason
    "vector-font-offload-not-proven"

fn web_render_vector_font_compute_backend_reason(backend: text, backend_status: text, backend_reason: text, backend_checksum: i64, cpu_checksum: i64) -> text:
    if backend_status == "":
        return "missing-" + backend + "-status"
    if backend_status == "unavailable":
        if backend_reason == "":
            return "missing-" + backend + "-unavailable-reason"
        return "pass"
    if backend_status != "pass":
        return backend + "-not-proven"
    if backend_checksum <= 0:
        return "missing-" + backend + "-checksum"
    if backend_checksum != cpu_checksum:
        return backend + "-checksum-mismatch"
    "pass"

fn web_render_vector_font_compute_reason(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> text:
    if scene_id == "":
        return "missing-scene"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    if cpu_checksum <= 0:
        return "missing-cpu-checksum"
    if cpu_ink_pixels <= 0:
        return "empty-cpu-render-output"
    val cuda = web_render_vector_font_compute_backend_reason("cuda", cuda_status, cuda_reason, cuda_checksum, cpu_checksum)
    if cuda != "pass":
        return cuda
    val opencl = web_render_vector_font_compute_backend_reason("opencl", opencl_status, opencl_reason, opencl_checksum, cpu_checksum)
    if opencl != "pass":
        return opencl
    "pass"

fn web_render_vector_font_compute_evidence(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> WebRenderVectorFontComputeEvidence:
    WebRenderVectorFontComputeEvidence.create(scene_id, cpu_checksum, cpu_ink_pixels, cuda_status, cuda_reason, cuda_checksum, opencl_status, opencl_reason, opencl_checksum, blur_or_tolerance_used)

class WebRenderVectorFontNativeComputeEvidence:
    scene_id: text
    cpu_checksum: i64
    cpu_ink_pixels: i64
    metal_status: text
    metal_reason: text
    metal_checksum: i64
    cuda_status: text
    cuda_reason: text
    cuda_checksum: i64
    rocm_status: text
    rocm_reason: text
    rocm_checksum: i64
    vulkan_status: text
    vulkan_reason: text
    vulkan_checksum: i64
    opencl_status: text
    opencl_reason: text
    opencl_checksum: i64
    blur_or_tolerance_used: bool
    offload_status: text
    offload_reason: text
    gpu_glyph_returned: bool
    production_offload_ready: bool
    status: text
    reason: text

    static fn create(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, metal_status: text, metal_reason: text, metal_checksum: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, rocm_status: text, rocm_reason: text, rocm_checksum: i64, vulkan_status: text, vulkan_reason: text, vulkan_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> WebRenderVectorFontNativeComputeEvidence:
        val reason = web_render_vector_font_native_compute_reason(scene_id, cpu_checksum, cpu_ink_pixels, metal_status, metal_reason, metal_checksum, cuda_status, cuda_reason, cuda_checksum, rocm_status, rocm_reason, rocm_checksum, vulkan_status, vulkan_reason, vulkan_checksum, opencl_status, opencl_reason, opencl_checksum, blur_or_tolerance_used)
        val offload_status = web_render_vector_font_native_compute_offload_status(metal_status, metal_reason, cuda_status, cuda_reason, rocm_status, rocm_reason, vulkan_status, vulkan_reason, opencl_status, opencl_reason)
        val offload_reason = web_render_vector_font_native_compute_offload_reason(metal_status, metal_reason, cuda_status, cuda_reason, rocm_status, rocm_reason, vulkan_status, vulkan_reason, opencl_status, opencl_reason)
        WebRenderVectorFontNativeComputeEvidence(
            scene_id: scene_id,
            cpu_checksum: cpu_checksum,
            cpu_ink_pixels: cpu_ink_pixels,
            metal_status: metal_status,
            metal_reason: metal_reason,
            metal_checksum: metal_checksum,
            cuda_status: cuda_status,
            cuda_reason: cuda_reason,
            cuda_checksum: cuda_checksum,
            rocm_status: rocm_status,
            rocm_reason: rocm_reason,
            rocm_checksum: rocm_checksum,
            vulkan_status: vulkan_status,
            vulkan_reason: vulkan_reason,
            vulkan_checksum: vulkan_checksum,
            opencl_status: opencl_status,
            opencl_reason: opencl_reason,
            opencl_checksum: opencl_checksum,
            blur_or_tolerance_used: blur_or_tolerance_used,
            offload_status: offload_status,
            offload_reason: offload_reason,
            gpu_glyph_returned: offload_status == "gpu-glyph-returned",
            production_offload_ready: offload_status == "gpu-glyph-returned",
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderVectorFontNativeComputeEvidence[scene={self.scene_id} cpu_checksum={self.cpu_checksum} cpu_ink_pixels={self.cpu_ink_pixels} metal_status={self.metal_status} metal_reason={self.metal_reason} metal_checksum={self.metal_checksum} cuda_status={self.cuda_status} cuda_reason={self.cuda_reason} cuda_checksum={self.cuda_checksum} rocm_status={self.rocm_status} rocm_reason={self.rocm_reason} rocm_checksum={self.rocm_checksum} vulkan_status={self.vulkan_status} vulkan_reason={self.vulkan_reason} vulkan_checksum={self.vulkan_checksum} opencl_status={self.opencl_status} opencl_reason={self.opencl_reason} opencl_checksum={self.opencl_checksum} offload_status={self.offload_status} offload_reason={self.offload_reason} gpu_glyph_returned={self.gpu_glyph_returned.to_text()} production_offload_ready={self.production_offload_ready.to_text()} blur_or_tolerance_used={self.blur_or_tolerance_used} status={self.status} reason={self.reason}]"

fn web_render_vector_font_native_compute_offload_status(metal_status: text, metal_reason: text, cuda_status: text, cuda_reason: text, rocm_status: text, rocm_reason: text, vulkan_status: text, vulkan_reason: text, opencl_status: text, opencl_reason: text) -> text:
    if web_render_vector_font_backend_returned_glyph_pixels(metal_status, metal_reason) or web_render_vector_font_backend_returned_glyph_pixels(cuda_status, cuda_reason) or web_render_vector_font_backend_returned_glyph_pixels(rocm_status, rocm_reason) or web_render_vector_font_backend_returned_glyph_pixels(vulkan_status, vulkan_reason) or web_render_vector_font_backend_returned_glyph_pixels(opencl_status, opencl_reason):
        return "gpu-glyph-returned"
    if web_render_vector_font_backend_proved_cpu_match(metal_status, metal_reason) or web_render_vector_font_backend_proved_cpu_match(cuda_status, cuda_reason) or web_render_vector_font_backend_proved_cpu_match(rocm_status, rocm_reason) or web_render_vector_font_backend_proved_cpu_match(vulkan_status, vulkan_reason) or web_render_vector_font_backend_proved_cpu_match(opencl_status, opencl_reason):
        return "gpu-proof-with-cpu-glyph"
    if metal_status == "unavailable" and cuda_status == "unavailable" and rocm_status == "unavailable" and vulkan_status == "unavailable" and opencl_status == "unavailable":
        return "accelerator-unavailable"
    "not-proven"

fn web_render_vector_font_native_compute_offload_reason(metal_status: text, metal_reason: text, cuda_status: text, cuda_reason: text, rocm_status: text, rocm_reason: text, vulkan_status: text, vulkan_reason: text, opencl_status: text, opencl_reason: text) -> text:
    if web_render_vector_font_backend_returned_glyph_pixels(metal_status, metal_reason):
        return metal_reason
    if web_render_vector_font_backend_returned_glyph_pixels(cuda_status, cuda_reason):
        return cuda_reason
    if web_render_vector_font_backend_returned_glyph_pixels(rocm_status, rocm_reason):
        return rocm_reason
    if web_render_vector_font_backend_returned_glyph_pixels(vulkan_status, vulkan_reason):
        return vulkan_reason
    if web_render_vector_font_backend_returned_glyph_pixels(opencl_status, opencl_reason):
        return opencl_reason
    if web_render_vector_font_backend_proved_cpu_match(metal_status, metal_reason):
        return metal_reason
    if web_render_vector_font_backend_proved_cpu_match(cuda_status, cuda_reason):
        return cuda_reason
    if web_render_vector_font_backend_proved_cpu_match(rocm_status, rocm_reason):
        return rocm_reason
    if web_render_vector_font_backend_proved_cpu_match(vulkan_status, vulkan_reason):
        return vulkan_reason
    if web_render_vector_font_backend_proved_cpu_match(opencl_status, opencl_reason):
        return opencl_reason
    if metal_status == "unavailable" and metal_reason != "":
        return metal_reason
    if cuda_status == "unavailable" and cuda_reason != "":
        return cuda_reason
    if rocm_status == "unavailable" and rocm_reason != "":
        return rocm_reason
    if vulkan_status == "unavailable" and vulkan_reason != "":
        return vulkan_reason
    if opencl_status == "unavailable" and opencl_reason != "":
        return opencl_reason
    "vector-font-offload-not-proven"

fn web_render_vector_font_native_compute_reason(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, metal_status: text, metal_reason: text, metal_checksum: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, rocm_status: text, rocm_reason: text, rocm_checksum: i64, vulkan_status: text, vulkan_reason: text, vulkan_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> text:
    if scene_id == "":
        return "missing-scene"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    if cpu_checksum <= 0:
        return "missing-cpu-checksum"
    if cpu_ink_pixels <= 0:
        return "empty-cpu-render-output"
    val metal = web_render_vector_font_compute_backend_reason("metal", metal_status, metal_reason, metal_checksum, cpu_checksum)
    if metal != "pass":
        return metal
    val cuda = web_render_vector_font_compute_backend_reason("cuda", cuda_status, cuda_reason, cuda_checksum, cpu_checksum)
    if cuda != "pass":
        return cuda
    val rocm = web_render_vector_font_compute_backend_reason("rocm", rocm_status, rocm_reason, rocm_checksum, cpu_checksum)
    if rocm != "pass":
        return rocm
    val vulkan = web_render_vector_font_compute_backend_reason("vulkan", vulkan_status, vulkan_reason, vulkan_checksum, cpu_checksum)
    if vulkan != "pass":
        return vulkan
    val opencl = web_render_vector_font_compute_backend_reason("opencl", opencl_status, opencl_reason, opencl_checksum, cpu_checksum)
    if opencl != "pass":
        return opencl
    "pass"

fn web_render_vector_font_native_compute_evidence(scene_id: text, cpu_checksum: i64, cpu_ink_pixels: i64, metal_status: text, metal_reason: text, metal_checksum: i64, cuda_status: text, cuda_reason: text, cuda_checksum: i64, rocm_status: text, rocm_reason: text, rocm_checksum: i64, vulkan_status: text, vulkan_reason: text, vulkan_checksum: i64, opencl_status: text, opencl_reason: text, opencl_checksum: i64, blur_or_tolerance_used: bool) -> WebRenderVectorFontNativeComputeEvidence:
    WebRenderVectorFontNativeComputeEvidence.create(scene_id, cpu_checksum, cpu_ink_pixels, metal_status, metal_reason, metal_checksum, cuda_status, cuda_reason, cuda_checksum, rocm_status, rocm_reason, rocm_checksum, vulkan_status, vulkan_reason, vulkan_checksum, opencl_status, opencl_reason, opencl_checksum, blur_or_tolerance_used)

fn web_render_capabilities_for_target(target: text) -> [Capability]:
    if target == WEB_RENDER_TARGET_HEADLESS:
        return []
    if target == WEB_RENDER_TARGET_TUI_WEB:
        return [Capability.Color]
    if target == WEB_RENDER_TARGET_ELECTRON:
        return [Capability.Mouse, Capability.Color, Capability.Images, Capability.NativeDialogs, Capability.Notification]
    if target == WEB_RENDER_TARGET_TAURI:
        return [Capability.Mouse, Capability.Color, Capability.Images, Capability.NativeDialogs, Capability.Notification]
    if target == WEB_RENDER_TARGET_CHROME or target == WEB_RENDER_TARGET_CHROMIUM:
        return [Capability.Mouse, Capability.Color, Capability.Images, Capability.Notification]
    [Capability.Mouse, Capability.Color, Capability.Images, Capability.Touch]

fn web_render_capability_summary(target: text) -> text:
    if target == WEB_RENDER_TARGET_HEADLESS:
        return "headless"
    if target == WEB_RENDER_TARGET_TUI_WEB:
        return "color"
    if target == WEB_RENDER_TARGET_ELECTRON:
        return "mouse,color,images,native_dialogs,notification"
    if target == WEB_RENDER_TARGET_TAURI:
        return "mouse,color,images,native_dialogs,notification"
    if target == WEB_RENDER_TARGET_CHROME or target == WEB_RENDER_TARGET_CHROMIUM:
        return "mouse,color,images,notification"
    if web_render_wasm_no_js_target(target):
        return "mouse,color,images,touch,generated_wasm,no_javascript"
    "mouse,color,images,touch"

fn web_render_full_html(req: WebRenderRequest) -> text:
    val title = if req.title != "": "<title>" + escape_json(req.title) + "</title>" else: ""
    val css = if req.css != "": "<style>" + req.css + "</style>" else: ""
    val js = if req.js != "": "<script>" + req.js + "</script>" else: ""
    # charset + responsive viewport are required for readable phone/tablet
    # layout: without width=device-width, mobile WebKit lays out at ~980px and
    # scales the whole page down, making everything tiny. viewport-fit=cover
    # lets content extend under the notch / home indicator.
    val meta = "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, viewport-fit=cover\">"
    "<!DOCTYPE html><html><head>" + meta + title + css + "</head><body><div id=\"app\">" + req.body_html + "</div>" + js + "</body></html>"

fn web_render_body_html(req: WebRenderRequest) -> text:
    req.body_html

fn web_render_ipc_json(req: WebRenderRequest) -> text:
    web_render_ipc_json_with_html(req, web_render_full_html(req))

fn web_render_ipc_json_with_html(req: WebRenderRequest, full_html: text) -> text:
    "{\"type\":\"render\",\"target\":\"" + escape_json(req.target) + "\",\"surface_id\":\"" + escape_json(req.surface_id) + "\",\"width\":" + str(req.viewport_w) + ",\"height\":" + str(req.viewport_h) + ",\"html\":\"" + escape_json(full_html) + "\",\"css\":\"" + escape_json(req.css) + "\",\"body_html\":\"" + escape_json(req.body_html) + "\"}"

fn web_render_ipc_json_with_html_and_semantic(req: WebRenderRequest, full_html: text, semantic_json: text) -> text:
    val semantic_part = if semantic_json != "": ",\"semantic\":" + semantic_json else: ""
    "{\"type\":\"render\",\"target\":\"" + escape_json(req.target) + "\",\"surface_id\":\"" + escape_json(req.surface_id) + "\",\"width\":" + str(req.viewport_w) + ",\"height\":" + str(req.viewport_h) + ",\"html\":\"" + escape_json(full_html) + "\",\"css\":\"" + escape_json(req.css) + "\",\"body_html\":\"" + escape_json(req.body_html) + "\"" + semantic_part + "}"

fn _web_render_index_of_from(haystack: text, marker: text, start: i64) -> i64:
    if marker == "":
        return start
    var offset = start
    while offset < haystack.len():
        val tail = haystack.substring(offset, haystack.len())
        val found = tail.index_of(marker)
        if found < 0:
            return -1
        return offset + found
    -1

fn _web_render_count_marker(haystack: text, marker: text) -> i32:
    if marker == "":
        return 0
    var count = 0
    var offset = 0i64
    while offset < haystack.len():
        val found = _web_render_index_of_from(haystack, marker, offset)
        if found < 0:
            return count
        count = count + 1
        offset = found + marker.len()
    count

fn _web_render_text_fingerprint(value: text) -> text:
    val len = value.len()
    val head_end = if len < 24: len else: 24
    val tail_start = if len < 24: 0 else: len - 24
    val head = value.substring(0, head_end)
    val tail = value.substring(tail_start, len)
    "len={len};head={escape_json(head)};tail={escape_json(tail)}"

fn web_render_dynamic_region_count(req: WebRenderRequest) -> i32:
    _web_render_count_marker(req.body_html, "data-simple-dynamic") +
    _web_render_count_marker(req.body_html, "data-live") +
    _web_render_count_marker(req.body_html, "data-ui-patch") +
    _web_render_count_marker(req.js, "WebSocket")

fn web_render_cache_key(req: WebRenderRequest) -> text:
    WEB_RENDER_CACHE_SCHEMA_VERSION +
    "|target=" + req.target +
    "|surface=" + req.surface_id +
    "|viewport=" + str(req.viewport_w) + "x" + str(req.viewport_h) +
    "|pixels=" + str(req.wants_pixels) +
    "|cap=" + web_render_capability_summary(req.target) +
    "|title=" + _web_render_text_fingerprint(req.title) +
    "|body=" + _web_render_text_fingerprint(req.body_html) +
    "|css=" + _web_render_text_fingerprint(req.css) +
    "|js=" + _web_render_text_fingerprint(req.js)

fn web_render_optimization_profile(req: WebRenderRequest) -> WebRenderOptimizationProfile:
    val dynamic_regions = web_render_dynamic_region_count(req)
    val cacheable = dynamic_regions == 0
    val plan = if cacheable:
        "binary_static_shell"
    else:
        "static_shell_with_dynamic_islands"
    WebRenderOptimizationProfile(
        cache_schema: WEB_RENDER_CACHE_SCHEMA_VERSION,
        cache_key: web_render_cache_key(req),
        cacheable_static_shell: cacheable,
        static_shell_bytes: req.body_html.len() + req.css.len(),
        dynamic_region_count: dynamic_regions,
        render_plan: plan
    )

fn web_render_host_window_command_to_json(cmd: WebRenderHostWindowCommand) -> text:
    "{" +
    "\"action\":\"{escape_json(cmd.action)}\"," +
    "\"window_id\":\"{escape_json(cmd.window_id)}\"," +
    "\"surface_id\":\"{escape_json(cmd.surface_id)}\"," +
    "\"app_id\":\"{escape_json(cmd.app_id)}\"," +
    "\"title\":\"{escape_json(cmd.title)}\"," +
    "\"url\":\"{escape_json(cmd.url)}\"," +
    "\"x\":{cmd.x}," +
    "\"y\":{cmd.y}," +
    "\"width\":{cmd.width}," +
    "\"height\":{cmd.height}" +
    "}"

fn web_render_snapshot_envelope_to_json(env: WebRenderSnapshotEnvelope) -> text:
    "{\"type\":\"snapshot\",\"target\":\"" + escape_json(env.target) + "\",\"surface_id\":\"" + escape_json(env.surface_id) + "\",\"revision\":" + str(env.revision) + ",\"snapshot\":" + env.snapshot_json + "}"

fn web_render_snapshot_envelope_to_json_with_semantic(env: WebRenderSnapshotEnvelope, semantic_json: text) -> text:
    val semantic_part = if semantic_json != "": ",\"semantic\":" + semantic_json else: ""
    "{\"type\":\"snapshot\",\"target\":\"" + escape_json(env.target) + "\",\"surface_id\":\"" + escape_json(env.surface_id) + "\",\"revision\":" + str(env.revision) + ",\"snapshot\":" + env.snapshot_json + semantic_part + "}"

fn web_render_patch_envelope_to_json(env: WebRenderPatchEnvelope) -> text:
    val snapshot_part = if env.snapshot_json != "": ",\"snapshot\":" + env.snapshot_json else: ""
    "{\"type\":\"patch\",\"target\":\"" + escape_json(env.target) + "\",\"surface_id\":\"" + escape_json(env.surface_id) + "\",\"from_sequence\":" + str(env.from_sequence) + ",\"to_sequence\":" + str(env.to_sequence) + ",\"patches\":" + env.patches_json + snapshot_part + "}"

fn web_render_input_envelope_to_json(env: WebRenderInputEnvelope) -> text:
    "{" +
    "\"type\":\"input\"," +
    "\"target\":\"{escape_json(env.target)}\"," +
    "\"surface_id\":\"{escape_json(env.surface_id)}\"," +
    "\"event_type\":\"{escape_json(env.event_type)}\"," +
    "\"target_id\":\"{escape_json(env.target_id)}\"," +
    "\"key\":\"{escape_json(env.key)}\"," +
    "\"value\":\"{escape_json(env.value)}\"," +
    "\"x\":{env.x}," +
    "\"y\":{env.y}," +
    "\"dx\":{env.dx}," +
    "\"dy\":{env.dy}," +
    "\"button\":\"{escape_json(env.button)}\"" +
    "}"

fn web_render_transport_bundle(req: WebRenderRequest, surface_id: text, event: UIEvent, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text, snapshot_json: text, cmd: WebRenderHostWindowCommand) -> WebRenderTransportBundle:
    val input = web_render_input_envelope_from_event(req.target, surface_id, event)
    WebRenderTransportBundle(
        render_json: web_render_to_artifact(req.with_surface(surface_id)).ipc_json,
        input_json: web_render_input_envelope_to_json(input),
        snapshot_json: web_render_snapshot_envelope_to_json(WebRenderSnapshotEnvelope(target: req.target, surface_id: surface_id, revision: revision, snapshot_json: snapshot_json)),
        patch_json: web_render_patch_envelope_to_json(WebRenderPatchEnvelope(target: req.target, surface_id: surface_id, from_sequence: from_sequence, to_sequence: to_sequence, patches_json: patches_json, snapshot_json: snapshot_json)),
        host_window_json: web_render_host_window_command_to_json(cmd)
    )

fn web_render_input_envelope_from_event(target: text, surface_id: text, event: UIEvent) -> WebRenderInputEnvelope:
    match event:
        UIEvent.KeyPress(key):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "key", target_id: "", key: key, value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.Resize(width, height):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "resize", target_id: "", key: "", value: "", x: width.to_f64(), y: height.to_f64(), dx: 0.0, dy: 0.0, button: "")
        UIEvent.Action(name):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "action", target_id: "", key: "", value: name, x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.TouchPress(x, y):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "touch_press", target_id: "", key: "", value: "", x: x.to_f64(), y: y.to_f64(), dx: 0.0, dy: 0.0, button: "")
        UIEvent.TouchMove(x, y):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "touch_move", target_id: "", key: "", value: "", x: x.to_f64(), y: y.to_f64(), dx: 0.0, dy: 0.0, button: "")
        UIEvent.TouchRelease(x, y):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "touch_release", target_id: "", key: "", value: "", x: x.to_f64(), y: y.to_f64(), dx: 0.0, dy: 0.0, button: "")
        UIEvent.MouseEvent(x, y, button, kind):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "mouse_" + kind, target_id: "", key: "", value: "", x: x, y: y, dx: 0.0, dy: 0.0, button: button)
        UIEvent.ScrollEvent(x, y, dx, dy):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "scroll", target_id: "", key: "", value: "", x: x, y: y, dx: dx, dy: dy, button: "")
        UIEvent.FocusEvent(target_id, kind):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: kind, target_id: target_id, key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.InputChange(target_id, value):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "input", target_id: target_id, key: "", value: value, x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.FetchResult(request_id, url, status, headers, body, error):
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "fetch_result", target_id: request_id, key: "", value: url, x: status.to_f64(), y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.FocusNext:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "focus_next", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.FocusPrev:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "focus_prev", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.CommandMode:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "command_mode", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.NormalMode:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "normal_mode", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.InsertMode:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "insert_mode", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.FileChanged:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "file_changed", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")
        UIEvent.Quit:
            WebRenderInputEnvelope(target: target, surface_id: surface_id, event_type: "quit", target_id: "", key: "", value: "", x: 0.0, y: 0.0, dx: 0.0, dy: 0.0, button: "")

fn web_render_to_artifact(req: WebRenderRequest) -> WebRenderArtifact:
    val html = web_render_full_html(req)
    val ipc = if req.target == WEB_RENDER_TARGET_ELECTRON or req.target == WEB_RENDER_TARGET_TAURI:
        web_render_ipc_json_with_html(req, html)
    else:
        ""
    WebRenderArtifact(
        target: req.target,
        html: html,
        ipc_json: ipc,
        pixels: [],
        viewport_w: req.viewport_w,
        viewport_h: req.viewport_h,
        capability_summary: web_render_capability_summary(req.target),
        binary_schema: "",
        binary_cache_key: "",
        binary_cache_path: "",
        binary_bytes: 0,
        binary_layout_bytes: 0,
        binary_command_count: 0,
        engine2d_status: WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED,
        engine2d_backend: "",
        engine2d_reason: "pixel output not requested"
    )

fn web_render_pixel_artifact(req: WebRenderRequest, pixels: [u32]) -> WebRenderArtifact:
    val base = web_render_to_artifact(req.with_pixel_output())
    WebRenderArtifact(
        target: base.target,
        html: base.html,
        ipc_json: base.ipc_json,
        pixels: pixels,
        viewport_w: base.viewport_w,
        viewport_h: base.viewport_h,
        capability_summary: base.capability_summary,
        binary_schema: base.binary_schema,
        binary_cache_key: base.binary_cache_key,
        binary_cache_path: base.binary_cache_path,
        binary_bytes: base.binary_bytes,
        binary_layout_bytes: base.binary_layout_bytes,
        binary_command_count: base.binary_command_count,
        engine2d_status: WEB_RENDER_ENGINE2D_STATUS_COMPATIBILITY,
        engine2d_backend: "unknown",
        engine2d_reason: "pixel artifact did not report Engine2D provenance"
    )
