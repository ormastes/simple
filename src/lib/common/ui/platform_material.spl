# Platform Material Selection
#
# Detects OS and returns platform-appropriate material, title bar style,
# and capability flags for the layered surface system.
# Windows 11: mica (shell) + acrylic (transient)
# macOS: vibrancy (sidebar, header, content)
# Linux / fallback: solid tinted surfaces

use nogc_sync_mut.env.platform.{detect_os}

class PlatformMaterial:
    shell_material: text       # "mica", "acrylic", "vibrancy", "solid"
    transient_material: text   # "acrylic", "vibrancy", "solid"
    title_bar_style: text      # "hidden", "hiddenInset", "default"
    supports_blur: bool
    supports_vibrancy: bool

    static fn detect() -> PlatformMaterial:
        val os = detect_os()
        if os == "macos":
            return PlatformMaterial(
                shell_material: "vibrancy",
                transient_material: "vibrancy",
                title_bar_style: "hiddenInset",
                supports_blur: true,
                supports_vibrancy: true
            )
        if os == "windows":
            return PlatformMaterial(
                shell_material: "mica",
                transient_material: "acrylic",
                title_bar_style: "hidden",
                supports_blur: true,
                supports_vibrancy: false
            )
        # Linux / fallback
        return PlatformMaterial(
            shell_material: "solid",
            transient_material: "solid",
            title_bar_style: "default",
            supports_blur: false,
            supports_vibrancy: false
        )

fn platform_material_to_css(mat: PlatformMaterial) -> text:
    """Generate CSS custom properties for the current platform material."""
    var css = ""
    css = css + "--shell-material: " + mat.shell_material + ";\n"
    css = css + "--transient-material: " + mat.transient_material + ";\n"
    css = css + "--title-bar-style: " + mat.title_bar_style + ";\n"
    if mat.supports_blur:
        css = css + "--supports-blur: 1;\n"
    else:
        css = css + "--supports-blur: 0;\n"
    if mat.supports_vibrancy:
        css = css + "--supports-vibrancy: 1;\n"
    else:
        css = css + "--supports-vibrancy: 0;\n"
    css
