# UI mode transitions and keybinding resolution.

use common.ui.widget.{UIMode, UIEvent, UIState}

fn switch_mode(state: UIState, new_mode: UIMode) -> UIState:
    return UIState(
        tree: state.tree,
        mode: new_mode,
        focused_id: state.focused_id,
        command_buffer: if new_mode == UIMode.Command: "" else: state.command_buffer
    )

fn resolve_keybinding(state: UIState, key: text) -> UIEvent?:
    val mode_name = match state.mode:
        UIMode.Normal => "normal"
        UIMode.Command => "command"
        UIMode.Insert => "insert"
        UIMode.Menu => "menu"

    # Bracket + contains_key, not `.get()`: dict `.get()` is unreliable on the
    # interpreter (returns nil for present keys). `[]` is reliable everywhere.
    val all_bindings = state.tree.bindings()
    if not all_bindings.contains_key(mode_name):
        return nil
    val bindings = all_bindings[mode_name]
    if not bindings.contains_key(key):
        return nil
    return action_to_event(bindings[key])

fn action_to_event(action: text) -> UIEvent:
    match action:
        "quit" => return UIEvent.Quit
        "focus_next" => return UIEvent.FocusNext
        "focus_prev" => return UIEvent.FocusPrev
        "command_mode" => return UIEvent.CommandMode
        "normal_mode" => return UIEvent.NormalMode
        "insert_mode" => return UIEvent.InsertMode
        "copy" => return UIEvent.Copy
        "cut" => return UIEvent.Cut
        "paste" => return UIEvent.Paste
        "paste_history" => return UIEvent.PasteFromHistory(index: 0)
        _ => return UIEvent.Action(name: action)
