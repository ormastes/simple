"""X11-class renderer and window-manager capability gate.

This is not an X11 protocol implementation. It records the native SimpleOS
backend semantics that a future Wine graphics driver will need before it can
map Win32 windows/messages onto the WM.
"""

pub fn x11_backend_required_features() -> [text]:
    [
        "display",
        "screen",
        "window",
        "map-unmap",
        "configure",
        "surface",
        "damage",
        "clip",
        "expose",
        "present",
        "input",
        "focus",
        "cursor",
        "clipboard",
        "text",
        "glyph",
        "blit",
        "fill"
    ]

pub fn x11_backend_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in x11_backend_required_features():
        if not features.contains(feature):
            missing.push(feature)
    return missing

pub fn x11_backend_gate(features: text) -> text:
    val missing = x11_backend_missing_features(features)
    if missing.len() == 0:
        return "ready"
    return "missing-" + missing[0]

pub fn x11_backend_event_gate(events: text) -> text:
    if not events.contains("create"):
        return "missing-create"
    if not events.contains("map"):
        return "missing-map"
    if not events.contains("unmap"):
        return "missing-unmap"
    if not events.contains("configure"):
        return "missing-configure"
    if not events.contains("expose"):
        return "missing-expose"
    if not events.contains("focus"):
        return "missing-focus"
    if not events.contains("input"):
        return "missing-input"
    if not events.contains("clipboard"):
        return "missing-clipboard"
    if not events.contains("destroy"):
        return "missing-destroy"
    return "ready"

pub fn x11_backend_pixel_gate(evidence: text) -> text:
    if not evidence.contains("golden"):
        return "missing-golden"
    if not evidence.contains("damage"):
        return "missing-damage"
    if not evidence.contains("text"):
        return "missing-text"
    if not evidence.contains("cursor"):
        return "missing-cursor"
    if not evidence.contains("present"):
        return "missing-present"
    return "ready"
