# Window Manager
#
# Geometry-aware window tracking that composes SurfaceManager.
# SurfaceManager owns content (widget trees + handle invalidation).
# WindowManager owns presentation (position, size, z-order, focus).

use common.ui.widget.{UITree}
use common.ui.surface.{SurfaceManager, SurfaceHandle, new_surface_manager}

# =========================================================================
# Window Geometry
# =========================================================================

struct WindowGeometry:
    x: i32
    y: i32
    width: i32
    height: i32
    z_order: i32
    minimized: bool
    maximized: bool

fn default_geometry(x: i32, y: i32, width: i32, height: i32) -> WindowGeometry:
    return WindowGeometry(
        x: x,
        y: y,
        width: width,
        height: height,
        z_order: 0,
        minimized: false,
        maximized: false
    )

# =========================================================================
# Window Info
# =========================================================================

struct WindowInfo:
    id: text
    title: text
    geometry: WindowGeometry

# =========================================================================
# Window Manager
# =========================================================================

class WindowManager:
    surfaces: SurfaceManager
    windows: [WindowInfo]
    next_z: i32
    focused_window: text

    static fn new() -> WindowManager:
        return WindowManager(
            surfaces: new_surface_manager(),
            windows: [],
            next_z: 1,
            focused_window: ""
        )

# =========================================================================
# Constructor Shorthand
# =========================================================================

fn new_window_manager() -> WindowManager:
    return WindowManager.new()

# =========================================================================
# WindowManager Methods
# =========================================================================

impl WindowManager:

    # -- Open / Close --------------------------------------------------------

    me open_window(id: text, title: text, x: i32, y: i32, width: i32, height: i32, tree: UITree) -> SurfaceHandle:
        """Open a new window with position and size."""
        val handle = self.surfaces.open(id, tree)
        val geo = WindowGeometry(
            x: x,
            y: y,
            width: width,
            height: height,
            z_order: self.next_z,
            minimized: false,
            maximized: false
        )
        self.next_z = self.next_z + 1
        val info = WindowInfo(id: id, title: title, geometry: geo)
        # Remove existing entry with same id, then add new
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id != id:
                updated = updated.push(w)
        updated = updated.push(info)
        self.windows = updated
        self.focused_window = id
        return handle

    me close_window(handle: SurfaceHandle) -> bool:
        """Close a window by handle. Returns false if handle is stale."""
        val ok = self.surfaces.close(handle)
        if not ok:
            return false
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id != handle.id:
                updated = updated.push(w)
        self.windows = updated
        if self.focused_window == handle.id:
            # Focus the topmost remaining window
            self.focused_window = ""
            var top_z: i32 = -1
            for w in self.windows:
                if w.geometry.z_order > top_z:
                    top_z = w.geometry.z_order
                    self.focused_window = w.id
        return true

    # -- Geometry updates ----------------------------------------------------

    me move_window(id: text, x: i32, y: i32):
        """Update window position."""
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id == id:
                val geo = WindowGeometry(
                    x: x,
                    y: y,
                    width: w.geometry.width,
                    height: w.geometry.height,
                    z_order: w.geometry.z_order,
                    minimized: w.geometry.minimized,
                    maximized: w.geometry.maximized
                )
                updated = updated.push(WindowInfo(id: w.id, title: w.title, geometry: geo))
            else:
                updated = updated.push(w)
        self.windows = updated

    me resize_window(id: text, width: i32, height: i32):
        """Update window size."""
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id == id:
                val geo = WindowGeometry(
                    x: w.geometry.x,
                    y: w.geometry.y,
                    width: width,
                    height: height,
                    z_order: w.geometry.z_order,
                    minimized: w.geometry.minimized,
                    maximized: w.geometry.maximized
                )
                updated = updated.push(WindowInfo(id: w.id, title: w.title, geometry: geo))
            else:
                updated = updated.push(w)
        self.windows = updated

    # -- Focus / Z-order -----------------------------------------------------

    me focus_window(id: text):
        """Focus a window — brings it to top z-order."""
        var found = false
        for w in self.windows:
            if w.id == id:
                found = true
        if not found:
            return
        self.focused_window = id
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id == id:
                val geo = WindowGeometry(
                    x: w.geometry.x,
                    y: w.geometry.y,
                    width: w.geometry.width,
                    height: w.geometry.height,
                    z_order: self.next_z,
                    minimized: false,
                    maximized: w.geometry.maximized
                )
                self.next_z = self.next_z + 1
                updated = updated.push(WindowInfo(id: w.id, title: w.title, geometry: geo))
            else:
                updated = updated.push(w)
        self.windows = updated

    me bring_to_front(id: text):
        """Alias for focus_window."""
        self.focus_window(id)

    # -- Minimize / Maximize -------------------------------------------------

    me minimize_window(id: text):
        """Minimize a window."""
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id == id:
                val geo = WindowGeometry(
                    x: w.geometry.x,
                    y: w.geometry.y,
                    width: w.geometry.width,
                    height: w.geometry.height,
                    z_order: w.geometry.z_order,
                    minimized: true,
                    maximized: w.geometry.maximized
                )
                updated = updated.push(WindowInfo(id: w.id, title: w.title, geometry: geo))
            else:
                updated = updated.push(w)
        self.windows = updated
        if self.focused_window == id:
            # Focus the topmost non-minimized window
            self.focused_window = ""
            var top_z: i32 = -1
            for w in self.windows:
                if not w.geometry.minimized and w.geometry.z_order > top_z:
                    top_z = w.geometry.z_order
                    self.focused_window = w.id

    me maximize_window(id: text):
        """Toggle maximize on a window."""
        var updated: [WindowInfo] = []
        for w in self.windows:
            if w.id == id:
                val geo = WindowGeometry(
                    x: w.geometry.x,
                    y: w.geometry.y,
                    width: w.geometry.width,
                    height: w.geometry.height,
                    z_order: w.geometry.z_order,
                    minimized: w.geometry.minimized,
                    maximized: not w.geometry.maximized
                )
                updated = updated.push(WindowInfo(id: w.id, title: w.title, geometry: geo))
            else:
                updated = updated.push(w)
        self.windows = updated

    # -- Getters -------------------------------------------------------------

    fn get_window(id: text) -> WindowInfo?:
        """Get window info by id."""
        for w in self.windows:
            if w.id == id:
                return w
        return nil

    fn window_ids() -> [text]:
        """Get all window IDs."""
        var ids: [text] = []
        for w in self.windows:
            ids = ids.push(w.id)
        return ids

    fn window_count() -> i32:
        """Get the number of open windows."""
        var count: i32 = 0
        for w in self.windows:
            count = count + 1
        return count

    fn focused() -> text:
        """Get the currently focused window ID."""
        return self.focused_window

    fn windows_by_z_order() -> [WindowInfo]:
        """Get windows sorted by z-order (back-to-front)."""
        # Simple insertion sort (window count is small)
        var sorted: [WindowInfo] = []
        for w in self.windows:
            sorted = sorted.push(w)
        # Bubble sort by z_order ascending
        var n = self.window_count()
        var i: i32 = 0
        while i < n - 1:
            var j: i32 = 0
            while j < n - 1 - i:
                val a = sorted[j]
                val b = sorted[j + 1]
                if a.geometry.z_order > b.geometry.z_order:
                    sorted[j] = b
                    sorted[j + 1] = a
                j = j + 1
            i = i + 1
        return sorted
