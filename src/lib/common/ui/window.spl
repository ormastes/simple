# Shared MDI Window Model
#
# Backend-neutral top-level window state. Host shells can keep HTML-only
# descriptors for IPC, while Simple UI and SimpleOS WM paths use UITree-backed
# managed windows from the same manager.

use common.ui.widget.{UITree}

struct WindowInfo:
    id: text
    title: text
    html: text
    x: i32
    y: i32
    width: i32
    height: i32

struct ManagedWindow:
    surface_id: text
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    tree: UITree?
    html: text
    minimized: bool
    focused: bool
    z_index: i32

class WindowManager:
    windows: [ManagedWindow]
    next_z_index: i32
    backend: text

impl WindowManager:
    static fn new() -> WindowManager:
        WindowManager(windows: [], next_z_index: 1, backend: "simple")

    static fn for_backend(backend: text) -> WindowManager:
        WindowManager(windows: [], next_z_index: 1, backend: normalize_window_backend(backend))

    me set_backend(backend: text):
        self.backend = normalize_window_backend(backend)

    fn current_backend() -> text:
        normalize_window_backend(self.backend)

    me open_window(surface_id: text, title: text, x: i32, y: i32, width: i32, height: i32, tree: UITree) -> ManagedWindow:
        val opened = ManagedWindow(
            surface_id: surface_id,
            title: title,
            x: x,
            y: y,
            width: width,
            height: height,
            tree: tree,
            html: "",
            minimized: false,
            focused: true,
            z_index: self.next_z_index
        )
        self.next_z_index = self.next_z_index + 1
        self.replace_window(opened)
        return opened

    me open_info(info: WindowInfo) -> ManagedWindow:
        val opened = ManagedWindow(
            surface_id: info.id,
            title: info.title,
            x: info.x,
            y: info.y,
            width: info.width,
            height: info.height,
            tree: nil,
            html: info.html,
            minimized: false,
            focused: true,
            z_index: self.next_z_index
        )
        self.next_z_index = self.next_z_index + 1
        self.replace_window(opened)
        return opened

    me replace_window(window: ManagedWindow):
        var keep_count = 0
        for existing in self.windows:
            if existing.surface_id != window.surface_id:
                keep_count = keep_count + 1
        var next: [ManagedWindow] = [window; keep_count + 1]
        var write_idx = 0
        for existing in self.windows:
            if existing.surface_id == window.surface_id:
                pass_dn
            else:
                next[write_idx] = ManagedWindow(
                    surface_id: existing.surface_id,
                    title: existing.title,
                    x: existing.x,
                    y: existing.y,
                    width: existing.width,
                    height: existing.height,
                    tree: existing.tree,
                    html: existing.html,
                    minimized: existing.minimized,
                    focused: false,
                    z_index: existing.z_index
                )
                write_idx = write_idx + 1
        if write_idx != keep_count:
            self.windows = []
            return
        next[write_idx] = window
        self.windows = next

    me close_window(surface_id: text):
        var keep_count = 0
        for existing in self.windows:
            if existing.surface_id != surface_id:
                keep_count = keep_count + 1
        if keep_count == 0:
            self.windows = []
            return
        var next: [ManagedWindow] = [self.windows[0]; keep_count]
        var write_idx = 0
        for existing in self.windows:
            if existing.surface_id == surface_id:
                pass_dn
            else:
                next[write_idx] = existing
                write_idx = write_idx + 1
        if write_idx != keep_count:
            self.windows = []
            return
        self.windows = next

    me minimize_window(surface_id: text):
        val window_count = self.windows.len()
        if window_count == 0:
            self.windows = []
            return
        var next: [ManagedWindow] = [self.windows[0]; window_count]
        var write_idx = 0
        for existing in self.windows:
            if existing.surface_id == surface_id:
                next[write_idx] = ManagedWindow(
                    surface_id: existing.surface_id,
                    title: existing.title,
                    x: existing.x,
                    y: existing.y,
                    width: existing.width,
                    height: existing.height,
                    tree: existing.tree,
                    html: existing.html,
                    minimized: true,
                    focused: false,
                    z_index: existing.z_index
                )
            else:
                next[write_idx] = existing
            write_idx = write_idx + 1
        self.windows = next

    me focus_window(surface_id: text):
        val window_count = self.windows.len()
        if window_count == 0:
            self.next_z_index = self.next_z_index + 1
            self.windows = []
            return
        var next: [ManagedWindow] = [self.windows[0]; window_count]
        var write_idx = 0
        for existing in self.windows:
            if existing.surface_id == surface_id:
                next[write_idx] = ManagedWindow(
                    surface_id: existing.surface_id,
                    title: existing.title,
                    x: existing.x,
                    y: existing.y,
                    width: existing.width,
                    height: existing.height,
                    tree: existing.tree,
                    html: existing.html,
                    minimized: false,
                    focused: true,
                    z_index: self.next_z_index
                )
            else:
                next[write_idx] = ManagedWindow(
                    surface_id: existing.surface_id,
                    title: existing.title,
                    x: existing.x,
                    y: existing.y,
                    width: existing.width,
                    height: existing.height,
                    tree: existing.tree,
                    html: existing.html,
                    minimized: existing.minimized,
                    focused: false,
                    z_index: existing.z_index
                )
            write_idx = write_idx + 1
        self.next_z_index = self.next_z_index + 1
        self.windows = next

    fn count() -> i32:
        self.windows.len()

    fn find(surface_id: text) -> ManagedWindow?:
        for existing in self.windows:
            if existing.surface_id == surface_id:
                return existing
        return nil

fn window_info(id: text, title: text, html: text, x: i32, y: i32, width: i32, height: i32) -> WindowInfo:
    WindowInfo(id: id, title: title, html: html, x: x, y: y, width: width, height: height)

fn normalize_window_backend(backend: text) -> text:
    if backend == "tauri":
        return "tauri"
    if backend == "electron":
        return "electron"
    if backend == "election":
        return "electron"
    "simple"

fn new_window_manager() -> WindowManager:
    WindowManager.new()

fn new_window_manager_for_backend(backend: text) -> WindowManager:
    WindowManager.for_backend(backend)
