# Theme Sync SDN — Serializer and parser for StitchDesignSystem ↔ SDN
#
# Converts StitchDesignSystem to the SDN schema emitted by `dump-local`.
# Also parses that same schema back to a ParsedStitchDesignSystem (for diff).
#
# SDN schema emitted:
#   display_name: <text>
#   pulled_from: <text>
#   pulled_at: <text>
#   theme:
#       color_mode: <text>
#       ... metadata fields ...
#       named_colors:
#           <key>: <value>   (47 alphabetized entries)
#
# design_md is NOT emitted — stays in the stitch skill.
# notes is NOT emitted — only present in pulled snapshots.

use common.ui.glass_tokens.{StitchDesignSystem, StitchMetadata, StitchMd3Colors}

# =========================================================================
# Parsed Design System (plain data structs, immutable after construction)
# =========================================================================

