    background: text
    error: text
    error_container: text
    inverse_on_surface: text
    inverse_primary: text
    inverse_surface: text
    on_background: text
    on_error: text
    on_error_container: text
    on_primary: text
    on_primary_container: text
    on_primary_fixed: text
    on_primary_fixed_variant: text
    on_secondary: text
    on_secondary_container: text
    on_secondary_fixed: text
    on_secondary_fixed_variant: text
    on_surface: text
    on_surface_variant: text
    on_tertiary: text
    on_tertiary_container: text
    on_tertiary_fixed: text
    on_tertiary_fixed_variant: text
    outline: text
    outline_variant: text
    primary: text
    primary_container: text
    primary_fixed: text
    primary_fixed_dim: text
    secondary: text
    secondary_container: text
    secondary_fixed: text
    secondary_fixed_dim: text
    surface: text
    surface_bright: text
    surface_container: text
    surface_container_high: text
    surface_container_highest: text
    surface_container_low: text
    surface_container_lowest: text
    surface_dim: text
    surface_tint: text
    surface_variant: text
    tertiary: text
    tertiary_container: text
    tertiary_fixed: text
    tertiary_fixed_dim: text

    static fn empty() -> ParsedStitchMd3Colors:
        ParsedStitchMd3Colors(
            background: "", error: "", error_container: "",
            inverse_on_surface: "", inverse_primary: "", inverse_surface: "",
            on_background: "", on_error: "", on_error_container: "",
            on_primary: "", on_primary_container: "",
            on_primary_fixed: "", on_primary_fixed_variant: "",
            on_secondary: "", on_secondary_container: "",
            on_secondary_fixed: "", on_secondary_fixed_variant: "",
            on_surface: "", on_surface_variant: "",
            on_tertiary: "", on_tertiary_container: "",
            on_tertiary_fixed: "", on_tertiary_fixed_variant: "",
            outline: "", outline_variant: "",
            primary: "", primary_container: "",
            primary_fixed: "", primary_fixed_dim: "",
            secondary: "", secondary_container: "",
            secondary_fixed: "", secondary_fixed_dim: "",
            surface: "", surface_bright: "",
            surface_container: "", surface_container_high: "",
            surface_container_highest: "",
            surface_container_low: "", surface_container_lowest: "",
            surface_dim: "", surface_tint: "", surface_variant: "",
