        )

class ParsedStitchMetadata:
    display_name: text
    pulled_from: text
    pulled_at: text
    color_mode: text
    color_variant: text
    custom_color: text
    roundness: text
    spacing_scale: text
    font: text
    headline_font: text
    body_font: text
    label_font: text
    override_primary_color: text
    override_secondary_color: text
    override_tertiary_color: text
    override_neutral_color: text

    static fn empty() -> ParsedStitchMetadata:
        ParsedStitchMetadata(
            display_name: "", pulled_from: "", pulled_at: "",
            color_mode: "", color_variant: "", custom_color: "",
            roundness: "", spacing_scale: "", font: "",
            headline_font: "", body_font: "", label_font: "",
            override_primary_color: "", override_secondary_color: "",
            override_tertiary_color: "", override_neutral_color: ""
        )

class ParsedStitchDesignSystem:
    metadata: ParsedStitchMetadata
    md3: ParsedStitchMd3Colors

    static fn empty() -> ParsedStitchDesignSystem:
        ParsedStitchDesignSystem(
            metadata: ParsedStitchMetadata.empty(),
            md3: ParsedStitchMd3Colors.empty()
        )

# =========================================================================
# Serializer helpers
# =========================================================================

fn _sdn_quoted(val_text: text) -> text:
    if val_text.starts_with("\""):
        return val_text
    return "\"{val_text}\""

fn _emit_field(key: text, value: text) -> text:
    """Root-level field: quoted value (display_name, pulled_from, pulled_at)."""
    return "{key}: {_sdn_quoted(value)}\n"

fn _emit_theme_field_quoted(key: text, value: text) -> text:
    """Theme-level field with quoted value (hex colors like custom_color, overrides)."""
    return "    {key}: {_sdn_quoted(value)}\n"

fn _emit_theme_field_bare(key: text, value: text) -> text:
    """Theme-level field with bare/unquoted value (enums like color_mode, font names)."""
    return "    {key}: {value}\n"

fn _emit_color_field(key: text, value: text) -> text:
    """Named-color entry: quoted hex value."""
    return "        {key}: {_sdn_quoted(value)}\n"

# =========================================================================
# Serializer: StitchDesignSystem → SDN text
# =========================================================================

fn dump_stitch_design_system_sdn(ds: StitchDesignSystem, pulled_from: text, pulled_at: text) -> text:
    """Serialize a StitchDesignSystem to the canonical SDN format.

    pulled_from: e.g. "local/glass_tokens.spl StitchDesignSystem.obsidian()"
    pulled_at:   e.g. "2026-04-12"
    """
    val m = ds.metadata
    val c = ds.md3

    var out = ""

    out = "{out}{_emit_field("display_name", m.display_name)}"
    out = "{out}{_emit_field("pulled_from", pulled_from)}"
    out = "{out}{_emit_field("pulled_at", pulled_at)}"
    out = "{out}\n"
    out = "{out}theme:\n"
    out = "{out}{_emit_theme_field_bare("color_mode", m.color_mode)}"
    out = "{out}{_emit_theme_field_bare("color_variant", m.color_variant)}"
    out = "{out}{_emit_theme_field_quoted("custom_color", m.custom_color)}"
    out = "{out}{_emit_theme_field_bare("roundness", m.roundness)}"
    out = "{out}    spacing_scale: {m.spacing_scale}\n"
    out = "{out}{_emit_theme_field_bare("font", m.font)}"
    out = "{out}{_emit_theme_field_bare("headline_font", m.headline_font)}"
    out = "{out}{_emit_theme_field_bare("body_font", m.body_font)}"
    out = "{out}{_emit_theme_field_bare("label_font", m.label_font)}"
    out = "{out}{_emit_theme_field_quoted("override_primary_color", m.override_primary_color)}"
    out = "{out}{_emit_theme_field_quoted("override_secondary_color", m.override_secondary_color)}"
    out = "{out}{_emit_theme_field_quoted("override_tertiary_color", m.override_tertiary_color)}"
    out = "{out}{_emit_theme_field_quoted("override_neutral_color", m.override_neutral_color)}"
    out = "{out}    named_colors:\n"
    out = "{out}{_emit_color_field("background", c.background)}"
    out = "{out}{_emit_color_field("error", c.error)}"
    out = "{out}{_emit_color_field("error_container", c.error_container)}"
    out = "{out}{_emit_color_field("inverse_on_surface", c.inverse_on_surface)}"
    out = "{out}{_emit_color_field("inverse_primary", c.inverse_primary)}"
    out = "{out}{_emit_color_field("inverse_surface", c.inverse_surface)}"
    out = "{out}{_emit_color_field("on_background", c.on_background)}"
    out = "{out}{_emit_color_field("on_error", c.on_error)}"
    out = "{out}{_emit_color_field("on_error_container", c.on_error_container)}"
    out = "{out}{_emit_color_field("on_primary", c.on_primary)}"
    out = "{out}{_emit_color_field("on_primary_container", c.on_primary_container)}"
    out = "{out}{_emit_color_field("on_primary_fixed", c.on_primary_fixed)}"
    out = "{out}{_emit_color_field("on_primary_fixed_variant", c.on_primary_fixed_variant)}"
    out = "{out}{_emit_color_field("on_secondary", c.on_secondary)}"
    out = "{out}{_emit_color_field("on_secondary_container", c.on_secondary_container)}"
    out = "{out}{_emit_color_field("on_secondary_fixed", c.on_secondary_fixed)}"
    out = "{out}{_emit_color_field("on_secondary_fixed_variant", c.on_secondary_fixed_variant)}"
    out = "{out}{_emit_color_field("on_surface", c.on_surface)}"
    out = "{out}{_emit_color_field("on_surface_variant", c.on_surface_variant)}"
    out = "{out}{_emit_color_field("on_tertiary", c.on_tertiary)}"
    out = "{out}{_emit_color_field("on_tertiary_container", c.on_tertiary_container)}"
    out = "{out}{_emit_color_field("on_tertiary_fixed", c.on_tertiary_fixed)}"
    out = "{out}{_emit_color_field("on_tertiary_fixed_variant", c.on_tertiary_fixed_variant)}"
    out = "{out}{_emit_color_field("outline", c.outline)}"
    out = "{out}{_emit_color_field("outline_variant", c.outline_variant)}"
    out = "{out}{_emit_color_field("primary", c.primary)}"
    out = "{out}{_emit_color_field("primary_container", c.primary_container)}"
    out = "{out}{_emit_color_field("primary_fixed", c.primary_fixed)}"
    out = "{out}{_emit_color_field("primary_fixed_dim", c.primary_fixed_dim)}"
    out = "{out}{_emit_color_field("secondary", c.secondary)}"
    out = "{out}{_emit_color_field("secondary_container", c.secondary_container)}"
    out = "{out}{_emit_color_field("secondary_fixed", c.secondary_fixed)}"
    out = "{out}{_emit_color_field("secondary_fixed_dim", c.secondary_fixed_dim)}"
    out = "{out}{_emit_color_field("surface", c.surface)}"
    out = "{out}{_emit_color_field("surface_bright", c.surface_bright)}"
    out = "{out}{_emit_color_field("surface_container", c.surface_container)}"
    out = "{out}{_emit_color_field("surface_container_high", c.surface_container_high)}"
    out = "{out}{_emit_color_field("surface_container_highest", c.surface_container_highest)}"
    out = "{out}{_emit_color_field("surface_container_low", c.surface_container_low)}"
    out = "{out}{_emit_color_field("surface_container_lowest", c.surface_container_lowest)}"
    out = "{out}{_emit_color_field("surface_dim", c.surface_dim)}"
    out = "{out}{_emit_color_field("surface_tint", c.surface_tint)}"
    out = "{out}{_emit_color_field("surface_variant", c.surface_variant)}"
    out = "{out}{_emit_color_field("tertiary", c.tertiary)}"
    out = "{out}{_emit_color_field("tertiary_container", c.tertiary_container)}"
    out = "{out}{_emit_color_field("tertiary_fixed", c.tertiary_fixed)}"
    out = "{out}{_emit_color_field("tertiary_fixed_dim", c.tertiary_fixed_dim)}"

    out

# =========================================================================
# Push payload emitter: ParsedStitchDesignSystem → Stitch update_design_system SDN
# =========================================================================
#
# Flat field layout (no nested `theme:` block) — matches the argument shape
# of `mcp__stitch__update_design_system`. Includes a multi-line `design_md: |`
# block at the end so the Claude skill session can read the file and pass
# every field verbatim to the MCP call.

fn _emit_flat_field_quoted(key: text, value: text) -> text:
    return "{key}: {_sdn_quoted(value)}\n"

fn _emit_flat_field_bare(key: text, value: text) -> text:
    return "{key}: {value}\n"

fn _emit_flat_color_field(key: text, value: text) -> text:
    return "    {key}: {_sdn_quoted(value)}\n"

fn _emit_design_md_block(design_md: text) -> text:
    """Emit design_md as a multi-line `|` block, indenting each line with 4 spaces."""
    var out = "design_md: |\n"
    val lines = design_md.split("\n")
    var i = 0
    while i < lines.len():
        out = "{out}    {lines[i]}\n"
        i = i + 1
    out

fn emit_push_payload_sdn(parsed: ParsedStitchDesignSystem, project_id: text, design_system_id: text, generated_at: text, design_md: text) -> text:
    """Serialize a ParsedStitchDesignSystem to a Stitch update_design_system payload SDN.

    Flat schema — the Claude skill reads this file and forwards every field to
    `mcp__stitch__update_design_system`. Keeps a `design_md: |` multi-line tail.
    """
    val m = parsed.metadata
    val c = parsed.md3

    var out = ""
    out = "{out}# Stitch update_design_system payload\n"
    out = "{out}# Generated by: bin/simple theme-sync build-push-payload\n"
    out = "{out}{_emit_flat_field_quoted("project_id", project_id)}"
    out = "{out}{_emit_flat_field_quoted("design_system_id", design_system_id)}"
    out = "{out}{_emit_flat_field_quoted("generated_at", generated_at)}"
    out = "{out}{_emit_flat_field_quoted("display_name", m.display_name)}"
    out = "{out}{_emit_flat_field_bare("color_mode", m.color_mode)}"
    out = "{out}{_emit_flat_field_bare("headline_font", m.headline_font)}"
    out = "{out}{_emit_flat_field_bare("body_font", m.body_font)}"
    out = "{out}{_emit_flat_field_bare("label_font", m.label_font)}"
    out = "{out}{_emit_flat_field_bare("roundness", m.roundness)}"
    out = "{out}{_emit_flat_field_bare("color_variant", m.color_variant)}"
    out = "{out}{_emit_flat_field_quoted("custom_color", m.custom_color)}"
    out = "{out}spacing_scale: {m.spacing_scale}\n"
    out = "{out}{_emit_flat_field_quoted("override_primary_color", m.override_primary_color)}"
    out = "{out}{_emit_flat_field_quoted("override_secondary_color", m.override_secondary_color)}"
    out = "{out}{_emit_flat_field_quoted("override_tertiary_color", m.override_tertiary_color)}"
    out = "{out}{_emit_flat_field_quoted("override_neutral_color", m.override_neutral_color)}"
    out = "{out}named_colors:\n"
    out = "{out}{_emit_flat_color_field("background", c.background)}"
    out = "{out}{_emit_flat_color_field("error", c.error)}"
    out = "{out}{_emit_flat_color_field("error_container", c.error_container)}"
    out = "{out}{_emit_flat_color_field("inverse_on_surface", c.inverse_on_surface)}"
    out = "{out}{_emit_flat_color_field("inverse_primary", c.inverse_primary)}"
    out = "{out}{_emit_flat_color_field("inverse_surface", c.inverse_surface)}"
    out = "{out}{_emit_flat_color_field("on_background", c.on_background)}"
    out = "{out}{_emit_flat_color_field("on_error", c.on_error)}"
    out = "{out}{_emit_flat_color_field("on_error_container", c.on_error_container)}"
    out = "{out}{_emit_flat_color_field("on_primary", c.on_primary)}"
    out = "{out}{_emit_flat_color_field("on_primary_container", c.on_primary_container)}"
    out = "{out}{_emit_flat_color_field("on_primary_fixed", c.on_primary_fixed)}"
    out = "{out}{_emit_flat_color_field("on_primary_fixed_variant", c.on_primary_fixed_variant)}"
    out = "{out}{_emit_flat_color_field("on_secondary", c.on_secondary)}"
    out = "{out}{_emit_flat_color_field("on_secondary_container", c.on_secondary_container)}"
    out = "{out}{_emit_flat_color_field("on_secondary_fixed", c.on_secondary_fixed)}"
    out = "{out}{_emit_flat_color_field("on_secondary_fixed_variant", c.on_secondary_fixed_variant)}"
    out = "{out}{_emit_flat_color_field("on_surface", c.on_surface)}"
    out = "{out}{_emit_flat_color_field("on_surface_variant", c.on_surface_variant)}"
    out = "{out}{_emit_flat_color_field("on_tertiary", c.on_tertiary)}"
    out = "{out}{_emit_flat_color_field("on_tertiary_container", c.on_tertiary_container)}"
    out = "{out}{_emit_flat_color_field("on_tertiary_fixed", c.on_tertiary_fixed)}"
    out = "{out}{_emit_flat_color_field("on_tertiary_fixed_variant", c.on_tertiary_fixed_variant)}"
    out = "{out}{_emit_flat_color_field("outline", c.outline)}"
    out = "{out}{_emit_flat_color_field("outline_variant", c.outline_variant)}"
    out = "{out}{_emit_flat_color_field("primary", c.primary)}"
    out = "{out}{_emit_flat_color_field("primary_container", c.primary_container)}"
    out = "{out}{_emit_flat_color_field("primary_fixed", c.primary_fixed)}"
    out = "{out}{_emit_flat_color_field("primary_fixed_dim", c.primary_fixed_dim)}"
    out = "{out}{_emit_flat_color_field("secondary", c.secondary)}"
    out = "{out}{_emit_flat_color_field("secondary_container", c.secondary_container)}"
    out = "{out}{_emit_flat_color_field("secondary_fixed", c.secondary_fixed)}"
    out = "{out}{_emit_flat_color_field("secondary_fixed_dim", c.secondary_fixed_dim)}"
    out = "{out}{_emit_flat_color_field("surface", c.surface)}"
    out = "{out}{_emit_flat_color_field("surface_bright", c.surface_bright)}"
    out = "{out}{_emit_flat_color_field("surface_container", c.surface_container)}"
    out = "{out}{_emit_flat_color_field("surface_container_high", c.surface_container_high)}"
    out = "{out}{_emit_flat_color_field("surface_container_highest", c.surface_container_highest)}"
    out = "{out}{_emit_flat_color_field("surface_container_low", c.surface_container_low)}"
    out = "{out}{_emit_flat_color_field("surface_container_lowest", c.surface_container_lowest)}"
    out = "{out}{_emit_flat_color_field("surface_dim", c.surface_dim)}"
    out = "{out}{_emit_flat_color_field("surface_tint", c.surface_tint)}"
    out = "{out}{_emit_flat_color_field("surface_variant", c.surface_variant)}"
    out = "{out}{_emit_flat_color_field("tertiary", c.tertiary)}"
    out = "{out}{_emit_flat_color_field("tertiary_container", c.tertiary_container)}"
    out = "{out}{_emit_flat_color_field("tertiary_fixed", c.tertiary_fixed)}"
    out = "{out}{_emit_flat_color_field("tertiary_fixed_dim", c.tertiary_fixed_dim)}"
    out = "{out}{_emit_design_md_block(design_md)}"

    out

# =========================================================================
# Parser helpers
# =========================================================================

fn _count_leading_spaces(line: text) -> i32:
    var count = 0
    var i = 0
    while i < line.len():
        if line[i] == " ":
            count = count + 1
        else:
            return count
        i = i + 1
    count

fn _strip_sdn_quotes(value: text) -> text:
    val v = value.trim()
    if v.len() >= 2 and v.starts_with("\"") and v.ends_with("\""):
        return v.substring(1, v.len() - 1)
    v

fn _split_kv(line: text) -> [text]:
    """Split 'key: value' into [key, value]. Returns [] if no colon found."""
    var i = 0
    while i < line.len():
        if line[i] == ":":
            return [line.substring(0, i).trim(), line.substring(i + 1).trim()]
        i = i + 1
    []

# =========================================================================
# Parser: SDN text → ParsedStitchDesignSystem
# =========================================================================
# State machine:
#   section 0 = root fields
#   section 1 = inside theme: block
#   section 2 = inside named_colors: block
# Multiline `|` values (design_md, notes) are skipped.
# Unknown fields are ignored (tolerant parsing per plan).

fn parse_stitch_design_system_sdn(sdn_text: text) -> ParsedStitchDesignSystem:
    """Parse SDN text into ParsedStitchDesignSystem. Tolerates unknown fields."""
    # Mutable accumulator fields — Simple immutable structs require rebuilding.
    # Use vars for each field, build struct at end.
    var display_name = ""
    var pulled_from = ""
    var pulled_at = ""
    var color_mode = ""
    var color_variant = ""
    var custom_color = ""
    var roundness = ""
    var spacing_scale = ""
    var font = ""
    var headline_font = ""
    var body_font = ""
    var label_font = ""
    var override_primary_color = ""
    var override_secondary_color = ""
    var override_tertiary_color = ""
    var override_neutral_color = ""
    # MD3 named colors
    var nc_background = ""
    var nc_error = ""
    var nc_error_container = ""
    var nc_inverse_on_surface = ""
    var nc_inverse_primary = ""
    var nc_inverse_surface = ""
    var nc_on_background = ""
    var nc_on_error = ""
    var nc_on_error_container = ""
    var nc_on_primary = ""
    var nc_on_primary_container = ""
    var nc_on_primary_fixed = ""
    var nc_on_primary_fixed_variant = ""
    var nc_on_secondary = ""
    var nc_on_secondary_container = ""
    var nc_on_secondary_fixed = ""
    var nc_on_secondary_fixed_variant = ""
    var nc_on_surface = ""
    var nc_on_surface_variant = ""
    var nc_on_tertiary = ""
    var nc_on_tertiary_container = ""
    var nc_on_tertiary_fixed = ""
    var nc_on_tertiary_fixed_variant = ""
    var nc_outline = ""
    var nc_outline_variant = ""
    var nc_primary = ""
    var nc_primary_container = ""
    var nc_primary_fixed = ""
    var nc_primary_fixed_dim = ""
    var nc_secondary = ""
    var nc_secondary_container = ""
    var nc_secondary_fixed = ""
    var nc_secondary_fixed_dim = ""
    var nc_surface = ""
    var nc_surface_bright = ""
    var nc_surface_container = ""
    var nc_surface_container_high = ""
    var nc_surface_container_highest = ""
    var nc_surface_container_low = ""
    var nc_surface_container_lowest = ""
    var nc_surface_dim = ""
    var nc_surface_tint = ""
    var nc_surface_variant = ""
    var nc_tertiary = ""
    var nc_tertiary_container = ""
    var nc_tertiary_fixed = ""
    var nc_tertiary_fixed_dim = ""

    var section = 0
    var skip_multiline = false
    var skip_indent = 0

    val lines = sdn_text.split("\n")
    var i = 0
    while i < lines.len():
        val raw_line = lines[i]
        val indent = _count_leading_spaces(raw_line)
        val line = raw_line.trim()

        if line == "" or line.starts_with("#"):
            i = i + 1
            continue

        if skip_multiline:
            if indent > skip_indent:
                i = i + 1
                continue
            else:
                skip_multiline = false

        val kv = _split_kv(line)
        if kv.len() < 2:
            i = i + 1
            continue

        val key = kv[0]
        val raw_val = kv[1]

        # Multiline block start
        if raw_val == "|":
            skip_multiline = true
            skip_indent = indent
            i = i + 1
            continue

        # Section headers (empty value after colon, or "{}")
        if raw_val == "" or raw_val == "{}":
            if key == "theme":
                section = 1
            elif key == "named_colors":
                section = 2
            i = i + 1
            continue

        val value = _strip_sdn_quotes(raw_val)

        if section == 0:
            if key == "display_name":
                display_name = value
            elif key == "pulled_from":
                pulled_from = value
            elif key == "pulled_at":
                pulled_at = value

        elif section == 1:
            if key == "color_mode":
                color_mode = value
            elif key == "color_variant":
                color_variant = value
            elif key == "custom_color":
                custom_color = value
            elif key == "roundness":
                roundness = value
            elif key == "spacing_scale":
                spacing_scale = value
            elif key == "font":
                font = value
            elif key == "headline_font":
                headline_font = value
            elif key == "body_font":
                body_font = value
            elif key == "label_font":
                label_font = value
            elif key == "override_primary_color":
                override_primary_color = value
            elif key == "override_secondary_color":
                override_secondary_color = value
            elif key == "override_tertiary_color":
                override_tertiary_color = value
            elif key == "override_neutral_color":
                override_neutral_color = value

        elif section == 2:
