# Session-scoped widget registry.

use common.ui.widget.{WidgetRecord, WidgetProp, WidgetNode, encode_child_ids, decode_child_ids, default_widget_record}

class WidgetStore:
    registry: [WidgetRecord]
    props: [WidgetProp]

    static fn new() -> WidgetStore:
        return WidgetStore(registry: [], props: [])

fn new_widget_store() -> WidgetStore:
    return WidgetStore.new()

impl WidgetStore:
    me upsert_record(record: WidgetRecord):
        val registry_len = self.registry.len()
        var replaced = false
        var scan_idx = 0
        while scan_idx < registry_len:
            if self.registry[scan_idx].id == record.id:
                replaced = true
                scan_idx = registry_len
            scan_idx = scan_idx + 1
        var updated_len = registry_len
        if not replaced:
            updated_len = registry_len + 1
        var updated: [WidgetRecord] = [record; updated_len]
        var write_idx = 0
        while write_idx < registry_len:
            val existing = self.registry[write_idx]
            if existing.id == record.id:
                updated[write_idx] = record
            else:
                updated[write_idx] = existing
            write_idx = write_idx + 1
        if not replaced:
            updated[registry_len] = record
        self.registry = updated

    fn get_record(id: text) -> WidgetRecord?:
        for record in self.registry:
            if record.id == id:
                return record
        return nil

    fn require_record(id: text) -> WidgetRecord:
        val found = self.get_record(id)
        if found != nil:
            return found
        val fallback = default_widget_record(id, "panel")
        self.upsert_record(fallback)
        return fallback

    fn record_count() -> i32:
        return self.registry.len()

    fn get_prop(node_id: text, key: text) -> text:
        for prop in self.props:
            if prop.node_id == node_id and prop.key == key:
                return prop.value
        return ""

    me set_prop(node_id: text, key: text, value: text):
        val new_prop = WidgetProp(node_id: node_id, key: key, value: value)
        val prop_len = self.props.len()
        var replaced = false
        var scan_idx = 0
        while scan_idx < prop_len:
            val prop = self.props[scan_idx]
            if prop.node_id == node_id and prop.key == key:
                replaced = true
                scan_idx = prop_len
            scan_idx = scan_idx + 1
        var updated_len = prop_len
        if not replaced:
            updated_len = prop_len + 1
        var updated: [WidgetProp] = [new_prop; updated_len]
        var write_idx = 0
        while write_idx < prop_len:
            val prop = self.props[write_idx]
            if prop.node_id == node_id and prop.key == key:
                updated[write_idx] = new_prop
            else:
                updated[write_idx] = prop
            write_idx = write_idx + 1
        if not replaced:
            updated[prop_len] = new_prop
        self.props = updated

    fn all_props() -> [WidgetProp]:
        return self.props

    fn prop_count() -> i32:
        return self.props.len()

    fn get_child_ids(node_id: text) -> [text]:
        return decode_child_ids(self.get_prop(node_id, "ui_children"))

    me register_child(parent_id: text, child_id: text):
        val existing = decode_child_ids(self.get_prop(parent_id, "ui_children"))
        for current_id in existing:
            if current_id == child_id:
                return
        val existing_len = existing.len()
        var updated: [text] = [child_id; existing_len + 1]
        var i = 0
        while i < existing_len:
            updated[i] = existing[i]
            i = i + 1
        updated[existing_len] = child_id
        self.set_prop(parent_id, "ui_children", encode_child_ids(updated))

    fn get_node(id: text) -> WidgetNode?:
        val record = self.get_record(id)
        if record == nil:
            return nil
        return WidgetNode(id: id)

impl WidgetNode:
    fn get_prop_from(store: WidgetStore, key: text) -> text:
        return store.get_prop(self.id, key)

    fn set_prop_in(store: WidgetStore, key: text, value: text) -> WidgetNode:
        store.set_prop(self.id, key, value)
        return self

    fn has_prop_in(store: WidgetStore, key: text) -> bool:
        return store.get_prop(self.id, key) != ""

    fn prop_keys_from(store: WidgetStore) -> [text]:
        var key_count = 0
        for prop in store.all_props():
            if prop.node_id == self.id:
                key_count = key_count + 1
        if key_count == 0:
            return []
        var keys: [text] = [""; key_count]
        var write_idx = 0
        for prop in store.all_props():
            if prop.node_id == self.id:
                keys[write_idx] = prop.key
                write_idx = write_idx + 1
        return keys

    fn children_from(store: WidgetStore) -> [WidgetNode]:
        val child_ids = store.get_child_ids(self.id)
        var child_count = 0
        for id in child_ids:
            if store.get_node(id) != nil:
                child_count = child_count + 1
        if child_count == 0:
            return []
        var result: [WidgetNode] = [WidgetNode(id: ""); child_count]
        var write_idx = 0
        for id in child_ids:
            val node = store.get_node(id)
            if node != nil:
                result[write_idx] = node
                write_idx = write_idx + 1
        return result

    fn add_child_in(store: WidgetStore, child: WidgetNode) -> WidgetNode:
        store.register_child(self.id, child.id)
        return self

    fn kind_name_from(store: WidgetStore) -> text:
        return store.require_record(self.id).kind

    fn layout_name_from(store: WidgetStore) -> text:
        return store.require_record(self.id).layout

    fn is_visible_from(store: WidgetStore) -> bool:
        return store.require_record(self.id).visible

    fn find_by_id_in(store: WidgetStore, target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children_from(store):
            val found = child.find_by_id_in(store, target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids_from(store: WidgetStore) -> [text]:
        var ids: [text] = [self.id]
        for child in self.children_from(store):
            for cid in child.collect_ids_from(store):
                ids.push(cid)
        return ids
