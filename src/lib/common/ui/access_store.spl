# UI Access Store — persisted event and current-node storage
#
# Minimal durable layer for the internal UI access protocol. This keeps
# append-only access events plus the latest known surfaces/nodes in SQLite so
# future search/history flows can query persisted state instead of depending on
# in-memory session lifetime.

use std.database.sql.connection.{Database}
use std.database.sql.types.{DbValue, DbRow, DbError}
use std.nogc_sync_mut.io.string_helpers.{text_hash_native}
use std.nogc_sync_mut.io.sysinfo_ops.{path_basename}
use common.ui.access.{UiAccessNode, UiAccessSurface, UiAccessEvent, UiAccessSnapshot}
use std.env.platform.{get_cache_dir}
use std.env.variables.{env_get}
use std.ffi.io.{dir_create_all}

class UiAccessStore:
    db: Database

impl UiAccessStore:
    static fn open(path: text) -> Result<UiAccessStore, DbError>:
        val db = Database.open(path)?
        var store = UiAccessStore(db: db)
        store.init_schema()?
        Ok(store)

    static fn memory() -> Result<UiAccessStore, DbError>:
        val db = Database.memory()?
        var store = UiAccessStore(db: db)
        store.init_schema()?
        Ok(store)

    me close() -> Result<(), DbError>:
        self.db.close()

    me init_schema() -> Result<(), DbError>:
        self.db.exec_sql(
            "CREATE TABLE IF NOT EXISTS ui_access_events (" +
            "id INTEGER PRIMARY KEY AUTOINCREMENT," +
            "sequence INTEGER NOT NULL," +
            "surface_id TEXT NOT NULL," +
            "widget_id TEXT NOT NULL," +
            "canonical_id TEXT NOT NULL," +
            "event_kind TEXT NOT NULL," +
            "payload TEXT NOT NULL)"
        )?
        self.db.exec_sql(
            "CREATE TABLE IF NOT EXISTS ui_access_surfaces (" +
            "surface_id TEXT PRIMARY KEY," +
            "title TEXT NOT NULL," +
            "active INTEGER NOT NULL," +
            "window_id TEXT NOT NULL," +
            "app_id TEXT NOT NULL," +
            "root_canonical_id TEXT NOT NULL)"
        )?
        self.db.exec_sql(
            "CREATE TABLE IF NOT EXISTS ui_access_nodes (" +
            "canonical_id TEXT PRIMARY KEY," +
            "surface_id TEXT NOT NULL," +
            "widget_id TEXT NOT NULL," +
            "kind TEXT NOT NULL," +
            "visible INTEGER NOT NULL," +
            "focused INTEGER NOT NULL," +
            "enabled INTEGER NOT NULL," +
            "selected INTEGER NOT NULL," +
            "text_value TEXT NOT NULL," +
            "child_ids_text TEXT NOT NULL," +
            "action_names_text TEXT NOT NULL)"
        )?
        self.db.exec_sql("CREATE INDEX IF NOT EXISTS idx_ui_access_events_surface_seq ON ui_access_events(surface_id, sequence)")?
        self.db.exec_sql("CREATE INDEX IF NOT EXISTS idx_ui_access_nodes_surface_kind ON ui_access_nodes(surface_id, kind)")?
        self.db.exec_sql("CREATE INDEX IF NOT EXISTS idx_ui_access_nodes_text ON ui_access_nodes(text_value)")?
        Ok(())

    me insert_event(event: UiAccessEvent) -> Result<i64, DbError>:
        val sql = "INSERT INTO ui_access_events (sequence, surface_id, widget_id, canonical_id, event_kind, payload) VALUES (?, ?, ?, ?, ?, ?)"
        val params: [DbValue] = [
            DbValue.Integer(value: event.sequence),
            DbValue.Text(value: event.surface_id),
            DbValue.Text(value: event.widget_id),
            DbValue.Text(value: event.canonical_id),
            DbValue.Text(value: event.event_kind),
            DbValue.Text(value: event.payload)
        ]
        self.db.exec(sql, params)?
        Ok(self.db.last_insert_rowid())

    me persist_snapshot(snapshot: UiAccessSnapshot) -> Result<(), DbError>:
        var tx = self.db.begin()?
        if val Err(e) = self.db.exec("DELETE FROM ui_access_surfaces", []):
            tx.rollback()?
            return Err(e)
        if val Err(e) = self.db.exec("DELETE FROM ui_access_nodes", []):
            tx.rollback()?
            return Err(e)
        for surface in snapshot.surfaces:
            if val Err(e) = self._insert_surface(surface):
                tx.rollback()?
                return Err(e)
        for node in snapshot.nodes:
            if val Err(e) = self._insert_node(node):
                tx.rollback()?
                return Err(e)
        tx.commit()?
        Ok(())

    fn query_events(from_sequence: i64, limit: i64) -> Result<[UiAccessEvent], DbError>:
        val sql = "SELECT sequence, surface_id, widget_id, canonical_id, event_kind, payload FROM ui_access_events WHERE sequence > ? ORDER BY sequence ASC LIMIT ?"
        val params: [DbValue] = [
            DbValue.Integer(value: from_sequence),
            DbValue.Integer(value: limit)
        ]
        val rows = self.db.query(sql, params)?
        var events: [UiAccessEvent] = []
        for row in rows:
            events = events.push(_decode_event_row(row)?)
        return Ok(events)

    fn list_events(surface_id: text, limit: i64) -> Result<[UiAccessEvent], DbError>:
        var sql = "SELECT sequence, surface_id, widget_id, canonical_id, event_kind, payload FROM ui_access_events"
        var params: [DbValue] = []
        if surface_id != "":
            sql = "{sql} WHERE surface_id = ?"
            params = [DbValue.Text(value: surface_id)]
        sql = "{sql} ORDER BY sequence DESC LIMIT ?"
        params = params.push(DbValue.Integer(value: limit))
        val rows = self.db.query(sql, params)?
        var events: [UiAccessEvent] = []
        for row in rows:
            events = events.push(_decode_event_row(row)?)
        return Ok(events)

    fn list_surfaces() -> Result<[UiAccessSurface], DbError>:
        val rows = self.db.query(
            "SELECT surface_id, title, active, window_id, app_id, root_canonical_id FROM ui_access_surfaces ORDER BY surface_id",
            []
        )?
        var surfaces: [UiAccessSurface] = []
        for row in rows:
            surfaces = surfaces.push(_decode_surface_row(row)?)
        Ok(surfaces)

    fn query_nodes(surface_id: text, kind: text, text_query: text, limit: i64) -> Result<[UiAccessNode], DbError>:
        var sql = "SELECT canonical_id, surface_id, widget_id, kind, visible, focused, enabled, selected, text_value, child_ids_text, action_names_text FROM ui_access_nodes WHERE 1 = 1"
        var params: [DbValue] = []
        if surface_id != "":
            sql = "{sql} AND surface_id = ?"
            params = params.push(DbValue.Text(value: surface_id))
        if kind != "":
            sql = "{sql} AND kind = ?"
            params = params.push(DbValue.Text(value: kind))
        if text_query != "":
            sql = "{sql} AND (text_value LIKE ? OR widget_id LIKE ? OR canonical_id LIKE ?)"
            val pattern = "%{text_query}%"
            params = params.push(DbValue.Text(value: pattern))
            params = params.push(DbValue.Text(value: pattern))
            params = params.push(DbValue.Text(value: pattern))
        sql = "{sql} ORDER BY surface_id, canonical_id LIMIT ?"
        params = params.push(DbValue.Integer(value: limit))
        val rows = self.db.query(sql, params)?
        var nodes: [UiAccessNode] = []
        for row in rows:
            nodes = nodes.push(_decode_node_row(row)?)
        Ok(nodes)

    me _insert_surface(surface: UiAccessSurface) -> Result<i64, DbError>:
        val sql = "INSERT INTO ui_access_surfaces (surface_id, title, active, window_id, app_id, root_canonical_id) VALUES (?, ?, ?, ?, ?, ?)"
        val params: [DbValue] = [
            DbValue.Text(value: surface.surface_id),
            DbValue.Text(value: surface.title),
            DbValue.Integer(value: _bool_to_i64(surface.active)),
            DbValue.Text(value: surface.window_id),
            DbValue.Text(value: surface.app_id),
            DbValue.Text(value: surface.root_canonical_id)
        ]
        self.db.exec(sql, params)?
        Ok(1)

    me _insert_node(node: UiAccessNode) -> Result<i64, DbError>:
        val sql = "INSERT INTO ui_access_nodes (canonical_id, surface_id, widget_id, kind, visible, focused, enabled, selected, text_value, child_ids_text, action_names_text) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)"
        val params: [DbValue] = [
            DbValue.Text(value: node.canonical_id),
            DbValue.Text(value: node.surface_id),
            DbValue.Text(value: node.widget_id),
            DbValue.Text(value: node.kind),
            DbValue.Integer(value: _bool_to_i64(node.visible)),
            DbValue.Integer(value: _bool_to_i64(node.focused)),
            DbValue.Integer(value: _bool_to_i64(node.enabled)),
            DbValue.Integer(value: _bool_to_i64(node.selected)),
            DbValue.Text(value: node.text),
            DbValue.Text(value: _join_with_pipe(node.child_ids)),
            DbValue.Text(value: _join_with_pipe(node.action_names))
        ]
        self.db.exec(sql, params)?
        Ok(1)

fn _decode_event_row(row: DbRow) -> Result<UiAccessEvent, DbError>:
    val sequence = row.get_int("sequence")
    val surface_id = row.get_text("surface_id")
    val widget_id = row.get_text("widget_id")
    val canonical_id = row.get_text("canonical_id")
    val event_kind = row.get_text("event_kind")
    val payload = row.get_text("payload")
    if sequence == nil or surface_id == nil or widget_id == nil or canonical_id == nil or event_kind == nil or payload == nil:
        return Err(DbError.TypeMismatch(column: "ui_access_events", expected: "complete event row", actual: "missing column"))
    Ok(UiAccessEvent(
        surface_id: surface_id,
        widget_id: widget_id,
        canonical_id: canonical_id,
        event_kind: event_kind,
        payload: payload,
        sequence: sequence
    ))

fn _decode_surface_row(row: DbRow) -> Result<UiAccessSurface, DbError>:
    val surface_id = row.get_text("surface_id")
    val title = row.get_text("title")
    val active = row.get_int("active")
    val window_id = row.get_text("window_id")
    val app_id = row.get_text("app_id")
    val root_canonical_id = row.get_text("root_canonical_id")
    if surface_id == nil or title == nil or active == nil or window_id == nil or app_id == nil or root_canonical_id == nil:
        return Err(DbError.TypeMismatch(column: "ui_access_surfaces", expected: "complete surface row", actual: "missing column"))
    Ok(UiAccessSurface(
        surface_id: surface_id,
        title: title,
        active: active != 0,
        window_id: window_id,
        app_id: app_id,
        root_canonical_id: root_canonical_id
    ))

fn _decode_node_row(row: DbRow) -> Result<UiAccessNode, DbError>:
    val canonical_id = row.get_text("canonical_id")
    val surface_id = row.get_text("surface_id")
    val widget_id = row.get_text("widget_id")
    val kind = row.get_text("kind")
    val visible = row.get_int("visible")
    val focused = row.get_int("focused")
    val enabled = row.get_int("enabled")
    val selected = row.get_int("selected")
    val text_value = row.get_text("text_value")
    val child_ids_text = row.get_text("child_ids_text")
    val action_names_text = row.get_text("action_names_text")
    if canonical_id == nil or surface_id == nil or widget_id == nil or kind == nil or visible == nil or focused == nil or enabled == nil or selected == nil or text_value == nil or child_ids_text == nil or action_names_text == nil:
        return Err(DbError.TypeMismatch(column: "ui_access_nodes", expected: "complete node row", actual: "missing column"))
    Ok(UiAccessNode(
        canonical_id: canonical_id,
        surface_id: surface_id,
        widget_id: widget_id,
        kind: kind,
        visible: visible != 0,
        focused: focused != 0,
        enabled: enabled != 0,
        selected: selected != 0,
        text: text_value,
        props: [],
        child_ids: _split_pipe(child_ids_text),
        action_names: _split_pipe(action_names_text)
    ))

fn _bool_to_i64(value: bool) -> i64:
    if value:
        return 1
    return 0

fn _join_with_pipe(items: [text]) -> text:
    var out = ""
    var first = true
    for item in items:
        if not first:
            out = "{out}|"
        out = "{out}{item}"
        first = false
    return out

fn _split_pipe(value: text) -> [text]:
    if value == "":
        return []
    return value.split("|")

fn ui_access_store_runtime_path(source_key: text, backend: text) -> text:
    return ui_access_store_runtime_path_with_override("", source_key, backend)

fn ui_access_store_runtime_path_with_override(configured_path: text, source_key: text, backend: text) -> text:
    val override = _first_nonempty_configured_path(configured_path, env_get("SIMPLE_UI_ACCESS_DB_PATH"))
    if _ui_access_store_disabled(override):
        return ""
    if override != "":
        return override
    val cache_root = get_cache_dir()
    val simple_root = "{cache_root}/simple/ui_access"
    val safe_source = _sanitize_component(path_basename(source_key))
    val safe_backend = _sanitize_component(backend)
    val source_hash = text_hash_native(source_key)
    return "{simple_root}/{safe_source}_{safe_backend}_{source_hash}.sqlite"

fn ui_access_store_runtime_open(source_key: text, backend: text) -> UiAccessStore?:
    return ui_access_store_runtime_open_with_override("", source_key, backend)

fn ui_access_store_runtime_open_with_override(configured_path: text, source_key: text, backend: text) -> UiAccessStore?:
    val override = _first_nonempty_configured_path(configured_path, env_get("SIMPLE_UI_ACCESS_DB_PATH"))
    if _ui_access_store_disabled(override):
        return nil
    val path = ui_access_store_runtime_path_with_override(configured_path, source_key, backend)
    if path == "":
        return nil
    val dir = _parent_dir(path)
    if dir != "" and not dir_create_all(dir):
        return nil
    match UiAccessStore.open(path):
        Ok(store):
            return store
        Err(_):
            return nil

fn _ui_access_store_disabled(value: text) -> bool:
    if value == nil or value == "":
        return false
    val lowered = value.lower()
    return lowered == "0" or lowered == "false" or lowered == "off" or lowered == "disabled"

fn _first_nonempty_configured_path(configured_path: text, env_override: text) -> text:
    if configured_path != nil and configured_path != "":
        return configured_path
    if env_override == nil:
        return ""
    return env_override

fn _sanitize_component(value: text) -> text:
    if value == "":
        return "ui"
    var out = ""
    var idx = 0
    while idx < value.len():
        val ch = value[idx]
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
            out = "{out}{ch}"
        elif ch == "_" or ch == "-" or ch == ".":
            out = "{out}{ch}"
        else:
            out = "{out}_"
        idx = idx + 1
    if out == "":
        return "ui"
    return out

fn _parent_dir(path: text) -> text:
    val normalized = path.replace("\\", "/")
    val slash = normalized.rfind("/")
    if not slash.?:
        return ""
    return normalized.slice(0, slash.unwrap())
