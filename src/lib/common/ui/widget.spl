# UI Core Widget Types
#
# Platform-independent type definitions for the UI system.
# All core enums and classes: UIMode, UIEvent,
# WidgetNode, UITree, WidgetRect, UIState.

# =========================================================================
# Enums
# =========================================================================

enum UIMode:
    Normal
    Command
    Insert
    Menu

enum UIEvent:
    KeyPress(key: text)
    Resize(width: i32, height: i32)
    FileChanged
    Quit
    Action(name: text)
    FocusNext
    FocusPrev
    CommandMode
    NormalMode
    InsertMode

# =========================================================================
# Widget Node
# =========================================================================

struct WidgetNode:
    id: text
    kind: text
    layout: text
    visible: bool
    focused: bool

struct WidgetProp:
    node_id: text
    key: text
    value: text

struct WidgetEdge:
    parent_id: text
    child_id: text

var _widget_registry: [WidgetNode] = []
var _widget_children: [WidgetEdge] = []

fn register_widget(node: WidgetNode) -> WidgetNode:
    var updated: [WidgetNode] = []
    var replaced = false
    for existing in _widget_registry:
        if existing.id == node.id:
            updated = updated.push(node)
            replaced = true
        else:
            updated = updated.push(existing)
    if not replaced:
        updated = updated.push(node)
    _widget_registry = updated
    return node

fn get_widget(id: text) -> WidgetNode?:
    for node in _widget_registry:
        if node.id == id:
            return node
    return nil

fn get_widget_child_ids(id: text) -> [text]:
    var ids: [text] = []
    for edge in _widget_children:
        if edge.parent_id == id:
            ids = ids.push(edge.child_id)
    return ids

fn register_widget_child(parent_id: text, child_id: text) -> WidgetNode:
    _widget_children = _widget_children.push(WidgetEdge(parent_id: parent_id, child_id: child_id))
    val existing = get_widget(parent_id)
    if existing != nil:
        return existing
    return WidgetNode(id: parent_id, kind: "panel", layout: "vbox", visible: true, focused: false)

impl WidgetNode:

    static fn new(id: text, kind: text) -> WidgetNode:
        return register_widget(WidgetNode(
            id: id,
            kind: kind,
            layout: "vbox",
            visible: true,
            focused: false
        ))

    fn set_prop(key: text, value: text) -> WidgetNode:
        var next_registry: [WidgetNode] = []
        for node in _widget_registry:
            next_registry = next_registry.push(node)
        _widget_registry = next_registry

        var new_props: [WidgetProp] = []
        var replaced = false
        for prop in _widget_props():
            if prop.node_id == self.id and prop.key == key:
                new_props = new_props.push(WidgetProp(node_id: self.id, key: key, value: value))
                replaced = true
            else:
                new_props = new_props.push(prop)
        if not replaced:
            new_props = new_props.push(WidgetProp(node_id: self.id, key: key, value: value))
        _set_widget_props(new_props)
        return self

    fn add_child(child: WidgetNode) -> WidgetNode:
        return register_widget_child(self.id, child.id)

    fn set_layout(layout: text) -> WidgetNode:
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            layout: layout,
            visible: self.visible,
            focused: self.focused
        ))

    fn set_visible(visible: bool) -> WidgetNode:
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            layout: self.layout,
            visible: visible,
            focused: self.focused
        ))

    fn get_prop(key: text) -> text:
        for prop in _widget_props():
            if prop.node_id == self.id and prop.key == key:
                return prop.value
        return ""

    fn has_prop(key: text) -> bool:
        for prop in _widget_props():
            if prop.node_id == self.id and prop.key == key:
                return true
        return false

    fn prop_keys() -> [text]:
        var keys: [text] = []
        for prop in _widget_props():
            if prop.node_id == self.id:
                keys = keys.push(prop.key)
        return keys

    fn children() -> [WidgetNode]:
        var result: [WidgetNode] = []
        for child_id in get_widget_child_ids(self.id):
            val child = get_widget(child_id)
            if child != nil:
                result = result.push(child)
        return result

    fn child_count() -> i32:
        return get_widget_child_ids(self.id).len()

    fn child_at(index: i32) -> WidgetNode?:
        val child_ids = get_widget_child_ids(self.id)
        if index < 0 or index >= child_ids.len():
            return nil
        return get_widget(child_ids[index])

    fn find_by_id(target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children():
            val found = child.find_by_id(target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids() -> [text]:
        var ids: [text] = [self.id]
        for child in self.children():
            val child_ids = child.collect_ids()
            for cid in child_ids:
                ids = ids.push(cid)
        return ids

    fn widget_summary() -> text:
        return "{self.id} ({self.kind})"

# =========================================================================
# UI Tree
# =========================================================================

struct UITree:
    root: WidgetNode
    title: text
    theme: text
    keybindings: Dict<text, Dict<text, text>>

    static fn new(root: WidgetNode) -> UITree:
        return UITree(
            root: root,
            title: "Simple UI",
            theme: "dark",
            keybindings: {}
        )

    fn find_widget(id: text) -> WidgetNode?:
        return self.root.find_by_id(id)

    fn all_widget_ids() -> [text]:
        return self.root.collect_ids()

# =========================================================================
# Widget Rect (layout result)
# =========================================================================

struct WidgetRect:
    id: text
    x: i32
    y: i32
    w: i32
    h: i32

    static fn new(id: text, x: i32, y: i32, w: i32, h: i32) -> WidgetRect:
        return WidgetRect(id: id, x: x, y: y, w: w, h: h)

# =========================================================================
# UI State
# =========================================================================

struct UIState:
    tree: UITree
    mode: UIMode
    focused_id: text
    command_buffer: text

    static fn new(tree: UITree) -> UIState:
        val ids = tree.all_widget_ids()
        val initial_focus = if ids.len() > 0:
            ids[0]
        else:
            ""
        return UIState(
            tree: tree,
            mode: UIMode.Normal,
            focused_id: initial_focus,
            command_buffer: ""
        )

    fn mode_name() -> text:
        return match self.mode:
            UIMode.Normal => "NORMAL"
            UIMode.Command => "COMMAND"
            UIMode.Insert => "INSERT"
            UIMode.Menu => "MENU"

# =========================================================================
# Helper: parse WidgetKind from text
# =========================================================================

fn parse_widget_kind(name: text) -> text:
    val kind = name.to_lower()
    match kind:
        "panel" => "panel"
        "text" => "text"
        "list" => "list"
        "table" => "table"
        "progress" => "progress"
        "menubar" => "menubar"
        "statusbar" => "statusbar"
        "input" => "input"
        "tabs" => "tabs"
        "button" => "button"
        "checkbox" => "checkbox"
        "dropdown" => "dropdown"
        "textfield" => "textfield"
        "image" => "image"
        "divider" => "divider"
        "dialog" => "dialog"
        "tooltip" => "tooltip"
        _ => "panel"

fn parse_layout_kind(name: text) -> text:
    val layout = name.to_lower()
    match layout:
        "vbox" => "vbox"
        "hbox" => "hbox"
        "grid" => "grid"
        "fixed" => "fixed"
        _ => "vbox"

var __widget_props_store: [WidgetProp] = []

fn _widget_props() -> [WidgetProp]:
    return __widget_props_store

fn _set_widget_props(props: [WidgetProp]):
    __widget_props_store = props
