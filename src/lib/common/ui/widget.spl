#![allow(unnamed_duplicate_typed_args)]
# UI Core Widget Types
#
# Platform-independent type definitions for the UI system.
# All core enums and handle-based carriers: UIMode, UIEvent,
# WidgetNode, UITree, WidgetRect, UIState.

use common.ui.widget_store.{WidgetStore}
use common.ui.design_tokens.{Spacing, Radius, SurfaceRole}
use common.ui.theme_registry.{ThemeId, theme_registry}
use common.ui.builder.{with_padding_token, with_radius_token, with_surface_role, with_on_typed_action,
    with_responsive_layout, with_responsive_columns,
    with_show_when_at_most, with_show_when_at_least, with_show_when_orientation}
use common.ui.profile.{SizeClass, Orientation}
use common.ui.action.{Action}

enum UIMode:
    Normal
    Command
    Insert
    Menu

enum UIEvent:
    KeyPress(key: text)
    Resize(width: i32, height: i32)
    FileChanged
    Quit
    Action(name: text)
    FocusNext
    FocusPrev
    CommandMode
    NormalMode
    InsertMode
    TouchPress(x: i32, y: i32)
    TouchMove(x: i32, y: i32)
    TouchRelease(x: i32, y: i32)
    # Mouse / scroll / focus / input from a Canvas2D-rendered surface.
    # `kind` for MouseEvent: "down" | "up" | "move".
    # `button` for MouseEvent: "left" | "right" | "middle" | "" (move events).
    MouseEvent(x: f64, y: f64, button: text, kind: text)
    ScrollEvent(x: f64, y: f64, dx: f64, dy: f64)
    # `kind` for FocusEvent: "focus" | "blur".
    FocusEvent(target_id: text, kind: text)
    InputChange(target_id: text, value: text)
    # Result of a previously requested HTTP fetch, fulfilled by the host
    # process (e.g. Electron main). `status` is HTTP status (0 on error);
    # `headers` is a newline-delimited "Name: value" block; `error` is an
    # error message (empty on success). `request_id` lets callers correlate
    # to their original request_fetch.
    FetchResult(request_id: text, url: text, status: i32, headers: text, body: text, error: text)

enum WidgetKind:
    Panel
    Text
    List
    Table
    Progress
    Menubar
    Statusbar
    Input
    Tabs
    Button
    Checkbox
    Dropdown
    Textfield
    Image
    Divider
    Dialog
    Tooltip
    Tree
    Treenode
    Scroll
    Textarea
    Heading
    Label
    NavigationBar
    TabBar
    Card
    Switch
    SegmentedControl
    SearchBar
    GlassTitleBar
    Sidebar
    CommandBar
    WorkspaceTabs
    CommandPalette
    Toast
    SheetModal
    ContextMenu
    Inspector
    UtilityRail
    StatusChip
    SelectionPill
    EmptyState

impl WidgetKind:
    fn to_wire(self) -> text:
        match self:
            case WidgetKind.Panel: return "panel"
            case WidgetKind.Text: return "text"
            case WidgetKind.List: return "list"
            case WidgetKind.Table: return "table"
            case WidgetKind.Progress: return "progress"
            case WidgetKind.Menubar: return "menubar"
            case WidgetKind.Statusbar: return "statusbar"
            case WidgetKind.Input: return "input"
            case WidgetKind.Tabs: return "tabs"
            case WidgetKind.Button: return "button"
            case WidgetKind.Checkbox: return "checkbox"
            case WidgetKind.Dropdown: return "dropdown"
            case WidgetKind.Textfield: return "textfield"
            case WidgetKind.Image: return "image"
            case WidgetKind.Divider: return "divider"
            case WidgetKind.Dialog: return "dialog"
            case WidgetKind.Tooltip: return "tooltip"
            case WidgetKind.Tree: return "tree"
            case WidgetKind.Treenode: return "treenode"
            case WidgetKind.Scroll: return "scroll"
            case WidgetKind.Textarea: return "textarea"
            case WidgetKind.Heading: return "heading"
            case WidgetKind.Label: return "label"
            case WidgetKind.NavigationBar: return "navigation_bar"
            case WidgetKind.TabBar: return "tab_bar"
            case WidgetKind.Card: return "card"
            case WidgetKind.Switch: return "switch"
            case WidgetKind.SegmentedControl: return "segmented_control"
            case WidgetKind.SearchBar: return "search_bar"
            case WidgetKind.GlassTitleBar: return "glass_title_bar"
            case WidgetKind.Sidebar: return "sidebar"
            case WidgetKind.CommandBar: return "command_bar"
            case WidgetKind.WorkspaceTabs: return "workspace_tabs"
            case WidgetKind.CommandPalette: return "command_palette"
            case WidgetKind.Toast: return "toast"
            case WidgetKind.SheetModal: return "sheet_modal"
            case WidgetKind.ContextMenu: return "context_menu"
            case WidgetKind.Inspector: return "inspector"
            case WidgetKind.UtilityRail: return "utility_rail"
            case WidgetKind.StatusChip: return "status_chip"
            case WidgetKind.SelectionPill: return "selection_pill"
            case WidgetKind.EmptyState: return "empty_state"

    static fn from_wire(s: text) -> WidgetKind:
        val k = s.lower()
        match k:
            "panel" => WidgetKind.Panel
            "text" => WidgetKind.Text
            "list" => WidgetKind.List
            "table" => WidgetKind.Table
            "progress" => WidgetKind.Progress
            "menubar" => WidgetKind.Menubar
            "statusbar" => WidgetKind.Statusbar
            "input" => WidgetKind.Input
            "tabs" => WidgetKind.Tabs
            "button" => WidgetKind.Button
            "checkbox" => WidgetKind.Checkbox
            "dropdown" => WidgetKind.Dropdown
            "textfield" => WidgetKind.Textfield
            "image" => WidgetKind.Image
            "divider" => WidgetKind.Divider
            "dialog" => WidgetKind.Dialog
            "tooltip" => WidgetKind.Tooltip
            "tree" => WidgetKind.Tree
            "treenode" => WidgetKind.Treenode
            "scroll" => WidgetKind.Scroll
            "textarea" => WidgetKind.Textarea
            "heading" => WidgetKind.Heading
            "label" => WidgetKind.Label
            "navigation_bar" => WidgetKind.NavigationBar
            "tab_bar" => WidgetKind.TabBar
            "card" => WidgetKind.Card
            "switch" => WidgetKind.Switch
            "segmented_control" => WidgetKind.SegmentedControl
            "search_bar" => WidgetKind.SearchBar
            "glass_title_bar" => WidgetKind.GlassTitleBar
            "sidebar" => WidgetKind.Sidebar
            "command_bar" => WidgetKind.CommandBar
            "workspace_tabs" => WidgetKind.WorkspaceTabs
            "command_palette" => WidgetKind.CommandPalette
            "toast" => WidgetKind.Toast
            "sheet_modal" => WidgetKind.SheetModal
            "context_menu" => WidgetKind.ContextMenu
            "inspector" => WidgetKind.Inspector
            "utility_rail" => WidgetKind.UtilityRail
            "status_chip" => WidgetKind.StatusChip
            "selection_pill" => WidgetKind.SelectionPill
            "empty_state" => WidgetKind.EmptyState
            _ => WidgetKind.Panel

enum LayoutKind:
    Vbox
    Hbox
    Grid
    Fixed

impl LayoutKind:
    fn to_wire(self) -> text:
        match self:
            case LayoutKind.Vbox: return "vbox"
            case LayoutKind.Hbox: return "hbox"
            case LayoutKind.Grid: return "grid"
            case LayoutKind.Fixed: return "fixed"

    static fn from_wire(s: text) -> LayoutKind:
        val k = s.lower()
        match k:
            "vbox" => LayoutKind.Vbox
            "hbox" => LayoutKind.Hbox
            "grid" => LayoutKind.Grid
            "fixed" => LayoutKind.Fixed
            _ => LayoutKind.Vbox

struct WidgetNode:
    id: text

struct WidgetRecord:
    id: text
    kind: WidgetKind
    layout: LayoutKind
    visible: bool
    focused: bool
    icon_id: text

struct WidgetProp:
    node_id: text
    key: text
    value: text

struct UITree:
    root_id: text
    tokens: Dict<text, text>

var _widget_registry: [WidgetRecord] = []
var _widget_props_store: [WidgetProp] = []

fn parse_widget_kind(name: text) -> WidgetKind:
    return WidgetKind.from_wire(name)

fn parse_layout_kind(name: text) -> LayoutKind:
    return LayoutKind.from_wire(name)

fn parse_semantic_prop(name: text) -> text:
    """Map kebab-case semantic CSS names to internal snake_case keys."""
    val key = name.lower()
    match key:
        "app-background" => return "app_background"
        "app-surface" => return "app_surface"
        "widget-radius" => return "widget_radius"
        "widget-shadow" => return "widget_shadow"
        "text-primary" => return "text_primary"
        "text-secondary" => return "text_secondary"
        "accent-color" => return "accent_color"
        "icon-id" => return "icon_id"
        _ => return key

fn default_widget_record(id: text, kind: text) -> WidgetRecord:
    return WidgetRecord(
        id: id,
        kind: parse_widget_kind(kind),
        layout: LayoutKind.Vbox,
        visible: true,
        focused: false,
        icon_id: ""
    )

fn upsert_widget_record(record: WidgetRecord):
    var updated: [WidgetRecord] = []
    var replaced = false
    for existing in _widget_registry:
        if existing.id == record.id:
            updated = updated.push(record)
            replaced = true
        else:
            updated = updated.push(existing)
    if not replaced:
        updated = updated.push(record)
    _widget_registry = updated

fn get_widget_record(id: text) -> WidgetRecord?:
    for record in _widget_registry:
        if record.id == id:
            return record
    return nil

fn require_widget_record(id: text) -> WidgetRecord:
    val found = get_widget_record(id)
    if found != nil:
        return found
    val fallback = default_widget_record(id, "panel")
    upsert_widget_record(fallback)
    return fallback

fn get_widget(id: text) -> WidgetNode?:
    val record = get_widget_record(id)
    if record == nil:
        return nil
    return WidgetNode(id: id)

fn get_widget_child_ids(id: text) -> [text]:
    return decode_child_ids(get_internal_prop(id, "ui_children"))

fn register_widget_child(parent_id: text, child_id: text):
    val existing = decode_child_ids(get_internal_prop(parent_id, "ui_children"))
    for current_id in existing:
        if current_id == child_id:
            return
    val updated = existing + [child_id]
    set_internal_prop(parent_id, "ui_children", encode_child_ids(updated))

fn widget_props() -> [WidgetProp]:
    return _widget_props_store

fn set_widget_props(props: [WidgetProp]):
    _widget_props_store = props

fn get_internal_prop(node_id: text, key: text) -> text:
    for prop in _widget_props_store:
        if prop.node_id == node_id and prop.key == key:
            return prop.value
    return ""

fn set_internal_prop(node_id: text, key: text, value: text):
    var props: [WidgetProp] = []
    var replaced = false
    for prop in _widget_props_store:
        if prop.node_id == node_id and prop.key == key:
            props = props.push(WidgetProp(node_id: node_id, key: key, value: value))
            replaced = true
        else:
            props = props.push(prop)
    if not replaced:
        props = props.push(WidgetProp(node_id: node_id, key: key, value: value))
    _widget_props_store = props

fn encode_child_ids(ids: [text]) -> text:
    return ids.join(",")

fn decode_child_ids(blob: text) -> [text]:
    if blob == "":
        return []
    var ids: [text] = []
    var current = ""
    for ch in blob:
        if ch == ",":
            if current != "":
                ids = ids.push(current)
                current = ""
        else:
            current = "{current}{ch}"
    if current != "":
        ids = ids.push(current)
    return ids

impl WidgetNode:

    static fn new(id: text, kind: text) -> WidgetNode:
        val handle = WidgetNode(id: id)
        upsert_widget_record(default_widget_record(id, kind))
        return handle

    fn kind_name() -> text:
        return require_widget_record(self.id).kind.to_wire()

    fn layout_name() -> text:
        return require_widget_record(self.id).layout.to_wire()

    fn is_visible() -> bool:
        return require_widget_record(self.id).visible

    fn is_focused() -> bool:
        return require_widget_record(self.id).focused

    fn kind() -> text: self.kind_name()
    fn layout() -> text: self.layout_name()
    fn visible() -> bool: self.is_visible()
    fn focused() -> bool: self.is_focused()

    fn set_prop(key: text, value: text) -> WidgetNode:
        set_internal_prop(self.id, parse_semantic_prop(key), value)
        return self

    fn add_child(child: WidgetNode) -> WidgetNode:
        register_widget_child(self.id, child.id)
        return self

    fn set_layout(layout: text) -> WidgetNode:
        val record = require_widget_record(self.id)
        upsert_widget_record(WidgetRecord(
            id: self.id,
            kind: record.kind,
            layout: parse_layout_kind(layout),
            visible: record.visible,
            focused: record.focused,
            icon_id: record.icon_id
        ))
        return self

    fn set_visible(visible: bool) -> WidgetNode:
        val record = require_widget_record(self.id)
        upsert_widget_record(WidgetRecord(
            id: self.id,
            kind: record.kind,
            layout: record.layout,
            visible: visible,
            focused: record.focused,
            icon_id: record.icon_id
        ))
        return self

    fn get_prop(key: text) -> text:
        return get_internal_prop(self.id, key)

    fn has_prop(key: text) -> bool:
        for prop in _widget_props_store:
            if prop.node_id == self.id and prop.key == key:
                return true
        return false

    fn prop_keys() -> [text]:
        var keys: [text] = []
        for prop in _widget_props_store:
            if prop.node_id == self.id:
                keys = keys.push(prop.key)
        return keys

    fn children() -> [WidgetNode]:
        var result: [WidgetNode] = []
        val blob = get_internal_prop(self.id, "ui_children")
        if blob == "":
            return result
        var current = ""
        for ch in blob:
            if ch == ",":
                if current != "":
                    val child = get_widget(current)
                    if child != nil:
                        result = result.push(child)
                    current = ""
            else:
                current = "{current}{ch}"
        if current != "":
            val child = get_widget(current)
            if child != nil:
                result = result.push(child)
        return result

    fn child_count() -> i32:
        val ids = decode_child_ids(get_internal_prop(self.id, "ui_children"))
        var count: i32 = 0
        for id in ids:
            count = count + 1
        return count

    fn child_at(index: i32) -> WidgetNode?:
        if index < 0:
            return nil
        val ids = decode_child_ids(get_internal_prop(self.id, "ui_children"))
        var i: i32 = 0
        for id in ids:
            if i == index:
                return get_widget(id)
            i = i + 1
        return nil

    fn find_by_id(target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children():
            val found = child.find_by_id(target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids() -> [text]:
        var ids: [text] = [self.id]
        for child in self.children():
            val child_ids = child.collect_ids()
            for cid in child_ids:
                ids = ids.push(cid)
        return ids

    fn widget_summary() -> text:
        return "{self.id} ({self.kind_name()})"

    # -- Store-param overloads -----------------------------------------------

    fn get_prop_from(store: WidgetStore, key: text) -> text:
        return store.get_prop(self.id, key)

    fn set_prop_in(store: WidgetStore, key: text, value: text) -> WidgetNode:
        store.set_prop(self.id, key, value)
        return self

    fn has_prop_in(store: WidgetStore, key: text) -> bool:
        return store.get_prop(self.id, key) != ""

    fn prop_keys_from(store: WidgetStore) -> [text]:
        var keys: [text] = []
        for prop in store.all_props():
            if prop.node_id == self.id:
                keys = keys.push(prop.key)
        return keys

    fn children_from(store: WidgetStore) -> [WidgetNode]:
        var result: [WidgetNode] = []
        val ids = store.get_child_ids(self.id)
        for id in ids:
            val node = store.get_node(id)
            if node != nil:
                result = result.push(node)
        return result

    fn add_child_in(store: WidgetStore, child: WidgetNode) -> WidgetNode:
        store.register_child(self.id, child.id)
        return self

    fn kind_name_from(store: WidgetStore) -> text:
        return store.require_record(self.id).kind.to_wire()

    fn layout_name_from(store: WidgetStore) -> text:
        return store.require_record(self.id).layout.to_wire()

    fn is_visible_from(store: WidgetStore) -> bool:
        return store.require_record(self.id).visible

    fn find_by_id_in(store: WidgetStore, target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children_from(store):
            val found = child.find_by_id_in(store, target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids_from(store: WidgetStore) -> [text]:
        var ids: [text] = [self.id]
        for child in self.children_from(store):
            val child_ids = child.collect_ids_from(store)
            for cid in child_ids:
                ids = ids.push(cid)
        return ids

    # =========================================================================
    # Fluent modifier methods (mirror builder.spl with_* helpers)
    # NOTE: chain syntax (node.width(120).height(40)) requires Phase 9
    # chain-fix RFC; until then, use intermediate var:
    #   var btn = Button("save", "Save")
    #   btn = btn.width(120)
    #   btn = btn.height(40)
    # Mapping: tooltip -> with_tooltip_text; child/add_children -> add_child
    # Skipped: visible (conflicts with 0-arg getter), children (conflicts with
    #   0-arg getter), profile (with_profile returns ProfileSet, not WidgetNode)
    # Legacy: with_* free functions in builder.spl remain valid.
    # =========================================================================

    fn flex(n: i32) -> WidgetNode:
        """Set flex sizing on a widget. Legacy: with_flex."""
        return self.set_prop("flex", "{n}")

    fn width(w: i32) -> WidgetNode:
        """Set fixed width on a widget. Legacy: with_width."""
        return self.set_prop("width", "{w}")

    fn height(h: i32) -> WidgetNode:
        """Set fixed height on a widget. Legacy: with_height."""
        return self.set_prop("height", "{h}")

    fn background(color: text) -> WidgetNode:
        """Set semantic background color. Legacy: with_background."""
        return self.set_prop("app-background", color)

    fn surface(color: text) -> WidgetNode:
        """Set semantic surface color. Legacy: with_surface."""
        return self.set_prop("app-surface", color)

    fn radius(r: text) -> WidgetNode:
        """Set semantic border radius. Legacy: with_radius."""
        return self.set_prop("widget-radius", r)

    fn icon(icon_id: text) -> WidgetNode:
        """Set a graphical icon for the widget. Legacy: with_icon."""
        return self.set_prop("icon-id", icon_id)

    fn shadow(s: text) -> WidgetNode:
        """Set semantic shadow. Legacy: with_shadow."""
        return self.set_prop("widget-shadow", s)

    fn accent(color: text) -> WidgetNode:
        """Set semantic accent color. Legacy: with_accent."""
        return self.set_prop("accent-color", color)

    fn set_visible_flag(v: bool) -> WidgetNode:
        """Set visibility on a widget. Legacy: with_visible.
        Named set_visible_flag to avoid conflict with the 0-arg visible() getter."""
        return self.set_visible(v)

    fn selected(index: i32) -> WidgetNode:
        """Set the selected item index on a list widget. Legacy: with_selected."""
        return self.set_prop("selected_index", "{index}")

    fn disabled() -> WidgetNode:
        """Mark a widget as disabled (non-interactive). Legacy: with_disabled."""
        return self.set_prop("disabled", "true")

    fn readonly() -> WidgetNode:
        """Mark a widget as read-only. Legacy: with_readonly."""
        return self.set_prop("readonly", "true")

    fn error(message: text) -> WidgetNode:
        """Set error state with a message on a widget. Legacy: with_error."""
        var n = self.set_prop("error", "true")
        n = n.set_prop("error_message", message)
        return n

    fn validator(pattern: text) -> WidgetNode:
        """Set a regex validation pattern on a widget. Legacy: with_validator."""
        return self.set_prop("validator", pattern)

    fn required() -> WidgetNode:
        """Mark a widget as required. Legacy: with_required."""
        return self.set_prop("required", "true")

    fn max_length(n: i32) -> WidgetNode:
        """Set a maximum input length on a widget. Legacy: with_max_length."""
        return self.set_prop("max_length", "{n}")

    fn tooltip(tip: text) -> WidgetNode:
        """Set an inline tooltip on any widget. Legacy: with_tooltip_text."""
        return self.set_prop("tooltip", tip)

    fn on_mount(handler_id: text) -> WidgetNode:
        """Set the on_mount lifecycle handler id. Legacy: with_on_mount."""
        return self.set_prop("on_mount", handler_id)

    fn on_unmount(handler_id: text) -> WidgetNode:
        """Set the on_unmount lifecycle handler id. Legacy: with_on_unmount."""
        return self.set_prop("on_unmount", handler_id)

    fn on_update(handler_id: text) -> WidgetNode:
        """Set the on_update lifecycle handler id. Legacy: with_on_update."""
        return self.set_prop("on_update", handler_id)

    fn on_action(handler_id: text) -> WidgetNode:
        """Set the on_action lifecycle handler id. Legacy: with_on_action."""
        return self.set_prop("on_action", handler_id)

    fn on_typed_action(action: Action) -> WidgetNode:
        """Set the on_action handler from a typed Action (Phase 5 UI Typed Core RFC)."""
        return with_on_typed_action(self, action)

    fn on_focus(handler_id: text) -> WidgetNode:
        """Set the on_focus lifecycle handler id. Legacy: with_on_focus."""
        return self.set_prop("on_focus", handler_id)

    fn on_blur(handler_id: text) -> WidgetNode:
        """Set the on_blur lifecycle handler id. Legacy: with_on_blur."""
        return self.set_prop("on_blur", handler_id)

    # =========================================================================
    # Responsive modifier methods (Phase 6 UI Typed Core RFC)
    # Delegates to with_responsive_* / with_show_when_* free fns in builder.spl.
    # =========================================================================

    fn responsive_layout(self, compact: text, regular: text, expanded: text) -> WidgetNode:
        """Store per-size-class layout names. Legacy: with_responsive_layout."""
        return with_responsive_layout(self, compact, regular, expanded)

    fn responsive_columns(self, compact: i32, regular: i32, expanded: i32) -> WidgetNode:
        """Store per-size-class column counts (Grid). Legacy: with_responsive_columns."""
        return with_responsive_columns(self, compact, regular, expanded)

    fn show_when_at_most(self, threshold: SizeClass) -> WidgetNode:
        """Hide when current size class > threshold. Legacy: with_show_when_at_most."""
        return with_show_when_at_most(self, threshold)

    fn show_when_at_least(self, threshold: SizeClass) -> WidgetNode:
        """Hide when current size class < threshold. Legacy: with_show_when_at_least."""
        return with_show_when_at_least(self, threshold)

    fn show_when_orientation(self, o: Orientation) -> WidgetNode:
        """Hide unless current orientation matches. Legacy: with_show_when_orientation."""
        return with_show_when_orientation(self, o)

    fn child(c: WidgetNode) -> WidgetNode:
        """Add a single child widget. Delegates to add_child."""
        return self.add_child(c)

    fn add_children(cs: [WidgetNode]) -> WidgetNode:
        """Add multiple children. Named add_children to avoid conflict with
        the 0-arg children() getter."""
        var n = self
        for c in cs:
            n = n.add_child(c)
        return n

    # =========================================================================
    # Token-accepting methods (Phase 4 UI Typed Core RFC)
    # Mirrors with_padding_token / with_radius_token / with_surface_role in builder.spl.
    # =========================================================================

    fn padding(self, theme: ThemeId, s: Spacing) -> WidgetNode:
        """Set padding from a typed Spacing token. Delegates to with_padding_token."""
        return with_padding_token(self, theme, s)

    fn radius_token(self, theme: ThemeId, r: Radius) -> WidgetNode:
        """Set border-radius from a typed Radius token. Delegates to with_radius_token."""
        return with_radius_token(self, theme, r)

    fn surface_role(self, theme: ThemeId, role: SurfaceRole) -> WidgetNode:
        """Set surface color from a typed SurfaceRole token. Delegates to with_surface_role."""
        return with_surface_role(self, theme, role)

impl UITree:

    static fn new(root: WidgetNode) -> UITree:
        return UITree(root_id: root.id, tokens: {})

    fn root_node() -> WidgetNode:
        return WidgetNode(id: self.root_id)

    fn title_text() -> text:
        val rn = self.root_node()
        val title = rn.get_prop("ui_tree_title")
        if title != "":
            return title
        return "Simple UI"

    fn theme_name() -> text:
        val rn = self.root_node()
        val theme = rn.get_prop("ui_tree_theme")
        if theme != "":
            return theme
        return "glass_dark"

    fn resolve_token(key: text) -> text:
        match self.tokens.get(key):
            case Some(v): return v
            case _: return ""

    fn root() -> WidgetNode: self.root_node()
    fn title() -> text: self.title_text()
    fn theme() -> text: self.theme_name()

    fn bindings() -> Dict<text, Dict<text, text>>:
        return {}

    fn with_title(title: text) -> UITree:
        val rn = self.root_node()
        val updated = rn.set_prop("ui_tree_title", title)
        return UITree(root_id: updated.id, tokens: self.tokens)

    fn with_theme(theme: text) -> UITree:
        val rn = self.root_node()
        val updated = rn.set_prop("ui_tree_theme", theme)
        return UITree(root_id: updated.id, tokens: self.tokens)

    fn with_token(key: text, value: text) -> UITree:
        var updated_tokens = self.tokens
        updated_tokens[key] = value
        return UITree(root_id: self.root_id, tokens: updated_tokens)

    fn with_keybindings(keybindings: Dict<text, Dict<text, text>>) -> UITree:
        return self

    fn find_widget(id: text) -> WidgetNode?:
        val rn = self.root_node()
        return rn.find_by_id(id)

    fn all_widget_ids() -> [text]:
        val rn = self.root_node()
        return rn.collect_ids()

struct WidgetRect:
    id: text
    x: i32
    y: i32
    w: i32
    h: i32

    static fn new(id: text, x: i32, y: i32, w: i32, h: i32) -> WidgetRect:
        return WidgetRect(id: id, x: x, y: y, w: w, h: h)

struct UIState:
    tree: UITree
    mode: UIMode
    focused_id: text
    command_buffer: text

    static fn new(tree: UITree) -> UIState:
        val ids = tree.all_widget_ids()
        var initial_focus = ""
        for id in ids:
            if initial_focus == "":
                initial_focus = id
        return UIState(
            tree: tree,
            mode: UIMode.Normal,
            focused_id: initial_focus,
            command_buffer: ""
        )

    fn mode_name() -> text:
        return match self.mode:
            UIMode.Normal => "NORMAL"
            UIMode.Command => "COMMAND"
            UIMode.Insert => "INSERT"
            UIMode.Menu => "MENU"
