# UI Core Widget Types
#
# Platform-independent type definitions for the UI system.
# All core enums and classes: UIMode, UIEvent,
# WidgetNode, UITree, WidgetRect, UIState.

# =========================================================================
# Enums
# =========================================================================

enum UIMode:
    Normal
    Command
    Insert
    Menu

enum UIEvent:
    KeyPress(key: text)
    Resize(width: i32, height: i32)
    FileChanged
    Quit
    Action(name: text)
    FocusNext
    FocusPrev
    CommandMode
    NormalMode
    InsertMode

# =========================================================================
# Widget Node
# =========================================================================

class WidgetNode:
    id: text
    kind: text
    props: [WidgetProp]
    child_ids: [text]
    layout: text
    visible: bool
    focused: bool

struct WidgetProp:
    key: text
    value: text

var _widget_registry: Dict<text, WidgetNode> = {}

fn register_widget(node: WidgetNode) -> WidgetNode:
    _widget_registry = _widget_registry.set(node.id, node)
    return node

fn get_widget(id: text) -> WidgetNode?:
    if _widget_registry.contains_key(id):
        return _widget_registry[id]
    return nil

impl WidgetNode:

    static fn new(id: text, kind: text) -> WidgetNode:
        return register_widget(WidgetNode(
            id: id,
            kind: kind,
            props: [],
            child_ids: [],
            layout: "vbox",
            visible: true,
            focused: false
        ))

    fn set_prop(key: text, value: text) -> WidgetNode:
        var new_props: [WidgetProp] = []
        var replaced = false
        for prop in self.props:
            if prop.key == key:
                new_props = new_props.push(WidgetProp(key: key, value: value))
                replaced = true
            else:
                new_props = new_props.push(prop)
        if not replaced:
            new_props = new_props.push(WidgetProp(key: key, value: value))
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            props: new_props,
            child_ids: self.child_ids,
            layout: self.layout,
            visible: self.visible,
            focused: self.focused
        ))

    fn add_child(child: WidgetNode) -> WidgetNode:
        var new_child_ids = self.child_ids
        new_child_ids = new_child_ids.push(child.id)
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            props: self.props,
            child_ids: new_child_ids,
            layout: self.layout,
            visible: self.visible,
            focused: self.focused
        ))

    fn set_layout(layout: text) -> WidgetNode:
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            props: self.props,
            child_ids: self.child_ids,
            layout: layout,
            visible: self.visible,
            focused: self.focused
        ))

    fn set_visible(visible: bool) -> WidgetNode:
        return register_widget(WidgetNode(
            id: self.id,
            kind: self.kind,
            props: self.props,
            child_ids: self.child_ids,
            layout: self.layout,
            visible: visible,
            focused: self.focused
        ))

    fn get_prop(key: text) -> text:
        for prop in self.props:
            if prop.key == key:
                return prop.value
        return ""

    fn has_prop(key: text) -> bool:
        for prop in self.props:
            if prop.key == key:
                return true
        return false

    fn prop_keys() -> [text]:
        var keys: [text] = []
        for prop in self.props:
            keys = keys.push(prop.key)
        return keys

    fn children() -> [WidgetNode]:
        var result: [WidgetNode] = []
        for child_id in self.child_ids:
            val child = get_widget(child_id)
            if child != nil:
                result = result.push(child)
        return result

    fn child_count() -> i32:
        return self.child_ids.len()

    fn child_at(index: i32) -> WidgetNode?:
        if index < 0 or index >= self.child_ids.len():
            return nil
        return get_widget(self.child_ids[index])

    fn find_by_id(target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children():
            val found = child.find_by_id(target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids() -> [text]:
        var ids: [text] = [self.id]
        for child in self.children():
            val child_ids = child.collect_ids()
            for cid in child_ids:
                ids = ids.push(cid)
        return ids

    fn widget_summary() -> text:
        return "{self.id} ({self.kind})"

# =========================================================================
# UI Tree
# =========================================================================

class UITree:
    root: WidgetNode
    keybindings: Dict<text, Dict<text, text>>
    title: text
    theme: text

    static fn new(root: WidgetNode) -> UITree:
        return UITree(
            root: root,
            title: "Simple UI",
            theme: "dark",
            keybindings: {}
        )

    fn find_widget(id: text) -> WidgetNode?:
        return self.root.find_by_id(id)

    fn all_widget_ids() -> [text]:
        return self.root.collect_ids()

# =========================================================================
# Widget Rect (layout result)
# =========================================================================

class WidgetRect:
    id: text
    x: i32
    y: i32
    w: i32
    h: i32

    static fn new(id: text, x: i32, y: i32, w: i32, h: i32) -> WidgetRect:
        return WidgetRect(id: id, x: x, y: y, w: w, h: h)

# =========================================================================
# UI State
# =========================================================================

class UIState:
    tree: UITree
    mode: UIMode
    focused_id: text
    command_buffer: text

    static fn new(tree: UITree) -> UIState:
        val ids = tree.all_widget_ids()
        val initial_focus = if ids.len() > 0:
            ids[0]
        else:
            ""
        return UIState(
            tree: tree,
            mode: UIMode.Normal,
            focused_id: initial_focus,
            command_buffer: ""
        )

    fn mode_name() -> text:
        return match self.mode:
            UIMode.Normal => "NORMAL"
            UIMode.Command => "COMMAND"
            UIMode.Insert => "INSERT"
            UIMode.Menu => "MENU"

# =========================================================================
# Helper: parse WidgetKind from text
# =========================================================================

fn parse_widget_kind(name: text) -> text:
    val kind = name.to_lower()
    match kind:
        "panel" => "panel"
        "text" => "text"
        "list" => "list"
        "table" => "table"
        "progress" => "progress"
        "menubar" => "menubar"
        "statusbar" => "statusbar"
        "input" => "input"
        "tabs" => "tabs"
        "button" => "button"
        "checkbox" => "checkbox"
        "dropdown" => "dropdown"
        "textfield" => "textfield"
        "image" => "image"
        "divider" => "divider"
        "dialog" => "dialog"
        "tooltip" => "tooltip"
        _ => "panel"

fn parse_layout_kind(name: text) -> text:
    val layout = name.to_lower()
    match layout:
        "vbox" => "vbox"
        "hbox" => "hbox"
        "grid" => "grid"
        "fixed" => "fixed"
        _ => "vbox"
