# UI Core Widget Types
#
# Platform-independent type definitions for the UI system.
# All core enums and classes: WidgetKind, LayoutKind, UIMode, UIEvent,
# WidgetNode, UITree, WidgetRect, UIState.

# =========================================================================
# Enums
# =========================================================================

enum WidgetKind:
    Panel
    Text
    List
    Table
    Progress
    MenuBar
    StatusBar
    Input
    Tabs
    Button
    Checkbox
    Dropdown
    TextField
    Image
    Divider
    Dialog
    Tooltip

enum LayoutKind:
    VBox
    HBox
    Grid
    Fixed

enum UIMode:
    Normal
    Command
    Insert
    Menu

enum UIEvent:
    KeyPress(key: text)
    Resize(width: i32, height: i32)
    FileChanged
    Quit
    Action(name: text)
    FocusNext
    FocusPrev
    CommandMode
    NormalMode
    InsertMode

# =========================================================================
# Widget Node
# =========================================================================

class WidgetNode:
    id: text
    kind: WidgetKind
    props: Dict<text, text>
    children: [WidgetNode]
    layout: LayoutKind
    visible: bool
    focused: bool

    static fn new(id: text, kind: WidgetKind) -> WidgetNode:
        return WidgetNode(
            id: id,
            kind: kind,
            props: {},
            children: [],
            layout: LayoutKind.VBox,
            visible: true,
            focused: false
        )

    fn set_prop(key: text, value: text) -> WidgetNode:
        var new_props = self.props
        new_props[key] = value
        return WidgetNode(
            id: self.id,
            kind: self.kind,
            props: new_props,
            children: self.children,
            layout: self.layout,
            visible: self.visible,
            focused: self.focused
        )

    fn add_child(child: WidgetNode) -> WidgetNode:
        var new_children = self.children
        new_children.push(child)
        return WidgetNode(
            id: self.id,
            kind: self.kind,
            props: self.props,
            children: new_children,
            layout: self.layout,
            visible: self.visible,
            focused: self.focused
        )

    fn get_prop(key: text) -> text:
        if self.props.contains_key(key):
            return self.props[key]
        return ""

    fn find_by_id(target_id: text) -> WidgetNode?:
        if self.id == target_id:
            return self
        for child in self.children:
            val found = child.find_by_id(target_id)
            if found != nil:
                return found
        return nil

    fn collect_ids() -> [text]:
        var ids: [text] = [self.id]
        for child in self.children:
            val child_ids = child.collect_ids()
            for cid in child_ids:
                ids.push(cid)
        return ids

    fn widget_summary() -> text:
        val kind_name = match self.kind:
            WidgetKind.Panel => "panel"
            WidgetKind.Text => "text"
            WidgetKind.List => "list"
            WidgetKind.Table => "table"
            WidgetKind.Progress => "progress"
            WidgetKind.MenuBar => "menubar"
            WidgetKind.StatusBar => "statusbar"
            WidgetKind.Input => "input"
            WidgetKind.Tabs => "tabs"
            WidgetKind.Button => "button"
            WidgetKind.Checkbox => "checkbox"
            WidgetKind.Dropdown => "dropdown"
            WidgetKind.TextField => "textfield"
            WidgetKind.Image => "image"
            WidgetKind.Divider => "divider"
            WidgetKind.Dialog => "dialog"
            WidgetKind.Tooltip => "tooltip"
        return "{self.id} ({kind_name})"

# =========================================================================
# UI Tree
# =========================================================================

class UITree:
    root: WidgetNode
    keybindings: Dict<text, Dict<text, text>>
    title: text
    theme: text

    static fn new(root: WidgetNode) -> UITree:
        return UITree(
            root: root,
            title: "Simple UI",
            theme: "dark",
            keybindings: {}
        )

    fn find_widget(id: text) -> WidgetNode?:
        return self.root.find_by_id(id)

    fn all_widget_ids() -> [text]:
        return self.root.collect_ids()

# =========================================================================
# Widget Rect (layout result)
# =========================================================================

class WidgetRect:
    id: text
    x: i32
    y: i32
    w: i32
    h: i32

    static fn new(id: text, x: i32, y: i32, w: i32, h: i32) -> WidgetRect:
        return WidgetRect(id: id, x: x, y: y, w: w, h: h)

# =========================================================================
# UI State
# =========================================================================

class UIState:
    tree: UITree
    mode: UIMode
    focused_id: text
    command_buffer: text

    static fn new(tree: UITree) -> UIState:
        val ids = tree.all_widget_ids()
        val initial_focus = if ids.len() > 0:
            ids[0]
        else:
            ""
        return UIState(
            tree: tree,
            mode: UIMode.Normal,
            focused_id: initial_focus,
            command_buffer: ""
        )

    fn mode_name() -> text:
        return match self.mode:
            UIMode.Normal => "NORMAL"
            UIMode.Command => "COMMAND"
            UIMode.Insert => "INSERT"
            UIMode.Menu => "MENU"

# =========================================================================
# Helper: parse WidgetKind from text
# =========================================================================

fn parse_widget_kind(name: text) -> WidgetKind:
    match name:
        "panel" => WidgetKind.Panel
        "text" => WidgetKind.Text
        "list" => WidgetKind.List
        "table" => WidgetKind.Table
        "progress" => WidgetKind.Progress
        "menubar" => WidgetKind.MenuBar
        "statusbar" => WidgetKind.StatusBar
        "input" => WidgetKind.Input
        "tabs" => WidgetKind.Tabs
        "button" => WidgetKind.Button
        "checkbox" => WidgetKind.Checkbox
        "dropdown" => WidgetKind.Dropdown
        "textfield" => WidgetKind.TextField
        "image" => WidgetKind.Image
        "divider" => WidgetKind.Divider
        "dialog" => WidgetKind.Dialog
        "tooltip" => WidgetKind.Tooltip
        _ => WidgetKind.Panel

fn parse_layout_kind(name: text) -> LayoutKind:
    match name:
        "vbox" => LayoutKind.VBox
        "hbox" => LayoutKind.HBox
        "grid" => LayoutKind.Grid
        "fixed" => LayoutKind.Fixed
        _ => LayoutKind.VBox
