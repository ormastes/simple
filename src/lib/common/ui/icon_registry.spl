# Global registry lookup
fn get_icon_definition(id: text) -> IconDefinition?:
    if id == "terminal": return IconDefinition.terminal()
    if id == "folder": return IconDefinition.folder()
    if id == "document": return IconDefinition.document()
    if id == "search": return IconDefinition.search()
    if id == "wifi": return IconDefinition.wifi()
    if id == "battery": return IconDefinition.battery()
    if id == "close": return IconDefinition.close()
    if id == "minimize": return IconDefinition.minimize()
    if id == "maximize": return IconDefinition.maximize()
    if id == "calculator": return IconDefinition.calculator()
    if id == "editor": return IconDefinition.editor()
    if id == "paint": return IconDefinition.paint()
    if id == "minesweeper": return IconDefinition.minesweeper()
    if id == "tetris": return IconDefinition.tetris()
    nil
