# Simple Theme — Unified CSS-based theme system
#
# Bridges Stitch design tokens and standard CSS for the UI library and WM.

use common.ui.glass_tokens.{GlassDesignTokens, StitchMetadata, GlassColorTokens, StitchMd3Colors}
use common.ui.style.{UITheme, ThemeColors, Spacing, BorderStyle, FontStyle}

class SimpleTheme:
    name: text
    metadata: StitchMetadata
    tokens: GlassDesignTokens

    static fn from_css(name: text, css: text) -> SimpleTheme:
        """Parse a .simple-theme CSS file into a SimpleTheme object."""
        val lines = css.split("\n")
        
        var metadata = StitchMetadata.obsidian()
        var tokens = GlassDesignTokens.obsidian_dark()
        
        for line in lines:
            val trimmed = line.trim()
            if trimmed.starts_with("--ui-bg:"):
                tokens.colors.surface_level_0 = parse_css_var(trimmed, "--ui-bg")
            elif trimmed.starts_with("--ui-fg:"):
                tokens.colors.text_primary = parse_css_var(trimmed, "--ui-fg")
            elif trimmed.starts_with("--ui-accent:"):
                tokens.colors.accent = parse_css_var(trimmed, "--ui-accent")
            elif trimmed.starts_with("--glass-surface:"):
                tokens.colors.surface_level_1 = parse_css_var(trimmed, "--glass-surface")
            elif trimmed.starts_with("--glass-blur:"):
                val val_text = parse_css_var(trimmed, "--glass-blur")
                # Basic numeric extraction: "20px" -> 20
                if val_text.ends_with("px"):
                    # For Phase 1, we keep it as 20 for the compositor
                    tokens.blur.surface_blur = 20
            elif trimmed.contains("@stitch.display_name:"):
                metadata.display_name = parse_metadata_val(trimmed, "@stitch.display_name")
            elif trimmed.contains("@stitch.color_mode:"):
                metadata.color_mode = parse_metadata_val(trimmed, "@stitch.color_mode")
            elif trimmed.contains("@stitch.project:"):
                # metadata projection extraction
                pass_dn
        
        return SimpleTheme(
            name: name,
            metadata: metadata,
            tokens: tokens
        )

fn parse_metadata_val(line: text, key: text) -> text:
    """Helper to extract @stitch metadata values from comments."""
    if not line.contains("{key}:"):
        return ""
    val parts = line.split(":")
    if parts.len() < 2:
        return ""
    return parts[1].trim()

    me to_css() -> text:
        """Generate a .simple-theme CSS file from this theme."""
        var s = "/*\n"
        s = "{s} @stitch.display_name: {self.metadata.display_name}\n"
        s = "{s} @stitch.color_mode: {self.metadata.color_mode}\n"
        s = "{s}*/\n\n"
        
        s = "{s}:root \{\n"
        s = "{s}  /* Generated from SimpleTheme */\n"
        s = "{s}  --ui-bg: {self.tokens.colors.surface_level_0};\n"
        s = "{s}  --ui-fg: {self.tokens.colors.text_primary};\n"
        s = "{s}  --ui-accent: {self.tokens.colors.accent};\n"
        s = "{s}  --glass-surface: {self.tokens.colors.surface_level_1};\n"
        s = "{s}  --glass-blur: {self.tokens.blur.surface_blur}px;\n"
        s = "{s}\}\n"
        return s

fn parse_css_var(line: text, name: text) -> text:
    """Helper to extract a CSS variable value from a line."""
    if not line.contains("{name}:"):
        return ""
    val parts = line.split(":")
    if parts.len() < 2:
        return ""
    var val_text = parts[1].trim()
    if val_text.ends_with(";"):
        val_text = val_text[0:val_text.len() - 1].trim()
    return val_text
