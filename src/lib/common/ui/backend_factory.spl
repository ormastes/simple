#![allow(unnamed_duplicate_typed_args)]
# UI Backend Factory
#
# Factory function to create render backends by name.
# Returns Result<any, text> wrapping either NoneBackend or BrowserBackend.
#
# Supported modes:
#   - "none" / "headless" — NoneBackend (no-op, for tests)
#   - "browser" / "os"    — BrowserBackend (browser engine pipeline)

use common.ui.widget.{UITree, UIState, UIEvent}
use os.compositor.browser_backend.{BrowserBackend}

# =========================================================================
# NoneBackend — minimal no-op backend for headless/test use
# =========================================================================

class NoneBackend:
    _name: text

impl NoneBackend:
    static fn create(name: text) -> NoneBackend:
        NoneBackend(_name: name)

    fn init() -> Result<bool, text>:
        Ok(true)

    fn shutdown():
        pass_dn

    fn render(state: UIState) -> Result<bool, text>:
        Ok(true)

    fn render_html(state: UIState) -> text:
        ""

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        nil

    fn supports_mouse() -> bool: false
    fn supports_color() -> bool: false
    fn supports_images() -> bool: false
    fn supports_touch() -> bool: false

    fn viewport_width() -> i32: 80
    fn viewport_height() -> i32: 24

    fn backend_name() -> text:
        self._name

# =========================================================================
# Factory
# =========================================================================

fn create_backend(mode: text, port: i64) -> Result<any, text>:
    """Create a render backend by mode name.

    Supported modes: "none", "headless", "browser", "os"
    Returns Err for unknown modes.

    The "browser" and "os" modes create a BrowserBackend with a default
    1024x768 viewport and glass_dark theme. For custom dimensions, use
    create_browser_backend() or create_os_backend() directly.
    """
    if mode == "none" or mode == "headless":
        return Ok(NoneBackend.create("none"))
    if mode == "browser" or mode == "os":
        return Ok(create_browser_backend(1024, 768, "glass_dark"))
    Err("Unknown backend mode: {mode}")

fn create_browser_backend(width: i32, height: i32, theme: text) -> BrowserBackend:
    """Create a browser-engine render backend.

    This backend routes widget trees through the full browser engine
    pipeline (DOM -> CSS layout -> paint -> render_scene -> pixels).

    Args:
        width  - viewport width in pixels
        height - viewport height in pixels
        theme  - "dark", "light", "glass_dark", "glass_light", "ios_dark", "ios_light"
    """
    BrowserBackend.new(width, height, theme)

fn create_os_backend(width: i32, height: i32) -> BrowserBackend:
    """Create the default OS render backend (browser engine, glass_dark theme).

    Convenience alias for create_browser_backend with the glass_dark theme,
    suitable for SimpleOS compositor integration.
    """
    create_browser_backend(width, height, "glass_dark")

fn create_sync_backend(mode: text, port: i64) -> Result<any, text>:
    """Create a synchronous render backend (alias for create_backend)."""
    create_backend(mode, port)
