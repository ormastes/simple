# Override colors from the Stitch design system `theme.override*` fields.
# Used when the compositor needs the seed palette rather than the computed
# MD3 tokens (e.g. for CTA gradients or brand-moment accents).
val GLASS_OBSIDIAN_OVERRIDE_PRIMARY: u64            = 0x00F5F5F7
