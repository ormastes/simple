val GLASS_OBSIDIAN_CONTAINER_HIGH: u64    = 0x00292937
val GLASS_OBSIDIAN_CONTAINER_HIGHEST: u64 = 0x00343342
val GLASS_OBSIDIAN_ELEVATED: u64          = 0x00292937
val GLASS_OBSIDIAN_ELEVATED_A: u64        = 224
