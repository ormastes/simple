# ---------------------------------------------------------------------------
# Glass MD3 seed colors (from Stitch project 14134637940805933672,
# pulled 2026-04-12). No explicit namedColors map — Stitch uses TONAL_SPOT
# to derive the full palette from these seeds at render time.
# ---------------------------------------------------------------------------
val GLASS_GLASS_OVERRIDE_PRIMARY: u64               = 0x000A84FF
val GLASS_GLASS_OVERRIDE_SECONDARY: u64             = 0x00BB86FC
