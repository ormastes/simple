val GLASS_GLASS_RADIUS_WINDOW: u64                  = 12  # ROUND_TWELVE

# ===========================================================================
# 5-Level Surface Hierarchy (shared by GUI + WM)
# ===========================================================================

# Surface alpha values (0-255)
val GLASS_SURFACE_0_A: u64 = 255  # opaque bg
val GLASS_SURFACE_1_A: u64 = 10   # 4% white
val GLASS_SURFACE_2_A: u64 = 15   # 6% white
val GLASS_SURFACE_3_A: u64 = 23   # 9% white
val GLASS_SURFACE_4_A: u64 = 31   # 12% white

# Surface 0 solid background color
val GLASS_SURFACE_0_BG: u64 = 0x000B0D10

# Surface blur radii (CSS px)
val GLASS_SURFACE_BLUR_0: u64 = 0
val GLASS_SURFACE_BLUR_1: u64 = 10
val GLASS_SURFACE_BLUR_2: u64 = 12
val GLASS_SURFACE_BLUR_3: u64 = 16
val GLASS_SURFACE_BLUR_4: u64 = 20

# ===========================================================================
# Theme Registry — registration block (Phase 1 UI Typed Core RFC)
# ===========================================================================

use common.ui.theme_registry.{ThemeId, theme_registry, IconSet}

fn _register_glass_icons():
    val r = theme_registry()
    val icons = IconSet(
        icon_term: GLASS_ICON_TERM,
        icon_files: GLASS_ICON_FILES,
        icon_calc: GLASS_ICON_CALC,
        icon_clock: GLASS_ICON_CLOCK,
        icon_settings: GLASS_ICON_SETTINGS,
        icon_browser: GLASS_ICON_BROWSER,
        icon_editor: GLASS_ICON_EDITOR
    )
    # Icon constants are theme-independent; register the same IconSet for all glass themes.
    r.register_icons(ThemeId.GlassLight, icons)
    r.register_icons(ThemeId.GlassDark, icons)
    r.register_icons(ThemeId.GlassObsidianDark, icons)

val _glass_icons_registered = _register_glass_icons()
