# Glass Theme Presets
#
# Factory functions that produce UITheme instances with macOS-inspired
# glassmorphism styling. Uses composition: GlassDesignTokens extend
# the base UITheme with translucency and blur tokens.
# No proprietary assets — generic CSS glassmorphism.

use common.ui.style.{UITheme, ThemeColors, Spacing, BorderStyle, FontStyle}
use common.ui.color.{Color}
use common.ui.glass.tokens.{GlassDesignTokens}

# =========================================================================
# Glass Font Stack (system fonts, no license issues)
# =========================================================================

val GLASS_FONT_FAMILY = "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', 'Segoe UI', system-ui, sans-serif"
val GLASS_OBSIDIAN_FONT_FAMILY = "'Space Grotesk', 'Manrope', 'Inter', system-ui, sans-serif"

# =========================================================================
# Glass Light Theme (Bright)
# =========================================================================

fn glass_light() -> UITheme:
    return UITheme(
        name: "glass_light",
        colors: ThemeColors(
            background: Color.from_hex("#F0F0F5"),
            foreground: Color.from_hex("#1D1D1F"),
            border: "rgba(0,0,0,0.08)",
            accent: Color.from_hex("#007AFF"),
            panel_bg: "rgba(255,255,255,0.72)",
            hover_bg: "rgba(0,0,0,0.04)",
            error: Color.from_hex("#FF3B30"),
            warning: Color.from_hex("#FF9500"),
            success: Color.from_hex("#34C759"),
            info: Color.from_hex("#5AC8FA")
        ),
        spacing: Spacing(xs: 4, sm: 8, md: 12, lg: 20, xl: 32),
        border: BorderStyle(width: 1, radius: 12, style: "solid"),
        font: FontStyle(
            family: GLASS_FONT_FAMILY,
            size: 15,
            weight: "normal",
            line_height: 1.35
        )
    )

# =========================================================================
# Glass Dark Theme
# =========================================================================

fn glass_dark() -> UITheme:
    return UITheme(
        name: "glass_dark",
        colors: ThemeColors(
            background: Color.from_hex("#0A0A0F"),
            foreground: Color.from_hex("#F5F5F7"),
            border: "rgba(255,255,255,0.08)",
            accent: Color.from_hex("#0A84FF"),
            panel_bg: "rgba(30,30,35,0.72)",
            hover_bg: "rgba(255,255,255,0.06)",
            error: Color.from_hex("#FF453A"),
            warning: Color.from_hex("#FF9F0A"),
            success: Color.from_hex("#30D158"),
            info: Color.from_hex("#64D2FF")
        ),
        spacing: Spacing(xs: 4, sm: 8, md: 12, lg: 20, xl: 32),
        border: BorderStyle(width: 1, radius: 12, style: "solid"),
        font: FontStyle(
            family: GLASS_FONT_FAMILY,
            size: 15,
            weight: "normal",
            line_height: 1.35
        )
    )

# =========================================================================
# Glass Obsidian Dark Theme (MD3 Fidelity)
# =========================================================================

fn glass_obsidian_dark() -> UITheme:
    return UITheme(
        name: "glass_obsidian_dark",
        colors: ThemeColors(
            background: Color.from_hex("#060612"),
            foreground: Color.from_hex("#E3E0F3"),
            border: "rgba(149,142,152,0.15)",
            accent: Color.from_hex("#C6C6C8"),
            panel_bg: "rgba(18,18,31,0.72)",
            hover_bg: "rgba(41,41,55,0.20)",
            error: Color.from_hex("#FFB4AB"),
            warning: Color.from_hex("#FF9F0A"),
            success: Color.from_hex("#30D158"),
            info: Color.from_hex("#64D2FF")
        ),
        spacing: Spacing(xs: 4, sm: 8, md: 12, lg: 20, xl: 32),
        border: BorderStyle(width: 1, radius: 8, style: "solid"),
        font: FontStyle(
            family: GLASS_OBSIDIAN_FONT_FAMILY,
            size: 15,
            weight: "normal",
            line_height: 1.35
        )
    )

# =========================================================================
# Glass Obsidian Light Theme — Stitch "Celestial Ether" palette
# =========================================================================

fn glass_obsidian_light() -> UITheme:
    return UITheme(
        name: "glass_obsidian_light",
        colors: ThemeColors(
            background: Color.from_hex("#F0ECF5"),
            foreground: Color.from_hex("#1D1D1F"),
            border: "rgba(74,69,77,0.15)",
            accent: Color.from_hex("#7C69A3"),
            panel_bg: "rgba(255,255,255,0.78)",
            hover_bg: "rgba(124,105,163,0.10)",
            error: Color.from_hex("#FF3B30"),
            warning: Color.from_hex("#FF9500"),
            success: Color.from_hex("#34C759"),
            info: Color.from_hex("#5AC8FA")
        ),
        spacing: Spacing(xs: 4, sm: 8, md: 12, lg: 20, xl: 32),
        border: BorderStyle(width: 1, radius: 8, style: "solid"),
        font: FontStyle(
            family: GLASS_OBSIDIAN_FONT_FAMILY,
            size: 15,
            weight: "normal",
            line_height: 1.35
        )
    )

# =========================================================================
# Design Tokens Access
# =========================================================================

fn glass_design_tokens(theme_name: text) -> GlassDesignTokens:
    if theme_name == "aetheric_dark":
        use common.ui.theme_package.{theme_design_tokens}
        return theme_design_tokens(theme_name)
    if theme_name == "glass_light":
        return GlassDesignTokens.light()
    if theme_name == "glass_obsidian_dark":
        return GlassDesignTokens.obsidian_dark()
    if theme_name == "glass_obsidian_light":
        return GlassDesignTokens.obsidian_light()
    return GlassDesignTokens.dark()

fn is_glass_theme(theme_name: text) -> bool:
    if theme_name == "aetheric_dark":
        return true
    if theme_name == "glass_light":
        return true
    if theme_name == "glass_dark":
        return true
    if theme_name == "glass_obsidian_dark":
        return true
    if theme_name == "glass_obsidian_light":
        return true
    return false

# =========================================================================
# Module-init: register themes with the central ThemeRegistry
# Top-level call runs once when this module is first imported.
# =========================================================================

use common.ui.theme_registry.{ThemeId, theme_registry}

fn _register_glass_themes():
    val r = theme_registry()
    r.register_theme(ThemeId.GlassLight, glass_light)
    r.register_theme(ThemeId.GlassDark, glass_dark)
    r.register_theme(ThemeId.GlassObsidianDark, glass_obsidian_dark)
    r.register_theme(ThemeId.Custom("glass_obsidian_light"), glass_obsidian_light)

# Top-level call — Simple's module-init idiom (same pattern as
# var _widget_registry = [] at widget.spl:64 — top-level statements
# execute once on module load).
val _glass_themes_registered = _register_glass_themes()
