# widget_draw_cmds.spl — Pure widget-tree → draw-command projection.
#
# Converts a WidgetNode tree into a flat list of DrawCmd records that
# any 2D drawing backend can execute without knowing about widgets.
# This bridges the adaptive layout layer (compute_layout) to concrete
# Engine2D draw calls — the backend consumes DrawCmd values, keeping
# ALL backend draw calls in the application's own functions that take
# the concrete backend type directly.
#
# DrawCmd kinds: "rect" | "rect_outline" | "text"
#
# Color palette (all ARGB u32, 0xFF prefix = fully opaque):
#   - nav container background (nav_pattern prop set):  0xFF2D2D44
#   - generic container/panel background:              0xFF1E1E2E
#   - button fill:                                     0xFF4C6EF5
#   - label/text foreground:                           0xFFE0E0E0
#
# See doc/01_research/ui/responsive_layout/responsive_layout_platforms.md

use common.ui.layout.{compute_layout}
use common.ui.widget.{WidgetNode, WidgetRect}

# =========================================================================
# DrawCmd
# =========================================================================

struct DrawCmd:
    kind:      text
    widget_id: text
    x:         i32
    y:         i32
    w:         i32
    h:         i32
    color:     u32
    label:     text
    size:      i32

# =========================================================================
# Color constants
# =========================================================================

val NAV_BG: u32 = 0xFF2D2D44u32
val GENERIC_BG: u32 = 0xFF1E1E2Eu32
val BUTTON_BG: u32 = 0xFF4C6EF5u32
val TEXT_FG: u32 = 0xFFE0E0E0u32

# =========================================================================
# Internal helpers
# =========================================================================

fn _rect_cmd(id: text, x: i32, y: i32, w: i32, h: i32, color: u32) -> DrawCmd:
    return DrawCmd(
        kind:      "rect",
        widget_id: id,
        x:         x,
        y:         y,
        w:         w,
        h:         h,
        color:     color,
        label:     "",
        size:      0
    )

fn _outline_cmd(id: text, x: i32, y: i32, w: i32, h: i32, color: u32) -> DrawCmd:
    return DrawCmd(
        kind:      "rect_outline",
        widget_id: id,
        x:         x,
        y:         y,
        w:         w,
        h:         h,
        color:     color,
        label:     "",
        size:      0
    )

fn _text_cmd(id: text, x: i32, y: i32, color: u32, text_label: text, text_size: i32) -> DrawCmd:
    return DrawCmd(
        kind:      "text",
        widget_id: id,
        x:         x,
        y:         y,
        w:         0,
        h:         0,
        color:     color,
        label:     text_label,
        size:      text_size
    )

fn _emit_for_rect(node: WidgetNode, rect: WidgetRect, cmds: [DrawCmd]) -> [DrawCmd]:
    """Emit draw commands for a single (node, rect) pair. Skips zero-area rects."""
    var result = cmds
    if rect.w <= 0 or rect.h <= 0:
        return result

    val kind = node.kind_name()

    if kind == "button":
        # Fill + outline + centered label text
        result.push(_rect_cmd(rect.id, rect.x, rect.y, rect.w, rect.h, BUTTON_BG))
        result.push(_outline_cmd(rect.id, rect.x, rect.y, rect.w, rect.h, BUTTON_BG))
        val lbl = node.get_prop("label")
        if lbl != "":
            val tx = rect.x + 6
            val ty = rect.y + rect.h / 2
            result.push(_text_cmd(rect.id, tx, ty, TEXT_FG, lbl, 7))
    elif kind == "label" or kind == "text":
        # Text only
        val lbl = node.get_prop("label")
        if lbl != "":
            result.push(_text_cmd(rect.id, rect.x, rect.y + rect.h / 2, TEXT_FG, lbl, 7))
    elif kind == "column" or kind == "row" or kind == "panel":
        # Container: fill with nav or generic color
        val nav_pat = node.get_prop("nav_pattern")
        val bg = if nav_pat != "": NAV_BG else: GENERIC_BG
        result.push(_rect_cmd(rect.id, rect.x, rect.y, rect.w, rect.h, bg))
    else:
        # Default: generic background rect
        result.push(_rect_cmd(rect.id, rect.x, rect.y, rect.w, rect.h, GENERIC_BG))

    return result

# =========================================================================
# Walk tree to collect (node, rect) pairs by id
# =========================================================================

fn _collect_nodes(node: WidgetNode, all_nodes: [WidgetNode]) -> [WidgetNode]:
    """Collect layout-visible nodes in the same pre-order shape as compute_layout."""
    var result = all_nodes
    result.push(node)
    if not node.is_visible():
        return result
    for child in node.children():
        if child.is_visible():
            result = _collect_nodes(child, result)
    return result

fn _find_node(nodes: [WidgetNode], id: text) -> WidgetNode?:
    for n in nodes:
        if n.id == id:
            return n
    return nil

# =========================================================================
# widget_tree_to_draw_cmds
# =========================================================================

fn widget_tree_to_draw_cmds(root: WidgetNode, w: i32, h: i32) -> [DrawCmd]:
    """Project a WidgetNode tree at viewport (w, h) into a flat [DrawCmd] list.

    Steps:
      1. compute_layout to get WidgetRect for every node.
      2. Collect all WidgetNode instances by pre-order traversal.
      3. For each WidgetRect, find the matching WidgetNode and emit cmds.
      4. Append a final "text" cmd with widget_id "nav_pattern_probe" whose
         label equals the root's nav_pattern prop — lets check scripts grep
         for the pattern without pixel-level inspection.
    """
    val rects = compute_layout(root, 0, 0, w, h)
    var all_nodes: [WidgetNode] = []
    all_nodes = _collect_nodes(root, all_nodes)

    var cmds: [DrawCmd] = []
    var rect_idx = 0
    while rect_idx < rects.len():
        val rect = rects[rect_idx]
        if rect_idx < all_nodes.len():
            val candidate = all_nodes[rect_idx]
            if candidate.id == rect.id:
                cmds = _emit_for_rect(candidate, rect, cmds)
            else:
                val node = _find_node(all_nodes, rect.id)
                if node != nil:
                    cmds = _emit_for_rect(node, rect, cmds)
        else:
            val node = _find_node(all_nodes, rect.id)
            if node != nil:
                cmds = _emit_for_rect(node, rect, cmds)
        rect_idx = rect_idx + 1

    # Probe: emit the root's nav_pattern as a greppable text cmd
    val nav_pattern_val = root.get_prop("nav_pattern")
    val probe_label = if nav_pattern_val != "": nav_pattern_val else: "none"
    cmds.push(_text_cmd("nav_pattern_probe", 0, 0, TEXT_FG, probe_label, 7))

    return cmds
