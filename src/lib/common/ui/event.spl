# UI Event Dispatch
#
# Processes UIEvents against the current UIState and produces
# a new UIState (immutable state transitions).

use common.ui.widget.{UIMode, UIEvent, UIState, UITree, WidgetNode}
use common.ui.mode.{switch_mode, resolve_keybinding}
use common.ui.layout.{compute_layout}
use common.ui.widget_hit.{
    widget_set_pressed,
    widget_clear_pressed,
    widget_dispatch_hover,
    widget_dispatch_click,
    widget_dispatch_scroll,
    widget_dispatch_key,
    widget_hit_test,
    widget_dispatch_composition_update,
    widget_dispatch_composition_commit
}

# Viewport used to lay out the tree for hit-testing. Stored in the tree's
# token bag (set by UIEvent.Resize); defaults to 640x480 when unset.
fn _viewport_dim(state: UIState, key: text, fallback: i32) -> i32:
    val raw = state.tree.resolve_token(key)
    if raw == "":
        return fallback
    raw.to_int() ?? fallback

fn _with_focus(state: UIState, focused_id: text) -> UIState:
    UIState(
        tree: state.tree,
        mode: state.mode,
        focused_id: focused_id,
        command_buffer: state.command_buffer
    )

# =========================================================================
# Event Processing
# =========================================================================

fn process_event(state: UIState, event: UIEvent) -> UIState:
    """Process a UIEvent and return the updated state."""
    match event:
        UIEvent.Quit:
            return state
        UIEvent.FocusNext:
            return focus_next(state)
        UIEvent.FocusPrev:
            return focus_prev(state)
        UIEvent.CommandMode:
            return switch_mode(state, UIMode.Command)
        UIEvent.NormalMode:
            return switch_mode(state, UIMode.Normal)
        UIEvent.InsertMode:
            return switch_mode(state, UIMode.Insert)
        UIEvent.KeyPress(key):
            return handle_keypress(state, key)
        UIEvent.Action(name):
            return handle_action(state, name)
        UIEvent.FileChanged:
            return state
        UIEvent.Resize(width, height):
            var tree = state.tree.with_token("viewport_w", "{width}")
            tree = tree.with_token("viewport_h", "{height}")
            return UIState(tree: tree, mode: state.mode, focused_id: state.focused_id, command_buffer: state.command_buffer)
        UIEvent.TouchPress(x, y):
            return handle_pointer(state, x, y, "down")
        UIEvent.TouchMove(x, y):
            return handle_pointer(state, x, y, "move")
        UIEvent.TouchRelease(x, y):
            return handle_pointer(state, x, y, "up")
        UIEvent.MouseEvent(x, y, button, kind):
            return handle_pointer(state, x as i32, y as i32, kind)
        UIEvent.ScrollEvent(x, y, dx, dy):
            return handle_scroll(state, x as i32, y as i32, dy as i32)
        UIEvent.FocusEvent(target_id, kind):
            return handle_focus_event(state, target_id, kind)
        UIEvent.InputChange(target_id, value):
            return handle_input_change(state, target_id, value)
        UIEvent.FetchResult(request_id, url, status, headers, body, error):
            return state
        UIEvent.DragStart(source_id, mime, data):
            return handle_drag_start(state, source_id, mime, data)
        UIEvent.DragMove(x, y):
            return handle_drag_move(state, x, y)
        UIEvent.DragDrop(mime, data, x, y, source_id):
            return handle_drag_drop(state, mime, data, x, y, source_id)
        # Copy/Cut/Paste/PasteFromHistory are stateless from process_event's
        # point of view: process_event is a pure (state, event) -> state
        # reducer with no side channel for a ClipboardService instance. The
        # actual clipboard mechanics are dispatched by the caller that owns
        # the service (see nogc_sync_mut.ui.session.UISession.dispatch,
        # which owns one ClipboardService per session and handles these
        # variants directly before/alongside calling process_event).
        UIEvent.Copy:
            return state
        UIEvent.Cut:
            return state
        UIEvent.Paste:
            return state
        UIEvent.PasteFromHistory(index):
            return state
        UIEvent.CompositionUpdate(text):
            return handle_composition_update(state, text)
        UIEvent.CompositionCommit(text):
            return handle_composition_commit(state, text)

fn handle_keypress(state: UIState, key: text) -> UIState:
    """Handle a key press by checking keybindings first."""
    # Check keybindings
    val bound_event = resolve_keybinding(state, key)
    if bound_event != nil:
        return process_event(state, bound_event)

    # Mode-specific key handling
    match state.mode:
        UIMode.Command:
            return handle_command_key(state, key)
        UIMode.Insert:
            return handle_insert_key(state, key)
        UIMode.Normal:
            return handle_normal_key(state, key)
        UIMode.Menu:
            return handle_menu_key(state, key)

fn handle_normal_key(state: UIState, key: text) -> UIState:
    """Handle keys in normal mode."""
    match key:
        "j":
            return focus_next(state)
        "k":
            return focus_prev(state)
        ":":
            return switch_mode(state, UIMode.Command)
        "i":
            return switch_mode(state, UIMode.Insert)
        _:
            return state

fn handle_command_key(state: UIState, key: text) -> UIState:
    """Handle keys in command mode (accumulate command buffer)."""
    if key == "enter":
        # Execute command
        return execute_command(state)
    elif key == "escape":
        return switch_mode(state, UIMode.Normal)
    else:
        # Append to command buffer
        return UIState(
            tree: state.tree,
            mode: state.mode,
            focused_id: state.focused_id,
            command_buffer: "{state.command_buffer}{key}"
        )

fn handle_insert_key(state: UIState, key: text) -> UIState:
    """Handle keys in insert mode: route printable keys to the focused input."""
    if key == "escape":
        return switch_mode(state, UIMode.Normal)
    widget_dispatch_key(state.focused_id, key)
    return state

fn handle_menu_key(state: UIState, key: text) -> UIState:
    """Handle keys in menu mode."""
    if key == "escape":
        return switch_mode(state, UIMode.Normal)
    return state

fn handle_action(state: UIState, name: text) -> UIState:
    """Handle a named action."""
    # Handle focus actions from mouse clicks: "focus_<widget_id>"
    if name.starts_with("focus_"):
        val target_id = name.slice(6, name.len())
        val target = state.tree.find_widget(target_id)
        if target != nil:
            return UIState(
                tree: state.tree,
                mode: state.mode,
                focused_id: target_id,
                command_buffer: state.command_buffer
            )
        return state

    # Handle tab switching: "tab_<tabs_id>_<index>"
    if name.starts_with("tab_"):
        val rest = name.slice(4, name.len())
        var last_us = -1
        var si = 0
        for ch in rest:
            if ch == "_":
                last_us = si
            si = si + 1
        if last_us > 0:
            val tabs_id = rest.slice(0, last_us)
            val idx_str = rest.slice(last_us + 1, rest.len())
            val tabs_node = state.tree.find_widget(tabs_id)
            if tabs_node != nil:
                tabs_node.set_prop("active_index", idx_str)
        return state

    # Handle tree node toggle actions (toggle_<node_id>)
    if name.starts_with("toggle_"):
        val node_id = name.slice(7, name.len())
        val node = state.tree.find_widget(node_id)
        if node != nil:
            val current = node.get_prop("expanded")
            val new_val = if current == "true": "false" else: "true"
            node.set_prop("expanded", new_val)
        return state

    # Handle table sort: "sort_col_N" -> toggle sort on column N
    if name.starts_with("sort_col_"):
        val col_str = name.slice(9, name.len())
        # Find the focused table widget and update its sort props
        val focused = state.tree.find_widget(state.focused_id)
        if focused != nil:
            val current_col = focused.get_prop("sort_column")
            if current_col == col_str:
                val current_dir = focused.get_prop("sort_dir")
                val new_dir = if current_dir == "asc": "desc" else: "asc"
                focused.set_prop("sort_dir", new_dir)
            else:
                focused.set_prop("sort_column", col_str)
                focused.set_prop("sort_dir", "asc")
        return state

    # Handle table filter: "filter_ID" -> update filter_text on table ID
    if name.starts_with("filter_"):
        val table_id = name.slice(7, name.len())
        val table_node = state.tree.find_widget(table_id)
        if table_node != nil:
            table_node.set_prop("filter_text", "")
        return state

    # Handle list select: "select_ID_N" -> set selected_index on list ID
    if name.starts_with("select_"):
        val rest = name.slice(7, name.len())
        # Find last underscore to split ID from index
        var last_us = -1
        var si = 0
        for ch in rest:
            if ch == "_":
                last_us = si
            si = si + 1
        if last_us > 0:
            val list_id = rest.slice(0, last_us)
            val idx_str = rest.slice(last_us + 1, rest.len())
            val list_node = state.tree.find_widget(list_id)
            if list_node != nil:
                list_node.set_prop("selected_index", idx_str)
        return state

    return state

# =========================================================================
# Pointer / scroll routing (hit-test over the laid-out widget tree)
# =========================================================================

fn handle_pointer(state: UIState, x: i32, y: i32, kind: text) -> UIState:
    """Route a pointer event to the widget under (x, y).

    `move` updates hover; `down` presses buttons, toggles checkboxes, focuses
    inputs, and moves focus to the hit widget; `up` clears pressed state.
    """
    val root = state.tree.root_node()
    val w = _viewport_dim(state, "viewport_w", 640)
    val h = _viewport_dim(state, "viewport_h", 480)
    if kind == "move":
        widget_dispatch_hover(root, w, h, x, y)
        return state
    if kind == "up":
        widget_clear_pressed(root)
        return state
    # down — compute layout once and share it across both dispatch calls
    # instead of each recomputing it from scratch (they used to run
    # compute_layout() independently, doubling layout cost per down event).
    val layout = compute_layout(root, 0, 0, w, h)
    widget_set_pressed(root, w, h, x, y, layout)
    val hit = widget_dispatch_click(root, w, h, x, y, layout)
    if hit != "":
        return _with_focus(state, hit)
    return state

fn handle_scroll(state: UIState, x: i32, y: i32, dy: i32) -> UIState:
    """Route a wheel event to the scroll container under (x, y)."""
    val root = state.tree.root_node()
    val w = _viewport_dim(state, "viewport_w", 640)
    val h = _viewport_dim(state, "viewport_h", 480)
    widget_dispatch_scroll(root, w, h, x, y, dy)
    return state

# =========================================================================
# Content drag-and-drop (distinct from window titlebar move, which the
# compositor handles on its own — this is CONTENT dragged between widgets).
# =========================================================================

# Drag bookkeeping is stored as props on the ROOT widget node (the same
# process-local widget prop store that `ui_hover` / `ui_pressed` / `ui_focus`
# already use), NOT as UITree tokens. Tokens live in the tree's `Dict` field
# and are copied by value on every `with_token`, so they do not round-trip
# through the pure `(state,event)->state` reducer under all backends; the
# prop store is the single shared surface every other pointer reducer here
# writes to, and it is what renderers read back. Keeping drag state on the
# root node keeps these handlers pure (they return `state` unchanged; all
# effects are in the shared store) and consistent with hover/press.
val _DRAG_ACTIVE_PROP: text = "ui_drag_active"
val _DRAG_SOURCE_PROP: text = "ui_drag_source"
val _DRAG_MIME_PROP: text = "ui_drag_mime"
val _DRAG_DATA_PROP: text = "ui_drag_data"

fn handle_drag_start(state: UIState, source_id: text, mime: text, data: text) -> UIState:
    """Begin a content drag: record the payload on the root node and mark the
    source widget so a renderer can show drag feedback."""
    val root = state.tree.root_node()
    root.set_prop(_DRAG_ACTIVE_PROP, "true")
    root.set_prop(_DRAG_SOURCE_PROP, source_id)
    root.set_prop(_DRAG_MIME_PROP, mime)
    root.set_prop(_DRAG_DATA_PROP, data)
    val node = state.tree.find_widget(source_id)
    if node != nil:
        node.set_prop("ui_dragging", "true")
    return state

fn handle_drag_move(state: UIState, x: i32, y: i32) -> UIState:
    """Highlight the widget under the pointer as the current drop target."""
    val root = state.tree.root_node()
    if root.get_prop(_DRAG_ACTIVE_PROP) != "true":
        return state
    val w = _viewport_dim(state, "viewport_w", 640)
    val h = _viewport_dim(state, "viewport_h", 480)
    val hit = widget_hit_test(root, w, h, x, y)
    for id in root.collect_ids():
        if id != "":
            var flag = "false"
            if hit.found and id == hit.id:
                flag = "true"
            WidgetNode(id: id).set_prop("ui_drop_target", flag)
    return state

fn handle_drag_drop(state: UIState, mime: text, data: text, x: i32, y: i32, source_id: text) -> UIState:
    """Deliver the dragged payload to the widget under (x, y) and clear drag
    state. Delivery target: an input/textfield's `value` prop (the same
    generic surface Copy/Cut/Paste write to) — the inter-widget minimum."""
    val root = state.tree.root_node()
    val w = _viewport_dim(state, "viewport_w", 640)
    val h = _viewport_dim(state, "viewport_h", 480)
    val hit = widget_hit_test(root, w, h, x, y)
    for id in root.collect_ids():
        if id != "":
            WidgetNode(id: id).set_prop("ui_drop_target", "false")
    if source_id != "":
        val src = state.tree.find_widget(source_id)
        if src != nil:
            src.set_prop("ui_dragging", "false")
    root.set_prop(_DRAG_ACTIVE_PROP, "false")
    if not hit.found:
        return state
    val target_kind = WidgetNode(id: hit.id).kind_name()
    if target_kind == "input" or target_kind == "textfield":
        WidgetNode(id: hit.id).set_prop("value", data)
    return state

# =========================================================================
# IME composition (CJK/accented input via a host input-method editor).
# =========================================================================

fn handle_composition_update(state: UIState, text: text) -> UIState:
    """IME preedit update: shows the in-progress composition on the focused
    input WITHOUT committing it (value/caret are untouched)."""
    widget_dispatch_composition_update(state.focused_id, text)
    return state

fn handle_composition_commit(state: UIState, text: text) -> UIState:
    """IME commit: inserts the composed STRING at the caret (char-indexed,
    not byte-indexed — see widget_hit's _char_slice/_nchars), replacing
    whatever preedit was showing."""
    widget_dispatch_composition_commit(state.focused_id, text)
    return state

fn handle_focus_event(state: UIState, target_id: text, kind: text) -> UIState:
    if kind == "blur":
        return state
    val target = state.tree.find_widget(target_id)
    if target != nil:
        return UIState(
            tree: state.tree,
            mode: state.mode,
            focused_id: target_id,
            command_buffer: state.command_buffer
        )
    state

fn handle_input_change(state: UIState, target_id: text, value: text) -> UIState:
    val target = state.tree.find_widget(target_id)
    if target != nil:
        target.set_prop("value", value)
    state

# =========================================================================
# Command Execution
# =========================================================================

fn execute_command(state: UIState) -> UIState:
    """Execute the command buffer and return to normal mode."""
    val cmd = state.command_buffer
    var new_state = switch_mode(state, UIMode.Normal)

    match cmd:
        "q" | "quit":
            return new_state
        _:
            return new_state

# =========================================================================
# Focus Management
# =========================================================================

fn focus_next(state: UIState) -> UIState:
    """Move focus to the next widget (tab_index order)."""
    val focusable = get_focusable_ordered(state.tree)
    if focusable.len() == 0:
        return state

    val next_id = get_next_id(focusable, state.focused_id)
    return UIState(
        tree: state.tree,
        mode: state.mode,
        focused_id: next_id,
        command_buffer: state.command_buffer
    )

fn focus_prev(state: UIState) -> UIState:
    """Move focus to the previous widget (tab_index order)."""
    val focusable = get_focusable_ordered(state.tree)
    if focusable.len() == 0:
        return state

    val prev_id = get_prev_id(focusable, state.focused_id)
    return UIState(
        tree: state.tree,
        mode: state.mode,
        focused_id: prev_id,
        command_buffer: state.command_buffer
    )

fn get_focusable_ids(ids: [text]) -> [text]:
    """Filter to only focusable widget IDs (non-empty)."""
    var result: [text] = []
    for id in ids:
        if id != "":
            result = result.push(id)
    return result

fn get_focusable_ordered(tree: UITree) -> [text]:
    """Focusable widget IDs in tab order.

    Each widget's sort key is its optional `tab_index` prop when present,
    otherwise its 0-based declaration position. IDs are ordered by ascending
    key, with declaration order as a stable tiebreak (so equal keys — and the
    no-tab_index widgets keyed by position — keep declaration order).
    """
    val ids = tree.all_widget_ids()
    var f_ids: [text] = []
    var f_keys: [i32] = []
    var pos = 0
    for id in ids:
        if id != "":
            val raw = WidgetNode(id: id).get_prop("tab_index")
            var key = pos
            if raw != "":
                key = (raw.to_int() ?? pos.to_i64()).to_i32()
            f_ids = f_ids.push(id)
            f_keys = f_keys.push(key)
            pos = pos + 1
    val n = f_ids.len()
    # Stable selection sort: scanning candidates in ascending original index
    # with a strict `<` comparison makes the lowest-index widget win ties.
    var used: [bool] = []
    var u = 0
    while u < n:
        used = used.push(false)
        u = u + 1
    var result: [text] = []
    var count = 0
    while count < n:
        var best = -1
        var bi = 0
        while bi < n:
            if not used[bi] and (best == -1 or f_keys[bi] < f_keys[best]):
                best = bi
            bi = bi + 1
        used[best] = true
        result = result.push(f_ids[best])
        count = count + 1
    return result

fn get_next_id(ids: [text], current: text) -> text:
    """Get the next ID in the list after current, wrapping around."""
    var found = false
    var first = ""
    for id in ids:
        if first == "":
            first = id
        if found:
            return id
        if id == current:
            found = true
    # Wrap to first
    if first != "":
        return first
    return current

fn get_prev_id(ids: [text], current: text) -> text:
    """Get the previous ID in the list before current, wrapping around."""
    if ids.len() == 0:
        return current
    var prev = ids[ids.len() - 1]
    for id in ids:
        if id == current:
            return prev
        prev = id
    return prev

# =========================================================================
# Typed Action Bridge (Phase 5 UI Typed Core RFC)
# =========================================================================

use common.ui.action.{Action}

# Constructs a wire-shape UIEvent.Action from a typed Action.
# The UIEvent.Action(name: text) variant is unchanged; this helper
# converts the typed action to its wire name at the API boundary.
fn ui_event_action(action: Action) -> UIEvent:
    """Bridge typed Action to the wire-shape UIEvent.Action."""
    return UIEvent.Action(name: action.into_wire_name())
