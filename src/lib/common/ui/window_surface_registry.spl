# UI Window-Surface Registry
#
# Runtime-only mapping between top-level window identifiers and UI surfaces.
# This is the authoritative in-process source for window metadata enrichment
# used by the UI access protocol. Persisted UI access snapshots should not use
# the runtime window IDs as durable identity.

val UI_SURFACE_KIND_LEGACY: text = "Legacy"
val UI_SURFACE_KIND_SIMPLE_WEB: text = "SimpleWeb"
val UI_SURFACE_KIND_ELECTRON: text = "Electron"
val UI_SURFACE_KIND_HEADLESS: text = "Headless"

fn ui_surface_kind_is_native_host(surface_kind: text) -> bool:
    """Return true when a surface kind is backed by host-native windows."""
    surface_kind == UI_SURFACE_KIND_ELECTRON

fn ui_surface_kind_supports_embedded_surface(surface_kind: text) -> bool:
    surface_kind == UI_SURFACE_KIND_LEGACY or surface_kind == UI_SURFACE_KIND_SIMPLE_WEB

fn ui_surface_kind_supports_headless_session(surface_kind: text) -> bool:
    surface_kind == UI_SURFACE_KIND_HEADLESS

struct UiWindowSurfaceBinding:
    surface_id: text
    window_id: text
    process_id: u64
    app_id: text
    title: text
    surface_kind: text   # UI_SURFACE_KIND_*

class UiWindowSurfaceRegistry:
    bindings: [UiWindowSurfaceBinding]

impl UiWindowSurfaceRegistry:
    static fn new() -> UiWindowSurfaceRegistry:
        UiWindowSurfaceRegistry(bindings: [])

    me bind(window_id: text, surface_id: text, process_id: u64, app_id: text, title: text):
        """Bind with default legacy surface kind — preserves pre-Wave-1 callers."""
        self.bind_with_kind(window_id, surface_id, process_id, app_id, title, UI_SURFACE_KIND_LEGACY)

    me bind_with_kind(window_id: text, surface_id: text, process_id: u64, app_id: text, title: text, surface_kind: text):
        """Bind with an explicit UI_SURFACE_KIND_* value."""
        var filtered: [UiWindowSurfaceBinding] = []
        for entry in self.bindings:
            if entry.surface_id == surface_id or entry.window_id == window_id:
                pass_dn
            else:
                filtered = filtered.push(entry)
        filtered = filtered.push(UiWindowSurfaceBinding(
            surface_id: surface_id,
            window_id: window_id,
            process_id: process_id,
            app_id: app_id,
            title: title,
            surface_kind: surface_kind
        ))
        self.bindings = filtered

    me clear_surface(surface_id: text):
        var filtered: [UiWindowSurfaceBinding] = []
        for entry in self.bindings:
            if entry.surface_id == surface_id:
                pass_dn
            else:
                filtered = filtered.push(entry)
        self.bindings = filtered

    me clear_window(window_id: text):
        var filtered: [UiWindowSurfaceBinding] = []
        for entry in self.bindings:
            if entry.window_id == window_id:
                pass_dn
            else:
                filtered = filtered.push(entry)
        self.bindings = filtered

    fn for_surface(surface_id: text) -> UiWindowSurfaceBinding?:
        for entry in self.bindings:
            if entry.surface_id == surface_id:
                return entry
        return nil

    fn for_window(window_id: text) -> UiWindowSurfaceBinding?:
        for entry in self.bindings:
            if entry.window_id == window_id:
                return entry
        return nil

    fn window_id_for_surface(surface_id: text) -> text:
        val entry = self.for_surface(surface_id)
        if entry == nil:
            return ""
        return entry.window_id

    fn len() -> i32:
        self.bindings.len()

fn new_ui_window_surface_registry() -> UiWindowSurfaceRegistry:
    UiWindowSurfaceRegistry.new()
