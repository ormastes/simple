# Shared Draw IR contract for Simple 2D advanced rendering.
#
# This is a pure Simple boundary. GPU execution is deliberately deferred to
# backend plugins that consume these batches and report fallback decisions.

val DRAW_IR_SCHEMA_VERSION: text = "simple-draw-ir-v1"
val DRAW_IR_BACKEND_CPU: text = "cpu"
val DRAW_IR_BACKEND_GPU: text = "gpu"
val DRAW_IR_BACKEND_AUTO: text = "auto"
val DRAW_IR_COMMAND_RECT: text = "rect"
val DRAW_IR_COMMAND_TEXT: text = "text"
val DRAW_IR_SOURCE_MANUAL: text = "manual"
val DRAW_IR_SOURCE_GUI_AST: text = "gui_ast"
val DRAW_IR_SOURCE_HTML_AST: text = "html_ast"
val DRAW_IR_SOURCE_WM_SCENE: text = "wm_scene"

struct DrawIrEmbeddingConfig:
    surface_id: text
    component_id: text
    x: i32
    y: i32
    width: i32
    height: i32
    layer: i32
    opacity_milli: i32
    clip: bool

struct DrawIrCommand:
    kind: text
    component_id: text
    x: i32
    y: i32
    width: i32
    height: i32
    color: u32
    text_value: text

struct DrawIrSourceInfo:
    source_kind: text
    source_id: text
    html_tag: text
    html_node_id: text
    css_selector: text
    css_class: text
    style_key: text
    style_revision: text

struct DrawIrBatch:
    schema: text
    batch_id: text
    backend_target: text
    source: DrawIrSourceInfo
    embedding: DrawIrEmbeddingConfig
    commands: [DrawIrCommand]

struct DrawIrComposition:
    schema: text
    composition_id: text
    scene_key: text
    backend_target: text
    batches: [DrawIrBatch]

struct DrawIrEventTargetContext:
    schema: text
    composition_id: text
    scene_key: text
    input_key: text
    action: text
    target_id: text
    component_kind: text
    local_x: i32
    local_y: i32
    batch_local_x: i32
    batch_local_y: i32
    backend_target: text
    batch_id: text
    surface_id: text
    component_id: text
    source_kind: text
    resolved: bool
    stale_scene_rejected: bool

struct Simple2dDrawIrPlan:
    schema: text
    batch_id: text
    backend_target: text
    selected_backend: text
    command_count: i32
    width: i32
    height: i32
    layer: i32
    opacity_milli: i32
    fallback_required: bool
    fallback_reason: text

struct Simple2dDrawIrCompositionPlan:
    schema: text
    composition_id: text
    scene_key: text
    backend_target: text
    selected_backend: text
    batch_count: i32
    command_count: i32
    fallback_required: bool
    fallback_reason: text

fn draw_ir_embedding_config(surface_id: text, component_id: text, x: i32, y: i32, width: i32, height: i32, layer: i32, opacity_milli: i32, clip: bool) -> DrawIrEmbeddingConfig:
    DrawIrEmbeddingConfig(
        surface_id: surface_id,
        component_id: component_id,
        x: x,
        y: y,
        width: width,
        height: height,
        layer: layer,
        opacity_milli: opacity_milli,
        clip: clip
    )

fn draw_ir_rect(component_id: text, x: i32, y: i32, width: i32, height: i32, color: u32) -> DrawIrCommand:
    DrawIrCommand(
        kind: DRAW_IR_COMMAND_RECT,
        component_id: component_id,
        x: x,
        y: y,
        width: width,
        height: height,
        color: color,
        text_value: ""
    )

fn draw_ir_text(component_id: text, x: i32, y: i32, text_value: text, color: u32) -> DrawIrCommand:
    DrawIrCommand(
        kind: DRAW_IR_COMMAND_TEXT,
        component_id: component_id,
        x: x,
        y: y,
        width: 0,
        height: 0,
        color: color,
        text_value: text_value
    )

fn draw_ir_source_info(source_kind: text, source_id: text, html_tag: text, html_node_id: text, css_selector: text, css_class: text, style_key: text, style_revision: text) -> DrawIrSourceInfo:
    DrawIrSourceInfo(
        source_kind: source_kind,
        source_id: source_id,
        html_tag: html_tag,
        html_node_id: html_node_id,
        css_selector: css_selector,
        css_class: css_class,
        style_key: style_key,
        style_revision: style_revision
    )

fn draw_ir_source_manual() -> DrawIrSourceInfo:
    draw_ir_source_info(DRAW_IR_SOURCE_MANUAL, "", "", "", "", "", "", "")

fn draw_ir_source_gui_ast(source_id: text, style_key: text, style_revision: text) -> DrawIrSourceInfo:
    draw_ir_source_info(DRAW_IR_SOURCE_GUI_AST, source_id, "", "", "", "", style_key, style_revision)

fn draw_ir_source_html_ast(source_id: text, html_tag: text, html_node_id: text, css_selector: text, css_class: text, style_key: text, style_revision: text) -> DrawIrSourceInfo:
    draw_ir_source_info(DRAW_IR_SOURCE_HTML_AST, source_id, html_tag, html_node_id, css_selector, css_class, style_key, style_revision)

fn draw_ir_batch_with_source(batch_id: text, backend_target: text, embedding: DrawIrEmbeddingConfig, commands: [DrawIrCommand], source: DrawIrSourceInfo) -> DrawIrBatch:
    DrawIrBatch(
        schema: DRAW_IR_SCHEMA_VERSION,
        batch_id: batch_id,
        backend_target: backend_target,
        source: source,
        embedding: embedding,
        commands: commands
    )

fn draw_ir_batch(batch_id: text, backend_target: text, embedding: DrawIrEmbeddingConfig, commands: [DrawIrCommand]) -> DrawIrBatch:
    draw_ir_batch_with_source(batch_id, backend_target, embedding, commands, draw_ir_source_manual())

fn draw_ir_composition(composition_id: text, scene_key: text, backend_target: text, batches: [DrawIrBatch]) -> DrawIrComposition:
    DrawIrComposition(
        schema: DRAW_IR_SCHEMA_VERSION,
        composition_id: composition_id,
        scene_key: scene_key,
        backend_target: backend_target,
        batches: batches
    )

fn _draw_ir_event_backend_target(composition: DrawIrComposition, backend_target: text) -> text:
    if backend_target == "":
        return composition.backend_target
    backend_target

fn _draw_ir_batch_command_matches(batch: DrawIrBatch, target_id: text) -> bool:
    for command in batch.commands:
        if command.component_id == target_id:
            return true
    false

fn _draw_ir_batch_matches_event(batch: DrawIrBatch, target_id: text, component_kind: text) -> bool:
    if batch.batch_id == target_id or batch.embedding.surface_id == target_id or batch.embedding.component_id == target_id:
        return true
    if _draw_ir_batch_command_matches(batch, target_id):
        return true
    if component_kind == "desktop" and batch.embedding.component_id == "desktop":
        return true
    if component_kind == "command_lane" and batch.embedding.component_id == "wm-chrome":
        return true
    if component_kind == "taskbar" and batch.embedding.component_id == "wm-chrome":
        return true
    false

fn _draw_ir_unresolved_event_context(composition: DrawIrComposition, scene_key: text, input_key: text, action: text, target_id: text, component_kind: text, local_x: i32, local_y: i32, backend_target: text, stale_scene_rejected: bool) -> DrawIrEventTargetContext:
    DrawIrEventTargetContext(
        schema: composition.schema,
        composition_id: composition.composition_id,
        scene_key: scene_key,
        input_key: input_key,
        action: action,
        target_id: target_id,
        component_kind: component_kind,
        local_x: local_x,
        local_y: local_y,
        batch_local_x: local_x,
        batch_local_y: local_y,
        backend_target: _draw_ir_event_backend_target(composition, backend_target),
        batch_id: "",
        surface_id: "",
        component_id: "",
        source_kind: "",
        resolved: false,
        stale_scene_rejected: stale_scene_rejected
    )

fn _draw_ir_resolved_event_context(composition: DrawIrComposition, scene_key: text, input_key: text, action: text, target_id: text, component_kind: text, local_x: i32, local_y: i32, backend_target: text, batch: DrawIrBatch) -> DrawIrEventTargetContext:
    DrawIrEventTargetContext(
        schema: composition.schema,
        composition_id: composition.composition_id,
        scene_key: scene_key,
        input_key: input_key,
        action: action,
        target_id: target_id,
        component_kind: component_kind,
        local_x: local_x,
        local_y: local_y,
        batch_local_x: local_x,
        batch_local_y: local_y,
        backend_target: _draw_ir_event_backend_target(composition, backend_target),
        batch_id: batch.batch_id,
        surface_id: batch.embedding.surface_id,
        component_id: batch.embedding.component_id,
        source_kind: batch.source.source_kind,
        resolved: true,
        stale_scene_rejected: false
    )

fn draw_ir_event_target_context(composition: DrawIrComposition, scene_key: text, input_key: text, action: text, target_id: text, component_kind: text, local_x: i32, local_y: i32, backend_target: text) -> DrawIrEventTargetContext:
    if composition.scene_key != scene_key:
        return _draw_ir_unresolved_event_context(composition, scene_key, input_key, action, target_id, component_kind, local_x, local_y, backend_target, true)
    for batch in composition.batches:
        if _draw_ir_batch_matches_event(batch, target_id, component_kind):
            return _draw_ir_resolved_event_context(composition, scene_key, input_key, action, target_id, component_kind, local_x, local_y, backend_target, batch)
    _draw_ir_unresolved_event_context(composition, scene_key, input_key, action, target_id, component_kind, local_x, local_y, backend_target, false)

fn simple_2d_draw_ir_adv_plan(batch: DrawIrBatch, gpu_available: bool) -> Simple2dDrawIrPlan:
    var selected_backend = DRAW_IR_BACKEND_CPU
    var fallback_required = false
    var fallback_reason = ""
    if batch.backend_target == DRAW_IR_BACKEND_GPU:
        if gpu_available:
            selected_backend = DRAW_IR_BACKEND_GPU
        else:
            fallback_required = true
            fallback_reason = "gpu backend unavailable; using cpu fallback"
    elif batch.backend_target == DRAW_IR_BACKEND_AUTO:
        if gpu_available:
            selected_backend = DRAW_IR_BACKEND_GPU
        else:
            selected_backend = DRAW_IR_BACKEND_CPU
            fallback_reason = "auto selected cpu because gpu backend unavailable"
    else:
        selected_backend = DRAW_IR_BACKEND_CPU
    Simple2dDrawIrPlan(
        schema: batch.schema,
        batch_id: batch.batch_id,
        backend_target: batch.backend_target,
        selected_backend: selected_backend,
        command_count: batch.commands.len(),
        width: batch.embedding.width,
        height: batch.embedding.height,
        layer: batch.embedding.layer,
        opacity_milli: batch.embedding.opacity_milli,
        fallback_required: fallback_required,
        fallback_reason: fallback_reason
    )

fn _simple_2d_draw_ir_backend_selection(backend_target: text, gpu_available: bool) -> text:
    if backend_target == DRAW_IR_BACKEND_GPU:
        if gpu_available:
            return DRAW_IR_BACKEND_GPU
        return DRAW_IR_BACKEND_CPU
    if backend_target == DRAW_IR_BACKEND_AUTO:
        if gpu_available:
            return DRAW_IR_BACKEND_GPU
        return DRAW_IR_BACKEND_CPU
    DRAW_IR_BACKEND_CPU

fn _simple_2d_draw_ir_fallback_required(backend_target: text, gpu_available: bool) -> bool:
    backend_target == DRAW_IR_BACKEND_GPU and not gpu_available

fn _simple_2d_draw_ir_fallback_reason(backend_target: text, gpu_available: bool) -> text:
    if backend_target == DRAW_IR_BACKEND_GPU and not gpu_available:
        return "gpu backend unavailable; using cpu fallback"
    if backend_target == DRAW_IR_BACKEND_AUTO and not gpu_available:
        return "auto selected cpu because gpu backend unavailable"
    ""

fn simple_2d_draw_ir_adv_composition_plan(composition: DrawIrComposition, gpu_available: bool) -> Simple2dDrawIrCompositionPlan:
    var command_count = 0
    for batch in composition.batches:
        command_count = command_count + batch.commands.len()
    Simple2dDrawIrCompositionPlan(
        schema: composition.schema,
        composition_id: composition.composition_id,
        scene_key: composition.scene_key,
        backend_target: composition.backend_target,
        selected_backend: _simple_2d_draw_ir_backend_selection(composition.backend_target, gpu_available),
        batch_count: composition.batches.len(),
        command_count: command_count,
        fallback_required: _simple_2d_draw_ir_fallback_required(composition.backend_target, gpu_available),
        fallback_reason: _simple_2d_draw_ir_fallback_reason(composition.backend_target, gpu_available)
    )
