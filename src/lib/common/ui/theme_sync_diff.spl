# Theme Sync Diff — Token drift detection between two ParsedStitchDesignSystem
#
# Compares local and remote design system snapshots field by field.
# Produces a DriftReport containing DriftEntry records.
# ANSI-colored output: red for DRIFT, dim for ok fields.
# Exit-code convention: caller uses report.any_drift() to choose 0 or 2.

use common.ui.theme_sync_sdn.{ParsedStitchDesignSystem, ParsedStitchMetadata, ParsedStitchMd3Colors}

# =========================================================================
# DriftKind enum
# =========================================================================

enum DriftKind:
    Typography
    Shape
    ColorNamed
    ColorOverride
    Spacing
    Metadata

fn drift_kind_label(kind: DriftKind) -> text:
    if kind == DriftKind.Typography:
        return "TYPOGRAPHY"
    if kind == DriftKind.Shape:
        return "SHAPE"
    if kind == DriftKind.ColorNamed:
        return "COLOR (named)"
    if kind == DriftKind.ColorOverride:
        return "COLOR (overrides)"
    if kind == DriftKind.Spacing:
        return "SPACING"
    "METADATA"

# =========================================================================
# DriftEntry and DriftReport
# =========================================================================

class DriftEntry:
    kind: DriftKind
    field: text
    local_val: text
    remote_val: text
    is_drift: bool

class DriftReport:
    entries: [DriftEntry]

    static fn empty() -> DriftReport:
        DriftReport(entries: [])

    fn any_drift(self) -> bool:
        var i = 0
        while i < self.entries.len():
            if self.entries[i].is_drift:
                return true
            i = i + 1
        false

# =========================================================================
# Diff helpers
# =========================================================================

fn _check_field(kind: DriftKind, field: text, local_val: text, remote_val: text) -> DriftEntry:
    val is_drift = local_val != remote_val
    DriftEntry(kind: kind, field: field, local_val: local_val, remote_val: remote_val, is_drift: is_drift)

# =========================================================================
# Core diff engine
# =========================================================================

fn diff_stitch_design_systems(local_ds: ParsedStitchDesignSystem, remote_ds: ParsedStitchDesignSystem) -> DriftReport:
    """Compare two ParsedStitchDesignSystem instances field by field.
    Returns a DriftReport with all comparisons. Caller uses report.any_drift()."""
    var entries: [DriftEntry] = []

    val lm = local_ds.metadata
    val rm = remote_ds.metadata
    val lc = local_ds.md3
    val rc = remote_ds.md3

    # Metadata fields
    entries.push(_check_field(DriftKind.Metadata, "display_name", lm.display_name, rm.display_name))
    entries.push(_check_field(DriftKind.Metadata, "color_mode", lm.color_mode, rm.color_mode))
    entries.push(_check_field(DriftKind.Metadata, "color_variant", lm.color_variant, rm.color_variant))
    entries.push(_check_field(DriftKind.Metadata, "custom_color", lm.custom_color, rm.custom_color))

    # Shape fields
    entries.push(_check_field(DriftKind.Shape, "roundness", lm.roundness, rm.roundness))

    # Spacing fields
    entries.push(_check_field(DriftKind.Spacing, "spacing_scale", lm.spacing_scale, rm.spacing_scale))

    # Typography fields
    entries.push(_check_field(DriftKind.Typography, "font", lm.font, rm.font))
    entries.push(_check_field(DriftKind.Typography, "headline_font", lm.headline_font, rm.headline_font))
    entries.push(_check_field(DriftKind.Typography, "body_font", lm.body_font, rm.body_font))
    entries.push(_check_field(DriftKind.Typography, "label_font", lm.label_font, rm.label_font))

    # Color override fields
    entries.push(_check_field(DriftKind.ColorOverride, "override_primary_color", lm.override_primary_color, rm.override_primary_color))
    entries.push(_check_field(DriftKind.ColorOverride, "override_secondary_color", lm.override_secondary_color, rm.override_secondary_color))
    entries.push(_check_field(DriftKind.ColorOverride, "override_tertiary_color", lm.override_tertiary_color, rm.override_tertiary_color))
    entries.push(_check_field(DriftKind.ColorOverride, "override_neutral_color", lm.override_neutral_color, rm.override_neutral_color))

    # Named color fields (47 total, alphabetical)
    entries.push(_check_field(DriftKind.ColorNamed, "background", lc.background, rc.background))
    entries.push(_check_field(DriftKind.ColorNamed, "error", lc.error, rc.error))
    entries.push(_check_field(DriftKind.ColorNamed, "error_container", lc.error_container, rc.error_container))
    entries.push(_check_field(DriftKind.ColorNamed, "inverse_on_surface", lc.inverse_on_surface, rc.inverse_on_surface))
    entries.push(_check_field(DriftKind.ColorNamed, "inverse_primary", lc.inverse_primary, rc.inverse_primary))
    entries.push(_check_field(DriftKind.ColorNamed, "inverse_surface", lc.inverse_surface, rc.inverse_surface))
    entries.push(_check_field(DriftKind.ColorNamed, "on_background", lc.on_background, rc.on_background))
    entries.push(_check_field(DriftKind.ColorNamed, "on_error", lc.on_error, rc.on_error))
    entries.push(_check_field(DriftKind.ColorNamed, "on_error_container", lc.on_error_container, rc.on_error_container))
    entries.push(_check_field(DriftKind.ColorNamed, "on_primary", lc.on_primary, rc.on_primary))
    entries.push(_check_field(DriftKind.ColorNamed, "on_primary_container", lc.on_primary_container, rc.on_primary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "on_primary_fixed", lc.on_primary_fixed, rc.on_primary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "on_primary_fixed_variant", lc.on_primary_fixed_variant, rc.on_primary_fixed_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "on_secondary", lc.on_secondary, rc.on_secondary))
    entries.push(_check_field(DriftKind.ColorNamed, "on_secondary_container", lc.on_secondary_container, rc.on_secondary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "on_secondary_fixed", lc.on_secondary_fixed, rc.on_secondary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "on_secondary_fixed_variant", lc.on_secondary_fixed_variant, rc.on_secondary_fixed_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "on_surface", lc.on_surface, rc.on_surface))
    entries.push(_check_field(DriftKind.ColorNamed, "on_surface_variant", lc.on_surface_variant, rc.on_surface_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "on_tertiary", lc.on_tertiary, rc.on_tertiary))
    entries.push(_check_field(DriftKind.ColorNamed, "on_tertiary_container", lc.on_tertiary_container, rc.on_tertiary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "on_tertiary_fixed", lc.on_tertiary_fixed, rc.on_tertiary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "on_tertiary_fixed_variant", lc.on_tertiary_fixed_variant, rc.on_tertiary_fixed_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "outline", lc.outline, rc.outline))
    entries.push(_check_field(DriftKind.ColorNamed, "outline_variant", lc.outline_variant, rc.outline_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "primary", lc.primary, rc.primary))
    entries.push(_check_field(DriftKind.ColorNamed, "primary_container", lc.primary_container, rc.primary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "primary_fixed", lc.primary_fixed, rc.primary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "primary_fixed_dim", lc.primary_fixed_dim, rc.primary_fixed_dim))
    entries.push(_check_field(DriftKind.ColorNamed, "secondary", lc.secondary, rc.secondary))
    entries.push(_check_field(DriftKind.ColorNamed, "secondary_container", lc.secondary_container, rc.secondary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "secondary_fixed", lc.secondary_fixed, rc.secondary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "secondary_fixed_dim", lc.secondary_fixed_dim, rc.secondary_fixed_dim))
    entries.push(_check_field(DriftKind.ColorNamed, "surface", lc.surface, rc.surface))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_bright", lc.surface_bright, rc.surface_bright))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_container", lc.surface_container, rc.surface_container))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_container_high", lc.surface_container_high, rc.surface_container_high))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_container_highest", lc.surface_container_highest, rc.surface_container_highest))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_container_low", lc.surface_container_low, rc.surface_container_low))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_container_lowest", lc.surface_container_lowest, rc.surface_container_lowest))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_dim", lc.surface_dim, rc.surface_dim))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_tint", lc.surface_tint, rc.surface_tint))
    entries.push(_check_field(DriftKind.ColorNamed, "surface_variant", lc.surface_variant, rc.surface_variant))
    entries.push(_check_field(DriftKind.ColorNamed, "tertiary", lc.tertiary, rc.tertiary))
    entries.push(_check_field(DriftKind.ColorNamed, "tertiary_container", lc.tertiary_container, rc.tertiary_container))
    entries.push(_check_field(DriftKind.ColorNamed, "tertiary_fixed", lc.tertiary_fixed, rc.tertiary_fixed))
    entries.push(_check_field(DriftKind.ColorNamed, "tertiary_fixed_dim", lc.tertiary_fixed_dim, rc.tertiary_fixed_dim))

    DriftReport(entries: entries)

# =========================================================================
# ANSI formatting helpers
# =========================================================================

fn _ansi_red(s: text) -> text:
    "\x1b[31m{s}\x1b[0m"

fn _ansi_dim(s: text) -> text:
    "\x1b[2m{s}\x1b[0m"

fn _pad_right(s: text, width: i32) -> text:
    """Right-pad text with spaces to the given width."""
    var result = s
    var pad = width - s.len()
    while pad > 0:
        result = "{result} "
        pad = pad - 1
    result

# =========================================================================
# Report formatter
# =========================================================================

fn format_drift_report(report: DriftReport, color: bool) -> text:
    """Format a DriftReport as a human-readable text report.
    color=true enables ANSI escape codes (red for DRIFT, dim for ok)."""
    var drift_count = 0
    var j = 0
    while j < report.entries.len():
        if report.entries[j].is_drift:
            drift_count = drift_count + 1
        j = j + 1

    var out = ""
    if drift_count == 0:
        val msg = "No drift detected — local and remote are in sync.\n"
        if color:
            out = _ansi_dim(msg)
        else:
            out = msg
        return out

    out = "Drift detected: {drift_count} fields\n"

    # Group by DriftKind — print section header before first entry of each kind
    var last_kind_label = ""
    var i = 0
    while i < report.entries.len():
        val entry = report.entries[i]
        val kind_label = drift_kind_label(entry.kind)

        # Print section header when kind changes and at least one drift entry exists for this kind
        if kind_label != last_kind_label and entry.is_drift:
            out = "{out}  {kind_label}\n"
            last_kind_label = kind_label

        if entry.is_drift:
            val field_col = _pad_right(entry.field, 26)
            val local_col = _pad_right("local={entry.local_val}", 28)
            val remote_col = "remote={entry.remote_val}"
            val line = "    {field_col} {local_col} {remote_col}   [DRIFT]\n"
            if color:
                out = "{out}{_ansi_red(line)}"
            else:
                out = "{out}{line}"

        i = i + 1

    out
