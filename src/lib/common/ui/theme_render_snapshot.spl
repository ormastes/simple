# Renderer-neutral, immutable-by-convention theme material values.
#
# These values are shared by hosted package resolution and generated
# bare-metal themes. All hashes use fixed-order integer serialization so a
# backend cannot reinterpret CSS text and silently change the theme identity.

use std.common.crypto.sha256.{sha256_text}

class ThemeShadowLayer:
    offset_x_px: i32
    offset_y_px: i32
    blur_radius_px: i32
    spread_radius_px: i32
    rgba: u32
    inset: bool

class ThemeMaterialSemantics:
    desktop_fill_rgba: u32
    window_fill_rgba: u32
    active_title_fill_rgba: u32
    inactive_title_fill_rgba: u32
    surface_alpha_milli: i32
    backdrop_blur_px: i32
    backdrop_saturation_milli: i32
    border_width_px: i32
    border_rgba: u32
    corner_radius_px: i32
    active_shadows: [ThemeShadowLayer]
    inactive_shadows: [ThemeShadowLayer]
    font_family: text
    font_size_px: i32
    font_weight: i32
    text_rgba: u32
    secondary_text_rgba: u32
    solid_fallback_rgba: u32
    fallback_contrast_milli: i32

class ThemeRenderSnapshot:
    id: text
    family_id: text
    source_reference: text
    source_manifest_sha256: text
    material_sha256: text
    composed_css: text
    background_rgba: u32
    foreground_rgba: u32
    accent_rgba: u32
    material: ThemeMaterialSemantics

fn _normalized_shadow_text(prefix: text, shadows: [ThemeShadowLayer]) -> text:
    var out = "{prefix}.count={shadows.len()}\n"
    var index = 0
    for shadow in shadows:
        out = "{out}{prefix}.{index}.x={shadow.offset_x_px}\n"
        out = "{out}{prefix}.{index}.y={shadow.offset_y_px}\n"
        out = "{out}{prefix}.{index}.blur={shadow.blur_radius_px}\n"
        out = "{out}{prefix}.{index}.spread={shadow.spread_radius_px}\n"
        out = "{out}{prefix}.{index}.rgba={shadow.rgba}\n"
        out = "{out}{prefix}.{index}.inset={shadow.inset}\n"
        index = index + 1
    out

fn normalized_theme_material_text(material: ThemeMaterialSemantics) -> text:
    var out = "theme-material-v1\n"
    out = "{out}desktop_fill_rgba={material.desktop_fill_rgba}\n"
    out = "{out}window_fill_rgba={material.window_fill_rgba}\n"
    out = "{out}active_title_fill_rgba={material.active_title_fill_rgba}\n"
    out = "{out}inactive_title_fill_rgba={material.inactive_title_fill_rgba}\n"
    out = "{out}surface_alpha_milli={material.surface_alpha_milli}\n"
    out = "{out}backdrop_blur_px={material.backdrop_blur_px}\n"
    out = "{out}backdrop_saturation_milli={material.backdrop_saturation_milli}\n"
    out = "{out}border_width_px={material.border_width_px}\n"
    out = "{out}border_rgba={material.border_rgba}\n"
    out = "{out}corner_radius_px={material.corner_radius_px}\n"
    out = "{out}{_normalized_shadow_text(\"active_shadow\", material.active_shadows)}"
    out = "{out}{_normalized_shadow_text(\"inactive_shadow\", material.inactive_shadows)}"
    out = "{out}font_family={material.font_family}\n"
    out = "{out}font_size_px={material.font_size_px}\n"
    out = "{out}font_weight={material.font_weight}\n"
    out = "{out}text_rgba={material.text_rgba}\n"
    out = "{out}secondary_text_rgba={material.secondary_text_rgba}\n"
    out = "{out}solid_fallback_rgba={material.solid_fallback_rgba}\n"
    out = "{out}fallback_contrast_milli={material.fallback_contrast_milli}\n"
    out

fn theme_material_sha256(material: ThemeMaterialSemantics) -> text:
    sha256_text(normalized_theme_material_text(material))

export ThemeShadowLayer, ThemeMaterialSemantics, ThemeRenderSnapshot
export normalized_theme_material_text, theme_material_sha256
