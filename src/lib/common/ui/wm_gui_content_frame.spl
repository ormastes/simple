# GUI content-frame producer.
#
# Mirrors os.compositor.simple_web_window_renderer's Simple Web content-frame
# adapter, but for a GUI panel producer that already has rendered pixels in
# hand (no HTML render pipeline in between). Used to embed a GUI panel inside
# another GUI window's content frame ("rendering inside rendering", Lane C):
# GUI-in-GUI nesting, as a sibling of the web-in-GUI path
# (simple_web_child_content_frame_cached).

use common.ui.window_scene.{WM_CONTENT_ORIGIN_GUI, WmContentFrame, wm_content_frame_checksum}

# Builds a WmContentFrame with origin_kind WM_CONTENT_ORIGIN_GUI from an
# already-rendered ARGB pixel buffer. `parent_window_id` == "" means a
# top-level frame; a non-empty value stamps this frame as nested inside the
# named parent content frame at (offset_x, offset_y) within the parent's
# content rect. Uses the exact same checksum algorithm as the Simple Web
# adapter (common.ui.window_scene.wm_content_frame_checksum) so downstream
# validation (revision/checksum/size) treats every producer uniformly.
#
# Fails closed (checksum 0u64, empty pixels) on any invalid input — same
# reserved-zero-checksum contract as simple_web_content_frame_cached — rather
# than fabricating a frame the render executor would then have to guess about.
fn wm_gui_content_frame_from_pixels(window_id: text, parent_window_id: text, offset_x: i32, offset_y: i32, w: i32, h: i32, pixels: [u32], scene_revision: i64, content_revision: i64) -> WmContentFrame:
    if window_id.len() == 0 or scene_revision <= 0 or content_revision <= 0 or w <= 0 or h <= 0 or pixels.len() != w * h:
        return WmContentFrame(
            window_id: window_id,
            scene_revision: scene_revision,
            content_revision: content_revision,
            origin_kind: WM_CONTENT_ORIGIN_GUI,
            width: w,
            height: h,
            pixels: [],
            checksum: 0u64,
            parent_window_id: parent_window_id,
            offset_x: offset_x,
            offset_y: offset_y
        )
    WmContentFrame(
        window_id: window_id,
        scene_revision: scene_revision,
        content_revision: content_revision,
        origin_kind: WM_CONTENT_ORIGIN_GUI,
        width: w,
        height: h,
        pixels: pixels,
        checksum: wm_content_frame_checksum(pixels),
        parent_window_id: parent_window_id,
        offset_x: offset_x,
        offset_y: offset_y
    )
