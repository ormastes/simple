# Clipboard service — current entry + bounded HISTORY (ring), framework-level.
#
# Single source of truth used by both GUI and TUI backends (wired through
# common.ui.event / nogc_sync_mut.ui.session.UISession). Pure-Simple,
# arch-neutral: this module holds NO module-level array state (freestanding
# hazard — a module-level array initializer can require a static
# constructor to run before a kernel entry point exists). The ring lives in
# a `ClipboardService` instance field instead; callers own the instance
# (e.g. one per UISession) and construct it at runtime via `.new()`.
#
# The "sync to the host OS clipboard" behavior is an injectable seam: two
# function-pointer fields (`host_read` / `host_write`) installed via
# `install_host_bridge`. On a hosted desktop, the caller installs the SDL2
# desktop bridge (see nogc_sync_mut.desktop.clipboard); on SimpleOS there is
# no OS below the service, so the bridge is simply never installed and the
# service becomes its own "system clipboard".

use common.ui.capability.{Capability, NotSupported, has_capability}

struct ClipboardEntry:
    mime: text
    data: text
    # Monotonic sequence number (not wall-clock time — keeps this module
    # free of any host-time FFI dependency). Higher = more recent.
    seq: i64

fn _no_host_read() -> text:
    ""

fn _no_host_write(content: text) -> bool:
    false

class ClipboardService:
    # Most-recent-first bounded ring. history[0] is always the "current"
    # entry once non-empty.
    history: [ClipboardEntry]
    capacity: i32
    seq_counter: i64
    host_read: fn() -> text
    host_write: fn(text) -> bool
    host_sync: bool

    static fn new() -> ClipboardService:
        return ClipboardService.with_capacity(16)

    static fn with_capacity(capacity: i32) -> ClipboardService:
        var cap = capacity
        if cap < 1:
            cap = 1
        return ClipboardService(
            history: [],
            capacity: cap,
            seq_counter: 0,
            host_read: _no_host_read,
            host_write: _no_host_write,
            host_sync: false
        )

impl ClipboardService:

    # -- Host bridge (injectable seam) ---------------------------------------

    me install_host_bridge(read_fn: fn() -> text, write_fn: fn(text) -> bool):
        """Install the host-OS clipboard bridge. Until installed, the
        service is its own clipboard (no OS-level sync) — the SimpleOS case."""
        self.host_read = read_fn
        self.host_write = write_fn
        self.host_sync = true

    me sync_from_host():
        """Pull the live host clipboard into history if it changed since the
        last known entry. No-op when no host bridge is installed."""
        if not self.host_sync:
            return
        val live = self.host_read()
        if live == "":
            return
        if self.history.len() > 0 and self.history[0].data == live:
            return
        self._push_entry("text/plain", live)

    # -- Core ring operations -------------------------------------------------

    me _push_entry(mime: text, data: text) -> ClipboardEntry:
        self.seq_counter = self.seq_counter + 1
        val entry = ClipboardEntry(mime: mime, data: data, seq: self.seq_counter)
        var new_hist: [ClipboardEntry] = [entry]
        var i = 0
        while i < self.history.len() and new_hist.len() < self.capacity:
            new_hist = new_hist.push(self.history[i])
            i = i + 1
        self.history = new_hist
        return entry

    me copy(mime: text, data: text) -> ClipboardEntry:
        """Copy: push a new current entry onto the history ring."""
        val entry = self._push_entry(mime, data)
        if self.host_sync:
            self.host_write(data)
        return entry

    me cut(mime: text, data: text) -> ClipboardEntry:
        """Cut: same clipboard mechanics as copy. Callers are responsible
        for clearing the source selection/value before calling this."""
        return self.copy(mime, data)

    me paste() -> ClipboardEntry?:
        """Return the current entry (history[0]), or nil when empty."""
        if self.history.len() == 0:
            return nil
        return self.history[0]

    me paste_from_history(idx: i32) -> ClipboardEntry?:
        """Select a history entry by index (0 = current) and promote it to
        current (kill-ring / clipboard-manager semantics: selecting an older
        entry makes it the new current, moving it to the front). Returns nil
        for an out-of-range index."""
        if idx < 0 or idx >= self.history.len():
            return nil
        val entry = self.history[idx]
        if idx == 0:
            return entry
        var new_hist: [ClipboardEntry] = [entry]
        var i = 0
        while i < self.history.len():
            if i != idx:
                new_hist = new_hist.push(self.history[i])
            i = i + 1
        self.history = new_hist
        if self.host_sync:
            self.host_write(entry.data)
        return entry

    me history_entries() -> [ClipboardEntry]:
        return self.history

    me history_len() -> i32:
        return self.history.len()

    me clear():
        self.history = []
        self.seq_counter = 0

    # -- Capability-gated entry points ----------------------------------------

    me copy_gated(caps: [Capability], mime: text, data: text) -> Result<ClipboardEntry, NotSupported>:
        if not has_capability(caps, Capability.ClipboardWrite):
            return Err(NotSupported.for_capability("clipboard_copy", Capability.ClipboardWrite, "clipboard_service"))
        return Ok(self.copy(mime, data))

    me paste_gated(caps: [Capability]) -> Result<ClipboardEntry?, NotSupported>:
        if not has_capability(caps, Capability.ClipboardRead):
            return Err(NotSupported.for_capability("clipboard_paste", Capability.ClipboardRead, "clipboard_service"))
        return Ok(self.paste())

export ClipboardEntry, ClipboardService
