# UI Core Library - Re-exports
#
# Platform-independent UI framework.
# Use `common.ui.*` for new code; `app.ui.core.*` still works (shim).

# Types (widget.spl)
export WidgetKind, LayoutKind, UIMode, UIEvent
export WidgetNode, UITree, UIState, WidgetRect
export parse_widget_kind, parse_layout_kind

# Layout (layout.spl)
export compute_layout, find_rect

# Mode (mode.spl)
export switch_mode, resolve_keybinding, action_to_event

# Event (event.spl)
export process_event

# State (state.spl)
export init_state, init_state_with_mode, update_state, update_tree
export is_quit_event, is_quit_command

# Backend trait (backend.spl)
export RenderBackend

# Builder API (builder.spl)
export column, row, grid, panel, text_widget, label, input, button
export checkbox, dropdown, text_field, image, divider, dialog, tooltip
export progress, menubar, statusbar, tabs, list_widget
export build_tree, build_tree_with_title
export with_flex, with_width, with_height, with_visible

# Style/Theme (style.spl)
export ThemeColors, Spacing, BorderStyle, FontStyle, UITheme
export theme_to_css, AnsiTheme

# Tree Diffing (diff.spl)
export diff_trees

# Patch Types (patch.spl)
export PatchKind, UIPatch

# Reactive State (reactive.spl)
export ReactiveValue, ReactiveStore, ReactiveUI
