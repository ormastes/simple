use common.string_core.{str_char_at}

val UI_ACCESS_PROTOCOL_VERSION: i32 = 1
val UI_ACCESS_MAX_EVENTS: i32 = 64

struct UiAccessProp:
    key: text
    value: text

struct UiAccessNode:
    canonical_id: text
    surface_id: text
    widget_id: text
    kind: text
    visible: bool
    focused: bool
    enabled: bool
    selected: bool
    text_value: text
    props: [UiAccessProp]
    child_ids: [text]
    action_names: [text]

struct UiAccessSurface:
    surface_id: text
    title: text
    active: bool
    window_id: text
    app_id: text
    root_canonical_id: text

struct UiAccessEvent:
    surface_id: text
    widget_id: text
    canonical_id: text
    event_kind: text
    payload: text
    sequence: i64

struct UiAccessSnapshot:
    protocol_version: i32
    snapshot_revision: i64
    mode: text
    active_surface: text
    surfaces: [UiAccessSurface]
    nodes: [UiAccessNode]
    recent_events: [UiAccessEvent]

struct UiAccessQueryResult:
    nodes: [UiAccessNode]
    count: i32

struct UiAccessEnsureResult:
    ok: bool
    message: text
    node: UiAccessNode?

fn ui_access_canonical_id(surface_id: text, widget_id: text) -> text:
    if widget_id.contains("#"):
        return widget_id
    "{surface_id}#{widget_id}"

fn ui_access_surface_id_from_canonical(canonical_id: text) -> text:
    val idx = _access_find_char(canonical_id, "#")
    if idx <= 0:
        return ""
    canonical_id.substring(0, idx)

fn ui_access_widget_id_from_canonical(canonical_id: text) -> text:
    val idx = _access_find_char(canonical_id, "#")
    if idx < 0:
        return canonical_id
    canonical_id.substring(idx + 1)

fn _access_find_char(value: text, needle: text) -> i32:
    var i = 0
    while i < value.len():
        if str_char_at(value, i.to_i64()) == needle:
            return i
        i = i + 1
    -1
