# UI Access Protocol — shared types and constants
#
# Structs and constants used across all access_* modules.

val UI_ACCESS_PROTOCOL_VERSION = 1
val UI_ACCESS_MAX_EVENTS = 200

struct UiAccessProp:
    key: text
    value: text

struct UiAccessNode:
    canonical_id: text
    surface_id: text
    widget_id: text
    kind: text
    visible: bool
    focused: bool
    enabled: bool
    selected: bool
    text: text
    props: [UiAccessProp]
    child_ids: [text]
    action_names: [text]

struct UiAccessSurface:
    surface_id: text
    title: text
    active: bool
    window_id: text
    app_id: text
    root_canonical_id: text

struct UiAccessEvent:
    surface_id: text
    widget_id: text
    canonical_id: text
    event_kind: text
    payload: text
    sequence: i64

struct UiAccessSnapshot:
    protocol_version: i32
    snapshot_revision: u64
    mode: text
    active_surface: text
    surfaces: [UiAccessSurface]
    nodes: [UiAccessNode]
    recent_events: [UiAccessEvent]

struct UiAccessQueryResult:
    applied_limit: i32
    match_count: i32
    truncated: bool
    surfaces: [UiAccessSurface]
    nodes: [UiAccessNode]

struct UiAccessEnsureResult:
    expectation: text
    expected_value: text
    satisfied: bool
    query: UiAccessQueryResult

fn ui_access_canonical_id(surface_id: text, widget_id: text) -> text:
    return "{surface_id}#{widget_id}"

fn ui_access_surface_id_from_canonical(canonical_id: text) -> text:
    if canonical_id == "":
        return ""
    val idx = canonical_id.find("#")
    if idx < 0:
        return ""
    return canonical_id.slice(0, idx)

fn ui_access_widget_id_from_canonical(canonical_id: text) -> text:
    if canonical_id == "":
        return ""
    val idx = canonical_id.find("#")
    if idx < 0:
        return ""
    return canonical_id.slice(idx + 1, canonical_id.len())
