# Shared WM to Draw IR projection.
#
# Converts the window-manager scene into ordered Draw IR batches. This keeps
# window composition in pure Simple and leaves real GPU execution to later
# backend/plugin work.

use common.ui.draw_ir.{
    DRAW_IR_SOURCE_WM_SCENE,
    DrawIrBatch,
    DrawIrComposition,
    DrawIrSourceInfo,
    draw_ir_batch_with_source,
    draw_ir_box_with_style,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_group_command,
    draw_ir_rect,
    draw_ir_rect_bounds,
    draw_ir_source_info,
    draw_ir_style_prop,
    draw_ir_text
}
use common.ui.taskbar_model.{TaskbarModel}
use common.ui.window_scene.{
    SharedWmScene,
    SharedWmWindow,
    SharedWmRect,
    SharedWmRenderInput,
    SharedWmTaskbarRenderInput,
    WmRenderMetrics,
    WmContentFrame,
    BackgroundSurface,
    WM_CHROME_KIND_BORDERLESS,
    WM_CONTENT_ORIGIN_SIMPLE_WEB,
    WM_CONTENT_ORIGIN_GUI,
    shared_wm_scene_chrome,
    shared_wm_scene_layout_key,
    shared_wm_scene_resolve_background
}
use common.ui.wm_chrome_theme.{wm_chrome_theme, WmChromeColors}
use os.compositor.display_backend_core.{CompositorBackend}

val WM_DRAW_IR_COMPOSITION_ID: text = "wm-composite"
val WM_DRAW_IR_DESKTOP_SURFACE: text = "wm-desktop"
val WM_DRAW_IR_CHROME_SURFACE: text = "wm-chrome"

# Nested content-frame recursion cap (Lane C, "rendering inside rendering").
# Depth 1 is a direct child of a top-level window frame, depth 2 a
# grandchild, depth 3 a great-grandchild; deeper requests stop recursing
# instead of walking an unbounded (or accidentally cyclic) parent chain.
val WM_CONTENT_FRAME_MAX_NESTING_DEPTH: i32 = 3

fn _wm_draw_ir_source(source_id: text, style_key: text, style_revision: text) -> DrawIrSourceInfo:
    draw_ir_source_info(DRAW_IR_SOURCE_WM_SCENE, source_id, "", "", "", "", style_key, style_revision)

fn _wm_draw_ir_desktop_revision(scene: SharedWmScene) -> text:
    "wm.desktop:{scene.width}x{scene.height}"

fn _wm_draw_ir_chrome_revision(scene: SharedWmScene, taskbar: TaskbarModel, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    "wm.chrome:{scene.width}x{scene.height}:dpi={dpi_scale_milli}:clock={clock_label}:icons={right_icon_count}:pinned={taskbar.pinned.len()}:running={taskbar.running.len()}"

fn _wm_draw_ir_window_revision(window: SharedWmWindow) -> text:
    val focused = if window.focused: "1" else: "0"
    val minimized = if window.minimized: "1" else: "0"
    "wm.window:{window.window_id}:surface={window.surface_id}:xy={window.x},{window.y}:size={window.width}x{window.height}:z={window.z_index}:focused={focused}:minimized={minimized}:title={window.title}"

fn _wm_draw_ir_window_opacity(window: SharedWmWindow) -> i32:
    if window.focused:
        return 1000
    930

fn _wm_draw_ir_window_style(window: SharedWmWindow, part: text):
    [
        draw_ir_style_prop("source", "wm_scene"),
        draw_ir_style_prop("part", part),
        draw_ir_style_prop("z-index", "{window.z_index}"),
        draw_ir_style_prop("focused", if window.focused: "true" else: "false")
    ]

fn _wm_draw_ir_window_box(window: SharedWmWindow, component_id: text, part: text, x: i32, y: i32, width: i32, height: i32, color: u32):
    val border_rect = draw_ir_rect_bounds(x, y, width, height)
    val content_rect = draw_ir_rect_bounds(x, y, width, height)
    val hit_rect = draw_ir_rect_bounds(x, y, width, height)
    val clip_rect = draw_ir_rect_bounds(0, 0, window.width, window.height)
    val computed_style = _wm_draw_ir_window_style(window, part)
    draw_ir_box_with_style(
        component_id,
        x,
        y,
        width,
        height,
        color,
        border_rect,
        content_rect,
        hit_rect,
        clip_rect,
        computed_style
    )

fn _wm_draw_ir_min_i32(a: i32, b: i32) -> i32:
    if a < b:
        return a
    b

fn _wm_draw_ir_stable_sort_windows_by_z(windows: [SharedWmWindow], count: i32) -> [SharedWmWindow]:
    if count <= 1:
        return windows
    var source = windows
    var dest: [SharedWmWindow] = [windows[0]; count]
    var width = 1
    while width < count:
        var left_start = 0
        while left_start < count:
            val mid = _wm_draw_ir_min_i32(left_start + width, count)
            val right_end = _wm_draw_ir_min_i32(left_start + width + width, count)
            var left = left_start
            var right = mid
            var write = left_start
            while left < mid and right < right_end:
                if source[left].z_index <= source[right].z_index:
                    dest[write] = source[left]
                    left = left + 1
                else:
                    dest[write] = source[right]
                    right = right + 1
                write = write + 1
            while left < mid:
                dest[write] = source[left]
                left = left + 1
                write = write + 1
            while right < right_end:
                dest[write] = source[right]
                right = right + 1
                write = write + 1
            left_start = left_start + width + width
        source = dest
        width = width + width
        if width < count:
            dest = [source[0]; count]
    source

fn _wm_draw_ir_visible_windows_by_layer(scene: SharedWmScene) -> [SharedWmWindow]:
    var visible_count = 0
    var min_z = 0
    var max_z = 0
    var saw_visible = false
    for window in scene.windows:
        if not window.minimized:
            if not saw_visible:
                min_z = window.z_index
                max_z = window.z_index
                saw_visible = true
            elif window.z_index < min_z:
                min_z = window.z_index
            elif window.z_index > max_z:
                max_z = window.z_index
            visible_count = visible_count + 1
    if visible_count == 0:
        return []
    val z_span = max_z - min_z + 1
    if z_span > 0 and z_span <= visible_count * 4:
        var counts: [i32] = [0; z_span]
        for window in scene.windows:
            if not window.minimized:
                val bucket = window.z_index - min_z
                counts[bucket] = counts[bucket] + 1
        var running = 0
        var bucket_idx = 0
        while bucket_idx < z_span:
            val count = counts[bucket_idx]
            counts[bucket_idx] = running
            running = running + count
            bucket_idx = bucket_idx + 1
        var ordered_dense: [SharedWmWindow] = [scene.windows[0]; visible_count]
        for window in scene.windows:
            if not window.minimized:
                val bucket = window.z_index - min_z
                val write_idx = counts[bucket]
                ordered_dense[write_idx] = window
                counts[bucket] = write_idx + 1
        return ordered_dense
    var ordered: [SharedWmWindow] = [scene.windows[0]; visible_count]
    var ordered_count = 0
    for window in scene.windows:
        if not window.minimized:
            ordered[ordered_count] = window
            ordered_count = ordered_count + 1
    if ordered_count != visible_count:
        if ordered_count == 0:
            return []
        var compact: [SharedWmWindow] = [ordered[0]; ordered_count]
        var compact_idx = 0
        while compact_idx < ordered_count:
            compact[compact_idx] = ordered[compact_idx]
            compact_idx = compact_idx + 1
        return _wm_draw_ir_stable_sort_windows_by_z(compact, ordered_count)
    _wm_draw_ir_stable_sort_windows_by_z(ordered, ordered_count)

fn _wm_draw_ir_desktop_batch(scene: SharedWmScene, backend_target: text) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val embedding = draw_ir_embedding_config(WM_DRAW_IR_DESKTOP_SURFACE, "desktop", 0, 0, scene.width, scene.height, 0, 1000, false)
    draw_ir_batch_with_source(
        "wm-desktop",
        backend_target,
        embedding,
        [draw_ir_rect("desktop-background", 0, 0, scene.width, scene.height, theme.desktop_bg)],
        _wm_draw_ir_source("wm.desktop", "wm.desktop", _wm_draw_ir_desktop_revision(scene))
    )

fn _wm_draw_ir_chrome_batch(scene: SharedWmScene, taskbar: TaskbarModel, backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    val embedding = draw_ir_embedding_config(WM_DRAW_IR_CHROME_SURFACE, "wm-chrome", 0, 0, scene.width, scene.height, 1, 1000, false)
    draw_ir_batch_with_source(
        "wm-chrome",
        backend_target,
        embedding,
        [
            draw_ir_rect("command-lane", chrome.command_lane.x, chrome.command_lane.y, chrome.command_lane.width, chrome.command_lane.height, theme.command_lane),
            draw_ir_rect("taskbar", chrome.taskbar.x, chrome.taskbar.y, chrome.taskbar.width, chrome.taskbar.height, theme.taskbar),
            draw_ir_text("clock", scene.width - 64, chrome.command_lane.y + 21, clock_label, theme.text_primary)
        ],
        _wm_draw_ir_source("wm.chrome", "wm.chrome", _wm_draw_ir_chrome_revision(scene, taskbar, dpi_scale_milli, clock_label, right_icon_count))
    )

fn _wm_draw_ir_window_batch(window: SharedWmWindow, backend_target: text) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val embedding = draw_ir_embedding_config(window.surface_id, window.window_id, window.x, window.y, window.width, window.height, window.z_index + 10, _wm_draw_ir_window_opacity(window), true)
    val title_color = if window.focused: theme.title_focused else: theme.title_unfocused
    draw_ir_batch_with_source(
        "window-{window.window_id}",
        backend_target,
        embedding,
        [
            _wm_draw_ir_window_box(window, "{window.window_id}-shadow", "shadow", 4, 6, window.width, window.height, theme.window_shadow),
            _wm_draw_ir_window_box(window, "{window.window_id}-body", "body", 0, 0, window.width, window.height, theme.window_body),
            _wm_draw_ir_window_box(window, "{window.window_id}-titlebar", "titlebar", 0, 0, window.width, 28, title_color),
            draw_ir_text("{window.window_id}-title", 12, 19, window.title, theme.text_primary)
        ],
        _wm_draw_ir_source("wm.window.{window.window_id}", "wm.window", _wm_draw_ir_window_revision(window))
    )

# Sibling of _wm_draw_ir_window_batch for a nested content frame (Lane C,
# "rendering inside rendering"): a GUI-in-GUI or web-in-GUI child embedded in
# a parent content frame rather than a top-level SharedWmWindow. The
# embedding surface_id is the CHILD frame's own window_id (so downstream Draw
# IR consumers can address it as its own surface), while the single command
# carries parent_id so consumers can still walk the hierarchy up to the
# parent. draw_ir_group_command is used because DrawIrCommand has no
# raw-pixel-blit kind — content pixels are still delivered to the
# CompositorBackend directly (_shared_wm_render_child_content_frames below);
# this batch only threads the surface/parent relationship into Draw IR, it
# does not duplicate the pixel data.
fn _wm_draw_ir_child_content_frame_batch(frame: WmContentFrame, parent_window_id: text, backend_target: text) -> DrawIrBatch:
    val embedding = draw_ir_embedding_config(frame.window_id, frame.window_id, frame.offset_x, frame.offset_y, frame.width, frame.height, 0, 1000, true)
    draw_ir_batch_with_source(
        "content-{frame.window_id}",
        backend_target,
        embedding,
        [draw_ir_group_command(frame.window_id, parent_window_id)],
        _wm_draw_ir_source("wm.content.{frame.window_id}", "wm.content", "rev={frame.content_revision}")
    )

fn shared_wm_scene_draw_ir_composition(scene: SharedWmScene, taskbar: TaskbarModel, backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrComposition:
    val desktop_batch = _wm_draw_ir_desktop_batch(scene, backend_target)
    val windows = _wm_draw_ir_visible_windows_by_layer(scene)
    var batches: [DrawIrBatch] = [desktop_batch; windows.len() + 2]
    batches[0] = desktop_batch
    batches[1] = _wm_draw_ir_chrome_batch(scene, taskbar, backend_target, dpi_scale_milli, clock_label, right_icon_count)
    var batch_idx = 2
    for window in windows:
        if batch_idx >= batches.len():
            return draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, batches)
        batches[batch_idx] = _wm_draw_ir_window_batch(window, backend_target)
        batch_idx = batch_idx + 1
    if batch_idx != batches.len():
        if batch_idx == 0:
            return draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, [])
        var compact_batches: [DrawIrBatch] = [batches[0]; batch_idx]
        var compact_batch_idx = 0
        while compact_batch_idx < batch_idx:
            compact_batches[compact_batch_idx] = batches[compact_batch_idx]
            compact_batch_idx = compact_batch_idx + 1
        return draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, compact_batches)
    draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, batches)

# Recursively collects Draw IR batches for the content frames nested under
# `parent_id` (parent_window_id == parent_id), one batch per child via
# _wm_draw_ir_child_content_frame_batch, then recurses into each child's own
# children up to WM_CONTENT_FRAME_MAX_NESTING_DEPTH — mirroring
# _shared_wm_render_child_content_frames's traversal, but for Draw IR
# projection instead of direct-to-backend pixels.
fn _wm_draw_ir_child_content_batches_recursive(content_frames: [WmContentFrame], parent_id: text, backend_target: text, depth: i32) -> [DrawIrBatch]:
    if depth > WM_CONTENT_FRAME_MAX_NESTING_DEPTH:
        return []
    var out: [DrawIrBatch] = []
    for frame in content_frames:
        if frame.parent_window_id == parent_id:
            out.push(_wm_draw_ir_child_content_frame_batch(frame, parent_id, backend_target))
            for nested in _wm_draw_ir_child_content_batches_recursive(content_frames, frame.window_id, backend_target, depth + 1):
                out.push(nested)
    out

# Content-aware sibling of shared_wm_scene_draw_ir_composition: same
# desktop/chrome/window batches (top-level behavior unchanged — this simply
# builds on the existing composition), plus one additional batch per nested
# content frame so downstream Draw IR consumers see the "rendering inside
# rendering" hierarchy (child surface_id + parent_id). A scene with no
# nested content frames produces byte-identical batches to
# shared_wm_scene_draw_ir_composition.
fn shared_wm_scene_draw_ir_composition_with_content(scene: SharedWmScene, taskbar: TaskbarModel, content_frames: [WmContentFrame], backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrComposition:
    val base = shared_wm_scene_draw_ir_composition(scene, taskbar, backend_target, dpi_scale_milli, clock_label, right_icon_count)
    if content_frames.len() == 0:
        return base
    var batches: [DrawIrBatch] = base.batches
    for window in scene.windows:
        if not window.minimized:
            for child_batch in _wm_draw_ir_child_content_batches_recursive(content_frames, window.window_id, backend_target, 1):
                batches.push(child_batch)
    draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, batches)

# =========================================================================
# Taskbar item geometry (pure math)
#
# Single source of truth for taskbar dock/item layout. Historically lived in
# os.compositor.wm_action_applier; moved here so the backend-neutral
# SharedWmScene executor below can compute taskbar item bounds without a
# common.ui -> os dependency. os.compositor.wm_action_applier re-exports
# these under the same names so its existing callers are unaffected.
# =========================================================================

fn wm_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    val available = screen_width - 80
    val fit = available / count
    if fit < 104: fit else: 104

fn wm_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    wm_taskbar_item_width(screen_width, count) * count + 20

fn wm_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    val dock_w = wm_taskbar_dock_width(screen_width, count)
    val start = (screen_width - dock_w) / 2 + 10
    start + index * wm_taskbar_item_width(screen_width, count)

fn shared_wm_taskbar_object_rect(metrics: WmRenderMetrics, screen_width: i32, screen_height: i32, index: i32) -> SharedWmRect:
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    SharedWmRect(x: index * slot_w, y: screen_height - taskbar_h, width: slot_w, height: taskbar_h)

fn shared_wm_taskbar_tray_object_rect(metrics: WmRenderMetrics, screen_width: i32, screen_height: i32, reverse_index: i32) -> SharedWmRect:
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    SharedWmRect(x: screen_width - (reverse_index + 2) * slot_w, y: screen_height - taskbar_h, width: slot_w, height: taskbar_h)

# =========================================================================
# SharedWmScene -> CompositorBackend executor
#
# Renders a SharedWmScene (as built by common.ui.window_scene, e.g. via
# simple_gui_internal_window_scene) directly against a backend-neutral
# CompositorBackend draw target: desktop/command-lane/taskbar chrome, then
# each visible window's chrome (titled only; borderless windows render as
# pure content surfaces per chrome_kind) + app content, then the taskbar
# item row. os.compositor.shared_mdi_framebuffer_scene.spl is glue: it builds
# a SharedWmScene and calls shared_wm_scene_render_to_backend — it no longer
# owns chrome/content/taskbar pixel-drawing logic itself. Both the host WM
# capture-evidence lane and the SimpleOS QEMU fullscreen lane call that same
# glue, so they share this exact render model; only backend/config differs.
# =========================================================================

struct SharedWmSceneRenderStats:
    content_pixel_count: i64

# Deprecated compatibility data for the title-derived canned app-content
# renderer only. Production chrome and taskbar text must use backend.draw_text.
fn _shared_wm_scene_legacy_content_ascii_codes(value: text) -> [i32]:
    if value == "Terminal": return [84, 101, 114, 109, 105, 110, 97, 108]
    if value == "Editor": return [69, 100, 105, 116, 111, 114]
    if value == "Browser": return [66, 114, 111, 119, 115, 101, 114]
    if value == "File Manager": return [70, 105, 108, 101, 32, 77, 97, 110, 97, 103, 101, 114]
    if value == "Calculator": return [67, 97, 108, 99, 117, 108, 97, 116, 111, 114]
    if value == "X": return [88]
    if value == "$ simple$ build check --live": return [36, 32, 115, 105, 109, 112, 108, 101, 36, 32, 98, 117, 105, 108, 100, 32, 99, 104, 101, 99, 107, 32, 45, 45, 108, 105, 118, 101]
    if value == "src/ test/ main.spl": return [115, 114, 99, 47, 32, 116, 101, 115, 116, 47, 32, 109, 97, 105, 110, 46, 115, 112, 108]
    if value == "SimpleOS shell via Simple Web": return [83, 105, 109, 112, 108, 101, 79, 83, 32, 115, 104, 101, 108, 108, 32, 118, 105, 97, 32, 83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "main.spl": return [109, 97, 105, 110, 46, 115, 112, 108]
    if value == "fn main():": return [102, 110, 32, 109, 97, 105, 110, 40, 41, 58]
    if value == "    print Hello SimpleOS": return [32, 32, 32, 32, 112, 114, 105, 110, 116, 32, 72, 101, 108, 108, 111, 32, 83, 105, 109, 112, 108, 101, 79, 83]
    if value == "# rendered by Simple Web": return [35, 32, 114, 101, 110, 100, 101, 114, 101, 100, 32, 98, 121, 32, 83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "/home/simple": return [47, 104, 111, 109, 101, 47, 115, 105, 109, 112, 108, 101]
    if value == "Desktop": return [68, 101, 115, 107, 116, 111, 112]
    if value == "Documents": return [68, 111, 99, 117, 109, 101, 110, 116, 115]
    if value == "Downloads": return [68, 111, 119, 110, 108, 111, 97, 100, 115]
    if value == "state: home": return [115, 116, 97, 116, 101, 58, 32, 104, 111, 109, 101]
    if value == "0": return [48]
    if value == "7 8 9 /": return [55, 32, 56, 32, 57, 32, 47]
    if value == "4 5 6 *": return [52, 32, 53, 32, 54, 32, 42]
    if value == "1 2 3 -": return [49, 32, 50, 32, 51, 32, 45]
    if value == "about:network": return [97, 98, 111, 117, 116, 58, 110, 101, 116, 119, 111, 114, 107]
    if value == "Simple Web": return [83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "GET /status 200": return [71, 69, 84, 32, 47, 115, 116, 97, 116, 117, 115, 32, 50, 48, 48]
    if value == "Simple Web app surface": return [83, 105, 109, 112, 108, 101, 32, 87, 101, 98, 32, 97, 112, 112, 32, 115, 117, 114, 102, 97, 99, 101]
    []

fn _draw_shared_wm_scene_text_fit(backend: CompositorBackend, x: i32, y: i32, text_value: text, fg: u32, bg: u32, max_chars: i32):
    val codes = _shared_wm_scene_legacy_content_ascii_codes(text_value)
    var count = codes.len()
    if max_chars > 0 and count > max_chars:
        count = max_chars
    var i = 0
    var cx = x
    while i < count:
        backend.draw_char_8x16(cx, y, codes[i].to_u8(), fg, bg)
        cx = cx + 12
        i = i + 1

fn _draw_shared_wm_backend_text_fit(backend: CompositorBackend, x: i32, y: i32, text_value: text, fg: u32, bg: u32, max_chars: i32):
    if max_chars <= 0 or text_value.len() <= 0:
        return
    val bounded = if text_value.len() > max_chars: text_value.slice(0, max_chars) else: text_value
    backend.draw_text(x, y, bounded, fg, bg)

fn shared_wm_scene_render_desktop_chrome(backend: CompositorBackend, width: i32, height: i32, theme: WmChromeColors, background_color: u32, background_surface: BackgroundSurface? = nil, top_lane_height: i32 = 44, taskbar_height: i32 = 56):
    if val surface = background_surface:
        backend.blit_pixels(0, 0, surface.width, surface.height, surface.pixels)
    else:
        backend.clear(background_color)
    val top_h = if top_lane_height > 0: top_lane_height else: 44
    val taskbar_h = if taskbar_height > 0: taskbar_height else: 56
    backend.fill_rect(0, 0, width, top_h, theme.command_lane)
    backend.fill_rect(0, top_h - 2, width, 2, theme.accent)
    backend.fill_rect(0, height - taskbar_h, width, taskbar_h, theme.taskbar)
    backend.fill_rect(0, height - taskbar_h, width, 2, theme.accent)

fn shared_wm_scene_draw_window_chrome(backend: CompositorBackend, window: SharedWmWindow, theme: WmChromeColors):
    if window.minimized:
        return
    val title_color = if window.focused: theme.accent else: theme.title_unfocused
    backend.fill_rect(window.x + 5, window.y + 6, window.width, window.height, theme.window_shadow)
    backend.fill_rect(window.x, window.y, window.width, window.height, theme.host_window_body)
    backend.fill_rect(window.x, window.y, window.width, 28, title_color)
    backend.fill_rect(window.x + 12, window.y + 9, 10, 10, 0xFFE74C3Cu32)
    backend.fill_rect(window.x + 30, window.y + 9, 10, 10, 0xFFF1C40Fu32)
    backend.fill_rect(window.x + 48, window.y + 9, 10, 10, 0xFF27AE60u32)
    _draw_shared_wm_backend_text_fit(backend, window.x + 66, window.y + 6, window.title, theme.text_primary, title_color, if window.width > 92: (window.width - 92) / 8 else: 0)
    backend.fill_rect(window.x + window.width - 24, window.y + 2, 20, 20, theme.close_button)
    _draw_shared_wm_backend_text_fit(backend, window.x + window.width - 18, window.y + 4, "X", theme.text_primary, theme.close_button, 1)

fn shared_wm_scene_render_taskbar(backend: CompositorBackend, windows: [SharedWmWindow], width: i32, height: i32, theme: WmChromeColors):
    val count = windows.len()
    if count <= 0:
        return
    val dock_w = wm_taskbar_dock_width(width, count)
    val dock_x = (width - dock_w) / 2
    val dock_y = height - 62
    val item_w = wm_taskbar_item_width(width, count)
    backend.fill_rect(dock_x, dock_y, dock_w, 44, theme.taskbar)
    var i = 0
    while i < count:
        val win = windows[i]
        val ix = wm_taskbar_item_x(width, count, i)
        var item_color = theme.title_unfocused
        if win.focused and not win.minimized:
            item_color = theme.accent
        elif win.minimized:
            item_color = theme.host_window_body
        backend.fill_rect(ix + 2, dock_y + 4, item_w - 4, 36, item_color)
        _draw_shared_wm_backend_text_fit(backend, ix + 8, dock_y + 14, win.title, theme.text_primary, item_color, if item_w > 16: (item_w - 16) / 8 else: 0)
        i = i + 1

fn shared_wm_scene_render_taskbar_model(backend: CompositorBackend, taskbar: TaskbarModel, width: i32, height: i32, theme: WmChromeColors, metrics: WmRenderMetrics, clock_label: text):
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    val taskbar_y = height - taskbar_h
    # Desktop chrome owns the single taskbar background/accent pass. This
    # function adds only authoritative taskbar objects.
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val reserved_right = (taskbar.tray.len() + 1) * slot_w
    val object_limit = width - reserved_right
    var object_index = 0
    for app in taskbar.pinned:
        val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.title_unfocused)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, app.display_name, theme.text_primary, theme.title_unfocused, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        object_index = object_index + 1
    for window in taskbar.running:
        val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            val color = if window.minimized: theme.host_window_body else: theme.accent
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, color)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, window.title, theme.text_primary, color, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        object_index = object_index + 1
    var tray_index = 0
    for tray in taskbar.tray:
        val rect = shared_wm_taskbar_tray_object_rect(metrics, width, height, tray_index)
        if rect.x >= 0 and rect.x + rect.width <= width - slot_w:
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.host_window_body)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, tray.label, theme.text_primary, theme.host_window_body, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        tray_index = tray_index + 1
    if width >= slot_w:
        _draw_shared_wm_backend_text_fit(backend, width - slot_w + 4, taskbar_y + 14, clock_label, theme.text_primary, theme.taskbar, if slot_w > 8: (slot_w - 8) / 8 else: 0)

fn _shared_wm_scene_content_line(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, line_index: i32, text_value: text, fg: u32, bg: u32):
    val y = cy + 34 + line_index * 22
    _draw_shared_wm_scene_text_fit(backend, cx + 10, y, text_value, fg, bg, if cw > 20: (cw - 20) / 12 else: 0)

fn shared_wm_scene_render_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    if cw <= 0 or ch <= 0:
        return
    val bg = 0xFF182230u32
    val header = 0xFF2050A0u32
    val text_primary = 0xFFE5E7EBu32
    val accent = 0xFF2563EBu32
    val success = 0xFF22C55Eu32
    val warning = 0xFFF59E0Bu32
    val muted = 0xFF94A3B8u32
    backend.fill_rect(cx, cy, cw, ch, bg)
    backend.fill_rect(cx, cy, cw, 24, header)
    _draw_shared_wm_scene_text_fit(backend, cx + 8, cy + 4, title, text_primary, header, if cw > 16: (cw - 16) / 12 else: 0)
    if title == "Terminal":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "$ " + state_text, success, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "src/ test/ main.spl", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "SimpleOS shell via Simple Web", success, bg)
        return
    if title == "Editor" or title == "Hello World":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "main.spl", muted, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "fn main():", warning, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "    print Hello SimpleOS", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "# rendered by Simple Web", success, bg)
        return
    if title == "File Manager" or title == "Finder":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "/home/simple", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "Desktop", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "Documents", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "Downloads", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 4, "state: " + state_text, muted, bg)
        return
    if title == "Calculator":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "0", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "7 8 9 /", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "4 5 6 *", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "1 2 3 -", text_primary, bg)
        return
    if title == "Browser" or title == "Simple Browser":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "about:network", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "Simple Web", success, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "GET /status 200", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, state_text, muted, bg)
        return
    _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "Simple Web app surface", text_primary, bg)

fn _shared_wm_scene_window_content_rect(window: SharedWmWindow) -> SharedWmRect:
    if window.chrome_kind == WM_CHROME_KIND_BORDERLESS:
        return SharedWmRect(x: window.x, y: window.y, width: window.width, height: window.height)
    SharedWmRect(x: window.x + 4, y: window.y + 32, width: window.width - 8, height: window.height - 36)

fn _shared_wm_scene_window_content_pixel_count(window: SharedWmWindow) -> i64:
    if window.minimized:
        return 0
    val content = _shared_wm_scene_window_content_rect(window)
    if content.width > 0 and content.height > 0:
        return content.width.to_i64() * content.height.to_i64()
    0

# Content frames may originate from the Simple Web adapter or from a GUI
# panel producer (common.ui.wm_gui_content_frame) — both are legitimate,
# fail-closed-validated content sources; anything else is rejected the same
# way an unknown background kind is rejected (loud, no silent fallback).
fn _wm_content_frame_origin_valid(origin_kind: text) -> bool:
    origin_kind == WM_CONTENT_ORIGIN_SIMPLE_WEB or origin_kind == WM_CONTENT_ORIGIN_GUI

fn _shared_wm_content_frame_for_window(input: SharedWmRenderInput, window: SharedWmWindow) -> WmContentFrame?:
    var found: WmContentFrame? = nil
    var matching_count = 0
    for frame in input.content_frames:
        if frame.window_id == window.window_id and frame.parent_window_id == "":
            matching_count = matching_count + 1
            val content = _shared_wm_scene_window_content_rect_with_titlebar(window, input.metrics.titlebar_height)
            val valid = input.revision.scene_revision > 0 and _wm_content_frame_origin_valid(frame.origin_kind) and frame.scene_revision == input.revision.scene_revision and frame.content_revision > 0 and frame.checksum > 0u64 and frame.width == content.width and frame.height == content.height and frame.width > 0 and frame.height > 0 and frame.pixels.len() == frame.width * frame.height
            if valid:
                found = frame
    if matching_count == 1:
        return found
    nil

# Geometry-only rect intersection (no pixel data): used both by the pixel-crop
# helper below and by the fail-closed magenta path, which needs the clipped
# rect but never touches pixel data for an invalid child.
fn _wm_rect_intersect(x: i32, y: i32, w: i32, h: i32, clip_rect: SharedWmRect) -> SharedWmRect:
    val clip_x1 = clip_rect.x + clip_rect.width
    val clip_y1 = clip_rect.y + clip_rect.height
    val x1 = x + w
    val y1 = y + h
    val out_x0 = if x > clip_rect.x: x else: clip_rect.x
    val out_y0 = if y > clip_rect.y: y else: clip_rect.y
    val out_x1 = if x1 < clip_x1: x1 else: clip_x1
    val out_y1 = if y1 < clip_y1: y1 else: clip_y1
    val out_w = out_x1 - out_x0
    val out_h = out_y1 - out_y0
    if out_w <= 0 or out_h <= 0:
        return SharedWmRect(x: out_x0, y: out_y0, width: 0, height: 0)
    SharedWmRect(x: out_x0, y: out_y0, width: out_w, height: out_h)

struct WmClippedPixelRect:
    dest_x: i32
    dest_y: i32
    width: i32
    height: i32
    pixels: [u32]

# Pure helper: crops a [u32] row-major pixel buffer (drawn at dest_x/dest_y,
# src_w x src_h) to its intersection with clip_rect, returning the cropped
# buffer plus the destination position to blit it at. CompositorBackend has
# no clip primitive of its own (display_backend.spl:9), so nested content
# frames that extend past their parent's content rect are clipped here,
# before blit_pixels, rather than needing a new backend method. Callers must
# check width/height > 0 before blitting (zero-area intersection is a no-op).
fn _wm_content_frame_clip_to_rect(pixels: [u32], src_w: i32, src_h: i32, dest_x: i32, dest_y: i32, clip_rect: SharedWmRect) -> WmClippedPixelRect:
    val out_rect = _wm_rect_intersect(dest_x, dest_y, src_w, src_h, clip_rect)
    if out_rect.width <= 0 or out_rect.height <= 0:
        return WmClippedPixelRect(dest_x: out_rect.x, dest_y: out_rect.y, width: 0, height: 0, pixels: [])
    val crop_src_x = out_rect.x - dest_x
    val crop_src_y = out_rect.y - dest_y
    var cropped: [u32] = [0u32; out_rect.width * out_rect.height]
    var row = 0
    while row < out_rect.height:
        val src_row = crop_src_y + row
        val src_row_start = src_row * src_w + crop_src_x
        val dst_row_start = row * out_rect.width
        var col = 0
        while col < out_rect.width:
            cropped[dst_row_start + col] = pixels[src_row_start + col]
            col = col + 1
        row = row + 1
    WmClippedPixelRect(dest_x: out_rect.x, dest_y: out_rect.y, width: out_rect.width, height: out_rect.height, pixels: cropped)

# Recursively renders the content frames nested under `parent_id`
# (parent_window_id == parent_id), clipped to `parent_rect` (the immediate
# parent's own content rect), then recurses into each child's own children
# (grandchildren etc.) up to WM_CONTENT_FRAME_MAX_NESTING_DEPTH. A valid
# child is blitted (cropped to the parent rect); an invalid child (bad
# revision/checksum/size) is fail-closed magenta-filled over its own rect
# (also cropped to the parent rect) instead of drawing stale/fabricated
# pixels — mirroring _shared_wm_content_frame_for_window's fail-closed
# contract for top-level frames. Returns the pixel count actually blitted
# (valid children only) so callers can fold it into SharedWmSceneRenderStats.
fn _shared_wm_render_child_content_frames(backend: CompositorBackend, input: SharedWmRenderInput, parent_id: text, parent_rect: SharedWmRect, depth: i32) -> i64:
    if depth > WM_CONTENT_FRAME_MAX_NESTING_DEPTH:
        return 0
    var content_pixel_count: i64 = 0
    for frame in input.content_frames:
        if frame.parent_window_id == parent_id:
            val child_x = parent_rect.x + frame.offset_x
            val child_y = parent_rect.y + frame.offset_y
            val valid = input.revision.scene_revision > 0 and _wm_content_frame_origin_valid(frame.origin_kind) and frame.scene_revision == input.revision.scene_revision and frame.content_revision > 0 and frame.checksum > 0u64 and frame.width > 0 and frame.height > 0 and frame.pixels.len() == frame.width * frame.height
            if valid:
                val clipped = _wm_content_frame_clip_to_rect(frame.pixels, frame.width, frame.height, child_x, child_y, parent_rect)
                if clipped.width > 0 and clipped.height > 0:
                    backend.blit_pixels(clipped.dest_x, clipped.dest_y, clipped.width, clipped.height, clipped.pixels)
                    content_pixel_count = content_pixel_count + (clipped.width.to_i64() * clipped.height.to_i64())
                val child_rect = SharedWmRect(x: child_x, y: child_y, width: frame.width, height: frame.height)
                content_pixel_count = content_pixel_count + _shared_wm_render_child_content_frames(backend, input, frame.window_id, child_rect, depth + 1)
            else:
                print("shared_wm_scene_render_context_to_backend: rejecting missing, stale, or invalid nested content frame for window '{frame.window_id}' (parent '{parent_id}')")
                val fail_rect = _wm_rect_intersect(child_x, child_y, frame.width, frame.height, parent_rect)
                if fail_rect.width > 0 and fail_rect.height > 0:
                    backend.fill_rect(fail_rect.x, fail_rect.y, fail_rect.width, fail_rect.height, 0xFFFF00FFu32)
    content_pixel_count

fn _shared_wm_scene_window_content_rect_with_titlebar(window: SharedWmWindow, titlebar_height: i32) -> SharedWmRect:
    if window.chrome_kind == WM_CHROME_KIND_BORDERLESS:
        return SharedWmRect(x: window.x, y: window.y, width: window.width, height: window.height)
    val title_h = if titlebar_height > 0: titlebar_height else: 28
    SharedWmRect(x: window.x + 4, y: window.y + title_h + 4, width: window.width - 8, height: window.height - title_h - 8)

# Rich content-frame executor. Unlike the compatibility API below, this path
# never substitutes canned title-based content for a missing or stale frame.
fn _shared_wm_scene_render_context_content_to_backend(backend: CompositorBackend, input: SharedWmRenderInput) -> SharedWmSceneRenderStats:
    val scene = input.scene
    val theme = wm_chrome_theme()
    val resolved_background = shared_wm_scene_resolve_background(scene.background, scene.width, scene.height, input.t_micros)
    shared_wm_scene_render_desktop_chrome(backend, scene.width, scene.height, theme, resolved_background.color, resolved_background.surface, input.metrics.top_lane_height, input.metrics.taskbar_height)
    var content_pixel_count: i64 = 0
    for window in scene.windows:
        if not window.minimized:
            if window.chrome_kind != WM_CHROME_KIND_BORDERLESS:
                shared_wm_scene_draw_window_chrome(backend, window, theme)
            val content = _shared_wm_scene_window_content_rect_with_titlebar(window, input.metrics.titlebar_height)
            if val frame = _shared_wm_content_frame_for_window(input, window):
                backend.blit_pixels(content.x, content.y, frame.width, frame.height, frame.pixels)
                content_pixel_count = content_pixel_count + frame.pixels.len().to_i64()
                content_pixel_count = content_pixel_count + _shared_wm_render_child_content_frames(backend, input, window.window_id, content, 1)
            else:
                print("shared_wm_scene_render_context_to_backend: rejecting missing, stale, or invalid Simple Web frame for window '{window.window_id}'")
                backend.fill_rect(content.x, content.y, content.width, content.height, 0xFFFF00FFu32)
    SharedWmSceneRenderStats(content_pixel_count: content_pixel_count)

fn shared_wm_scene_render_context_to_backend(backend: CompositorBackend, input: SharedWmRenderInput) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_context_content_to_backend(backend, input)
    val scene = input.scene
    shared_wm_scene_render_taskbar(backend, scene.windows, scene.width, scene.height, wm_chrome_theme())
    stats

# Authoritative rich executor. The final taskbar pass consumes TaskbarModel
# objects directly; it never derives pinned, running, tray, or clock objects
# from window titles.
fn shared_wm_scene_render_taskbar_context_to_backend(backend: CompositorBackend, input: SharedWmTaskbarRenderInput) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_context_content_to_backend(backend, input.render)
    val scene = input.render.scene
    shared_wm_scene_render_taskbar_model(backend, input.taskbar, scene.width, scene.height, wm_chrome_theme(), input.render.metrics, input.clock_label)
    stats

# `t_micros` (default 0) is only consumed by a kind:"motion" background (see
# shared_wm_scene_resolve_background); every existing caller that never sets
# a motion background is unaffected by the new trailing param.
fn _shared_wm_scene_render_compat_content_to_backend(backend: CompositorBackend, scene: SharedWmScene, t_micros: i64 = 0) -> SharedWmSceneRenderStats:
    val theme = wm_chrome_theme()
    val resolved_background = shared_wm_scene_resolve_background(scene.background, scene.width, scene.height, t_micros)
    shared_wm_scene_render_desktop_chrome(backend, scene.width, scene.height, theme, resolved_background.color, resolved_background.surface)
    var content_pixel_count: i64 = 0
    for window in scene.windows:
        if not window.minimized:
            if window.chrome_kind != WM_CHROME_KIND_BORDERLESS:
                shared_wm_scene_draw_window_chrome(backend, window, theme)
            val content = _shared_wm_scene_window_content_rect(window)
            shared_wm_scene_render_app_content(backend, window.title, content.x, content.y, content.width, content.height, window.html)
            content_pixel_count = content_pixel_count + _shared_wm_scene_window_content_pixel_count(window)
    SharedWmSceneRenderStats(content_pixel_count: content_pixel_count)

fn shared_wm_scene_render_to_backend(backend: CompositorBackend, scene: SharedWmScene, t_micros: i64 = 0) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_compat_content_to_backend(backend, scene, t_micros)
    shared_wm_scene_render_taskbar(backend, scene.windows, scene.width, scene.height, wm_chrome_theme())
    stats
