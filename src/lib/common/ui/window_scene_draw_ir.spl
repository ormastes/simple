#![allow(large_file)]  # Intentional: shared WM backend and scene ABI remain one native-safe module.
# Shared WM to Draw IR projection.
#
# Converts the window-manager scene into ordered Draw IR batches. This keeps
# window composition in pure Simple and leaves real GPU execution to later
# backend/plugin work.

use common.ui.draw_ir.{
    DRAW_IR_SOURCE_WM_SCENE,
    DrawIrBatch,
    DrawIrCommand,
    DrawIrComposition,
    DrawIrSourceInfo,
    draw_ir_batch_with_source,
    draw_ir_box_with_style,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_group_command,
    draw_ir_image_command,
    draw_ir_rect,
    draw_ir_rect_bounds,
    draw_ir_source_info,
    draw_ir_style_prop,
    draw_ir_text,
    draw_ir_text_resolved_font,
    draw_ir_text_shaped_font
}
use std.common.encoding.font_registry.{simpleos_default_font_asset_candidate}
use std.nogc_sync_mut.text_layout.font_renderer.{resolve_font_metrics_with_language}
use common.ui.taskbar_model.{TaskbarModel}
use common.ui.window_scene.{
    SharedWmScene,
    SharedWmWindow,
    SharedWmRect,
    SharedWmRenderInput,
    SharedWmTaskbarRenderInput,
    WmRenderMetrics,
    WmContentFrame,
    BackgroundSurface,
    WM_BACKGROUND_KIND_COLOR,
    WM_CHROME_KIND_BORDERLESS,
    WM_CONTENT_ORIGIN_SIMPLE_WEB,
    WM_CONTENT_ORIGIN_GUI,
    wm_content_frame_checksum,
    shared_wm_scene_chrome,
    shared_wm_scene_layout_key,
    shared_wm_scene_resolve_background
}
use common.ui.wm_chrome_theme.{wm_chrome_theme, WmChromeColors}
use os.compositor.display_backend_core.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}

val WM_DRAW_IR_COMPOSITION_ID: text = "wm-composite"
val WM_DRAW_IR_DESKTOP_SURFACE: text = "wm-desktop"
val WM_DRAW_IR_CHROME_SURFACE: text = "wm-chrome"
val WM_WINDOW_SHADOW_OFFSET_X: i32 = 5
val WM_WINDOW_SHADOW_OFFSET_Y: i32 = 6

# --- Aqua titlebar gloss (scout prototype) ------------------------------
# Classic Aqua titlebars are a vertical gradient (light top -> darker
# bottom) plus a 1px darker separator on the bottom edge. There is no
# gradient/hline draw primitive on the raw pixel-buffer path (only
# fill_rect), and the two concrete framebuffer backends both opt out of
# CompositorGlassCapable (`as_glass_capable() -> nil`), so the gradient is
# built from a per-row fill_rect loop rather than a new primitive. Colors
# are derived arithmetically from theme.title_focused/title_unfocused (NOT
# new WmChromeColors fields) so an installed theme keeps reskinning the
# titlebar without this prototype needing struct changes.
val WM_TITLEBAR_GLOSS_LIGHTEN: i32 = 14
val WM_TITLEBAR_GLOSS_DARKEN: i32 = 14
val WM_TITLEBAR_BORDER_DARKEN: i32 = 40

fn _wm_argb_channel(color: u32, shift: i32) -> i32:
    ((color >> shift) & 0xFFu32) as i32

fn _wm_argb_clamp_u8(v: i32) -> i32:
    if v < 0: 0 elif v > 255: 255 else: v

fn _wm_argb_from_channels(r: i32, g: i32, b: i32) -> u32:
    0xFF000000u32 | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()

fn _wm_titlebar_shade(base: u32, delta: i32) -> u32:
    """Shift each RGB channel of `base` by `delta` (positive lightens,
    negative darkens), clamped to u8 range. Alpha stays opaque."""
    val r = _wm_argb_clamp_u8(_wm_argb_channel(base, 16) + delta)
    val g = _wm_argb_clamp_u8(_wm_argb_channel(base, 8) + delta)
    val b = _wm_argb_clamp_u8(_wm_argb_channel(base, 0) + delta)
    _wm_argb_from_channels(r, g, b)

fn _wm_titlebar_lerp(top: u32, bottom: u32, row: i32, last_row: i32) -> u32:
    """Linear-interpolate between `top` and `bottom` at `row` of
    [0, last_row]."""
    if last_row <= 0:
        return top
    val tr = _wm_argb_channel(top, 16)
    val tg = _wm_argb_channel(top, 8)
    val tb = _wm_argb_channel(top, 0)
    val br = _wm_argb_channel(bottom, 16)
    val bg = _wm_argb_channel(bottom, 8)
    val bb = _wm_argb_channel(bottom, 0)
    val r = tr + (br - tr) * row / last_row
    val g = tg + (bg - tg) * row / last_row
    val b = tb + (bb - tb) * row / last_row
    _wm_argb_from_channels(_wm_argb_clamp_u8(r), _wm_argb_clamp_u8(g), _wm_argb_clamp_u8(b))

# Stage3 baremetal proved the `[u32]` pixels class field is a live corruption
# boundary: mutations through receiver methods write to a copy, and reading
# the field back across the aggregate boundary returned a garbage length
# (pixels_len=1153202240580805315 in guest serial). The authoritative pixel
# store is therefore a raw scalar-owned buffer: address/count/width/height
# are module-global SCALARS (module-global aggregates are themselves a proven
# stage3 trap; scalars are safe — same rule as PMM/VMM state), written via
# rt_ptr_write_i32. The class keeps its public shape; `pixels` stays as a
# compatibility field but is no longer the render target.
extern fn rt_alloc(size: i64) -> i64
extern fn rt_ptr_write_i32(addr: i64, offset: i64, value: i32)
# NOTE: rt_ptr_read_i32 is NOT exported by the native runtime selection
# (dyld abort: symbol not found '_rt_ptr_read_i32' in flat namespace);
# only write_i32/read_i64 exist. Readback therefore uses rt_ptr_read_i64
# low-32-bit extraction over a 4-byte-padded allocation.
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
# Raw byte copy/fill for row replication: per-pixel extern-call loops cost
# ~800k calls per 1024x768 frame, which under QEMU TCG exceeds the evidence
# wrapper's 10s input-correlation windows. memcpy/memset are strong libc
# symbols on hosts and strong boot-stub symbols in the freestanding kernel.
extern fn memcpy(dst: i64, src: i64, n: i64) -> i64
extern fn memset(dst: i64, value: i64, n: i64) -> i64

var _shared_wm_px_addr: i64 = 0
var _shared_wm_px_count: i64 = 0
var _shared_wm_px_width: i64 = 0
var _shared_wm_px_height: i64 = 0

fn _shared_wm_px_alloc(width: i32, height: i32):
    _shared_wm_px_width = width as i64
    _shared_wm_px_height = height as i64
    val count = width as i64 * height as i64
    if count <= 0:
        _shared_wm_px_addr = 0
        _shared_wm_px_count = 0
        return
    _shared_wm_px_count = count
    # +4 tail padding keeps the final pixel's 8-byte rt_ptr_read_i64 readback
    # in bounds (per-pixel low-32-bit extraction; see extern note above).
    _shared_wm_px_addr = rt_alloc(count * 4 + 4)
    memset(_shared_wm_px_addr, 0, count * 4 + 4)

fn _shared_wm_px_store(x: i64, y: i64, color: u32):
    if _shared_wm_px_addr == 0:
        return
    if x < 0 or y < 0 or x >= _shared_wm_px_width or y >= _shared_wm_px_height:
        return
    rt_ptr_write_i32(_shared_wm_px_addr, (y * _shared_wm_px_width + x) * 4, color as i32)

fn shared_wm_pixel_buffer_addr() -> i64: _shared_wm_px_addr

fn shared_wm_pixel_buffer_count() -> i64: _shared_wm_px_count

class SharedWmPixelBufferBackend:
    width_px: i32
    height_px: i32
    pixels: [u32]
    present_count: i64

    static fn new(width: i32, height: i32) -> SharedWmPixelBufferBackend:
        _shared_wm_px_alloc(width, height)
        SharedWmPixelBufferBackend(
            width_px: width,
            height_px: height,
            pixels: [],
            present_count: 0
        )

    # --- Concrete receiver-method Draw-IR executor -------------------------
    # Stage3 native builds do not materialize a usable vtable for the
    # concrete->trait upcast even within ONE compilation unit: the first
    # CompositorBackend dispatch (backend.clear) loads a null vtable pointer
    # and faults. The production pixel lane therefore executes the SAME
    # shared scene/taskbar render contract through these statically
    # dispatched receiver methods, with indexed while loops (for-in over
    # aggregate-held arrays is a proven nil-element trap in this codegen).

    me _px_clear(color: u32):
        # Row replication: write the first row per-pixel, then memcpy it into
        # every remaining row (~1.8k calls instead of ~786k per frame).
        if _shared_wm_px_addr == 0 or _shared_wm_px_width <= 0 or _shared_wm_px_height <= 0:
            return
        var x: i64 = 0
        while x < _shared_wm_px_width:
            rt_ptr_write_i32(_shared_wm_px_addr, x * 4, color as i32)
            x = x + 1
        val row_bytes = _shared_wm_px_width * 4
        var y: i64 = 1
        while y < _shared_wm_px_height:
            memcpy(_shared_wm_px_addr + y * row_bytes, _shared_wm_px_addr, row_bytes)
            y = y + 1

    me _px_fill_rect(x: i32, y: i32, width: i32, height: i32, color: u32):
        # Clip, write the rect's first row per-pixel, then memcpy-replicate.
        if _shared_wm_px_addr == 0:
            return
        var x0 = x as i64
        var y0 = y as i64
        var x1 = x as i64 + width as i64
        var y1 = y as i64 + height as i64
        if x0 < 0:
            x0 = 0
        if y0 < 0:
            y0 = 0
        if x1 > _shared_wm_px_width:
            x1 = _shared_wm_px_width
        if y1 > _shared_wm_px_height:
            y1 = _shared_wm_px_height
        if x0 >= x1 or y0 >= y1:
            return
        val buf_row_bytes = _shared_wm_px_width * 4
        val first_row_off = y0 * buf_row_bytes + x0 * 4
        var cx = x0
        while cx < x1:
            rt_ptr_write_i32(_shared_wm_px_addr, y0 * buf_row_bytes + cx * 4, color as i32)
            cx = cx + 1
        val span_bytes = (x1 - x0) * 4
        var cy = y0 + 1
        while cy < y1:
            memcpy(_shared_wm_px_addr + cy * buf_row_bytes + x0 * 4, _shared_wm_px_addr + first_row_off, span_bytes)
            cy = cy + 1

    me _px_fill_titlebar_gradient(x: i32, y: i32, width: i32, height: i32, base_color: u32):
        # Aqua gloss: light-top -> dark-bottom vertical gradient plus a 1px
        # darker separator on the last row. Each row is a 1-row fill_rect
        # (no memcpy-replicate work since height=1 per call), so this is
        # ~`height` extra fill_rect calls per titlebar per frame — cheap
        # next to the ~800k-call/frame budget noted above for _px_clear.
        if height <= 0:
            return
        val top = _wm_titlebar_shade(base_color, WM_TITLEBAR_GLOSS_LIGHTEN)
        val bottom = _wm_titlebar_shade(base_color, 0 - WM_TITLEBAR_GLOSS_DARKEN)
        val border = _wm_titlebar_shade(base_color, 0 - WM_TITLEBAR_BORDER_DARKEN)
        val gradient_rows = if height > 1: height - 1 else: height
        val last_row = if gradient_rows > 1: gradient_rows - 1 else: 1
        var row = 0
        while row < gradient_rows:
            self._px_fill_rect(x, y + row, width, 1, _wm_titlebar_lerp(top, bottom, row, last_row))
            row = row + 1
        if height > 1:
            self._px_fill_rect(x, y + height - 1, width, 1, border)

    me _px_blit(x: i32, y: i32, width: i32, height: i32, source: [u32]):
        var row = 0
        while row < height:
            var col = 0
            while col < width:
                val source_index = row * width + col
                if source_index >= 0 and source_index < source.len():
                    _shared_wm_px_store((x + col) as i64, (y + row) as i64, source[source_index])
                col = col + 1
            row = row + 1

    # i64 bit-test + byte accessor: works around native-lane u8 !=-miscompile and char_code_at tag-shift (see doc/08_tracking/bug/, 2026-07-19 glyph probes)
    me _px_draw_text(x: i32, y: i32, text_value: text, fg: u32, bg: u32):
        var cx = x
        var ti = 0
        val text_bytes = text_value.bytes()
        while ti < text_value.len():
            val glyph = get_glyph_8x16(text_bytes[ti])
            var row = 0
            while row < 16:
                val bits = glyph[row]
                var col = 0
                while col < 8:
                    val bits_i = bits as i64
                    val mask_i = (0x80 >> col)
                    val px_color = if (bits_i & mask_i) != 0: fg else: bg
                    _shared_wm_px_store((cx + col) as i64, (y + row) as i64, px_color)
                    col = col + 1
                row = row + 1
            cx = cx + 8
            ti = ti + 1

    me _px_text_fit(x: i32, y: i32, text_value: text, fg: u32, bg: u32, max_chars: i32):
        if max_chars <= 0 or text_value.len() <= 0:
            return
        val bounded = if text_value.len() > max_chars: text_value.slice(0, max_chars) else: text_value
        self._px_draw_text(x, y, bounded, fg, bg)

    me _px_render_desktop_chrome(width: i32, height: i32, theme: WmChromeColors, background_color: u32, background_surface: BackgroundSurface?, top_lane_height: i32, taskbar_height: i32):
        if val surface = background_surface:
            self._px_blit(0, 0, surface.width, surface.height, surface.pixels)
        else:
            self._px_clear(background_color)
        val top_h = if top_lane_height > 0: top_lane_height else: 44
        val taskbar_h = if taskbar_height > 0: taskbar_height else: 56
        self._px_fill_rect(0, 0, width, top_h, theme.command_lane)
        self._px_fill_rect(0, top_h - 2, width, 2, theme.accent)
        self._px_fill_rect(0, height - taskbar_h, width, taskbar_h, theme.taskbar)
        self._px_fill_rect(0, height - taskbar_h, width, 2, theme.accent)

    me _px_draw_window_chrome(window: SharedWmWindow, theme: WmChromeColors):
        if window.minimized:
            return
        val title_color = if window.focused: theme.title_focused else: theme.title_unfocused
        self._px_fill_rect(window.x + WM_WINDOW_SHADOW_OFFSET_X, window.y + WM_WINDOW_SHADOW_OFFSET_Y, window.width, window.height, theme.window_shadow)
        self._px_fill_rect(window.x, window.y, window.width, window.height, theme.host_window_body)
        self._px_fill_titlebar_gradient(window.x, window.y, window.width, 28, title_color)
        self._px_fill_rect(window.x + 12, window.y + 9, 10, 10, 0xFFE74C3Cu32)
        self._px_fill_rect(window.x + 30, window.y + 9, 10, 10, 0xFFF1C40Fu32)
        self._px_fill_rect(window.x + 48, window.y + 9, 10, 10, 0xFF27AE60u32)
        self._px_text_fit(window.x + 66, window.y + 6, window.title, theme.text_primary, title_color, if window.width > 92: (window.width - 92) / 8 else: 0)
        self._px_fill_rect(window.x + window.width - 24, window.y + 2, 20, 20, theme.close_button)
        self._px_text_fit(window.x + window.width - 18, window.y + 4, "X", theme.text_primary, theme.close_button, 1)

    me _px_render_taskbar_model(taskbar: TaskbarModel, width: i32, height: i32, theme: WmChromeColors, metrics: WmRenderMetrics, clock_label: text):
        val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
        val taskbar_y = height - taskbar_h
        val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
        val reserved_right = (taskbar.tray.len() + 1) * slot_w
        val object_limit = width - reserved_right
        var object_index = 0
        var pi = 0
        while pi < taskbar.pinned.len():
            val app = taskbar.pinned[pi]
            val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
            if rect.x >= 0 and rect.x + rect.width <= object_limit:
                self._px_fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.title_unfocused)
                self._px_text_fit(rect.x + 6, rect.y + 14, app.display_name, theme.text_primary, theme.title_unfocused, if rect.width > 12: (rect.width - 12) / 8 else: 0)
            object_index = object_index + 1
            pi = pi + 1
        var ri = 0
        while ri < taskbar.running.len():
            val window = taskbar.running[ri]
            val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
            if rect.x >= 0 and rect.x + rect.width <= object_limit:
                val color = if window.minimized: theme.host_window_body else: theme.title_focused
                self._px_fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, color)
                self._px_text_fit(rect.x + 6, rect.y + 14, window.title, theme.text_primary, color, if rect.width > 12: (rect.width - 12) / 8 else: 0)
            object_index = object_index + 1
            ri = ri + 1
        var tray_index = 0
        while tray_index < taskbar.tray.len():
            val tray = taskbar.tray[tray_index]
            val rect = shared_wm_taskbar_tray_object_rect(metrics, width, height, tray_index)
            if rect.x >= 0 and rect.x + rect.width <= width - slot_w:
                self._px_fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.host_window_body)
                self._px_text_fit(rect.x + 6, rect.y + 14, tray.label, theme.text_primary, theme.host_window_body, if rect.width > 12: (rect.width - 12) / 8 else: 0)
            tray_index = tray_index + 1
        if width >= slot_w:
            self._px_text_fit(width - slot_w + 4, taskbar_y + 14, clock_label, theme.text_primary, theme.taskbar, if slot_w > 8: (slot_w - 8) / 8 else: 0)

    me _px_render_child_content_frames(frames: [WmContentFrame], scene_revision: i64, parent_id: text, parent_rect: SharedWmRect, depth: i32) -> i64:
        if depth > WM_CONTENT_FRAME_MAX_NESTING_DEPTH:
            return 0
        var content_pixel_count: i64 = 0
        var i = 0
        while i < frames.len():
            val frame = frames[i]
            if frame.parent_window_id == parent_id:
                val child_x = parent_rect.x + frame.offset_x
                val child_y = parent_rect.y + frame.offset_y
                val valid = scene_revision > 0 and _wm_content_frame_origin_valid(frame.origin_kind) and frame.scene_revision == scene_revision and frame.content_revision > 0 and frame.checksum > 0u64 and frame.width > 0 and frame.height > 0 and frame.pixels.len() == frame.width * frame.height
                if valid:
                    val clipped = _wm_content_frame_clip_to_rect(frame.pixels, frame.width, frame.height, child_x, child_y, parent_rect)
                    if clipped.width > 0 and clipped.height > 0:
                        self._px_blit(clipped.dest_x, clipped.dest_y, clipped.width, clipped.height, clipped.pixels)
                        content_pixel_count = content_pixel_count + (clipped.width.to_i64() * clipped.height.to_i64())
                    val child_rect = SharedWmRect(x: child_x, y: child_y, width: frame.width, height: frame.height)
                    content_pixel_count = content_pixel_count + self._px_render_child_content_frames(frames, scene_revision, frame.window_id, child_rect, depth + 1)
                else:
                    print("shared_wm_scene_render_taskbar_context_to_pixel_buffer: rejecting missing, stale, or invalid nested content frame for window '{frame.window_id}' (parent '{parent_id}')")
                    val fail_rect = _wm_rect_intersect(child_x, child_y, frame.width, frame.height, parent_rect)
                    if fail_rect.width > 0 and fail_rect.height > 0:
                        self._px_fill_rect(fail_rect.x, fail_rect.y, fail_rect.width, fail_rect.height, 0xFFFF00FFu32)
            i = i + 1
        content_pixel_count

    me _px_render_context_content(input: SharedWmRenderInput) -> i64:
        val scene = input.scene
        val theme = wm_chrome_theme()
        val resolved_background = shared_wm_scene_resolve_background(scene.background, scene.width, scene.height, input.t_micros)
        self._px_render_desktop_chrome(scene.width, scene.height, theme, resolved_background.color, resolved_background.surface, input.metrics.top_lane_height, input.metrics.taskbar_height)
        var content_pixel_count: i64 = 0
        var wi = 0
        while wi < scene.windows.len():
            val window = scene.windows[wi]
            if not window.minimized:
                if window.chrome_kind != WM_CHROME_KIND_BORDERLESS:
                    self._px_draw_window_chrome(window, theme)
                val content = shared_wm_scene_window_content_rect_with_titlebar(window, input.metrics.titlebar_height)
                val frame_index = shared_wm_top_content_frame_index(input.content_frames, input.revision.scene_revision, window.window_id, content.width, content.height)
                if frame_index >= 0:
                    val frame = input.content_frames[frame_index]
                    self._px_blit(content.x, content.y, frame.width, frame.height, frame.pixels)
                    content_pixel_count = content_pixel_count + frame.pixels.len().to_i64()
                    content_pixel_count = content_pixel_count + self._px_render_child_content_frames(input.content_frames, input.revision.scene_revision, window.window_id, content, 1)
                else:
                    print("shared_wm_scene_render_taskbar_context_to_pixel_buffer: rejecting missing, stale, or invalid Simple Web frame for window '{window.window_id}'")
                    self._px_fill_rect(content.x, content.y, content.width, content.height, 0xFFFF00FFu32)
            wi = wi + 1
        content_pixel_count

    me render_taskbar_context(input: SharedWmTaskbarRenderInput) -> SharedWmSceneRenderStats:
        val content_pixel_count = self._px_render_context_content(input.render)
        val scene = input.render.scene
        self._px_render_taskbar_model(input.taskbar, scene.width, scene.height, wm_chrome_theme(), input.render.metrics, input.clock_label)
        SharedWmSceneRenderStats(content_pixel_count: content_pixel_count)

# Indexed, fail-closed top-level frame match (same contract as
# _shared_wm_content_frame_for_window but returning an index instead of an
# Optional aggregate — Optional struct returns are a known stage3 payload
# corruption boundary). Returns the index of the single valid frame for
# `window_id`, or -1 when there is no frame, more than one, or an invalid one.
fn shared_wm_top_content_frame_index(frames: [WmContentFrame], scene_revision: i64, window_id: text, expected_width: i32, expected_height: i32) -> i64:
    var found: i64 = -1
    var matching_count = 0
    var i = 0
    while i < frames.len():
        val frame = frames[i]
        if frame.window_id == window_id and frame.parent_window_id == "":
            matching_count = matching_count + 1
            val valid = scene_revision > 0 and _wm_content_frame_origin_valid(frame.origin_kind) and frame.scene_revision == scene_revision and frame.content_revision > 0 and frame.checksum > 0u64 and frame.width == expected_width and frame.height == expected_height and frame.width > 0 and frame.height > 0 and frame.pixels.len() == frame.width * frame.height
            if valid:
                found = i
        i = i + 1
    if matching_count == 1:
        return found
    -1

fn shared_wm_pixel_buffer_pixels(backend: SharedWmPixelBufferBackend) -> [u32]:
    # Rebuild from the authoritative raw buffer (see the scalar-owner note at
    # the top of this file). Host presentation paths keep their [u32] view.
    val count = _shared_wm_px_count
    if _shared_wm_px_addr == 0 or count <= 0:
        return []
    var out: [u32] = [0u32; count]
    var i: i64 = 0
    while i < count:
        # Little-endian: the low 32 bits of the 8-byte load at offset i*4 are
        # pixel i. The allocation carries 4 bytes of tail padding so this is
        # in bounds for the last pixel (rt_ptr_read_i32 is not exported).
        out[i] = (rt_ptr_read_i64(_shared_wm_px_addr, i * 4) & 0xFFFFFFFF) as u32
        i = i + 1
    out

fn shared_wm_pixel_buffer_resize(backend: SharedWmPixelBufferBackend, width: i32, height: i32):
    if width <= 0 or height <= 0 or (backend.width_px == width and backend.height_px == height):
        return
    backend.width_px = width
    backend.height_px = height
    _shared_wm_px_alloc(width, height)

impl CompositorBackend for SharedWmPixelBufferBackend:
    fn width() -> i32: self.width_px
    fn height() -> i32: self.height_px

    me clear(color: u32):
        self._px_clear(color)

    me fill_rect(x: i32, y: i32, width: i32, height: i32, color: u32):
        self._px_fill_rect(x, y, width, height, color)

    me draw_text(x: i32, y: i32, text_value: text, fg: u32, bg: u32):
        self._px_draw_text(x, y, text_value, fg, bg)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        var row = 0
        while row < 16:
            val bits = glyph[row]
            var col = 0
            while col < 8:
                val bits_i = bits as i64
                val mask_i = (0x80 >> col)
                val px_color = if (bits_i & mask_i) != 0: fg else: bg
                _shared_wm_px_store((x + col) as i64, (y + row) as i64, px_color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        _shared_wm_px_store(x as i64, y as i64, color)

    me blit_pixels(x: i32, y: i32, width: i32, height: i32, source: [u32]):
        self._px_blit(x, y, width, height, source)

    me present():
        self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, width: i32, height: i32):
        self.present_count = self.present_count + 1
    fn as_glass_capable() -> CompositorGlassCapable?: nil

# Nested content-frame recursion cap (Lane C, "rendering inside rendering").
# Depth 1 is a direct child of a top-level window frame, depth 2 a
# grandchild, depth 3 a great-grandchild; deeper requests stop recursing
# instead of walking an unbounded (or accidentally cyclic) parent chain.
val WM_CONTENT_FRAME_MAX_NESTING_DEPTH: i32 = 3

fn _wm_draw_ir_source(source_id: text, style_key: text, style_revision: text) -> DrawIrSourceInfo:
    draw_ir_source_info(DRAW_IR_SOURCE_WM_SCENE, source_id, "", "", "", "", style_key, style_revision)

fn _wm_draw_ir_desktop_revision(scene: SharedWmScene) -> text:
    "wm.desktop:{scene.width}x{scene.height}:background={scene.background.kind}:{scene.background.color}"

fn _wm_draw_ir_chrome_revision(scene: SharedWmScene, taskbar: TaskbarModel, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> text:
    "wm.chrome:{scene.width}x{scene.height}:dpi={dpi_scale_milli}:clock={clock_label}:icons={right_icon_count}:pinned={taskbar.pinned.len()}:running={taskbar.running.len()}"

fn _wm_draw_ir_window_revision(window: SharedWmWindow) -> text:
    val focused = if window.focused: "1" else: "0"
    val minimized = if window.minimized: "1" else: "0"
    "wm.window:{window.window_id}:surface={window.surface_id}:xy={window.x},{window.y}:size={window.width}x{window.height}:z={window.z_index}:focused={focused}:minimized={minimized}:title={window.title}:lang={window.language}"

fn _wm_draw_ir_window_opacity(window: SharedWmWindow) -> i32:
    if window.focused:
        return 1000
    930

fn _wm_draw_ir_window_style(window: SharedWmWindow, part: text) -> [DrawIrStyleProp]:
    [
        draw_ir_style_prop("source", "wm_scene"),
        draw_ir_style_prop("part", part),
        draw_ir_style_prop("z-index", "{window.z_index}"),
        draw_ir_style_prop("focused", if window.focused: "true" else: "false")
    ]

fn _wm_draw_ir_window_box(window: SharedWmWindow, component_id: text, part: text, x: i32, y: i32, width: i32, height: i32, color: u32) -> DrawIrCommand:
    val border_rect = draw_ir_rect_bounds(x, y, width, height)
    val content_rect = draw_ir_rect_bounds(x, y, width, height)
    val hit_rect = draw_ir_rect_bounds(x, y, width, height)
    val clip_rect = draw_ir_rect_bounds(0, 0, window.width, window.height)
    val computed_style = _wm_draw_ir_window_style(window, part)
    draw_ir_box_with_style(
        component_id,
        x,
        y,
        width,
        height,
        color,
        border_rect,
        content_rect,
        hit_rect,
        clip_rect,
        computed_style
    )

fn _wm_draw_ir_text(component_id: text, x: i32, legacy_y: i32, box_y: i32, box_height: i32, value: text, color: u32, language: text) -> DrawIrCommand:
    val candidate = simpleos_default_font_asset_candidate()
    val normalized_language = language.trim().lower()
    val family = if normalized_language != "" and normalized_language != "und": "sans" else: candidate.family
    val metrics = resolve_font_metrics_with_language(family, value, 12, language)
    var command = if metrics.valid and metrics.shaping_required:
        draw_ir_text_shaped_font(component_id, x, legacy_y, value, color, metrics.family, metrics.identity, metrics.advances, metrics.width, metrics.line_height, 12, metrics.glyph_run)
    else if metrics.valid:
        draw_ir_text_resolved_font(component_id, x, legacy_y, value, color, metrics.family, metrics.identity, metrics.advances, metrics.width, metrics.line_height, 12)
    else:
        # Selected metrics may be unavailable during no-VFS boot. The shared
        # renderer's facade locks are now freestanding-safe, so retain readable
        # legacy bitmap text instead of the former rectangle placeholder.
        draw_ir_text(component_id, x, legacy_y, value, color)
    if command.height > 0:
        command.y = box_y + (box_height - command.height) / 2
    command

fn _wm_draw_ir_min_i32(a: i32, b: i32) -> i32:
    if a < b:
        return a
    b

fn _wm_draw_ir_stable_sort_windows_by_z(windows: [SharedWmWindow], count: i32) -> [SharedWmWindow]:
    if count <= 1:
        return windows
    var source = windows
    var dest: [SharedWmWindow] = [windows[0]; count]
    var width = 1
    while width < count:
        var left_start = 0
        while left_start < count:
            val mid = _wm_draw_ir_min_i32(left_start + width, count)
            val right_end = _wm_draw_ir_min_i32(left_start + width + width, count)
            var left = left_start
            var right = mid
            var write = left_start
            while left < mid and right < right_end:
                if source[left].z_index <= source[right].z_index:
                    dest[write] = source[left]
                    left = left + 1
                else:
                    dest[write] = source[right]
                    right = right + 1
                write = write + 1
            while left < mid:
                dest[write] = source[left]
                left = left + 1
                write = write + 1
            while right < right_end:
                dest[write] = source[right]
                right = right + 1
                write = write + 1
            left_start = left_start + width + width
        source = dest
        width = width + width
        if width < count:
            dest = [source[0]; count]
    source

fn _wm_draw_ir_visible_windows_by_layer(scene: SharedWmScene) -> [SharedWmWindow]:
    var visible_count = 0
    var min_z = 0
    var max_z = 0
    var saw_visible = false
    for window in scene.windows:
        if not window.minimized:
            if not saw_visible:
                min_z = window.z_index
                max_z = window.z_index
                saw_visible = true
            elif window.z_index < min_z:
                min_z = window.z_index
            elif window.z_index > max_z:
                max_z = window.z_index
            visible_count = visible_count + 1
    if visible_count == 0:
        return []
    val z_span = max_z - min_z + 1
    if z_span > 0 and z_span <= visible_count * 4:
        var counts: [i32] = [0; z_span]
        for window in scene.windows:
            if not window.minimized:
                val bucket = window.z_index - min_z
                counts[bucket] = counts[bucket] + 1
        var running = 0
        var bucket_idx = 0
        while bucket_idx < z_span:
            val count = counts[bucket_idx]
            counts[bucket_idx] = running
            running = running + count
            bucket_idx = bucket_idx + 1
        var ordered_dense: [SharedWmWindow] = [scene.windows[0]; visible_count]
        for window in scene.windows:
            if not window.minimized:
                val bucket = window.z_index - min_z
                val write_idx = counts[bucket]
                ordered_dense[write_idx] = window
                counts[bucket] = write_idx + 1
        return ordered_dense
    var ordered: [SharedWmWindow] = [scene.windows[0]; visible_count]
    var ordered_count = 0
    for window in scene.windows:
        if not window.minimized:
            ordered[ordered_count] = window
            ordered_count = ordered_count + 1
    if ordered_count != visible_count:
        if ordered_count == 0:
            return []
        var compact: [SharedWmWindow] = [ordered[0]; ordered_count]
        var compact_idx = 0
        while compact_idx < ordered_count:
            compact[compact_idx] = ordered[compact_idx]
            compact_idx = compact_idx + 1
        return _wm_draw_ir_stable_sort_windows_by_z(compact, ordered_count)
    _wm_draw_ir_stable_sort_windows_by_z(ordered, ordered_count)

fn _wm_draw_ir_desktop_batch(scene: SharedWmScene, backend_target: text) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val background_color = if scene.background.kind == WM_BACKGROUND_KIND_COLOR: scene.background.color else: theme.desktop_bg
    val embedding = draw_ir_embedding_config(WM_DRAW_IR_DESKTOP_SURFACE, "desktop", 0, 0, scene.width, scene.height, 0, 1000, false)
    draw_ir_batch_with_source(
        "wm-desktop",
        backend_target,
        embedding,
        [draw_ir_rect("desktop-background", 0, 0, scene.width, scene.height, background_color)],
        _wm_draw_ir_source("wm.desktop", "wm.desktop", _wm_draw_ir_desktop_revision(scene))
    )

fn _wm_draw_ir_chrome_batch(scene: SharedWmScene, taskbar: TaskbarModel, backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    val embedding = draw_ir_embedding_config(WM_DRAW_IR_CHROME_SURFACE, "wm-chrome", 0, 0, scene.width, scene.height, 1, 1000, false)
    draw_ir_batch_with_source(
        "wm-chrome",
        backend_target,
        embedding,
        [
            draw_ir_rect("command-lane", chrome.command_lane.x, chrome.command_lane.y, chrome.command_lane.width, chrome.command_lane.height, theme.command_lane),
            draw_ir_rect("command-lane-accent", chrome.command_lane.x, chrome.command_lane.y + chrome.command_lane.height - 2, chrome.command_lane.width, 2, theme.accent),
            draw_ir_rect("taskbar", chrome.taskbar.x, chrome.taskbar.y, chrome.taskbar.width, chrome.taskbar.height, theme.taskbar),
            draw_ir_rect("taskbar-accent", chrome.taskbar.x, chrome.taskbar.y, chrome.taskbar.width, 2, theme.accent)
        ],
        _wm_draw_ir_source("wm.chrome", "wm.chrome", _wm_draw_ir_chrome_revision(scene, taskbar, dpi_scale_milli, clock_label, right_icon_count))
    )

fn _wm_draw_ir_taskbar_objects_batch(scene: SharedWmScene, taskbar: TaskbarModel, backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    val metrics = WmRenderMetrics(scale_milli: dpi_scale_milli, top_lane_height: chrome.command_lane.height, titlebar_height: 28, taskbar_height: chrome.taskbar.height, min_hit_target: 56)
    val slot_w = metrics.min_hit_target
    val reserved_right = (taskbar.tray.len() + 1) * slot_w
    val object_limit = scene.width - reserved_right
    var commands: [DrawIrCommand] = []
    var object_index = 0
    for app in taskbar.pinned:
        val rect = shared_wm_taskbar_object_rect(metrics, scene.width, scene.height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            commands.push(draw_ir_rect("taskbar-pinned-{app.app_id}", rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.title_unfocused))
            commands.push(_wm_draw_ir_text("taskbar-pinned-label-{app.app_id}", rect.x + 6, rect.y + 14, rect.y + 4, rect.height - 8, app.display_name, theme.text_primary, "und"))
        object_index = object_index + 1
    for window in taskbar.running:
        val rect = shared_wm_taskbar_object_rect(metrics, scene.width, scene.height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            val color = if window.minimized: theme.host_window_body else: theme.title_focused
            commands.push(draw_ir_rect("taskbar-running-{window.window_id}", rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, color))
            commands.push(_wm_draw_ir_text("taskbar-running-label-{window.window_id}", rect.x + 6, rect.y + 14, rect.y + 4, rect.height - 8, window.title, theme.text_primary, "und"))
        object_index = object_index + 1
    var tray_index = 0
    for tray in taskbar.tray:
        val rect = shared_wm_taskbar_tray_object_rect(metrics, scene.width, scene.height, tray_index)
        if rect.x >= 0 and rect.x + rect.width <= scene.width - slot_w:
            commands.push(draw_ir_rect("taskbar-tray-{tray.item_id}", rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.host_window_body))
            commands.push(_wm_draw_ir_text("taskbar-tray-label-{tray.item_id}", rect.x + 6, rect.y + 14, rect.y + 4, rect.height - 8, tray.label, theme.text_primary, "und"))
        tray_index = tray_index + 1
    if scene.width >= slot_w:
        commands.push(_wm_draw_ir_text("taskbar-clock", scene.width - slot_w + 4, chrome.taskbar.y + 14, chrome.taskbar.y, chrome.taskbar.height, clock_label, theme.text_primary, "und"))
    val embedding = draw_ir_embedding_config("wm-taskbar-objects", "wm-taskbar-objects", 0, 0, scene.width, scene.height, 10000, 1000, false)
    draw_ir_batch_with_source("wm-taskbar-objects", backend_target, embedding, commands, _wm_draw_ir_source("wm.taskbar.objects", "wm.taskbar", _wm_draw_ir_chrome_revision(scene, taskbar, dpi_scale_milli, clock_label, right_icon_count)))

fn _wm_draw_ir_window_batch(scene: SharedWmScene, window: SharedWmWindow, backend_target: text) -> DrawIrBatch:
    val theme = wm_chrome_theme()
    val remaining_width = scene.width - window.x - window.width
    val remaining_height = scene.height - window.y - window.height
    val shadow_width = if window.chrome_kind != WM_CHROME_KIND_BORDERLESS and remaining_width > 0: _wm_draw_ir_min_i32(WM_WINDOW_SHADOW_OFFSET_X, remaining_width) else: 0
    val shadow_height = if window.chrome_kind != WM_CHROME_KIND_BORDERLESS and remaining_height > 0: _wm_draw_ir_min_i32(WM_WINDOW_SHADOW_OFFSET_Y, remaining_height) else: 0
    val embedding = draw_ir_embedding_config(window.surface_id, window.window_id, window.x, window.y, window.width + shadow_width, window.height + shadow_height, window.z_index + 10, _wm_draw_ir_window_opacity(window), true)
    if window.chrome_kind == WM_CHROME_KIND_BORDERLESS:
        return draw_ir_batch_with_source("window-{window.window_id}", backend_target, embedding, [], _wm_draw_ir_source("wm.window.{window.window_id}", "wm.window", _wm_draw_ir_window_revision(window)))
    val title_color = if window.focused: theme.title_focused else: theme.title_unfocused
    draw_ir_batch_with_source(
        "window-{window.window_id}",
        backend_target,
        embedding,
        [
            _wm_draw_ir_window_box(window, "{window.window_id}-shadow", "shadow", WM_WINDOW_SHADOW_OFFSET_X, WM_WINDOW_SHADOW_OFFSET_Y, window.width, window.height, theme.window_shadow),
            _wm_draw_ir_window_box(window, "{window.window_id}-body", "body", 0, 0, window.width, window.height, theme.host_window_body),
            _wm_draw_ir_window_box(window, "{window.window_id}-titlebar", "titlebar", 0, 0, window.width, 28, title_color),
            draw_ir_rect("{window.window_id}-traffic-red", 12, 9, 10, 10, 0xFFE74C3Cu32),
            draw_ir_rect("{window.window_id}-traffic-yellow", 30, 9, 10, 10, 0xFFF1C40Fu32),
            draw_ir_rect("{window.window_id}-traffic-green", 48, 9, 10, 10, 0xFF27AE60u32),
            _wm_draw_ir_text("{window.window_id}-title", 66, 19, 0, 28, window.title, theme.text_primary, window.language),
            draw_ir_rect("{window.window_id}-close", window.width - 24, 2, 20, 20, theme.close_button),
            _wm_draw_ir_text("{window.window_id}-close-label", window.width - 18, 17, 2, 20, "X", theme.text_primary, "und")
        ],
        _wm_draw_ir_source("wm.window.{window.window_id}", "wm.window", _wm_draw_ir_window_revision(window))
    )

# Sibling of _wm_draw_ir_window_batch for a nested content frame (Lane C,
# "rendering inside rendering"): a GUI-in-GUI or web-in-GUI child embedded in
# a parent content frame rather than a top-level SharedWmWindow. The
# embedding surface_id is the CHILD frame's own window_id (so downstream Draw
# IR consumers can address it as its own surface), while the single command
# carries parent_id so consumers can still walk the hierarchy up to the
# parent. Nested pixels remain on the existing clipped compositor path for
# now; the GROUP fails closed in Engine2D instead of pretending they rendered.
fn shared_wm_content_frame_image_uri(frame: WmContentFrame) -> text:
    "wm-content://{frame.window_id}/{frame.scene_revision}/{frame.content_revision}/{frame.checksum}"

fn _wm_draw_ir_top_content_frame_batch(window: SharedWmWindow, frame: WmContentFrame, content: SharedWmRect, backend_target: text) -> DrawIrBatch:
    val embedding = draw_ir_embedding_config("{window.surface_id}-content", window.window_id, content.x, content.y, content.width, content.height, window.z_index + 11, 1000, true)
    draw_ir_batch_with_source(
        "content-{window.window_id}",
        backend_target,
        embedding,
        [draw_ir_image_command("{window.window_id}-content-image", 0, 0, content.width, content.height, shared_wm_content_frame_image_uri(frame), [])],
        _wm_draw_ir_source("wm.content.{window.window_id}", "wm.content", "rev={frame.content_revision};checksum={frame.checksum}")
    )

fn _wm_draw_ir_invalid_top_content_frame_batch(window: SharedWmWindow, content: SharedWmRect, backend_target: text) -> DrawIrBatch:
    val embedding = draw_ir_embedding_config("{window.surface_id}-content", window.window_id, content.x, content.y, content.width, content.height, window.z_index + 11, 1000, true)
    draw_ir_batch_with_source(
        "content-{window.window_id}",
        backend_target,
        embedding,
        [draw_ir_rect("{window.window_id}-content-invalid", 0, 0, content.width, content.height, 0xFFFF00FFu32)],
        _wm_draw_ir_source("wm.content.{window.window_id}", "wm.content", "invalid")
    )

fn _wm_draw_ir_child_content_frame_batch(frame: WmContentFrame, parent_window_id: text, backend_target: text) -> DrawIrBatch:
    val embedding = draw_ir_embedding_config(frame.window_id, frame.window_id, frame.offset_x, frame.offset_y, frame.width, frame.height, 0, 1000, true)
    draw_ir_batch_with_source(
        "content-{frame.window_id}",
        backend_target,
        embedding,
        [draw_ir_group_command(frame.window_id, parent_window_id)],
        _wm_draw_ir_source("wm.content.{frame.window_id}", "wm.content", "rev={frame.content_revision}")
    )

fn shared_wm_scene_draw_ir_composition(scene: SharedWmScene, taskbar: TaskbarModel, backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrComposition:
    val desktop_batch = _wm_draw_ir_desktop_batch(scene, backend_target)
    val windows = _wm_draw_ir_visible_windows_by_layer(scene)
    var batches: [DrawIrBatch] = [desktop_batch, _wm_draw_ir_chrome_batch(scene, taskbar, backend_target, dpi_scale_milli, clock_label, right_icon_count)]
    for window in windows:
        batches.push(_wm_draw_ir_window_batch(scene, window, backend_target))
    batches.push(_wm_draw_ir_taskbar_objects_batch(scene, taskbar, backend_target, dpi_scale_milli, clock_label, right_icon_count))
    draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, batches)

# Recursively collects Draw IR batches for the content frames nested under
# `parent_id` (parent_window_id == parent_id), one batch per child via
# _wm_draw_ir_child_content_frame_batch, then recurses into each child's own
# children up to WM_CONTENT_FRAME_MAX_NESTING_DEPTH — mirroring
# _shared_wm_render_child_content_frames's traversal, but for Draw IR
# projection instead of direct-to-backend pixels.
fn _wm_draw_ir_child_content_batches_recursive(content_frames: [WmContentFrame], parent_id: text, backend_target: text, depth: i32) -> [DrawIrBatch]:
    if depth > WM_CONTENT_FRAME_MAX_NESTING_DEPTH:
        return []
    var out: [DrawIrBatch] = []
    for frame in content_frames:
        if frame.parent_window_id == parent_id:
            out.push(_wm_draw_ir_child_content_frame_batch(frame, parent_id, backend_target))
            for nested in _wm_draw_ir_child_content_batches_recursive(content_frames, frame.window_id, backend_target, depth + 1):
                out.push(nested)
    out

# Content-aware sibling of shared_wm_scene_draw_ir_composition: same
# desktop/chrome/window batches plus a resolved IMAGE batch for each validated
# top-level content frame, interleaved directly after its window chrome. Nested
# frames retain their GROUP metadata and therefore fail closed in Engine2D
# until clipped nested IMAGE projection is implemented.
fn shared_wm_scene_draw_ir_composition_with_content(scene: SharedWmScene, taskbar: TaskbarModel, content_frames: [WmContentFrame], backend_target: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> DrawIrComposition:
    val base = shared_wm_scene_draw_ir_composition(scene, taskbar, backend_target, dpi_scale_milli, clock_label, right_icon_count)
    if content_frames.len() == 0:
        return base
    var batches: [DrawIrBatch] = []
    for batch in base.batches:
        batches.push(batch)
        for window in scene.windows:
            if not window.minimized and batch.batch_id == "window-{window.window_id}":
                val content = shared_wm_scene_window_content_rect_with_titlebar(window, 28)
                if content.width > 0 and content.height > 0:
                    if val frame = shared_wm_content_frame_for_window(content_frames, 0, window, 28):
                        batches.push(_wm_draw_ir_top_content_frame_batch(window, frame, content, backend_target))
                    else:
                        batches.push(_wm_draw_ir_invalid_top_content_frame_batch(window, content, backend_target))
                for child_batch in _wm_draw_ir_child_content_batches_recursive(content_frames, window.window_id, backend_target, 1):
                    batches.push(child_batch)
    draw_ir_composition(WM_DRAW_IR_COMPOSITION_ID, shared_wm_scene_layout_key(scene), backend_target, batches)

# =========================================================================
# Taskbar item geometry (pure math)
#
# Single source of truth for taskbar dock/item layout. Historically lived in
# os.compositor.wm_action_applier; moved here so the backend-neutral
# SharedWmScene executor below can compute taskbar item bounds without a
# common.ui -> os dependency. os.compositor.wm_action_applier re-exports
# these under the same names so its existing callers are unaffected.
# =========================================================================

fn wm_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    val available = screen_width - 80
    val fit = available / count
    if fit < 104: fit else: 104

fn wm_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    wm_taskbar_item_width(screen_width, count) * count + 20

fn wm_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    val dock_w = wm_taskbar_dock_width(screen_width, count)
    val start = (screen_width - dock_w) / 2 + 10
    start + index * wm_taskbar_item_width(screen_width, count)

fn shared_wm_taskbar_object_rect(metrics: WmRenderMetrics, screen_width: i32, screen_height: i32, index: i32) -> SharedWmRect:
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    SharedWmRect(x: index * slot_w, y: screen_height - taskbar_h, width: slot_w, height: taskbar_h)

fn shared_wm_taskbar_tray_object_rect(metrics: WmRenderMetrics, screen_width: i32, screen_height: i32, reverse_index: i32) -> SharedWmRect:
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    SharedWmRect(x: screen_width - (reverse_index + 2) * slot_w, y: screen_height - taskbar_h, width: slot_w, height: taskbar_h)

# =========================================================================
# SharedWmScene -> CompositorBackend executor
#
# Renders a SharedWmScene (as built by common.ui.window_scene, e.g. via
# simple_gui_internal_window_scene) directly against a backend-neutral
# CompositorBackend draw target: desktop/command-lane/taskbar chrome, then
# each visible window's chrome (titled only; borderless windows render as
# pure content surfaces per chrome_kind) + app content, then the taskbar
# item row. os.compositor.shared_mdi_framebuffer_scene.spl is glue: it builds
# a SharedWmScene and calls shared_wm_scene_render_to_backend — it no longer
# owns chrome/content/taskbar pixel-drawing logic itself. Both the host WM
# capture-evidence lane and the SimpleOS QEMU fullscreen lane call that same
# glue, so they share this exact render model; only backend/config differs.
# =========================================================================

struct SharedWmSceneRenderStats:
    content_pixel_count: i64

fn _draw_shared_wm_backend_text_fit(backend: CompositorBackend, x: i32, y: i32, text_value: text, fg: u32, bg: u32, max_chars: i32):
    if max_chars <= 0 or text_value.len() <= 0:
        return
    val bounded = if text_value.len() > max_chars: text_value.slice(0, max_chars) else: text_value
    backend.draw_text(x, y, bounded, fg, bg)

fn shared_wm_scene_render_desktop_chrome(backend: CompositorBackend, width: i32, height: i32, theme: WmChromeColors, background_color: u32, background_surface: BackgroundSurface? = nil, top_lane_height: i32 = 44, taskbar_height: i32 = 56):
    if val surface = background_surface:
        backend.blit_pixels(0, 0, surface.width, surface.height, surface.pixels)
    else:
        backend.clear(background_color)
    val top_h = if top_lane_height > 0: top_lane_height else: 44
    val taskbar_h = if taskbar_height > 0: taskbar_height else: 56
    backend.fill_rect(0, 0, width, top_h, theme.command_lane)
    backend.fill_rect(0, top_h - 2, width, 2, theme.accent)
    backend.fill_rect(0, height - taskbar_h, width, taskbar_h, theme.taskbar)
    backend.fill_rect(0, height - taskbar_h, width, 2, theme.accent)

fn _wm_draw_titlebar_gradient(backend: CompositorBackend, x: i32, y: i32, width: i32, height: i32, base_color: u32):
    """Same Aqua gloss as SharedWmPixelBufferBackend._px_fill_titlebar_gradient,
    but through the generic CompositorBackend.fill_rect trait method for the
    hosted/GPU backends that route through this shared draw-contract fn."""
    if height <= 0:
        return
    val top = _wm_titlebar_shade(base_color, WM_TITLEBAR_GLOSS_LIGHTEN)
    val bottom = _wm_titlebar_shade(base_color, 0 - WM_TITLEBAR_GLOSS_DARKEN)
    val border = _wm_titlebar_shade(base_color, 0 - WM_TITLEBAR_BORDER_DARKEN)
    val gradient_rows = if height > 1: height - 1 else: height
    val last_row = if gradient_rows > 1: gradient_rows - 1 else: 1
    var row = 0
    while row < gradient_rows:
        backend.fill_rect(x, y + row, width, 1, _wm_titlebar_lerp(top, bottom, row, last_row))
        row = row + 1
    if height > 1:
        backend.fill_rect(x, y + height - 1, width, 1, border)

fn shared_wm_scene_draw_window_chrome(backend: CompositorBackend, window: SharedWmWindow, theme: WmChromeColors):
    if window.minimized:
        return
    val title_color = if window.focused: theme.title_focused else: theme.title_unfocused
    backend.fill_rect(window.x + WM_WINDOW_SHADOW_OFFSET_X, window.y + WM_WINDOW_SHADOW_OFFSET_Y, window.width, window.height, theme.window_shadow)
    backend.fill_rect(window.x, window.y, window.width, window.height, theme.host_window_body)
    _wm_draw_titlebar_gradient(backend, window.x, window.y, window.width, 28, title_color)
    backend.fill_rect(window.x + 12, window.y + 9, 10, 10, 0xFFE74C3Cu32)
    backend.fill_rect(window.x + 30, window.y + 9, 10, 10, 0xFFF1C40Fu32)
    backend.fill_rect(window.x + 48, window.y + 9, 10, 10, 0xFF27AE60u32)
    _draw_shared_wm_backend_text_fit(backend, window.x + 66, window.y + 6, window.title, theme.text_primary, title_color, if window.width > 92: (window.width - 92) / 8 else: 0)
    backend.fill_rect(window.x + window.width - 24, window.y + 2, 20, 20, theme.close_button)
    _draw_shared_wm_backend_text_fit(backend, window.x + window.width - 18, window.y + 4, "X", theme.text_primary, theme.close_button, 1)

fn shared_wm_scene_render_taskbar(backend: CompositorBackend, windows: [SharedWmWindow], width: i32, height: i32, theme: WmChromeColors):
    val count = windows.len()
    if count <= 0:
        return
    val dock_w = wm_taskbar_dock_width(width, count)
    val dock_x = (width - dock_w) / 2
    val dock_y = height - 62
    val item_w = wm_taskbar_item_width(width, count)
    backend.fill_rect(dock_x, dock_y, dock_w, 44, theme.taskbar)
    var i = 0
    while i < count:
        val win = windows[i]
        val ix = wm_taskbar_item_x(width, count, i)
        var item_color = theme.title_unfocused
        if win.focused and not win.minimized:
            item_color = theme.title_focused
        elif win.minimized:
            item_color = theme.host_window_body
        backend.fill_rect(ix + 2, dock_y + 4, item_w - 4, 36, item_color)
        _draw_shared_wm_backend_text_fit(backend, ix + 8, dock_y + 14, win.title, theme.text_primary, item_color, if item_w > 16: (item_w - 16) / 8 else: 0)
        i = i + 1

fn shared_wm_scene_render_taskbar_model(backend: CompositorBackend, taskbar: TaskbarModel, width: i32, height: i32, theme: WmChromeColors, metrics: WmRenderMetrics, clock_label: text):
    val taskbar_h = if metrics.taskbar_height > 0: metrics.taskbar_height else: 56
    val taskbar_y = height - taskbar_h
    # Desktop chrome owns the single taskbar background/accent pass. This
    # function adds only authoritative taskbar objects.
    val slot_w = if metrics.min_hit_target > 0: metrics.min_hit_target else: 44
    val reserved_right = (taskbar.tray.len() + 1) * slot_w
    val object_limit = width - reserved_right
    var object_index = 0
    for app in taskbar.pinned:
        val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.title_unfocused)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, app.display_name, theme.text_primary, theme.title_unfocused, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        object_index = object_index + 1
    for window in taskbar.running:
        val rect = shared_wm_taskbar_object_rect(metrics, width, height, object_index)
        if rect.x >= 0 and rect.x + rect.width <= object_limit:
            val color = if window.minimized: theme.host_window_body else: theme.title_focused
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, color)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, window.title, theme.text_primary, color, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        object_index = object_index + 1
    var tray_index = 0
    for tray in taskbar.tray:
        val rect = shared_wm_taskbar_tray_object_rect(metrics, width, height, tray_index)
        if rect.x >= 0 and rect.x + rect.width <= width - slot_w:
            backend.fill_rect(rect.x + 2, rect.y + 4, rect.width - 4, rect.height - 8, theme.host_window_body)
            _draw_shared_wm_backend_text_fit(backend, rect.x + 6, rect.y + 14, tray.label, theme.text_primary, theme.host_window_body, if rect.width > 12: (rect.width - 12) / 8 else: 0)
        tray_index = tray_index + 1
    if width >= slot_w:
        _draw_shared_wm_backend_text_fit(backend, width - slot_w + 4, taskbar_y + 14, clock_label, theme.text_primary, theme.taskbar, if slot_w > 8: (slot_w - 8) / 8 else: 0)

fn _shared_wm_scene_content_line(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, line_index: i32, text_value: text, fg: u32, bg: u32):
    val y = cy + 34 + line_index * 22
    _draw_shared_wm_backend_text_fit(backend, cx + 10, y, text_value, fg, bg, if cw > 20: (cw - 20) / 8 else: 0)

# Renders `state_text` (the caller's real window content, e.g. window.html)
# as plain wrapped lines through the real backend.draw_text path. Used
# whenever the caller supplies non-empty content, so live content is never
# silently discarded in favor of the canned per-title table below.
fn _shared_wm_scene_render_live_state_text(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text, fg: u32, bg: u32):
    val lines = state_text.split("\n")
    val max_lines = if ch > 34: (ch - 34) / 22 else: 0
    var limit = lines.len()
    if limit > max_lines:
        limit = max_lines
    var i = 0
    while i < limit:
        _shared_wm_scene_content_line(backend, cx, cy, cw, i, lines[i], fg, bg)
        i = i + 1

# Compatibility app-content renderer. `state_text` (window.html) is the
# caller's authoritative live content: when it is non-empty this renders it
# verbatim (line-wrapped) and never substitutes canned markup. The per-title
# table below is a placeholder ONLY for the case where no live content is
# available at all (state_text == ""), and every canned block is tagged with
# an explicit "[canned]" marker line so a captured frame is visibly
# distinguishable from real app content — see
# doc/08_tracking/bug/browser_demo_frozen_loading_placeholder_2026-07-12.md
# for the underlying de-fake audit this guards against regressing.
fn shared_wm_scene_render_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    if cw <= 0 or ch <= 0:
        return
    val bg = 0xFF182230u32
    val header = 0xFF2050A0u32
    val text_primary = 0xFFE5E7EBu32
    val accent = 0xFF2563EBu32
    val success = 0xFF22C55Eu32
    val warning = 0xFFF59E0Bu32
    val muted = 0xFF94A3B8u32
    backend.fill_rect(cx, cy, cw, ch, bg)
    backend.fill_rect(cx, cy, cw, 24, header)
    _draw_shared_wm_backend_text_fit(backend, cx + 8, cy + 4, title, text_primary, header, if cw > 16: (cw - 16) / 8 else: 0)
    if state_text != "":
        _shared_wm_scene_render_live_state_text(backend, cx, cy, cw, ch, state_text, text_primary, bg)
        return
    if title == "Terminal":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "$", success, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "src/ test/ main.spl", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "[canned demo — no live content]", muted, bg)
        return
    if title == "Editor" or title == "Hello World":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "main.spl", muted, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "fn main():", warning, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "    print Hello SimpleOS", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "[canned demo — no live content]", muted, bg)
        return
    if title == "File Manager" or title == "Finder":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "/home/simple", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "Desktop", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "Documents", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "Downloads", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 4, "[canned demo — no live content]", muted, bg)
        return
    if title == "Calculator":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "0", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "7 8 9 /", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "4 5 6 *", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "1 2 3 -", text_primary, bg)
        return
    if title == "Browser" or title == "Simple Browser":
        _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "about:network", accent, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 1, "Simple Web", success, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 2, "GET /status 200", text_primary, bg)
        _shared_wm_scene_content_line(backend, cx, cy, cw, 3, "[canned demo — no live content]", muted, bg)
        return
    _shared_wm_scene_content_line(backend, cx, cy, cw, 0, "[canned demo — no live content]", text_primary, bg)

fn _shared_wm_scene_window_content_rect(window: SharedWmWindow) -> SharedWmRect:
    if window.chrome_kind == WM_CHROME_KIND_BORDERLESS:
        return SharedWmRect(x: window.x, y: window.y, width: window.width, height: window.height)
    SharedWmRect(x: window.x + 4, y: window.y + 32, width: window.width - 8, height: window.height - 36)

fn _shared_wm_scene_window_content_pixel_count(window: SharedWmWindow) -> i64:
    if window.minimized:
        return 0
    val content = _shared_wm_scene_window_content_rect(window)
    if content.width > 0 and content.height > 0:
        return content.width.to_i64() * content.height.to_i64()
    0

# Content frames may originate from the Simple Web adapter or from a GUI
# panel producer (common.ui.wm_gui_content_frame) — both are legitimate,
# fail-closed-validated content sources; anything else is rejected the same
# way an unknown background kind is rejected (loud, no silent fallback).
fn _wm_content_frame_origin_valid(origin_kind: text) -> bool:
    origin_kind == WM_CONTENT_ORIGIN_SIMPLE_WEB or origin_kind == WM_CONTENT_ORIGIN_GUI

fn shared_wm_content_frame_for_window(content_frames: [WmContentFrame], scene_revision: i64, window: SharedWmWindow, titlebar_height: i32) -> WmContentFrame?:
    var found: WmContentFrame? = nil
    var matching_count = 0
    for frame in content_frames:
        if frame.window_id == window.window_id and frame.parent_window_id == "":
            matching_count = matching_count + 1
            val content = shared_wm_scene_window_content_rect_with_titlebar(window, titlebar_height)
            val revision_valid = if scene_revision > 0: frame.scene_revision == scene_revision else: frame.scene_revision > 0
            val checksum_valid = frame.checksum > 0u64 and frame.checksum == wm_content_frame_checksum(frame.pixels)
            val valid = revision_valid and _wm_content_frame_origin_valid(frame.origin_kind) and frame.content_revision > 0 and frame.width > 0 and frame.height > 0 and frame.width == content.width and frame.height == content.height and frame.pixels.len().to_i64() == frame.width.to_i64() * frame.height.to_i64() and checksum_valid
            if valid:
                found = frame
    if matching_count == 1:
        return found
    nil

fn _shared_wm_content_frame_for_window(input: SharedWmRenderInput, window: SharedWmWindow) -> WmContentFrame?:
    shared_wm_content_frame_for_window(input.content_frames, input.revision.scene_revision, window, input.metrics.titlebar_height)

# Geometry-only rect intersection (no pixel data): used both by the pixel-crop
# helper below and by the fail-closed magenta path, which needs the clipped
# rect but never touches pixel data for an invalid child.
fn _wm_rect_intersect(x: i32, y: i32, w: i32, h: i32, clip_rect: SharedWmRect) -> SharedWmRect:
    val clip_x1 = clip_rect.x + clip_rect.width
    val clip_y1 = clip_rect.y + clip_rect.height
    val x1 = x + w
    val y1 = y + h
    val out_x0 = if x > clip_rect.x: x else: clip_rect.x
    val out_y0 = if y > clip_rect.y: y else: clip_rect.y
    val out_x1 = if x1 < clip_x1: x1 else: clip_x1
    val out_y1 = if y1 < clip_y1: y1 else: clip_y1
    val out_w = out_x1 - out_x0
    val out_h = out_y1 - out_y0
    if out_w <= 0 or out_h <= 0:
        return SharedWmRect(x: out_x0, y: out_y0, width: 0, height: 0)
    SharedWmRect(x: out_x0, y: out_y0, width: out_w, height: out_h)

struct WmClippedPixelRect:
    dest_x: i32
    dest_y: i32
    width: i32
    height: i32
    pixels: [u32]

# Pure helper: crops a [u32] row-major pixel buffer (drawn at dest_x/dest_y,
# src_w x src_h) to its intersection with clip_rect, returning the cropped
# buffer plus the destination position to blit it at. CompositorBackend has
# no clip primitive of its own (display_backend.spl:9), so nested content
# frames that extend past their parent's content rect are clipped here,
# before blit_pixels, rather than needing a new backend method. Callers must
# check width/height > 0 before blitting (zero-area intersection is a no-op).
fn _wm_content_frame_clip_to_rect(pixels: [u32], src_w: i32, src_h: i32, dest_x: i32, dest_y: i32, clip_rect: SharedWmRect) -> WmClippedPixelRect:
    val out_rect = _wm_rect_intersect(dest_x, dest_y, src_w, src_h, clip_rect)
    if out_rect.width <= 0 or out_rect.height <= 0:
        return WmClippedPixelRect(dest_x: out_rect.x, dest_y: out_rect.y, width: 0, height: 0, pixels: [])
    val crop_src_x = out_rect.x - dest_x
    val crop_src_y = out_rect.y - dest_y
    var cropped: [u32] = [0u32; out_rect.width * out_rect.height]
    var row = 0
    while row < out_rect.height:
        val src_row = crop_src_y + row
        val src_row_start = src_row * src_w + crop_src_x
        val dst_row_start = row * out_rect.width
        var col = 0
        while col < out_rect.width:
            cropped[dst_row_start + col] = pixels[src_row_start + col]
            col = col + 1
        row = row + 1
    WmClippedPixelRect(dest_x: out_rect.x, dest_y: out_rect.y, width: out_rect.width, height: out_rect.height, pixels: cropped)

# Recursively renders the content frames nested under `parent_id`
# (parent_window_id == parent_id), clipped to `parent_rect` (the immediate
# parent's own content rect), then recurses into each child's own children
# (grandchildren etc.) up to WM_CONTENT_FRAME_MAX_NESTING_DEPTH. A valid
# child is blitted (cropped to the parent rect); an invalid child (bad
# revision/checksum/size) is fail-closed magenta-filled over its own rect
# (also cropped to the parent rect) instead of drawing stale/fabricated
# pixels — mirroring _shared_wm_content_frame_for_window's fail-closed
# contract for top-level frames. Returns the pixel count actually blitted
# (valid children only) so callers can fold it into SharedWmSceneRenderStats.
fn _shared_wm_render_child_content_frames(backend: CompositorBackend, input: SharedWmRenderInput, parent_id: text, parent_rect: SharedWmRect, depth: i32) -> i64:
    if depth > WM_CONTENT_FRAME_MAX_NESTING_DEPTH:
        return 0
    var content_pixel_count: i64 = 0
    for frame in input.content_frames:
        if frame.parent_window_id == parent_id:
            val child_x = parent_rect.x + frame.offset_x
            val child_y = parent_rect.y + frame.offset_y
            val valid = input.revision.scene_revision > 0 and _wm_content_frame_origin_valid(frame.origin_kind) and frame.scene_revision == input.revision.scene_revision and frame.content_revision > 0 and frame.checksum > 0u64 and frame.width > 0 and frame.height > 0 and frame.pixels.len() == frame.width * frame.height
            if valid:
                val clipped = _wm_content_frame_clip_to_rect(frame.pixels, frame.width, frame.height, child_x, child_y, parent_rect)
                if clipped.width > 0 and clipped.height > 0:
                    backend.blit_pixels(clipped.dest_x, clipped.dest_y, clipped.width, clipped.height, clipped.pixels)
                    content_pixel_count = content_pixel_count + (clipped.width.to_i64() * clipped.height.to_i64())
                val child_rect = SharedWmRect(x: child_x, y: child_y, width: frame.width, height: frame.height)
                content_pixel_count = content_pixel_count + _shared_wm_render_child_content_frames(backend, input, frame.window_id, child_rect, depth + 1)
            else:
                print("shared_wm_scene_render_context_to_backend: rejecting missing, stale, or invalid nested content frame for window '{frame.window_id}' (parent '{parent_id}')")
                val fail_rect = _wm_rect_intersect(child_x, child_y, frame.width, frame.height, parent_rect)
                if fail_rect.width > 0 and fail_rect.height > 0:
                    backend.fill_rect(fail_rect.x, fail_rect.y, fail_rect.width, fail_rect.height, 0xFFFF00FFu32)
    content_pixel_count

fn shared_wm_scene_window_content_rect_with_titlebar(window: SharedWmWindow, titlebar_height: i32) -> SharedWmRect:
    if window.chrome_kind == WM_CHROME_KIND_BORDERLESS:
        return SharedWmRect(x: window.x, y: window.y, width: window.width, height: window.height)
    val title_h = if titlebar_height > 0: titlebar_height else: 28
    SharedWmRect(x: window.x + 4, y: window.y + title_h + 4, width: window.width - 8, height: window.height - title_h - 8)

# Rich content-frame executor. Unlike the compatibility API below, this path
# never substitutes canned title-based content for a missing or stale frame.
fn _shared_wm_scene_render_context_content_to_backend(backend: CompositorBackend, input: SharedWmRenderInput) -> SharedWmSceneRenderStats:
    val scene = input.scene
    val theme = wm_chrome_theme()
    val resolved_background = shared_wm_scene_resolve_background(scene.background, scene.width, scene.height, input.t_micros)
    shared_wm_scene_render_desktop_chrome(backend, scene.width, scene.height, theme, resolved_background.color, resolved_background.surface, input.metrics.top_lane_height, input.metrics.taskbar_height)
    var content_pixel_count: i64 = 0
    for window in scene.windows:
        if not window.minimized:
            if window.chrome_kind != WM_CHROME_KIND_BORDERLESS:
                shared_wm_scene_draw_window_chrome(backend, window, theme)
            val content = shared_wm_scene_window_content_rect_with_titlebar(window, input.metrics.titlebar_height)
            if val frame = _shared_wm_content_frame_for_window(input, window):
                backend.blit_pixels(content.x, content.y, frame.width, frame.height, frame.pixels)
                content_pixel_count = content_pixel_count + frame.pixels.len().to_i64()
                content_pixel_count = content_pixel_count + _shared_wm_render_child_content_frames(backend, input, window.window_id, content, 1)
            else:
                print("shared_wm_scene_render_context_to_backend: rejecting missing, stale, or invalid Simple Web frame for window '{window.window_id}'")
                backend.fill_rect(content.x, content.y, content.width, content.height, 0xFFFF00FFu32)
    SharedWmSceneRenderStats(content_pixel_count: content_pixel_count)

fn shared_wm_scene_render_context_to_backend(backend: CompositorBackend, input: SharedWmRenderInput) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_context_content_to_backend(backend, input)
    val scene = input.scene
    shared_wm_scene_render_taskbar(backend, scene.windows, scene.width, scene.height, wm_chrome_theme())
    stats

# Authoritative rich executor. The final taskbar pass consumes TaskbarModel
# objects directly; it never derives pinned, running, tray, or clock objects
# from window titles.
fn shared_wm_scene_render_taskbar_context_to_backend(backend: CompositorBackend, input: SharedWmTaskbarRenderInput) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_context_content_to_backend(backend, input.render)
    val scene = input.render.scene
    shared_wm_scene_render_taskbar_model(backend, input.taskbar, scene.width, scene.height, wm_chrome_theme(), input.render.metrics, input.clock_label)
    stats

fn shared_wm_scene_render_taskbar_context_to_pixel_buffer(backend: SharedWmPixelBufferBackend, input: SharedWmTaskbarRenderInput) -> SharedWmSceneRenderStats:
    # Fully concrete receiver-method execution. Same-unit impl+call-site is
    # NOT sufficient for stage3 native builds: the concrete->trait upcast
    # still yields a null vtable and the first backend.clear dispatch faults.
    # The pixel lane therefore must never enter CompositorBackend dispatch.
    backend.render_taskbar_context(input)

# `t_micros` (default 0) is only consumed by a kind:"motion" background (see
# shared_wm_scene_resolve_background); every existing caller that never sets
# a motion background is unaffected by the new trailing param.
fn _shared_wm_scene_render_compat_content_to_backend(backend: CompositorBackend, scene: SharedWmScene, t_micros: i64 = 0) -> SharedWmSceneRenderStats:
    val theme = wm_chrome_theme()
    val resolved_background = shared_wm_scene_resolve_background(scene.background, scene.width, scene.height, t_micros)
    shared_wm_scene_render_desktop_chrome(backend, scene.width, scene.height, theme, resolved_background.color, resolved_background.surface)
    var content_pixel_count: i64 = 0
    for window in scene.windows:
        if not window.minimized:
            if window.chrome_kind != WM_CHROME_KIND_BORDERLESS:
                shared_wm_scene_draw_window_chrome(backend, window, theme)
            val content = _shared_wm_scene_window_content_rect(window)
            shared_wm_scene_render_app_content(backend, window.title, content.x, content.y, content.width, content.height, window.html)
            content_pixel_count = content_pixel_count + _shared_wm_scene_window_content_pixel_count(window)
    SharedWmSceneRenderStats(content_pixel_count: content_pixel_count)

fn shared_wm_scene_render_to_backend(backend: CompositorBackend, scene: SharedWmScene, t_micros: i64 = 0) -> SharedWmSceneRenderStats:
    val stats = _shared_wm_scene_render_compat_content_to_backend(backend, scene, t_micros)
    shared_wm_scene_render_taskbar(backend, scene.windows, scene.width, scene.height, wm_chrome_theme())
    stats
