# Dirty-Region Tracking for Partial Redraw
#
# Opt-in geometry/accounting helper for partial-redraw rendering. A renderer
# marks the rectangles it touched this frame; the tracker accumulates them,
# reports the total dirty-pixel count, and can be cleared at frame start.
#
# This module deliberately holds NO framebuffer. In Simple arrays are value
# types (passed by copy), so a persistent pixel buffer must live as a field on
# a class that mutates it via `me`-methods — passing a [i64] into a free helper
# would copy 8K * 4K * 8 bytes per call and erase any win. The owning renderer
# therefore keeps its own buffer and uses DirtyTracker only for the geometry of
# WHICH spans to repaint and to account for how many pixels that was.
#
# Two modes are expressed by how a caller uses this:
#   - optimization OFF: ignore the tracker, repaint the whole viewport.
#   - optimization ON : repaint only the rects the tracker collected.

struct DirtyRect:
    x: i32
    y: i32
    w: i32
    h: i32

fn make_dirty_rect(x: i32, y: i32, w: i32, h: i32) -> DirtyRect:
    return DirtyRect(x: x, y: y, w: w, h: h)

impl DirtyRect:
    fn area() -> i32:
        if self.w <= 0 or self.h <= 0:
            return 0
        return self.w * self.h

    fn right() -> i32:
        return self.x + self.w

    fn bottom() -> i32:
        return self.y + self.h

    fn is_empty() -> bool:
        return self.w <= 0 or self.h <= 0

# Clamp a rect to a [0,0,bound_w,bound_h] viewport. Returns a possibly-empty rect.
fn clamp_rect(r: DirtyRect, bound_w: i32, bound_h: i32) -> DirtyRect:
    var x0 = r.x
    var y0 = r.y
    var x1 = r.x + r.w
    var y1 = r.y + r.h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > bound_w:
        x1 = bound_w
    if y1 > bound_h:
        y1 = bound_h
    if x1 <= x0 or y1 <= y0:
        return DirtyRect(x: 0, y: 0, w: 0, h: 0)
    return DirtyRect(x: x0, y: y0, w: x1 - x0, h: y1 - y0)

# Accumulates dirty rectangles for one frame.
#
# The rects list is the work-list a partial-redraw renderer walks. The pixel
# count is the honest "how much did we actually touch" number reported by the
# benchmark: it is the sum of each clamped rect's area (rects may overlap, so
# this is an upper bound on distinct pixels, which is the conservative figure a
# real partial present would have to upload).
class DirtyTracker:
    rects: [DirtyRect]
    bound_w: i32
    bound_h: i32

    static fn create(bound_w: i32, bound_h: i32) -> DirtyTracker:
        return DirtyTracker(rects: [], bound_w: bound_w, bound_h: bound_h)

    me reset():
        self.rects = []

    me mark(x: i32, y: i32, w: i32, h: i32):
        val clamped = clamp_rect(DirtyRect(x: x, y: y, w: w, h: h), self.bound_w, self.bound_h)
        if not clamped.is_empty():
            self.rects = self.rects + [clamped]

    me mark_rect(r: DirtyRect):
        self.mark(r.x, r.y, r.w, r.h)

    fn count() -> i32:
        return self.rects.len().to_i32()

    fn dirty_pixels() -> i64:
        var total: i64 = 0
        for r in self.rects:
            total = total + r.area().to_i64()
        return total

    # Convenience: the whole viewport as a single dirty rect (the OFF baseline).
    fn full_pixels() -> i64:
        return self.bound_w.to_i64() * self.bound_h.to_i64()
