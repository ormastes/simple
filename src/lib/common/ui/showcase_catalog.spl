# Canonical identities and readiness for the GUI/web/2D showcase applications.
# A readiness bit is enabled only after the corresponding surface launches the
# real app and has event plus rendered-frame evidence.

enum ShowcaseSurface:
    Standalone
    HostWm
    SimpleOsWm

struct ShowcaseEntry:
    app_id: text
    title: text
    source_path: text
    page_path: text
    installed_path: text
    standalone_ready: bool
    host_wm_ready: bool
    simpleos_wm_ready: bool

val GRAPHICS_2D_SHOWCASE_APP_ID: text = "graphics_2d_showcase"
val WEB_STANDARDS_SHOWCASE_APP_ID: text = "web_standards_showcase"
val GUI_WIDGET_SHOWCASE_APP_ID: text = "gui_widget_showcase"

val GRAPHICS_2D_SHOWCASE_SOURCE: text = "examples/06_io/ui/graphics_2d_showcase_gui.spl"
val WEB_STANDARDS_SHOWCASE_SOURCE: text = "examples/06_io/ui/web_standards_showcase_gui.spl"
val WEB_STANDARDS_SHOWCASE_PAGE: text = "examples/06_io/ui/browser_common_elements_showcase.html"
val GUI_WIDGET_SHOWCASE_SOURCE: text = "examples/06_io/ui/widget_showcase_gui.spl"

fn showcase_catalog() -> [ShowcaseEntry]:
    [
        ShowcaseEntry(
            app_id: GRAPHICS_2D_SHOWCASE_APP_ID,
            title: "2D Rendering Showcase",
            source_path: GRAPHICS_2D_SHOWCASE_SOURCE,
            page_path: "",
            installed_path: "/sys/apps/graphics_2d_showcase.smf",
            standalone_ready: false,
            host_wm_ready: false,
            simpleos_wm_ready: false
        ),
        ShowcaseEntry(
            app_id: WEB_STANDARDS_SHOWCASE_APP_ID,
            title: "Web Standards Showcase",
            source_path: WEB_STANDARDS_SHOWCASE_SOURCE,
            page_path: WEB_STANDARDS_SHOWCASE_PAGE,
            installed_path: "/sys/apps/web_standards_showcase.smf",
            standalone_ready: false,
            host_wm_ready: false,
            simpleos_wm_ready: false
        ),
        ShowcaseEntry(
            app_id: GUI_WIDGET_SHOWCASE_APP_ID,
            title: "Widget Showcase",
            source_path: GUI_WIDGET_SHOWCASE_SOURCE,
            page_path: "",
            installed_path: "/sys/apps/gui_widget_showcase.smf",
            standalone_ready: false,
            host_wm_ready: false,
            simpleos_wm_ready: false
        )
    ]

fn showcase_find(app_id: text) -> ShowcaseEntry?:
    val entries = showcase_catalog()
    for entry in entries:
        if entry.app_id == app_id:
            return Some(entry)
    nil

fn showcase_surface_supported(entry: ShowcaseEntry, surface: ShowcaseSurface) -> bool:
    match surface:
        ShowcaseSurface.Standalone:
            entry.standalone_ready
        ShowcaseSurface.HostWm:
            entry.host_wm_ready
        ShowcaseSurface.SimpleOsWm:
            entry.simpleos_wm_ready

fn showcase_installed_path(entry: ShowcaseEntry) -> text:
    entry.installed_path
