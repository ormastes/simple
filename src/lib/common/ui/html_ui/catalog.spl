# HTML UI Catalog — tag-to-widget mapping and catalog queries.
#
# Covers the full set of HTML elements supported by the html_ui toolchain.
# widget_kind strings mirror WidgetKind.to_wire() values from widget_kind.spl.

struct UiCatalogEntry:
    tag: text
    widget_kind: text
    tui_note: text

fn _entries() -> [UiCatalogEntry]:
    [
        UiCatalogEntry(tag: "html",        widget_kind: "panel",     tui_note: "root container; ignore in TUI"),
        UiCatalogEntry(tag: "body",        widget_kind: "panel",     tui_note: "root container; ignore in TUI"),
        UiCatalogEntry(tag: "div",         widget_kind: "panel",     tui_note: "generic container"),
        UiCatalogEntry(tag: "section",     widget_kind: "panel",     tui_note: "semantic section"),
        UiCatalogEntry(tag: "article",     widget_kind: "card",      tui_note: "card-like block"),
        UiCatalogEntry(tag: "aside",       widget_kind: "sidebar",   tui_note: "sidebar panel"),
        UiCatalogEntry(tag: "main",        widget_kind: "panel",     tui_note: "main content area"),
        UiCatalogEntry(tag: "header",      widget_kind: "panel",     tui_note: "header bar; map to statusbar in TUI"),
        UiCatalogEntry(tag: "footer",      widget_kind: "statusbar", tui_note: "footer / status bar"),
        UiCatalogEntry(tag: "nav",         widget_kind: "navigation_bar", tui_note: "navigation bar"),
        UiCatalogEntry(tag: "h1",          widget_kind: "heading",   tui_note: "top-level heading"),
        UiCatalogEntry(tag: "h2",          widget_kind: "heading",   tui_note: "heading level 2"),
        UiCatalogEntry(tag: "h3",          widget_kind: "heading",   tui_note: "heading level 3"),
        UiCatalogEntry(tag: "h4",          widget_kind: "heading",   tui_note: "heading level 4"),
        UiCatalogEntry(tag: "h5",          widget_kind: "heading",   tui_note: "heading level 5"),
        UiCatalogEntry(tag: "h6",          widget_kind: "heading",   tui_note: "heading level 6"),
        UiCatalogEntry(tag: "p",           widget_kind: "text",      tui_note: "paragraph text"),
        UiCatalogEntry(tag: "span",        widget_kind: "text",      tui_note: "inline text"),
        UiCatalogEntry(tag: "ul",          widget_kind: "list",      tui_note: "unordered list"),
        UiCatalogEntry(tag: "ol",          widget_kind: "list",      tui_note: "ordered list"),
        UiCatalogEntry(tag: "li",          widget_kind: "text",      tui_note: "list item"),
        UiCatalogEntry(tag: "table",       widget_kind: "table",     tui_note: "table widget"),
        UiCatalogEntry(tag: "thead",       widget_kind: "panel",     tui_note: "table header group"),
        UiCatalogEntry(tag: "tbody",       widget_kind: "panel",     tui_note: "table body group"),
        UiCatalogEntry(tag: "tfoot",       widget_kind: "panel",     tui_note: "table footer group"),
        UiCatalogEntry(tag: "tr",          widget_kind: "panel",     tui_note: "table row"),
        UiCatalogEntry(tag: "th",          widget_kind: "text",      tui_note: "table header cell"),
        UiCatalogEntry(tag: "td",          widget_kind: "text",      tui_note: "table data cell"),
        UiCatalogEntry(tag: "caption",     widget_kind: "text",      tui_note: "table caption"),
        UiCatalogEntry(tag: "button",      widget_kind: "button",    tui_note: "button"),
        UiCatalogEntry(tag: "input",       widget_kind: "input",     tui_note: "input; type=checkbox->checkbox, type=radio->radio, else textfield"),
        UiCatalogEntry(tag: "select",      widget_kind: "dropdown",  tui_note: "dropdown selector"),
        UiCatalogEntry(tag: "option",      widget_kind: "text",      tui_note: "dropdown option item"),
        UiCatalogEntry(tag: "textarea",    widget_kind: "textarea",  tui_note: "multi-line text input"),
        UiCatalogEntry(tag: "label",       widget_kind: "label",     tui_note: "form label"),
        UiCatalogEntry(tag: "form",        widget_kind: "panel",     tui_note: "form container"),
        UiCatalogEntry(tag: "fieldset",    widget_kind: "panel",     tui_note: "grouped form fields"),
        UiCatalogEntry(tag: "legend",      widget_kind: "text",      tui_note: "fieldset caption"),
        UiCatalogEntry(tag: "img",         widget_kind: "image",     tui_note: "image; TUI shows alt text"),
        UiCatalogEntry(tag: "a",           widget_kind: "text",      tui_note: "hyperlink; TUI shows as text"),
        UiCatalogEntry(tag: "blockquote",  widget_kind: "panel",     tui_note: "block quote"),
        UiCatalogEntry(tag: "code",        widget_kind: "text",      tui_note: "inline code"),
        UiCatalogEntry(tag: "pre",         widget_kind: "text",      tui_note: "preformatted text block"),
        UiCatalogEntry(tag: "strong",      widget_kind: "text",      tui_note: "bold inline"),
        UiCatalogEntry(tag: "em",          widget_kind: "text",      tui_note: "italic inline"),
        UiCatalogEntry(tag: "hr",          widget_kind: "divider",   tui_note: "horizontal rule"),
        UiCatalogEntry(tag: "details",     widget_kind: "panel",     tui_note: "disclosure widget"),
        UiCatalogEntry(tag: "summary",     widget_kind: "text",      tui_note: "details summary / toggle label"),
        UiCatalogEntry(tag: "dialog",      widget_kind: "dialog",    tui_note: "modal dialog"),
        UiCatalogEntry(tag: "progress",    widget_kind: "progress",  tui_note: "progress bar")
    ]

fn catalog_elements() -> [UiCatalogEntry]:
    _entries()

fn catalog_supports(tag: text) -> bool:
    val entries = _entries()
    var found = false
    var i = 0
    while i < entries.len():
        if entries[i].tag == tag:
            found = true
        i = i + 1
    found

fn catalog_tags() -> [text]:
    val entries = _entries()
    var tags: [text] = []
    var i = 0
    while i < entries.len():
        tags = tags + [entries[i].tag]
        i = i + 1
    tags

export UiCatalogEntry
export catalog_elements
export catalog_supports
export catalog_tags
