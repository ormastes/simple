# html_ui — HTML UI toolchain core library.
#
# Catalog: tag → widget_kind mapping.
# Pair:    HtmlCssPair struct (pure, common tier). The file-backed
#          pair_load/pair_add_css/pair_save operations live in the impure
#          sibling module std.nogc_sync_mut.ui.html_ui.pair_io (#35 core-lib
#          purity split) — import them from there directly, not through
#          this package index, so this file stays common-tier pure.
# DocOps:  text-based parse/serialize/query/mutate.
# Payload: base64 payload codegen for std and dyn SMF builds.
# Entry:   dynsmf_entry (ui_html module id) for background lane.

export use std.common.ui.html_ui.catalog.{
    UiCatalogEntry,
    catalog_elements,
    catalog_supports,
    catalog_tags
}

export use std.common.ui.html_ui.pair.{
    HtmlCssPair
}

export use std.common.ui.html_ui.doc_ops.{
    html_parse_text,
    html_serialize,
    used_tags,
    list_elements,
    add_element
}

export use std.common.ui.html_ui.payload.{
    UiPartMap,
    payload_encode,
    payload_decode,
    payload_split,
    gen_std_module_source,
    gen_dyn_main_source,
    gen_dyn_part_source
}

export use std.common.ui.html_ui.dynsmf_entry.{
    ui_html_lib_ready
}
