# payload.spl — base64 payload helpers and .spl source code generation.
#
# IMPORTANT: generated Simple source strings must NEVER contain a raw CSS/HTML
# literal with brace characters, because {ident} in Simple string literals is
# interpolation. All payload content is kept base64-encoded. The generated
# source code itself is constructed via string concatenation that never places
# '{' immediately before an identifier token.
#
# Interpreter-safe base64: the stdlib base64_encode calls text.bytes() which
# is not available in interpreter mode ("Function 'str.bytes' not found").
# This module provides a pure-Simple fallback using char_at/chr/bitwise ops
# that works in both interpreter and compiled modes.

# Element-to-part mapping for dyn builds.
struct UiPartMap:
    tags: [text]
    parts: [text]

# ---------------------------------------------------------------------------
# Interpreter-safe base64 (RFC 4648 standard, with '=' padding)
# Derives UTF-8 bytes from codepoints via arithmetic — no .bytes() call.
# ---------------------------------------------------------------------------

val _B64_TABLE = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

# Encode a single codepoint (Unicode scalar) into its UTF-8 byte sequence
# and append to out_bytes array (value type — returns updated array).
fn _cp_to_utf8_bytes(cp: i64, out: [i64]) -> [i64]:
    if cp < 0x80:
        out = out + [cp]
    else if cp < 0x800:
        out = out + [(0xC0 | (cp >> 6))]
        out = out + [(0x80 | (cp & 0x3F))]
    else if cp < 0x10000:
        out = out + [(0xE0 | (cp >> 12))]
        out = out + [(0x80 | ((cp >> 6) & 0x3F))]
        out = out + [(0x80 | (cp & 0x3F))]
    else:
        out = out + [(0xF0 | (cp >> 18))]
        out = out + [(0x80 | ((cp >> 12) & 0x3F))]
        out = out + [(0x80 | ((cp >> 6) & 0x3F))]
        out = out + [(0x80 | (cp & 0x3F))]
    out

# Convert text to a list of UTF-8 byte values (i64) using char_at + codepoint arithmetic.
fn _text_to_utf8_bytes(data: text) -> [i64]:
    val n = data.length()
    var bytes: [i64] = []
    var i = 0
    while i < n:
        val cp = data.char_at(i) as i64
        bytes = _cp_to_utf8_bytes(cp, bytes)
        i = i + 1
    bytes

# Decode a base64 char to its 6-bit value; returns -1 for invalid/whitespace.
fn _b64_char_value(c: i64) -> i64:
    # A-Z: 0-25
    if c >= 65 and c <= 90:
        return c - 65
    # a-z: 26-51
    if c >= 97 and c <= 122:
        return c - 71
    # 0-9: 52-61
    if c >= 48 and c <= 57:
        return c + 4
    # '+': 62
    if c == 43:
        return 62
    # '/': 63
    if c == 47:
        return 63
    -1

# Encode arbitrary text as standard base64 (RFC 4648 §4, with '=' padding).
# Works in interpreter mode — uses char_at and codepoint arithmetic only.
fn _interp_base64_encode(data: text) -> text:
    val bytes = _text_to_utf8_bytes(data)
    val n = bytes.len()
    var out = ""
    var i = 0
    while i < n:
        val b1 = bytes[i]
        var b2: i64 = 0
        var b3: i64 = 0
        if i + 1 < n:
            b2 = bytes[i + 1]
        if i + 2 < n:
            b3 = bytes[i + 2]
        val idx0 = b1 >> 2
        val idx1 = ((b1 & 3) << 4) | (b2 >> 4)
        val idx2 = ((b2 & 15) << 2) | (b3 >> 6)
        val idx3 = b3 & 63
        out = out + _B64_TABLE.char_at(idx0)
        out = out + _B64_TABLE.char_at(idx1)
        if i + 1 < n:
            out = out + _B64_TABLE.char_at(idx2)
        else:
            out = out + "="
        if i + 2 < n:
            out = out + _B64_TABLE.char_at(idx3)
        else:
            out = out + "="
        i = i + 3
    out

# Decode standard base64 text back to UTF-8 text.
# Works in interpreter mode — uses char_at only.
fn _interp_base64_decode(encoded: text) -> text:
    val n = encoded.length()
    var out_bytes: [i64] = []
    var acc = 0
    var bits = 0
    var i = 0
    while i < n:
        val raw = encoded.char_at(i) as i64
        i = i + 1
        # skip whitespace
        if raw == 32 or raw == 9 or raw == 10 or raw == 13:
            pass_dn
        # padding terminates
        if raw == 61:
            bits = 0
        else:
            val v = _b64_char_value(raw)
            if v >= 0:
                acc = (acc << 6) | v
                bits = bits + 6
                if bits >= 8:
                    bits = bits - 8
                    out_bytes = out_bytes + [(acc >> bits) & 0xFF]
    # Reconstruct text from UTF-8 bytes (codepoints)
    var result = ""
    var bi = 0
    val bn = out_bytes.len()
    while bi < bn:
        val b = out_bytes[bi]
        if b < 0x80:
            result = result + b.chr()
            bi = bi + 1
        else if b < 0xE0:
            if bi + 1 < bn:
                val b2 = out_bytes[bi + 1]
                val cp = ((b & 0x1F) << 6) | (b2 & 0x3F)
                result = result + cp.chr()
                bi = bi + 2
            else:
                result = result + "?"
                bi = bi + 1
        else if b < 0xF0:
            if bi + 2 < bn:
                val b2 = out_bytes[bi + 1]
                val b3 = out_bytes[bi + 2]
                val cp = ((b & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
                result = result + cp.chr()
                bi = bi + 3
            else:
                result = result + "?"
                bi = bi + 1
        else:
            if bi + 3 < bn:
                val b2 = out_bytes[bi + 1]
                val b3 = out_bytes[bi + 2]
                val b4 = out_bytes[bi + 3]
                val cp = ((b & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
                result = result + cp.chr()
                bi = bi + 4
            else:
                result = result + "?"
                bi = bi + 1
    result

# ---------------------------------------------------------------------------
# Public API: encode/decode wrappers
# ---------------------------------------------------------------------------

fn payload_encode(data: text) -> text:
    _interp_base64_encode(data)

fn payload_decode(encoded: text) -> text:
    _interp_base64_decode(encoded)

# Split a base64 string into chunks of at most chunk_len characters.
fn payload_split(b64_text: text, chunk_len: i64) -> [text]:
    var chunks: [text] = []
    val n = b64_text.len()
    var pos = 0
    while pos < n:
        val end = if pos + chunk_len > n: n else: pos + chunk_len
        chunks = chunks + [b64_text.slice(pos, end)]
        pos = end
    chunks

# ---------------------------------------------------------------------------
# Code generation
# ---------------------------------------------------------------------------

# Generate a single-module std-form source that embeds html + css as b64 consts.
# name         : module identifier (ASCII, no spaces)
# html_b64     : base64-encoded HTML content
# css_b64s     : list of base64-encoded CSS contents (one per sheet)
#
# The generated module exports:
#   ui_name()         -> text
#   ui_elements()     -> [text]   (populated externally; returns [] here)
#   ui_html_b64()     -> text
#   ui_css_b64(idx)   -> text
fn gen_std_module_source(name: text, html_b64: text, css_b64s: [text]) -> text:
    val nl = "\n"
    val q = "\""
    var src = "# Generated std UI module: " + name + nl
    src = src + "# Do not edit — produced by html_ui payload codegen." + nl
    src = src + nl
    src = src + "fn ui_name() -> text:" + nl
    src = src + "    " + q + name + q + nl
    src = src + nl
    src = src + "fn ui_elements() -> [text]:" + nl
    src = src + "    []" + nl
    src = src + nl
    src = src + "fn ui_html_b64() -> text:" + nl
    src = src + "    " + q + html_b64 + q + nl
    src = src + nl
    # css_b64 by index via if/elif chain (no struct literals needed)
    src = src + "fn ui_css_b64(idx: i64) -> text:" + nl
    if css_b64s.len() == 0:
        src = src + "    " + q + q + nl
    else:
        var i = 0
        while i < css_b64s.len():
            if i == 0:
                src = src + "    if idx == 0:" + nl
            else:
                src = src + "    else if idx == " + i.to_text() + ":" + nl
            src = src + "        " + q + css_b64s[i] + q + nl
            i = i + 1
        src = src + "    else:" + nl
        src = src + "        " + q + q + nl
    src = src + nl
    src = src + "export ui_name" + nl
    src = src + "export ui_elements" + nl
    src = src + "export ui_html_b64" + nl
    src = src + "export ui_css_b64" + nl
    src

# Generate the dyn main module source. This is the module with the element→part
# map. For merged (small) builds, embed the full payloads directly.
#
# name              : module name
# map               : element-to-part-filename map
# embedded_html_b64 : html payload (may be "" if split into parts)
# embedded_css_b64s : css payloads (may be [] if split into parts)
fn gen_dyn_main_source(name: text, map: UiPartMap, embedded_html_b64: text, embedded_css_b64s: [text]) -> text:
    val nl = "\n"
    val q = "\""
    var src = "# Generated dyn main UI module: " + name + nl
    src = src + "# Do not edit — produced by html_ui payload codegen." + nl
    src = src + nl
    src = src + "fn ui_name() -> text:" + nl
    src = src + "    " + q + name + q + nl
    src = src + nl
    # ui_elements — list all tags in the map
    src = src + "fn ui_elements() -> [text]:" + nl
    if map.tags.len() == 0:
        src = src + "    []" + nl
    else:
        src = src + "    [" + nl
        var i = 0
        while i < map.tags.len():
            val comma = if i + 1 < map.tags.len(): "," else: ""
            src = src + "        " + q + map.tags[i] + q + comma + nl
            i = i + 1
        src = src + "    ]" + nl
    src = src + nl
    # ui_html_b64 — embedded or empty
    src = src + "fn ui_html_b64() -> text:" + nl
    src = src + "    " + q + embedded_html_b64 + q + nl
    src = src + nl
    # ui_css_b64 — embedded or empty
    src = src + "fn ui_css_b64(idx: i64) -> text:" + nl
    if embedded_css_b64s.len() == 0:
        src = src + "    " + q + q + nl
    else:
        var ci = 0
        while ci < embedded_css_b64s.len():
            if ci == 0:
                src = src + "    if idx == 0:" + nl
            else:
                src = src + "    else if idx == " + ci.to_text() + ":" + nl
            src = src + "        " + q + embedded_css_b64s[ci] + q + nl
            ci = ci + 1
        src = src + "    else:" + nl
        src = src + "        " + q + q + nl
    src = src + nl
    # ui_part_for — element → part filename
    src = src + "fn ui_part_for(tag: text) -> text:" + nl
    if map.tags.len() == 0:
        src = src + "    " + q + q + nl
    else:
        var pi = 0
        while pi < map.tags.len():
            if pi == 0:
                src = src + "    if tag == " + q + map.tags[pi] + q + ":" + nl
            else:
                src = src + "    else if tag == " + q + map.tags[pi] + q + ":" + nl
            src = src + "        " + q + map.parts[pi] + q + nl
            pi = pi + 1
        src = src + "    else:" + nl
        src = src + "        " + q + q + nl
    src = src + nl
    src = src + "export ui_name" + nl
    src = src + "export ui_elements" + nl
    src = src + "export ui_html_b64" + nl
    src = src + "export ui_css_b64" + nl
    src = src + "export ui_part_for" + nl
    src

# Generate a dyn part module source.
# name        : parent module name
# idx         : part index
# payload_b64 : the b64-encoded payload chunk for this part
fn gen_dyn_part_source(name: text, idx: i64, payload_b64: text) -> text:
    val nl = "\n"
    val q = "\""
    var src = "# Generated dyn part module: " + name + "_part_" + idx.to_text() + nl
    src = src + "# Do not edit — produced by html_ui payload codegen." + nl
    src = src + nl
    src = src + "fn ui_part_payload() -> text:" + nl
    src = src + "    " + q + payload_b64 + q + nl
    src = src + nl
    src = src + "export ui_part_payload" + nl
    src

export UiPartMap
export payload_encode
export payload_decode
export payload_split
export gen_std_module_source
export gen_dyn_main_source
export gen_dyn_part_source
