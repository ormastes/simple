"""Modeled X11-class native backend contract for future Wine graphics work."""

use common.ui.x11_backend_gate.{x11_backend_event_gate, x11_backend_gate, x11_backend_pixel_gate, x11_backend_property_gate}
use common.ui.wine_simpleos_window_bridge.{WineSimpleOsWindowBridge, wine_simpleos_window_bridge_gate, wine_simpleos_window_evidence}

class WineX11BackendState:
    features: text
    events: text
    pixels: text
    mapped_windows: [text]
    focused_window: text
    clipboard_text: text
    cursor_name: text
    os_evidence: text
    properties: text
    event_queue: [text]

class WineX11OpResult:
    ok: bool
    state: text
    backend: WineX11BackendState

class WineX11EventResult:
    ok: bool
    state: text
    backend: WineX11BackendState
    event: text

fn _backend(features: text, events: text, pixels: text, mapped_windows: [text], focused_window: text, clipboard_text: text, cursor_name: text, os_evidence: text, properties: text, event_queue: [text]) -> WineX11BackendState:
    WineX11BackendState(features: features, events: events, pixels: pixels, mapped_windows: mapped_windows, focused_window: focused_window, clipboard_text: clipboard_text, cursor_name: cursor_name, os_evidence: os_evidence, properties: properties, event_queue: event_queue)

fn _result(ok: bool, state: text, backend: WineX11BackendState) -> WineX11OpResult:
    WineX11OpResult(ok: ok, state: state, backend: backend)

fn _event_result(ok: bool, state: text, backend: WineX11BackendState, event: text) -> WineX11EventResult:
    WineX11EventResult(ok: ok, state: state, backend: backend, event: event)

fn _append_once(items: text, item: text) -> text:
    if items.contains(item):
        return items
    if items == "":
        return item
    items + " " + item

fn _contains_window(windows: [text], id: text) -> bool:
    for window in windows:
        if window == id:
            return true
    false

fn _push_event(queue: [text], event: text) -> [text]:
    var events = queue
    events.push(event)
    events

pub fn wine_x11_backend_new() -> WineX11BackendState:
    _backend("display screen", "", "", [], "", "", "", "", "", [])

pub fn wine_x11_backend_bind_simpleos(backend: WineX11BackendState, bridge: WineSimpleOsWindowBridge) -> WineX11OpResult:
    val bridge_state = wine_simpleos_window_bridge_gate(bridge)
    if bridge_state != "ready":
        return _result(false, bridge_state, backend)
    _result(true, "bound", _backend(backend.features, backend.events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, wine_simpleos_window_evidence(bridge), backend.properties, backend.event_queue))

pub fn wine_x11_create_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if id == "":
        return _result(false, "invalid-window", backend)
    if _contains_window(backend.mapped_windows, id):
        return _result(false, "window-exists", backend)
    var windows = backend.mapped_windows
    windows.push(id)
    val features = _append_once(_append_once(_append_once(backend.features, "window"), "surface"), "configure")
    val events = _append_once(backend.events, "create")
    _result(true, "created", _backend(features, events, backend.pixels, windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "create:" + id)))

pub fn wine_x11_map_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    val features = _append_once(backend.features, "map-unmap")
    val events = _append_once(backend.events, "map")
    _result(true, "mapped", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "map:" + id)))

pub fn wine_x11_unmap_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    var focus = backend.focused_window
    if focus == id:
        focus = ""
    val features = _append_once(backend.features, "map-unmap")
    val events = _append_once(backend.events, "unmap")
    _result(true, "unmapped", _backend(features, events, backend.pixels, backend.mapped_windows, focus, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "unmap:" + id)))

pub fn wine_x11_configure_window(backend: WineX11BackendState, id: text, width: i64, height: i64) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if width <= 0 or height <= 0:
        return _result(false, "invalid-size", backend)
    val events = _append_once(backend.events, "configure")
    _result(true, "configured", _backend(backend.features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "configure:" + id)))

pub fn wine_x11_damage_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    val features = _append_once(_append_once(_append_once(_append_once(_append_once(backend.features, "damage"), "clip"), "expose"), "present"), "blit")
    val events = _append_once(backend.events, "expose")
    val pixels = _append_once(_append_once(_append_once(backend.pixels, "golden"), "damage"), "present")
    _result(true, "damaged", _backend(features, events, pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "expose:" + id)))

pub fn wine_x11_fill_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    val features = _append_once(backend.features, "fill")
    _result(true, "filled", _backend(features, backend.events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, backend.event_queue))

pub fn wine_x11_text_window(backend: WineX11BackendState, id: text, text: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if text == "":
        return _result(false, "empty-text", backend)
    val features = _append_once(_append_once(backend.features, "text"), "glyph")
    val pixels = _append_once(backend.pixels, "text")
    _result(true, "text", _backend(features, backend.events, pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, backend.event_queue))

pub fn wine_x11_focus_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    val features = _append_once(_append_once(backend.features, "input"), "focus")
    val events = _append_once(_append_once(backend.events, "focus"), "input")
    _result(true, "focused", _backend(features, events, backend.pixels, backend.mapped_windows, id, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "focus:" + id)))

pub fn wine_x11_intern_atom(backend: WineX11BackendState, atom_name: text) -> WineX11OpResult:
    if atom_name == "":
        return _result(false, "invalid-atom", backend)
    val features = _append_once(backend.features, "atom")
    val properties = _append_once(backend.properties, atom_name)
    _result(true, "atom", _backend(features, backend.events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, properties, backend.event_queue))

pub fn wine_x11_set_wm_name(backend: WineX11BackendState, id: text, value: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if value == "":
        return _result(false, "invalid-property", backend)
    val features = _append_once(_append_once(backend.features, "property"), "wm-name")
    val events = _append_once(backend.events, "property")
    val properties = _append_once(_append_once(backend.properties, "WM_NAME"), "NET_WM_NAME")
    _result(true, "property", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, properties, _push_event(backend.event_queue, "property:" + id + ":WM_NAME")))

pub fn wine_x11_set_wm_class(backend: WineX11BackendState, id: text, instance: text, class_name: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if instance == "" or class_name == "":
        return _result(false, "invalid-property", backend)
    val features = _append_once(_append_once(backend.features, "property"), "wm-class")
    val events = _append_once(backend.events, "property")
    val properties = _append_once(backend.properties, "WM_CLASS")
    _result(true, "property", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, properties, _push_event(backend.event_queue, "property:" + id + ":WM_CLASS")))

pub fn wine_x11_set_wm_protocols(backend: WineX11BackendState, id: text, protocols: [text]) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if protocols.len() == 0:
        return _result(false, "invalid-property", backend)
    val features = _append_once(_append_once(backend.features, "property"), "wm-protocols")
    val events = _append_once(backend.events, "property")
    var properties = _append_once(backend.properties, "WM_PROTOCOLS")
    for protocol in protocols:
        properties = _append_once(properties, protocol)
    _result(true, "property", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, properties, _push_event(backend.event_queue, "property:" + id + ":WM_PROTOCOLS")))

pub fn wine_x11_set_wm_state(backend: WineX11BackendState, id: text, state: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    if state == "":
        return _result(false, "invalid-property", backend)
    val features = _append_once(_append_once(backend.features, "property"), "wm-state")
    val events = _append_once(backend.events, "property")
    val properties = _append_once(_append_once(backend.properties, "_NET_WM_STATE"), state)
    _result(true, "property", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, properties, _push_event(backend.event_queue, "property:" + id + ":_NET_WM_STATE")))

pub fn wine_x11_set_cursor(backend: WineX11BackendState, name: text) -> WineX11OpResult:
    if name == "":
        return _result(false, "invalid-cursor", backend)
    val features = _append_once(backend.features, "cursor")
    val pixels = _append_once(backend.pixels, "cursor")
    _result(true, "cursor", _backend(features, backend.events, pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, name, backend.os_evidence, backend.properties, backend.event_queue))

pub fn wine_x11_set_clipboard(backend: WineX11BackendState, value: text) -> WineX11OpResult:
    val features = _append_once(backend.features, "clipboard")
    val events = _append_once(backend.events, "clipboard")
    _result(true, "clipboard", _backend(features, events, backend.pixels, backend.mapped_windows, backend.focused_window, value, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "clipboard")))

pub fn wine_x11_destroy_window(backend: WineX11BackendState, id: text) -> WineX11OpResult:
    if not _contains_window(backend.mapped_windows, id):
        return _result(false, "missing-window", backend)
    var windows: [text] = []
    for window in backend.mapped_windows:
        if window != id:
            windows.push(window)
    var focus = backend.focused_window
    if focus == id:
        focus = ""
    val events = _append_once(backend.events, "destroy")
    _result(true, "destroyed", _backend(backend.features, events, backend.pixels, windows, focus, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, _push_event(backend.event_queue, "destroy:" + id)))

pub fn wine_x11_poll_event(backend: WineX11BackendState) -> WineX11EventResult:
    if backend.event_queue.len() == 0:
        return _event_result(false, "event-queue-empty", backend, "")
    var queue: [text] = []
    var i = 1
    while i < backend.event_queue.len():
        queue.push(backend.event_queue[i])
        i = i + 1
    _event_result(true, "event", _backend(backend.features, backend.events, backend.pixels, backend.mapped_windows, backend.focused_window, backend.clipboard_text, backend.cursor_name, backend.os_evidence, backend.properties, queue), backend.event_queue[0])

pub fn wine_x11_backend_feature_gate(backend: WineX11BackendState) -> text:
    x11_backend_gate(backend.features)

pub fn wine_x11_backend_event_state(backend: WineX11BackendState) -> text:
    x11_backend_event_gate(backend.events)

pub fn wine_x11_backend_pixel_state(backend: WineX11BackendState) -> text:
    x11_backend_pixel_gate(backend.pixels)

pub fn wine_x11_backend_property_state(backend: WineX11BackendState) -> text:
    x11_backend_property_gate(backend.properties)

pub fn wine_x11_backend_ready(backend: WineX11BackendState) -> text:
    val feature_state = wine_x11_backend_feature_gate(backend)
    if feature_state != "ready":
        return "blocked-feature:" + feature_state
    val event_state = wine_x11_backend_event_state(backend)
    if event_state != "ready":
        return "blocked-event:" + event_state
    val pixel_state = wine_x11_backend_pixel_state(backend)
    if pixel_state != "ready":
        return "blocked-pixel:" + pixel_state
    val property_state = wine_x11_backend_property_state(backend)
    if property_state != "ready":
        return "blocked-property:" + property_state
    "ready"

pub fn wine_x11_backend_production_ready(backend: WineX11BackendState) -> text:
    val ready_state = wine_x11_backend_ready(backend)
    if ready_state != "ready":
        return ready_state
    if not backend.os_evidence.contains("simpleos-window-record"):
        return "missing-simpleos-window-record"
    if not backend.os_evidence.contains("simpleos-framebuffer-present"):
        return "missing-simpleos-framebuffer-present"
    if not backend.os_evidence.contains("framebuffer-checksum"):
        return "missing-framebuffer-checksum"
    "ready"
