# UI Access Protocol — snapshot construction
#
# Functions for building UiAccessSnapshot from UIState, SurfaceManager, and events.

use common.ui.access_types.{
    UI_ACCESS_PROTOCOL_VERSION,
    UI_ACCESS_MAX_EVENTS,
    UiAccessEvent,
    UiAccessNode,
    UiAccessSurface,
    UiAccessSnapshot,
    ui_access_canonical_id
}
use common.ui.widget.{UIState, UITree}
use common.ui.surface.{SurfaceManager}
use common.ui.lifecycle.{LifecycleEvent}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry}
use common.ui.access_node.{_collect_access_nodes}

fn ui_access_empty_snapshot(mode: text, active_surface: text, recent_events: [UiAccessEvent]) -> UiAccessSnapshot:
    return UiAccessSnapshot(
        protocol_version: UI_ACCESS_PROTOCOL_VERSION,
        snapshot_revision: 0,
        mode: mode,
        active_surface: active_surface,
        surfaces: [],
        nodes: [],
        recent_events: recent_events
    )

fn ui_access_snapshot_from_state(state: UIState, recent_events: [UiAccessEvent]) -> UiAccessSnapshot:
    val surface_id = "main"
    val tree = state.tree
    val surface = UiAccessSurface(
        surface_id: surface_id,
        title: tree.title_text(),
        active: true,
        window_id: "",
        app_id: "",
        root_canonical_id: ui_access_canonical_id(surface_id, tree.root_node().id)
    )
    val nodes = _collect_access_nodes(surface_id, tree)
    return UiAccessSnapshot(
        protocol_version: UI_ACCESS_PROTOCOL_VERSION,
        snapshot_revision: 0,
        mode: state.mode_name(),
        active_surface: surface_id,
        surfaces: [surface],
        nodes: nodes,
        recent_events: recent_events
    )

fn ui_access_snapshot_from_session(state: UIState, surfaces: SurfaceManager, active_surface: text, recent_events: [UiAccessEvent], window_surfaces: UiWindowSurfaceRegistry) -> UiAccessSnapshot:
    var snapshot = ui_access_empty_snapshot(state.mode_name(), active_surface, recent_events)
    val ids = surfaces.surface_ids()
    if ids.len() == 0:
        return ui_access_snapshot_from_state(state, recent_events)

    var snapshot_surfaces: [UiAccessSurface] = []
    var snapshot_nodes: [UiAccessNode] = []
    for surface_id in ids:
        val tree_opt = surfaces.get(surface_id)
        if tree_opt == nil:
            pass_dn
        else:
            val tree = tree_opt
            val root = tree.root_node()
            val root_canonical_id = ui_access_canonical_id(surface_id, root.id)
            val binding = window_surfaces.for_surface(surface_id)
            var title = tree.title_text()
            var window_id = ""
            var app_id = ""
            if binding != nil:
                window_id = binding.window_id
                app_id = binding.app_id
                if title == "" and binding.title != "":
                    title = binding.title
            snapshot_surfaces = snapshot_surfaces.push(UiAccessSurface(
                surface_id: surface_id,
                title: title,
                active: surface_id == active_surface,
                window_id: window_id,
                app_id: app_id,
                root_canonical_id: root_canonical_id
            ))
            val nodes = _collect_access_nodes(surface_id, tree)
            for node in nodes:
                snapshot_nodes = snapshot_nodes.push(node)
    snapshot.surfaces = snapshot_surfaces
    snapshot.nodes = snapshot_nodes
    return snapshot

fn ui_access_snapshot_persistable(snapshot: UiAccessSnapshot) -> UiAccessSnapshot:
    var surfaces: [UiAccessSurface] = []
    for surface in snapshot.surfaces:
        surfaces = surfaces.push(UiAccessSurface(
            surface_id: surface.surface_id,
            title: surface.title,
            active: surface.active,
            window_id: "",
            app_id: surface.app_id,
            root_canonical_id: surface.root_canonical_id
        ))
    return UiAccessSnapshot(
        protocol_version: snapshot.protocol_version,
        snapshot_revision: snapshot.snapshot_revision,
        mode: snapshot.mode,
        active_surface: snapshot.active_surface,
        surfaces: surfaces,
        nodes: snapshot.nodes,
        recent_events: snapshot.recent_events
    )

fn ui_access_recent_events(events: [UiAccessEvent], count: i32) -> [UiAccessEvent]:
    if count <= 0:
        return []
    val total = events.len()
    if count >= total:
        return events
    var result: [UiAccessEvent] = []
    val start = total - count
    var idx = 0
    for event in events:
        if idx >= start:
            result = result.push(event)
        idx = idx + 1
    return result

fn ui_access_recent_surface_events(events: [UiAccessEvent], surface_id: text, count: i32) -> [UiAccessEvent]:
    if count <= 0:
        return []
    var filtered: [UiAccessEvent] = []
    for event in events:
        if event.surface_id == surface_id:
            filtered = filtered.push(event)
    return ui_access_recent_events(filtered, count)

fn ui_access_record_event(events: [UiAccessEvent], event: UiAccessEvent) -> [UiAccessEvent]:
    var updated = events.push(event)
    if updated.len() <= UI_ACCESS_MAX_EVENTS:
        return updated
    var trimmed: [UiAccessEvent] = []
    val start = updated.len() - UI_ACCESS_MAX_EVENTS
    var idx = 0
    for current in updated:
        if idx >= start:
            trimmed = trimmed.push(current)
        idx = idx + 1
    return trimmed

fn ui_access_record_action(events: [UiAccessEvent], sequence: i64, surface_id: text, widget_id: text, event_kind: text, payload: text) -> [UiAccessEvent]:
    val canonical_id = if widget_id == "": "" else: ui_access_canonical_id(surface_id, widget_id)
    val event = UiAccessEvent(
        surface_id: surface_id,
        widget_id: widget_id,
        canonical_id: canonical_id,
        event_kind: event_kind,
        payload: payload,
        sequence: sequence
    )
    return ui_access_record_event(events, event)

fn ui_access_lifecycle_events(events: [UiAccessEvent], start_sequence: i64, surface_id: text, lifecycle_events: [LifecycleEvent]) -> [UiAccessEvent]:
    var updated = events
    var seq = start_sequence
    for lifecycle_event in lifecycle_events:
        seq = seq + 1
        val event = _lifecycle_to_access_event(seq, surface_id, lifecycle_event)
        updated = ui_access_record_event(updated, event)
    return updated

fn _lifecycle_to_access_event(sequence: i64, surface_id: text, lifecycle_event: LifecycleEvent) -> UiAccessEvent:
    match lifecycle_event:
        LifecycleEvent.Mount(widget_id):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "mount",
                payload: widget_id,
                sequence: sequence
            )
        LifecycleEvent.Unmount(widget_id):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "unmount",
                payload: widget_id,
                sequence: sequence
            )
        LifecycleEvent.Update(widget_id, prop_key, prop_value):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "update",
                payload: "{prop_key}={prop_value}",
                sequence: sequence
            )
        LifecycleEvent.Action(widget_id, action_name):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "action",
                payload: action_name,
                sequence: sequence
            )
        LifecycleEvent.Focus(widget_id):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "focus",
                payload: widget_id,
                sequence: sequence
            )
        LifecycleEvent.Blur(widget_id):
            return UiAccessEvent(
                surface_id: surface_id,
                widget_id: widget_id,
                canonical_id: ui_access_canonical_id(surface_id, widget_id),
                event_kind: "blur",
                payload: widget_id,
                sequence: sequence
            )
