# Glass CSS Generation
#
# Generates comprehensive CSS for glassmorphism-styled widgets.
# Produces CSS custom properties from glass design tokens and
# component-level styles with backdrop-filter blur, translucent
# surfaces, and subtle glass-edge borders.

use common.ui.glass_tokens.{GlassDesignTokens}
use common.ui.glass_theme.{glass_design_tokens, is_glass_theme}

# =========================================================================
# Token CSS Variables
# =========================================================================

fn glass_tokens_to_css(tokens: GlassDesignTokens) -> text:
    val c = tokens.colors
    val b = tokens.blur
    val r = tokens.radius
    val sh = tokens.shadows
    val sp = tokens.spacing
    val a = tokens.animation

    var css = "  /* Glass Surface Tokens */\n"
    css = "{css}  --glass-surface-primary: {c.surface_primary};\n"
    css = "{css}  --glass-surface-secondary: {c.surface_secondary};\n"
    css = "{css}  --glass-surface-tertiary: {c.surface_tertiary};\n"
    css = "{css}  --glass-surface-elevated: {c.surface_elevated};\n"
    css = "{css}  /* Glass Text */\n"
    css = "{css}  --glass-text-primary: {c.text_primary};\n"
    css = "{css}  --glass-text-secondary: {c.text_secondary};\n"
    css = "{css}  --glass-text-tertiary: {c.text_tertiary};\n"
    css = "{css}  /* Glass Accent */\n"
    css = "{css}  --glass-accent: {c.accent};\n"
    css = "{css}  --glass-accent-hover: {c.accent_hover};\n"
    css = "{css}  /* Glass Semantic */\n"
    css = "{css}  --glass-error: {c.error};\n"
    css = "{css}  --glass-warning: {c.warning};\n"
    css = "{css}  --glass-success: {c.success};\n"
    css = "{css}  --glass-info: {c.info};\n"
    css = "{css}  /* Glass Borders */\n"
    css = "{css}  --glass-border-subtle: {c.border_subtle};\n"
    css = "{css}  --glass-border-prominent: {c.border_prominent};\n"
    css = "{css}  --glass-separator: {c.separator};\n"
    css = "{css}  /* Glass Blur */\n"
    css = "{css}  --glass-blur-surface: {b.surface_blur}px;\n"
    css = "{css}  --glass-blur-elevated: {b.elevated_blur}px;\n"
    css = "{css}  --glass-blur-nav: {b.nav_blur}px;\n"
    css = "{css}  --glass-blur-subtle: {b.subtle_blur}px;\n"
    css = "{css}  /* Glass Radius */\n"
    css = "{css}  --glass-radius-sm: {r.sm}px;\n"
    css = "{css}  --glass-radius-md: {r.md}px;\n"
    css = "{css}  --glass-radius-lg: {r.lg}px;\n"
    css = "{css}  --glass-radius-xl: {r.xl}px;\n"
    css = "{css}  /* Glass Shadows */\n"
    css = "{css}  --glass-shadow-sm: {sh.sm};\n"
    css = "{css}  --glass-shadow-md: {sh.md};\n"
    css = "{css}  --glass-shadow-lg: {sh.lg};\n"
    css = "{css}  /* Glass Spacing */\n"
    css = "{css}  --glass-spacing-xs: {sp.s1}px;\n"
    css = "{css}  --glass-spacing-sm: {sp.s2}px;\n"
    css = "{css}  --glass-spacing-md: {sp.s4}px;\n"
    css = "{css}  --glass-spacing-lg: {sp.s6}px;\n"
    css = "{css}  --glass-spacing-xl: {sp.s8}px;\n"
    css = "{css}  /* Glass Animation */\n"
    css = "{css}  --glass-duration-fast: {a.duration_fast}ms;\n"
    css = "{css}  --glass-duration-normal: {a.duration_normal}ms;\n"
    css = "{css}  --glass-easing: {a.easing_default};\n"
    css

# =========================================================================
# Glass Component CSS
# =========================================================================

fn glass_component_css(theme_name: text) -> text:
    val is_dark = theme_name == "glass_dark"

    var css = "\n/* ===== Glass Component Overrides ===== */\n\n"

    # Base glass mixin (applied to surface elements)
    css = "{css}/* Panel */\n"
    css = "{css}.widget-panel {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing),\n"
    css = "{css}             box-shadow var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n\n"

    # Card
    css = "{css}.widget-card {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}  padding: var(--glass-spacing-md);\n"
    css = "{css}}\n"
    css = "{css}.widget-card:hover {\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  border-color: var(--glass-border-prominent);\n"
    css = "{css}}\n\n"

    # Button
    css = "{css}.widget-button {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}  font-weight: 500;\n"
    css = "{css}}\n"
    css = "{css}.widget-button:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  border-color: var(--glass-border-prominent);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n"
    css = "{css}.widget-button:active {\n"
    css = "{css}  transform: scale(0.98);\n"
    css = "{css}}\n"
    css = "{css}.widget-button.primary {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}  border-color: transparent;\n"
    css = "{css}}\n"
    css = "{css}.widget-button.primary:hover {\n"
    css = "{css}  background: var(--glass-accent-hover);\n"
    css = "{css}}\n\n"

    # Navigation bar
    css = "{css}.widget-navigation-bar, .widget-menubar {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  position: sticky;\n"
    css = "{css}  top: 0;\n"
    css = "{css}  z-index: 100;\n"
    css = "{css}}\n\n"

    # Statusbar
    css = "{css}.widget-statusbar {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-top: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n\n"

    # Dialog / Modal
    css = "{css}.widget-dialog {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-xl);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}}\n"
    css = "{css}.widget-dialog-overlay {\n"
    css = "{css}  background: rgba(0,0,0,0.3);\n"
    css = "{css}  backdrop-filter: blur(4px);\n"
    css = "{css}  -webkit-backdrop-filter: blur(4px);\n"
    css = "{css}}\n\n"

    # Input / TextField / Textarea
    css = "{css}.widget-input, .widget-text-field, .widget-textarea {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  transition: border-color var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-input:focus, .widget-text-field:focus, .widget-textarea:focus {\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}  outline: none;\n"
    css = "{css}  box-shadow: 0 0 0 3px rgba(10,132,255,0.2);\n"
    css = "{css}}\n\n"

    # Tabs
    css = "{css}.widget-tabs {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  padding: 2px;\n"
    css = "{css}}\n"
    css = "{css}.widget-tabs .tab-active {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n\n"

    # List
    css = "{css}.widget-list {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}}\n"
    css = "{css}.widget-list .list-item:hover {\n"
    css = "{css}  background: var(--ui-hover-bg);\n"
    css = "{css}}\n"
    css = "{css}.widget-list .list-item.selected {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}}\n\n"

    # Tooltip
    css = "{css}.widget-tooltip {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-sm);\n"
    css = "{css}}\n\n"

    # Dropdown
    css = "{css}.widget-dropdown {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}}\n"
    css = "{css}.widget-dropdown-menu {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}}\n\n"

    # Progress bar
    css = "{css}.widget-progress {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  overflow: hidden;\n"
    css = "{css}}\n"
    css = "{css}.widget-progress .progress-fill {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  transition: width var(--glass-duration-normal) var(--glass-easing);\n"
    css = "{css}}\n\n"

    # Checkbox / Switch
    css = "{css}.widget-checkbox {\n"
    css = "{css}  accent-color: var(--glass-accent);\n"
    css = "{css}}\n\n"

    # Divider
    css = "{css}.widget-divider {\n"
    css = "{css}  border-color: var(--glass-separator);\n"
    css = "{css}}\n\n"

    # Scrollbar
    css = "{css}::-webkit-scrollbar {\n"
    css = "{css}  width: 8px;\n"
    css = "{css}  height: 8px;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-track {\n"
    css = "{css}  background: transparent;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-thumb {\n"
    css = "{css}  background: var(--glass-border-prominent);\n"
    css = "{css}  border-radius: 4px;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-thumb:hover {\n"
    css = "{css}  background: var(--glass-text-tertiary);\n"
    css = "{css}}\n\n"

    # Typography helpers
    css = "{css}.text-secondary {\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n"
    css = "{css}.text-tertiary {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}}\n"

    css

# =========================================================================
# Combined Glass CSS Entry Point
# =========================================================================

fn generate_glass_css(theme_name: text) -> text:
    if not is_glass_theme(theme_name):
        return ""
    val tokens = glass_design_tokens(theme_name)
    var css = "\n/* ===== Glass Design Tokens ===== */\n"
    css = "{css}:root {\n"
    css = "{css}" + glass_tokens_to_css(tokens)
    css = "{css}}\n"
    css = "{css}" + glass_component_css(theme_name)
    css
