# Glass CSS Generation
#
# Generates comprehensive CSS for glassmorphism-styled widgets.
# Produces CSS custom properties from glass design tokens and
# component-level styles with backdrop-filter blur, translucent
# surfaces, and subtle glass-edge borders.

use common.ui.glass_tokens.{GlassDesignTokens}
use common.ui.glass_theme.{glass_design_tokens, is_glass_theme}

# =========================================================================
# Token CSS Variables
# =========================================================================

fn glass_tokens_to_css(tokens: GlassDesignTokens) -> text:
    val c = tokens.colors
    val b = tokens.blur
    val r = tokens.radius
    val sh = tokens.shadows
    val sp = tokens.spacing
    val a = tokens.animation

    var css = "  /* Glass Surface Tokens */\n"
    css = "{css}  --glass-surface-primary: {c.surface_primary};\n"
    css = "{css}  --glass-surface-secondary: {c.surface_secondary};\n"
    css = "{css}  --glass-surface-tertiary: {c.surface_tertiary};\n"
    css = "{css}  --glass-surface-elevated: {c.surface_elevated};\n"
    css = "{css}  /* Glass Text */\n"
    css = "{css}  --glass-text-primary: {c.text_primary};\n"
    css = "{css}  --glass-text-secondary: {c.text_secondary};\n"
    css = "{css}  --glass-text-tertiary: {c.text_tertiary};\n"
    css = "{css}  /* Glass Accent */\n"
    css = "{css}  --glass-accent: {c.accent};\n"
    css = "{css}  --glass-accent-hover: {c.accent_hover};\n"
    css = "{css}  /* Glass Semantic */\n"
    css = "{css}  --glass-error: {c.error};\n"
    css = "{css}  --glass-warning: {c.warning};\n"
    css = "{css}  --glass-success: {c.success};\n"
    css = "{css}  --glass-info: {c.info};\n"
    css = "{css}  /* Glass Borders */\n"
    css = "{css}  --glass-border-subtle: {c.border_subtle};\n"
    css = "{css}  --glass-border-prominent: {c.border_prominent};\n"
    css = "{css}  --glass-separator: {c.separator};\n"
    css = "{css}  /* Glass Blur */\n"
    css = "{css}  --glass-blur-surface: {b.surface_blur}px;\n"
    css = "{css}  --glass-blur-elevated: {b.elevated_blur}px;\n"
    css = "{css}  --glass-blur-nav: {b.nav_blur}px;\n"
    css = "{css}  --glass-blur-subtle: {b.subtle_blur}px;\n"
    css = "{css}  /* Glass Radius */\n"
    css = "{css}  --glass-radius-sm: {r.sm}px;\n"
    css = "{css}  --glass-radius-md: {r.md}px;\n"
    css = "{css}  --glass-radius-lg: {r.lg}px;\n"
    css = "{css}  --glass-radius-xl: {r.xl}px;\n"
    css = "{css}  /* Glass Shadows (multi-layer with ring + inset glow) */\n"
    css = "{css}  --glass-shadow-sm: {sh.sm};\n"
    css = "{css}  --glass-shadow-md: {sh.md};\n"
    css = "{css}  --glass-shadow-lg: {sh.lg};\n"
    css = "{css}  --glass-shadow-xl: {sh.xl};\n"
    css = "{css}  /* Glass Spacing */\n"
    css = "{css}  --glass-spacing-xs: {sp.s1}px;\n"
    css = "{css}  --glass-spacing-sm: {sp.s2}px;\n"
    css = "{css}  --glass-spacing-md: {sp.s4}px;\n"
    css = "{css}  --glass-spacing-lg: {sp.s6}px;\n"
    css = "{css}  --glass-spacing-xl: {sp.s8}px;\n"
    css = "{css}  /* Glass Animation */\n"
    css = "{css}  --glass-duration-fast: {a.duration_fast}ms;\n"
    css = "{css}  --glass-duration-normal: {a.duration_normal}ms;\n"
    css = "{css}  --glass-easing: {a.easing_default};\n"
    css

# =========================================================================
# Glass Component CSS
# =========================================================================

fn glass_component_css(theme_name: text) -> text:
    val is_dark = theme_name == "glass_dark"

    var css = "\n/* ===== Glass Component Overrides ===== */\n\n"

    # Base glass mixin (applied to surface elements)
    css = "{css}/* Panel */\n"
    css = "{css}.widget-panel {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-top-color: rgba(255,255,255,0.20);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing),\n"
    css = "{css}             box-shadow var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n\n"

    # Card
    css = "{css}.widget-card {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}  padding: var(--glass-spacing-md);\n"
    css = "{css}}\n"
    css = "{css}.widget-card:hover {\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  border-color: var(--glass-border-prominent);\n"
    css = "{css}}\n\n"

    # Button
    css = "{css}.widget-button {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}  font-weight: 500;\n"
    css = "{css}}\n"
    css = "{css}.widget-button:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  border-color: var(--glass-border-prominent);\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n"
    css = "{css}.widget-button:active {\n"
    css = "{css}  transform: scale(0.98);\n"
    css = "{css}}\n"
    css = "{css}.widget-button.primary {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}  border-color: transparent;\n"
    css = "{css}}\n"
    css = "{css}.widget-button.primary:hover {\n"
    css = "{css}  background: var(--glass-accent-hover);\n"
    css = "{css}}\n\n"

    # Navigation bar
    css = "{css}.widget-navigation-bar, .widget-menubar {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  position: sticky;\n"
    css = "{css}  top: 0;\n"
    css = "{css}  z-index: 100;\n"
    css = "{css}}\n\n"

    # Statusbar
    css = "{css}.widget-statusbar {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-top: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n\n"

    # Dialog / Modal
    css = "{css}.widget-dialog {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-xl);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}}\n"
    css = "{css}.widget-dialog-overlay {\n"
    css = "{css}  background: rgba(0,0,0,0.3);\n"
    css = "{css}  backdrop-filter: blur(4px);\n"
    css = "{css}  -webkit-backdrop-filter: blur(4px);\n"
    css = "{css}}\n\n"

    # Window Chrome (Stitch-aligned glassmorphism window frame)
    css = "{css}.glass-window {\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-top-color: rgba(255,255,255,0.20);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}  overflow: hidden;\n"
    css = "{css}}\n"
    css = "{css}.glass-window.focused {\n"
    css = "{css}  border-color: var(--glass-border-prominent);\n"
    css = "{css}  border-top-color: rgba(255,255,255,0.30);\n"
    css = "{css}  box-shadow: var(--glass-shadow-xl);\n"
    css = "{css}}\n"
    css = "{css}.glass-window.inactive {\n"
    css = "{css}  opacity: 0.85;\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n\n"

    # Title bar with traffic light buttons
    css = "{css}.glass-titlebar {\n"
    css = "{css}  height: 28px;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  padding: 0 12px;\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  position: relative;\n"
    css = "{css}}\n"
    css = "{css}.glass-titlebar::after {\n"
    css = "{css}  content: '';\n"
    css = "{css}  position: absolute;\n"
    css = "{css}  top: 0;\n"
    css = "{css}  left: 0;\n"
    css = "{css}  right: 0;\n"
    css = "{css}  height: 1px;\n"
    css = "{css}  background: rgba(255,255,255,0.12);\n"
    css = "{css}}\n"
    css = "{css}.glass-titlebar .title {\n"
    css = "{css}  flex: 1;\n"
    css = "{css}  text-align: center;\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  font-weight: 500;\n"
    css = "{css}}\n"
    css = "{css}.traffic-lights {\n"
    css = "{css}  display: flex;\n"
    css = "{css}  gap: 8px;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}}\n"
    css = "{css}.traffic-light {\n"
    css = "{css}  width: 12px;\n"
    css = "{css}  height: 12px;\n"
    css = "{css}  border-radius: 50%;\n"
    css = "{css}  border: none;\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}}\n"
    css = "{css}.traffic-light.close { background: #FF5F57; }\n"
    css = "{css}.traffic-light.minimize { background: #FFBD2E; }\n"
    css = "{css}.traffic-light.maximize { background: #28CA41; }\n\n"

    # System bar
    css = "{css}.glass-systembar {\n"
    css = "{css}  height: 28px;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  justify-content: space-between;\n"
    css = "{css}  padding: 0 16px;\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  top: 0;\n"
    css = "{css}  left: 0;\n"
    css = "{css}  right: 0;\n"
    css = "{css}  z-index: 1000;\n"
    css = "{css}}\n\n"

    # Dock
    css = "{css}.glass-dock {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: 26px;\n"
    css = "{css}  padding: 6px 16px;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  gap: 16px;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  bottom: 6px;\n"
    css = "{css}  left: 50%;\n"
    css = "{css}  transform: translateX(-50%);\n"
    css = "{css}  z-index: 1000;\n"
    css = "{css}}\n"
    css = "{css}.glass-dock .dock-icon {\n"
    css = "{css}  width: 40px;\n"
    css = "{css}  height: 40px;\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  justify-content: center;\n"
    css = "{css}  transition: transform var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}}\n"
    css = "{css}.glass-dock .dock-icon:hover {\n"
    css = "{css}  transform: scale(1.3);\n"
    css = "{css}}\n"
    css = "{css}.glass-dock .dock-indicator {\n"
    css = "{css}  width: 4px;\n"
    css = "{css}  height: 4px;\n"
    css = "{css}  border-radius: 50%;\n"
    css = "{css}  background: var(--glass-text-secondary);\n"
    css = "{css}}\n\n"

    # Input / TextField / Textarea
    css = "{css}.widget-input, .widget-textfield, .widget-text-field, .widget-textarea {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  transition: border-color var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-input:focus, .widget-textfield:focus, .widget-text-field:focus, .widget-textarea:focus {\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}  outline: none;\n"
    css = "{css}  box-shadow: 0 0 0 3px color-mix(in srgb, var(--glass-accent) 25%, transparent);\n"
    css = "{css}}\n\n"

    # Tabs
    css = "{css}.widget-tabs {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: 0;\n"
    css = "{css}  padding: 0 var(--glass-spacing-sm);\n"
    css = "{css}}\n"
    css = "{css}.tab-item {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  border-bottom: 2px solid transparent;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.tab-item.active, .widget-tabs .tab-active {\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}  border-bottom-color: var(--glass-accent);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  background: var(--glass-surface-primary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm) var(--glass-radius-sm) 0 0;\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n"
    css = "{css}.tab-item:hover {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm) var(--glass-radius-sm) 0 0;\n"
    css = "{css}}\n\n"

    # List
    css = "{css}.widget-list {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}}\n"
    css = "{css}.widget-list .list-item:hover {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}}\n"
    css = "{css}.widget-list .list-item.selected {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}}\n\n"

    # Tooltip
    css = "{css}.tooltip-content {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-sm);\n"
    css = "{css}}\n"
    css = "{css}.tooltip-trigger {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  border-bottom-color: var(--glass-text-tertiary);\n"
    css = "{css}}\n\n"

    # Dropdown
    css = "{css}.widget-dropdown {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-subtle));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}}\n"
    css = "{css}.widget-dropdown-menu {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}}\n\n"

    # Progress bar
    css = "{css}.widget-progress {\n"
    css = "{css}  padding: var(--glass-spacing-sm) 0;\n"
    css = "{css}}\n"
    css = "{css}.widget-progress .progress-track {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  height: 4px;\n"
    css = "{css}  overflow: hidden;\n"
    css = "{css}}\n"
    css = "{css}.widget-progress .progress-bar, .widget-progress .progress-fill {\n"
    css = "{css}  background: linear-gradient(90deg, var(--glass-accent), var(--glass-success));\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  transition: width var(--glass-duration-normal) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.progress-label {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}}\n\n"

    # Checkbox / Switch
    css = "{css}.widget-checkbox {\n"
    css = "{css}  accent-color: var(--glass-accent);\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-sm);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-checkbox:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n"
    css = "{css}.widget-checkbox .check-box {\n"
    css = "{css}  border: 2px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-checkbox.checked .check-box {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}}\n"
    css = "{css}.widget-checkbox:hover .check-box {\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}}\n"
    css = "{css}.widget-checkbox.disabled {\n"
    css = "{css}  opacity: 0.4;\n"
    css = "{css}  cursor: not-allowed;\n"
    css = "{css}}\n\n"

    # Divider
    css = "{css}.widget-divider {\n"
    css = "{css}  border-color: var(--glass-separator);\n"
    css = "{css}}\n\n"

    # Scrollbar
    css = "{css}::-webkit-scrollbar {\n"
    css = "{css}  width: 8px;\n"
    css = "{css}  height: 8px;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-track {\n"
    css = "{css}  background: transparent;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-thumb {\n"
    css = "{css}  background: var(--glass-border-prominent);\n"
    css = "{css}  border-radius: 4px;\n"
    css = "{css}}\n"
    css = "{css}::-webkit-scrollbar-thumb:hover {\n"
    css = "{css}  background: var(--glass-text-tertiary);\n"
    css = "{css}}\n\n"

    # Typography helpers
    css = "{css}.text-secondary {\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n"
    css = "{css}.text-tertiary {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}}\n\n"

    # ── Body / Base ──
    css = "{css}body {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  -webkit-font-smoothing: antialiased;\n"
    css = "{css}  -moz-osx-font-smoothing: grayscale;\n"
    css = "{css}}\n\n"

    # ── Layout gaps ──
    css = "{css}.layout-vbox {\n"
    css = "{css}  gap: var(--glass-spacing-sm);\n"
    css = "{css}}\n"
    css = "{css}.layout-hbox {\n"
    css = "{css}  gap: var(--glass-spacing-sm);\n"
    css = "{css}}\n"
    css = "{css}.layout-grid {\n"
    css = "{css}  gap: var(--glass-spacing-md);\n"
    css = "{css}}\n\n"

    # ── Panel sub-elements ──
    css = "{css}.panel-title {\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  font-size: 11px;\n"
    css = "{css}  text-transform: uppercase;\n"
    css = "{css}  letter-spacing: 1.2px;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  background: transparent;\n"
    css = "{css}}\n"
    css = "{css}.panel-content {\n"
    css = "{css}  padding: var(--glass-spacing-md);\n"
    css = "{css}  gap: var(--glass-spacing-sm);\n"
    css = "{css}}\n\n"

    # ── Text ──
    css = "{css}.widget-text {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-sm);\n"
    css = "{css}  line-height: 1.5;\n"
    css = "{css}}\n"
    css = "{css}.widget-text.focused {\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}}\n\n"

    # ── Heading ──
    css = "{css}.widget-heading {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  font-weight: 700;\n"
    css = "{css}  border-bottom: 2px solid var(--glass-accent);\n"
    css = "{css}  margin-bottom: var(--glass-spacing-sm);\n"
    css = "{css}}\n"
    css = "{css}h1.widget-heading {\n"
    css = "{css}  font-size: 20px;\n"
    css = "{css}}\n"
    css = "{css}h2.widget-heading {\n"
    css = "{css}  font-size: 16px;\n"
    css = "{css}}\n"
    css = "{css}h3.widget-heading {\n"
    css = "{css}  font-size: 14px;\n"
    css = "{css}}\n\n"

    # ── Table ──
    css = "{css}.table-filter {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-sm);\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}}\n"
    css = "{css}.table-filter:focus {\n"
    css = "{css}  outline: none;\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}}\n"
    css = "{css}.widget-table {\n"
    css = "{css}  border-collapse: separate;\n"
    css = "{css}  border-spacing: 0;\n"
    css = "{css}}\n"
    css = "{css}.widget-table th {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  font-size: 11px;\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  text-transform: uppercase;\n"
    css = "{css}  letter-spacing: 0.5px;\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-prominent);\n"
    css = "{css}}\n"
    css = "{css}.widget-table th:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n"
    css = "{css}.widget-table td {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n"
    css = "{css}.widget-table tr:hover td {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n\n"

    # ── Image ──
    css = "{css}.widget-image {\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  max-width: 100%;\n"
    css = "{css}  height: auto;\n"
    css = "{css}}\n\n"

    # ── Tree ──
    css = "{css}.widget-tree {\n"
    css = "{css}  padding: var(--glass-spacing-xs) 0;\n"
    css = "{css}}\n"
    css = "{css}.tree-root {\n"
    css = "{css}  list-style: none;\n"
    css = "{css}  padding-left: 0;\n"
    css = "{css}}\n"
    css = "{css}.tree-node ul {\n"
    css = "{css}  list-style: none;\n"
    css = "{css}}\n"
    css = "{css}.tree-toggle {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}}\n"
    css = "{css}.tree-toggle:hover {\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}}\n"
    css = "{css}.tree-label {\n"
    css = "{css}  padding: 2px var(--glass-spacing-xs);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}}\n"
    css = "{css}.tree-label:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n\n"

    # ── Scroll container ──
    css = "{css}.widget-scroll {\n"
    css = "{css}  scrollbar-width: thin;\n"
    css = "{css}  scrollbar-color: var(--glass-border-prominent) transparent;\n"
    css = "{css}}\n"
    css = "{css}.widget-scroll::-webkit-scrollbar {\n"
    css = "{css}  width: 6px;\n"
    css = "{css}}\n"
    css = "{css}.widget-scroll::-webkit-scrollbar-thumb {\n"
    css = "{css}  background: var(--glass-border-prominent);\n"
    css = "{css}  border-radius: 3px;\n"
    css = "{css}}\n"
    css = "{css}.widget-scroll::-webkit-scrollbar-thumb:hover {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}}\n\n"

    # ── MenuBar sub-elements ──
    css = "{css}.menu-item {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.menu-item:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n"
    css = "{css}.menu-separator {\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}}\n"
    css = "{css}.menu-item.has-submenu .submenu {\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated));\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}}\n"
    css = "{css}.submenu-item {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.submenu-item:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}}\n\n"

    # ── Dialog sub-elements ──
    css = "{css}.dialog-title {\n"
    css = "{css}  padding: var(--glass-spacing-md) var(--glass-spacing-lg);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  font-size: 15px;\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n"
    css = "{css}.dialog-content {\n"
    css = "{css}  padding: var(--glass-spacing-lg);\n"
    css = "{css}}\n\n"

    # ── StatusBar sub-elements ──
    css = "{css}.status-left {\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n"
    css = "{css}.status-right {\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n\n"

    # ── Focus ring ──
    css = "{css}[data-focused=true] {\n"
    css = "{css}  outline: none;\n"
    css = "{css}  box-shadow: 0 0 0 3px rgba(10,132,255,0.25);\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}}\n\n"

    # ── Disabled states ──
    css = "{css}.widget-input:disabled, .widget-input[disabled],\n"
    css = "{css}.widget-textfield:disabled, .widget-textfield[disabled],\n"
    css = "{css}.widget-textarea:disabled, .widget-textarea[disabled],\n"
    css = "{css}.widget-dropdown:disabled, .widget-dropdown[disabled] {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  cursor: not-allowed;\n"
    css = "{css}  opacity: 0.5;\n"
    css = "{css}}\n"
    css = "{css}.widget-input[readonly],\n"
    css = "{css}.widget-textfield[readonly],\n"
    css = "{css}.widget-textarea[readonly] {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}}\n"
    css = "{css}.widget-input.error,\n"
    css = "{css}.widget-textfield.error,\n"
    css = "{css}.widget-textarea.error {\n"
    css = "{css}  border-color: var(--glass-error);\n"
    css = "{css}}\n"
    css = "{css}.widget-button:disabled, .widget-button[disabled] {\n"
    css = "{css}  opacity: 0.4;\n"
    css = "{css}  cursor: not-allowed;\n"
    css = "{css}  transform: none;\n"
    css = "{css}  box-shadow: none;\n"
    css = "{css}}\n"

    css

# =========================================================================
# Combined Glass CSS Entry Point
# =========================================================================

fn generate_glass_css(theme_name: text) -> text:
    if not is_glass_theme(theme_name):
        return ""
    val tokens = glass_design_tokens(theme_name)
    var css = "\n/* ===== Glass Design Tokens ===== */\n"
    css = "{css}:root {\n"
    css = "{css}" + glass_tokens_to_css(tokens)
    css = "{css}}\n"
    css = "{css}" + glass_component_css(theme_name)
    css
