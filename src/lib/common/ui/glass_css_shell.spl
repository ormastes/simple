# Glass CSS — Shell Widget Components
#
# CSS rules for glass shell UI: command palette, sidebar, toast/snackbar,
# sheet modal, context menu, inspector, utility rail, status chip,
# selection pill, empty state, command bar, workspace tabs, and
# glass title bar. Called from glass_css_components.spl via glass_shell_css().

fn glass_shell_css() -> text:
    var css = ""

    # Glass Shell: Command Palette
    css = "{css}.widget-command-palette {\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  top: 20%;\n"
    css = "{css}  left: 50%;\n"
    css = "{css}  transform: translateX(-50%);\n"
    css = "{css}  width: min(560px, 90vw);\n"
    css = "{css}  max-height: 420px;\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated)) saturate(180%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated)) saturate(180%);\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-xl);\n"
    css = "{css}  box-shadow: var(--glass-shadow-xl);\n"
    css = "{css}  overflow: hidden;\n"
    css = "{css}  z-index: 9000;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}}\n"
    css = "{css}.widget-command-palette .palette-input {\n"
    css = "{css}  padding: var(--glass-spacing-md) var(--glass-spacing-lg);\n"
    css = "{css}  background: transparent;\n"
    css = "{css}  border: none;\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  font-size: 15px;\n"
    css = "{css}}\n"
    css = "{css}.widget-command-palette .palette-input:focus {\n"
    css = "{css}  outline: none;\n"
    css = "{css}}\n"
    css = "{css}.widget-command-palette .palette-results {\n"
    css = "{css}  overflow-y: auto;\n"
    css = "{css}  padding: var(--glass-spacing-xs) 0;\n"
    css = "{css}}\n"
    css = "{css}.widget-command-palette .palette-item {\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-lg);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-command-palette .palette-item:hover,\n"
    css = "{css}.widget-command-palette .palette-item.active {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}}\n\n"

    # Glass Shell: Sidebar
    css = "{css}.widget-sidebar {\n"
    css = "{css}  width: 220px;\n"
    css = "{css}  min-width: 200px;\n"
    css = "{css}  max-width: 240px;\n"
    css = "{css}  background: var(--glass-surface-container-lowest);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface)) saturate(140%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface)) saturate(140%);\n"
    css = "{css}  border-right: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}  overflow-y: auto;\n"
    css = "{css}  transition: width 220ms var(--glass-easing),\n"
    css = "{css}             opacity 220ms var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-sidebar.collapsed {\n"
    css = "{css}  width: 0;\n"
    css = "{css}  min-width: 0;\n"
    css = "{css}  opacity: 0;\n"
    css = "{css}  overflow: hidden;\n"
    css = "{css}}\n\n"

    # Glass Shell: Toast / Snackbar
    css = "{css}.widget-toast {\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  bottom: 24px;\n"
    css = "{css}  right: 24px;\n"
    css = "{css}  min-width: 280px;\n"
    css = "{css}  max-width: 400px;\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  background: var(--glass-surface-container-high);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated)) saturate(160%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated)) saturate(160%);\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  z-index: 8000;\n"
    css = "{css}  animation: toast-rise 240ms var(--glass-easing) forwards;\n"
    css = "{css}}\n"
    css = "{css}.widget-toast.info { border-left: 3px solid var(--glass-info); }\n"
    css = "{css}.widget-toast.success { border-left: 3px solid var(--glass-success); }\n"
    css = "{css}.widget-toast.warning { border-left: 3px solid var(--glass-warning); }\n"
    css = "{css}.widget-toast.error { border-left: 3px solid var(--glass-error); }\n"
    css = "{css}@keyframes toast-rise {\n"
    css = "{css}  from { opacity: 0; transform: translateY(8px); }\n"
    css = "{css}  to   { opacity: 1; transform: translateY(0); }\n"
    css = "{css}}\n\n"

    # Glass Shell: Sheet Modal
    css = "{css}.widget-sheet-modal-overlay {\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  inset: 0;\n"
    css = "{css}  background: rgba(0,0,0,0.35);\n"
    css = "{css}  backdrop-filter: blur(4px);\n"
    css = "{css}  -webkit-backdrop-filter: blur(4px);\n"
    css = "{css}  z-index: 8500;\n"
    css = "{css}}\n"
    css = "{css}.widget-sheet-modal {\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  bottom: 0;\n"
    css = "{css}  left: 0;\n"
    css = "{css}  right: 0;\n"
    css = "{css}  max-height: 85vh;\n"
    css = "{css}  background: var(--glass-surface-elevated);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated)) saturate(180%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated)) saturate(180%);\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-bottom: none;\n"
    css = "{css}  border-radius: var(--glass-radius-xl) var(--glass-radius-xl) 0 0;\n"
    css = "{css}  box-shadow: var(--glass-shadow-xl);\n"
    css = "{css}  z-index: 9000;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}  animation: sheet-slide-up 280ms var(--glass-easing) forwards;\n"
    css = "{css}}\n"
    css = "{css}.widget-sheet-modal .sheet-handle {\n"
    css = "{css}  width: 36px;\n"
    css = "{css}  height: 4px;\n"
    css = "{css}  border-radius: 2px;\n"
    css = "{css}  background: var(--glass-border-prominent);\n"
    css = "{css}  margin: var(--glass-spacing-sm) auto;\n"
    css = "{css}}\n"
    css = "{css}.widget-sheet-modal .sheet-title {\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-lg);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  font-size: 15px;\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n"
    css = "{css}.widget-sheet-modal .sheet-content {\n"
    css = "{css}  padding: var(--glass-spacing-lg);\n"
    css = "{css}  overflow-y: auto;\n"
    css = "{css}}\n"
    css = "{css}@keyframes sheet-slide-up {\n"
    css = "{css}  from { transform: translateY(100%); }\n"
    css = "{css}  to   { transform: translateY(0); }\n"
    css = "{css}}\n\n"

    # Glass Shell: Context Menu
    css = "{css}.widget-context-menu {\n"
    css = "{css}  position: absolute;\n"
    css = "{css}  min-width: 180px;\n"
    css = "{css}  background: var(--glass-surface-container-high);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-elevated)) saturate(160%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-elevated)) saturate(160%);\n"
    css = "{css}  border: 1px solid var(--glass-border-prominent);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  box-shadow: var(--glass-shadow-lg);\n"
    css = "{css}  padding: var(--glass-spacing-xs) 0;\n"
    css = "{css}  z-index: 8000;\n"
    css = "{css}}\n"
    css = "{css}.widget-context-menu .context-item {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: background var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-context-menu .context-item:hover {\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}}\n\n"

    # Glass Shell: Inspector (floating right panel)
    css = "{css}.widget-inspector {\n"
    css = "{css}  position: fixed;\n"
    css = "{css}  top: 40px;\n"
    css = "{css}  right: 12px;\n"
    css = "{css}  width: 280px;\n"
    css = "{css}  max-height: calc(100vh - 80px);\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface)) saturate(150%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface)) saturate(150%);\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}  box-shadow: var(--glass-shadow-md);\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}  overflow-y: auto;\n"
    css = "{css}  z-index: 500;\n"
    css = "{css}}\n"
    css = "{css}.widget-inspector .inspector-title {\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}  text-transform: uppercase;\n"
    css = "{css}  letter-spacing: 0.8px;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}}\n"
    css = "{css}.widget-inspector .inspector-content {\n"
    css = "{css}  padding: var(--glass-spacing-md);\n"
    css = "{css}  gap: var(--glass-spacing-sm);\n"
    css = "{css}}\n\n"

    # Glass Shell: Utility Rail
    css = "{css}.widget-utility-rail {\n"
    css = "{css}  width: 48px;\n"
    css = "{css}  background: var(--glass-surface-container-lowest);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface));\n"
    css = "{css}  border-right: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  padding: var(--glass-spacing-sm) 0;\n"
    css = "{css}  gap: var(--glass-spacing-xs);\n"
    css = "{css}}\n"
    css = "{css}.widget-utility-rail .rail-icon {\n"
    css = "{css}  width: 36px;\n"
    css = "{css}  height: 36px;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  justify-content: center;\n"
    css = "{css}  border-radius: var(--glass-radius-sm);\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-utility-rail .rail-icon:hover {\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}}\n"
    css = "{css}.widget-utility-rail .rail-icon.active {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}}\n\n"

    # Glass Shell: Status Chip
    css = "{css}.widget-status-chip {\n"
    css = "{css}  display: inline-flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  padding: 2px var(--glass-spacing-sm);\n"
    css = "{css}  border-radius: 100px;\n"
    css = "{css}  font-size: 11px;\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  letter-spacing: 0.3px;\n"
    css = "{css}}\n"
    css = "{css}.widget-status-chip.info {\n"
    css = "{css}  background: color-mix(in srgb, var(--glass-info) 15%, transparent);\n"
    css = "{css}  color: var(--glass-info);\n"
    css = "{css}}\n"
    css = "{css}.widget-status-chip.success {\n"
    css = "{css}  background: color-mix(in srgb, var(--glass-success) 15%, transparent);\n"
    css = "{css}  color: var(--glass-success);\n"
    css = "{css}}\n"
    css = "{css}.widget-status-chip.warning {\n"
    css = "{css}  background: color-mix(in srgb, var(--glass-warning) 15%, transparent);\n"
    css = "{css}  color: var(--glass-warning);\n"
    css = "{css}}\n"
    css = "{css}.widget-status-chip.error {\n"
    css = "{css}  background: color-mix(in srgb, var(--glass-error) 15%, transparent);\n"
    css = "{css}  color: var(--glass-error);\n"
    css = "{css}}\n\n"

    # Glass Shell: Selection Pill
    css = "{css}.widget-selection-pill {\n"
    css = "{css}  display: inline-flex;\n"
    css = "{css}  background: var(--glass-surface-tertiary);\n"
    css = "{css}  border-radius: 100px;\n"
    css = "{css}  padding: 2px;\n"
    css = "{css}  gap: 2px;\n"
    css = "{css}}\n"
    css = "{css}.widget-selection-pill .pill-item {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  border-radius: 100px;\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-selection-pill .pill-item:hover {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}}\n"
    css = "{css}.widget-selection-pill .pill-item.active {\n"
    css = "{css}  background: var(--glass-accent);\n"
    css = "{css}  color: #FFFFFF;\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  box-shadow: var(--glass-shadow-sm);\n"
    css = "{css}}\n\n"

    # Glass Shell: Empty State
    css = "{css}.widget-empty-state {\n"
    css = "{css}  display: flex;\n"
    css = "{css}  flex-direction: column;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  justify-content: center;\n"
    css = "{css}  padding: var(--glass-spacing-xl);\n"
    css = "{css}  text-align: center;\n"
    css = "{css}  background: linear-gradient(\n"
    css = "{css}    135deg,\n"
    css = "{css}    var(--glass-surface-secondary),\n"
    css = "{css}    var(--glass-surface-container-low)\n"
    css = "{css}  );\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-lg);\n"
    css = "{css}}\n"
    css = "{css}.widget-empty-state .empty-title {\n"
    css = "{css}  font-size: 16px;\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  margin-bottom: var(--glass-spacing-xs);\n"
    css = "{css}}\n"
    css = "{css}.widget-empty-state .empty-subtitle {\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n\n"

    # Glass Shell: Command Bar
    css = "{css}.widget-command-bar {\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  width: 100%;\n"
    css = "{css}  padding: var(--glass-spacing-sm) var(--glass-spacing-md);\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-surface)) saturate(140%);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-surface)) saturate(140%);\n"
    css = "{css}  border: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  border-radius: var(--glass-radius-md);\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  transition: border-color var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-command-bar:focus-within {\n"
    css = "{css}  border-color: var(--glass-accent);\n"
    css = "{css}  box-shadow: 0 0 0 3px color-mix(in srgb, var(--glass-accent) 25%, transparent);\n"
    css = "{css}}\n\n"

    # Glass Shell: Workspace Tabs
    css = "{css}.widget-workspace-tabs {\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  background: var(--glass-surface-container-lowest);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  padding: 0 var(--glass-spacing-sm);\n"
    css = "{css}  gap: 2px;\n"
    css = "{css}}\n"
    css = "{css}.widget-workspace-tabs .ws-tab {\n"
    css = "{css}  padding: var(--glass-spacing-xs) var(--glass-spacing-md);\n"
    css = "{css}  font-size: 12px;\n"
    css = "{css}  color: var(--glass-text-tertiary);\n"
    css = "{css}  border-bottom: 2px solid transparent;\n"
    css = "{css}  cursor: pointer;\n"
    css = "{css}  transition: all var(--glass-duration-fast) var(--glass-easing);\n"
    css = "{css}}\n"
    css = "{css}.widget-workspace-tabs .ws-tab:hover {\n"
    css = "{css}  color: var(--glass-text-primary);\n"
    css = "{css}  background: var(--glass-surface-secondary);\n"
    css = "{css}  border-radius: var(--glass-radius-sm) var(--glass-radius-sm) 0 0;\n"
    css = "{css}}\n"
    css = "{css}.widget-workspace-tabs .ws-tab.active {\n"
    css = "{css}  color: var(--glass-accent);\n"
    css = "{css}  border-bottom-color: var(--glass-accent);\n"
    css = "{css}  font-weight: 600;\n"
    css = "{css}}\n\n"

    # Glass Shell: Glass Title Bar
    css = "{css}.widget-glass-title-bar {\n"
    css = "{css}  height: 38px;\n"
    css = "{css}  display: flex;\n"
    css = "{css}  align-items: center;\n"
    css = "{css}  padding: 0 var(--glass-spacing-md);\n"
    css = "{css}  background: var(--glass-surface-container-low);\n"
    css = "{css}  backdrop-filter: blur(var(--glass-blur-nav)) saturate(180%) brightness(1.05);\n"
    css = "{css}  -webkit-backdrop-filter: blur(var(--glass-blur-nav)) saturate(180%) brightness(1.05);\n"
    css = "{css}  border-bottom: 1px solid var(--glass-border-subtle);\n"
    css = "{css}  -webkit-app-region: drag;\n"
    css = "{css}  position: relative;\n"
    css = "{css}}\n"
    css = "{css}.widget-glass-title-bar::after {\n"
    css = "{css}  content: '';\n"
    css = "{css}  position: absolute;\n"
    css = "{css}  top: 0;\n"
    css = "{css}  left: 0;\n"
    css = "{css}  right: 0;\n"
    css = "{css}  height: 1px;\n"
    css = "{css}  background: rgba(255,255,255,0.10);\n"
    css = "{css}}\n"
    css = "{css}.widget-glass-title-bar .titlebar-title {\n"
    css = "{css}  flex: 1;\n"
    css = "{css}  text-align: center;\n"
    css = "{css}  font-size: 13px;\n"
    css = "{css}  font-weight: 500;\n"
    css = "{css}  color: var(--glass-text-secondary);\n"
    css = "{css}}\n"

    css
