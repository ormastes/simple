# Shared semantic UI contract facade.
#
# This module names the surface-neutral UI contract above concrete transports
# and renderer envelopes. It intentionally reuses the existing UI access
# snapshot model as the semantic state substrate instead of creating a parallel
# widget tree.

use common.ui.access_types.{
    UI_ACCESS_PROTOCOL_VERSION,
    UiAccessNode,
    UiAccessProp,
    UiAccessEvent,
    UiAccessSnapshot
}
use common.ui.access_snapshot.{ui_access_snapshot_from_state}
use common.ui.capability.{Capability}
use common.ui.capability_policy.{capability_name}
use common.ui.widget.{UIState, UIEvent}
use common.ui.web_render_api.{
    WebRenderPatchEnvelope,
    WebRenderSnapshotEnvelope,
    web_render_input_envelope_from_event,
    web_render_input_envelope_to_json,
    web_render_patch_envelope_to_json,
    web_render_snapshot_envelope_to_json
}
use common.text_advanced.{escape_json}

val SEMANTIC_UI_PROTOCOL_VERSION: i32 = UI_ACCESS_PROTOCOL_VERSION

val SEMANTIC_UI_STAGE_ADAPTER_ONLY: text = "S0"
val SEMANTIC_UI_STAGE_STATE: text = "S1"
val SEMANTIC_UI_STAGE_EVENTS: text = "S2"
val SEMANTIC_UI_STAGE_RENDERER: text = "S3"
val SEMANTIC_UI_STAGE_PROTOCOL: text = "S4"

val SEMANTIC_UI_STATUS_AVAILABLE: text = "available"
val SEMANTIC_UI_STATUS_UNAVAILABLE: text = "semantic_adapter_unavailable"

class SemanticUiCapability:
    name: text
    value: text
    available: bool

    static fn create(name: text, value: text, available: bool) -> SemanticUiCapability:
        SemanticUiCapability(name: name, value: value, available: available)

class SemanticElementInfo:
    canonical_id: text
    surface_id: text
    widget_id: text
    kind: text
    visible: bool
    focused: bool
    enabled: bool
    selected: bool
    text: text
    props: [UiAccessProp]
    child_ids: [text]
    action_names: [text]

    static fn from_access(node: UiAccessNode) -> SemanticElementInfo:
        SemanticElementInfo(
            canonical_id: node.canonical_id,
            surface_id: node.surface_id,
            widget_id: node.widget_id,
            kind: node.kind,
            visible: node.visible,
            focused: node.focused,
            enabled: node.enabled,
            selected: node.selected,
            text: node.text_value,
            props: node.props,
            child_ids: node.child_ids,
            action_names: node.action_names
        )

class SemanticUiStateInfo:
    mode: text
    focused_id: text
    title: text
    theme: text
    element_count: i32
    protocol_version: i32
    active_surface: text

    static fn from_access(snapshot: UiAccessSnapshot) -> SemanticUiStateInfo:
        var focused_id = ""
        for node in snapshot.nodes:
            if node.focused:
                focused_id = node.canonical_id
        var title = ""
        if snapshot.surfaces.len() > 0:
            title = snapshot.surfaces[0].title
        SemanticUiStateInfo(
            mode: snapshot.mode,
            focused_id: focused_id,
            title: title,
            theme: "",
            element_count: snapshot.nodes.len(),
            protocol_version: snapshot.protocol_version,
            active_surface: snapshot.active_surface
        )

class SemanticUiCommand:
    command_type: text
    surface_id: text
    target_id: text
    value: text
    key: text
    x: f64
    y: f64
    dx: f64
    dy: f64

    static fn create(command_type: text, surface_id: text, target_id: text, value: text, key: text) -> SemanticUiCommand:
        SemanticUiCommand(
            command_type: command_type,
            surface_id: surface_id,
            target_id: target_id,
            value: value,
            key: key,
            x: 0.0,
            y: 0.0,
            dx: 0.0,
            dy: 0.0
        )

    static fn click(surface_id: text, target_id: text) -> SemanticUiCommand:
        SemanticUiCommand.create("click", surface_id, target_id, "", "")

    static fn type_text(surface_id: text, target_id: text, value: text) -> SemanticUiCommand:
        SemanticUiCommand.create("type", surface_id, target_id, value, "")

    static fn key(surface_id: text, key: text) -> SemanticUiCommand:
        SemanticUiCommand.create("key", surface_id, "", "", key)

    static fn action(surface_id: text, name: text) -> SemanticUiCommand:
        SemanticUiCommand.create("action", surface_id, "", name, "")

    static fn focus(surface_id: text, target_id: text) -> SemanticUiCommand:
        SemanticUiCommand.create("focus", surface_id, target_id, "", "")

class SemanticUiDispatchResult:
    ok: bool
    command_type: text
    surface_id: text
    target_id: text
    affected_id: text
    reason: text
    snapshot_revision: i64

    static fn success(command: SemanticUiCommand, affected_id: text, snapshot_revision: i64) -> SemanticUiDispatchResult:
        SemanticUiDispatchResult(
            ok: true,
            command_type: command.command_type,
            surface_id: command.surface_id,
            target_id: command.target_id,
            affected_id: affected_id,
            reason: "ok",
            snapshot_revision: snapshot_revision
        )

    static fn failure(command: SemanticUiCommand, reason: text, snapshot_revision: i64) -> SemanticUiDispatchResult:
        SemanticUiDispatchResult(
            ok: false,
            command_type: command.command_type,
            surface_id: command.surface_id,
            target_id: command.target_id,
            affected_id: "",
            reason: reason,
            snapshot_revision: snapshot_revision
        )

class SemanticUiSnapshot:
    protocol_version: i32
    stage: text
    adapter_status: text
    state: SemanticUiStateInfo
    elements: [SemanticElementInfo]
    capabilities: [SemanticUiCapability]
    recent_events: [UiAccessEvent]

    static fn unavailable(stage: text, reason: text) -> SemanticUiSnapshot:
        SemanticUiSnapshot(
            protocol_version: SEMANTIC_UI_PROTOCOL_VERSION,
            stage: stage,
            adapter_status: reason,
            state: SemanticUiStateInfo(
                mode: "",
                focused_id: "",
                title: "",
                theme: "",
                element_count: 0,
                protocol_version: SEMANTIC_UI_PROTOCOL_VERSION,
                active_surface: ""
            ),
            elements: [],
            capabilities: [],
            recent_events: []
        )

class SemanticUiRenderTransportBundle:
    target: text
    surface_id: text
    semantic_json: text
    input_json: text
    snapshot_json: text
    patch_json: text

    static fn create(target: text, surface_id: text, snapshot: SemanticUiSnapshot, command: SemanticUiCommand, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text) -> SemanticUiRenderTransportBundle:
        val semantic_json = semantic_ui_snapshot_to_json(snapshot)
        val event = _semantic_ui_command_event_or_action(command)
        val input = web_render_input_envelope_from_event(target, surface_id, event)
        SemanticUiRenderTransportBundle(
            target: target,
            surface_id: surface_id,
            semantic_json: semantic_json,
            input_json: web_render_input_envelope_to_json(input),
            snapshot_json: semantic_ui_snapshot_transport_json(target, surface_id, revision, snapshot),
            patch_json: web_render_patch_envelope_to_json(WebRenderPatchEnvelope(target: target, surface_id: surface_id, from_sequence: from_sequence, to_sequence: to_sequence, patches_json: patches_json, snapshot_json: semantic_json))
        )

class SemanticUiRenderTargetEvidence:
    target: text
    surface_id: text
    command_type: text
    input_has_target: bool
    input_has_event: bool
    snapshot_has_target: bool
    snapshot_has_semantic: bool
    patch_has_target: bool
    patch_has_snapshot: bool
    ready: bool
    reason: text

    fn summary() -> text:
        "SemanticUiRenderTargetEvidence[target={self.target} command={self.command_type} ready={self.ready.to_text()} reason={self.reason}]"

class SemanticUiCommandDispatchEvidence:
    target: text
    surface_id: text
    command_type: text
    dispatch_ok: bool
    affected_id: text
    snapshot_revision: i64
    revision_advanced: bool
    recent_event_matches: bool
    read_after_write_observed: bool
    ready: bool
    reason: text

    fn summary() -> text:
        "SemanticUiCommandDispatchEvidence[target={self.target} command={self.command_type} ready={self.ready.to_text()} revision={self.snapshot_revision} reason={self.reason}]"

fn semantic_ui_elements_from_access(nodes: [UiAccessNode]) -> [SemanticElementInfo]:
    var out: [SemanticElementInfo] = []
    for node in nodes:
        out = out.push(SemanticElementInfo.from_access(node))
    out

fn semantic_ui_snapshot_from_access(snapshot: UiAccessSnapshot, stage: text, adapter_status: text) -> SemanticUiSnapshot:
    SemanticUiSnapshot(
        protocol_version: snapshot.protocol_version,
        stage: stage,
        adapter_status: adapter_status,
        state: SemanticUiStateInfo.from_access(snapshot),
        elements: semantic_ui_elements_from_access(snapshot.nodes),
        capabilities: [],
        recent_events: snapshot.recent_events
    )

fn semantic_ui_snapshot_from_state(state: UIState, stage: text, adapter_status: text) -> SemanticUiSnapshot:
    semantic_ui_snapshot_from_access(ui_access_snapshot_from_state(state, []), stage, adapter_status)

fn semantic_ui_capabilities_from_backend(caps: [Capability]) -> [SemanticUiCapability]:
    var out: [SemanticUiCapability] = []
    for cap in caps:
        out = out.push(SemanticUiCapability.create(capability_name(cap), "true", true))
    out

fn semantic_ui_snapshot_from_state_with_capabilities(state: UIState, stage: text, adapter_status: text, caps: [Capability]) -> SemanticUiSnapshot:
    val snapshot = semantic_ui_snapshot_from_state(state, stage, adapter_status)
    SemanticUiSnapshot(
        protocol_version: snapshot.protocol_version,
        stage: snapshot.stage,
        adapter_status: snapshot.adapter_status,
        state: snapshot.state,
        elements: snapshot.elements,
        capabilities: semantic_ui_capabilities_from_backend(caps),
        recent_events: snapshot.recent_events
    )

fn semantic_ui_has_capability(snapshot: SemanticUiSnapshot, capability: text) -> bool:
    for cap in snapshot.capabilities:
        if cap.name == capability and cap.available:
            return true
    false

fn semantic_ui_snapshot_to_json(snapshot: SemanticUiSnapshot) -> text:
    "{" +
    "\"protocol_version\":{snapshot.protocol_version}," +
    "\"stage\":\"{escape_json(snapshot.stage)}\"," +
    "\"adapter_status\":\"{escape_json(snapshot.adapter_status)}\"," +
    "\"state\":{" +
    "\"mode\":\"{escape_json(snapshot.state.mode)}\"," +
    "\"focused_id\":\"{escape_json(snapshot.state.focused_id)}\"," +
    "\"title\":\"{escape_json(snapshot.state.title)}\"," +
    "\"theme\":\"{escape_json(snapshot.state.theme)}\"," +
    "\"element_count\":{snapshot.state.element_count}," +
    "\"active_surface\":\"{escape_json(snapshot.state.active_surface)}\"" +
    "}," +
    "\"capabilities\":" + _semantic_ui_capabilities_json(snapshot.capabilities) + "," +
    "\"elements\":" + _semantic_ui_elements_json(snapshot.elements) + "," +
    "\"recent_event_count\":{snapshot.recent_events.len()}" +
    "}"

fn semantic_ui_snapshot_transport_json(target: text, surface_id: text, revision: u64, snapshot: SemanticUiSnapshot) -> text:
    web_render_snapshot_envelope_to_json(WebRenderSnapshotEnvelope(target: target, surface_id: surface_id, revision: revision, snapshot_json: semantic_ui_snapshot_to_json(snapshot)))

fn semantic_ui_render_transport_bundle(target: text, surface_id: text, snapshot: SemanticUiSnapshot, command: SemanticUiCommand, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text) -> SemanticUiRenderTransportBundle:
    SemanticUiRenderTransportBundle.create(target, surface_id, snapshot, command, revision, from_sequence, to_sequence, patches_json)

fn semantic_ui_render_target_evidence(target: text, surface_id: text, snapshot: SemanticUiSnapshot, command: SemanticUiCommand, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text) -> SemanticUiRenderTargetEvidence:
    val bundle = semantic_ui_render_transport_bundle(target, surface_id, snapshot, command, revision, from_sequence, to_sequence, patches_json)
    val target_fragment = "\"target\":\"" + escape_json(target) + "\""
    val input_has_target = bundle.input_json.contains(target_fragment)
    val input_has_event = bundle.input_json.contains("\"event_type\":\"" + semantic_ui_command_to_event_kind(command) + "\"")
    val snapshot_has_target = bundle.snapshot_json.contains(target_fragment)
    val snapshot_has_semantic = bundle.snapshot_json.contains("\"snapshot\":{\"protocol_version\"")
    val patch_has_target = bundle.patch_json.contains(target_fragment)
    val patch_has_snapshot = bundle.patch_json.contains("\"snapshot\":{\"protocol_version\"")
    val ready = input_has_target and input_has_event and snapshot_has_target and snapshot_has_semantic and patch_has_target and patch_has_snapshot
    SemanticUiRenderTargetEvidence(
        target: target,
        surface_id: surface_id,
        command_type: command.command_type,
        input_has_target: input_has_target,
        input_has_event: input_has_event,
        snapshot_has_target: snapshot_has_target,
        snapshot_has_semantic: snapshot_has_semantic,
        patch_has_target: patch_has_target,
        patch_has_snapshot: patch_has_snapshot,
        ready: ready,
        reason: if ready: "pass" else: "semantic-render-transport-mismatch"
    )

fn semantic_ui_render_target_evidence_matrix(targets: [text], surface_id: text, snapshot: SemanticUiSnapshot, command: SemanticUiCommand, revision: u64, from_sequence: u64, to_sequence: u64, patches_json: text) -> [SemanticUiRenderTargetEvidence]:
    var out: [SemanticUiRenderTargetEvidence] = []
    for target in targets:
        out.push(semantic_ui_render_target_evidence(target, surface_id, snapshot, command, revision, from_sequence, to_sequence, patches_json))
    out

fn semantic_ui_command_dispatch_evidence(target: text, surface_id: text, before_snapshot: SemanticUiSnapshot, after_snapshot: SemanticUiSnapshot, command: SemanticUiCommand, result: SemanticUiDispatchResult) -> SemanticUiCommandDispatchEvidence:
    val revision_advanced = result.snapshot_revision > before_snapshot.recent_events.len().to_i64() and after_snapshot.recent_events.len() > before_snapshot.recent_events.len()
    val recent_event_matches = _semantic_ui_recent_event_matches(after_snapshot, command)
    val read_after_write_observed = _semantic_ui_read_after_write_observed(after_snapshot, command, result)
    val ready = result.ok and revision_advanced and recent_event_matches and read_after_write_observed
    SemanticUiCommandDispatchEvidence(
        target: target,
        surface_id: surface_id,
        command_type: command.command_type,
        dispatch_ok: result.ok,
        affected_id: result.affected_id,
        snapshot_revision: result.snapshot_revision,
        revision_advanced: revision_advanced,
        recent_event_matches: recent_event_matches,
        read_after_write_observed: read_after_write_observed,
        ready: ready,
        reason: if ready: "pass" else: _semantic_ui_dispatch_reason(result, revision_advanced, recent_event_matches, read_after_write_observed)
    )

fn semantic_ui_command_dispatch_evidence_matrix(targets: [text], surface_id: text, before_snapshot: SemanticUiSnapshot, after_snapshots: [SemanticUiSnapshot], command: SemanticUiCommand, results: [SemanticUiDispatchResult]) -> [SemanticUiCommandDispatchEvidence]:
    var out: [SemanticUiCommandDispatchEvidence] = []
    var i = 0
    while i < targets.len():
        if i < after_snapshots.len() and i < results.len():
            out.push(semantic_ui_command_dispatch_evidence(targets[i], surface_id, before_snapshot, after_snapshots[i], command, results[i]))
        i = i + 1
    out

fn _semantic_ui_command_event_or_action(command: SemanticUiCommand) -> UIEvent:
    val event = semantic_ui_command_to_event(command)
    if event != nil:
        return event
    UIEvent.Action(name: command.command_type)

fn _semantic_ui_capabilities_json(caps: [SemanticUiCapability]) -> text:
    var parts: [text] = []
    for cap in caps:
        parts.push("{" +
            "\"name\":\"{escape_json(cap.name)}\"," +
            "\"value\":\"{escape_json(cap.value)}\"," +
            "\"available\":{cap.available.to_text()}" +
            "}")
    "[" + parts.join(",") + "]"

fn _semantic_ui_elements_json(elements: [SemanticElementInfo]) -> text:
    var parts: [text] = []
    for el in elements:
        parts.push("{" +
            "\"canonical_id\":\"{escape_json(el.canonical_id)}\"," +
            "\"surface_id\":\"{escape_json(el.surface_id)}\"," +
            "\"widget_id\":\"{escape_json(el.widget_id)}\"," +
            "\"kind\":\"{escape_json(el.kind)}\"," +
            "\"visible\":{el.visible.to_text()}," +
            "\"focused\":{el.focused.to_text()}," +
            "\"enabled\":{el.enabled.to_text()}," +
            "\"selected\":{el.selected.to_text()}," +
            "\"text\":\"{escape_json(el.text)}\"" +
            "}")
    "[" + parts.join(",") + "]"

fn semantic_ui_command_to_event_kind(command: SemanticUiCommand) -> text:
    if command.command_type == "type":
        return "input"
    if command.command_type == "key":
        return "key"
    command.command_type

fn semantic_ui_command_to_access_event_kind(command: SemanticUiCommand) -> text:
    if command.command_type == "click":
        return "action"
    if command.command_type == "type":
        return "input_change"
    if command.command_type == "key":
        return "key_press"
    if command.command_type == "action":
        return "action"
    if command.command_type == "focus":
        return "focus_focus"
    command.command_type

fn semantic_ui_command_to_access_payload(command: SemanticUiCommand) -> text:
    if command.command_type == "click":
        return "click_" + command.target_id
    if command.command_type == "type":
        return command.value
    if command.command_type == "key":
        return command.key
    if command.command_type == "action":
        return command.value
    if command.command_type == "focus":
        return command.target_id
    if command.command_type == "focus_next" or command.command_type == "focus_prev" or command.command_type == "quit":
        return command.command_type
    command.value

fn semantic_ui_command_to_event(command: SemanticUiCommand) -> UIEvent?:
    if command.command_type == "click":
        return UIEvent.Action(name: "click_" + command.target_id)
    if command.command_type == "type":
        return UIEvent.InputChange(target_id: command.target_id, value: command.value)
    if command.command_type == "key":
        return UIEvent.KeyPress(key: command.key)
    if command.command_type == "action":
        return UIEvent.Action(name: command.value)
    if command.command_type == "focus":
        return UIEvent.FocusEvent(target_id: command.target_id, kind: "focus")
    if command.command_type == "focus_next":
        return UIEvent.FocusNext
    if command.command_type == "focus_prev":
        return UIEvent.FocusPrev
    if command.command_type == "quit":
        return UIEvent.Quit
    nil

fn semantic_ui_stage_at_least(stage: text, required: text) -> bool:
    _semantic_stage_rank(stage) >= _semantic_stage_rank(required)

fn _semantic_ui_recent_event_matches(snapshot: SemanticUiSnapshot, command: SemanticUiCommand) -> bool:
    if snapshot.recent_events.len() == 0:
        return false
    val event = snapshot.recent_events[snapshot.recent_events.len() - 1]
    event.event_kind == semantic_ui_command_to_access_event_kind(command) and event.payload == semantic_ui_command_to_access_payload(command)

fn _semantic_ui_read_after_write_observed(snapshot: SemanticUiSnapshot, command: SemanticUiCommand, result: SemanticUiDispatchResult) -> bool:
    if not result.ok:
        return false
    if command.command_type == "focus":
        return snapshot.state.focused_id == result.affected_id
    if command.target_id == "":
        return result.affected_id != ""
    result.affected_id == "main#" + command.target_id or result.affected_id == command.target_id

fn _semantic_ui_dispatch_reason(result: SemanticUiDispatchResult, revision_advanced: bool, recent_event_matches: bool, read_after_write_observed: bool) -> text:
    if not result.ok:
        return result.reason
    if not revision_advanced:
        return "snapshot-revision-not-advanced"
    if not recent_event_matches:
        return "recent-event-mismatch"
    if not read_after_write_observed:
        return "read-after-write-mismatch"
    "semantic-command-dispatch-mismatch"

fn _semantic_stage_rank(stage: text) -> i32:
    if stage == SEMANTIC_UI_STAGE_PROTOCOL:
        return 4
    if stage == SEMANTIC_UI_STAGE_RENDERER:
        return 3
    if stage == SEMANTIC_UI_STAGE_EVENTS:
        return 2
    if stage == SEMANTIC_UI_STAGE_STATE:
        return 1
    0
