# Glass Numeric Design Tokens
#
# Shared u64 color/opacity/radius values for baremetal glass rendering.
# Used by both wm_entry.spl (standalone WM) and compositor glass_effects.spl.
# CSS-text equivalents in glass_tokens.spl — keep both in sync.

# ===========================================================================
# Dark Glass Theme
# ===========================================================================
val GLASS_DARK_BG_TOP: u64       = 0x00060612   # Deep space gradient top
val GLASS_DARK_BG_BOT: u64       = 0x001A0830   # Deep space gradient bottom
val GLASS_DARK_SURFACE: u64      = 0x001E1E23   # Glass surface color
val GLASS_DARK_SURFACE_A: u64    = 184          # 72% opacity
val GLASS_DARK_ELEVATED: u64     = 0x002C2C32   # Elevated glass
val GLASS_DARK_ELEVATED_A: u64   = 224          # 88% opacity
val GLASS_DARK_BORDER: u64       = 0x00FFFFFF   # Glass border (white)
val GLASS_DARK_BORDER_A: u64     = 46           # 18% opacity
val GLASS_DARK_TEXT: u64         = 0x00F5F5F7   # Primary text
val GLASS_DARK_TEXT_SEC: u64     = 0x00EBEBF5   # Secondary text (60%)
val GLASS_DARK_ACCENT: u64       = 0x000A84FF   # Blue accent (iOS)
val GLASS_DARK_ACCENT2: u64      = 0x00BB86FC   # Purple accent
val GLASS_DARK_SHADOW_A: u64     = 80           # Shadow opacity

# ===========================================================================
# Light Glass Theme
# ===========================================================================
val GLASS_LIGHT_BG_TOP: u64      = 0x00C8B8E8   # Lavender gradient top
val GLASS_LIGHT_BG_BOT: u64      = 0x00F0ECF5   # Soft white gradient bottom
val GLASS_LIGHT_SURFACE: u64     = 0x00FFFFFF   # Glass surface (white)
val GLASS_LIGHT_SURFACE_A: u64   = 184          # 72% opacity
val GLASS_LIGHT_ELEVATED: u64    = 0x00FFFFFF   # Elevated glass
val GLASS_LIGHT_ELEVATED_A: u64  = 230          # 90% opacity
val GLASS_LIGHT_BORDER: u64      = 0x00000000   # Glass border (black)
val GLASS_LIGHT_BORDER_A: u64    = 20           # 8% opacity
val GLASS_LIGHT_TEXT: u64        = 0x001D1D1F   # Primary text
val GLASS_LIGHT_TEXT_SEC: u64    = 0x003C3C43   # Secondary text
val GLASS_LIGHT_ACCENT: u64      = 0x00007AFF   # Blue accent (iOS)
val GLASS_LIGHT_ACCENT2: u64     = 0x009B59B6   # Purple accent
val GLASS_LIGHT_SHADOW_A: u64    = 40           # Shadow opacity (lighter)

# ===========================================================================
# Shared Constants (theme-independent)
# ===========================================================================

# Traffic light button colors (macOS standard)
val GLASS_BTN_CLOSE: u64   = 0x00FF5F57  # Red
val GLASS_BTN_MIN: u64     = 0x00FFBD2E  # Yellow  (was FEBC2E in macOS)
val GLASS_BTN_MAX: u64     = 0x0028CA41  # Green   (was 28C840 in macOS)

# Corner radii (pixels)
val GLASS_RADIUS_SM: u64   = 8    # Small elements (sidebar items, icon pills)
val GLASS_RADIUS_MD: u64   = 12   # Windows, title bars
val GLASS_RADIUS_LG: u64   = 16   # Dock pill
val GLASS_RADIUS_XL: u64   = 20   # Large panels
val GLASS_RADIUS_FULL: u64 = 9999 # Fully rounded (pill shape)

# Blur radii (pixels) — compositor uses 5-pass HVHVH box blur
# which visually equals ~2x CSS backdrop-filter blur, so values
# are lower here than in glass_tokens.spl CSS equivalents.
# CSS: surface=20, elevated=40, nav=24, subtle=8
val GLASS_BLUR_SURFACE: u64  = 12   # Standard window blur (CSS: 20px)
val GLASS_BLUR_ELEVATED: u64 = 20   # Elevated panels (CSS: 40px)
val GLASS_BLUR_NAV: u64      = 14   # System bar / dock (CSS: 24px)
val GLASS_BLUR_SUBTLE: u64   = 6    # Subtle effects (CSS: 8px)

# Shadow — multi-layer (compositor stacks 10 layers)
val GLASS_SHADOW_BLUR: u64   = 10   # Primary shadow blur radius
val GLASS_SHADOW_OFFSET: u64 = 6    # Primary shadow offset (down + right)
val GLASS_SHADOW_ACCENT_SPREAD: u64 = 100  # Accent glow spread (CSS: 100px)

# Traffic light layout (pixels)
val GLASS_BTN_DIAMETER: u64 = 12   # Button diameter
val GLASS_BTN_GAP: u64     = 8    # Gap between buttons
val GLASS_BTN_X: u64       = 12   # X offset from window left
val GLASS_BTN_Y: u64       = 10   # Y offset from window top

# Layout
val GLASS_TITLE_BAR_H: u64  = 28   # Title bar height (macOS = 24-28)
val GLASS_SYSTEM_BAR_H: u64 = 28   # System bar height
val GLASS_DOCK_H: u64       = 56   # Dock height
val GLASS_DOCK_RADIUS: u64  = 26   # Dock pill corner radius (Stitch-aligned)
val GLASS_DOCK_ICON: u64    = 40   # Dock icon size
val GLASS_DOCK_PILL: u64    = 48   # Dock icon pill background size

# Icon colors
val GLASS_ICON_TERM: u64     = 0x003498DB   # Terminal (blue)
val GLASS_ICON_FILES: u64    = 0x0027AE60   # Files (green)
val GLASS_ICON_CALC: u64     = 0x00E74C3C   # Calculator (red)
val GLASS_ICON_CLOCK: u64    = 0x00F39C12   # Clock (orange)
val GLASS_ICON_SETTINGS: u64 = 0x009B59B6   # Settings (purple)
val GLASS_ICON_BROWSER: u64  = 0x00E67E22   # Browser (orange-brown)
val GLASS_ICON_EDITOR: u64   = 0x001ABC9C   # Editor (teal)

# ===========================================================================
# Obsidian Dark Theme (MD3 Fidelity)
# ===========================================================================
val GLASS_OBSIDIAN_SURFACE: u64           = 0x0012121F
val GLASS_OBSIDIAN_SURFACE_A: u64         = 184
val GLASS_OBSIDIAN_CONTAINER_LOWEST: u64  = 0x000D0D1A
val GLASS_OBSIDIAN_CONTAINER_LOW: u64     = 0x001A1A28
val GLASS_OBSIDIAN_CONTAINER: u64         = 0x001E1E2C
val GLASS_OBSIDIAN_CONTAINER_HIGH: u64    = 0x00292937
val GLASS_OBSIDIAN_CONTAINER_HIGHEST: u64 = 0x00343342
val GLASS_OBSIDIAN_TEXT: u64              = 0x00E3E0F3
val GLASS_OBSIDIAN_TEXT_SEC: u64          = 0x00CCC4CE
val GLASS_OBSIDIAN_ACCENT: u64            = 0x00C6C6C8
val GLASS_OBSIDIAN_BORDER: u64            = 0x00958E98
val GLASS_OBSIDIAN_BORDER_A: u64          = 38
val GLASS_OBSIDIAN_ERROR: u64             = 0x00FFB4AB
val GLASS_OBSIDIAN_ACCENT2: u64           = 0x00C6C6C8   # Same as accent (MD3 single primary)
val GLASS_OBSIDIAN_SHADOW_A: u64          = 80           # Same as dark (shared shadow opacity)
val GLASS_OBSIDIAN_BG_TOP: u64            = 0x00060612
val GLASS_OBSIDIAN_BG_BOT: u64            = 0x001A0830
val GLASS_OBSIDIAN_RADIUS_MD: u64         = 8
