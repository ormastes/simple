# Shared WM Scene Projection
#
# Converts WindowManager state plus host window bindings into a scene shape
# that Tauri, Electron, Simple Web, and SimpleOS compositor code can inspect.

use common.ui.widget.{UITree}
use common.ui.window.{WindowManager, ManagedWindow}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry, UI_SURFACE_KIND_LEGACY}
use common.ui.taskbar_model.{TaskbarModel}
use common.ui.wm_chrome_theme.{wm_chrome_theme}

struct SharedWmWindow:
    surface_id: text
    window_id: text
    surface_kind: text
    process_id: u64
    app_id: text
    title: text
    language: text
    x: i32
    y: i32
    width: i32
    height: i32
    tree: UITree?
    html: text
    minimized: bool
    focused: bool
    z_index: i32
    chrome_kind: text

# chrome_kind values: "titled" draws the standard title bar + border chrome;
# "borderless" renders the window as a pure content surface (taskbar-like
# windows and plain drawn objects) with z-order/focus/hit-test bounds
# unchanged. Default is "titled" so existing callers keep current chrome.
val WM_CHROME_KIND_TITLED: text = "titled"
val WM_CHROME_KIND_BORDERLESS: text = "borderless"

struct SharedWmRect:
    x: i32
    y: i32
    width: i32
    height: i32

# BackgroundSpec is a provider contract for the scene background, not a
# hardcoded fill. kind: "color" is implemented now; "image" is implemented via
# an injected BackgroundImageProvider (see below); "motion" remains reserved
# and must not be silently treated as "color" — callers that only need a
# solid fill today will not need to change now that image/motion providers
# are landing.
struct BackgroundSpec:
    kind: text
    color: u32
    source: text
    fit: text

val WM_BACKGROUND_KIND_COLOR: text = "color"
val WM_BACKGROUND_KIND_IMAGE: text = "image"
val WM_BACKGROUND_KIND_MOTION: text = "motion"

# fit values for kind:"image": "cover" (default, uniform scale + center-crop),
# "contain" (uniform scale + letterbox to the desktop-chrome fill color),
# "stretch" (non-uniform scale to exactly fill target), "tile" (repeat the
# intrinsic-size image, no scaling).
val WM_BACKGROUND_FIT_COVER: text = "cover"
val WM_BACKGROUND_FIT_CONTAIN: text = "contain"
val WM_BACKGROUND_FIT_STRETCH: text = "stretch"
val WM_BACKGROUND_FIT_TILE: text = "tile"

fn shared_wm_background_color(color: u32) -> BackgroundSpec:
    BackgroundSpec(kind: WM_BACKGROUND_KIND_COLOR, color: color, source: "", fit: WM_BACKGROUND_FIT_COVER)

# Decoded RGBA (as ARGB u32) surface already resampled to the requested
# target_w x target_h per the requested fit policy — the common.ui executor
# never decodes/resamples itself, it only blits this buffer.
struct BackgroundSurface:
    width: i32
    height: i32
    pixels: [u32]

struct SharedWmBackgroundResolution:
    resolved: bool
    color: u32
    surface: BackgroundSurface?
    stale: bool
    error_message: text

# Outcome returned by a BackgroundImageProvider.resolve(...) call — the
# provider's raw report before shared_wm_scene_resolve_background wraps it
# into a SharedWmBackgroundResolution.
struct BackgroundResolveOutcome:
    ok: bool
    surface: BackgroundSurface?
    stale: bool
    error_message: text

# The common.ui executor never decodes and never touches the filesystem: a
# provider is injected (host provides an fs-backed implementation; SimpleOS
# provides an in-image pre-decoded one). This preserves the baremetal-lane
# boundary documented in shared_wm_renderer_unification.md (no direct
# filesystem-existence-check or theme-package reads on the freestanding
# path) — this trait definition and its registration hook are the only
# things common.ui knows about image providers.
trait BackgroundImageProvider:
    me resolve(source: text, target_w: i32, target_h: i32, fit: text) -> BackgroundResolveOutcome

var _wm_background_image_provider: BackgroundImageProvider? = nil

# Registers (or clears, with nil) the single process-wide image-background
# provider. Host wiring registers an fs-backed provider at startup; SimpleOS
# wiring registers an in-image pre-decoded provider; tests register a fake
# and must unregister (nil) when done so global state does not leak across
# spec files sharing this process.
fn shared_wm_scene_register_background_image_provider(provider: BackgroundImageProvider?):
    _wm_background_image_provider = provider

# Motion (moving-image) background provider (plan item B,
# doc/03_plan/os/desktop/wm_window_render_api_hardening_plan.md; design
# doc/05_design/os/desktop/simple_gui_internal_window_impl_spec.md 'Phase-2
# Provider Design'). A MotionBackgroundSource yields the frame surface that is
# current for a caller-supplied wall-clock timestamp — the executor/resolver
# never owns a clock itself (common.ui never touches an extern time source;
# the compositor/present-loop layer supplies t_micros), and never decodes: the
# source has already resolved+resampled the frame to paintable pixels by the
# time frame_for_time returns.
#
# next_frame_due_micros() lets the present loop (hosted_entry.spl) fold "a
# motion frame is due" into its existing dirty-gated redraw decision without
# converting the loop into a busy-poll: it is a plain field read, not a wait.
#
# Loud-fail note: this trait's return type is a plain BackgroundSurface (no
# Result/Outcome channel), matching the signature the design doc specifies.
# A concrete source that cannot produce a real frame (unreadable frame file,
# decode failure with no prior good frame) returns the documented sentinel
# BackgroundSurface(width: 0, height: 0, pixels: []) instead of throwing or
# fabricating pixels; shared_wm_scene_resolve_background below treats a
# non-positive-area surface as "no frame available" and falls through to the
# same loud WM_BACKGROUND_UNRESOLVED_MARKER_COLOR path used for an unknown
# kind / no-provider case. Missing/empty frame sets are caught earlier, at
# source construction (loud Result-returning factory on the concrete
# provider), so this call-time sentinel only covers a frame going bad after
# construction (e.g. a frame file deleted mid-run).
trait MotionBackgroundSource:
    me frame_for_time(t_micros: i64) -> BackgroundSurface
    me next_frame_due_micros() -> i64

var _wm_motion_background_source: MotionBackgroundSource? = nil
# Scalar mirror of "a source is registered". Stage3 native builds corrupt
# the module-global Optional trait read above: with nothing registered the
# `if val` arm still entered and hit the duck-typed no-vtable trap
# (LLDB-proven in shared_wm_motion_background_next_due_micros from the
# hosted production loop). The scalar bool is checked FIRST so the
# unregistered path never touches the Optional or trait dispatch.
var _wm_motion_background_source_registered: bool = false

# Registers (or clears, with nil) the single process-wide motion-background
# source. Same lifecycle contract as
# shared_wm_scene_register_background_image_provider: host wiring registers
# an fs-backed frame-list source at startup; SimpleOS would register an
# in-image pre-decoded one (not implemented yet — SimpleOS visual proof of
# motion is blocked the same way image is, per plan item D); tests register a
# fake and must unregister (nil) when done.
fn shared_wm_scene_register_motion_background_source(source: MotionBackgroundSource?):
    _wm_motion_background_source = source
    _wm_motion_background_source_registered = source != nil

# Present-loop seam: returns the absolute wall-clock micros at which the next
# motion-background frame becomes due, or -1 if no motion source is
# registered (never due). hosted_entry.spl's dirty-gated event loop reads
# this once per already-scheduled poll iteration and folds
# "now >= due" into its existing `dirty` decision — this does not introduce
# any new polling/sleeping, it only adds a condition to a loop that already
# runs on a fixed cadence.
fn shared_wm_motion_background_next_due_micros() -> i64:
    if not _wm_motion_background_source_registered:
        return -1
    if val source = _wm_motion_background_source:
        return source.next_frame_due_micros()
    -1

# Pure fire decision for the present loop's motion-dirty trigger: fire exactly
# once per due timestamp (`due != last_fired_due`), and only once that
# timestamp has arrived (`now >= due`). `due < 0` means "no motion source
# registered / never due". The once-per-due-value guard is what keeps the
# present loop dirty-gated (GUI-5a) instead of perpetually dirty: consuming a
# frame (frame_for_time during render) advances the source's next-due,
# producing a NEW due value that re-arms the trigger for the next frame; if
# the due value does not advance (e.g. a render lane that does not consume
# motion frames), the trigger fires once and then stays quiet rather than
# degenerating into an unconditional re-present every loop iteration.
fn shared_wm_motion_dirty_due(now_micros: i64, due_micros: i64, last_fired_due_micros: i64) -> bool:
    due_micros >= 0 and due_micros != last_fired_due_micros and now_micros >= due_micros

# Present-loop seam: self-re-arm the motion trigger for the timestamp that
# just fired. Per shared_wm_motion_dirty_due's contract, a due value only
# re-arms the trigger once frame_for_time() advances next-due to a NEW value
# — normally that happens as a side effect of render actually consuming the
# motion frame. Today only the shared-MDI production lane
# (shared_mdi_framebuffer_scene.render_shared_mdi_framebuffer_scene_for_windows,
# threaded from this same seam) renders a resolved kind:"motion" background;
# the hosted chrome lane (host_compositor_entry.render_frame) still direct-
# draws chrome and does not resolve scene backgrounds at all (deferred,
# gated on the region-dirty work design invariant I8 needs — see plan item B
# dependency note). Calling this at the seam right after
# shared_wm_motion_dirty_due fires means the "due advances" half of the
# contract holds even on iterations where no render call happens to reach
# the motion source, so the seam re-arms itself instead of firing once and
# then going permanently stale.
fn shared_wm_motion_background_consume_due(t_micros: i64):
    if not _wm_motion_background_source_registered:
        return
    if val source = _wm_motion_background_source:
        source.frame_for_time(t_micros)

# Resolves a BackgroundSpec to paintable pixels. Unknown/unimplemented kinds
# (including "image" with no provider registered, and the reserved "motion")
# never silently fall back to a default fill: they log a diagnostic and
# report resolved=false with a loud marker color so callers can detect and
# surface the failure instead of masking it.
val WM_BACKGROUND_UNRESOLVED_MARKER_COLOR: u32 = 0xFFFF00FFu32

# Loud unresolved-marker path shared by: a truly unknown kind, "motion"
# (still reserved), and "image" with no provider registered — the error
# semantics extension in the design doc states the no-provider case is
# "the same as an unknown kind", so it reuses this exact message shape
# (existing callers/specs asserting on "unsupported background kind" keep
# passing unchanged).
fn _shared_wm_scene_unresolved_background(background: BackgroundSpec) -> SharedWmBackgroundResolution:
    val message = "shared_wm_scene_resolve_background: unsupported background kind '{background.kind}' (only '{WM_BACKGROUND_KIND_COLOR}' is implemented, or '{WM_BACKGROUND_KIND_IMAGE}' with a registered BackgroundImageProvider); refusing silent fallback"
    print(message)
    SharedWmBackgroundResolution(resolved: false, color: WM_BACKGROUND_UNRESOLVED_MARKER_COLOR, surface: nil, stale: false, error_message: message)

fn _shared_wm_scene_image_resolve_failed(background: BackgroundSpec, provider_message: text) -> SharedWmBackgroundResolution:
    val message = "shared_wm_scene_resolve_background: image provider resolve failed: {provider_message} (kind='{background.kind}', source='{background.source}'); refusing silent fallback"
    print(message)
    SharedWmBackgroundResolution(resolved: false, color: WM_BACKGROUND_UNRESOLVED_MARKER_COLOR, surface: nil, stale: false, error_message: message)

fn _shared_wm_scene_motion_frame_unavailable(background: BackgroundSpec) -> SharedWmBackgroundResolution:
    val message = "shared_wm_scene_resolve_background: motion source returned no frame (kind='{background.kind}', source='{background.source}'); refusing silent fallback"
    print(message)
    SharedWmBackgroundResolution(resolved: false, color: WM_BACKGROUND_UNRESOLVED_MARKER_COLOR, surface: nil, stale: false, error_message: message)

# `t_micros` is the caller-supplied wall-clock time used only by kind:"motion"
# (default 0 keeps every existing kind:"color"/kind:"image" call site
# byte-identical — those branches never read it). common.ui does not read a
# clock itself; the compositor/present-loop layer (which already has extern
# time access) is the one that must pass a real `t_micros` for a motion
# background to advance.
fn shared_wm_scene_resolve_background(background: BackgroundSpec, target_w: i32 = 0, target_h: i32 = 0, t_micros: i64 = 0) -> SharedWmBackgroundResolution:
    if background.kind == WM_BACKGROUND_KIND_COLOR:
        return SharedWmBackgroundResolution(resolved: true, color: background.color, surface: nil, stale: false, error_message: "")
    if background.kind == WM_BACKGROUND_KIND_IMAGE:
        if val provider = _wm_background_image_provider:
            val outcome = provider.resolve(background.source, target_w, target_h, background.fit)
            if outcome.ok:
                return SharedWmBackgroundResolution(resolved: true, color: background.color, surface: outcome.surface, stale: outcome.stale, error_message: outcome.error_message)
            return _shared_wm_scene_image_resolve_failed(background, outcome.error_message)
        return _shared_wm_scene_unresolved_background(background)
    if background.kind == WM_BACKGROUND_KIND_MOTION:
        if val source = _wm_motion_background_source:
            val surface = source.frame_for_time(t_micros)
            if surface.width > 0 and surface.height > 0:
                return SharedWmBackgroundResolution(resolved: true, color: background.color, surface: surface, stale: false, error_message: "")
            return _shared_wm_scene_motion_frame_unavailable(background)
        return _shared_wm_scene_unresolved_background(background)
    _shared_wm_scene_unresolved_background(background)

struct SharedWmChrome:
    background_color: text
    command_lane: SharedWmRect
    content_area: SharedWmRect
    taskbar: SharedWmRect
    dpi_scale_milli: i32
    clock_label: text
    right_icon_count: i32
    taskbar_icon_count: i32

# Immutable revision tuple carried beside a SharedWmScene projection. Target
# authorities own and advance these counters; common.ui only transports them.
struct WmSceneRevision:
    scene_revision: i64
    input_revision: i64
    taskbar_revision: i64

val WM_CONTENT_ORIGIN_SIMPLE_WEB: text = "simple_web"
val WM_CONTENT_ORIGIN_GUI: text = "gui"

# Canonical rendered content supplied by the Simple Web adapter (or, with
# origin_kind WM_CONTENT_ORIGIN_GUI, a GUI panel producer). Pixels are ARGB
# u32 values in row-major order and must exactly match width * height.
#
# parent_window_id/offset_x/offset_y express nested content frames ("rendering
# inside rendering"): a top-level frame (rendered directly into a WM window's
# content rect) has parent_window_id == "" and offset_x/offset_y == 0. A
# nested frame (a panel embedded inside another content frame — GUI-in-GUI or
# web-in-GUI) carries the window_id of the PARENT content frame it is
# embedded in, plus its pixel offset within that parent's content rect. This
# lets the render executor discover children by scanning content_frames for
# parent_window_id == some_frame.window_id without inventing a second parent
# side-channel.
struct WmContentFrame:
    window_id: text
    scene_revision: i64
    content_revision: i64
    origin_kind: text
    width: i32
    height: i32
    pixels: [u32]
    checksum: u64
    parent_window_id: text
    offset_x: i32
    offset_y: i32

# Shared checksum algorithm for WmContentFrame.checksum. Extracted from the
# Simple Web adapter (os.compositor.simple_web_window_renderer) so every
# content-frame producer (Simple Web, GUI) uses the exact same provenance
# algorithm instead of each inventing its own — position is folded in
# alongside color so equal-color permutations do not collapse to the same
# value. A valid frame must never carry the executor's reserved zero
# checksum (0u64 is reserved to mean "no/invalid content").
#
# The result is masked to 63 bits (high bit always 0) as a workaround for a
# confirmed interpreter bug: a u64 struct field >= 2^63 corrupts `if val` /
# Option-unwrap on the JIT-bailout interpreter path used by this checksum's
# consumer (_shared_wm_content_frame_for_window in window_scene_draw_ir.spl —
# `var found: WmContentFrame? = nil` triggers a "shared pointers cannot be
# reassigned" JIT bail, and under that fallback a >= 2^63 u64 field makes
# `if val f = fn_returning_option():` fail to narrow the Option, so a later
# `f.field` access errors with "unknown property or method on Option"). See
# doc/08_tracking/bug/interp_u64_high_bit_option_unwrap_corruption_2026-07-11.md
# for the isolated repro. This costs one bit of hash space, not a redesign of
# the algorithm.
fn wm_content_frame_checksum(pixels: [u32]) -> u64:
    var checksum = 0x9E3779B97F4A7C15u64
    var i = 0
    while i < pixels.len():
        checksum = checksum ^ (pixels[i].to_u64() + (i + 1).to_u64() * 0x100000001B3u64)
        i = i + 1
    val masked = checksum & 0x7FFFFFFFFFFFFFFFu64
    if masked == 0u64: 1u64 else: masked

# Physical metrics shared by render and hit-test callers. Values are pixels
# after scale_milli has been applied.
struct WmRenderMetrics:
    scale_milli: i32
    top_lane_height: i32
    titlebar_height: i32
    taskbar_height: i32
    min_hit_target: i32

struct SharedWmScene:
    width: i32
    height: i32
    backend: text
    windows: [SharedWmWindow]
    background: BackgroundSpec

# Rich renderer input. The scene remains the immutable projection; content
# frames and metrics are inputs rather than new mutable scene ownership.
struct SharedWmRenderInput:
    scene: SharedWmScene
    revision: WmSceneRevision
    content_frames: [WmContentFrame]
    metrics: WmRenderMetrics
    t_micros: i64

# Taskbar-aware rich renderer input. Kept distinct from SharedWmRenderInput so
# existing content-frame producers remain source compatible while new callers
# must supply the authoritative shell model and clock label explicitly.
struct SharedWmTaskbarRenderInput:
    render: SharedWmRenderInput
    taskbar: TaskbarModel
    clock_label: text

struct SharedWmDispatchResult:
    action: text
    target_id: text
    app_id: text
    window_id: text
    scene: SharedWmScene

struct SharedWmEventTargetTranslation:
    scene_key: text
    input_key: text
    action: text
    target_id: text
    app_id: text
    window_id: text
    component_kind: text
    local_x: i32
    local_y: i32
    backend_target: text
    cache_hit: bool
    stale_cache_rejected: bool

struct SharedWmEventTargetTranslationCache:
    scene_key: text
    input_key: text
    translation: SharedWmEventTargetTranslation

struct SharedWmEventTargetTranslationResult:
    translation: SharedWmEventTargetTranslation
    cache: SharedWmEventTargetTranslationCache

fn simple_gui_internal_window(surface_id: text, window_id: text, process_id: u64, app_id: text, title: text, x: i32, y: i32, width: i32, height: i32, html: text, minimized: bool, focused: bool, z_index: i32) -> SharedWmWindow:
    simple_gui_internal_window_with_chrome_kind(surface_id, window_id, process_id, app_id, title, x, y, width, height, html, minimized, focused, z_index, WM_CHROME_KIND_TITLED)

fn simple_gui_internal_window_with_chrome_kind(surface_id: text, window_id: text, process_id: u64, app_id: text, title: text, x: i32, y: i32, width: i32, height: i32, html: text, minimized: bool, focused: bool, z_index: i32, chrome_kind: text) -> SharedWmWindow:
    SharedWmWindow(
        surface_id: surface_id,
        window_id: window_id,
        surface_kind: UI_SURFACE_KIND_LEGACY,
        process_id: process_id,
        app_id: app_id,
        title: title,
        language: "und",
        x: x,
        y: y,
        width: width,
        height: height,
        tree: nil,
        html: html,
        minimized: minimized,
        focused: focused,
        z_index: z_index,
        chrome_kind: chrome_kind
    )

fn simple_gui_internal_window_scene(width: i32, height: i32, backend: text, windows: [SharedWmWindow]) -> SharedWmScene:
    SharedWmScene(width: width, height: height, backend: backend, windows: windows, background: shared_wm_background_color(wm_chrome_theme().compositor_bg))

fn simple_gui_internal_window_renderer_handoff_marker() -> text:
    "implemented: WM framebuffer rendering can consume common.ui simple_gui_internal_window_scene"

fn _project_window(window: ManagedWindow, registry: UiWindowSurfaceRegistry) -> SharedWmWindow:
    val binding = registry.for_surface(window.surface_id)
    if binding != nil:
        return SharedWmWindow(
            surface_id: window.surface_id,
            window_id: binding.window_id,
            surface_kind: binding.surface_kind,
            process_id: binding.process_id,
            app_id: binding.app_id,
            title: binding.title,
            language: "und",
            x: window.x,
            y: window.y,
            width: window.width,
            height: window.height,
            tree: window.tree,
            html: window.html,
            minimized: window.minimized,
            focused: window.focused,
            z_index: window.z_index,
            chrome_kind: WM_CHROME_KIND_TITLED
        )
    return SharedWmWindow(
        surface_id: window.surface_id,
        window_id: window.surface_id,
        surface_kind: UI_SURFACE_KIND_LEGACY,
        process_id: 0u64,
        app_id: "",
        title: window.title,
        language: "und",
        x: window.x,
        y: window.y,
        width: window.width,
        height: window.height,
        tree: window.tree,
        html: window.html,
        minimized: window.minimized,
        focused: window.focused,
        z_index: window.z_index,
        chrome_kind: WM_CHROME_KIND_TITLED
    )

fn shared_wm_scene_from_window_manager(manager: WindowManager, registry: UiWindowSurfaceRegistry, width: i32, height: i32) -> SharedWmScene:
    val window_count = manager.windows.len()
    val default_background = shared_wm_background_color(wm_chrome_theme().compositor_bg)
    if window_count == 0:
        return SharedWmScene(width: width, height: height, backend: manager.current_backend(), windows: [], background: default_background)
    var windows: [SharedWmWindow] = []
    var idx = 0
    while idx < window_count:
        windows.push(_project_window(manager.windows[idx], registry))
        idx = idx + 1
    SharedWmScene(width: width, height: height, backend: manager.current_backend(), windows: windows, background: default_background)

fn shared_wm_visible_windows(scene: SharedWmScene) -> [SharedWmWindow]:
    var visible_count = 0
    for window in scene.windows:
        if not window.minimized:
            visible_count = visible_count + 1
    if visible_count == 0:
        return []
    var visible: [SharedWmWindow] = []
    for window in scene.windows:
        if not window.minimized:
            visible.push(window)
    return visible

fn shared_wm_focused_window_id(scene: SharedWmScene) -> text:
    var best_id = ""
    var best_z = -1
    for window in scene.windows:
        if window.focused and not window.minimized:
            if window.z_index > best_z:
                best_id = window.window_id
                best_z = window.z_index
    return best_id

fn shared_wm_scene_layout_key(scene: SharedWmScene) -> text:
    val window_count = scene.windows.len()
    var parts: [text] = []
    parts.push("w={scene.width};h={scene.height};backend={scene.backend};count={window_count}")
    var idx = 0
    while idx < window_count:
        val window = scene.windows[idx]
        parts.push("{window.surface_id}:{window.window_id}:{window.x},{window.y},{window.width},{window.height}:z{window.z_index}:min{window.minimized}:focus{window.focused}")
        idx = idx + 1
    parts.join(";")

fn _shared_wm_nonnegative(value: i32) -> i32:
    if value < 0:
        return 0
    value

fn _shared_wm_clamp(value: i32, min_value: i32, max_value: i32) -> i32:
    if value < min_value:
        return min_value
    if value > max_value:
        return max_value
    value

fn _shared_wm_scale_px(px: i32, dpi_scale_milli: i32) -> i32:
    val scale = if dpi_scale_milli <= 0: 1000 else: dpi_scale_milli
    val scaled = (px * scale + 999) / 1000
    if scaled < 1:
        return 1
    scaled

fn shared_wm_scene_chrome(scene: SharedWmScene, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32, taskbar_icon_count: i32) -> SharedWmChrome:
    val command_h = _shared_wm_scale_px(32, dpi_scale_milli)
    val taskbar_h = _shared_wm_scale_px(48, dpi_scale_milli)
    val content_h = _shared_wm_nonnegative(scene.height - command_h - taskbar_h)
    SharedWmChrome(
        background_color: wm_chrome_theme().background_hex,
        command_lane: SharedWmRect(x: 0, y: 0, width: scene.width, height: command_h),
        content_area: SharedWmRect(x: 0, y: command_h, width: scene.width, height: content_h),
        taskbar: SharedWmRect(x: 0, y: command_h + content_h, width: scene.width, height: taskbar_h),
        dpi_scale_milli: if dpi_scale_milli <= 0: 1000 else: dpi_scale_milli,
        clock_label: clock_label,
        right_icon_count: right_icon_count,
        taskbar_icon_count: taskbar_icon_count
    )

fn shared_wm_drag_window(scene: SharedWmScene, surface_id: text, dx: i32, dy: i32) -> SharedWmScene:
    val chrome = shared_wm_scene_chrome(scene, 1000, "", 0, 0)
    val min_x = chrome.content_area.x
    val min_y = chrome.content_area.y
    val window_count = scene.windows.len()
    if window_count == 0:
        return SharedWmScene(width: scene.width, height: scene.height, backend: scene.backend, windows: [], background: scene.background)
    var moved: [SharedWmWindow] = []
    var idx = 0
    while idx < window_count:
        val window = scene.windows[idx]
        if window.surface_id == surface_id and not window.minimized:
            val max_x = _shared_wm_nonnegative(chrome.content_area.x + chrome.content_area.width - window.width)
            val max_y = _shared_wm_nonnegative(chrome.content_area.y + chrome.content_area.height - window.height)
            moved.push(SharedWmWindow(
                surface_id: window.surface_id,
                window_id: window.window_id,
                surface_kind: window.surface_kind,
                process_id: window.process_id,
                app_id: window.app_id,
                title: window.title,
                language: window.language,
                x: _shared_wm_clamp(window.x + dx, min_x, max_x),
                y: _shared_wm_clamp(window.y + dy, min_y, max_y),
                width: window.width,
                height: window.height,
                tree: window.tree,
                html: window.html,
                minimized: window.minimized,
                focused: true,
                z_index: window.z_index,
                chrome_kind: window.chrome_kind
            ))
        else:
            moved.push(window)
        idx = idx + 1
    SharedWmScene(width: scene.width, height: scene.height, backend: scene.backend, windows: moved, background: scene.background)

fn shared_wm_focus_window_by_window_id(scene: SharedWmScene, window_id: text) -> SharedWmScene:
    val window_count = scene.windows.len()
    if window_count == 0:
        return SharedWmScene(width: scene.width, height: scene.height, backend: scene.backend, windows: [], background: scene.background)
    var focused: [SharedWmWindow] = []
    var idx = 0
    while idx < window_count:
        val window = scene.windows[idx]
        if window.window_id == window_id:
            focused.push(SharedWmWindow(
                surface_id: window.surface_id,
                window_id: window.window_id,
                surface_kind: window.surface_kind,
                process_id: window.process_id,
                app_id: window.app_id,
                title: window.title,
                language: window.language,
                x: window.x,
                y: window.y,
                width: window.width,
                height: window.height,
                tree: window.tree,
                html: window.html,
                minimized: false,
                focused: true,
                z_index: window.z_index,
                chrome_kind: window.chrome_kind
            ))
        else:
            focused.push(SharedWmWindow(
                surface_id: window.surface_id,
                window_id: window.window_id,
                surface_kind: window.surface_kind,
                process_id: window.process_id,
                app_id: window.app_id,
                title: window.title,
                language: window.language,
                x: window.x,
                y: window.y,
                width: window.width,
                height: window.height,
                tree: window.tree,
                html: window.html,
                minimized: window.minimized,
                focused: false,
                z_index: window.z_index,
                chrome_kind: window.chrome_kind
            ))
        idx = idx + 1
    SharedWmScene(width: scene.width, height: scene.height, backend: scene.backend, windows: focused, background: scene.background)

fn _shared_wm_dispatch_result(action: text, target_id: text, app_id: text, window_id: text, scene: SharedWmScene) -> SharedWmDispatchResult:
    SharedWmDispatchResult(action: action, target_id: target_id, app_id: app_id, window_id: window_id, scene: scene)

fn _shared_wm_rect_contains(rect: SharedWmRect, x: i32, y: i32) -> bool:
    x >= rect.x and y >= rect.y and x < rect.x + rect.width and y < rect.y + rect.height

fn _shared_wm_window_contains(window: SharedWmWindow, x: i32, y: i32) -> bool:
    x >= window.x and y >= window.y and x < window.x + window.width and y < window.y + window.height

fn _shared_wm_command_lane_dispatch(scene: SharedWmScene, chrome: SharedWmChrome, x: i32) -> SharedWmDispatchResult:
    val icon_w = _shared_wm_scale_px(32, chrome.dpi_scale_milli)
    val clock_w = _shared_wm_scale_px(72, chrome.dpi_scale_milli)
    val icons_w = icon_w * chrome.right_icon_count
    val icons_start = scene.width - icons_w
    if chrome.right_icon_count > 0 and x >= icons_start:
        val rel = x - icons_start
        val idx = rel / icon_w
        return _shared_wm_dispatch_result("command_lane_icon", "right_icon_{idx}", "", "", scene)
    if x >= icons_start - clock_w:
        return _shared_wm_dispatch_result("command_lane_clock", "clock", "", "", scene)
    _shared_wm_dispatch_result("command_lane", "command_lane", "", "", scene)

fn _shared_wm_taskbar_dispatch(scene: SharedWmScene, taskbar: TaskbarModel, x: i32) -> SharedWmDispatchResult:
    val slot_w = 56
    val slot = x / slot_w
    if slot >= 0 and slot < taskbar.pinned.len():
        val app = taskbar.pinned[slot]
        return _shared_wm_dispatch_result("launch_app", app.app_id, app.app_id, "", scene)
    val running_index = slot - taskbar.pinned.len()
    if running_index >= 0 and running_index < taskbar.running.len():
        val running = taskbar.running[running_index]
        val focused_scene = shared_wm_focus_window_by_window_id(scene, running.window_id)
        return _shared_wm_dispatch_result("focus_window", running.window_id, running.app_id, running.window_id, focused_scene)
    _shared_wm_dispatch_result("taskbar_empty", "taskbar", "", "", scene)

fn _shared_wm_content_dispatch(scene: SharedWmScene, x: i32, y: i32) -> SharedWmDispatchResult:
    var best_index = -1
    var best_z = -1
    var i = 0
    val window_count = scene.windows.len()
    while i < window_count:
        val window = scene.windows[i]
        if not window.minimized and _shared_wm_window_contains(window, x, y):
            if window.z_index > best_z:
                best_index = i
                best_z = window.z_index
        i = i + 1
    if best_index < 0:
        return _shared_wm_dispatch_result("desktop_background", "background", "", "", scene)
    val window = scene.windows[best_index]
    val focused_scene = shared_wm_focus_window_by_window_id(scene, window.window_id)
    if y < window.y + _shared_wm_scale_px(28, 1000):
        return _shared_wm_dispatch_result("begin_drag_window", window.surface_id, window.app_id, window.window_id, focused_scene)
    _shared_wm_dispatch_result("focus_window", window.window_id, window.app_id, window.window_id, focused_scene)

fn _shared_wm_component_kind(action: text) -> text:
    if action == "begin_drag_window" or action == "focus_window":
        return "window"
    if action == "launch_app":
        return "taskbar"
    if action == "command_lane_clock" or action == "command_lane_icon" or action == "command_lane":
        return "command_lane"
    if action == "desktop_background":
        return "desktop"
    "unknown"

fn _shared_wm_translation_local(scene: SharedWmScene, target_id: text, x: i32, y: i32) -> SharedWmRect:
    for window in scene.windows:
        if window.surface_id == target_id or window.window_id == target_id:
            return SharedWmRect(x: x - window.x, y: y - window.y, width: window.width, height: window.height)
    SharedWmRect(x: x, y: y, width: 0, height: 0)

fn _shared_wm_pointer_input_key(x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32, taskbar_count: i32, backend_target: text) -> text:
    "x={x};y={y};button={button};kind={kind};dpi={dpi_scale_milli};clock={clock_label};right={right_icon_count};taskbar={taskbar_count};backend={backend_target}"

fn _shared_wm_event_target_translation(scene_key: text, input_key: text, scene: SharedWmScene, result: SharedWmDispatchResult, x: i32, y: i32, backend_target: text, cache_hit: bool, stale_cache_rejected: bool) -> SharedWmEventTargetTranslation:
    val local = _shared_wm_translation_local(scene, result.target_id, x, y)
    SharedWmEventTargetTranslation(
        scene_key: scene_key,
        input_key: input_key,
        action: result.action,
        target_id: result.target_id,
        app_id: result.app_id,
        window_id: result.window_id,
        component_kind: _shared_wm_component_kind(result.action),
        local_x: local.x,
        local_y: local.y,
        backend_target: backend_target,
        cache_hit: cache_hit,
        stale_cache_rejected: stale_cache_rejected
    )

fn shared_wm_dispatch_pointer(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> SharedWmDispatchResult:
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    if kind != "down" or button != "left":
        return _shared_wm_dispatch_result("ignored", "", "", "", scene)
    if _shared_wm_rect_contains(chrome.command_lane, x, y):
        return _shared_wm_command_lane_dispatch(scene, chrome, x)
    if _shared_wm_rect_contains(chrome.taskbar, x, y):
        return _shared_wm_taskbar_dispatch(scene, taskbar, x)
    if _shared_wm_rect_contains(chrome.content_area, x, y):
        return _shared_wm_content_dispatch(scene, x, y)
    _shared_wm_dispatch_result("outside", "", "", "", scene)

fn shared_wm_translate_pointer_event(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32, backend_target: text) -> SharedWmEventTargetTranslationResult:
    val scene_key = shared_wm_scene_layout_key(scene)
    val input_key = _shared_wm_pointer_input_key(x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len(), backend_target)
    val dispatch = shared_wm_dispatch_pointer(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count)
    val translation = _shared_wm_event_target_translation(scene_key, input_key, scene, dispatch, x, y, backend_target, false, false)
    SharedWmEventTargetTranslationResult(
        translation: translation,
        cache: SharedWmEventTargetTranslationCache(scene_key: scene_key, input_key: input_key, translation: translation)
    )

fn shared_wm_translate_pointer_event_cached(scene: SharedWmScene, taskbar: TaskbarModel, x: i32, y: i32, button: text, kind: text, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32, backend_target: text, cache: SharedWmEventTargetTranslationCache) -> SharedWmEventTargetTranslationResult:
    val scene_key = shared_wm_scene_layout_key(scene)
    val input_key = _shared_wm_pointer_input_key(x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len(), backend_target)
    if cache.scene_key == scene_key and cache.input_key == input_key:
        val cached = cache.translation
        val hit = SharedWmEventTargetTranslation(
            scene_key: cached.scene_key,
            input_key: cached.input_key,
            action: cached.action,
            target_id: cached.target_id,
            app_id: cached.app_id,
            window_id: cached.window_id,
            component_kind: cached.component_kind,
            local_x: cached.local_x,
            local_y: cached.local_y,
            backend_target: cached.backend_target,
            cache_hit: true,
            stale_cache_rejected: false
        )
        return SharedWmEventTargetTranslationResult(
            translation: hit,
            cache: SharedWmEventTargetTranslationCache(scene_key: scene_key, input_key: input_key, translation: hit)
        )
    val recomputed = shared_wm_translate_pointer_event(scene, taskbar, x, y, button, kind, dpi_scale_milli, clock_label, right_icon_count, backend_target)
    val stale = cache.input_key == input_key and cache.scene_key != scene_key
    val translated = recomputed.translation
    val fresh = SharedWmEventTargetTranslation(
        scene_key: translated.scene_key,
        input_key: translated.input_key,
        action: translated.action,
        target_id: translated.target_id,
        app_id: translated.app_id,
        window_id: translated.window_id,
        component_kind: translated.component_kind,
        local_x: translated.local_x,
        local_y: translated.local_y,
        backend_target: translated.backend_target,
        cache_hit: false,
        stale_cache_rejected: stale
    )
    SharedWmEventTargetTranslationResult(
        translation: fresh,
        cache: SharedWmEventTargetTranslationCache(scene_key: scene_key, input_key: input_key, translation: fresh)
    )
