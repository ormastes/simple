# codex-impl
# Shared CLI access grammar for TRACE32 GUI, Simple UI, and host WM adapters.
# Data and presentation only: live enumeration and actions remain adapter-owned.

use common.text_advanced.{escape_json}
use common.ui.access_types.{UiAccessNode, UiAccessSurface, UiAccessSnapshot}
use common.ui.access_query.{ui_access_find_node, ui_access_snapshot_to_json}

pub val ACCESS_SCHEMA_VERSION: i32 = 1
pub val ACCESS_OPERATION_LIST: text = "list"
pub val ACCESS_OPERATION_SNAPSHOT: text = "snapshot"
pub val ACCESS_OPERATION_SURFACE: text = "surface"
pub val ACCESS_OPERATION_FIND: text = "find"
pub val ACCESS_OPERATION_ACT: text = "act"
pub val ACCESS_OPERATION_HISTORY: text = "history"
pub val ACCESS_OUTPUT_HUMAN: text = "human"
pub val ACCESS_OUTPUT_JSON: text = "json"

type AccessOperation = text
type AccessOutputMode = text

class AccessSafety:
    read_only: bool
    destructive: bool
    idempotent: bool
    requires_confirmation: bool
    may_prompt: bool
    timeout_ms: i64

impl AccessSafety:
    static fn read(timeout_ms: i64) -> AccessSafety:
        AccessSafety(read_only: true, destructive: false, idempotent: true, requires_confirmation: false, may_prompt: false, timeout_ms: timeout_ms)

    static fn action(timeout_ms: i64, destructive: bool, requires_confirmation: bool, may_prompt: bool) -> AccessSafety:
        AccessSafety(read_only: false, destructive: destructive, idempotent: false, requires_confirmation: requires_confirmation, may_prompt: may_prompt, timeout_ms: timeout_ms)

class AccessCommandDescriptor:
    name: text
    subcommand: text
    handler_key: text
    operation: AccessOperation
    usage: text
    example: text
    min_args: i64
    description: text
    aliases: [text]
    safety: AccessSafety

impl AccessCommandDescriptor:
    static fn create(name: text, subcommand: text, handler_key: text, operation: AccessOperation, usage: text, example: text, min_args: i64, description: text, aliases: [text], safety: AccessSafety) -> AccessCommandDescriptor:
        AccessCommandDescriptor(name: name, subcommand: subcommand, handler_key: handler_key, operation: operation, usage: usage, example: example, min_args: min_args, description: description, aliases: aliases, safety: safety)

class AccessRequest:
    descriptor: AccessCommandDescriptor
    output_mode: AccessOutputMode
    source_id: text
    session_id: text
    correlation_id: text
    args: [text]
    timeout_ms: i64
    confirmed: bool

impl AccessRequest:
    static fn create(descriptor: AccessCommandDescriptor, output_mode: AccessOutputMode, source_id: text, session_id: text, correlation_id: text, args: [text], timeout_ms: i64, confirmed: bool) -> AccessRequest:
        AccessRequest(descriptor: descriptor, output_mode: output_mode, source_id: source_id, session_id: session_id, correlation_id: correlation_id, args: args, timeout_ms: timeout_ms, confirmed: confirmed)

class AccessError:
    code: text
    message: text
    source_code: text
    hint: text
    retryable: bool
    interaction_required: bool
    request_id: text

impl AccessError:
    static fn create(code: text, message: text) -> AccessError:
        AccessError(code: code, message: message, source_code: "", hint: "", retryable: false, interaction_required: code == "interaction_required", request_id: "")

    static fn detailed(code: text, message: text, source_code: text, hint: text, retryable: bool, interaction_required: bool) -> AccessError:
        AccessError(code: code, message: message, source_code: source_code, hint: hint, retryable: retryable, interaction_required: interaction_required, request_id: "")

    me set_request_id(request_id: text):
        self.request_id = request_id

class AccessResult:
    schema_version: i32
    operation: AccessOperation
    source_id: text
    session_id: text
    revision: i64
    correlation_id: text
    kind: text
    title: text
    rows: [[text]]
    kv_pairs: [[text]]
    scalar_value: text
    gui_status: text
    raw_output: text
    items: [text]
    payload_json: text
    returned_count: i64
    truncated: bool

impl AccessResult:
    static fn empty(kind: text) -> AccessResult:
        AccessResult(schema_version: ACCESS_SCHEMA_VERSION, operation: "", source_id: "", session_id: "", revision: 0, correlation_id: "", kind: kind, title: "", rows: [], kv_pairs: [], scalar_value: "", gui_status: "", raw_output: "", items: [], payload_json: "", returned_count: 0, truncated: false)

    static fn scalar(value: text) -> AccessResult:
        var result = AccessResult.empty("scalar")
        result.scalar_value = value
        result

    static fn scalar_titled(title: text, value: text) -> AccessResult:
        var result = AccessResult.scalar(value)
        result.title = title
        result

    static fn table(title: text, rows: [[text]]) -> AccessResult:
        var result = AccessResult.empty("table")
        result.title = title
        result.rows = rows
        result.returned_count = if rows.len() > 1: rows.len().to_i64() - 1 else: 0
        result

    static fn kv(title: text, pairs: [[text]]) -> AccessResult:
        var result = AccessResult.empty("kv")
        result.title = title
        result.kv_pairs = pairs
        result.returned_count = pairs.len().to_i64()
        result

    static fn list(title: text, items: [text]) -> AccessResult:
        var result = AccessResult.empty("list")
        result.title = title
        result.items = items
        result.returned_count = items.len().to_i64()
        result

    static fn raw(output: text) -> AccessResult:
        var result = AccessResult.empty("raw")
        result.raw_output = output
        result

    static fn status(pairs: [[text]], gui: text) -> AccessResult:
        var result = AccessResult.kv("Status", pairs)
        result.kind = "status"
        result.gui_status = gui
        result

    static fn document(operation: AccessOperation, source_id: text, session_id: text, revision: i64, payload_json: text, returned_count: i64, truncated: bool) -> AccessResult:
        AccessResult(schema_version: ACCESS_SCHEMA_VERSION, operation: operation, source_id: source_id, session_id: session_id, revision: revision, correlation_id: "", kind: "document", title: "", rows: [], kv_pairs: [], scalar_value: "", gui_status: "", raw_output: "", items: [], payload_json: payload_json, returned_count: returned_count, truncated: truncated)

    me set_gui_status(gui: text):
        self.gui_status = gui

    me set_context(operation: AccessOperation, source_id: text, session_id: text, revision: i64, correlation_id: text, payload_json: text, truncated: bool):
        self.operation = operation
        self.source_id = source_id
        self.session_id = session_id
        self.revision = revision
        self.correlation_id = correlation_id
        self.payload_json = payload_json
        self.truncated = truncated

pub fn access_operation_is_valid(operation: AccessOperation) -> bool:
    operation == ACCESS_OPERATION_LIST or operation == ACCESS_OPERATION_SNAPSHOT or operation == ACCESS_OPERATION_SURFACE or operation == ACCESS_OPERATION_FIND or operation == ACCESS_OPERATION_ACT or operation == ACCESS_OPERATION_HISTORY

pub fn access_output_mode_is_valid(mode: AccessOutputMode) -> bool:
    mode == ACCESS_OUTPUT_HUMAN or mode == ACCESS_OUTPUT_JSON

pub fn access_find_descriptor(name: text, subcommand: text, descriptors: [AccessCommandDescriptor]) -> AccessCommandDescriptor?:
    var i = 0
    while i < descriptors.len():
        val descriptor = descriptors[i]
        if descriptor.name == name and descriptor.subcommand == subcommand:
            return descriptor
        var j = 0
        while j < descriptor.aliases.len():
            val alias = descriptor.aliases[j]
            if alias == name and descriptor.subcommand == subcommand:
                return descriptor
            j = j + 1
        i = i + 1
    nil

pub fn access_validate_request(request: AccessRequest) -> Result<(), AccessError>:
    if not access_operation_is_valid(request.descriptor.operation):
        return Err(AccessError.create("invalid_argument", "unsupported access operation '" + request.descriptor.operation + "'"))
    if not access_output_mode_is_valid(request.output_mode):
        return Err(AccessError.create("invalid_argument", "unsupported output mode '" + request.output_mode + "'"))
    if request.args.len().to_i64() < request.descriptor.min_args:
        return Err(AccessError.detailed("invalid_argument", "missing arguments", "", "Usage: " + request.descriptor.usage, false, false))
    if request.timeout_ms <= 0:
        return Err(AccessError.create("invalid_argument", "timeout must be positive"))
    if request.descriptor.safety.requires_confirmation and not request.confirmed:
        return Err(AccessError.detailed("interaction_required", "explicit confirmation is required", "", "Review the exact target and action", false, true))
    Ok(())

pub fn access_validate_snapshot_action(snapshot: UiAccessSnapshot, target_id: text, action: text) -> Result<UiAccessNode, AccessError>:
    val node = ui_access_find_node(snapshot, target_id)
    if node == nil:
        return Err(AccessError.create("target_not_found", "target '" + target_id + "' was not found"))
    if not node.enabled or _access_prop(node, "defunct") == "true":
        return Err(AccessError.create("target_disabled", "target '" + target_id + "' is disabled or defunct"))
    if _access_prop(node, "busy") == "true":
        return Err(AccessError.detailed("target_busy", "target '" + target_id + "' is busy", "", "Observe the target before retrying", true, false))
    for advertised in node.action_names:
        if advertised == action:
            return Ok(node)
    Err(AccessError.create("unsupported_action", "target '" + target_id + "' does not advertise action '" + action + "'"))

pub fn access_result_from_snapshot(operation: AccessOperation, source_id: text, session_id: text, snapshot: UiAccessSnapshot, limit: i64) -> AccessResult:
    if operation == ACCESS_OPERATION_LIST:
        return _access_window_list_result(source_id, session_id, snapshot, limit)
    val payload = ui_access_snapshot_to_json(snapshot)
    AccessResult.document(operation, source_id, session_id, snapshot.snapshot_revision, payload, snapshot.nodes.len().to_i64(), false)

pub fn access_render_human(result: AccessResult) -> text:
    var body = ""
    match result.kind:
        "table": body = _access_render_table(result)
        "kv": body = _access_render_kv(result)
        "status": body = _access_render_kv(result)
        "list": body = _access_render_list(result)
        "raw": body = result.raw_output
        "document": body = if result.raw_output != "": result.raw_output else: result.payload_json
        _: body = _access_render_scalar(result)
    body

pub fn access_render_json(result: AccessResult) -> text:
    val payload = if result.payload_json == "": "null" else: result.payload_json
    val item_payload = if result.operation == ACCESS_OPERATION_LIST and result.payload_json != "": result.payload_json else: _access_texts_to_json(result.items)
    val page = _access_json_object([
        ["returned", result.returned_count.to_text()],
        ["truncated", _access_json_bool(result.truncated)]
    ])
    val source_obj = _access_json_object([
        ["id", _access_json_str(result.source_id)],
        ["session", _access_json_nullable(result.session_id)]
    ])
    val result_value = if result.operation == ACCESS_OPERATION_LIST: "null" else: payload
    _access_json_object([
        ["schema", _access_json_str("simple.access/v" + result.schema_version.to_text())],
        ["schema_version", result.schema_version.to_text()],
        ["operation", _access_json_str(result.operation)],
        ["source", source_obj],
        ["revision", result.revision.to_text()],
        ["request_id", _access_json_nullable(result.correlation_id)],
        ["kind", _access_json_str(result.kind)],
        ["title", _access_json_str(result.title)],
        ["rows", _access_rows_to_json(result.rows)],
        ["kv", _access_rows_to_json(result.kv_pairs)],
        ["scalar", _access_json_str(result.scalar_value)],
        ["raw", _access_json_str(result.raw_output)],
        ["items", item_payload],
        ["result", result_value],
        ["page", page]
    ])

pub fn access_error_to_json(operation: AccessOperation, request_id: text, error: AccessError) -> text:
    val error_obj = _access_json_object([
        ["code", _access_json_str(error.code)],
        ["message", _access_json_str(error.message)],
        ["source_code", _access_json_nullable(error.source_code)],
        ["hint", _access_json_nullable(error.hint)],
        ["retryable", _access_json_bool(error.retryable)],
        ["interaction_required", _access_json_bool(error.interaction_required)]
    ])
    _access_json_object([
        ["schema", _access_json_str("simple.access/v1")],
        ["operation", _access_json_str(operation)],
        ["request_id", _access_json_nullable(request_id)],
        ["ok", "false"],
        ["error", error_obj]
    ])

fn _access_window_list_result(source_id: text, session_id: text, snapshot: UiAccessSnapshot, limit: i64) -> AccessResult:
    val sorted = _access_sorted_surfaces(snapshot.surfaces)
    val max_count = if limit <= 0 or limit > sorted.len().to_i64(): sorted.len().to_i64() else: limit
    var rows: [[text]] = [["ID", "TITLE", "OWNER", "KIND", "STATE", "GEOMETRY", "FOCUS", "VISIBLE", "PARENT", "CAPS", "REVISION", "CAPTURED_AT", "GENERATION", "STALE"]]
    var idx: i64 = 0
    while idx < max_count:
        val surface = sorted[idx]
        val root = ui_access_find_node(snapshot, surface.root_canonical_id)
        val root_surface_kind = if root == nil: "" else: _access_prop(root, "surface_kind")
        val kind = if root == nil: "-" else: if root_surface_kind != "": root_surface_kind else: root.kind
        val state = if root == nil: "-" else: if root.enabled: "ready" else: "disabled"
        val focused = if root == nil: "-" else: if root.focused: "yes" else: "no"
        val visible = if root == nil: "-" else: if root.visible: "yes" else: "no"
        val geometry = if root == nil: "-" else: _access_geometry(root)
        val capabilities = if root == nil: "" else: root.action_names.join(",")
        val parent_id = if root == nil: "" else: _access_prop(root, "parent_id")
        val captured_at = if root == nil: "" else: _access_prop(root, "captured_at")
        val generation = if root == nil: "" else: _access_prop(root, "generation")
        val stale = if root == nil: "" else: _access_prop(root, "stale")
        rows = rows.push([surface.surface_id, surface.title, if surface.app_id == "": "-" else: surface.app_id, kind, state, geometry, focused, visible, if parent_id == "": "-" else: parent_id, if capabilities == "": "-" else: capabilities, snapshot.snapshot_revision.to_text(), if captured_at == "": "-" else: captured_at, if generation == "": "-" else: generation, if stale == "": "-" else: stale])
        idx = idx + 1
    var result = AccessResult.table("Windows", rows)
    result.set_context(ACCESS_OPERATION_LIST, source_id, session_id, snapshot.snapshot_revision, "", _access_window_items_json(sorted, snapshot, max_count), max_count < sorted.len().to_i64())
    result.returned_count = max_count
    result

fn _access_sorted_surfaces(surfaces: [UiAccessSurface]) -> [UiAccessSurface]:
    var sorted = surfaces
    var i = 1
    while i < sorted.len():
        val item = sorted[i]
        var j = i
        while j > 0 and sorted[j - 1].surface_id > item.surface_id:
            sorted[j] = sorted[j - 1]
            j = j - 1
        sorted[j] = item
        i = i + 1
    sorted

fn _access_geometry(node: UiAccessNode) -> text:
    val x = _access_prop(node, "x")
    val y = _access_prop(node, "y")
    val width = _access_prop(node, "width")
    val height = _access_prop(node, "height")
    if not _access_integer_text(x) or not _access_integer_text(y) or not _access_integer_text(width) or not _access_integer_text(height):
        return "-"
    x + "," + y + " " + width + "x" + height

fn _access_prop(node: UiAccessNode, key: text) -> text:
    var i: i64 = 0
    while i < node.props.len():
        val prop = node.props[i]
        if prop.key == key:
            return prop.value
        i = i + 1
    ""

fn _access_window_items_json(surfaces: [UiAccessSurface], snapshot: UiAccessSnapshot, count: i64) -> text:
    var items: [text] = []
    var idx: i64 = 0
    while idx < count:
        val surface = surfaces[idx]
        val root = ui_access_find_node(snapshot, surface.root_canonical_id)
        val root_surface_kind = if root == nil: "" else: _access_prop(root, "surface_kind")
        val kind = if root == nil: "" else: if root_surface_kind != "": root_surface_kind else: root.kind
        val state = if root == nil: "null" else: _access_json_str(if root.enabled: "ready" else: "disabled")
        val focused = if root == nil: "null" else: _access_json_bool(root.focused)
        val visible = if root == nil: "null" else: _access_json_bool(root.visible)
        val actions = if root == nil: "null" else: _access_texts_to_json(root.action_names)
        val geometry = if root == nil: "null" else: _access_geometry_json(root)
        val captured_at = if root == nil: "null" else: _access_json_nullable(_access_prop(root, "captured_at"))
        val stale = if root == nil: "null" else: _access_bool_text_nullable(_access_prop(root, "stale"))
        val generation = if root == nil: "null" else: _access_json_nullable(_access_prop(root, "generation"))
        val parent_id = if root == nil: "null" else: _access_json_nullable(_access_prop(root, "parent_id"))
        items = items.push(_access_json_object([
            ["id", _access_json_str(surface.surface_id)],
            ["title", _access_json_str(surface.title)],
            ["owner", _access_json_nullable(surface.app_id)],
            ["surface_kind", _access_json_nullable(kind)],
            ["state", state],
            ["geometry", geometry],
            ["focused", focused],
            ["visible", visible],
            ["parent_id", parent_id],
            ["capabilities", actions],
            ["captured_revision", snapshot.snapshot_revision.to_text()],
            ["captured_at", captured_at],
            ["generation", generation],
            ["stale", stale]
        ]))
        idx = idx + 1
    "[" + items.join(",") + "]"

fn _access_render_scalar(result: AccessResult) -> text:
    if result.raw_output != "":
        return result.raw_output
    if result.title != "":
        return result.title + ": " + result.scalar_value
    result.scalar_value

fn _access_render_kv(result: AccessResult) -> text:
    var lines: [text] = []
    if result.title != "":
        lines = lines.push(result.title + ":")
    for pair in result.kv_pairs:
        if pair.len() >= 2:
            lines = lines.push("  " + pair[0] + ": " + pair[1])
        elif pair.len() == 1:
            lines = lines.push("  " + pair[0])
    lines.join("\n")

fn _access_render_table(result: AccessResult) -> text:
    if result.rows.len() == 0:
        return if result.title == "": "(empty)" else: result.title + ": (empty)"
    var lines: [text] = []
    if result.title != "":
        lines = lines.push(result.title + ":")
    var i: i64 = 0
    while i < result.rows.len():
        val row = result.rows[i]
        lines = lines.push("  " + row.join("  "))
        i = i + 1
    lines.join("\n")

fn _access_render_list(result: AccessResult) -> text:
    var lines: [text] = []
    if result.title != "":
        lines = lines.push(result.title + ":")
    for item in result.items:
        lines = lines.push("  - " + item)
    lines.join("\n")

fn _access_rows_to_json(rows: [[text]]) -> text:
    var encoded: [text] = []
    for row in rows:
        encoded = encoded.push(_access_texts_to_json(row))
    "[" + encoded.join(",") + "]"

fn _access_texts_to_json(values: [text]) -> text:
    var encoded: [text] = []
    for value in values:
        encoded = encoded.push(_access_json_str(value))
    "[" + encoded.join(",") + "]"

fn _access_json_object(pairs: [[text]]) -> text:
    var parts: [text] = []
    for pair in pairs:
        parts = parts.push(_access_json_pair(pair[0], pair[1]))
    "{" + parts.join(",") + "}"

fn _access_json_pair(key: text, value: text) -> text:
    _access_json_str(key) + ":" + value

fn _access_json_str(value: text) -> text:
    "\"" + escape_json(value) + "\""

fn _access_json_nullable(value: text) -> text:
    if value == "":
        return "null"
    _access_json_str(value)

fn _access_json_bool(value: bool) -> text:
    if value:
        return "true"
    "false"

fn _access_geometry_json(node: UiAccessNode) -> text:
    val x = _access_prop(node, "x")
    val y = _access_prop(node, "y")
    val width = _access_prop(node, "width")
    val height = _access_prop(node, "height")
    if not _access_integer_text(x) or not _access_integer_text(y) or not _access_integer_text(width) or not _access_integer_text(height):
        return "null"
    "{" + _access_json_pair("x", x) + "," + _access_json_pair("y", y) + "," + _access_json_pair("width", width) + "," + _access_json_pair("height", height) + "}"

fn _access_integer_text(value: text) -> bool:
    if value == "": return false
    var digits = 0
    var index = 0
    for ch in value:
        if ch == "-":
            if index != 0: return false
        else:
            if not "0123456789".contains(ch): return false
            digits = digits + 1
        index = index + 1
    digits > 0

fn _access_bool_text_nullable(value: text) -> text:
    if value == "true":
        return "true"
    if value == "false":
        return "false"
    "null"
