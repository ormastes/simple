# UI Access Adapter Registry
#
# Runtime selection of additive snapshot adapters. The initial implementation
# provides a working null adapter and a registry of target->adapter bindings.

use common.ui.access_source.{UiAccessAdapterTarget, UiAccessSnapshotEnvelope, UiAccessIssue, ui_access_issue_warning, ui_access_snapshot_envelope_empty}

struct UiAccessAdapterRegistryEntry:
    target: UiAccessAdapterTarget
    adapter_kind: text
    adapter_name: text
    enabled: bool

class UiAccessNullAdapter:
    pass_dn

impl UiAccessNullAdapter:
    static fn new() -> UiAccessNullAdapter:
        UiAccessNullAdapter()

    fn name() -> text:
        return "ui_access_null_adapter"

    fn adapter_kind() -> text:
        return "null"

    fn supports(target: UiAccessAdapterTarget) -> bool:
        return target.operation != ""

    fn describe_target(target: UiAccessAdapterTarget) -> text:
        return "{target.operation}:{target.source.source_kind}/{target.source.source_id}"

    fn adapt(target: UiAccessAdapterTarget) -> UiAccessSnapshotEnvelope:
        return ui_access_snapshot_envelope_empty(target)

class UiAccessAdapterRegistry:
    entries: [UiAccessAdapterRegistryEntry]

impl UiAccessAdapterRegistry:
    static fn new() -> UiAccessAdapterRegistry:
        UiAccessAdapterRegistry(entries: [])

    me register_target(target: UiAccessAdapterTarget, adapter_kind: text, adapter_name: text, enabled: bool):
        var filtered: [UiAccessAdapterRegistryEntry] = []
        for entry in self.entries:
            if _same_target(entry.target, target):
                pass_dn
            else:
                filtered = filtered.push(entry)
        filtered = filtered.push(UiAccessAdapterRegistryEntry(
            target: target,
            adapter_kind: adapter_kind,
            adapter_name: adapter_name,
            enabled: enabled
        ))
        self.entries = filtered

    fn entry_count() -> i32:
        return self.entries.len()

    fn has_target(target: UiAccessAdapterTarget) -> bool:
        return self.resolve_target(target) != nil

    fn resolve_target(target: UiAccessAdapterTarget) -> UiAccessAdapterRegistryEntry?:
        for entry in self.entries:
            if _same_target(entry.target, target):
                return entry
        return nil

    fn adapter_name_for(target: UiAccessAdapterTarget) -> text:
        val entry = self.resolve_target(target)
        if entry == nil:
            return ""
        return entry.adapter_name

    fn adapter_kind_for(target: UiAccessAdapterTarget) -> text:
        val entry = self.resolve_target(target)
        if entry == nil:
            return ""
        return entry.adapter_kind

    fn adapt(target: UiAccessAdapterTarget) -> UiAccessSnapshotEnvelope:
        val entry = self.resolve_target(target)
        if entry == nil:
            val adapter = ui_access_null_adapter_new()
            return adapter.adapt(target)
        if not entry.enabled:
            return _with_issue(ui_access_snapshot_envelope_empty(target), ui_access_issue_warning("adapter.disabled", "adapter disabled", target.source.source_id, target.operation, "Registry entry disabled"))
        val adapter = ui_access_null_adapter_new()
        return adapter.adapt(target)

fn ui_access_null_adapter_new() -> UiAccessNullAdapter:
    return UiAccessNullAdapter.new()

fn ui_access_adapter_registry_new() -> UiAccessAdapterRegistry:
    return UiAccessAdapterRegistry.new()

fn ui_access_default_adapter_registry() -> UiAccessAdapterRegistry:
    return ui_access_adapter_registry_new()

fn _same_target(left: UiAccessAdapterTarget, right: UiAccessAdapterTarget) -> bool:
    return left.source.source_kind == right.source.source_kind and
        left.source.source_id == right.source.source_id and
        left.operation == right.operation and
        left.snapshot_mode == right.snapshot_mode and
        left.active_surface == right.active_surface and
        left.surface_id == right.surface_id

fn _with_issue(envelope: UiAccessSnapshotEnvelope, issue: UiAccessIssue) -> UiAccessSnapshotEnvelope:
    var issues = envelope.issues
    issues = issues.push(issue)
    return UiAccessSnapshotEnvelope(
        source: envelope.source,
        target: envelope.target,
        snapshot: envelope.snapshot,
        issues: issues
    )
