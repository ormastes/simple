# Character Mode System
#
# Defines the two character modes for text operations:
#   - Utf8:        byte-oriented (default). len() returns bytes, indexing by byte offset.
#   - FullUnicode: codepoint-oriented. len() returns codepoint count, indexing by codepoint.
#
# UTF-8 mode is the default for performance — O(1) length, O(1) byte indexing.
# FullUnicode mode is for user-facing text where codepoint semantics matter.
#
# Usage:
#     use std.common.encoding.char_mode.{CharMode, char_mode, set_char_mode}
#
#     set_char_mode(CharMode.FullUnicode)
#     val n = text_len("cafe\u0301")  # 5 codepoints
#
#     set_char_mode(CharMode.Utf8)
#     val n = text_len("cafe\u0301")  # 6 bytes

# ============================================================================
# CharMode enum
# ============================================================================

enum CharMode:
    Utf8
    FullUnicode

# Global default — UTF-8 is the default mode
var g_char_mode: CharMode = CharMode.Utf8

fn char_mode() -> CharMode:
    """Return the current global character mode."""
    g_char_mode

fn set_char_mode(mode: CharMode):
    """Set the global character mode."""
    g_char_mode = mode

fn is_utf8_mode() -> bool:
    """Check if current mode is UTF-8 (byte-oriented)."""
    g_char_mode == CharMode.Utf8

fn is_unicode_mode() -> bool:
    """Check if current mode is FullUnicode (codepoint-oriented)."""
    g_char_mode == CharMode.FullUnicode
