class FontAssetRuntimeValidation:
    selected: bool
    valid: bool
    family: text
    reason: text

fn selected_font_asset_candidate_for_path(path: text) -> FontAssetCandidate?:
    for candidate in selected_font_asset_candidates():
        if candidate.local_path == path: return candidate
    nil

fn _font_sha256_hex_valid(value: text) -> bool:
    if value.len() != 64: return false
    var index: i64 = 0
    while index < value.len():
        if not "0123456789abcdef".contains(value[index]): return false
        index = index + 1
    true

fn _font_asset_validation(selected: bool, valid: bool, family: text, reason: text) -> FontAssetRuntimeValidation:
    FontAssetRuntimeValidation(selected: selected, valid: valid, family: family, reason: reason)

fn validate_selected_font_asset(path: text, blob: [u8]) -> FontAssetRuntimeValidation:
    val maybe_candidate = selected_font_asset_candidate_for_path(path)
    val candidate = match maybe_candidate:
        Some(value): value
        None: return _font_asset_validation(false, true, "", "unmanaged")
    if blob.len() != candidate.byte_len:
        return _font_asset_validation(true, false, candidate.family, "byte-length")
    if not _font_sha256_hex_valid(candidate.sha256) or sha256_u8_hex(blob) != candidate.sha256:
        return _font_asset_validation(true, false, candidate.family, "sha256")
    val instance = validate_glyf_font_instance(blob, candidate.default_axes)
    if not instance.supported:
        val reason = if instance.reason == "unsupported-variation-instance": "default-axes" else: "format"
        return _font_asset_validation(true, false, candidate.family, reason)
    if not sfnt_manifest_tables_match(blob, candidate.sfnt_tables):
        return _font_asset_validation(true, false, candidate.family, "tables")
    if not sfnt_manifest_names_match(blob, candidate.family, candidate.embedded_style,
                                     candidate.embedded_full_name, candidate.embedded_postscript_name,
                                     candidate.embedded_version):
        return _font_asset_validation(true, false, candidate.family, "names")
    _font_asset_validation(true, true, candidate.family, "valid")

class FontCoverageCell:
    language: text
    category: text
    status: text
    witness_family: text

fn selected_font_coverage_languages() -> [text]:
    ["en", "zh", "es", "hi", "ar", "fr", "pt", "ru", "ur", "id"]

fn selected_font_coverage_categories() -> [text]:
    ["sans", "serif", "mono", "display", "rounded", "handwriting", "slab", "blackletter", "pixel", "emoji"]

fn _font_language_is_latin(language: text) -> bool:
    language == "en" or language == "es" or language == "fr" or language == "pt" or language == "id"

fn _font_language_is_latin_or_cyrillic(language: text) -> bool:
    _font_language_is_latin(language) or language == "ru"

fn _font_script_face(language: text, category: text) -> text:
    if category == "sans":
        if language == "hi": return "Noto Sans Devanagari"
        if language == "ar" or language == "ur": return "Noto Sans Arabic"
        return "Noto Sans SC"
    if language == "hi": return "Noto Serif Devanagari"
    if language == "ar" or language == "ur": return "Noto Naskh Arabic"
    "Noto Serif SC"

fn selected_font_simple_tuple_accepted(family: text, language: text) -> bool:
    if family == "Noto Sans SC" or family == "Noto Serif SC":
        return language == "en" or language == "zh" or language == "es" or language == "fr" or language == "pt" or language == "ru" or language == "id"
    if family == "Bungee" or family == "UnifrakturCook":
        return _font_language_is_latin(language)
    if (family == "Noto Sans Mono" or family == "Nunito" or family == "Caveat" or
        family == "Roboto Slab" or family == "Pixelify Sans"):
        return _font_language_is_latin_or_cyrillic(language)
    false

fn _font_direct_category_face(language: text, category: text) -> text:
    if category == "sans" or category == "serif": return _font_script_face(language, category)
    if category == "mono": return "Noto Sans Mono"
    if category == "display": return "Bungee"
    if category == "rounded": return "Nunito"
    if category == "handwriting": return "Caveat"
    if category == "slab": return "Roboto Slab"
    if category == "blackletter": return "UnifrakturCook"
    if category == "pixel": return "Pixelify Sans"
    "Noto Emoji"

class FontCoverageResolution:
    status: text
    witness_family: text

fn _font_coverage_resolution(language: text, category: text) -> FontCoverageResolution:
    if category == "display" or category == "blackletter":
        if not _font_language_is_latin(language):
            return FontCoverageResolution(status: "not-designed-for-script", witness_family: "")
    if (category == "rounded" or category == "handwriting" or category == "slab" or category == "pixel"):
        if not _font_language_is_latin_or_cyrillic(language):
            return FontCoverageResolution(status: "not-designed-for-script", witness_family: "")
    val direct = _font_direct_category_face(language, category)
    if selected_font_simple_tuple_accepted(direct, language):
        return FontCoverageResolution(status: "native", witness_family: direct)
    if language == "zh" and category == "mono":
        val fallback = _font_script_face(language, "sans")
        if selected_font_simple_tuple_accepted(fallback, language):
            return FontCoverageResolution(status: "fallback", witness_family: fallback)
    FontCoverageResolution(status: "unavailable", witness_family: "")

fn selected_font_coverage_matrix() -> [FontCoverageCell]:
    """Return the complete language-major 10x10 sparse coverage matrix."""
    val languages = selected_font_coverage_languages()
    val categories = selected_font_coverage_categories()
    var cells: [FontCoverageCell] = []
    var language_index: i64 = 0
    while language_index < languages.len():
        var category_index: i64 = 0
        while category_index < categories.len():
            val language = languages[language_index]
            val category = categories[category_index]
            val resolution = _font_coverage_resolution(language, category)
            cells.push(FontCoverageCell(
                language: language, category: category, status: resolution.status,
                witness_family: resolution.witness_family
            ))
            category_index = category_index + 1
        language_index = language_index + 1
    cells

fn selected_font_coverage_cell(language: text, category: text) -> FontCoverageCell?:
    """Resolve exact accepted-simple policy for one known matrix axis pair."""
    for cell in selected_font_coverage_matrix():
        if cell.language == language and cell.category == category:
            return cell
    nil

export selected_font_simple_tuple_accepted
