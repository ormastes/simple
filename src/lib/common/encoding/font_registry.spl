        _google_font_candidate("Caveat", "handwriting", "ofl/caveat/Caveat[wght].ttf", "ofl/caveat/OFL.txt", "OFL-1.1", "Copyright 2014 The Caveat Project Authors (https://github.com/googlefonts/caveat)", "none declared", 403648, "0bdb6b660482d31531b3945849fba5916b3ef8695da7024a9e6b9ee3c4157988", "DSIG,GDEF,GPOS,GSUB,HVAR,OS/2,STAT,cmap,fvar,gasp,glyf,gvar,head,hhea,hmtx,loca,maxp,name,post,prep", "cyrillic,cyrillic-ext,latin,latin-ext"),
        _google_font_candidate("Roboto Slab", "slab", "apache/robotoslab/RobotoSlab[wght].ttf", "apache/robotoslab/LICENSE.txt", "Apache-2.0", "Copyright 2018 The Roboto Slab Project Authors (https://github.com/googlefonts/robotoslab)", "not applicable", 251880, "786ae192477447d33c6672c3055fba7cbfe45184c9a79e77a14f15716ca05b16", "GDEF,GPOS,GSUB,HVAR,OS/2,STAT,avar,cmap,fvar,gasp,glyf,gvar,head,hhea,hmtx,loca,maxp,name,post,prep", "cyrillic,cyrillic-ext,greek,greek-ext,latin,latin-ext,vietnamese"),
        _google_font_candidate("UnifrakturCook", "blackletter", "ofl/unifrakturcook/UnifrakturCook-Bold.ttf", "ofl/unifrakturcook/OFL.txt", "OFL-1.1", "Copyright (c) 2010, j. 'mach' wust, with Reserved Font Name UnifrakturCook. Copyright (c) 2009, Peter Wiegel.", "reserved: UnifrakturCook", 42688, "ea002fa9c65f1a612af100e00d87ab65f16381f450020ec3d021f3dbf79a6dcd", "DSIG,FFTM,GDEF,GPOS,GSUB,OS/2,cmap,cvt ,fpgm,gasp,glyf,head,hhea,hmtx,loca,maxp,name,post,prep", "latin"),
        _google_font_candidate("Pixelify Sans", "pixel", "ofl/pixelifysans/PixelifySans[wght].ttf", "ofl/pixelifysans/OFL.txt", "OFL-1.1", "Copyright 2021 The Pixelify Sans Project Authors (https://github.com/eifetx/Pixelify-Sans)", "none declared", 79160, "9ba86cd010a4de309d263ceff8e8044092c9db7efda869620cb9ff1c4389e8a5", "GDEF,GPOS,GSUB,HVAR,MVAR,OS/2,STAT,cmap,fvar,gasp,glyf,gvar,head,hhea,hmtx,loca,maxp,name,post,prep", "cyrillic,latin,latin-ext"),
        _google_font_candidate("Noto Emoji", "emoji", "ofl/notoemoji/NotoEmoji[wght].ttf", "ofl/notoemoji/OFL.txt", "OFL-1.1", "Copyright 2013 Google LLC", "none declared", 1982596, "de6c18832938afc99caf132b39d6a30a19bac7f2e812e28db2535b4608d27551", "GSUB,HVAR,OS/2,STAT,VVAR,cmap,fvar,gasp,glyf,gvar,head,hhea,hmtx,loca,maxp,name,post,vhea,vmtx", "emoji")
    ]

fn selected_font_bundle_asset_pins() -> [FontBundleAssetPin]:
    """Return the closed 57-file immutable font distribution."""
    var pins: [FontBundleAssetPin] = []
    val google_root = "assets/fonts/google-fonts/"
    for candidate in selected_font_asset_candidates():
        pins.push(FontBundleAssetPin(path: candidate.local_path, sha256: candidate.sha256))
        pins.push(FontBundleAssetPin(path: google_root + candidate.metadata_path, sha256: candidate.metadata_sha256))
        pins.push(FontBundleAssetPin(path: google_root + candidate.license_path, sha256: candidate.license_sha256))
        if candidate.notice_path != "":
            pins.push(FontBundleAssetPin(path: google_root + candidate.notice_path, sha256: candidate.notice_sha256))
    pins.push(_font_bundle_corpus_pin())

    val cldr_root = "assets/fonts/cldr/release-48-2/"
    val source = selected_font_language_ranking_source()
    pins.push(FontBundleAssetPin(path: cldr_root + "common/supplemental/supplementalData.xml", sha256: source.supplemental_data_sha256))
    pins.push(FontBundleAssetPin(path: cldr_root + "common/supplemental/supplementalMetadata.xml", sha256: source.supplemental_metadata_sha256))
    pins.push(FontBundleAssetPin(path: cldr_root + "common/supplemental/likelySubtags.xml", sha256: source.likely_subtags_sha256))
    pins.push(FontBundleAssetPin(path: cldr_root + "LICENSE", sha256: "b49d0e9f8ead51ca8b7df6fec89cc3ae6809198b4b9d43c74216da0118f23f5b"))
    pins.push(FontBundleAssetPin(path: cldr_root + "TAG.txt", sha256: "b95ecf54f9dc853dbf6d2f5bb2fd3c418d3ecc72922b06f8481e8004210e2e05"))
    pins.push(FontBundleAssetPin(path: cldr_root + "SOURCE.sdn", sha256: "f64ee0280b246a5f0f47b39cca6bddcdfe2e0d3e93488e5558b76ca7d626f4b4"))
    pins.push(FontBundleAssetPin(path: cldr_root + "RANKING.sdn", sha256: "e4279236032d02966eaaeb502af7b19edc8d371e454a3fc6beb676ef4e7c70df"))
    pins

class FontAssetRuntimeValidation:
    selected: bool
    valid: bool
    family: text
    reason: text

fn _font_asset_normalized_root(root: text) -> text:
    var normalized = root.trim().replace("\\", "/")
    while normalized.len() > 1 and normalized.ends_with("/"):
        normalized = normalized.slice(0, normalized.len() - 1)
    normalized

fn _font_asset_path_beneath_root(root: text, path: text) -> text:
    if root == "/": return root + path
    root + "/" + path

fn _selected_font_asset_candidate_index_for_path_with_root(path: text, root: text) -> i64:
    val base = _font_asset_normalized_root(root)
    val normalized_path = path.replace("\\", "/")
    val candidates = selected_font_asset_candidates()
    var index: i64 = 0
    while index < candidates.len():
        val candidate = candidates[index]
        if candidate.local_path == normalized_path:
            return index
        if base != "" and normalized_path == _font_asset_path_beneath_root(base, candidate.local_path):
            return index
        index = index + 1
    -1

fn _selected_font_asset_candidate_for_path_with_root(path: text, root: text) -> FontAssetCandidate?:
    val candidates = selected_font_asset_candidates()
    val index = _selected_font_asset_candidate_index_for_path_with_root(path, root)
    if index < 0:
        return nil
    candidates[index]

fn selected_font_asset_candidate_for_path(path: text) -> FontAssetCandidate?:
    _selected_font_asset_candidate_for_path_with_root(path, env_get("SIMPLE_ASSET_ROOT"))

fn _selected_font_asset_physical_path_from_root(path: text, root: text) -> text:
    val candidate = _selected_font_asset_candidate_for_path_with_root(path, root)
    val base = _font_asset_normalized_root(root)
    if candidate == nil or base == "": return path
    _font_asset_path_beneath_root(base, candidate.?.local_path)

fn selected_font_asset_physical_path(path: text) -> text:
    """Resolve a selected asset beneath the installed Simple share root."""
    _selected_font_asset_physical_path_from_root(path, env_get("SIMPLE_ASSET_ROOT"))

fn simpleos_default_font_asset_candidate() -> FontAssetCandidate:
    """Pinned monospace face staged into SimpleOS images."""
    selected_font_asset_candidate_for_path(
        "assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf"
    ) ?? selected_font_asset_candidates()[8]

fn simpleos_font_asset_guest_path(candidate: FontAssetCandidate) -> text:
    """Return the readable VFAT long-name byte-source path for a selected face."""
    val parts = candidate.local_path.split("/")
    if parts.len() == 0:
        return ""
    "/SYS/FONTS/" + parts[parts.len() - 1]

fn simpleos_font_asset_short_name(candidate: FontAssetCandidate) -> text:
    """Return the unique 8.3 base alias retained for compatibility readers."""
    val names = [
        "NSANSSC", "NSANSDEV", "NSANSARB", "NSANSBEN",
        "NSERIFSC", "NSERFDEV", "NNASKHAR", "NSERFBEN",
        "NOTOSANS", "BUNGEE", "NUNITO", "CAVEAT",
        "ROBOSLAB", "UNIFRAKT", "PIXELIFY", "NOTOEMOJ",
    ]
    val candidates = selected_font_asset_candidates()
    var index: i64 = 0
    while index < candidates.len() and index < names.len():
        if candidates[index].local_path == candidate.local_path:
            return names[index]
        index = index + 1
    ""

fn simpleos_font_asset_short_guest_path(candidate: FontAssetCandidate) -> text:
    val name = simpleos_font_asset_short_name(candidate)
    if name == "": return ""
    "/SYS/FONTS/" + name

fn selected_font_asset_identity(candidate: FontAssetCandidate) -> text:
    "sha256={candidate.sha256};axes={candidate.default_axes}"

fn selected_font_asset_candidate_for_identity(identity: text) -> FontAssetCandidate?:
    for candidate in selected_font_asset_candidates():
        if selected_font_asset_identity(candidate) == identity: return candidate
    nil

fn _font_sha256_hex_valid(value: text) -> bool:
    if value.len() != 64: return false
    var index: i64 = 0
    while index < value.len():
        if not "0123456789abcdef".contains(value[index]): return false
        index = index + 1
    true

fn _font_asset_validation(selected: bool, valid: bool, family: text, reason: text) -> FontAssetRuntimeValidation:
    FontAssetRuntimeValidation(selected: selected, valid: valid, family: family, reason: reason)

fn _validate_selected_font_asset(path: text, blob: [u8]) -> FontAssetRuntimeValidation:
    val root = env_get("SIMPLE_ASSET_ROOT")
    val candidates = selected_font_asset_candidates()
    val candidate_index = _selected_font_asset_candidate_index_for_path_with_root(path, root)
    if candidate_index < 0:
        return _font_asset_validation(false, true, "", "unmanaged")
    val candidate = candidates[candidate_index]
    if blob.len() != candidate.byte_len:
        return _font_asset_validation(true, false, candidate.family, "byte-length")
    val actual_sha256 = sha256_u8_hex(blob)
    if not _font_sha256_hex_valid(candidate.sha256) or actual_sha256 != candidate.sha256:
        return _font_asset_validation(true, false, candidate.family, "sha256")
    val instance = validate_glyf_font_instance(blob, candidate.default_axes)
    if not instance.supported:
        val reason = if instance.reason == "unsupported-variation-instance": "default-axes" else: "format"
        return _font_asset_validation(true, false, candidate.family, reason)
    if not sfnt_manifest_tables_match(blob, candidate.sfnt_tables):
        return _font_asset_validation(true, false, candidate.family, "tables")
    if not sfnt_manifest_names_match(blob, candidate.family, candidate.embedded_style,
                                     candidate.embedded_full_name, candidate.embedded_postscript_name,
                                     candidate.embedded_version):
        return _font_asset_validation(true, false, candidate.family, "names")
    _font_asset_validation(true, true, candidate.family, "valid")

fn validate_selected_font_asset(path: text, blob: [u8]) -> FontAssetRuntimeValidation:
    """Validate the exact supplied bytes for a selected asset identity."""
    _validate_selected_font_asset(path, blob)

fn load_selected_font_file(path: text) -> ([u8], FontAssetRuntimeValidation):
    """Read and validate the exact bytes returned to the caller.

    Existence-gate the raw read: on freestanding/baremetal targets
    rt_file_read_bytes is a hosted-only trap stub that HALTS the kernel,
    while rt_file_exists is either VFS-backed (kernel export) or a plain
    hosted check. A missing font must fail SOFT into the bitmap fallback,
    not take down the first desktop compose (proven live 2026-07-16:
    first-frame render halted in [TRAP] rt_file_read_bytes)."""
    val physical_path = selected_font_asset_physical_path(path)
    val exists = rt_file_exists(physical_path)
    if not exists:
        val missing_validation = _validate_selected_font_asset(path, [])
        return ([], missing_validation)
    val blob = rt_file_read_bytes(physical_path)
    val validation = _validate_selected_font_asset(path, blob)
    (blob, validation)

class FontCoverageCell:
    language: text
    category: text
    status: text
    witness_family: text

fn selected_font_coverage_languages() -> [text]:
    ["en", "zh", "es", "hi", "ar", "fr", "pt", "ru", "ur", "id"]

fn selected_font_coverage_categories() -> [text]:
    ["sans", "serif", "mono", "display", "rounded", "handwriting", "slab", "blackletter", "pixel", "emoji"]

fn _font_language_is_latin(language: text) -> bool:
    language == "en" or language == "es" or language == "fr" or language == "pt" or language == "id"

fn _font_language_is_latin_or_cyrillic(language: text) -> bool:
    _font_language_is_latin(language) or language == "ru"

fn _font_script_face(language: text, category: text) -> text:
    if category == "sans":
        if language == "hi": return "Noto Sans Devanagari"
        if language == "ar" or language == "ur": return "Noto Sans Arabic"
        return "Noto Sans SC"
    if language == "hi": return "Noto Serif Devanagari"
    if language == "ar" or language == "ur": return "Noto Naskh Arabic"
    "Noto Serif SC"

fn selected_font_simple_tuple_accepted(family: text, language: text) -> bool:
    if family == "Noto Emoji": return selected_font_coverage_languages().contains(language)
    if family == "Noto Sans SC" or family == "Noto Serif SC":
        return language == "en" or language == "zh" or language == "es" or language == "fr" or language == "pt" or language == "ru" or language == "id"
    if family == "Bungee" or family == "UnifrakturCook":
        return _font_language_is_latin(language)
    if family == "Noto Sans Devanagari": return language == "hi"
    if family == "Noto Sans Arabic": return language == "ar" or language == "ur"
    if (family == "Noto Sans Mono" or family == "Nunito" or family == "Caveat" or
        family == "Roboto Slab" or family == "Pixelify Sans"):
        return _font_language_is_latin_or_cyrillic(language)
    false

fn _font_direct_category_face(language: text, category: text) -> text:
    if category == "sans" or category == "serif": return _font_script_face(language, category)
    if category == "mono": return "Noto Sans Mono"
    if category == "display": return "Bungee"
    if category == "rounded": return "Nunito"
    if category == "handwriting": return "Caveat"
    if category == "slab": return "Roboto Slab"
    if category == "blackletter": return "UnifrakturCook"
    if category == "pixel": return "Pixelify Sans"
    "Noto Emoji"

class FontCoverageResolution:
    status: text
    witness_family: text

fn _font_coverage_resolution(language: text, category: text) -> FontCoverageResolution:
    if category == "display" or category == "blackletter":
        if not _font_language_is_latin(language):
            return FontCoverageResolution(status: "not-designed-for-script", witness_family: "")
    if (category == "rounded" or category == "handwriting" or category == "slab" or category == "pixel"):
        if not _font_language_is_latin_or_cyrillic(language):
            return FontCoverageResolution(status: "not-designed-for-script", witness_family: "")
    val direct = _font_direct_category_face(language, category)
    if selected_font_simple_tuple_accepted(direct, language):
        return FontCoverageResolution(status: "native", witness_family: direct)
    if category == "mono" and (language == "zh" or language == "hi" or language == "ar" or language == "ur"):
        val fallback = _font_script_face(language, "sans")
        if selected_font_simple_tuple_accepted(fallback, language):
            return FontCoverageResolution(status: "fallback", witness_family: fallback)
    FontCoverageResolution(status: "unavailable", witness_family: "")

fn selected_font_coverage_matrix() -> [FontCoverageCell]:
    """Return the complete language-major 10x10 sparse coverage matrix."""
    val languages = selected_font_coverage_languages()
    val categories = selected_font_coverage_categories()
    var cells: [FontCoverageCell] = []
    var language_index: i64 = 0
    while language_index < languages.len():
        var category_index: i64 = 0
        while category_index < categories.len():
            val language = languages[language_index]
            val category = categories[category_index]
            val resolution = _font_coverage_resolution(language, category)
            cells.push(FontCoverageCell(
                language: language, category: category, status: resolution.status,
                witness_family: resolution.witness_family
            ))
            category_index = category_index + 1
        language_index = language_index + 1
    cells

fn selected_font_coverage_cell(language: text, category: text) -> FontCoverageCell?:
    """Resolve exact accepted-simple policy for one known matrix axis pair."""
    for cell in selected_font_coverage_matrix():
        if cell.language == language and cell.category == category:
            return cell
    nil

fn selected_font_asset_for_language_category(language: text, category: text) -> FontAssetCandidate?:
    """Resolve one accepted bundled face through the canonical sparse policy."""
    val cell = selected_font_coverage_cell(language, category)
    if cell == nil:
        return nil
    val resolved = cell.?
    if ((resolved.status != "native" and resolved.status != "fallback") or
        resolved.witness_family == ""):
        return nil
    for candidate in selected_font_asset_candidates():
        if (candidate.family == resolved.witness_family and
            candidate.coverage_state.starts_with("accepted-simple:")):
            return candidate
    nil

export selected_font_simple_tuple_accepted, selected_font_asset_for_language_category
