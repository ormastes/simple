# Font Registry — Unicode Font System for Simple
#
# Organizes open-source fonts by script group and font type (Sans/Serif/Mono).
# Provides a font fallback chain for multi-script text rendering.
#
# Supports 10 languages across 6 script groups:
#   1. Latin+Cyrillic  (English, Spanish, French, Portuguese, Russian)
#   2. CJK-SC          (Chinese Simplified)
#   3. Hangul           (Korean)
#   4. Devanagari       (Hindi)
#   5. Arabic           (Arabic)
#   6. Bengali          (Bengali)
#
# Default internal encoding: UTF-8.
# Font selection uses script detection to choose appropriate font.
#
# Usage:
#     use std.common.encoding.font_registry.{
#         FontType, ScriptGroup, FontEntry,
#         get_font_for_script, font_fallback_chain
#     }

use std.common.encoding.text_ops.{UnicodeScript}

# ============================================================================
# Font type classification
# ============================================================================

enum FontType:
    Sans        # Clean, modern — default for UI
    Serif       # Traditional — reading, documents
    Mono        # Fixed-width — code, terminal
    Display     # Decorative — headings, branding

# ============================================================================
# Script group — groups scripts served by the same font file
# ============================================================================

enum ScriptGroup:
    LatinCyrillic    # Noto Sans covers both
    CjkSC            # Chinese Simplified
    CjkTC            # Chinese Traditional
    Hangul           # Korean
    Devanagari       # Hindi
    Arabic           # Arabic
    Bengali          # Bengali

# ============================================================================
# Font entry — metadata for one font file
# ============================================================================

class FontEntry:
    name: text           # Human-readable name (e.g., "Noto Sans")
    family: text         # Family identifier (e.g., "noto-sans")
    script_group: ScriptGroup
    font_type: FontType
    filename: text       # Expected filename (e.g., "NotoSans-Regular.ttf")
    license: text        # License type (e.g., "OFL-1.1")
    approx_size_kb: i64  # Approximate file size in KB
    url: text            # Download URL (Google Fonts CDN)
    supports_stb: bool   # true if stb_truetype can render (no complex shaping)

# ============================================================================
# Font catalog — all recommended fonts organized by script + type
# ============================================================================

fn font_catalog() -> [FontEntry]:
    """Return the complete font catalog for 10 target languages."""
    var catalog: [FontEntry] = []

    # ---- Latin + Cyrillic (English, Spanish, French, Portuguese, Russian) ----

    catalog.push(FontEntry(
        name: "Noto Sans",
        family: "noto-sans",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Sans,
        filename: "NotoSans-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 500,
        url: "https://github.com/notofonts/latin-greek-cyrillic/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif",
        family: "noto-serif",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Serif,
        filename: "NotoSerif-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 450,
        url: "https://github.com/notofonts/latin-greek-cyrillic/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "JetBrains Mono",
        family: "jetbrains-mono",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Mono,
        filename: "JetBrainsMono-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 150,
        url: "https://github.com/JetBrains/JetBrainsMono/releases",
        supports_stb: true
    ))

    # ---- CJK Simplified Chinese ----

    catalog.push(FontEntry(
        name: "Noto Sans SC",
        family: "noto-sans-sc",
        script_group: ScriptGroup.CjkSC,
        font_type: FontType.Sans,
        filename: "NotoSansSC-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 16000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif SC",
        family: "noto-serif-sc",
        script_group: ScriptGroup.CjkSC,
        font_type: FontType.Serif,
        filename: "NotoSerifSC-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 18000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    # ---- Korean (Hangul) ----

    catalog.push(FontEntry(
        name: "Noto Sans KR",
        family: "noto-sans-kr",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Sans,
        filename: "NotoSansKR-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 5000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif KR",
        family: "noto-serif-kr",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Serif,
        filename: "NotoSerifKR-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 5500,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "D2Coding",
        family: "d2coding",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Mono,
        filename: "D2Coding-Ver1.3.2-20180524.ttf",
        license: "OFL-1.1",
        approx_size_kb: 3000,
        url: "https://github.com/naver/d2codingfont/releases",
        supports_stb: true
    ))

    # ---- Hindi (Devanagari) ----

    catalog.push(FontEntry(
        name: "Noto Sans Devanagari",
        family: "noto-sans-devanagari",
        script_group: ScriptGroup.Devanagari,
        font_type: FontType.Sans,
        filename: "NotoSansDevanagari-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/devanagari/releases",
        supports_stb: false  # Requires HarfBuzz for complex shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Serif Devanagari",
        family: "noto-serif-devanagari",
        script_group: ScriptGroup.Devanagari,
        font_type: FontType.Serif,
        filename: "NotoSerifDevanagari-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 250,
        url: "https://github.com/notofonts/devanagari/releases",
        supports_stb: false
    ))

    # ---- Arabic ----

    catalog.push(FontEntry(
        name: "Noto Sans Arabic",
        family: "noto-sans-arabic",
        script_group: ScriptGroup.Arabic,
        font_type: FontType.Sans,
        filename: "NotoSansArabic-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 300,
        url: "https://github.com/notofonts/arabic/releases",
        supports_stb: false  # Requires HarfBuzz + BiDi for RTL + contextual shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Naskh Arabic",
        family: "noto-naskh-arabic",
        script_group: ScriptGroup.Arabic,
        font_type: FontType.Serif,
        filename: "NotoNaskhArabic-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/arabic/releases",
        supports_stb: false
    ))

    # ---- Bengali ----

    catalog.push(FontEntry(
        name: "Noto Sans Bengali",
        family: "noto-sans-bengali",
        script_group: ScriptGroup.Bengali,
        font_type: FontType.Sans,
        filename: "NotoSansBengali-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/bengali/releases",
        supports_stb: false  # Requires HarfBuzz for conjunct shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Serif Bengali",
        family: "noto-serif-bengali",
        script_group: ScriptGroup.Bengali,
        font_type: FontType.Serif,
        filename: "NotoSerifBengali-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 250,
        url: "https://github.com/notofonts/bengali/releases",
        supports_stb: false
    ))

    catalog

# ============================================================================
# Font selection — choose best font for a script + type combination
# ============================================================================

fn script_group_from_unicode_script(script: UnicodeScript) -> ScriptGroup:
    """Map UnicodeScript to ScriptGroup for font lookup."""
    match script:
        UnicodeScript.Latin: ScriptGroup.LatinCyrillic
        UnicodeScript.Cyrillic: ScriptGroup.LatinCyrillic
        UnicodeScript.CJK: ScriptGroup.CjkSC
        UnicodeScript.Hangul: ScriptGroup.Hangul
        UnicodeScript.Devanagari: ScriptGroup.Devanagari
        UnicodeScript.Arabic: ScriptGroup.Arabic
        UnicodeScript.Bengali: ScriptGroup.Bengali
        UnicodeScript.Common: ScriptGroup.LatinCyrillic
        UnicodeScript.Unknown: ScriptGroup.LatinCyrillic

fn get_font_for_script(script: ScriptGroup, font_type: FontType) -> FontEntry:
    """Find the best font for a script group and type.
    Returns the first matching entry from the catalog.
    Falls back to Sans if requested type not available."""
    val catalog = font_catalog()
    # Try exact match first
    var i: i64 = 0
    while i < catalog.len():
        val entry = catalog[i]
        if entry.script_group == script and entry.font_type == font_type:
            return entry
        i = i + 1
    # Fallback to Sans
    i = 0
    while i < catalog.len():
        val entry = catalog[i]
        if entry.script_group == script and entry.font_type == FontType.Sans:
            return entry
        i = i + 1
    # Last resort: return Latin Sans
    catalog[0]

# ============================================================================
# Font fallback chain — ordered list of fonts to try for a given type
# ============================================================================

fn font_fallback_chain(font_type: FontType) -> [FontEntry]:
    """Return an ordered fallback chain for a font type.
    Order: Latin/Cyrillic -> CJK -> Hangul -> Devanagari -> Arabic -> Bengali.
    This ensures common scripts are tried first."""
    var chain: [FontEntry] = []
    val groups = [
        ScriptGroup.LatinCyrillic,
        ScriptGroup.CjkSC,
        ScriptGroup.Hangul,
        ScriptGroup.Devanagari,
        ScriptGroup.Arabic,
        ScriptGroup.Bengali
    ]
    var i: i64 = 0
    while i < groups.len():
        chain.push(get_font_for_script(groups[i], font_type))
        i = i + 1
    chain

# ============================================================================
# Summary table — for documentation and display
# ============================================================================

fn font_summary() -> text:
    """Return a formatted summary of font assignments per language."""
    var lines: [text] = []
    lines.push("Font Registry — 10 Languages, 6 Script Groups")
    lines.push("=" * 60)
    lines.push("")
    lines.push("Script Group       | Sans                  | Serif                 | Mono")
    lines.push("-------------------|-----------------------|-----------------------|------------------")
    lines.push("Latin+Cyrillic     | Noto Sans             | Noto Serif            | JetBrains Mono")
    lines.push("  English, Spanish, French, Portuguese, Russian")
    lines.push("CJK (Chinese SC)   | Noto Sans SC          | Noto Serif SC         | (use Sans)")
    lines.push("Hangul (Korean)    | Noto Sans KR          | Noto Serif KR         | D2Coding")
    lines.push("Devanagari (Hindi) | Noto Sans Devanagari* | Noto Serif Devanagari*| (use Sans)")
    lines.push("Arabic             | Noto Sans Arabic*     | Noto Naskh Arabic*    | (use Sans)")
    lines.push("Bengali            | Noto Sans Bengali*    | Noto Serif Bengali*   | (use Sans)")
    lines.push("")
    lines.push("* = Requires HarfBuzz for complex text shaping (Tier 2)")
    lines.push("")
    lines.push("stb_truetype-compatible (Tier 1): Latin, Cyrillic, CJK, Korean")
    lines.push("Needs complex shaping (Tier 2):   Hindi, Arabic, Bengali")
    lines.push("")
    lines.push("All fonts: OFL-1.1 (SIL Open Font License)")
    lines.push("Total size (Sans only, 1 weight): ~22 MB full / ~5.7 MB subsetted")
    lines.join("\n")
