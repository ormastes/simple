# Font Registry — Unicode Font System for Simple
#
# Organizes open-source fonts by script group and font type (Sans/Serif/Mono).
# Provides a font fallback chain for multi-script text rendering.
#
# Selected top-ten languages use 5 script groups:
#   1. Latin+Cyrillic  (English, Spanish, French, Portuguese, Russian, Indonesian)
#   2. CJK-SC          (Chinese Simplified)
#   3. Devanagari       (Hindi)
#   4. Arabic           (Arabic)
# Urdu shares the selected Arabic script group. Bengali and legacy Hangul
# catalog entries remain available but are not in this CLDR-derived top ten.
#
# Default internal encoding: UTF-8.
# Font selection uses script detection to choose appropriate font.
#
# Usage:
#     use std.common.encoding.font_registry.{
#         FontType, ScriptGroup, FontEntry,
#         get_font_for_script, font_fallback_chain
#     }

use std.common.encoding.sfnt.{validate_glyf_font_instance, sfnt_manifest_tables_match, sfnt_manifest_names_match}
use std.common.crypto.sha256.{sha256_u8_hex}

# ============================================================================
# Font type classification
# ============================================================================

enum UnicodeScript:
    Latin
    Cyrillic
    CJK
    Hangul
    Devanagari
    Arabic
    Bengali
    Common
    Unknown

enum FontType:
    Sans        # Clean, modern — default for UI
    Serif       # Traditional — reading, documents
    Mono        # Fixed-width — code, terminal
    Display     # Decorative — headings, branding

# ============================================================================
# Script group — groups scripts served by the same font file
# ============================================================================

enum ScriptGroup:
    LatinCyrillic    # Noto Sans covers both
    CjkSC            # Chinese Simplified
    CjkTC            # Chinese Traditional
    Hangul           # Korean
    Devanagari       # Hindi
    Arabic           # Arabic
    Bengali          # Bengali

# ============================================================================
# Font entry — metadata for one font file
# ============================================================================

class FontEntry:
    name: text           # Human-readable name (e.g., "Noto Sans")
    family: text         # Family identifier (e.g., "noto-sans")
    script_group: ScriptGroup
    font_type: FontType
    filename: text       # Expected filename (e.g., "NotoSans-Regular.ttf")
    license: text        # License type (e.g., "OFL-1.1")
    approx_size_kb: i64  # Approximate file size in KB
    url: text            # Download URL (Google Fonts CDN)
    supports_stb: bool   # true if stb_truetype can render (no complex shaping)

# ============================================================================
# Font catalog — all recommended fonts organized by script + type
# ============================================================================

fn font_catalog() -> [FontEntry]:
    """Return the complete font catalog for 10 target languages."""
    var catalog: [FontEntry] = []

    # ---- Latin + Cyrillic (English, Spanish, French, Portuguese, Russian) ----

    catalog.push(FontEntry(
        name: "Noto Sans",
        family: "noto-sans",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Sans,
        filename: "NotoSans-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 500,
        url: "https://github.com/notofonts/latin-greek-cyrillic/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif",
        family: "noto-serif",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Serif,
        filename: "NotoSerif-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 450,
        url: "https://github.com/notofonts/latin-greek-cyrillic/releases",
        supports_stb: true
    ))

    # Default mono: the unchanged pinned Noto Sans Mono candidate.
    catalog.push(FontEntry(
        name: "Noto Sans Mono",
        family: "noto-sans-mono",
        script_group: ScriptGroup.LatinCyrillic,
        font_type: FontType.Mono,
        filename: "NotoSansMono[wdth,wght].ttf",
        license: "OFL-1.1",
        approx_size_kb: 1669,
        url: "https://github.com/google/fonts/blob/ec0464b978de222073645d6d3366f3fdf03376d8/ofl/notosansmono/NotoSansMono%5Bwdth%2Cwght%5D.ttf",
        supports_stb: true
    ))

    # ---- CJK Simplified Chinese ----

    catalog.push(FontEntry(
        name: "Noto Sans SC",
        family: "noto-sans-sc",
        script_group: ScriptGroup.CjkSC,
        font_type: FontType.Sans,
        filename: "NotoSansSC-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 16000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif SC",
        family: "noto-serif-sc",
        script_group: ScriptGroup.CjkSC,
        font_type: FontType.Serif,
        filename: "NotoSerifSC-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 18000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    # ---- Korean (Hangul) ----

    catalog.push(FontEntry(
        name: "Noto Sans KR",
        family: "noto-sans-kr",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Sans,
        filename: "NotoSansKR-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 5000,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "Noto Serif KR",
        family: "noto-serif-kr",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Serif,
        filename: "NotoSerifKR-Regular.otf",
        license: "OFL-1.1",
        approx_size_kb: 5500,
        url: "https://github.com/notofonts/cjk/releases",
        supports_stb: true
    ))

    catalog.push(FontEntry(
        name: "D2Coding",
        family: "d2coding",
        script_group: ScriptGroup.Hangul,
        font_type: FontType.Mono,
        filename: "D2Coding-Ver1.3.2-20180524.ttf",
        license: "OFL-1.1",
        approx_size_kb: 3000,
        url: "https://github.com/naver/d2codingfont/releases",
        supports_stb: true
    ))

    # ---- Hindi (Devanagari) ----

    catalog.push(FontEntry(
        name: "Noto Sans Devanagari",
        family: "noto-sans-devanagari",
        script_group: ScriptGroup.Devanagari,
        font_type: FontType.Sans,
        filename: "NotoSansDevanagari-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/devanagari/releases",
        supports_stb: false  # Requires HarfBuzz for complex shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Serif Devanagari",
        family: "noto-serif-devanagari",
        script_group: ScriptGroup.Devanagari,
        font_type: FontType.Serif,
        filename: "NotoSerifDevanagari-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 250,
        url: "https://github.com/notofonts/devanagari/releases",
        supports_stb: false
    ))

    # ---- Arabic ----

    catalog.push(FontEntry(
        name: "Noto Sans Arabic",
        family: "noto-sans-arabic",
        script_group: ScriptGroup.Arabic,
        font_type: FontType.Sans,
        filename: "NotoSansArabic-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 300,
        url: "https://github.com/notofonts/arabic/releases",
        supports_stb: false  # Requires HarfBuzz + BiDi for RTL + contextual shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Naskh Arabic",
        family: "noto-naskh-arabic",
        script_group: ScriptGroup.Arabic,
        font_type: FontType.Serif,
        filename: "NotoNaskhArabic-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/arabic/releases",
        supports_stb: false
    ))

    # ---- Bengali ----

    catalog.push(FontEntry(
        name: "Noto Sans Bengali",
        family: "noto-sans-bengali",
        script_group: ScriptGroup.Bengali,
        font_type: FontType.Sans,
        filename: "NotoSansBengali-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 200,
        url: "https://github.com/notofonts/bengali/releases",
        supports_stb: false  # Requires HarfBuzz for conjunct shaping
    ))

    catalog.push(FontEntry(
        name: "Noto Serif Bengali",
        family: "noto-serif-bengali",
        script_group: ScriptGroup.Bengali,
        font_type: FontType.Serif,
        filename: "NotoSerifBengali-Regular.ttf",
        license: "OFL-1.1",
        approx_size_kb: 250,
        url: "https://github.com/notofonts/bengali/releases",
        supports_stb: false
    ))

    catalog

# ============================================================================
# Font selection — choose best font for a script + type combination
# ============================================================================

fn script_group_from_unicode_script(script: UnicodeScript) -> ScriptGroup:
    """Map UnicodeScript to ScriptGroup for font lookup."""
    match script:
        UnicodeScript.Latin: ScriptGroup.LatinCyrillic
        UnicodeScript.Cyrillic: ScriptGroup.LatinCyrillic
        UnicodeScript.CJK: ScriptGroup.CjkSC
        UnicodeScript.Hangul: ScriptGroup.Hangul
        UnicodeScript.Devanagari: ScriptGroup.Devanagari
        UnicodeScript.Arabic: ScriptGroup.Arabic
        UnicodeScript.Bengali: ScriptGroup.Bengali
        UnicodeScript.Common: ScriptGroup.LatinCyrillic
        UnicodeScript.Unknown: ScriptGroup.LatinCyrillic

fn get_font_for_script(script: ScriptGroup, font_type: FontType) -> FontEntry:
    """Find the best font for a script group and type.
    Returns the first matching entry from the catalog.
    Falls back to Sans if requested type not available."""
    val catalog = font_catalog()
    # Try exact match first
    var i: i64 = 0
    while i < catalog.len():
        val entry = catalog[i]
        if entry.script_group == script and entry.font_type == font_type:
            return entry
        i = i + 1
    # Fallback to Sans
    i = 0
    while i < catalog.len():
        val entry = catalog[i]
        if entry.script_group == script and entry.font_type == FontType.Sans:
            return entry
        i = i + 1
    # Last resort: return Latin Sans
    catalog[0]

# ============================================================================
# Font fallback chain — ordered list of fonts to try for a given type
# ============================================================================

fn font_fallback_chain(font_type: FontType) -> [FontEntry]:
    """Return an ordered fallback chain for a font type.
    Order: Latin/Cyrillic -> CJK -> Hangul -> Devanagari -> Arabic -> Bengali.
    This ensures common scripts are tried first."""
    var chain: [FontEntry] = []
    val groups = [
        ScriptGroup.LatinCyrillic,
        ScriptGroup.CjkSC,
        ScriptGroup.Hangul,
        ScriptGroup.Devanagari,
        ScriptGroup.Arabic,
        ScriptGroup.Bengali
    ]
    var i: i64 = 0
    while i < groups.len():
        chain.push(get_font_for_script(groups[i], font_type))
        i = i + 1
    chain

# ============================================================================
# Summary table — for documentation and display
# ============================================================================

fn font_summary() -> text:
    """Return a formatted summary of font assignments per language."""
    var lines: [text] = []
    lines.push("Font Registry — CLDR 48.2 Top 10 + Extra Script Support")
    lines.push("=" * 60)
    lines.push("")
    lines.push("Script Group       | Sans                  | Serif                 | Mono")
    lines.push("-------------------|-----------------------|-----------------------|------------------")
    lines.push("Latin+Cyrillic     | Noto Sans             | Noto Serif            | Noto Sans Mono")
    lines.push("  English, Spanish, French, Portuguese, Russian, Indonesian")
    lines.push("CJK (Chinese SC)   | Noto Sans SC          | Noto Serif SC         | (use Sans)")
    lines.push("Legacy Hangul      | Noto Sans KR          | Noto Serif KR         | D2Coding")
    lines.push("Devanagari (Hindi) | Noto Sans Devanagari* | Noto Serif Devanagari*| (use Sans)")
    lines.push("Arabic (AR, UR)    | Noto Sans Arabic*     | Noto Naskh Arabic*    | (use Sans)")
    lines.push("Extra Bengali      | Noto Sans Bengali*    | Noto Serif Bengali*   | (use Sans)")
    lines.push("")
    lines.push("* = Requires the selected Pure Simple complex-script shaping lane")
    lines.push("")
    lines.push("stb_truetype-compatible (Tier 1): Latin, Cyrillic, CJK, Korean")
    lines.push("Needs complex shaping: Hindi, Arabic/Urdu, extra Bengali")
    lines.push("")
    lines.push("All fonts: OFL-1.1 (SIL Open Font License)")
    lines.push("Pinned 16-file candidate set: 51,764,704 font bytes")
    lines.join("\n")

# Pinned CLDR 48.2 literate-functional reach evidence. The annotated tag object
# peels to the source commit below. Totals use per-territory fixed-decimal
# half-up rounding, same-release aliases, no macrolanguage roll-up, and lexical
# language-ID tie breaking. Rank 11 is retained as the executable cutoff.
class FontLanguageRank:
    rank: i32
    language: text
    likely_script: text
    literate_functional_total: i64
    script_totals: text

class FontLanguageRankingSource:
    release: text
    tag_object: text
    source_commit: text
    supplemental_data_sha256: text
    supplemental_metadata_sha256: text
    likely_subtags_sha256: text
    license: text

fn selected_font_language_ranking_source() -> FontLanguageRankingSource:
    FontLanguageRankingSource(
        release: "release-48-2",
        tag_object: "fc1fd058cc6f50544a450a3b15a4bba0e0c1e653",
        source_commit: "11299982335beb974c1c63c45265184e759c0f41",
        supplemental_data_sha256: "cd2af39aef82fdbfba4d591c87548203350538ad2318486d104b3b38b8d62f1a",
        supplemental_metadata_sha256: "36e807ce72b15304dd993f132216f408351be1c4376edaa2fe9e9547e2efcac1",
        likely_subtags_sha256: "b0049bc6420715b1e3010f43d95745dca227c5aa60357d1d89a1bdcb06287312",
        license: "Unicode-3.0"
    )

fn font_language_ranking_evidence() -> [FontLanguageRank]:
    [
        FontLanguageRank(rank: 1, language: "en", likely_script: "Latn", literate_functional_total: 1393231713, script_totals: "Latn=1393231713,Shaw=0"),
        FontLanguageRank(rank: 2, language: "zh", likely_script: "Hans", literate_functional_total: 1260669749, script_totals: "Hans=1222992537,Hant=37677212"),
        FontLanguageRank(rank: 3, language: "es", likely_script: "Latn", literate_functional_total: 478211561, script_totals: "Latn=478211561"),
        FontLanguageRank(rank: 4, language: "hi", likely_script: "Deva", literate_functional_total: 365817361, script_totals: "Deva=364932427,Latn=884934"),
        FontLanguageRank(rank: 5, language: "ar", likely_script: "Arab", literate_functional_total: 290601433, script_totals: "Arab=290601433"),
        FontLanguageRank(rank: 6, language: "fr", likely_script: "Latn", literate_functional_total: 263194864, script_totals: "Latn=263194864"),
        FontLanguageRank(rank: 7, language: "pt", likely_script: "Latn", literate_functional_total: 217359637, script_totals: "Latn=217359637"),
        FontLanguageRank(rank: 8, language: "ru", likely_script: "Cyrl", literate_functional_total: 200421637, script_totals: "Cyrl=200421637"),
        FontLanguageRank(rank: 9, language: "ur", likely_script: "Arab", literate_functional_total: 178722223, script_totals: "Arab=178722223"),
        FontLanguageRank(rank: 10, language: "id", likely_script: "Latn", literate_functional_total: 167542007, script_totals: "Latn=167542007"),
        FontLanguageRank(rank: 11, language: "bn", likely_script: "Beng", literate_functional_total: 167485664, script_totals: "Beng=167485664")
    ]

fn selected_font_language_ranks() -> [FontLanguageRank]:
    val evidence = font_language_ranking_evidence()
    evidence.slice(0, 10)

# Immutable upstream candidates selected by REQ-005. Their unchanged binaries,
# metadata, and licenses are bundled; acceptance still requires executable
# target-corpus coverage.
class FontAssetCandidate:
    family: text
    category: text
    upstream_repository: text
    upstream_revision: text
    upstream_path: text
    local_path: text
    metadata_path: text
    license_path: text
    license: text
    copyright_notice: text
    rfn_state: text
    byte_len: i64
    sha256: text
    sfnt_tables: text
    metadata_scripts: text
    modification_state: text
    coverage_state: text
    embedded_style: text
    embedded_full_name: text
    embedded_postscript_name: text
    embedded_version: text
    default_axes: text
    coverage_corpus_ref: text
    fallback_role: text

fn _font_candidate_coverage_state(upstream_path: text) -> text:
    if upstream_path.contains("notosanssc/") or upstream_path.contains("notoserifsc/"):
        return "accepted-simple: exact Pure Simple identity shaping accepted for en,zh,es,fr,pt,ru,id"
    if upstream_path.contains("devanagari/"):
        return "candidate: exact CORPUS witness cmap verified for en,es,hi,fr,pt,id; executable Simple shaping acceptance pending"
    if upstream_path.contains("arabic/"):
        return "candidate: exact CORPUS witness cmap verified for en,es,ar,fr,pt,ur,id; executable Simple shaping acceptance pending"
    if upstream_path.contains("bengali/"):
        return "candidate: exact rank-11 CORPUS witness cmap verified for bn; executable Simple shaping acceptance pending"
    if upstream_path.contains("notosansmono/"):
        return "accepted-simple: exact Pure Simple identity shaping accepted for en,es,fr,pt,ru,id"
    if upstream_path.contains("bungee/") or upstream_path.contains("unifrakturcook/"):
        return "accepted-simple: exact Pure Simple identity shaping accepted for en,es,fr,pt,id"
    if (upstream_path.contains("nunito/") or upstream_path.contains("caveat/") or
        upstream_path.contains("robotoslab/") or upstream_path.contains("pixelifysans/")):
        return "accepted-simple: exact Pure Simple identity shaping accepted for en,es,fr,pt,ru,id"
    if upstream_path.contains("notoemoji/"):
        return "candidate: exact CORPUS U+1F600 format-12 cmap verified; executable Simple shaping acceptance pending"
    "candidate: exact CORPUS witness cmap pending; executable Simple shaping acceptance pending"

fn _font_candidate_embedded_style(family: text) -> text:
    if family == "Noto Sans SC": return "Thin"
    if family == "Noto Serif SC" or family == "Nunito": return "ExtraLight"
    if family == "UnifrakturCook": return "Bold"
    "Regular"

fn _font_candidate_embedded_full_name(family: text) -> text:
    if family == "UnifrakturCook": return family
    family + " " + _font_candidate_embedded_style(family)

fn _font_candidate_embedded_postscript_name(family: text) -> text:
    family.replace(" ", "") + "-" + _font_candidate_embedded_style(family)

fn _font_candidate_embedded_version(family: text) -> text:
    if family == "Roboto Slab": return "Version 2.002"
    if family == "Bungee" or family == "Caveat": return "Version 2.000"
    if family == "Noto Emoji": return "Version 3.002"
    if family == "Noto Naskh Arabic": return "Version 2.021"
    if family == "Noto Sans Arabic": return "Version 2.012"
    if family == "Noto Sans Bengali": return "Version 3.011"
    if family == "Noto Sans Devanagari" or family == "Noto Serif Devanagari": return "Version 2.006"
    if family == "Noto Sans Mono": return "Version 2.014"
    if family == "Noto Sans SC": return "Version 2.004-H2;hotconv 1.0.118;makeotfexe 2.5.65603"
    if family == "Noto Serif Bengali": return "Version 3.000"
    if family == "Noto Serif SC": return "Version 2.003-H1;hotconv 1.1.1;makeotfexe 2.6.0"
    if family == "Nunito": return "Version 3.602"
    if family == "Pixelify Sans": return "Version 1.000"
    if family == "UnifrakturCook": return "Version 2011-09-01 "
    ""

fn _font_candidate_default_axes(family: text) -> text:
    if family == "Bungee" or family == "UnifrakturCook": return "static"
    if family == "Noto Sans SC": return "wght=100"
    if family == "Noto Serif SC" or family == "Nunito": return "wght=200"
    if (family == "Noto Sans Arabic" or family == "Noto Sans Bengali" or
        family == "Noto Sans Devanagari" or family == "Noto Sans Mono" or
        family == "Noto Serif Bengali" or family == "Noto Serif Devanagari"):
        return "wght=400,wdth=100"
    "wght=400"

fn _font_candidate_fallback_role(category: text, family: text) -> text:
    if family.contains("Bengali"): return "rank11-cutoff-only"
    if category == "emoji": return "common-emoji-fallback"
    if category == "sans" or category == "serif": return "candidate-script-primary"
    "candidate-category-witness"

fn _google_font_candidate(family: text, category: text, upstream_path: text,
                          license_path: text, license: text,
                          copyright_notice: text, rfn_state: text,
                          byte_len: i64, sha256: text, sfnt_tables: text,
                          metadata_scripts: text) -> FontAssetCandidate:
    val slash = upstream_path.rfind("/")
    val metadata_path = upstream_path[0:slash] + "/METADATA.pb"
    FontAssetCandidate(
        family: family, category: category,
        upstream_repository: "https://github.com/google/fonts",
        upstream_revision: "ec0464b978de222073645d6d3366f3fdf03376d8",
        upstream_path: upstream_path,
        local_path: "assets/fonts/google-fonts/" + upstream_path,
        metadata_path: metadata_path,
        license_path: license_path, license: license,
        copyright_notice: copyright_notice, rfn_state: rfn_state,
        byte_len: byte_len, sha256: sha256, sfnt_tables: sfnt_tables,
        metadata_scripts: metadata_scripts, modification_state: "unchanged",
        coverage_state: _font_candidate_coverage_state(upstream_path),
        embedded_style: _font_candidate_embedded_style(family),
        embedded_full_name: _font_candidate_embedded_full_name(family),
        embedded_postscript_name: _font_candidate_embedded_postscript_name(family),
        embedded_version: _font_candidate_embedded_version(family),
        default_axes: _font_candidate_default_axes(family),
        coverage_corpus_ref: "assets/fonts/google-fonts/CORPUS.sdn#sha256:c7cffbf3e1a29c75dcd481593c6880d071966c5cbf0611e2185fe0d73e0c83f6",
        fallback_role: _font_candidate_fallback_role(category, family)
    )

fn selected_font_asset_candidates() -> [FontAssetCandidate]:
    """Return the pinned 16-file C1/F1/P1 candidate catalog."""
    [
