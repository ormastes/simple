# Neutral bounded OpenType glyf outline parser and rasterizer.

use std.common.encoding.sfnt.{OtFont, OtTable, read_u16_be, read_i16_be, find_table, parse_offset_table}
use std.common.encoding.sfnt_cmap.{sfnt_cmap_glyph_id}

val SFNT_GLYF_MOVE: i64 = 0
val SFNT_GLYF_LINE: i64 = 1
val SFNT_GLYF_QUAD: i64 = 2
val SFNT_GLYF_CLOSE: i64 = 3

class SfntGlyfCommand:
    verb: i64
    x1: f64
    y1: f64
    x2: f64
    y2: f64

class SfntGlyfOutline:
    commands: [SfntGlyfCommand]
    components: i64

class SfntGlyfBitmap:
    # Field names are prefixed (not `width`/`height`/`pixels`/...) to stay
    # GLOBALLY unique. The native/bootstrap MIR path resolves field access on
    # an ANY-erased or match-arm-bound receiver via a receiver-blind "struct
    # declaring this name with the MOST fields wins" scan (documented in
    # doc/08_tracking/bug/simpleos_native_build_framebufferdriver_crossmodule_field_offset_shift_2026-07-14.md);
    # `width`/`height`/`advance`/`bearing_x`/`bearing_y`/`pixels` are also
    # declared (at different indices) by GlyphBitmap (spl_fonts.spl) and the
    # much-larger CachedGlyph (font_types.spl), so an ambiguous name here
    # silently resolves to a WRONG struct's field offset — root cause of the
    # 2026-07-19 pure-sfnt-glyf rasterizer pointer-corruption fault
    # (cr2 landed inside the font's sha256 identity text). Unique names make
    # the scan unambiguous regardless of receiver-type erasure.
    sgb_width: i64
    sgb_height: i64
    sgb_advance: i64
    sgb_bearing_x: i64
    sgb_bearing_y: i64
    sgb_pixels: [u8]

fn _table_is_bounded(font: OtFont, table: OtTable, minimum: i64) -> bool:
    val start = table.offset as i64
    val length = table.length as i64
    start >= 0 and length >= minimum and start <= font.blob.len() and length <= font.blob.len() - start

fn _active_has(active: [u32], glyph_id: u32) -> bool:
    for value in active:
        if value == glyph_id:
            return true
    false

fn _command(verb: i64, x1: f64, y1: f64, x2: f64, y2: f64) -> SfntGlyfCommand:
    SfntGlyfCommand(verb: verb, x1: x1, y1: y1, x2: x2, y2: y2)

fn _append_transformed(dst: [SfntGlyfCommand], src: [SfntGlyfCommand], xx: f64, xy: f64, yx: f64, yy: f64, dx: f64, dy: f64) -> [SfntGlyfCommand]:
    var out = dst
    for command in src:
        if command.verb == SFNT_GLYF_CLOSE:
            out.push(command)
        else:
            out.push(_command(command.verb,
                xx * command.x1 + xy * command.y1 + dx,
                yx * command.x1 + yy * command.y1 + dy,
                xx * command.x2 + xy * command.y2 + dx,
                yx * command.x2 + yy * command.y2 + dy))
    out

fn _parse_simple_slice(blob: [u8], start: i64, end: i64, contour_count: i64) -> Option<[SfntGlyfCommand]>:
    if contour_count < 0 or start + 10 > end or contour_count > (end - start - 10) / 2:
        return None
    if contour_count == 0:
        if start + 12 > end:
            return None
        val instruction_length = read_u16_be(blob, start + 10) as i64
        if instruction_length > end - start - 12:
            return None
        return Some([])
    var endpoints: [i32] = []
    var previous: i32 = -1
    var i: i64 = 0
    while i < contour_count:
        val endpoint = read_u16_be(blob, start + 10 + i * 2) as i32
        if endpoint <= previous:
            return None
        endpoints.append(endpoint)
        previous = endpoint
        i = i + 1
    val point_count = previous as i64 + 1
    val instruction_offset = start + 10 + contour_count * 2
    if instruction_offset + 2 > end:
        return None
    val instruction_length = read_u16_be(blob, instruction_offset) as i64
    var pos = instruction_offset + 2
    if instruction_length > end - pos:
        return None
    pos = pos + instruction_length

    var flags: [u8] = []
    while flags.len() < point_count:
        if pos >= end:
            return None
        val flag = blob[pos]
        pos = pos + 1
        if (flag & 192) != 0:
            return None
        flags.append(flag)
        if (flag & 8) != 0:
            if pos >= end:
                return None
            val repeat_count = blob[pos] as i64
            pos = pos + 1
            if repeat_count > point_count - flags.len():
                return None
            var repeat: i64 = 0
            while repeat < repeat_count:
                flags.append(flag)
                repeat = repeat + 1

    var xs: [i32] = []
    var current: i32 = 0
    i = 0
    while i < point_count:
        val flag = flags[i]
        if (flag & 2) != 0:
            if pos >= end:
                return None
            val delta = blob[pos] as i32
            pos = pos + 1
            if (flag & 16) != 0:
                current = current + delta
            else:
                current = current - delta
        else:
            if (flag & 16) == 0:
                if pos + 2 > end:
                    return None
                current = current + read_i16_be(blob, pos)
                pos = pos + 2
        xs.append(current)
        i = i + 1

    var ys: [i32] = []
    current = 0
    i = 0
    while i < point_count:
        val flag = flags[i]
        if (flag & 4) != 0:
            if pos >= end:
                return None
            val delta = blob[pos] as i32
            pos = pos + 1
            if (flag & 32) != 0:
                current = current + delta
            else:
                current = current - delta
        else:
            if (flag & 32) == 0:
                if pos + 2 > end:
                    return None
                current = current + read_i16_be(blob, pos)
                pos = pos + 2
        ys.append(current)
        i = i + 1

    var commands: [SfntGlyfCommand] = []
    var contour_start: i64 = 0
    var contour: i64 = 0
    while contour < contour_count:
        val contour_end = endpoints[contour] as i64
        val first_on = (flags[contour_start] & 1) != 0
        val last_on = (flags[contour_end] & 1) != 0
        var move_x: f64 = 0.0
        var move_y: f64 = 0.0
        var point = contour_start
        if first_on:
            move_x = xs[contour_start] as f64
            move_y = ys[contour_start] as f64
            point = contour_start + 1
        else:
            if last_on:
                move_x = xs[contour_end] as f64
                move_y = ys[contour_end] as f64
            else:
                move_x = (xs[contour_start] as f64 + xs[contour_end] as f64) / 2.0
                move_y = (ys[contour_start] as f64 + ys[contour_end] as f64) / 2.0
        commands.push(_command(SFNT_GLYF_MOVE, move_x, move_y, 0.0, 0.0))
        while point <= contour_end:
            val x = xs[point] as f64
            val y = ys[point] as f64
            if (flags[point] & 1) != 0:
                commands.push(_command(SFNT_GLYF_LINE, x, y, 0.0, 0.0))
            else:
                var next = point + 1
                var next_x = move_x
                var next_y = move_y
                var next_on = true
                if next <= contour_end:
                    next_x = xs[next] as f64
                    next_y = ys[next] as f64
                    next_on = (flags[next] & 1) != 0
                if next_on:
                    commands.push(_command(SFNT_GLYF_QUAD, x, y, next_x, next_y))
                    point = point + 1
                else:
                    commands.push(_command(SFNT_GLYF_QUAD, x, y, (x + next_x) / 2.0, (y + next_y) / 2.0))
            point = point + 1
        commands.push(_command(SFNT_GLYF_CLOSE, 0.0, 0.0, 0.0, 0.0))
        contour_start = contour_end + 1
        contour = contour + 1
    Some(commands)

fn _f2dot14(blob: [u8], offset: i64) -> f64:
    (read_i16_be(blob, offset) as f64) / 16384.0

fn _parse_glyph(font: OtFont, glyf: OtTable, loca: OtTable, glyph_id: u32, num_glyphs: i64, long_loca: bool, depth: i64, active: [u32], components: i64) -> Option<SfntGlyfOutline>:
    if depth > 8 or glyph_id as i64 >= num_glyphs or _active_has(active, glyph_id):
        return None
    val entry_size: i64 = if long_loca: 4 else: 2
    val loca_pos = loca.offset as i64 + glyph_id as i64 * entry_size
    var relative_start: i64 = 0
    var relative_end: i64 = 0
    if long_loca:
        relative_start = ((blob_u32(font.blob, loca_pos)) as i64)
        relative_end = ((blob_u32(font.blob, loca_pos + 4)) as i64)
    else:
        relative_start = (read_u16_be(font.blob, loca_pos) as i64) * 2
        relative_end = (read_u16_be(font.blob, loca_pos + 2) as i64) * 2
    if relative_end < relative_start or relative_end > glyf.length as i64:
        return None
    val start = glyf.offset as i64 + relative_start
    val end = glyf.offset as i64 + relative_end
    if start == end:
        return Some(SfntGlyfOutline(commands: [], components: components))
    if end - start < 10:
        return None
    val contour_count = read_i16_be(font.blob, start) as i64
    if contour_count >= 0:
        # match unwrap, not `== None`/`.unwrap()`: Option compare/unwrap sinks
        # mis-evaluate on the baremetal native lane (2026-07-18 render-fault
        # chain); match Some/None is the kernel-proven form (applies to every
        # conversion in this file).
        val simple = _parse_simple_slice(font.blob, start, end, contour_count)
        match simple:
            Some(simple_commands):
                return Some(SfntGlyfOutline(commands: simple_commands, components: components))
            None:
                return None
    if contour_count != -1:
        return None

    var next_active = active
    next_active.append(glyph_id)
    var pos = start + 10
    var commands: [SfntGlyfCommand] = []
    var total = components
    var more = true
    var last_flags: u16 = 0
    while more:
        total = total + 1
        if total > 64 or pos + 4 > end:
            return None
        val flags = read_u16_be(font.blob, pos)
        val child_id = read_u16_be(font.blob, pos + 2) as u32
        pos = pos + 4
        if (flags & 2) == 0 or (flags & 57344) != 0 or (flags & 16) != 0 or (flags & 4) != 0 or (flags & 2048) != 0:
            return None
        if (flags & 256) != 0 and (flags & 32) != 0:
            return None
        var dx: f64 = 0.0
        var dy: f64 = 0.0
        if (flags & 1) != 0:
            if pos + 4 > end:
                return None
            dx = read_i16_be(font.blob, pos) as f64
            dy = read_i16_be(font.blob, pos + 2) as f64
            pos = pos + 4
        else:
            if pos + 2 > end:
                return None
            var ax = font.blob[pos] as i32
            var ay = font.blob[pos + 1] as i32
            if ax >= 128:
                ax = ax - 256
            if ay >= 128:
                ay = ay - 256
            dx = ax as f64
            dy = ay as f64
            pos = pos + 2
        var xx: f64 = 1.0
        var xy: f64 = 0.0
        var yx: f64 = 0.0
        var yy: f64 = 1.0
        val transform_bits = flags & 200
        if transform_bits == 8:
            if pos + 2 > end:
                return None
            xx = _f2dot14(font.blob, pos)
            yy = xx
            pos = pos + 2
        else:
            if transform_bits == 64:
                if pos + 4 > end:
                    return None
                xx = _f2dot14(font.blob, pos)
                yy = _f2dot14(font.blob, pos + 2)
                pos = pos + 4
            else:
                if transform_bits == 128:
                    if pos + 8 > end:
                        return None
                    xx = _f2dot14(font.blob, pos)
                    xy = _f2dot14(font.blob, pos + 2)
                    yx = _f2dot14(font.blob, pos + 4)
                    yy = _f2dot14(font.blob, pos + 6)
                    pos = pos + 8
                else:
                    if transform_bits != 0:
                        return None
        val child = _parse_glyph(font, glyf, loca, child_id, num_glyphs, long_loca, depth + 1, next_active, total)
        val parsed = match child:
            Some(value): value
            None: return None
        total = parsed.components
        commands = _append_transformed(commands, parsed.commands, xx, xy, yx, yy, dx, dy)
        more = (flags & 32) != 0
        last_flags = flags
    if (last_flags & 256) != 0:
        if pos + 2 > end:
            return None
        val instruction_length = read_u16_be(font.blob, pos) as i64
        pos = pos + 2
        if instruction_length > end - pos:
            return None
        pos = pos + instruction_length
    if pos > end:
        return None
    Some(SfntGlyfOutline(commands: commands, components: total))

fn blob_u32(blob: [u8], offset: i64) -> u32:
    ((blob[offset] as u32) << 24) | ((blob[offset + 1] as u32) << 16) | ((blob[offset + 2] as u32) << 8) | (blob[offset + 3] as u32)

fn parse_sfnt_glyf_outline(font: OtFont, glyph_id: u32) -> Option<SfntGlyfOutline>:
    val head_table = match find_table(font, 1751474532):
        Some(value): value
        None: return None
    val maxp_table = match find_table(font, 1835104368):
        Some(value): value
        None: return None
    val loca_table = match find_table(font, 1819239265):
        Some(value): value
        None: return None
    val glyf_table = match find_table(font, 1735162214):
        Some(value): value
        None: return None
    if not _table_is_bounded(font, head_table, 54) or not _table_is_bounded(font, maxp_table, 6) or not _table_is_bounded(font, loca_table, 2) or not _table_is_bounded(font, glyf_table, 0):
        return None
    val num_glyphs = read_u16_be(font.blob, maxp_table.offset as i64 + 4) as i64
    val format = read_i16_be(font.blob, head_table.offset as i64 + 50)
    if num_glyphs <= 0 or glyph_id as i64 >= num_glyphs or (format != 0 and format != 1):
        return None
    val entry_size: i64 = if format == 1: 4 else: 2
    if (loca_table.length as i64) < (num_glyphs + 1) * entry_size:
        return None
    _parse_glyph(font, glyf_table, loca_table, glyph_id, num_glyphs, format == 1, 0, [], 0)

# Deprecated offset compatibility cannot establish loca-bounded glyph identity.
fn parse_sfnt_glyf_simple_at(font: OtFont, glyph_offset: u32) -> Option<SfntGlyfOutline>:
    val table = match find_table(font, 1735162214):
        Some(value): value
        None: return None
    val start = glyph_offset as i64
    var end = table.offset as i64 + table.length as i64
    if end > font.blob.len(): end = font.blob.len()
    if start < table.offset as i64 or start + 10 > end: return None
    val contour_count = read_i16_be(font.blob, start) as i64
    if contour_count < 0: return None
    val commands = match _parse_simple_slice(font.blob, start, end, contour_count):
        Some(value): value
        None: return None
    Some(SfntGlyfOutline(commands: commands, components: 0))

fn _round_glyf_metric(value: f64) -> i64:
    # Compute the rounded float first, then cast ONCE. Casting inside both branches
    # (`if X: (a) as i64 else: (b) as i64`) lowers to a `CastElse` HIR node the JIT
    # cannot compile, which defers this whole hot glyph-rasterizer module to the
    # interpreter. Hoisting the cast out keeps the module JIT-lowerable.
    val rounded = if value >= 0.0: value + 0.5 else: value - 0.5
    rounded as i64

fn _ceil_glyf_dimension(value: f64) -> i64:
    if value < 1.0:
        return 1
    val whole = value as i64
    if value > whole as f64: whole + 1 else: whole

class _SfntBounds:
    left: f64
    top: f64
    right: f64
    bottom: f64

class _SfntEdge:
    y_top: f64
    y_bottom: f64
    x_top: f64
    dx_dy: f64
    direction: i64

fn _outline_bounds(commands: [SfntGlyfCommand]) -> Option<_SfntBounds>:
    if commands.len() == 0: return None
    var first = true
    var left = 0.0
    var top = 0.0
    var right = 0.0
    var bottom = 0.0
    for command in commands:
        if command.verb != SFNT_GLYF_CLOSE:
            val count: i64 = if command.verb == SFNT_GLYF_QUAD: 2 else: 1
            var index: i64 = 0
            while index < count:
                val x = if index == 0: command.x1 else: command.x2
                val y = if index == 0: command.y1 else: command.y2
                if first:
                    left = x
                    right = x
                    top = y
                    bottom = y
                    first = false
                else:
                    if x < left: left = x
                    if x > right: right = x
                    if y < top: top = y
                    if y > bottom: bottom = y
                index = index + 1
    if first: None else: Some(_SfntBounds(left: left, top: top, right: right, bottom: bottom))

fn _edge(ax: f64, ay: f64, bx: f64, by: f64) -> _SfntEdge:
    if ay < by:
        _SfntEdge(y_top: ay, y_bottom: by, x_top: ax, dx_dy: (bx - ax) / (by - ay), direction: 1)
    else:
        _SfntEdge(y_top: by, y_bottom: ay, x_top: bx, dx_dy: (ax - bx) / (ay - by), direction: -1)

fn _add_edge(edges: [_SfntEdge], ax: f64, ay: f64, bx: f64, by: f64) -> [_SfntEdge]:
    var result = edges
    if ay != by: result.push(_edge(ax, ay, bx, by))
    result

fn _quad_edges(edges: [_SfntEdge], ax: f64, ay: f64, cx: f64, cy: f64, bx: f64, by: f64, depth: i64) -> [_SfntEdge]:
    if depth == 0: return _add_edge(edges, ax, ay, bx, by)
    val lx = (ax + cx) / 2.0
    val ly = (ay + cy) / 2.0
    val rx = (cx + bx) / 2.0
    val ry = (cy + by) / 2.0
    val mx = (lx + rx) / 2.0
    val my = (ly + ry) / 2.0
    val left = _quad_edges(edges, ax, ay, lx, ly, mx, my, depth - 1)
    _quad_edges(left, mx, my, rx, ry, bx, by, depth - 1)

fn _outline_edges(commands: [SfntGlyfCommand], scale: f64, left: f64, top: f64) -> [_SfntEdge]:
    var edges: [_SfntEdge] = []
    var pen_x = 0.0
    var pen_y = 0.0
    var move_x = 0.0
    var move_y = 0.0
    for command in commands:
        val x1 = command.x1 * scale - left
        val y1 = -command.y1 * scale - top
        if command.verb == SFNT_GLYF_MOVE:
            pen_x = x1
            pen_y = y1
            move_x = x1
            move_y = y1
        elif command.verb == SFNT_GLYF_LINE:
            edges = _add_edge(edges, pen_x, pen_y, x1, y1)
            pen_x = x1
            pen_y = y1
        elif command.verb == SFNT_GLYF_QUAD:
            val x2 = command.x2 * scale - left
            val y2 = -command.y2 * scale - top
            edges = _quad_edges(edges, pen_x, pen_y, x1, y1, x2, y2, 4)
            pen_x = x2
            pen_y = y2
        elif command.verb == SFNT_GLYF_CLOSE:
            edges = _add_edge(edges, pen_x, pen_y, move_x, move_y)
            pen_x = move_x
            pen_y = move_y
    edges

fn _coverage(edges: [_SfntEdge], x: f64, y: f64) -> u8:
    # 4x4 supersample grid (was 4 y-only samples with a single x point test
    # per scanline): 16 sub-pixel samples -> 17 coverage levels vs 5, and
    # isotropic (both axes supersampled) instead of anisotropic. This is
    # rasterize-time only cost — glyph bitmaps are atlas-cached, so per-frame
    # draw cost is unchanged; only cache-miss rasterize cost rises (~4x more
    # inner-loop samples), which is acceptable.
    var hits: i64 = 0
    var sample_y: i64 = 0
    while sample_y < 4:
        val sy = y + (sample_y as f64 * 2.0 + 1.0) / 8.0
        var sample_x: i64 = 0
        while sample_x < 4:
            val sx = x + (sample_x as f64 * 2.0 + 1.0) / 8.0
            var winding: i64 = 0
            for edge in edges:
                if edge.y_top <= sy and sy < edge.y_bottom:
                    val crossing = edge.x_top + edge.dx_dy * (sy - edge.y_top)
                    if crossing <= sx: winding = winding + edge.direction
            if winding != 0: hits = hits + 1
            sample_x = sample_x + 1
        sample_y = sample_y + 1
    (hits * 255 / 16) as u8

fn _hmtx(font: OtFont, long_metrics: i64, glyph_id: u32) -> Option<[i64]>:
    if long_metrics <= 0: return None
    val table = match find_table(font, 1752003704):
        Some(value): value
        None: return None
    val gid = glyph_id as i64
    val advance_index = if gid < long_metrics: gid else: long_metrics - 1
    val advance_pos = table.offset as i64 + advance_index * 4
    val bearing_pos = if gid < long_metrics: advance_pos + 2 else: table.offset as i64 + long_metrics * 4 + (gid - long_metrics) * 2
    val limit = table.offset as i64 + table.length as i64
    if advance_pos + 2 > limit or bearing_pos + 2 > limit: return None
    Some([read_u16_be(font.blob, advance_pos) as i64, read_i16_be(font.blob, bearing_pos) as i64])

fn rasterize_sfnt_glyf(font: OtFont, glyph_id: u32, size_px: i64) -> Option<SfntGlyfBitmap>:
    if size_px <= 0 or size_px > 512:
        return None
    val head_table = match find_table(font, 1751474532):
        Some(value): value
        None: return None
    val hhea_table = match find_table(font, 1751672161):
        Some(value): value
        None: return None
    val hmtx_table = match find_table(font, 1752003704):
        Some(value): value
        None: return None
    if not _table_is_bounded(font, head_table, 54) or not _table_is_bounded(font, hhea_table, 36) or not _table_is_bounded(font, hmtx_table, 4):
        return None
    val units_per_em = read_u16_be(font.blob, head_table.offset as i64 + 18) as i64
    val long_metrics = read_u16_be(font.blob, hhea_table.offset as i64 + 34) as i64
    if units_per_em == 0 or long_metrics == 0:
        return None
    var metric_end: i64 = 0
    if (glyph_id as i64) < long_metrics:
        metric_end = (glyph_id as i64 + 1) * 4
    else:
        metric_end = long_metrics * 4 + (glyph_id as i64 - long_metrics + 1) * 2
    if metric_end > hmtx_table.length as i64:
        return None
    val parsed_outline = match parse_sfnt_glyf_outline(font, glyph_id):
        Some(value): value
        None: return None
    val horizontal = match _hmtx(font, long_metrics, glyph_id):
        Some(value): value
        None: return None
    val commands = parsed_outline.commands
    val scale = size_px as f64 / units_per_em as f64
    var has_drawable_point = false
    for command in commands:
        if command.verb != SFNT_GLYF_CLOSE:
            has_drawable_point = true
    if not has_drawable_point:
        # Whitespace/empty glyph: a valid 0x0 bitmap with real advance —
        # matches the dylib lane's semantics. Also avoids returning None for
        # a routine case: match None-discrimination is unreliable on the
        # baremetal lane (a legit None here surfaced in the caller's Some
        # arm as nil -> "field access on nil receiver" panic at bounds.right,
        # 2026-07-18; first WM label glyph was a space).
        return Some(SfntGlyfBitmap(
            sgb_width: 0, sgb_height: 0,
            sgb_advance: _round_glyf_metric(horizontal[0] as f64 * scale),
            sgb_bearing_x: _round_glyf_metric(horizontal[1] as f64 * scale),
            sgb_bearing_y: 0, sgb_pixels: []))
    val bounds = match _outline_bounds(commands):
        Some(value): value
        None: return None
    val em_w = bounds.right - bounds.left
    val em_h = bounds.bottom - bounds.top
    val raw_w = em_w * scale
    val raw_h = em_h * scale
    val width = _ceil_glyf_dimension(raw_w)
    val height = _ceil_glyf_dimension(raw_h)
    if raw_w < 0.0 or raw_h < 0.0 or width > 4096 or height > 4096 or width > 16777216 / height:
        return None
    val edges = _outline_edges(commands, scale, bounds.left * scale, -bounds.bottom * scale)
    var pixels: [u8] = []
    var y: i64 = 0
    while y < height:
        var x: i64 = 0
        while x < width:
            pixels.push(_coverage(edges, x as f64, y as f64))
            x = x + 1
        y = y + 1
    Some(SfntGlyfBitmap(
        sgb_width: width,
        sgb_height: height,
        sgb_advance: _round_glyf_metric(horizontal[0] as f64 * scale),
        sgb_bearing_x: _round_glyf_metric(horizontal[1] as f64 * scale),
        sgb_bearing_y: _round_glyf_metric(bounds.top * scale),
        sgb_pixels: pixels
    ))

# ===== Flat cross-module rasterization API =====
#
# Option<struct> results do NOT survive the module boundary on the baremetal
# native lane (None/Some discrimination breaks and the caller's Some binding
# arrives nil -> "field access on nil receiver" panic, 2026-07-18 render-fault
# chain). These wrappers keep every Option intra-module and return only
# arrays + bool, the kernel-proven cross-module shapes.
# Metrics layout: [width, height, advance, bearing_x, bearing_y].

fn sfnt_rasterize_codepoint_parts(blob: [u8], codepoint: i64, size_px: i64) -> ([u8], [i64], bool):
    if blob.len() == 0 or codepoint < 0 or codepoint > 1114111 or size_px <= 0:
        return ([], [], false)
    val font = match parse_offset_table(blob):
        Some(value): value
        None: return ([], [], false)
    val glyph_id = sfnt_cmap_glyph_id(font, codepoint as u32)
    if glyph_id == 0:
        return ([], [], false)
    _sfnt_rasterize_glyph_parts(font, glyph_id, size_px)

fn sfnt_rasterize_glyph_index_parts(blob: [u8], glyph_index: i64, size_px: i64) -> ([u8], [i64], bool):
    if blob.len() == 0 or glyph_index <= 0 or glyph_index > 4294967295 or size_px <= 0:
        return ([], [], false)
    val font = match parse_offset_table(blob):
        Some(value): value
        None: return ([], [], false)
    _sfnt_rasterize_glyph_parts(font, glyph_index as u32, size_px)

fn _sfnt_rasterize_glyph_parts(font: OtFont, glyph_id: u32, size_px: i64) -> ([u8], [i64], bool):
    val bitmap = match rasterize_sfnt_glyf(font, glyph_id, size_px):
        Some(value): value
        None: return ([], [], false)
    val bm_width: i64 = bitmap.sgb_width
    val bm_height: i64 = bitmap.sgb_height
    val bm_advance: i64 = bitmap.sgb_advance
    val bm_bearing_x: i64 = bitmap.sgb_bearing_x
    val bm_bearing_y: i64 = bitmap.sgb_bearing_y
    val bm_pixels: [u8] = bitmap.sgb_pixels
    (bm_pixels, [bm_width, bm_height, bm_advance, bm_bearing_x, bm_bearing_y], true)

fn sfnt_blob_glyph_exists(blob: [u8], codepoint: i64) -> bool:
    if blob.len() == 0 or codepoint < 0 or codepoint > 1114111:
        return false
    val font = match parse_offset_table(blob):
        Some(value): value
        None: return false
    sfnt_cmap_glyph_id(font, codepoint as u32) != 0
