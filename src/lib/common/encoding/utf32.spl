@allow(primitive_api)
# UTF-32 Encoding / Decoding
#
# Pure Simple implementation of UTF-32 codec.
# UTF-32 maps 1:1 with Unicode codepoints (fixed-width 32-bit per char).
# Supports both big-endian (UTF-32BE) and little-endian (UTF-32LE).

use std.common.encoding.utf8.{utf8_encode_one, utf8_decode_all}

# ============================================================================
# UTF-32 encode / decode (trivial — identity mapping with validation)
# ============================================================================

fn utf32_encode_one(codepoint: i64) -> i64:
    """Encode a codepoint to UTF-32 (identity, but validates range)."""
    if codepoint < 0 or codepoint > 0x10FFFF:
        return 0xFFFD
    if codepoint >= 0xD800 and codepoint <= 0xDFFF:
        return 0xFFFD
    codepoint

fn utf32_decode_one(value: i64) -> i64:
    """Decode a UTF-32 value to codepoint (validates range)."""
    if value < 0 or value > 0x10FFFF:
        return 0xFFFD
    if value >= 0xD800 and value <= 0xDFFF:
        return 0xFFFD
    value

fn utf32_encode_all(codepoints: [i64]) -> [i64]:
    """Encode codepoint array to UTF-32 (validates each)."""
    var result: [i64] = []
    var i: i64 = 0
    while i < codepoints.len():
        result.push(utf32_encode_one(codepoints[i]))
        i = i + 1
    result

fn utf32_decode_all(values: [i64]) -> [i64]:
    """Decode UTF-32 array to codepoints (validates each)."""
    var result: [i64] = []
    var i: i64 = 0
    while i < values.len():
        result.push(utf32_decode_one(values[i]))
        i = i + 1
    result

# ============================================================================
# UTF-32 to/from bytes
# ============================================================================

fn utf32_to_bytes_le(values: [i64]) -> [i64]:
    """Convert UTF-32 values to little-endian byte array."""
    var result: [i64] = []
    var i: i64 = 0
    while i < values.len():
        val v = values[i] & 0xFFFFFFFF
        result.push(v & 0xFF)
        result.push((v >> 8) & 0xFF)
        result.push((v >> 16) & 0xFF)
        result.push((v >> 24) & 0xFF)
        i = i + 1
    result

fn utf32_to_bytes_be(values: [i64]) -> [i64]:
    """Convert UTF-32 values to big-endian byte array."""
    var result: [i64] = []
    var i: i64 = 0
    while i < values.len():
        val v = values[i] & 0xFFFFFFFF
        result.push((v >> 24) & 0xFF)
        result.push((v >> 16) & 0xFF)
        result.push((v >> 8) & 0xFF)
        result.push(v & 0xFF)
        i = i + 1
    result

fn utf32_from_bytes_le(bytes: [i64]) -> [i64]:
    """Convert little-endian byte array to UTF-32 values."""
    var result: [i64] = []
    var i: i64 = 0
    while i + 3 < bytes.len():
        val v = (bytes[i] & 0xFF) | ((bytes[i+1] & 0xFF) << 8) | ((bytes[i+2] & 0xFF) << 16) | ((bytes[i+3] & 0xFF) << 24)
        result.push(utf32_decode_one(v))
        i = i + 4
    result

fn utf32_from_bytes_be(bytes: [i64]) -> [i64]:
    """Convert big-endian byte array to UTF-32 values."""
    var result: [i64] = []
    var i: i64 = 0
    while i + 3 < bytes.len():
        val v = ((bytes[i] & 0xFF) << 24) | ((bytes[i+1] & 0xFF) << 16) | ((bytes[i+2] & 0xFF) << 8) | (bytes[i+3] & 0xFF)
        result.push(utf32_decode_one(v))
        i = i + 4
    result

# ============================================================================
# Cross-codec: UTF-32 <-> UTF-8
# ============================================================================

fn utf32_to_utf8(values: [i64]) -> [i64]:
    """Convert UTF-32 values to UTF-8 byte array."""
    var result: [i64] = []
    var i: i64 = 0
    while i < values.len():
        val encoded = utf8_encode_one(values[i])
        var j: i64 = 0
        while j < encoded.len():
            result.push(encoded[j])
            j = j + 1
        i = i + 1
    result

fn utf8_to_utf32(bytes: [i64]) -> [i64]:
    """Convert UTF-8 byte array to UTF-32 values (codepoints)."""
    utf8_decode_all(bytes)
