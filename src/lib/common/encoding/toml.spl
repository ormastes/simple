# TOML Parser (v1.0 subset)
#
# Supports:
#   - Bare keys: key = value
#   - String values: key = "value" (basic strings with \n, \t, \" escapes)
#   - Integer values: key = 42, key = -7
#   - Boolean values: key = true, key = false
#   - Tables (sections): [section]
#   - Dotted keys: section.key = value
#   - Array of values: key = [1, 2, 3] and key = ["a", "b"]
#   - Comments: # this is a comment
#   - NOT supported: inline tables, multi-line strings, datetimes, floats
#
# Internal representation: each entry is a [text] triple:
#   [0] = full dotted key  (e.g. "database.host")
#   [1] = type tag         ("string" | "int" | "bool" | "array")
#   [2] = raw value text   (e.g. "localhost", "5432", "true", "[1,2,3]")
#
# NOTE: All module-level helper functions used to avoid it-block var-mutation
# footgun (see .claude/memory/feedback_it_block_var_mutation.md).
#
# Usage:
#   use std.common.encoding.toml.{toml_parse, toml_get, toml_get_int,
#       toml_get_bool, toml_get_array, toml_encode}

mod std.common.encoding.toml

# ============================================================================
# Character helpers
# ============================================================================

fn _toml_char_at(s: text, i: i64) -> i64:
    s[i].ord()

fn _toml_is_digit(c: i64) -> bool:
    c >= 48 and c <= 57

fn _toml_is_alpha(c: i64) -> bool:
    (c >= 65 and c <= 90) or (c >= 97 and c <= 122)

fn _toml_is_key_char(c: i64) -> bool:
    _toml_is_alpha(c) or _toml_is_digit(c) or c == 45 or c == 95

fn _toml_is_ws(c: i64) -> bool:
    c == 32 or c == 9

fn _toml_skip_ws(s: text, pos: i64) -> i64:
    val slen = s.length()
    var i = pos
    while (i < slen and _toml_is_ws(_toml_char_at(s, i))):
        i = i + 1
    i

# ============================================================================
# String parsing (basic strings with escapes)
# ============================================================================

fn _toml_parse_string(s: text, pos: i64) -> [text]:
    # Returns ["ok", value, new_pos] or ["error", msg, pos]
    val slen = s.length()
    # pos must point to opening quote '"'
    if pos >= slen:
        var r: [text] = []
        r.push("error")
        r.push("unexpected end")
        r.push(pos.to_string())
        return r
    if _toml_char_at(s, pos) != 34:
        var r: [text] = []
        r.push("error")
        r.push("expected quote")
        r.push(pos.to_string())
        return r
    var i = pos + 1
    var result = ""
    var done = false
    while (i < slen and not done):
        val c = _toml_char_at(s, i)
        if c == 34:
            # closing quote
            done = true
        elif c == 92:
            # backslash escape
            val next_i = i + 1
            if next_i >= slen:
                var r: [text] = []
                r.push("error")
                r.push("truncated escape")
                r.push(i.to_string())
                return r
            val nc = _toml_char_at(s, next_i)
            if nc == 110:
                result = result + "\n"
                i = next_i + 1
            elif nc == 116:
                result = result + "\t"
                i = next_i + 1
            elif nc == 34:
                result = result + "\""
                i = next_i + 1
            elif nc == 92:
                result = result + "\\"
                i = next_i + 1
            else:
                result = result + s[next_i]
                i = next_i + 1
        else:
            result = result + s[i]
            i = i + 1
    if not done:
        var r: [text] = []
        r.push("error")
        r.push("unterminated string")
        r.push(i.to_string())
        return r
    var r: [text] = []
    r.push("ok")
    r.push(result)
    r.push((i + 1).to_string())
    r

# ============================================================================
# Key parsing
# ============================================================================

fn _toml_parse_key(s: text, pos: i64) -> [text]:
    # Returns ["ok", key_text, new_pos] or ["error", msg, pos]
    val slen = s.length()
    var i = pos
    var key = ""
    while (i < slen and _toml_is_key_char(_toml_char_at(s, i))):
        key = key + s[i]
        i = i + 1
    if key.length() == 0:
        var r: [text] = []
        r.push("error")
        r.push("empty key")
        r.push(pos.to_string())
        return r
    var r: [text] = []
    r.push("ok")
    r.push(key)
    r.push(i.to_string())
    r

# ============================================================================
# Integer parsing
# ============================================================================

fn _toml_parse_int_text(s: text, pos: i64) -> [text]:
    # Returns ["ok", int_text, new_pos] or ["error", msg, pos]
    val slen = s.length()
    var i = pos
    var num = ""
    if i < slen and _toml_char_at(s, i) == 45:
        num = "-"
        i = i + 1
    if i >= slen:
        var r: [text] = []
        r.push("error")
        r.push("expected digit")
        r.push(i.to_string())
        return r
    if not _toml_is_digit(_toml_char_at(s, i)):
        var r: [text] = []
        r.push("error")
        r.push("expected digit")
        r.push(i.to_string())
        return r
    while (i < slen and _toml_is_digit(_toml_char_at(s, i))):
        num = num + s[i]
        i = i + 1
    var r: [text] = []
    r.push("ok")
    r.push(num)
    r.push(i.to_string())
    r

# ============================================================================
# Array parsing
# ============================================================================

fn _toml_parse_array(s: text, pos: i64) -> [text]:
    # Returns ["ok", item1, item2, ..., itemN, "end", new_pos]
    # or ["error", msg, pos]
    val slen = s.length()
    if pos >= slen or _toml_char_at(s, pos) != 91:
        var r: [text] = []
        r.push("error")
        r.push("expected [")
        r.push(pos.to_string())
        return r
    var i = pos + 1
    var items: [text] = []
    var done = false
    var had_error = false
    var error_msg = ""
    while (i < slen and not done and not had_error):
        i = _toml_skip_ws(s, i)
        if i >= slen:
            had_error = true
            error_msg = "unterminated array"
        elif _toml_char_at(s, i) == 93:
            # closing ]
            i = i + 1
            done = true
        elif _toml_char_at(s, i) == 35:
            # comment inside array — not standard TOML but skip
            had_error = true
            error_msg = "unexpected comment in array"
        elif _toml_char_at(s, i) == 44:
            # comma — skip
            i = i + 1
        elif _toml_char_at(s, i) == 34:
            # string item
            val sr = _toml_parse_string(s, i)
            if sr[0] == "error":
                had_error = true
                error_msg = sr[1]
            else:
                items.push(sr[1])
                i = sr[2].to_int()
        elif (_toml_char_at(s, i) == 116 and i + 3 < slen):
            # true
            val t0 = _toml_char_at(s, i)
            val t1 = _toml_char_at(s, i + 1)
            val t2 = _toml_char_at(s, i + 2)
            val t3 = _toml_char_at(s, i + 3)
            if (t0 == 116 and t1 == 114 and t2 == 117 and t3 == 101):
                items.push("true")
                i = i + 4
            else:
                had_error = true
                error_msg = "unexpected token in array"
        elif (_toml_char_at(s, i) == 102 and i + 4 < slen):
            # false
            val f0 = _toml_char_at(s, i)
            val f1 = _toml_char_at(s, i + 1)
            val f2 = _toml_char_at(s, i + 2)
            val f3 = _toml_char_at(s, i + 3)
            val f4 = _toml_char_at(s, i + 4)
            if (f0 == 102 and f1 == 97 and f2 == 108 and f3 == 115 and f4 == 101):
                items.push("false")
                i = i + 5
            else:
                had_error = true
                error_msg = "unexpected token in array"
        elif (_toml_char_at(s, i) == 45 or _toml_is_digit(_toml_char_at(s, i))):
            # integer item
            val ir = _toml_parse_int_text(s, i)
            if ir[0] == "error":
                had_error = true
                error_msg = ir[1]
            else:
                items.push(ir[1])
                i = ir[2].to_int()
        else:
            had_error = true
            error_msg = "unexpected char in array"
    if had_error:
        var r: [text] = []
        r.push("error")
        r.push(error_msg)
        r.push(i.to_string())
        return r
    var r: [text] = []
    r.push("ok")
    var idx = 0
    while idx < items.len():
        r.push(items[idx])
        idx = idx + 1
    r.push("end")
    r.push(i.to_string())
    r

# ============================================================================
# Value parsing
# ============================================================================

fn _toml_parse_value(s: text, pos: i64) -> [text]:
    # Returns ["string", value, new_pos] or ["int", value, new_pos]
    # or ["bool", value, new_pos] or ["array", item1..itemN, "end", new_pos]
    # or ["error", msg, pos]
    val slen = s.length()
    val i = _toml_skip_ws(s, pos)
    if i >= slen:
        var r: [text] = []
        r.push("error")
        r.push("expected value")
        r.push(i.to_string())
        return r
    val c = _toml_char_at(s, i)
    if c == 34:
        # string
        val sr = _toml_parse_string(s, i)
        if sr[0] == "error":
            return sr
        var r: [text] = []
        r.push("string")
        r.push(sr[1])
        r.push(sr[2])
        return r
    elif c == 91:
        # array
        val ar = _toml_parse_array(s, i)
        if ar[0] == "error":
            return ar
        return ar
    elif (c == 116 and i + 3 < slen):
        # true?
        val t0 = _toml_char_at(s, i)
        val t1 = _toml_char_at(s, i + 1)
        val t2 = _toml_char_at(s, i + 2)
        val t3 = _toml_char_at(s, i + 3)
        if (t0 == 116 and t1 == 114 and t2 == 117 and t3 == 101):
            var r: [text] = []
            r.push("bool")
            r.push("true")
            r.push((i + 4).to_string())
            return r
        var r: [text] = []
        r.push("error")
        r.push("unexpected token")
        r.push(i.to_string())
        return r
    elif (c == 102 and i + 4 < slen):
        # false?
        val f0 = _toml_char_at(s, i)
        val f1 = _toml_char_at(s, i + 1)
        val f2 = _toml_char_at(s, i + 2)
        val f3 = _toml_char_at(s, i + 3)
        val f4 = _toml_char_at(s, i + 4)
        if (f0 == 102 and f1 == 97 and f2 == 108 and f3 == 115 and f4 == 101):
            var r: [text] = []
            r.push("bool")
            r.push("false")
            r.push((i + 5).to_string())
            return r
        var r: [text] = []
        r.push("error")
        r.push("unexpected token")
        r.push(i.to_string())
        return r
    elif (c == 45 or _toml_is_digit(c)):
        # integer
        val ir = _toml_parse_int_text(s, i)
        if ir[0] == "error":
            return ir
        var r: [text] = []
        r.push("int")
        r.push(ir[1])
        r.push(ir[2])
        return r
    else:
        var r: [text] = []
        r.push("error")
        r.push("unrecognized value")
        r.push(i.to_string())
        return r

# ============================================================================
# Entry packing helpers
# ============================================================================

fn _toml_make_entry(full_key: text, type_tag: text, raw_val: text) -> [text]:
    var e: [text] = []
    e.push(full_key)
    e.push(type_tag)
    e.push(raw_val)
    e

fn _toml_pack_array_items(ar: [text]) -> text:
    # ar[0] == "ok", ar[1..n-2] are items, ar[n-2]=="end", ar[n-1]==new_pos
    var packed = ""
    val alen = ar.len()
    # items from index 1 up to but not including "end" marker
    var i = 1
    while (i < alen and ar[i] != "end"):
        if packed.length() > 0:
            packed = packed + ","
        packed = packed + ar[i]
        i = i + 1
    packed

fn _toml_split_lines(content: text) -> [text]:
    var lines: [text] = []
    val clen = content.length()
    var start = 0
    var i = 0
    while i < clen:
        val c = _toml_char_at(content, i)
        if c == 10:
            # newline
            lines.push(content.slice(start, i))
            start = i + 1
        elif c == 13:
            # carriage return
            lines.push(content.slice(start, i))
            # skip \n if next char
            if (i + 1 < clen and _toml_char_at(content, i + 1) == 10):
                i = i + 1
            start = i + 1
        i = i + 1
    # last line (no trailing newline)
    if start < clen:
        lines.push(content.slice(start, clen))
    lines

# ============================================================================
# Strip comment from a raw value portion of a line
# ============================================================================

fn _toml_strip_comment(s: text) -> text:
    # Remove trailing # comment, but respect quoted strings
    val slen = s.length()
    var i = 0
    var in_str = false
    var result_end = slen
    var done = false
    while (i < slen and not done):
        val c = _toml_char_at(s, i)
        if in_str:
            if c == 92:
                # skip escaped char
                i = i + 2
            elif c == 34:
                in_str = false
                i = i + 1
            else:
                i = i + 1
        else:
            if c == 34:
                in_str = true
                i = i + 1
            elif c == 35:
                # comment starts
                result_end = i
                done = true
            else:
                i = i + 1
    s.slice(0, result_end).trim()

# ============================================================================
# Main parser
# ============================================================================

fn toml_parse(content: text) -> [[text]]:
    """Parse TOML content into a list of [key, type, value] triples.

    Each entry is a [text] list: [full_dotted_key, type_tag, raw_value].
    type_tag is one of: "string", "int", "bool", "array".
    For arrays, raw_value is comma-separated items without brackets."""
    var entries: [[text]] = []
    val lines = _toml_split_lines(content)
    val nlines = lines.len()
    var current_section = ""
    var li = 0
    while li < nlines:
        val raw_line = lines[li]
        val line = raw_line.trim()
        val llen = line.length()
        if llen == 0:
            # blank line
            li = li + 1
        elif _toml_char_at(line, 0) == 35:
            # comment line
            li = li + 1
        elif _toml_char_at(line, 0) == 91:
            # section header [section.name]
            # find closing ]
            var close = 1
            var found_close = false
            while (close < llen and not found_close):
                if _toml_char_at(line, close) == 93:
                    found_close = true
                else:
                    close = close + 1
            if found_close:
                current_section = line.slice(1, close).trim()
            li = li + 1
        else:
            # key = value line
            # find '='
            var eq_pos = 0
            var found_eq = false
            while (eq_pos < llen and not found_eq):
                if _toml_char_at(line, eq_pos) == 61:
                    found_eq = true
                else:
                    eq_pos = eq_pos + 1
            if found_eq:
                val key_part = line.slice(0, eq_pos).trim()
                val val_part = line.slice(eq_pos + 1, llen)
                # Determine full key
                var full_key = ""
                if current_section.length() > 0:
                    full_key = current_section + "." + key_part
                else:
                    full_key = key_part
                # Parse value
                val vr = _toml_parse_value(val_part, 0)
                if vr[0] == "string":
                    val entry = _toml_make_entry(full_key, "string", vr[1])
                    entries.push(entry)
                elif vr[0] == "int":
                    val entry = _toml_make_entry(full_key, "int", vr[1])
                    entries.push(entry)
                elif vr[0] == "bool":
                    val entry = _toml_make_entry(full_key, "bool", vr[1])
                    entries.push(entry)
                elif vr[0] == "ok":
                    # array result
                    val packed = _toml_pack_array_items(vr)
                    val entry = _toml_make_entry(full_key, "array", packed)
                    entries.push(entry)
                else:
                    # error or unknown — skip
                    ()
            li = li + 1
    entries

# ============================================================================
# Query helpers
# ============================================================================

fn toml_get(entries: [[text]], key: text) -> text:
    """Get string value by dotted key. Returns empty string if not found."""
    var i = 0
    var result = ""
    while i < entries.len():
        val e = entries[i]
        if e[0] == key:
            result = e[2]
            i = entries.len()
        else:
            i = i + 1
    result

fn toml_get_int(entries: [[text]], key: text) -> i64:
    """Get integer value by dotted key. Returns 0 if not found."""
    var i = 0
    var result: i64 = 0
    while i < entries.len():
        val e = entries[i]
        if e[0] == key:
            result = e[2].to_int()
            i = entries.len()
        else:
            i = i + 1
    result

fn toml_get_bool(entries: [[text]], key: text) -> bool:
    """Get boolean value by dotted key. Returns false if not found."""
    var i = 0
    var result = false
    while i < entries.len():
        val e = entries[i]
        if e[0] == key:
            result = e[2] == "true"
            i = entries.len()
        else:
            i = i + 1
    result

fn toml_get_array(entries: [[text]], key: text) -> [text]:
    """Get array items by dotted key. Returns empty list if not found."""
    var i = 0
    var result: [text] = []
    while i < entries.len():
        val e = entries[i]
        if e[0] == key:
            # packed is comma-separated items
            val packed = e[2]
            if packed.length() > 0:
                result = packed.split(",")
            i = entries.len()
        else:
            i = i + 1
    result

# ============================================================================
# Encoder
# ============================================================================

fn toml_encode(entries: [[text]]) -> text:
    """Serialize entries back to TOML text (flat dotted-key form, no sections)."""
    var out = ""
    var i = 0
    while i < entries.len():
        val e = entries[i]
        val key = e[0]
        val tag = e[1]
        val raw = e[2]
        if tag == "string":
            # Re-encode string: escape special chars
            var enc = "\""
            var j = 0
            val rlen = raw.length()
            while j < rlen:
                val c = _toml_char_at(raw, j)
                if c == 34:
                    enc = enc + "\\\""
                elif c == 92:
                    enc = enc + "\\\\"
                elif c == 10:
                    enc = enc + "\\n"
                elif c == 9:
                    enc = enc + "\\t"
                else:
                    enc = enc + raw[j]
                j = j + 1
            enc = enc + "\""
            out = out + key + " = " + enc + "\n"
        elif tag == "int":
            out = out + key + " = " + raw + "\n"
        elif tag == "bool":
            out = out + key + " = " + raw + "\n"
        elif tag == "array":
            out = out + key + " = [" + raw + "]\n"
        else:
            ()
        i = i + 1
    out
