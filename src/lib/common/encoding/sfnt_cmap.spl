# OpenType cmap table parser (formats 4 and 12)

use std.common.encoding.sfnt.{OtFont, find_table, read_u16_be, read_i16_be, read_u32_be}

# ===== cmap =====

class CmapFormat4:
    seg_count: u32
    end_codes: [u32]
    start_codes: [u32]
    id_deltas: [i32]
    id_range_offsets: [u32]
    glyph_ids: [u32]

class CmapFormat12:
    group_count: u32
    start_codes: [u32]
    end_codes: [u32]
    start_glyph_ids: [u32]

fn parse_cmap_format12(font: OtFont) -> Option<CmapFormat12>:
    val cmap_tag: u32 = 1668112752
    val maybe_tbl = find_table(font, cmap_tag)
    val tbl = match maybe_tbl:
        Some(value): value
        None: return None
    val base = tbl.offset as i64
    val table_length = tbl.length as i64
    val blob_length = font.blob.len() as i64
    if table_length < 4 or base > blob_length or table_length > blob_length - base:
        return None
    val table_end = base + table_length
    val blob = font.blob
    if read_u16_be(blob, base) != 0:
        return None
    val num_subtables = read_u16_be(blob, base + 2) as i64
    if num_subtables > (table_end - base - 4) / 8:
        return None
    var selected: i64 = -1
    var selected_score: i64 = -1
    var i: i64 = 0
    while i < num_subtables:
        val rec = base + 4 + i * 8
        val platform_id = read_u16_be(blob, rec)
        val encoding_id = read_u16_be(blob, rec + 2)
        val sub_offset = read_u32_be(blob, rec + 4) as i64
        if sub_offset <= table_length - 16:
            val sub_abs = base + sub_offset
            if read_u16_be(blob, sub_abs) == 12:
                var score: i64 = -1
                if platform_id == 0 and (encoding_id == 4 or encoding_id == 6):
                    score = 2
                if platform_id == 3 and encoding_id == 10:
                    score = 3
                if score > selected_score:
                    selected = sub_abs
                    selected_score = score
        i = i + 1
    if selected < 0 or read_u16_be(blob, selected + 2) != 0:
        return None
    val sub_length = read_u32_be(blob, selected + 4) as i64
    if sub_length < 16 or sub_length > table_end - selected:
        return None
    val group_count = read_u32_be(blob, selected + 12) as i64
    if group_count > (sub_length - 16) / 12 or sub_length != 16 + group_count * 12:
        return None
    var starts: [u32] = []
    var ends: [u32] = []
    var glyphs: [u32] = []
    var previous_end: i64 = -1
    i = 0
    while i < group_count:
        val group = selected + 16 + i * 12
        val start = read_u32_be(blob, group)
        val end = read_u32_be(blob, group + 4)
        val glyph = read_u32_be(blob, group + 8)
        val span = end as i64 - start as i64
        if start > end or end > 1114111 or start as i64 <= previous_end:
            return None
        if glyph as i64 + span > 4294967295:
            return None
        starts.push(start)
        ends.push(end)
        glyphs.push(glyph)
        previous_end = end as i64
        i = i + 1
    Some(CmapFormat12(group_count: group_count as u32, start_codes: starts, end_codes: ends, start_glyph_ids: glyphs))

fn cmap12_lookup(cmap: CmapFormat12, codepoint: u32) -> u32:
    if codepoint > 1114111:
        return 0
    val n = cmap.group_count as i64
    if n <= 0 or cmap.start_codes.len() < n or cmap.end_codes.len() < n or cmap.start_glyph_ids.len() < n:
        return 0
    var lo: i64 = 0
    var hi: i64 = n - 1
    var group: i64 = n
    while lo <= hi:
        val mid = (lo + hi) / 2
        if cmap.end_codes[mid] >= codepoint:
            group = mid
            hi = mid - 1
        else:
            lo = mid + 1
    if group >= n or cmap.start_codes[group] > codepoint:
        return 0
    val delta = codepoint as i64 - cmap.start_codes[group] as i64
    val glyph = cmap.start_glyph_ids[group] as i64
    if glyph + delta > 4294967295:
        return 0
    (glyph + delta) as u32

fn parse_cmap_format4(font: OtFont) -> Option<CmapFormat4>:
    # Tag 'cmap' = 0x636D6170
    val cmap_tag: u32 = 1668112752
    val maybe_tbl = find_table(font, cmap_tag)
    val tbl = match maybe_tbl:
        Some(value):
            value
        None:
            return None
    val base = tbl.offset as i64
    val table_length = tbl.length as i64
    val blob = font.blob
    val blob_length = blob.len() as i64
    if table_length < 4 or base > blob_length or table_length > blob_length - base:
        return None
    val table_end = base + table_length
    if read_u16_be(blob, base) != 0:
        return None
    val num_subtables = read_u16_be(blob, base + 2) as i64
    if num_subtables > (table_length - 4) / 8:
        return None
    # Walk encoding records looking for format 4 (prefer platform 3 encoding 1, or platform 0)
    var fmt4_offset: i64 = -1
    var i: i64 = 0
    while i < num_subtables:
        val rec = base + 4 + i * 8
        val platform_id = read_u16_be(blob, rec)
        val encoding_id = read_u16_be(blob, rec + 2)
        val sub_offset = read_u32_be(blob, rec + 4) as i64
        if sub_offset <= table_length - 14:
            val sub_abs = base + sub_offset
            val fmt = read_u16_be(blob, sub_abs)
            if fmt == 4:
                if fmt4_offset < 0:
                    fmt4_offset = sub_abs
                # Prefer platform 3 encoding 1
                if platform_id == 3 and encoding_id == 1:
                    fmt4_offset = sub_abs
        i = i + 1
    if fmt4_offset < 0:
        return None
    # Parse format 4 subtable
    val sub_length = read_u16_be(blob, fmt4_offset + 2) as i64
    if sub_length < 16 or sub_length > table_end - fmt4_offset:
        return None
    val sub_end = fmt4_offset + sub_length
    val seg_count_x2 = read_u16_be(blob, fmt4_offset + 6) as i64
    if seg_count_x2 == 0 or seg_count_x2 % 2 != 0:
        return None
    val seg_count_i64 = seg_count_x2 / 2
    if seg_count_i64 > (sub_length - 16) / 8:
        return None
    val seg_count = seg_count_i64 as u32
    val end_code_base = fmt4_offset + 14
    var end_codes: [u32] = []
    var start_codes: [u32] = []
    var id_deltas: [i32] = []
    var id_range_offsets: [u32] = []
    var j: i64 = 0
    while j < seg_count as i64:
        val ec = read_u16_be(blob, end_code_base + j * 2)
        end_codes.append(ec)
        j = j + 1
    # reserved pad at end_code_base + seg_count * 2
    val start_code_base = end_code_base + seg_count as i64 * 2 + 2
    j = 0
    while j < seg_count as i64:
        val sc = read_u16_be(blob, start_code_base + j * 2)
        start_codes.append(sc)
        j = j + 1
    val delta_base = start_code_base + seg_count as i64 * 2
    j = 0
    while j < seg_count as i64:
        val delta = read_i16_be(blob, delta_base + j * 2)
        id_deltas.append(delta)
        j = j + 1
    val range_base = delta_base + seg_count as i64 * 2
    j = 0
    while j < seg_count as i64:
        val ro = read_u16_be(blob, range_base + j * 2)
        id_range_offsets.append(ro)
        j = j + 1
    # glyph id array follows range offsets
    val gid_base = range_base + seg_count as i64 * 2
    if gid_base > sub_end:
        return None
    val gid_count = (sub_end - gid_base) / 2
    var glyph_ids: [u32] = []
    j = 0
    while j < gid_count and j < 65536:
        val gid = read_u16_be(blob, gid_base + j * 2)
        glyph_ids.append(gid)
        j = j + 1
    Some(CmapFormat4(
        seg_count: seg_count,
        end_codes: end_codes,
        start_codes: start_codes,
        id_deltas: id_deltas,
        id_range_offsets: id_range_offsets,
        glyph_ids: glyph_ids
    ))

fn cmap_lookup(cmap: CmapFormat4, codepoint: u32) -> u32:
    val n = cmap.seg_count as i64
    # Binary search end_codes for first segment where end_code >= codepoint
    var lo: i64 = 0
    var hi: i64 = n - 1
    var seg: i64 = n  # sentinel: not found
    while lo <= hi:
        val mid = (lo + hi) / 2
        if cmap.end_codes[mid] >= codepoint:
            seg = mid
            hi = mid - 1
        else:
            lo = mid + 1
    if seg >= n:
        return 0
    if cmap.start_codes[seg] > codepoint:
        return 0
    val ro = cmap.id_range_offsets[seg]
    if ro == 0:
        val raw = (codepoint as i32 + cmap.id_deltas[seg]) & 0xFFFF
        return raw as u32
    # Use glyph id array
    val gid_idx = (ro / 2) as i64 + (codepoint as i64 - cmap.start_codes[seg] as i64) - (n - seg)
    if gid_idx < 0 or gid_idx >= cmap.glyph_ids.len():
        return 0
    val gid = cmap.glyph_ids[gid_idx]
    if gid == 0:
        return 0
    val adjusted = (gid as i32 + cmap.id_deltas[seg]) & 0xFFFF
    adjusted as u32

fn sfnt_cmap_glyph_id(font: OtFont, codepoint: u32) -> u32:
    val maybe_format12 = parse_cmap_format12(font)
    match maybe_format12:
        case Some(cmap):
            val glyph = cmap12_lookup(cmap, codepoint)
            if glyph != 0:
                return glyph
        case None: ()
    val maybe_format4 = parse_cmap_format4(font)
    match maybe_format4:
        case Some(cmap):
            cmap_lookup(cmap, codepoint)
        case None:
            0
