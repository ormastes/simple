# SIMD Text FFI — extern declarations for SIMD-accelerated text operations
#
# These bridge to C runtime kernels in:
#   runtime_simd_utf8.c, runtime_simd_search.c,
#   runtime_simd_case.c, runtime_string_index.c

# UTF-8 counting and validation (SIMD-dispatched)
extern fn rt_text_count_codepoints_cached(s: text) -> i64
extern fn rt_text_is_ascii(s: text) -> bool
extern fn rt_text_validate_utf8(s: text) -> bool
extern fn rt_text_find_invalid_utf8(s: text) -> i64

# SIMD string search
extern fn rt_simd_str_search(haystack: text, needle: text) -> i64
extern fn rt_simd_str_equal(a: text, b: text) -> bool
extern fn rt_simd_str_last_index_of(haystack: text, needle: text) -> i64

# SIMD ASCII case conversion
extern fn rt_text_to_upper_ascii(s: text) -> text
extern fn rt_text_to_lower_ascii(s: text) -> text

# Segmented Width Index (SWI) — O(log B) codepoint random access
extern fn rt_swi_build(s: text) -> i64
extern fn rt_swi_char_to_byte(handle: i64, char_idx: i64) -> i64
extern fn rt_swi_byte_to_char(handle: i64, byte_idx: i64) -> i64
extern fn rt_swi_free(handle: i64)

# Rank/Select bit-vector — O(1) codepoint access for degenerate cases
extern fn rt_rank_select_build(s: text) -> i64
extern fn rt_rank_query(handle: i64, byte_pos: i64) -> i64
extern fn rt_select_query(handle: i64, char_idx: i64) -> i64
extern fn rt_rank_select_free(handle: i64)

export rt_text_count_codepoints_cached
export rt_text_is_ascii
export rt_text_validate_utf8
export rt_swi_build
export rt_swi_char_to_byte
export rt_swi_byte_to_char
export rt_swi_free
export rt_rank_select_build
export rt_rank_query
export rt_select_query
export rt_rank_select_free
