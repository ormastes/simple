# Mode-Aware Text Operations
#
# These functions respect the current CharMode setting.
# In Utf8 mode: operations work on bytes (fast, O(1) length).
# In FullUnicode mode: operations work on codepoints (correct, O(n) length).
#
# Usage:
#     use std.common.encoding.text_ops.{text_len_mode, text_char_at_mode, text_slice_mode}

use std.common.encoding.char_mode.{CharMode, char_mode, is_utf8_mode}
use std.common.encoding.utf8.{
    text_byte_len, text_codepoint_len, text_codepoints,
    utf8_seq_len, utf8_decode_one, utf8_encode_one
}

# ============================================================================
# Mode-aware length
# ============================================================================

fn text_len_mode(s: text) -> i64:
    """Return string length based on current CharMode.
    Utf8 mode: byte count (O(1)).
    FullUnicode mode: codepoint count (O(n))."""
    if is_utf8_mode():
        return text_byte_len(s)
    text_codepoint_len(s)

# ============================================================================
# Mode-aware character access
# ============================================================================

fn text_char_at_mode(s: text, idx: i64) -> text:
    """Get character at index based on current CharMode.
    Utf8 mode: idx is byte offset, returns single byte as text.
    FullUnicode mode: idx is codepoint index, returns full codepoint as text."""
    if is_utf8_mode():
        val byte_len = s.len()
        if idx < 0 or idx >= byte_len:
            return ""
        return s[idx:idx + 1]

    # FullUnicode mode: walk codepoints
    val bytes = s.bytes()
    var pos: i64 = 0
    var cp_idx: i64 = 0
    while pos < bytes.len():
        if cp_idx == idx:
            val seq_len = utf8_seq_len(bytes[pos])
            val end_pos = pos + (if seq_len > 0: seq_len else: 1)
            if end_pos > bytes.len():
                return ""
            return s[pos:end_pos]
        val seq_len = utf8_seq_len(bytes[pos])
        if seq_len <= 0:
            pos = pos + 1
        else:
            pos = pos + seq_len
        cp_idx = cp_idx + 1
    ""

# ============================================================================
# Mode-aware slicing
# ============================================================================

fn text_slice_mode(s: text, start: i64, end_idx: i64) -> text:
    """Slice string based on current CharMode.
    Utf8 mode: start/end_idx are byte offsets.
    FullUnicode mode: start/end_idx are codepoint indices."""
    if is_utf8_mode():
        val byte_len = s.len()
        var s_val = start
        var e_val = end_idx
        if s_val < 0:
            s_val = 0
        if e_val > byte_len:
            e_val = byte_len
        if s_val >= e_val:
            return ""
        return s[s_val:e_val]

    # FullUnicode mode: map codepoint indices to byte offsets
    val bytes = s.bytes()
    var pos: i64 = 0
    var cp_idx: i64 = 0
    var byte_start: i64 = -1
    var byte_end: i64 = -1

    while pos <= bytes.len() and (byte_start < 0 or byte_end < 0):
        if cp_idx == start:
            byte_start = pos
        if cp_idx == end_idx:
            byte_end = pos
        if pos >= bytes.len():
            break
        val seq_len = utf8_seq_len(bytes[pos])
        if seq_len <= 0:
            pos = pos + 1
        else:
            pos = pos + seq_len
        cp_idx = cp_idx + 1

    # Handle end-of-string cases
    if byte_start < 0:
        byte_start = bytes.len()
    if byte_end < 0:
        byte_end = bytes.len()
    if byte_start >= byte_end:
        return ""
    s[byte_start:byte_end]

# ============================================================================
# Mode-aware iteration
# ============================================================================

fn text_chars_mode(s: text) -> [text]:
    """Split text into individual characters based on current CharMode.
    Utf8 mode: each element is one byte.
    FullUnicode mode: each element is one codepoint (1-4 bytes)."""
    if is_utf8_mode():
        var result: [text] = []
        var i: i64 = 0
        while i < s.len():
            result.push(s[i:i+1])
            i = i + 1
        return result

    # FullUnicode mode: split by codepoint boundaries
    val bytes = s.bytes()
    var result: [text] = []
    var pos: i64 = 0
    while pos < bytes.len():
        val seq_len = utf8_seq_len(bytes[pos])
        val end_pos = pos + (if seq_len > 0: seq_len else: 1)
        val actual_end = if end_pos > bytes.len(): bytes.len() else: end_pos
        result.push(s[pos:actual_end])
        pos = actual_end
    result

# ============================================================================
# Codepoint width classification (for display/terminal width)
# ============================================================================

fn codepoint_display_width(cp: i64) -> i64:
    """Return the display width of a Unicode codepoint.
    0 for zero-width (combining marks, control chars).
    1 for narrow (Latin, Cyrillic, etc.).
    2 for wide (CJK, Hangul syllables, fullwidth forms)."""

    # Control characters and NULL
    if cp < 32:
        return 0
    if cp == 127:
        return 0  # DEL

    # Combining marks (general categories Mn, Mc, Me)
    # Combining Diacritical Marks
    if cp >= 0x0300 and cp <= 0x036F:
        return 0
    # Combining Diacritical Marks Extended
    if cp >= 0x1AB0 and cp <= 0x1AFF:
        return 0
    # Combining Diacritical Marks Supplement
    if cp >= 0x1DC0 and cp <= 0x1DFF:
        return 0
    # Combining Half Marks
    if cp >= 0xFE20 and cp <= 0xFE2F:
        return 0
    # Zero-width space, joiner, non-joiner
    if cp == 0x200B or cp == 0x200C or cp == 0x200D:
        return 0
    # Zero-width no-break space (BOM)
    if cp == 0xFEFF:
        return 0
    # Soft hyphen
    if cp == 0x00AD:
        return 0

    # East Asian Wide characters
    # CJK Unified Ideographs
    if cp >= 0x4E00 and cp <= 0x9FFF:
        return 2
    # CJK Unified Ideographs Extension A
    if cp >= 0x3400 and cp <= 0x4DBF:
        return 2
    # CJK Unified Ideographs Extension B
    if cp >= 0x20000 and cp <= 0x2A6DF:
        return 2
    # CJK Compatibility Ideographs
    if cp >= 0xF900 and cp <= 0xFAFF:
        return 2
    # Hangul Syllables
    if cp >= 0xAC00 and cp <= 0xD7AF:
        return 2
    # Hangul Jamo
    if cp >= 0x1100 and cp <= 0x115F:
        return 2
    if cp >= 0x2329 and cp <= 0x232A:
        return 2
    # CJK Symbols and Punctuation
    if cp >= 0x3000 and cp <= 0x303F:
        return 2
    # Hiragana
    if cp >= 0x3040 and cp <= 0x309F:
        return 2
    # Katakana
    if cp >= 0x30A0 and cp <= 0x30FF:
        return 2
    # Bopomofo
    if cp >= 0x3100 and cp <= 0x312F:
        return 2
    # Hangul Compatibility Jamo
    if cp >= 0x3130 and cp <= 0x318F:
        return 2
    # Kanbun
    if cp >= 0x3190 and cp <= 0x319F:
        return 2
    # Enclosed CJK Letters
    if cp >= 0x3200 and cp <= 0x32FF:
        return 2
    # CJK Compatibility
    if cp >= 0x3300 and cp <= 0x33FF:
        return 2
    # Fullwidth Forms
    if cp >= 0xFF01 and cp <= 0xFF60:
        return 2
    if cp >= 0xFFE0 and cp <= 0xFFE6:
        return 2

    # Default: narrow
    1

fn text_display_width(s: text) -> i64:
    """Return the total display width of a text string.
    Accounts for wide (CJK/Hangul) and zero-width characters."""
    val bytes = s.bytes()
    var width: i64 = 0
    var pos: i64 = 0
    while pos < bytes.len():
        val decoded = utf8_decode_one(bytes, pos)
        val cp = decoded[0]
        val consumed = decoded[1]
        width = width + codepoint_display_width(cp)
        if consumed <= 0:
            pos = pos + 1
        else:
            pos = pos + consumed
    width

# ============================================================================
# Script detection (basic — for font fallback)
# ============================================================================

enum UnicodeScript:
    Latin
    Cyrillic
    Arabic
    Devanagari
    Bengali
    Hangul
    CJK
    Common
    Unknown

fn codepoint_script(cp: i64) -> UnicodeScript:
    """Detect the script of a Unicode codepoint (simplified)."""
    # ASCII / Basic Latin
    if cp >= 0x0041 and cp <= 0x024F:
        return UnicodeScript.Latin
    # Latin Extended
    if cp >= 0x1E00 and cp <= 0x1EFF:
        return UnicodeScript.Latin
    # Cyrillic
    if cp >= 0x0400 and cp <= 0x052F:
        return UnicodeScript.Cyrillic
    # Arabic
    if cp >= 0x0600 and cp <= 0x06FF:
        return UnicodeScript.Arabic
    if cp >= 0x0750 and cp <= 0x077F:
        return UnicodeScript.Arabic
    if cp >= 0x08A0 and cp <= 0x08FF:
        return UnicodeScript.Arabic
    if cp >= 0xFB50 and cp <= 0xFDFF:
        return UnicodeScript.Arabic
    if cp >= 0xFE70 and cp <= 0xFEFF:
        return UnicodeScript.Arabic
    # Devanagari
    if cp >= 0x0900 and cp <= 0x097F:
        return UnicodeScript.Devanagari
    if cp >= 0xA8E0 and cp <= 0xA8FF:
        return UnicodeScript.Devanagari
    # Bengali
    if cp >= 0x0980 and cp <= 0x09FF:
        return UnicodeScript.Bengali
    # Hangul
    if cp >= 0xAC00 and cp <= 0xD7AF:
        return UnicodeScript.Hangul
    if cp >= 0x1100 and cp <= 0x11FF:
        return UnicodeScript.Hangul
    if cp >= 0x3130 and cp <= 0x318F:
        return UnicodeScript.Hangul
    if cp >= 0xA960 and cp <= 0xA97F:
        return UnicodeScript.Hangul
    if cp >= 0xD7B0 and cp <= 0xD7FF:
        return UnicodeScript.Hangul
    # CJK
    if cp >= 0x4E00 and cp <= 0x9FFF:
        return UnicodeScript.CJK
    if cp >= 0x3400 and cp <= 0x4DBF:
        return UnicodeScript.CJK
    if cp >= 0x20000 and cp <= 0x2A6DF:
        return UnicodeScript.CJK
    if cp >= 0x3040 and cp <= 0x30FF:
        return UnicodeScript.CJK  # Hiragana + Katakana
    if cp >= 0xF900 and cp <= 0xFAFF:
        return UnicodeScript.CJK
    # Common (numbers, punctuation, symbols)
    if cp < 0x0041:
        return UnicodeScript.Common
    if cp >= 0x2000 and cp <= 0x206F:
        return UnicodeScript.Common
    if cp >= 0x3000 and cp <= 0x303F:
        return UnicodeScript.Common
    UnicodeScript.Unknown
