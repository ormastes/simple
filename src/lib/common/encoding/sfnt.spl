# Neutral sfnt directory and default-instance TrueType validation.

use std.common.string_core.{char_from_code}
use std.common.encoding.utf16.{utf16_decode_one}

fn read_u16_be(buf: [u8], offset: i64) -> u32:
    if offset < 0 or offset + 1 >= buf.len(): return 0
    ((buf[offset] as u32) << 8) | (buf[offset + 1] as u32)

fn read_i16_be(buf: [u8], offset: i64) -> i32:
    val raw = read_u16_be(buf, offset)
    if raw >= 32768: (raw as i32) - 65536
    else: raw as i32

fn read_u32_be(buf: [u8], offset: i64) -> u32:
    if offset < 0 or offset + 3 >= buf.len(): return 0
    ((buf[offset] as u32) << 24) | ((buf[offset + 1] as u32) << 16) |
        ((buf[offset + 2] as u32) << 8) | (buf[offset + 3] as u32)

fn read_fixed_1616(buf: [u8], offset: i64) -> f64:
    val raw = read_u32_be(buf, offset) as i64
    val signed = if raw >= 2147483648: raw - 4294967296 else: raw
    signed as f64 / 65536.0

fn read_f2dot14(buf: [u8], offset: i64) -> f64:
    read_i16_be(buf, offset) as f64 / 16384.0

class OtTable:
    tag: u32
    offset: u32
    length: u32

class OtFont:
    blob: [u8]
    tables: [OtTable]

fn parse_offset_table(blob: [u8]) -> Option<OtFont>:
    if blob.len() < 12: return None
    val version = read_u32_be(blob, 0)
    if (version != 65536 and version != 1330926671 and
        version != 1953658213 and version != 1954115633): return None
    val table_count = read_u16_be(blob, 4) as i64
    if table_count > (blob.len() - 12) / 16: return None
    val directory_end = 12 + table_count * 16
    var tables: [OtTable] = []
    var index: i64 = 0
    while index < table_count:
        val record = 12 + index * 16
        val tag = read_u32_be(blob, record)
        val offset = read_u32_be(blob, record + 8)
        val length = read_u32_be(blob, record + 12)
        val start = offset as i64
        val size = length as i64
        if start > blob.len() or size > blob.len() - start: return None
        if size > 0 and start < directory_end: return None
        for existing in tables:
            if existing.tag == tag: return None
            val existing_start = existing.offset as i64
            val existing_size = existing.length as i64
            if (size > 0 and existing_size > 0 and start < existing_start + existing_size and
                existing_start < start + size): return None
        tables.push(OtTable(tag: tag, offset: offset, length: length))
        index = index + 1
    Some(OtFont(blob: blob, tables: tables))

fn find_table(font: OtFont, tag: u32) -> Option<OtTable>:
    for table in font.tables:
        if table.tag == tag: return Some(table)
    None

class FvarAxis:
    tag: u32
    min_value: f64
    default_value: f64
    max_value: f64

fn parse_fvar_axes(font: OtFont) -> [FvarAxis]:
    val maybe_table = find_table(font, 1719034226)
    val table = match maybe_table:
        Some(value): value
        None: return []
    val base = table.offset as i64
    val limit = base + table.length as i64
    val blob = font.blob
    if (table.length < 16 or read_u16_be(blob, base) != 1 or
        read_u16_be(blob, base + 2) != 0 or read_u16_be(blob, base + 6) != 2): return []
    val axes_offset = read_u16_be(blob, base + 4) as i64
    val axis_count = read_u16_be(blob, base + 8) as i64
    val axis_size = read_u16_be(blob, base + 10) as i64
    val instance_count = read_u16_be(blob, base + 12) as i64
    val instance_size = read_u16_be(blob, base + 14) as i64
    if axes_offset < 16 or axis_count < 1 or axis_size != 20: return []
    val axes_base = base + axes_offset
    if axes_base > limit or axis_count > (limit - axes_base) / axis_size: return []
    val instances_base = axes_base + axis_count * axis_size
    val minimum_instance_size = 4 + axis_count * 4
    if instance_size != minimum_instance_size and instance_size != minimum_instance_size + 2: return []
    if instances_base > limit or instance_count > (limit - instances_base) / instance_size: return []
    var axes: [FvarAxis] = []
    var index: i64 = 0
    while index < axis_count:
        val axis_base = axes_base + index * axis_size
        val tag = read_u32_be(blob, axis_base)
        val min_value = read_fixed_1616(blob, axis_base + 4)
        val default_value = read_fixed_1616(blob, axis_base + 8)
        val max_value = read_fixed_1616(blob, axis_base + 12)
        if tag == 0 or min_value > default_value or default_value > max_value: return []
        for axis in axes:
            if axis.tag == tag: return []
        axes.push(FvarAxis(tag: tag, min_value: min_value, default_value: default_value, max_value: max_value))
        index = index + 1
    axes

class SfntValidation:
    supported: bool
    reason: text

fn _sfnt_supported() -> SfntValidation:
    SfntValidation(supported: true, reason: "supported-default-glyf")

fn _sfnt_unsupported(reason: text) -> SfntValidation:
    SfntValidation(supported: false, reason: reason)

fn validate_default_glyf_font(blob: [u8]) -> SfntValidation:
    if read_u32_be(blob, 0) != 65536: return _sfnt_unsupported("unsupported-sfnt-version")
    val maybe_font = parse_offset_table(blob)
    val font = match maybe_font:
        Some(value): value
        None: return _sfnt_unsupported("invalid-sfnt-directory")
    val required: [u32] = [1735162214, 1819239265, 1751474532, 1835104368, 1668112752, 1751672161, 1752003704]
    for tag in required:
        val maybe_table = find_table(font, tag)
        match maybe_table:
            Some(table):
                if table.length == 0: return _sfnt_unsupported("empty-required-table")
            None: return _sfnt_unsupported("missing-required-table")
    val excluded: [u32] = [1128678944, 1128678962, 1129270354, 1129333068, 1398163232, 1128416340, 1128418371, 1161970772, 1161972803, 1161974595, 1935829368, 1650745716, 1651273571]
    # match instead of `Option != None` compares: Option-vs-None `==`/`!=` is
    # an unhealed marshalling sink on the native lane (this fn first executed
    # on baremetal 2026-07-18 once the name gate passed).
    for tag in excluded:
        match find_table(font, tag):
            Some(_): return _sfnt_unsupported("unsupported-sfnt-table")
            None: ()
    val has_fvar = match find_table(font, 1719034226):
        Some(_): true
        None: false
    if has_fvar and parse_fvar_axes(font).len() == 0:
        return _sfnt_unsupported("invalid-fvar-default")
    _sfnt_supported()

fn font_runtime_ttf_default_supported(blob: [u8]) -> bool:
    validate_default_glyf_font(blob).supported

fn _sfnt_tag_text(tag: u32) -> text:
    char_from_code(((tag >> 24) & 255) as i64) +
        char_from_code(((tag >> 16) & 255) as i64) +
        char_from_code(((tag >> 8) & 255) as i64) +
        char_from_code((tag & 255) as i64)

fn _sfnt_names_contain(names: [text], wanted: text) -> bool:
    for name in names:
        if name == wanted: return true
    false

fn sfnt_manifest_tables_match(blob: [u8], manifest: text) -> bool:
    val maybe_font = parse_offset_table(blob)
    val font = match maybe_font:
        Some(value): value
        None: return false
    val names = manifest.split(",")
    if names.len() != font.tables.len(): return false
    for table in font.tables:
        if not _sfnt_names_contain(names, _sfnt_tag_text(table.tag)): return false
    true

fn sfnt_manifest_default_axes_match(blob: [u8], manifest: text) -> bool:
    val maybe_font = parse_offset_table(blob)
    val font = match maybe_font:
        Some(value): value
        None: return false
    if find_table(font, 1719034226) == None: return manifest == "static"
    val axes = parse_fvar_axes(font)
    val defaults = manifest.split(",")
    if axes.len() == 0 or defaults.len() != axes.len(): return false
    for axis in axes:
        val integer = axis.default_value as i64
        val value = if integer as f64 == axis.default_value: integer.to_text() else: axis.default_value.to_text()
        if not _sfnt_names_contain(defaults, _sfnt_tag_text(axis.tag) + "=" + value): return false
    true

fn validate_glyf_font_instance(blob: [u8], requested_axes: text) -> SfntValidation:
    val format = validate_default_glyf_font(blob)
    if not format.supported: return format
    if not sfnt_manifest_default_axes_match(blob, requested_axes):
        return _sfnt_unsupported("unsupported-variation-instance")
    format

class SfntNameValue:
    name_id: i64
    value: text
    seen: bool
    valid: bool

    me add(candidate: text):
        if self.seen and self.value != candidate:
            self.valid = false
        else:
            self.value = candidate
            self.seen = true

# Local re-implementation of std.common.string_core.char_from_code, used only
# by _sfnt_utf16be_text below. ROOT CAUSE (host-reproduced on the seed
# `--native` backend, isolated to a 6-line repro): calling the cross-module
# std.common.encoding.utf16.utf16_decode_one immediately followed by the
# cross-module std.common.string_core.char_from_code corrupts
# char_from_code's returned text (len() reports -1, concatenation silently
# drops it) -- a text-return marshalling defect triggered specifically by
# THAT call sequence across THOSE two modules; char_from_code alone, or a
# same-file copy of its logic called right after utf16_decode_one, both
# return correct text. This is exactly the sequence _sfnt_utf16be_text uses
# per decoded character, so every decoded name-table string was built from
# corrupted/empty pieces. Kept file-local (mirrors the existing
# native-lane-workaround pattern in this file) instead of touching the
# shared std.common.string_core/utf16 modules, which are out of this lane's
# scope and other call sites (e.g. _sfnt_tag_text's char_from_code use)
# already work correctly in production serial evidence.
fn _sfnt_char_from_code(code: i64) -> text:
    if code == 9:
        return "\t"
    elif code == 10:
        return "\n"
    elif code == 11:
        return "\u000B"
    elif code == 12:
        return "\u000C"
    elif code == 13:
        return "\r"
    elif code >= 32 and code <= 126:
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        val index = code - 32
        return chars[index]
    ""

fn _sfnt_utf16be_text(blob: [u8], start: i64, length: i64) -> Option<text>:
    if length % 2 != 0: return None
    var units: [i64] = []
    var offset: i64 = 0
    while offset < length:
        units.push(read_u16_be(blob, start + offset) as i64)
        offset = offset + 2
    var result = ""
    var index: i64 = 0
    while index < units.len():
        val code_unit = units[index]
        if code_unit >= 0xD800 and code_unit <= 0xDBFF:
            if index + 1 >= units.len() or units[index + 1] < 0xDC00 or units[index + 1] > 0xDFFF:
                return None
        elif code_unit >= 0xDC00 and code_unit <= 0xDFFF:
            return None
        val decoded = utf16_decode_one(units, index)
        # `.chr()` has no working native-lane lowering (empty on baremetal).
        # `_sfnt_char_from_code` (file-local, NOT the cross-module
        # std.common.string_core.char_from_code) is required here: calling
        # utf16_decode_one immediately followed by the cross-module
        # char_from_code corrupts char_from_code's returned text under the
        # native backend (host-reproduced; see _sfnt_char_from_code doc
        # comment above). ASCII coverage suffices for name matching.
        val decoded_cp: i64 = decoded[0]
        val decoded_len: i64 = decoded[1]
        if decoded_len <= 0: return None
        val piece: text = _sfnt_char_from_code(decoded_cp)
        result = result + piece
        index = index + decoded_len
    Some(result)

fn _sfnt_selected_name(values: [SfntNameValue], primary: i64, fallback: i64) -> Option<text>:
    for value in values:
        if value.name_id == primary and value.seen:
            if not value.valid: return None
            return Some(value.value)
    for value in values:
        if value.name_id == fallback and value.seen:
            if not value.valid: return None
            return Some(value.value)
    None

fn _sfnt_collect_names(blob: [u8]) -> Option<[SfntNameValue]>:
    """Collect the Windows-platform English name-table entries used by the
    manifest matcher. None = structurally invalid name table."""
    val maybe_font = parse_offset_table(blob)
    val font = match maybe_font:
        Some(value): value
        None: return None
    val maybe_table = find_table(font, 1851878757)
    val table = match maybe_table:
        Some(value): value
        None: return None
    val base = table.offset as i64
    val limit = base + table.length as i64
    if table.length < 6 or read_u16_be(blob, base) != 0: return None
    val count = read_u16_be(blob, base + 2) as i64
    val records_end = base + 6 + count * 12
    val strings = base + read_u16_be(blob, base + 4) as i64
    if records_end > limit or strings < records_end or strings > limit: return None
    var values: [SfntNameValue] = []
    for name_id in [1, 2, 4, 5, 6, 16, 17]:
        values.push(SfntNameValue(name_id: name_id, value: "", seen: false, valid: true))
    var index: i64 = 0
    while index < count:
        val record = base + 6 + index * 12
        val length = read_u16_be(blob, record + 8) as i64
        val start = strings + read_u16_be(blob, record + 10) as i64
        if start > limit or length > limit - start: return None
        val platform = read_u16_be(blob, record)
        val encoding = read_u16_be(blob, record + 2)
        val language = read_u16_be(blob, record + 4)
        val name_id = read_u16_be(blob, record + 6) as i64
        if platform == 3 and (encoding == 1 or encoding == 10) and language == 0x0409:
            # Index-assign rebuild instead of `value.add(...)` on the loop
            # variable: under the freestanding native-build, struct iteration
            # yields VALUE COPIES, so the loop-var field mutation never
            # persisted into `values` — every entry stayed seen=false and the
            # name match failed with reason=names (same value-copy class as
            # the fb_driver back-buffer defect). `values[vi] = ...` in-place
            # assignment is the proven-persistent form.
            var vi: i64 = 0
            while vi < values.len():
                val existing = values[vi]
                val existing_name_id: i64 = existing.name_id
                if existing_name_id == name_id:
                    val decoded = _sfnt_utf16be_text(blob, start, length)
                    match decoded:
                        Some(candidate):
                            val was_seen = existing.seen
                            val prior_value: text = existing.value
                            val stays_valid = existing.valid
                            if was_seen and prior_value != candidate:
                                values[vi] = SfntNameValue(name_id: existing_name_id, value: prior_value, seen: was_seen, valid: false)
                            else:
                                values[vi] = SfntNameValue(name_id: existing_name_id, value: candidate, seen: true, valid: stays_valid)
                        None: return None
                vi = vi + 1
        index = index + 1
    Some(values)

fn sfnt_debug_selected_names(blob: [u8]) -> text:
    """Diagnostic: the five manifest-matched name selections as one line.
    '<collect-fail>' = structurally invalid table; '<none>' = entry missing."""
    val collected = _sfnt_collect_names(blob)
    val values = match collected:
        Some(v): v
        None: return "<collect-fail>"
    # Fixed-index while-loop instead of `for pair in [(16,1),(17,2),...]:`
    # over an inline array-of-tuples literal (H1 hardening): this file's
    # other native-lane defects (see _sfnt_collect_names, _sfnt_char_from_code
    # above) are all in the same "array/struct iteration variable on the
    # native backend" class, and the boot symptom (all five slots return
    # nameID 5's value -- the LAST pair in the literal) is exactly the
    # fingerprint of a for-loop that binds its iteration variable to the
    # final element on every pass. Not host-reproduced on seed --native
    # (wrong backend: boot is freestanding x86_64-unknown-simpleos), so this
    # is defensive hardening pending QEMU-boot confirmation, not a proven fix
    # -- kept behavior-identical on the interpreter (see sfnt_spec.spl).
    var out = ""
    val primaries: [i64] = [16, 17, 4, 6, 5]
    val fallbacks: [i64] = [1, 2, -1, -1, -1]
    var pi: i64 = 0
    while pi < primaries.len():
        val primary: i64 = primaries[pi]
        val fallback: i64 = fallbacks[pi]
        val sel = _sfnt_selected_name(values, primary, fallback)
        val piece: text = match sel:
            Some(v): v
            None: "<none>"
        out = out + "|" + piece
        pi = pi + 1
    out

fn sfnt_debug_collected_values(blob: [u8]) -> text:
    """Diagnostic for the H1 (loop-selection) vs H2 (storage-aliasing) split
    on a real boot: dumps every collected name_id/seen/valid/value, one
    'id=..,seen=..,valid=..,value=..' group per ';'. If every id's value
    differs appropriately (family/style/full/postscript/version look
    distinct) collection is fine and the bug is in selection (H1). If every
    id's value is the SAME (e.g. all equal the version string), the bug is
    in storage/aliasing inside _sfnt_collect_names (H2). Not wired into any
    boot entry point by this change -- callers add the serial_println."""
    val collected = _sfnt_collect_names(blob)
    val values = match collected:
        Some(v): v
        None: return "<collect-fail>"
    var out = ""
    var vi: i64 = 0
    while vi < values.len():
        val entry = values[vi]
        val nid: i64 = entry.name_id
        val seen: bool = entry.seen
        val valid: bool = entry.valid
        val value: text = entry.value
        out = out + ";id=" + nid.to_text() + ",seen=" + seen.to_text() + ",valid=" + valid.to_text() + ",value=" + value
        vi = vi + 1
    out

fn sfnt_manifest_names_match(blob: [u8], family: text, style: text, full_name: text,
                             postscript_name: text, version: text) -> bool:
    # Compare via the same joined-line path as sfnt_debug_selected_names: the
    # previous per-field form (`selected_x == None` then `.unwrap() == arg`)
    # returned false on the freestanding native lane even when every field
    # decoded byte-exact (in-guest proof: `font names decoded=` printed the
    # exact expected line while this matcher said no). Option-vs-None `==` and
    # unwrap-then-compare are the known-unhealed marshalling sinks; a single
    # text == text on identically-constructed (concat-built) lines avoids both.
    # Missing/invalid entries surface as "<none>"/"<collect-fail>", which can
    # never equal an expected line, preserving the reject semantics.
    val decoded_line: text = sfnt_debug_selected_names(blob)
    val expected_line: text = "|" + family + "|" + style + "|" + full_name + "|" +
        postscript_name + "|" + version
    decoded_line == expected_line
