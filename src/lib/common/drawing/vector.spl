# Vector Elements — paths, shapes, text for vector layers
#
# Provides geometric primitives and vector drawing elements
# used by the drawing document's vector layers.

# ============================================================================
# SkPoint — 2D point
# ============================================================================

struct SkPoint:
    x: f64
    y: f64

impl SkPoint:
    static fn zero() -> SkPoint:
        SkPoint(x: 0.0, y: 0.0)

    fn distance_to(self, other: SkPoint) -> f64:
        """Euclidean distance to another point."""
        val dx = other.x - self.x
        val dy = other.y - self.y
        val sq = dx * dx + dy * dy
        sq ** 0.5

# ============================================================================
# SkRect — axis-aligned rectangle
# ============================================================================

struct SkRect:
    x: f64
    y: f64
    width: f64
    height: f64

impl SkRect:
    static fn from_xywh(x: f64, y: f64, w: f64, h: f64) -> SkRect:
        SkRect(x: x, y: y, width: w, height: h)

    fn contains_point(self, px: f64, py: f64) -> bool:
        """Check whether a point falls inside this rectangle."""
        (px >= self.x and px <= self.x + self.width and
         py >= self.y and py <= self.y + self.height)

    fn center(self) -> SkPoint:
        SkPoint(x: self.x + self.width / 2.0, y: self.y + self.height / 2.0)

# ============================================================================
# Stroke and Fill styles
# ============================================================================

struct StrokeStyle:
    color: i64
    width: f64

struct FillStyle:
    color: i64

# ============================================================================
# PathPoint — cubic bezier control point
# ============================================================================

struct PathPoint:
    position: SkPoint
    control_in_x: f64
    control_in_y: f64
    control_out_x: f64
    control_out_y: f64
    has_controls: bool

impl PathPoint:
    static fn linear(pos: SkPoint) -> PathPoint:
        """A path point with no control handles (straight segment)."""
        PathPoint(
            position: pos,
            control_in_x: 0.0,
            control_in_y: 0.0,
            control_out_x: 0.0,
            control_out_y: 0.0,
            has_controls: false
        )

    static fn cubic(pos: SkPoint, in_x: f64, in_y: f64, out_x: f64, out_y: f64) -> PathPoint:
        """A path point with cubic bezier control handles."""
        PathPoint(
            position: pos,
            control_in_x: in_x,
            control_in_y: in_y,
            control_out_x: out_x,
            control_out_y: out_y,
            has_controls: true
        )

# ============================================================================
# Matrix3x3 — 2D affine transform
# ============================================================================

struct Matrix3x3:
    m00: f64
    m01: f64
    m02: f64
    m10: f64
    m11: f64
    m12: f64
    m20: f64
    m21: f64
    m22: f64

impl Matrix3x3:
    static fn identity() -> Matrix3x3:
        Matrix3x3(
            m00: 1.0, m01: 0.0, m02: 0.0,
            m10: 0.0, m11: 1.0, m12: 0.0,
            m20: 0.0, m21: 0.0, m22: 1.0
        )

# ============================================================================
# VectorElement — drawable vector primitives
# ============================================================================

enum VectorElement:
    Path(points: [PathPoint], stroke: StrokeStyle, has_fill: bool, fill: FillStyle)
    RectShape(rect: SkRect, stroke: StrokeStyle, has_fill: bool, fill: FillStyle)
    EllipseShape(center: SkPoint, rx: f64, ry: f64, stroke: StrokeStyle, has_fill: bool, fill: FillStyle)
    TextElement(pos: SkPoint, content: text, font_size: i32, color: i64)
    Group(children: [VectorElement], transform: Matrix3x3)

impl VectorElement:
    fn element_type(self) -> text:
        """Return a human-readable type name for this element."""
        match self:
            case Path: "path"
            case RectShape: "rect"
            case EllipseShape: "ellipse"
            case TextElement: "text"
            case Group: "group"
