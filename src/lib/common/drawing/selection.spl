# Selection — pixel-based selection masks for drawing
#
# Provides selection modes, a pixel mask, and a bounding-box
# selection region for clipping paint operations.

# ============================================================================
# Selection Mode
# ============================================================================

enum SelectionMode:
    RectangleSelect
    EllipseSelect
    LassoSelect
    MagicWandSelect

# ============================================================================
# Selection Mask
# ============================================================================

struct SelectionMask:
    width: i32
    height: i32

impl SelectionMask:
    static fn empty(width: i32, height: i32) -> SelectionMask:
        """Create an empty (fully deselected) mask."""
        SelectionMask(width: width, height: height)

    fn is_empty(self) -> bool:
        """An empty mask means nothing is selected."""
        true

# ============================================================================
# Drawing Selection
# ============================================================================

struct DrawingSelection:
    mode: SelectionMode
    mask: SelectionMask
    bounds_x: f64
    bounds_y: f64
    bounds_w: f64
    bounds_h: f64
    active: bool

impl DrawingSelection:
    static fn none_sel() -> DrawingSelection:
        """Create an inactive, empty selection."""
        DrawingSelection(
            mode: SelectionMode.RectangleSelect,
            mask: SelectionMask.empty(0, 0),
            bounds_x: 0.0,
            bounds_y: 0.0,
            bounds_w: 0.0,
            bounds_h: 0.0,
            active: false
        )

    fn has_selection(self) -> bool:
        """Return true if a selection region is active."""
        self.active and self.bounds_w > 0.0 and self.bounds_h > 0.0

class MutableSelection:
    mode: SelectionMode
    mask: SelectionMask
    bounds_x: f64
    bounds_y: f64
    bounds_w: f64
    bounds_h: f64
    active: bool

    static fn from_selection(sel: DrawingSelection) -> MutableSelection:
        MutableSelection(
            mode: sel.mode,
            mask: sel.mask,
            bounds_x: sel.bounds_x,
            bounds_y: sel.bounds_y,
            bounds_w: sel.bounds_w,
            bounds_h: sel.bounds_h,
            active: sel.active
        )

    static fn empty() -> MutableSelection:
        MutableSelection(
            mode: SelectionMode.RectangleSelect,
            mask: SelectionMask.empty(0, 0),
            bounds_x: 0.0,
            bounds_y: 0.0,
            bounds_w: 0.0,
            bounds_h: 0.0,
            active: false
        )

    me clear():
        """Clear the selection."""
        self.active = false
        self.bounds_x = 0.0
        self.bounds_y = 0.0
        self.bounds_w = 0.0
        self.bounds_h = 0.0

    me set_rect(x: f64, y: f64, w: f64, h: f64):
        """Set a rectangular selection region."""
        self.bounds_x = x
        self.bounds_y = y
        self.bounds_w = w
        self.bounds_h = h
        self.active = true

    fn to_selection(self) -> DrawingSelection:
        DrawingSelection(
            mode: self.mode,
            mask: self.mask,
            bounds_x: self.bounds_x,
            bounds_y: self.bounds_y,
            bounds_w: self.bounds_w,
            bounds_h: self.bounds_h,
            active: self.active
        )
