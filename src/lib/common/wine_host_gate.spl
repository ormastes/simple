"""Wine host-substrate readiness gate for non-VM/non-renderer services."""

pub fn wine_host_required_features() -> [text]:
    [
        "fd-table",
        "stdio",
        "pipes",
        "sockets",
        "poll-wait",
        "timers",
        "errno",
        "cwd-env-argv",
        "spawn",
        "fs-paths",
        "fs-attrs",
        "fs-locks",
        "ipc-server",
        "handle-table",
        "pthread",
        "tls",
        "mutex",
        "condvar",
        "semaphore",
        "event",
        "dynload",
        "audio",
        "fonts",
        "crypto",
        "hid",
        "printing",
        "multimedia"
    ]

pub fn wine_host_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in wine_host_required_features():
        if not features.contains(feature):
            missing.push(feature)
    return missing

pub fn wine_host_gate(features: text) -> text:
    val missing = wine_host_missing_features(features)
    if missing.len() == 0:
        return "ready"
    return "missing-" + missing[0]

pub fn wine_thread_gate(features: text) -> text:
    if not features.contains("pthread"):
        return "missing-pthread"
    if not features.contains("tls"):
        return "missing-tls"
    if not features.contains("mutex"):
        return "missing-mutex"
    if not features.contains("condvar"):
        return "missing-condvar"
    if not features.contains("semaphore"):
        return "missing-semaphore"
    if not features.contains("event"):
        return "missing-event"
    if not features.contains("thread-fault"):
        return "missing-thread-fault"
    return "ready"

pub fn wine_posix_gate(features: text) -> text:
    if not features.contains("fd-table"):
        return "missing-fd-table"
    if not features.contains("stdio"):
        return "missing-stdio"
    if not features.contains("pipes"):
        return "missing-pipes"
    if not features.contains("sockets"):
        return "missing-sockets"
    if not features.contains("poll-wait"):
        return "missing-poll-wait"
    if not features.contains("timers"):
        return "missing-timers"
    if not features.contains("errno"):
        return "missing-errno"
    if not features.contains("cwd-env-argv"):
        return "missing-cwd-env-argv"
    if not features.contains("spawn"):
        return "missing-spawn"
    return "ready"

pub fn wine_dynamic_gate(features: text) -> text:
    if not features.contains("dynload"):
        return "missing-dynload"
    if not features.contains("symbol-lookup"):
        return "missing-symbol-lookup"
    if not features.contains("relocation"):
        return "missing-relocation"
    if not features.contains("loader-errors"):
        return "missing-loader-errors"
    return "ready"

