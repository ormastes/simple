"""
# Strong Parameters

Whitelist permitted fields from request parameters, inspired by
Rails strong parameters. Prevents mass-assignment vulnerabilities
by filtering out unpermitted keys.

## Usage

```simple
val sp = StrongParams.permit(["name", "email", "age"])
val filtered = sp.filter(request_params)
# filtered only contains "name", "email", "age" keys

val email = sp.require(request_params, "email")
match email:
    Ok(val): print "Email: {val}"
    Err(msg): print "Missing: {msg}"
```
"""

# ============================================================================
# StrongParams
# ============================================================================

class StrongParams:
    """Whitelist-based parameter filter.

    Prevents mass-assignment by only allowing explicitly
    permitted fields through.
    """
    permitted: [text]

impl StrongParams:
    static fn permit(fields: [text]) -> StrongParams:
        """Create a StrongParams that permits the given fields.

        Args:
            fields: List of field names to allow

        Returns:
            StrongParams instance
        """
        StrongParams(permitted: fields)

    fn filter(params: Dict<text, text>) -> Dict<text, text>:
        """Filter params to only include permitted fields.

        Args:
            params: Raw request parameters

        Returns:
            Dict containing only permitted keys that exist in params
        """
        var result: Dict<text, text> = {}
        for field in self.permitted:
            val value = params.get(field)
            if value != nil:
                result[field] = value ?? ""
        result

    fn require(params: Dict<text, text>, field: text) -> Result<text, text>:
        """Require a specific field to be present and non-empty.

        Args:
            params: Raw request parameters
            field: Field name that must be present

        Returns:
            Ok(value) if present and non-empty, Err(message) otherwise
        """
        # Check if field is in permitted list
        var is_permitted = false
        for f in self.permitted:
            if f == field:
                is_permitted = true
        if not is_permitted:
            return Err("Field '{field}' is not permitted")

        val value = params.get(field)
        if value == nil:
            return Err("Field '{field}' is required but missing")

        val v = value ?? ""
        if v.len() == 0:
            return Err("Field '{field}' is required but empty")

        Ok(v)

    fn require_all(params: Dict<text, text>) -> Result<Dict<text, text>, text>:
        """Require all permitted fields to be present and non-empty.

        Returns:
            Ok(filtered_params) if all present, Err(message) with first missing field
        """
        var result: Dict<text, text> = {}
        for field in self.permitted:
            val value = params.get(field)
            if value == nil:
                return Err("Field '{field}' is required but missing")
            val v = value ?? ""
            if v.len() == 0:
                return Err("Field '{field}' is required but empty")
            result[field] = v
        Ok(result)

    fn has_field(field: text) -> bool:
        """Check if a field is in the permitted list."""
        for f in self.permitted:
            if f == field:
                return true
        false

# ============================================================================
# Convenience Functions
# ============================================================================

fn permit_and_filter(params: Dict<text, text>, fields: [text]) -> Dict<text, text>:
    """One-shot permit and filter.

    Args:
        params: Raw request parameters
        fields: List of permitted field names

    Returns:
        Filtered parameter dict
    """
    val sp = StrongParams.permit(fields)
    sp.filter(params)

fn merge_params(base: Dict<text, text>, overlay: Dict<text, text>) -> Dict<text, text>:
    """Merge two parameter dicts. Overlay values win on conflict.

    Args:
        base: Base parameters (e.g., route params)
        overlay: Override parameters (e.g., query params)

    Returns:
        Merged parameter dict
    """
    var result: Dict<text, text> = {}
    for key in base.keys():
        result[key] = base.get(key) ?? ""
    for key in overlay.keys():
        result[key] = overlay.get(key) ?? ""
    result
