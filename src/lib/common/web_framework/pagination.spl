"""
# Pagination

Pagination utilities for dividing query results into pages.
Provides offset calculation, total page count, and navigation helpers.

## Usage

```simple
val total_items = repo.count()?
val paginator = paginator_new(page: 2, per_page: 25, total: total_items)

val items = repo.find_all_offset(paginator.offset(), paginator.per_page)
val total_pages = paginator.total_pages()
val html = paginator_to_html(paginator, "/items")
```
"""

# ============================================================================
# Paginator
# ============================================================================

class Paginator:
    """Pagination state and calculation.

    Tracks current page, items per page, and total item count.
    Computes offsets, total pages, and prev/next availability.
    """
    page: i64
    per_page: i64
    total: i64

impl Paginator:
    static fn new(page: i64, per_page: i64, total: i64) -> Paginator:
        """Create a new paginator.

        Args:
            page: Current page number (1-based)
            per_page: Number of items per page
            total: Total number of items

        Returns:
            Paginator instance (clamped to valid range)
        """
        var p = page
        if p < 1:
            p = 1
        var pp = per_page
        if pp < 1:
            pp = 10
        Paginator(page: p, per_page: pp, total: total)

    fn offset() -> i64:
        """Calculate the SQL OFFSET for the current page.

        Returns:
            Number of items to skip (0-based)
        """
        (self.page - 1) * self.per_page

    fn total_pages() -> i64:
        """Calculate total number of pages.

        Returns:
            Total pages (at least 1)
        """
        if self.total <= 0:
            return 1
        val pages = (self.total + self.per_page - 1) / self.per_page
        if pages < 1:
            return 1
        pages

    fn has_next() -> bool:
        """Check if there is a next page."""
        self.page < self.total_pages()

    fn has_prev() -> bool:
        """Check if there is a previous page."""
        self.page > 1

    fn next_page() -> i64:
        """Get the next page number (clamped to total_pages)."""
        val np = self.page + 1
        val tp = self.total_pages()
        if np > tp:
            return tp
        np

    fn prev_page() -> i64:
        """Get the previous page number (clamped to 1)."""
        val pp = self.page - 1
        if pp < 1:
            return 1
        pp

    fn is_first_page() -> bool:
        """Check if this is the first page."""
        self.page <= 1

    fn is_last_page() -> bool:
        """Check if this is the last page."""
        self.page >= self.total_pages()

    fn page_range() -> [i64]:
        """Get a range of page numbers for navigation.

        Returns up to 7 page numbers centered around current page.
        """
        val tp = self.total_pages()
        var start = self.page - 3
        if start < 1:
            start = 1
        var end_page = start + 6
        if end_page > tp:
            end_page = tp
            start = end_page - 6
            if start < 1:
                start = 1

        var pages: [i64] = []
        var i = start
        while i <= end_page:
            pages.push(i)
            i = i + 1
        pages

# ============================================================================
# Paged Result
# ============================================================================

class PagedResult<T>:
    """A page of results with pagination metadata."""
    items: [T]
    paginator: Paginator

# ============================================================================
# HTML Helpers
# ============================================================================

fn paginator_to_html(p: Paginator, base_url: text) -> text:
    """Render pagination navigation as HTML.

    Args:
        p: Paginator with current state
        base_url: Base URL for page links (e.g., "/items")

    Returns:
        HTML nav element with pagination links
    """
    val tp = p.total_pages()
    if tp <= 1:
        return ""

    var parts: [text] = []
    parts.push("<nav class=\"pagination\">")

    # Previous link
    if p.has_prev():
        parts.push("  <a href=\"{base_url}?page={p.prev_page()}\" class=\"page-prev\">&laquo; Prev</a>")
    else:
        parts.push("  <span class=\"page-prev disabled\">&laquo; Prev</span>")

    # Page numbers
    val pages = p.page_range()
    for pg in pages:
        if pg == p.page:
            parts.push("  <span class=\"page-current\">{pg}</span>")
        else:
            parts.push("  <a href=\"{base_url}?page={pg}\" class=\"page-link\">{pg}</a>")

    # Next link
    if p.has_next():
        parts.push("  <a href=\"{base_url}?page={p.next_page()}\" class=\"page-next\">Next &raquo;</a>")
    else:
        parts.push("  <span class=\"page-next disabled\">Next &raquo;</span>")

    parts.push("</nav>")
    parts.join("\n")

fn parse_page_param(query: text) -> i64:
    """Extract page number from query string.

    Looks for `page=N` in the query string. Defaults to 1.

    Args:
        query: Raw query string (e.g., "page=3&sort=name")

    Returns:
        Page number (1 if not found or invalid)
    """
    val pairs = query.split("&")
    for pair in pairs:
        val eq_pos = pair.index_of("=")
        if eq_pos > 0:
            val key = pair[0:eq_pos]
            if key == "page":
                val val_str = pair[eq_pos + 1:]
                val page_num = val_str.to_i64() ?? 1
                if page_num < 1:
                    return 1
                return page_num
    1
