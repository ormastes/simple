"""
# Route Types

Route method enum, route entry definitions, and RESTful resource
route generation. Used by the router to match incoming requests
to controller actions.

## RESTful Routes

`resource_routes("posts")` generates:

| Method | Pattern           | Controller | Action  |
|--------|-------------------|------------|---------|
| GET    | /posts            | posts      | index   |
| GET    | /posts/new        | posts      | new     |
| POST   | /posts            | posts      | create  |
| GET    | /posts/:id        | posts      | show    |
| GET    | /posts/:id/edit   | posts      | edit    |
| PUT    | /posts/:id        | posts      | update  |
| DELETE | /posts/:id        | posts      | destroy |
"""

# ============================================================================
# Route Method
# ============================================================================

enum RouteMethod:
    """HTTP method for route matching."""
    GET
    POST
    PUT
    DELETE
    PATCH
    HEAD
    OPTIONS
    ANY

fn method_to_text(m: RouteMethod) -> text:
    """Convert RouteMethod to HTTP method string."""
    match m:
        RouteMethod.GET: "GET"
        RouteMethod.POST: "POST"
        RouteMethod.PUT: "PUT"
        RouteMethod.DELETE: "DELETE"
        RouteMethod.PATCH: "PATCH"
        RouteMethod.HEAD: "HEAD"
        RouteMethod.OPTIONS: "OPTIONS"
        RouteMethod.ANY: "*"

fn text_to_method(s: text) -> RouteMethod:
    """Parse HTTP method string to RouteMethod."""
    val upper = s.to_upper()
    match upper:
        "GET": RouteMethod.GET
        "POST": RouteMethod.POST
        "PUT": RouteMethod.PUT
        "DELETE": RouteMethod.DELETE
        "PATCH": RouteMethod.PATCH
        "HEAD": RouteMethod.HEAD
        "OPTIONS": RouteMethod.OPTIONS
        "*": RouteMethod.ANY
        _: RouteMethod.GET

# ============================================================================
# Route Entry
# ============================================================================

class RouteEntry:
    """A single route mapping method+pattern to controller#action."""
    method: RouteMethod
    pattern: text
    controller_name: text
    action_name: text
    middlewares: [text]

class RouteMatch:
    """Result of a successful route match."""
    route: RouteEntry
    params: Dict<text, text>

# ============================================================================
# RESTful Resource Routes
# ============================================================================

fn resource_routes(name: text) -> [RouteEntry]:
    """Generate 7 RESTful routes for a resource.

    Args:
        name: Resource name (plural, e.g., "posts")

    Returns:
        List of 7 RouteEntry objects for full CRUD
    """
    [
        RouteEntry(
            method: RouteMethod.GET,
            pattern: "/{name}",
            controller_name: name,
            action_name: "index",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.GET,
            pattern: "/{name}/new",
            controller_name: name,
            action_name: "new",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.POST,
            pattern: "/{name}",
            controller_name: name,
            action_name: "create",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.GET,
            pattern: "/{name}/:id",
            controller_name: name,
            action_name: "show",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.GET,
            pattern: "/{name}/:id/edit",
            controller_name: name,
            action_name: "edit",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.PUT,
            pattern: "/{name}/:id",
            controller_name: name,
            action_name: "update",
            middlewares: []
        ),
        RouteEntry(
            method: RouteMethod.DELETE,
            pattern: "/{name}/:id",
            controller_name: name,
            action_name: "destroy",
            middlewares: []
        )
    ]

# ============================================================================
# Route Pattern Matching
# ============================================================================

fn match_pattern(pattern: text, path: text) -> Dict<text, text>?:
    """Match a URL path against a route pattern.

    Patterns use `:name` for named parameters.
    e.g., `/posts/:id` matches `/posts/42` with params {"id": "42"}

    Args:
        pattern: Route pattern (e.g., "/posts/:id")
        path: Actual request path (e.g., "/posts/42")

    Returns:
        Dict of extracted params if match, nil otherwise
    """
    val pattern_parts = split_path(pattern)
    val path_parts = split_path(path)

    if pattern_parts.len() != path_parts.len():
        return nil

    var params: Dict<text, text> = {}
    var i = 0
    while i < pattern_parts.len():
        val pp = pattern_parts[i]
        val rp = path_parts[i]

        if pp.starts_with(":"):
            # Named parameter
            val param_name = pp[1:]
            params[param_name] = rp
        elif pp == "*":
            # Wildcard (matches anything)
            pass_do_nothing
        elif pp != rp:
            # Literal mismatch
            return nil
        i = i + 1

    Some(params)

fn split_path(path: text) -> [text]:
    """Split a URL path into segments, removing empty parts.

    Args:
        path: URL path (e.g., "/posts/42/edit")

    Returns:
        List of path segments (e.g., ["posts", "42", "edit"])
    """
    val parts = path.split("/")
    var result: [text] = []
    for part in parts:
        if part.len() > 0:
            result.push(part)
    result

fn methods_match(route_method: RouteMethod, request_method: text) -> bool:
    """Check if a route method matches a request method.

    RouteMethod.ANY matches all methods.
    """
    match route_method:
        RouteMethod.ANY: true
        _: method_to_text(route_method) == request_method.to_upper()

# ============================================================================
# Namespace Prefixing
# ============================================================================

fn prefix_routes(prefix: text, routes: [RouteEntry]) -> [RouteEntry]:
    """Add a prefix to all route patterns.

    Args:
        prefix: URL prefix (e.g., "/api/v1")
        routes: Routes to prefix

    Returns:
        New list of routes with prefixed patterns
    """
    var result: [RouteEntry] = []
    for route in routes:
        val new_pattern = "{prefix}{route.pattern}"
        result.push(RouteEntry(
            method: route.method,
            pattern: new_pattern,
            controller_name: route.controller_name,
            action_name: route.action_name,
            middlewares: route.middlewares
        ))
    result
