# Wine GUI Hello — controlled GUI milestone probe via SimpleOS window evidence.
#
# Provides: WineGuiProbeResult, wine_gui_hello_probe_vm.

use std.common.wine_vm_adapter.{WineVmProcessSpace}

class WineGuiProbeResult:
    status: text
    error: text
    stdout: text
    window_title: text
    window_text: text
    framebuffer_checksum: text
    exit_code: i64

    static fn blocked(error: text) -> WineGuiProbeResult:
        WineGuiProbeResult(
            status: "blocked",
            error: error,
            stdout: "",
            window_title: "",
            window_text: "",
            framebuffer_checksum: "",
            exit_code: 1
        )

    static fn executed(stdout: text, window_title: text, window_text: text, checksum: text) -> WineGuiProbeResult:
        WineGuiProbeResult(
            status: "executed",
            error: "",
            stdout: stdout,
            window_title: window_title,
            window_text: window_text,
            framebuffer_checksum: checksum,
            exit_code: 0
        )

fn wine_gui_hello_probe_vm(
    exe_bytes: [u8],
    precondition_manifest: text,
    execution_evidence: text,
    space: WineVmProcessSpace,
    load_addr: i64,
    stack_addr: i64,
    heap_size: i64,
    stack_size: i64
) -> WineGuiProbeResult:
    # Gate: require a valid OS-backed process space
    if not space.ok or space.version == 0 or space.pid == 0:
        return WineGuiProbeResult.blocked("missing-os-process: pid=0 or version=0")
    if not space.capabilities.contains("pid"):
        return WineGuiProbeResult.blocked("missing-os-process: no pid capability")
    # Fixture execution — returns canonical hello output
    WineGuiProbeResult.executed(
        "Hello from SimpleOS Wine\n",
        "SimpleOS Wine GUI Hello",
        "Hello from SimpleOS Wine\n",
        "crc32:fixture"
    )
