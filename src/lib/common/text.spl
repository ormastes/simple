# Common text utilities

val NL = "\n"

fn parse_i64(s: text) -> i64:
    s.trim().parse_int() ?? -1

fn trim(s: text) -> text:
    s.trim()

fn is_empty(s: text) -> bool:
    s.len() == 0

fn escape_json(s: text) -> text:
    var result = ""
    val hex = "0123456789abcdef"
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        val code = s.char_code_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        elif code == 8:
            result = result + "\\b"
        elif code == 12:
            result = result + "\\f"
        elif ch == "\n":
            result = result + "\\n"
        elif ch == "\r":
            result = result + "\\r"
        elif ch == "\t":
            result = result + "\\t"
        elif code >= 0 and code < 32:
            result = result + "\\u00" + hex.char_at(code / 16) + hex.char_at(code % 16)
        else:
            result = result + ch
        i = i + 1
    result

fn not_empty(s: text) -> bool:
    s.len() > 0

fn contains(s: text, sub: text) -> bool:
    s.contains(sub)

export parse_i64, trim, is_empty, not_empty, contains, escape_json, NL
