# Common text utilities

val NL = "\n"

fn parse_i64(s: text) -> i64:
    s.trim().parse_int() ?? -1

fn trim(s: text) -> text:
    s.trim()

fn is_empty(s: text) -> bool:
    s.len() == 0

fn escape_json(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\"":
            result = result + "\\\""
        elif ch == "\\":
            result = result + "\\\\"
        elif ch == "\n":
            result = result + "\\n"
        elif ch == "\r":
            result = result + "\\r"
        elif ch == "\t":
            result = result + "\\t"
        else:
            result = result + ch
        i = i + 1
    result

export parse_i64, trim, is_empty, escape_json, NL
