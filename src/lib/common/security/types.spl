# Security Types — events, audit entries, and configuration for security logging.
#
# Provides: SecurityEvent, AuditEntry, AuditConfig, SecuritySeverity, SecurityContext.

enum SecuritySeverity:
    Debug
    Info
    Warn
    Error
    Critical

# Structured security event variants.
enum SecurityEvent:
    AccessDenied(resource: text, capability: text, peer: text)
    AuthFailure(user: text, reason: text)
    PrivilegeEscalation(subject: text, attempted_level: text)
    AnomalyDetected(description: text)

# A single audit log entry.
class AuditEntry:
    event: SecurityEvent
    correlation_id: text
    module_path: text
    severity: SecuritySeverity

impl AuditEntry:
    static fn new(event: SecurityEvent, correlation_id: text, module_path: text) -> AuditEntry:
        AuditEntry(
            event: event,
            correlation_id: correlation_id,
            module_path: module_path,
            severity: SecuritySeverity.Info)

# Configuration for the audit logger.
struct AuditConfig:
    enabled: bool
    log_file: text
    log_to_stdout: bool
    min_severity: SecuritySeverity
    mask_secrets: bool

impl AuditConfig:
    static fn default() -> AuditConfig:
        AuditConfig(
            enabled: true,
            log_file: "tmp/security_audit.log",
            log_to_stdout: false,
            min_severity: SecuritySeverity.Info,
            mask_secrets: true)

# Runtime security context carried with a request.
struct SecurityContext:
    principal_id: text
    session_id: text
    remote_addr: text
