# AOP validation advice — woven at matched join points by the MDSOC weaving engine.
#
# These functions are NOT called directly by business code.
# The capsule.sdn weaving rules inject them at compile time.

use std.security.sanitize.{sanitize_html, is_path_traversal, sanitize_path}
use std.security.types.{SecurityEvent, AuditEntry, AuditConfig}
use std.security.audit_log.{log_security_event}
use compiler.mdsoc.weaving.join_point.{JoinPointContext}

## Around advice that sanitizes HTML output from render functions.
##
## Calls proceed() to get the raw render output, then passes it through
## sanitize_html() before returning. Logs an InputSanitized event when
## the output was modified.
## Woven at: execution(*.render) & within(std.ui.**)
fn sanitize_html_output(ctx: JoinPointContext, proceed: fn() -> any) -> any:
    val raw_output = proceed()

    val raw_text = "{raw_output}"
    val sanitized = sanitize_html(raw_text)

    if sanitized != raw_text:
        val config = AuditConfig.default()
        val event = SecurityEvent.InputSanitized(
            field: ctx.function_name,
            original_len: raw_text.len()
        )

        val entry = AuditEntry.new(
            event: event,
            correlation_id: generate_validation_id(ctx),
            module_path: ctx.module_path
        )

        log_security_event(entry, config)

    sanitized

## Before advice that validates request input parameters.
##
## Inspects join point attributes for input parameters and checks them
## against common attack patterns (path traversal, null bytes, oversized input).
## Woven at: execution(*.handle_request) & within(std.http.**)
fn validate_request_input(ctx: JoinPointContext) -> Result<(), text>:
    val config = AuditConfig.default()

    for attr in ctx.attributes:
        if attr.starts_with("path="):
            val path_value = attr.slice(5, attr.len())
            validate_path_param(ctx, path_value, config)?

        else if attr.starts_with("input="):
            val input_value = attr.slice(6, attr.len())
            validate_input_length(ctx, input_value, config)?

    Ok(())

# ---------------------------------------------------------------------------
# Internal validators
# ---------------------------------------------------------------------------

## Validate a path parameter for traversal attacks.
fn validate_path_param(ctx: JoinPointContext, path_value: text, config: AuditConfig) -> Result<(), text>:
    if is_path_traversal(path_value):
        val event = SecurityEvent.InputSanitized(
            field: "path",
            original_len: path_value.len()
        )

        val entry = AuditEntry.new(
            event: event,
            correlation_id: generate_validation_id(ctx),
            module_path: ctx.module_path
        )

        log_security_event(entry, config)
        return Err("path traversal detected in request input")

    val result = sanitize_path(path_value)
    match result:
        Err(msg):
            return Err("invalid path parameter: {msg}")
        Ok(_):
            Ok(())

## Validate input length against maximum allowed size.
## Rejects inputs exceeding 1 MB to prevent denial-of-service.
fn validate_input_length(ctx: JoinPointContext, input_value: text, config: AuditConfig) -> Result<(), text>:
    val max_input_len = 1048576  # 1 MB

    if input_value.len() > max_input_len:
        val event = SecurityEvent.InputSanitized(
            field: "input",
            original_len: input_value.len()
        )

        val entry = AuditEntry.new(
            event: event,
            correlation_id: generate_validation_id(ctx),
            module_path: ctx.module_path
        )

        log_security_event(entry, config)
        return Err("input exceeds maximum allowed length: {input_value.len()} > {max_input_len}")

    Ok(())

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

## Generate a validation-scoped correlation ID.
fn generate_validation_id(ctx: JoinPointContext) -> text:
    use std.time
    val ts = time.now_ms()
    "{ts}-validate-{ctx.module_path}"
