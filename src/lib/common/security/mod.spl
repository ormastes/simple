# Security module — types, audit logging, input sanitization, and AOP aspects.
#
# MDSOC security dimension: crypto → enforcement → validation → auth → audit
# AOP aspects in security/aspects/ are woven at compile time.
# See capsule.sdn for dimension definition, caret mappings, and weaving rules.

pub use std.security.types
pub use std.security.audit_log
pub use std.security.sanitize
pub use std.security.aspects

# Enforcement layer — capability system, permission resolution, gate
pub use std.security.enforcement.capability
pub use std.security.enforcement.resolver
pub use std.security.enforcement.gate

# Auth layer — context propagation, credential store, env config, rotation
pub use std.security.auth.context_propagation
pub use std.security.auth.credential_store
pub use std.security.auth.env_config
pub use std.security.auth.rotation

# Validation layer — URL validator, prompt sanitizer
pub use std.security.validation.url_validator
pub use std.security.validation.prompt_sanitizer
