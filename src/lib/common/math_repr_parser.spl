# Math Expression Parser — ParseState, MathParser class with OOP parse methods

use std.common.math_repr_symbols

fn _is_digit(ch: text) -> bool:
    if ch == "0": return true
    if ch == "1": return true
    if ch == "2": return true
    if ch == "3": return true
    if ch == "4": return true
    if ch == "5": return true
    if ch == "6": return true
    if ch == "7": return true
    if ch == "8": return true
    if ch == "9": return true
    false

fn _is_alpha(ch: text) -> bool:
    if ch == "_": return true
    if ch == "a": return true
    if ch == "b": return true
    if ch == "c": return true
    if ch == "d": return true
    if ch == "e": return true
    if ch == "f": return true
    if ch == "g": return true
    if ch == "h": return true
    if ch == "i": return true
    if ch == "j": return true
    if ch == "k": return true
    if ch == "l": return true
    if ch == "m": return true
    if ch == "n": return true
    if ch == "o": return true
    if ch == "p": return true
    if ch == "q": return true
    if ch == "r": return true
    if ch == "s": return true
    if ch == "t": return true
    if ch == "u": return true
    if ch == "v": return true
    if ch == "w": return true
    if ch == "x": return true
    if ch == "y": return true
    if ch == "z": return true
    if ch == "A": return true
    if ch == "B": return true
    if ch == "C": return true
    if ch == "D": return true
    if ch == "E": return true
    if ch == "F": return true
    if ch == "G": return true
    if ch == "H": return true
    if ch == "I": return true
    if ch == "J": return true
    if ch == "K": return true
    if ch == "L": return true
    if ch == "M": return true
    if ch == "N": return true
    if ch == "O": return true
    if ch == "P": return true
    if ch == "Q": return true
    if ch == "R": return true
    if ch == "S": return true
    if ch == "T": return true
    if ch == "U": return true
    if ch == "V": return true
    if ch == "W": return true
    if ch == "X": return true
    if ch == "Y": return true
    if ch == "Z": return true
    false

fn _is_alnum(ch: text) -> bool:
    if _is_digit(ch): return true
    _is_alpha(ch)

fn _char_at(source: text, index: i64) -> text:
    source[index]

fn _resolve_greek(name: text) -> text:
    val g = greek(name)
    if g != name:
        return g
    val gu = greek_upper(name)
    if gu != name:
        return gu
    name

fn _is_known_fn(name: text) -> bool:
    if name == "sin": return true
    if name == "cos": return true
    if name == "tan": return true
    if name == "tanh": return true
    if name == "sinh": return true
    if name == "cosh": return true
    if name == "log": return true
    if name == "ln": return true
    if name == "exp": return true
    if name == "min": return true
    if name == "max": return true
    if name == "lim": return true
    false

fn _latex_greek(name: text) -> text:
    val g = greek(name)
    if g != name:
        return "\\" + name
    val gu = greek_upper(name)
    if gu != name:
        return "\\" + name
    name

class ParseState:
    pos: i64
    root: i64

    fn peek_kind(tk_kinds: [text]) -> text:
        if self.pos >= tk_kinds.len():
            return "eof"
        tk_kinds[self.pos]

    fn peek_val(tk_vals: [text]) -> text:
        if self.pos >= tk_vals.len():
            return ""
        tk_vals[self.pos]

    me advance():
        self.pos = self.pos + 1

class MathParser:
    tags: [text]
    vals: [text]
    lefts: [i64]
    rights: [i64]
    extras: [[i64]]
    tk_kinds: [text]
    tk_vals: [text]
    pos: i64
    root: i64

    static fn create() -> MathParser:
        MathParser(
            tags: [], vals: [], lefts: [], rights: [], extras: [],
            tk_kinds: [], tk_vals: [], pos: 0, root: -1
        )

    me reset():
        self.tags.clear()
        self.vals.clear()
        self.lefts.clear()
        self.rights.clear()
        self.extras.clear()
        self.tk_kinds.clear()
        self.tk_vals.clear()
        self.pos = 0
        self.root = -1

    me mk(tag: text, tval: text, left: i64, right: i64) -> i64:
        val idx = self.tags.len()
        self.tags.push(tag)
        self.vals.push(tval)
        self.lefts.push(left)
        self.rights.push(right)
        self.extras.push([])
        idx

    me mk_call(name: text, args: [i64]) -> i64:
        val idx = self.tags.len()
        self.tags.push("call")
        self.vals.push(name)
        self.lefts.push(-1)
        self.rights.push(-1)
        self.extras.push(args)
        idx

    me tokenize(source: text):
        self.tk_kinds.clear()
        self.tk_vals.clear()
        var i = 0
        val slen = source.len()
        for _loop in 0..10000:
            if i >= slen:
                break
            val ch = _char_at(source, i)
            if ch == " " or ch == "\t":
                i = i + 1
            elif _is_digit(ch):
                var num_parts: [text] = []
                for _inner in 0..1000:
                    if i >= slen:
                        break
                    val c2 = _char_at(source, i)
                    if _is_digit(c2) or c2 == ".":
                        num_parts.push(c2)
                        i = i + 1
                    else:
                        break
                self.tk_kinds.push("num")
                self.tk_vals.push(num_parts.join(""))
            elif _is_alpha(ch):
                var id_parts: [text] = []
                for _inner in 0..1000:
                    if i >= slen:
                        break
                    val c2 = _char_at(source, i)
                    if _is_alnum(c2):
                        id_parts.push(c2)
                        i = i + 1
                    else:
                        break
                self.tk_kinds.push("id")
                self.tk_vals.push(id_parts.join(""))
            elif ch == ".":
                if i + 1 < slen:
                    val next = _char_at(source, i + 1)
                    if next == ".":
                        self.tk_kinds.push("op")
                        self.tk_vals.push("..")
                        i = i + 2
                    else:
                        self.tk_kinds.push("op")
                        self.tk_vals.push(".")
                        i = i + 1
                else:
                    self.tk_kinds.push("op")
                    self.tk_vals.push(".")
                    i = i + 1
            elif ch == "+":
                self.tk_kinds.push("op")
                self.tk_vals.push("+")
                i = i + 1
            elif ch == "-":
                self.tk_kinds.push("op")
                self.tk_vals.push("-")
                i = i + 1
            elif ch == "*":
                self.tk_kinds.push("op")
                self.tk_vals.push("*")
                i = i + 1
            elif ch == "/":
                self.tk_kinds.push("op")
                self.tk_vals.push("/")
                i = i + 1
            elif ch == "^":
                self.tk_kinds.push("op")
                self.tk_vals.push("^")
                i = i + 1
            elif ch == "'":
                self.tk_kinds.push("op")
                self.tk_vals.push("'")
                i = i + 1
            elif ch == "(":
                self.tk_kinds.push("lparen")
                self.tk_vals.push("(")
                i = i + 1
            elif ch == ")":
                self.tk_kinds.push("rparen")
                self.tk_vals.push(")")
                i = i + 1
            elif ch == "[":
                self.tk_kinds.push("lbracket")
                self.tk_vals.push("[")
                i = i + 1
            elif ch == "]":
                self.tk_kinds.push("rbracket")
                self.tk_vals.push("]")
                i = i + 1
            elif ch == ",":
                self.tk_kinds.push("comma")
                self.tk_vals.push(",")
                i = i + 1
            else:
                i = i + 1
        self.tk_kinds.push("eof")
        self.tk_vals.push("")

    fn peek_kind() -> text:
        if self.pos >= self.tk_kinds.len():
            return "eof"
        self.tk_kinds[self.pos]

    fn peek_val() -> text:
        if self.pos >= self.tk_vals.len():
            return ""
        self.tk_vals[self.pos]

    me advance():
        self.pos = self.pos + 1

    fn can_start_expr() -> bool:
        val pk = self.peek_kind()
        if pk == "num": return true
        if pk == "id": return true
        if pk == "lparen": return true
        false

    fn can_implicit_mul() -> bool:
        if not self.can_start_expr():
            return false
        val pk = self.peek_kind()
        if pk == "id": return true
        if pk == "lparen": return true
        false

    me parse_expr() -> i64:
        self.parse_add()

    me parse_add() -> i64:
        var left = self.parse_mul()
        for _loop in 0..1000:
            val pk = self.peek_kind()
            val pv = self.peek_val()
            if pk == "op" and pv == "+":
                self.advance()
                val right = self.parse_mul()
                left = self.mk("add", "+", left, right)
            elif pk == "op" and pv == "-":
                self.advance()
                val right = self.parse_mul()
                left = self.mk("sub", "-", left, right)
            else:
                break
        left

    me parse_mul() -> i64:
        var left = self.parse_unary()
        for _loop in 0..1000:
            val pk = self.peek_kind()
            val pv = self.peek_val()
            if pk == "op" and pv == "*":
                self.advance()
                val right = self.parse_unary()
                left = self.mk("mul", "*", left, right)
            elif pk == "op" and pv == "/":
                self.advance()
                val right = self.parse_unary()
                left = self.mk("div", "/", left, right)
            elif self.can_implicit_mul():
                val right = self.parse_unary()
                left = self.mk("mul", "", left, right)
            else:
                break
        left

    me parse_unary() -> i64:
        val pk = self.peek_kind()
        val pv = self.peek_val()
        if pk == "op" and pv == "-":
            self.advance()
            val operand = self.parse_unary()
            return self.mk("neg", "-", operand, -1)
        self.parse_pow()

    me parse_pow() -> i64:
        var base = self.parse_postfix()
        val pk = self.peek_kind()
        val pv = self.peek_val()
        if pk == "op" and pv == "^":
            self.advance()
            val exp = self.parse_unary()
            base = self.mk("pow", "^", base, exp)
        base

    me parse_postfix() -> i64:
        var node = self.parse_primary()
        for _loop in 0..100:
            if self.peek_kind() == "lbracket":
                self.advance()
                val idx = self.parse_expr()
                if self.peek_kind() == "rbracket":
                    self.advance()
                node = self.mk("subscript", "", node, idx)
            elif self.peek_kind() == "op" and self.peek_val() == "'":
                self.advance()
                node = self.mk("transpose", "'", node, -1)
            else:
                break
        node

    me parse_primary() -> i64:
        val pk = self.peek_kind()
        val pv = self.peek_val()

        if pk == "num":
            self.advance()
            return self.mk("num", pv, -1, -1)

        if pk == "id":
            self.advance()
            val name = pv
            if name == "frac" and self.peek_kind() == "lparen":
                return self.parse_frac_call()
            if name == "sum" and self.peek_kind() == "lparen":
                return self.parse_sum_call(name)
            if name == "int" and self.peek_kind() == "lparen":
                return self.parse_sum_call(name)
            if self.peek_kind() == "lparen":
                self.advance()
                var args: [i64] = []
                if self.peek_kind() != "rparen":
                    args.push(self.parse_expr())
                    for _loop in 0..100:
                        if self.peek_kind() == "comma":
                            self.advance()
                            args.push(self.parse_expr())
                        else:
                            break
                if self.peek_kind() == "rparen":
                    self.advance()
                return self.mk_call(name, args)
            return self.mk("id", name, -1, -1)

        if pk == "lparen":
            self.advance()
            val inner = self.parse_expr()
            if self.peek_kind() == "rparen":
                self.advance()
            return self.mk("group", "", inner, -1)

        self.advance()
        self.mk("id", "?", -1, -1)

    me parse_frac_call() -> i64:
        self.advance()
        val num = self.parse_expr()
        if self.peek_kind() == "comma":
            self.advance()
        val den = self.parse_expr()
        if self.peek_kind() == "rparen":
            self.advance()
        self.mk("frac", "frac", num, den)

    me parse_sum_call(kind: text) -> i64:
        self.advance()
        val var_name = self.peek_val()
        self.advance()
        if self.peek_kind() == "comma":
            self.advance()
        val from_val = self.parse_expr()
        if self.peek_kind() == "op" and self.peek_val() == "..":
            self.advance()
        val to_val = self.parse_expr()
        if self.peek_kind() == "rparen":
            self.advance()
        val body = self.parse_unary()
        val idx = self.tags.len()
        var tag = "sum_expr"
        if kind == "int":
            tag = "int_expr"
        self.tags.push(tag)
        self.vals.push(var_name)
        self.lefts.push(body)
        self.rights.push(-1)
        self.extras.push([from_val, to_val])
        idx

    me parse_source(source: text):
        self.reset()
        self.tokenize(source)
        self.pos = 0
        self.root = self.parse_expr()
