# Seeded cellular-automata cave generator (4-5 rule), operating on [[i32]]
# grids. Cell value 1 = wall, 0 = floor. Pure/deterministic: same seed and
# parameters always produce the same grid.
#
# Uses random_pure's explicit-state `LcgRng` struct (NOT the shared-state
# module functions) for the initial random fill — call order matters for a
# scatter/dice generator like this one, unlike noise.spl's position-pure
# gradient noise, so an explicit-state generator is the right tool here.
#
# NOTE: parameters/locals are named `cave` rather than `grid` — `grid` as a
# bare identifier confuses the parser when followed by `.field[index]` (it
# collides with the GPU-kernel-launch `grid: (...)` argument grammar even
# outside that context). See
# doc/08_tracking/bug/parser_grid_identifier_keyword_collision_2026-07-03.md.
#
# Import path: use std.common.cave_ca.{CaveGrid, ca_generate, ca_step, ca_floor_reachable}

use std.common.random_pure.{LcgRng, lcg_rng, lcg_advance, lcg_value}

val WALL: i32 = 1
val FLOOR: i32 = 0

struct CaveGrid:
    """A cols x rows grid of cells (row-major: cells[row][col])."""
    cols: i64
    rows: i64
    cells: [[i32]]

fn _rng_unit(rng: LcgRng) -> (LcgRng, f64):
    """Advance rng and return (new_rng, value in [0, 1))."""
    val next = lcg_advance(rng)
    (next, lcg_value(next) as f64 / 4294967296.0)

fn ca_init(seed: i64, cols: i64, rows: i64, fill_prob: f64) -> CaveGrid:
    """Random initial grid: border cells are always wall; interior cells are
    wall with probability fill_prob, driven by a seeded LcgRng."""
    var rng = lcg_rng(seed)
    var cells: [[i32]] = []
    var y: i64 = 0
    while y < rows:
        var row: [i32] = []
        var x: i64 = 0
        while x < cols:
            if (x == 0 or y == 0 or x == cols - 1 or y == rows - 1):
                row.push(WALL)
            else:
                val (next_rng, v) = _rng_unit(rng)
                rng = next_rng
                row.push(if v < fill_prob: WALL else: FLOOR)
            x = x + 1
        cells.push(row)
        y = y + 1
    CaveGrid(cols: cols, rows: rows, cells: cells)

fn _wall_neighbor_count(cave: CaveGrid, x: i64, y: i64) -> i64:
    """Count wall cells in the 8-neighborhood; out-of-bounds counts as wall
    so the map stays enclosed."""
    var count: i64 = 0
    var dy: i64 = -1
    while dy <= 1:
        var dx: i64 = -1
        while dx <= 1:
            if not (dx == 0 and dy == 0):
                val nx = x + dx
                val ny = y + dy
                if (nx < 0 or ny < 0 or nx >= cave.cols or ny >= cave.rows):
                    count = count + 1
                elif cave.cells[ny][nx] == WALL:
                    count = count + 1
            dx = dx + 1
        dy = dy + 1
    count

pub fn ca_step(cave: CaveGrid) -> CaveGrid:
    """Apply one 4-5 rule pass: a cell becomes wall with >4 wall neighbors,
    becomes floor with <4 wall neighbors, else keeps its current state."""
    var cells: [[i32]] = []
    var y: i64 = 0
    while y < cave.rows:
        var row: [i32] = []
        var x: i64 = 0
        while x < cave.cols:
            val n = _wall_neighbor_count(cave, x, y)
            if n > 4:
                row.push(WALL)
            elif n < 4:
                row.push(FLOOR)
            else:
                row.push(cave.cells[y][x])
            x = x + 1
        cells.push(row)
        y = y + 1
    CaveGrid(cols: cave.cols, rows: cave.rows, cells: cells)

fn _grids_equal(a: CaveGrid, b: CaveGrid) -> bool:
    var y: i64 = 0
    while y < a.rows:
        var x: i64 = 0
        while x < a.cols:
            if a.cells[y][x] != b.cells[y][x]:
                return false
            x = x + 1
        y = y + 1
    true

pub fn ca_generate(seed: i64, cols: i64, rows: i64, fill_prob: f64, max_iters: i64) -> CaveGrid:
    """Seeded initial fill, then repeated `ca_step` passes until a fixpoint
    is reached (or max_iters is hit, as a safety cap)."""
    var g = ca_init(seed, cols, rows, fill_prob)
    var i: i64 = 0
    while i < max_iters:
        val g2 = ca_step(g)
        if _grids_equal(g, g2):
            return g2
        g = g2
        i = i + 1
    g

pub fn ca_floor_reachable(cave: CaveGrid) -> bool:
    """True iff every floor cell is reachable from the first floor cell
    found (single connected floor region), via 4-neighbor flood fill.

    `visited` is a flattened row-major `[bool]` (index = y*cols+x) rather
    than `[[bool]]` — nested-array double-index *assignment* is not
    supported by the parser/compiler (only nested-index *read* is; see
    `matrix[(ri*cols) as i32]` in fuzzy.spl for the same flattening
    workaround), so a flat array sidesteps it entirely."""
    val cols = cave.cols
    val rows = cave.rows
    var visited: [bool] = []
    var total_floor: i64 = 0
    var i: i64 = 0
    while i < cols * rows:
        visited.push(false)
        i = i + 1
    var y: i64 = 0
    while y < rows:
        var x: i64 = 0
        while x < cols:
            if cave.cells[y][x] == FLOOR:
                total_floor = total_floor + 1
            x = x + 1
        y = y + 1
    if total_floor == 0:
        return true
    var start_x: i64 = -1
    var start_y: i64 = -1
    y = 0
    while y < rows and start_x < 0:
        var x: i64 = 0
        while x < cols and start_x < 0:
            if cave.cells[y][x] == FLOOR:
                start_x = x
                start_y = y
            x = x + 1
        y = y + 1
    var stack_x: [i64] = [start_x]
    var stack_y: [i64] = [start_y]
    visited[start_y * cols + start_x] = true
    var reached: i64 = 1
    while stack_x.len() > 0:
        val cx = stack_x[stack_x.len() - 1]
        val cy = stack_y[stack_y.len() - 1]
        stack_x.pop()
        stack_y.pop()
        val deltas_x = [1, -1, 0, 0]
        val deltas_y = [0, 0, 1, -1]
        var k: i64 = 0
        while k < 4:
            val nx = cx + deltas_x[k]
            val ny = cy + deltas_y[k]
            if (nx >= 0 and ny >= 0 and nx < cols and ny < rows):
                if (cave.cells[ny][nx] == FLOOR and not visited[ny * cols + nx]):
                    visited[ny * cols + nx] = true
                    reached = reached + 1
                    stack_x.push(nx)
                    stack_y.push(ny)
            k = k + 1
    reached == total_floor
