fn str_char_at(s: text, idx: i64) -> text:
    s[idx]

fn char_code(c: text) -> i64:
    """Get numeric ASCII code of first character of c. Returns 0 for empty string."""
    if c.len() == 0:
        0
    else:
        c[0].to_i64()

fn char_from_code(code: i64) -> text:
    if code >= 32 and code <= 126:
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        val index = code - 32
        if index >= 0 and index < chars.len():
            return chars[index]
    "?"
