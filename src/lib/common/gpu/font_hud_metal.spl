# Pure source contract for the native Metal HUD font lane. This module emits
# MSL only; it does not claim compilation or execution.

val FONT_HUD_METAL_VERTEX_ENTRY: text = "simple_font_hud_vertex_v1"
val FONT_HUD_METAL_FRAGMENT_ENTRY: text = "simple_font_hud_fragment_v1"
val FONT_HUD_METAL_VERTEX_BYTES: i64 = 20
val FONT_HUD_METAL_ATLAS_FORMAT: i64 = 1  # A8Unorm; fragment samples alpha.
val FONT_HUD_METAL_RGBA8_FORMAT: i64 = 70
val FONT_HUD_METAL_BGRA8_FORMAT: i64 = 80

fn font_hud_metal_source() -> text:
    "#include <metal_stdlib>\nusing namespace metal;\n\n" +
    "struct FontHudVertex { packed_float2 position; packed_float2 uv; uint color; };\n" +
    "static_assert(sizeof(FontHudVertex) == 20, \"FontHudVertex ABI\");\n" +
    "struct FontHudVarying { float4 position [[position]]; float2 uv; float4 color; };\n\n" +
    "vertex FontHudVarying simple_font_hud_vertex_v1(\n" +
    "    device const FontHudVertex* vertices [[buffer(0)]],\n" +
    "    uint vertex_id [[vertex_id]]) {\n" +
    "    FontHudVertex v = vertices[vertex_id];\n" +
    "    FontHudVarying out;\n" +
    "    out.position = float4(float2(v.position), 0.0, 1.0);\n" +
    "    out.uv = float2(v.uv);\n" +
    "    out.color = float4(float((v.color >> 16u) & 255u), float((v.color >> 8u) & 255u), float(v.color & 255u), float(v.color >> 24u)) / 255.0;\n" +
    "    return out;\n" +
    "}\n\n" +
    "fragment float4 simple_font_hud_fragment_v1(\n" +
    "    FontHudVarying in [[stage_in]],\n" +
    "    texture2d<float> atlas [[texture(0)]],\n" +
    "    sampler atlas_sampler [[sampler(0)]]) {\n" +
    "    float mask = atlas.sample(atlas_sampler, in.uv).a;\n" +
    "    return float4(in.color.rgb, in.color.a * mask);\n" +
    "}\n"

export FONT_HUD_METAL_VERTEX_ENTRY, FONT_HUD_METAL_FRAGMENT_ENTRY,
    FONT_HUD_METAL_VERTEX_BYTES, FONT_HUD_METAL_ATLAS_FORMAT,
    FONT_HUD_METAL_RGBA8_FORMAT, FONT_HUD_METAL_BGRA8_FORMAT,
    font_hud_metal_source
