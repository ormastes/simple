# codex-impl
"""Bounded protocol contract for SimpleOS QEMU host-GPU batches."""

val SIMPLEOS_HOST_GPU_PROTOCOL_MAGIC: i64 = 0x53484750
val SIMPLEOS_HOST_GPU_PROTOCOL_VERSION: i64 = 1
val SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US: i64 = 500000
val SIMPLEOS_HOST_GPU_REGION_BYTES: i64 = 8 * 1024 * 1024
val SIMPLEOS_HOST_GPU_CONTROL_BYTES: i64 = 4 * 1024
val SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES: i64 = 64 * 1024
val SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS: i64 = 1024
val SIMPLEOS_HOST_GPU_MAX_IMAGE_URI_BYTES: i64 = 256
val SIMPLEOS_HOST_GPU_IMAGE_RESOURCE_HEADER_BYTES: i64 = 48

fn simpleos_host_gpu_wire_payload_offset() -> i64:
    SIMPLEOS_HOST_GPU_CONTROL_BYTES

fn simpleos_host_gpu_wire_readback_offset() -> i64:
    simpleos_host_gpu_wire_payload_offset() + SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES

fn simpleos_host_gpu_max_readback_bytes() -> i64:
    SIMPLEOS_HOST_GPU_REGION_BYTES - simpleos_host_gpu_wire_readback_offset()
val SIMPLEOS_HOST_GPU_MAX_WIDTH: i64 = 4096
val SIMPLEOS_HOST_GPU_MAX_HEIGHT: i64 = 4096
val SIMPLEOS_HOST_GPU_MAX_ID_BYTES: i64 = 64

# 64-bit aligned ivshmem wire layout. Payload starts after the control page;
# readback starts after the fixed payload window.
val SIMPLEOS_HOST_GPU_WIRE_MAGIC: i64 = 0
val SIMPLEOS_HOST_GPU_WIRE_VERSION: i64 = 8
val SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION: i64 = 16
val SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION: i64 = 24
val SIMPLEOS_HOST_GPU_WIRE_KIND: i64 = 32
val SIMPLEOS_HOST_GPU_WIRE_BACKEND: i64 = 40
val SIMPLEOS_HOST_GPU_WIRE_WIDTH: i64 = 48
val SIMPLEOS_HOST_GPU_WIRE_HEIGHT: i64 = 56
val SIMPLEOS_HOST_GPU_WIRE_ELEMENT_COUNT: i64 = 64
val SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_BYTES: i64 = 72
val SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_CHECKSUM: i64 = 80
val SIMPLEOS_HOST_GPU_WIRE_FRAME_ID: i64 = 88
val SIMPLEOS_HOST_GPU_WIRE_STATUS: i64 = 96
val SIMPLEOS_HOST_GPU_WIRE_REASON: i64 = 104
val SIMPLEOS_HOST_GPU_WIRE_NATIVE_HANDLE: i64 = 112
val SIMPLEOS_HOST_GPU_WIRE_OUTPUT_BYTES: i64 = 120
val SIMPLEOS_HOST_GPU_WIRE_OUTPUT_CHECKSUM: i64 = 128
val SIMPLEOS_HOST_GPU_WIRE_ELAPSED_US: i64 = 136
val SIMPLEOS_HOST_GPU_WIRE_READBACK_SOURCE: i64 = 144
val SIMPLEOS_HOST_GPU_WIRE_DEVICE_IDENTITY: i64 = 152
val SIMPLEOS_HOST_GPU_WIRE_RUN_ID_HASH: i64 = 160
val SIMPLEOS_HOST_GPU_WIRE_GUEST_ISA: i64 = 168
val SIMPLEOS_HOST_GPU_WIRE_REQUESTED_RENDER_MASK: i64 = 176
val SIMPLEOS_HOST_GPU_WIRE_REQUESTED_PROCESSING_MASK: i64 = 184
val SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_RENDER_MASK: i64 = 192
val SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK: i64 = 200
val SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_PAYLOAD: i64 = 208
val SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_READBACK: i64 = 216
val SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION: i64 = 224
val SIMPLEOS_HOST_GPU_WIRE_COMPLETION_RUN_ID_HASH: i64 = 232
val SIMPLEOS_HOST_GPU_WIRE_COMPLETION_FRAME_ID: i64 = 240
val SIMPLEOS_HOST_GPU_WIRE_COMPLETION_BACKEND: i64 = 248
val SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_COUNT: i64 = 256
val SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_BYTES: i64 = 264
val SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM: i64 = 272
val SIMPLEOS_HOST_GPU_WIRE_COMMAND_BYTES: i64 = 48

val SIMPLEOS_HOST_GPU_KIND_HELLO: i64 = 0
val SIMPLEOS_HOST_GPU_KIND_RENDER: i64 = 1
val SIMPLEOS_HOST_GPU_KIND_PROCESSING: i64 = 2
val SIMPLEOS_HOST_GPU_KIND_DRAW_IR: i64 = 3
val SIMPLEOS_HOST_GPU_BACKEND_VULKAN: i64 = 1
val SIMPLEOS_HOST_GPU_BACKEND_METAL: i64 = 2
val SIMPLEOS_HOST_GPU_BACKEND_DIRECTX: i64 = 3
val SIMPLEOS_HOST_GPU_BACKEND_CUDA: i64 = 4
val SIMPLEOS_HOST_GPU_BACKEND_CPU: i64 = 5
val SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN: i64 = 1
val SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL: i64 = 2
val SIMPLEOS_HOST_GPU_BACKEND_MASK_DIRECTX: i64 = 4
val SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA: i64 = 8
val SIMPLEOS_HOST_GPU_BACKEND_MASK_CPU: i64 = 16
val SIMPLEOS_HOST_GPU_ISA_X86_64: i64 = 1
val SIMPLEOS_HOST_GPU_ISA_AARCH64: i64 = 2
val SIMPLEOS_HOST_GPU_ISA_RISCV64: i64 = 3
val SIMPLEOS_HOST_GPU_COMMAND_CLEAR: i64 = 1
val SIMPLEOS_HOST_GPU_COMMAND_FILL_RECT: i64 = 2
val SIMPLEOS_HOST_GPU_COMMAND_FILL_U32: i64 = 100
val SIMPLEOS_HOST_GPU_STATUS_IDLE: i64 = 0
val SIMPLEOS_HOST_GPU_STATUS_PASS: i64 = 1
val SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED: i64 = 2
val SIMPLEOS_HOST_GPU_STATUS_FAIL: i64 = 3
val SIMPLEOS_HOST_GPU_READBACK_DEVICE: i64 = 1
val SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST: i64 = 1
val SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND: i64 = 2
val SIMPLEOS_HOST_GPU_REASON_TIMEOUT: i64 = 3
val SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION: i64 = 7
val SIMPLEOS_HOST_GPU_REASON_HELLO_REQUIRED: i64 = 8
val SIMPLEOS_HOST_GPU_REASON_INVALID_HELLO: i64 = 9
val SIMPLEOS_HOST_GPU_REASON_CORRELATION_MISMATCH: i64 = 10
val SIMPLEOS_HOST_GPU_REASON_CHECKSUM_MISMATCH: i64 = 11
val SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_COMMAND: i64 = 12
val SIMPLEOS_HOST_GPU_REASON_BACKEND_MISMATCH: i64 = 13
val SIMPLEOS_HOST_GPU_REASON_NON_DEVICE_READBACK: i64 = 14

struct SimpleOsHostGpuWireCommand:
    op: i64
    x: i64
    y: i64
    width: i64
    height: i64
    value: i64

fn simpleos_host_gpu_backend_code(backend: text) -> i64:
    match backend:
        "vulkan": SIMPLEOS_HOST_GPU_BACKEND_VULKAN
        "metal": SIMPLEOS_HOST_GPU_BACKEND_METAL
        "directx": SIMPLEOS_HOST_GPU_BACKEND_DIRECTX
        "cuda": SIMPLEOS_HOST_GPU_BACKEND_CUDA
        "cpu": SIMPLEOS_HOST_GPU_BACKEND_CPU
        _: 0

fn simpleos_host_gpu_backend_name(code: i64) -> text:
    match code:
        SIMPLEOS_HOST_GPU_BACKEND_VULKAN: "vulkan"
        SIMPLEOS_HOST_GPU_BACKEND_METAL: "metal"
        SIMPLEOS_HOST_GPU_BACKEND_DIRECTX: "directx"
        SIMPLEOS_HOST_GPU_BACKEND_CUDA: "cuda"
        SIMPLEOS_HOST_GPU_BACKEND_CPU: "cpu"
        _: "unsupported"

fn simpleos_host_gpu_backend_mask(code: i64) -> i64:
    match code:
        SIMPLEOS_HOST_GPU_BACKEND_VULKAN: SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN
        SIMPLEOS_HOST_GPU_BACKEND_METAL: SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL
        SIMPLEOS_HOST_GPU_BACKEND_DIRECTX: SIMPLEOS_HOST_GPU_BACKEND_MASK_DIRECTX
        SIMPLEOS_HOST_GPU_BACKEND_CUDA: SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA
        SIMPLEOS_HOST_GPU_BACKEND_CPU: SIMPLEOS_HOST_GPU_BACKEND_MASK_CPU
        _: 0

fn simpleos_host_gpu_guest_isa_code(guest_isa: text) -> i64:
    match guest_isa:
        "x86_64": SIMPLEOS_HOST_GPU_ISA_X86_64
        "aarch64": SIMPLEOS_HOST_GPU_ISA_AARCH64
        "riscv64": SIMPLEOS_HOST_GPU_ISA_RISCV64
        _: 0

fn simpleos_host_gpu_guest_isa_name(code: i64) -> text:
    match code:
        SIMPLEOS_HOST_GPU_ISA_X86_64: "x86_64"
        SIMPLEOS_HOST_GPU_ISA_AARCH64: "aarch64"
        SIMPLEOS_HOST_GPU_ISA_RISCV64: "riscv64"
        _: "unsupported"

fn simpleos_host_gpu_generation_is_fresh(request_generation: i64, completion_generation: i64) -> bool:
    request_generation > 0 and request_generation > completion_generation

fn simpleos_host_gpu_wire_correlation_valid(run_id_hash: i64, frame_id: i64) -> bool:
    run_id_hash > 0 and frame_id > 0

fn simpleos_host_gpu_wire_checksum_words(words: [i64]) -> i64:
    var checksum: i64 = 0
    for word in words:
        checksum = (checksum + (word & 0x7FFFFFFF)) % 2147483647
    if checksum == 0: 1 else: checksum

fn simpleos_host_gpu_readback_checksum_step(checksum: i64, pixel: u32) -> i64:
    (checksum + ((pixel & 0x7FFFFFFFu32) as i64)) % 2147483647

fn simpleos_host_gpu_readback_checksum_finalize(checksum: i64) -> i64:
    if checksum == 0: 1 else: checksum

fn simpleos_host_gpu_readback_checksum(pixels: [u32], count: i64) -> i64:
    if count < 0 or count > pixels.len().to_i64():
        return 0
    var checksum: i64 = 0
    var i: i64 = 0
    while i < count:
        checksum = simpleos_host_gpu_readback_checksum_step(checksum, pixels[i])
        i = i + 1
    simpleos_host_gpu_readback_checksum_finalize(checksum)

struct SimpleOsHostGpuValidation:
    ok: bool
    status: text
    reason: text

struct SimpleOsHostGpuHello:
    version: i64
    guest_isa: text
    region_bytes: i64
    max_payload_bytes: i64
    max_readback_bytes: i64
    render_backend: text
    processing_backend: text

struct SimpleOsHostGpuBatch:
    version: i64
    generation: i64
    run_id: text
    frame_id: i64
    kind: text
    backend: text
    width: i64
    height: i64
    element_count: i64
    payload_bytes: i64
    payload_checksum: i64

struct SimpleOsHostGpuReceipt:
    version: i64
    generation: i64
    run_id: text
    frame_id: i64
    status: text
    backend: text
    reason: text
    native_handle: i64
    native_device_identity: text
    readback_source: text
    output_bytes: i64
    output_checksum: i64
    elapsed_us: i64

fn simpleos_host_gpu_validation_ok() -> SimpleOsHostGpuValidation:
    SimpleOsHostGpuValidation(ok: true, status: "pass", reason: "pass")

fn simpleos_host_gpu_validation_reject(status: text, reason: text) -> SimpleOsHostGpuValidation:
    SimpleOsHostGpuValidation(ok: false, status: status, reason: reason)

fn simpleos_host_gpu_guest_isa_supported(guest_isa: text) -> bool:
    guest_isa == "x86_64" or guest_isa == "aarch64" or guest_isa == "riscv64"

fn simpleos_host_gpu_render_backend_supported(backend: text) -> bool:
    backend == "auto" or backend == "vulkan" or backend == "metal" or backend == "directx" or backend == "software"

fn simpleos_host_gpu_processing_backend_supported(backend: text) -> bool:
    backend == "auto" or backend == "vulkan" or backend == "cuda" or backend == "metal" or backend == "cpu"

fn simpleos_host_gpu_status_supported(status: text) -> bool:
    status == "pass" or status == "available-not-preferred" or status == "fallback" or status == "unsupported" or status == "blocked" or status == "fail"

fn simpleos_host_gpu_validate_hello(hello: SimpleOsHostGpuHello) -> SimpleOsHostGpuValidation:
    if hello.version != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        return simpleos_host_gpu_validation_reject("fail", "unsupported-protocol-version")
    if not simpleos_host_gpu_guest_isa_supported(hello.guest_isa):
        return simpleos_host_gpu_validation_reject("fail", "unsupported-guest-isa")
    if hello.region_bytes < SIMPLEOS_HOST_GPU_REGION_BYTES:
        return simpleos_host_gpu_validation_reject("fail", "shared-region-too-small")
    if hello.max_payload_bytes <= 0 or hello.max_payload_bytes > SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES:
        return simpleos_host_gpu_validation_reject("fail", "invalid-payload-limit")
    if hello.max_readback_bytes <= 0 or hello.max_readback_bytes > simpleos_host_gpu_max_readback_bytes():
        return simpleos_host_gpu_validation_reject("fail", "invalid-readback-limit")
    if not simpleos_host_gpu_render_backend_supported(hello.render_backend):
        return simpleos_host_gpu_validation_reject("unsupported", "unsupported-render-backend")
    if not simpleos_host_gpu_processing_backend_supported(hello.processing_backend):
        return simpleos_host_gpu_validation_reject("unsupported", "unsupported-processing-backend")
    simpleos_host_gpu_validation_ok()

fn simpleos_host_gpu_batch_output_bytes(batch: SimpleOsHostGpuBatch) -> i64:
    if batch.kind == "render" or batch.kind == "draw_ir":
        return batch.width * batch.height * 4
    if batch.kind == "processing":
        return batch.element_count * 4
    0

fn simpleos_host_gpu_validate_batch(batch: SimpleOsHostGpuBatch) -> SimpleOsHostGpuValidation:
    if batch.version != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        return simpleos_host_gpu_validation_reject("fail", "unsupported-protocol-version")
    if batch.generation <= 0:
        return simpleos_host_gpu_validation_reject("fail", "invalid-generation")
    if batch.run_id.len() == 0 or batch.run_id.len().to_i64() > SIMPLEOS_HOST_GPU_MAX_ID_BYTES:
        return simpleos_host_gpu_validation_reject("fail", "invalid-run-id")
    if batch.frame_id <= 0:
        return simpleos_host_gpu_validation_reject("fail", "invalid-frame-id")
    if batch.kind != "render" and batch.kind != "draw_ir" and batch.kind != "processing":
        return simpleos_host_gpu_validation_reject("unsupported", "unsupported-batch-kind")
    if batch.payload_bytes <= 0 or batch.payload_bytes > SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES:
        return simpleos_host_gpu_validation_reject("fail", "invalid-payload-size")
    if batch.payload_checksum <= 0:
        return simpleos_host_gpu_validation_reject("fail", "invalid-payload-checksum")
    if batch.kind == "render" or batch.kind == "draw_ir":
        if not simpleos_host_gpu_render_backend_supported(batch.backend) or batch.backend == "auto":
            return simpleos_host_gpu_validation_reject("unsupported", "unsupported-render-backend")
        if batch.width <= 0 or batch.height <= 0 or batch.width > SIMPLEOS_HOST_GPU_MAX_WIDTH or batch.height > SIMPLEOS_HOST_GPU_MAX_HEIGHT:
            return simpleos_host_gpu_validation_reject("fail", "invalid-render-dimensions")
    else:
        if not simpleos_host_gpu_processing_backend_supported(batch.backend) or batch.backend == "auto":
            return simpleos_host_gpu_validation_reject("unsupported", "unsupported-processing-backend")
        if batch.element_count <= 0:
            return simpleos_host_gpu_validation_reject("fail", "invalid-processing-element-count")
    val output_bytes = simpleos_host_gpu_batch_output_bytes(batch)
    if output_bytes <= 0 or output_bytes > simpleos_host_gpu_max_readback_bytes():
        return simpleos_host_gpu_validation_reject("fail", "output-exceeds-shared-region")
    simpleos_host_gpu_validation_ok()

fn simpleos_host_gpu_validate_receipt(batch: SimpleOsHostGpuBatch, receipt: SimpleOsHostGpuReceipt) -> SimpleOsHostGpuValidation:
    if receipt.version != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        return simpleos_host_gpu_validation_reject("fail", "receipt-version-mismatch")
    if receipt.generation != batch.generation:
        return simpleos_host_gpu_validation_reject("fail", "stale-generation")
    if receipt.run_id != batch.run_id or receipt.frame_id != batch.frame_id:
        return simpleos_host_gpu_validation_reject("fail", "run-frame-correlation-mismatch")
    if not simpleos_host_gpu_status_supported(receipt.status):
        return simpleos_host_gpu_validation_reject("fail", "unsupported-receipt-status")
    if receipt.reason.len() == 0:
        return simpleos_host_gpu_validation_reject("fail", "missing-receipt-reason")
    if receipt.status == "pass" or receipt.status == "available-not-preferred":
        if receipt.backend != batch.backend:
            return simpleos_host_gpu_validation_reject("fail", "backend-correlation-mismatch")
        if receipt.native_handle <= 0 or receipt.native_device_identity.len() == 0:
            return simpleos_host_gpu_validation_reject("fail", "missing-native-device-provenance")
        if receipt.readback_source != "device_readback":
            return simpleos_host_gpu_validation_reject("fail", "non-device-readback")
        if receipt.output_bytes != simpleos_host_gpu_batch_output_bytes(batch):
            return simpleos_host_gpu_validation_reject("fail", "output-size-mismatch")
        if receipt.output_checksum <= 0:
            return simpleos_host_gpu_validation_reject("fail", "missing-output-checksum")
        if receipt.elapsed_us <= 0:
            return simpleos_host_gpu_validation_reject("fail", "missing-device-timing")
    elif receipt.status == "fallback":
        if receipt.backend != "cpu" and receipt.backend != "software":
            return simpleos_host_gpu_validation_reject("fail", "invalid-fallback-backend")
        if receipt.native_handle != 0 or receipt.readback_source != "cpu_reference":
            return simpleos_host_gpu_validation_reject("fail", "dishonest-fallback-provenance")
    simpleos_host_gpu_validation_ok()

