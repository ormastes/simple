# YAML value model
#
# A YAML value is a (tag, content) tuple:
#   ("null", nil) | ("boolean", bool) | ("number", text) | ("string", text)
#   ("sequence", [value]) | ("mapping", [(text, value)])
#   ("anchor", (name, value)) | ("alias", name)
# Numbers carry their text form so no float round-tripping is involved.

fn yaml_null():
    ("null", nil)

fn yaml_boolean(value: bool):
    ("boolean", value)

fn yaml_number(content: text):
    ("number", content)

fn yaml_string(content: text):
    ("string", content)

fn yaml_sequence(items: [any]):
    ("sequence", items)

fn yaml_mapping(pairs: [any]):
    ("mapping", pairs)

fn _yaml_tag(v: any) -> text:
    if v == nil:
        return "null"
    val t = v.0
    if t == nil:
        return "null"
    "{t}"

fn is_yaml_null(v: any) -> bool:
    _yaml_tag(v) == "null"

fn is_yaml_boolean(v: any) -> bool:
    _yaml_tag(v) == "boolean"

fn is_yaml_number(v: any) -> bool:
    _yaml_tag(v) == "number"

fn is_yaml_string(v: any) -> bool:
    _yaml_tag(v) == "string"

fn is_yaml_sequence(v: any) -> bool:
    _yaml_tag(v) == "sequence"

fn is_yaml_mapping(v: any) -> bool:
    _yaml_tag(v) == "mapping"

fn is_yaml_scalar(v: any) -> bool:
    val t = _yaml_tag(v)
    t == "null" or t == "boolean" or t == "number" or t == "string"

fn yaml_get_scalar_type(v: any) -> text:
    _yaml_tag(v)

fn yaml_get_scalar_content(v: any) -> text:
    if v == nil:
        return ""
    val c = v.1
    if c == nil:
        return ""
    "{c}"

fn yaml_get_sequence_items(v: any) -> [any]:
    if not is_yaml_sequence(v):
        return []
    v.1

fn yaml_get_mapping_pairs(v: any) -> [any]:
    if not is_yaml_mapping(v):
        return []
    v.1
