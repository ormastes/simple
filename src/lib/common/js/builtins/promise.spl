# Promise implementation with microtask queue for the JS engine.
# Models Promise states, handlers, and chaining.

use std.js.types.js_types.*

enum PromiseState:
    Pending
    Fulfilled
    Rejected

class PromiseHandler:
    on_fulfilled: i64   # callback id, -1 if not set
    on_rejected: i64    # callback id, -1 if not set
    next_promise_id: i64

class Promise:
    id: i64
    state: PromiseState
    value: JsValue
    handlers: [PromiseHandler]

    static fn pending(id: i64) -> Promise:
        Promise(
            id: id,
            state: PromiseState.Pending,
            value: JsValue.Undefined,
            handlers: [PromiseHandler]()
        )

class Microtask:
    callback_id: i64
    args: [JsValue]

class MicrotaskQueue:
    tasks: [Microtask]
    is_running: bool

    static fn create() -> MicrotaskQueue:
        MicrotaskQueue(tasks: [Microtask](), is_running: false)

# --- Promise creation ---

fn promise_resolve(value: JsValue) -> Promise:
    Promise(
        id: -1,
        state: PromiseState.Fulfilled,
        value: value,
        handlers: [PromiseHandler]()
    )

fn promise_reject(reason: JsValue) -> Promise:
    Promise(
        id: -1,
        state: PromiseState.Rejected,
        value: reason,
        handlers: [PromiseHandler]()
    )

fn promise_new(id: i64) -> Promise:
    Promise.pending(id)

# --- Promise chaining ---

fn promise_then(promise: Promise, on_fulfilled: i64, on_rejected: i64) -> Promise:
    val next_id = promise.id * 1000 + promise.handlers.len() + 1
    val handler = PromiseHandler(
        on_fulfilled: on_fulfilled,
        on_rejected: on_rejected,
        next_promise_id: next_id
    )
    var result = Promise.pending(next_id)
    # If already settled, the handler should be scheduled as microtask
    match promise.state:
        PromiseState.Pending:
            promise.handlers.push(handler)
        PromiseState.Fulfilled:
            promise.handlers.push(handler)
            # Caller should schedule microtask for on_fulfilled
        PromiseState.Rejected:
            promise.handlers.push(handler)
            # Caller should schedule microtask for on_rejected
    result

fn promise_catch(promise: Promise, on_rejected: i64) -> Promise:
    promise_then(promise, -1, on_rejected)

fn promise_finally(promise: Promise, on_finally: i64) -> Promise:
    # finally handler runs regardless of outcome
    promise_then(promise, on_finally, on_finally)

# --- Promise settlement ---

me promise_fulfill(promise: Promise, value: JsValue):
    match promise.state:
        PromiseState.Pending:
            promise.state = PromiseState.Fulfilled
            promise.value = value
        _:
            # Already settled — ignore
            pass_dn

me promise_reject_with(promise: Promise, reason: JsValue):
    match promise.state:
        PromiseState.Pending:
            promise.state = PromiseState.Rejected
            promise.value = reason
        _:
            pass_dn

# --- Combinators ---

fn promise_all(promises: [Promise]) -> Promise:
    val count = promises.len()
    if count == 0:
        return promise_resolve(JsValue.Array(id: -1))
    var all_fulfilled = true
    var rejected_value = JsValue.Undefined
    var i = 0
    while i < count:
        val p = promises.get(i)
        match p.state:
            PromiseState.Rejected:
                all_fulfilled = false
                rejected_value = p.value
            PromiseState.Pending:
                all_fulfilled = false
            _:
                pass_dn
        i = i + 1
    match rejected_value:
        JsValue.Undefined:
            if all_fulfilled:
                # All fulfilled — collect values
                return promise_resolve(JsValue.Array(id: -1))
            # Some still pending
            Promise.pending(-1)
        _:
            promise_reject(rejected_value)

fn promise_race(promises: [Promise]) -> Promise:
    val count = promises.len()
    var i = 0
    while i < count:
        val p = promises.get(i)
        match p.state:
            PromiseState.Fulfilled:
                return promise_resolve(p.value)
            PromiseState.Rejected:
                return promise_reject(p.value)
            _:
                pass_dn
        i = i + 1
    # All still pending
    Promise.pending(-1)

fn promise_allSettled(promises: [Promise]) -> Promise:
    val count = promises.len()
    var settled_count = 0
    var i = 0
    while i < count:
        val p = promises.get(i)
        match p.state:
            PromiseState.Pending:
                pass_dn
            _:
                settled_count = settled_count + 1
        i = i + 1
    if settled_count == count:
        return promise_resolve(JsValue.Array(id: -1))
    Promise.pending(-1)

fn promise_any(promises: [Promise]) -> Promise:
    val count = promises.len()
    var all_rejected = true
    var i = 0
    while i < count:
        val p = promises.get(i)
        match p.state:
            PromiseState.Fulfilled:
                return promise_resolve(p.value)
            PromiseState.Pending:
                all_rejected = false
            _:
                pass_dn
        i = i + 1
    if all_rejected:
        return promise_reject(JsValue.String(v: "AggregateError: All promises were rejected"))
    Promise.pending(-1)

# --- Microtask queue ---

me enqueue_microtask(queue: MicrotaskQueue, task: Microtask):
    queue.tasks.push(task)

me drain_microtasks(queue: MicrotaskQueue):
    queue.is_running = true
    while queue.tasks.len() > 0:
        val task = queue.tasks.get(0)
        queue.tasks.remove(0)
        _execute_microtask(task)
    queue.is_running = false

fn _execute_microtask(task: Microtask):
    # Actual callback dispatch requires the JS engine runtime.
    # The engine integrates by setting a callback dispatcher on the MicrotaskQueue.
    # At the builtin level, we log and skip — the engine's event loop calls
    # the interpreter directly with the callback_id and args.
    pass_dn  # Engine-level dispatch; see runtime.spl for integration

fn microtask_queue_length(queue: MicrotaskQueue) -> i64:
    queue.tasks.len()

fn microtask_queue_is_empty(queue: MicrotaskQueue) -> bool:
    queue.tasks.len() == 0

# --- Promise state inspection ---

fn promise_is_pending(promise: Promise) -> bool:
    match promise.state:
        PromiseState.Pending: true
        _: false

fn promise_is_fulfilled(promise: Promise) -> bool:
    match promise.state:
        PromiseState.Fulfilled: true
        _: false

fn promise_is_rejected(promise: Promise) -> bool:
    match promise.state:
        PromiseState.Rejected: true
        _: false

fn promise_get_value(promise: Promise) -> JsValue:
    promise.value

fn promise_get_handlers(promise: Promise) -> [PromiseHandler]:
    promise.handlers

fn promise_handler_count(promise: Promise) -> i64:
    promise.handlers.len()
