# ECMAScript Conformance Report Generator
# Generates markdown conformance reports from test results.

use std.js.conformance.runner.{ConformanceRunner, TestResult}

class ConformanceReport:
    es5_pass: i64
    es5_total: i64
    es2015_pass: i64
    es2015_total: i64
    es2020_pass: i64
    es2020_total: i64
    node_pass: i64
    node_total: i64

    static fn empty() -> ConformanceReport:
        ConformanceReport(
            es5_pass: 0, es5_total: 0,
            es2015_pass: 0, es2015_total: 0,
            es2020_pass: 0, es2020_total: 0,
            node_pass: 0, node_total: 0
        )

fn generate_report(runner: ConformanceRunner) -> text:
    """Generate markdown conformance report from test results."""
    var report = ConformanceReport.empty()

    # Categorize results
    var i = 0
    while i < runner.results.len():
        val r = runner.results[i]
        if r.category == "es5":
            report.es5_total = report.es5_total + 1
            if r.passed:
                report.es5_pass = report.es5_pass + 1
        elif r.category == "es2015":
            report.es2015_total = report.es2015_total + 1
            if r.passed:
                report.es2015_pass = report.es2015_pass + 1
        elif r.category == "es2020":
            report.es2020_total = report.es2020_total + 1
            if r.passed:
                report.es2020_pass = report.es2020_pass + 1
        elif r.category == "node":
            report.node_total = report.node_total + 1
            if r.passed:
                report.node_pass = report.node_pass + 1
        i = i + 1

    val total_pass = report.es5_pass + report.es2015_pass + report.es2020_pass + report.node_pass
    val total_all = report.es5_total + report.es2015_total + report.es2020_total + report.node_total

    var md = "# ECMAScript Conformance Report\n\n"
    md = md + "## ES5: {report.es5_pass}/{report.es5_total}\n"
    md = md + "## ES2015: {report.es2015_pass}/{report.es2015_total}\n"
    md = md + "## ES2020+: {report.es2020_pass}/{report.es2020_total}\n"
    md = md + "## Node.js API: {report.node_pass}/{report.node_total}\n"
    md = md + "## Total: {total_pass}/{total_all}\n"
    md = md + "\n"

    # List failures
    var has_failures = false
    i = 0
    while i < runner.results.len():
        val r = runner.results[i]
        if not r.passed:
            if not has_failures:
                md = md + "## Failures\n\n"
                has_failures = true
            md = md + "- **{r.name}** ({r.category}): expected `{r.expected}`, got `{r.actual}`\n"
        i = i + 1

    md

fn print_report(runner: ConformanceRunner):
    """Print conformance report to stdout."""
    val md = generate_report(runner)
    print md
