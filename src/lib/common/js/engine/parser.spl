# JavaScript parser for the Simple Browser Platform.
# Recursive-descent parser with Pratt precedence climbing for expressions.
# Produces AST nodes from the ast_types module (Statement / Expression enums).

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.ast_types.{Expression, Statement, SwitchCase, FnParam, DestructProp, ImportSpec, ExportSpec}
use std.js.engine.lexer.{JsLexer, token_kind_name}
use std.js.engine.lexer.JsTokenKind

# ── Helpers ──────────────────────────────────────────────────────────────

fn _get_ident_name(expr: Expression) -> text:
    match expr:
        Expression.Identifier(name): name
        _: ""

fn _is_token(kind_name: text, kind: JsTokenKind) -> bool:
    kind_name == token_kind_name(kind)

fn _clone_text(value: text) -> text:
    value.substring(0, value.len())

# ── Parser ───────────────────────────────────────────────────────────────

class JsParser:
    lexer: JsLexer
    current_kind: text
    current_value: text
    current_line: i64
    current_col: i64
    previous_kind: text
    previous_value: text
    previous_line: i64
    previous_col: i64
    logger: Logger

    static fn new(input: text, logger: Logger) -> JsParser:
        var lex = JsLexer.new(input, logger)
        val _ = lex.next_token()
        logger.debug("[js-parser] new current_kind={lex.current_kind} current_value={lex.current_value}")
        JsParser(
            lexer: lex,
            current_kind: lex.current_kind,
            current_value: _clone_text(lex.current_value),
            current_line: lex.current_line,
            current_col: lex.current_col,
            previous_kind: "Eof",
            previous_value: "",
            previous_line: 1,
            previous_col: 1,
            logger: logger,
        )

    # ── Helpers ──────────────────────────────────────────────────────────

    # Advance to the next token, returning the consumed one
    me advance():
        self.previous_kind = self.current_kind
        self.previous_value = _clone_text(self.current_value)
        self.previous_line = self.current_line
        self.previous_col = self.current_col
        val _ = self.lexer.next_token()
        self.current_kind = self.lexer.current_kind
        self.current_value = _clone_text(self.lexer.current_value)
        self.current_line = self.lexer.current_line
        self.current_col = self.lexer.current_col

    # Check if the current token matches a given kind
    fn check(kind: JsTokenKind) -> bool:
        self.current_kind == token_kind_name(kind)

    # Consume the current token if it matches, return true; otherwise false
    me match_token(kind: JsTokenKind) -> bool:
        if self.current_kind == token_kind_name(kind):
            self.advance()
            return true
        false

    # Expect the current token to be a given kind; consume and return it, or error
    me expect(kind: JsTokenKind) -> BrowserResult<text>:
        if self.current_kind == token_kind_name(kind):
            val value = _clone_text(self.current_value)
            self.advance()
            return Ok(value)
        val msg = "Expected token kind {kind} but got {self.current_kind} ('{self.current_value}') at line {self.current_line}:{self.current_col}"
        self.logger.error(msg)
        Err(script_error(msg))

    # Check if we've reached end-of-file
    fn is_at_end() -> bool:
        self.lexer.pos >= self.lexer.input_len or self.current_kind == "Eof"

    # ── Program ──────────────────────────────────────────────────────────

    me parse_program() -> BrowserResult<[Statement]>:
        var stmts: [Statement] = []
        var debug_iter = 0
        while not self.is_at_end():
            if debug_iter < 8:
                self.logger.debug("[js-parser] loop kind={self.current_kind} value={self.current_value}")
            val stmt = self.parse_statement()?
            stmts.push(stmt)
            debug_iter = debug_iter + 1
        self.logger.debug("[js-parser] reached eof kind={self.current_kind} value={self.current_value}")
        Ok(stmts)

    # ── Statements ───────────────────────────────────────────────────────

    me parse_statement() -> BrowserResult<Statement>:
        val kind = self.current_kind

        if _is_token(kind, JsTokenKind.Var) or _is_token(kind, JsTokenKind.Let) or _is_token(kind, JsTokenKind.Const):
            return self.parse_var_declaration(self.current_value)

        if _is_token(kind, JsTokenKind.Function):
            return self.parse_function_declaration()

        if _is_token(kind, JsTokenKind.Return):
            return self.parse_return_statement()

        if _is_token(kind, JsTokenKind.If):
            return self.parse_if_statement()

        if _is_token(kind, JsTokenKind.While):
            return self.parse_while_statement()

        if _is_token(kind, JsTokenKind.For):
            return self.parse_for_statement()

        if _is_token(kind, JsTokenKind.OpenBrace):
            val block = self.parse_block()?
            return Ok(Statement.Block(stmts: block))

        if _is_token(kind, JsTokenKind.Try):
            return self.parse_try_statement()

        if _is_token(kind, JsTokenKind.Switch):
            return self.parse_switch_statement()

        if _is_token(kind, JsTokenKind.Throw):
            return self.parse_throw_statement()

        if _is_token(kind, JsTokenKind.Class):
            return self.parse_class_declaration()

        if _is_token(kind, JsTokenKind.Break):
            self.advance()
            self.match_token(JsTokenKind.Semicolon)
            return Ok(Statement.BreakStmt)

        if _is_token(kind, JsTokenKind.Continue):
            self.advance()
            self.match_token(JsTokenKind.Semicolon)
            return Ok(Statement.ContinueStmt)

        if _is_token(kind, JsTokenKind.Do):
            return self.parse_do_while_statement()

        self.parse_expression_statement()

    # var/let/const declaration
    me parse_var_declaration(kind: text) -> BrowserResult<Statement>:
        self.advance()  # consume var/let/const

        # Check for destructuring pattern
        if self.check(JsTokenKind.OpenBrace) or self.check(JsTokenKind.OpenBracket):
            val pattern = self._parse_destruct_pattern()?
            self.match_token(JsTokenKind.Eq)
            val init_expr = self.parse_expression()?
            self.match_token(JsTokenKind.Semicolon)
            return Ok(Statement.DestructVarDecl(pattern: pattern, init: init_expr, kind: kind))

        val name = self.expect(JsTokenKind.Identifier)?

        var init_expr = Expression.Literal(value: JsValue.Undefined)
        if self.match_token(JsTokenKind.Eq):
            init_expr = self.parse_expression()?

        self.match_token(JsTokenKind.Semicolon)
        # Use LetDecl/ConstDecl for let/const to enable block scoping
        if kind == "let":
            return Ok(Statement.LetDecl(name: name, init: init_expr))
        if kind == "const":
            return Ok(Statement.ConstDecl(name: name, init: init_expr))
        Ok(Statement.VarDecl(name: name, init: init_expr))

    # Parse destructuring pattern: { a, b: c, d = 5 } or [a, b, ...rest]
    me _parse_destruct_pattern() -> BrowserResult<Expression>:
        if self.check(JsTokenKind.OpenBrace):
            self.advance()  # consume '{'
            var props: [DestructProp] = []
            if not self.check(JsTokenKind.CloseBrace):
                val first = self._parse_destruct_prop()?
                props.push(first)
                while self.match_token(JsTokenKind.Comma):
                    if self.check(JsTokenKind.CloseBrace):
                        break
                    val prop = self._parse_destruct_prop()?
                    props.push(prop)
            self.expect(JsTokenKind.CloseBrace)?
            return Ok(Expression.ObjectPattern(props: props))
        else:
            self.advance()  # consume '['
            var elements: [Expression] = []
            if not self.check(JsTokenKind.CloseBracket):
                # Check for rest element
                if self.check(JsTokenKind.DotDotDot):
                    self.advance()
                    val name = self.expect(JsTokenKind.Identifier)?
                    elements.push(Expression.SpreadElement(argument: Expression.Identifier(name: name)))
                else:
                    val first = self.parse_assignment()?
                    elements.push(first)
                while self.match_token(JsTokenKind.Comma):
                    if self.check(JsTokenKind.CloseBracket):
                        break
                    if self.check(JsTokenKind.DotDotDot):
                        self.advance()
                        val name = self.expect(JsTokenKind.Identifier)?
                        elements.push(Expression.SpreadElement(argument: Expression.Identifier(name: name)))
                    else:
                        val elem = self.parse_assignment()?
                        elements.push(elem)
            self.expect(JsTokenKind.CloseBracket)?
            return Ok(Expression.ArrayPattern(elements: elements))

    me _parse_destruct_prop() -> BrowserResult<DestructProp>:
        val key = self.expect(JsTokenKind.Identifier)?
        # Check for rename: { key: local_name }
        if self.match_token(JsTokenKind.Colon):
            val local_name = self.expect(JsTokenKind.Identifier)?
            var rename_default: Expression? = nil
            if self.match_token(JsTokenKind.Eq):
                val dv = self.parse_assignment()?
                rename_default = Some(dv)
            return Ok(DestructProp(key: key, value: Expression.Identifier(name: local_name), default_value: rename_default, is_computed: false))
        # Check for default value: { key = default }
        var default_val: Expression? = nil
        if self.match_token(JsTokenKind.Eq):
            val dv = self.parse_assignment()?
            default_val = Some(dv)
        Ok(DestructProp(key: key, value: Expression.Identifier(name: key), default_value: default_val, is_computed: false))

    # function declaration
    me parse_function_declaration() -> BrowserResult<Statement>:
        self.advance()  # consume 'function'
        val name = self.expect(JsTokenKind.Identifier)?
        self.expect(JsTokenKind.OpenParen)?

        var params: [text] = []
        if not self.check(JsTokenKind.CloseParen):
            val first = self.expect(JsTokenKind.Identifier)?
            params.push(first)
            while self.match_token(JsTokenKind.Comma):
                val param = self.expect(JsTokenKind.Identifier)?
                params.push(param)

        self.expect(JsTokenKind.CloseParen)?
        val body = self.parse_block()?
        Ok(Statement.FnDecl(name: name, params: params, body: body))

    # return statement
    me parse_return_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'return'
        var value = Expression.Literal(value: JsValue.Undefined)
        val is_end = self.check(JsTokenKind.Semicolon) or self.check(JsTokenKind.CloseBrace) or self.is_at_end()
        if not is_end:
            value = self.parse_expression()?
        self.match_token(JsTokenKind.Semicolon)
        Ok(Statement.Return(value: value))

    # if / else if / else
    me parse_if_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'if'
        self.expect(JsTokenKind.OpenParen)?
        val cond = self.parse_expression()?
        self.expect(JsTokenKind.CloseParen)?

        var then_body: [Statement] = []
        if self.check(JsTokenKind.OpenBrace):
            then_body = self.parse_block()?
        else:
            val single = self.parse_statement()?
            then_body.push(single)

        var else_body: [Statement] = []
        if self.match_token(JsTokenKind.Else):
            if self.check(JsTokenKind.If):
                val else_if = self.parse_if_statement()?
                else_body.push(else_if)
            else if self.check(JsTokenKind.OpenBrace):
                else_body = self.parse_block()?
            else:
                val single = self.parse_statement()?
                else_body.push(single)

        Ok(Statement.If(cond: cond, then_body: then_body, else_body: else_body))

    # while loop
    me parse_while_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'while'
        self.expect(JsTokenKind.OpenParen)?
        val cond = self.parse_expression()?
        self.expect(JsTokenKind.CloseParen)?

        var body: [Statement] = []
        if self.check(JsTokenKind.OpenBrace):
            body = self.parse_block()?
        else:
            val single = self.parse_statement()?
            body.push(single)

        Ok(Statement.While(cond: cond, body: body))

    # do...while loop
    me parse_do_while_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'do'
        var body: [Statement] = []
        if self.check(JsTokenKind.OpenBrace):
            body = self.parse_block()?
        else:
            body.push(self.parse_statement()?)
        self.expect(JsTokenKind.While)?
        self.expect(JsTokenKind.OpenParen)?
        val cond = self.parse_expression()?
        self.expect(JsTokenKind.CloseParen)?
        self.match_token(JsTokenKind.Semicolon)
        Ok(Statement.DoWhile(cond: cond, body: body))

    # for loop — C-style, for-in, for-of
    me parse_for_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'for'
        self.expect(JsTokenKind.OpenParen)?

        # Check for for-in / for-of
        val kind = self.current_kind
        if _is_token(kind, JsTokenKind.Var) or _is_token(kind, JsTokenKind.Let) or _is_token(kind, JsTokenKind.Const):
            val decl_kind = self.current_value
            self.advance()  # consume var/let/const
            val binding = self.expect(JsTokenKind.Identifier)?

            if self.check(JsTokenKind.In):
                # for (var k in obj) { ... }
                self.advance()  # consume 'in'
                val obj_expr = self.parse_expression()?
                self.expect(JsTokenKind.CloseParen)?
                var body: [Statement] = []
                if self.check(JsTokenKind.OpenBrace):
                    body = self.parse_block()?
                else:
                    body.push(self.parse_statement()?)
                return Ok(Statement.ForIn(binding: binding, object: obj_expr, body: body))

            if self.check(JsTokenKind.Of):
                # for (var x of arr) { ... }
                self.advance()  # consume 'of'
                val iter_expr = self.parse_expression()?
                self.expect(JsTokenKind.CloseParen)?
                var body: [Statement] = []
                if self.check(JsTokenKind.OpenBrace):
                    body = self.parse_block()?
                else:
                    body.push(self.parse_statement()?)
                return Ok(Statement.ForOf(binding: binding, iterable: iter_expr, body: body))

            # C-style for: var x = init; cond; update
            # We already consumed "var x", now need "= expr;"
            var init_expr = Expression.Literal(value: JsValue.Undefined)
            if self.match_token(JsTokenKind.Eq):
                init_expr = self.parse_expression()?
            val init_stmt = Statement.VarDecl(name: binding, init: init_expr)
            self.match_token(JsTokenKind.Semicolon)

            # Condition
            var cond = Expression.Literal(value: JsValue.Boolean(v: true))
            if not self.check(JsTokenKind.Semicolon):
                cond = self.parse_expression()?
            self.expect(JsTokenKind.Semicolon)?

            # Update
            var update = Expression.Literal(value: JsValue.Undefined)
            if not self.check(JsTokenKind.CloseParen):
                update = self.parse_expression()?
            self.expect(JsTokenKind.CloseParen)?

            var body: [Statement] = []
            if self.check(JsTokenKind.OpenBrace):
                body = self.parse_block()?
            else:
                body.push(self.parse_statement()?)
            return Ok(Statement.For(init: init_stmt, cond: cond, update: update, body: body))

        # Non-var init
        var init_stmt = Statement.ExprStmt(expr: Expression.Literal(value: JsValue.Undefined))
        if not self.check(JsTokenKind.Semicolon):
            val expr = self.parse_expression()?
            init_stmt = Statement.ExprStmt(expr: expr)
            self.match_token(JsTokenKind.Semicolon)
        else:
            self.match_token(JsTokenKind.Semicolon)

        var cond = Expression.Literal(value: JsValue.Boolean(v: true))
        if not self.check(JsTokenKind.Semicolon):
            cond = self.parse_expression()?
        self.expect(JsTokenKind.Semicolon)?

        var update = Expression.Literal(value: JsValue.Undefined)
        if not self.check(JsTokenKind.CloseParen):
            update = self.parse_expression()?
        self.expect(JsTokenKind.CloseParen)?

        var body: [Statement] = []
        if self.check(JsTokenKind.OpenBrace):
            body = self.parse_block()?
        else:
            body.push(self.parse_statement()?)
        Ok(Statement.For(init: init_stmt, cond: cond, update: update, body: body))

    # Block { ... }
    me parse_block() -> BrowserResult<[Statement]>:
        self.expect(JsTokenKind.OpenBrace)?
        var stmts: [Statement] = []
        while not self.check(JsTokenKind.CloseBrace) and not self.is_at_end():
            val stmt = self.parse_statement()?
            stmts.push(stmt)
        self.expect(JsTokenKind.CloseBrace)?
        Ok(stmts)

    # Expression statement
    me parse_expression_statement() -> BrowserResult<Statement>:
        val expr = self.parse_expression()?
        # Check for labeled statement: Identifier followed by Colon
        val ident_name = _get_ident_name(expr)
        if ident_name != "" and self.check(JsTokenKind.Colon):
            self.advance()
            val body = self.parse_statement()?
            return Ok(Statement.LabeledStmt(label: ident_name, body: body))
        self.match_token(JsTokenKind.Semicolon)
        Ok(Statement.ExprStmt(expr: expr))

    # try / catch / finally
    me parse_try_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'try'
        val try_body = self.parse_block()?

        var catch_body: [Statement] = []
        var catch_param = ""
        if self.match_token(JsTokenKind.Catch):
            if self.match_token(JsTokenKind.OpenParen):
                val param = self.expect(JsTokenKind.Identifier)?
                catch_param = param
                self.expect(JsTokenKind.CloseParen)?
            catch_body = self.parse_block()?

        var finally_body: [Statement] = []
        if self.match_token(JsTokenKind.Finally):
            finally_body = self.parse_block()?

        Ok(Statement.TryCatch(try_body: try_body, catch_param: catch_param, catch_body: catch_body, finally_body: finally_body))

    # switch statement with proper SwitchCase nodes
    me parse_switch_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'switch'
        self.expect(JsTokenKind.OpenParen)?
        val discriminant = self.parse_expression()?
        self.expect(JsTokenKind.CloseParen)?
        self.expect(JsTokenKind.OpenBrace)?

        var cases: [SwitchCase] = []
        while not self.check(JsTokenKind.CloseBrace) and not self.is_at_end():
            if self.match_token(JsTokenKind.Case):
                val test_expr = self.parse_expression()?
                self.expect(JsTokenKind.Colon)?
                var case_body: [Statement] = []
                while not self.check(JsTokenKind.Case) and not self.check(JsTokenKind.Default) and not self.check(JsTokenKind.CloseBrace):
                    val s = self.parse_statement()?
                    case_body.push(s)
                cases.push(SwitchCase.case_clause(test_expr, case_body))
            else if self.match_token(JsTokenKind.Default):
                self.expect(JsTokenKind.Colon)?
                var default_body: [Statement] = []
                while not self.check(JsTokenKind.Case) and not self.check(JsTokenKind.CloseBrace):
                    val s = self.parse_statement()?
                    default_body.push(s)
                cases.push(SwitchCase.default_clause(default_body))
            else:
                self.advance()  # skip unexpected token

        self.expect(JsTokenKind.CloseBrace)?
        Ok(Statement.Switch(discriminant: discriminant, cases: cases))

    # throw statement
    me parse_throw_statement() -> BrowserResult<Statement>:
        self.advance()  # consume 'throw'
        val expr = self.parse_expression()?
        self.match_token(JsTokenKind.Semicolon)
        Ok(Statement.ThrowStmt(expr: expr))

    # class declaration: class Name [extends Parent] { constructor(...) {...} method(...) {...} }
    me parse_class_declaration() -> BrowserResult<Statement>:
        self.advance()  # consume 'class'
        var class_name = ""
        if self.check(JsTokenKind.Identifier):
            class_name = self.current_value
            self.advance()

        var parent_name = ""
        if self.match_token(JsTokenKind.Extends):
            if self.check(JsTokenKind.Identifier):
                parent_name = self.current_value
                self.advance()

        self.expect(JsTokenKind.OpenBrace)?

        var empty_params: [text] = []
        var empty_body: [Statement] = []
        var constructor_decl = Statement.FnDecl(name: "constructor", params: empty_params, body: empty_body)
        var methods: [Statement] = []

        while not self.check(JsTokenKind.CloseBrace) and not self.is_at_end():
            # Parse method name
            var method_name = ""
            if self.check(JsTokenKind.Identifier):
                method_name = self.current_value
                self.advance()
            else:
                self.advance()
                continue

            # Parse method params
            self.expect(JsTokenKind.OpenParen)?
            var params: [text] = []
            if not self.check(JsTokenKind.CloseParen):
                val first = self.expect(JsTokenKind.Identifier)?
                params.push(first)
                while self.match_token(JsTokenKind.Comma):
                    val param = self.expect(JsTokenKind.Identifier)?
                    params.push(param)
            self.expect(JsTokenKind.CloseParen)?

            # Parse method body
            val body = self.parse_block()?
            val fn_decl = Statement.FnDecl(name: method_name, params: params, body: body)

            if method_name == "constructor":
                constructor_decl = fn_decl
            else:
                methods.push(fn_decl)

        self.expect(JsTokenKind.CloseBrace)?
        Ok(Statement.ClassDecl(name: class_name, parent_name: parent_name, constructor: constructor_decl, methods: methods))

    # ── Expressions (precedence climbing) ────────────────────────────────

    me parse_expression() -> BrowserResult<Expression>:
        self.parse_assignment()

    # Assignment: x = expr, x += expr, etc.
    me parse_assignment() -> BrowserResult<Expression>:
        val left = self.parse_ternary()?

        val kind = self.current_kind
        if _is_token(kind, JsTokenKind.Eq):
            self.advance()
            val right = self.parse_assignment()?
            return Ok(Expression.Assignment(target: left, value: right))

        if _is_token(kind, JsTokenKind.PlusEq):
            self.advance()
            val right = self.parse_assignment()?
            val sum = Expression.Binary(op: "+", left: left, right: right)
            return Ok(Expression.Assignment(target: left, value: sum))

        if _is_token(kind, JsTokenKind.MinusEq):
            self.advance()
            val right = self.parse_assignment()?
            val diff = Expression.Binary(op: "-", left: left, right: right)
            return Ok(Expression.Assignment(target: left, value: diff))

        if _is_token(kind, JsTokenKind.StarEq):
            self.advance()
            val right = self.parse_assignment()?
            val prod = Expression.Binary(op: "*", left: left, right: right)
            return Ok(Expression.Assignment(target: left, value: prod))

        if _is_token(kind, JsTokenKind.SlashEq):
            self.advance()
            val right = self.parse_assignment()?
            val quot = Expression.Binary(op: "/", left: left, right: right)
            return Ok(Expression.Assignment(target: left, value: quot))

        Ok(left)

    # Ternary: cond ? then : else
    me parse_ternary() -> BrowserResult<Expression>:
        var expr = self.parse_nullish_coalescing()?

        if self.match_token(JsTokenKind.Question):
            val then_expr = self.parse_assignment()?
            self.expect(JsTokenKind.Colon)?
            val else_expr = self.parse_assignment()?
            expr = Expression.Ternary(condition: expr, consequent: then_expr, alternate: else_expr)

        Ok(expr)

    # Nullish coalescing: a ?? b
    me parse_nullish_coalescing() -> BrowserResult<Expression>:
        var left = self.parse_or()?
        while self.match_token(JsTokenKind.QuestionQuestion):
            val right = self.parse_or()?
            left = Expression.Binary(op: "??", left: left, right: right)
        Ok(left)

    # Logical OR: a || b
    me parse_or() -> BrowserResult<Expression>:
        var left = self.parse_and()?
        while self.match_token(JsTokenKind.PipePipe):
            val right = self.parse_and()?
            left = Expression.Binary(op: "||", left: left, right: right)
        Ok(left)

    # Logical AND: a && b
    me parse_and() -> BrowserResult<Expression>:
        var left = self.parse_bitwise_or()?
        while self.match_token(JsTokenKind.AmpersandAmpersand):
            val right = self.parse_bitwise_or()?
            left = Expression.Binary(op: "&&", left: left, right: right)
        Ok(left)

    # Bitwise OR: a | b
    me parse_bitwise_or() -> BrowserResult<Expression>:
        var left = self.parse_bitwise_xor()?
        while self.match_token(JsTokenKind.Pipe):
            val right = self.parse_bitwise_xor()?
            left = Expression.Binary(op: "|", left: left, right: right)
        Ok(left)

    # Bitwise XOR: a ^ b
    me parse_bitwise_xor() -> BrowserResult<Expression>:
        var left = self.parse_bitwise_and()?
        while self.match_token(JsTokenKind.Caret):
            val right = self.parse_bitwise_and()?
            left = Expression.Binary(op: "^", left: left, right: right)
        Ok(left)

    # Bitwise AND: a & b
    me parse_bitwise_and() -> BrowserResult<Expression>:
        var left = self.parse_equality()?
        while self.match_token(JsTokenKind.Ampersand):
            val right = self.parse_equality()?
            left = Expression.Binary(op: "&", left: left, right: right)
        Ok(left)

    # Equality: == === != !==
    me parse_equality() -> BrowserResult<Expression>:
        var left = self.parse_comparison()?
        while true:
            val kind = self.current_kind
            if _is_token(kind, JsTokenKind.EqEq):
                self.advance()
                val right = self.parse_comparison()?
                left = Expression.Binary(op: "==", left: left, right: right)
            else if _is_token(kind, JsTokenKind.EqEqEq):
                self.advance()
                val right = self.parse_comparison()?
                left = Expression.Binary(op: "===", left: left, right: right)
            else if _is_token(kind, JsTokenKind.BangEq):
                self.advance()
                val right = self.parse_comparison()?
                left = Expression.Binary(op: "!=", left: left, right: right)
            else if _is_token(kind, JsTokenKind.BangEqEq):
                self.advance()
                val right = self.parse_comparison()?
                left = Expression.Binary(op: "!==", left: left, right: right)
            else:
                break
        Ok(left)

    # Comparison: < > <= >= instanceof in
    me parse_comparison() -> BrowserResult<Expression>:
        var left = self.parse_addition()?
        while true:
            val kind = self.current_kind
            if _is_token(kind, JsTokenKind.Lt):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.Binary(op: "<", left: left, right: right)
            else if _is_token(kind, JsTokenKind.Gt):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.Binary(op: ">", left: left, right: right)
            else if _is_token(kind, JsTokenKind.LtEq):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.Binary(op: "<=", left: left, right: right)
            else if _is_token(kind, JsTokenKind.GtEq):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.Binary(op: ">=", left: left, right: right)
            else if _is_token(kind, JsTokenKind.Instanceof):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.InstanceOf(left: left, right: right)
            else if _is_token(kind, JsTokenKind.In):
                self.advance()
                val right = self.parse_addition()?
                left = Expression.InExpr(left: left, right: right)
            else:
                break
        Ok(left)

    # Addition / subtraction: + -
    me parse_addition() -> BrowserResult<Expression>:
        var left = self.parse_multiplication()?
        while true:
            val kind = self.current_kind
            if _is_token(kind, JsTokenKind.Plus):
                self.advance()
                val right = self.parse_multiplication()?
                left = Expression.Binary(op: "+", left: left, right: right)
            else if _is_token(kind, JsTokenKind.Minus):
                self.advance()
                val right = self.parse_multiplication()?
                left = Expression.Binary(op: "-", left: left, right: right)
            else:
                break
        Ok(left)

    # Multiplication / division / modulo: * / %
    me parse_multiplication() -> BrowserResult<Expression>:
        var left = self.parse_exponentiation()?
        while true:
            val kind = self.current_kind
            if _is_token(kind, JsTokenKind.Star):
                self.advance()
                val right = self.parse_exponentiation()?
                left = Expression.Binary(op: "*", left: left, right: right)
            else if _is_token(kind, JsTokenKind.Slash):
                self.advance()
                val right = self.parse_exponentiation()?
                left = Expression.Binary(op: "/", left: left, right: right)
            else if _is_token(kind, JsTokenKind.Percent):
                self.advance()
                val right = self.parse_exponentiation()?
                left = Expression.Binary(op: "%", left: left, right: right)
            else:
                break
        Ok(left)

    # Exponentiation: ** (right-associative)
    me parse_exponentiation() -> BrowserResult<Expression>:
        val base = self.parse_unary()?
        if self.match_token(JsTokenKind.StarStar):
            val exp = self.parse_exponentiation()?  # right-assoc recursion
            return Ok(Expression.Binary(op: "**", left: base, right: exp))
        Ok(base)

    # Unary: ! - + typeof void delete ~ ++x --x
    me parse_unary() -> BrowserResult<Expression>:
        val kind = self.current_kind

        if _is_token(kind, JsTokenKind.Bang):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "!", operand: operand))

        if _is_token(kind, JsTokenKind.Minus):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "-", operand: operand))

        if _is_token(kind, JsTokenKind.Plus):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "+", operand: operand))

        if _is_token(kind, JsTokenKind.Typeof):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "typeof", operand: operand))

        if _is_token(kind, JsTokenKind.Void):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "void", operand: operand))

        if _is_token(kind, JsTokenKind.Delete):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Delete(expr: operand))

        if _is_token(kind, JsTokenKind.Tilde):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "~", operand: operand))

        if _is_token(kind, JsTokenKind.PlusPlus):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "++pre", operand: operand))

        if _is_token(kind, JsTokenKind.MinusMinus):
            self.advance()
            val operand = self.parse_unary()?
            return Ok(Expression.Unary(op: "--pre", operand: operand))

        self.parse_postfix()

    # Postfix: x++ x--
    me parse_postfix() -> BrowserResult<Expression>:
        var expr = self.parse_call_expression()?

        if _is_token(self.current_kind, JsTokenKind.PlusPlus):
            self.advance()
            expr = Expression.Unary(op: "++post", operand: expr)

        if _is_token(self.current_kind, JsTokenKind.MinusMinus):
            self.advance()
            expr = Expression.Unary(op: "--post", operand: expr)

        Ok(expr)

    # Call / member / index: f(args), obj.prop, arr[idx], obj?.prop
    me parse_call_expression() -> BrowserResult<Expression>:
        var expr = self.parse_primary()?

        while true:
            val kind = self.current_kind

            if _is_token(kind, JsTokenKind.OpenParen):
                # Function call
                self.advance()
                var args: [Expression] = []
                if not self.check(JsTokenKind.CloseParen):
                    val first_arg = self.parse_assignment()?
                    args.push(first_arg)
                    while self.match_token(JsTokenKind.Comma):
                        val arg = self.parse_assignment()?
                        args.push(arg)
                self.expect(JsTokenKind.CloseParen)?
                expr = Expression.Call(callee: expr, args: args)

            else if _is_token(kind, JsTokenKind.Dot):
                # Member access
                self.advance()
                val prop = self.expect(JsTokenKind.Identifier)?
                expr = Expression.Member(object: expr, property: prop)

            else if _is_token(kind, JsTokenKind.QuestionDot):
                # Optional chaining
                self.advance()
                val prop = self.expect(JsTokenKind.Identifier)?
                expr = Expression.Member(object: expr, property: prop)

            else if _is_token(kind, JsTokenKind.OpenBracket):
                # Index access: obj[expr]
                self.advance()
                val index_expr = self.parse_expression()?
                self.expect(JsTokenKind.CloseBracket)?
                # Encode computed member access as Call with special callee
                expr = Expression.Binary(op: "[]", left: expr, right: index_expr)

            else:
                break

        Ok(expr)

    # Primary: literals, identifiers, grouped, arrays, objects, arrow functions
    me parse_primary() -> BrowserResult<Expression>:
        val kind = self.current_kind

        # Number literal
        if _is_token(kind, JsTokenKind.Number):
            val value = self.current_value
            self.advance()
            val num = value.parse_float() ?? 0.0
            return Ok(Expression.Literal(value: JsValue.Number(v: num)))

        # String literal
        if _is_token(kind, JsTokenKind.String):
            val value = self.current_value
            self.advance()
            return Ok(Expression.Literal(value: JsValue.String(v: value)))

        # Template literal
        if _is_token(kind, JsTokenKind.TemplateLiteral):
            val value = self.current_value
            self.advance()
            return self._parse_template_parts(value)

        # Boolean true
        if _is_token(kind, JsTokenKind.TrueKw):
            self.advance()
            return Ok(Expression.Literal(value: JsValue.Boolean(v: true)))

        # Boolean false
        if _is_token(kind, JsTokenKind.FalseKw):
            self.advance()
            return Ok(Expression.Literal(value: JsValue.Boolean(v: false)))

        # null
        if _is_token(kind, JsTokenKind.NullKw):
            self.advance()
            return Ok(Expression.Literal(value: JsValue.Null))

        # undefined
        if _is_token(kind, JsTokenKind.Undefined):
            self.advance()
            return Ok(Expression.Literal(value: JsValue.Undefined))

        # this
        if _is_token(kind, JsTokenKind.This):
            self.advance()
            return Ok(Expression.Identifier(name: "this"))

        # new — e.g., new Foo(args)
        if _is_token(kind, JsTokenKind.New):
            self.advance()
            val callee = self.parse_call_expression()?
            return Ok(Expression.Unary(op: "new", operand: callee))

        # Identifier (or arrow function)
        if _is_token(kind, JsTokenKind.Identifier):
            # Check for single-param arrow: ident => expr
            val ident_name = self.current_value
            self.advance()
            if self.check(JsTokenKind.Arrow):
                var single_param: [text] = []
                single_param.push(ident_name)
                return self.parse_arrow_body(single_param)
            return Ok(Expression.Identifier(name: ident_name))

        # Grouped expression or arrow function params
        if _is_token(kind, JsTokenKind.OpenParen):
            return self.parse_grouped_or_arrow()

        # Array literal [...]
        if _is_token(kind, JsTokenKind.OpenBracket):
            return self.parse_array_literal()

        # Object literal {...}
        if _is_token(kind, JsTokenKind.OpenBrace):
            return self.parse_object_literal()

        # function expression
        if _is_token(kind, JsTokenKind.Function):
            return self.parse_function_expression()

        # Fallthrough — unexpected token
        val bad_value = self.current_value
        self.advance()
        val msg = "Unexpected token '{bad_value}'"
        self.logger.warn(msg)
        Err(script_error(msg))

    # Grouped expression (a + b) or arrow function (a, b) => ...
    me parse_grouped_or_arrow() -> BrowserResult<Expression>:
        self.advance()  # consume '('

        # Empty parens => arrow with no params
        if self.check(JsTokenKind.CloseParen):
            self.advance()
            if self.check(JsTokenKind.Arrow):
                var no_params: [text] = []
                return self.parse_arrow_body(no_params)
            return Ok(Expression.Literal(value: JsValue.Undefined))

        # Parse first item as assignment (not full expression, to not consume commas)
        val first = self.parse_assignment()?

        # If comma follows, could be arrow params OR comma expression
        if self.check(JsTokenKind.Comma):
            var items: [Expression] = []
            items.push(first)
            while self.match_token(JsTokenKind.Comma):
                val item = self.parse_assignment()?
                items.push(item)
            self.expect(JsTokenKind.CloseParen)?
            # Check for arrow after close paren
            if self.check(JsTokenKind.Arrow):
                var params: [text] = []
                var pi = 0
                while pi < items.len():
                    val pname = _get_ident_name(items.get(pi))
                    if pname != "":
                        params.push(pname)
                    pi = pi + 1
                return self.parse_arrow_body(params)
            # Not arrow — comma expression, fold left
            var result = items.get(0)
            var ci = 1
            while ci < items.len():
                result = Expression.Binary(op: ",", left: result, right: items.get(ci))
                ci = ci + 1
            return Ok(result)

        self.expect(JsTokenKind.CloseParen)?

        # Check for arrow after single-param parens: (x) => ...
        val ident_name = _get_ident_name(first)
        if ident_name != "" and self.check(JsTokenKind.Arrow):
            var single_param: [text] = []
            single_param.push(ident_name)
            return self.parse_arrow_body(single_param)

        Ok(first)

    # Parse template literal parts — split raw string into quasis and ${...} expressions
    me _parse_template_parts(raw: text) -> BrowserResult<Expression>:
        var quasis: [text] = []
        var exprs: [Expression] = []
        var current = ""
        var i = 0
        val len = raw.len()
        while i < len:
            val c = raw[i]
            if c == "$" and i + 1 < len and raw[i + 1] == "{":
                quasis.push(current)
                current = ""
                i = i + 2
                # Find matching closing brace
                var depth = 1
                var expr_text = ""
                while i < len and depth > 0:
                    val ec = raw[i]
                    if ec == "{":
                        depth = depth + 1
                        expr_text = expr_text + ec
                    if ec == "}":
                        depth = depth - 1
                        if depth > 0:
                            expr_text = expr_text + ec
                    if depth > 0 and ec != "{" and ec != "}":
                        expr_text = expr_text + ec
                    i = i + 1
                # Parse the expression
                var sub_parser = JsParser.new(expr_text, self.logger)
                val expr = sub_parser.parse_expression()?
                exprs.push(expr)
            else:
                current = current + c
                i = i + 1
        quasis.push(current)
        if exprs.len() == 0:
            return Ok(Expression.Literal(value: JsValue.String(v: raw)))
        Ok(Expression.TemplateLiteral(quasis: quasis, expressions: exprs))

    # Parse arrow function body: => expr or => { stmts }
    me parse_arrow_body(params: [text]) -> BrowserResult<Expression>:
        self.expect(JsTokenKind.Arrow)?

        if self.check(JsTokenKind.OpenBrace):
            val body = self.parse_block()?
            return Ok(Expression.ArrowFunction(params: params, body: body))
        else:
            val body_expr = self.parse_assignment()?
            # Wrap expression body as implicit return
            var body: [Statement] = []
            body.push(Statement.Return(value: body_expr))
            return Ok(Expression.ArrowFunction(params: params, body: body))

    # Array literal: [1, 2, 3] with spread support: [1, ...arr, 3]
    me parse_array_literal() -> BrowserResult<Expression>:
        self.advance()  # consume '['
        var elements: [Expression] = []
        if not self.check(JsTokenKind.CloseBracket):
            if self.check(JsTokenKind.DotDotDot):
                self.advance()
                val spread_expr = self.parse_assignment()?
                elements.push(Expression.SpreadElement(argument: spread_expr))
            else:
                val first = self.parse_assignment()?
                elements.push(first)
            while self.match_token(JsTokenKind.Comma):
                if self.check(JsTokenKind.CloseBracket):
                    break  # trailing comma
                if self.check(JsTokenKind.DotDotDot):
                    self.advance()
                    val spread_expr = self.parse_assignment()?
                    elements.push(Expression.SpreadElement(argument: spread_expr))
                else:
                    val elem = self.parse_assignment()?
                    elements.push(elem)
        self.expect(JsTokenKind.CloseBracket)?
        Ok(Expression.Array(elements: elements))

    # Object literal: { key: value, ... }
    me parse_object_literal() -> BrowserResult<Expression>:
        self.advance()  # consume '{'
        var properties: [Pair<text, Expression>] = []
        if not self.check(JsTokenKind.CloseBrace):
            val first = self._parse_object_property()?
            properties.push(first)
            while self.match_token(JsTokenKind.Comma):
                if self.check(JsTokenKind.CloseBrace):
                    break  # trailing comma
                val prop = self._parse_object_property()?
                properties.push(prop)
        self.expect(JsTokenKind.CloseBrace)?
        Ok(Expression.ObjectExpr(properties: properties))

    # Parse a single object property: key: value
    me _parse_object_property() -> BrowserResult<Pair<text, Expression>>:
        var key = ""
        val kind = self.current_kind
        if _is_token(kind, JsTokenKind.Identifier):
            key = self.current_value
            self.advance()
        else if _is_token(kind, JsTokenKind.String):
            key = self.current_value
            self.advance()
        else if _is_token(kind, JsTokenKind.Number):
            key = self.current_value
            self.advance()
        else:
            key = self.current_value
            self.advance()

        # Shorthand: { x } means { x: x }
        if not self.check(JsTokenKind.Colon):
            val shorthand = Expression.Identifier(name: key)
            return Ok(Pair(first: key, second: shorthand))

        self.expect(JsTokenKind.Colon)?
        val value = self.parse_assignment()?
        Ok(Pair(first: key, second: value))

    # Function expression: function(params) { body }
    # Reuses ArrowFunction AST node — interpreter handles both the same way
    me parse_function_expression() -> BrowserResult<Expression>:
        self.advance()  # consume 'function'

        var name = ""
        if self.check(JsTokenKind.Identifier):
            name = self.current_value
            self.advance()

        self.expect(JsTokenKind.OpenParen)?
        var params: [text] = []
        if not self.check(JsTokenKind.CloseParen):
            val first = self.expect(JsTokenKind.Identifier)?
            params.push(first)
            while self.match_token(JsTokenKind.Comma):
                val param = self.expect(JsTokenKind.Identifier)?
                params.push(param)
        self.expect(JsTokenKind.CloseParen)?

        val body = self.parse_block()?

        # Use ArrowFunction node — interpreter registers it as a closure
        Ok(Expression.ArrowFunction(params: params, body: body))
