#![allow(unnamed_duplicate_typed_args)]
# JavaScript interpreter support types and helpers.
# Extracted from interpreter.spl: scope chain, call frames, type coercion, equality.

use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.engine.js_error.{js_nan, js_infinity, js_neg_infinity, is_nan}

# ── Environment (scope chain) ───────────────────────────────────────────

class Environment:
    variables: [Pair<text, JsValue>]
    parent_id: i64
    id: i64

    static fn create(id: i64, parent_id: i64) -> Environment:
        Environment(variables: [], parent_id: parent_id, id: id)

class EnvironmentStack:
    # Flat parallel arrays — avoids .get(i).field.mutate() copy bug in interpreter mode.
    # Environment metadata (indexed by env_id)
    env_parent_ids: [i64]
    next_id: i64
    # Variable storage (one entry per variable across all envs)
    var_names: [text]
    var_values: [JsValue]
    var_env_ids: [i64]

    static fn new() -> EnvironmentStack:
        EnvironmentStack(env_parent_ids: [], next_id: 0, var_names: [], var_values: [], var_env_ids: [])

    me create_env(parent_id: i64) -> i64:
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.env_parent_ids.push(parent_id)
        id

    me _env_parent(env_id: i64) -> i64:
        if env_id >= 0 and env_id < self.env_parent_ids.len():
            return self.env_parent_ids.get(env_id)
        -1

    # Get a variable by searching up the scope chain
    # Scans from end — latest push wins (append-only, no .set())
    me get_var(env_id: i64, name: text) -> Option<JsValue>:
        var current_id = env_id
        while current_id >= 0:
            var j = self.var_names.len() - 1
            while j >= 0:
                if self.var_env_ids.get(j) == current_id and self.var_names.get(j) == name:
                    return Some(self.var_values.get(j))
                j = j - 1
            current_id = self._env_parent(current_id)
        nil

    # Set an existing variable (searches up scope chain)
    # Appends new entry — latest wins on read
    me set_var(env_id: i64, name: text, value: JsValue):
        var current_id = env_id
        while current_id >= 0:
            var j = self.var_names.len() - 1
            while j >= 0:
                if self.var_env_ids.get(j) == current_id and self.var_names.get(j) == name:
                    # Found in this scope — push update
                    self.var_names.push(name)
                    self.var_values.push(value)
                    self.var_env_ids.push(current_id)
                    return
                j = j - 1
            current_id = self._env_parent(current_id)
        # Variable not found — define in the given env
        self.define_var(env_id, name, value)

    # Define a new variable in the given environment
    # Always appends — latest entry wins on read
    me define_var(env_id: i64, name: text, value: JsValue):
        self.var_names.push(name)
        self.var_values.push(value)
        self.var_env_ids.push(env_id)

# ── Call frame ───────────────────────────────────────────────────────────

class CallFrame:
    function_name: text
    env_id: i64
    line: i64
    this_value: JsValue

# ── Stored function ──────────────────────────────────────────────────────

class JsFunction:
    name: text
    params: [text]
    body: [Statement]
    closure_env: i64

use std.js.types.ast_types.Statement

# ── Float-to-int helper (interpreter mode has no .to_i64() on f64) ──────

fn _digit_val(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

fn f64_to_i64(v: f64) -> i64:
    val s = "{v}"
    var n = 0
    var neg = false
    var i = 0
    val slen = s.len()
    if slen > 0 and s[0] == "-":
        neg = true
        i = 1
    while i < slen:
        val ch = s[i]
        if ch == ".":
            i = slen
        else:
            val d = _digit_val(ch)
            if d >= 0:
                n = n * 10 + d
        i = i + 1
    if neg:
        return 0 - n
    n

# ── Type coercion helpers ────────────────────────────────────────────────

fn to_number(value: JsValue) -> f64:
    match value:
        JsValue.Number(v): v
        JsValue.Boolean(v):
            if v: 1.0
            else: 0.0
        JsValue.Null: 0.0
        JsValue.Undefined: js_nan()  # NaN
        JsValue.String(v):
            if v == "":
                return 0.0
            val parsed = v.parse_float()
            if val Some(n) = parsed:
                return n
            js_nan()  # NaN
        _: js_nan()  # NaN

fn js_to_string(value: JsValue) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(v):
            if v: "true"
            else: "false"
        JsValue.Number(v):
            # JS: integer-valued floats display without decimal (1.0 → "1")
            var s = "{v}"
            val slen = s.len()
            if slen >= 3 and s[slen - 2] == "." and s[slen - 1] == "0":
                var result = ""
                var ci = 0
                while ci < slen - 2:
                    result = result + s[ci]
                    ci = ci + 1
                return result
            s
        JsValue.String(v): v
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "function"
        JsValue.Symbol(id): "Symbol()"

fn to_boolean(value: JsValue) -> bool:
    match value:
        JsValue.Undefined: false
        JsValue.Null: false
        JsValue.Boolean(v): v
        JsValue.Number(v):
            if v == 0.0: false
            else: true
        JsValue.String(v):
            v.len() > 0
        _: true

fn is_truthy(value: JsValue) -> bool:
    to_boolean(value)

fn typeof_value(value: JsValue) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "object"  # JS spec quirk
        JsValue.Boolean(v): "boolean"
        JsValue.Number(v): "number"
        JsValue.String(v): "string"
        JsValue.Object(id): "object"
        JsValue.Array(id): "object"
        JsValue.Function(id): "function"
        JsValue.Symbol(id): "symbol"

fn strict_equals(a: JsValue, b: JsValue) -> bool:
    match a:
        JsValue.Undefined:
            match b:
                JsValue.Undefined: true
                _: false
        JsValue.Null:
            match b:
                JsValue.Null: true
                _: false
        JsValue.Boolean(va):
            match b:
                JsValue.Boolean(vb): va == vb
                _: false
        JsValue.Number(va):
            match b:
                JsValue.Number(vb): va == vb
                _: false
        JsValue.String(va):
            match b:
                JsValue.String(vb): va == vb
                _: false
        JsValue.Object(ia):
            match b:
                JsValue.Object(ib): ia == ib
                _: false
        JsValue.Array(ia):
            match b:
                JsValue.Array(ib): ia == ib
                _: false
        JsValue.Function(ia):
            match b:
                JsValue.Function(ib): ia == ib
                _: false
        _: false

fn abstract_equals(a: JsValue, b: JsValue) -> bool:
    # Same type — use strict
    val ta = typeof_value(a)
    val tb = typeof_value(b)
    if ta == tb:
        return strict_equals(a, b)

    # null == undefined (avoid nested match — interpreter mode issue)
    val a_null = strict_equals(a, JsValue.Null)
    val b_null = strict_equals(b, JsValue.Null)
    val a_undef = strict_equals(a, JsValue.Undefined)
    val b_undef = strict_equals(b, JsValue.Undefined)
    if (a_null and b_undef) or (a_undef and b_null):
        return true
    if a_null or b_null or a_undef or b_undef:
        return false

    # Number comparisons with coercion
    val na = to_number(a)
    val nb = to_number(b)
    na == nb

# ── Signal values for control flow ───────────────────────────────────────

# We use a special string convention to signal return from functions.
# The interpreter checks for this after each statement execution.
val RETURN_SIGNAL = "__js_return__"

fn _get_fn_id(v: JsValue) -> i64:
    match v:
        JsValue.Function(id): id
        _: -1

fn _get_obj_id(v: JsValue) -> i64:
    match v:
        JsValue.Object(id): id
        JsValue.Array(id): id
        _: -1

fn _is_array_method(name: text) -> bool:
    (name == "map" or name == "filter" or name == "reduce" or
    name == "forEach" or name == "find" or name == "findIndex" or
    name == "some" or name == "every" or name == "sort" or
    name == "push" or name == "pop" or name == "shift" or
    name == "unshift" or name == "slice" or name == "splice" or
    name == "indexOf" or name == "includes" or name == "join" or
    name == "reverse" or name == "concat" or
    name == "at" or name == "flat" or name == "flatMap")

fn _is_string_method(name: text) -> bool:
    (name == "indexOf" or name == "lastIndexOf" or
    name == "toLowerCase" or name == "toUpperCase" or
    name == "trim" or name == "trimStart" or name == "trimEnd" or
    name == "split" or name == "slice" or name == "substring" or
    name == "charAt" or name == "charCodeAt" or
    name == "startsWith" or name == "endsWith" or
    name == "includes" or name == "replace" or name == "replaceAll" or
    name == "repeat" or name == "padStart" or name == "padEnd" or
    name == "concat" or name == "at")
