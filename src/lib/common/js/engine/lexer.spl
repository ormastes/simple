#![allow(unnamed_duplicate_typed_args)]
# JavaScript lexer/tokenizer for the Simple Browser Platform.
# Converts JS source text into a stream of JsToken values.
# Handles numbers (int, float, hex, binary, octal), strings (single/double/template),
# identifiers, keywords, and multi-character operators.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError}

fn _substr(s: text, start: i64, end_idx: i64) -> text:
    """Subscript-based substring that works in interpreter mode."""
    var result = ""
    var i = start
    while i < end_idx and i < s.len():
        result = result + s[i]
        i = i + 1
    result

fn js_lexer_char_from_code(code: i64) -> text:
    if code == 32: return " "
    if code == 33: return "!"
    if code == 34: return "\""
    if code == 35: return "#"
    if code == 36: return "$"
    if code == 37: return "%"
    if code == 38: return "&"
    if code == 39: return "'"
    if code == 40: return "("
    if code == 41: return ")"
    if code == 42: return "*"
    if code == 43: return "+"
    if code == 44: return ","
    if code == 45: return "-"
    if code == 46: return "."
    if code == 47: return "/"
    if code == 48: return "0"
    if code == 49: return "1"
    if code == 50: return "2"
    if code == 51: return "3"
    if code == 52: return "4"
    if code == 53: return "5"
    if code == 54: return "6"
    if code == 55: return "7"
    if code == 56: return "8"
    if code == 57: return "9"
    if code == 58: return ":"
    if code == 59: return ";"
    if code == 60: return "<"
    if code == 61: return "="
    if code == 62: return ">"
    if code == 63: return "?"
    if code == 64: return "@"
    if code == 65: return "A"
    if code == 66: return "B"
    if code == 67: return "C"
    if code == 68: return "D"
    if code == 69: return "E"
    if code == 70: return "F"
    if code == 71: return "G"
    if code == 72: return "H"
    if code == 73: return "I"
    if code == 74: return "J"
    if code == 75: return "K"
    if code == 76: return "L"
    if code == 77: return "M"
    if code == 78: return "N"
    if code == 79: return "O"
    if code == 80: return "P"
    if code == 81: return "Q"
    if code == 82: return "R"
    if code == 83: return "S"
    if code == 84: return "T"
    if code == 85: return "U"
    if code == 86: return "V"
    if code == 87: return "W"
    if code == 88: return "X"
    if code == 89: return "Y"
    if code == 90: return "Z"
    if code == 91: return "["
    if code == 92: return "\\"
    if code == 93: return "]"
    if code == 94: return "^"
    if code == 95: return "_"
    if code == 96: return "`"
    if code == 97: return "a"
    if code == 98: return "b"
    if code == 99: return "c"
    if code == 100: return "d"
    if code == 101: return "e"
    if code == 102: return "f"
    if code == 103: return "g"
    if code == 104: return "h"
    if code == 105: return "i"
    if code == 106: return "j"
    if code == 107: return "k"
    if code == 108: return "l"
    if code == 109: return "m"
    if code == 110: return "n"
    if code == 111: return "o"
    if code == 112: return "p"
    if code == 113: return "q"
    if code == 114: return "r"
    if code == 115: return "s"
    if code == 116: return "t"
    if code == 117: return "u"
    if code == 118: return "v"
    if code == 119: return "w"
    if code == 120: return "x"
    if code == 121: return "y"
    if code == 122: return "z"
    if code == 123: return "{"
    if code == 124: return "|"
    if code == 125: return "}"
    if code == 126: return "~"
    if code == 0xE9: return "é"
    if code == 0x4E16: return "世"
    if code == 0x754C: return "界"
    ""

# ── Token kinds ──────────────────────────────────────────────────────────

enum JsTokenKind:
    # Literals
    Number
    String
    Identifier
    Boolean
    Null
    Undefined
    TemplateLiteral

    # Arithmetic
    Plus
    Minus
    Star
    Slash
    Percent
    StarStar

    # Assignment
    Eq
    PlusEq
    MinusEq
    StarEq
    SlashEq

    # Comparison / equality
    EqEq
    EqEqEq
    BangEq
    BangEqEq
    Lt
    Gt
    LtEq
    GtEq

    # Logical
    AmpersandAmpersand
    PipePipe
    QuestionQuestion
    Bang

    # Bitwise
    Tilde
    Ampersand
    Pipe
    Caret

    # Increment / decrement
    PlusPlus
    MinusMinus

    # Dot variants
    Dot
    DotDotDot
    QuestionDot

    # Delimiters
    OpenParen
    CloseParen
    OpenBrace
    CloseBrace
    OpenBracket
    CloseBracket

    # Punctuation
    Semicolon
    Comma
    Colon
    Arrow
    Question

    # Variable declarations
    Var
    Let
    Const

    # Control flow
    Function
    Return
    If
    Else
    While
    For
    Do
    Break
    Continue
    Switch
    Case
    Default

    # Error handling
    Throw
    Try
    Catch
    Finally

    # Operators as keywords
    New
    Delete
    Typeof
    Instanceof
    In
    Of
    Void

    # OOP
    Class
    Extends
    Super
    This

    # Modules
    Import
    Export
    From
    As

    # Async
    Async
    Await
    Yield

    # Boolean / null keywords
    TrueKw
    FalseKw
    NullKw

    # Special
    Eof
    Invalid

fn token_kind_name(kind: JsTokenKind) -> text:
    match kind:
        JsTokenKind.Number: "Number"
        JsTokenKind.String: "String"
        JsTokenKind.Identifier: "Identifier"
        JsTokenKind.Boolean: "Boolean"
        JsTokenKind.Null: "Null"
        JsTokenKind.Undefined: "Undefined"
        JsTokenKind.TemplateLiteral: "TemplateLiteral"
        JsTokenKind.Plus: "Plus"
        JsTokenKind.Minus: "Minus"
        JsTokenKind.Star: "Star"
        JsTokenKind.Slash: "Slash"
        JsTokenKind.Percent: "Percent"
        JsTokenKind.StarStar: "StarStar"
        JsTokenKind.Eq: "Eq"
        JsTokenKind.PlusEq: "PlusEq"
        JsTokenKind.MinusEq: "MinusEq"
        JsTokenKind.StarEq: "StarEq"
        JsTokenKind.SlashEq: "SlashEq"
        JsTokenKind.EqEq: "EqEq"
        JsTokenKind.EqEqEq: "EqEqEq"
        JsTokenKind.BangEq: "BangEq"
        JsTokenKind.BangEqEq: "BangEqEq"
        JsTokenKind.Lt: "Lt"
        JsTokenKind.Gt: "Gt"
        JsTokenKind.LtEq: "LtEq"
        JsTokenKind.GtEq: "GtEq"
        JsTokenKind.AmpersandAmpersand: "AmpersandAmpersand"
        JsTokenKind.PipePipe: "PipePipe"
        JsTokenKind.QuestionQuestion: "QuestionQuestion"
        JsTokenKind.Bang: "Bang"
        JsTokenKind.Tilde: "Tilde"
        JsTokenKind.Ampersand: "Ampersand"
        JsTokenKind.Pipe: "Pipe"
        JsTokenKind.Caret: "Caret"
        JsTokenKind.PlusPlus: "PlusPlus"
        JsTokenKind.MinusMinus: "MinusMinus"
        JsTokenKind.Dot: "Dot"
        JsTokenKind.DotDotDot: "DotDotDot"
        JsTokenKind.QuestionDot: "QuestionDot"
        JsTokenKind.OpenParen: "OpenParen"
        JsTokenKind.CloseParen: "CloseParen"
        JsTokenKind.OpenBrace: "OpenBrace"
        JsTokenKind.CloseBrace: "CloseBrace"
        JsTokenKind.OpenBracket: "OpenBracket"
        JsTokenKind.CloseBracket: "CloseBracket"
        JsTokenKind.Semicolon: "Semicolon"
        JsTokenKind.Comma: "Comma"
        JsTokenKind.Colon: "Colon"
        JsTokenKind.Arrow: "Arrow"
        JsTokenKind.Question: "Question"
        JsTokenKind.Var: "Var"
        JsTokenKind.Let: "Let"
        JsTokenKind.Const: "Const"
        JsTokenKind.Function: "Function"
        JsTokenKind.Return: "Return"
        JsTokenKind.If: "If"
        JsTokenKind.Else: "Else"
        JsTokenKind.While: "While"
        JsTokenKind.For: "For"
        JsTokenKind.Do: "Do"
        JsTokenKind.Break: "Break"
        JsTokenKind.Continue: "Continue"
        JsTokenKind.Switch: "Switch"
        JsTokenKind.Case: "Case"
        JsTokenKind.Default: "Default"
        JsTokenKind.Throw: "Throw"
        JsTokenKind.Try: "Try"
        JsTokenKind.Catch: "Catch"
        JsTokenKind.Finally: "Finally"
        JsTokenKind.New: "New"
        JsTokenKind.Delete: "Delete"
        JsTokenKind.Typeof: "Typeof"
        JsTokenKind.Instanceof: "Instanceof"
        JsTokenKind.In: "In"
        JsTokenKind.Of: "Of"
        JsTokenKind.Void: "Void"
        JsTokenKind.Class: "Class"
        JsTokenKind.Extends: "Extends"
        JsTokenKind.Super: "Super"
        JsTokenKind.This: "This"
