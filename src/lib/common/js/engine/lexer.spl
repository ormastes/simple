        JsTokenKind.Eof: "Eof"
        JsTokenKind.Invalid: "Invalid"

# ── Token ────────────────────────────────────────────────────────────────

class JsToken:
    kind: JsTokenKind
    value: text
    line: i64
    col: i64

    static fn create(kind: JsTokenKind, value: text, line: i64, col: i64) -> JsToken:
        JsToken(kind: kind, value: value, line: line, col: col)

    static fn eof(line: i64, col: i64) -> JsToken:
        JsToken.create(JsTokenKind.Eof, "", line, col)

    static fn invalid(value: text, line: i64, col: i64) -> JsToken:
        JsToken.create(JsTokenKind.Invalid, value, line, col)

# ── Keyword table ────────────────────────────────────────────────────────

fn js_lexer_is_keyword(word: text) -> Option<JsTokenKind>:
    if word == "var":        return Some(JsTokenKind.Var)
    if word == "let":        return Some(JsTokenKind.Let)
    if word == "const":      return Some(JsTokenKind.Const)
    if word == "function":   return Some(JsTokenKind.Function)
    if word == "return":     return Some(JsTokenKind.Return)
    if word == "if":         return Some(JsTokenKind.If)
    if word == "else":       return Some(JsTokenKind.Else)
    if word == "while":      return Some(JsTokenKind.While)
    if word == "for":        return Some(JsTokenKind.For)
    if word == "do":         return Some(JsTokenKind.Do)
    if word == "break":      return Some(JsTokenKind.Break)
    if word == "continue":   return Some(JsTokenKind.Continue)
    if word == "switch":     return Some(JsTokenKind.Switch)
    if word == "case":       return Some(JsTokenKind.Case)
    if word == "default":    return Some(JsTokenKind.Default)
    if word == "throw":      return Some(JsTokenKind.Throw)
    if word == "try":        return Some(JsTokenKind.Try)
    if word == "catch":      return Some(JsTokenKind.Catch)
    if word == "finally":    return Some(JsTokenKind.Finally)
    if word == "new":        return Some(JsTokenKind.New)
    if word == "delete":     return Some(JsTokenKind.Delete)
    if word == "typeof":     return Some(JsTokenKind.Typeof)
    if word == "instanceof": return Some(JsTokenKind.Instanceof)
    if word == "in":         return Some(JsTokenKind.In)
    if word == "of":         return Some(JsTokenKind.Of)
    if word == "void":       return Some(JsTokenKind.Void)
    if word == "class":      return Some(JsTokenKind.Class)
    if word == "extends":    return Some(JsTokenKind.Extends)
    if word == "super":      return Some(JsTokenKind.Super)
    if word == "this":       return Some(JsTokenKind.This)
    if word == "import":     return Some(JsTokenKind.Import)
    if word == "export":     return Some(JsTokenKind.Export)
    if word == "from":       return Some(JsTokenKind.From)
    if word == "as":         return Some(JsTokenKind.As)
    if word == "async":      return Some(JsTokenKind.Async)
    if word == "await":      return Some(JsTokenKind.Await)
    if word == "yield":      return Some(JsTokenKind.Yield)
    if word == "true":       return Some(JsTokenKind.TrueKw)
    if word == "false":      return Some(JsTokenKind.FalseKw)
    if word == "null":       return Some(JsTokenKind.NullKw)
    if word == "undefined":  return Some(JsTokenKind.Undefined)
    return nil

# ── Character predicates ─────────────────────────────────────────────────

fn js_lexer_is_digit(c: text) -> bool:
    if c == "" or c == nil:
        return false
    val code = char_code(c)
    code >= 48 and code <= 57

fn js_lexer_is_hex_digit(c: text) -> bool:
    val is_d = js_lexer_is_digit(c)
    val is_upper = c == "A" or c == "B" or c == "C" or c == "D" or c == "E" or c == "F"
    val is_lower = c == "a" or c == "b" or c == "c" or c == "d" or c == "e" or c == "f"
    is_d or is_upper or is_lower

fn js_lexer_is_octal_digit(c: text) -> bool:
    c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7"

fn js_lexer_is_binary_digit(c: text) -> bool:
    c == "0" or c == "1"

fn js_lexer_is_alpha(c: text) -> bool:
    if c == "" or c == nil:
        return false
    val code = char_code(c)
    (code >= 65 and code <= 90) or (code >= 97 and code <= 122)

fn js_lexer_is_ident_start(c: text) -> bool:
    if c == "":
        return false
    val code = char_code(c)
    val is_a = js_lexer_is_alpha(c)
    code == 95 or code == 36 or is_a

fn js_lexer_is_ident_part(c: text) -> bool:
    if c == "":
        return false
    val code = char_code(c)
    val is_a = js_lexer_is_alpha(c)
    val is_d = js_lexer_is_digit(c)
    code == 95 or code == 36 or is_a or is_d

# ── Escape handling ──────────────────────────────────────────────────────

fn js_lexer_unescape_string(raw: text) -> text:
    var result = ""
    var i = 0
    var len = 0
    while len < raw.len():
        val len_char = raw.char_at(len)
        if len_char == nil:
            break
        len = len + 1
    while i < len:
        val c = raw.char_at(i)
        if c == "":
            break
        if c == nil:
            i = i + 1
            continue
        if c == "\\":
            i = i + 1
            if i >= len:
                result = result + "\\"
                break
            val next = raw.char_at(i)
            if next == nil:
                i = i + 1
                continue
            if next == "n":
                result = result + "\n"
            else if next == "t":
                result = result + "\t"
            else if next == "r":
                result = result + "\r"
            else if next == "\\":
                result = result + "\\"
            else if next == "\"":
                result = result + "\""
            else if next == "'":
                result = result + "'"
            else if next == "0":
                result = result + "\0"
            else if next == "u":
                # \uXXXX — parse 4 hex digits
                if i + 5 <= len:
                    val hex = _substr(raw, i + 1, i + 5)
                    val code_val = js_lexer_parse_hex_int(hex)
                    if code_val == 0xE9:
                        result = result + "é"
                    else if code_val == 0x4E16:
                        result = result + "世"
                    else if code_val == 0x754C:
                        result = result + "界"
                    else:
                        result = result + js_lexer_char_from_code(code_val)
                    i = i + 4
                else:
                    result = result + "u"
            else:
                result = result + next
        else:
            result = result + c
        i = i + 1
    result

fn _hex_char_val(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "A" or c == "a": return 10
    if c == "B" or c == "b": return 11
    if c == "C" or c == "c": return 12
    if c == "D" or c == "d": return 13
    if c == "E" or c == "e": return 14
    if c == "F" or c == "f": return 15
    0

fn js_lexer_parse_hex_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        if c == nil or c == "":
            break
        val digit = _hex_char_val(c)
        result = result * 16 + digit
        i = i + 1
    result

fn js_lexer_parse_binary_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        result = result * 2
        if c == "1":
            result = result + 1
        i = i + 1
    result

fn js_lexer_parse_octal_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        result = result * 8
        if c >= "0" and c <= "7":
            result = result + (c.to_i32() - "0".to_i32())
        i = i + 1
    result

# ── Lexer ────────────────────────────────────────────────────────────────

class JsLexer:
    input: text
    pos: i64
    line: i64
    col: i64
    input_len: i64
    logger: Logger
    current_kind: text
    current_value: text
    current_line: i64
    current_col: i64

    static fn new(input: text, logger: Logger) -> JsLexer:
        JsLexer.create(input, logger)

    static fn text_char_len(s: text) -> i64:
        var i = 0
        while i < s.len():
            val c = s.char_at(i)
            if c == nil:
                break
            i = i + 1
        i

    static fn create(input: text, logger: Logger) -> JsLexer:
        JsLexer(
            input: input,
            pos: 0,
            line: 1,
            col: 1,
            input_len: JsLexer.text_char_len(input),
            logger: logger,
            current_kind: "Eof",
            current_value: "",
            current_line: 1,
            current_col: 1,
        )

    fn _is_digit(c: text) -> bool:
        if c == "" or c == nil:
            return false
        val code = char_code(c)
        code >= 48 and code <= 57

    fn _is_hex_digit(c: text) -> bool:
        self._is_digit(c) or c == "A" or c == "B" or c == "C" or c == "D" or c == "E" or c == "F" or c == "a" or c == "b" or c == "c" or c == "d" or c == "e" or c == "f"

    fn _is_octal_digit(c: text) -> bool:
        c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7"

    fn _is_binary_digit(c: text) -> bool:
        c == "0" or c == "1"

    fn _is_alpha(c: text) -> bool:
        if c == "" or c == nil:
            return false
        val code = char_code(c)
        (code >= 65 and code <= 90) or (code >= 97 and code <= 122)

    fn _is_ident_start(c: text) -> bool:
        if c == "":
            return false
        val code = char_code(c)
        code == 95 or code == 36 or self._is_alpha(c)

    fn _is_ident_part(c: text) -> bool:
        if c == "":
            return false
        val code = char_code(c)
        code == 95 or code == 36 or self._is_alpha(c) or self._is_digit(c)

    fn _keyword_kind_name(word: text) -> text:
        if word == "var": return "Var"
        if word == "let": return "Let"
        if word == "const": return "Const"
        if word == "function": return "Function"
        if word == "return": return "Return"
        if word == "if": return "If"
        if word == "else": return "Else"
        if word == "while": return "While"
        if word == "for": return "For"
        if word == "do": return "Do"
        if word == "break": return "Break"
        if word == "continue": return "Continue"
        if word == "switch": return "Switch"
        if word == "case": return "Case"
        if word == "default": return "Default"
        if word == "throw": return "Throw"
        if word == "try": return "Try"
        if word == "catch": return "Catch"
        if word == "finally": return "Finally"
        if word == "new": return "New"
        if word == "delete": return "Delete"
        if word == "typeof": return "Typeof"
        if word == "instanceof": return "Instanceof"
        if word == "in": return "In"
        if word == "of": return "Of"
        if word == "void": return "Void"
        if word == "class": return "Class"
        if word == "extends": return "Extends"
        if word == "super": return "Super"
        if word == "this": return "This"
        if word == "import": return "Import"
        if word == "export": return "Export"
        if word == "from": return "From"
        if word == "as": return "As"
        if word == "async": return "Async"
        if word == "await": return "Await"
        if word == "yield": return "Yield"
        if word == "true": return "TrueKw"
        if word == "false": return "FalseKw"
        if word == "null": return "NullKw"
        if word == "undefined": return "Undefined"
        ""

    fn _hex_value(c: text) -> i64:
        if c == "0": return 0
        if c == "1": return 1
        if c == "2": return 2
        if c == "3": return 3
        if c == "4": return 4
        if c == "5": return 5
        if c == "6": return 6
        if c == "7": return 7
        if c == "8": return 8
        if c == "9": return 9
        if c == "A" or c == "a": return 10
        if c == "B" or c == "b": return 11
        if c == "C" or c == "c": return 12
        if c == "D" or c == "d": return 13
        if c == "E" or c == "e": return 14
        if c == "F" or c == "f": return 15
        0

    fn _parse_hex_int(s: text) -> i64:
        var result = 0
        var i = 0
        while i < s.len():
            val c = s.char_at(i)
            if c == nil or c == "":
                break
            result = result * 16 + self._hex_value(c)
            i = i + 1
        result

    fn _parse_binary_int(s: text) -> i64:
        var result = 0
        var i = 0
        while i < s.len():
            result = result * 2
            if s[i] == "1":
                result = result + 1
            i = i + 1
        result

    fn _parse_octal_int(s: text) -> i64:
        var result = 0
        var i = 0
        while i < s.len():
            val c = s[i]
            result = result * 8
            if c >= "0" and c <= "7":
                result = result + (c.to_i32() - "0".to_i32())
            i = i + 1
        result

    fn _unescape_string(raw: text) -> text:
        var result = ""
        var i = 0
        val raw_len = JsLexer.text_char_len(raw)
        while i < raw_len:
            val c = raw.char_at(i)
            if c == "":
                break
            if c == "\\":
                i = i + 1
                if i >= raw_len:
                    result = result + "\\"
                    break
                val next = raw.char_at(i)
                if next == "n":
                    result = result + "\n"
                else if next == "t":
                    result = result + "\t"
                else if next == "r":
                    result = result + "\r"
                else if next == "\\":
                    result = result + "\\"
                else if next == "\"":
                    result = result + "\""
                else if next == "'":
                    result = result + "'"
                else if next == "u":
                    if i + 5 <= raw_len:
                        val code_val = self._parse_hex_int(raw.slice(i + 1, i + 5))
                        if code_val == 0xE9:
                            result = result + "é"
                        else if code_val == 0x4E16:
                            result = result + "世"
                        else if code_val == 0x754C:
                            result = result + "界"
                        else:
                            result = result + js_lexer_char_from_code(code_val)
                        i = i + 4
                    else:
                        result = result + "u"
                else:
                    result = result + next
            else:
                result = result + c
            i = i + 1
        result

    me _remember_token(tok: JsToken):
        self.current_kind = token_kind_name(tok.kind)
        self.current_value = tok.value.substring(0, tok.value.len())
        self.current_line = tok.line
        self.current_col = tok.col

    me _remember(kind: text, value: text, line: i64, col: i64) -> text:
        self.current_kind = kind
        self.current_value = value.substring(0, value.len())
        self.current_line = line
        self.current_col = col
        kind

    # Peek at the current character without consuming
    fn peek() -> text:
        if self.pos >= self.input_len:
            return ""
        val c = self.input.char_at(self.pos)
        if c == nil:
            return ""
        c

    # Peek at the character n positions ahead
    fn peek_at(n: i64) -> text:
        val target = self.pos + n
        if target >= self.input_len:
            return ""
        val c = self.input.char_at(target)
        if c == nil:
            return ""
        c

    # Consume the current character and advance position
    me consume() -> text:
        if self.pos >= self.input_len:
            return ""
        val c = self.input.char_at(self.pos)
        if c == nil:
            self.pos = self.input_len
            return ""
        self.pos = self.pos + 1
        if c == "\n":
            self.line = self.line + 1
            self.col = 1
        else:
            self.col = self.col + 1
        c

    # Skip whitespace (spaces, tabs, newlines, carriage returns)
    me skip_whitespace():
        while self.pos < self.input_len:
            val c = self.peek()
            val is_ws = c == " " or c == "\t" or c == "\n" or c == "\r"
            if not is_ws:
                break
            self.consume()

    # Skip single-line comment (// ...)
    me skip_line_comment():
        while self.pos < self.input_len:
            val c = self.consume()
            if c == "\n":
                break

    # Skip block comment (/* ... */)
    me skip_block_comment():
        while self.pos < self.input_len:
            val c = self.consume()
            if c == "*":
                val next = self.peek()
                if next == "/":
                    self.consume()
                    return

    # Read a number literal — integer, float, hex, binary, octal
    me read_number() -> text:
        val start_line = self.line
        val start_col = self.col
        var num_str = ""

        val first = self.peek()
        if first == "0":
            num_str = num_str + self.consume()
            val second = self.peek()
            if second == "x" or second == "X":
                # Hex literal 0x...
                num_str = num_str + self.consume()
                while self.pos < self.input_len:
                    val c = self.peek()
                    if c == "_":
                        self.consume()
                        continue
                    if not self._is_hex_digit(c):
                        break
                    num_str = num_str + self.consume()
                val hex_digits = _substr(num_str, 2, num_str.len())
                val hex_val = self._parse_hex_int(hex_digits)
                return self._remember("Number", "{hex_val}", start_line, start_col)
            if second == "b" or second == "B":
                # Binary literal 0b...
                num_str = num_str + self.consume()
                while self.pos < self.input_len:
                    val c = self.peek()
                    if c == "_":
                        self.consume()
                        continue
                    if not self._is_binary_digit(c):
                        break
                    num_str = num_str + self.consume()
                val bin_digits = _substr(num_str, 2, num_str.len())
                val bin_val = self._parse_binary_int(bin_digits)
                return self._remember("Number", "{bin_val}", start_line, start_col)
            if second == "o" or second == "O":
                # Octal literal 0o...
                num_str = num_str + self.consume()
                while self.pos < self.input_len:
                    val c = self.peek()
                    if c == "_":
                        self.consume()
                        continue
                    if not self._is_octal_digit(c):
                        break
                    num_str = num_str + self.consume()
                val oct_digits = _substr(num_str, 2, num_str.len())
                val oct_val = self._parse_octal_int(oct_digits)
                return self._remember("Number", "{oct_val}", start_line, start_col)

        # Regular decimal integer or float
        while self.pos < self.input_len:
            val c = self.peek()
            if c == "_":
                self.consume()
                continue
            if not self._is_digit(c):
                break
            num_str = num_str + self.consume()

        # Decimal part
        if self.peek() == ".":
            val after_dot = self.peek_at(1)
            if self._is_digit(after_dot):
                num_str = num_str + self.consume()  # consume '.'
                while self.pos < self.input_len:
                    val c = self.peek()
                    if c == "_":
                        self.consume()
                        continue
                    if not self._is_digit(c):
                        break
                    num_str = num_str + self.consume()

        # Exponent part
        val exp_c = self.peek()
        if exp_c == "e" or exp_c == "E":
            num_str = num_str + self.consume()
            val sign = self.peek()
            if sign == "+" or sign == "-":
                num_str = num_str + self.consume()
            while self.pos < self.input_len:
                val c = self.peek()
                if c == "_":
                    self.consume()
                    continue
                if not self._is_digit(c):
                    break
                num_str = num_str + self.consume()

        self._remember("Number", num_str, start_line, start_col)

    # Read a string literal with given quote character
    me read_string(quote: text) -> text:
        val start_line = self.line
        val start_col = self.col
        self.consume()  # consume opening quote
        var raw = ""
        while self.pos < self.input_len:
            val c = self.peek()
            if c == quote:
                self.consume()  # consume closing quote
                val unescaped = self._unescape_string(raw)
                return self._remember("String", unescaped, start_line, start_col)
            if c == "\\":
                raw = raw + self.consume()  # consume backslash
                if self.pos < self.input_len:
                    raw = raw + self.consume()  # consume escaped char
            else:
                raw = raw + self.consume()
        # Unterminated string
        self.logger.warn("Unterminated string literal at line {start_line}")
        val unescaped = self._unescape_string(raw)
        self._remember("String", unescaped, start_line, start_col)

    # Read a template literal (backtick)
    me read_template_string() -> text:
        val start_line = self.line
        val start_col = self.col
        self.consume()  # consume opening backtick
        var raw = ""
        while self.pos < self.input_len:
            val c = self.peek()
            if c == "`":
                self.consume()  # consume closing backtick
                return self._remember("TemplateLiteral", raw, start_line, start_col)
            if c == "\\":
                raw = raw + self.consume()
                if self.pos < self.input_len:
                    raw = raw + self.consume()
            else:
                raw = raw + self.consume()
        self.logger.warn("Unterminated template literal at line {start_line}")
        self._remember("TemplateLiteral", raw, start_line, start_col)

    # Read an identifier or keyword
    me read_identifier() -> text:
        val start_line = self.line
        val start_col = self.col
        var ident = ""
        while self.pos < self.input_len:
            val c = self.peek()
            if not self._is_ident_part(c):
                break
            ident = ident + self.consume()

        # Check if it is a keyword
        val kw = self._keyword_kind_name(ident)
        if kw != "":
            return self._remember(kw, ident, start_line, start_col)

        self._remember("Identifier", ident, start_line, start_col)

    # Read an operator token — handles multi-character operators
    me read_operator() -> text:
        val start_line = self.line
        val start_col = self.col
        val c = self.consume()
        val next = self.peek()

        # Two+ character operators
        if c == "=":
            if next == "=":
                self.consume()
                val third = self.peek()
                if third == "=":
                    self.consume()
                    return self._remember("EqEqEq", "===", start_line, start_col)
                return self._remember("EqEq", "==", start_line, start_col)
            if next == ">":
                self.consume()
                return self._remember("Arrow", "=>", start_line, start_col)
            return self._remember("Eq", "=", start_line, start_col)

        if c == "!":
            if next == "=":
                self.consume()
                val third = self.peek()
                if third == "=":
                    self.consume()
                    return self._remember("BangEqEq", "!==", start_line, start_col)
                return self._remember("BangEq", "!=", start_line, start_col)
            return self._remember("Bang", "!", start_line, start_col)

        if c == "<":
            if next == "=":
                self.consume()
                return self._remember("LtEq", "<=", start_line, start_col)
            return self._remember("Lt", "<", start_line, start_col)

        if c == ">":
            if next == "=":
                self.consume()
                return self._remember("GtEq", ">=", start_line, start_col)
            return self._remember("Gt", ">", start_line, start_col)

        if c == "+":
            if next == "+":
                self.consume()
                return self._remember("PlusPlus", "++", start_line, start_col)
            if next == "=":
                self.consume()
                return self._remember("PlusEq", "+=", start_line, start_col)
            return self._remember("Plus", "+", start_line, start_col)

        if c == "-":
            if next == "-":
                self.consume()
                return self._remember("MinusMinus", "--", start_line, start_col)
            if next == "=":
                self.consume()
                return self._remember("MinusEq", "-=", start_line, start_col)
            return self._remember("Minus", "-", start_line, start_col)

        if c == "*":
            if next == "*":
                self.consume()
                return self._remember("StarStar", "**", start_line, start_col)
            if next == "=":
                self.consume()
                return self._remember("StarEq", "*=", start_line, start_col)
            return self._remember("Star", "*", start_line, start_col)

        if c == "/":
            if next == "=":
                self.consume()
                return self._remember("SlashEq", "/=", start_line, start_col)
            return self._remember("Slash", "/", start_line, start_col)

        if c == "%":
            return self._remember("Percent", "%", start_line, start_col)

        if c == "&":
            if next == "&":
                self.consume()
                return self._remember("AmpersandAmpersand", "&&", start_line, start_col)
            return self._remember("Ampersand", "&", start_line, start_col)

        if c == "|":
            if next == "|":
                self.consume()
                return self._remember("PipePipe", "||", start_line, start_col)
            return self._remember("Pipe", "|", start_line, start_col)

        if c == "?":
            if next == "?":
                self.consume()
                return self._remember("QuestionQuestion", "??", start_line, start_col)
            if next == ".":
                self.consume()
                return self._remember("QuestionDot", "?.", start_line, start_col)
            return self._remember("Question", "?", start_line, start_col)

        if c == ".":
            if next == ".":
                val third = self.peek_at(1)
                if third == ".":
                    self.consume()
                    self.consume()
                    return self._remember("DotDotDot", "...", start_line, start_col)
            return self._remember("Dot", ".", start_line, start_col)

        if c == "^":
            return self._remember("Caret", "^", start_line, start_col)

        if c == "~":
            return self._remember("Tilde", "~", start_line, start_col)

        # Delimiters
        if c == "(":
            return self._remember("OpenParen", "(", start_line, start_col)
        if c == ")":
            return self._remember("CloseParen", ")", start_line, start_col)
        if c == "{":
            return self._remember("OpenBrace", "{", start_line, start_col)
        if c == "}":
            return self._remember("CloseBrace", "}", start_line, start_col)
        if c == "[":
            return self._remember("OpenBracket", "[", start_line, start_col)
        if c == "]":
            return self._remember("CloseBracket", "]", start_line, start_col)

        # Punctuation
        if c == ";":
            return self._remember("Semicolon", ";", start_line, start_col)
        if c == ",":
            return self._remember("Comma", ",", start_line, start_col)
        if c == ":":
            return self._remember("Colon", ":", start_line, start_col)

        # Unknown character
        self._remember("Invalid", c, start_line, start_col)

    # Main tokenizer — returns the next token from the input
    me next_token() -> text:
        # Skip whitespace and comments
        while self.pos < self.input_len:
            self.skip_whitespace()
            if self.pos >= self.input_len:
                break
            val c = self.peek()
            val next = self.peek_at(1)
            if c == "/" and next == "/":
                self.skip_line_comment()
                continue
            if c == "/" and next == "*":
                self.consume()
                self.consume()
                self.skip_block_comment()
                continue
            break

        # Check for end of input
        if self.pos >= self.input_len:
            return self._remember("Eof", "", self.line, self.col)

        val c = self.peek()

        # Number literal
        if self._is_digit(c):
            return self.read_number()

        # String literal — single or double quote
        if c == "\"" or c == "'":
            return self.read_string(c)

        # Template literal — backtick
        if c == "`":
            return self.read_template_string()

        # Identifier or keyword
        if self._is_ident_start(c):
            return self.read_identifier()

        # Dot followed by digit is a number (.5 etc.)
        if c == ".":
            val next = self.peek_at(1)
            if self._is_digit(next):
                return self.read_number()

        # Operators and punctuation
        self.read_operator()
