# Generational, incremental garbage collector for the JS engine.
# Implements tri-color mark-sweep with young/old/permanent generations.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError}
use std.js.types.gc_types.{Generation, GcHeader, GcObject, GcStats}
use std.js.types.js_types.{JsValue}

# --- GC Heap ---

class GcHeap:
    objects: [GcObject]
    young: [i64]
    old: [i64]
    permanent: [i64]
    next_id: i64
    young_threshold: i64
    old_threshold: i64
    total_allocated: i64
    total_freed: i64
    collections: i64
    bytes_allocated: i64
    gc_threshold_bytes: i64
    is_marking: bool
    mark_stack: [i64]
    sweep_index: i64
    logger: Logger

    static fn new(logger: Logger) -> GcHeap:
        GcHeap(
            objects: [],
            young: [],
            old: [],
            permanent: [],
            next_id: 0,
            young_threshold: 256,
            old_threshold: 1024,
            total_allocated: 0,
            total_freed: 0,
            collections: 0,
            bytes_allocated: 0,
            gc_threshold_bytes: 65536,
            is_marking: false,
            mark_stack: [],
            sweep_index: 0,
            logger: logger
        )

    # --- Allocation ---

    me allocate(value: JsValue) -> i64:
        val id = self.next_id
        val obj = GcObject.create(value)
        self.objects.push(obj)
        self.young.push(id)
        self.next_id = self.next_id + 1
        self.total_allocated = self.total_allocated + 1
        self.bytes_allocated = self.bytes_allocated + _estimate_size(value)
        self.logger.trace("Allocated object {id} in young generation")
        # Trigger GC if needed
        if self.should_collect():
            self.logger.debug("GC threshold reached, collecting young generation")
            self.collect_young()
        id

    me add_reference(from_id: i64, to_id: i64):
        if from_id >= 0 and from_id < self.objects.len():
            var obj = self.objects.get(from_id)
            obj.references.push(to_id)
            # Write barrier for incremental GC
            self.write_barrier(from_id)

    me remove_reference(from_id: i64, to_id: i64):
        if from_id >= 0 and from_id < self.objects.len():
            var obj = self.objects.get(from_id)
            var new_refs: [i64] = []
            var i = 0
            while i < obj.references.len():
                val ref_id = obj.references.get(i)
                if ref_id != to_id:
                    new_refs.push(ref_id)
                i = i + 1
            obj.references = new_refs

    # --- Collection ---

    me collect_young() -> GcStats:
        self.logger.info("Minor GC: collecting young generation ({self.young.len()} objects)")
        self.collections = self.collections + 1
        val before_count = self.young.len()
        # Mark phase — mark all reachable young objects
        self._reset_marks_young()
        # Mark from roots (young objects referenced by old/permanent)
        self._mark_cross_generation_roots()
        self.process_mark_stack()
        # Sweep
        self.sweep_young()
        # Promote survivors
        self.promote_survivors()
        val freed = before_count - self.young.len()
        self.total_freed = self.total_freed + freed
        self.logger.info("Minor GC complete: freed {freed} objects")
        self.get_stats()

    me collect_full() -> GcStats:
        self.logger.info("Major GC: collecting all generations")
        self.collections = self.collections + 1
        val before_total = self.objects.len()
        # Reset all marks
        self._reset_all_marks()
        # Mark from all roots
        var roots: [i64] = []
        # Old and permanent are considered roots for full GC
        var i = 0
        while i < self.permanent.len():
            roots.push(self.permanent.get(i))
            i = i + 1
        self.mark_roots(roots)
        self.process_mark_stack()
        # Sweep all
        self.sweep_all()
        val after_total = self.young.len() + self.old.len() + self.permanent.len()
        val freed = before_total - after_total
        self.total_freed = self.total_freed + freed
        self.logger.info("Major GC complete: freed {freed} objects")
        self.get_stats()

    fn should_collect() -> bool:
        self.young.len() >= self.young_threshold or self.bytes_allocated >= self.gc_threshold_bytes

    # --- Mark phase (tri-color marking) ---

    me mark_roots(roots: [i64]):
        var i = 0
        while i < roots.len():
            val root_id = roots.get(i)
            self.mark_object(root_id)
            i = i + 1

    me mark_object(obj_id: i64):
        if obj_id < 0 or obj_id >= self.objects.len():
            return
        var obj = self.objects.get(obj_id)
        if obj.header.marked:
            return  # Already black
        # Mark as gray (marked but references not yet processed)
        obj.header.marked = true
        self.mark_stack.push(obj_id)

    me process_mark_stack():
        while self.mark_stack.len() > 0:
            val obj_id = self.mark_stack.pop()
            if obj_id >= 0 and obj_id < self.objects.len():
                val obj = self.objects.get(obj_id)
                # Process all references (turn gray to black)
                var i = 0
                while i < obj.references.len():
                    val ref_id = obj.references.get(i)
                    self.mark_object(ref_id)
                    i = i + 1

    me incremental_mark(budget_ms: f64) -> bool:
        # Process a limited number of objects per call
        # Returns true if marking is complete
        val budget_items = (budget_ms * 100.0).to_i64()  # Approximate items per ms
        var processed = 0
        while self.mark_stack.len() > 0 and processed < budget_items:
            val obj_id = self.mark_stack.pop()
            if obj_id >= 0 and obj_id < self.objects.len():
                val obj = self.objects.get(obj_id)
                var i = 0
                while i < obj.references.len():
                    val ref_id = obj.references.get(i)
                    self.mark_object(ref_id)
                    i = i + 1
            processed = processed + 1
        val done = self.mark_stack.len() == 0
        if done:
            self.is_marking = false
        done

    # --- Sweep phase ---

    me sweep_young():
        var surviving: [i64] = []
        var i = 0
        while i < self.young.len():
            val obj_id = self.young.get(i)
            if obj_id >= 0 and obj_id < self.objects.len():
                val obj = self.objects.get(obj_id)
                if obj.header.marked:
                    surviving.push(obj_id)
                else:
                    self.bytes_allocated = self.bytes_allocated - _estimate_size(obj.value)
                    self.logger.trace("Swept young object {obj_id}")
            i = i + 1
        self.young = surviving

    me sweep_old():
        var surviving: [i64] = []
        var i = 0
        while i < self.old.len():
            val obj_id = self.old.get(i)
            if obj_id >= 0 and obj_id < self.objects.len():
                val obj = self.objects.get(obj_id)
                if obj.header.marked:
                    surviving.push(obj_id)
                else:
                    self.bytes_allocated = self.bytes_allocated - _estimate_size(obj.value)
                    self.logger.trace("Swept old object {obj_id}")
            i = i + 1
        self.old = surviving

    me sweep_all():
        self.sweep_young()
        self.sweep_old()
        # Permanent objects are never swept

    # --- Promotion ---

    me promote_survivors():
        var still_young: [i64] = []
        var i = 0
        while i < self.young.len():
            val obj_id = self.young.get(i)
            if obj_id >= 0 and obj_id < self.objects.len():
                var obj = self.objects.get(obj_id)
                if should_promote(obj):
                    obj.header.generation = Generation.Old
                    self.old.push(obj_id)
                    self.logger.trace("Promoted object {obj_id} to old generation")
                else:
                    obj.header.ref_count = obj.header.ref_count + 1
                    still_young.push(obj_id)
            i = i + 1
        self.young = still_young

    # --- Write barrier ---

    me write_barrier(obj_id: i64):
        if self.is_marking:
            # If we're in the middle of incremental marking,
            # re-mark the modified object so it gets rescanned
            self.mark_object(obj_id)

    # --- Stats ---

    fn get_stats() -> GcStats:
        GcStats(
            total_allocated: self.total_allocated,
            total_freed: self.total_freed,
            young_count: self.young.len(),
            old_count: self.old.len(),
            collections: self.collections
        )

    fn heap_size() -> i64:
        self.young.len() + self.old.len() + self.permanent.len()

    # --- Private helpers ---

    me _reset_marks_young():
        var i = 0
        while i < self.young.len():
            val obj_id = self.young.get(i)
            if obj_id >= 0 and obj_id < self.objects.len():
                var obj = self.objects.get(obj_id)
                obj.header.marked = false
            i = i + 1

    me _reset_all_marks():
        var i = 0
        while i < self.objects.len():
            var obj = self.objects.get(i)
            obj.header.marked = false
            i = i + 1

    me _mark_cross_generation_roots():
        # Mark young objects that are referenced by old or permanent objects
        var i = 0
        while i < self.old.len():
            val old_id = self.old.get(i)
            if old_id >= 0 and old_id < self.objects.len():
                val obj = self.objects.get(old_id)
                var r = 0
                while r < obj.references.len():
                    val ref_id = obj.references.get(r)
                    if self._is_young(ref_id):
                        self.mark_object(ref_id)
                    r = r + 1
            i = i + 1
        # Same for permanent
        var p = 0
        while p < self.permanent.len():
            val perm_id = self.permanent.get(p)
            if perm_id >= 0 and perm_id < self.objects.len():
                val obj = self.objects.get(perm_id)
                var r = 0
                while r < obj.references.len():
                    val ref_id = obj.references.get(r)
                    if self._is_young(ref_id):
                        self.mark_object(ref_id)
                    r = r + 1
            p = p + 1

    fn _is_young(obj_id: i64) -> bool:
        var i = 0
        while i < self.young.len():
            if self.young.get(i) == obj_id:
                return true
            i = i + 1
        false

# --- Free functions ---

fn should_promote(obj: GcObject) -> bool:
    # Promote after surviving 2 collections
    obj.header.ref_count >= 2

fn _estimate_size(value: JsValue) -> i64:
    match value:
        JsValue.Undefined: 8
        JsValue.Null: 8
        JsValue.Boolean(_): 8
        JsValue.Number(_): 16
        JsValue.String(v): 24 + v.len()
        JsValue.Object(_): 64
        JsValue.Array(_): 64
        JsValue.Function(_): 48
        JsValue.Symbol(_): 24
