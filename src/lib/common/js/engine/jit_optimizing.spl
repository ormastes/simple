# JIT optimizing compiler.
# Applies type specialization, constant folding, and dead-code elimination
# to a JitIR sequence produced by the baseline compiler.

use std.js.engine.js_error.{Logger}
use std.js.engine.jit_types.{JitIR, JitTypeTag}
use std.js.types.js_types.{JsValue}

# --- Optimizing compiler: JitIR + type profile -> optimized JitIR ---

class OptimizingCompiler:
    logger: Logger

    static fn create(logger: Logger) -> OptimizingCompiler:
        OptimizingCompiler(logger: logger)

    fn optimize(ir: [JitIR], type_observations: [JitTypeTag]) -> [JitIR]:
        var optimized = self._type_specialize(ir, type_observations)
        var pass_idx = 0
        var previous_len = -1
        while pass_idx < 4:
            if optimized.len() == previous_len:
                break
            previous_len = optimized.len()
            optimized = self._constant_fold(optimized)
            optimized = self._dead_code_eliminate(optimized)
            pass_idx = pass_idx + 1
        optimized

    # --- Type specialization ---
    # If type observations show numbers, replace generic Add/Sub/Mul with Int variants
    # and insert Guard instructions for deoptimization safety.

    fn _type_specialize(ir: [JitIR], type_observations: [JitTypeTag]) -> [JitIR]:
        val all_numbers = self._all_tags_are_number(type_observations)
        if not all_numbers:
            return ir
        var result: [JitIR] = []
        var i = 0
        while i < ir.len():
            val instr = ir.get(i)
            match instr:
                JitIR.Add(dst, lhs, rhs):
                    # Insert guard then use specialized IntAdd
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntAdd(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Sub(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntSub(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Mul(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntMul(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Div(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntDiv(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Mod(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntMod(dst: dst, lhs: lhs, rhs: rhs))
                _:
                    result.push(instr)
            i = i + 1
        result

    fn _all_tags_are_number(observations: [JitTypeTag]) -> bool:
        if observations.len() == 0:
            return false
        var i = 0
        while i < observations.len():
            val tag = observations.get(i)
            match tag:
                JitTypeTag.TagNumber: pass_dn
                _: return false
            i = i + 1
        true

    # --- Constant folding ---
    # If two consecutive LoadConst instructions feed into an arithmetic op,
    # compute the result at compile time.

    fn _constant_fold(ir: [JitIR]) -> [JitIR]:
        var result: [JitIR] = []
        var known_regs: [i64] = []
        var known_vals: [f64] = []
        var i = 0
        while i < ir.len():
            val instr = ir.get(i)
            match instr:
                JitIR.LoadConst(reg, value):
                    match value:
                        JsValue.Number(n):
                            self._record_number_const(known_regs, known_vals, reg, n)
                        _:
                            self._invalidate_number_const(known_regs, known_vals, reg)
                    result.push(instr)
                JitIR.IntAdd(dst, lhs, rhs):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0:
                        val n = known_vals.get(lhs_idx) + known_vals.get(rhs_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.IntSub(dst, lhs, rhs):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0:
                        val n = known_vals.get(lhs_idx) - known_vals.get(rhs_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.IntMul(dst, lhs, rhs):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0:
                        val n = known_vals.get(lhs_idx) * known_vals.get(rhs_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.IntDiv(dst, lhs, rhs):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0 and known_vals.get(rhs_idx) != 0.0:
                        val n = known_vals.get(lhs_idx) / known_vals.get(rhs_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.IntMod(dst, lhs, rhs):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0 and known_vals.get(rhs_idx) != 0.0:
                        val n = known_vals.get(lhs_idx) % known_vals.get(rhs_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.Compare(dst, lhs, rhs, op):
                    val lhs_idx = self._number_const_index(known_regs, lhs)
                    val rhs_idx = self._number_const_index(known_regs, rhs)
                    if lhs_idx >= 0 and rhs_idx >= 0:
                        val b = self._compare_numbers(known_vals.get(lhs_idx), known_vals.get(rhs_idx), op)
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Boolean(v: b)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.Negate(dst, src):
                    val src_idx = self._number_const_index(known_regs, src)
                    if src_idx >= 0:
                        val n = 0.0 - known_vals.get(src_idx)
                        self._record_number_const(known_regs, known_vals, dst, n)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: n)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                JitIR.LogicalNot(dst, src):
                    val src_idx = self._number_const_index(known_regs, src)
                    if src_idx >= 0:
                        val b = known_vals.get(src_idx) == 0.0
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(JitIR.LoadConst(reg: dst, value: JsValue.Boolean(v: b)))
                    else:
                        self._invalidate_number_const(known_regs, known_vals, dst)
                        result.push(instr)
                _:
                    val defined_reg = self._defined_register_or_negative(instr)
                    if defined_reg >= 0:
                        self._invalidate_number_const(known_regs, known_vals, defined_reg)
                    result.push(instr)
            i = i + 1
        result

    fn _number_const_index(regs: [i64], reg: i64) -> i64:
        var i = 0
        while i < regs.len():
            if regs.get(i) == reg:
                return i
            i = i + 1
        -1

    fn _record_number_const(regs: mut [i64], vals: mut [f64], reg: i64, value: f64):
        val idx = self._number_const_index(regs, reg)
        if idx >= 0:
            vals[idx] = value
        else:
            regs.push(reg)
            vals.push(value)

    fn _invalidate_number_const(regs: mut [i64], vals: mut [f64], reg: i64):
        val idx = self._number_const_index(regs, reg)
        if idx >= 0:
            val last_idx = regs.len() - 1
            regs[idx] = regs.get(last_idx)
            vals[idx] = vals.get(last_idx)
            regs.pop()
            vals.pop()

    fn _compare_numbers(lhs: f64, rhs: f64, op: text) -> bool:
        if op == "eq":
            lhs == rhs
        else if op == "ne":
            lhs != rhs
        else if op == "lt":
            lhs < rhs
        else if op == "gt":
            lhs > rhs
        else if op == "le":
            lhs <= rhs
        else if op == "ge":
            lhs >= rhs
        else:
            false

    # --- Dead code elimination ---
    # Remove Nop instructions and pure register writes whose destination is
    # never read after later optimization passes fold their consumers.

    fn _dead_code_eliminate(ir: [JitIR]) -> [JitIR]:
        var reversed: [JitIR] = []
        var live_regs: [i64] = []
        var i = ir.len() - 1
        while i >= 0:
            val instr = ir.get(i)
            match instr:
                JitIR.Nop:
                    pass_dn
                JitIR.Guard(reg, expected_type):
                    if self._live_contains(live_regs, reg):
                        reversed.push(instr)
                        self._live_add(live_regs, reg)
                _:
                    val reg = self._defined_register_or_negative(instr)
                    if reg >= 0:
                        if self._pure_definition(instr) and not self._live_contains(live_regs, reg):
                            pass_dn
                        else:
                            self._live_remove(live_regs, reg)
                            self._mark_inputs_live(live_regs, instr)
                            reversed.push(instr)
                    else:
                        self._mark_inputs_live(live_regs, instr)
                        reversed.push(instr)
            i = i - 1
        reversed.reverse()
        reversed

    fn _defined_register_or_negative(instr: JitIR) -> i64:
        match instr:
            JitIR.LoadConst(reg, _): reg
            JitIR.LoadLocal(reg, _): reg
            JitIR.LoadGlobal(reg, _): reg
            JitIR.Add(dst, _, _): dst
            JitIR.Sub(dst, _, _): dst
            JitIR.Mul(dst, _, _): dst
            JitIR.Div(dst, _, _): dst
            JitIR.Mod(dst, _, _): dst
            JitIR.IntAdd(dst, _, _): dst
            JitIR.IntSub(dst, _, _): dst
            JitIR.IntMul(dst, _, _): dst
            JitIR.IntDiv(dst, _, _): dst
            JitIR.IntMod(dst, _, _): dst
            JitIR.Compare(dst, _, _, _): dst
            JitIR.Negate(dst, _): dst
            JitIR.LogicalNot(dst, _): dst
            JitIR.Call(dst, _, _): dst
            JitIR.Dup(dst, _): dst
            JitIR.GetProperty(dst, _, _): dst
            JitIR.NewObject(dst): dst
            JitIR.NewArray(dst, _): dst
            _: -1

    fn _pure_definition(instr: JitIR) -> bool:
        match instr:
            JitIR.LoadConst(_, _): true
            JitIR.LoadLocal(_, _): true
            JitIR.Add(_, _, _): true
            JitIR.Sub(_, _, _): true
            JitIR.Mul(_, _, _): true
            JitIR.Div(_, _, _): true
            JitIR.Mod(_, _, _): true
            JitIR.IntAdd(_, _, _): true
            JitIR.IntSub(_, _, _): true
            JitIR.IntMul(_, _, _): true
            JitIR.IntDiv(_, _, _): true
            JitIR.IntMod(_, _, _): true
            JitIR.Compare(_, _, _, _): true
            JitIR.Negate(_, _): true
            JitIR.LogicalNot(_, _): true
            JitIR.Dup(_, _): true
            _: false

    fn _mark_inputs_live(live_regs: mut [i64], instr: JitIR):
        match instr:
            JitIR.StoreLocal(_, reg):
                self._live_add(live_regs, reg)
            JitIR.StoreGlobal(_, reg):
                self._live_add(live_regs, reg)
            JitIR.Add(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Sub(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Mul(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Div(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Mod(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.IntAdd(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.IntSub(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.IntMul(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.IntDiv(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.IntMod(_, lhs, rhs):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Compare(_, lhs, rhs, _):
                self._live_add(live_regs, lhs)
                self._live_add(live_regs, rhs)
            JitIR.Negate(_, src):
                self._live_add(live_regs, src)
            JitIR.LogicalNot(_, src):
                self._live_add(live_regs, src)
            JitIR.JumpIfFalse(reg, _):
                self._live_add(live_regs, reg)
            JitIR.Call(_, func_reg, _):
                self._live_add(live_regs, func_reg)
            JitIR.Return(reg):
                self._live_add(live_regs, reg)
            JitIR.Guard(reg, _):
                self._live_add(live_regs, reg)
            JitIR.Pop(reg):
                self._live_add(live_regs, reg)
            JitIR.Dup(_, src):
                self._live_add(live_regs, src)
            JitIR.GetProperty(_, obj_reg, _):
                self._live_add(live_regs, obj_reg)
            JitIR.SetProperty(obj_reg, _, val_reg):
                self._live_add(live_regs, obj_reg)
                self._live_add(live_regs, val_reg)
            _: pass_dn

    fn _live_contains(live_regs: [i64], reg: i64) -> bool:
        var i = 0
        while i < live_regs.len():
            if live_regs.get(i) == reg:
                return true
            i = i + 1
        false

    fn _live_add(live_regs: mut [i64], reg: i64):
        if not self._live_contains(live_regs, reg):
            live_regs.push(reg)

    fn _live_remove(live_regs: mut [i64], reg: i64):
        var i = 0
        while i < live_regs.len():
            if live_regs.get(i) == reg:
                val last_idx = live_regs.len() - 1
                live_regs[i] = live_regs.get(last_idx)
                live_regs.pop()
                return ()
            i = i + 1
