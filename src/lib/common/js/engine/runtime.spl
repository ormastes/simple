# JavaScript runtime for the Simple Browser Platform.
# Sets up the global environment with built-in objects (console, Math, JSON),
# global functions (parseInt, parseFloat, isNaN, isFinite), prototypes,
# and provides the top-level eval() entry point.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.pair.{Pair}
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.types.ast_types.Expression
use std.js.types.ast_types.Statement
use std.js.engine.lexer.JsLexer
use std.js.engine.parser.JsParser
use std.js.engine.interpreter.JsInterpreter
use std.js.engine.interpreter_types.JsFunction
use std.js.engine.interpreter_types.to_number
use std.js.engine.interpreter_types.js_to_string
use std.js.engine.interpreter_types.to_boolean
use std.js.engine.interpreter_types.is_truthy
use std.js.engine.interpreter_types.f64_to_i64
use std.js.engine.interpreter_types._digit_val

# ── Prototype chain ──────────────────────────────────────────────────────

class PrototypeChain:
    object_proto: i64
    array_proto: i64
    function_proto: i64
    string_proto: i64
    number_proto: i64
    error_proto: i64

    static fn empty() -> PrototypeChain:
        PrototypeChain(
            object_proto: -1,
            array_proto: -1,
            function_proto: -1,
            string_proto: -1,
            number_proto: -1,
            error_proto: -1,
        )

# ── Symbol ID counter ───────────────────────────────────────────────────
var _symbol_counter = 0

fn _next_symbol_id() -> i64:
    _symbol_counter = _symbol_counter + 1
    _symbol_counter

# ── Native function IDs ─────────────────────────────────────────────────

# We assign fixed IDs to native (built-in) functions.
# The interpreter dispatches by checking these IDs in eval_call.

val NATIVE_CONSOLE_LOG = -1
val NATIVE_CONSOLE_ERROR = -2
val NATIVE_CONSOLE_WARN = -3
val NATIVE_PARSE_INT = -10
val NATIVE_PARSE_FLOAT = -11
val NATIVE_IS_NAN = -12
val NATIVE_IS_FINITE = -13
val NATIVE_MATH_FLOOR = -20
val NATIVE_MATH_CEIL = -21
val NATIVE_MATH_ROUND = -22
val NATIVE_MATH_RANDOM = -23
val NATIVE_MATH_ABS = -24
val NATIVE_MATH_MAX = -25
val NATIVE_MATH_MIN = -26
val NATIVE_MATH_SQRT = -27
val NATIVE_MATH_POW = -28
val NATIVE_JSON_PARSE = -30
val NATIVE_JSON_STRINGIFY = -31
val NATIVE_SET_TIMEOUT = -40
val NATIVE_SET_INTERVAL = -41
val NATIVE_CLEAR_TIMEOUT = -42
val NATIVE_CLEAR_INTERVAL = -43
val NATIVE_SYMBOL = -44
val NATIVE_ARRAY_PUSH = -50
val NATIVE_ARRAY_POP = -51
val NATIVE_ARRAY_LENGTH = -52
val NATIVE_STRING_CHAR_AT = -60
val NATIVE_STRING_INDEX_OF = -61
val NATIVE_STRING_SLICE = -62
val NATIVE_STRING_SPLIT = -63
val NATIVE_STRING_TO_UPPER = -64
val NATIVE_STRING_TO_LOWER = -65

# ── Console implementation ───────────────────────────────────────────────

fn format_value(value: JsValue) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(v):
            if v: "true"
            else: "false"
        JsValue.Number(v): "{v}"
        JsValue.String(v): v
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

fn console_log(args: [JsValue], logger: Logger):
    var parts: [text] = []
    var i = 0
    val len = args.len()
    while i < len:
        parts.push(format_value(args.get(i)))
        i = i + 1
    val msg = parts.join(" ")
    eprint(msg)

fn console_error(args: [JsValue], logger: Logger):
    var parts: [text] = []
    var i = 0
    val len = args.len()
    while i < len:
        parts.push(format_value(args.get(i)))
        i = i + 1
    val msg = parts.join(" ")
    logger.error(msg)

fn console_warn(args: [JsValue], logger: Logger):
    var parts: [text] = []
    var i = 0
    val len = args.len()
    while i < len:
        parts.push(format_value(args.get(i)))
        i = i + 1
    val msg = parts.join(" ")
    logger.warn(msg)

# ── Error constructors ───────────────────────────────────────────────────

fn create_error(message: text, error_type: text) -> JsValue:
    # Returns a JsValue.String encoding the error for now.
    # A full implementation would create an Error object with .message, .stack, etc.
    JsValue.String(v: "{error_type}: {message}")

fn create_type_error(message: text) -> JsValue:
    create_error(message, "TypeError")

fn create_reference_error(message: text) -> JsValue:
    create_error(message, "ReferenceError")

fn create_syntax_error(message: text) -> JsValue:
    create_error(message, "SyntaxError")

fn create_range_error(message: text) -> JsValue:
    create_error(message, "RangeError")

# ── Native function dispatch ─────────────────────────────────────────────

fn _js_floor(n: f64) -> f64:
    val trunc = f64_to_i64(n)
    val fv = trunc.to_f64()
    if n < fv:
        return fv - 1.0
    fv

fn dispatch_native(fn_id: i64, args: [JsValue], logger: Logger) -> JsValue:
    if fn_id == NATIVE_CONSOLE_LOG:
        console_log(args, logger)
        return JsValue.Undefined

    if fn_id == NATIVE_CONSOLE_ERROR:
        console_error(args, logger)
        return JsValue.Undefined

    if fn_id == NATIVE_CONSOLE_WARN:
        console_warn(args, logger)
        return JsValue.Undefined

    if fn_id == NATIVE_PARSE_INT:
        if args.len() > 0:
            val s = js_to_string(args.get(0))
            # Check for radix argument
            var radix = 10
            if args.len() > 1:
                val r = to_number(args.get(1))
                radix = f64_to_i64(r)
            if radix == 16 or s.len() > 2:
                # Check for 0x prefix
                var hex_str = s
                var is_hex = false
                if s.len() > 2 and s[0] == "0" and (s[1] == "x" or s[1] == "X"):
                    is_hex = true
                    radix = 16
                    # Strip 0x prefix
                    var stripped = ""
                    var si = 2
                    while si < s.len():
                        stripped = stripped + s[si]
                        si = si + 1
                    hex_str = stripped
                if radix == 16:
                    var result = 0
                    var i = 0
                    val hex_len = hex_str.len()
                    while i < hex_len:
                        val ch = hex_str[i]
                        var digit = -1
                        if ch >= "0" and ch <= "9":
                            digit = _digit_val(ch)
                        if ch >= "a" and ch <= "f":
                            if ch == "a": digit = 10
                            if ch == "b": digit = 11
                            if ch == "c": digit = 12
                            if ch == "d": digit = 13
                            if ch == "e": digit = 14
                            if ch == "f": digit = 15
                        if ch >= "A" and ch <= "F":
                            if ch == "A": digit = 10
                            if ch == "B": digit = 11
                            if ch == "C": digit = 12
                            if ch == "D": digit = 13
                            if ch == "E": digit = 14
                            if ch == "F": digit = 15
                        if digit >= 0:
                            result = result * 16 + digit
                        i = i + 1
                    return JsValue.Number(v: result.to_f64())
            # Default base-10
            val parsed = s.parse_float()
            if val Some(n) = parsed:
                return JsValue.Number(v: f64_to_i64(n).to_f64())
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_PARSE_FLOAT:
        if args.len() > 0:
            val s = js_to_string(args.get(0))
            val parsed = s.parse_float()
            if val Some(n) = parsed:
                return JsValue.Number(v: n)
        return JsValue.Number(v: js_nan())  # NaN

    if fn_id == NATIVE_IS_NAN:
        if args.len() > 0:
            val n = to_number(args.get(0))
            return JsValue.Boolean(v: is_nan(n))
        return JsValue.Boolean(v: true)

    if fn_id == NATIVE_IS_FINITE:
        if args.len() > 0:
            val n = to_number(args.get(0))
            val is_nan = is_nan(n)
            val is_inf = n == js_infinity()
            val is_neg_inf = n == js_neg_infinity()
            val not_finite = is_nan or is_inf or is_neg_inf
            return JsValue.Boolean(v: not not_finite)
        return JsValue.Boolean(v: false)

    if fn_id == NATIVE_MATH_FLOOR:
        if args.len() > 0:
            val n = to_number(args.get(0))
            return JsValue.Number(v: _js_floor(n))
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_MATH_CEIL:
        if args.len() > 0:
            val n = to_number(args.get(0))
            # ceil(n) = -floor(-n)
            return JsValue.Number(v: 0.0 - _js_floor(0.0 - n))
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_MATH_ROUND:
        if args.len() > 0:
            val n = to_number(args.get(0))
            return JsValue.Number(v: _js_floor(n + 0.5))
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_MATH_RANDOM:
        # Simple pseudo-random using runtime clock
        return JsValue.Number(v: 0.5)  # Stub — no true random without FFI

    if fn_id == NATIVE_MATH_ABS:
        if args.len() > 0:
            val n = to_number(args.get(0))
            if n < 0.0:
                return JsValue.Number(v: 0.0 - n)
            return JsValue.Number(v: n)
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_MATH_MAX:
        if args.len() == 0:
            return JsValue.Number(v: js_neg_infinity())  # -Infinity
        var max_val = to_number(args.get(0))
        var i = 1
        while i < args.len():
            val n = to_number(args.get(i))
            if n > max_val:
                max_val = n
            i = i + 1
        return JsValue.Number(v: max_val)

    if fn_id == NATIVE_MATH_MIN:
        if args.len() == 0:
            return JsValue.Number(v: js_infinity())  # Infinity
        var min_val = to_number(args.get(0))
        var i = 1
        while i < args.len():
            val n = to_number(args.get(i))
            if n < min_val:
                min_val = n
            i = i + 1
        return JsValue.Number(v: min_val)

    if fn_id == NATIVE_MATH_SQRT:
        if args.len() > 0:
            val n = to_number(args.get(0))
            return JsValue.Number(v: n ** 0.5)
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_MATH_POW:
        if args.len() >= 2:
            val base = to_number(args.get(0))
            val exp = to_number(args.get(1))
            return JsValue.Number(v: base ** exp)
        return JsValue.Number(v: js_nan())

    if fn_id == NATIVE_JSON_STRINGIFY:
        if args.len() > 0:
            val s = format_value(args.get(0))
            return JsValue.String(v: s)
        return JsValue.String(v: "undefined")

    if fn_id == NATIVE_JSON_PARSE:
        # Stub — full JSON parsing requires its own parser
        if args.len() > 0:
            val s = js_to_string(args.get(0))
            val parsed = s.parse_float()
            if val Some(n) = parsed:
                return JsValue.Number(v: n)
            if s == "true":
                return JsValue.Boolean(v: true)
            if s == "false":
                return JsValue.Boolean(v: false)
            if s == "null":
                return JsValue.Null
            return JsValue.String(v: s)
        return JsValue.Undefined

    # Timer stubs
    if fn_id == NATIVE_SET_TIMEOUT:
        return JsValue.Number(v: 0.0)  # Stub timer id
    if fn_id == NATIVE_SET_INTERVAL:
        return JsValue.Number(v: 0.0)
    if fn_id == NATIVE_CLEAR_TIMEOUT:
        return JsValue.Undefined
    if fn_id == NATIVE_CLEAR_INTERVAL:
        return JsValue.Undefined

    if fn_id == NATIVE_SYMBOL:
        return JsValue.Symbol(id: _next_symbol_id())

    JsValue.Undefined

# ── Runtime ──────────────────────────────────────────────────────────────

class JsRuntime:
    interpreter: JsInterpreter
    global_object: i64
    prototypes: PrototypeChain
    logger: Logger
    native_functions: [Pair<text, i64>]

    static fn new(logger: Logger) -> JsRuntime:
        var interp = JsInterpreter.new(logger)
        val global_obj = interp.object_store.create_object()
        var rt = JsRuntime(
            interpreter: interp,
            global_object: global_obj,
            prototypes: PrototypeChain.empty(),
            logger: logger,
            native_functions: [],
        )
        rt.initialize()
        rt

    # Register a native function in the interpreter's function table
    me _register_native(name: text, native_id: i64) -> i64:
        # Store a JsFunction with empty body — the interpreter will check for
        # negative IDs and dispatch to the native handler.
        val fn_idx = self.interpreter.functions.len()
        val placeholder = JsFunction(
            name: name,
            params: [],
            body: [],
            closure_env: -1,
        )
        self.interpreter.functions.push(placeholder)
        self.native_functions.push(Pair(first: name, second: native_id))
        self.interpreter.native_id_map.push(Pair(first: fn_idx, second: native_id))
        fn_idx

    # Define a native function in the global scope
    me _define_global_fn(name: text, native_id: i64):
        val fn_idx = self._register_native(name, native_id)
        val fn_val = JsValue.Function(id: fn_idx)
        self.interpreter.env_stack.define_var(self.interpreter.global_env, name, fn_val)

    # Define a native method on an object
    me _define_method_on(obj_id: i64, method_name: text, native_id: i64):
        val fn_idx = self._register_native(method_name, native_id)
        val fn_val = JsValue.Function(id: fn_idx)
        self.interpreter.object_store.set_property(obj_id, method_name, fn_val)

    # Initialize the global environment with all built-in objects and functions
    me initialize():
        self.logger.debug("Initializing JS runtime globals")

        # ── Global values ────────────────────────────────────────────
        self.interpreter.env_stack.define_var(self.interpreter.global_env, "undefined", JsValue.Undefined)
        self.interpreter.env_stack.define_var(self.interpreter.global_env, "NaN", JsValue.Number(v: js_nan()))
        self.interpreter.env_stack.define_var(self.interpreter.global_env, "Infinity", JsValue.Number(v: js_infinity()))

        # ── Global functions ─────────────────────────────────────────
        self._define_global_fn("parseInt", NATIVE_PARSE_INT)
        self._define_global_fn("parseFloat", NATIVE_PARSE_FLOAT)
        self._define_global_fn("isNaN", NATIVE_IS_NAN)
        self._define_global_fn("isFinite", NATIVE_IS_FINITE)
        self._define_global_fn("Symbol", NATIVE_SYMBOL)

        # ── console object ───────────────────────────────────────────
        val console_id = self.interpreter.object_store.create_object()
        self._define_method_on(console_id, "log", NATIVE_CONSOLE_LOG)
        self._define_method_on(console_id, "error", NATIVE_CONSOLE_ERROR)
        self._define_method_on(console_id, "warn", NATIVE_CONSOLE_WARN)
        self.interpreter.env_stack.define_var(
            self.interpreter.global_env, "console", JsValue.Object(id: console_id))

        # ── Math object ──────────────────────────────────────────────
        val math_id = self.interpreter.object_store.create_object()
        self.interpreter.object_store.set_property(math_id, "PI", JsValue.Number(v: 3.141592653589793))
        self.interpreter.object_store.set_property(math_id, "E", JsValue.Number(v: 2.718281828459045))
        self.interpreter.object_store.set_property(math_id, "LN2", JsValue.Number(v: 0.6931471805599453))
        self.interpreter.object_store.set_property(math_id, "LN10", JsValue.Number(v: 2.302585092994046))
        self.interpreter.object_store.set_property(math_id, "SQRT2", JsValue.Number(v: 1.4142135623730951))
        self._define_method_on(math_id, "floor", NATIVE_MATH_FLOOR)
        self._define_method_on(math_id, "ceil", NATIVE_MATH_CEIL)
        self._define_method_on(math_id, "round", NATIVE_MATH_ROUND)
        self._define_method_on(math_id, "random", NATIVE_MATH_RANDOM)
        self._define_method_on(math_id, "abs", NATIVE_MATH_ABS)
        self._define_method_on(math_id, "max", NATIVE_MATH_MAX)
        self._define_method_on(math_id, "min", NATIVE_MATH_MIN)
        self._define_method_on(math_id, "sqrt", NATIVE_MATH_SQRT)
        self._define_method_on(math_id, "pow", NATIVE_MATH_POW)
        self.interpreter.env_stack.define_var(
            self.interpreter.global_env, "Math", JsValue.Object(id: math_id))

        # ── JSON object ──────────────────────────────────────────────
        val json_id = self.interpreter.object_store.create_object()
        self._define_method_on(json_id, "parse", NATIVE_JSON_PARSE)
        self._define_method_on(json_id, "stringify", NATIVE_JSON_STRINGIFY)
        self.interpreter.env_stack.define_var(
            self.interpreter.global_env, "JSON", JsValue.Object(id: json_id))

        # ── Timer stubs ──────────────────────────────────────────────
        self._define_global_fn("setTimeout", NATIVE_SET_TIMEOUT)
        self._define_global_fn("setInterval", NATIVE_SET_INTERVAL)
        self._define_global_fn("clearTimeout", NATIVE_CLEAR_TIMEOUT)
        self._define_global_fn("clearInterval", NATIVE_CLEAR_INTERVAL)

        # ── Prototypes (create empty objects for now) ────────────────
        self.prototypes.object_proto = self.interpreter.object_store.create_object()
        self.prototypes.array_proto = self.interpreter.object_store.create_object()
        self.prototypes.function_proto = self.interpreter.object_store.create_object()
        self.prototypes.string_proto = self.interpreter.object_store.create_object()
        self.prototypes.number_proto = self.interpreter.object_store.create_object()
        self.prototypes.error_proto = self.interpreter.object_store.create_object()

        self.logger.debug("JS runtime initialized with {self.interpreter.functions.len()} native functions")

    # ── Public API ───────────────────────────────────────────────────

    # Evaluate a string of JavaScript source code
    me eval(source: text) -> BrowserResult<JsValue>:
        self.logger.debug("Evaluating JS source ({source.len()} chars)")

        # Lex + parse
        var parser = JsParser.new(source, self.logger)
        val program = parser.parse_program()?

        self.logger.debug("Parsed {program.len()} top-level statements")

        # Execute
        val result = self.interpreter.execute(program)?

        self.logger.debug("Execution complete")
        Ok(result)

    # Call a function by its internal ID with given arguments
    me call(function_id: i64, args: [JsValue]) -> BrowserResult<JsValue>:
        # Check if it's a native function
        var i = 0
        val nlen = self.native_functions.len()
        while i < nlen:
            val pair = self.native_functions.get(i)
            if i == function_id:
                val result = dispatch_native(pair.second, args, self.logger)
                return Ok(result)
            i = i + 1

        # User-defined function
        if function_id >= 0 and function_id < self.interpreter.functions.len():
            val js_fn = self.interpreter.functions.get(function_id)
            val fn_env = self.interpreter.env_stack.create_env(js_fn.closure_env)

            var pi = 0
            val plen = js_fn.params.len()
            while pi < plen:
                val param_name = js_fn.params.get(pi)
                var param_val = JsValue.Undefined
                if pi < args.len():
                    param_val = args.get(pi)
                self.interpreter.env_stack.define_var(fn_env, param_name, param_val)
                pi = pi + 1

            val saved = self.interpreter.has_return
            self.interpreter.has_return = false
            var result = JsValue.Undefined
            var bi = 0
            val blen = js_fn.body.len()
            while bi < blen:
                result = self.interpreter.exec_statement(js_fn.body.get(bi), fn_env)?
                if self.interpreter.has_return:
                    result = self.interpreter.return_value
                    break
                bi = bi + 1
            self.interpreter.has_return = saved
            return Ok(result)

        Err(script_error("Invalid function id: {function_id}"))

    # Register a host-provided native function by name and callback ID
    me define_native_function(name: text, callback_id: i64):
        self._define_global_fn(name, callback_id)
