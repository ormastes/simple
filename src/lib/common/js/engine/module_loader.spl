# JavaScript Module Loader — CommonJS require() and ES module support
# Resolves, loads, and caches JavaScript modules.

use std.js.types.js_types.{JsValue, JsObject, JsProperty}
use std.js.types.ast_types.{Statement, Expression}
use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

val CORE_MODULES = ["fs", "path", "process", "http", "https", "crypto", "os", "url", "child_process", "util", "events", "stream", "buffer", "assert", "querystring"]

fn is_core_module(name: text) -> bool:
    var i = 0
    while i < CORE_MODULES.len():
        if CORE_MODULES[i] == name:
            return true
        i = i + 1
    false

fn is_relative_path(path: text) -> bool:
    path.starts_with("./") or path.starts_with("../") or path.starts_with("/")

class CachedModule:
    path: text
    exports: JsValue
    loaded: bool

class JsModuleLoader:
    cache: [CachedModule]
    search_paths: [text]
    core_modules: [Pair<text, JsValue>]
    logger: Logger

    static fn new(logger: Logger) -> JsModuleLoader:
        JsModuleLoader(
            cache: [],
            search_paths: [],
            core_modules: [],
            logger: logger
        )

    me register_core(name: text, module_exports: JsValue):
        self.core_modules.push(Pair(first: name, second: module_exports))

    me add_search_path(path: text):
        self.search_paths.push(path)

    fn resolve(specifier: text, from_dir: text) -> Result<text, text>:
        if is_core_module(specifier):
            return Ok("__core__:" + specifier)
        if is_relative_path(specifier):
            val resolved = _resolve_file_path(from_dir, specifier)
            if resolved != "":
                return Ok(resolved)
            return Err("Cannot find module '{specifier}' from '{from_dir}'")
        var current_dir = from_dir
        var depth = 0
        while depth < 20:
            val modules_dir = current_dir + "/spl_modules/" + specifier
            val resolved = _resolve_package_entry(modules_dir)
            if resolved != "":
                return Ok(resolved)
            val parent = _parent_dir(current_dir)
            if parent == current_dir:
                break
            current_dir = parent
            depth = depth + 1
        var i = 0
        while i < self.search_paths.len():
            val sp = self.search_paths[i]
            val candidate = sp + "/" + specifier
            val resolved = _resolve_package_entry(candidate)
            if resolved != "":
                return Ok(resolved)
            i = i + 1
        Err("Cannot find module '{specifier}'")

    me require(specifier: text, from_dir: text) -> JsValue:
        val resolved = self.resolve(specifier, from_dir)
        match resolved:
            Ok(path):
                if path.starts_with("__core__:"):
                    val core_name = path.slice(9, path.len())
                    var ci = 0
                    while ci < self.core_modules.len():
                        val cm = self.core_modules[ci]
                        if cm.first == core_name:
                            return cm.second
                        ci = ci + 1
                    self.logger.warn("Core module '{core_name}' not registered")
                    return JsValue.Object(id: -1)
                var ci = 0
                while ci < self.cache.len():
                    if self.cache[ci].path == path:
                        return self.cache[ci].exports
                    ci = ci + 1
                val source = rt_file_read_text(path)
                if source == "" or source == nil:
                    self.logger.warn("Cannot read module: {path}")
                    return JsValue.Undefined
                val entry = CachedModule(path: path, exports: JsValue.Object(id: -1), loaded: false)
                self.cache.push(entry)
                return JsValue.String(v: source)
            Err(msg):
                self.logger.warn(msg)
                return JsValue.Undefined

    me set_exports(path: text, exports: JsValue):
        var i = 0
        while i < self.cache.len():
            if self.cache[i].path == path:
                self.cache[i] = CachedModule(path: path, exports: exports, loaded: true)
                return
            i = i + 1

fn _resolve_file_path(base_dir: text, relative: text) -> text:
    var full = ""
    if relative.starts_with("/"):
        full = relative
    elif relative.starts_with("./"):
        full = base_dir + "/" + relative.slice(2, relative.len())
    elif relative.starts_with("../"):
        val parent = _parent_dir(base_dir)
        full = parent + "/" + relative.slice(3, relative.len())
    else:
        full = base_dir + "/" + relative
    if rt_file_exists(full):
        return full
    if rt_file_exists(full + ".js"):
        return full + ".js"
    if rt_file_exists(full + ".spl"):
        return full + ".spl"
    if rt_file_exists(full + "/index.js"):
        return full + "/index.js"
    ""

fn _resolve_package_entry(pkg_dir: text) -> text:
    if rt_file_exists(pkg_dir + "/index.js"):
        return pkg_dir + "/index.js"
    if rt_file_exists(pkg_dir + "/index.spl"):
        return pkg_dir + "/index.spl"
    if rt_file_exists(pkg_dir + "/main.js"):
        return pkg_dir + "/main.js"
    if rt_file_exists(pkg_dir + "/main.spl"):
        return pkg_dir + "/main.spl"
    if rt_file_exists(pkg_dir + ".js"):
        return pkg_dir + ".js"
    ""

fn _parent_dir(path: text) -> text:
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash <= 0:
        return "/"
    path.slice(0, last_slash)
