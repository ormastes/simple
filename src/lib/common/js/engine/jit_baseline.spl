# JIT baseline compiler and profiling data.
# Provides JitProfile for call-count tracking, CompiledFunction as the handle
# for compiled code, and BaselineCompiler for bytecode -> JitIR translation.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError}
use std.js.engine.jit_types.{JitIR, JitTier, JitTypeTag}
use std.js.types.bytecode_types.{BytecodeChunk, OpCode, ConstantPool}
use std.js.types.js_types.{JsValue}

# --- Profiling data ---

class JitProfile:
    function_name: text
    call_count: i64
    hot_threshold: i64
    is_compiled: bool
    tier: JitTier
    deopt_count: i64
    type_observations: [JitTypeTag]
    optimizing_threshold: i64

    static fn create(function_name: text, hot_threshold: i64) -> JitProfile:
        JitProfile(
            function_name: function_name,
            call_count: 0,
            hot_threshold: hot_threshold,
            is_compiled: false,
            tier: JitTier.Baseline,
            deopt_count: 0,
            type_observations: [],
            optimizing_threshold: hot_threshold * 5
        )

# --- Compiled function handle ---

class CompiledFunction:
    name: text
    tier: JitTier
    native_code_id: i64
    ir: [JitIR]

# --- Baseline compiler: bytecode -> JitIR ---

class BaselineCompiler:
    next_reg: i64
    stack_top: i64
    logger: Logger

    static fn create(logger: Logger) -> BaselineCompiler:
        BaselineCompiler(next_reg: 0, stack_top: 0, logger: logger)

    me compile(chunk: BytecodeChunk) -> [JitIR]:
        self.next_reg = 0
        self.stack_top = 0
        var ir: [JitIR] = []
        var i = 0
        val ops = chunk.ops
        val constants = chunk.constants
        while i < ops.len():
            val op = ops.get(i)
            val instrs = self._translate_op(op, constants)
            var j = 0
            while j < instrs.len():
                ir.push(instrs.get(j))
                j = j + 1
            i = i + 1
        ir

    me _alloc_reg() -> i64:
        val r = self.next_reg
        self.next_reg = self.next_reg + 1
        r

    me _push_stack() -> i64:
        val r = self.stack_top
        self.stack_top = self.stack_top + 1
        r

    me _pop_stack() -> i64:
        self.stack_top = self.stack_top - 1
        self.stack_top

    me _translate_op(op: OpCode, constants: ConstantPool) -> [JitIR]:
        var result: [JitIR] = []
        match op:
            OpCode.LoadConst(idx):
                val reg = self._push_stack()
                val value = constants.values.get(idx)
                result.push(JitIR.LoadConst(reg: reg, value: value))
            OpCode.LoadLocal(idx):
                val reg = self._push_stack()
                result.push(JitIR.LoadLocal(reg: reg, slot: idx))
            OpCode.StoreLocal(idx):
                val reg = self._pop_stack()
                result.push(JitIR.StoreLocal(slot: idx, reg: reg))
            OpCode.LoadGlobal(name):
                val reg = self._push_stack()
                result.push(JitIR.LoadGlobal(reg: reg, name: name))
            OpCode.StoreGlobal(name):
                val reg = self._pop_stack()
                result.push(JitIR.StoreGlobal(name: name, reg: reg))
            OpCode.Add:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Add(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Sub:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Sub(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Mul:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Mul(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Div:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Div(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Mod:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Mod(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Eq:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "eq"))
            OpCode.Ne:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "ne"))
            OpCode.Lt:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "lt"))
            OpCode.Gt:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "gt"))
            OpCode.Le:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "le"))
            OpCode.Ge:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "ge"))
            OpCode.Not:
                val src = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.LogicalNot(dst: dst, src: src))
            OpCode.Neg:
                val src = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Negate(dst: dst, src: src))
            OpCode.Call(argc):
                # Pop arguments + function, push result
                var a = 0
                while a < argc:
                    self._pop_stack()
                    a = a + 1
                val func_reg = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Call(dst: dst, func_reg: func_reg, arg_count: argc))
            OpCode.Return:
                val reg = self._pop_stack()
                result.push(JitIR.Return(reg: reg))
            OpCode.Jump(offset):
                result.push(JitIR.Jump(offset: offset))
            OpCode.JumpIfFalse(offset):
                val reg = self._pop_stack()
                result.push(JitIR.JumpIfFalse(reg: reg, offset: offset))
            OpCode.Pop:
                val reg = self._pop_stack()
                result.push(JitIR.Pop(reg: reg))
            OpCode.Dup:
                val src = self.stack_top - 1
                val dst = self._push_stack()
                result.push(JitIR.Dup(dst: dst, src: src))
            OpCode.GetProperty(name):
                val obj_reg = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.GetProperty(dst: dst, obj_reg: obj_reg, name: name))
            OpCode.SetProperty(name):
                val val_reg = self._pop_stack()
                val obj_reg = self._pop_stack()
                result.push(JitIR.SetProperty(obj_reg: obj_reg, name: name, val_reg: val_reg))
            OpCode.NewObject:
                val dst = self._push_stack()
                result.push(JitIR.NewObject(dst: dst))
            OpCode.NewArray(count):
                # Pop count items, push array
                var a = 0
                while a < count:
                    self._pop_stack()
                    a = a + 1
                val dst = self._push_stack()
                result.push(JitIR.NewArray(dst: dst, count: count))
            OpCode.Halt:
                # No IR needed, execution ends naturally
                pass_dn
            _:
                # Unsupported opcodes become Nop (closures, exceptions, iterators)
                result.push(JitIR.Nop)
        result
