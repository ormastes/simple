# Node.js os module — operating system info

use std.js.types.js_types.{JsValue}

extern fn rt_env_get(key: text) -> text

fn os_platform(args: [JsValue]) -> JsValue:
    JsValue.String(v: "simpleos")

fn os_arch(args: [JsValue]) -> JsValue:
    JsValue.String(v: "x86_64")

fn os_homedir(args: [JsValue]) -> JsValue:
    val home = rt_env_get("HOME")
    if home != "" and home != nil:
        return JsValue.String(v: home)
    JsValue.String(v: "/root")

fn os_tmpdir(args: [JsValue]) -> JsValue:
    JsValue.String(v: "/tmp")

fn os_hostname(args: [JsValue]) -> JsValue:
    JsValue.String(v: "simpleos")

fn create_os_module() -> [Pair<text, JsValue>]:
    var methods: [Pair<text, JsValue>] = []
    methods
