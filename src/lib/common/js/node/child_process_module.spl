# Node.js child_process module — command execution

use std.js.types.js_types.{JsValue}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn exec_sync(args: [JsValue]) -> JsValue:
    """Execute a command synchronously, return stdout."""
    if args.len() == 0:
        return JsValue.Undefined
    match args[0]:
        JsValue.String(cmd):
            var empty_args: [text] = []
            val result = rt_process_run(cmd, empty_args)
            JsValue.String(v: result.0)
        _:
            JsValue.Undefined

fn create_child_process_module() -> [Pair<text, JsValue>]:
    var methods: [Pair<text, JsValue>] = []
    methods
