# Node.js process module — process info and control

use std.js.types.js_types.{JsValue}

extern fn rt_env_get(key: text) -> text
extern fn rt_get_cwd() -> text

fn process_cwd(args: [JsValue]) -> JsValue:
    JsValue.String(v: rt_get_cwd())

fn process_exit(args: [JsValue]) -> JsValue:
    # In-process: just signal exit intention
    JsValue.Undefined

fn process_env_get(key: text) -> JsValue:
    val val = rt_env_get(key)
    if val == "" or val == nil:
        return JsValue.Undefined
    JsValue.String(v: val)

fn create_process_module(argv: [text], platform: text) -> [Pair<text, JsValue>]:
    """Create process module data."""
    var data = [Pair<text, JsValue>]()
    data.push(Pair(first: "platform", second: JsValue.String(v: platform)))
    data.push(Pair(first: "version", second: JsValue.String(v: "v0.9.5-simple")))
    data
