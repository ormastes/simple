# Node.js fs module — file system operations
# Provides readFileSync, writeFileSync, existsSync, mkdirSync, etc.

use std.js.types.js_types.{JsValue, JsObject, JsProperty}
use std.js.engine.js_error.{Logger, LogLevel}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_list_dir(path: text) -> [text]
extern fn rt_file_delete(path: text) -> bool
extern fn rt_mkdir(path: text) -> bool

class FsModule:
    """Node.js-compatible filesystem module."""

    static fn readFileSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Undefined
        val path = _to_text(args[0])
        val content = rt_file_read_text(path)
        if content == nil:
            return JsValue.Undefined
        JsValue.String(v: content)

    static fn writeFileSync(args: [JsValue]) -> JsValue:
        if args.len() < 2:
            return JsValue.Undefined
        val path = _to_text(args[0])
        val data = _to_text(args[1])
        rt_file_write_text(path, data)
        JsValue.Undefined

    static fn existsSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Boolean(v: false)
        val path = _to_text(args[0])
        JsValue.Boolean(v: rt_file_exists(path))

    static fn readdirSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Array(id: -1)
        val path = _to_text(args[0])
        val entries = rt_file_list_dir(path)
        # Return as array — caller needs to wrap in proper array object
        JsValue.Array(id: -1)

    static fn mkdirSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Undefined
        val path = _to_text(args[0])
        rt_mkdir(path)
        JsValue.Undefined

    static fn unlinkSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Undefined
        val path = _to_text(args[0])
        rt_file_delete(path)
        JsValue.Undefined

    static fn statSync(args: [JsValue]) -> JsValue:
        if args.len() == 0:
            return JsValue.Undefined
        val path = _to_text(args[0])
        if rt_file_exists(path):
            return JsValue.Object(id: -1)
        JsValue.Undefined

fn create_fs_module() -> [Pair<text, JsValue>]:
    """Create fs module methods as name-value pairs for registration."""
    var methods = [Pair<text, JsValue>]()
    # Methods will be registered by the runtime as native functions
    methods

fn _to_text(val: JsValue) -> text:
    match val:
        JsValue.String(v): v
        JsValue.Number(v): "{v}"
        _: ""
