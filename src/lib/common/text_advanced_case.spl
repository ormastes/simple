@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Text Advanced — Case Conversion and String Predicates
#
# Contains:
# - Case conversion (to_title_case, to_snake_case, to_camel_case,
#                    to_kebab_case, to_pascal_case, to_screaming_snake)
# - String predicates (is_upper, is_lower, is_title, is_ascii, is_printable)
#
# NOTE: Do NOT import from lib.common.text here — circular dependency risk.
use std.string_core.{char_code, is_whitespace_char, str_capitalize}
use common.string_builder.{StringBuilder}
use common.text_advanced_chars.{_is_alpha, _is_uppercase_char, _is_lowercase_char, _split_words}

# ============================================================================
# Advanced Case Conversion
# ============================================================================

fn to_title_case(text: text) -> text:
    """Convert text to title case (capitalize first letter of each word).

    Example:
        to_title_case("hello world")  # "Hello World"
    """
    val sb = StringBuilder(parts: [])
    var capitalize_next = true
    var i = 0

    while i < text.len():
        val ch = text[i]

        if is_whitespace_char(ch):
            sb.push(ch)
            capitalize_next = true
        elif capitalize_next and _is_alpha(ch):
            if _is_lowercase_char(ch):
                val upper_code = ch[0] - 32
                sb.push("{upper_code}")
            else:
                sb.push(ch)
            capitalize_next = false
        else:
            if _is_uppercase_char(ch):
                val lower_code = ch[0] + 32
                sb.push("{lower_code}")
            else:
                sb.push(ch)

        i = i + 1

    sb.to_text()

fn to_snake_case(text: text) -> text:
    """Convert text to snake_case.

    Example:
        to_snake_case("HelloWorld")  # "hello_world"
        to_snake_case("hello world")  # "hello_world"
    """
    val sb = StringBuilder(parts: [])
    var i = 0

    while i < text.len():
        val ch = text[i]

        if is_whitespace_char(ch):
            sb.push("_")
        elif _is_uppercase_char(ch):
            if i > 0 and not is_whitespace_char(text[i-1]):
                sb.push("_")
            val lower_code = ch[0] + 32
            sb.push("{lower_code}")
        else:
            sb.push(ch)

        i = i + 1

    sb.to_text()

fn to_camel_case(text: text) -> text:
    """Convert text to camelCase.

    Example:
        to_camel_case("hello world")  # "helloWorld"
        to_camel_case("hello_world")  # "helloWorld"
    """
    val sb = StringBuilder(parts: [])
    var capitalize_next = false
    var i = 0

    while i < text.len():
        val ch = text[i]

        if ch == " " or ch == "_":
            capitalize_next = true
        elif capitalize_next and _is_alpha(ch):
            if _is_lowercase_char(ch):
                val upper_code = ch[0] - 32
                sb.push("{upper_code}")
            else:
                sb.push(ch)
            capitalize_next = false
        else:
            sb.push(ch)

        i = i + 1

    sb.to_text()

fn to_kebab_case(s: text) -> text:
    """Convert text to kebab-case.

    sdoctest:
        expect(to_kebab_case("HelloWorld")).to_equal("hello-world")
        expect(to_kebab_case("hello_world")).to_equal("hello-world")
        expect(to_kebab_case("helloWorld")).to_equal("hello-world")
        expect(to_kebab_case("HELLO_WORLD")).to_equal("hello-world")
        expect(to_kebab_case("already-kebab")).to_equal("already-kebab")
        expect(to_kebab_case("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(word.lower())
    parts.join("-")

fn to_pascal_case(s: text) -> text:
    """Convert text to PascalCase.

    sdoctest:
        expect(to_pascal_case("hello_world")).to_equal("HelloWorld")
        expect(to_pascal_case("hello-world")).to_equal("HelloWorld")
        expect(to_pascal_case("helloWorld")).to_equal("HelloWorld")
        expect(to_pascal_case("HELLO_WORLD")).to_equal("HelloWorld")
        expect(to_pascal_case("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(str_capitalize(word))
    parts.join("")

fn to_screaming_snake(s: text) -> text:
    """Convert text to SCREAMING_SNAKE_CASE.

    sdoctest:
        expect(to_screaming_snake("helloWorld")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("hello-world")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("HelloWorld")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("hello_world")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(word.upper())
    parts.join("_")

# ============================================================================
# String Predicates
# ============================================================================

fn is_ascii(s: text) -> bool:
    """Check if all characters are ASCII (code 0-127).

    sdoctest:
        expect(is_ascii("hello")).to_equal(true)
        expect(is_ascii("")).to_equal(true)
    """
    var i = 0
    while i < s.len():
        val code = s[i][0]
        if code < 0 or code > 127:
            return false
        i = i + 1
    true

fn is_upper(s: text) -> bool:
    """Check if entire string is uppercase (ignoring non-alpha characters).

    Returns false for empty strings.

    sdoctest:
        expect(is_upper("HELLO")).to_equal(true)
        expect(is_upper("Hello")).to_equal(false)
        expect(is_upper("HELLO 123")).to_equal(true)
        expect(is_upper("")).to_equal(false)
    """
    if s.len() == 0:
        return false
    var has_alpha = false
    var i = 0
    while i < s.len():
        val ch = s[i]
        if _is_alpha(ch):
            has_alpha = true
            if _is_lowercase_char(ch):
                return false
        i = i + 1
    has_alpha

fn is_lower(s: text) -> bool:
    """Check if entire string is lowercase (ignoring non-alpha characters).

    Returns false for empty strings.

    sdoctest:
        expect(is_lower("hello")).to_equal(true)
        expect(is_lower("Hello")).to_equal(false)
        expect(is_lower("hello 123")).to_equal(true)
        expect(is_lower("")).to_equal(false)
    """
    if s.len() == 0:
        return false
    var has_alpha = false
    var i = 0
    while i < s.len():
        val ch = s[i]
        if _is_alpha(ch):
            has_alpha = true
            if _is_uppercase_char(ch):
                return false
        i = i + 1
    has_alpha

fn is_printable(s: text) -> bool:
    """Check if all characters are printable (code 32-126).

    Empty string is considered printable.

    sdoctest:
        expect(is_printable("hello world")).to_equal(true)
        expect(is_printable("")).to_equal(true)
    """
    var i = 0
    while i < s.len():
        val code = s[i][0]
        if code < 32 or code > 126:
            return false
        i = i + 1
    true

fn is_title(s: text) -> bool:
    """Check if string is title-cased (each word starts with uppercase).

    sdoctest:
        expect(is_title("Hello World")).to_equal(true)
        expect(is_title("hello World")).to_equal(false)
        expect(is_title("Hello")).to_equal(true)
        expect(is_title("")).to_equal(false)
    """
    if s.len() == 0:
        return false
    var expect_upper = true
    var has_alpha = false
    var i = 0
    while i < s.len():
        val ch = s[i]
        if is_whitespace_char(ch):
            expect_upper = true
        elif _is_alpha(ch):
            has_alpha = true
            if expect_upper:
                if _is_lowercase_char(ch):
                    return false
                expect_upper = false
            else:
                if _is_uppercase_char(ch):
                    return false
        i = i + 1
    has_alpha
