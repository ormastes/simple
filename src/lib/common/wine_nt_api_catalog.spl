"""NT/Win32 API catalog for the Wine hello.exe milestone and next gates."""

class WineNtApiCatalogEntry:
    dll: text
    symbol: text
    category: text
    state: text

fn _entry(dll: text, symbol: text, category: text, state: text) -> WineNtApiCatalogEntry:
    WineNtApiCatalogEntry(dll: dll, symbol: symbol, category: category, state: state)

fn _normalized_dll(dll: text) -> text:
    dll.lower()

fn _is_kernel32(dll: text) -> bool:
    _normalized_dll(dll) == "kernel32.dll"

fn _is_ntdll(dll: text) -> bool:
    _normalized_dll(dll) == "ntdll.dll"

fn _is_user32(dll: text) -> bool:
    _normalized_dll(dll) == "user32.dll"

fn _is_gdi32(dll: text) -> bool:
    _normalized_dll(dll) == "gdi32.dll"

fn _is_advapi32(dll: text) -> bool:
    _normalized_dll(dll) == "advapi32.dll"

fn _contains_symbol(symbols: [text], required: text) -> bool:
    for symbol in symbols:
        if symbol == required:
            return true
    false

fn _catalog_entry(dll: text, symbol: text) -> WineNtApiCatalogEntry:
    if _is_kernel32(dll):
        if symbol == "GetStdHandle":
            return _entry("kernel32.dll", symbol, "console", "implemented")
        if symbol == "WriteFile":
            return _entry("kernel32.dll", symbol, "console", "implemented")
        if symbol == "ExitProcess":
            return _entry("kernel32.dll", symbol, "process", "implemented")
        if symbol == "VirtualAlloc" or symbol == "VirtualProtect" or symbol == "VirtualFree":
            return _entry("kernel32.dll", symbol, "virtual-memory", "implemented")
        if symbol == "CreateFileW" or symbol == "ReadFile" or symbol == "GetFileType" or symbol == "CloseHandle":
            return _entry("kernel32.dll", symbol, "file-io", "implemented")
        if symbol == "GetFileAttributesW" or symbol == "GetFileSize" or symbol == "GetFileInformationByHandle" or symbol == "SetFilePointer":
            return _entry("kernel32.dll", symbol, "file-metadata", "implemented")
        if symbol == "DeleteFileW" or symbol == "CopyFileW" or symbol == "MoveFileW" or symbol == "CreateDirectoryW" or symbol == "RemoveDirectoryW":
            return _entry("kernel32.dll", symbol, "file-management", "implemented")
        if symbol == "CreateThread" or symbol == "WaitForSingleObject":
            return _entry("kernel32.dll", symbol, "thread-wait", "implemented")
        if symbol == "GetLastError" or symbol == "SetLastError" or symbol == "FormatMessageW":
            return _entry("kernel32.dll", symbol, "error-state", "implemented")
        if symbol == "GetCommandLineW" or symbol == "GetEnvironmentStringsW" or symbol == "GetCurrentDirectoryW" or symbol == "SetCurrentDirectoryW" or symbol == "GetModuleFileNameW" or symbol == "GetEnvironmentVariableW" or symbol == "SetEnvironmentVariableW" or symbol == "ExpandEnvironmentStringsW":
            return _entry("kernel32.dll", symbol, "process-env", "implemented")
        if symbol == "GetProcessHeap" or symbol == "HeapAlloc" or symbol == "HeapFree":
            return _entry("kernel32.dll", symbol, "heap", "implemented")
        if symbol == "LocalAlloc" or symbol == "LocalSize" or symbol == "LocalReAlloc" or symbol == "LocalFree":
            return _entry("kernel32.dll", symbol, "local-memory", "implemented")
        if symbol == "GlobalAlloc" or symbol == "GlobalSize" or symbol == "GlobalLock" or symbol == "GlobalUnlock" or symbol == "GlobalReAlloc" or symbol == "GlobalFree":
            return _entry("kernel32.dll", symbol, "global-memory", "implemented")
        if symbol == "GetModuleHandleW" or symbol == "LoadLibraryW" or symbol == "LoadLibraryExW" or symbol == "GetProcAddress" or symbol == "FreeLibrary":
            return _entry("kernel32.dll", symbol, "module-loader", "implemented")
        if symbol == "GetTickCount" or symbol == "QueryPerformanceCounter" or symbol == "QueryPerformanceFrequency" or symbol == "GetVersion" or symbol == "GetVersionExW":
            return _entry("kernel32.dll", symbol, "time-version", "implemented")
        if symbol == "GetWindowsDirectoryW" or symbol == "GetSystemDirectoryW" or symbol == "GetTempPathW" or symbol == "GetTempFileNameW" or symbol == "GetFullPathNameW" or symbol == "SearchPathW":
            return _entry("kernel32.dll", symbol, "path", "implemented")
        if symbol == "GetCurrentProcessId" or symbol == "GetCurrentThreadId" or symbol == "GetCurrentProcess" or symbol == "GetCurrentThread":
            return _entry("kernel32.dll", symbol, "process-identity", "implemented")
        if symbol == "CreateEventW" or symbol == "SetEvent" or symbol == "ResetEvent":
            return _entry("kernel32.dll", symbol, "sync-event", "implemented")
        if symbol == "GetStartupInfoW":
            return _entry("kernel32.dll", symbol, "startup-info", "implemented")
        if symbol == "InitializeCriticalSection" or symbol == "EnterCriticalSection" or symbol == "LeaveCriticalSection" or symbol == "DeleteCriticalSection":
            return _entry("kernel32.dll", symbol, "critical-section", "implemented")
        if symbol == "GlobalAddAtomW" or symbol == "GlobalFindAtomW" or symbol == "GlobalDeleteAtom":
            return _entry("kernel32.dll", symbol, "atom-table", "implemented")
        if symbol == "TlsAlloc" or symbol == "TlsSetValue" or symbol == "TlsGetValue" or symbol == "TlsFree":
            return _entry("kernel32.dll", symbol, "tls", "implemented")
        if symbol == "FlsAlloc" or symbol == "FlsSetValue" or symbol == "FlsGetValue" or symbol == "FlsFree":
            return _entry("kernel32.dll", symbol, "fls", "implemented")
        if symbol == "InterlockedIncrement" or symbol == "InterlockedDecrement" or symbol == "InterlockedExchange" or symbol == "InterlockedCompareExchange" or symbol == "InterlockedExchangeAdd":
            return _entry("kernel32.dll", symbol, "interlocked", "implemented")
    if _is_ntdll(dll):
        if symbol == "NtAllocateVirtualMemory" or symbol == "NtProtectVirtualMemory" or symbol == "NtFreeVirtualMemory":
            return _entry("ntdll.dll", symbol, "nt-virtual-memory", "implemented")
        if symbol == "NtCreateFile" or symbol == "NtReadFile" or symbol == "NtClose" or symbol == "NtSetInformationFile":
            return _entry("ntdll.dll", symbol, "nt-file-io", "implemented")
        if symbol == "RtlAllocateHeap" or symbol == "RtlFreeHeap":
            return _entry("ntdll.dll", symbol, "rtl-heap", "implemented")
        if symbol == "RtlInitUnicodeString" or symbol == "RtlUnicodeStringToAnsiString" or symbol == "RtlFreeAnsiString":
            return _entry("ntdll.dll", symbol, "rtl-string", "implemented")
    if _is_user32(dll):
        if symbol == "MessageBoxW":
            return _entry("user32.dll", symbol, "gui-dialog", "implemented")
        if symbol == "CreateWindowExW" or symbol == "ShowWindow" or symbol == "UpdateWindow" or symbol == "DefWindowProcW":
            return _entry("user32.dll", symbol, "window-lifecycle", "implemented")
        if symbol == "GetMessageW" or symbol == "TranslateMessage" or symbol == "DispatchMessageW" or symbol == "PeekMessageW":
            return _entry("user32.dll", symbol, "message-loop", "implemented")
    if _is_gdi32(dll):
        if symbol == "TextOutW" or symbol == "BitBlt" or symbol == "CreateCompatibleDC" or symbol == "DeleteDC":
            return _entry("gdi32.dll", symbol, "gdi-drawing", "implemented")
    if _is_advapi32(dll):
        if symbol == "RegCreateKeyExW" or symbol == "RegOpenKeyExW" or symbol == "RegSetValueExW" or symbol == "RegQueryValueExW" or symbol == "RegCloseKey":
            return _entry("advapi32.dll", symbol, "registry", "implemented")
        if symbol == "OpenSCManagerW" or symbol == "CreateServiceW" or symbol == "OpenServiceW" or symbol == "StartServiceW" or symbol == "CloseServiceHandle":
            return _entry("advapi32.dll", symbol, "service-control", "implemented")
    _entry(_normalized_dll(dll), symbol, "unknown", "unsupported")

