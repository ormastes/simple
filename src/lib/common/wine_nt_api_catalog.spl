pub fn wine_nt_api_dll_gate(dll: text) -> text:
    if _is_kernel32(dll):
        return "ready"
    if _is_user32(dll):
        return "ready"
    if _is_ntdll(dll):
        return "catalogued-dll:ntdll.dll"
    if _is_gdi32(dll):
        return "ready"
    if _is_advapi32(dll):
        return "ready"
    "unsupported-dll:" + dll

pub fn wine_nt_api_symbol_state(dll: text, symbol: text) -> WineNtApiCatalogEntry:
    _catalog_entry(dll, symbol)

pub fn wine_nt_api_import_gate(dll: text, symbols: [text]) -> text:
    val dll_state = wine_nt_api_dll_gate(dll)
    if dll_state != "ready":
        return dll_state
    for required in wine_nt_api_implemented_symbols_for_hello():
        if not _contains_symbol(symbols, required):
            return "missing-symbol:" + required
    for symbol in symbols:
        val entry = wine_nt_api_symbol_state(dll, symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
        if not _contains_symbol(wine_nt_api_implemented_symbols_for_hello(), symbol):
            return "wrong-category:" + symbol
    "ready"

pub fn wine_nt_api_dispatch_gate(symbols: [text]) -> text:
    for required in wine_nt_api_implemented_symbols_for_hello():
        if not _contains_symbol(symbols, required):
            return "bridge-missing:" + required
    for symbol in symbols:
        val entry = wine_nt_api_symbol_state("kernel32.dll", symbol)
        if entry.state != "implemented":
            return "bridge-unsupported:" + symbol
        if not _contains_symbol(wine_nt_api_implemented_symbols_for_hello(), symbol):
            return "bridge-wrong-category:" + symbol
    "ready"
