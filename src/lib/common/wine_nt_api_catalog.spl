    if not _is_advapi32(dll):
        return wine_nt_api_dll_gate(dll)
    if symbols.len() == 0:
        return "missing-symbol:advapi32"
    for symbol in symbols:
        val entry = wine_nt_api_symbol_state(dll, symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
    "ready"

pub fn wine_nt_api_advapi32_dispatch_gate(symbols: [text]) -> text:
    if symbols.len() == 0:
        return "bridge-missing:advapi32"
    for symbol in symbols:
        val entry = wine_nt_api_symbol_state("advapi32.dll", symbol)
        if entry.state != "implemented":
            return "bridge-unsupported:" + symbol
    "ready"
