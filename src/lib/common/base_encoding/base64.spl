# Pure Simple Base64 encode/decode (RFC 4648).
#
# Replaces the compiled-only base64.smf with auditable source.
# The C functions __c_rt_base64_encode / __c_rt_base64_decode in
# src/runtime/runtime_base64.c are NOT called from Simple; they are
# only used internally by other C runtime functions (e.g. rt_sha1_finish_base64).
# This library operates on Simple text values directly.
#
# NOTE: In Simple `and`/`or` are boolean operators; `&`/`|` are bitwise.
#
# Exported functions:
#   base64_encode(data: text) -> text
#   base64_decode(encoded: text) -> text
#   base64url_encode(data: text) -> text
#   base64url_decode(encoded: text) -> text

# ============================================================================
# Encoding table (RFC 4648 §4)
# ============================================================================

val ENCODE_TABLE = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

# ============================================================================
# Decode helper: maps ASCII ordinal → 6-bit value, or 255 for invalid.
# ============================================================================

fn _decode_char(c: i64) -> i64:
    """Return the 6-bit value for an ASCII base64 character, or 255 if invalid."""
    if c >= 65 and c <= 90:
        c - 65
    else if c >= 97 and c <= 122:
        c - 97 + 26
    else if c >= 48 and c <= 57:
        c - 48 + 52
    else if c == 43:   # '+'
        62
    else if c == 47:   # '/'
        63
    else:
        255

# ============================================================================
# Encode
# ============================================================================

pub fn base64_encode(data: text) -> text:
    """Encode arbitrary text as standard base64 (RFC 4648 §4, with '=' padding)."""
    val bytes = data.bytes()
    val n = bytes.len()
    var out = ""
    var i = 0
    while i < n:
        val b1 = bytes[i] as i64
        var b2: i64 = 0
        var b3: i64 = 0
        if i + 1 < n:
            b2 = bytes[i + 1] as i64
        if i + 2 < n:
            b3 = bytes[i + 2] as i64

        # Use & (bitwise AND) and | (bitwise OR) — not `and`/`or` (boolean)
        val idx0 = b1 >> 2
        val idx1 = ((b1 & 3) << 4) | (b2 >> 4)
        val idx2 = ((b2 & 15) << 2) | (b3 >> 6)
        val idx3 = b3 & 63

        out = out + ENCODE_TABLE.char_at(idx0)
        out = out + ENCODE_TABLE.char_at(idx1)
        if i + 1 < n:
            out = out + ENCODE_TABLE.char_at(idx2)
        else:
            out = out + "="
        if i + 2 < n:
            out = out + ENCODE_TABLE.char_at(idx3)
        else:
            out = out + "="

        i = i + 3
    out

# ============================================================================
# Decode
# ============================================================================

pub fn base64_decode(encoded: text) -> text:
    """Decode standard base64 text (RFC 4648 §4).

    Whitespace is ignored. Invalid characters are skipped (lenient mode).
    Padding '=' terminates the current group.
    """
    val n = encoded.length()
    var out_bytes: [u8] = []
    var c0 = 0
    var c1 = 0
    var c2 = 0
    var c3 = 0
    var chunk_len = 0
    var pad_count = 0
    var i = 0
    while i < n:
        # Use char_at(i) as i64 to get code point — byte_at is not available
        # on the str type returned by char_at in interpreter mode.
        val raw = encoded.char_at(i) as i64
        i = i + 1

        # Skip whitespace (space, tab, LF, CR)
        if raw == 32 or raw == 9 or raw == 10 or raw == 13:
            pass_dn

        if raw == 61:  # '=' padding
            pad_count = pad_count + 1
            chunk_len = chunk_len + 1
            if chunk_len == 4:
                out_bytes = out_bytes.push(((c0 << 2) | (c1 >> 4)) as u8)
                if pad_count < 2:
                    out_bytes = out_bytes.push((((c1 & 15) << 4) | (c2 >> 2)) as u8)
                chunk_len = 0
                c0 = 0
                c1 = 0
                c2 = 0
                c3 = 0
                pad_count = 0
        else:
            val v = _decode_char(raw)
            if v != 255:
                if chunk_len == 0:
                    c0 = v
                else if chunk_len == 1:
                    c1 = v
                else if chunk_len == 2:
                    c2 = v
                else:
                    c3 = v
                chunk_len = chunk_len + 1
                if chunk_len == 4:
                    out_bytes = out_bytes.push(((c0 << 2) | (c1 >> 4)) as u8)
                    out_bytes = out_bytes.push((((c1 & 15) << 4) | (c2 >> 2)) as u8)
                    out_bytes = out_bytes.push((((c2 & 3) << 6) | c3) as u8)
                    chunk_len = 0
                    c0 = 0
                    c1 = 0
                    c2 = 0
                    c3 = 0

    # Handle incomplete final group (no explicit padding in stream)
    if chunk_len >= 2:
        out_bytes = out_bytes.push(((c0 << 2) | (c1 >> 4)) as u8)
    if chunk_len >= 3:
        out_bytes = out_bytes.push((((c1 & 15) << 4) | (c2 >> 2)) as u8)

    _bytes_to_text(out_bytes)

# ============================================================================
# Base64url variants (RFC 4648 §5): replaces +→-, /→_; no padding
# ============================================================================

pub fn base64url_encode(data: text) -> text:
    """Encode text as URL-safe base64 (RFC 4648 §5, no padding)."""
    val std = base64_encode(data)
    val n = std.length()
    var out = ""
    var i = 0
    while i < n:
        val c = std.char_at(i)
        if c == "+":
            out = out + "-"
        else if c == "/":
            out = out + "_"
        else if c != "=":
            out = out + c
        i = i + 1
    out

pub fn base64url_decode(encoded: text) -> text:
    """Decode URL-safe base64 text (RFC 4648 §5).

    Replaces '-'→'+', '_'→'/', re-pads to 4-char boundary, then
    delegates to standard base64_decode. This is the pure-Simple
    replacement for the C extern rt_base64url_decode used in id_token.spl.
    """
    val n = encoded.length()
    var std_b64 = ""
    var i = 0
    while i < n:
        val c = encoded.char_at(i)
        if c == "-":
            std_b64 = std_b64 + "+"
        else if c == "_":
            std_b64 = std_b64 + "/"
        else:
            std_b64 = std_b64 + c
        i = i + 1

    # Re-add '=' padding to reach 4-char boundary
    val rem = std_b64.length() % 4
    if rem == 2:
        std_b64 = std_b64 + "=="
    else if rem == 3:
        std_b64 = std_b64 + "="

    base64_decode(std_b64)

# ============================================================================
# Internal: convert a raw byte array to text (UTF-8 interpretation)
# ============================================================================

fn _bytes_to_text(data: [u8]) -> text:
    """Interpret a raw byte slice as UTF-8 text.

    Non-UTF-8 bytes are replaced with '?'.
    Mirrors Rust's String::from_utf8_lossy behaviour.
    """
    var result = ""
    var i = 0
    val n = data.len()
    while i < n:
        val b = data[i] as i64
        if b < 0x80:
            result = result + b.chr()
            i = i + 1
        else if b < 0xC0:
            result = result + "?"
            i = i + 1
        else if b < 0xE0:
            if i + 1 < n:
                val b2 = data[i + 1] as i64
                val cp = ((b & 0x1F) << 6) | (b2 & 0x3F)
                result = result + cp.chr()
                i = i + 2
            else:
                result = result + "?"
                i = i + 1
        else if b < 0xF0:
            if i + 2 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val cp = ((b & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
                result = result + cp.chr()
                i = i + 3
            else:
                result = result + "?"
                i = i + 1
        else:
            if i + 3 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val b4 = data[i + 3] as i64
                val cp = ((b & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
                result = result + cp.chr()
                i = i + 4
            else:
                result = result + "?"
                i = i + 1
    result
