# Advanced text utilities (minimal slice).
#
# The full module was removed by commit 2cca0bc; this restores the
# self-contained, widely-imported helpers. escape_json is required by the
# UI IPC protocol (app.ui.ipc.protocol) for the Tauri/Electron backends.
# TODO(text): restore the remaining text_advanced helpers from 2cca0bc~1.

fn escape_json(s: text) -> text:
    """Escape special characters for JSON strings.

    Escapes: backslash, double quote, newline, carriage return, tab
    """
    var r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    r
