@allow(unnamed_duplicate_typed_args)
# Text — Advanced Operations
#
# Extracted from text.spl. Contains:
# - Advanced tokenization (split_whitespace, extract_words)
# - Line processing (trim_lines, number_lines, prefix_lines, suffix_lines)
# - Case conversion (to_title_case, to_snake_case, to_camel_case)
# - Word operations (word_count, word_wrap, reverse_words, longest_word)
# - Character analysis (char_frequency, most_common_char, most_common_words)
# - Indentation (detect_indent, normalize_indent, dedent_lines)
# - String similarity (levenshtein_distance, hamming_distance)
# - Advanced joining (join_with_separator, join_natural)
# - JSON escaping (escape_json)

# NOTE: Do NOT import from lib.common.text here — that creates a circular
# dependency (text imports text_advanced, text_advanced imports text) which
# hangs the module resolver. Import from string_core + format_utils instead.
use std.string_core.{char_code, is_whitespace_char}
use std.format_utils.{wrap_text}
use common.string_builder.{StringBuilder}

# Inlined character helpers (originally from text.spl) to break circular dep
fn _is_alpha(ch: text) -> bool:
    val code = char_code(ch)
    (code >= 65 and code <= 90) or (code >= 97 and code <= 122)

fn _is_alphanumeric(ch: text) -> bool:
    _is_alpha(ch) or (ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9")

fn _is_uppercase_char(ch: text) -> bool:
    if ch.len() != 1: return false
    val code = ch[0]
    code >= 'A' and code <= 'Z'

fn _is_lowercase_char(ch: text) -> bool:
    if ch.len() != 1: return false
    val code = ch[0]
    code >= 'a' and code <= 'z'

# ============================================================================
# Advanced Tokenization (from text_utils)
# ============================================================================

fn split_whitespace(text: text):
    """Split text by whitespace, removing empty tokens.

    Example:
        split_whitespace("hello   world  \n foo")  # ["hello", "world", "foo"]
    """
    val parts = text.split(" ")
    var result = []

    for part in parts:
        val trimmed = part.trim()
        if trimmed.len() > 0:
            result.push(trimmed)

    result

fn extract_words(text: text):
    """Extract words (alphanumeric sequences) from text.

    Example:
        extract_words("Hello, world! 123")  # ["Hello", "world", "123"]
    """
    var words = []
    var word_chars: [text] = []
    var i = 0

    while i < text.len():
        val ch = text[i]
        if _is_alphanumeric(ch):
            word_chars.push(ch)
        else:
            if word_chars.len() > 0:
                words.push(word_chars.join(""))
                word_chars = []
        i = i + 1

    if word_chars.len() > 0:
        words.push(word_chars.join(""))

    words

# ============================================================================
# Line Processing (from text_utils)
# ============================================================================

fn trim_lines(lines):
    """Trim whitespace from each line.

    Example:
        trim_lines(["  hello  ", "  world  "])  # ["hello", "world"]
    """
    var result = []
    for line in lines:
        result.push(line.trim())
    result

fn remove_empty_lines(lines):
    """Remove empty or whitespace-only lines.

    Example:
        remove_empty_lines(["hello", "", "world", "  "])
        # ["hello", "world"]
    """
    var result = []
    for line in lines:
        if line.trim().len() > 0:
            result.push(line)
    result

fn number_lines(lines, start: i64):
    """Add line numbers to lines.

    Example:
        number_lines(["hello", "world"], 1)
        # ["1: hello", "2: world"]
    """
    var result = []
    var i = 0

    while i < lines.len():
        val line_num = start + i
        result.push("{line_num}: {lines[i]}")
        i = i + 1

    result

fn prefix_lines(lines, prefix: text):
    """Add prefix to each line.

    Example:
        prefix_lines(["hello", "world"], "> ")
        # ["> hello", "> world"]
    """
    var result = []
    for line in lines:
        result.push(prefix + line)
    result

fn suffix_lines(lines, suffix: text):
    """Add suffix to each line.

    Example:
        suffix_lines(["hello", "world"], "!")
        # ["hello!", "world!"]
    """
    var result = []
    for line in lines:
        result.push(line + suffix)
    result

# ============================================================================
# Advanced Case Conversion (from text_utils)
# ============================================================================

fn to_title_case(text: text) -> text:
    """Convert text to title case (capitalize first letter of each word).

    Example:
        to_title_case("hello world")  # "Hello World"
    """
    val sb = StringBuilder(parts: [])
    var capitalize_next = true
    var i = 0

    while i < text.len():
        val ch = text[i]

        if is_whitespace_char(ch):
            sb.push(ch)
            capitalize_next = true
        elif capitalize_next and _is_alpha(ch):
            if _is_lowercase_char(ch):
                val upper_code = ch[0] - 32
                sb.push("{upper_code}")
            else:
                sb.push(ch)
            capitalize_next = false
        else:
            if _is_uppercase_char(ch):
                val lower_code = ch[0] + 32
                sb.push("{lower_code}")
            else:
                sb.push(ch)

        i = i + 1

    sb.to_text()

fn to_snake_case(text: text) -> text:
    """Convert text to snake_case.

    Example:
        to_snake_case("HelloWorld")  # "hello_world"
        to_snake_case("hello world")  # "hello_world"
    """
    val sb = StringBuilder(parts: [])
    var i = 0

    while i < text.len():
        val ch = text[i]

        if is_whitespace_char(ch):
            sb.push("_")
        elif _is_uppercase_char(ch):
            if i > 0 and not is_whitespace_char(text[i-1]):
                sb.push("_")
            val lower_code = ch[0] + 32
            sb.push("{lower_code}")
        else:
            sb.push(ch)

        i = i + 1

    sb.to_text()

fn to_camel_case(text: text) -> text:
    """Convert text to camelCase.

    Example:
        to_camel_case("hello world")  # "helloWorld"
        to_camel_case("hello_world")  # "helloWorld"
    """
    val sb = StringBuilder(parts: [])
    var capitalize_next = false
    var i = 0

    while i < text.len():
        val ch = text[i]

        if ch == " " or ch == "_":
            capitalize_next = true
        elif capitalize_next and _is_alpha(ch):
            if _is_lowercase_char(ch):
                val upper_code = ch[0] - 32
                sb.push("{upper_code}")
            else:
                sb.push(ch)
            capitalize_next = false
        else:
            sb.push(ch)

        i = i + 1

    sb.to_text()

# ============================================================================
# Word Operations (from text_utils)
# ============================================================================

fn word_count(text: text) -> i64:
    """Count words in text.

    Example:
        word_count("Hello world, how are you?")  # 5
    """
    val words = extract_words(text)
    words.len()

fn word_wrap(text: text, width: i64):
    """Wrap text to specified width.

    Delegates to wrap_text() from std.format_utils.

    Returns array of lines.

    Example:
        word_wrap("The quick brown fox", 10)
        # ["The quick", "brown fox"]
    """
    wrap_text(text, width)

fn reverse_words(text: text) -> text:
    """Reverse order of words in text.

    Example:
        reverse_words("hello world")  # "world hello"
    """
    val words = split_whitespace(text)
    var reversed = []
    var i = words.len() - 1

    while i >= 0:
        reversed.push(words[i])
        i = i - 1

    reversed.join(" ")

fn longest_word(text: text):
    """Find longest word in text.

    Returns (word, length) tuple or nil.

    Example:
        longest_word("The quick brown fox")  # ("quick", 5)
    """
    val words = extract_words(text)
    if words.len() == 0:
        return nil

    var longest = words[0]
    var max_len = longest.len()

    for word in words:
        if word.len() > max_len:
            longest = word
            max_len = word.len()

    (longest, max_len)

# ============================================================================
# Text Analysis (from text_utils)
# ============================================================================

fn char_frequency(text: text):
    """Calculate character frequency.

    Returns array of (char, count) tuples.

    Example:
        char_frequency("hello")
        # [('h',1), ('e',1), ('l',2), ('o',1)]
    """
    var freq_map: {text: i64} = {}
    var order: [text] = []
    var i = 0

    while i < text.len():
        val ch = text[i]
        if freq_map.contains_key(ch):
            freq_map[ch] = freq_map[ch] + 1
        else:
            freq_map[ch] = 1
            order.push(ch)
        i = i + 1

    # Build result in insertion order
    var counts = []
    for ch in order:
        counts.push((ch, freq_map[ch]))

    counts

fn most_common_char(text: text):
    """Find most common character.

    Returns (char, count) tuple or nil.

    Example:
        most_common_char("hello")  # ('l', 2)
    """
    val freqs = char_frequency(text)
    if freqs.len() == 0:
        return nil

    var max_char = nil
    var max_count = 0

    for (char, count) in freqs:
        if count > max_count:
            max_char = char
            max_count = count

    (max_char, max_count)

fn most_common_words(text: text, n: i64):
    """Find n most common words.

    Example:
        most_common_words("hello world hello", 1)
        # [("hello", 2)]
    """
    val words = extract_words(text)

    # Count word frequencies
    var counts = []
    for word in words:
        var found = false
        var i = 0
        while i < counts.len():
            val (w, count) = counts[i]
            if w == word:
                counts[i] = (w, count + 1)
                found = true
                break
            i = i + 1

        if not found:
            counts.push((word, 1))

    # Sort by frequency (simple selection sort)
    var sorted = counts
    var i = 0
    while i < sorted.len() - 1:
        var max_idx = i
        var j = i + 1
        while j < sorted.len():
            val (_, count1) = sorted[max_idx]
            val (_, count2) = sorted[j]
            if count2 > count1:
                max_idx = j
            j = j + 1

        if max_idx != i:
            val temp = sorted[i]
            sorted[i] = sorted[max_idx]
            sorted[max_idx] = temp

        i = i + 1

    # Take top n
    var result = []
    i = 0
    while i < n and i < sorted.len():
        result.push(sorted[i])
        i = i + 1

    result

# ============================================================================
# Indentation (from text_utils)
# ============================================================================

fn detect_indent(lines):
    """Detect indentation level of first indented line.

    Returns number of leading spaces.

    Example:
        detect_indent(["hello", "  world", "    foo"])  # 2
    """
    for line in lines:
        var spaces = 0
        var i = 0

        while i < line.len():
            if line[i] == ' ':
                spaces = spaces + 1
            else:
                break
            i = i + 1

        if spaces > 0:
            return spaces

    0

fn normalize_indent(lines, new_indent: i64):
    """Normalize indentation to specified number of spaces.

    Example:
        normalize_indent(["  hello", "    world"], 4)
        # ["    hello", "        world"]
    """
    val current_indent = detect_indent(lines)
    if current_indent == 0:
        return lines

    var result = []

    for line in lines:
        # Count leading spaces
        var spaces = 0
        var i = 0
        while i < line.len():
            if line[i] == ' ':
                spaces = spaces + 1
            else:
                break
            i = i + 1

        # Calculate new indentation
        val indent_level = spaces / current_indent
        val new_spaces = indent_level * new_indent

        # Build new line
        var indent_parts: [text] = []
        var j = 0
        while j < new_spaces:
            indent_parts.push(" ")
            j = j + 1

        # Add rest of line
        indent_parts.push(line[spaces..])
        val new_line = indent_parts.join("")
        result.push(new_line)

    result

fn dedent_lines(lines):
    """Remove common leading whitespace from all lines.

    Example:
        dedent_lines(["  hello", "    world"])
        # ["hello", "  world"]
    """
    val min_indent = detect_indent(lines)
    if min_indent == 0:
        return lines

    var result = []

    for line in lines:
        if line.len() >= min_indent:
            result.push(line[min_indent..])
        else:
            result.push(line)

    result

# ============================================================================
# String Similarity (from text_utils)
# ============================================================================

fn levenshtein_distance(s1: text, s2: text) -> i64:
    """Calculate Levenshtein (edit) distance between two strings.

    Number of single-character edits needed to transform s1 into s2.

    Example:
        levenshtein_distance("kitten", "sitting")  # 3
    """
    val len1 = s1.len()
    val len2 = s2.len()

    # Create distance matrix
    var dp = []
    var i = 0
    while i <= len1:
        var row = []
        var j = 0
        while j <= len2:
            row.push(0)
            j = j + 1
        dp.push(row)
        i = i + 1

    # Initialize first row and column
    i = 0
    while i <= len1:
        var row_i = dp[i]
        row_i[0] = i
        i = i + 1

    var j = 0
    while j <= len2:
        var row_0 = dp[0]
        row_0[j] = j
        j = j + 1

    # Fill matrix
    i = 1
    while i <= len1:
        j = 1
        while j <= len2:
            val cost = if s1[i-1] == s2[j-1]: 0 else: 1

            val prev_row = dp[i-1]
            var cur_row = dp[i]
            val delete = prev_row[j] + 1
            val insert = cur_row[j-1] + 1
            val substitute = prev_row[j-1] + cost

            var min_val = delete
            if insert < min_val:
                min_val = insert
            if substitute < min_val:
                min_val = substitute

            cur_row[j] = min_val
            j = j + 1
        i = i + 1

    var result_row = dp[len1]
    result_row[len2]

fn hamming_distance(s1: text, s2: text):
    """Calculate Hamming distance (must be same length).

    Number of positions where characters differ.

    Example:
        hamming_distance("karolin", "kathrin")  # 3
    """
    if s1.len() != s2.len():
        return nil

    var distance = 0
    var i = 0

    while i < s1.len():
        if s1[i] != s2[i]:
            distance = distance + 1
        i = i + 1

    distance

# ============================================================================
# Advanced Text Joining (from text_utils)
# ============================================================================

fn join_with_separator(items, separator: text, final_separator: text) -> text:
    """Join items with different final separator.

    Example:
        join_with_separator(["a", "b", "c"], ", ", " and ")
        # "a, b and c"
    """
    if items.len() == 0:
        return ""
    if items.len() == 1:
        return items[0]

    var parts: [text] = []
    var i = 0
    while i < items.len() - 1:
        parts.push(items[i])
        i = i + 1

    parts.join(separator) + final_separator + items[items.len() - 1]

fn join_natural(items) -> text:
    """Join items naturally with commas and 'and'.

    Example:
        join_natural(["Alice", "Bob", "Charlie"])
        # "Alice, Bob, and Charlie"
    """
    join_with_separator(items, ", ", ", and ")

# ============================================================================
# JSON Escaping
# ============================================================================

fn escape_json(s: text) -> text:
    """Escape special characters for JSON strings.

    Escapes: backslash, double quote, newline, carriage return, tab

    Example:
        escape_json("Hello\\n\\\"World\\\"") -> "Hello\\\\n\\\\\\\"World\\\\\\\""
    """
    var r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    r

# ============================================================================
# Word Splitting (shared helper for case conversions)
# ============================================================================

fn _split_words(s: text) -> [text]:
    """Split text into words at separators and camelCase boundaries.

    Handles underscores, hyphens, spaces, camelCase, PascalCase, SCREAMING_SNAKE,
    and acronym boundaries (e.g. XMLParser -> [XML, Parser]).
    """
    if s.len() == 0:
        return []

    var words: [text] = []
    var current: [text] = []
    var i = 0

    while i < s.len():
        val ch = s[i]

        if ch == "_" or ch == "-" or is_whitespace_char(ch):
            if current.len() > 0:
                words.push(current.join(""))
                current = []
        elif _is_uppercase_char(ch) and current.len() > 0:
            val prev = current[current.len() - 1]
            if _is_lowercase_char(prev):
                # camelCase boundary: lowercase -> Uppercase
                words.push(current.join(""))
                current = []
            elif (_is_uppercase_char(prev) and i + 1 < s.len() and _is_lowercase_char(s[i + 1])):
                # Acronym boundary: XMLParser -> XML | Parser
                words.push(current.join(""))
                current = []
            current.push(ch)
        else:
            current.push(ch)

        i = i + 1

    if current.len() > 0:
        words.push(current.join(""))

    words

# ============================================================================
# Additional Case Conversions (#TEXT-P1-001, #TEXT-P1-002, #TEXT-P1-003)
# ============================================================================

fn to_kebab_case(s: text) -> text:
    """Convert text to kebab-case.

    sdoctest:
        expect(to_kebab_case("HelloWorld")).to_equal("hello-world")
        expect(to_kebab_case("hello_world")).to_equal("hello-world")
        expect(to_kebab_case("helloWorld")).to_equal("hello-world")
        expect(to_kebab_case("HELLO_WORLD")).to_equal("hello-world")
        expect(to_kebab_case("already-kebab")).to_equal("already-kebab")
        expect(to_kebab_case("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(word.to_lower())
    parts.join("-")

fn to_pascal_case(s: text) -> text:
    """Convert text to PascalCase.

    sdoctest:
        expect(to_pascal_case("hello_world")).to_equal("HelloWorld")
        expect(to_pascal_case("hello-world")).to_equal("HelloWorld")
        expect(to_pascal_case("helloWorld")).to_equal("HelloWorld")
        expect(to_pascal_case("HELLO_WORLD")).to_equal("HelloWorld")
        expect(to_pascal_case("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(word.capitalize())
    parts.join("")

fn to_screaming_snake(s: text) -> text:
    """Convert text to SCREAMING_SNAKE_CASE.

    sdoctest:
        expect(to_screaming_snake("helloWorld")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("hello-world")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("HelloWorld")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("hello_world")).to_equal("HELLO_WORLD")
        expect(to_screaming_snake("")).to_equal("")
    """
    val words = _split_words(s)
    if words.len() == 0:
        return ""
    var parts: [text] = []
    for word in words:
        parts.push(word.to_upper())
    parts.join("_")

# ============================================================================
# Character Transformation (#TEXT-P1-004, #TEXT-P1-005)
# ============================================================================

fn chars_map(s: text, f: fn(text) -> text) -> text:
    """Apply function to each character and concatenate results.

    The callback receives each character as a single-character text and
    returns text (may be empty for deletion or multi-char for expansion).

    sdoctest:
        expect(chars_map("hello", \c: c.to_upper())).to_equal("HELLO")
        expect(chars_map("", \c: c)).to_equal("")
    """
    if s.len() == 0:
        return ""
    val sb = StringBuilder(parts: [])
    var i = 0
    while i < s.len():
        sb.push(f(s[i]))
        i = i + 1
    sb.to_text()

fn tr(s: text, from: text, to: text) -> text:
    """Character-level transliteration.

    Each character in `from` is replaced by the corresponding character in `to`.
    If `to` is shorter than `from`, the last character of `to` is used for
    remaining `from` characters. If `to` is empty, matched characters are deleted.

    sdoctest:
        expect(tr("hello", "elo", "ELO")).to_equal("hELLO")
        expect(tr("aabbcc", "abc", "xyz")).to_equal("xxyyzz")
        expect(tr("hello", "", "")).to_equal("hello")
        expect(tr("", "a", "b")).to_equal("")
    """
    if s.len() == 0 or from.len() == 0:
        return s

    val sb = StringBuilder(parts: [])
    var i = 0
    while i < s.len():
        val ch = s[i]
        var match_idx = -1
        var j = 0
        while j < from.len():
            if ch == from[j]:
                match_idx = j
                break
            j = j + 1

        if match_idx >= 0:
            if to.len() > 0:
                if match_idx < to.len():
                    sb.push(to[match_idx])
                else:
                    sb.push(to[to.len() - 1])
        else:
            sb.push(ch)

        i = i + 1
    sb.to_text()

# ============================================================================
# Advanced Tokenization (#TEXT-P1-006, #TEXT-P1-008)
# ============================================================================

fn split_n(s: text, sep: text, n: i64) -> [text]:
    """Split text into at most n parts.

    After n-1 splits, the remainder (including further separators) becomes
    the final part.

    sdoctest:
        expect(split_n("a,b,c,d", ",", 2)[0]).to_equal("a")
        expect(split_n("a,b,c,d", ",", 2)[1]).to_equal("b,c,d")
        expect(split_n("hello", ",", 2).len()).to_equal(1)
    """
    if n <= 1 or sep.len() == 0:
        return [s]

    val all_parts = s.split(sep)
    if all_parts.len() <= n:
        return all_parts

    var result: [text] = []
    var i = 0
    while i < n - 1:
        result.push(all_parts[i])
        i = i + 1

    var remaining: [text] = []
    while i < all_parts.len():
        remaining.push(all_parts[i])
        i = i + 1

    result.push(remaining.join(sep))
    result

fn cut(s: text, sep: text) -> (text, text, bool):
    """Cut text at first occurrence of separator.

    Returns (before, after, found) tuple. Unlike partition, the separator
    is not included in the result and a boolean indicates if it was found.

    sdoctest:
        val (b1, a1, f1) = cut("hello=world", "=")
        expect(b1).to_equal("hello")
        expect(a1).to_equal("world")
        expect(f1).to_equal(true)
    """
    if sep.len() == 0 or not s.contains(sep):
        return (s, "", false)

    val parts = s.split(sep)
    val before = parts[0]
    var after_parts: [text] = []
    var i = 1
    while i < parts.len():
        after_parts.push(parts[i])
        i = i + 1
    val after = after_parts.join(sep)
    (before, after, true)

# ============================================================================
# Character Search (#TEXT-P1-007)
# ============================================================================

fn contains_any(s: text, chars: text) -> bool:
    """Check if text contains any character from the given set.

    Each character in `chars` is checked independently (not substring search).

    sdoctest:
        expect(contains_any("hello", "aeiou")).to_equal(true)
        expect(contains_any("xyz", "aeiou")).to_equal(false)
        expect(contains_any("", "abc")).to_equal(false)
        expect(contains_any("hello", "")).to_equal(false)
    """
    if s.len() == 0 or chars.len() == 0:
        return false

    var i = 0
    while i < s.len():
        var j = 0
        while j < chars.len():
            if s[i] == chars[j]:
                return true
            j = j + 1
        i = i + 1

    false

# ============================================================================
# Advanced String Replacement (#TEXT-P1-009)
# ============================================================================

fn gsub(s: text, pattern: text, f: fn(text) -> text) -> text:
    """Replace all occurrences of pattern using callback function.

    For each non-overlapping match of `pattern`, calls `f(match)` to produce
    the replacement string.

    sdoctest:
        expect(gsub("hello world", "o", \m: m.to_upper())).to_equal("hellO wOrld")
        expect(gsub("abc", "b", \m: "BB")).to_equal("aBBc")
        expect(gsub("hello", "x", \m: "Y")).to_equal("hello")
        expect(gsub("", "a", \m: "b")).to_equal("")
    """
    if s.len() == 0 or pattern.len() == 0:
        return s

    val parts = s.split(pattern)
    if parts.len() <= 1:
        return s

    val replacement = f(pattern)
    parts.join(replacement)

