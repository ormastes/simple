@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Text — Advanced Operations (hub)
#
# This file re-exports all public symbols from the split sub-modules and
# provides the joining, encoding, transformation, replacement, radix, and
# advanced split operations that do not depend on the shared helpers.
#
# Sub-modules (all in src/lib/common/):
# - text_advanced_chars.spl   — char helpers + _split_words
# - text_advanced_lines.spl   — tokenization, line processing, indentation, iteration
# - text_advanced_case.spl    — case conversions + string predicates
# - text_advanced_search.spl  — word ops, char analysis, similarity, search
#
# NOTE: Do NOT import from lib.common.text here — that creates a circular
# dependency (text imports text_advanced, text_advanced imports text) which
# hangs the module resolver. Import from string_core + format_utils instead.
use std.string_core.{char_code, is_whitespace_char, str_capitalize}
use std.format_utils.{wrap_text}
use common.string_builder.{StringBuilder}

# Pull in all sub-module symbols so callers using `use common.text_advanced.{...}`
# continue to resolve correctly regardless of which sub-module the symbol lives in.
use common.text_advanced_lines.{split_whitespace, extract_words, trim_lines, remove_empty_lines, number_lines, prefix_lines, suffix_lines, detect_indent, normalize_indent, dedent_lines, each_char, each_line}
use common.text_advanced_case.{to_title_case, to_snake_case, to_camel_case, to_kebab_case, to_pascal_case, to_screaming_snake, is_ascii, is_upper, is_lower, is_printable, is_title}
use common.text_advanced_search.{word_count, word_wrap, reverse_words, longest_word, char_frequency, most_common_char, most_common_words, levenshtein_distance, hamming_distance, contains_any, index_of_any, index_of_func, last_index_of_func, fields_func}

# ============================================================================
# Advanced Text Joining
# ============================================================================

fn join_with_separator(items, separator: text, final_separator: text) -> text:
    """Join items with different final separator.

    Example:
        join_with_separator(["a", "b", "c"], ", ", " and ")
        # "a, b and c"
    """
    if items.len() == 0:
        return ""
    if items.len() == 1:
        return items[0]

    var parts: [text] = []
    var i = 0
    while i < items.len() - 1:
        parts.push(items[i])
        i = i + 1

    parts.join(separator) + final_separator + items[items.len() - 1]

fn join_natural(items) -> text:
    """Join items naturally with commas and 'and'.

    Example:
        join_natural(["Alice", "Bob", "Charlie"])
        # "Alice, Bob, and Charlie"
    """
    join_with_separator(items, ", ", ", and ")

# ============================================================================
# JSON Escaping
# ============================================================================

fn escape_json(s: text) -> text:
    """Escape special characters for JSON strings.

    Escapes: backslash, double quote, newline, carriage return, tab

    Example:
        escape_json("Hello\\n\\\"World\\\"") -> "Hello\\\\n\\\\\\\"World\\\\\\\""
    """
    var r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    r

# ============================================================================
# Character Transformation
# ============================================================================

fn chars_map(s: text, f: fn(text) -> text) -> text:
    """Apply function to each character and concatenate results.

    The callback receives each character as a single-character text and
    returns text (may be empty for deletion or multi-char for expansion).

    sdoctest:
        expect(chars_map("hello", \c: c.upper())).to_equal("HELLO")
        expect(chars_map("", \c: c)).to_equal("")
    """
    if s.len() == 0:
        return ""
    val sb = StringBuilder(parts: [])
    var i = 0
    while i < s.len():
        sb.push(f(s[i]))
        i = i + 1
    sb.to_text()

fn tr(s: text, from: text, to: text) -> text:
    """Character-level transliteration.

    Each character in `from` is replaced by the corresponding character in `to`.
    If `to` is shorter than `from`, the last character of `to` is used for
    remaining `from` characters. If `to` is empty, matched characters are deleted.

    sdoctest:
        expect(tr("hello", "elo", "ELO")).to_equal("hELLO")
        expect(tr("aabbcc", "abc", "xyz")).to_equal("xxyyzz")
        expect(tr("hello", "", "")).to_equal("hello")
        expect(tr("", "a", "b")).to_equal("")
    """
    if s.len() == 0 or from.len() == 0:
        return s

    val sb = StringBuilder(parts: [])
    var i = 0
    while i < s.len():
        val ch = s[i]
        var match_idx = -1
        var j = 0
        while j < from.len():
            if ch == from[j]:
                match_idx = j
                break
            j = j + 1

        if match_idx >= 0:
            if to.len() > 0:
                if match_idx < to.len():
                    sb.push(to[match_idx])
                else:
                    sb.push(to[to.len() - 1])
        else:
            sb.push(ch)

        i = i + 1
    sb.to_text()

fn delete_chars(s: text, chars: text) -> text:
    """Delete all characters in the given set from the string.

    sdoctest:
        expect(delete_chars("hello world", "lo")).to_equal("he wrd")
        expect(delete_chars("abc", "")).to_equal("abc")
        expect(delete_chars("", "abc")).to_equal("")
    """
    if s.len() == 0 or chars.len() == 0:
        return s

    val sb = StringBuilder(parts: [])
    var i = 0
    while i < s.len():
        val ch = s[i]
        var found = false
        var j = 0
        while j < chars.len():
            if ch == chars[j]:
                found = true
                break
            j = j + 1
        if not found:
            sb.push(ch)
        i = i + 1
    sb.to_text()

# ============================================================================
# Advanced String Replacement
# ============================================================================

fn gsub(s: text, pattern: text, f: fn(text) -> text) -> text:
    """Replace all occurrences of pattern using callback function.

    For each non-overlapping match of `pattern`, calls `f(match)` to produce
    the replacement string.

    sdoctest:
        expect(gsub("hello world", "o", \m: m.upper())).to_equal("hellO wOrld")
        expect(gsub("abc", "b", \m: "BB")).to_equal("aBBc")
        expect(gsub("hello", "x", \m: "Y")).to_equal("hello")
        expect(gsub("", "a", \m: "b")).to_equal("")
    """
    if s.len() == 0 or pattern.len() == 0:
        return s

    val parts = s.split(pattern)
    if parts.len() <= 1:
        return s

    val replacement = f(pattern)
    parts.join(replacement)

fn replace_n(s: text, old: text, new_str: text, n: i64) -> text:
    """Replace first n occurrences of old with new_str.

    sdoctest:
        expect(replace_n("aaa", "a", "b", 2)).to_equal("bba")
        expect(replace_n("hello", "l", "r", 1)).to_equal("herlo")
        expect(replace_n("hello", "x", "y", 5)).to_equal("hello")
    """
    if n <= 0 or old.len() == 0 or s.len() == 0:
        return s

    val parts = s.split(old)
    if parts.len() <= 1:
        return s

    val sb = StringBuilder(parts: [])
    var replacements = 0
    var i = 0
    while i < parts.len():
        if i > 0:
            if replacements < n:
                sb.push(new_str)
                replacements = replacements + 1
            else:
                sb.push(old)
        sb.push(parts[i])
        i = i + 1

    sb.to_text()

fn multi_replace(s: text, pairs) -> text:
    """Replace multiple pairs at once.

    Pairs is an array of (old, new) tuples. Applied sequentially.

    sdoctest:
        val result = multi_replace("hello world", [("hello", "hi"), ("world", "earth")])
        expect(result).to_equal("hi earth")
    """
    var result = s
    for (old, new_str) in pairs:
        result = result.replace(old, new_str)
    result

# ============================================================================
# String Insertion
# ============================================================================

fn text_insert(s: text, idx: i64, insertion: text) -> text:
    """Insert string at specified index.

    sdoctest:
        expect(text_insert("hello", 2, "XY")).to_equal("heXYllo")
        expect(text_insert("hello", 0, "AB")).to_equal("ABhello")
        expect(text_insert("hello", 5, "!")).to_equal("hello!")
    """
    var actual_idx = idx
    if actual_idx < 0:
        actual_idx = 0
    if actual_idx > s.len():
        actual_idx = s.len()

    s[0:actual_idx] + insertion + s[actual_idx:]

# ============================================================================
# Radix Parsing
# ============================================================================

fn hex_to_int(s: text) -> i64?:
    """Parse hexadecimal string to integer.

    Supports optional "0x" or "0X" prefix.

    sdoctest:
        expect(hex_to_int("ff")).to_equal(255)
        expect(hex_to_int("0xFF")).to_equal(255)
        expect(hex_to_int("10")).to_equal(16)
        expect(hex_to_int("xyz")).to_be_nil()
    """
    to_int_radix(s, 16)

fn oct_to_int(s: text) -> i64?:
    """Parse octal string to integer.

    Supports optional "0o" or "0O" prefix.

    sdoctest:
        expect(oct_to_int("77")).to_equal(63)
        expect(oct_to_int("0o77")).to_equal(63)
        expect(oct_to_int("10")).to_equal(8)
    """
    to_int_radix(s, 8)

fn to_int_radix(s: text, base: i64) -> i64?:
    """Parse string as integer in given base (2-36).

    sdoctest:
        expect(to_int_radix("1010", 2)).to_equal(10)
        expect(to_int_radix("ff", 16)).to_equal(255)
        expect(to_int_radix("77", 8)).to_equal(63)
        expect(to_int_radix("z", 36)).to_equal(35)
    """
    if base < 2 or base > 36 or s.len() == 0:
        return nil

    var start = 0
    var str = s.lower()

    # Skip common prefixes
    if str.len() >= 2:
        val prefix = str[0:2]
        if (base == 16 and prefix == "0x"):
            start = 2
        elif (base == 8 and prefix == "0o"):
            start = 2
        elif (base == 2 and prefix == "0b"):
            start = 2

    if start >= str.len():
        return nil

    var result: i64 = 0
    var i = start
    while i < str.len():
        val ch = str[i]
        var digit: i64 = -1

        val code = char_code(ch)
        if code >= 48 and code <= 57:
            digit = code - 48
        elif code >= 97 and code <= 122:
            digit = code - 97 + 10

        if digit < 0 or digit >= base:
            return nil

        result = result * base + digit
        i = i + 1

    result

# ============================================================================
# Quote / Unquote
# ============================================================================

fn text_quote(s: text) -> text:
    """Escape string for safe representation (add quotes and escapes).

    sdoctest:
        expect(text_quote("hello")).to_equal("\"hello\"")
    """
    val sb = StringBuilder(parts: [])
    sb.push("\"")
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\"":
            sb.push("\\\"")
        elif ch == "\\":
            sb.push("\\\\")
        elif ch == "\n":
            sb.push("\\n")
        elif ch == "\r":
            sb.push("\\r")
        elif ch == "\t":
            sb.push("\\t")
        else:
            sb.push(ch)
        i = i + 1
    sb.push("\"")
    sb.to_text()

# ============================================================================
# Advanced Tokenization
# ============================================================================

fn split_n(s: text, sep: text, n: i64) -> [text]:
    """Split text into at most n parts.

    After n-1 splits, the remainder (including further separators) becomes
    the final part.

    sdoctest:
        expect(split_n("a,b,c,d", ",", 2)[0]).to_equal("a")
        expect(split_n("a,b,c,d", ",", 2)[1]).to_equal("b,c,d")
        expect(split_n("hello", ",", 2).len()).to_equal(1)
    """
    if n <= 1 or sep.len() == 0:
        return [s]

    val all_parts = s.split(sep)
    if all_parts.len() <= n:
        return all_parts

    var result: [text] = []
    var i = 0
    while i < n - 1:
        result.push(all_parts[i])
        i = i + 1

    var remaining: [text] = []
    while i < all_parts.len():
        remaining.push(all_parts[i])
        i = i + 1

    result.push(remaining.join(sep))
    result

fn cut(s: text, sep: text) -> (text, text, bool):
    """Cut text at first occurrence of separator.

    Returns (before, after, found) tuple. Unlike partition, the separator
    is not included in the result and a boolean indicates if it was found.

    sdoctest:
        val (b1, a1, f1) = cut("hello=world", "=")
        expect(b1).to_equal("hello")
        expect(a1).to_equal("world")
        expect(f1).to_equal(true)
    """
    if sep.len() == 0 or not s.contains(sep):
        return (s, "", false)

    val parts = s.split(sep)
    val before = parts[0]
    var after_parts: [text] = []
    var i = 1
    while i < parts.len():
        after_parts.push(parts[i])
        i = i + 1
    val after = after_parts.join(sep)
    (before, after, true)

fn split_after(s: text, sep: text) -> [text]:
    """Split but keep separator at end of each part.

    sdoctest:
        val result = split_after("a,b,c", ",")
        expect(result.len()).to_equal(3)
        expect(result[0]).to_equal("a,")
        expect(result[1]).to_equal("b,")
        expect(result[2]).to_equal("c")
    """
    if sep.len() == 0:
        return [s]

    val parts = s.split(sep)
    if parts.len() <= 1:
        return [s]

    var result: [text] = []
    var i = 0
    while i < parts.len() - 1:
        result.push(parts[i] + sep)
        i = i + 1
    result.push(parts[parts.len() - 1])
    result

# ============================================================================
# Expand Tabs
# ============================================================================

fn expandtabs(s: text, tabsize: i64) -> text:
    """Replace tab characters with spaces.

    sdoctest:
        expect(expandtabs("a\tb", 4)).to_equal("a   b")
        expect(expandtabs("hello", 4)).to_equal("hello")
    """
    if tabsize <= 0:
        return s.replace("\t", "")

    var spaces: [text] = []
    var i = 0
    while i < tabsize:
        spaces.push(" ")
        i = i + 1
    val tab_replacement = spaces.join("")
    s.replace("\t", tab_replacement)
