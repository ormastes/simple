"""Wine-level virtual memory and container readiness gate."""

pub fn wine_vm_required_features() -> [text]:
    [
        "reserve",
        "commit",
        "unmap",
        "fixed-map",
        "mprotect",
        "exec-perm",
        "guard-page",
        "page-fault",
        "stack-growth",
        "user-pointer",
        "pid-namespace",
        "fs-namespace",
        "ipc-namespace",
        "net-namespace",
        "cap-namespace"
    ]

pub fn wine_vm_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in wine_vm_required_features():
        if not features.contains(feature):
            missing.push(feature)
    return missing

pub fn wine_vm_gate(features: text) -> text:
    val missing = wine_vm_missing_features(features)
    if missing.len() == 0:
        return "ready"
    return "missing-" + missing[0]

pub fn wine_vm_fault_gate(evidence: text) -> text:
    if not evidence.contains("process"):
        return "missing-process"
    if not evidence.contains("thread"):
        return "missing-thread"
    if not evidence.contains("address"):
        return "missing-address"
    if not evidence.contains("access"):
        return "missing-access"
    if not evidence.contains("policy"):
        return "missing-policy"
    return "ready"

pub fn wine_container_gate(evidence: text) -> text:
    if not evidence.contains("pid"):
        return "missing-pid"
    if not evidence.contains("fs"):
        return "missing-fs"
    if not evidence.contains("ipc"):
        return "missing-ipc"
    if not evidence.contains("net"):
        return "missing-net"
    if not evidence.contains("capability"):
        return "missing-capability"
    return "ready"

