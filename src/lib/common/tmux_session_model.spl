# Tmux Session Model
#
# Minimal terminal multiplexer planning for SimpleOS shell surfaces.

struct TmuxPane:
    id: text
    command: text
    active: bool

struct TmuxWindow:
    name: text
    panes: [TmuxPane]
    active_pane: u64

struct TmuxSession:
    name: text
    windows: [TmuxWindow]
    active_window: u64

# Build a single pane record.
fn tmux_pane(id: text, command: text, active: bool) -> TmuxPane:
    TmuxPane(id: id, command: command, active: active)

# Build a window containing one initial pane running command.
fn tmux_window(name: text, command: text) -> TmuxWindow:
    TmuxWindow(name: name, panes: [tmux_pane("0", command, true)], active_pane: 0)

# Build a session containing one initial window running command.
fn tmux_session(name: text, command: text) -> TmuxSession:
    TmuxSession(name: name, windows: [tmux_window("0", command)], active_window: 0)

# Append a new window to session and make it the active window.
fn tmux_add_window(session: TmuxSession, name: text, command: text) -> TmuxSession:
    var windows = session.windows
    windows = windows.push(tmux_window(name, command))
    TmuxSession(name: session.name, windows: windows, active_window: windows.len() - 1)

# Split the active window's active pane, adding a new inactive pane running command.
fn tmux_split_active_pane(session: TmuxSession, command: text) -> TmuxSession:
    var windows = session.windows
    var window = windows[session.active_window]
    var panes = window.panes
    val pane_id = "{panes.len()}"
    panes = panes.push(tmux_pane(pane_id, command, false))
    window = TmuxWindow(name: window.name, panes: panes, active_pane: window.active_pane)
    windows[session.active_window] = window
    TmuxSession(name: session.name, windows: windows, active_window: session.active_window)

# Advance the session's active window index, wrapping back to 0 at the end.
fn tmux_select_next_window(session: TmuxSession) -> TmuxSession:
    if session.windows.len() == 0:
        return session
    val next = if session.active_window + 1 >= session.windows.len(): 0 else: session.active_window + 1
    TmuxSession(name: session.name, windows: session.windows, active_window: next)

# Return the command running in the session's currently active pane, or "" if none.
fn tmux_active_command(session: TmuxSession) -> text:
    if session.windows.len() == 0:
        return ""
    val window = session.windows[session.active_window]
    if window.panes.len() == 0:
        return ""
    window.panes[window.active_pane].command
