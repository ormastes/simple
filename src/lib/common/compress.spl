use compress.types.{CompressionCodec, CompressionError, CompressionOptions, CompressionLevel, CompressionEncoderState, CompressionDecoderState}
use compress.utilities.{default_compression_options, new_encoder_state, new_decoder_state, encoder_write, decoder_write, detect_codec}
use compress.lz4.{lz4_compress_block, lz4_decompress_block, lz4_compress_frame, lz4_decompress_frame}
use compress.zstd.{zstd_compress_frame, zstd_decompress_frame}
use compress.lzma2_xz_format.{lzma2_compress_xz, lzma2_decompress_xz}

fn _validate_common_options(input: [u8], options: CompressionOptions) -> Result<bool, CompressionError>:
    if options.dictionary_id != nil and options.dictionary_bytes == nil:
        return Err(CompressionError.UnsupportedFeature("dictionary_id requires dictionary_bytes"))
    if options.dictionary_id != nil and (options.dictionary_id ?? 0) < 0:
        return Err(CompressionError.UnsupportedFeature("dictionary_id must be >= 0"))
    if options.dictionary_bytes != nil:
        return Err(CompressionError.UnsupportedFeature("dictionaries are not supported by the shared compression facade"))
    if options.content_size != nil:
        val declared = options.content_size ?? 0
        if declared < 0:
            return Err(CompressionError.UnsupportedFeature("content_size must be >= 0"))
        if declared != input.len():
            return Err(CompressionError.UnsupportedFeature("content_size must match input length"))
    Ok(true)

fn _validate_lz4_options(options: CompressionOptions) -> Result<bool, CompressionError>:
    if options.block_mode != "frame" and options.block_mode != "block":
        return Err(CompressionError.UnsupportedFeature("lz4 block_mode must be frame or block"))
    if options.block_mode == "block":
        if options.checksum:
            return Err(CompressionError.UnsupportedFeature("lz4 block mode does not support checksum"))
        if options.content_size != nil:
            return Err(CompressionError.UnsupportedFeature("lz4 block mode does not support content_size"))
    if options.level.value != 1:
        return Err(CompressionError.UnsupportedFeature("lz4 facade supports levels other than 1 only through codec-specific APIs"))
    Ok(true)

fn _validate_zstd_options(options: CompressionOptions) -> Result<bool, CompressionError>:
    if options.block_mode != "frame":
        return Err(CompressionError.UnsupportedFeature("zstd block_mode must be frame"))
    Ok(true)

fn _validate_lzma2_options(options: CompressionOptions) -> Result<bool, CompressionError>:
    if options.block_mode != "frame":
        return Err(CompressionError.UnsupportedFeature("lzma2 block_mode must be frame"))
    if not options.checksum:
        return Err(CompressionError.UnsupportedFeature("lzma2 facade requires checksum=true"))
    Ok(true)

fn try_compress_bytes(input: [u8], options: CompressionOptions) -> Result<[u8], CompressionError>:
    val common = _validate_common_options(input, options)
    if common.is_err():
        return Err(common.unwrap_err())
    match options.codec:
        CompressionCodec.lz4:
            val valid = _validate_lz4_options(options)
            if valid.is_err():
                return Err(valid.unwrap_err())
            if options.block_mode == "block":
                return Ok(lz4_compress_block(input))
            Ok(lz4_compress_frame(input, options))
        CompressionCodec.zstd:
            val valid = _validate_zstd_options(options)
            if valid.is_err():
                return Err(valid.unwrap_err())
            Ok(zstd_compress_frame(input, options))
        CompressionCodec.lzma2:
            val valid = _validate_lzma2_options(options)
            if valid.is_err():
                return Err(valid.unwrap_err())
            Ok(lzma2_compress_xz(input, options))

fn compress_bytes(input: [u8], options: CompressionOptions) -> [u8]:
    match try_compress_bytes(input, options):
        Ok(bytes): bytes
        Err(_): []

fn _is_lz4_frame(input: [u8]) -> bool:
    input.len() >= 4 and input[0] == 0x04u8 and input[1] == 0x22u8 and input[2] == 0x4Du8 and input[3] == 0x18u8

fn decompress_bytes(input: [u8], codec_hint: CompressionCodec?) -> Result<[u8], CompressionError>:
    val codec_res = detect_codec(input, codec_hint)
    if codec_res.is_err():
        return Err(codec_res.unwrap_err())
    match codec_res.unwrap():
        CompressionCodec.lz4:
            if _is_lz4_frame(input):
                lz4_decompress_frame(input)
            else:
                lz4_decompress_block(input)
        CompressionCodec.zstd: zstd_decompress_frame(input)
        CompressionCodec.lzma2: lzma2_decompress_xz(input)

fn encoder_finish_checked(state: CompressionEncoderState) -> Result<[u8], CompressionError>:
    try_compress_bytes(state.pending, state.options)

fn encoder_finish(state: CompressionEncoderState) -> [u8]:
    compress_bytes(state.pending, state.options)

fn decoder_finish(state: CompressionDecoderState) -> Result<[u8], CompressionError>:
    decompress_bytes(state.pending, state.codec_hint)
