"""Bounded KERNEL32 process-heap bridge for Wine startup probes."""

use common.wine_nt_heap.{WineNtHeap, WineNtHeapResult, wine_nt_get_process_heap, wine_nt_heap_alloc, wine_nt_heap_free}

class WineKernel32HeapResult:
    ok: bool
    error: text
    heap: WineNtHeap
    ptr: i64
    size: i64
    operations: text

fn _result(ok: bool, error: text, heap: WineNtHeap, ptr: i64, size: i64, operations: text) -> WineKernel32HeapResult:
    WineKernel32HeapResult(ok: ok, error: error, heap: heap, ptr: ptr, size: size, operations: operations)

fn _kernel32_heap_sequence_gate(symbols: [text]) -> text:
    if symbols.len() == 0:
        return "bridge-missing:kernel32-heap"
    for symbol in symbols:
        if symbol != "GetProcessHeap" and symbol != "HeapAlloc" and symbol != "HeapFree":
            return "bridge-wrong-category:" + symbol
    if symbols.len() != 3:
        return "kernel32-heap-sequence-count-mismatch"
    if symbols[0] != "GetProcessHeap":
        return "kernel32-heap-sequence-expected:GetProcessHeap"
    if symbols[1] != "HeapAlloc":
        return "kernel32-heap-sequence-expected:HeapAlloc"
    if symbols[2] != "HeapFree":
        return "kernel32-heap-sequence-expected:HeapFree"
    "ready"

fn _failure(symbol: text, step: WineNtHeapResult, operations: text) -> WineKernel32HeapResult:
    _result(false, symbol + ":" + step.state, step.heap, step.ptr, step.size, operations)

pub fn wine_kernel32_execute_heap(symbols: [text], heap: WineNtHeap, size: i64) -> WineKernel32HeapResult:
    val sequence_state = _kernel32_heap_sequence_gate(symbols)
    if sequence_state != "ready":
        return _result(false, sequence_state, heap, 0, 0, "")

    val process_heap = wine_nt_get_process_heap(heap)
    if not process_heap.ok:
        return _failure("GetProcessHeap", process_heap, "")

    val allocated = wine_nt_heap_alloc(process_heap.heap, process_heap.ptr, size)
    if not allocated.ok:
        return _failure("HeapAlloc", allocated, "GetProcessHeap")

    val freed = wine_nt_heap_free(allocated.heap, process_heap.ptr, allocated.ptr)
    if not freed.ok:
        return _failure("HeapFree", freed, "GetProcessHeap HeapAlloc")

    _result(true, "", freed.heap, allocated.ptr, allocated.size, "GetProcessHeap HeapAlloc HeapFree")
