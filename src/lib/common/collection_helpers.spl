@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Collection Helpers — hub file
#
# P1 array helpers split across:
#   collection_helpers_sort      — sort_by_key, min_by_key, max_by_key, top_n, bottom_n
#   collection_helpers_transform — flat_map, compact_map, reject, none, one, compress,
#                                  reduce_right, fill, tally, sum_by, product
#   collection_helpers_index     — insert_at, remove_at, arr_pop, arr_shift, find_last,
#                                  find_last_index, at, arr_clone, values_at, replace_range
#   collection_helpers_window    — each_slice, chunk, pairwise, each_cons,
#                                  slice_when, chunk_while, zip_longest
#   collection_helpers_slice     — arr_compare, dedup_by, arr_slice, arr_take_last,
#                                  arr_drop_last, arr_rotate

use std.common.collection_helpers_sort
use std.common.collection_helpers_transform
use std.common.collection_helpers_index
use std.common.collection_helpers_window
use std.common.collection_helpers_slice
