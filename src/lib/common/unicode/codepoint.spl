# Unicode Codepoint Utilities
#
# Character classification, case mapping, and properties for Unicode codepoints.
# Extends ASCII-only functions in string_core.spl to full Unicode.
#
# Covers the Basic Multilingual Plane (BMP) ranges needed for the 10 target languages:
#   Latin, Cyrillic, Arabic, Devanagari, Bengali, Hangul, CJK

# ============================================================================
# Character classification
# ============================================================================

fn is_ascii(cp: i64) -> bool:
    """Check if codepoint is ASCII (U+0000..U+007F)."""
    cp >= 0 and cp <= 0x7F

fn is_latin(cp: i64) -> bool:
    """Check if codepoint is a Latin letter (basic + extended)."""
    if cp >= 0x41 and cp <= 0x5A:
        return true  # A-Z
    if cp >= 0x61 and cp <= 0x7A:
        return true  # a-z
    if cp >= 0xC0 and cp <= 0x024F:
        return true  # Latin Extended (accented chars)
    if cp >= 0x1E00 and cp <= 0x1EFF:
        return true  # Latin Extended Additional
    false

fn is_cyrillic(cp: i64) -> bool:
    """Check if codepoint is Cyrillic."""
    if cp >= 0x0400 and cp <= 0x04FF:
        return true
    if cp >= 0x0500 and cp <= 0x052F:
        return true  # Cyrillic Supplement
    false

fn is_arabic(cp: i64) -> bool:
    """Check if codepoint is Arabic."""
    if cp >= 0x0600 and cp <= 0x06FF:
        return true
    if cp >= 0x0750 and cp <= 0x077F:
        return true
    if cp >= 0x08A0 and cp <= 0x08FF:
        return true
    if cp >= 0xFB50 and cp <= 0xFDFF:
        return true  # Presentation Forms-A
    if cp >= 0xFE70 and cp <= 0xFEFF:
        return true  # Presentation Forms-B
    false

fn is_devanagari(cp: i64) -> bool:
    """Check if codepoint is Devanagari."""
    if cp >= 0x0900 and cp <= 0x097F:
        return true
    if cp >= 0xA8E0 and cp <= 0xA8FF:
        return true  # Devanagari Extended
    false

fn is_bengali(cp: i64) -> bool:
    """Check if codepoint is Bengali."""
    cp >= 0x0980 and cp <= 0x09FF

fn is_hangul(cp: i64) -> bool:
    """Check if codepoint is Hangul (Korean)."""
    if cp >= 0xAC00 and cp <= 0xD7AF:
        return true  # Hangul Syllables
    if cp >= 0x1100 and cp <= 0x11FF:
        return true  # Hangul Jamo
    if cp >= 0x3130 and cp <= 0x318F:
        return true  # Hangul Compatibility Jamo
    if cp >= 0xA960 and cp <= 0xA97F:
        return true  # Hangul Jamo Extended-A
    if cp >= 0xD7B0 and cp <= 0xD7FF:
        return true  # Hangul Jamo Extended-B
    false

fn is_cjk(cp: i64) -> bool:
    """Check if codepoint is CJK ideograph."""
    if cp >= 0x4E00 and cp <= 0x9FFF:
        return true  # CJK Unified Ideographs
    if cp >= 0x3400 and cp <= 0x4DBF:
        return true  # Extension A
    if cp >= 0x20000 and cp <= 0x2A6DF:
        return true  # Extension B
    if cp >= 0xF900 and cp <= 0xFAFF:
        return true  # Compatibility Ideographs
    false

fn is_hiragana(cp: i64) -> bool:
    """Check if codepoint is Hiragana."""
    cp >= 0x3040 and cp <= 0x309F

fn is_katakana(cp: i64) -> bool:
    """Check if codepoint is Katakana."""
    cp >= 0x30A0 and cp <= 0x30FF

# ============================================================================
# General category classification
# ============================================================================

fn is_unicode_letter(cp: i64) -> bool:
    """Check if codepoint is a letter (any script)."""
    if is_latin(cp):
        return true
    if is_cyrillic(cp):
        return true
    if is_arabic(cp):
        return true
    if is_devanagari(cp):
        return true
    if is_bengali(cp):
        return true
    if is_hangul(cp):
        return true
    if is_cjk(cp):
        return true
    if is_hiragana(cp):
        return true
    if is_katakana(cp):
        return true
    false

fn is_unicode_digit(cp: i64) -> bool:
    """Check if codepoint is a digit (includes non-ASCII digit ranges)."""
    if cp >= 0x30 and cp <= 0x39:
        return true  # ASCII 0-9
    # Arabic-Indic digits
    if cp >= 0x0660 and cp <= 0x0669:
        return true
    # Extended Arabic-Indic digits
    if cp >= 0x06F0 and cp <= 0x06F9:
        return true
    # Devanagari digits
    if cp >= 0x0966 and cp <= 0x096F:
        return true
    # Bengali digits
    if cp >= 0x09E6 and cp <= 0x09EF:
        return true
    # Fullwidth digits
    if cp >= 0xFF10 and cp <= 0xFF19:
        return true
    false

fn is_unicode_whitespace(cp: i64) -> bool:
    """Check if codepoint is whitespace (Unicode Zs + ASCII controls)."""
    if cp == 0x20:
        return true  # space
    if cp == 0x09:
        return true  # tab
    if cp == 0x0A:
        return true  # LF
    if cp == 0x0D:
        return true  # CR
    if cp == 0x0C:
        return true  # FF
    if cp == 0x0B:
        return true  # VT
    if cp == 0x85:
        return true  # NEL
    if cp == 0xA0:
        return true  # NBSP
    # Unicode space characters (Zs category)
    if cp == 0x1680:
        return true  # Ogham space
    if cp >= 0x2000 and cp <= 0x200A:
        return true  # En/Em spaces, thin space, etc.
    if cp == 0x2028:
        return true  # Line separator
    if cp == 0x2029:
        return true  # Paragraph separator
    if cp == 0x202F:
        return true  # Narrow NBSP
    if cp == 0x205F:
        return true  # Medium mathematical space
    if cp == 0x3000:
        return true  # Ideographic space (CJK)
    false

fn is_unicode_punctuation(cp: i64) -> bool:
    """Check if codepoint is punctuation."""
    # ASCII punctuation
    if cp >= 0x21 and cp <= 0x2F:
        return true
    if cp >= 0x3A and cp <= 0x40:
        return true
    if cp >= 0x5B and cp <= 0x60:
        return true
    if cp >= 0x7B and cp <= 0x7E:
        return true
    # General punctuation block
    if cp >= 0x2000 and cp <= 0x206F:
        return true
    # CJK punctuation
    if cp >= 0x3001 and cp <= 0x3003:
        return true
    # Fullwidth punctuation
    if cp >= 0xFF01 and cp <= 0xFF0F:
        return true
    if cp >= 0xFF1A and cp <= 0xFF20:
        return true
    false

fn is_combining_mark(cp: i64) -> bool:
    """Check if codepoint is a combining mark (zero-width modifier)."""
    # Combining Diacritical Marks
    if cp >= 0x0300 and cp <= 0x036F:
        return true
    # Combining Diacritical Marks Extended
    if cp >= 0x1AB0 and cp <= 0x1AFF:
        return true
    # Combining Diacritical Marks Supplement
    if cp >= 0x1DC0 and cp <= 0x1DFF:
        return true
    # Combining Diacritical Marks for Symbols
    if cp >= 0x20D0 and cp <= 0x20FF:
        return true
    # Combining Half Marks
    if cp >= 0xFE20 and cp <= 0xFE2F:
        return true
    # Devanagari vowel signs, virama
    if cp >= 0x0901 and cp <= 0x0903:
        return true
    if cp >= 0x093A and cp <= 0x094F:
        return true
    if cp >= 0x0951 and cp <= 0x0957:
        return true
    # Bengali vowel signs
    if cp >= 0x0981 and cp <= 0x0983:
        return true
    if cp >= 0x09BC and cp <= 0x09CD:
        return true
    # Arabic marks
    if cp >= 0x064B and cp <= 0x065F:
        return true
    if cp == 0x0670:
        return true
    false

# ============================================================================
# Case mapping (basic — covers Latin + Cyrillic)
# ============================================================================

fn unicode_to_upper(cp: i64) -> i64:
    """Convert codepoint to uppercase (Latin + Cyrillic ranges)."""
    # ASCII lowercase
    if cp >= 0x61 and cp <= 0x7A:
        return cp - 32
    # Latin-1 Supplement lowercase (à-ö, ø-ÿ)
    if cp >= 0xE0 and cp <= 0xF6:
        return cp - 32
    if cp >= 0xF8 and cp <= 0xFE:
        return cp - 32
    # Cyrillic lowercase (а-я)
    if cp >= 0x0430 and cp <= 0x044F:
        return cp - 32
    # Cyrillic extended lowercase (ё, etc.)
    if cp == 0x0451:
        return 0x0401  # ё -> Ё
    cp

fn unicode_to_lower(cp: i64) -> i64:
    """Convert codepoint to lowercase (Latin + Cyrillic ranges)."""
    # ASCII uppercase
    if cp >= 0x41 and cp <= 0x5A:
        return cp + 32
    # Latin-1 Supplement uppercase (À-Ö, Ø-Þ)
    if cp >= 0xC0 and cp <= 0xD6:
        return cp + 32
    if cp >= 0xD8 and cp <= 0xDE:
        return cp + 32
    # Cyrillic uppercase (А-Я)
    if cp >= 0x0410 and cp <= 0x042F:
        return cp + 32
    # Cyrillic extended uppercase
    if cp == 0x0401:
        return 0x0451  # Ё -> ё
    cp

fn is_unicode_upper(cp: i64) -> bool:
    """Check if codepoint is uppercase."""
    if cp >= 0x41 and cp <= 0x5A:
        return true
    if cp >= 0xC0 and cp <= 0xD6:
        return true
    if cp >= 0xD8 and cp <= 0xDE:
        return true
    if cp >= 0x0410 and cp <= 0x042F:
        return true
    if cp == 0x0401:
        return true
    false

fn is_unicode_lower(cp: i64) -> bool:
    """Check if codepoint is lowercase."""
    if cp >= 0x61 and cp <= 0x7A:
        return true
    if cp >= 0xE0 and cp <= 0xF6:
        return true
    if cp >= 0xF8 and cp <= 0xFE:
        return true
    if cp >= 0x0430 and cp <= 0x044F:
        return true
    if cp == 0x0451:
        return true
    false

# ============================================================================
# Hangul decomposition (Jamo ↔ Syllable)
# ============================================================================

val HANGUL_S_BASE: i64 = 0xAC00  # First Hangul syllable
val HANGUL_L_BASE: i64 = 0x1100  # First leading consonant (Choseong)
val HANGUL_V_BASE: i64 = 0x1161  # First vowel (Jungseong)
val HANGUL_T_BASE: i64 = 0x11A7  # First trailing consonant (Jongseong)
val HANGUL_L_COUNT: i64 = 19     # Number of leading consonants
val HANGUL_V_COUNT: i64 = 21     # Number of vowels
val HANGUL_T_COUNT: i64 = 28     # Number of trailing consonants (including none)
val HANGUL_N_COUNT: i64 = 588    # V_COUNT * T_COUNT
val HANGUL_S_COUNT: i64 = 11172  # L_COUNT * N_COUNT

fn hangul_decompose(syllable: i64) -> [i64]:
    """Decompose a precomposed Hangul syllable into Jamo components.
    Returns [L, V] or [L, V, T] where L=leading, V=vowel, T=trailing."""
    if syllable < HANGUL_S_BASE or syllable >= HANGUL_S_BASE + HANGUL_S_COUNT:
        return [syllable]  # Not a syllable

    val s_index = syllable - HANGUL_S_BASE
    val l_index = s_index / HANGUL_N_COUNT
    val v_index = (s_index % HANGUL_N_COUNT) / HANGUL_T_COUNT
    val t_index = s_index % HANGUL_T_COUNT

    val l = HANGUL_L_BASE + l_index
    val v = HANGUL_V_BASE + v_index

    if t_index == 0:
        return [l, v]
    [l, v, HANGUL_T_BASE + t_index]

fn hangul_compose(l: i64, v: i64, t: i64) -> i64:
    """Compose Hangul Jamo into a precomposed syllable.
    l = leading consonant (Choseong), v = vowel (Jungseong), t = trailing (Jongseong, 0 for none)."""
    val l_index = l - HANGUL_L_BASE
    val v_index = v - HANGUL_V_BASE
    var t_index: i64 = 0
    if t > 0:
        t_index = t - HANGUL_T_BASE

    if l_index < 0 or l_index >= HANGUL_L_COUNT:
        return 0xFFFD
    if v_index < 0 or v_index >= HANGUL_V_COUNT:
        return 0xFFFD
    if t_index < 0 or t_index >= HANGUL_T_COUNT:
        return 0xFFFD

    HANGUL_S_BASE + (l_index * HANGUL_N_COUNT) + (v_index * HANGUL_T_COUNT) + t_index
