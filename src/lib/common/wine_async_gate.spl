"""Wine async-substrate readiness gate based on nogc_async_mut primitives."""

pub fn wine_async_required_features() -> [text]:
    [
        "nogc-future",
        "poll",
        "waker",
        "io-driver",
        "submit-open",
        "submit-read",
        "submit-write",
        "submit-close",
        "submit-timeout",
        "poll-completion",
        "event-loop",
        "register-fd",
        "deregister-fd",
        "wake",
        "noalloc-capability"
    ]

pub fn wine_async_missing_features(features: text) -> [text]:
    var missing: [text] = []
    for feature in wine_async_required_features():
        if not features.contains(feature):
            missing.push(feature)
    return missing

pub fn wine_async_gate(features: text) -> text:
    val missing = wine_async_missing_features(features)
    if missing.len() == 0:
        return "ready"
    return "missing-" + missing[0]

pub fn wine_async_io_gate(features: text) -> text:
    if not features.contains("io-driver"):
        return "missing-io-driver"
    if not features.contains("submit-open"):
        return "missing-submit-open"
    if not features.contains("submit-read"):
        return "missing-submit-read"
    if not features.contains("submit-write"):
        return "missing-submit-write"
    if not features.contains("submit-close"):
        return "missing-submit-close"
    if not features.contains("submit-timeout"):
        return "missing-submit-timeout"
    if not features.contains("poll-completion"):
        return "missing-poll-completion"
    return "ready"

pub fn wine_async_event_loop_gate(features: text) -> text:
    if not features.contains("event-loop"):
        return "missing-event-loop"
    if not features.contains("register-fd"):
        return "missing-register-fd"
    if not features.contains("deregister-fd"):
        return "missing-deregister-fd"
    if not features.contains("waker"):
        return "missing-waker"
    if not features.contains("wake"):
        return "missing-wake"
    return "ready"
