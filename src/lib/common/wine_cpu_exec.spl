"""CPU/thread execution readiness gates for the hello.exe milestone."""

use common.pe_coff_header.{pe_entry_point_rva, pe_rva_to_file_offset}
use common.wine_image_map.{wine_image_entry_window_gate}
use common.wine_x86_64_decode.{wine_x86_64_hello_decode_plan, wine_x86_64_scan_window}

class WineCpuHelloExecutionPlan:
    ok: bool
    error: text
    entry_rva: i64
    call_sequence: text
    call_count: i64
    get_std_handle_rva: i64
    stdout_payload_rva: i64
    write_file_rva: i64
    exit_process_rva: i64

class WineCpuExecutionEvidence:
    thread_context: bool
    user_stack: bool
    entrypoint_mapped: bool
    import_thunks_bound: bool
    stdout_handle: bool
    exit_trap: bool
    no_native_jump: bool
    win64_abi: bool
    x86_64_decoder: bool
    x86_64_dispatch: bool

fn _hello_plan_error(error: text) -> WineCpuHelloExecutionPlan:
    WineCpuHelloExecutionPlan(ok: false, error: error, entry_rva: 0, call_sequence: "", call_count: 0, get_std_handle_rva: 0, stdout_payload_rva: 0, write_file_rva: 0, exit_process_rva: 0)

fn _hello_plan_ready(entry_rva: i64, get_std_handle_rva: i64, stdout_payload_rva: i64, write_file_rva: i64, exit_process_rva: i64) -> WineCpuHelloExecutionPlan:
    WineCpuHelloExecutionPlan(
        ok: true,
        error: "",
        entry_rva: entry_rva,
        call_sequence: "GetStdHandle WriteFile ExitProcess",
        call_count: 3,
        get_std_handle_rva: get_std_handle_rva,
        stdout_payload_rva: stdout_payload_rva,
        write_file_rva: write_file_rva,
        exit_process_rva: exit_process_rva
    )

pub fn wine_cpu_execution_evidence(
    thread_context: bool,
    user_stack: bool,
    entrypoint_mapped: bool,
    import_thunks_bound: bool,
    stdout_handle: bool,
    exit_trap: bool,
    no_native_jump: bool,
    win64_abi: bool,
    x86_64_decoder: bool,
    x86_64_dispatch: bool
) -> WineCpuExecutionEvidence:
    WineCpuExecutionEvidence(
        thread_context: thread_context,
        user_stack: user_stack,
        entrypoint_mapped: entrypoint_mapped,
        import_thunks_bound: import_thunks_bound,
        stdout_handle: stdout_handle,
        exit_trap: exit_trap,
        no_native_jump: no_native_jump,
        win64_abi: win64_abi,
        x86_64_decoder: x86_64_decoder,
        x86_64_dispatch: x86_64_dispatch
    )

pub fn wine_cpu_execution_evidence_all_ready() -> WineCpuExecutionEvidence:
    wine_cpu_execution_evidence(true, true, true, true, true, true, true, true, true, true)

pub fn wine_cpu_execution_evidence_text(evidence: WineCpuExecutionEvidence) -> text:
    var out = ""
    if evidence.thread_context:
        out = out + " thread-context thread-context-rip thread-context-rsp thread-context-registers-zeroed thread-context-teb-bound"
    if evidence.user_stack:
        out = out + " user-stack user-stack-allocated user-stack-committed user-stack-guard-page user-stack-aligned"
    if evidence.entrypoint_mapped:
        out = out + " entrypoint-mapped entrypoint-rva-valid entrypoint-section-executable entrypoint-window-readable"
    if evidence.import_thunks_bound:
        out = out + " import-thunks-bound import-thunk-table-valid import-thunk-symbols-resolved import-thunk-bindings-match import-thunk-iat-guarded"
    if evidence.stdout_handle:
        out = out + " stdout-handle stdout-handle-std-output stdout-handle-writable stdout-byte-count-checked stdout-write-guarded"
    if evidence.exit_trap:
        out = out + " exit-trap exit-trap-process-exit exit-trap-status-code exit-trap-no-fallthrough"
    if evidence.no_native_jump:
        out = out + " no-native-jump no-native-jump-import-targets no-native-jump-entry-bounds no-native-jump-host-code-blocked"
    if evidence.win64_abi:
        out = out + " win64-abi win64-abi-register-args win64-abi-shadow-space win64-abi-stack-align win64-abi-return-value win64-abi-guarded-call"
    if evidence.x86_64_decoder:
        out = out + " x86_64-decoder x86_64-decode-window-mapped x86_64-decode-window-bounded x86_64-decode-supported-ops x86_64-decode-call-targets"
    if evidence.x86_64_dispatch:
        out = out + " x86_64-dispatch x86_64-dispatch-no-native-jump x86_64-dispatch-import-calls-only x86_64-dispatch-exit-trap x86_64-dispatch-stdout-sequence"
    out

pub fn wine_win64_abi_required_features() -> [text]:
    [
        "win64-abi-register-args",
        "win64-abi-shadow-space",
        "win64-abi-stack-align",
        "win64-abi-return-value",
        "win64-abi-guarded-call"
    ]

pub fn wine_win64_abi_gate(evidence: text) -> text:
    if not evidence.contains("win64-abi"):
        return "missing-win64-abi"
    for feature in wine_win64_abi_required_features():
        if not evidence.contains(feature):
            return "missing-" + feature
    "ready"

