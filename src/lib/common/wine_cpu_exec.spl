pub fn wine_cpu_execution_required_features() -> [text]:
    [
        "thread-context",
        "user-stack",
        "entrypoint-mapped",
        "import-thunks-bound",
        "stdout-handle",
        "exit-trap",
        "no-native-jump",
        "win64-abi"
    ]

pub fn wine_cpu_execution_gate(evidence: text) -> text:
    for feature in wine_cpu_execution_required_features():
        if not evidence.contains(feature):
            return "missing-" + feature
    val thread_state = wine_thread_context_gate(evidence)
    if thread_state != "ready":
        return thread_state
    val stack_state = wine_user_stack_gate(evidence)
    if stack_state != "ready":
        return stack_state
    val entrypoint_state = wine_entrypoint_mapping_gate(evidence)
    if entrypoint_state != "ready":
        return entrypoint_state
    val import_state = wine_import_thunk_binding_gate(evidence)
    if import_state != "ready":
        return import_state
    val stdout_state = wine_stdout_handle_gate(evidence)
    if stdout_state != "ready":
        return stdout_state
    val exit_state = wine_exit_trap_gate(evidence)
    if exit_state != "ready":
        return exit_state
    val native_jump_state = wine_no_native_jump_gate(evidence)
    if native_jump_state != "ready":
        return native_jump_state
    val abi_state = wine_win64_abi_gate(evidence)
    if abi_state != "ready":
        return abi_state
    "ready"

pub fn wine_instruction_dispatch_gate(evidence: text) -> text:
    val decoder_state = wine_x86_64_decoder_gate(evidence)
    if decoder_state != "ready":
        return decoder_state
    val dispatch_state = wine_x86_64_dispatch_gate(evidence)
    if dispatch_state != "ready":
        return dispatch_state
    "ready"

pub fn wine_cpu_entry_scan_gate(data: [u8], max_bytes: i64, max_instructions: i64) -> text:
    val window_state = wine_image_entry_window_gate(data, max_bytes)
    if window_state != "ready":
        return window_state
    val entry_rva = pe_entry_point_rva(data)
    val entry_offset = pe_rva_to_file_offset(data, entry_rva)
    if entry_offset < 0:
        return "entrypoint-unmapped"
    val scan = wine_x86_64_scan_window(data, entry_offset, max_bytes, max_instructions)
    if not scan.ok:
        return scan.state
    "ready"

pub fn wine_cpu_hello_execution_plan(data: [u8], evidence: text) -> WineCpuHelloExecutionPlan:
    val cpu_state = wine_cpu_execution_gate(evidence)
    if cpu_state != "ready":
        return _hello_plan_error(cpu_state)
    val dispatch_state = wine_instruction_dispatch_gate(evidence)
    if dispatch_state != "ready":
        return _hello_plan_error(dispatch_state)
    val decode_plan = wine_x86_64_hello_decode_plan(data)
    if not decode_plan.ok:
        return _hello_plan_error(decode_plan.error)
    val scan_state = wine_cpu_entry_scan_gate(data, 27, 16)
    if scan_state != "ready":
        return _hello_plan_error("instruction-scan-" + scan_state)
    if decode_plan.get_std_handle_rva != 0x2080 or
       decode_plan.stdout_payload_rva != 0x2120 or
       decode_plan.write_file_rva != 0x20a0 or
       decode_plan.exit_process_rva != 0x20c0:
        return _hello_plan_error("instruction-plan-target-mismatch")
    _hello_plan_ready(decode_plan.entry_rva, decode_plan.get_std_handle_rva, decode_plan.stdout_payload_rva, decode_plan.write_file_rva, decode_plan.exit_process_rva)

pub fn wine_cpu_hello_execution_plan_from_evidence(data: [u8], evidence: WineCpuExecutionEvidence) -> WineCpuHelloExecutionPlan:
    wine_cpu_hello_execution_plan(data, wine_cpu_execution_evidence_text(evidence))
