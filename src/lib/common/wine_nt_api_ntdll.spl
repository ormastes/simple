"""ntdll.dll symbol lists and category gates for the Wine NT API catalog."""

use common.wine_nt_api_types.{WineNtApiCatalogEntry}

fn _ntdll_entry(symbol: text, category: text) -> WineNtApiCatalogEntry:
    WineNtApiCatalogEntry(dll: "ntdll.dll", symbol: symbol, category: category, state: "implemented")

fn _ntdll_lookup(symbol: text) -> WineNtApiCatalogEntry:
    if symbol == "NtAllocateVirtualMemory" or symbol == "NtProtectVirtualMemory" or symbol == "NtFreeVirtualMemory":
        return _ntdll_entry(symbol, "nt-virtual-memory")
    if symbol == "NtCreateFile" or symbol == "NtOpenFile" or symbol == "NtReadFile" or symbol == "NtWriteFile" or symbol == "NtClose" or symbol == "NtQueryInformationFile" or symbol == "NtQueryAttributesFile" or symbol == "NtQueryDirectoryFile" or symbol == "NtSetInformationFile":
        return _ntdll_entry(symbol, "nt-file-io")
    if symbol == "NtCreateEvent" or symbol == "NtSetEvent" or symbol == "NtWaitForSingleObject" or symbol == "NtResetEvent":
        return _ntdll_entry(symbol, "nt-sync-event")
    if symbol == "NtCreateSection" or symbol == "NtMapViewOfSection" or symbol == "NtUnmapViewOfSection":
        return _ntdll_entry(symbol, "nt-section-map")
    if symbol == "NtQuerySystemInformation":
        return _ntdll_entry(symbol, "nt-system-info")
    if symbol == "NtQueryInformationProcess" or symbol == "NtQueryInformationThread":
        return _ntdll_entry(symbol, "nt-process-info")
    if symbol == "NtOpenDirectoryObject" or symbol == "NtQueryDirectoryObject":
        return _ntdll_entry(symbol, "nt-object-namespace")
    if symbol == "NtOpenKey" or symbol == "NtQueryValueKey":
        return _ntdll_entry(symbol, "nt-registry")
    if symbol == "LdrLoadDll" or symbol == "LdrGetProcedureAddress" or symbol == "LdrUnloadDll":
        return _ntdll_entry(symbol, "nt-loader")
    if symbol == "RtlAllocateHeap" or symbol == "RtlFreeHeap":
        return _ntdll_entry(symbol, "rtl-heap")
    if symbol == "RtlInitUnicodeString" or symbol == "RtlUnicodeStringToAnsiString" or symbol == "RtlFreeAnsiString":
        return _ntdll_entry(symbol, "rtl-string")
    WineNtApiCatalogEntry(dll: "ntdll.dll", symbol: symbol, category: "unknown", state: "unsupported")

pub fn wine_nt_api_implemented_ntdll_virtual_memory_symbols() -> [text]:
    [
        "NtAllocateVirtualMemory",
        "NtProtectVirtualMemory",
        "NtFreeVirtualMemory"
    ]

