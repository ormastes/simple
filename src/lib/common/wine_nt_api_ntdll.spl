pub fn wine_nt_api_ntdll_virtual_memory_import_gate(dll: text, symbols: [text]) -> text:
    if dll.lower() != "ntdll.dll":
        return "unsupported-dll:" + dll
    if symbols.len() == 0:
        return "missing-symbol:ntdll-virtual-memory"
    for symbol in symbols:
        val entry = _ntdll_lookup(symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
        if entry.category != "nt-virtual-memory":
            return "wrong-category:" + symbol
    "ready"

pub fn wine_nt_api_ntdll_virtual_memory_dispatch_gate(symbols: [text]) -> text:
    if symbols.len() == 0:
        return "bridge-missing:ntdll-virtual-memory"
    for symbol in symbols:
        val entry = _ntdll_lookup(symbol)
        if entry.state != "implemented":
            return "bridge-unsupported:" + symbol
        if entry.category != "nt-virtual-memory":
            return "bridge-wrong-category:" + symbol
    "ready"

