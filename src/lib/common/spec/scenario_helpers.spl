# Scenario checker and capture helpers for SSpec manual authoring.
#
# Reusable helpers that test authors use in Then_* scenario steps to produce
# structured evidence artifacts and step results. Built on top of the
# scenario_evidence vocabulary.
#
# This module uses extern fn for file I/O so it stays in the common layer
# without cross-layer imports.

use std.common.spec.scenario_evidence.{
    ScenarioCaptureKind,
    ScenarioEvidenceArtifact,
    ScenarioCheckerEvidence,
    scenario_evidence_artifact,
    scenario_api_evidence,
    scenario_api_protocol_evidence,
    scenario_checker_evidence
}

extern fn rt_file_exists(path: text) -> bool

# A step result pairs a human-readable description with a pass/fail outcome.
pub struct ScenarioStepResult:
    description: text
    passed: bool

# ---------------------------------------------------------------------------
# Checker helpers — produce bool + ScenarioCheckerEvidence side output
# ---------------------------------------------------------------------------

# Check whether actual text contains the expected substring.
# Returns true when the substring is found.
pub fn check_text_contains(actual: text, expected: text) -> bool:
    actual.contains(expected)

# Check whether an HTTP/protocol status code matches the expected value.
# Returns true when the codes are equal.
pub fn check_status_code(actual: i64, expected: i64) -> bool:
    actual == expected

# Check whether a file exists at the given path.
# Returns true when the file is present on disk.
pub fn check_file_exists(path: text) -> bool:
    rt_file_exists(path)

# Check whether a JSON text contains a given field name.
# Uses a simple key-presence heuristic: looks for "field": in the text.
# For deep or escaped-key queries, use std.common.json directly.
pub fn check_json_field(json_text: text, field: text) -> bool:
    val needle = "\"" + field + "\":"
    json_text.contains(needle)

# ---------------------------------------------------------------------------
# Capture helpers — produce ScenarioEvidenceArtifact for manual rendering
# ---------------------------------------------------------------------------

# Capture a plain text snippet as evidence.
pub fn capture_text(label: text, content: text) -> ScenarioEvidenceArtifact:
    scenario_evidence_artifact(
        ScenarioCaptureKind.text,
        label,
        "text/plain",
        "",
        content,
        "",
        ""
    )

# Capture a sequence of log lines as evidence.
pub fn capture_log(label: text, lines: [text]) -> ScenarioEvidenceArtifact:
    var body = ""
    var i = 0
    for line in lines:
        if i > 0:
            body = body + "\n"
        body = body + line
        i = i + 1
    scenario_evidence_artifact(
        ScenarioCaptureKind.log,
        label,
        "text/plain",
        "",
        body,
        "",
        ""
    )

# Capture a basic API response with method, path, status, and response summary.
pub fn capture_api_response(
    label: text,
    method: text,
    path: text,
    status: i64,
    response_summary: text
) -> ScenarioEvidenceArtifact:
    scenario_api_evidence(
        label,
        method,
        path,
        status,
        response_summary,
        "",
        ""
    )

# Capture protocol/API provider details with params, headers, response fields,
# and sensitive-value redaction notes.
pub fn capture_api_protocol(
    label: text,
    method: text,
    path: text,
    params_summary: text,
    headers_summary: text,
    response_fields: text,
    redacted_values: text
) -> ScenarioEvidenceArtifact:
    scenario_api_protocol_evidence(
        label,
        method,
        path,
        params_summary,
        headers_summary,
        response_fields,
        redacted_values,
        "",
        ""
    )

# ---------------------------------------------------------------------------
# Step result helper — wrap a check outcome with a human description
# ---------------------------------------------------------------------------

# Create a step result from a description and pass/fail boolean.
pub fn step_result(description: text, passed: bool) -> ScenarioStepResult:
    ScenarioStepResult(
        description: description,
        passed: passed
    )

# Render a step result as a single-line manual summary.
pub fn step_result_summary(result: ScenarioStepResult) -> text:
    val status = if result.passed: "passed" else: "failed"
    "{result.description} ({status})"
