# Scenario checker and capture helpers for SSpec manual authoring.
#
# Reusable helpers that test authors use in Then_* scenario steps to produce
# structured evidence artifacts and step results. Built on top of the
# scenario_evidence vocabulary.
#
# This module uses extern fn for file I/O so it stays in the common layer
# without cross-layer imports.

use std.common.spec.scenario_evidence.{
    ScenarioCaptureKind,
    ScenarioEvidenceArtifact,
    ScenarioCheckerEvidence,
    scenario_evidence_artifact,
    scenario_api_evidence,
    scenario_api_protocol_evidence,
    scenario_exec_evidence,
    scenario_exec_detailed_evidence,
    scenario_binary_evidence,
    scenario_binary_detailed_evidence,
    scenario_checker_evidence
}

extern fn rt_file_exists(path: text) -> bool

# A step result pairs a human-readable description with a pass/fail outcome.
pub struct ScenarioStepResult:
    description: text
    passed: bool

# Check whether actual text contains the expected substring.
pub fn check_text_contains(actual: text, expected: text) -> bool:
    actual.contains(expected)

# Check whether an HTTP/protocol status code matches the expected value.
pub fn check_status_code(actual: i64, expected: i64) -> bool:
    actual == expected

pub fn check_exit_code(actual: i64, expected: i64) -> bool:
    actual == expected

# Check whether a file exists at the given path.
pub fn check_file_exists(path: text) -> bool:
    rt_file_exists(path)

# Check whether a JSON text contains a given field name.
# Uses a simple key-presence heuristic: looks for "field": in the text.
# For deep or escaped-key queries, use std.common.json directly.
pub fn check_json_field(json_text: text, field: text) -> bool:
    val needle = "\"" + field + "\":"
    json_text.contains(needle)

pub fn check_text_contains_evidence(
    label: text,
    actual: text,
    expected: text
) -> ScenarioCheckerEvidence:
    val artifact = capture_text(
        label,
        "expected substring: " + expected + "\nactual: " + actual
    )
    scenario_checker_evidence(
        "text contains " + expected,
        check_text_contains(actual, expected),
        artifact
    )

pub fn check_status_code_evidence(
    label: text,
    method: text,
    path: text,
    actual: i64,
    expected: i64,
    response_summary: text
) -> ScenarioCheckerEvidence:
    val artifact = scenario_api_evidence(
        label,
        method,
        path,
        actual,
        "expected status: " + "{expected}" + "\n" + response_summary,
        "",
        ""
    )
    scenario_checker_evidence(
        "status " + "{actual}" + " equals " + "{expected}",
        check_status_code(actual, expected),
        artifact
    )

pub fn check_exit_code_evidence(
    label: text,
    command: text,
    actual: i64,
    expected: i64,
    output_summary: text
) -> ScenarioCheckerEvidence:
    val artifact = scenario_exec_evidence(
        label,
        command,
        actual,
        "expected exit: " + "{expected}" + "\n" + output_summary,
        "",
        ""
    )
    scenario_checker_evidence(
        "exit " + "{actual}" + " equals " + "{expected}",
        check_exit_code(actual, expected),
        artifact
    )

pub fn check_json_field_evidence(
    label: text,
    json_text: text,
    field: text
) -> ScenarioCheckerEvidence:
    val artifact = capture_text(
        label,
        "expected field: " + field + "\njson: " + json_text
    )
    scenario_checker_evidence(
        "json field exists " + field,
        check_json_field(json_text, field),
        artifact
    )

# Capture a command result with command, exit code, and output summary.
pub fn capture_exec_response(
    label: text,
    command: text,
    exit_code: i64,
    output_summary: text
) -> ScenarioEvidenceArtifact:
    scenario_exec_evidence(
        label,
        command,
        exit_code,
        output_summary,
        "",
        ""
    )

# Capture detailed command/provider execution evidence with args, input,
# stdout, stderr, and exit code.
pub fn capture_exec_detailed(
    label: text,
    command: text,
    args_summary: text,
    input_trigger: text,
    stdout_summary: text,
    stderr_summary: text,
    exit_code: i64
) -> ScenarioEvidenceArtifact:
    scenario_exec_detailed_evidence(
        label,
        command,
        args_summary,
        input_trigger,
        stdout_summary,
        stderr_summary,
        exit_code,
        "",
        ""
    )

pub fn capture_binary_response(
    label: text,
    format_name: text,
    field_summary: text
) -> ScenarioEvidenceArtifact:
    scenario_binary_evidence(
        label,
        format_name,
        field_summary,
        "",
        ""
    )

pub fn capture_binary_detailed(
    label: text,
    format_name: text,
    raw_bytes_summary: text,
    decoded_fields: text,
    field_comments: text
) -> ScenarioEvidenceArtifact:
    scenario_binary_detailed_evidence(
        label,
        format_name,
        raw_bytes_summary,
        decoded_fields,
        field_comments,
        "",
        ""
    )
# Capture a plain text snippet as evidence.
pub fn capture_text(label: text, content: text) -> ScenarioEvidenceArtifact:
    scenario_evidence_artifact(
        ScenarioCaptureKind.text,
        label,
        "text/plain",
        "",
        content,
        "",
        ""
    )

# Capture a sequence of log lines as evidence.
pub fn capture_log(label: text, lines: [text]) -> ScenarioEvidenceArtifact:
    var body = ""
    var i = 0
    for line in lines:
        if i > 0:
            body = body + "\n"
        body = body + line
        i = i + 1
    scenario_evidence_artifact(
        ScenarioCaptureKind.log,
        label,
        "text/plain",
        "",
        body,
        "",
        ""
    )

# Capture a basic API response with method, path, status, and response summary.
pub fn capture_api_response(
    label: text,
    method: text,
    path: text,
    status: i64,
    response_summary: text
) -> ScenarioEvidenceArtifact:
    scenario_api_evidence(
        label,
        method,
        path,
        status,
        response_summary,
        "",
        ""
    )

# Return true for common API/protocol field names whose values must be hidden
# in generated manuals and provider evidence.
pub fn is_sensitive_api_field(name: text) -> bool:
    name == "authorization" or
        name == "cookie" or
        name == "set-cookie" or
        name == "token" or
        name == "access_token" or
        name == "refresh_token" or
        name == "api_key" or
        name == "password" or
        name == "secret"

# Render a single API/protocol field summary with redaction applied.
pub fn api_field_summary(name: text, value: text) -> text:
    if is_sensitive_api_field(name):
        return name + "=<redacted>"
    name + "=" + value

# Render aligned field names and values as a semicolon-separated summary.
pub fn api_field_list_summary(names: [text], values: [text]) -> text:
    var limit = names.len()
    if values.len() < limit:
        limit = values.len()
    var out = ""
    for i in 0..limit:
        if i > 0:
            out = out + "; "
        out = out + api_field_summary(names[i], values[i])
    out

# Render the sensitive field names that were redacted from an API/protocol
# capture. Values are intentionally not included.
pub fn redacted_api_field_names(names: [text]) -> text:
    var out = ""
    for name in names:
        if is_sensitive_api_field(name):
            if out != "":
                out = out + "; "
            out = out + name
    out

pub fn redacted_api_field_group_names(
    group_name: text,
    names: [text]
) -> text:
    var out = ""
    for name in names:
        if is_sensitive_api_field(name):
            if out != "":
                out = out + "; "
            out = out + group_name + "." + name
    out

pub fn redacted_api_protocol_field_names(
    param_names: [text],
    header_names: [text],
    response_field_names: [text]
) -> text:
    var out = redacted_api_field_group_names("params", param_names)
    val headers = redacted_api_field_group_names("headers", header_names)
    if headers != "":
        if out != "":
            out = out + "; "
        out = out + headers
    val response = redacted_api_field_group_names("response", response_field_names)
    if response != "":
        if out != "":
            out = out + "; "
        out = out + response
    out

# Capture protocol/API provider details with params, headers, response fields,
# and sensitive-value redaction notes.
pub fn capture_api_protocol(
    label: text,
    method: text,
    path: text,
    params_summary: text,
    headers_summary: text,
    response_fields: text,
    redacted_values: text
) -> ScenarioEvidenceArtifact:
    scenario_api_protocol_evidence(
        label,
        method,
        path,
        params_summary,
        headers_summary,
        response_fields,
        redacted_values,
        "",
        ""
    )

# Capture protocol/API provider details from structured field lists. Header
# values are redacted by common sensitive field names before manual rendering.
pub fn capture_api_protocol_fields(
    label: text,
    method: text,
    path: text,
    param_names: [text],
    param_values: [text],
    header_names: [text],
    header_values: [text],
    response_field_names: [text],
    response_field_values: [text]
) -> ScenarioEvidenceArtifact:
    val params_summary = api_field_list_summary(param_names, param_values)
    val headers_summary = api_field_list_summary(header_names, header_values)
    val response_fields = api_field_list_summary(response_field_names, response_field_values)
    val redacted_values = redacted_api_protocol_field_names(
        param_names,
        header_names,
        response_field_names
    )
    scenario_api_protocol_evidence(
        label,
        method,
        path,
        params_summary,
        headers_summary,
        response_fields,
        redacted_values,
        "",
        ""
    )

# Create a step result from a description and pass/fail boolean.
pub fn step_result(description: text, passed: bool) -> ScenarioStepResult:
    ScenarioStepResult(
        description: description,
        passed: passed
    )

# Render a step result as a single-line manual summary.
pub fn step_result_summary(result: ScenarioStepResult) -> text:
    val status = if result.passed: "passed" else: "failed"
    "{result.description} ({status})"
