enum TargetArch:
    X86_64
    X86
    Aarch64
    Arm
    ARM
    Riscv64
    Riscv32
    RiscV64
    RiscV32
    Wasm64
    Wasm32
    AVR
    Avr
    MCS51
    I8086
    MSP430
    Host

impl TargetArch:
    static fn host() -> TargetArch:
        TargetArch.X86_64

    me bits() -> i32:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51:
                8
            TargetArch.MSP430 | TargetArch.I8086:
                16
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                32
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64:
                64
            TargetArch.Host:
                64

    me pointer_bytes() -> i32:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51 | TargetArch.MSP430 | TargetArch.I8086:
                2
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                4
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64:
                8
            TargetArch.Host:
                8

    me pointer_size() -> PointerSize:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51 | TargetArch.MSP430 | TargetArch.I8086:
                PointerSize.Bits16
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                PointerSize.Bits32
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64:
                PointerSize.Bits64
            TargetArch.Host:
                PointerSize.Bits64

    # ABI-required stack alignment in bytes.
    me stack_align() -> i32:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51:
                1
            TargetArch.MSP430 | TargetArch.I8086:
                2
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                4
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64:
                16
            TargetArch.Host:
                16

    # Widest value (in bits) the target can atomically load/store/CAS in one
    # instruction (e.g. x86 cmpxchg8b, x86_64 cmpxchg16b).
    me max_atomic_width() -> i32:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51:
                8
            TargetArch.MSP430 | TargetArch.I8086:
                16
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                64
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64:
                128
            TargetArch.Host:
                128

    me has_fpu() -> bool:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51 | TargetArch.MSP430 | TargetArch.I8086 | TargetArch.Arm | TargetArch.ARM:
                false
            _:
                true

    # Harvard architectures keep program and data memory in separate address
    # spaces (AVR, 8051); everything else here is von Neumann.
    me is_harvard() -> bool:
        match self:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51:
                true
            _:
                false

    me endianness() -> Endian:
        match self:
            TargetArch.MCS51:
                Endian.Big
            _:
                Endian.Little

    me is_8bit() -> bool:
        self.bits() == 8

    me is_16bit() -> bool:
        self.bits() == 16

    me is_32bit() -> bool:
        self.bits() == 32

    me is_64bit() -> bool:
        self.bits() == 64

    # Bare-metal (no-OS) target triple.
    me triple_str_baremetal() -> text:
        match self:
            TargetArch.AVR | TargetArch.Avr:
                "avr-unknown-unknown"
            TargetArch.MCS51:
                "mcs51-unknown-unknown"
            TargetArch.MSP430:
                "msp430-none-elf"
            TargetArch.I8086:
                "i8086-unknown-unknown"
            TargetArch.X86:
                "i686-unknown-none"
            TargetArch.Arm | TargetArch.ARM:
                "thumbv7m-none-eabi"
            TargetArch.Riscv32 | TargetArch.RiscV32:
                "riscv32imac-unknown-none-elf"
            TargetArch.Riscv64 | TargetArch.RiscV64:
                "riscv64gc-unknown-none-elf"
            TargetArch.Wasm32:
                "wasm32-unknown-unknown"
            TargetArch.Wasm64:
                "wasm64-unknown-unknown"
            TargetArch.X86_64 | TargetArch.Host:
                "x86_64-unknown-none"
            TargetArch.Aarch64:
                "aarch64-unknown-none"

    # Hosted (OS-backed, Linux GNU) target triple.
    me triple_str() -> text:
        match self:
            TargetArch.X86:
                "i686-unknown-linux-gnu"
            TargetArch.X86_64 | TargetArch.Host:
                "x86_64-unknown-linux-gnu"
            TargetArch.Arm | TargetArch.ARM:
                "armv7-unknown-linux-gnueabihf"
            TargetArch.Aarch64:
                "aarch64-unknown-linux-gnu"
            TargetArch.Riscv32 | TargetArch.RiscV32:
                "riscv32gc-unknown-linux-gnu"
            TargetArch.Riscv64 | TargetArch.RiscV64:
                "riscv64gc-unknown-linux-gnu"
            TargetArch.Wasm32:
                "wasm32-unknown-unknown"
            TargetArch.Wasm64:
                "wasm64-unknown-unknown"
            _:
                # No hosted OS for these baremetal-only targets; fall back
                # to the baremetal triple.
                self.triple_str_baremetal()

# Pointer width class, independent of the specific architecture.
enum PointerSize:
    Bits16
    Bits32
    Bits64

impl PointerSize:
    me bytes() -> i32:
        match self:
            PointerSize.Bits16:
                2
            PointerSize.Bits32:
                4
            PointerSize.Bits64:
                8

# Parse a target-arch name (including common vendor aliases) into a
# TargetArch. Free function (not TargetArch.parse()) because static methods
# on enums are not supported by the interpreter fallback.
fn parse_target_arch(name: text) -> TargetArch?:
    match name:
        "avr" | "atmega":
            Some(TargetArch.AVR)
        "mcs51" | "8051" | "c51":
            Some(TargetArch.MCS51)
        "msp430":
            Some(TargetArch.MSP430)
        "i8086" | "8086":
            Some(TargetArch.I8086)
        "x86" | "i386" | "i686":
            Some(TargetArch.X86)
        "arm" | "armv7" | "thumb" | "thumbv7m":
            Some(TargetArch.Arm)
        "x86_64" | "x64" | "amd64":
            Some(TargetArch.X86_64)
        "aarch64" | "arm64":
            Some(TargetArch.Aarch64)
        "riscv32" | "rv32":
            Some(TargetArch.Riscv32)
        "riscv64" | "rv64":
            Some(TargetArch.Riscv64)
        "wasm32":
            Some(TargetArch.Wasm32)
        "wasm64":
            Some(TargetArch.Wasm64)
        "host":
            Some(TargetArch.Host)
        _:
            nil

# Per-architecture layout knobs for the tagged-Value runtime representation.
# tag_bits = log2(heap_align): the low zero bits of a heap_align-aligned
# pointer available for inline type tagging. Baremetal 8/16-bit MCUs use a
# compact tagged Value sized to the native pointer; 32/64-bit targets use a
# uniform 8-byte Value slot (so f64/i64 fit inline without extra boxing).
struct TargetConfig:
    pointer_bytes: i32
    value_bytes: i32
    tag_bits: i32
    heap_align: i32
    default_stack_size: i32

impl TargetConfig:
    static fn for_arch(arch: TargetArch) -> TargetConfig:
        match arch:
            TargetArch.AVR | TargetArch.Avr | TargetArch.MCS51:
                TargetConfig(pointer_bytes: 2, value_bytes: 2, tag_bits: 0, heap_align: 1, default_stack_size: 256)
            TargetArch.MSP430 | TargetArch.I8086:
                TargetConfig(pointer_bytes: 2, value_bytes: 2, tag_bits: 1, heap_align: 2, default_stack_size: 512)
            TargetArch.X86 | TargetArch.Arm | TargetArch.ARM | TargetArch.Riscv32 | TargetArch.RiscV32 | TargetArch.Wasm32:
                TargetConfig(pointer_bytes: 4, value_bytes: 8, tag_bits: 2, heap_align: 4, default_stack_size: 8192)
            TargetArch.X86_64 | TargetArch.Aarch64 | TargetArch.Riscv64 | TargetArch.RiscV64 | TargetArch.Wasm64 | TargetArch.Host:
                TargetConfig(pointer_bytes: 8, value_bytes: 8, tag_bits: 3, heap_align: 8, default_stack_size: 1048576)

enum TargetOS:
    Linux
    Windows
    MacOS
    FreeBSD
    Unknown

impl TargetOS:
    static fn host() -> TargetOS:
        TargetOS.Linux

enum Endian:
    Little
    Big

impl Endian:
    static fn host() -> Endian:
        Endian.Little
