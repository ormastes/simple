# SDN Document — higher-level document access over an SdnValue tree.
#
# Provides: SdnDocument, sdn_doc_get, sdn_doc_set, sdn_doc_keys.

use std.common.sdn.value.{SdnValue}

class SdnDocument:
    root: SdnValue
    source_path: text

    static fn from_value(v: SdnValue) -> SdnDocument:
        SdnDocument(root: v, source_path: "")

    static fn from_file(path: text, v: SdnValue) -> SdnDocument:
        SdnDocument(root: v, source_path: path)

    static fn empty() -> SdnDocument:
        SdnDocument(root: SdnValue.Dict({}), source_path: "")

fn sdn_doc_get(doc: SdnDocument, key: text) -> SdnValue:
    match doc.root:
        case Dict(d):
            if d.contains(key):
                d[key]
            else:
                SdnValue.Null
        case _:
            SdnValue.Null

fn sdn_doc_keys(doc: SdnDocument) -> [text]:
    match doc.root:
        case Dict(d):
            d.keys()
        case _:
            []

fn sdn_doc_get_path(doc: SdnDocument, path: text) -> SdnValue:
    val parts = path.split(".")
    var cur = doc.root
    for part in parts:
        match cur:
            case Dict(d):
                if d.contains(part):
                    cur = d[part]
                else:
                    return SdnValue.Null
            case _:
                return SdnValue.Null
    cur
