# SDN Lexer — tokenize SDN source text.
#
# Provides: Token, TokenKind, Lexer, tokenize.

pub enum TokenKind:
    Word
    Colon
    LBracket
    RBracket
    LBrace
    RBrace
    Comma
    Newline

pub class Token:
    kind: TokenKind
    text: text

    static fn make(kind: TokenKind, text: text) -> Token:
        Token(kind: kind, text: text)

pub class Lexer:
    source: text

    static fn new(source: text) -> Lexer:
        Lexer(source: source)

    fn run(self) -> [Token]:
        tokenize(self.source)

fn _punct_kind(ch: text) -> TokenKind:
    if ch == ":":
        return TokenKind.Colon
    if ch == "[":
        return TokenKind.LBracket
    if ch == "]":
        return TokenKind.RBracket
    if ch == "{":
        return TokenKind.LBrace
    if ch == "}":
        return TokenKind.RBrace
    if ch == ",":
        return TokenKind.Comma
    TokenKind.Newline

fn tokenize(source: text) -> [Token]:
    var tokens: [Token] = []
    var cur = ""
    var i = 0
    while i < source.length():
        val ch = source.substring(i, i + 1)
        if ch == " " or ch == "\t":
            if cur != "":
                tokens.push(Token.make(TokenKind.Word, cur))
                cur = ""
        else:
            if ch == ":" or ch == "[" or ch == "]" or ch == "{" or ch == "}" or ch == "," or ch == "\n":
                if cur != "":
                    tokens.push(Token.make(TokenKind.Word, cur))
                    cur = ""
                tokens.push(Token.make(_punct_kind(ch), ch))
            else:
                cur = cur + ch
        i = i + 1
    if cur != "":
        tokens.push(Token.make(TokenKind.Word, cur))
    tokens
