# SDN Value — Simple Data Notation value types.
#
# Provides: SdnValue, Span.

# Source location span for error reporting.
pub class Span:
    line: i64
    column: i64
    start: i64 = 0
    end: i64 = 0

    static fn empty() -> Span:
        Span(line: 0, column: 0, start: 0, end: 0)

    static fn at(line: i64, column: i64) -> Span:
        Span(line: line, column: column, start: 0, end: 0)

    fn merge(self, other: Span) -> Span:
        var lo = self.start
        if other.start < lo:
            lo = other.start
        var hi = self.end
        if other.end > hi:
            hi = other.end
        Span(line: self.line, column: self.column, start: lo, end: hi)

# Keep the recursive map behind a named type. The bootstrap parser can treat
# the `?` after a raw `Dict<K, V>` return type as another enum variant.
type SdnDict = {text: SdnValue}

# The core SDN value type.
pub enum SdnValue:
    Null
    Bool(bool)
    Int(i64)
    Float(f64)
    String(text)
    Array([SdnValue])
    Dict(SdnDict)
    Table(headers: [text], rows: [[SdnValue]])

    static fn null() -> SdnValue:
        SdnValue.Null

    static fn bool(b: bool) -> SdnValue:
        SdnValue.Bool(b)

    static fn int(i: i64) -> SdnValue:
        SdnValue.Int(i)

    static fn float(f: f64) -> SdnValue:
        SdnValue.Float(f)

    static fn string(s: text) -> SdnValue:
        SdnValue.String(s)

    static fn array(items: [SdnValue]) -> SdnValue:
        SdnValue.Array(items)

    static fn empty_array() -> SdnValue:
        SdnValue.Array([])

    static fn empty_dict() -> SdnValue:
        SdnValue.Dict({})

    fn is_null(self) -> bool:
        match self:
            case Null: true
            case _: false

    fn is_bool(self) -> bool:
        match self:
            case Bool(_): true
            case _: false

    fn is_int(self) -> bool:
        match self:
            case Int(_): true
            case _: false

    fn is_float(self) -> bool:
        match self:
            case Float(_): true
            case _: false

    fn is_number(self) -> bool:
        match self:
            case Int(_): true
            case Float(_): true
            case _: false

    fn is_string(self) -> bool:
        match self:
            case String(_): true
            case _: false

    fn is_array(self) -> bool:
        match self:
            case Array(_): true
            case _: false

    fn is_dict(self) -> bool:
        match self:
            case Dict(_): true
            case _: false

    fn is_table(self) -> bool:
        match self:
            case Table(_, _): true
            case _: false

    fn as_bool(self) -> bool?:
        match self:
            case Bool(b): Some(b)
            case _: None

    fn as_i64(self) -> i64?:
        match self:
            case Int(i): Some(i)
            case _: None

    fn as_f64(self) -> f64?:
        match self:
            case Float(f): Some(f)
            case Int(i): Some(i.to_float())
            case _: None

    fn as_str(self) -> text?:
        match self:
            case String(s): Some(s)
            case _: None

    fn as_array(self) -> [SdnValue]?:
        match self:
            case Array(a): Some(a)
            case _: None

    fn as_dict(self) -> SdnDict?:
        match self:
            case Dict(d): Some(d)
            case _: None

    fn get(self, key: text) -> SdnValue?:
        match self:
            case Dict(d):
                if d.contains_key(key):
                    Some(d[key])
                else:
                    None
            case Array(a):
                val idx = _sdn_index(key)
                if idx >= 0 and idx < a.len():
                    Some(a[idx])
                else:
                    None
            case _:
                None

    # Traverse a dotted path (e.g. "config.server.host") through nested dicts,
    # returning None if any segment is missing.
    fn get_path(self, path: text) -> SdnValue?:
        var current = self
        for part in path.split("."):
            match current.get(part):
                case Some(v):
                    current = v
                case None:
                    return None
        Some(current)

    # NOTE: SdnValue is an immutable enum; the interpreter does not propagate
    # in-place mutation of an enum-held collection, so insert/push report
    # whether the operation applies to this variant rather than mutating.
    fn insert(self, key: text, value: SdnValue) -> bool:
        match self:
            case Dict(_): true
            case _: false

    fn push(self, value: SdnValue) -> bool:
        match self:
            case Array(_): true
            case _: false

    fn len(self) -> i64:
        match self:
            case Array(a): a.len()
            case Dict(d): d.len()
            case String(s): s.len()
            case _: 0

    fn type_name(self) -> text:
        match self:
            case Null: "null"
            case Bool(_): "bool"
            case Int(_): "int"
            case Float(_): "float"
            case String(_): "string"
            case Array(_): "array"
            case Dict(_): "dict"
            case Table(_, _): "table"

    fn to_text(self) -> text:
        match self:
            case Null:
                "null"
            case Bool(b):
                if b: "true" else: "false"
            case Int(i):
                i.to_text()
            case Float(f):
                f.to_text()
            case String(s):
                if _sdn_needs_quotes(s): "\"" + s + "\"" else: s
            case Array(items):
                var parts: [text] = []
                for item in items:
                    parts.push(item.to_text())
                "[" + parts.join(", ") + "]"
            case Dict(_):
                "{...}"
            case Table(_, _):
                "[[...]]"

fn _sdn_needs_quotes(s: text) -> bool:
    s == "" or s.contains(" ") or s.contains(":")

# Parse a non-negative array index from a key, or -1 if not all digits.
# (text.to_int_or is unreliable under the interpreter; to_int after a digit
# guard is not.)
fn _sdn_index(key: text) -> i64:
    if key.len() == 0:
        return -1
    val digits = "0123456789"
    var i = 0
    while i < key.len():
        if not digits.contains(key.substring(i, i + 1)):
            return -1
        i = i + 1
    key.to_int()

pub fn sdn_value_to_text(v: SdnValue) -> text:
    v.to_text()

pub fn sdn_value_is_null(v: SdnValue) -> bool:
    v.is_null()
