# SDN - Simple Data Notation
#
# Native Simple implementation of the SDN parser.
# A minimal, token-efficient data notation format.
#
# Usage:
#   from std.sdn import {parse, parse_file, SdnValue}
#
#   val data = parse("name: Alice\nage: 30")
#   val config = parse_file("config.sdn")

