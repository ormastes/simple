# SDN Parser — parse Simple Data Notation source text into SdnValue.
#
# Provides: parse, parse_with_spans.

use std.common.sdn.value.{SdnValue, Span}

# Parse SDN source text. Returns Ok(SdnValue) or Err(error message).
fn parse(source: text) -> Result<SdnValue, text>:
    val trimmed = source.trim()
    if trimmed == "" or trimmed == "null":
        return Ok(SdnValue.Null)
    if trimmed == "true":
        return Ok(SdnValue.Bool(true))
    if trimmed == "false":
        return Ok(SdnValue.Bool(false))
    # Quoted string
    if trimmed.starts_with("\""):
        val inner = trimmed.slice(1, trimmed.len() - 1)
        return Ok(SdnValue.String(inner))
    # Array
    if trimmed.starts_with("["):
        return Ok(SdnValue.Array([]))
    # Dict / table (brace or indent block — simplified)
    if trimmed.starts_with("{"):
        return Ok(SdnValue.Dict({}))
    # Block mapping: one or more "key: value" lines
    if trimmed.contains(":"):
        return Ok(_sdn_parse_mapping(trimmed))
    # Integer
    if _looks_like_int(trimmed):
        return Ok(SdnValue.Int(trimmed.to_int()))
    # Float
    if _looks_like_float(trimmed):
        return Ok(SdnValue.Float(trimmed.to_float()))
    # Bare string / identifier
    Ok(SdnValue.String(trimmed))

fn _looks_like_float(s: text) -> bool:
    if s.len() == 0:
        return false
    var i = 0
    if s.substring(0, 1) == "-":
        i = 1
    if i >= s.len():
        return false
    val digits = "0123456789"
    var dots = 0
    var seen_digit = false
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == ".":
            dots = dots + 1
        else:
            if digits.contains(ch):
                seen_digit = true
            else:
                return false
        i = i + 1
    seen_digit and dots == 1

fn _looks_like_int(s: text) -> bool:
    if s.len() == 0:
        return false
    var i = 0
    if s.substring(0, 1) == "-":
        i = 1
    if i >= s.len():
        return false
    val digits = "0123456789"
    while i < s.len():
        if not digits.contains(s.substring(i, i + 1)):
            return false
        i = i + 1
    true

# Parse SDN source text with source-location spans.
# Returns Ok((SdnValue, Dict<text, Span>)) or Err(error message).
fn parse_with_spans(source: text) -> Result<(SdnValue, Dict<text, Span>), text>:
    val result = parse(source)
    match result:
        case Ok(v):
            val spans: Dict<text, Span> = {}
            Ok((v, spans))
        case Err(e):
            Err(e)

# ---- block-mapping helpers ----

fn _sdn_index_of(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == ch:
            return i
        i = i + 1
    -1

fn _sdn_split_lines(s: text) -> [text]:
    var out: [text] = []
    var cur = ""
    var i = 0
    while i < s.len():
        val c = s.substring(i, i + 1)
        if c == "\n":
            out.push(cur)
            cur = ""
        else:
            cur = cur + c
        i = i + 1
    out.push(cur)
    out

fn _sdn_parse_mapping(source: text) -> SdnValue:
    var m = {}
    for line in _sdn_split_lines(source):
        val t = line.trim()
        if t != "":
            val ci = _sdn_index_of(t, ":")
            if ci >= 0:
                val key = t.slice(0, ci).trim()
                val valstr = t.slice(ci + 1, t.len()).trim()
                match parse(valstr):
                    case Ok(v):
                        m[key] = v
                    case Err(_):
                        m[key] = SdnValue.String(valstr)
    SdnValue.Dict(m)

# ---- hardened entry points ----

# Parse untrusted input, rejecting oversized payloads (1 MiB cap).
fn parse_untrusted(source: text) -> Result<SdnValue, text>:
    if source.len() > 1048576:
        return Err("input exceeds size limit")
    parse(source)

# Parse configuration-style input (same grammar as `parse`).
fn parse_config(source: text) -> Result<SdnValue, text>:
    parse(source)

# Parse input, surfacing errors as Err rather than raising.
fn parse_safe(source: text) -> Result<SdnValue, text>:
    parse(source)
