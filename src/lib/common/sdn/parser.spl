# SDN Parser — parse Simple Data Notation source text into SdnValue.
#
# Provides: parse, parse_with_spans.

use std.common.sdn.value.{SdnValue, Span}

# Parse SDN source text. Returns Ok(SdnValue) or Err(error message).
fn parse(source: text) -> Result<SdnValue, text>:
    val trimmed = source.trim()
    if trimmed == "" or trimmed == "null":
        return Ok(SdnValue.Null)
    if trimmed == "true":
        return Ok(SdnValue.Bool(true))
    if trimmed == "false":
        return Ok(SdnValue.Bool(false))
    # Quoted string
    if trimmed.starts_with("\""):
        val inner = trimmed.slice(1, trimmed.len() - 1)
        return Ok(SdnValue.String(inner))
    # Inline array: [a, b, c]
    if trimmed.starts_with("["):
        return Ok(_sdn_parse_inline_array(trimmed))
    # Inline dict: {key: value, ...}
    if trimmed.starts_with("{"):
        return Ok(_sdn_parse_inline_dict(trimmed))
    # Block mapping: one or more "key: value" / "key = value" lines. Route on a
    # top-level separator so collection entries like `items = [1, 2, 3]` (which
    # contain no top-level `:`) are still parsed as a mapping, not a bare string.
    if _sdn_top_sep(trimmed) >= 0:
        return _sdn_parse_mapping(trimmed)
    # Integer
    if _looks_like_int(trimmed):
        return Ok(SdnValue.Int(trimmed.to_int()))
    # Float
    if _looks_like_float(trimmed):
        return Ok(SdnValue.Float(trimmed.to_float()))
    # Bare string / identifier
    Ok(SdnValue.String(trimmed))

fn _looks_like_float(s: text) -> bool:
    if s.len() == 0:
        return false
    var i = 0
    if s.substring(0, 1) == "-":
        i = 1
    if i >= s.len():
        return false
    val digits = "0123456789"
    var dots = 0
    var seen_digit = false
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == ".":
            dots = dots + 1
        else:
            if digits.contains(ch):
                seen_digit = true
            else:
                return false
        i = i + 1
    seen_digit and dots == 1

fn _looks_like_int(s: text) -> bool:
    if s.len() == 0:
        return false
    var i = 0
    if s.substring(0, 1) == "-":
        i = 1
    if i >= s.len():
        return false
    val digits = "0123456789"
    while i < s.len():
        if not digits.contains(s.substring(i, i + 1)):
            return false
        i = i + 1
    true

# Parse SDN source text with source-location spans.
# Returns Ok((SdnValue, Dict<text, Span>)) or Err(error message).
fn parse_with_spans(source: text) -> Result<(SdnValue, Dict<text, Span>), text>:
    val result = parse(source)
    match result:
        case Ok(v):
            val spans: Dict<text, Span> = {}
            Ok((v, spans))
        case Err(e):
            Err(e)

# ---- block-mapping helpers ----

fn _sdn_index_of(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == ch:
            return i
        i = i + 1
    -1

fn _sdn_split_lines(s: text) -> [text]:
    var out: [text] = []
    var cur = ""
    var i = 0
    while i < s.len():
        val c = s.substring(i, i + 1)
        if c == "\n":
            out.push(cur)
            cur = ""
        else:
            cur = cur + c
        i = i + 1
    out.push(cur)
    out

fn _sdn_parse_mapping(source: text) -> Result<SdnValue, text>:
    val lines = _sdn_split_lines(source)
    match _sdn_parse_block(lines, 0, 0):
        case Ok(result): Ok(result.0)
        case Err(e): Err(e)

# Count leading-space indentation of a line.
fn _sdn_indent(line: text) -> i64:
    val b = line.bytes()
    var i = 0
    var counting = true
    while counting and i < b.len():
        if b[i].to_i64() == 32:
            i = i + 1
        else:
            counting = false
    i

# Parse a block of `key: value` / `key = value` lines whose indentation is
# >= `indent` into a Dict. A key with an empty value followed by more-indented
# lines nests those lines as its value (indent-based hierarchy). Returns the
# Dict and the index of the first line NOT consumed by this block.
fn _sdn_parse_block(lines: [text], start: i64, indent: i64) -> Result<(SdnValue, i64), text>:
    var m = {}
    var i = start
    var running = true
    while running and i < lines.len():
        val line = lines[i]
        if line.trim() == "":
            i = i + 1
        else:
            val ind = _sdn_indent(line)
            if ind < indent:
                running = false
            else:
                val t = line.trim()
                val ci = _sdn_top_sep(t)
                if ci < 0:
                    i = i + 1
                else:
                    val key = t.slice(0, ci).trim()
                    val valstr = t.slice(ci + 1, t.len()).trim()
                    if valstr == "":
                        # Nested block: consume the deeper-indented following lines.
                        match _sdn_parse_block(lines, i + 1, ind + 1):
                            case Ok(child):
                                m[key] = child.0
                                i = child.1
                            case Err(e):
                                return Err(e)
                    else:
                        var value_source = valstr
                        if valstr.starts_with("[") or valstr.starts_with("{"):
                            match _sdn_collection_depth(value_source):
                                case Err(e):
                                    return Err(e)
                                case Ok(initial_depth):
                                    var depth = initial_depth
                                    while depth > 0:
                                        i = i + 1
                                        if i >= lines.len():
                                            return Err("unterminated collection for key '" + key + "'")
                                        value_source = value_source + "\n" + lines[i].trim()
                                        match _sdn_collection_depth(value_source):
                                            case Err(e):
                                                return Err(e)
                                            case Ok(next_depth):
                                                depth = next_depth
                        match parse(value_source):
                            case Ok(v):
                                m[key] = v
                            case Err(e):
                                return Err(e)
                        i = i + 1
    Ok((SdnValue.Dict(m), i))

# Return the number of unclosed collection delimiters, rejecting mismatched
# closers. Delimiters inside quoted strings, including after escaped quotes,
# are data rather than structure.
fn _sdn_collection_depth(s: text) -> Result<i64, text>:
    val b = s.bytes()
    var stack: [i64] = []
    var in_str = false
    var escaped = false
    var i = 0
    while i < b.len():
        val c = b[i].to_i64()
        if in_str:
            if escaped:
                escaped = false
            else:
                if c == 92:       # \
                    escaped = true
                else:
                    if c == 34:   # "
                        in_str = false
        else:
            if c == 34:
                in_str = true
            else:
                if c == 123 or c == 91:       # { or [
                    stack.push(c)
                else:
                    if c == 125 or c == 93:   # } or ]
                        if stack.len() == 0:
                            return Err("unexpected collection closer")
                        val opener = stack[stack.len() - 1]
                        if (c == 125 and opener != 123) or (c == 93 and opener != 91):
                            return Err("mismatched collection closer")
                        stack.pop()
        i = i + 1
    Ok(stack.len())

# Index of the first top-level `=` or `:` separator, skipping any that sit
# inside an inline {}/[] collection or a "" string. Returns -1 if none.
# ponytail: byte-scan assumes ASCII structural chars (SDN keys/seps are ASCII).
fn _sdn_top_sep(s: text) -> i64:
    val b = s.bytes()
    var depth = 0
    var in_str = false
    var escaped = false
    var i = 0
    while i < b.len():
        val c = b[i].to_i64()
        if in_str:
            if escaped:
                escaped = false
            else:
                if c == 92:
                    escaped = true
                else:
                    if c == 34:
                        in_str = false
        else:
            if c == 34:
                in_str = true
            else:
                if c == 123 or c == 91:        # { or [
                    depth = depth + 1
                else:
                    if c == 125 or c == 93:    # } or ]
                        depth = depth - 1
                    else:
                        if depth == 0 and (c == 61 or c == 58):  # = or :
                            return i
        i = i + 1
    -1

# Split on top-level commas or newlines, ignoring separators inside nested
# {}/[] or "". The newline form supports SDN arrays whose entries are written
# one per line without commas.
# Returns trimmed, non-empty parts.
# ponytail: ASCII structural chars only.
fn _sdn_split_top_commas(s: text) -> [text]:
    var out: [text] = []
    val b = s.bytes()
    var depth = 0
    var in_str = false
    var escaped = false
    var start = 0
    var i = 0
    while i < b.len():
        val c = b[i].to_i64()
        if in_str:
            if escaped:
                escaped = false
            else:
                if c == 92:
                    escaped = true
                else:
                    if c == 34:
                        in_str = false
        else:
            if c == 34:
                in_str = true
            else:
                if c == 123 or c == 91:
                    depth = depth + 1
                else:
                    if c == 125 or c == 93:
                        depth = depth - 1
                    else:
                        if depth == 0 and (c == 44 or c == 10):  # , or newline
                            val part = s.slice(start, i).trim()
                            if part != "":
                                out.push(part)
                            start = i + 1
        i = i + 1
    val last = s.slice(start, s.len()).trim()
    if last != "":
        out.push(last)
    out

# Parse an inline array `[a, b, c]` into SdnValue.Array, recursing on elements.
fn _sdn_parse_inline_array(s: text) -> SdnValue:
    val inner = s.slice(1, s.len() - 1).trim()
    var items: [SdnValue] = []
    if inner != "":
        for part in _sdn_split_top_commas(inner):
            match parse(part):
                case Ok(v):
                    items.push(v)
                case Err(_):
                    items.push(SdnValue.String(part))
    SdnValue.Array(items)

# Parse an inline dict `{key: value, ...}` into SdnValue.Dict, recursing on values.
fn _sdn_parse_inline_dict(s: text) -> SdnValue:
    val inner = s.slice(1, s.len() - 1).trim()
    var m = {}
    if inner != "":
        for pair in _sdn_split_top_commas(inner):
            val ci = _sdn_top_sep(pair)
            if ci >= 0:
                val key = pair.slice(0, ci).trim()
                val valstr = pair.slice(ci + 1, pair.len()).trim()
                match parse(valstr):
                    case Ok(v):
                        m[key] = v
                    case Err(_):
                        m[key] = SdnValue.String(valstr)
    SdnValue.Dict(m)

# ---- hardened entry points ----

# Parse untrusted input, rejecting oversized payloads (1 MiB cap).
fn parse_untrusted(source: text) -> Result<SdnValue, text>:
    if source.len() > 1048576:
        return Err("input exceeds size limit")
    parse(source)

# Parse configuration-style input (same grammar as `parse`).
fn parse_config(source: text) -> Result<SdnValue, text>:
    parse(source)

# Parse input, surfacing errors as Err rather than raising.
fn parse_safe(source: text) -> Result<SdnValue, text>:
    parse(source)
