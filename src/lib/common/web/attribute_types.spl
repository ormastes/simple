"""
DOM Attribute Types

Provides the Attr struct representing a key-value pair on a DOM element.
Consumed by ui.browser.dom_bridge.
"""

# ============================================================================
# Attr
# ============================================================================

struct Attr:
    """A single HTML attribute: name + value."""
    name: text
    value: text

fn attr_new(name: text, value: text) -> Attr:
    """Construct an Attr."""
    Attr(name: name, value: value)

fn attrs_get(attrs: [Attr], name: text) -> text:
    """Find an attribute by name, returning "" if absent."""
    var i = 0
    while i < attrs.len():
        if attrs[i].name == name:
            return attrs[i].value
        i = i + 1
    ""

fn attrs_has(attrs: [Attr], name: text) -> bool:
    """Return true if an attribute with the given name exists."""
    var i = 0
    while i < attrs.len():
        if attrs[i].name == name:
            return true
        i = i + 1
    false

fn attrs_set(attrs: [Attr], name: text, value: text) -> [Attr]:
    """Set an attribute by name, inserting if absent, updating if present."""
    var result: [Attr] = []
    var found = false
    var i = 0
    while i < attrs.len():
        if attrs[i].name == name:
            result.push(Attr(name: name, value: value))
            found = true
        else:
            result.push(attrs[i])
        i = i + 1
    if not found:
        result.push(Attr(name: name, value: value))
    result

fn attrs_remove(attrs: [Attr], name: text) -> [Attr]:
    """Remove an attribute by name."""
    var result: [Attr] = []
    var i = 0
    while i < attrs.len():
        if attrs[i].name != name:
            result.push(attrs[i])
        i = i + 1
    result
