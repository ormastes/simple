"""
DOM Node Types

Core types for the browser DOM tree: DomNode, NodeKind, Element, TextNode.
Consumed by ui.browser.dom_bridge and the gc_async_mut browser engine.
"""

# ============================================================================
# NodeKind
# ============================================================================

enum NodeKind:
    """Type discriminant for a DOM node."""
    Document
    Element
    Text
    Comment
    CdataSection
    ProcessingInstruction
    DocumentType
    DocumentFragment

# ============================================================================
# DomNode
# ============================================================================

class DomNode:
    """A node in the browser document tree."""
    node_id: i64
    kind: NodeKind
    parent_id: i64   # -1 for root
    tag_or_text: text
    children: [i64]  # child node_ids

impl DomNode:
    static fn create(node_id: i64, kind: NodeKind, parent_id: i64, tag_or_text: text) -> DomNode:
        """Construct a DomNode with no children."""
        DomNode(
            node_id: node_id,
            kind: kind,
            parent_id: parent_id,
            tag_or_text: tag_or_text,
            children: []
        )

    fn add_child(child_id: i64):
        """Append a child node id."""
        self.children.push(child_id)

    fn is_element() -> bool:
        match self.kind:
            NodeKind.Element: true
            _: false

    fn is_text() -> bool:
        match self.kind:
            NodeKind.Text: true
            _: false

# ============================================================================
# Element
# ============================================================================

class Element:
    """Element node metadata: tag name, attributes, and namespace."""
    node_id: i64
    tag_name: text
    attributes: Dict<text, text>
    namespace: text

impl Element:
    static fn create(node_id: i64, tag_name: text) -> Element:
        Element(node_id: node_id, tag_name: tag_name, attributes: {}, namespace: "")

    fn get_attr(name: text) -> text:
        self.attributes.get(name) ?? ""

    fn has_attr(name: text) -> bool:
        val v = self.attributes.get(name)
        v != nil

    fn set_attr(name: text, value: text):
        self.attributes[name] = value

# ============================================================================
# TextNode
# ============================================================================

class TextNode:
    """Text content node."""
    node_id: i64
    data: text

impl TextNode:
    static fn create(node_id: i64, data: text) -> TextNode:
        TextNode(node_id: node_id, data: data)
