# Web DOM interface — platform-independent HTML/CSS manipulation.
#
# Provides DomBackend trait for element creation, tree manipulation,
# attributes, content, CSS classes, styles, and queries.
# EventBackend trait for event listener registration.
# WebStyle builder for fluent CSS property construction.
#
# Usage:
#   use std.web.dom.{DomBackend, WebElement, create_div, create_button}
#   use std.web.event.{EventBackend, WebEvent, WebEventType}
#   use std.web.style.{WebStyle}
#   use std.web.query.{find, by_id}

use std.common.web.dom.{DomBackend, WebElement, WebDocumentHandle}
use std.common.web.dom.{create_div, create_span, create_p, create_h1, create_h2, create_h3}
use std.common.web.dom.{create_button, create_input, create_img, create_a}
use std.common.web.dom.{create_ul, create_li, create_textarea, create_select, create_option}
use std.common.web.dom.{create_form, create_label}
use std.common.web.event.{EventBackend, WebEvent, WebEventType, event_type_name}
use std.common.web.style.{WebStyle}
use std.common.web.query.{find, find_all, by_id, element_exists, get_body, get_root}
