"""
DOM Backend Interface

Provides DomBackend trait and WebElement type used by web_ui's
EngineDomBackend and any other platform-specific backend implementations.
"""

use std.common.web.node_types.{DomNode, NodeKind}

# ============================================================================
# WebElement
# ============================================================================

class WebElement:
    """A handle to a DOM element, returned by DomBackend operations."""
    element_id: i64
    tag_name: text

impl WebElement:
    static fn create(element_id: i64, tag_name: text) -> WebElement:
        WebElement(element_id: element_id, tag_name: tag_name)

    fn is_valid() -> bool:
        self.element_id > 0

# ============================================================================
# DomBackend trait
# ============================================================================

trait DomBackend:
    """Abstract interface for a DOM implementation.

    Implementors: EngineDomBackend (nogc_sync_mut/web_ui/dom_backend.spl)
    """

    fn create_element(tag_name: text) -> WebElement
    fn create_text_node(data: text) -> WebElement
    fn append_child(parent_id: i64, child_id: i64)
    fn remove_child(parent_id: i64, child_id: i64)
    fn set_attribute(element_id: i64, name: text, value: text)
    fn get_attribute(element_id: i64, name: text) -> text
    fn set_text_content(element_id: i64, text_content: text)
    fn get_text_content(element_id: i64) -> text
    fn set_inner_html(element_id: i64, html: text)
    fn query_selector(selector: text) -> WebElement?
    fn get_element_by_id(id: text) -> WebElement?
    fn body_id() -> i64
