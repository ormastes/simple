#![allow(unnamed_duplicate_typed_args)]
# Small browser-style history state for the Simple browser shells.

class SimpleBrowserNavState:
    entries: [text]
    current_index: i32

    static fn new(seed_url: text) -> SimpleBrowserNavState:
        if seed_url == "":
            return SimpleBrowserNavState(entries: [], current_index: -1)
        SimpleBrowserNavState(entries: [seed_url], current_index: 0)

fn simple_browser_nav_current_url(state: SimpleBrowserNavState) -> text:
    if state.current_index >= 0 and state.current_index < state.entries.len():
        return state.entries[state.current_index]
    ""

fn simple_browser_nav_can_go_back(state: SimpleBrowserNavState) -> bool:
    state.current_index > 0

fn simple_browser_nav_can_go_forward(state: SimpleBrowserNavState) -> bool:
    state.current_index >= 0 and state.current_index < state.entries.len() - 1

fn simple_browser_nav_push(state: SimpleBrowserNavState, url: text) -> SimpleBrowserNavState:
    if url == "":
        return state
    if simple_browser_nav_current_url(state) == url:
        return simple_browser_nav_replace_current(state, url)
    var next_entries: [text] = []
    var idx = 0
    while idx <= state.current_index and idx < state.entries.len():
        next_entries.push(state.entries[idx])
        idx = idx + 1
    next_entries.push(url)
    SimpleBrowserNavState(entries: next_entries, current_index: next_entries.len() - 1)

fn simple_browser_nav_replace_current(state: SimpleBrowserNavState, url: text) -> SimpleBrowserNavState:
    if url == "":
        return state
    if state.current_index < 0 or state.current_index >= state.entries.len():
        return SimpleBrowserNavState(entries: [url], current_index: 0)
    var next_entries: [text] = []
    var idx = 0
    while idx < state.entries.len():
        if idx == state.current_index:
            next_entries.push(url)
        else:
            next_entries.push(state.entries[idx])
        idx = idx + 1
    SimpleBrowserNavState(entries: next_entries, current_index: state.current_index)

fn simple_browser_nav_back_target(state: SimpleBrowserNavState) -> text:
    if not simple_browser_nav_can_go_back(state):
        return ""
    state.entries[state.current_index - 1]

fn simple_browser_nav_forward_target(state: SimpleBrowserNavState) -> text:
    if not simple_browser_nav_can_go_forward(state):
        return ""
    state.entries[state.current_index + 1]

fn simple_browser_nav_move_back(state: SimpleBrowserNavState) -> SimpleBrowserNavState:
    if not simple_browser_nav_can_go_back(state):
        return state
    SimpleBrowserNavState(entries: state.entries, current_index: state.current_index - 1)

fn simple_browser_nav_move_forward(state: SimpleBrowserNavState) -> SimpleBrowserNavState:
    if not simple_browser_nav_can_go_forward(state):
        return state
    SimpleBrowserNavState(entries: state.entries, current_index: state.current_index + 1)

export SimpleBrowserNavState
export simple_browser_nav_current_url
export simple_browser_nav_can_go_back
export simple_browser_nav_can_go_forward
export simple_browser_nav_push
export simple_browser_nav_replace_current
export simple_browser_nav_back_target
export simple_browser_nav_forward_target
export simple_browser_nav_move_back
export simple_browser_nav_move_forward
