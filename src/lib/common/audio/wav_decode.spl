# WAV Decode — RIFF/WAVE bytes to f32 samples, pure Simple
#
# Mirror of wav_encode.spl: parses the two variants that encoder emits
#   audio_format=1 (PCM16) and audio_format=3 (IEEE float32)
# Chunk-walks the RIFF body (does not assume fixed offsets) so it tolerates
# extra chunks (e.g. a `fact` chunk, cbSize padding on the fmt chunk) between
# "RIFF/WAVE" and the "data" chunk, or after it.
#
# PCM16 dequantization (inverse of wav_encode's documented rounding):
#   sample = i16_value / 32768.0
# This is exact for every value wav_encode can produce EXCEPT the encoder's
# own clamp case (source 1.0 -> encoded 32767 -> decoded ~0.999969, never
# back to 1.0 — the trunc-then-clamp quantization is lossy by design, see
# wav_encode.spl's header comment). float32 round-trips bit-exact via
# f32_from_bits, no scaling.

use std.common.binary_io.{f32_from_bits}

# ============================================================================
# Public API
# ============================================================================

class WavAudio:
    samples: [f32]
    sample_rate: i64
    channels: i64

pub fn decode_wav(bytes: [u8]) -> Result<WavAudio, text>:
    """Parse RIFF/WAVE PCM16 or float32 bytes into interleaved f32 samples.
    Unknown chunks between "WAVE" and "data" (or after) are skipped by size,
    not assumed absent. Any other audio_format/bits_per_sample combination is
    rejected with a clear Err."""
    if bytes.len() < 12:
        return Err("wav: truncated header (need >=12 bytes, got {bytes.len()})")
    if not (bytes[0] == 82u8 and bytes[1] == 73u8 and bytes[2] == 70u8 and bytes[3] == 70u8):
        return Err("wav: missing \"RIFF\" tag")
    if not (bytes[8] == 87u8 and bytes[9] == 65u8 and bytes[10] == 86u8 and bytes[11] == 69u8):
        return Err("wav: missing \"WAVE\" tag")

    var pos: i64 = 12
    var audio_format: i64 = -1
    var channels: i64 = 0
    var sample_rate: i64 = 0
    var bits_per_sample: i64 = 0
    var data_start: i64 = -1
    var data_len: i64 = 0
    var fmt_seen = false

    while pos + 8 <= bytes.len():
        val id0 = bytes[pos]
        val id1 = bytes[pos + 1]
        val id2 = bytes[pos + 2]
        val id3 = bytes[pos + 3]
        val csize = _u32_of(bytes[pos + 4], bytes[pos + 5], bytes[pos + 6], bytes[pos + 7])
        val body_start = pos + 8
        if csize < 0 or body_start + csize > bytes.len():
            return Err("wav: chunk at offset {pos} overruns file (declared size={csize})")

        if (id0 == 102u8 and id1 == 109u8 and id2 == 116u8 and id3 == 32u8):
            # "fmt "
            if csize < 16:
                return Err("wav: fmt chunk too small ({csize} bytes, need >=16)")
            audio_format = _u16_of(bytes[body_start], bytes[body_start + 1])
            channels = _u16_of(bytes[body_start + 2], bytes[body_start + 3])
            sample_rate = _u32_of(bytes[body_start + 4], bytes[body_start + 5], bytes[body_start + 6], bytes[body_start + 7])
            bits_per_sample = _u16_of(bytes[body_start + 14], bytes[body_start + 15])
            fmt_seen = true
        elif (id0 == 100u8 and id1 == 97u8 and id2 == 116u8 and id3 == 97u8):
            # "data"
            data_start = body_start
            data_len = csize

        var advance = csize
        if advance % 2 == 1:
            advance = advance + 1
        pos = body_start + advance

    if not fmt_seen:
        return Err("wav: missing \"fmt \" chunk")
    if data_start < 0:
        return Err("wav: missing \"data\" chunk")
    if channels <= 0:
        return Err("wav: invalid channel count {channels}")
    if sample_rate <= 0:
        return Err("wav: invalid sample_rate {sample_rate}")

    var samples: [f32] = []
    val end = data_start + data_len
    if audio_format == 1 and bits_per_sample == 16:
        var i = data_start
        while i + 2 <= end:
            val lo = bytes[i]
            val hi = bytes[i + 1]
            var v = (lo as i64) | ((hi as i64) << 8)
            if v >= 32768:
                v = v - 65536
            val s = (v as f64) / 32768.0
            samples.push(s as f32)
            i = i + 2
    elif audio_format == 3 and bits_per_sample == 32:
        var i = data_start
        while i + 4 <= end:
            val bits = (bytes[i] as u32) | ((bytes[i + 1] as u32) << 8) |
                ((bytes[i + 2] as u32) << 16) | ((bytes[i + 3] as u32) << 24)
            samples.push(f32_from_bits(bits))
            i = i + 4
    else:
        return Err("wav: unsupported format (audio_format={audio_format}, bits_per_sample={bits_per_sample}); supported: PCM16 (format 1, 16-bit), float32 (format 3, 32-bit)")

    Ok(WavAudio(samples: samples, sample_rate: sample_rate, channels: channels))

# ============================================================================
# Internals
# ============================================================================

fn _u16_of(lo: u8, hi: u8) -> i64:
    (lo as i64) | ((hi as i64) << 8)

fn _u32_of(b0: u8, b1: u8, b2: u8, b3: u8) -> i64:
    (b0 as i64) | ((b1 as i64) << 8) | ((b2 as i64) << 16) | ((b3 as i64) << 24)
