#![allow(unnamed_duplicate_typed_args)]
"""Principal — the identity that mints / holds an AuthorityToken.

This release only permits local principals (single-host). The Remote kind
exists as a placeholder for future cross-machine federation but is rejected
by `principal_validate` today.

Feature: spm-winfs-llm-suite AC-1. Pure module.
"""

enum PrincipalKind:
    """Scope of a Principal. Remote is reserved for a future release."""
    Local
    Remote

class Principal:
    """A named identity that can mint or hold tokens."""
    kind: PrincipalKind
    id: text

    static fn default_local(name: text) -> Principal:
        """Construct a local Principal with the given name."""
        Principal(kind: PrincipalKind.Local, id: name)

class PrincipalResult:
    """Validation outcome with a human-readable error."""
    ok: bool
    value: Principal
    error: text

fn principal_is_local(p: Principal) -> bool:
    """True when `p` is a local (same-host) principal."""
    match p.kind:
        case PrincipalKind.Local: true
        case PrincipalKind.Remote: false

fn principal_validate(p: Principal) -> PrincipalResult:
    """Accept local principals with non-empty id; reject remote."""
    if p.id == "":
        return PrincipalResult(ok: false, value: p, error: "empty principal id")
    match p.kind:
        case PrincipalKind.Local: PrincipalResult(ok: true, value: p, error: "")
        case PrincipalKind.Remote: PrincipalResult(ok: false, value: p, error: "remote principals are not supported in this release")

fn principal_local(name: text) -> Principal:
    """Free-fn alias for `Principal.default_local`."""
    Principal.default_local(name)
