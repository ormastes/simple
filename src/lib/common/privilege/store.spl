# Privilege Store — in-memory registry of issued and revoked authority tokens.
#
# Provides: PrivilegeStore — tracks issued tokens and supports revocation checks.

use std.common.privilege.authority_token.{AuthorityToken}

class PrivilegeStore:
    issued: [text]
    revoked: [text]

impl PrivilegeStore:
    static fn new() -> PrivilegeStore:
        PrivilegeStore(issued: [], revoked: [])

    fn register(self, token: AuthorityToken) -> PrivilegeStore:
        val key = token.id_path.path + ":" + token.principal.id
        val new_issued = self.issued.push(key)
        PrivilegeStore(issued: new_issued, revoked: self.revoked)

    fn revoke(self, token: AuthorityToken) -> PrivilegeStore:
        val key = token.id_path.path + ":" + token.principal.id
        val new_revoked = self.revoked.push(key)
        PrivilegeStore(issued: self.issued, revoked: new_revoked)

    fn is_revoked(self, token: AuthorityToken) -> bool:
        val key = token.id_path.path + ":" + token.principal.id
        var i = 0
        while i < self.revoked.len():
            if self.revoked[i] == key:
                return true
            i = i + 1
        false

class DecodeResult:
    ok: bool
    value: PrivilegeStore
    error: text

fn privilege_store_encode(store: PrivilegeStore) -> text:
    var lines: [text] = []
    var i = 0
    while i < store.issued.len():
        lines = lines.push("issued:" + store.issued[i])
        i = i + 1
    var j = 0
    while j < store.revoked.len():
        lines = lines.push("revoked:" + store.revoked[j])
        j = j + 1
    lines.join("\n")

fn privilege_store_decode(data: text) -> DecodeResult:
    val lines = data.split("\n")
    var issued: [text] = []
    var revoked: [text] = []
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("issued:"):
            issued = issued.push(line[7:line.len()])
        elif line.starts_with("revoked:"):
            revoked = revoked.push(line[8:line.len()])
        i = i + 1
    DecodeResult(ok: true, value: PrivilegeStore(issued: issued, revoked: revoked), error: "")

export PrivilegeStore, DecodeResult, privilege_store_encode, privilege_store_decode
