# Privilege IdPath — hierarchical dotted-path identity strings.
#
# An IdPath is a canonical dotted namespace path used to scope authority
# tokens and ACL entries (e.g. "id.public", "app.wiki.notes").

struct IdPath:
    path: text
    intern_id: u32
    segments: [text]

fn _path_hash(path: text) -> u32:
    val bs = path.bytes()
    var h: i64 = 5381
    var i: i64 = 0
    while i < bs.len():
        h = h + (bs[i] as i64) * (i + 1)
        i = i + 1
    h as u32

# Create an IdPath from a dotted-path string.
fn id_path_intern(path: text) -> IdPath:
    IdPath(path: path, intern_id: _path_hash(path), segments: path.split("."))

# Convert an IdPath back to its text representation.
fn id_path_to_text(id: IdPath) -> text:
    id.path

# Return true if prefix.path is a proper prefix of or equal to target.path.
# "a.b" covers "a.b.c" and "a.b" but not "a.bc".
fn id_path_prefix_match(prefix: IdPath, target: IdPath) -> bool:
    val p = prefix.path
    val t = target.path
    if p == t:
        return true
    if t.starts_with(p + "."):
        return true
    false

# Structural equality by path text.
fn id_path_equals(a: IdPath, b: IdPath) -> bool:
    a.path == b.path

struct SubdivideResult:
    ok: bool
    value: IdPath
    error: text

# Mint a child IdPath by appending a single label segment.
# Fails if label is empty or contains a dot.
fn id_path_subdivide(parent: IdPath, label: text) -> SubdivideResult:
    if label == "":
        return SubdivideResult(ok: false, value: parent, error: "empty segment")
    if label.split(".").len() > 1:
        return SubdivideResult(ok: false, value: parent, error: "label contains dot")
    SubdivideResult(ok: true, value: id_path_intern(parent.path + "." + label), error: "")

export IdPath, SubdivideResult
export id_path_intern, id_path_to_text, id_path_prefix_match, id_path_equals, id_path_subdivide
