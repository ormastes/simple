# Generic box model types for layout engines.
# Each layoutable element maps to a LayoutBox with margin, border, and padding geometry.
#
# These types are not tied to any specific rendering context (CSS, GUI toolkit, etc.).

# ---------------------------------------------------------------------------
# BoxKind — the layout formatting type of a box.
# ---------------------------------------------------------------------------

enum BoxKind:
    Block
    Inline
    InlineBlock
    Flex
    Grid
    Table
    TableRow
    TableCell
    None

# ---------------------------------------------------------------------------
# BoxModel — margin, border, and padding edges of a box.
# ---------------------------------------------------------------------------

class BoxModel:
    margin_top: f64
    margin_right: f64
    margin_bottom: f64
    margin_left: f64
    border_top: f64
    border_right: f64
    border_bottom: f64
    border_left: f64
    padding_top: f64
    padding_right: f64
    padding_bottom: f64
    padding_left: f64

    static fn zero() -> BoxModel:
        BoxModel(
            margin_top: 0.0, margin_right: 0.0, margin_bottom: 0.0, margin_left: 0.0,
            border_top: 0.0, border_right: 0.0, border_bottom: 0.0, border_left: 0.0,
            padding_top: 0.0, padding_right: 0.0, padding_bottom: 0.0, padding_left: 0.0
        )

    # Total horizontal margin
    fn margin_horizontal() -> f64:
        self.margin_left + self.margin_right

    # Total vertical margin
    fn margin_vertical() -> f64:
        self.margin_top + self.margin_bottom

    # Total horizontal border
    fn border_horizontal() -> f64:
        self.border_left + self.border_right

    # Total vertical border
    fn border_vertical() -> f64:
        self.border_top + self.border_bottom

    # Total horizontal padding
    fn padding_horizontal() -> f64:
        self.padding_left + self.padding_right

    # Total vertical padding
    fn padding_vertical() -> f64:
        self.padding_top + self.padding_bottom

    # Total horizontal space consumed by box model (margin + border + padding)
    fn total_horizontal() -> f64:
        self.margin_horizontal() + self.border_horizontal() + self.padding_horizontal()

    # Total vertical space consumed by box model (margin + border + padding)
    fn total_vertical() -> f64:
        self.margin_vertical() + self.border_vertical() + self.padding_vertical()

# ---------------------------------------------------------------------------
# LayoutBox — a box positioned in the layout tree.
# ---------------------------------------------------------------------------

class LayoutBox:
    node_id: i64
    kind: BoxKind
    x: f64
    y: f64
    width: f64
    height: f64
    box_model: BoxModel
    children: List<LayoutBox>

    static fn create(node_id: i64, kind: BoxKind) -> LayoutBox:
        LayoutBox(
            node_id: node_id, kind: kind,
            x: 0.0, y: 0.0, width: 0.0, height: 0.0,
            box_model: BoxModel.zero(),
            children: List<LayoutBox>()
        )
