# CSS-style box model — BoxModel, LayoutBox, and BoxKind.
#
# These types are consumed by the browser backend and renderer.
# Consumer call sites:
#   LayoutBox(node_id:, kind:, x:, y:, width:, height:, box_model:, children:)
#   BoxModel.zero()
#   BoxKind.Block / BoxKind.Inline

# ============================================================================
# Box kind
# ============================================================================

enum BoxKind:
    """CSS display type for a layout box."""
    Block
    Inline
    InlineBlock
    Flex
    Grid
    None

# ============================================================================
# Box model (spacing)
# ============================================================================

struct BoxModel:
    """CSS box-model spacing values (in device pixels / CSS px)."""
    margin_top: f64
    margin_right: f64
    margin_bottom: f64
    margin_left: f64
    padding_top: f64
    padding_right: f64
    padding_bottom: f64
    padding_left: f64
    border_top: f64
    border_right: f64
    border_bottom: f64
    border_left: f64

impl BoxModel:
    static fn zero() -> BoxModel:
        """All spacing fields initialised to zero."""
        BoxModel(
            margin_top: 0.0, margin_right: 0.0,
            margin_bottom: 0.0, margin_left: 0.0,
            padding_top: 0.0, padding_right: 0.0,
            padding_bottom: 0.0, padding_left: 0.0,
            border_top: 0.0, border_right: 0.0,
            border_bottom: 0.0, border_left: 0.0
        )

    static fn uniform(margin: f64, padding: f64) -> BoxModel:
        """Convenience: same margin / padding on all four sides."""
        BoxModel(
            margin_top: margin, margin_right: margin,
            margin_bottom: margin, margin_left: margin,
            padding_top: padding, padding_right: padding,
            padding_bottom: padding, padding_left: padding,
            border_top: 0.0, border_right: 0.0,
            border_bottom: 0.0, border_left: 0.0
        )

    fn horizontal_space(self) -> f64:
        """Total horizontal space consumed by margin + padding + border."""
        self.margin_left + self.padding_left + self.border_left +
            self.border_right + self.padding_right + self.margin_right

    fn vertical_space(self) -> f64:
        """Total vertical space consumed by margin + padding + border."""
        self.margin_top + self.padding_top + self.border_top +
            self.border_bottom + self.padding_bottom + self.margin_bottom

# ============================================================================
# Layout box tree node
# ============================================================================

struct LayoutBox:
    """A positioned, sized node in the layout tree.

    `children` is typed as [LayoutBox] to form a recursive tree.
    Consumers build the tree with the named-field constructor:

        LayoutBox(node_id: id, kind: BoxKind.Block,
                  x: 0.0, y: 0.0, width: w, height: h,
                  box_model: BoxModel.zero(),
                  children: [])
    """
    node_id: i64
    kind: BoxKind
    x: f64
    y: f64
    width: f64
    height: f64
    box_model: BoxModel
    children: [LayoutBox]

impl LayoutBox:
    static fn create(node_id: i64, kind: BoxKind) -> LayoutBox:
        """Create a zero-sized box — caller sets x/y/width/height afterwards."""
        LayoutBox(
            node_id: node_id,
            kind: kind,
            x: 0.0, y: 0.0, width: 0.0, height: 0.0,
            box_model: BoxModel.zero(),
            children: []
        )

    fn contains(self, px: f64, py: f64) -> bool:
        """Return true if point (px, py) falls within this box."""
        px >= self.x and px < self.x + self.width and
            py >= self.y and py < self.y + self.height

    fn right(self) -> f64:
        self.x + self.width

    fn bottom(self) -> f64:
        self.y + self.height
