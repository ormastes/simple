# Source-backed color blend and palette helpers.

use std.common.color.types.{Color, from_rgb, from_rgba, black}
use std.common.color.manipulate.{adjust_hue, lighten, darken}

fn _clamp_percent(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 100:
        return 100
    value

fn _overlay_component(base: i64, top: i64) -> i64:
    if base < 128:
        return (2 * base * top) / 255
    255 - (2 * (255 - base) * (255 - top)) / 255

pub fn mix(c1: Color, c2: Color, weight: i64) -> Color:
    val w = _clamp_percent(weight)
    val inv = 100 - w
    from_rgba(
        (c1.r * inv + c2.r * w) / 100,
        (c1.g * inv + c2.g * w) / 100,
        (c1.b * inv + c2.b * w) / 100,
        (c1.a * inv + c2.a * w) / 100
    )

pub fn blend(c1: Color, c2: Color) -> Color:
    mix(c1, c2, 50)

pub fn average(colors) -> Color:
    if colors.length() == 0:
        return black()
    var r = 0
    var g = 0
    var b = 0
    var a = 0
    var i = 0
    while i < colors.length():
        r = r + colors[i].r
        g = g + colors[i].g
        b = b + colors[i].b
        a = a + colors[i].a
        i = i + 1
    from_rgba(r / colors.length(), g / colors.length(), b / colors.length(), a / colors.length())

pub fn multiply(c1: Color, c2: Color) -> Color:
    from_rgba((c1.r * c2.r) / 255, (c1.g * c2.g) / 255, (c1.b * c2.b) / 255, c1.a)

pub fn screen(c1: Color, c2: Color) -> Color:
    from_rgba(
        255 - ((255 - c1.r) * (255 - c2.r)) / 255,
        255 - ((255 - c1.g) * (255 - c2.g)) / 255,
        255 - ((255 - c1.b) * (255 - c2.b)) / 255,
        c1.a
    )

pub fn overlay(c1: Color, c2: Color) -> Color:
    from_rgba(_overlay_component(c1.r, c2.r), _overlay_component(c1.g, c2.g), _overlay_component(c1.b, c2.b), c1.a)

pub fn complement(color: Color) -> Color:
    adjust_hue(color, 180)

pub fn triadic(color: Color):
    [color, adjust_hue(color, 120), adjust_hue(color, 240)]

pub fn analogous(color: Color):
    [adjust_hue(color, -30), color, adjust_hue(color, 30)]

pub fn split_complement(color: Color):
    [color, adjust_hue(color, 150), adjust_hue(color, 210)]

pub fn tetradic(color: Color):
    [color, adjust_hue(color, 90), adjust_hue(color, 180), adjust_hue(color, 270)]

pub fn monochromatic(color: Color):
    [darken(color, 40), darken(color, 20), color, lighten(color, 20), lighten(color, 40)]
