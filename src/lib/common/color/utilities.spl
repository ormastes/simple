# Source-backed color utility helpers.

use std.common.color.types.{Color, from_rgb}

fn _abs(value: i64) -> i64:
    if value < 0:
        return 0 - value
    value

pub fn luminance(color: Color) -> i64:
    (color.r * 299 + color.g * 587 + color.b * 114) / 1000

pub fn contrast_ratio(c1: Color, c2: Color) -> i64:
    val l1 = luminance(c1)
    val l2 = luminance(c2)
    var lighter = l1
    var darker = l2
    if l2 > l1:
        lighter = l2
        darker = l1
    if darker == 0:
        return 2100
    ((lighter + 5) * 100) / (darker + 5)

pub fn is_dark(color: Color) -> bool:
    luminance(color) < 128

pub fn is_light(color: Color) -> bool:
    luminance(color) >= 128

pub fn is_accessible(fg: Color, bg: Color, level: text) -> bool:
    val ratio = contrast_ratio(fg, bg)
    if level == "AAA":
        return ratio >= 700
    ratio >= 450

pub fn color_distance(c1: Color, c2: Color) -> i64:
    val dr = c1.r - c2.r
    val dg = c1.g - c2.g
    val db = c1.b - c2.b
    dr * dr + dg * dg + db * db

pub fn is_similar(c1: Color, c2: Color, threshold: i64) -> bool:
    color_distance(c1, c2) <= threshold

pub fn snap_to_web_safe(value: i64) -> i64:
    if value <= 25: return 0
    if value <= 76: return 51
    if value <= 127: return 102
    if value <= 178: return 153
    if value <= 229: return 204
    255

pub fn web_safe(color: Color) -> Color:
    from_rgb(snap_to_web_safe(color.r), snap_to_web_safe(color.g), snap_to_web_safe(color.b))
