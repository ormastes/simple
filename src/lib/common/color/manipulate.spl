# Source-backed color manipulation helpers.

use std.common.color.types.{Color, from_rgb, from_rgba}
use std.common.color.convert.{rgb_to_hsl, hsl_to_rgb}
use std.common.color.utilities.{luminance}

fn _clamp_byte(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 255:
        return 255
    value

fn _clamp_percent(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 100:
        return 100
    value

fn _normalize_hue(value: i64) -> i64:
    var h = value % 360
    if h < 0:
        h = h + 360
    h

fn _with_alpha(rgb: Color, alpha: i64) -> Color:
    from_rgba(rgb.r, rgb.g, rgb.b, alpha)

pub fn lighten(color: Color, amount: i64) -> Color:
    val hsl = rgb_to_hsl(color)
    _with_alpha(hsl_to_rgb(hsl.0, hsl.1, _clamp_percent(hsl.2 + amount)), color.a)

pub fn darken(color: Color, amount: i64) -> Color:
    val hsl = rgb_to_hsl(color)
    _with_alpha(hsl_to_rgb(hsl.0, hsl.1, _clamp_percent(hsl.2 - amount)), color.a)

pub fn saturate(color: Color, amount: i64) -> Color:
    val hsl = rgb_to_hsl(color)
    _with_alpha(hsl_to_rgb(hsl.0, _clamp_percent(hsl.1 + amount), hsl.2), color.a)

pub fn desaturate(color: Color, amount: i64) -> Color:
    val hsl = rgb_to_hsl(color)
    _with_alpha(hsl_to_rgb(hsl.0, _clamp_percent(hsl.1 - amount), hsl.2), color.a)

pub fn invert(color: Color) -> Color:
    from_rgba(255 - color.r, 255 - color.g, 255 - color.b, color.a)

pub fn grayscale(color: Color) -> Color:
    val gray = luminance(color)
    from_rgba(gray, gray, gray, color.a)

pub fn adjust_hue(color: Color, degrees: i64) -> Color:
    val hsl = rgb_to_hsl(color)
    _with_alpha(hsl_to_rgb(_normalize_hue(hsl.0 + degrees), hsl.1, hsl.2), color.a)

pub fn set_alpha(color: Color, alpha: i64) -> Color:
    from_rgba(color.r, color.g, color.b, _clamp_byte(alpha))
