@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Collection Helpers — Windowing, Chunking, and Zipping

# ============================================================================
# Each Slice / Chunk (#COLL-P1-026)
# ============================================================================

fn each_slice(arr, n: i64, f):
    """Process array in chunks of size n with callback.

    The last chunk may be smaller than n.

    sdoctest:
        var chunks = []
        each_slice([1, 2, 3, 4, 5], 2, \chunk: chunks.push(chunk.len()))
        expect(chunks.len()).to_equal(3)
    """
    if n <= 0:
        return nil

    var i = 0
    while i < arr.len():
        var chunk = []
        var j = 0
        while j < n and (i + j) < arr.len():
            chunk.push(arr[i + j])
            j = j + 1
        f(chunk)
        i = i + n

fn chunk(arr, n: i64):
    """Split array into chunks of size n.

    Returns array of arrays. The last chunk may be smaller.

    sdoctest:
        val result = chunk([1, 2, 3, 4, 5], 2)
        expect(result.len()).to_equal(3)
        expect(result[0].len()).to_equal(2)
        expect(result[2].len()).to_equal(1)
    """
    if n <= 0:
        return []

    var result = []
    var i = 0
    while i < arr.len():
        var c = []
        var j = 0
        while j < n and (i + j) < arr.len():
            c.push(arr[i + j])
            j = j + 1
        result.push(c)
        i = i + n

    result

# ============================================================================
# Pairwise (#COLL-P1-055)
# ============================================================================

fn pairwise(arr):
    """Return consecutive pairs as array of tuples.

    sdoctest:
        val result = pairwise([1, 2, 3, 4])
        expect(result.len()).to_equal(3)
    """
    if arr.len() < 2:
        return []

    var result = []
    var i = 0
    while i < arr.len() - 1:
        result.push((arr[i], arr[i + 1]))
        i = i + 1

    result

# ============================================================================
# Each Cons (Sliding Window) (#COLL-P1-027)
# ============================================================================

fn each_cons(arr, n: i64, f):
    """Sliding window iteration with callback.

    Calls f with each consecutive n-element sub-array.

    sdoctest:
        var windows = []
        each_cons([1, 2, 3, 4, 5], 3, \w: windows.push(w.len()))
        expect(windows.len()).to_equal(3)
    """
    if n <= 0 or n > arr.len():
        return nil

    var i = 0
    while i + n <= arr.len():
        var window = []
        var j = 0
        while j < n:
            window.push(arr[i + j])
            j = j + 1
        f(window)
        i = i + 1

# ============================================================================
# Slice When / Chunk While (#COLL-P1-046, #COLL-P1-047)
# ============================================================================

fn slice_when(arr, pred):
    """Split array when predicate is true between consecutive elements.

    sdoctest:
        val result = slice_when([1, 2, 4, 5, 7], \a, b: b - a > 1)
        expect(result.len()).to_equal(3)
    """
    if arr.len() == 0:
        return []

    var result = []
    var current = [arr[0]]
    var i = 1
    while i < arr.len():
        if pred(arr[i - 1], arr[i]):
            result.push(current)
            current = []
        current.push(arr[i])
        i = i + 1

    if current.len() > 0:
        result.push(current)

    result

fn chunk_while(arr, pred):
    """Chunk consecutive elements while predicate is true.

    sdoctest:
        val result = chunk_while([1, 2, 4, 5, 7], \a, b: b - a <= 1)
        expect(result.len()).to_equal(3)
    """
    if arr.len() == 0:
        return []

    var result = []
    var current = [arr[0]]
    var i = 1
    while i < arr.len():
        if pred(arr[i - 1], arr[i]):
            current.push(arr[i])
        else:
            result.push(current)
            current = [arr[i]]
        i = i + 1

    if current.len() > 0:
        result.push(current)

    result

# ============================================================================
# Zip with Default (#COLL-P1-054)
# ============================================================================

fn zip_longest(arr1, arr2, default1, default2):
    """Zip two arrays with fill values for unequal lengths.

    sdoctest:
        val result = zip_longest([1, 2, 3], ["a", "b"], 0, "z")
        expect(result.len()).to_equal(3)
    """
    var max_len = arr1.len()
    if arr2.len() > max_len:
        max_len = arr2.len()

    var result = []
    var i = 0
    while i < max_len:
        val v1 = if i < arr1.len(): arr1[i] else: default1
        val v2 = if i < arr2.len(): arr2[i] else: default2
        result.push((v1, v2))
        i = i + 1

    result
