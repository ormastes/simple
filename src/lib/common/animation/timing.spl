#![allow(primitive_api)]
# Timing functions for animations and transitions.
# Provides easing curves including linear, ease, ease-in, ease-out, ease-in-out,
# cubic bezier (with Newton-Raphson solver), and step functions.
#
# Extracted from browser animation engine. Works for any animation system.

# ---------------------------------------------------------------------------
# TimingFunction — easing curves for animations and transitions.
# ---------------------------------------------------------------------------

enum TimingFunction:
    Linear
    Ease
    EaseIn
    EaseOut
    EaseInOut
    CubicBezier(x1: f64, y1: f64, x2: f64, y2: f64)
    Steps(count: i64, jump_start: bool)

# ---------------------------------------------------------------------------
# evaluate_timing — apply a timing function to a progress value [0.0, 1.0].
# ---------------------------------------------------------------------------

fn evaluate_timing(timing: TimingFunction, progress: f64) -> f64:
    match timing:
        TimingFunction.Linear:
            progress
        TimingFunction.Ease:
            cubic_bezier_at(progress, 0.25, 0.1, 0.25, 1.0)
        TimingFunction.EaseIn:
            cubic_bezier_at(progress, 0.42, 0.0, 1.0, 1.0)
        TimingFunction.EaseOut:
            cubic_bezier_at(progress, 0.0, 0.0, 0.58, 1.0)
        TimingFunction.EaseInOut:
            cubic_bezier_at(progress, 0.42, 0.0, 0.58, 1.0)
        TimingFunction.CubicBezier(x1, y1, x2, y2):
            cubic_bezier_at(progress, x1, y1, x2, y2)
        TimingFunction.Steps(count, jump_start):
            val step = (progress * count.to_f64()).floor() / count.to_f64()
            if jump_start:
                val step_up = ((progress * count.to_f64()).floor() + 1.0) / count.to_f64()
                if step_up > 1.0: 1.0
                else: step_up
            else:
                step

# ---------------------------------------------------------------------------
# Cubic bezier evaluation using iterative Newton-Raphson to find t for x,
# then evaluate y. The bezier is defined by P0=(0,0), P1=(x1,y1), P2=(x2,y2), P3=(1,1).
# ---------------------------------------------------------------------------

fn cubic_bezier_at(t: f64, p1x: f64, p1y: f64, p2x: f64, p2y: f64) -> f64:
    # Find the parametric t_param such that bezier_x(t_param) == t
    var t_param = t
    # Newton-Raphson iterations
    var i = 0
    while i < 8:
        val x_at = _bezier_component(t_param, p1x, p2x) - t
        val dx_at = _bezier_derivative(t_param, p1x, p2x)
        if dx_at.abs() < 0.00001:
            i = 8
        else:
            t_param = t_param - x_at / dx_at
        i = i + 1

    # Clamp t_param to [0, 1]
    if t_param < 0.0:
        t_param = 0.0
    if t_param > 1.0:
        t_param = 1.0

    _bezier_component(t_param, p1y, p2y)

# ---------------------------------------------------------------------------
# Interpolation helpers.
# ---------------------------------------------------------------------------

# Linear interpolation between two values.
fn interpolate_f64(from: f64, to: f64, t: f64) -> f64:
    from + (to - from) * t

# Linear interpolation for integer values (returns i64).
fn interpolate_i64(from: i64, to: i64, t: f64) -> i64:
    (from.to_f64() + (to.to_f64() - from.to_f64()) * t).to_i64()

# ---------------------------------------------------------------------------
# Parsing helper — convert text keyword to TimingFunction.
# ---------------------------------------------------------------------------

fn parse_timing_function(value: text) -> TimingFunction:
    match value:
        "linear": TimingFunction.Linear
        "ease": TimingFunction.Ease
        "ease-in": TimingFunction.EaseIn
        "ease-out": TimingFunction.EaseOut
        "ease-in-out": TimingFunction.EaseInOut
        _: TimingFunction.Ease

# ---------------------------------------------------------------------------
# Internal bezier math.
# ---------------------------------------------------------------------------

# Evaluate one component of a cubic bezier at parameter t.
# B(t) = 3(1-t)^2*t*p1 + 3(1-t)*t^2*p2 + t^3
fn _bezier_component(t: f64, p1: f64, p2: f64) -> f64:
    val mt = 1.0 - t
    3.0 * mt * mt * t * p1 + 3.0 * mt * t * t * p2 + t * t * t

# Derivative of _bezier_component with respect to t.
fn _bezier_derivative(t: f64, p1: f64, p2: f64) -> f64:
    val mt = 1.0 - t
    3.0 * mt * mt * p1 + 6.0 * mt * t * (p2 - p1) + 3.0 * t * t * (1.0 - p2)
