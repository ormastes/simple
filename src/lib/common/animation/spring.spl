# Damped spring animation for smooth window transitions.

struct SpringConfig:
    stiffness: f64
    damping: f64
    mass: f64

struct SpringAnimation:
    config: SpringConfig
    from_value: f64
    to_value: f64
    velocity: f64
    current: f64
    elapsed: f64
    is_complete: bool

fn spring_step(anim: SpringAnimation, dt: f64) -> SpringAnimation:
    if anim.is_complete:
        return anim
    val displacement = anim.current - anim.to_value
    val spring_force = 0.0 - anim.config.stiffness * displacement
    val damping_force = 0.0 - anim.config.damping * anim.velocity
    val acceleration = (spring_force + damping_force) / anim.config.mass
    val new_velocity = anim.velocity + acceleration * dt
    val new_current = anim.current + new_velocity * dt
    val new_elapsed = anim.elapsed + dt
    val at_rest = spring_is_at_rest_values(new_current, anim.to_value, new_velocity)
    if at_rest:
        return SpringAnimation(
            config: anim.config,
            from_value: anim.from_value,
            to_value: anim.to_value,
            velocity: 0.0,
            current: anim.to_value,
            elapsed: new_elapsed,
            is_complete: true
        )
    SpringAnimation(
        config: anim.config,
        from_value: anim.from_value,
        to_value: anim.to_value,
        velocity: new_velocity,
        current: new_current,
        elapsed: new_elapsed,
        is_complete: false
    )

fn spring_is_at_rest(anim: SpringAnimation) -> bool:
    if anim.is_complete:
        return true
    spring_is_at_rest_values(anim.current, anim.to_value, anim.velocity)

fn spring_is_at_rest_values(current: f64, target: f64, velocity: f64) -> bool:
    val displacement = current - target
    val abs_disp = if displacement < 0.0: 0.0 - displacement else: displacement
    val abs_vel = if velocity < 0.0: 0.0 - velocity else: velocity
    abs_disp < 0.001 and abs_vel < 0.001
