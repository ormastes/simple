# Display detection helpers for GUI-capable system tests.

extern fn rt_env_get(key: text) -> text
extern fn rt_platform_name() -> text

val DISPLAY_NONE: i32 = 0
val DISPLAY_X11: i32 = 1
val DISPLAY_WAYLAND: i32 = 2
val DISPLAY_MACOS: i32 = 3
val DISPLAY_XVFB: i32 = 4

struct DisplayInfo:
    kind: i32
    display_name: text
    is_virtual: bool

fn detect_display() -> DisplayInfo:
    val platform = rt_platform_name()
    if platform == "macos":
        return DisplayInfo(kind: DISPLAY_MACOS, display_name: "macOS", is_virtual: false)

    val wayland = rt_env_get("WAYLAND_DISPLAY")
    if wayland != nil and wayland != "":
        return DisplayInfo(kind: DISPLAY_WAYLAND, display_name: wayland, is_virtual: false)

    val display = rt_env_get("DISPLAY")
    if display != nil and display != "":
        val virtual = display.starts_with(":99") or display.to_lower().contains("xvfb")
        if virtual:
            return DisplayInfo(kind: DISPLAY_XVFB, display_name: display, is_virtual: true)
        return DisplayInfo(kind: DISPLAY_X11, display_name: display, is_virtual: false)

    return DisplayInfo(kind: DISPLAY_NONE, display_name: "", is_virtual: false)

fn display_kind_name(kind: i32) -> text:
    if kind == DISPLAY_NONE:
        return "none"
    if kind == DISPLAY_X11:
        return "X11"
    if kind == DISPLAY_WAYLAND:
        return "Wayland"
    if kind == DISPLAY_MACOS:
        return "macOS"
    if kind == DISPLAY_XVFB:
        return "Xvfb"
    return "unknown"

fn has_any_display() -> bool:
    detect_display().kind != DISPLAY_NONE

fn can_show_gui() -> bool:
    val info = detect_display()
    return info.kind != DISPLAY_NONE and not info.is_virtual
