fn wildcard_match(input: text, pattern: text) -> bool:
    """Match input against a wildcard pattern (. = any char, * = any string)."""
    pass_todo("doctest wildcard_match not yet implemented")
    false

fn exact_match(a: text, b: text) -> bool:
    """Exact match with whitespace normalization."""
    a.trim() == b.trim()

fn normalize(s: text) -> text:
    """Normalize whitespace: strip trailing from each line."""
    var lines = s.split("\n")
    var result = []
    var i = 0
    while i < lines.len():
        result = result.push(lines[i].trim_end())
        i = i + 1
    result.join("\n").trim_end()
