# Doctest Matcher
#
# Matching functions for doctest output verification.
# Provides exact, wildcard, and exception matching for doctest output.

enum MatchResult:
    Pass
    Fail(msg: text)

fn match_output(actual: text, expected: any) -> MatchResult:
    """Match actual output against expected output.

    Normalizes whitespace before comparison. Uses exact_match
    (trailing whitespace stripped per line).
    """
    val expected_text = "{expected}"
    if exact_match(actual, expected_text):
        MatchResult.Pass
    else:
        val norm_actual = normalize(actual)
        val norm_expected = normalize(expected_text)
        MatchResult.Fail("Expected:\n{norm_expected}\nGot:\n{norm_actual}")

fn match_exception(exc_type: text, exc_msg: text, expected: any) -> MatchResult:
    """Match actual exception against expected exception.

    Expected can be a type name string or a "Type: message" format.
    """
    val expected_text = "{expected}"
    if expected_text.contains(":"):
        # "Type: message" format
        val parts = expected_text.split(":")
        val exp_type = parts[0].trim()
        val exp_msg = parts[1].trim()
        if exc_type == exp_type and exc_msg.contains(exp_msg):
            MatchResult.Pass
        else:
            MatchResult.Fail("Expected {exp_type}: {exp_msg}, got {exc_type}: {exc_msg}")
    else:
        # Type-only match
        if exc_type == expected_text.trim():
            MatchResult.Pass
        else:
            MatchResult.Fail("Expected exception type {expected_text}, got {exc_type}")

fn wildcard_match(input: text, pattern: text) -> bool:
    """Match input against a wildcard pattern.

    Supports `...` as a wildcard matching any substring within a line.
    Each line of input is matched against the corresponding line of pattern.
    """
    val input_lines = input.split("\n")
    val pattern_lines = pattern.split("\n")

    if input_lines.len() != pattern_lines.len():
        return false

    var i = 0
    while i < input_lines.len():
        val inp = input_lines[i].trim()
        val pat = pattern_lines[i].trim()

        if pat.contains("..."):
            # Split pattern on "..." and check that all non-wildcard parts
            # appear in the input line
            val segments = pat.split("...")
            var matched = true
            for seg in segments:
                val s = seg.trim()
                if s.len() > 0:
                    if not inp.contains(s):
                        matched = false
            if not matched:
                return false
        elif inp != pat:
            return false

        i = i + 1

    true

fn exact_match(a: text, b: text) -> bool:
    """Exact match with whitespace normalization."""
    a.trim() == b.trim()

fn normalize(s: text) -> text:
    """Normalize whitespace: strip trailing from each line."""
    var lines = s.split("\n")
    var result = []
    var i = 0
    while i < lines.len():
        result = result.push(lines[i].trim_end())
        i = i + 1
    result.join("\n").trim_end()
