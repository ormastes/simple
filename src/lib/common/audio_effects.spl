# Audio Effects — Pure Simple stubs
#
# Mirrors runtime_audio_effects.c (pitch, filters, reverb, delay).
# All functions are stubs returning 0 until miniaudio node-graph support
# is available.  These are the Simple-side implementations of the symbols
# declared as extern fn in audio_sffi.spl.

fn rt_audio_set_pitch(sound_handle: i64, pitch: f64) -> i64:
    0

fn rt_audio_add_lowpass(sound_handle: i64, cutoff_hz: f64) -> i64:
    0

fn rt_audio_add_highpass(sound_handle: i64, cutoff_hz: f64) -> i64:
    0

fn rt_audio_add_reverb(sound_handle: i64, decay: f64, wet_dry: f64) -> i64:
    0

fn rt_audio_add_delay(sound_handle: i64, time_ms: f64, feedback: f64) -> i64:
    0

fn rt_audio_remove_effect(sound_handle: i64, effect_handle: i64) -> i64:
    0

fn rt_audio_clear_effects(sound_handle: i64) -> i64:
    0
