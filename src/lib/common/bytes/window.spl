# ============================================================================
# common/bytes/window.spl — RingWindow sliding history buffer
#
# A fixed-capacity circular history of recent bytes, shared by LZ-style
# back-references and substring search. Maintains the sliding-window distance
# invariant: a byte pushed `d` positions ago is recoverable via `at_distance(d)`
# for 1 <= d <= min(capacity, total_pushed).
#
#   me push(b)              append a byte (evicting the oldest when full)
#   fn at_distance(d)       byte d positions back (d=1 is the most recent)
#   fn match_len(span, off) length of match between recent history and a span
#   me copy_match(d, len)   LZ77 overlapping copy from distance d
# ============================================================================

use lib.common.bytes.span.{ByteSpan}

struct RingWindow:
    """Circular byte history of fixed capacity. `head` is the index where the
    next byte will be written; `filled` is how many slots hold valid data
    (saturates at capacity)."""
    cap: i64
    buf: [u8]
    head: i64
    filled: i64

impl RingWindow:
    static fn new(capacity: i64) -> RingWindow:
        var c = capacity
        if c < 1:
            c = 1
        var b: [u8] = []
        var i = 0
        while i < c:
            b.push(0u8)
            i = i + 1
        RingWindow(cap: c, buf: b, head: 0, filled: 0)

    fn capacity() -> i64:
        self.cap

    fn size() -> i64:
        self.filled

    me push(b: u8):
        self.buf[self.head] = b
        self.head = self.head + 1
        if self.head == self.cap:
            self.head = 0
        if self.filled < self.cap:
            self.filled = self.filled + 1

    fn at_distance(d: i64) -> u8:
        """Byte `d` positions back (d=1 is most recently pushed). Out-of-range
        distances fail closed with 0."""
        if d < 1 or d > self.filled:
            return 0u8
        var idx = self.head - d
        if idx < 0:
            idx = idx + self.cap
        self.buf[idx]

    fn match_len(span: ByteSpan, off: i64) -> i64:
        """Longest prefix of `span` starting at `off` that equals the most-recent
        history bytes (history[ -k .. ] compared against span[off + k ])."""
        if off < 0 or off >= span.len():
            return 0
        var n = 0
        val avail = span.len() - off
        var limit = self.filled
        if avail < limit:
            limit = avail
        while n < limit:
            if self.at_distance(self.filled - n) != span.get(off + n):
                return n
            n = n + 1
        n

    me copy_match(distance: i64, length: i64):
        """LZ77-style copy: append `length` bytes each taken from `distance`
        back. Overlapping copies (distance < length) repeat correctly because
        each pushed byte becomes part of the readable history."""
        var i = 0
        while i < length:
            val b = self.at_distance(distance)
            self.push(b)
            i = i + 1
