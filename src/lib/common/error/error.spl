# Runtime error helpers — pure Simple equivalents of runtime_error.c
#
# SimpleError is the standard runtime error type used by extern fn bindings
# (net, fs, etc.). It is a builtin type; this declaration makes it exportable.
#
# RT_ERROR tagged value: (SPECIAL_ERROR << 3) | TAG_SPECIAL = (3 << 3) | 3 = 27
# RT_NIL  tagged value:  (SPECIAL_NIL   << 3) | TAG_SPECIAL = (0 << 3) | 3 = 3
#
# Note: rt_function_not_found already exists in src/runtime/simple_core/core_memory.spl
# as a stub returning 3 (RT_NIL). The canonical form below returns RT_ERROR (27)
# which is the correct semantics from the C original, but this file intentionally
# does NOT redefine rt_function_not_found to avoid a duplicate-symbol collision
# with core_memory.spl. Only rt_method_not_found is added here (it has no prior stub).

extern class SimpleError:
    """Runtime error type used by extern SFFI bindings (net, fs, etc.)."""
    message: text
    code: i32

pub fn error(message: text) -> SimpleError:
    """Construct a SimpleError with the given message and code 0."""
    SimpleError(message: message, code: 0)

export SimpleError, error, rt_error_value, rt_method_not_found

# RT_ERROR constant: (SPECIAL_ERROR=3 << 3) | TAG_SPECIAL=3 = 27
pub fn rt_error_value() -> i64:
    """Return the canonical RT_ERROR tagged value (27 = 0x1B)."""
    27

# rt_method_not_found — not previously implemented in any .spl file.
# Prints a diagnostic to stderr and returns RT_ERROR (27).
pub fn rt_method_not_found(type_name: text, method_name: text) -> i64:
    """Report that method_name was not found on type_name; returns RT_ERROR."""
    print("Runtime error: Method '{method_name}' not found on type '{type_name}'")
    27
