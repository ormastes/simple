@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Collection Helpers — Transformation and Aggregation

# ============================================================================
# Flat Map (#COLL-P1-013)
# ============================================================================

fn flat_map(arr, f):
    """Map each element then flatten one level.

    The callback should return an array for each input element.

    sdoctest:
        val result = flat_map([1, 2, 3], \x: [x, x * 10])
        expect(result.len()).to_equal(6)
        expect(result[0]).to_equal(1)
        expect(result[1]).to_equal(10)
    """
    var result = []
    for item in arr:
        val sub = f(item)
        for s in sub:
            result.push(s)
    result

# ============================================================================
# Compact Map (#COLL-P1-014)
# ============================================================================

fn compact_map(arr, f):
    """Map then remove nil results.

    sdoctest:
        val result = compact_map([1, 2, 3, 4], \x: if x % 2 == 0: x * 10 else: nil)
        expect(result.len()).to_equal(2)
        expect(result[0]).to_equal(20)
        expect(result[1]).to_equal(40)
    """
    var result = []
    for item in arr:
        val mapped = f(item)
        if mapped != nil:
            result.push(mapped)
    result

# ============================================================================
# Reject / None / One (#COLL-P1-028, #COLL-P1-033)
# ============================================================================

fn reject(arr, pred):
    """Return elements that do NOT match the predicate (inverse of filter).

    sdoctest:
        val result = reject([1, 2, 3, 4, 5], \x: x % 2 == 0)
        expect(result.len()).to_equal(3)
        expect(result[0]).to_equal(1)
    """
    var result = []
    for item in arr:
        if not pred(item):
            result.push(item)
    result

fn none(arr, pred):
    """Return true if NO elements match the predicate.

    sdoctest:
        expect(none([1, 3, 5], \x: x % 2 == 0)).to_equal(true)
        expect(none([1, 2, 3], \x: x % 2 == 0)).to_equal(false)
        expect(none([], \x: true)).to_equal(true)
    """
    for item in arr:
        if pred(item):
            return false
    true

fn one(arr, pred):
    """Return true if EXACTLY one element matches the predicate.

    sdoctest:
        expect(one([1, 2, 3], \x: x == 2)).to_equal(true)
        expect(one([1, 2, 2], \x: x == 2)).to_equal(false)
        expect(one([], \x: true)).to_equal(false)
    """
    var count = 0
    for item in arr:
        if pred(item):
            count = count + 1
            if count > 1:
                return false
    count == 1

# ============================================================================
# Compress (#COLL-P1-056)
# ============================================================================

fn compress(arr, selectors):
    """Filter elements by boolean selector array.

    Returns elements where the corresponding selector is true.

    sdoctest:
        val result = compress(["a", "b", "c", "d"], [true, false, true, false])
        expect(result.len()).to_equal(2)
        expect(result[0]).to_equal("a")
        expect(result[1]).to_equal("c")
    """
    var result = []
    var i = 0
    while i < arr.len() and i < selectors.len():
        if selectors[i]:
            result.push(arr[i])
        i = i + 1
    result

# ============================================================================
# Reduce Right (#COLL-P1-057)
# ============================================================================

fn reduce_right(arr, init, f):
    """Right-fold over array elements.

    Processes elements from right to left.

    sdoctest:
        val result = reduce_right(["a", "b", "c"], "", \acc, x: acc + x)
        expect(result).to_equal("cba")
    """
    var acc = init
    var i = arr.len() - 1
    while i >= 0:
        acc = f(acc, arr[i])
        i = i - 1
    acc

# ============================================================================
# Fill (#COLL-P1-015)
# ============================================================================

fn fill(arr, value):
    """Return new array of same length filled with value.

    sdoctest:
        val result = fill([1, 2, 3], 0)
        expect(result.len()).to_equal(3)
        expect(result[0]).to_equal(0)
        expect(result[2]).to_equal(0)
    """
    var result = []
    var i = 0
    while i < arr.len():
        result.push(value)
        i = i + 1
    result

# ============================================================================
# Tally (#COLL-P1-025)
# ============================================================================

fn tally(arr):
    """Count frequency of each element.

    Returns array of (element, count) tuples in first-seen order.

    sdoctest:
        val result = tally(["a", "b", "a", "c", "b", "a"])
        expect(result.len()).to_equal(3)
    """
    var keys = []
    var counts: {text: i64} = {}

    for item in arr:
        val key = "{item}"
        if counts.has(key):
            counts[key] = counts[key] + 1
        else:
            counts[key] = 1
            keys.push(item)

    var result = []
    for k in keys:
        result.push((k, counts["{k}"]))
    result

# ============================================================================
# Sum By / Product (#COLL-P1-024, #COLL-P1-059)
# ============================================================================

fn sum_by(arr, f):
    """Sum extracted values from array elements.

    sdoctest:
        expect(sum_by(["hi", "hello", "hey"], &:len)).to_equal(10)
        expect(sum_by([], &:len)).to_equal(0)
    """
    var total = 0
    for item in arr:
        total = total + f(item)
    total

fn product(arr):
    """Multiply all numeric elements together.

    Returns 1 for empty arrays.

    sdoctest:
        expect(product([1, 2, 3, 4])).to_equal(24)
        expect(product([])).to_equal(1)
    """
    if arr.len() == 0:
        return 1

    var result = 1
    for item in arr:
        result = result * item
    result
