# SCV byte-exact object store and operation metadata.

use app.io.mod (file_exists, file_read, file_write, file_copy, file_delete, file_size, file_modified_time, dir_create, process_run)
use std.nogc_sync_mut.io.file_ops.{file_read_bytes, file_write_bytes}
use os.crypto.sha256.{sha256}
use std.nogc_sync_mut.database.atomic.{atomic_write}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.scv.core.{scv_repo_dir, scv_meta_dir, scv_objects_dir, scv_parsers_dir, scv_head_path, scv_status_index_path, scv_workspace_path, scv_bookmarks_path, scv_parser_lock_path, scv_langmap_path, scv_parser_index_path, scv_object_index_path, scv_object_path, scv_chunk_path, scv_line_set_contains, scv_metadata_path_safe, scv_object_ref_safe, scv_worktree_path_safe}
use std.scv.core.{scv_state_private, scv_state_valid}

fn scv_write_text(path: text, content: text) -> bool:
    if atomic_write(path, content):
        true
    else:
        file_write(path, content)

fn scv_i64_bytes_to_u8(values: [i64]) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < values.len():
        out.push((values[i] & 0xFF).to_u8())
        i = i + 1
    out

fn scv_text_to_u8(value: text) -> [u8]:
    var out: [u8] = []
    for ch in value:
        out.push((ch.to_i64() & 0xFF).to_u8())
    out

fn scv_hex_nibble(value: i64) -> text:
    "0123456789abcdef".char_at(value & 0x0F)

fn scv_bytes_to_hex(values: [u8]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        val b = values[i].to_i64() & 0xFF
        out = out + scv_hex_nibble(b >> 4) + scv_hex_nibble(b)
        i = i + 1
    out

fn scv_hash_text(prefix: text, value: text) -> text:
    "{prefix}_{scv_bytes_to_hex(sha256(scv_text_to_u8(value)))}"

fn scv_content_id_for_file(path: text) -> text:
    val bytes = scv_i64_bytes_to_u8(file_read_bytes(path) ?? [])
    "sha256_{scv_bytes_to_hex(sha256(bytes))}"

fn scv_content_id_for_bytes(bytes: [i64]) -> text:
    "sha256_{scv_bytes_to_hex(sha256(scv_i64_bytes_to_u8(bytes)))}"

fn scv_content_id_for_u8(bytes: [u8]) -> text:
    "sha256_{scv_bytes_to_hex(sha256(bytes))}"

fn scv_write_chunk_u8(root: text, bytes: [u8]) -> text:
    val id = scv_content_id_for_u8(bytes)
    val dst = scv_chunk_path(root, id)
    if not file_exists(dst):
        file_write_bytes(dst, bytes)
    id

fn scv_chunk_min_size() -> i64:
    2048

fn scv_chunk_max_size() -> i64:
    8192

fn scv_cdc_boundary(rolling: i64, chunk_len: i64) -> bool:
    if chunk_len < scv_chunk_min_size():
        return false
    if chunk_len >= scv_chunk_max_size():
        return true
    (rolling & 0x7FF) == 0

fn scv_write_chunk_bytes(root: text, bytes: [i64]) -> text:
    val id = scv_content_id_for_bytes(bytes)
    val dst = scv_chunk_path(root, id)
    if not file_exists(dst):
        file_write_bytes(dst, scv_i64_bytes_to_u8(bytes))
    id

fn scv_chunk_payload_from_u8(root: text, bytes: [u8]) -> text:
    if bytes.len() <= scv_chunk_min_size():
        return ""
    var payload = "chunks:\n"
    var part: [u8] = []
    var offset = 0
    var rolling = 0
    var i = 0
    while i < bytes.len():
        val value = bytes[i].to_i64() & 0xFF
        part.push(bytes[i])
        rolling = ((rolling * 257) + value + (i % 251)) & 0xFFFFF
        val chunk_len = i - offset + 1
        if scv_cdc_boundary(rolling, chunk_len) or i == bytes.len() - 1:
            val part_id = scv_write_chunk_u8(root, part)
            payload = payload + "{part_id}|{offset}|{part.len()}\n"
            part = []
            offset = i + 1
            rolling = 0
        i = i + 1
    payload

fn scv_file_chunk_payload(root: text, path: text, size: i64) -> text:
    if size <= scv_chunk_min_size():
        return ""
    val bytes = file_read_bytes(path) ?? []
    var payload = "chunks:\n"
    var part: [i64] = []
    var offset = 0
    var rolling = 0
    var i = 0
    while i < bytes.len():
        val value = bytes[i] & 0xFF
        part.push(value)
        rolling = ((rolling * 257) + value + (i % 251)) & 0xFFFFF
        val chunk_len = i - offset + 1
        if scv_cdc_boundary(rolling, chunk_len) or i == bytes.len() - 1:
            val part_id = scv_write_chunk_bytes(root, part)
            payload = payload + "{part_id}|{offset}|{part.len()}\n"
            part = []
            offset = i + 1
            rolling = 0
        i = i + 1
    payload

fn scv_create_parent_dir(path: text) -> bool:
    val parts = path.split("/")
    var current = ""
    var i = 0
    while i < parts.len() - 1:
        val part = parts[i]
        if part == "":
            current = "/"
        elif current == "":
            current = part
        elif current == "/":
            current = "/{part}"
        else:
            current = "{current}/{part}"
        if current != "" and current != "/":
            dir_create(current, true)
        i = i + 1
    true

fn scv_repo_exists(root: text) -> bool:
    file_exists(scv_repo_dir(root)) and file_exists(scv_head_path(root))

fn scv_init_repo(root: text) -> text:
    if scv_repo_exists(root):
        return "already initialized\n"
    dir_create(scv_repo_dir(root), true)
    dir_create(scv_meta_dir(root), true)
    dir_create(scv_objects_dir(root), true)
    dir_create(scv_parsers_dir(root), true)
    for kind in ["chunks", "files", "trees", "commits", "changes", "operations", "conflicts", "syntax", "packs"]:
        dir_create("{scv_objects_dir(root)}/{kind}", true)
    scv_write_text(scv_status_index_path(root), "")
    scv_write_text(scv_workspace_path(root), "default:\n")
    scv_write_text(scv_bookmarks_path(root), "")
    scv_write_text(scv_parser_lock_path(root), "language: fallback-line\nruntime: pure-simple\nversion: builtin\n")
    scv_write_text(scv_langmap_path(root), "")
    scv_write_text(scv_parser_index_path(root), "")
    scv_write_text(scv_object_index_path(root), "")
    val view_payload = "heads:\nbookmarks:\nworkspaces:\ndefault:\n"
    val view_id = scv_hash_text("view", view_payload)
    scv_write_text(scv_object_path(root, "operations", view_id), view_payload)
    val op_payload = "parents:\nview: {view_id}\nmetadata: init\n"
    val op_id = scv_hash_text("op", "{op_payload}{current_time_ms()}")
    scv_write_text(scv_object_path(root, "operations", op_id), op_payload)
    scv_write_text(scv_head_path(root), "{op_id}\n")
    "initialized\n"

fn scv_current_op(root: text) -> text:
    if file_exists(scv_head_path(root)):
        file_read(scv_head_path(root)).trim()
    else:
        ""

fn scv_read_workspace_commit(root: text) -> text:
    if not file_exists(scv_workspace_path(root)):
        return ""
    for line in file_read(scv_workspace_path(root)).split("\n"):
        if line.starts_with("default:"):
            return line[8:].trim()
    ""

fn scv_write_chunk_from_file(root: text, path: text) -> text:
    val id = scv_content_id_for_file(path)
    val dst = scv_chunk_path(root, id)
    if not file_exists(dst):
        file_write_bytes(dst, scv_i64_bytes_to_u8(file_read_bytes(path) ?? []))
    id

fn scv_write_file_object(root: text, rel: text, chunk: text, size: i64, mtime: i64) -> text:
    val payload = "path: {rel}\nchunk: {chunk}\nsize: {size}\nmtime: {mtime}\n{scv_file_chunk_payload(root, \"{root}/{rel}\", size)}"
    val id = scv_hash_text("file", payload)
    val path = scv_object_path(root, "files", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    id

fn scv_write_file_object_from_bytes(root: text, rel: text, bytes: [u8], mtime: i64) -> (text, text):
    val chunk = scv_write_chunk_u8(root, bytes)
    val payload = "path: {rel}\nchunk: {chunk}\nsize: {bytes.len()}\nmtime: {mtime}\n{scv_chunk_payload_from_u8(root, bytes)}"
    val id = scv_hash_text("file", payload)
    val path = scv_object_path(root, "files", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    (id, chunk)

fn scv_write_tree_object(root: text, lines: [text]) -> text:
    var payload = ""
    for line in lines:
        payload = payload + line + "\n"
    val id = scv_hash_text("tree", payload)
    val path = scv_object_path(root, "trees", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    id

fn scv_change_latest(root: text, change_id: text) -> text:
    val path = scv_object_path(root, "changes", change_id)
    if file_exists(path):
        scv_object_field(file_read(path), "latest")
    else:
        ""

fn scv_new_change_id(parent: text, tree: text) -> text:
    val change_payload = if parent == "": "root:{tree}" else: "change-parent:{parent}"
    scv_hash_text("change", change_payload)

fn scv_new_change_id_multi(parents: [text], tree: text) -> text:
    if parents.len() == 0:
        return scv_hash_text("change", "root:{tree}")
    if parents.len() == 1:
        return scv_hash_text("change", "change-parent:{parents[0]}")
    var joined = ""
    var i = 0
    while i < parents.len():
        if i > 0:
            joined = joined + " "
        joined = joined + parents[i]
        i = i + 1
    scv_hash_text("change", "change-merge:{joined}")

fn scv_commit_parents(root: text, commit_id: text) -> [text]:
    val path = scv_object_path(root, "commits", commit_id)
    if not file_exists(path):
        return []
    val parents_field = scv_object_field(file_read(path), "parents")
    var out: [text] = []
    for part in parents_field.split(" "):
        val trimmed = part.trim()
        if trimmed != "":
            out.push(trimmed)
    out

fn scv_write_commit_multi(root: text, parents: [text], tree: text, state: text, author: text, committer: text) -> text:
    val change_id = scv_new_change_id_multi(parents, tree)
    var parents_joined = ""
    var i = 0
    while i < parents.len():
        if i > 0:
            parents_joined = parents_joined + " "
        parents_joined = parents_joined + parents[i]
        i = i + 1
    var payload = "change: {change_id}\nparents: {parents_joined}\ntree: {tree}\nstate: {state}\n"
    if author != "":
        payload = payload + "author: {author}\n"
    if committer != "":
        payload = payload + "committer: {committer}\n"
    val id = scv_hash_text("commit", payload)
    val path = scv_object_path(root, "commits", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    val change_path = scv_object_path(root, "changes", change_id)
    val previous = scv_change_latest(root, change_id)
    val predecessors = if previous != "" and previous != id: previous else: ""
    scv_write_text(change_path, "latest: {id}\npredecessors: {predecessors}\n")
    id

fn scv_write_commit_with_change(root: text, parent: text, tree: text, state: text, change_id: text) -> text:
    val payload = "change: {change_id}\nparents: {parent}\ntree: {tree}\nstate: {state}\n"
    val id = scv_hash_text("commit", payload)
    val path = scv_object_path(root, "commits", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    val change_path = scv_object_path(root, "changes", change_id)
    val previous = scv_change_latest(root, change_id)
    val predecessors = if previous != "" and previous != id: previous else: ""
    scv_write_text(change_path, "latest: {id}\npredecessors: {predecessors}\n")
    id

fn scv_write_commit(root: text, parent: text, tree: text, state: text) -> text:
    scv_write_commit_with_change(root, parent, tree, state, scv_new_change_id(parent, tree))

fn scv_write_tag_object(root: text, name: text, target: text, target_type: text, tagger: text, message: text) -> text:
    dir_create("{scv_objects_dir(root)}/tags", true)
    val payload = "target: {target}\ntype: {target_type}\ntagger: {tagger}\nmessage: {message}\n"
    val id = scv_hash_text("tag", payload)
    val path = scv_object_path(root, "tags", id)
    if not file_exists(path):
        scv_write_text(path, payload)
    id

fn scv_tag_name_valid(name: text) -> bool:
    name != "" and not name.contains("|") and not name.contains("\n") and not name.contains("\r") and not name.contains(" ") and not name.contains("..") and not name.contains("//") and not name.starts_with("/") and not name.ends_with("/")

fn scv_operation_commit_error(root: text, commit: text) -> text:
    if not scv_object_ref_safe(commit, "commit_") or not file_exists(scv_object_path(root, "commits", commit)):
        return "ERROR invalid operation commit\n"
    val content = file_read(scv_object_path(root, "commits", commit))
    val tree = scv_object_field(content, "tree")
    if not scv_object_ref_safe(tree, "tree_") or not file_exists(scv_object_path(root, "trees", tree)):
        return "ERROR invalid operation commit tree\n"
    val state = scv_object_field(content, "state")
    if not scv_state_valid(state):
        return "ERROR invalid operation commit state\n"
    val parents = scv_object_field(content, "parents")
    for parent in parents.split(" "):
        val parent_commit = parent.trim()
        if parent_commit == "":
            continue
        if not scv_object_ref_safe(parent_commit, "commit_") or not file_exists(scv_object_path(root, "commits", parent_commit)):
            return "ERROR invalid operation commit parent\n"
    ""

fn scv_workspace_parent_error(root: text) -> text:
    val parent = scv_read_workspace_commit(root)
    if parent == "":
        return ""
    if not scv_object_ref_safe(parent, "commit_") or not file_exists(scv_object_path(root, "commits", parent)):
        return "ERROR invalid workspace parent\n"
    val commit_error = scv_operation_commit_error(root, parent)
    if commit_error != "":
        return "ERROR invalid workspace parent\n"
    ""

fn scv_write_operation(root: text, parent_op: text, commit: text, metadata: text) -> text:
    val bookmarks = if file_exists(scv_bookmarks_path(root)): file_read(scv_bookmarks_path(root)) else: ""
    if parent_op != "":
        if not scv_object_ref_safe(parent_op, "op_") or not file_exists(scv_object_path(root, "operations", parent_op)):
            return "ERROR invalid operation parent\n"
    val commit_error = scv_operation_commit_error(root, commit)
    if commit_error != "":
        return commit_error
    val bookmark_error = scv_restore_bookmarks_error(root, bookmarks)
    if bookmark_error != "":
        return bookmark_error
    val view_payload = "heads:\n{commit}\nbookmarks:\n{bookmarks}workspaces:\ndefault: {commit}\n"
    val view_id = scv_hash_text("view", view_payload)
    scv_write_text(scv_object_path(root, "operations", view_id), view_payload)
    val payload = "parents: {parent_op}\nview: {view_id}\nmetadata: {metadata}\n"
    val op_id = scv_hash_text("op", "{payload}{current_time_ms()}")
    scv_write_text(scv_object_path(root, "operations", op_id), payload)
    scv_write_text(scv_head_path(root), "{op_id}\n")
    scv_write_text(scv_workspace_path(root), "default: {commit}\n")
    op_id

fn scv_view_section(content: text, start: text, stop: text) -> text:
    var active = false
    var out = ""
    for line in content.split("\n"):
        if line == start:
            active = true
            continue
        if line == stop:
            active = false
        if active:
            out = out + line + "\n"
    out

fn scv_restore_bookmark_name_valid(name: text) -> bool:
    scv_metadata_path_safe(name) and not name.contains(" ")

fn scv_restore_bookmarks_error(root: text, bookmarks: text) -> text:
    var seen = ""
    for line in bookmarks.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 2:
            return "ERROR bad restore bookmark row\n"
        if not scv_restore_bookmark_name_valid(parts[0]):
            return "ERROR invalid restore bookmark name\n"
        val commit = parts[1].trim()
        if not scv_object_ref_safe(commit, "commit_") or not file_exists(scv_object_path(root, "commits", commit)):
            return "ERROR invalid restore bookmark commit\n"
        if scv_line_set_contains(seen, parts[0]):
            return "ERROR duplicate restore bookmark\n"
        seen = seen + parts[0] + "\n"
    ""

fn scv_object_field(content: text, name: text) -> text:
    for line in content.split("\n"):
        if line.starts_with("{name}:"):
            return line[name.len() + 1:].trim()
    ""

fn scv_commit_tree(root: text, commit: text) -> text:
    val path = scv_object_path(root, "commits", commit)
    if file_exists(path):
        scv_object_field(file_read(path), "tree")
    else:
        ""

fn scv_commit_state(root: text, commit: text) -> text:
    val path = scv_object_path(root, "commits", commit)
    if file_exists(path):
        scv_object_field(file_read(path), "state")
    else:
        ""

fn scv_commit_change(root: text, commit: text) -> text:
    val path = scv_object_path(root, "commits", commit)
    if file_exists(path):
        scv_object_field(file_read(path), "change")
    else:
        ""

fn scv_file_chunk(root: text, file_id: text) -> text:
    val path = scv_object_path(root, "files", file_id)
    if file_exists(path):
        scv_object_field(file_read(path), "chunk")
    else:
        ""

fn scv_file_path(root: text, file_id: text) -> text:
    val path = scv_object_path(root, "files", file_id)
    if file_exists(path):
        scv_object_field(file_read(path), "path")
    else:
        ""

fn scv_tree_paths(content: text) -> text:
    var out = ""
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() > 0:
            out = out + parts[0] + "\n"
    out

fn scv_remove_tracked_paths_absent_from_tree(root: text, target_paths: text) -> i64:
    if not file_exists(scv_status_index_path(root)):
        return 0
    var removed = 0
    for line in file_read(scv_status_index_path(root)).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() == 0:
            continue
        val rel = parts[0]
        if not scv_worktree_path_safe(rel):
            continue
        if not scv_line_set_contains(target_paths, rel):
            val dst = "{root}/{rel}"
            if file_exists(dst):
                file_delete(dst)
                removed = removed + 1
    removed

fn scv_restore_tree_entry_error(root: text, parts: [text]) -> text:
    if parts.len() != 5:
        return "ERROR bad tree entry\n"
    val rel = parts[0]
    if not scv_worktree_path_safe(rel):
        return "ERROR unsafe tree path: {rel}\n"
    val chunk = parts[2]
    val size = parts[3].to_i64() ?? -1
    if size < 0:
        return "ERROR bad tree size: {rel}\n"
    val chunk_path = scv_chunk_path(root, chunk)
    if not file_exists(chunk_path):
        return "ERROR missing chunk: {chunk}\n"
    if file_size(chunk_path) != size:
        return "ERROR chunk size mismatch: {chunk}\n"
    if scv_content_id_for_file(chunk_path) != chunk:
        return "ERROR corrupt chunk: {chunk}\n"
    ""

fn scv_restore_commit(root: text, commit: text) -> text:
    val tree = scv_commit_tree(root, commit)
    if tree == "":
        return "ERROR missing commit\n"
    val tree_path = scv_object_path(root, "trees", tree)
    if not file_exists(tree_path):
        return "ERROR missing tree\n"
    val tree_content = file_read(tree_path)
    var seen_paths = ""
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        val error = scv_restore_tree_entry_error(root, parts)
        if error != "":
            return error
        if scv_line_set_contains(seen_paths, parts[0]):
            return "ERROR duplicate tree path: {parts[0]}\n"
        seen_paths = seen_paths + parts[0] + "\n"
    scv_remove_tracked_paths_absent_from_tree(root, scv_tree_paths(tree_content))
    var restored = 0
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        val rel = parts[0]
        val chunk = parts[2]
        val dst = "{root}/{rel}"
        scv_create_parent_dir(dst)
        file_write_bytes(dst, scv_i64_bytes_to_u8(file_read_bytes(scv_chunk_path(root, chunk)) ?? []))
        restored = restored + 1
    scv_write_text(scv_status_index_path(root), tree_content)
    "restored {restored}\n"

fn scv_restore_op(root: text, op: text) -> text:
    if not scv_object_ref_safe(op, "op_"):
        return "ERROR invalid operation id\n"
    val op_path = scv_object_path(root, "operations", op)
    if not file_exists(op_path):
        return "ERROR missing operation\n"
    val view_id = scv_object_field(file_read(op_path), "view")
    if not scv_object_ref_safe(view_id, "view_"):
        return "ERROR invalid view id\n"
    val view_path = scv_object_path(root, "operations", view_id)
    if not file_exists(view_path):
        return "ERROR missing view\n"
    val view_content = file_read(view_path)
    val commit = scv_object_field(view_content, "default")
    if not scv_object_ref_safe(commit, "commit_"):
        return "ERROR invalid restore commit\n"
    val bookmarks = scv_view_section(view_content, "bookmarks:", "workspaces:")
    val bookmark_error = scv_restore_bookmarks_error(root, bookmarks)
    if bookmark_error != "":
        return bookmark_error
    val result = scv_restore_commit(root, commit)
    if result.starts_with("ERROR"):
        return result
    scv_write_text(scv_head_path(root), "{op}\n")
    scv_write_text(scv_workspace_path(root), "default: {commit}\n")
    scv_write_text(scv_bookmarks_path(root), bookmarks)
    result

fn scv_mark_current_state(root: text, state: text) -> text:
    if not scv_state_valid(state):
        return "ERROR invalid state\n"
    val parent_error = scv_workspace_parent_error(root)
    if parent_error != "":
        return parent_error
    val current = scv_read_workspace_commit(root)
    if current == "":
        return "ERROR no current commit\n"
    val tree = scv_commit_tree(root, current)
    val change = scv_commit_change(root, current)
    val next = if change == "": scv_write_commit(root, current, tree, state) else: scv_write_commit_with_change(root, current, tree, state, change)
    val op = scv_write_operation(root, scv_current_op(root), next, "mark-state {state}")
    if op.starts_with("ERROR"):
        return op
    "state {state} {next} {op}\n"
