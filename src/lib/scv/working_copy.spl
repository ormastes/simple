# SCV working-copy scan, status, log, and snapshot.

use app.io.mod (file_exists, file_read, file_size, file_modified_time, dir_walk)
use std.nogc_sync_mut.io.thread.{thread_sleep_ms}
use std.scv.core.{scv_rel_path, scv_is_repo_path, scv_status_index_path, scv_object_path, scv_state_private, scv_line_set_contains, scv_worktree_path_safe}
use std.scv.core.{scv_bookmarks_path}
use std.scv.store.{scv_repo_exists, scv_current_op, scv_read_workspace_commit, scv_workspace_parent_error, scv_write_chunk_from_file, scv_write_file_object, scv_write_tree_object, scv_write_commit, scv_write_operation, scv_write_text, scv_content_id_for_file, scv_commit_tree, scv_commit_state, scv_commit_change, scv_object_field}

fn scv_should_skip(root: text, path: text) -> bool:
    val rel = scv_rel_path(root, path)
    scv_is_repo_path(path) or rel == ".git" or rel.starts_with(".git/") or rel == ".jj" or rel.starts_with(".jj/") or rel == ".simple" or rel.starts_with(".simple/")

fn scv_sort_entries(entries: [text]) -> [text]:
    var remaining: [text] = []
    for entry in entries:
        remaining.push(entry)
    var out: [text] = []
    while remaining.len() > 0:
        var min_value = remaining[0]
        var min_index = 0
        var i = 1
        while i < remaining.len():
            if remaining[i] < min_value:
                min_value = remaining[i]
                min_index = i
            i = i + 1
        out.push(min_value)
        var next: [text] = []
        var j = 0
        while j < remaining.len():
            if j != min_index:
                next.push(remaining[j])
            j = j + 1
        remaining = next
    out

fn scv_line_for_path(index: text, rel: text) -> text:
    for line in index.split("\n"):
        if line.starts_with("{rel}|"):
            return line
    ""

fn scv_line_chunk(line: text) -> text:
    val parts = line.split("|")
    if parts.len() >= 3:
        parts[2]
    else:
        ""

fn scv_snapshot(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val parent_error = scv_workspace_parent_error(root)
    if parent_error != "":
        return parent_error
    var entries: [text] = []
    for path in dir_walk(root):
        if scv_should_skip(root, path):
            continue
        val rel = scv_rel_path(root, path)
        if not scv_worktree_path_safe(rel):
            return "ERROR unsafe path for SCV metadata: {rel}\n"
        val size = file_size(path)
        val mtime = file_modified_time(path)
        val chunk = scv_write_chunk_from_file(root, path)
        val file_id = scv_write_file_object(root, rel, chunk, size, mtime)
        entries.push("{rel}|{file_id}|{chunk}|{size}|{mtime}")
    val sorted = scv_sort_entries(entries)
    var index = ""
    for line in sorted:
        index = index + line + "\n"
    val tree = scv_write_tree_object(root, sorted)
    val parent = scv_read_workspace_commit(root)
    val commit = scv_write_commit(root, parent, tree, scv_state_private())
    val op = scv_write_operation(root, scv_current_op(root), commit, "snapshot")
    if op.starts_with("ERROR"):
        return op
    scv_write_text(scv_status_index_path(root), index)
    "snapshot {commit} {op}\n"

fn scv_auto_snapshot(root: text) -> text:
    val status = scv_status(root)
    if status.starts_with("ERROR"):
        return status
    if status == "clean\n":
        return "auto-snapshot clean\n"
    val result = scv_snapshot(root)
    if result.starts_with("snapshot "):
        "auto-" + result
    else:
        result

fn scv_watch(root: text, iterations: i64, poll_ms: i64) -> text:
    if iterations < 0:
        return "ERROR watch iterations must be >= 0\n"
    if poll_ms < 0:
        return "ERROR watch poll-ms must be >= 0\n"
    var out = "watch iterations={iterations} poll_ms={poll_ms}\n"
    var i = 0
    while iterations == 0 or i < iterations:
        val result = scv_auto_snapshot(root)
        if result.starts_with("ERROR"):
            return result
        out = out + result
        i = i + 1
        if iterations == 0 or i < iterations:
            if poll_ms > 0:
                thread_sleep_ms(poll_ms)
    out

fn scv_status(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val old_index = if file_exists(scv_status_index_path(root)): file_read(scv_status_index_path(root)) else: ""
    var out = ""
    var seen = ""
    for path in dir_walk(root):
        if scv_should_skip(root, path):
            continue
        val rel = scv_rel_path(root, path)
        seen = seen + rel + "\n"
        val old_line = scv_line_for_path(old_index, rel)
        if old_line == "":
            out = out + "A {rel}\n"
        else:
            val old_chunk = scv_line_chunk(old_line)
            val new_chunk = scv_content_id_for_file(path)
            if old_chunk != new_chunk:
                out = out + "M {rel}\n"
    for line in old_index.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        val rel = parts[0]
        if not scv_line_set_contains(seen, rel):
            out = out + "D {rel}\n"
    if out == "":
        "clean\n"
    else:
        out

fn scv_log(root: text) -> text:
    val commit = scv_read_workspace_commit(root)
    if commit == "":
        return "no commits\n"
    val tree = scv_commit_tree(root, commit)
    val state = scv_commit_state(root, commit)
    val change = scv_commit_change(root, commit)
    "commit {commit} change={change} tree={tree} state={state}\n"

fn scv_bookmark_commit(root: text, name: text) -> text:
    val path = scv_bookmarks_path(root)
    if not file_exists(path):
        return ""
    for line in file_read(path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 2 and parts[0] == name:
            return parts[1]
    ""

fn scv_log_branch(root: text, branch: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val head = if branch == "": scv_read_workspace_commit(root) else: scv_bookmark_commit(root, branch)
    if head == "":
        return "no commits\n"
    var out = ""
    var current = head
    var seen = ""
    while current != "" and not scv_line_set_contains(seen, current):
        seen = seen + current + "\n"
        val path = scv_object_path(root, "commits", current)
        if not file_exists(path):
            out = out + "commit_id {current} missing\n"
            current = ""
            continue
        val content = file_read(path)
        val tree = scv_object_field(content, "tree")
        val state = scv_object_field(content, "state")
        val change = scv_object_field(content, "change")
        val parents_field = scv_object_field(content, "parents")
        out = out + "commit_id {current} change={change} tree={tree} state={state}\n"
        val first_parent = if parents_field == "": "" else:
            var fp = ""
            for part in parents_field.split(" "):
                val trimmed = part.trim()
                if trimmed != "" and fp == "":
                    fp = trimmed
            fp
        current = first_parent
    out

fn scv_op_log(root: text) -> text:
    val op = scv_current_op(root)
    if op == "":
        return "no operations\n"
    var out = ""
    var current = op
    var seen = ""
    while current != "" and not scv_line_set_contains(seen, current):
        seen = seen + current + "\n"
        val path = scv_object_path(root, "operations", current)
        if not file_exists(path):
            out = out + "op {current} missing\n"
            current = ""
            continue
        val content = file_read(path)
        var parent = ""
        var metadata = ""
        for line in content.split("\n"):
            if line.starts_with("parents:"):
                parent = line[8:].trim()
            elif line.starts_with("metadata:"):
                metadata = line[9:].trim()
        out = out + "op {current} {metadata}\n"
        current = parent
    out
