# SCV integrity checks.

use app.io.mod (file_exists, file_read, dir_walk, file_size)
use std.scv.core.{scv_objects_dir, scv_object_path, scv_chunk_path, scv_line_set_contains, scv_object_ref_safe, scv_worktree_path_safe}
use std.scv.store.{scv_repo_exists, scv_read_workspace_commit, scv_commit_tree, scv_object_field, scv_content_id_for_file}
use std.scv.integrity_parser.{scv_validate_parser_index, scv_validate_parser_lockfile, scv_validate_langmap}
use std.scv.integrity_view.{scv_validate_current_head, scv_validate_current_bookmarks, scv_validate_current_workspaces, scv_validate_operation_views}
use std.scv.integrity_object.{scv_object_id_from_path, scv_validate_object_index, scv_validate_deterministic_object_hashes}
use std.scv.integrity_commit.{scv_validate_commit_parent_refs, scv_validate_change_refs, scv_validate_commit_change_refs}

fn scv_current_tree_content(root: text) -> text:
    val commit = scv_read_workspace_commit(root)
    if commit == "":
        return ""
    val tree = scv_commit_tree(root, commit)
    if tree == "":
        return ""
    val tree_path = scv_object_path(root, "trees", tree)
    if file_exists(tree_path):
        file_read(tree_path)
    else:
        ""

fn scv_validate_file_chunk_parts(root: text, file_id: text) -> text:
    if not scv_object_ref_safe(file_id, "file_"):
        return "bad file object ref: {file_id}\n"
    val path = scv_object_path(root, "files", file_id)
    if not file_exists(path):
        return "missing file object: {file_id}\n"
    val content = file_read(path)
    var errors = ""
    var in_chunks = false
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "chunks:":
            in_chunks = true
            continue
        if not in_chunks or trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() < 3:
            errors = errors + "bad chunk part: {trimmed}\n"
            continue
        val chunk = parts[0]
        if not scv_object_ref_safe(chunk, "sha256_"):
            errors = errors + "bad chunk part ref: {chunk}\n"
            continue
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk part: {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk part: {chunk}\n"
    errors

fn scv_validate_tree_file_link(root: text, rel: text, file_id: text, chunk: text, size_text: text) -> text:
    if not scv_object_ref_safe(file_id, "file_"):
        return "bad tree file ref: {file_id}\n"
    if not scv_object_ref_safe(chunk, "sha256_"):
        return "bad tree chunk ref: {chunk}\n"
    val path = scv_object_path(root, "files", file_id)
    if not file_exists(path):
        return "missing file object: {file_id}\n"
    val content = file_read(path)
    var errors = ""
    val file_path = scv_object_field(content, "path")
    if file_path != rel:
        errors = errors + "tree file path mismatch: {file_id}\n"
    val file_chunk = scv_object_field(content, "chunk")
    if file_chunk != chunk:
        errors = errors + "tree file chunk mismatch: {file_id}\n"
    val file_size = scv_object_field(content, "size")
    if file_size != size_text:
        errors = errors + "tree file size mismatch: {file_id}\n"
    errors

fn scv_validate_tree_row_object_refs(tree_id: text, file_id: text, chunk: text) -> text:
    val label = if tree_id == "": "" else: "{tree_id} "
    var errors = ""
    if not scv_object_ref_safe(file_id, "file_"):
        errors = errors + "bad tree file ref: {label}{file_id}\n"
    if not scv_object_ref_safe(chunk, "sha256_"):
        errors = errors + "bad tree chunk ref: {label}{chunk}\n"
    errors

fn scv_validate_tree_object_rows(root: text, tree_id: text, content: text) -> text:
    var errors = ""
    var seen_paths = ""
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 5:
            errors = errors + "bad tree entry: {tree_id} {trimmed}\n"
            continue
        if not scv_worktree_path_safe(parts[0]):
            errors = errors + "unsafe tree path: {tree_id} {parts[0]}\n"
        if scv_line_set_contains(seen_paths, parts[0]):
            errors = errors + "duplicate tree path: {tree_id} {parts[0]}\n"
        else:
            seen_paths = seen_paths + parts[0] + "\n"
        val file_id = parts[1]
        val chunk = parts[2]
        val size_text = parts[3]
        val ref_errors = scv_validate_tree_row_object_refs(tree_id, file_id, chunk)
        if ref_errors != "":
            errors = errors + ref_errors
            continue
        val size = size_text.to_i64() ?? -1
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(scv_object_path(root, "files", file_id)):
            errors = errors + "missing file object: {file_id}\n"
        else:
            errors = errors + scv_validate_tree_file_link(root, parts[0], file_id, chunk, size_text)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk: {chunk}\n"
        elif size < 0:
            errors = errors + "bad tree size: {tree_id} {parts[0]}\n"
        elif file_size(chunk_path) != size:
            errors = errors + "chunk size mismatch: {tree_id} {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk: {tree_id} {chunk}\n"
    errors

fn scv_validate_tree_objects(root: text) -> text:
    val trees_dir = "{scv_objects_dir(root)}/trees"
    if not file_exists(trees_dir):
        return ""
    var errors = ""
    for tree_path in dir_walk(trees_dir):
        val tree_id = scv_object_id_from_path(tree_path)
        errors = errors + scv_validate_tree_object_rows(root, tree_id, file_read(tree_path))
    errors

fn scv_fsck(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val tree_content = scv_current_tree_content(root)
    if tree_content == "":
        return "ERROR missing current tree\n"
    var errors = ""
    var checked = 0
    var seen_paths = ""
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 5:
            errors = errors + "bad tree entry: {trimmed}\n"
            continue
        if not scv_worktree_path_safe(parts[0]):
            errors = errors + "unsafe tree path: {parts[0]}\n"
        if scv_line_set_contains(seen_paths, parts[0]):
            errors = errors + "duplicate tree path: {parts[0]}\n"
        else:
            seen_paths = seen_paths + parts[0] + "\n"
        val file_id = parts[1]
        val chunk = parts[2]
        val size_text = parts[3]
        val ref_errors = scv_validate_tree_row_object_refs("", file_id, chunk)
        if ref_errors != "":
            errors = errors + ref_errors
            continue
        val size = parts[3].to_i64() ?? -1
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk: {chunk}\n"
        elif size < 0:
            errors = errors + "bad tree size: {parts[0]}\n"
        elif file_size(chunk_path) != size:
            errors = errors + "chunk size mismatch: {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk: {chunk}\n"
        errors = errors + scv_validate_tree_file_link(root, parts[0], file_id, chunk, size_text)
        errors = errors + scv_validate_file_chunk_parts(root, file_id)
        checked = checked + 1
    errors = errors + scv_validate_parser_index(root)
    errors = errors + scv_validate_parser_lockfile(root)
    errors = errors + scv_validate_langmap(root)
    errors = errors + scv_validate_current_head(root)
    errors = errors + scv_validate_current_bookmarks(root)
    errors = errors + scv_validate_current_workspaces(root)
    errors = errors + scv_validate_operation_views(root)
    errors = errors + scv_validate_commit_parent_refs(root)
    errors = errors + scv_validate_change_refs(root)
    errors = errors + scv_validate_commit_change_refs(root)
    errors = errors + scv_validate_deterministic_object_hashes(root)
    errors = errors + scv_validate_tree_objects(root)
    errors = errors + scv_validate_object_index(root)
    if errors == "":
        "OK checked={checked}\n"
    else:
        "ERROR fsck failed\n{errors}"
