# SCV integrity checks.

use app.io.mod (file_exists, file_read, dir_walk, file_size)
use std.nogc_sync_mut.database.core.{SdnDatabase}
use std.nogc_sync_mut.io.file_ops.{file_read_bytes}
use std.scv.core.{scv_objects_dir, scv_object_path, scv_chunk_path, scv_head_path, scv_parser_index_path, scv_parser_lock_path, scv_parsers_dir, scv_langmap_path, scv_object_index_path, scv_bookmarks_path, scv_workspace_path, scv_line_set_contains, scv_metadata_path_safe, scv_object_ref_safe, scv_worktree_path_safe}
use std.scv.store.{scv_repo_exists, scv_read_workspace_commit, scv_commit_tree, scv_object_field, scv_content_id_for_file, scv_hash_text}

fn scv_current_tree_content(root: text) -> text:
    val commit = scv_read_workspace_commit(root)
    if commit == "":
        return ""
    val tree = scv_commit_tree(root, commit)
    if tree == "":
        return ""
    val tree_path = scv_object_path(root, "trees", tree)
    if file_exists(tree_path):
        file_read(tree_path)
    else:
        ""

fn scv_validate_file_chunk_parts(root: text, file_id: text) -> text:
    if not scv_object_ref_safe(file_id, "file_"):
        return "bad file object ref: {file_id}\n"
    val path = scv_object_path(root, "files", file_id)
    if not file_exists(path):
        return "missing file object: {file_id}\n"
    val content = file_read(path)
    var errors = ""
    var in_chunks = false
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "chunks:":
            in_chunks = true
            continue
        if not in_chunks or trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() < 3:
            errors = errors + "bad chunk part: {trimmed}\n"
            continue
        val chunk = parts[0]
        if not scv_object_ref_safe(chunk, "sha256_"):
            errors = errors + "bad chunk part ref: {chunk}\n"
            continue
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk part: {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk part: {chunk}\n"
    errors

fn scv_validate_tree_file_link(root: text, rel: text, file_id: text, chunk: text, size_text: text) -> text:
    if not scv_object_ref_safe(file_id, "file_"):
        return "bad tree file ref: {file_id}\n"
    if not scv_object_ref_safe(chunk, "sha256_"):
        return "bad tree chunk ref: {chunk}\n"
    val path = scv_object_path(root, "files", file_id)
    if not file_exists(path):
        return "missing file object: {file_id}\n"
    val content = file_read(path)
    var errors = ""
    val file_path = scv_object_field(content, "path")
    if file_path != rel:
        errors = errors + "tree file path mismatch: {file_id}\n"
    val file_chunk = scv_object_field(content, "chunk")
    if file_chunk != chunk:
        errors = errors + "tree file chunk mismatch: {file_id}\n"
    val file_size = scv_object_field(content, "size")
    if file_size != size_text:
        errors = errors + "tree file size mismatch: {file_id}\n"
    errors

fn scv_validate_tree_row_object_refs(tree_id: text, file_id: text, chunk: text) -> text:
    val label = if tree_id == "": "" else: "{tree_id} "
    var errors = ""
    if not scv_object_ref_safe(file_id, "file_"):
        errors = errors + "bad tree file ref: {label}{file_id}\n"
    if not scv_object_ref_safe(chunk, "sha256_"):
        errors = errors + "bad tree chunk ref: {label}{chunk}\n"
    errors

fn scv_validate_syntax_node(root: text, node_id: text, visited: text) -> (text, text):
    if node_id == "" or scv_line_set_contains(visited, node_id):
        return ("", visited)
    if not scv_object_ref_safe(node_id, "syntax_node_"):
        return ("bad syntax node id: {node_id}\n", visited + node_id + "\n")
    val path = scv_object_path(root, "syntax", node_id)
    if not file_exists(path):
        return ("missing syntax node: {node_id}\n", visited + node_id + "\n")
    val content = file_read(path)
    var errors = ""
    val grammar = scv_object_field(content, "grammar")
    val execution = scv_object_field(content, "execution")
    if execution == "":
        errors = errors + "missing syntax execution: {node_id}\n"
    elif grammar == "fallback-binary" and execution != "fallback-binary":
        errors = errors + "syntax execution mismatch: {node_id}\n"
    elif grammar != "fallback-binary" and execution != "fallback-line":
        errors = errors + "syntax execution mismatch: {node_id}\n"
    var next_visited = visited + node_id + "\n"
    for line in content.split("\n"):
        val trimmed = line.trim()
        if not trimmed.starts_with("children:"):
            continue
        val children = trimmed[9:].trim()
        if children == "":
            continue
        for child in children.split(","):
            val child_id = child.trim()
            if child_id == "":
                continue
            val (child_errors, child_visited) = scv_validate_syntax_node(root, child_id, next_visited)
            errors = errors + child_errors
            next_visited = child_visited
    (errors, next_visited)

fn scv_parser_lock_hash(root: text, language: text, grammar: text, version: text) -> text:
    val lock_path = scv_parser_lock_path(root)
    if not file_exists(lock_path):
        return ""
    for line in file_read(lock_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 7 and parts[0] == "parser" and parts[1] == language and parts[2] == grammar and parts[3] == version:
            return parts[6]
    ""

fn scv_parser_wasm_magic_ok(bytes: [i64]) -> bool:
    bytes.len() >= 4 and (bytes[0] & 0xFF) == 0 and (bytes[1] & 0xFF) == 0x61 and (bytes[2] & 0xFF) == 0x73 and (bytes[3] & 0xFF) == 0x6D

fn scv_validate_parser_lockfile(root: text) -> text:
    val lock_path = scv_parser_lock_path(root)
    if not file_exists(lock_path):
        return ""
    var errors = ""
    var seen = ""
    for line in file_read(lock_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 8 or parts[0] != "parser":
            errors = errors + "bad parser lock entry: {trimmed}\n"
            continue
        val key = "{parts[1]}|{parts[2]}"
        if scv_line_set_contains(seen, key):
            errors = errors + "duplicate parser lock entry: {parts[1]} {parts[2]}\n"
        else:
            seen = seen + key + "\n"
        if parts[4] != "wasm":
            errors = errors + "unsupported parser runtime: {parts[4]}\n"
            continue
        val expected_path = "{scv_parsers_dir(root)}/{parts[6]}.wasm"
        val artifact_path = parts[7]
        if artifact_path != expected_path:
            errors = errors + "unsafe parser artifact path: {parts[1]} {parts[2]}\n"
            continue
        if not file_exists(artifact_path):
            errors = errors + "missing parser artifact: {parts[1]} {parts[2]}\n"
            continue
        val raw = file_read_bytes(artifact_path) ?? []
        if not scv_parser_wasm_magic_ok(raw):
            errors = errors + "parser artifact is not wasm: {parts[1]} {parts[2]}\n"
            continue
        val actual = scv_content_id_for_file(artifact_path)
        if actual != parts[6]:
            errors = errors + "parser artifact hash mismatch: {parts[1]} {parts[2]}\n"
    errors

fn scv_langmap_field_safe(value: text) -> bool:
    value != "" and not value.contains("|") and not value.contains("\n") and not value.contains("\r")

fn scv_validate_langmap(root: text) -> text:
    val map_path = scv_langmap_path(root)
    if not file_exists(map_path):
        return ""
    var errors = ""
    var seen = ""
    for line in file_read(map_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 4:
            errors = errors + "bad language mapping entry: {trimmed}\n"
            continue
        if not scv_langmap_field_safe(parts[0]) or not scv_langmap_field_safe(parts[1]) or not scv_langmap_field_safe(parts[2]) or not scv_langmap_field_safe(parts[3]):
            errors = errors + "unsafe language mapping entry: {trimmed}\n"
            continue
        if scv_line_set_contains(seen, parts[0]):
            errors = errors + "duplicate language mapping entry: {parts[0]}\n"
        else:
            seen = seen + parts[0] + "\n"
    errors

fn scv_validate_parser_root_identity(root: text, node_id: text) -> text:
    val path = scv_object_path(root, "syntax", node_id)
    if not file_exists(path):
        return ""
    val content = file_read(path)
    val grammar = scv_object_field(content, "grammar")
    if grammar == "" or grammar.starts_with("fallback-"):
        return ""
    val version = scv_object_field(content, "version")
    val language = scv_object_field(content, "language")
    val parser_hash = scv_object_field(content, "parser_hash")
    if parser_hash == "":
        return "missing parser hash: {node_id}\n"
    val expected = scv_parser_lock_hash(root, language, grammar, version)
    if expected == "":
        return "missing parser lock for syntax node: {node_id} {language} {grammar} {version}\n"
    if expected != parser_hash:
        return "parser hash mismatch: {node_id} {grammar} {version}\n"
    ""

fn scv_validate_parser_index_root_fields(root: text, row: text, node_id: text) -> text:
    val path = scv_object_path(root, "syntax", node_id)
    if not file_exists(path):
        return ""
    val parts = row.split("|")
    if parts.len() < 7:
        return "bad parser index entry: {row}\n"
    val content = file_read(path)
    var errors = ""
    val indexed_path = scv_object_field(content, "path")
    val language = scv_object_field(content, "language")
    val raw = scv_object_field(content, "raw")
    val syntax = scv_object_field(content, "syntax")
    val semantic = scv_object_field(content, "semantic")
    val status = scv_object_field(content, "parse_status")
    if indexed_path != "" and parts[0] != indexed_path:
        errors = errors + "parser index path mismatch: {node_id}\n"
    if language != "" and parts[1] != language:
        errors = errors + "parser index language mismatch: {node_id}\n"
    if raw != "" and parts[2] != raw:
        errors = errors + "parser index raw mismatch: {node_id}\n"
    if syntax != "" and parts[3] != syntax:
        errors = errors + "parser index syntax mismatch: {node_id}\n"
    if semantic != "" and parts[4] != semantic:
        errors = errors + "parser index semantic mismatch: {node_id}\n"
    if status != "" and parts[6] != status:
        errors = errors + "parser index status mismatch: {node_id}\n"
    errors

fn scv_validate_parser_index(root: text) -> text:
    val index_path = scv_parser_index_path(root)
    if not file_exists(index_path):
        return ""
    var errors = ""
    var visited = ""
    for line in file_read(index_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val marker = "|node="
        if not trimmed.contains(marker):
            errors = errors + "bad parser index entry: {trimmed}\n"
            continue
        val pieces = trimmed.split(marker)
        if pieces.len() < 2:
            errors = errors + "bad parser index entry: {trimmed}\n"
            continue
        val node_id = pieces[1].trim()
        val (node_errors, next_visited) = scv_validate_syntax_node(root, node_id, visited)
        errors = errors + node_errors
        errors = errors + scv_validate_parser_index_root_fields(root, trimmed, node_id)
        errors = errors + scv_validate_parser_root_identity(root, node_id)
        visited = next_visited
    errors

fn scv_validate_view_commit_ref(root: text, commit: text, label: text) -> text:
    if commit == "":
        return ""
    if file_exists(scv_object_path(root, "commits", commit)):
        ""
    else:
        "missing view commit: {label} {commit}\n"

fn scv_validate_bookmark_name(name: text) -> bool:
    scv_metadata_path_safe(name) and not name.contains(" ")

fn scv_validate_current_head(root: text) -> text:
    val path = scv_head_path(root)
    if not file_exists(path):
        return "missing HEAD_OP\n"
    val head = file_read(path).trim()
    if not scv_object_ref_safe(head, "op_"):
        return "bad HEAD_OP: {head}\n"
    if not file_exists(scv_object_path(root, "operations", head)):
        return "missing HEAD_OP operation: {head}\n"
    ""

fn scv_validate_view_content(root: text, view_content: text) -> text:
    var errors = ""
    var section = ""
    var seen_bookmarks = ""
    var seen_workspaces = ""
    for line in view_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if trimmed == "heads:" or trimmed == "bookmarks:" or trimmed == "workspaces:":
            section = trimmed
            continue
        if section == "heads:":
            if trimmed.contains("|") or trimmed.contains(" "):
                errors = errors + "bad view head row: {trimmed}\n"
            else:
                errors = errors + scv_validate_view_commit_ref(root, trimmed, "head")
        elif section == "bookmarks:":
            val parts = trimmed.split("|")
            if parts.len() != 2:
                errors = errors + "bad view bookmark row: {trimmed}\n"
                continue
            if not scv_validate_bookmark_name(parts[0]):
                errors = errors + "invalid view bookmark name: {parts[0]}\n"
            if scv_line_set_contains(seen_bookmarks, parts[0]):
                errors = errors + "duplicate view bookmark: {parts[0]}\n"
            else:
                seen_bookmarks = seen_bookmarks + parts[0] + "\n"
            errors = errors + scv_validate_view_commit_ref(root, parts[1].trim(), "bookmark {parts[0]}")
        elif section == "workspaces:":
            val parts = trimmed.split(":")
            if parts.len() != 2:
                errors = errors + "bad view workspace row: {trimmed}\n"
                continue
            val workspace = parts[0].trim()
            val commit = parts[1].trim()
            if not scv_validate_bookmark_name(workspace):
                errors = errors + "invalid view workspace name: {workspace}\n"
            if scv_line_set_contains(seen_workspaces, workspace):
                errors = errors + "duplicate view workspace: {workspace}\n"
            else:
                seen_workspaces = seen_workspaces + workspace + "\n"
            errors = errors + scv_validate_view_commit_ref(root, commit, "workspace {workspace}")
    errors

fn scv_validate_current_bookmarks(root: text) -> text:
    val path = scv_bookmarks_path(root)
    if not file_exists(path):
        return ""
    var errors = ""
    var seen = ""
    for line in file_read(path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 2:
            errors = errors + "bad bookmark row: {trimmed}\n"
            continue
        if not scv_validate_bookmark_name(parts[0]):
            errors = errors + "invalid bookmark name: {parts[0]}\n"
        if scv_line_set_contains(seen, parts[0]):
            errors = errors + "duplicate bookmark: {parts[0]}\n"
        else:
            seen = seen + parts[0] + "\n"
        errors = errors + scv_validate_view_commit_ref(root, parts[1].trim(), "bookmark {parts[0]}")
    errors

fn scv_validate_current_workspaces(root: text) -> text:
    val path = scv_workspace_path(root)
    if not file_exists(path):
        return "missing workspace metadata\n"
    var errors = ""
    var seen = ""
    for line in file_read(path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split(":")
        if parts.len() != 2:
            errors = errors + "bad workspace row: {trimmed}\n"
            continue
        val workspace = parts[0].trim()
        val commit = parts[1].trim()
        if not scv_validate_bookmark_name(workspace):
            errors = errors + "invalid workspace name: {workspace}\n"
        if scv_line_set_contains(seen, workspace):
            errors = errors + "duplicate workspace: {workspace}\n"
        else:
            seen = seen + workspace + "\n"
        errors = errors + scv_validate_view_commit_ref(root, commit, "workspace {workspace}")
    errors

fn scv_validate_operation_views(root: text) -> text:
    val ops_dir = "{scv_objects_dir(root)}/operations"
    if not file_exists(ops_dir):
        return ""
    var errors = ""
    for op_path in dir_walk(ops_dir):
        val op_id = scv_object_id_from_path(op_path)
        val content = file_read(op_path)
        val parents = scv_object_field(content, "parents")
        for parent in parents.split(","):
            val parent_op = parent.trim()
            if parent_op == "":
                continue
            if not scv_object_ref_safe(parent_op, "op_"):
                errors = errors + "bad operation parent ref: {op_id} {parent_op}\n"
                continue
            if not file_exists(scv_object_path(root, "operations", parent_op)):
                errors = errors + "missing operation parent: {op_id} {parent_op}\n"
        val view = scv_object_field(content, "view")
        if view == "":
            continue
        if not scv_object_ref_safe(view, "view_"):
            errors = errors + "bad operation view ref: {op_id} {view}\n"
            continue
        val view_path = scv_object_path(root, "operations", view)
        if not file_exists(view_path):
            errors = errors + "missing operation view: {view}\n"
            continue
        errors = errors + scv_validate_view_content(root, file_read(view_path))
    errors

fn scv_object_id_from_path(path: text) -> text:
    val parts = path.split("/")
    val name = parts[parts.len() - 1]
    if name.ends_with(".sdn"):
        name[0:name.len() - 4]
    elif name.ends_with(".blob"):
        name[0:name.len() - 5]
    else:
        name

fn scv_object_index_expected_path(root: text, kind: text, id: text, indexed_path: text) -> text:
    if kind == "chunks":
        scv_chunk_path(root, id)
    elif kind == "packs":
        indexed_path
    else:
        scv_object_path(root, kind, id)

fn scv_object_index_kind_ok(kind: text) -> bool:
    kind == "chunks" or kind == "files" or kind == "trees" or kind == "commits" or kind == "changes" or kind == "operations" or kind == "conflicts" or kind == "syntax" or kind == "packs"

fn scv_object_index_actual_keys(root: text) -> text:
    var out = ""
    for kind in ["chunks", "files", "trees", "commits", "changes", "operations", "conflicts", "syntax", "packs"]:
        val dir = "{scv_objects_dir(root)}/{kind}"
        if not file_exists(dir):
            continue
        for path in dir_walk(dir):
            out = out + "{kind}|{scv_object_id_from_path(path)}\n"
    out

fn scv_validate_object_index(root: text) -> text:
    val index_path = scv_object_index_path(root)
    if not file_exists(index_path):
        return ""
    val content = file_read(index_path)
    if content.trim() == "":
        return ""
    val db_opt = SdnDatabase.load(index_path)
    if not db_opt.?:
        return "bad object index database\n"
    val db = db_opt.unwrap()
    val table_opt = db.get_table("objects")
    if not table_opt.?:
        return "missing object index table\n"
    val table = table_opt.unwrap()
    var errors = ""
    var seen = ""
    for row in table.rows:
        val id = row.get("id") ?? ""
        val kind = row.get("kind") ?? ""
        val path = row.get("path") ?? ""
        val size = row.get("size") ?? ""
        val valid = row.get("valid") ?? ""
        val key = "{kind}|{id}"
        if id == "" or kind == "" or path == "":
            errors = errors + "bad object index row\n"
            continue
        if not scv_object_index_kind_ok(kind):
            errors = errors + "bad object index kind: {kind}\n"
            continue
        if valid != "true":
            errors = errors + "invalid object index row: {kind} {id}\n"
        if scv_line_set_contains(seen, key):
            errors = errors + "duplicate object index row: {kind} {id}\n"
        else:
            seen = seen + key + "\n"
        val expected_path = scv_object_index_expected_path(root, kind, id, path)
        if kind == "packs" and not path.starts_with("{scv_objects_dir(root)}/packs/"):
            errors = errors + "unsafe object index path: {kind} {id}\n"
        elif path != expected_path:
            errors = errors + "object index path mismatch: {kind} {id}\n"
        if not file_exists(path):
            errors = errors + "missing indexed object: {kind} {id}\n"
        elif size != "{file_size(path)}":
            errors = errors + "object index size mismatch: {kind} {id}\n"
    val actual = scv_object_index_actual_keys(root)
    for key in actual.split("\n"):
        val trimmed = key.trim()
        if trimmed == "":
            continue
        if not scv_line_set_contains(seen, trimmed):
            val parts = trimmed.split("|")
            errors = errors + "missing object index row: {parts[0]} {parts[1]}\n"
    errors

fn scv_expected_object_hash(kind: text, id: text, content: text) -> text:
    if kind == "files":
        scv_hash_text("file", content)
    elif kind == "trees":
        scv_hash_text("tree", content)
    elif kind == "commits":
        scv_hash_text("commit", content)
    elif kind == "conflicts":
        scv_hash_text("conflict", content)
    elif kind == "syntax":
        scv_hash_text("syntax_node", content)
    elif kind == "operations" and id.starts_with("view_"):
        scv_hash_text("view", content)
    else:
        id

fn scv_validate_deterministic_object_dir(root: text, kind: text) -> text:
    val object_dir = "{scv_objects_dir(root)}/{kind}"
    if not file_exists(object_dir):
        return ""
    var errors = ""
    for path in dir_walk(object_dir):
        val id = scv_object_id_from_path(path)
        val expected = scv_expected_object_hash(kind, id, file_read(path))
        if expected != id:
            errors = errors + "object hash mismatch: {kind} {id}\n"
    errors

fn scv_validate_deterministic_object_hashes(root: text) -> text:
    var errors = ""
    errors = errors + scv_validate_deterministic_object_dir(root, "files")
    errors = errors + scv_validate_deterministic_object_dir(root, "trees")
    errors = errors + scv_validate_deterministic_object_dir(root, "commits")
    errors = errors + scv_validate_deterministic_object_dir(root, "conflicts")
    errors = errors + scv_validate_deterministic_object_dir(root, "syntax")
    errors = errors + scv_validate_deterministic_object_dir(root, "operations")
    errors

fn scv_validate_tree_object_rows(root: text, tree_id: text, content: text) -> text:
    var errors = ""
    var seen_paths = ""
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 5:
            errors = errors + "bad tree entry: {tree_id} {trimmed}\n"
            continue
        if not scv_worktree_path_safe(parts[0]):
            errors = errors + "unsafe tree path: {tree_id} {parts[0]}\n"
        if scv_line_set_contains(seen_paths, parts[0]):
            errors = errors + "duplicate tree path: {tree_id} {parts[0]}\n"
        else:
            seen_paths = seen_paths + parts[0] + "\n"
        val file_id = parts[1]
        val chunk = parts[2]
        val size_text = parts[3]
        val ref_errors = scv_validate_tree_row_object_refs(tree_id, file_id, chunk)
        if ref_errors != "":
            errors = errors + ref_errors
            continue
        val size = size_text.to_i64() ?? -1
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(scv_object_path(root, "files", file_id)):
            errors = errors + "missing file object: {file_id}\n"
        else:
            errors = errors + scv_validate_tree_file_link(root, parts[0], file_id, chunk, size_text)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk: {chunk}\n"
        elif size < 0:
            errors = errors + "bad tree size: {tree_id} {parts[0]}\n"
        elif file_size(chunk_path) != size:
            errors = errors + "chunk size mismatch: {tree_id} {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk: {tree_id} {chunk}\n"
    errors

fn scv_validate_tree_objects(root: text) -> text:
    val trees_dir = "{scv_objects_dir(root)}/trees"
    if not file_exists(trees_dir):
        return ""
    var errors = ""
    for tree_path in dir_walk(trees_dir):
        val tree_id = scv_object_id_from_path(tree_path)
        errors = errors + scv_validate_tree_object_rows(root, tree_id, file_read(tree_path))
    errors

fn scv_validate_commit_parent_refs(root: text) -> text:
    val commits_dir = "{scv_objects_dir(root)}/commits"
    if not file_exists(commits_dir):
        return ""
    var errors = ""
    for commit_path in dir_walk(commits_dir):
        val commit_id = scv_object_id_from_path(commit_path)
        val parents = scv_object_field(file_read(commit_path), "parents")
        for parent in parents.split(","):
            val parent_commit = parent.trim()
            if parent_commit == "":
                continue
            if not scv_object_ref_safe(parent_commit, "commit_"):
                errors = errors + "bad commit parent ref: {commit_id} {parent_commit}\n"
                continue
            if not file_exists(scv_object_path(root, "commits", parent_commit)):
                errors = errors + "missing commit parent: {commit_id} {parent_commit}\n"
    errors

fn scv_validate_change_refs(root: text) -> text:
    val changes_dir = "{scv_objects_dir(root)}/changes"
    if not file_exists(changes_dir):
        return ""
    var errors = ""
    for change_path in dir_walk(changes_dir):
        val change_id = scv_object_id_from_path(change_path)
        val content = file_read(change_path)
        val latest = scv_object_field(content, "latest")
        if latest == "":
            errors = errors + "missing change latest: {change_id}\n"
        elif not scv_object_ref_safe(latest, "commit_"):
            errors = errors + "bad change latest ref: {change_id} {latest}\n"
        elif not file_exists(scv_object_path(root, "commits", latest)):
            errors = errors + "missing change latest commit: {change_id} {latest}\n"
        val predecessors = scv_object_field(content, "predecessors")
        for predecessor in predecessors.split(","):
            val commit = predecessor.trim()
            if commit == "":
                continue
            if not scv_object_ref_safe(commit, "commit_"):
                errors = errors + "bad change predecessor ref: {change_id} {commit}\n"
                continue
            if not file_exists(scv_object_path(root, "commits", commit)):
                errors = errors + "missing change predecessor commit: {change_id} {commit}\n"
    errors

fn scv_validate_commit_change_refs(root: text) -> text:
    val commits_dir = "{scv_objects_dir(root)}/commits"
    if not file_exists(commits_dir):
        return ""
    var errors = ""
    for commit_path in dir_walk(commits_dir):
        val commit_id = scv_object_id_from_path(commit_path)
        val change = scv_object_field(file_read(commit_path), "change")
        if change == "":
            errors = errors + "missing commit change: {commit_id}\n"
        elif not scv_object_ref_safe(change, "change_"):
            errors = errors + "bad commit change ref: {commit_id} {change}\n"
        elif not file_exists(scv_object_path(root, "changes", change)):
            errors = errors + "missing commit change object: {commit_id} {change}\n"
    errors

fn scv_fsck(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val tree_content = scv_current_tree_content(root)
    if tree_content == "":
        return "ERROR missing current tree\n"
    var errors = ""
    var checked = 0
    var seen_paths = ""
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() != 5:
            errors = errors + "bad tree entry: {trimmed}\n"
            continue
        if not scv_worktree_path_safe(parts[0]):
            errors = errors + "unsafe tree path: {parts[0]}\n"
        if scv_line_set_contains(seen_paths, parts[0]):
            errors = errors + "duplicate tree path: {parts[0]}\n"
        else:
            seen_paths = seen_paths + parts[0] + "\n"
        val file_id = parts[1]
        val chunk = parts[2]
        val size_text = parts[3]
        val ref_errors = scv_validate_tree_row_object_refs("", file_id, chunk)
        if ref_errors != "":
            errors = errors + ref_errors
            continue
        val size = parts[3].to_i64() ?? -1
        val chunk_path = scv_chunk_path(root, chunk)
        if not file_exists(chunk_path):
            errors = errors + "missing chunk: {chunk}\n"
        elif size < 0:
            errors = errors + "bad tree size: {parts[0]}\n"
        elif file_size(chunk_path) != size:
            errors = errors + "chunk size mismatch: {chunk}\n"
        elif scv_content_id_for_file(chunk_path) != chunk:
            errors = errors + "corrupt chunk: {chunk}\n"
        errors = errors + scv_validate_tree_file_link(root, parts[0], file_id, chunk, size_text)
        errors = errors + scv_validate_file_chunk_parts(root, file_id)
        checked = checked + 1
    errors = errors + scv_validate_parser_index(root)
    errors = errors + scv_validate_parser_lockfile(root)
    errors = errors + scv_validate_langmap(root)
    errors = errors + scv_validate_current_head(root)
    errors = errors + scv_validate_current_bookmarks(root)
    errors = errors + scv_validate_current_workspaces(root)
    errors = errors + scv_validate_operation_views(root)
    errors = errors + scv_validate_commit_parent_refs(root)
    errors = errors + scv_validate_change_refs(root)
    errors = errors + scv_validate_commit_change_refs(root)
    errors = errors + scv_validate_deterministic_object_hashes(root)
    errors = errors + scv_validate_tree_objects(root)
    errors = errors + scv_validate_object_index(root)
    if errors == "":
        "OK checked={checked}\n"
    else:
        "ERROR fsck failed\n{errors}"
