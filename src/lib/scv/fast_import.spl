# SCV bounded Git fast-import interchange.

use app.io.mod (file_exists, file_read)
use std.nogc_sync_mut.io.file_ops.{file_read_bytes, file_write_bytes}
use std.scv.core.{scv_object_path, scv_chunk_path}
use std.scv.integrity.{scv_current_tree_content}
use std.scv.store.{scv_repo_exists, scv_read_workspace_commit, scv_workspace_parent_error, scv_commit_tree, scv_object_field, scv_create_parent_dir, scv_i64_bytes_to_u8, scv_write_text, scv_write_file_object_from_bytes, scv_write_tree_object, scv_write_commit, scv_write_commit_multi, scv_commit_parents, scv_write_tag_object, scv_write_operation, scv_current_op}
use std.scv.core.{scv_state_private}
use std.scv.refs.{scv_tag_set, scv_tag_get, scv_tag_list, scv_tag_annotated_set, scv_tag_annotated_get, scv_tag_annotated_list, scv_bookmark_set}
use std.scv.fast_import_format.{scv_git_ref_safe, scv_fast_import_path_safe, scv_fast_import_quote_path, scv_fast_import_split_command, scv_fast_import_bytes_line, scv_fast_import_next_line_pos, scv_fast_import_skip_data_payload, scv_fast_import_mark_seen, scv_fast_import_mark_ref_safe, scv_fast_import_commit_branch_error, scv_fast_import_parent_ref_error, scv_fast_import_reset_ref_error, scv_fast_import_tag_record_error, scv_fast_import_tag_ref_safe}

fn scv_fast_append_bytes(target: [u8], source: [u8]) -> [u8]:
    var out = target
    for b in source:
        out.push(b)
    out

fn scv_fast_append_text_bytes(target: [u8], value: text) -> [u8]:
    scv_fast_append_bytes(target, value.bytes())

fn scv_fast_import_file_primary_bytes(root: text, file_id: text) -> [u8]:
    val file_path = scv_object_path(root, "files", file_id)
    if not file_exists(file_path):
        return []
    val chunk = scv_object_field(file_read(file_path), "chunk")
    if chunk == "":
        return []
    scv_i64_bytes_to_u8(file_read_bytes(scv_chunk_path(root, chunk)) ?? [])

fn scv_fast_import_commit_all_parents(root: text, commit: text) -> [text]:
    val path = scv_object_path(root, "commits", commit)
    if not file_exists(path):
        return []
    val parents_field = scv_object_field(file_read(path), "parents")
    var out: [text] = []
    for part in parents_field.split(" "):
        val trimmed = part.trim()
        if trimmed != "":
            out.push(trimmed)
    out

fn scv_fast_import_commit_first_parent(root: text, commit: text) -> text:
    val parents = scv_fast_import_commit_all_parents(root, commit)
    if parents.len() > 0:
        parents[0]
    else:
        ""

fn scv_fast_import_tree_content_by_commit(root: text, commit: text) -> text:
    val tree = scv_commit_tree(root, commit)
    if tree == "":
        return ""
    val tree_path = scv_object_path(root, "trees", tree)
    if file_exists(tree_path):
        file_read(tree_path)
    else:
        ""

fn scv_fast_import_tree_content_has_path(tree_content: text, rel: text) -> bool:
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() > 0 and parts[0] == rel:
            return true
    false

fn scv_fast_import_blob_for_mark(marks: [text], payloads: [[u8]], mark: text) -> ([u8], bool):
    var i = 0
    while i < marks.len():
        if marks[i] == mark:
            return (payloads[i], true)
        i = i + 1
    ([], false)

fn scv_fast_import_tree_without_path(tree_lines: [text], rel: text) -> [text]:
    var out: [text] = []
    for entry in tree_lines:
        val trimmed = entry.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() > 0 and parts[0] == rel:
            continue
        out.push(trimmed)
    out

fn scv_fast_import_tree_has_path(tree_lines: [text], rel: text) -> bool:
    for entry in tree_lines:
        val trimmed = entry.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() > 0 and parts[0] == rel:
            return true
    false

fn scv_fast_import_tree_file_id_for_path(tree_lines: [text], rel: text) -> text:
    for entry in tree_lines:
        val trimmed = entry.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 2 and parts[0] == rel:
            return parts[1]
    ""

fn scv_fast_import_current_tree_lines(root: text) -> [text]:
    var out: [text] = []
    for line in scv_current_tree_content(root).split("\n"):
        val trimmed = line.trim()
        if trimmed != "":
            out.push(trimmed)
    out

# Resolve a mark (:N) or commit_id to an SCV commit id using a mark→commit table
fn scv_fast_import_resolve_commit_ref(ref: text, commit_marks: [text], commit_ids: [text]) -> text:
    if ref.starts_with(":"):
        val mark = ref[1:]
        var i = 0
        while i < commit_marks.len():
            if commit_marks[i] == mark:
                return commit_ids[i]
            i = i + 1
        return ""
    if ref.starts_with("commit_"):
        return ref
    ""

fn scv_fast_import_inline_blob(root: text, bytes: [u8], commit_seq: i64, file_seq: i64) -> text:
    val (file_id, chunk) = scv_write_file_object_from_bytes(root, "inline-{commit_seq}-{file_seq}", bytes, 0)
    "inline-{commit_seq}-{file_seq}|{file_id}|{chunk}|{bytes.len()}|0"

# DAG walk: collect commits from head back to (but not including) since, in reverse BFS order
# Returns list ordered oldest-first (topological order for export)
fn scv_export_dag_commits(root: text, head: text, since: text) -> [text]:
    var visited: [text] = []
    var queue: [text] = []
    var result: [text] = []
    queue.push(head)
    while queue.len() > 0:
        val current = queue[0]
        var new_queue: [text] = []
        var qi = 1
        while qi < queue.len():
            new_queue.push(queue[qi])
            qi = qi + 1
        queue = new_queue
        if current == "" or current == since:
            continue
        var already = false
        for v in visited:
            if v == current:
                already = true
        if already:
            continue
        visited.push(current)
        result.push(current)
        val parents = scv_fast_import_commit_all_parents(root, current)
        for parent in parents:
            if parent != "" and parent != since:
                var parent_visited = false
                for v in visited:
                    if v == parent:
                        parent_visited = true
                if not parent_visited:
                    queue.push(parent)
    # Reverse result so oldest comes first
    var ordered: [text] = []
    var ri = result.len() - 1
    while ri >= 0:
        ordered.push(result[ri])
        ri = ri - 1
    ordered

fn scv_export_git_fast_import(root: text, stream_path: text, branch: text, since: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    if not scv_git_ref_safe(branch):
        return "ERROR unsafe git branch\n"
    val head_commit = scv_read_workspace_commit(root)
    if head_commit == "":
        return "ERROR missing current commit\n"
    val commits = scv_export_dag_commits(root, head_commit, since)
    if commits.len() == 0:
        return "ERROR no commits to export\n"
    var stream: [u8] = []
    var mark = 1
    # Track blobs already emitted: file_id → mark number (as text)
    var emitted_file_ids: [text] = []
    var emitted_file_marks: [text] = []
    # Track commit mark assignments
    var commit_mark_map: [text] = []
    var commit_mark_ids: [text] = []
    var total_blobs = 0
    var total_deletes = 0
    for commit in commits:
        val tree_id = scv_commit_tree(root, commit)
        if tree_id == "":
            continue
        val tree_path = scv_object_path(root, "trees", tree_id)
        if not file_exists(tree_path):
            continue
        val tree_content = file_read(tree_path)
        # Emit blobs for files in this commit that haven't been emitted yet
        for line in tree_content.split("\n"):
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val parts = trimmed.split("|")
            if parts.len() < 2:
                continue
            val rel = parts[0]
            val file_id = parts[1]
            if not scv_fast_import_path_safe(rel):
                continue
            var already_emitted = false
            for eid in emitted_file_ids:
                if eid == file_id:
                    already_emitted = true
            if not already_emitted:
                val bytes = scv_fast_import_file_primary_bytes(root, file_id)
                stream = scv_fast_append_text_bytes(stream, "blob\nmark :{mark}\ndata {bytes.len()}\n")
                stream = scv_fast_append_bytes(stream, bytes)
                stream = scv_fast_append_text_bytes(stream, "\n")
                emitted_file_ids.push(file_id)
                emitted_file_marks.push("{mark}")
                mark = mark + 1
                total_blobs = total_blobs + 1
        commit_mark_map.push(commit)
        commit_mark_ids.push("{mark}")
        # Emit commit record
        stream = scv_fast_append_text_bytes(stream, "commit refs/heads/{branch}\nmark :{mark}\n")
        mark = mark + 1
        # Emit author line if present
        val author = scv_object_field(file_read(scv_object_path(root, "commits", commit)), "author")
        if author != "":
            stream = scv_fast_append_text_bytes(stream, "author {author}\n")
        # Emit committer line (use stored committer or fallback)
        val committer = scv_object_field(file_read(scv_object_path(root, "commits", commit)), "committer")
        if committer != "":
            stream = scv_fast_append_text_bytes(stream, "committer {committer}\n")
        else:
            stream = scv_fast_append_text_bytes(stream, "committer scv <scv@example.invalid> 0 +0000\n")
        val state = scv_object_field(file_read(scv_object_path(root, "commits", commit)), "state")
        val message = "SCV export {commit}\n"
        stream = scv_fast_append_text_bytes(stream, "data {message.bytes().len()}\n{message}")
        # Emit from and merge lines for parents
        val parents = scv_fast_import_commit_all_parents(root, commit)
        var pi = 0
        while pi < parents.len():
            val parent = parents[pi]
            # Find mark for this parent commit
            var parent_mark = ""
            var pmi = 0
            while pmi < commit_mark_map.len():
                if commit_mark_map[pmi] == parent:
                    parent_mark = commit_mark_ids[pmi]
                pmi = pmi + 1
            if pi == 0:
                if parent_mark != "":
                    stream = scv_fast_append_text_bytes(stream, "from :{parent_mark}\n")
                else:
                    stream = scv_fast_append_text_bytes(stream, "from {parent}\n")
            else:
                if parent_mark != "":
                    stream = scv_fast_append_text_bytes(stream, "merge :{parent_mark}\n")
                else:
                    stream = scv_fast_append_text_bytes(stream, "merge {parent}\n")
            pi = pi + 1
        # Emit file commands by comparing with parent tree
        val parent_tree_content = if parents.len() > 0: scv_fast_import_tree_content_by_commit(root, parents[0]) else: ""
        # Delete files removed vs first parent
        for pline in parent_tree_content.split("\n"):
            val ptrimmed = pline.trim()
            if ptrimmed == "":
                continue
            val pparts = ptrimmed.split("|")
            if pparts.len() < 1:
                continue
            val prel = pparts[0]
            if not scv_fast_import_tree_content_has_path(tree_content, prel):
                stream = scv_fast_append_text_bytes(stream, "D {scv_fast_import_quote_path(prel)}\n")
                total_deletes = total_deletes + 1
        # Add/modify files
        for line in tree_content.split("\n"):
            val trimmed = line.trim()
            if trimmed == "":
                continue
            val parts = trimmed.split("|")
            if parts.len() < 2:
                continue
            val rel = parts[0]
            val file_id = parts[1]
            if not scv_fast_import_path_safe(rel):
                continue
            var file_mark = ""
            var fmi = 0
            while fmi < emitted_file_ids.len():
                if emitted_file_ids[fmi] == file_id:
                    file_mark = emitted_file_marks[fmi]
                fmi = fmi + 1
            if file_mark != "":
                stream = scv_fast_append_text_bytes(stream, "M 100644 :{file_mark} {scv_fast_import_quote_path(rel)}\n")
        stream = scv_fast_append_text_bytes(stream, "\n")
    # Emit lightweight tags as reset refs/tags/ lines
    val tags_content = scv_tag_list(root)
    if tags_content != "empty\n" and tags_content != "" and not tags_content.starts_with("ERROR"):
        for tline in tags_content.split("\n"):
            val ttrimmed = tline.trim()
            if ttrimmed == "":
                continue
            val tparts = ttrimmed.split("|")
            if tparts.len() >= 2:
                val tname = tparts[0]
                val tcommit = tparts[1]
                # Find mark for this commit if it's in export set
                var tmark = ""
                var tmi = 0
                while tmi < commit_mark_map.len():
                    if commit_mark_map[tmi] == tcommit:
                        tmark = commit_mark_ids[tmi]
                    tmi = tmi + 1
                # Only emit annotated tags as tag records; lightweight as reset
                val annotated_id = scv_tag_annotated_get(root, tname)
                if annotated_id != "":
                    val tag_path = scv_object_path(root, "tags", annotated_id)
                    if file_exists(tag_path):
                        val tag_content = file_read(tag_path)
                        val tagger = scv_object_field(tag_content, "tagger")
                        val tmessage = scv_object_field(tag_content, "message")
                        val from_ref = if tmark != "": ":{tmark}" else: tcommit
                        val msg_bytes = tmessage.bytes()
                        stream = scv_fast_append_text_bytes(stream, "tag {tname}\nfrom {from_ref}\ntagger {tagger}\ndata {msg_bytes.len()}\n{tmessage}\n\n")
                else:
                    val from_ref = if tmark != "": ":{tmark}" else: tcommit
                    stream = scv_fast_append_text_bytes(stream, "reset refs/tags/{tname}\nfrom {from_ref}\n\n")
    scv_create_parent_dir(stream_path)
    file_write_bytes(stream_path, stream)
    "export-git-fast-import {stream_path} branch={branch} commits={commits.len()} blobs={total_blobs} bytes={stream.len()}\n"

fn scv_import_git_fast_import(root: text, stream_path: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val parent_error = scv_workspace_parent_error(root)
    if parent_error != "":
        return parent_error
    if not file_exists(stream_path):
        return "ERROR missing fast-import stream\n"
    # Blob marks: mark string → payload bytes
    var marks: [text] = []
    var payloads: [[u8]] = []
    # Commit marks: mark string → scv commit_id
    var commit_marks: [text] = []
    var commit_ids: [text] = []
    var tree_lines = scv_fast_import_current_tree_lines(root)
    var imported = 0
    var deleted = 0
    var renamed = 0
    var copied = 0
    var in_commit = false
    var current_author = ""
    var current_committer = ""
    # Track multi-parent accumulation for current commit
    var current_from_mark = ""
    var current_merge_marks: [text] = []
    var commit_seq = 0
    var inline_file_seq = 0
    val stream = scv_i64_bytes_to_u8(file_read_bytes(stream_path) ?? [])
    var pos = 0
    while pos < stream.len():
        val (raw_line, line_end) = scv_fast_import_bytes_line(stream, pos)
        val line = raw_line.trim()
        val next_pos = scv_fast_import_next_line_pos(stream, line_end)
        if line == "":
            if in_commit:
                # End of commit — write the commit object
                var parent_commits: [text] = []
                if current_from_mark != "":
                    val from_commit = scv_fast_import_resolve_commit_ref(current_from_mark, commit_marks, commit_ids)
                    if from_commit != "":
                        parent_commits.push(from_commit)
                for merge_mark in current_merge_marks:
                    val merge_commit = scv_fast_import_resolve_commit_ref(merge_mark, commit_marks, commit_ids)
                    if merge_commit != "":
                        parent_commits.push(merge_commit)
                val tree = scv_write_tree_object(root, tree_lines)
                val new_commit = scv_write_commit_multi(root, parent_commits, tree, scv_state_private(), current_author, current_committer)
                # Store commit mark if we have a pending one
                if commit_marks.len() > commit_ids.len():
                    commit_ids.push(new_commit)
                val op = scv_write_operation(root, scv_current_op(root), new_commit, "import-git-fast-import")
                if op.starts_with("ERROR"):
                    return op
                scv_write_text("{root}/.scv/meta/status_index.sdn", file_read(scv_object_path(root, "trees", tree)))
                in_commit = false
                current_author = ""
                current_committer = ""
                current_from_mark = ""
                current_merge_marks = []
                inline_file_seq = 0
            pos = next_pos
            continue
        if line == "blob":
            if next_pos >= stream.len():
                return "ERROR truncated blob record\n"
            val (raw_mark_line, mark_end) = scv_fast_import_bytes_line(stream, next_pos)
            val mark_line = raw_mark_line.trim()
            val data_pos = scv_fast_import_next_line_pos(stream, mark_end)
            if data_pos >= stream.len():
                return "ERROR truncated blob record\n"
            val (raw_data_line, data_end_line) = scv_fast_import_bytes_line(stream, data_pos)
            val data_line = raw_data_line.trim()
            if not mark_line.starts_with("mark :") or not data_line.starts_with("data "):
                return "ERROR unsupported blob record\n"
            val bmark = mark_line[6:].trim()
            val size = data_line[5:].trim().to_i64() ?? -1
            if size < 0:
                return "ERROR bad blob size\n"
            if bmark == "" or not scv_fast_import_mark_ref_safe(":{bmark}"):
                return "ERROR unsupported blob record\n"
            if scv_fast_import_mark_seen(marks, bmark):
                return "ERROR duplicate blob mark: {bmark}\n"
            val data_start = scv_fast_import_next_line_pos(stream, data_end_line)
            val data_end = data_start + size
            if data_end > stream.len():
                return "ERROR truncated blob payload\n"
            marks.push(bmark)
            payloads.push(stream[data_start:data_end])
            pos = data_end
            continue
        if line.starts_with("data "):
            val size = line[5:].trim().to_i64() ?? -1
            if size < 0:
                return "ERROR bad data size\n"
            val data_start = next_pos
            val data_end = data_start + size
            if data_end > stream.len():
                return "ERROR truncated data payload\n"
            pos = data_end
            continue
        if line.starts_with("author "):
            if in_commit:
                current_author = line[7:].trim()
            pos = next_pos
            continue
        if line.starts_with("committer ") and not line.starts_with("commit "):
            if in_commit:
                current_committer = line[10:].trim()
            pos = next_pos
            continue
        if line.starts_with("from "):
            if in_commit:
                current_from_mark = line[5:].trim()
            pos = next_pos
            continue
        if line.starts_with("merge "):
            if in_commit:
                current_merge_marks.push(line[6:].trim())
            pos = next_pos
            continue
        if line.starts_with("mark :"):
            val new_mark = line[6:].trim()
            if in_commit:
                # This is a commit mark
                commit_marks.push(new_mark)
            pos = next_pos
            continue
        if line.starts_with("M "):
            if not in_commit:
                return "ERROR file command outside commit\n"
            val parts = scv_fast_import_split_command(line)
            # Handle inline blob: M 100644 inline path
            if parts.len() == 4 and parts[2] == "inline":
                val mode = parts[1]
                if mode != "100644" and mode != "100755":
                    return "ERROR unsupported file mode: {mode}\n"
                val rel = parts[3]
                if not scv_fast_import_path_safe(rel):
                    return "ERROR unsafe git path: {rel}\n"
                # Next must be a data line
                val (raw_data_line, data_end_line) = scv_fast_import_bytes_line(stream, next_pos)
                val data_line = raw_data_line.trim()
                if not data_line.starts_with("data "):
                    return "ERROR expected data after inline M command\n"
                val size = data_line[5:].trim().to_i64() ?? -1
                if size < 0:
                    return "ERROR bad inline blob size\n"
                val data_start = scv_fast_import_next_line_pos(stream, data_end_line)
                val data_end = data_start + size
                if data_end > stream.len():
                    return "ERROR truncated inline blob payload\n"
                val blob_bytes = stream[data_start:data_end]
                val (file_id, chunk) = scv_write_file_object_from_bytes(root, rel, blob_bytes, 0)
                tree_lines = scv_fast_import_tree_without_path(tree_lines, rel)
                tree_lines.push("{rel}|{file_id}|{chunk}|{blob_bytes.len()}|0")
                imported = imported + 1
                inline_file_seq = inline_file_seq + 1
                pos = data_end
                continue
            # Normal mark-referenced blob
            if parts.len() != 4:
                return "ERROR unsupported file command\n"
            val mode = parts[1]
            if mode != "100644" and mode != "100755":
                return "ERROR unsupported file mode: {mode}\n"
            if not scv_fast_import_mark_ref_safe(parts[2]):
                return "ERROR unsupported file command\n"
            val bmark = parts[2][1:]
            val rel = parts[3]
            if not scv_fast_import_path_safe(rel):
                return "ERROR unsafe git path: {rel}\n"
            val (payload, found) = scv_fast_import_blob_for_mark(marks, payloads, bmark)
            if not found:
                return "ERROR missing blob mark: {bmark}\n"
            val (file_id, chunk) = scv_write_file_object_from_bytes(root, rel, payload, 0)
            tree_lines = scv_fast_import_tree_without_path(tree_lines, rel)
            tree_lines.push("{rel}|{file_id}|{chunk}|{payload.len()}|0")
            imported = imported + 1
        elif line.starts_with("D "):
            if not in_commit:
                return "ERROR file command outside commit\n"
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 2:
                return "ERROR unsupported delete command\n"
            val rel = parts[1]
            if not scv_fast_import_path_safe(rel):
                return "ERROR unsafe git path: {rel}\n"
            if scv_fast_import_tree_has_path(tree_lines, rel):
                tree_lines = scv_fast_import_tree_without_path(tree_lines, rel)
                deleted = deleted + 1
        elif line == "deleteall":
            if not in_commit:
                return "ERROR file command outside commit\n"
            deleted = deleted + tree_lines.len()
            tree_lines = []
        elif line.starts_with("R "):
            if not in_commit:
                return "ERROR file command outside commit\n"
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 3:
                return "ERROR unsupported rename command\n"
            val source = parts[1]
            val target = parts[2]
            if not scv_fast_import_path_safe(source):
                return "ERROR unsafe git path: {source}\n"
            if not scv_fast_import_path_safe(target):
                return "ERROR unsafe git path: {target}\n"
            val old_file_id = scv_fast_import_tree_file_id_for_path(tree_lines, source)
            if old_file_id == "":
                return "ERROR missing rename source: {source}\n"
            val bytes = scv_fast_import_file_primary_bytes(root, old_file_id)
            val (file_id, chunk) = scv_write_file_object_from_bytes(root, target, bytes, 0)
            tree_lines = scv_fast_import_tree_without_path(tree_lines, source)
            tree_lines = scv_fast_import_tree_without_path(tree_lines, target)
            tree_lines.push("{target}|{file_id}|{chunk}|{bytes.len()}|0")
            renamed = renamed + 1
        elif line.starts_with("C "):
            if not in_commit:
                return "ERROR file command outside commit\n"
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 3:
                return "ERROR unsupported copy command\n"
            val source = parts[1]
            val target = parts[2]
            if not scv_fast_import_path_safe(source):
                return "ERROR unsafe git path: {source}\n"
            if not scv_fast_import_path_safe(target):
                return "ERROR unsafe git path: {target}\n"
            val old_file_id = scv_fast_import_tree_file_id_for_path(tree_lines, source)
            if old_file_id == "":
                return "ERROR missing copy source: {source}\n"
            val bytes = scv_fast_import_file_primary_bytes(root, old_file_id)
            val (file_id, chunk) = scv_write_file_object_from_bytes(root, target, bytes, 0)
            tree_lines = scv_fast_import_tree_without_path(tree_lines, target)
            tree_lines.push("{target}|{file_id}|{chunk}|{bytes.len()}|0")
            copied = copied + 1
        elif line.starts_with("reset "):
            # reset refs/heads/<branch> or reset refs/tags/<name>
            val reset_error = scv_fast_import_reset_ref_error(line)
            if reset_error != "":
                return reset_error
            val ref = line[6:].trim()
            # The next line should be "from <ref>"
            val (raw_from_line, from_end) = scv_fast_import_bytes_line(stream, next_pos)
            val from_line = raw_from_line.trim()
            if not from_line.starts_with("from "):
                return "ERROR reset requires a from line\n"
            val from_ref = from_line[5:].trim()
            val target_commit = scv_fast_import_resolve_commit_ref(from_ref, commit_marks, commit_ids)
            if target_commit == "":
                return "ERROR unresolved reset target: {from_ref}\n"
            if ref.starts_with("refs/tags/"):
                val tag_name = ref[10:]
                val tag_result = scv_tag_set(root, tag_name, target_commit)
                if tag_result.starts_with("ERROR"):
                    return tag_result
            elif ref.starts_with("refs/heads/"):
                # Update workspace to point to this commit
                val op = scv_write_operation(root, scv_current_op(root), target_commit, "import-git-fast-import-reset")
                if op.starts_with("ERROR"):
                    return op
                scv_write_text("{root}/.scv/meta/status_index.sdn", file_read(scv_object_path(root, "trees", scv_commit_tree(root, target_commit))))
                tree_lines = scv_fast_import_current_tree_lines(root)
            pos = scv_fast_import_next_line_pos(stream, from_end)
            continue
        elif line.starts_with("tag "):
            # Annotated tag record: tag <name>\nfrom <ref>\ntagger ...\ndata N\n<msg>
            val tag_error = scv_fast_import_tag_record_error(line)
            if tag_error != "":
                return tag_error
            val tag_name = line[4:].trim()
            # from line
            val (raw_from_line, from_end) = scv_fast_import_bytes_line(stream, next_pos)
            val from_line = raw_from_line.trim()
            if not from_line.starts_with("from "):
                return "ERROR tag record requires from line\n"
            val from_ref = from_line[5:].trim()
            val target_commit = scv_fast_import_resolve_commit_ref(from_ref, commit_marks, commit_ids)
            if target_commit == "":
                return "ERROR unresolved tag target: {from_ref}\n"
            # tagger line
            val tagger_pos = scv_fast_import_next_line_pos(stream, from_end)
            val (raw_tagger_line, tagger_end) = scv_fast_import_bytes_line(stream, tagger_pos)
            val tagger_line = raw_tagger_line.trim()
            val tagger = if tagger_line.starts_with("tagger "): tagger_line[7:].trim() else: ""
            # data line for message
            val data_pos = scv_fast_import_next_line_pos(stream, tagger_end)
            val (raw_data_line, data_end_line) = scv_fast_import_bytes_line(stream, data_pos)
            val data_line = raw_data_line.trim()
            var tag_message = ""
            if data_line.starts_with("data "):
                val msg_size = data_line[5:].trim().to_i64() ?? 0
                val msg_start = scv_fast_import_next_line_pos(stream, data_end_line)
                val msg_end = msg_start + msg_size
                if msg_end <= stream.len():
                    tag_message = text.from_bytes(stream[msg_start:msg_end])
                    pos = msg_end
                else:
                    pos = scv_fast_import_next_line_pos(stream, data_end_line)
            else:
                pos = scv_fast_import_next_line_pos(stream, tagger_end)
            # Write annotated tag object
            val tag_id = scv_write_tag_object(root, tag_name, target_commit, "commit", tagger, tag_message)
            # Store as lightweight tag pointing to the commit, plus annotated record
            val tag_result = scv_tag_set(root, tag_name, target_commit)
            if tag_result.starts_with("ERROR"):
                return tag_result
            val annotated_result = scv_tag_annotated_set(root, tag_name, tag_id)
            if annotated_result.starts_with("ERROR"):
                return annotated_result
            continue
        else:
            val commit_error = scv_fast_import_commit_branch_error(line, "")
            if commit_error != "":
                return commit_error
            val perror = scv_fast_import_parent_ref_error(line, "")
            if perror != "":
                return perror
            if line.starts_with("commit "):
                # Flush previous commit if we were in one
                if in_commit:
                    var parent_commits: [text] = []
                    if current_from_mark != "":
                        val from_commit = scv_fast_import_resolve_commit_ref(current_from_mark, commit_marks, commit_ids)
                        if from_commit != "":
                            parent_commits.push(from_commit)
                    for merge_mark in current_merge_marks:
                        val merge_commit = scv_fast_import_resolve_commit_ref(merge_mark, commit_marks, commit_ids)
                        if merge_commit != "":
                            parent_commits.push(merge_commit)
                    val tree = scv_write_tree_object(root, tree_lines)
                    val new_commit = scv_write_commit_multi(root, parent_commits, tree, scv_state_private(), current_author, current_committer)
                    if commit_marks.len() > commit_ids.len():
                        commit_ids.push(new_commit)
                    val op = scv_write_operation(root, scv_current_op(root), new_commit, "import-git-fast-import")
                    if op.starts_with("ERROR"):
                        return op
                    scv_write_text("{root}/.scv/meta/status_index.sdn", file_read(scv_object_path(root, "trees", tree)))
                    current_author = ""
                    current_committer = ""
                    current_from_mark = ""
                    current_merge_marks = []
                    inline_file_seq = 0
                in_commit = true
                commit_seq = commit_seq + 1
        pos = next_pos
    # Flush final commit if any
    if in_commit:
        var parent_commits: [text] = []
        if current_from_mark != "":
            val from_commit = scv_fast_import_resolve_commit_ref(current_from_mark, commit_marks, commit_ids)
            if from_commit != "":
                parent_commits.push(from_commit)
        for merge_mark in current_merge_marks:
            val merge_commit = scv_fast_import_resolve_commit_ref(merge_mark, commit_marks, commit_ids)
            if merge_commit != "":
                parent_commits.push(merge_commit)
        val tree = scv_write_tree_object(root, tree_lines)
        val new_commit = scv_write_commit_multi(root, parent_commits, tree, scv_state_private(), current_author, current_committer)
        if commit_marks.len() > commit_ids.len():
            commit_ids.push(new_commit)
        val op = scv_write_operation(root, scv_current_op(root), new_commit, "import-git-fast-import")
        if op.starts_with("ERROR"):
            return op
        scv_write_text("{root}/.scv/meta/status_index.sdn", file_read(scv_object_path(root, "trees", tree)))
    if imported == 0 and deleted == 0 and renamed == 0 and copied == 0:
        return "ERROR fast-import stream has no file commands\n"
    "import-git-fast-import files={imported} deleted={deleted} renamed={renamed} copied={copied} commits={commit_seq}\n"
