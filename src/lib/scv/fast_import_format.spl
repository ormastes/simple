# SCV bounded Git fast-import stream format helpers.

use std.scv.core.{scv_worktree_path_safe}

fn scv_git_ref_safe(ref_name: text) -> bool:
    if ref_name == "":
        return false
    if ref_name.starts_with("/") or ref_name.ends_with("/") or ref_name.ends_with("."):
        return false
    if ref_name.contains("..") or ref_name.contains("//") or ref_name.contains("@{"):
        return false
    if ref_name.contains("\n") or ref_name.contains("\r") or ref_name.contains("\t"):
        return false
    for ch in ref_name:
        if ch == " " or ch == "\\" or ch == "~" or ch == "^" or ch == ":" or ch == "?" or ch == "*" or ch == "[":
            return false
    for component in ref_name.split("/"):
        if component == "" or component.starts_with(".") or component.ends_with(".lock"):
            return false
    true

fn scv_fast_import_path_safe(rel: text) -> bool:
    if rel.contains("\t"):
        return false
    scv_worktree_path_safe(rel)

fn scv_fast_import_quote_path(rel: text) -> text:
    if not rel.contains(" ") and not rel.contains("\"") and not rel.contains("\\"):
        return rel
    var out = "\""
    for ch in rel:
        if ch == "\"" or ch == "\\":
            out = out + "\\"
        out = out + ch
    out + "\""

fn scv_fast_import_split_command(line: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var in_quote = false
    var escape = false
    for ch in line:
        if escape:
            current = current + ch
            escape = false
        elif in_quote and ch == "\\":
            escape = true
        elif ch == "\"":
            in_quote = not in_quote
        elif not in_quote and ch == " ":
            if current != "":
                parts.push(current)
                current = ""
        else:
            current = current + ch
    if current != "":
        parts.push(current)
    if in_quote or escape:
        return []
    parts

fn scv_fast_import_bytes_line(stream: [u8], start: i64) -> (text, i64):
    var end = start
    while end < stream.len() and stream[end] != 10.to_u8():
        end = end + 1
    (text.from_bytes(stream[start:end]), end)

fn scv_fast_import_next_line_pos(stream: [u8], line_end: i64) -> i64:
    if line_end < stream.len():
        line_end + 1
    else:
        line_end

fn scv_fast_import_skip_data_payload(line: text, stream: [u8], next_pos: i64) -> i64:
    if not line.starts_with("data "):
        return -1
    val size = line[5:].trim().to_i64() ?? -1
    if size < 0:
        return -1
    val data_end = next_pos + size
    if data_end > stream.len():
        return -1
    data_end

fn scv_fast_import_mark_seen(marks: [text], mark: text) -> bool:
    for existing in marks:
        if existing == mark:
            return true
    false

fn scv_fast_import_commit_branch_error(line: text, prefix: text) -> text:
    if not line.starts_with("commit "):
        return ""
    val ref = line[7:].trim()
    if not ref.starts_with("refs/heads/"):
        return "ERROR unsupported {prefix}commit ref: {ref}\n"
    val branch = ref[11:]
    if not scv_git_ref_safe(branch):
        return "ERROR unsafe {prefix}git branch: {branch}\n"
    ""

fn scv_fast_import_mark_ref_safe(ref: text) -> bool:
    if not ref.starts_with(":") or ref.len() < 2:
        return false
    val digits = "0123456789"
    for ch in ref[1:]:
        if not digits.contains(ch):
            return false
    true

fn scv_fast_import_parent_ref_error(line: text, prefix: text) -> text:
    if not line.starts_with("from ") and not line.starts_with("merge "):
        return ""
    val parts = line.split(" ")
    if parts.len() != 2:
        return "ERROR unsupported {prefix}parent ref\n"
    val ref = parts[1]
    if scv_fast_import_mark_ref_safe(ref):
        return ""
    if not ref.starts_with("refs/heads/"):
        return "ERROR unsupported {prefix}parent ref: {ref}\n"
    val branch = ref[11:]
    if not scv_git_ref_safe(branch):
        return "ERROR unsafe {prefix}git branch: {branch}\n"
    ""

fn scv_fast_import_verify_commands_bytes(stream: [u8]) -> (text, i64):
    var count = 0
    var pos = 0
    var marks: [text] = []
    var in_commit = false
    while pos < stream.len():
        val (raw_line, line_end) = scv_fast_import_bytes_line(stream, pos)
        val line = raw_line.trim()
        val next_pos = scv_fast_import_next_line_pos(stream, line_end)
        if line == "blob":
            if next_pos >= stream.len():
                return ("ERROR truncated fast-import blob record\n", count)
            val (raw_mark_line, mark_end) = scv_fast_import_bytes_line(stream, next_pos)
            val mark_line = raw_mark_line.trim()
            val data_pos = scv_fast_import_next_line_pos(stream, mark_end)
            if data_pos >= stream.len():
                return ("ERROR truncated fast-import blob record\n", count)
            val (raw_data_line, data_end_line) = scv_fast_import_bytes_line(stream, data_pos)
            val data_line = raw_data_line.trim()
            if not mark_line.starts_with("mark :") or not data_line.starts_with("data "):
                return ("ERROR unsupported fast-import blob record\n", count)
            val mark = mark_line[6:].trim()
            val size = data_line[5:].trim().to_i64() ?? -1
            if mark == "" or size < 0 or not scv_fast_import_mark_ref_safe(":{mark}"):
                return ("ERROR unsupported fast-import blob record\n", count)
            if scv_fast_import_mark_seen(marks, mark):
                return ("ERROR duplicate fast-import blob mark: {mark}\n", count)
            val data_start = scv_fast_import_next_line_pos(stream, data_end_line)
            val payload_end = data_start + size
            if payload_end > stream.len():
                return ("ERROR truncated fast-import blob payload\n", count)
            marks.push(mark)
            pos = payload_end
            continue
        val data_end = scv_fast_import_skip_data_payload(line, stream, next_pos)
        if data_end >= 0:
            pos = data_end
            continue
        val commit_error = scv_fast_import_commit_branch_error(line, "fast-import ")
        if commit_error != "":
            return (commit_error, count)
        val parent_error = scv_fast_import_parent_ref_error(line, "fast-import ")
        if parent_error != "":
            return (parent_error, count)
        if line.starts_with("commit "):
            in_commit = true
            pos = next_pos
            continue
        if line.starts_with("M "):
            if not in_commit:
                return ("ERROR fast-import file command outside commit\n", count)
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 4:
                return ("ERROR unsupported fast-import file command\n", count)
            val mode = parts[1]
            if mode != "100644" and mode != "100755":
                return ("ERROR unsupported fast-import file mode: {mode}\n", count)
            if not scv_fast_import_mark_ref_safe(parts[2]):
                return ("ERROR unsupported fast-import file command\n", count)
            val mark = parts[2][1:]
            if not scv_fast_import_mark_seen(marks, mark):
                return ("ERROR missing fast-import blob mark: {mark}\n", count)
            if not scv_fast_import_path_safe(parts[3]):
                return ("ERROR unsafe fast-import path: {parts[3]}\n", count)
            count = count + 1
        elif line.starts_with("D "):
            if not in_commit:
                return ("ERROR fast-import file command outside commit\n", count)
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 2:
                return ("ERROR unsupported fast-import delete command\n", count)
            if not scv_fast_import_path_safe(parts[1]):
                return ("ERROR unsafe fast-import path: {parts[1]}\n", count)
        elif line.starts_with("R "):
            if not in_commit:
                return ("ERROR fast-import file command outside commit\n", count)
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 3:
                return ("ERROR unsupported fast-import rename command\n", count)
            if not scv_fast_import_path_safe(parts[1]) or not scv_fast_import_path_safe(parts[2]):
                return ("ERROR unsafe fast-import path\n", count)
        elif line.starts_with("C "):
            if not in_commit:
                return ("ERROR fast-import file command outside commit\n", count)
            val parts = scv_fast_import_split_command(line)
            if parts.len() != 3:
                return ("ERROR unsupported fast-import copy command\n", count)
            if not scv_fast_import_path_safe(parts[1]) or not scv_fast_import_path_safe(parts[2]):
                return ("ERROR unsafe fast-import path\n", count)
        pos = next_pos
    ("", count)

fn scv_fast_import_has_commit_branch_bytes(stream: [u8], branch: text) -> bool:
    val expected = "commit refs/heads/{branch}"
    var pos = 0
    while pos < stream.len():
        val (raw_line, line_end) = scv_fast_import_bytes_line(stream, pos)
        val line = raw_line.trim()
        val next_pos = scv_fast_import_next_line_pos(stream, line_end)
        val data_end = scv_fast_import_skip_data_payload(line, stream, next_pos)
        if data_end >= 0:
            pos = data_end
            continue
        if line == expected:
            return true
        pos = next_pos
    false
