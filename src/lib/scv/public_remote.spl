# SCV filesystem public remote transport.

use app.io.mod (file_exists, file_read, dir_create)
use std.nogc_sync_mut.io.file_ops.{file_read_bytes}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.scv.core.{scv_state_public_ready, scv_metadata_path_safe, scv_object_path, scv_line_set_contains}
use std.scv.maintenance.{scv_export_manifest}
use std.scv.fast_import.{scv_export_git_fast_import, scv_import_git_fast_import}
use std.scv.fast_import_format.{scv_git_ref_safe, scv_fast_import_verify_commands_bytes, scv_fast_import_has_commit_branch_bytes}
use std.scv.integrity.{scv_fsck}
use std.scv.store.{scv_repo_exists, scv_read_workspace_commit, scv_commit_tree, scv_commit_state, scv_i64_bytes_to_u8, scv_write_text, scv_restore_op}

fn scv_public_field(content: text, name: text) -> text:
    for line in content.split("\n"):
        if line.starts_with("{name}:"):
            return line[name.len() + 1:].trim()
    ""

fn scv_public_result_token_value(content: text, prefix: text) -> text:
    for token in content.split(" "):
        val trimmed = token.trim()
        if trimmed.starts_with(prefix):
            return trimmed[prefix.len():]
    ""

fn scv_public_marker_id_safe(value: text, prefix: text) -> bool:
    value.starts_with(prefix) and scv_metadata_path_safe(value)

fn scv_public_branch_safe(branch: text) -> bool:
    scv_git_ref_safe(branch) and scv_metadata_path_safe(branch)

fn scv_public_export(root: text, out_dir: text, branch: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe public branch\n"
    val commit = scv_read_workspace_commit(root)
    if commit == "":
        return "ERROR no current commit\n"
    val state = scv_commit_state(root, commit)
    if state != scv_state_public_ready():
        return "ERROR public-export requires public_ready\n"
    val tree = scv_commit_tree(root, commit)
    if tree == "":
        return "ERROR missing current tree\n"
    val fsck = scv_fsck(root)
    if not fsck.starts_with("OK"):
        return fsck
    dir_create(out_dir, true)
    val manifest_result = scv_export_manifest(root, "{out_dir}/manifest.sdn")
    if manifest_result.starts_with("ERROR"):
        return manifest_result
    val git_result = scv_export_git_fast_import(root, "{out_dir}/export.fi", branch)
    if git_result.starts_with("ERROR"):
        return git_result
    val marker = "format: scv-public-export-v1\ncommit: {commit}\ntree: {tree}\nstate: {state}\nbranch: {branch}\ntime_ms: {current_time_ms()}\n"
    scv_write_text("{out_dir}/publish.sdn", marker)
    "public-export {out_dir} commit={commit} branch={branch}\n"

fn scv_public_export_verify(out_dir: text) -> text:
    val publish_path = "{out_dir}/publish.sdn"
    val manifest_path = "{out_dir}/manifest.sdn"
    val stream_path = "{out_dir}/export.fi"
    if not file_exists(publish_path):
        return "ERROR missing public-export marker\n"
    if not file_exists(manifest_path):
        return "ERROR missing public-export manifest\n"
    if not file_exists(stream_path):
        return "ERROR missing public-export stream\n"
    val marker = file_read(publish_path)
    if not marker.starts_with("format: scv-public-export-v1\n"):
        return "ERROR unsupported public-export marker\n"
    val branch = scv_public_field(marker, "branch")
    if branch == "":
        return "ERROR public-export marker missing branch\n"
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe public branch\n"
    val state = scv_public_field(marker, "state")
    if state != scv_state_public_ready():
        return "ERROR public-export marker state is not public_ready\n"
    val commit = scv_public_field(marker, "commit")
    if not scv_public_marker_id_safe(commit, "commit_"):
        return "ERROR unsafe public-export commit id\n"
    val tree = scv_public_field(marker, "tree")
    if not scv_public_marker_id_safe(tree, "tree_"):
        return "ERROR unsafe public-export tree id\n"
    val manifest = file_read(manifest_path)
    if not manifest.starts_with("format: scv-export-manifest-v1\n"):
        return "ERROR unsupported public-export manifest\n"
    val manifest_commit = scv_public_field(manifest, "commit")
    if manifest_commit != commit:
        return "ERROR public-export manifest commit mismatch\n"
    val manifest_tree = scv_public_field(manifest, "tree")
    if manifest_tree != tree:
        return "ERROR public-export manifest tree mismatch\n"
    val stream_bytes = scv_i64_bytes_to_u8(file_read_bytes(stream_path) ?? [])
    if not scv_fast_import_has_commit_branch_bytes(stream_bytes, branch):
        return "ERROR public-export stream branch mismatch\n"
    val (command_error, files) = scv_fast_import_verify_commands_bytes(stream_bytes)
    if command_error != "":
        return command_error
    if files == 0:
        return "ERROR public-export stream has no files\n"
    "public-export-verify {out_dir} commit={commit} branch={branch} files={files}\n"

fn scv_remote_refs_update(remote_dir: text, branch: text, commit: text, artifact_dir: text) -> text:
    val refs_path = "{remote_dir}/refs.sdn"
    val old = if file_exists(refs_path): file_read(refs_path) else: "format: scv-remote-refs-v1\n"
    var out = ""
    var replaced = false
    for line in old.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if trimmed.starts_with("{branch}|"):
            if not replaced:
                out = out + "{branch}|{commit}|{artifact_dir}\n"
                replaced = true
        else:
            out = out + trimmed + "\n"
    if not replaced:
        out = out + "{branch}|{commit}|{artifact_dir}\n"
    out

fn scv_public_push_ref_line(remote_dir: text, branch: text) -> text:
    val refs_path = "{remote_dir}/refs.sdn"
    if not file_exists(refs_path):
        return ""
    val refs = file_read(refs_path)
    if not refs.starts_with("format: scv-remote-refs-v1\n"):
        return ""
    for line in refs.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("{branch}|"):
            return trimmed
    ""

fn scv_public_remote_refs_error(refs: text) -> text:
    if not refs.starts_with("format: scv-remote-refs-v1\n"):
        return "ERROR unsupported public remote refs\n"
    var seen = ""
    for line in refs.split("\n"):
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("format:"):
            continue
        val parts = trimmed.split("|")
        if parts.len() != 3:
            return "ERROR corrupt public remote ref\n"
        val branch = parts[0]
        if not scv_public_branch_safe(branch):
            return "ERROR unsafe public branch\n"
        if not scv_public_marker_id_safe(parts[1], "commit_"):
            return "ERROR unsafe public remote commit id\n"
        if scv_line_set_contains(seen, branch):
            return "ERROR duplicate public remote branch: {branch}\n"
        seen = seen + branch + "\n"
    ""

fn scv_public_push(root: text, remote_dir: text, branch: text) -> text:
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe public branch\n"
    val commit = scv_read_workspace_commit(root)
    if commit == "":
        return "ERROR no current commit\n"
    val artifact_dir = "{remote_dir}/branches/{branch}"
    val export_result = scv_public_export(root, artifact_dir, branch)
    if export_result.starts_with("ERROR"):
        return export_result
    val verify_result = scv_public_export_verify(artifact_dir)
    if verify_result.starts_with("ERROR"):
        return verify_result
    dir_create(remote_dir, true)
    val next_refs = scv_remote_refs_update(remote_dir, branch, commit, artifact_dir)
    val refs_error = scv_public_remote_refs_error(next_refs)
    if refs_error != "":
        return refs_error
    scv_write_text("{remote_dir}/refs.sdn", next_refs)
    "public-push {remote_dir} branch={branch} commit={commit}\n"

fn scv_public_artifact_dir_expected(remote_dir: text, branch: text) -> text:
    "{remote_dir}/branches/{branch}"

fn scv_public_push_verify(remote_dir: text, branch: text) -> text:
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe public branch\n"
    val refs_path = "{remote_dir}/refs.sdn"
    if not file_exists(refs_path):
        return "ERROR missing public remote refs\n"
    val refs = file_read(refs_path)
    val refs_error = scv_public_remote_refs_error(refs)
    if refs_error != "":
        return refs_error
    val ref_line = scv_public_push_ref_line(remote_dir, branch)
    if ref_line == "":
        return "ERROR public remote branch not found\n"
    val parts = ref_line.split("|")
    if parts.len() != 3:
        return "ERROR corrupt public remote ref\n"
    val commit = parts[1]
    val artifact_dir = parts[2]
    if not scv_public_marker_id_safe(commit, "commit_"):
        return "ERROR unsafe public remote commit id\n"
    if artifact_dir != scv_public_artifact_dir_expected(remote_dir, branch):
        return "ERROR unsafe public remote artifact\n"
    val verify = scv_public_export_verify(artifact_dir)
    if verify.starts_with("ERROR"):
        return verify
    val marker = file_read("{artifact_dir}/publish.sdn")
    val artifact_commit = scv_public_field(marker, "commit")
    val artifact_branch = scv_public_field(marker, "branch")
    if artifact_commit != commit:
        return "ERROR public remote commit mismatch\n"
    if artifact_branch != branch:
        return "ERROR public remote branch mismatch\n"
    "public-push-verify {remote_dir} branch={branch} commit={commit}\n"

fn scv_manifest_file_keys(manifest: text) -> text:
    var out = ""
    for line in manifest.split("\n"):
        val trimmed = line.trim()
        if not trimmed.starts_with("file|"):
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 4:
            out = out + "{parts[1]}|{parts[2]}|{parts[3]}\n"
    out

fn scv_tree_file_keys(tree_content: text) -> text:
    var out = ""
    for line in tree_content.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 4:
            out = out + "{parts[0]}|{parts[2]}|{parts[3]}\n"
    out

fn scv_public_manifest_matches_imported_tree(root: text, artifact_dir: text, imported_commit: text) -> bool:
    val manifest_path = "{artifact_dir}/manifest.sdn"
    if not file_exists(manifest_path):
        return false
    val manifest = file_read(manifest_path)
    if not manifest.starts_with("format: scv-export-manifest-v1\n"):
        return false
    val tree = scv_commit_tree(root, imported_commit)
    if tree == "":
        return false
    val tree_path = scv_object_path(root, "trees", tree)
    if not file_exists(tree_path):
        return false
    val manifest_keys = scv_manifest_file_keys(manifest)
    val tree_keys = scv_tree_file_keys(file_read(tree_path))
    if manifest_keys.trim() == "":
        return false
    for key in manifest_keys.split("\n"):
        val trimmed = key.trim()
        if trimmed != "" and not scv_line_set_contains(tree_keys, trimmed):
            return false
    for key in tree_keys.split("\n"):
        val trimmed = key.trim()
        if trimmed != "" and not scv_line_set_contains(manifest_keys, trimmed):
            return false
    true

fn scv_public_pull(root: text, remote_dir: text, branch: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val verify = scv_public_push_verify(remote_dir, branch)
    if verify.starts_with("ERROR"):
        return verify
    val ref_line = scv_public_push_ref_line(remote_dir, branch)
    val parts = ref_line.split("|")
    if parts.len() != 3:
        return "ERROR corrupt public remote ref\n"
    val remote_commit = parts[1]
    val artifact_dir = parts[2]
    val import_result = scv_import_git_fast_import(root, "{artifact_dir}/export.fi")
    if import_result.starts_with("ERROR"):
        return import_result
    val imported_commit = scv_public_result_token_value(import_result, "commit=")
    if imported_commit == "":
        return "ERROR public-pull missing imported commit\n"
    if not scv_public_manifest_matches_imported_tree(root, artifact_dir, imported_commit):
        return "ERROR public-pull manifest does not match imported commit\n"
    val op = scv_public_result_token_value(import_result, "op=")
    if op == "":
        return "ERROR public-pull missing imported operation\n"
    val restore = scv_restore_op(root, op)
    if restore.starts_with("ERROR"):
        return restore
    val fsck = scv_fsck(root)
    if not fsck.starts_with("OK"):
        return fsck
    "public-pull {remote_dir} branch={branch} remote_commit={remote_commit}\n{import_result}"
