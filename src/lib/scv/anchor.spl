# SCV structural anchor types — named (qualified path) and ordinal (parent + index).

struct NamedAnchor:
    qpath: text

struct OrdinalAnchor:
    parent_qpath: text
    index: i64

# Tagged variant — kind is "named" or "ordinal".
# No inheritance; caller dispatches on kind field.
struct Anchor:
    kind: text
    named: NamedAnchor
    ordinal: OrdinalAnchor

fn scv_named_anchor(qpath: text) -> Anchor:
    val named = NamedAnchor(qpath: qpath)
    val ordinal = OrdinalAnchor(parent_qpath: "", index: 0)
    Anchor(kind: "named", named: named, ordinal: ordinal)

fn scv_ordinal_anchor(parent_qpath: text, index: i64) -> Anchor:
    val named = NamedAnchor(qpath: "")
    val ordinal = OrdinalAnchor(parent_qpath: parent_qpath, index: index)
    Anchor(kind: "ordinal", named: named, ordinal: ordinal)

fn scv_anchor_id(anchor: Anchor) -> text:
    if anchor.kind == "named":
        "named:{anchor.named.qpath}"
    else:
        "ordinal:{anchor.ordinal.parent_qpath}[{anchor.ordinal.index}]"

fn scv_anchor_display(anchor: Anchor) -> text:
    if anchor.kind == "named":
        anchor.named.qpath
    else:
        "{anchor.ordinal.parent_qpath}.stmt[{anchor.ordinal.index}]"

fn scv_build_qpath(parent_qpath: text, name: text) -> text:
    if parent_qpath == "":
        name
    else:
        "{parent_qpath}.{name}"
