# SCV WASM executor — tree-sitter WASM grammar loading and parse execution.
# Implements PROD-001: Tree-sitter WASM execution with graceful fallback.
#
# When libwasmtime and libscv_wasm are absent (or SCV_FORCE_FALLBACK=1),
# all entry points route to the existing fallback-line path.
# No extern fn declarations for wasmtime symbols — wasmtime is probed at
# runtime via DynLib.  The shim (src/runtime/scv_wasm_shim.c) is loaded
# dynamically; it exposes:
#   wasm_rt_load(path: text) -> i64
#   wasm_rt_free(handle: i64)
#   wasm_rt_parse_all(handle: i64, source: text, source_len: i64) -> text
# The shim pre-flattens the tree-sitter cursor walk to "kind|field|start|end|leaf\n"
# lines so Simple never holds raw TS or wasmtime pointers.

use app.io.mod (file_exists)
use std.nogc_sync_mut.sffi.{DynLib, sffi_lib_path}
use std.scv.store.{scv_write_text, scv_hash_text}
use std.scv.core.{scv_object_path}

extern fn rt_env_get(key: text) -> text

# ---------------------------------------------------------------------------
# Availability probe
# ---------------------------------------------------------------------------

# Returns true when BOTH the wasmtime dynamic library AND the scv_wasm shim
# are loadable on this machine, AND SCV_FORCE_FALLBACK is not "1".
# When false, all parse paths fall through to line-walk simulation.
fn scv_wasm_executor_available() -> bool:
    val force_fallback = rt_env_get("SCV_FORCE_FALLBACK")
    if force_fallback == "1":
        return false
    val wasmtime_path = sffi_lib_path("wasmtime")
    val shim_path = sffi_lib_path("scv_wasm")
    val wt_lib = DynLib.load(wasmtime_path)
    if not wt_lib.?:
        return false
    val wt = wt_lib.unwrap()
    wt.close()
    val sh_lib = DynLib.load(shim_path)
    if not sh_lib.?:
        return false
    val sh = sh_lib.unwrap()
    sh.close()
    true

# ---------------------------------------------------------------------------
# Structural node-ID hashing
# ---------------------------------------------------------------------------

# Compute a structural ID for a syntax node, excluding byte positions.
# Identical subtrees across edits share the same structural ID.
fn scv_ts_node_structural_id(kind: text, field: text, source_slice: text, child_ids: [text]) -> text:
    var child_concat = ""
    var i = 0
    while i < child_ids.len():
        if i > 0:
            child_concat = child_concat + ","
        child_concat = child_concat + child_ids[i]
        i = i + 1
    scv_hash_text("syntax_node", "ts:{kind}:{field}:{source_slice}:{child_concat}")

# ---------------------------------------------------------------------------
# Node writers for tree-sitter-wasm execution path
# ---------------------------------------------------------------------------

# Write a simulated leaf node from a text source slice.
fn scv_wasm_sim_leaf(root: text, kind: text, field: text, byte_start: i64,
                     byte_end: i64, source_slice: text, language: text,
                     grammar: text, version: text, parser_hash: text) -> text:
    val node_id = scv_ts_node_structural_id(kind, field, source_slice, [])
    val payload = "grammar: {grammar}\nversion: {version}\nparser_hash: {parser_hash}\nexecution: tree-sitter-wasm\nkind: {kind}\nfield: {field}\nchildren:\nbyte_start: {byte_start}\nbyte_end: {byte_end}\nlanguage: {language}\nsyntax: {node_id}\nparse_status: ok\n"
    val path = scv_object_path(root, "syntax", node_id)
    if not file_exists(path):
        scv_write_text(path, payload)
    node_id

# Write an inner syntax node (with children) and return its structural ID.
fn scv_wasm_inner_node(root: text, kind: text, field: text, byte_start: i64,
                       byte_end: i64, child_ids: [text], language: text,
                       grammar: text, version: text, parser_hash: text) -> text:
    val node_id = scv_ts_node_structural_id(kind, field, "", child_ids)
    var child_concat = ""
    var i = 0
    while i < child_ids.len():
        if i > 0:
            child_concat = child_concat + ","
        child_concat = child_concat + child_ids[i]
        i = i + 1
    val payload = "grammar: {grammar}\nversion: {version}\nparser_hash: {parser_hash}\nexecution: tree-sitter-wasm\nkind: {kind}\nfield: {field}\nchildren: {child_concat}\nbyte_start: {byte_start}\nbyte_end: {byte_end}\nlanguage: {language}\nsyntax: {node_id}\nparse_status: ok\n"
    val path = scv_object_path(root, "syntax", node_id)
    if not file_exists(path):
        scv_write_text(path, payload)
    node_id

# ---------------------------------------------------------------------------
# Line-walk simulation (used when wasmtime shim is absent)
# ---------------------------------------------------------------------------

# Walk source text line-by-line producing one tree-sitter-wasm tagged leaf per line.
fn scv_wasm_simulate_line_walk(root: text, source: text, language: text,
                                grammar: text, version: text, parser_hash: text) -> (text, text):
    var children: [text] = []
    var byte_start = 0
    for line in source.split("\n"):
        val byte_end = byte_start + line.len()
        val child_id = scv_wasm_sim_leaf(root, "line", "", byte_start, byte_end,
                                         line, language, grammar, version, parser_hash)
        children.push(child_id)
        byte_start = byte_end + 1
    if children.len() == 0:
        val child_id = scv_wasm_sim_leaf(root, "line", "", 0, 0, "",
                                         language, grammar, version, parser_hash)
        children.push(child_id)
    val source_len = if byte_start > 0: byte_start - 1 else: 0
    val root_id = scv_wasm_inner_node(root, "file", "root", 0, source_len,
                                      children, language, grammar, version, parser_hash)
    (root_id, "")

# ---------------------------------------------------------------------------
# Real WASM parse via shim extern fns
# ---------------------------------------------------------------------------

# Parse the serialised cursor blob returned by wasm_rt_parse_all.
# Each line is "kind|field|byte_start|byte_end|is_leaf|depth".
# The depth field (0-based) drives stack management: before processing each node
# we pop the stack down to the node's depth level, flushing completed inner nodes
# to their parents as we go.  This correctly handles sibling inner nodes.
# source is needed to extract leaf text slices from byte offsets.
fn _scv_parse_node_blob(root: text, blob: text, source: text, language: text,
                         grammar: text, version: text, parser_hash: text) -> text:
    val lines = blob.split("\n")
    var stack_kinds:    [text] = []
    var stack_fields:   [text] = []
    var stack_starts:   [i64]  = []
    var stack_ends:     [i64]  = []
    var stack_children: [text] = []
    var root_id = ""
    var li = 0
    while li < lines.len():
        val line = lines[li]
        li = li + 1
        if line == "":
            continue
        val parts = line.split("|")
        if parts.len() < 5:
            continue
        val nkind  = parts[0]
        val nfield = parts[1]
        val nstart = parts[2].to_i64() ?? 0
        val nend   = parts[3].to_i64() ?? 0
        val nleaf  = parts[4] == "1"
        val ndepth = if parts.len() >= 6: parts[5].to_i64() ?? 0 else: 0
        # Pop the stack down to ndepth, flushing completed inner nodes upward.
        # An inner node at depth D lives at stack index D (root is index 0).
        # Before placing a new node at depth D we need the stack to have exactly
        # D entries — i.e., all entries at index >= D must be flushed first.
        while stack_kinds.len() > ndepth:
            val si = stack_kinds.len() - 1
            val fkind     = stack_kinds[si]
            val ffield    = stack_fields[si]
            val fstart    = stack_starts[si]
            val fend      = stack_ends[si]
            val fchild_str = stack_children[si]
            val fchildren: [text] = if fchild_str == "": [] else: fchild_str.split(",")
            val fid = scv_wasm_inner_node(root, fkind, ffield, fstart, fend,
                                          fchildren, language, grammar, version, parser_hash)
            stack_kinds.pop()
            stack_fields.pop()
            stack_starts.pop()
            stack_ends.pop()
            stack_children.pop()
            if stack_kinds.len() > 0:
                val parent = stack_kinds.len() - 1
                val pcur = stack_children[parent]
                stack_children[parent] = if pcur == "": fid else: pcur + "," + fid
            else:
                root_id = fid
        if nleaf:
            val slen = nend - nstart
            val slice = if (slen > 0 and nstart >= 0 and nend <= source.len()):
                            source.slice(nstart, nend)
                        else:
                            ""
            val child_id = scv_wasm_sim_leaf(root, nkind, nfield, nstart, nend,
                                             slice, language, grammar, version, parser_hash)
            if stack_kinds.len() > 0:
                val top = stack_kinds.len() - 1
                val cur = stack_children[top]
                stack_children[top] = if cur == "": child_id else: cur + "," + child_id
            else:
                root_id = child_id
        else:
            stack_kinds.push(nkind)
            stack_fields.push(nfield)
            stack_starts.push(nstart)
            stack_ends.push(nend)
            stack_children.push("")
    # Flush any remaining inner nodes on the stack bottom-up
    while stack_kinds.len() > 0:
        val si = stack_kinds.len() - 1
        val fkind     = stack_kinds[si]
        val ffield    = stack_fields[si]
        val fstart    = stack_starts[si]
        val fend      = stack_ends[si]
        val fchild_str = stack_children[si]
        val fchildren: [text] = if fchild_str == "": [] else: fchild_str.split(",")
        val fid = scv_wasm_inner_node(root, fkind, ffield, fstart, fend,
                                      fchildren, language, grammar, version, parser_hash)
        stack_kinds.pop()
        stack_fields.pop()
        stack_starts.pop()
        stack_ends.pop()
        stack_children.pop()
        if stack_kinds.len() > 0:
            val parent = stack_kinds.len() - 1
            val pcur = stack_children[parent]
            stack_children[parent] = if pcur == "": fid else: pcur + "," + fid
        else:
            root_id = fid
    root_id

# ---------------------------------------------------------------------------
# Public high-level parse API
# ---------------------------------------------------------------------------

# Full WASM parse pipeline: load grammar → parse → walk → write nodes.
# Returns (root_node_id, error_or_empty).
#
# When the scv_wasm shim is compiled and linked (i.e., the runtime is built
# with wasmtime support), these extern declarations are resolved and the real
# path is used.  When the shim is absent, scv_wasm_executor_available()
# returns false and the call never reaches these externs — fallback-line runs
# instead.
#
# In interpreter mode or when only DynLib probing is available (no compiled
# shim), the availability check gates everything and we stay on fallback-line.
extern fn wasm_rt_load(path: text) -> i64
extern fn wasm_rt_free(handle: i64)
extern fn wasm_rt_parse_all(handle: i64, source: text, source_len: i64) -> text

fn scv_wasm_parse(root: text, language: text, grammar: text, version: text,
                  parser_hash: text, source: text) -> (text, text):
    if not scv_wasm_executor_available():
        return scv_wasm_simulate_line_walk(root, source, language, grammar, version, parser_hash)
    # Build grammar artifact path: .scv/parsers/<parser_hash>.wasm
    val grammar_path = "{root}/.scv/parsers/{parser_hash}.wasm"
    if not file_exists(grammar_path):
        return scv_wasm_simulate_line_walk(root, source, language, grammar, version, parser_hash)
    # Load grammar via shim extern (resolved when libscv_wasm is linked)
    val handle = wasm_rt_load(grammar_path)
    if handle == 0:
        return scv_wasm_simulate_line_walk(root, source, language, grammar, version, parser_hash)
    # Parse and get the full node blob
    val source_len = source.len()
    val blob = wasm_rt_parse_all(handle, source, source_len)
    wasm_rt_free(handle)
    if blob == "":
        return scv_wasm_simulate_line_walk(root, source, language, grammar, version, parser_hash)
    # Walk the blob and write tree-sitter-wasm nodes
    val root_id = _scv_parse_node_blob(root, blob, source, language, grammar, version, parser_hash)
    if root_id == "":
        return scv_wasm_simulate_line_walk(root, source, language, grammar, version, parser_hash)
    (root_id, "")
