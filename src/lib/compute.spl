# Compute — namespace anchor for the std.compute sub-library.
#
# Sub-modules are accessed via their full paths (e.g. std.compute.tensor).
val compute_namespace_anchor = true

use std.common.gpu.device.{Gpu, GpuBackend}

export use std.nogc_sync_mut.gpu_runtime.mod.{gpu_available}
export use std.common.gpu.device.{Gpu, GpuBackend, gpu_cuda, gpu_vulkan, gpu_none}

fn gpu_default() -> Gpu:
    Gpu(backend: GpuBackend.Cuda, device_id: 0)

export gpu_default
