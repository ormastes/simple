# cc::RasterBufferProvider — allocates raster buffers for tile upload

use std.cc.entity.tile.{Tile}
use std.skia.capability.{SkCapability}

class RasterBuffer:
    width: i32
    height: i32
    handle: i64

    static fn new(width: i32, height: i32, handle: i64) -> RasterBuffer:
        RasterBuffer(width: width, height: height, handle: handle)

class RasterBufferProvider:
    capability: SkCapability
    next_handle: i64

    static fn new(cap: SkCapability) -> RasterBufferProvider:
        RasterBufferProvider(capability: cap, next_handle: 1)

    me acquire_buffer_for_raster(tile: Tile) -> RasterBuffer:
        val w = tile.content_rect.width()
        val h = tile.content_rect.height()
        val handle = me.next_handle
        me.next_handle = me.next_handle + 1
        RasterBuffer.new(w, h, handle)

    me release_buffer(buf: RasterBuffer):
        pass
