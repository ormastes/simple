# cc::PictureLayerImpl — rasterizable layer backed by a RasterSource

use std.cc.entity.layer.{Layer}
use std.cc.entity.tile.{Tile, TileKey, TilePriority}
use std.cc.feature.raster_source.{RasterSource}
use std.skia.entity.geometry.{SkRect, SkIRect}
use std.blink.entity.paint_artifact.{PaintArtifact}

class PictureLayerImpl:
    base: Layer
    raster_source: RasterSource
    tiles: [Tile]
    tile_size: i32
    contents_scale: f64

    static fn from_layer(layer: Layer, raster_source: RasterSource) -> PictureLayerImpl:
        PictureLayerImpl(
            base: layer,
            raster_source: raster_source,
            tiles: [],
            tile_size: 256,
            contents_scale: 1.0
        )

    me create_tilings():
        me.tiles = [Tile]()
        val bounds = me.base.bounds
        val wf = bounds.width()
        val hf = bounds.height()
        val w = wf as i32
        val h = hf as i32
        val sz = me.tile_size
        var col = 0
        var x = 0
        while x < w:
            var row = 0
            var y = 0
            while y < h:
                var rect_w = sz
                if x + sz > w:
                    rect_w = w - x
                var rect_h = sz
                if y + sz > h:
                    rect_h = h - y
                val content_rect = SkIRect.make_xywh(x, y, rect_w, rect_h)
                val key = TileKey.new(me.base.id, col, row, me.contents_scale)
                val tile = Tile.new(key, content_rect, TilePriority.NowBin)
                me.tiles.push(tile)
                row = row + 1
                y = y + sz
            col = col + 1
            x = x + sz

    me invalidate_rect(r: SkIRect):
        var i = 0
        while i < me.tiles.len():
            val t = me.tiles[i]
            if t.content_rect.intersects(r):
                me.tiles[i].invalidate()
            i = i + 1

    me tile_count() -> i32:
        me.tiles.len() as i32
