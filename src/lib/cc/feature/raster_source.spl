# raster_source.spl — cc::RasterSource wrapping an SkPicture for tile raster

use std.skia.entity.picture.{SkPicture}
use std.skia.entity.geometry.{SkRect}

class RasterSource:
    picture: SkPicture
    recorded_bounds: SkRect

    static fn from_picture(picture: SkPicture) -> RasterSource:
        RasterSource(picture: picture, recorded_bounds: picture.cull_rect)
