# cc::PropertyTrees — four compositor property trees mirroring Chromium's cc layer.

# ---------------------------------------------------------------------------
# TransformTree
# ---------------------------------------------------------------------------

class TransformNode:
    id: i32
    parent_id: i32
    local: [f32]
    origin_x: f32
    origin_y: f32
    scrolls: bool
    flattens_inherited_transform: bool

class TransformTree:
    nodes: [TransformNode]

    static fn new() -> TransformTree:
        val root = TransformNode(
            id: 0,
            parent_id: -1,
            local: [f32](),
            origin_x: 0.0,
            origin_y: 0.0,
            scrolls: false,
            flattens_inherited_transform: false
        )
        val ns = [TransformNode]()
        ns.push(root)
        TransformTree(nodes: ns)

    me add_node(n: TransformNode) -> i32:
        val new_id = self.nodes.len().to_i32()
        val node = TransformNode(
            id: new_id,
            parent_id: n.parent_id,
            local: n.local,
            origin_x: n.origin_x,
            origin_y: n.origin_y,
            scrolls: n.scrolls,
            flattens_inherited_transform: n.flattens_inherited_transform
        )
        self.nodes.push(node)
        new_id

    me get(id: i32) -> TransformNode:
        val idx = id.to_i64()
        val opt = self.nodes.get(idx)
        if val node = opt:
            node
        else:
            self.nodes.get(0).unwrap()

    me root_id() -> i32:
        0

# ---------------------------------------------------------------------------
# ClipTree
# ---------------------------------------------------------------------------

class ClipNode:
    id: i32
    parent_id: i32
    clip_x: f32
    clip_y: f32
    clip_w: f32
    clip_h: f32
    transform_id: i32
    applies_local_clip: bool

class ClipTree:
    nodes: [ClipNode]

    static fn new() -> ClipTree:
        val root = ClipNode(
            id: 0,
            parent_id: -1,
            clip_x: 0.0,
            clip_y: 0.0,
            clip_w: 0.0,
            clip_h: 0.0,
            transform_id: 0,
            applies_local_clip: false
        )
        val ns = [ClipNode]()
        ns.push(root)
        ClipTree(nodes: ns)

    me add_node(n: ClipNode) -> i32:
        val new_id = self.nodes.len().to_i32()
        val node = ClipNode(
            id: new_id,
            parent_id: n.parent_id,
            clip_x: n.clip_x,
            clip_y: n.clip_y,
            clip_w: n.clip_w,
            clip_h: n.clip_h,
            transform_id: n.transform_id,
            applies_local_clip: n.applies_local_clip
        )
        self.nodes.push(node)
        new_id

    me get(id: i32) -> ClipNode:
        val idx = id.to_i64()
        val opt = self.nodes.get(idx)
        if val node = opt:
            node
        else:
            self.nodes.get(0).unwrap()

    me root_id() -> i32:
        0

# ---------------------------------------------------------------------------
# EffectTree
# ---------------------------------------------------------------------------

class EffectNode:
    id: i32
    parent_id: i32
    opacity: f32
    blend_mode: i32
    has_render_surface: bool
    clip_id: i32
    transform_id: i32

class EffectTree:
    nodes: [EffectNode]

    static fn new() -> EffectTree:
        val root = EffectNode(
            id: 0,
            parent_id: -1,
            opacity: 1.0,
            blend_mode: 0,
            has_render_surface: false,
            clip_id: 0,
            transform_id: 0
        )
        val ns = [EffectNode]()
        ns.push(root)
        EffectTree(nodes: ns)

    me add_node(n: EffectNode) -> i32:
        val new_id = self.nodes.len().to_i32()
        val node = EffectNode(
            id: new_id,
            parent_id: n.parent_id,
            opacity: n.opacity,
            blend_mode: n.blend_mode,
            has_render_surface: n.has_render_surface,
            clip_id: n.clip_id,
            transform_id: n.transform_id
        )
        self.nodes.push(node)
        new_id

    me get(id: i32) -> EffectNode:
        val idx = id.to_i64()
        val opt = self.nodes.get(idx)
        if val node = opt:
            node
        else:
            self.nodes.get(0).unwrap()

    me root_id() -> i32:
        0

# ---------------------------------------------------------------------------
# ScrollTree
# ---------------------------------------------------------------------------

class ScrollNode:
    id: i32
    parent_id: i32
    scrollable: bool
    scroll_offset_x: f32
    scroll_offset_y: f32
    container_width: f32
    container_height: f32
    content_width: f32
    content_height: f32

class ScrollTree:
    nodes: [ScrollNode]

    static fn new() -> ScrollTree:
        val root = ScrollNode(
            id: 0,
            parent_id: -1,
            scrollable: false,
            scroll_offset_x: 0.0,
            scroll_offset_y: 0.0,
            container_width: 0.0,
            container_height: 0.0,
            content_width: 0.0,
            content_height: 0.0
        )
        val ns = [ScrollNode]()
        ns.push(root)
        ScrollTree(nodes: ns)

    me add_node(n: ScrollNode) -> i32:
        val new_id = self.nodes.len().to_i32()
        val node = ScrollNode(
            id: new_id,
            parent_id: n.parent_id,
            scrollable: n.scrollable,
            scroll_offset_x: n.scroll_offset_x,
            scroll_offset_y: n.scroll_offset_y,
            container_width: n.container_width,
            container_height: n.container_height,
            content_width: n.content_width,
            content_height: n.content_height
        )
        self.nodes.push(node)
        new_id

    me get(id: i32) -> ScrollNode:
        val idx = id.to_i64()
        val opt = self.nodes.get(idx)
        if val node = opt:
            node
        else:
            self.nodes.get(0).unwrap()

    me root_id() -> i32:
        0

# ---------------------------------------------------------------------------
# PropertyTrees — bundle of the four trees
# ---------------------------------------------------------------------------

class PropertyTrees:
    transform_tree: TransformTree
    clip_tree: ClipTree
    effect_tree: EffectTree
    scroll_tree: ScrollTree

    static fn new() -> PropertyTrees:
        PropertyTrees(
            transform_tree: TransformTree.new(),
            clip_tree: ClipTree.new(),
            effect_tree: EffectTree.new(),
            scroll_tree: ScrollTree.new()
        )
