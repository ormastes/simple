# Property Tree — transform, clip, and effect trees for the compositor.
#
# Provides: TransformNode, TransformTree, ClipNode, ClipTree, EffectNode, EffectTree.

struct TransformNode:
    id: i32
    parent_id: i32
    local: [f32]

class TransformTree:
    nodes: [TransformNode]

    static fn new() -> TransformTree:
        TransformTree(nodes: [])

    me add_node(node: TransformNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<TransformNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None

struct ClipNode:
    id: i32
    parent_id: i32
    clip_rect_left: f64
    clip_rect_top: f64
    clip_rect_right: f64
    clip_rect_bottom: f64

class ClipTree:
    nodes: [ClipNode]

    static fn new() -> ClipTree:
        ClipTree(nodes: [])

    me add_node(node: ClipNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<ClipNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None

struct EffectNode:
    id: i32
    parent_id: i32
    opacity: f64
    blend_mode: i32
    has_render_surface: bool
    clip_id: i32
    transform_id: i32

class EffectTree:
    nodes: [EffectNode]

    static fn new() -> EffectTree:
        EffectTree(nodes: [])

    me add_node(node: EffectNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<EffectNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None
