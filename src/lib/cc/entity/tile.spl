# cc::Tile and TileKey — raster tile descriptors

use std.skia.entity.geometry.{SkIRect}

enum TilePriority:
    NowBin
    SoonBin
    EventuallyBin

class TileKey:
    layer_id: i32
    tiling_i: i32
    tiling_j: i32
    contents_scale: f64

    static fn new(layer_id: i32, tiling_i: i32, tiling_j: i32, contents_scale: f64) -> TileKey:
        TileKey(
            layer_id: layer_id,
            tiling_i: tiling_i,
            tiling_j: tiling_j,
            contents_scale: contents_scale
        )

    fn matches(other: TileKey) -> bool:
        (me.layer_id == other.layer_id and
            me.tiling_i == other.tiling_i and
            me.tiling_j == other.tiling_j)

class Tile:
    key: TileKey
    content_rect: SkIRect
    priority: TilePriority
    is_ready: bool
    raster_handle: i64
    draw_info_handle: i64

    static fn new(key: TileKey, content_rect: SkIRect, priority: TilePriority) -> Tile:
        Tile(
            key: key,
            content_rect: content_rect,
            priority: priority,
            is_ready: false,
            raster_handle: 0,
            draw_info_handle: 0
        )

    me set_ready(handle: i64):
        me.is_ready = true
        me.raster_handle = handle

    me invalidate():
        me.is_ready = false
        me.raster_handle = 0
