# ============================================================================
# Shared RTL constants (XLEN-neutral) — Wave-3 W3-1 extraction
# ============================================================================
#
# The rv32i_rtl and rv64gc_rtl packages agreed, byte-for-byte, on the 10 shared
# opcodes, the 11 shared ALU codes (0..10), and the RV32I load/store funct3 set
# (a strict subset of the RV64 set). This module is the single source of truth
# for those; both per-width pkgs re-export the names unchanged so downstream
# `use std.hardware.rvXX_rtl.pkg.{...}` importers are untouched.
#
# Width specialization is COMPILE-TIME only (W2-A fail-closed): these are plain
# integer consts, no runtime XlenConfig dispatch. RV64-only opcodes/ALU codes
# (OP_OP_32, OP_OP_IMM_32, OP_AMO, ALU_*W, MULDIV_*) stay in the rv64 pkg.
#
# NOTE: RTL naming (OP_IMMED / OP_REG) intentionally differs from the behavioral
# tree (riscv_common/decode.spl's OP_OP_IMM / OP_OP); the VALUES match. This
# module carries the RTL names to keep the RTL importers bit-identical.
# ============================================================================

# ----------------------------------------------------------------------------
# Shared opcode constants (7-bit, stored in u32) — 10 opcodes common to RV32/RV64
# ----------------------------------------------------------------------------

val OP_LUI: u32    = 0x37    # Load Upper Immediate
val OP_AUIPC: u32  = 0x17    # Add Upper Immediate to PC
val OP_JAL: u32    = 0x6F    # Jump And Link
val OP_JALR: u32   = 0x67    # Jump And Link Register
val OP_BRANCH: u32 = 0x63    # Conditional branch
val OP_LOAD: u32   = 0x03    # Load
val OP_STORE: u32  = 0x23    # Store
val OP_IMMED: u32  = 0x13    # Integer register-immediate
val OP_REG: u32    = 0x33    # Integer register-register
val OP_SYSTEM: u32 = 0x73    # ECALL, EBREAK, CSR

# ----------------------------------------------------------------------------
# Shared ALU operation codes (i64 enum) — 11 codes common to RV32/RV64 (0..10)
# ----------------------------------------------------------------------------

val ALU_ADD: i64    = 0
val ALU_SUB: i64    = 1
val ALU_SLL: i64    = 2
val ALU_SLT: i64    = 3
val ALU_SLTU: i64   = 4
val ALU_XOR: i64    = 5
val ALU_SRL: i64    = 6
val ALU_SRA: i64    = 7
val ALU_OR: i64     = 8
val ALU_AND: i64    = 9
val ALU_PASS_B: i64 = 10

# ----------------------------------------------------------------------------
# Shared load/store funct3 (3-bit) — the RV32I set (strict subset of RV64's)
# ----------------------------------------------------------------------------

val FUNCT3_LB: u32  = 0x0   # Load byte (sign-extend)
val FUNCT3_LH: u32  = 0x1   # Load halfword (sign-extend)
val FUNCT3_LW: u32  = 0x2   # Load word
val FUNCT3_LBU: u32 = 0x4   # Load byte unsigned
val FUNCT3_LHU: u32 = 0x5   # Load halfword unsigned

export OP_LUI, OP_AUIPC, OP_JAL, OP_JALR, OP_BRANCH
export OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM
export ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU
export ALU_XOR, ALU_SRL, ALU_SRA, ALU_OR, ALU_AND, ALU_PASS_B
export FUNCT3_LB, FUNCT3_LH, FUNCT3_LW, FUNCT3_LBU, FUNCT3_LHU
