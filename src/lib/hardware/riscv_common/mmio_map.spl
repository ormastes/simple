# ============================================================================
# RISC-V Canonical MMIO Memory Map (shared RV32 / RV64)
# ============================================================================
#
# Single source of truth for the QEMU-virt-compatible peripheral base
# addresses and sizes used by BOTH the RV32 (`wb_interconnect.spl`, u32) and
# RV64 (`wb64_interconnect.spl`, i64) Wishbone interconnects. Previously each
# interconnect (and `platform.spl`) hard-coded its own copy of these numbers;
# any edit to one silently diverged the other. They now derive from here so
# the rv32 and rv64 SoCs share one map.
#
# Values are i64 canonical form; the u32 rv32 side casts via `as u32`
# (all bases fit in 32 bits). This module is pure constants — VHDL/Verilog
# synthesis lowers each to a plain address literal.
#
#   0x00001000  Boot ROM   (4 KB)
#   0x02000000  CLINT      (64 KB)   — timer / IPI
#   0x0C000000  PLIC       (4 MB)    — external interrupt controller
#   0x10000000  UART0      (256 B)   — ns16550a console
#   0x80000000  DRAM       (main RAM)
# ============================================================================

val MMIO_BOOTROM_BASE: i64 = 0x0000_1000
val MMIO_BOOTROM_SIZE: i64 = 0x0000_1000

val MMIO_CLINT_BASE: i64   = 0x0200_0000
val MMIO_CLINT_SIZE: i64   = 0x0001_0000

val MMIO_PLIC_BASE: i64    = 0x0C00_0000
val MMIO_PLIC_SIZE: i64    = 0x0040_0000

val MMIO_UART_BASE: i64    = 0x1000_0000
val MMIO_UART_SIZE: i64    = 0x0000_0100

val MMIO_DRAM_BASE: i64    = 0x8000_0000

export MMIO_BOOTROM_BASE, MMIO_BOOTROM_SIZE, MMIO_CLINT_BASE, MMIO_CLINT_SIZE
export MMIO_PLIC_BASE, MMIO_PLIC_SIZE, MMIO_UART_BASE, MMIO_UART_SIZE
export MMIO_DRAM_BASE
