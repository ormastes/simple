# Generated RISC-V core proof-lane contracts.

pub enum RiscvProofLane:
    GeneratedRv32Linux
    GeneratedRv64Linux
    ReferenceExternalRv64Linux

impl RiscvProofLane:
    fn to_text() -> text:
        match self:
            case RiscvProofLane.GeneratedRv32Linux: "generated_rv32_linux"
            case RiscvProofLane.GeneratedRv64Linux: "generated_rv64_linux"
            case RiscvProofLane.ReferenceExternalRv64Linux: "reference_external_rv64_linux"

    fn requires_linux_boot() -> bool:
        self == RiscvProofLane.GeneratedRv32Linux or self == RiscvProofLane.GeneratedRv64Linux

    fn is_external_reference() -> bool:
        self == RiscvProofLane.ReferenceExternalRv64Linux

pub struct GeneratedCoreBootContract:
    opensbi_fw_jump: bool
    hartid_register: text
    dtb_register: text
    satp_reset_value: i64

pub struct GeneratedCoreSourceMapEntry:
    signal: text
    bit_slice: text

pub struct GeneratedCoreRunnerTestbench:
    file_name: text
    pass_marker: text

pub struct GeneratedCoreDebugMetadata:
    schema_version: text
    lane_id: text
    debug_outputs: [text]
    source_map: [GeneratedCoreSourceMapEntry]
    report_markers: [text]
    runner_testbenches: [GeneratedCoreRunnerTestbench]

pub struct GeneratedCoreShellContract:
    xlen_bits: i64
    proof_lane: RiscvProofLane
    boot: GeneratedCoreBootContract
    interrupt_inputs: [text]
    debug_outputs: [text]
    shell_services: [text]

impl GeneratedCoreShellContract:
    static fn rv32_linux() -> GeneratedCoreShellContract:
        GeneratedCoreShellContract(
            xlen_bits: 32,
            proof_lane: RiscvProofLane.GeneratedRv32Linux,
            boot: linux_boot_contract(),
            interrupt_inputs: ["machine_timer", "machine_external"],
            debug_outputs: ["semi_trigger", "semi_op", "semi_param"],
            shell_services: []
        )

    static fn rv64_linux() -> GeneratedCoreShellContract:
        GeneratedCoreShellContract(
            xlen_bits: 64,
            proof_lane: RiscvProofLane.GeneratedRv64Linux,
            boot: linux_boot_contract(),
            interrupt_inputs: ["machine_timer", "machine_external", "supervisor_external"],
            debug_outputs: ["semi_trigger", "semi_op", "semi_param", "debug_pc"],
            shell_services: []
        )

    fn acceptance_markers() -> [text]:
        ["OpenSBI", "Linux version", "OF: fdt", "Freeing unused kernel memory", "init started"]

    fn shell_services_summary() -> text:
        if self.shell_services.len() == 0:
            return "none"
        self.shell_services.join(",")

    fn debug_metadata() -> GeneratedCoreDebugMetadata:
        if self.xlen_bits == 32:
            return rv32_debug_metadata()
        rv64_debug_metadata()

fn linux_boot_contract() -> GeneratedCoreBootContract:
    GeneratedCoreBootContract(
        opensbi_fw_jump: true,
        hartid_register: "a0",
        dtb_register: "a1",
        satp_reset_value: 0
    )

fn common_source_map() -> [GeneratedCoreSourceMapEntry]:
    [
        GeneratedCoreSourceMapEntry(signal: "Instruction.opcode", bit_slice: "imem_rdata(6 downto 0)"),
        GeneratedCoreSourceMapEntry(signal: "Instruction.rd", bit_slice: "imem_rdata(11 downto 7)"),
        GeneratedCoreSourceMapEntry(signal: "Instruction.funct3", bit_slice: "imem_rdata(14 downto 12)"),
        GeneratedCoreSourceMapEntry(signal: "Instruction.rs1", bit_slice: "imem_rdata(19 downto 15)"),
        GeneratedCoreSourceMapEntry(signal: "Instruction.rs2", bit_slice: "imem_rdata(24 downto 20)"),
        GeneratedCoreSourceMapEntry(signal: "Instruction.funct7", bit_slice: "imem_rdata(31 downto 25)"),
        GeneratedCoreSourceMapEntry(signal: "Boot.hartid", bit_slice: "a0"),
        GeneratedCoreSourceMapEntry(signal: "Boot.dtb", bit_slice: "a1"),
        GeneratedCoreSourceMapEntry(signal: "Trap.cause", bit_slice: "mcause"),
        GeneratedCoreSourceMapEntry(signal: "Trap.value", bit_slice: "mtval"),
        GeneratedCoreSourceMapEntry(signal: "Debug.pc", bit_slice: "pc"),
        GeneratedCoreSourceMapEntry(signal: "Debug.halt", bit_slice: "halted")
    ]

fn rv32_debug_metadata() -> GeneratedCoreDebugMetadata:
    GeneratedCoreDebugMetadata(
        schema_version: "riscv_rtl_debuggability_lint/v1",
        lane_id: "rv32",
        debug_outputs: ["semi_trigger", "semi_op", "semi_param"],
        source_map: common_source_map(),
        report_markers: ["PASS_WORD:", "A0_LOW32:", "A1_LOW32:", "UART_BYTES_LOW32:", "DTB_PROBE_SEEN:", "FINAL_PC_HEX32:", "HALT_SEEN:", "TRAP_SEEN:"],
        runner_testbenches: [
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv32_linux_handoff.vhd", pass_marker: "GENERATED_RV32_LINUX_HANDOFF: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv32_boot_info_real_dtb.vhd", pass_marker: "GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS")
        ]
    )

fn rv64_debug_metadata() -> GeneratedCoreDebugMetadata:
    GeneratedCoreDebugMetadata(
        schema_version: "riscv_rtl_debuggability_lint/v1",
        lane_id: "rv64",
        debug_outputs: ["semi_trigger", "semi_op", "semi_param", "debug_pc"],
        source_map: common_source_map(),
        report_markers: ["PASS_WORD:", "A0_LOW32:", "A1_LOW32:", "UART_BYTES_LOW32:", "PC_LOW32:", "DTB_PROBE_SEEN:", "TRAP_EDGE_PC_HEX32", "HALT_EDGE_PC_HEX32", "HEARTBEAT_PC_HEX32", "PROGRESS_PC_HEX32", "CHECK_PRIV_MODE_OK:", "TRAP_CAUSE_WORD:", "TRAP_TVAL_WORD:", "CAUSE_WORD:", "TVAL_WORD:"],
        runner_testbenches: [
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_linux_handoff.vhd", pass_marker: "GENERATED_RV64_LINUX_HANDOFF: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_boot_banner.vhd", pass_marker: "GENERATED_RV64_BOOT_BANNER: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_boot_info_dtb.vhd", pass_marker: "GENERATED_RV64_BOOT_INFO_DTB: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_fw_jump.vhd", pass_marker: "GENERATED_RV64_FW_JUMP: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_boot_info_real_dtb.vhd", pass_marker: "GENERATED_RV64_BOOT_INFO_REAL_DTB: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_sv39.vhd", pass_marker: "GENERATED_RV64_SV39: PASS"),
            GeneratedCoreRunnerTestbench(file_name: "tb_generated_rv64_sv39_fault.vhd", pass_marker: "GENERATED_RV64_SV39_FAULT: PASS")
        ]
    )
