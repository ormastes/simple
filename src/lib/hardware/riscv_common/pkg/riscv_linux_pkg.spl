# Shared RISC-V Linux platform contracts.

pub enum RiscvTargetAbi:
    ILP32
    ILP32D
    LP64
    LP64D

impl RiscvTargetAbi:
    fn to_text() -> text:
        match self:
            case RiscvTargetAbi.ILP32: "ilp32"
            case RiscvTargetAbi.ILP32D: "ilp32d"
            case RiscvTargetAbi.LP64: "lp64"
            case RiscvTargetAbi.LP64D: "lp64d"

pub enum RiscvMmuMode:
    Bare
    Sv32
    Sv39

impl RiscvMmuMode:
    fn to_text() -> text:
        match self:
            case RiscvMmuMode.Bare: "bare"
            case RiscvMmuMode.Sv32: "sv32"
            case RiscvMmuMode.Sv39: "sv39"

pub struct RiscvLinuxProfile:
    xlen: i64
    abi: RiscvTargetAbi
    isa: text
    mmu_mode: RiscvMmuMode
    opensbi_required: bool

impl RiscvLinuxProfile:
    static fn rv32_qemu_virt_linux() -> RiscvLinuxProfile:
        RiscvLinuxProfile(
            xlen: 32,
            abi: RiscvTargetAbi.ILP32D,
            isa: "rv32gc",
            mmu_mode: RiscvMmuMode.Sv32,
            opensbi_required: true
        )

    static fn rv64_qemu_virt_linux() -> RiscvLinuxProfile:
        RiscvLinuxProfile(
            xlen: 64,
            abi: RiscvTargetAbi.LP64D,
            isa: "rv64gc",
            mmu_mode: RiscvMmuMode.Sv39,
            opensbi_required: true
        )

pub struct RiscvPlatformProfile:
    name: text
    linux: RiscvLinuxProfile
    hartid_register: text
    dtb_register: text
    satp_reset_value: i64
    blocks: [text]

impl RiscvPlatformProfile:
    static fn qemu_virt_rv32() -> RiscvPlatformProfile:
        RiscvPlatformProfile(
            name: "qemu_virt_rv32",
            linux: RiscvLinuxProfile.rv32_qemu_virt_linux(),
            hartid_register: "a0",
            dtb_register: "a1",
            satp_reset_value: 0,
            blocks: ["rv32gc-core", "sv32-mmu", "opensbi-handoff", "qemu-virt-mmio"]
        )

    static fn qemu_virt_rv64() -> RiscvPlatformProfile:
        RiscvPlatformProfile(
            name: "qemu_virt_rv64",
            linux: RiscvLinuxProfile.rv64_qemu_virt_linux(),
            hartid_register: "a0",
            dtb_register: "a1",
            satp_reset_value: 0,
            blocks: ["rv64gc-core", "sv39-mmu", "opensbi-handoff", "qemu-virt-mmio"]
        )

    fn required_soc_blocks() -> [text]:
        self.blocks

pub struct Rv32LinuxBootArtifacts:
    kernel_image: text
    initrd_rootfs: text
    dtb: text
    firmware: text

impl Rv32LinuxBootArtifacts:
    static fn empty() -> Rv32LinuxBootArtifacts:
        Rv32LinuxBootArtifacts(kernel_image: "", initrd_rootfs: "", dtb: "", firmware: "")

    fn validate_for(profile: RiscvLinuxProfile) -> [text]:
        validate_linux_boot_artifacts(self.kernel_image, self.initrd_rootfs, self.dtb, self.firmware, profile)

pub struct Rv64LinuxBootArtifacts:
    kernel_image: text
    initrd_rootfs: text
    dtb: text
    firmware: text

impl Rv64LinuxBootArtifacts:
    static fn empty() -> Rv64LinuxBootArtifacts:
        Rv64LinuxBootArtifacts(kernel_image: "", initrd_rootfs: "", dtb: "", firmware: "")

    fn validate_for(profile: RiscvLinuxProfile) -> [text]:
        validate_linux_boot_artifacts(self.kernel_image, self.initrd_rootfs, self.dtb, self.firmware, profile)

fn validate_linux_boot_artifacts(kernel_image: text, initrd_rootfs: text, dtb: text, firmware: text, profile: RiscvLinuxProfile) -> [text]:
    var errors: [text] = []
    if kernel_image == "":
        errors = errors.push("kernel_image is required")
    if initrd_rootfs == "":
        errors = errors.push("initrd_rootfs is required")
    if dtb == "":
        errors = errors.push("dtb is required")
    if profile.opensbi_required and firmware == "":
        errors = errors.push("OpenSBI or U-Boot firmware is required")
    errors
