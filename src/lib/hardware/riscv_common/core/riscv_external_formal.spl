# RV32 external formal bundle generation.

use std.io_runtime.{file_read, file_write, shell}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{probe_external_formal}
use std.nogc_sync_mut.debug.remote.exec.result_channel.{ResultPacket}

struct RiscvExternalFormalBundle:
    root_dir: text
    harness_path: text
    sby_path: text
    manifest_path: text

fn rv32_external_formal_default_dir() -> text:
    "build/rtl/formal/rv32_external"

fn rv32_external_formal_harness_text() -> text:
    """Render a VHDL harness around rv32i_core with RVFI-visible assertions."""
    """
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity rv32i_core_external_formal is
    port (
        clk : in std_logic;
        reset_n : in std_logic;
        imem_data : in std_logic_vector(31 downto 0);
        dmem_rdata : in std_logic_vector(31 downto 0)
    );
end entity rv32i_core_external_formal;

architecture formal of rv32i_core_external_formal is
    signal imem_addr : std_logic_vector(31 downto 0);
    signal dmem_addr : std_logic_vector(31 downto 0);
    signal dmem_wdata : std_logic_vector(31 downto 0);
    signal dmem_we : std_logic;
    signal dmem_re : std_logic;
    signal dmem_width : std_logic_vector(1 downto 0);
    signal halted : std_logic;
    signal semi_trigger : std_logic;
    signal semi_op : std_logic_vector(31 downto 0);
    signal semi_param : std_logic_vector(31 downto 0);
    signal halted_seen : std_logic := '0';
    signal rvfi_valid : std_logic;
    signal rvfi_order : std_logic_vector(63 downto 0);
    signal rvfi_insn : std_logic_vector(31 downto 0);
    signal rvfi_trap : std_logic;
    signal rvfi_rs1_addr : std_logic_vector(4 downto 0);
    signal rvfi_rs2_addr : std_logic_vector(4 downto 0);
    signal rvfi_rs1_rdata : std_logic_vector(31 downto 0);
    signal rvfi_rs2_rdata : std_logic_vector(31 downto 0);
    signal rvfi_rd_addr : std_logic_vector(4 downto 0);
    signal rvfi_rd_wdata : std_logic_vector(31 downto 0);
    signal rvfi_pc_rdata : std_logic_vector(31 downto 0);
    signal rvfi_pc_wdata : std_logic_vector(31 downto 0);
    signal rvfi_mem_addr : std_logic_vector(31 downto 0);
    signal rvfi_mem_rmask : std_logic_vector(3 downto 0);
    signal rvfi_mem_wmask : std_logic_vector(3 downto 0);
    signal rvfi_mem_rdata : std_logic_vector(31 downto 0);
    signal rvfi_mem_wdata : std_logic_vector(31 downto 0);
begin
    dut: entity work.rv32i_core
        port map (
            clk => clk,
            reset_n => reset_n,
            imem_addr => imem_addr,
            imem_data => imem_data,
            dmem_addr => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we => dmem_we,
            dmem_re => dmem_re,
            dmem_width => dmem_width,
            halted => halted,
            semi_trigger => semi_trigger,
            semi_op => semi_op,
            semi_param => semi_param,
            rvfi_valid => rvfi_valid,
            rvfi_order => rvfi_order,
            rvfi_insn => rvfi_insn,
            rvfi_trap => rvfi_trap,
            rvfi_rs1_addr => rvfi_rs1_addr,
            rvfi_rs2_addr => rvfi_rs2_addr,
            rvfi_rs1_rdata => rvfi_rs1_rdata,
            rvfi_rs2_rdata => rvfi_rs2_rdata,
            rvfi_rd_addr => rvfi_rd_addr,
            rvfi_rd_wdata => rvfi_rd_wdata,
            rvfi_pc_rdata => rvfi_pc_rdata,
            rvfi_pc_wdata => rvfi_pc_wdata,
            rvfi_mem_addr => rvfi_mem_addr,
            rvfi_mem_rmask => rvfi_mem_rmask,
            rvfi_mem_wmask => rvfi_mem_wmask,
            rvfi_mem_rdata => rvfi_mem_rdata,
            rvfi_mem_wdata => rvfi_mem_wdata
        );

    process(clk)
    begin
        if rising_edge(clk) then
            if reset_n = '0' then
                halted_seen <= '0';
            else
                assert imem_addr(0) = '0'
                    report "instruction fetch address must stay halfword aligned"
                    severity failure;
                if dmem_re = '1' or dmem_we = '1' then
                    assert dmem_addr(0) = '0' or dmem_width = "00"
                        report "halfword memory accesses must stay halfword aligned"
                        severity failure;
                end if;
                if halted_seen = '1' then
                    assert halted = '1'
                        report "halted must be sticky once asserted"
                        severity failure;
                end if;
                if halted = '1' then
                    halted_seen <= '1';
                end if;
                if semi_trigger = '1' then
                    assert semi_op = x"00000018"
                        report "unexpected semihost operation observed"
                        severity failure;
                end if;
                if rvfi_valid = '1' then
                    assert rvfi_insn = imem_data
                        report "rvfi_insn must mirror fetched instruction"
                        severity failure;
                    assert rvfi_pc_rdata = imem_addr
                        report "rvfi_pc_rdata must mirror instruction address"
                        severity failure;
                    assert rvfi_pc_wdata(0) = '0'
                        report "rvfi_pc_wdata must stay halfword aligned"
                        severity failure;
                end if;
            end if;
        end if;
    end process;
end architecture formal;
"""

fn rv32_external_formal_sby_text() -> text:
    """
[options]
mode prove
depth 8

[engines]
smtbmc

[script]
ghdl --std=08 examples/09_embedded/fpga_riscv/rtl/rv32i_pkg.vhd examples/09_embedded/fpga_riscv/rtl/decoder.vhd examples/09_embedded/fpga_riscv/rtl/regfile.vhd examples/09_embedded/fpga_riscv/rtl/alu.vhd examples/09_embedded/fpga_riscv/rtl/rv32i_core.vhd rv32i_core_external_formal.vhd -e rv32i_core_external_formal
prep -top rv32i_core_external_formal

[files]
examples/09_embedded/fpga_riscv/rtl/rv32i_pkg.vhd
examples/09_embedded/fpga_riscv/rtl/decoder.vhd
examples/09_embedded/fpga_riscv/rtl/regfile.vhd
examples/09_embedded/fpga_riscv/rtl/alu.vhd
examples/09_embedded/fpga_riscv/rtl/rv32i_core.vhd
rv32i_core_external_formal.vhd
"""

fn rv32_external_formal_manifest_text(bundle: RiscvExternalFormalBundle) -> text:
    "arch = \"riscv32\"\n" +
    "proof_style = \"rvfi_structural\"\n" +
    "runner = \"sby -f rv32i_core_external.sby\"\n" +
    "harness = \"" + bundle.harness_path + "\"\n" +
    "sby = \"" + bundle.sby_path + "\"\n"

fn generate_rv32_external_formal_bundle(root_dir: text) -> Result<RiscvExternalFormalBundle, text>:
    val mkdir_result = shell("mkdir -p '" + root_dir + "'")
    if mkdir_result.exit_code != 0:
        return Err(mkdir_result.stderr)
    val bundle = RiscvExternalFormalBundle(
        root_dir: root_dir,
        harness_path: root_dir + "/rv32i_core_external_formal.vhd",
        sby_path: root_dir + "/rv32i_core_external.sby",
        manifest_path: root_dir + "/manifest.sdn"
    )
    if not file_write(bundle.harness_path, rv32_external_formal_harness_text()):
        return Err("failed to write RV32 external formal harness")
    if not file_write(bundle.sby_path, rv32_external_formal_sby_text()):
        return Err("failed to write RV32 external formal sby")
    if not file_write(bundle.manifest_path, rv32_external_formal_manifest_text(bundle)):
        return Err("failed to write RV32 external formal manifest")
    Ok(bundle)

fn read_generated_bundle_file(path: text) -> text:
    file_read(path)

fn run_rv32_external_formal_packet(bundle: RiscvExternalFormalBundle) -> ResultPacket:
    val report = probe_external_formal()
    if not report.is_runnable():
        return ResultPacket.skipped("riscv_external_formal", "exit_code", report.detail, 0)
    val result = shell("cd '" + bundle.root_dir + "' && sby -f rv32i_core_external.sby")
    ResultPacket.from_exit_code("riscv_external_formal", result.exit_code, result.stdout + result.stderr, 0)

fn run_rv32_external_formal(bundle: RiscvExternalFormalBundle) -> Result<text, text>:
    val packet = run_rv32_external_formal_packet(bundle)
    if packet.is_skip():
        return Err(packet.output)
    if packet.is_pass():
        return Ok(packet.output)
    Err(packet.output)
