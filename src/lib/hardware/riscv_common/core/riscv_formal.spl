# RISC-V formal verification stubs — hardware.riscv_common.core.riscv_formal
#
# Provides formal verification contract functions for GHDL RV32 simulation.
# Consumers: nogc_sync_mut/debug/remote/exec/adapter_ghdl_rv32.spl,
#            nogc_async_mut/debug/remote/exec/adapter_ghdl_rv32.spl

extern fn rt_ghdl_verify_vhdl_constraints(arch: text) -> i64
extern fn rt_ghdl_verify_return_zero_contract(code_start: i64, exit_code: i64, arch: text) -> i64

use std.nogc_sync_mut.debug.remote.exec.capability_report.{CapabilityReport, probe_external_formal}

fn verify_rv32_default_vhdl_constraints() -> Result<text, text>:
    """Run default VHDL constraint checks for a GHDL RV32 simulation.

    Returns Ok("passed") if all constraints pass, Err with diagnostic on failure.
    """
    val result = rt_ghdl_verify_vhdl_constraints("rv32")
    if result == 0:
        Ok("passed")
    else:
        Err("VHDL constraint check failed (code {result})")

fn verify_rv32_ghdl_return_zero_contract(code_start: i64, exit_code: i64) -> Result<text, text>:
    """Verify that an RV32 program under GHDL returned exit code 0.

    Args:
        code_start: Base address of the code segment in the memory map.
        exit_code:  Observed exit code from the simulation run.

    Returns Ok("contract satisfied") if exit_code == 0, Err otherwise.
    """
    val result = rt_ghdl_verify_return_zero_contract(code_start, exit_code, "rv32")
    if result == 0:
        Ok("contract satisfied")
    else:
        Err("RV32 return-zero contract violated: exit_code={exit_code}")

fn verify_rv64_qemu_user_proof_contract(code_start: i64, exit_code: i64) -> Result<text, text>:
    """Verify that an RV64 program under QEMU user-mode returned exit code 0.

    Args:
        code_start: Base address of the code segment.
        exit_code:  Observed exit code from the QEMU run.

    Returns Ok("contract satisfied") if exit_code == 0, Err otherwise.
    """
    val result = rt_ghdl_verify_return_zero_contract(code_start, exit_code, "rv64")
    if result == 0:
        Ok("contract satisfied")
    else:
        Err("RV64 QEMU user-mode contract violated: exit_code={exit_code}")

fn probe_riscv_external_formal() -> CapabilityReport:
    """Probe the external RV32 formal lane through the shared capability model."""
    probe_external_formal()
