# RISC-V Common Hardware Abstractions
#
# Shared types, traits, and utilities for both RV32I and RV64I architectures.
# This module provides arch-neutral definitions that can be parameterised by
# XLEN (32 or 64) at construction time, avoiding code duplication between the
# riscv/ and riscv32/ baremetal modules.
#
# Components:
# - xlen:       XLEN configuration and width-aware helpers
# - registers:  Register file interface (x0-x31 + PC)
# - alu:        ALU operation definitions and evaluation
# - decode:     RV32I/RV64I base integer instruction decode
# - memory:     Memory interface trait for load/store abstraction
# - csr_defs:   Common CSR address constants and helpers
# - platform:   Platform contract for QEMU virt / SiFive boards

mod xlen
mod registers
mod alu
mod decode
mod memory
mod csr_defs
mod platform
mod pkg
