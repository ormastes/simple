# RV32I RVFI trace metadata.

struct RvfiTrace:
    """RISC-V Formal Interface trace bundle for one retired RV32I instruction."""
    rvfi_valid: bool
    rvfi_order: i64
    rvfi_insn: u32
    rvfi_trap: bool
    rvfi_rs1_addr: u32
    rvfi_rs2_addr: u32
    rvfi_rs1_rdata: u32
    rvfi_rs2_rdata: u32
    rvfi_rd_addr: u32
    rvfi_rd_wdata: u32
    rvfi_pc_rdata: u32
    rvfi_pc_wdata: u32
    rvfi_mem_addr: u32
    rvfi_mem_rmask: u32
    rvfi_mem_wmask: u32
    rvfi_mem_rdata: u32
    rvfi_mem_wdata: u32

struct RvfiPort:
    name: text
    width: i32
    direction: text

struct RvfiConfig:
    enabled: bool
    order_start: i64

struct RvfiFormalReadiness:
    core_entity: text
    ready: bool
    missing_ports: [text]
    message: text

struct RvfiCoreSnapshot:
    """Core signals needed to form an RVFI trace."""
    halted: bool
    suppress: bool
    pc: u32
    pc_next: u32
    insn: u32
    rs1_addr: u32
    rs2_addr: u32
    rs1_rdata: u32
    rs2_rdata: u32
    rd_addr: u32
    rd_wdata: u32
    dmem_addr: u32
    dmem_width: u32
    dmem_re: bool
    dmem_we: bool
    dmem_rdata: u32
    dmem_wdata: u32

fn rvfi_disabled_config() -> RvfiConfig:
    RvfiConfig(enabled: false, order_start: 0)

fn rvfi_enabled_config(order_start: i64) -> RvfiConfig:
    RvfiConfig(enabled: true, order_start: order_start)

fn rvfi_port_manifest() -> [RvfiPort]:
    [
        RvfiPort(name: "rvfi_valid", width: 1, direction: "out"),
        RvfiPort(name: "rvfi_order", width: 64, direction: "out"),
        RvfiPort(name: "rvfi_insn", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_trap", width: 1, direction: "out"),
        RvfiPort(name: "rvfi_halt", width: 1, direction: "out"),
        RvfiPort(name: "rvfi_intr", width: 1, direction: "out"),
        RvfiPort(name: "rvfi_mode", width: 2, direction: "out"),
        RvfiPort(name: "rvfi_ixl", width: 2, direction: "out"),
        RvfiPort(name: "rvfi_rs1_addr", width: 5, direction: "out"),
        RvfiPort(name: "rvfi_rs2_addr", width: 5, direction: "out"),
        RvfiPort(name: "rvfi_rs1_rdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_rs2_rdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_rd_addr", width: 5, direction: "out"),
        RvfiPort(name: "rvfi_rd_wdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_pc_rdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_pc_wdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_mem_addr", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_mem_rmask", width: 4, direction: "out"),
        RvfiPort(name: "rvfi_mem_wmask", width: 4, direction: "out"),
        RvfiPort(name: "rvfi_mem_rdata", width: 32, direction: "out"),
        RvfiPort(name: "rvfi_mem_wdata", width: 32, direction: "out")
    ]

fn rvfi_mask_for_width(width: u32) -> u32:
    if width == 0:
        return 0x1
    if width == 1:
        return 0x3
    if width == 2:
        return 0xF
    0xF

fn rvfi_trace_from_snapshot(config: RvfiConfig, order: i64, snapshot: RvfiCoreSnapshot) -> RvfiTrace:
    val valid = config.enabled and not snapshot.halted and not snapshot.suppress
    val mem_mask = rvfi_mask_for_width(snapshot.dmem_width)
    val rmask = if snapshot.dmem_re: mem_mask else: 0
    val wmask = if snapshot.dmem_we: mem_mask else: 0
    RvfiTrace(
        rvfi_valid: valid,
        rvfi_order: config.order_start + order,
        rvfi_insn: snapshot.insn,
        rvfi_trap: snapshot.halted,
        rvfi_rs1_addr: snapshot.rs1_addr,
        rvfi_rs2_addr: snapshot.rs2_addr,
        rvfi_rs1_rdata: snapshot.rs1_rdata,
        rvfi_rs2_rdata: snapshot.rs2_rdata,
        rvfi_rd_addr: snapshot.rd_addr,
        rvfi_rd_wdata: snapshot.rd_wdata,
        rvfi_pc_rdata: snapshot.pc,
        rvfi_pc_wdata: snapshot.pc_next,
        rvfi_mem_addr: snapshot.dmem_addr,
        rvfi_mem_rmask: rmask,
        rvfi_mem_wmask: wmask,
        rvfi_mem_rdata: snapshot.dmem_rdata,
        rvfi_mem_wdata: snapshot.dmem_wdata
    )

# ============================================================================
# RVFI trace self-check (retire-chain invariants)
# ============================================================================

fn rvfi_check_traces(traces: [RvfiTrace]) -> [text]:
    """Check retire-chain invariants over a collected RVFI trace.

    Invariants (riscv-formal insn_check / reg_check core subset):
      1. rvfi_order strictly increasing across valid retires.
      2. pc chaining: pc_wdata of retire N == pc_rdata of retire N+1,
         except when retire N trapped.
      3. x0 gating: rd_addr == 0 implies rd_wdata == 0.
      4. simultaneous rmask/wmask is reserved for one retired AMO.

    Returns a list of violation strings; empty list == all invariants hold.
    The caller must additionally reject vacuous runs (fewer than 2 valid
    retires) — see check_retire_chain in riscv_common.core.riscv_formal.
    """
    var violations: [text] = []
    var have_prev = false
    var prev_order: i64 = 0
    var prev_pc_wdata: u32 = 0
    var prev_trap = false
    var idx = 0
    for t in traces:
        if not t.rvfi_valid:
            idx = idx + 1
            continue
        if t.rvfi_rd_addr == 0 and t.rvfi_rd_wdata != 0:
            violations = violations.push("retire {idx}: x0 write nonzero rd_wdata")
        val is_amo = (t.rvfi_insn & 0x7F) == 0x2F
        if t.rvfi_mem_rmask != 0 and t.rvfi_mem_wmask != 0 and not is_amo:
            violations = violations.push("retire {idx}: simultaneous rmask and wmask")
        if have_prev:
            if t.rvfi_order <= prev_order:
                violations = violations.push("retire {idx}: order not monotonic ({t.rvfi_order} after {prev_order})")
            if not prev_trap and t.rvfi_pc_rdata != prev_pc_wdata:
                violations = violations.push("retire {idx}: pc chain broken (pc_rdata != prev pc_wdata)")
        prev_order = t.rvfi_order
        prev_pc_wdata = t.rvfi_pc_wdata
        prev_trap = t.rvfi_trap
        have_prev = true
        idx = idx + 1
    violations

fn rvfi_valid_retire_count(traces: [RvfiTrace]) -> i64:
    """Count valid retires in a trace (vacuity guard input)."""
    var n: i64 = 0
    for t in traces:
        if t.rvfi_valid:
            n = n + 1
    n

fn rvfi_vhdl_type(width: i32) -> text:
    if width == 1:
        return "std_logic"
    "std_logic_vector(" + (width - 1).to_text() + " downto 0)"

fn rvfi_missing_vhdl_ports(entity_vhdl: text) -> [text]:
    var missing: [text] = []
    for port in rvfi_port_manifest():
        if not entity_vhdl.contains(port.name):
            missing = missing.push(port.name)
    missing

fn rvfi_formal_readiness(core_entity: text, entity_vhdl: text) -> RvfiFormalReadiness:
    val missing = rvfi_missing_vhdl_ports(entity_vhdl)
    if missing.len() == 0:
        return RvfiFormalReadiness(
            core_entity: core_entity,
            ready: true,
            missing_ports: missing,
            message: core_entity + " exposes the full RVFI port manifest"
        )
    RvfiFormalReadiness(
        core_entity: core_entity,
        ready: false,
        missing_ports: missing,
        message: core_entity + " is missing " + missing.len().to_text() + " RVFI ports"
    )

fn rvfi_render_formal_readiness(readiness: RvfiFormalReadiness) -> text:
    var out = readiness.message + "\n"
    for port in readiness.missing_ports:
        out = out + "- " + port + "\n"
    out

fn rvfi_formal_wrapper_ports(entity_name: text) -> text:
    var out = "-- RVFI wrapper ports for " + entity_name + "\n"
    for port in rvfi_port_manifest():
        out = out + "    " + port.name + " : " + port.direction + " " + rvfi_vhdl_type(port.width) + "\n"
    out

fn rvfi_formal_wrapper_vhdl(wrapper_entity: text, core_entity: text) -> text:
    """Render a VHDL-2008 riscv-formal wrapper for an RVFI-enabled RV32I core."""
    val ports = rvfi_port_manifest()
    var out = "library ieee;\n"
    out = out + "use ieee.std_logic_1164.all;\n\n"
    out = out + "entity " + wrapper_entity + " is\n"
    out = out + "    port (\n"
    out = out + "        clk : in std_logic;\n"
    out = out + "        reset_n : in std_logic;\n"
    out = out + "        imem_data : in std_logic_vector(31 downto 0);\n"
    out = out + "        dmem_rdata : in std_logic_vector(31 downto 0);\n"
    out = out + "        imem_addr : out std_logic_vector(31 downto 0);\n"
    out = out + "        dmem_addr : out std_logic_vector(31 downto 0);\n"
    out = out + "        dmem_wdata : out std_logic_vector(31 downto 0);\n"
    out = out + "        dmem_we : out std_logic;\n"
    out = out + "        dmem_re : out std_logic;\n"
    out = out + "        dmem_width : out std_logic_vector(1 downto 0);\n"
    for i in 0..ports.len():
        val port = ports[i]
        var sep = ";"
        if i == ports.len() - 1:
            sep = ""
        out = out + "        " + port.name + " : " + port.direction + " " + rvfi_vhdl_type(port.width) + sep + "\n"
    out = out + "    );\n"
    out = out + "end entity " + wrapper_entity + ";\n\n"
    out = out + "architecture formal of " + wrapper_entity + " is\n"
    out = out + "begin\n"
    out = out + "    dut: entity work." + core_entity + "\n"
    out = out + "        port map (\n"
    out = out + "            clk => clk,\n"
    out = out + "            reset_n => reset_n,\n"
    out = out + "            imem_addr => imem_addr,\n"
    out = out + "            imem_data => imem_data,\n"
    out = out + "            dmem_addr => dmem_addr,\n"
    out = out + "            dmem_wdata => dmem_wdata,\n"
    out = out + "            dmem_rdata => dmem_rdata,\n"
    out = out + "            dmem_we => dmem_we,\n"
    out = out + "            dmem_re => dmem_re,\n"
    out = out + "            dmem_width => dmem_width,\n"
    for i in 0..ports.len():
        val port = ports[i]
        var sep = ","
        if i == ports.len() - 1:
            sep = ""
        out = out + "            " + port.name + " => " + port.name + sep + "\n"
    out = out + "        );\n"
    out = out + "end architecture formal;\n"
    out
