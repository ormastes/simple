# ============================================================================
# RV32IM RTL CSR File — M-Mode Control/Status Registers
# ============================================================================
#
# Implements the machine-mode CSR register file for RV32IMSU. All operations
# are pure functions returning new state — suitable for synthesizable RTL.
#
# Supported CSRs:
#   Trap Setup:    mstatus, misa, mie, mtvec, mcounteren
#   Trap Handling: mscratch, mepc, mcause, mtval, mip
#   Counters:      mcycle/h, minstret/h and Zicntr read-only shadows
#   Info:          mhartid (read-only)
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

# ============================================================================
# CSR Address Constants (u32 for RTL address matching)
# ============================================================================

val CSR_ADDR_MSTATUS: u32   = 0x300
val CSR_ADDR_MISA: u32      = 0x301
val CSR_ADDR_MEDELEG: u32   = 0x302
val CSR_ADDR_MIDELEG: u32   = 0x303
val CSR_ADDR_MIE: u32       = 0x304
val CSR_ADDR_MTVEC: u32     = 0x305
val CSR_ADDR_MCOUNTEREN: u32 = 0x306
val CSR_ADDR_MSCRATCH: u32  = 0x340
val CSR_ADDR_MEPC: u32      = 0x341
val CSR_ADDR_MCAUSE: u32    = 0x342
val CSR_ADDR_MTVAL: u32     = 0x343
val CSR_ADDR_MIP: u32       = 0x344
val CSR_ADDR_MCYCLE: u32    = 0xB00
val CSR_ADDR_MCYCLEH: u32   = 0xB80
val CSR_ADDR_MINSTRET: u32  = 0xB02
val CSR_ADDR_MINSTRETH: u32 = 0xB82
val CSR_ADDR_CYCLE: u32     = 0xC00
val CSR_ADDR_TIME: u32      = 0xC01
val CSR_ADDR_INSTRET: u32   = 0xC02
val CSR_ADDR_CYCLEH: u32    = 0xC80
val CSR_ADDR_TIMEH: u32     = 0xC81
val CSR_ADDR_INSTRETH: u32  = 0xC82
val CSR_ADDR_MHARTID: u32   = 0xF14

# ============================================================================
# MSTATUS Bit Masks (u32 for bitwise ops)
# ============================================================================

val MSTATUS_MIE_MASK: u32   = 0x00000008   # bit 3
val MSTATUS_MPIE_MASK: u32  = 0x00000080   # bit 7
val MSTATUS_MPP_MASK: u32   = 0x00001800   # bits [12:11]
val MSTATUS_MPRV_MASK: u32  = 0x00020000   # bit 17
val MSTATUS_TW_MASK: u32    = 0x00200000   # bit 21
val MSTATUS_SUPERVISOR_MASK: u32 = 0x000C0122

val COUNTEREN_CY_MASK: u32 = 0x1
val COUNTEREN_TM_MASK: u32 = 0x2
val COUNTEREN_IR_MASK: u32 = 0x4
val COUNTEREN_SUPPORTED_MASK: u32 = 0x7

val MSTATUS_MIE_BIT: u32    = 3
val MSTATUS_MPIE_BIT: u32   = 7
val MSTATUS_MPP_LO_BIT: u32 = 11

val MPP_S_MODE: u32         = 0x00000800
val MPP_M_MODE: u32         = 0x00001800

# ============================================================================
# MIE / MIP Bit Masks
# ============================================================================

val MIP_MSIP_MASK: u32 = 0x00000008   # bit 3 — Machine Software Interrupt
val MIP_MTIP_MASK: u32 = 0x00000080   # bit 7 — Machine Timer Interrupt
val MIP_MEIP_MASK: u32 = 0x00000800   # bit 11 — Machine External Interrupt
val MIP_SSIP_MASK: u32 = 0x00000002   # bit 1 — Supervisor Software Interrupt
val MIP_STIP_MASK: u32 = 0x00000020   # bit 5 — Supervisor Timer Interrupt
val MIP_SEIP_MASK: u32 = 0x00000200   # bit 9 — Supervisor External Interrupt
val MIP_MACHINE_MASK: u32 = MIP_MSIP_MASK | MIP_MTIP_MASK | MIP_MEIP_MASK
val MIP_SUPERVISOR_MASK: u32 = MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK
val MIP_SUPPORTED_MASK: u32 = MIP_MACHINE_MASK | MIP_SUPERVISOR_MASK
# Implemented synchronous causes, including Sv32 page faults 12/13/15.
val MEDELEG_SUPPORTED_MASK: u32 = 0x0000B3AE
val MIDELEG_SUPPORTED_MASK: u32 = MIP_SUPERVISOR_MASK

# ============================================================================
# MISA: MXL=01 (bits [31:30]) plus implemented extension bits
# ============================================================================

val MISA_RV32I: u32 = 0x40000100
val MISA_RV32IM: u32 = 0x40001100
val MISA_RV32IMSU: u32 = 0x40141100
val MISA_RV32IMASU: u32 = 0x40141101

# ============================================================================
# CSR funct3 encodings (from SYSTEM instruction)
# ============================================================================

val FUNCT3_CSRRW: u32  = 0x1
val FUNCT3_CSRRS: u32  = 0x2
val FUNCT3_CSRRC: u32  = 0x3
val FUNCT3_CSRRWI: u32 = 0x5
val FUNCT3_CSRRSI: u32 = 0x6
val FUNCT3_CSRRCI: u32 = 0x7

export CSR_ADDR_MSTATUS
export CSR_ADDR_MISA
export CSR_ADDR_MEDELEG
export CSR_ADDR_MIDELEG
export CSR_ADDR_MIE
export CSR_ADDR_MTVEC
export CSR_ADDR_MCOUNTEREN
export CSR_ADDR_MSCRATCH
export CSR_ADDR_MEPC
export CSR_ADDR_MCAUSE
export CSR_ADDR_MTVAL
export CSR_ADDR_MIP
export CSR_ADDR_MCYCLE
export CSR_ADDR_MCYCLEH
export CSR_ADDR_MINSTRET
export CSR_ADDR_MINSTRETH
export CSR_ADDR_CYCLE
export CSR_ADDR_TIME
export CSR_ADDR_INSTRET
export CSR_ADDR_CYCLEH
export CSR_ADDR_TIMEH
export CSR_ADDR_INSTRETH
export CSR_ADDR_MHARTID
export MSTATUS_MIE_MASK
export MSTATUS_MPIE_MASK
export MSTATUS_MPP_MASK
export MSTATUS_MPRV_MASK
export MSTATUS_TW_MASK
export MSTATUS_SUPERVISOR_MASK
export COUNTEREN_CY_MASK
export COUNTEREN_TM_MASK
export COUNTEREN_IR_MASK
export COUNTEREN_SUPPORTED_MASK
export MSTATUS_MIE_BIT
export MSTATUS_MPIE_BIT
export MSTATUS_MPP_LO_BIT
export MPP_S_MODE
export MPP_M_MODE
export MIP_MSIP_MASK
export MIP_MTIP_MASK
export MIP_MEIP_MASK
export MIP_SSIP_MASK
export MIP_STIP_MASK
export MIP_SEIP_MASK
export MIP_MACHINE_MASK
export MIP_SUPERVISOR_MASK
export MIP_SUPPORTED_MASK
export MEDELEG_SUPPORTED_MASK
export MIDELEG_SUPPORTED_MASK
export MISA_RV32I
export MISA_RV32IM
export MISA_RV32IMSU
export MISA_RV32IMASU
export FUNCT3_CSRRW
export FUNCT3_CSRRS
export FUNCT3_CSRRC
export FUNCT3_CSRRWI
export FUNCT3_CSRRSI
export FUNCT3_CSRRCI

# ============================================================================
# CSR File Struct
# ============================================================================

struct CsrFile:
    """M-mode CSR register file.  All fields are u32."""
    mstatus: u32
    misa: u32
    medeleg: u32
    mideleg: u32
    mie: u32
    mtvec: u32
    mcounteren: u32
    mscratch: u32
    mepc: u32
    mcause: u32
    mtval: u32
    mip: u32
    seip_external: bool
    seip_software: bool
    mcycle: u32
    mcycleh: u32
    minstret: u32
    minstreth: u32
    mhartid: u32

# ============================================================================
# CSR Read/Write Result
# ============================================================================

struct CsrRwResult:
    """Result of a CSR read-modify-write operation."""
    csr: CsrFile      # Updated CSR file
    old_value: u32     # Previous value (written to rd)

# ============================================================================
# Create — initial CSR state after reset
# ============================================================================

@hardware
fn csr_create(hartid: u32) -> CsrFile:
    """Create initial CSR state for a given hart.
    misa indicates RV32IMSU, mstatus starts with interrupts disabled."""
    CsrFile(
        mstatus: 0,
        misa: MISA_RV32IMSU,
        medeleg: 0,
        mideleg: 0,
        mie: 0,
        mtvec: 0,
        mcounteren: 0,
        mscratch: 0,
        mepc: 0,
        mcause: 0,
        mtval: 0,
        mip: 0,
        seip_external: false,
        seip_software: false,
        mcycle: 0,
        mcycleh: 0,
        minstret: 0,
        minstreth: 0,
        mhartid: hartid
    )

# ============================================================================
# CSR Read — read by 12-bit address
# ============================================================================

@hardware
fn csr_read(csr: CsrFile, addr: u32) -> u32:
    """Read a CSR by its 12-bit address.  Unknown addresses return 0."""
    if addr == CSR_ADDR_MSTATUS:
        return csr.mstatus
    if addr == CSR_ADDR_MISA:
        return csr.misa
    if addr == CSR_ADDR_MEDELEG:
        return csr.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return csr.mideleg
    if addr == CSR_ADDR_MIE:
        return csr.mie
    if addr == CSR_ADDR_MTVEC:
        return csr.mtvec
    if addr == CSR_ADDR_MCOUNTEREN:
        return csr.mcounteren
    if addr == CSR_ADDR_MSCRATCH:
        return csr.mscratch
    if addr == CSR_ADDR_MEPC:
        return csr.mepc
    if addr == CSR_ADDR_MCAUSE:
        return csr.mcause
    if addr == CSR_ADDR_MTVAL:
        return csr.mtval
    if addr == CSR_ADDR_MIP:
        return csr.mip
    if addr == CSR_ADDR_MCYCLE:
        return csr.mcycle
    if addr == CSR_ADDR_MCYCLEH:
        return csr.mcycleh
    if addr == CSR_ADDR_MINSTRET:
        return csr.minstret
    if addr == CSR_ADDR_MINSTRETH:
        return csr.minstreth
    if addr == CSR_ADDR_CYCLE:
        return csr.mcycle
    if addr == CSR_ADDR_INSTRET:
        return csr.minstret
    if addr == CSR_ADDR_CYCLEH:
        return csr.mcycleh
    if addr == CSR_ADDR_INSTRETH:
        return csr.minstreth
    # TIME/TIMEH are known CSRs supplied by CoreState's CLINT inputs.
    if addr == CSR_ADDR_TIME or addr == CSR_ADDR_TIMEH:
        return 0
    if addr == CSR_ADDR_MHARTID:
        return csr.mhartid
    # Unknown CSR — return 0
    0

@hardware
fn csr_is_known(addr: u32) -> bool:
    (addr == CSR_ADDR_MSTATUS or addr == CSR_ADDR_MISA or
     addr == CSR_ADDR_MEDELEG or addr == CSR_ADDR_MIDELEG or
     addr == CSR_ADDR_MIE or addr == CSR_ADDR_MTVEC or
     addr == CSR_ADDR_MCOUNTEREN or
     addr == CSR_ADDR_MSCRATCH or addr == CSR_ADDR_MEPC or
     addr == CSR_ADDR_MCAUSE or addr == CSR_ADDR_MTVAL or
     addr == CSR_ADDR_MIP or addr == CSR_ADDR_MCYCLE or
     addr == CSR_ADDR_MCYCLEH or addr == CSR_ADDR_MINSTRET or
     addr == CSR_ADDR_MINSTRETH or addr == CSR_ADDR_CYCLE or
     addr == CSR_ADDR_TIME or addr == CSR_ADDR_INSTRET or
     addr == CSR_ADDR_CYCLEH or addr == CSR_ADDR_TIMEH or
     addr == CSR_ADDR_INSTRETH or addr == CSR_ADDR_MHARTID)

# ============================================================================
# CSR Write — write by 12-bit address
# ============================================================================

@hardware
fn csr_write(csr: CsrFile, addr: u32, value: u32) -> CsrFile:
    """Write a value to a CSR by address.  Read-only CSRs (misa, mhartid)
    and unknown addresses are silently ignored."""
    var out = csr
    if addr == CSR_ADDR_MSTATUS:
        val writable_mask: u32 = (MSTATUS_MIE_MASK | MSTATUS_MPIE_MASK |
            MSTATUS_MPP_MASK | MSTATUS_MPRV_MASK | MSTATUS_TW_MASK |
            MSTATUS_SUPERVISOR_MASK)
        var normalized = value & writable_mask
        if ((normalized & MSTATUS_MPP_MASK) >> MSTATUS_MPP_LO_BIT) == 2:
            normalized = normalized & (MSTATUS_MPP_MASK ^ 0xFFFFFFFF)
        out.mstatus = normalized
    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value & MEDELEG_SUPPORTED_MASK
    else if addr == CSR_ADDR_MIDELEG:
        out.mideleg = value & MIDELEG_SUPPORTED_MASK
    else if addr == CSR_ADDR_MIE:
        out.mie = value & MIP_SUPPORTED_MASK
    else if addr == CSR_ADDR_MTVEC:
        out.mtvec = value
    else if addr == CSR_ADDR_MCOUNTEREN:
        out.mcounteren = value & COUNTEREN_SUPPORTED_MASK
    else if addr == CSR_ADDR_MSCRATCH:
        out.mscratch = value
    else if addr == CSR_ADDR_MEPC:
        # mepc must be aligned to 4 bytes (IALIGN=32)
        out.mepc = value & 0xFFFFFFFC
    else if addr == CSR_ADDR_MCAUSE:
        out.mcause = value
    else if addr == CSR_ADDR_MTVAL:
        out.mtval = value
    else if addr == CSR_ADDR_MIP:
        # Machine firmware injects supervisor pending bits.  Platform-owned
        # machine bits remain driven by CLINT/PLIC, and SEIP is the logical OR
        # of the software latch and the external supervisor PLIC context.
        out.seip_software = (value & MIP_SEIP_MASK) != 0
        out.mip = (csr.mip & MIP_MACHINE_MASK) |
            (value & (MIP_SSIP_MASK | MIP_STIP_MASK))
        if out.seip_software or csr.seip_external:
            out.mip = out.mip | MIP_SEIP_MASK
    else if addr == CSR_ADDR_MCYCLE:
        out.mcycle = value
    else if addr == CSR_ADDR_MCYCLEH:
        out.mcycleh = value
    else if addr == CSR_ADDR_MINSTRET:
        out.minstret = value
    else if addr == CSR_ADDR_MINSTRETH:
        out.minstreth = value
    # misa, mhartid and the Zicntr shadows are read-only.
    out

# ============================================================================
# CSR Read-Modify-Write — CSRRW, CSRRS, CSRRC
# ============================================================================

@hardware
fn csr_next_value(old_value: u32, source: u32, funct3: u32) -> u32:
    """Apply the shared Zicsr read/modify/write operation."""
    val op = funct3 & 0x3
    if op == 1:
        return source
    if op == 2 and source != 0:
        return old_value | source
    if op == 3 and source != 0:
        return old_value & (source ^ 0xFFFFFFFF)
    old_value

@hardware
fn csr_write_requested(source: u32, funct3: u32) -> bool:
    val op = funct3 & 0x3
    op == 1 or ((op == 2 or op == 3) and source != 0)

@hardware
fn csr_rw(csr: CsrFile, addr: u32, rs1_val: u32, funct3: u32) -> CsrRwResult:
    """Perform a CSR read-modify-write operation.
    Returns the old value (for rd writeback) and the updated CsrFile.

    funct3 encoding:
      CSRRW  (0x1): swap — write rs1_val, return old
      CSRRS  (0x2): set bits — old | rs1_val
      CSRRC  (0x3): clear bits — old & ~rs1_val
      CSRRWI (0x5): swap with immediate (rs1_val is zero-extended imm)
      CSRRSI (0x6): set bits with immediate
      CSRRCI (0x7): clear bits with immediate
    """
    val old_value = csr_read(csr, addr)
    if not csr_write_requested(rs1_val, funct3):
        return CsrRwResult(csr: csr, old_value: old_value)
    var software_value = old_value
    if addr == CSR_ADDR_MIP:
        software_value = old_value & (MIP_SEIP_MASK ^ 0xFFFFFFFF)
        if csr.seip_software:
            software_value = software_value | MIP_SEIP_MASK
    val new_value = csr_next_value(software_value, rs1_val, funct3)
    CsrRwResult(csr: csr_write(csr, addr, new_value),
        old_value: old_value)

# ============================================================================
# CSR Tick — increment cycle and instruction counters
# ============================================================================

@hardware
fn csr_cycle_tick(csr: CsrFile) -> CsrFile:
    """Increment the 64-bit split cycle counter once per core clock."""
    var out = csr
    val new_mcycle = csr.mcycle + 1
    out.mcycle = new_mcycle
    if new_mcycle == 0:
        out.mcycleh = csr.mcycleh + 1
    out

@hardware
fn csr_retire_tick(csr: CsrFile) -> CsrFile:
    """Increment the 64-bit split retired-instruction counter."""
    var out = csr
    val new_minstret = csr.minstret + 1
    out.minstret = new_minstret
    if new_minstret == 0:
        out.minstreth = csr.minstreth + 1
    out

fn csr_tick(csr: CsrFile) -> CsrFile:
    """Compatibility helper for one cycle that also retires an instruction."""
    csr_retire_tick(csr_cycle_tick(csr))

# ============================================================================
# Update MIP — set interrupt pending bits from external sources
# ============================================================================

@hardware
fn csr_update_mip_ext(csr: CsrFile, mtip: bool, msip: bool, meip: bool,
                      seip: bool) -> CsrFile:
    """Update platform-owned pending bits while preserving M-injected S bits."""
    var new_mip = csr.mip & (MIP_SSIP_MASK | MIP_STIP_MASK)
    if msip:
        new_mip = new_mip | MIP_MSIP_MASK
    if mtip:
        new_mip = new_mip | MIP_MTIP_MASK
    if meip:
        new_mip = new_mip | MIP_MEIP_MASK
    if seip or csr.seip_software:
        new_mip = new_mip | MIP_SEIP_MASK
    var out = csr
    out.seip_external = seip
    out.mip = new_mip
    out

fn csr_update_mip(csr: CsrFile, mtip: bool, msip: bool, meip: bool) -> CsrFile:
    """Compatibility update for platforms with machine interrupt inputs only."""
    csr_update_mip_ext(csr, mtip, msip, meip, false)
