# ============================================================================
# RV32I RTL Trap Controller — Exception and Interrupt Handling
# ============================================================================
#
# Implements RISC-V M/S-mode trap entry/exit logic:
#   - Machine-before-supervisor interrupt priority checking
#   - Delegated trap entry through mtvec/stvec
#   - Trap exit through mret/sret
#
# All operations are pure functions — suitable for synthesizable RTL.
# Only direct mtvec mode is supported (vectored mode is a future extension).
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

use std.hardware.rv32i_rtl.csr.{CsrFile}
use std.hardware.rv32i_rtl.csr.{MSTATUS_MIE_MASK, MSTATUS_MPIE_MASK, MSTATUS_MPP_MASK}
use std.hardware.rv32i_rtl.csr.{MSTATUS_MIE_BIT, MSTATUS_MPIE_BIT, MSTATUS_MPP_LO_BIT}
use std.hardware.rv32i_rtl.csr.MSTATUS_MPRV_MASK
use std.hardware.rv32i_rtl.csr.{MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK}
use std.hardware.rv32i_rtl.csr.{MIP_SSIP_MASK, MIP_STIP_MASK, MIP_SEIP_MASK}
use std.hardware.rv32i_rtl.csr_s.{CsrSMode, csr_s_merge_mstatus}
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SIE_MASK, SSTATUS_SPIE_MASK}
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SPP_MASK, SSTATUS_SPP_BIT}

# ============================================================================
# Trap phase constants
# ============================================================================

val TRAP_NORMAL: u32 = 0   # Normal execution
val TRAP_ENTER: u32  = 1   # Entering trap handler
val TRAP_EXIT: u32   = 2   # Exiting trap handler (mret)

# ============================================================================
# Exception cause codes (mcause with MSB=0)
# ============================================================================

val CAUSE_MISALIGNED_FETCH: u32  = 0
val CAUSE_ILLEGAL_INSN: u32     = 2
val CAUSE_BREAKPOINT: u32       = 3
val CAUSE_LOAD_MISALIGNED: u32  = 4
val CAUSE_STORE_MISALIGNED: u32 = 6
val CAUSE_ECALL_U: u32         = 8
val CAUSE_ECALL_S: u32         = 9
val CAUSE_ECALL_M: u32         = 11

# ============================================================================
# Interrupt cause codes (mcause with MSB=1, bit 31 set)
# ============================================================================

val CAUSE_MSI: u32 = 0x80000003   # Machine Software Interrupt
val CAUSE_MTI: u32 = 0x80000007   # Machine Timer Interrupt
val CAUSE_MEI: u32 = 0x8000000B   # Machine External Interrupt
val CAUSE_SSI: u32 = 0x80000001   # Supervisor Software Interrupt
val CAUSE_STI: u32 = 0x80000005   # Supervisor Timer Interrupt
val CAUSE_SEI: u32 = 0x80000009   # Supervisor External Interrupt

# ============================================================================
# Trap State
# ============================================================================

struct TrapState:
    """Trap controller state."""
    phase: u32   # TRAP_NORMAL, TRAP_ENTER, or TRAP_EXIT

# ============================================================================
# Trap Enter Result
# ============================================================================

struct TrapEnterResult:
    """Result of entering a trap."""
    csr: CsrFile    # Updated CSR file (mepc, mcause, mtval, mstatus saved)
    trap_pc: u32     # Target PC (from mtvec, direct mode)

# ============================================================================
# Trap Exit Result
# ============================================================================

struct TrapExitResult:
    """Result of exiting a trap via mret."""
    csr: CsrFile      # Updated CSR file (mstatus restored)
    return_pc: u32     # Return PC (from mepc)
    target_mode: u32   # Restored privilege mode

struct TrapRouteResult:
    csr: CsrFile
    csr_s: CsrSMode
    trap_pc: u32
    target_mode: u32

struct SupervisorTrapExitResult:
    csr: CsrFile
    csr_s: CsrSMode
    return_pc: u32
    target_mode: u32

# ============================================================================
# Interrupt Check Result
# ============================================================================

struct InterruptCheckResult:
    """Result of checking for pending interrupts."""
    pending: bool    # True if an interrupt should be taken
    cause: u32       # Interrupt cause code (valid only if pending=true)

# ============================================================================
# Check for Pending Interrupts
# ============================================================================

@hardware
fn trap_interrupt_enabled(csr: CsrFile, priv_mode: u32,
                          bit: u32) -> bool:
    if priv_mode != 0 and priv_mode != 1 and priv_mode != 3:
        return false
    val delegated = (csr.mideleg & bit) != 0
    if delegated:
        if priv_mode == 3 or (csr.mie & bit) == 0:
            return false
        return priv_mode == 0 or (priv_mode == 1 and
            (csr.mstatus & SSTATUS_SIE_MASK) != 0)
    if (csr.mie & bit) == 0:
        return false
    priv_mode < 3 or (priv_mode == 3 and
        (csr.mstatus & MSTATUS_MIE_MASK) != 0)

@hardware
fn trap_check_interrupt_from_priv(csr: CsrFile,
                                  priv_mode: u32) -> InterruptCheckResult:
    """Select the highest-priority enabled M- or S-target interrupt."""
    val pending = csr.mip
    # Every M-target interrupt outranks every delegated S-target interrupt.
    if (csr.mideleg & MIP_MEIP_MASK) == 0 and
        (pending & MIP_MEIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_MEIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_MEI)
    if (csr.mideleg & MIP_MSIP_MASK) == 0 and
        (pending & MIP_MSIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_MSIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_MSI)
    if (csr.mideleg & MIP_MTIP_MASK) == 0 and
        (pending & MIP_MTIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_MTIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_MTI)
    if (csr.mideleg & MIP_SEIP_MASK) == 0 and
        (pending & MIP_SEIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_SEIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_SEI)
    if (csr.mideleg & MIP_SSIP_MASK) == 0 and
        (pending & MIP_SSIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_SSIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_SSI)
    if (csr.mideleg & MIP_STIP_MASK) == 0 and
        (pending & MIP_STIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_STIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_STI)
    if (csr.mideleg & MIP_SEIP_MASK) != 0 and
        (pending & MIP_SEIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_SEIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_SEI)
    if (csr.mideleg & MIP_SSIP_MASK) != 0 and
        (pending & MIP_SSIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_SSIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_SSI)
    if (csr.mideleg & MIP_STIP_MASK) != 0 and
        (pending & MIP_STIP_MASK) != 0 and
        trap_interrupt_enabled(csr, priv_mode, MIP_STIP_MASK):
        return InterruptCheckResult(pending: true, cause: CAUSE_STI)
    InterruptCheckResult(pending: false, cause: 0)

fn trap_check_interrupt(csr: CsrFile) -> InterruptCheckResult:
    """Compatibility check for callers currently executing in M-mode."""
    trap_check_interrupt_from_priv(csr, 3)

# ============================================================================
# Trap Entry
# ============================================================================

@hardware
fn trap_enter_from_priv(csr: CsrFile, pc: u32, cause: u32, tval: u32,
                        priv_mode: u32) -> TrapEnterResult:
    """Enter a trap: save context to CSRs, compute handler address.

    Updates:
      mepc    <- pc (faulting/interrupted instruction)
      mcause  <- cause
      mtval   <- tval (additional info, e.g. faulting address)
      mstatus <- MPIE=MIE, MIE=0, MPP=previous privilege

    Returns the new CSR state and the trap handler PC (mtvec direct mode)."""

    var new_csr = csr

    # Save exception context
    new_csr.mepc = pc & 0xFFFFFFFC    # Align to 4 bytes
    new_csr.mcause = cause
    new_csr.mtval = tval

    # Save and update mstatus:
    #   MPIE <- current MIE
    #   MIE  <- 0 (disable interrupts in handler)
    #   MPP  <- previous privilege
    val old_mie = (csr.mstatus & MSTATUS_MIE_MASK) >> MSTATUS_MIE_BIT
    var new_mstatus = csr.mstatus

    # Clear MIE, MPIE, MPP fields
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ 0xFFFFFFFF)

    # Set MPIE = old MIE
    new_mstatus = new_mstatus | (old_mie << MSTATUS_MPIE_BIT)
    # MIE = 0 (already cleared above)
    # Save the interrupted mode; reserved mode 2 is coerced to U.
    var previous_mode = priv_mode
    if previous_mode != 0 and previous_mode != 1 and previous_mode != 3:
        previous_mode = 0
    new_mstatus = new_mstatus | (previous_mode << MSTATUS_MPP_LO_BIT)

    new_csr.mstatus = new_mstatus

    # Compute trap handler PC from mtvec (direct mode only — mask off mode bits)
    val trap_pc = csr.mtvec & 0xFFFFFFFC

    TrapEnterResult(csr: new_csr, trap_pc: trap_pc)

fn trap_enter(csr: CsrFile, pc: u32, cause: u32, tval: u32) -> TrapEnterResult:
    """Compatibility trap entry for callers currently executing in M-mode."""
    trap_enter_from_priv(csr, pc, cause, tval, 3)

@hardware
fn trap_route(csr: CsrFile, csr_s: CsrSMode, pc: u32, cause: u32,
              tval: u32, priv_mode: u32) -> TrapRouteResult:
    """Route one trap to S when delegated from U/S, otherwise to M."""
    val is_interrupt = (cause & 0x80000000) != 0
    val cause_number = cause & 0x7FFFFFFF
    var delegated = false
    if priv_mode != 3 and cause_number < 32:
        if is_interrupt:
            delegated = ((csr.mideleg >> cause_number) & 1) != 0
        else:
            delegated = ((csr.medeleg >> cause_number) & 1) != 0

    if delegated:
        var next_s = csr_s
        next_s.sepc = pc & 0xFFFFFFFC
        next_s.scause = cause
        next_s.stval = tval
        val old_sie = (csr.mstatus & SSTATUS_SIE_MASK) != 0
        var next_status = (csr.mstatus &
            ((SSTATUS_SIE_MASK | SSTATUS_SPIE_MASK | SSTATUS_SPP_MASK) ^
             0xFFFFFFFF))
        if old_sie:
            next_status = next_status | SSTATUS_SPIE_MASK
        if priv_mode == 1:
            next_status = next_status | SSTATUS_SPP_MASK
        var next_m = csr
        next_m.mstatus = csr_s_merge_mstatus(next_m.mstatus, next_status)
        return TrapRouteResult(csr: next_m, csr_s: next_s,
            trap_pc: csr_s.stvec & 0xFFFFFFFC, target_mode: 1)

    val machine = trap_enter_from_priv(csr, pc, cause, tval, priv_mode)
    TrapRouteResult(csr: machine.csr, csr_s: csr_s,
        trap_pc: machine.trap_pc, target_mode: 3)

# ============================================================================
# Trap Exit (mret)
# ============================================================================

@hardware
fn trap_exit_mret(csr: CsrFile) -> TrapExitResult:
    """Exit from M-mode trap via MRET instruction.

    Updates:
      mstatus <- MIE=MPIE, MPIE=1, MPP=U

    Returns the new CSR state and the return PC (from mepc)."""

    var new_mstatus = csr.mstatus

    # Restore MIE from MPIE
    val old_mpie = (csr.mstatus & MSTATUS_MPIE_MASK) >> MSTATUS_MPIE_BIT

    # Clear MIE, MPIE, MPP
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ 0xFFFFFFFF)

    # MIE <- MPIE
    new_mstatus = new_mstatus | (old_mpie << MSTATUS_MIE_BIT)
    # MPIE <- 1
    new_mstatus = new_mstatus | MSTATUS_MPIE_MASK
    var target_mode = (csr.mstatus & MSTATUS_MPP_MASK) >> MSTATUS_MPP_LO_BIT
    if target_mode != 0 and target_mode != 1 and target_mode != 3:
        target_mode = 0
    if target_mode < 3:
        new_mstatus = new_mstatus & (MSTATUS_MPRV_MASK ^ 0xFFFFFFFF)

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    # Return PC from mepc
    val return_pc = csr.mepc

    TrapExitResult(csr: new_csr, return_pc: return_pc,
        target_mode: target_mode)

@hardware
fn trap_exit_sret(csr: CsrFile,
                  csr_s: CsrSMode) -> SupervisorTrapExitResult:
    """Restore SIE/SPIE/SPP and return to the privilege recorded in SPP."""
    val target_mode = (csr.mstatus & SSTATUS_SPP_MASK) >> SSTATUS_SPP_BIT
    val old_spie = (csr.mstatus & SSTATUS_SPIE_MASK) != 0
    var next_status = (csr.mstatus &
        ((SSTATUS_SIE_MASK | SSTATUS_SPIE_MASK | SSTATUS_SPP_MASK) ^
         0xFFFFFFFF))
    if old_spie:
        next_status = next_status | SSTATUS_SIE_MASK
    next_status = next_status | SSTATUS_SPIE_MASK
    var next_m = csr
    next_m.mstatus = csr_s_merge_mstatus(next_m.mstatus, next_status)
    next_m.mstatus = next_m.mstatus & (MSTATUS_MPRV_MASK ^ 0xFFFFFFFF)
    SupervisorTrapExitResult(csr: next_m, csr_s: csr_s,
        return_pc: csr_s.sepc, target_mode: target_mode)

export CAUSE_ECALL_M
export CAUSE_MISALIGNED_FETCH
export CAUSE_ILLEGAL_INSN
export CAUSE_BREAKPOINT
export CAUSE_LOAD_MISALIGNED
export CAUSE_STORE_MISALIGNED
export CAUSE_ECALL_U
export CAUSE_ECALL_S
export CAUSE_MSI
export CAUSE_MTI
export CAUSE_MEI
export CAUSE_SSI
export CAUSE_STI
export CAUSE_SEI
