# ============================================================================
# RV32I RTL Trap Controller — Exception and Interrupt Handling
# ============================================================================
#
# Implements RISC-V M-mode trap entry/exit logic:
#   - Interrupt priority checking (MEI > MSI > MTI)
#   - Trap entry: save context, jump to mtvec
#   - Trap exit (mret): restore context, return to mepc
#
# All operations are pure functions — suitable for synthesizable RTL.
# Only direct mtvec mode is supported (vectored mode is a future extension).
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

use std.hardware.rv32i_rtl.csr.{CsrFile}
use std.hardware.rv32i_rtl.csr.{MSTATUS_MIE_MASK, MSTATUS_MPIE_MASK, MSTATUS_MPP_MASK}
use std.hardware.rv32i_rtl.csr.{MSTATUS_MIE_BIT, MSTATUS_MPIE_BIT, MSTATUS_MPP_LO_BIT}
use std.hardware.rv32i_rtl.csr.{MPP_M_MODE}
use std.hardware.rv32i_rtl.csr.{MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK}

# ============================================================================
# Trap phase constants
# ============================================================================

val TRAP_NORMAL: u32 = 0   # Normal execution
val TRAP_ENTER: u32  = 1   # Entering trap handler
val TRAP_EXIT: u32   = 2   # Exiting trap handler (mret)

# ============================================================================
# Exception cause codes (mcause with MSB=0)
# ============================================================================

val CAUSE_MISALIGNED_FETCH: u32  = 0
val CAUSE_ILLEGAL_INSN: u32     = 2
val CAUSE_BREAKPOINT: u32       = 3
val CAUSE_LOAD_MISALIGNED: u32  = 4
val CAUSE_STORE_MISALIGNED: u32 = 6
val CAUSE_ECALL_M: u32         = 11

# ============================================================================
# Interrupt cause codes (mcause with MSB=1, bit 31 set)
# ============================================================================

val CAUSE_MSI: u32 = 0x80000003   # Machine Software Interrupt
val CAUSE_MTI: u32 = 0x80000007   # Machine Timer Interrupt
val CAUSE_MEI: u32 = 0x8000000B   # Machine External Interrupt

# ============================================================================
# Trap State
# ============================================================================

struct TrapState:
    """Trap controller state."""
    phase: u32   # TRAP_NORMAL, TRAP_ENTER, or TRAP_EXIT

# ============================================================================
# Trap Enter Result
# ============================================================================

struct TrapEnterResult:
    """Result of entering a trap."""
    csr: CsrFile    # Updated CSR file (mepc, mcause, mtval, mstatus saved)
    trap_pc: u32     # Target PC (from mtvec, direct mode)

# ============================================================================
# Trap Exit Result
# ============================================================================

struct TrapExitResult:
    """Result of exiting a trap via mret."""
    csr: CsrFile      # Updated CSR file (mstatus restored)
    return_pc: u32     # Return PC (from mepc)

# ============================================================================
# Interrupt Check Result
# ============================================================================

struct InterruptCheckResult:
    """Result of checking for pending interrupts."""
    pending: bool    # True if an interrupt should be taken
    cause: u32       # Interrupt cause code (valid only if pending=true)

# ============================================================================
# Check for Pending Interrupts
# ============================================================================

fn trap_check_interrupt(csr: CsrFile) -> InterruptCheckResult:
    """Check if an interrupt should be taken.
    Conditions: mstatus.MIE is set AND (mie & mip) has enabled pending bits.
    Priority: MEI > MSI > MTI (per RISC-V spec)."""

    # Global interrupt enable must be set
    val mie_enabled = (csr.mstatus & MSTATUS_MIE_MASK) != 0
    if mie_enabled == false:
        return InterruptCheckResult(pending: false, cause: 0)

    # Check enabled AND pending interrupts
    val enabled_pending = csr.mie & csr.mip

    # Priority: Machine External > Machine Software > Machine Timer
    if (enabled_pending & MIP_MEIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: CAUSE_MEI)
    if (enabled_pending & MIP_MSIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: CAUSE_MSI)
    if (enabled_pending & MIP_MTIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: CAUSE_MTI)

    InterruptCheckResult(pending: false, cause: 0)

# ============================================================================
# Trap Entry
# ============================================================================

fn trap_enter(csr: CsrFile, pc: u32, cause: u32, tval: u32) -> TrapEnterResult:
    """Enter a trap: save context to CSRs, compute handler address.

    Updates:
      mepc    <- pc (faulting/interrupted instruction)
      mcause  <- cause
      mtval   <- tval (additional info, e.g. faulting address)
      mstatus <- MPIE=MIE, MIE=0, MPP=M-mode (0b11)

    Returns the new CSR state and the trap handler PC (mtvec direct mode)."""

    var new_csr = csr

    # Save exception context
    new_csr.mepc = pc & 0xFFFFFFFC    # Align to 4 bytes
    new_csr.mcause = cause
    new_csr.mtval = tval

    # Save and update mstatus:
    #   MPIE <- current MIE
    #   MIE  <- 0 (disable interrupts in handler)
    #   MPP  <- M-mode (0b11)
    val old_mie = (csr.mstatus & MSTATUS_MIE_MASK) >> MSTATUS_MIE_BIT
    var new_mstatus = csr.mstatus

    # Clear MIE, MPIE, MPP fields
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ 0xFFFFFFFF)

    # Set MPIE = old MIE
    new_mstatus = new_mstatus | (old_mie << MSTATUS_MPIE_BIT)
    # MIE = 0 (already cleared above)
    # MPP = M-mode (0b11)
    new_mstatus = new_mstatus | MPP_M_MODE

    new_csr.mstatus = new_mstatus

    # Compute trap handler PC from mtvec (direct mode only — mask off mode bits)
    val trap_pc = csr.mtvec & 0xFFFFFFFC

    TrapEnterResult(csr: new_csr, trap_pc: trap_pc)

# ============================================================================
# Trap Exit (mret)
# ============================================================================

fn trap_exit_mret(csr: CsrFile) -> TrapExitResult:
    """Exit from M-mode trap via MRET instruction.

    Updates:
      mstatus <- MIE=MPIE, MPIE=1, MPP=M-mode (0b11)

    Returns the new CSR state and the return PC (from mepc)."""

    var new_mstatus = csr.mstatus

    # Restore MIE from MPIE
    val old_mpie = (csr.mstatus & MSTATUS_MPIE_MASK) >> MSTATUS_MPIE_BIT

    # Clear MIE, MPIE, MPP
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ 0xFFFFFFFF)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ 0xFFFFFFFF)

    # MIE <- MPIE
    new_mstatus = new_mstatus | (old_mpie << MSTATUS_MIE_BIT)
    # MPIE <- 1
    new_mstatus = new_mstatus | MSTATUS_MPIE_MASK
    # MPP <- M-mode (0b11, since we only support M-mode)
    new_mstatus = new_mstatus | MPP_M_MODE

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    # Return PC from mepc
    val return_pc = csr.mepc

    TrapExitResult(csr: new_csr, return_pc: return_pc)
