# RV32 PMP CSR read/write ownership.
#
# RV32 packs four PMP configuration bytes into each pmpcfg CSR.  All branches
# are explicit so this remains a fixed combinational hardware boundary.

use std.hardware.rv32i_rtl.pmp.PmpEntries32

val PMP32_CSR_PMPCFG0: u32 = 0x3A0
val PMP32_CSR_PMPCFG1: u32 = 0x3A1
val PMP32_CSR_PMPCFG2: u32 = 0x3A2
val PMP32_CSR_PMPCFG3: u32 = 0x3A3
val PMP32_CSR_PMPADDR0: u32 = 0x3B0

val PMP32_CSR_CFG_R: u32 = 0x01
val PMP32_CSR_CFG_W: u32 = 0x02
val PMP32_CSR_CFG_L: u32 = 0x80
val PMP32_CSR_CFG_ALLOWED: u32 = 0x9F
val PMP32_CSR_CFG_CLEAR_W: u32 = 0x9D
val PMP32_CSR_LOCKED_TOR_MASK: u32 = 0x98
val PMP32_CSR_LOCKED_TOR: u32 = 0x88

struct PmpCsrReadResult32:
    handled: bool
    value: u32

struct PmpCsrWriteResult32:
    handled: bool
    entries: PmpEntries32

@hardware
fn pmp32_entries_reset() -> PmpEntries32:
    PmpEntries32(
        cfg_0: 0, cfg_1: 0, cfg_2: 0, cfg_3: 0,
        cfg_4: 0, cfg_5: 0, cfg_6: 0, cfg_7: 0,
        cfg_8: 0, cfg_9: 0, cfg_10: 0, cfg_11: 0,
        cfg_12: 0, cfg_13: 0, cfg_14: 0, cfg_15: 0,
        addr_0: 0, addr_1: 0, addr_2: 0, addr_3: 0,
        addr_4: 0, addr_5: 0, addr_6: 0, addr_7: 0,
        addr_8: 0, addr_9: 0, addr_10: 0, addr_11: 0,
        addr_12: 0, addr_13: 0, addr_14: 0, addr_15: 0
    )

@hardware
fn pmp32_cfg_normalize(cfg: u32) -> u32:
    val normalized = cfg & PMP32_CSR_CFG_ALLOWED
    val readable = (normalized & PMP32_CSR_CFG_R) != 0
    val writable = (normalized & PMP32_CSR_CFG_W) != 0
    if writable and readable == false:
        return normalized & PMP32_CSR_CFG_CLEAR_W
    normalized

@hardware
fn pmp32_csr_read(entries: PmpEntries32, csr_addr: u32) -> PmpCsrReadResult32:
    if csr_addr == PMP32_CSR_PMPCFG0:
        val value = (entries.cfg_0 & 0xFF) | ((entries.cfg_1 & 0xFF) << 8) | ((entries.cfg_2 & 0xFF) << 16) | ((entries.cfg_3 & 0xFF) << 24)
        return PmpCsrReadResult32(handled: true, value: value)
    if csr_addr == PMP32_CSR_PMPCFG1:
        val value = (entries.cfg_4 & 0xFF) | ((entries.cfg_5 & 0xFF) << 8) | ((entries.cfg_6 & 0xFF) << 16) | ((entries.cfg_7 & 0xFF) << 24)
        return PmpCsrReadResult32(handled: true, value: value)
    if csr_addr == PMP32_CSR_PMPCFG2:
        val value = (entries.cfg_8 & 0xFF) | ((entries.cfg_9 & 0xFF) << 8) | ((entries.cfg_10 & 0xFF) << 16) | ((entries.cfg_11 & 0xFF) << 24)
        return PmpCsrReadResult32(handled: true, value: value)
    if csr_addr == PMP32_CSR_PMPCFG3:
        val value = (entries.cfg_12 & 0xFF) | ((entries.cfg_13 & 0xFF) << 8) | ((entries.cfg_14 & 0xFF) << 16) | ((entries.cfg_15 & 0xFF) << 24)
        return PmpCsrReadResult32(handled: true, value: value)

    if csr_addr == PMP32_CSR_PMPADDR0:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_0 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 1:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_1 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 2:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_2 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 3:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_3 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 4:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_4 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 5:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_5 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 6:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_6 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 7:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_7 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 8:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_8 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 9:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_9 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 10:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_10 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 11:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_11 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 12:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_12 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 13:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_13 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 14:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_14 & 0xFFFFFFFF) as u32)
    if csr_addr == PMP32_CSR_PMPADDR0 + 15:
        return PmpCsrReadResult32(handled: true, value: (entries.addr_15 & 0xFFFFFFFF) as u32)
    PmpCsrReadResult32(handled: false, value: 0)

@hardware
fn pmp32_csr_write(entries: PmpEntries32, csr_addr: u32, value: u32) -> PmpCsrWriteResult32:
    if csr_addr == PMP32_CSR_PMPCFG0:
        var out = entries
        if (entries.cfg_0 & PMP32_CSR_CFG_L) == 0:
            out.cfg_0 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_1 & PMP32_CSR_CFG_L) == 0:
            out.cfg_1 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_2 & PMP32_CSR_CFG_L) == 0:
            out.cfg_2 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_3 & PMP32_CSR_CFG_L) == 0:
            out.cfg_3 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG1:
        var out = entries
        if (entries.cfg_4 & PMP32_CSR_CFG_L) == 0:
            out.cfg_4 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_5 & PMP32_CSR_CFG_L) == 0:
            out.cfg_5 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_6 & PMP32_CSR_CFG_L) == 0:
            out.cfg_6 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_7 & PMP32_CSR_CFG_L) == 0:
            out.cfg_7 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG2:
        var out = entries
        if (entries.cfg_8 & PMP32_CSR_CFG_L) == 0:
            out.cfg_8 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_9 & PMP32_CSR_CFG_L) == 0:
            out.cfg_9 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_10 & PMP32_CSR_CFG_L) == 0:
            out.cfg_10 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_11 & PMP32_CSR_CFG_L) == 0:
            out.cfg_11 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG3:
        var out = entries
        if (entries.cfg_12 & PMP32_CSR_CFG_L) == 0:
            out.cfg_12 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_13 & PMP32_CSR_CFG_L) == 0:
            out.cfg_13 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_14 & PMP32_CSR_CFG_L) == 0:
            out.cfg_14 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_15 & PMP32_CSR_CFG_L) == 0:
            out.cfg_15 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)

    if csr_addr == PMP32_CSR_PMPADDR0:
        var out = entries
        val locked = (entries.cfg_0 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_1 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_0 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 1:
        var out = entries
        val locked = (entries.cfg_1 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_2 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_1 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 2:
        var out = entries
        val locked = (entries.cfg_2 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_3 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_2 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 3:
        var out = entries
        val locked = (entries.cfg_3 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_4 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_3 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 4:
        var out = entries
        val locked = (entries.cfg_4 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_5 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_4 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 5:
        var out = entries
        val locked = (entries.cfg_5 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_6 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_5 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 6:
        var out = entries
        val locked = (entries.cfg_6 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_7 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_6 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 7:
        var out = entries
        val locked = (entries.cfg_7 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_8 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_7 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 8:
        var out = entries
        val locked = (entries.cfg_8 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_9 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_8 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 9:
        var out = entries
        val locked = (entries.cfg_9 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_10 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_9 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 10:
        var out = entries
        val locked = (entries.cfg_10 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_11 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_10 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 11:
        var out = entries
        val locked = (entries.cfg_11 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_12 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_11 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 12:
        var out = entries
        val locked = (entries.cfg_12 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_13 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_12 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 13:
        var out = entries
        val locked = (entries.cfg_13 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_14 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_13 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 14:
        var out = entries
        val locked = (entries.cfg_14 & PMP32_CSR_CFG_L) != 0 or (entries.cfg_15 & PMP32_CSR_LOCKED_TOR_MASK) == PMP32_CSR_LOCKED_TOR
        if locked == false:
            out.addr_14 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 15:
        var out = entries
        if (entries.cfg_15 & PMP32_CSR_CFG_L) == 0:
            out.addr_15 = value as i64
        return PmpCsrWriteResult32(handled: true, entries: out)
    PmpCsrWriteResult32(handled: false, entries: entries)

export PmpCsrReadResult32, PmpCsrWriteResult32
export pmp32_entries_reset, pmp32_cfg_normalize, pmp32_csr_read, pmp32_csr_write
