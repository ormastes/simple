# RV32 PMP CSR storage access.  RV32 exposes pmpcfg0 through pmpcfg3,
# each packing four configuration bytes.

use std.hardware.rv32i_rtl.pmp.PmpEntries32

val PMP32_CSR_PMPCFG0: u32 = 0x3A0
val PMP32_CSR_PMPCFG1: u32 = 0x3A1
val PMP32_CSR_PMPCFG2: u32 = 0x3A2
val PMP32_CSR_PMPCFG3: u32 = 0x3A3
val PMP32_CSR_PMPADDR0: u32 = 0x3B0
val PMP32_CFG_ADDRESS_MASK: u32 = 0x18
val PMP32_CFG_ADDRESS_TOR: u32 = 0x08
val PMP32_CFG_LOCKED: u32 = 0x80
val PMP32_CFG_DEFINED_MASK: u32 = 0x9F
val PMP32_CFG_READ: u32 = 0x01
val PMP32_CFG_WRITE: u32 = 0x02
val PMP32_CSR_PMPADDR_MASK: u32 = 0xFFFFFFFF

struct PmpCsrReadResult32:
    handled: bool
    value: u32

struct PmpCsrWriteResult32:
    handled: bool
    entries: PmpEntries32

@hardware
fn pmp32_entries_reset() -> PmpEntries32:
    PmpEntries32(
        cfg_0: 0, cfg_1: 0, cfg_2: 0, cfg_3: 0,
        cfg_4: 0, cfg_5: 0, cfg_6: 0, cfg_7: 0,
        cfg_8: 0, cfg_9: 0, cfg_10: 0, cfg_11: 0,
        cfg_12: 0, cfg_13: 0, cfg_14: 0, cfg_15: 0,
        addr_0: 0, addr_1: 0, addr_2: 0, addr_3: 0,
        addr_4: 0, addr_5: 0, addr_6: 0, addr_7: 0,
        addr_8: 0, addr_9: 0, addr_10: 0, addr_11: 0,
        addr_12: 0, addr_13: 0, addr_14: 0, addr_15: 0
    )

@hardware
fn pmp32_cfg_normalize(cfg: u32) -> u32:
    """Clear reserved bits and the reserved R=0/W=1 encoding."""
    var normalized = cfg & PMP32_CFG_DEFINED_MASK
    if (normalized & PMP32_CFG_WRITE) != 0 and (normalized & PMP32_CFG_READ) == 0:
        normalized = normalized & 0xFD
    normalized

@hardware
fn pmp32_csr_read(entries: PmpEntries32, csr_addr: u32) -> PmpCsrReadResult32:
    if csr_addr == PMP32_CSR_PMPCFG0:
        return PmpCsrReadResult32(handled: true, value: (entries.cfg_0 & 0xFF) | ((entries.cfg_1 & 0xFF) << 8) | ((entries.cfg_2 & 0xFF) << 16) | ((entries.cfg_3 & 0xFF) << 24))
    if csr_addr == PMP32_CSR_PMPCFG1:
        return PmpCsrReadResult32(handled: true, value: (entries.cfg_4 & 0xFF) | ((entries.cfg_5 & 0xFF) << 8) | ((entries.cfg_6 & 0xFF) << 16) | ((entries.cfg_7 & 0xFF) << 24))
    if csr_addr == PMP32_CSR_PMPCFG2:
        return PmpCsrReadResult32(handled: true, value: (entries.cfg_8 & 0xFF) | ((entries.cfg_9 & 0xFF) << 8) | ((entries.cfg_10 & 0xFF) << 16) | ((entries.cfg_11 & 0xFF) << 24))
    if csr_addr == PMP32_CSR_PMPCFG3:
        return PmpCsrReadResult32(handled: true, value: (entries.cfg_12 & 0xFF) | ((entries.cfg_13 & 0xFF) << 8) | ((entries.cfg_14 & 0xFF) << 16) | ((entries.cfg_15 & 0xFF) << 24))
    if csr_addr == PMP32_CSR_PMPADDR0: return PmpCsrReadResult32(handled: true, value: entries.addr_0)
    if csr_addr == PMP32_CSR_PMPADDR0 + 1: return PmpCsrReadResult32(handled: true, value: entries.addr_1)
    if csr_addr == PMP32_CSR_PMPADDR0 + 2: return PmpCsrReadResult32(handled: true, value: entries.addr_2)
    if csr_addr == PMP32_CSR_PMPADDR0 + 3: return PmpCsrReadResult32(handled: true, value: entries.addr_3)
    if csr_addr == PMP32_CSR_PMPADDR0 + 4: return PmpCsrReadResult32(handled: true, value: entries.addr_4)
    if csr_addr == PMP32_CSR_PMPADDR0 + 5: return PmpCsrReadResult32(handled: true, value: entries.addr_5)
    if csr_addr == PMP32_CSR_PMPADDR0 + 6: return PmpCsrReadResult32(handled: true, value: entries.addr_6)
    if csr_addr == PMP32_CSR_PMPADDR0 + 7: return PmpCsrReadResult32(handled: true, value: entries.addr_7)
    if csr_addr == PMP32_CSR_PMPADDR0 + 8: return PmpCsrReadResult32(handled: true, value: entries.addr_8)
    if csr_addr == PMP32_CSR_PMPADDR0 + 9: return PmpCsrReadResult32(handled: true, value: entries.addr_9)
    if csr_addr == PMP32_CSR_PMPADDR0 + 10: return PmpCsrReadResult32(handled: true, value: entries.addr_10)
    if csr_addr == PMP32_CSR_PMPADDR0 + 11: return PmpCsrReadResult32(handled: true, value: entries.addr_11)
    if csr_addr == PMP32_CSR_PMPADDR0 + 12: return PmpCsrReadResult32(handled: true, value: entries.addr_12)
    if csr_addr == PMP32_CSR_PMPADDR0 + 13: return PmpCsrReadResult32(handled: true, value: entries.addr_13)
    if csr_addr == PMP32_CSR_PMPADDR0 + 14: return PmpCsrReadResult32(handled: true, value: entries.addr_14)
    if csr_addr == PMP32_CSR_PMPADDR0 + 15: return PmpCsrReadResult32(handled: true, value: entries.addr_15)
    PmpCsrReadResult32(handled: false, value: 0)

@hardware
fn pmp32_csr_write(entries: PmpEntries32, csr_addr: u32, value: u32) -> PmpCsrWriteResult32:
    var out = entries
    if csr_addr == PMP32_CSR_PMPCFG0:
        if (entries.cfg_0 & PMP32_CFG_LOCKED) == 0: out.cfg_0 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_1 & PMP32_CFG_LOCKED) == 0: out.cfg_1 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_2 & PMP32_CFG_LOCKED) == 0: out.cfg_2 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_3 & PMP32_CFG_LOCKED) == 0: out.cfg_3 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG1:
        if (entries.cfg_4 & PMP32_CFG_LOCKED) == 0: out.cfg_4 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_5 & PMP32_CFG_LOCKED) == 0: out.cfg_5 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_6 & PMP32_CFG_LOCKED) == 0: out.cfg_6 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_7 & PMP32_CFG_LOCKED) == 0: out.cfg_7 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG2:
        if (entries.cfg_8 & PMP32_CFG_LOCKED) == 0: out.cfg_8 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_9 & PMP32_CFG_LOCKED) == 0: out.cfg_9 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_10 & PMP32_CFG_LOCKED) == 0: out.cfg_10 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_11 & PMP32_CFG_LOCKED) == 0: out.cfg_11 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPCFG3:
        if (entries.cfg_12 & PMP32_CFG_LOCKED) == 0: out.cfg_12 = pmp32_cfg_normalize(value & 0xFF)
        if (entries.cfg_13 & PMP32_CFG_LOCKED) == 0: out.cfg_13 = pmp32_cfg_normalize((value >> 8) & 0xFF)
        if (entries.cfg_14 & PMP32_CFG_LOCKED) == 0: out.cfg_14 = pmp32_cfg_normalize((value >> 16) & 0xFF)
        if (entries.cfg_15 & PMP32_CFG_LOCKED) == 0: out.cfg_15 = pmp32_cfg_normalize((value >> 24) & 0xFF)
        return PmpCsrWriteResult32(handled: true, entries: out)

    val masked_value = value & PMP32_CSR_PMPADDR_MASK
    if csr_addr == PMP32_CSR_PMPADDR0:
        val successor_locks = (entries.cfg_1 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_0 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_0 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 1:
        val successor_locks = (entries.cfg_2 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_1 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_1 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 2:
        val successor_locks = (entries.cfg_3 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_2 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_2 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 3:
        val successor_locks = (entries.cfg_4 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_3 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_3 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 4:
        val successor_locks = (entries.cfg_5 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_4 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_4 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 5:
        val successor_locks = (entries.cfg_6 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_5 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_5 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 6:
        val successor_locks = (entries.cfg_7 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_6 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_6 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 7:
        val successor_locks = (entries.cfg_8 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_7 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_7 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 8:
        val successor_locks = (entries.cfg_9 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_8 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_8 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 9:
        val successor_locks = (entries.cfg_10 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_9 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_9 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 10:
        val successor_locks = (entries.cfg_11 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_10 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_10 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 11:
        val successor_locks = (entries.cfg_12 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_11 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_11 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 12:
        val successor_locks = (entries.cfg_13 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_12 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_12 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 13:
        val successor_locks = (entries.cfg_14 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_13 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_13 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 14:
        val successor_locks = (entries.cfg_15 & (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_MASK)) == (PMP32_CFG_LOCKED | PMP32_CFG_ADDRESS_TOR)
        if (entries.cfg_14 & PMP32_CFG_LOCKED) == 0 and not successor_locks: out.addr_14 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    if csr_addr == PMP32_CSR_PMPADDR0 + 15:
        if (entries.cfg_15 & PMP32_CFG_LOCKED) == 0: out.addr_15 = masked_value
        return PmpCsrWriteResult32(handled: true, entries: out)
    PmpCsrWriteResult32(handled: false, entries: entries)

export PmpCsrReadResult32, PmpCsrWriteResult32
export pmp32_entries_reset, pmp32_cfg_normalize, pmp32_csr_read, pmp32_csr_write
