# ============================================================================
# RV32I RTL Register File — 2R1W, 32 x 32-bit
# ============================================================================

val INIT_SP: u32 = 0x00000FFC

# Fixed scalar fields are deliberate: the VHDL backend supports records but a
# Simple `[u32]` is a dynamic array and cannot be stored in clocked RTL state.
struct RegFile:
    reg_0: u32
    reg_1: u32
    reg_2: u32
    reg_3: u32
    reg_4: u32
    reg_5: u32
    reg_6: u32
    reg_7: u32
    reg_8: u32
    reg_9: u32
    reg_10: u32
    reg_11: u32
    reg_12: u32
    reg_13: u32
    reg_14: u32
    reg_15: u32
    reg_16: u32
    reg_17: u32
    reg_18: u32
    reg_19: u32
    reg_20: u32
    reg_21: u32
    reg_22: u32
    reg_23: u32
    reg_24: u32
    reg_25: u32
    reg_26: u32
    reg_27: u32
    reg_28: u32
    reg_29: u32
    reg_30: u32
    reg_31: u32

struct RegReadResult:
    rs1_data: u32
    rs2_data: u32
    a0_val: u32
    a1_val: u32

fn regfile_create() -> RegFile:
    RegFile(
        reg_0: 0, reg_1: 0, reg_2: INIT_SP, reg_3: 0,
        reg_4: 0, reg_5: 0, reg_6: 0, reg_7: 0,
        reg_8: 0, reg_9: 0, reg_10: 0, reg_11: 0,
        reg_12: 0, reg_13: 0, reg_14: 0, reg_15: 0,
        reg_16: 0, reg_17: 0, reg_18: 0, reg_19: 0,
        reg_20: 0, reg_21: 0, reg_22: 0, reg_23: 0,
        reg_24: 0, reg_25: 0, reg_26: 0, reg_27: 0,
        reg_28: 0, reg_29: 0, reg_30: 0, reg_31: 0
    )

fn regfile_read_one(rf: RegFile, addr: u32) -> u32:
    if addr == 1: return rf.reg_1
    if addr == 2: return rf.reg_2
    if addr == 3: return rf.reg_3
    if addr == 4: return rf.reg_4
    if addr == 5: return rf.reg_5
    if addr == 6: return rf.reg_6
    if addr == 7: return rf.reg_7
    if addr == 8: return rf.reg_8
    if addr == 9: return rf.reg_9
    if addr == 10: return rf.reg_10
    if addr == 11: return rf.reg_11
    if addr == 12: return rf.reg_12
    if addr == 13: return rf.reg_13
    if addr == 14: return rf.reg_14
    if addr == 15: return rf.reg_15
    if addr == 16: return rf.reg_16
    if addr == 17: return rf.reg_17
    if addr == 18: return rf.reg_18
    if addr == 19: return rf.reg_19
    if addr == 20: return rf.reg_20
    if addr == 21: return rf.reg_21
    if addr == 22: return rf.reg_22
    if addr == 23: return rf.reg_23
    if addr == 24: return rf.reg_24
    if addr == 25: return rf.reg_25
    if addr == 26: return rf.reg_26
    if addr == 27: return rf.reg_27
    if addr == 28: return rf.reg_28
    if addr == 29: return rf.reg_29
    if addr == 30: return rf.reg_30
    if addr == 31: return rf.reg_31
    0

fn regfile_read(rf: RegFile, rs1_addr: u32, rs2_addr: u32) -> RegReadResult:
    RegReadResult(
        rs1_data: regfile_read_one(rf, rs1_addr),
        rs2_data: regfile_read_one(rf, rs2_addr),
        a0_val: rf.reg_10,
        a1_val: rf.reg_11
    )

fn regfile_write(rf: RegFile, rd_addr: u32, rd_data: u32, we: bool) -> RegFile:
    var out = rf
    if not we or rd_addr == 0:
        return out
    if rd_addr == 1: out.reg_1 = rd_data
    else if rd_addr == 2: out.reg_2 = rd_data
    else if rd_addr == 3: out.reg_3 = rd_data
    else if rd_addr == 4: out.reg_4 = rd_data
    else if rd_addr == 5: out.reg_5 = rd_data
    else if rd_addr == 6: out.reg_6 = rd_data
    else if rd_addr == 7: out.reg_7 = rd_data
    else if rd_addr == 8: out.reg_8 = rd_data
    else if rd_addr == 9: out.reg_9 = rd_data
    else if rd_addr == 10: out.reg_10 = rd_data
    else if rd_addr == 11: out.reg_11 = rd_data
    else if rd_addr == 12: out.reg_12 = rd_data
    else if rd_addr == 13: out.reg_13 = rd_data
    else if rd_addr == 14: out.reg_14 = rd_data
    else if rd_addr == 15: out.reg_15 = rd_data
    else if rd_addr == 16: out.reg_16 = rd_data
    else if rd_addr == 17: out.reg_17 = rd_data
    else if rd_addr == 18: out.reg_18 = rd_data
    else if rd_addr == 19: out.reg_19 = rd_data
    else if rd_addr == 20: out.reg_20 = rd_data
    else if rd_addr == 21: out.reg_21 = rd_data
    else if rd_addr == 22: out.reg_22 = rd_data
    else if rd_addr == 23: out.reg_23 = rd_data
    else if rd_addr == 24: out.reg_24 = rd_data
    else if rd_addr == 25: out.reg_25 = rd_data
    else if rd_addr == 26: out.reg_26 = rd_data
    else if rd_addr == 27: out.reg_27 = rd_data
    else if rd_addr == 28: out.reg_28 = rd_data
    else if rd_addr == 29: out.reg_29 = rd_data
    else if rd_addr == 30: out.reg_30 = rd_data
    else if rd_addr == 31: out.reg_31 = rd_data
    out
