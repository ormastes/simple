# ============================================================================
# RV32IM RTL Package — Constants and Type Aliases
# ============================================================================
#
# Translates rv32i_pkg.vhd into Simple.  All values use u32 for 32-bit
# hardware-width constants and i64 for ALU-op enum codes (matching the
# behavioral riscv_common convention).
#
# VHDL synthesizable subset: only integer constants; no heap, no closures.
# ============================================================================

# ============================================================================
# Opcode constants (7-bit, stored in u32)
# ============================================================================

val OP_LUI: u32    = 0x37    # Load Upper Immediate
val OP_AUIPC: u32  = 0x17    # Add Upper Immediate to PC
val OP_JAL: u32    = 0x6F    # Jump And Link
val OP_JALR: u32   = 0x67    # Jump And Link Register
val OP_BRANCH: u32 = 0x63    # Conditional branch
val OP_LOAD: u32   = 0x03    # Load (LB, LH, LW, LBU, LHU)
val OP_STORE: u32  = 0x23    # Store (SB, SH, SW)
val OP_IMMED: u32  = 0x13    # Integer register-immediate
val OP_REG: u32    = 0x33    # Integer register-register
val OP_MISC_MEM: u32 = 0x0F  # FENCE / FENCE.I
val OP_SYSTEM: u32 = 0x73    # ECALL, EBREAK
val OP_AMO: u32 = 0x2F       # LR.W, SC.W, and AMO*.W

# ============================================================================
# ALU operation codes (i64 enum)
# ============================================================================

val ALU_ADD: i64    = 0
val ALU_SUB: i64    = 1
val ALU_SLL: i64    = 2
val ALU_SLT: i64    = 3
val ALU_SLTU: i64   = 4
val ALU_XOR: i64    = 5
val ALU_SRL: i64    = 6
val ALU_SRA: i64    = 7
val ALU_OR: i64     = 8
val ALU_AND: i64    = 9
val ALU_PASS_B: i64 = 10

# ============================================================================
# Branch funct3 constants (3-bit, stored in u32)
# ============================================================================

val BR_BEQ: u32  = 0x0   # 000
val BR_BNE: u32  = 0x1   # 001
val BR_BLT: u32  = 0x4   # 100
val BR_BGE: u32  = 0x5   # 101
val BR_BLTU: u32 = 0x6   # 110
val BR_BGEU: u32 = 0x7   # 111

# ============================================================================
# Load/Store funct3 constants
# ============================================================================

val FUNCT3_LB: u32  = 0x0   # Load byte (sign-extend)
val FUNCT3_LH: u32  = 0x1   # Load halfword (sign-extend)
val FUNCT3_LW: u32  = 0x2   # Load word
val FUNCT3_LBU: u32 = 0x4   # Load byte unsigned
val FUNCT3_LHU: u32 = 0x5   # Load halfword unsigned

# ============================================================================
# Memory width encoding (2-bit, matches funct3[1:0])
# ============================================================================

val MEM_WIDTH_BYTE: u32 = 0x0
val MEM_WIDTH_HALF: u32 = 0x1
val MEM_WIDTH_WORD: u32 = 0x2

# ============================================================================
# Multiply/divide operation codes (i64 enum)
# ============================================================================

val MULDIV_MUL: i64    = 0
val MULDIV_MULH: i64   = 1
val MULDIV_MULHSU: i64 = 2
val MULDIV_MULHU: i64  = 3
val MULDIV_DIV: i64    = 4
val MULDIV_DIVU: i64   = 5
val MULDIV_REM: i64    = 6
val MULDIV_REMU: i64   = 7

# Atomic funct5 codes (instruction bits [31:27]).
val AMO_LR: u32   = 0x02
val AMO_SC: u32   = 0x03
val AMO_SWAP: u32 = 0x01
val AMO_ADD: u32  = 0x00
val AMO_XOR: u32  = 0x04
val AMO_AND: u32  = 0x0C
val AMO_OR: u32   = 0x08
val AMO_MIN: u32  = 0x10
val AMO_MAX: u32  = 0x14
val AMO_MINU: u32 = 0x18
val AMO_MAXU: u32 = 0x1C

# ============================================================================
# Semihosting magic instruction encodings
# ============================================================================

val SEMI_ENTRY: u32 = 0x01F01013   # slli zero,zero,0x1f
val SEMI_BREAK: u32 = 0x00100073   # ebreak
val SEMI_EXIT: u32  = 0x40705013   # srai zero,zero,0x7

# ============================================================================
# Semihosting operation codes
# ============================================================================

val SYS_WRITEC: u32 = 0x00000003
val SYS_WRITE0: u32 = 0x00000004
val SYS_EXIT: u32   = 0x00000018

# ============================================================================
# Mailbox MMIO base address and register offsets
# ============================================================================

val MB_BASE_ADDR: u32     = 0x80FF0000
val MB_OFF_CMD: u32       = 0x00
val MB_OFF_ARG0: u32      = 0x04
val MB_OFF_ARG1: u32      = 0x08
val MB_OFF_STATUS: u32    = 0x0C
val MB_OFF_RESULT: u32    = 0x10
val MB_OFF_SEQ_ID: u32    = 0x14
val MB_OFF_TRIGGER: u32   = 0x18

# ============================================================================
# Mailbox command codes
# ============================================================================

val MB_CMD_PUTC: u32   = 0x00000001
val MB_CMD_EXIT: u32   = 0x00000002
val MB_CMD_RESULT: u32 = 0x00000003

# ============================================================================
# Mailbox sentinel address and values
# ============================================================================

val MB_SENTINEL_ADDR: u32    = 0x80008000
val MB_SENTINEL_SUCCESS: u32 = 0xCAFE0000
val MB_SENTINEL_TIMEOUT: u32 = 0xDEAD0000
val MB_TRIGGER_MAGIC: u32    = 0x0000DEAD

export OP_LUI
export OP_AUIPC
export OP_JAL
export OP_JALR
export OP_BRANCH
export OP_LOAD
export OP_STORE
export OP_IMMED
export OP_REG
export OP_MISC_MEM
export OP_SYSTEM
export OP_AMO
export ALU_ADD
export ALU_SUB
export ALU_SLL
export ALU_SLT
export ALU_SLTU
export ALU_XOR
export ALU_SRL
export ALU_SRA
export ALU_OR
export ALU_AND
export ALU_PASS_B
export BR_BEQ
export BR_BNE
export BR_BLT
export BR_BGE
export BR_BLTU
export BR_BGEU
export FUNCT3_LB
export FUNCT3_LH
export FUNCT3_LW
export FUNCT3_LBU
export FUNCT3_LHU
export MEM_WIDTH_BYTE
export MEM_WIDTH_HALF
export MEM_WIDTH_WORD
export MULDIV_MUL
export MULDIV_MULH
export MULDIV_MULHSU
export MULDIV_MULHU
export MULDIV_DIV
export MULDIV_DIVU
export MULDIV_REM
export MULDIV_REMU
export AMO_LR
export AMO_SC
export AMO_SWAP
export AMO_ADD
export AMO_XOR
export AMO_AND
export AMO_OR
export AMO_MIN
export AMO_MAX
export AMO_MINU
export AMO_MAXU
export SEMI_ENTRY
export SEMI_BREAK
export SEMI_EXIT
export SYS_WRITEC
export SYS_WRITE0
export SYS_EXIT
export MB_BASE_ADDR
export MB_OFF_CMD
export MB_OFF_ARG0
export MB_OFF_ARG1
export MB_OFF_STATUS
export MB_OFF_RESULT
export MB_OFF_SEQ_ID
export MB_OFF_TRIGGER
export MB_CMD_PUTC
export MB_CMD_EXIT
export MB_CMD_RESULT
export MB_SENTINEL_ADDR
export MB_SENTINEL_SUCCESS
export MB_SENTINEL_TIMEOUT
export MB_TRIGGER_MAGIC
