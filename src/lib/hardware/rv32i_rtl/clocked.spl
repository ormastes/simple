use std.hardware.rv32i_rtl.core.{CoreState, Core32CycleResult}
use std.hardware.rv32i_rtl.core.{core_reset, core32_cycle}

struct Core32ClockedResult:
    """Registered product boundary plus its reset-initialization witness."""
    initialized: bool
    cycle: Core32CycleResult

@clocked(clk, reset_n)
@hardware
fn core32_clocked(initialized: bool, state: CoreState, reset_addr: u32,
                  request_ready: bool, response_valid: bool,
                  response_error: bool,
                  response_data: u32) -> Core32ClockedResult:
    """Register one RV32 transition; zero reset initializes on the first edge."""
    if not initialized:
        return Core32ClockedResult(
            initialized: true,
            cycle: Core32CycleResult(
                state: core_reset(reset_addr),
                bus_valid: false,
                bus_addr: 0,
                bus_size: 1,
                bus_write: false,
                bus_wdata: 0,
                bus_is_pte: false,
                bus_atomic: false
            )
        )
    Core32ClockedResult(
        initialized: true,
        cycle: core32_cycle(state, request_ready, response_valid,
            response_error, response_data)
    )
