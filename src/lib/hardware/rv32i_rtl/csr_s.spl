# ============================================================================
# RV32I RTL CSR S-Mode Extension — Supervisor Control/Status Registers
# ============================================================================
#
# Extends the M-mode CSR file with supervisor-mode registers required for
# virtual memory (Sv32) and S-mode trap delegation.
#
# Stored CSRs: stvec, sscratch, sepc, scause, stval.
# sstatus is an alias of canonical mstatus. sie/sip/mideleg remain WARL-zero
# until supervisor interrupt delivery exists; satp remains Bare until the
# clocked Sv32 walker owns production requests.
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

# ============================================================================
# S-mode CSR Address Constants
# ============================================================================

val CSR_ADDR_SSTATUS: u32  = 0x100
val CSR_ADDR_SIE: u32      = 0x104
val CSR_ADDR_STVEC: u32    = 0x105
val CSR_ADDR_SSCRATCH: u32 = 0x140
val CSR_ADDR_SEPC: u32     = 0x141
val CSR_ADDR_SCAUSE: u32   = 0x142
val CSR_ADDR_STVAL: u32    = 0x143
val CSR_ADDR_SIP: u32      = 0x144
val CSR_ADDR_SATP: u32     = 0x180

# ============================================================================
# SSTATUS Bit Masks
# ============================================================================
#
# sstatus is a restricted view of mstatus.  Writable fields:
#   SIE  (bit 1)  — Supervisor Interrupt Enable
#   SPIE (bit 5)  — Previous SIE
#   SPP  (bit 8)  — Previous privilege (0=U, 1=S)
#   SUM  (bit 18) — Supervisor User Memory access
#   MXR  (bit 19) — Make eXecutable Readable

val SSTATUS_SIE_MASK: u32   = 0x00000002   # bit 1
val SSTATUS_SPIE_MASK: u32  = 0x00000020   # bit 5
val SSTATUS_SPP_MASK: u32   = 0x00000100   # bit 8
val SSTATUS_SUM_MASK: u32   = 0x00040000   # bit 18
val SSTATUS_MXR_MASK: u32   = 0x00080000   # bit 19

val SSTATUS_WRITABLE: u32 = 0x000C0122  # SIE | SPIE | SPP | SUM | MXR

val SSTATUS_SIE_BIT: u32  = 1
val SSTATUS_SPIE_BIT: u32 = 5
val SSTATUS_SPP_BIT: u32  = 8

fn csr_s_merge_mstatus(mstatus: u32, sstatus: u32) -> u32:
    (mstatus & (SSTATUS_WRITABLE ^ 0xFFFFFFFF)) |
        (sstatus & SSTATUS_WRITABLE)

# ============================================================================
# SIE / SIP Bit Masks
# ============================================================================

val SIP_SSIP_MASK: u32 = 0x00000002   # bit 1 — Supervisor Software Interrupt
val SIP_STIP_MASK: u32 = 0x00000020   # bit 5 — Supervisor Timer Interrupt
val SIP_SEIP_MASK: u32 = 0x00000200   # bit 9 — Supervisor External Interrupt

# ============================================================================
# S-mode CSR File
# ============================================================================

struct CsrSMode:
    """Non-alias supervisor CSR storage."""
    stvec: u32
    sscratch: u32
    sepc: u32
    scause: u32
    stval: u32

# ============================================================================
# Create — initial S-mode CSR state
# ============================================================================

fn csr_s_create() -> CsrSMode:
    """Create initial S-mode CSR state.  All registers start at zero
    (no delegation, interrupts disabled, Bare addressing mode)."""
    CsrSMode(
        stvec: 0,
        sscratch: 0,
        sepc: 0,
        scause: 0,
        stval: 0
    )

# ============================================================================
# CSR Read
# ============================================================================

fn csr_s_read(smode: CsrSMode, addr: u32) -> u32:
    """Read an S-mode CSR by its 12-bit address.  Unknown addresses return 0."""
    if addr == CSR_ADDR_STVEC:
        return smode.stvec
    if addr == CSR_ADDR_SSCRATCH:
        return smode.sscratch
    if addr == CSR_ADDR_SEPC:
        return smode.sepc
    if addr == CSR_ADDR_SCAUSE:
        return smode.scause
    if addr == CSR_ADDR_STVAL:
        return smode.stval
    0

fn csr_s_is_known(addr: u32) -> bool:
    (addr == CSR_ADDR_SSTATUS or addr == CSR_ADDR_SIE or
     addr == CSR_ADDR_STVEC or addr == CSR_ADDR_SSCRATCH or
     addr == CSR_ADDR_SEPC or addr == CSR_ADDR_SCAUSE or
     addr == CSR_ADDR_STVAL or addr == CSR_ADDR_SIP or
     addr == CSR_ADDR_SATP)

# ============================================================================
# CSR Write
# ============================================================================

fn csr_s_write(smode: CsrSMode, addr: u32, value: u32) -> CsrSMode:
    """Write a value to an S-mode CSR.  Enforces field masks where required.
    Unknown addresses are silently ignored."""
    var out = smode

    if addr == CSR_ADDR_STVEC:
        out.stvec = value & 0xFFFFFFFC

    else if addr == CSR_ADDR_SSCRATCH:
        out.sscratch = value

    else if addr == CSR_ADDR_SEPC:
        # sepc must be 4-byte aligned (IALIGN=32)
        out.sepc = value & 0xFFFFFFFC

    else if addr == CSR_ADDR_SCAUSE:
        out.scause = value

    else if addr == CSR_ADDR_STVAL:
        out.stval = value

    out
