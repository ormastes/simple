# ============================================================================
# RV32I RTL Decoder — Combinational Instruction Decoder
# ============================================================================
#
# Translates decoder.vhd into Simple.  Pure functions only (combinational).
# Extracts all fields from a 32-bit instruction, selects ALU op, generates
# control signals, and sign-extends immediates.
#
# Supports all RV32I instruction formats: R, I, S, B, U, J.
# ============================================================================

use std.hardware.rv32i_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv32i_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM}
# Shared XLEN-neutral bit-assembly + ALU-op base (Wave-3 W3-2/W3-3). rv32 wraps
# the raw bits with its u32-domain sign-extend; width is fixed at compile time.
use std.hardware.riscv_common.rtl_decode.{rtl_i_imm_bits, rtl_s_imm_bits, rtl_b_imm_bits}
use std.hardware.riscv_common.rtl_decode.{rtl_u_imm_bits, rtl_j_imm_bits, rtl_select_alu_op_base}

# ============================================================================
# A-extension opcode (RV32A: LR.W / SC.W / AMO*.W)
# ============================================================================
# pkg.spl predates the A extension; the opcode lives here (decoder-owned)
# to keep the change local. funct5 constants live in lsu.spl next to the
# AMO compute helper.

val OP_AMO: u32 = 0x2F    # Atomic memory operations (funct3=2 for .W); canonical copy in pkg.spl

export OP_AMO

# ============================================================================
# Decode result — all decoder output signals
# ============================================================================

struct DecodeResult:
    """All outputs from the combinational decoder."""
    opcode: u32       # bits [6:0]
    rd: u32           # bits [11:7]   — destination register
    rs1: u32          # bits [19:15]  — source register 1
    rs2: u32          # bits [24:20]  — source register 2
    funct3: u32       # bits [14:12]
    funct7: u32       # bits [31:25]
    imm: u32          # Sign-extended immediate
    alu_op: i64       # ALU operation code
    reg_write: bool   # Write-back to register file
    mem_read: bool    # Read from data memory
    mem_write: bool   # Write to data memory
    mem_to_reg: bool  # Load result goes to rd
    alu_src: bool     # true = ALU op_b from immediate; false = from rs2
    branch: bool      # Conditional branch instruction
    jump: bool        # JAL or JALR
    is_amo: bool      # A-extension memory operation (opcode 0x2F)
    is_wfi: bool      # WFI — Wait For Interrupt (0x10500073)

# ============================================================================
# Sign-extension helper (32-bit)
# ============================================================================

fn sign_extend_u32(value: u32, width: u32) -> u32:
    """Sign-extend a value of the given bit width to 32 bits."""
    val sign_bit = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill = 0xFFFFFFFF << width
        value | fill
    else:
        value

# ============================================================================
# Immediate extraction
# ============================================================================

# Thin rv32 shims: shared bit-assembly (rtl_*_imm_bits, non-negative) narrowed
# to u32, then the 32-bit sign-extend. `bits as u32` is exact (bits are always
# non-negative, so no seed-JIT negative-cast hazard).

fn extract_i_imm_u32(insn: u32) -> u32:
    """I-type immediate: bits [31:20], sign-extended to 32 bits."""
    sign_extend_u32(rtl_i_imm_bits(insn as i64) as u32, 12)

fn extract_s_imm_u32(insn: u32) -> u32:
    """S-type immediate: [31:25] | [11:7], sign-extended to 32 bits."""
    sign_extend_u32(rtl_s_imm_bits(insn as i64) as u32, 12)

fn extract_b_imm_u32(insn: u32) -> u32:
    """B-type immediate: 13-bit, sign-extended, bit[0]=0."""
    sign_extend_u32(rtl_b_imm_bits(insn as i64) as u32, 13)

fn extract_u_imm_u32(insn: u32) -> u32:
    """U-type immediate: bits [31:12] in place (not sign-extended on RV32)."""
    rtl_u_imm_bits(insn as i64) as u32

fn extract_j_imm_u32(insn: u32) -> u32:
    """J-type immediate: 21-bit, sign-extended, bit[0]=0."""
    sign_extend_u32(rtl_j_imm_bits(insn as i64) as u32, 21)

# ============================================================================
# ALU operation selection
# ============================================================================

fn select_alu_op(opcode: u32, funct3: u32, funct7: u32) -> i64:
    """Select ALU operation based on opcode, funct3, and funct7.
    RV32I uses only the shared base mapping (OP_REG / OP_IMMED / OP_LUI plus the
    ADD default); there are no RV32-specific ALU ops."""
    rtl_select_alu_op_base(opcode, funct3, funct7)

# ============================================================================
# Main decode function
# ============================================================================

fn decode_instruction(instruction: u32) -> DecodeResult:
    """Decode a 32-bit RV32I instruction into all control and data signals.
    Mirrors the VHDL decoder entity."""

    # Field extraction
    val op = instruction & 0x7F
    val rd = (instruction >> 7) & 0x1F
    val f3 = (instruction >> 12) & 0x7
    val rs1 = (instruction >> 15) & 0x1F
    val rs2 = (instruction >> 20) & 0x1F
    val f7 = (instruction >> 25) & 0x7F

    # Immediate extraction based on opcode format
    var imm: u32 = 0
    if op == OP_IMMED or op == OP_LOAD or op == OP_JALR:
        imm = extract_i_imm_u32(instruction)
    else if op == OP_STORE:
        imm = extract_s_imm_u32(instruction)
    else if op == OP_BRANCH:
        imm = extract_b_imm_u32(instruction)
    else if op == OP_LUI or op == OP_AUIPC:
        imm = extract_u_imm_u32(instruction)
    else if op == OP_JAL:
        imm = extract_j_imm_u32(instruction)

    # ALU operation
    val alu_op = select_alu_op(op, f3, f7)

    # A-extension / WFI detection (mirrors the rv64 decoder shape)
    val amo = op == OP_AMO
    val wfi = instruction == 0x10500073u32

    # Control signals (matching VHDL concurrent assignments)
    # OP_AMO writes rd (LR load value / SC status / AMO old value) and uses
    # the ALU as an address unit: imm stays 0, so rs1 + 0 = address.
    val reg_w = (op == OP_REG or op == OP_IMMED or op == OP_LOAD or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_AMO)
    val m_read = op == OP_LOAD
    val m_write = op == OP_STORE
    val m_to_reg = op == OP_LOAD
    val a_src = (op == OP_IMMED or op == OP_LOAD or op == OP_STORE or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_AMO)
    val br = op == OP_BRANCH
    val jmp = op == OP_JAL or op == OP_JALR

    DecodeResult(
        opcode: op,
        rd: rd,
        rs1: rs1,
        rs2: rs2,
        funct3: f3,
        funct7: f7,
        imm: imm,
        alu_op: alu_op,
        reg_write: reg_w,
        mem_read: m_read,
        mem_write: m_write,
        mem_to_reg: m_to_reg,
        alu_src: a_src,
        branch: br,
        jump: jmp,
        is_amo: amo,
        is_wfi: wfi
    )
