# RV32 Sv32 request/response page-table walker.
#
# One aligned 4-byte PTE read may be outstanding.  A/D uses Svade semantics:
# a clear A, or a clear D on store, faults rather than updating a PTE.

use std.hardware.rv32i_rtl.mmu_sv32.{MmuState, mmu_tlb_lookup, mmu_tlb_insert}
use std.hardware.rv32i_rtl.mmu_sv32.{sv32_vpn1, sv32_vpn0, sv32_full_vpn}
use std.hardware.rv32i_rtl.mmu_sv32.{pte_ppn0, pte_ppn_full, pte_flags_extract}
use std.hardware.rv32i_rtl.mmu_sv32.{fault_cause_for, ACCESS_FETCH, ACCESS_LOAD, ACCESS_STORE}
use std.hardware.rv32i_rtl.mmu_sv32.{PRIV_U, PRIV_S, PRIV_M}
use std.hardware.rv32i_rtl.mmu_sv32.{PTE_V_MASK, PTE_R_MASK, PTE_W_MASK, PTE_X_MASK}
use std.hardware.rv32i_rtl.mmu_sv32.{PTE_U_MASK, PTE_G_MASK, PTE_A_MASK, PTE_D_MASK}
use std.hardware.rv32i_rtl.sv32_address.{sv32_bus_addr_fits, sv32_table_pte_addr, sv32_leaf_paddr}
use std.hardware.rv32i_rtl.pmp.{PmpEntries32, pmp32_gate_access}
use std.hardware.rv32i_rtl.pmp.{PMP32_ACCESS_READ, PMP32_PRIV_S}
use std.hardware.rv32i_rtl.pmp.{PMP32_CAUSE_INSN_ACCESS_FAULT, PMP32_CAUSE_LOAD_ACCESS_FAULT, PMP32_CAUSE_STORE_ACCESS_FAULT}

val SV32_WALK_IDLE: u32 = 0
val SV32_WALK_REQUEST: u32 = 1
val SV32_WALK_WAIT: u32 = 2
val SV32_WALK_DONE: u32 = 3
val SV32_WALK_FAULT: u32 = 4

struct Sv32Walker32:
    phase: u32
    level: u32
    vaddr: u32
    access_type: u32
    privilege: u32
    sum: bool
    mxr: bool
    table_ppn: u32
    global_mapping: bool
    paddr: i64
    fault_cause: u32
    tlb_hit: bool

struct Sv32PteConsume32:
    walker: Sv32Walker32
    mmu: MmuState

struct Sv32WalkCycle32:
    walker: Sv32Walker32
    mmu: MmuState
    bus_valid: bool
    bus_addr: i64
    bus_size: u32
    bus_write: bool
    done: bool
    fault: bool
    paddr: i64
    fault_cause: u32
    fault_tval: u32
    tlb_hit: bool

@hardware
fn sv32_walker32_reset() -> Sv32Walker32:
    Sv32Walker32(phase: SV32_WALK_IDLE, level: 1, vaddr: 0,
        access_type: ACCESS_LOAD, privilege: PRIV_S, sum: false, mxr: false,
        table_ppn: 0, global_mapping: false,
        paddr: 0, fault_cause: 0, tlb_hit: false)

@hardware
fn sv32_walker32_page_fault(state: Sv32Walker32) -> Sv32Walker32:
    var out = state
    out.phase = SV32_WALK_FAULT
    out.paddr = 0
    out.fault_cause = fault_cause_for(state.access_type)
    out

@hardware
fn sv32_walker32_access_fault_cause(access_type: u32) -> u32:
    if access_type == ACCESS_FETCH:
        return PMP32_CAUSE_INSN_ACCESS_FAULT
    if access_type == ACCESS_STORE:
        return PMP32_CAUSE_STORE_ACCESS_FAULT
    PMP32_CAUSE_LOAD_ACCESS_FAULT

@hardware
fn sv32_walker32_access_fault(state: Sv32Walker32) -> Sv32Walker32:
    var out = state
    out.phase = SV32_WALK_FAULT
    out.paddr = 0
    out.fault_cause = sv32_walker32_access_fault_cause(state.access_type)
    out

@hardware
fn sv32_walker32_check_perms(flags: u32, access_type: u32, privilege: u32,
                              sum: bool, mxr: bool) -> bool:
    if (flags & PTE_V_MASK) == 0:
        return false
    if (flags & (PTE_R_MASK | PTE_W_MASK | PTE_X_MASK)) == 0:
        return false
    if (flags & PTE_W_MASK) != 0 and (flags & PTE_R_MASK) == 0:
        return false

    val user_page = (flags & PTE_U_MASK) != 0
    if privilege == PRIV_U and not user_page:
        return false
    if privilege == PRIV_S and user_page and (access_type == ACCESS_FETCH or not sum):
        return false
    if privilege != PRIV_U and privilege != PRIV_S:
        return false

    if (flags & PTE_A_MASK) == 0:
        return false
    if access_type == ACCESS_STORE and (flags & PTE_D_MASK) == 0:
        return false

    if access_type == ACCESS_FETCH:
        return (flags & PTE_X_MASK) != 0
    if access_type == ACCESS_LOAD:
        return (flags & PTE_R_MASK) != 0 or (mxr and (flags & PTE_X_MASK) != 0)
    if access_type == ACCESS_STORE:
        return (flags & PTE_W_MASK) != 0
    false

@hardware
fn sv32_walker32_start(mmu: MmuState, pmp: PmpEntries32, vaddr: u32, access_type: u32,
                       privilege: u32, sum: bool, mxr: bool) -> Sv32Walker32:
    var out = sv32_walker32_reset()
    out.vaddr = vaddr
    out.access_type = access_type
    out.privilege = privilege
    out.sum = sum
    out.mxr = mxr

    if access_type > ACCESS_STORE:
        return sv32_walker32_page_fault(out)
    if privilege != PRIV_U and privilege != PRIV_S and privilege != PRIV_M:
        return sv32_walker32_page_fault(out)
    if privilege == PRIV_M or mmu.satp_mode == 0:
        out.phase = SV32_WALK_DONE
        out.paddr = vaddr as i64
        return out
    if mmu.satp_mode != 1:
        return sv32_walker32_page_fault(out)

    val hit = mmu_tlb_lookup(mmu, sv32_full_vpn(vaddr))
    if hit.hit:
        val hit_paddr = sv32_leaf_paddr(vaddr, hit.ppn, 0)
        if (not sv32_walker32_check_perms(hit.flags, access_type, privilege, sum, mxr) or
            not sv32_bus_addr_fits(hit_paddr)):
            return sv32_walker32_page_fault(out)
        out.phase = SV32_WALK_DONE
        out.paddr = hit_paddr
        out.tlb_hit = true
        return out

    out.phase = SV32_WALK_REQUEST
    out.level = 1
    out.table_ppn = mmu.satp_ppn
    out

@hardware
fn sv32_walker32_pte_addr(state: Sv32Walker32) -> i64:
    val vpn_index = if state.level == 1: sv32_vpn1(state.vaddr) else: sv32_vpn0(state.vaddr)
    sv32_table_pte_addr(state.table_ppn, vpn_index)

@hardware
fn sv32_walker32_consume_pte(state: Sv32Walker32, mmu: MmuState,
                              pte: u32) -> Sv32PteConsume32:
    val flags = pte_flags_extract(pte)
    val valid = (flags & PTE_V_MASK) != 0
    val readable = (flags & PTE_R_MASK) != 0
    val writable = (flags & PTE_W_MASK) != 0
    val executable = (flags & PTE_X_MASK) != 0

    if not valid or (writable and not readable):
        return Sv32PteConsume32(walker: sv32_walker32_page_fault(state), mmu: mmu)

    val leaf = readable or executable
    if not leaf:
        val reserved_nonleaf = (flags & (PTE_U_MASK | PTE_A_MASK | PTE_D_MASK)) != 0
        if state.level == 0 or reserved_nonleaf:
            return Sv32PteConsume32(walker: sv32_walker32_page_fault(state), mmu: mmu)
        var next = state
        next.phase = SV32_WALK_REQUEST
        next.level = 0
        next.table_ppn = pte_ppn_full(pte)
        next.global_mapping = state.global_mapping or (flags & PTE_G_MASK) != 0
        return Sv32PteConsume32(walker: next, mmu: mmu)

    if state.level == 1 and pte_ppn0(pte) != 0:
        return Sv32PteConsume32(walker: sv32_walker32_page_fault(state), mmu: mmu)
    if not sv32_walker32_check_perms(flags, state.access_type, state.privilege,
                                     state.sum, state.mxr):
        return Sv32PteConsume32(walker: sv32_walker32_page_fault(state), mmu: mmu)

    val paddr = sv32_leaf_paddr(state.vaddr, pte_ppn_full(pte), state.level)
    if not sv32_bus_addr_fits(paddr):
        return Sv32PteConsume32(walker: sv32_walker32_page_fault(state), mmu: mmu)

    var done = state
    done.phase = SV32_WALK_DONE
    done.paddr = paddr
    done.fault_cause = 0
    # MmuState cannot encode a superpage level, so only cache exact 4 KiB leaves.
    val cached_flags = if state.global_mapping: flags | PTE_G_MASK else: flags
    val next_mmu = if state.level == 0:
        mmu_tlb_insert(mmu, sv32_full_vpn(state.vaddr), pte_ppn_full(pte), cached_flags)
    else:
        mmu
    Sv32PteConsume32(walker: done, mmu: next_mmu)

@hardware
fn sv32_walker32_cycle(state: Sv32Walker32, mmu: MmuState, pmp: PmpEntries32,
                       request_ready: bool,
                       response_valid: bool, response_error: bool,
                       response_data: u32) -> Sv32WalkCycle32:
    var next = state
    var next_mmu = mmu
    var bus_valid = false
    var bus_addr: i64 = 0

    if state.phase == SV32_WALK_REQUEST:
        val pte_addr = sv32_walker32_pte_addr(state)
        if not sv32_bus_addr_fits(pte_addr):
            next = sv32_walker32_page_fault(state)
        else:
            val gate = pmp32_gate_access(pmp, pte_addr, 4, PMP32_ACCESS_READ,
                PMP32_PRIV_S, false, 0)
            if not gate.bus_valid:
                next = sv32_walker32_access_fault(state)
            else:
                bus_valid = true
                bus_addr = gate.paddr
                if request_ready:
                    if response_valid:
                        if response_error:
                            next = sv32_walker32_access_fault(state)
                        else:
                            val consumed = sv32_walker32_consume_pte(state, mmu, response_data)
                            next = consumed.walker
                            next_mmu = consumed.mmu
                    else:
                        next.phase = SV32_WALK_WAIT
    else if state.phase == SV32_WALK_WAIT and response_valid:
        if response_error:
            next = sv32_walker32_access_fault(state)
        else:
            val consumed = sv32_walker32_consume_pte(state, mmu, response_data)
            next = consumed.walker
            next_mmu = consumed.mmu

    val done = next.phase == SV32_WALK_DONE or next.phase == SV32_WALK_FAULT
    Sv32WalkCycle32(walker: next, mmu: next_mmu, bus_valid: bus_valid,
        bus_addr: bus_addr, bus_size: 4, bus_write: false, done: done,
        fault: next.phase == SV32_WALK_FAULT, paddr: next.paddr,
        fault_cause: next.fault_cause, fault_tval: next.vaddr,
        tlb_hit: next.tlb_hit)

export Sv32Walker32, Sv32WalkCycle32
export sv32_walker32_reset, sv32_walker32_start, sv32_walker32_cycle
export SV32_WALK_IDLE, SV32_WALK_REQUEST, SV32_WALK_WAIT, SV32_WALK_DONE, SV32_WALK_FAULT
