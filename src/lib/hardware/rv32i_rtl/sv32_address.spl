# RV32 Sv32 address decomposition.
#
# This owner is intentionally a small, combinational compiler boundary.  It
# does not claim to implement the page-table walker or PMP enforcement.

@hardware
fn sv32_full_vpn(vaddr: u32) -> u32:
    """Extract the full 20-bit VPN (VPN[1]:VPN[0]) from a virtual address."""
    (vaddr >> 12) & 0xFFFFF
