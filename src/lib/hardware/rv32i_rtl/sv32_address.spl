# RV32 Sv32 physical-address helpers for the request/response walker.
#
# Sv32 PPNs describe a 34-bit physical address space.

@hardware
fn sv32_bus_addr_fits(paddr: i64) -> bool:
    paddr >= 0 and paddr <= 0x3FFFFFFFF

@hardware
fn sv32_table_pte_addr(table_ppn: u32, vpn_index: u32) -> i64:
    ((table_ppn as i64) << 12) | ((vpn_index as i64) << 2)

@hardware
fn sv32_leaf_paddr(vaddr: u32, ppn: u32, level: u32) -> i64:
    val offset = (vaddr & 0xFFF) as i64
    if level == 1:
        return ((((ppn >> 10) as i64) << 22) |
                ((((vaddr >> 12) & 0x3FF) as i64) << 12) | offset)
    ((ppn as i64) << 12) | offset

export sv32_bus_addr_fits, sv32_table_pte_addr, sv32_leaf_paddr
