# ============================================================================
# K26 PS-PL Bridge — AXI4-Lite to Wishbone
# ============================================================================
#
# Bridges the Zynq UltraScale+ PS AXI4-Lite master to the SoC's Wishbone
# bus.  Simplified same-clock-domain version (PS and PL share a common
# clock from EMIO).
#
# AXI4-Lite side:
#   - 32-bit address, 32-bit data (matches PS GP port width)
#   - Single-beat reads and writes only
#
# Wishbone side:
#   - Classic single-cycle handshake (STB/ACK)
#   - 32-bit address, 32-bit data
#
# All operations are pure functions — suitable for synthesizable RTL.
#
# VHDL synthesizable subset: u32, i64, bool, structs only.
# ============================================================================

# ============================================================================
# AXI4-Lite Request
# ============================================================================

struct AxiLiteRequest:
    """AXI4-Lite master request signals."""
    addr: u32       # Address
    wdata: u32      # Write data
    we: bool        # Write enable (true=write, false=read)
    valid: bool     # Request valid

# ============================================================================
# AXI4-Lite Response
# ============================================================================

struct AxiLiteResponse:
    """AXI4-Lite slave response signals."""
    rdata: u32      # Read data
    ready: bool     # Response ready
    resp_ok: bool   # Response status (true=OKAY, false=SLVERR)

# ============================================================================
# Wishbone Master Bus
# ============================================================================

struct WbMasterBus:
    """Wishbone classic master signals (from bridge to SoC bus)."""
    adr: u32        # Address
    dat_w: u32      # Write data
    we: bool        # Write enable
    stb: bool       # Strobe
    cyc: bool       # Cycle

# ============================================================================
# Wishbone Slave Response
# ============================================================================

struct WbSlaveResponse:
    """Wishbone classic slave response signals."""
    dat_r: u32      # Read data
    ack: bool       # Acknowledge

# ============================================================================
# Bridge State
# ============================================================================

struct AxiLiteBridge:
    """AXI4-Lite to Wishbone bridge state."""
    pending: bool       # Transaction in progress
    pending_addr: u32   # Latched address
    pending_wdata: u32  # Latched write data
    pending_we: bool    # Latched write enable

# ============================================================================
# Create — initial idle bridge state
# ============================================================================

fn bridge_create() -> AxiLiteBridge:
    """Create an idle bridge."""
    AxiLiteBridge(pending: false, pending_addr: 0, pending_wdata: 0, pending_we: false)

# ============================================================================
# AXI to Wishbone — convert AXI request to WB master signals
# ============================================================================

fn axi_to_wb(req: AxiLiteRequest) -> WbMasterBus:
    """Convert an AXI4-Lite request to Wishbone master bus signals.
    Direct mapping for same-clock-domain operation."""
    if req.valid:
        WbMasterBus(
            adr: req.addr,
            dat_w: req.wdata,
            we: req.we,
            stb: true,
            cyc: true
        )
    else:
        WbMasterBus(adr: 0, dat_w: 0, we: false, stb: false, cyc: false)

# ============================================================================
# Wishbone to AXI — convert WB slave response to AXI response
# ============================================================================

fn wb_to_axi(wb_resp: WbSlaveResponse) -> AxiLiteResponse:
    """Convert a Wishbone slave response to AXI4-Lite response signals."""
    AxiLiteResponse(
        rdata: wb_resp.dat_r,
        ready: wb_resp.ack,
        resp_ok: true
    )

# ============================================================================
# Bridge Tick — handle one clock cycle of the bridge FSM
# ============================================================================

fn bridge_tick(state: AxiLiteBridge, axi_req: AxiLiteRequest, wb_resp: WbSlaveResponse) -> AxiLiteBridge:
    """Advance bridge state by one clock cycle.
    In same-clock-domain mode, transactions complete in a single cycle
    when the Wishbone slave ACKs."""
    if state.pending and wb_resp.ack:
        # Transaction complete — return to idle
        return AxiLiteBridge(pending: false, pending_addr: 0, pending_wdata: 0, pending_we: false)

    if axi_req.valid and state.pending == false:
        # New transaction — latch and start
        return AxiLiteBridge(
            pending: true,
            pending_addr: axi_req.addr,
            pending_wdata: axi_req.wdata,
            pending_we: axi_req.we
        )

    state
