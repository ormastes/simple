# ============================================================================
# K26 XDC Constraint Generator
# ============================================================================
#
# Generates Xilinx Design Constraints (.xdc) for the Kria K26 SOM
# (xck26-sfvc784-2LV-c).  Follows the same pattern as xdc_gen.spl.
#
# K26 specifics:
#   - PL clock from PS via EMIO (typically 100 MHz)
#   - PMOD connectors for UART I/O
#   - Status LEDs on carrier board
#   - Part: xck26-sfvc784-2LV-c
# ============================================================================

# ============================================================================
# K26 XDC Configuration
# ============================================================================

struct K26XdcConfig:
    """Configuration for K26 XDC constraint generation."""
    clock_freq: i64        # PL clock frequency in Hz
    uart_tx_pin: text      # PMOD pin for UART TX
    uart_rx_pin: text      # PMOD pin for UART RX
    led_pins: [text]       # LED pin locations
    reset_pin: text        # Reset button pin
    io_standard: text      # I/O standard for PMOD pins

# ============================================================================
# Default K26 Configuration
# ============================================================================

pub fn k26_default_config() -> K26XdcConfig:
    """Default K26 configuration for KV260 carrier board.
    PMOD J2 used for UART, LEDs on carrier board."""
    K26XdcConfig(
        clock_freq: 100000000,
        uart_tx_pin: "H12",
        uart_rx_pin: "E10",
        led_pins: ["F8", "E8", "D8", "C7"],
        reset_pin: "G11",
        io_standard: "LVCMOS33"
    )

# ============================================================================
# XDC Generation
# ============================================================================

fn k26_render_xdc(config: K26XdcConfig) -> text:
    """Generates XDC constraint text for the K26 SOM."""
    var lines: [text] = []
    val ios = config.io_standard

    lines = lines + ["## ============================================================================"]
    lines = lines + ["## XDC Constraints for Kria K26 SOM (xck26-sfvc784-2LV-c)"]
    lines = lines + ["## Auto-generated by Simple compiler — do not edit manually"]
    lines = lines + ["## ============================================================================"]
    lines = lines + [""]

    # Clock constraint — PL clock from PS EMIO
    val freq = config.clock_freq
    var period_ns: i64 = 10
    if freq > 0:
        period_ns = 1000000000 / freq
    val half_ns = period_ns / 2
    lines = lines + ["## PL Clock from PS (EMIO)"]
    lines = lines + ["create_clock -period {period_ns}.000 -name pl_clk0 -waveform {{0.000 {half_ns}.000}} [get_clocks clk_pl_0]"]
    lines = lines + [""]

    # Reset
    val rst = config.reset_pin
    lines = lines + ["## Reset"]
    lines = lines + ["set_property PACKAGE_PIN {rst} [get_ports sys_rst_n]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports sys_rst_n]"]
    lines = lines + [""]

    # UART on PMOD
    val tx = config.uart_tx_pin
    val rx = config.uart_rx_pin
    lines = lines + ["## UART (PMOD)"]
    lines = lines + ["set_property PACKAGE_PIN {tx} [get_ports uart_txd]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports uart_txd]"]
    lines = lines + ["set_property PACKAGE_PIN {rx} [get_ports uart_rxd]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports uart_rxd]"]
    lines = lines + [""]

    # LEDs
    lines = lines + ["## Status LEDs"]
    var led_idx = 0
    for pin in config.led_pins:
        lines = lines + ["set_property PACKAGE_PIN {pin} [get_ports led[{led_idx}]]"]
        lines = lines + ["set_property IOSTANDARD {ios} [get_ports led[{led_idx}]]"]
        led_idx = led_idx + 1
    lines = lines + [""]

    # Bitstream configuration
    lines = lines + ["## Bitstream Settings"]
    lines = lines + ["set_property BITSTREAM.GENERAL.COMPRESS TRUE [current_design]"]
    lines = lines + ["set_property CONFIG_VOLTAGE 1.8 [current_design]"]
    lines = lines + [""]

    lines.join("\n")

# ============================================================================
# Quick XDC generation with defaults
# ============================================================================

fn k26_generate_default_xdc() -> text:
    """Generate XDC constraints with default K26/KV260 configuration."""
    k26_render_xdc(k26_default_config())

# ============================================================================
# Public no-arg K26 XDC generator
# ============================================================================

pub fn k26_generate_xdc() -> text:
    """Generates XDC constraints for the Kria K26 SOM (xck26-sfvc784-2LV-c).
    Includes clock, UART (PMOD), reset, LEDs, and JTAG debug constraints."""
    val cfg = k26_default_config()
    var lines: [text] = []
    val ios = cfg.io_standard

    lines = lines + ["## ============================================================================"]
    lines = lines + ["## XDC Constraints for Kria K26 SOM (xck26-sfvc784-2LV-c)"]
    lines = lines + ["## Auto-generated by Simple compiler — do not edit manually"]
    lines = lines + ["## ============================================================================"]
    lines = lines + [""]

    # PL clock from PS EMIO
    val freq = cfg.clock_freq
    var period_ns: i64 = 10
    if freq > 0:
        period_ns = 1000000000 / freq
    val half_ns = period_ns / 2
    lines = lines + ["## PL Clock from PS (EMIO)"]
    lines = lines + ["create_clock -period {period_ns}.000 -name pl_clk0 -waveform {{0.000 {half_ns}.000}} [get_clocks clk_pl_0]"]
    lines = lines + [""]

    # Reset
    val rst = cfg.reset_pin
    lines = lines + ["## Reset"]
    lines = lines + ["set_property PACKAGE_PIN {rst} [get_ports rst]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports rst]"]
    lines = lines + [""]

    # UART on PMOD
    val tx = cfg.uart_tx_pin
    val rx = cfg.uart_rx_pin
    lines = lines + ["## UART (PMOD)"]
    lines = lines + ["set_property PACKAGE_PIN {tx} [get_ports uart_tx]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports uart_tx]"]
    lines = lines + ["set_property PACKAGE_PIN {rx} [get_ports uart_rx]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports uart_rx]"]
    lines = lines + [""]

    # JTAG debug constraints
    lines = lines + ["## JTAG Debug"]
    lines = lines + ["set_property PACKAGE_PIN A12 [get_ports jtag_tck]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports jtag_tck]"]
    lines = lines + ["set_property PACKAGE_PIN B12 [get_ports jtag_tms]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports jtag_tms]"]
    lines = lines + ["set_property PACKAGE_PIN C12 [get_ports jtag_tdi]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports jtag_tdi]"]
    lines = lines + ["set_property PACKAGE_PIN D12 [get_ports jtag_tdo]"]
    lines = lines + ["set_property IOSTANDARD {ios} [get_ports jtag_tdo]"]
    lines = lines + [""]

    # LEDs
    lines = lines + ["## Status LEDs"]
    var led_idx = 0
    for pin in cfg.led_pins:
        lines = lines + ["set_property PACKAGE_PIN {pin} [get_ports led[{led_idx}]]"]
        lines = lines + ["set_property IOSTANDARD {ios} [get_ports led[{led_idx}]]"]
        led_idx = led_idx + 1
    lines = lines + [""]

    lines.join("\n")
