# ============================================================================
# RISC-V RTL Trap Controller — XLEN-Parameterized Exception/Interrupt Handling
# ============================================================================
#
# Unified trap controller supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# Implements RISC-V M-mode trap entry/exit logic, with optional S-mode
# delegation support (RV64).
#
# All operations are pure functions — suitable for synthesizable RTL.
# Only direct mtvec mode is supported.
# ============================================================================

use std.hardware.riscv_rtl.common.pkg.{mstatus_mie_mask, mstatus_mpie_mask, mstatus_mpp_mask, mpp_m_mode}
use std.hardware.riscv_rtl.common.pkg.{MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK}
use std.hardware.riscv_rtl.common.csr.{CsrFile, CsrFile32, CsrFile64}
use std.hardware.riscv_rtl.common.csr_s.{CsrSMode, CsrSMode32, CsrSMode64}
use std.hardware.riscv_rtl.common.csr_s.{csr_s_is_exception_delegated, csr_s_is_interrupt_delegated}
use std.hardware.riscv_rtl.common.csr_s.{csr_s64_is_exception_delegated, csr_s64_is_interrupt_delegated}

# ============================================================================
# Trap phase constants
# ============================================================================

val TRAP_NORMAL: u32 = 0
val TRAP_ENTER: u32  = 1
val TRAP_EXIT: u32   = 2

# ============================================================================
# Exception cause codes (mcause with MSB=0)
# ============================================================================

val CAUSE_MISALIGNED_FETCH: i64  = 0
val CAUSE_ILLEGAL_INSN: i64     = 2
val CAUSE_BREAKPOINT: i64       = 3
val CAUSE_LOAD_MISALIGNED: i64  = 4
val CAUSE_STORE_MISALIGNED: i64 = 6
val CAUSE_ECALL_M: i64          = 11
val CAUSE_ECALL_S: i64          = 9
val CAUSE_ECALL_U: i64          = 8

# ============================================================================
# Interrupt cause codes (MSB=1)
# ============================================================================

fn cause_msi() -> i64:
    """Machine Software Interrupt cause (bit63 | 3)."""
    (1 << 63) | 3

fn cause_mti() -> i64:
    """Machine Timer Interrupt cause (bit63 | 7)."""
    (1 << 63) | 7

fn cause_mei() -> i64:
    """Machine External Interrupt cause (bit63 | 11)."""
    (1 << 63) | 11

# Legacy RV32 interrupt constants
val CAUSE_MSI: u32 = 0x80000003
val CAUSE_MTI: u32 = 0x80000007
val CAUSE_MEI: u32 = 0x8000000B

# ============================================================================
# Trap State
# ============================================================================

struct TrapState:
    """Trap controller state."""
    phase: u32

struct TrapState64:
    """RV64 trap controller state."""
    phase: u32

# ============================================================================
# Interrupt Check Result
# ============================================================================

struct InterruptCheckResult:
    pending: bool
    cause: i64

struct InterruptCheckResult64:
    pending: bool
    cause: i64

# ============================================================================
# Trap Enter/Exit Results
# ============================================================================

struct TrapEnterResult:
    csr: CsrFile
    trap_pc: i64

struct TrapEnterResult64:
    csr: CsrFile64
    csr_s: CsrSMode64
    trap_pc: i64
    target_mode: i64

struct TrapExitResult:
    csr: CsrFile
    return_pc: i64

struct TrapExitResult64:
    csr: CsrFile64
    return_pc: i64
    target_mode: i64

# ============================================================================
# Check for Pending Interrupts
# ============================================================================

fn trap_check_interrupt(csr: CsrFile) -> InterruptCheckResult:
    """Check if an interrupt should be taken (RV32/RV64 unified)."""
    val mie_enabled = (csr.mstatus & mstatus_mie_mask(64)) != 0
    if mie_enabled == false:
        return InterruptCheckResult(pending: false, cause: 0)

    val enabled_pending = csr.mie & csr.mip

    if (enabled_pending & MIP_MEIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: cause_mei())
    if (enabled_pending & MIP_MSIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: cause_msi())
    if (enabled_pending & MIP_MTIP_MASK) != 0:
        return InterruptCheckResult(pending: true, cause: cause_mti())

    InterruptCheckResult(pending: false, cause: 0)

fn trap64_check_interrupt(csr: CsrFile64) -> InterruptCheckResult64:
    """RV64 interrupt check."""
    val mie_enabled = (csr.mstatus & mstatus_mie_mask(64)) != 0
    if mie_enabled == false:
        return InterruptCheckResult64(pending: false, cause: 0)

    val enabled_pending = csr.mie & csr.mip

    if (enabled_pending & MIP_MEIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_mei())
    if (enabled_pending & MIP_MSIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_msi())
    if (enabled_pending & MIP_MTIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_mti())

    InterruptCheckResult64(pending: false, cause: 0)

# ============================================================================
# Trap Entry (M-mode only)
# ============================================================================

fn trap_enter(csr: CsrFile, pc: i64, cause: i64, tval: i64, xlen: u32) -> TrapEnterResult:
    """Enter a trap: save context to CSRs, compute handler address."""
    var new_csr = csr

    new_csr.mepc = pc & (-4)
    new_csr.mcause = cause
    new_csr.mtval = tval

    val old_mie = (csr.mstatus & mstatus_mie_mask(xlen)) >> 3
    var new_mstatus = csr.mstatus

    new_mstatus = new_mstatus & (mstatus_mie_mask(xlen) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpie_mask(xlen) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpp_mask(xlen) ^ -1)

    new_mstatus = new_mstatus | (old_mie << 7)
    new_mstatus = new_mstatus | mpp_m_mode(xlen)

    new_csr.mstatus = new_mstatus

    val trap_pc = csr.mtvec & (-4)

    TrapEnterResult(csr: new_csr, trap_pc: trap_pc)

fn trap64_enter_m_only(csr: CsrFile64, pc: i64, cause: i64, tval: i64) -> TrapEnterResult64:
    """RV64 M-mode-only trap entry."""
    var new_csr = csr

    new_csr.mepc = pc & 0xFFFFFFFFFFFFFFFC
    new_csr.mcause = cause
    new_csr.mtval = tval

    val old_mie = (csr.mstatus & mstatus_mie_mask(64)) >> 3
    var new_mstatus = csr.mstatus

    new_mstatus = new_mstatus & (mstatus_mie_mask(64) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpie_mask(64) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpp_mask(64) ^ -1)

    new_mstatus = new_mstatus | (old_mie << 7)
    new_mstatus = new_mstatus | mpp_m_mode(64)

    new_csr.mstatus = new_mstatus

    val trap_pc = csr.mtvec & 0xFFFFFFFFFFFFFFFC

    TrapEnterResult64(csr: new_csr, csr_s: CsrSMode64(sstatus: 0, sie: 0, stvec: 0, sscratch: 0,
        sepc: 0, scause: 0, stval: 0, sip: 0, satp: 0, medeleg: 0, mideleg: 0), trap_pc: trap_pc, target_mode: 3)

# ============================================================================
# Trap Entry with S-mode delegation (RV64)
# ============================================================================

fn trap64_enter_with_s_mode(ts: TrapState64, cause: i64, tval: i64, pc: i64,
                            priv_mode: i64, csr_m: CsrFile64, csr_s: CsrSMode64) -> TrapEnterResult64:
    """Enter a trap with S-mode delegation support."""
    val int_bit: i64 = 1 << 63
    val is_interrupt = (cause & int_bit) != 0

    var delegated: bool = false
    if is_interrupt:
        val irq_num = cause & (int_bit ^ -1)
        delegated = csr_s64_is_interrupt_delegated(csr_s, irq_num)
    else:
        delegated = csr_s64_is_exception_delegated(csr_s, cause)

    if delegated:
        var new_csr_s = csr_s
        new_csr_s.sepc = pc & 0xFFFFFFFFFFFFFFFC
        new_csr_s.scause = cause
        new_csr_s.stval = tval

        val old_sie = (csr_s.sstatus & 0x02) >> 1
        var new_sstatus = csr_s.sstatus
        new_sstatus = new_sstatus & 0xFFFFFFFD
        new_sstatus = new_sstatus & 0xFFFFFFDF
        new_sstatus = new_sstatus & (0x00000100 ^ -1)
        new_sstatus = new_sstatus | (old_sie << 5)
        if priv_mode == 1:
            new_sstatus = new_sstatus | 0x00000100
        new_csr_s.sstatus = new_sstatus

        val trap_pc = csr_s.stvec & 0xFFFFFFFFFFFFFFFC
        TrapEnterResult64(csr: csr_m, csr_s: new_csr_s, trap_pc: trap_pc, target_mode: 1)
    else:
        val m_only = trap64_enter_m_only(csr_m, pc, cause, tval)
        TrapEnterResult64(csr: m_only.csr, csr_s: csr_s, trap_pc: m_only.trap_pc, target_mode: 3)

# ============================================================================
# Trap Exit (MRET)
# ============================================================================

fn trap_exit_mret(csr: CsrFile, xlen: u32) -> TrapExitResult:
    """Exit from M-mode trap via MRET."""
    var new_mstatus = csr.mstatus

    val old_mpie = (csr.mstatus & mstatus_mpie_mask(xlen)) >> 7
    val mpp = (csr.mstatus & mstatus_mpp_mask(xlen)) >> 11

    new_mstatus = new_mstatus & (mstatus_mie_mask(xlen) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpie_mask(xlen) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpp_mask(xlen) ^ -1)

    new_mstatus = new_mstatus | (old_mpie << 3)
    new_mstatus = new_mstatus | mstatus_mpie_mask(xlen)

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    val return_pc = csr.mepc

    TrapExitResult(csr: new_csr, return_pc: return_pc)

fn trap64_exit_mret(csr: CsrFile64) -> TrapExitResult64:
    """RV64 M-mode trap exit."""
    var new_mstatus = csr.mstatus

    val old_mpie = (csr.mstatus & mstatus_mpie_mask(64)) >> 7
    val mpp = (csr.mstatus & mstatus_mpp_mask(64)) >> 11

    new_mstatus = new_mstatus & (mstatus_mie_mask(64) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpie_mask(64) ^ -1)
    new_mstatus = new_mstatus & (mstatus_mpp_mask(64) ^ -1)

    new_mstatus = new_mstatus | (old_mpie << 3)
    new_mstatus = new_mstatus | mstatus_mpie_mask(64)

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    val return_pc = csr.mepc

    TrapExitResult64(csr: new_csr, return_pc: return_pc, target_mode: mpp)

# ============================================================================
# S-mode SRET (RV64)
# ============================================================================

fn trap64_sret_csr(csr_s: CsrSMode64) -> CsrSMode64:
    """Return updated S-mode CSR state after SRET."""
    val old_spie = (csr_s.sstatus & 0x20) >> 5

    var new_sstatus = csr_s.sstatus
    new_sstatus = new_sstatus & 0xFFFFFFFD
    new_sstatus = new_sstatus & 0xFFFFFFDF
    new_sstatus = new_sstatus & (0x00000100 ^ -1)

    new_sstatus = new_sstatus | (old_spie << 1)
    new_sstatus = new_sstatus | 0x20

    var new_csr_s = csr_s
    new_csr_s.sstatus = new_sstatus
    new_csr_s

fn trap64_sret(csr_s: CsrSMode64) -> TrapExitResult64:
    """Exit S-mode trap via SRET."""
    val spp = (csr_s.sstatus & 0x00000100) >> 8
    val new_csr_s = trap64_sret_csr(csr_s)

    val dummy_csr_m = CsrFile64(mstatus: 0, misa: 0, mie: 0, mtvec: 0, mscratch: 0,
        mepc: 0, mcause: 0, mtval: 0, mip: 0, medeleg: 0, mideleg: 0,
        mcycle: 0, minstret: 0, mhartid: 0)

    TrapExitResult64(csr: dummy_csr_m, return_pc: csr_s.sepc, target_mode: spp)

# ============================================================================
# Trap State Init
# ============================================================================

fn trap_state_init() -> TrapState:
    """Create zeroed initial trap state."""
    TrapState(phase: 0)

fn trap64_state_init() -> TrapState64:
    """Create zeroed initial trap state (RV64)."""
    TrapState64(phase: 0)

# ============================================================================
# RV32-compatible wrappers
# ============================================================================

struct TrapState32:
    phase: u32

fn trap32_state_init() -> TrapState32:
    TrapState32(phase: 0)

fn trap32_check_interrupt(csr: CsrFile32) -> InterruptCheckResult:
    """RV32 interrupt check."""
    val mie_enabled = (csr.mstatus & 0x08) != 0
    if mie_enabled == false:
        return InterruptCheckResult(pending: false, cause: 0)

    val enabled_pending = csr.mie & csr.mip

    if (enabled_pending & 0x800) != 0:
        return InterruptCheckResult(pending: true, cause: 0x8000000B)
    if (enabled_pending & 0x8) != 0:
        return InterruptCheckResult(pending: true, cause: 0x80000003)
    if (enabled_pending & 0x80) != 0:
        return InterruptCheckResult(pending: true, cause: 0x80000007)

    InterruptCheckResult(pending: false, cause: 0)

fn trap32_enter(csr: CsrFile32, pc: u32, cause: u32, tval: u32) -> TrapEnterResult:
    """RV32 M-mode trap entry."""
    var new_csr = csr

    new_csr.mepc = pc & 0xFFFFFFFC
    new_csr.mcause = cause as i64
    new_csr.mtval = tval as i64

    val old_mie = (csr.mstatus & 0x08) >> 3
    var new_mstatus = csr.mstatus & 0xFFFFF6F

    new_mstatus = new_mstatus | (old_mie << 7)
    new_mstatus = new_mstatus | 0x00001800

    new_csr.mstatus = new_mstatus

    val trap_pc = csr.mtvec & 0xFFFFFFFC

    TrapEnterResult(csr: new_csr, trap_pc: trap_pc as i64)

fn trap32_exit_mret(csr: CsrFile32) -> TrapExitResult:
    """RV32 M-mode trap exit."""
    var new_mstatus = csr.mstatus

    val old_mpie = (csr.mstatus & 0x80) >> 7

    new_mstatus = new_mstatus & 0xFFFFF6F
    new_mstatus = new_mstatus | (old_mpie << 3)
    new_mstatus = new_mstatus | 0x80

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    val return_pc = csr.mepc

    TrapExitResult(csr: new_csr, return_pc: return_pc as i64)

# ============================================================================
# Exports
# ============================================================================

export TRAP_NORMAL, TRAP_ENTER, TRAP_EXIT
export CAUSE_MISALIGNED_FETCH, CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT
export CAUSE_LOAD_MISALIGNED, CAUSE_STORE_MISALIGNED, CAUSE_ECALL_M
export CAUSE_ECALL_S, CAUSE_ECALL_U
export cause_msi, cause_mti, cause_mei
export CAUSE_MSI, CAUSE_MTI, CAUSE_MEI
export TrapState, trap_state_init, trap_check_interrupt, trap_enter, trap_exit_mret
export TrapState64, trap64_state_init, trap64_check_interrupt
export trap64_enter_m_only, trap64_enter_with_s_mode, trap64_exit_mret, trap64_sret, trap64_sret_csr
export TrapState32, trap32_state_init, trap32_check_interrupt, trap32_enter, trap32_exit_mret
export TrapEnterResult, TrapExitResult, InterruptCheckResult
export TrapEnterResult64, TrapExitResult64, InterruptCheckResult64
