# ============================================================================
# RISC-V RTL Package — XLEN-Parameterized Constants and Type Aliases
# ============================================================================
#
# Unified package supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# Width-specific values are selected at compile time via XLEN constant.
#
# Usage: In rv32i_rtl/pkg.spl:  const XLEN: u32 = 32; then use std.hardware.riscv_rtl.common.pkg
#         In rv64gc_rtl/pkg.spl: const XLEN: u32 = 64; then use std.hardware.riscv_rtl.common.pkg
#
# VHDL synthesizable subset: only integer constants; no heap, no closures.
# ============================================================================

# ============================================================================
# Base opcode constants (7-bit, stored in u32)
# ============================================================================

val OP_LUI: u32    = 0x37    # Load Upper Immediate
val OP_AUIPC: u32  = 0x17    # Add Upper Immediate to PC
val OP_JAL: u32    = 0x6F    # Jump And Link
val OP_JALR: u32   = 0x67    # Jump And Link Register
val OP_BRANCH: u32 = 0x63    # Conditional branch
val OP_LOAD: u32   = 0x03    # Load (LB, LH, LW, LD, LBU, LHU, LWU)
val OP_STORE: u32  = 0x23    # Store (SB, SH, SW, SD)
val OP_IMMED: u32  = 0x13    # Integer register-immediate
val OP_REG: u32    = 0x33    # Integer register-register
val OP_SYSTEM: u32 = 0x73    # ECALL, EBREAK, CSR

# RV64I additional opcodes (W-suffix instructions)
val OP_OP_IMM_32: u32 = 0x1B   # ADDIW, SLLIW, SRLIW, SRAIW
val OP_OP_32: u32     = 0x3B   # ADDW, SUBW, SLLW, SRLW, SRAW, MULW, DIVW, etc.

# Atomic extension (A) — RV64 only
val OP_AMO: u32 = 0x2F   # Atomic memory operations (LR, SC, AMO*)

# ============================================================================
# ALU operation codes (i64 enum)
# ============================================================================

val ALU_ADD: i64    = 0
val ALU_SUB: i64    = 1
val ALU_SLL: i64    = 2
val ALU_SLT: i64    = 3
val ALU_SLTU: i64   = 4
val ALU_XOR: i64    = 5
val ALU_SRL: i64    = 6
val ALU_SRA: i64    = 7
val ALU_OR: i64     = 8
val ALU_AND: i64    = 9
val ALU_PASS_B: i64 = 10

# W-suffix ALU operations (RV64 only — operate on low 32 bits, sign-extend result)
val ALU_ADDW: i64   = 11
val ALU_SUBW: i64   = 12
val ALU_SLLW: i64   = 13
val ALU_SRLW: i64   = 14
val ALU_SRAW: i64   = 15

# ============================================================================
# Branch funct3 constants (3-bit, stored in u32)
# ============================================================================

val BR_BEQ: u32  = 0x0   # 000
val BR_BNE: u32  = 0x1   # 001
val BR_BLT: u32  = 0x4   # 100
val BR_BGE: u32  = 0x5   # 101
val BR_BLTU: u32 = 0x6   # 110
val BR_BGEU: u32 = 0x7   # 111

# ============================================================================
# Load/Store funct3 constants
# ============================================================================

val FUNCT3_LB: u32  = 0x0   # Load byte (sign-extend)
val FUNCT3_LH: u32  = 0x1   # Load halfword (sign-extend)
val FUNCT3_LW: u32  = 0x2   # Load word (sign-extend)
val FUNCT3_LD: u32  = 0x3   # Load doubleword (RV64)
val FUNCT3_LBU: u32 = 0x4   # Load byte unsigned
val FUNCT3_LHU: u32 = 0x5   # Load halfword unsigned
val FUNCT3_LWU: u32 = 0x6   # Load word unsigned (RV64)

val FUNCT3_SB: u32  = 0x0   # Store byte
val FUNCT3_SH: u32  = 0x1   # Store halfword
val FUNCT3_SW: u32  = 0x2   # Store word
val FUNCT3_SD: u32  = 0x3   # Store doubleword (RV64)

# ============================================================================
# Memory width encoding
# ============================================================================

val MEM_WIDTH_BYTE: u32  = 0x0
val MEM_WIDTH_HALF: u32  = 0x1
val MEM_WIDTH_WORD: u32  = 0x2
val MEM_WIDTH_DWORD: u32 = 0x3   # RV64 only

# ============================================================================
# Multiply/divide operation codes (i64 enum) — RV64 M extension
# ============================================================================

val MULDIV_MUL: i64    = 0
val MULDIV_MULH: i64   = 1
val MULDIV_MULHSU: i64 = 2
val MULDIV_MULHU: i64  = 3
val MULDIV_DIV: i64    = 4
val MULDIV_DIVU: i64   = 5
val MULDIV_REM: i64    = 6
val MULDIV_REMU: i64   = 7
val MULDIV_MULW: i64   = 8
val MULDIV_DIVW: i64   = 9
val MULDIV_DIVUW: i64  = 10
val MULDIV_REMW: i64   = 11
val MULDIV_REMUW: i64  = 12

# ============================================================================
# Atomic funct5 codes (upper 5 bits of funct7) — RV64 A extension
# ============================================================================

val AMO_LR: u32      = 0x02
val AMO_SC: u32      = 0x03
val AMO_SWAP: u32    = 0x01
val AMO_ADD: u32     = 0x00
val AMO_XOR: u32     = 0x04
val AMO_AND: u32     = 0x0C
val AMO_OR: u32      = 0x08
val AMO_MIN: u32     = 0x10
val AMO_MAX: u32     = 0x14
val AMO_MINU: u32    = 0x18
val AMO_MAXU: u32    = 0x1C

# ============================================================================
# Semihosting magic instruction encodings
# ============================================================================

val SEMI_ENTRY: u32 = 0x01F01013   # slli zero,zero,0x1f
val SEMI_BREAK: u32 = 0x00100073   # ebreak
val SEMI_EXIT: u32  = 0x40705013   # srai zero,zero,0x7

# ============================================================================
# Semihosting operation codes
# ============================================================================

val SYS_WRITEC: u32 = 0x00000003
val SYS_WRITE0: u32 = 0x00000004
val SYS_EXIT: u32   = 0x00000018

# ============================================================================
# Mailbox MMIO base address and register offsets
# ============================================================================

val MB_BASE_ADDR: u32     = 0x80FF0000
val MB_OFF_CMD: u32       = 0x00
val MB_OFF_ARG0: u32      = 0x04
val MB_OFF_ARG1: u32      = 0x08
val MB_OFF_STATUS: u32    = 0x0C
val MB_OFF_RESULT: u32    = 0x10
val MB_OFF_SEQ_ID: u32    = 0x14
val MB_OFF_TRIGGER: u32   = 0x18

# ============================================================================
# Mailbox command codes
# ============================================================================

val MB_CMD_PUTC: u32   = 0x00000001
val MB_CMD_EXIT: u32   = 0x00000002
val MB_CMD_RESULT: u32 = 0x00000003

# ============================================================================
# Mailbox sentinel address and values
# ============================================================================

val MB_SENTINEL_ADDR: u32    = 0x80008000
val MB_SENTINEL_SUCCESS: u32 = 0xCAFE0000
val MB_SENTINEL_TIMEOUT: u32 = 0xDEAD0000
val MB_TRIGGER_MAGIC: u32    = 0x0000DEAD

# ============================================================================
# MISA for RV32I and RV64IMAC (computed at runtime to avoid sign-bit issues)
# ============================================================================

fn misa_rv32i() -> u32:
    """MISA value for RV32I: MXL=1 (32-bit) + I extension."""
    0x40000100   # MXL=1 in bits [31:30], I=bit8

fn misa_rv64imac() -> i64:
    """Compute MISA value for RV64IMAC.
    MXL=2 (64-bit) in bits[63:62], plus I+M+A+C extension bits."""
    val mxl: i64 = 2 << 62
    val ext_i: i64 = 1 << 8
    val ext_m: i64 = 1 << 12
    val ext_a: i64 = 1 << 0
    val ext_c: i64 = 1 << 2
    mxl | ext_i | ext_m | ext_a | ext_c

# ============================================================================
# SoC Bus abstraction (shared between core and LSU)
# ============================================================================

struct SocBus64:
    data: i64

fn soc_bus64_init() -> SocBus64:
    SocBus64(data: 0)

# ============================================================================
# CSR Address Constants (u32 for RTL address matching)
# ============================================================================

val CSR_ADDR_MSTATUS: u32   = 0x300
val CSR_ADDR_MISA: u32      = 0x301
val CSR_ADDR_MIE: u32       = 0x304
val CSR_ADDR_MTVEC: u32     = 0x305
val CSR_ADDR_MSCRATCH: u32  = 0x340
val CSR_ADDR_MEPC: u32      = 0x341
val CSR_ADDR_MCAUSE: u32    = 0x342
val CSR_ADDR_MTVAL: u32     = 0x343
val CSR_ADDR_MIP: u32       = 0x344
val CSR_ADDR_MCYCLE: u32    = 0xB00
val CSR_ADDR_MCYCLEH: u32   = 0xB80   # RV32 only
val CSR_ADDR_MINSTRET: u32  = 0xB02
val CSR_ADDR_MINSTRETH: u32 = 0xB82   # RV32 only
val CSR_ADDR_MEDELEG: u32   = 0x302
val CSR_ADDR_MIDELEG: u32   = 0x303
val CSR_ADDR_MHARTID: u32   = 0xF14

# S-mode CSR addresses
val CSR_ADDR_SSTATUS: u32  = 0x100
val CSR_ADDR_SIE: u32      = 0x104
val CSR_ADDR_STVEC: u32    = 0x105
val CSR_ADDR_SSCRATCH: u32 = 0x140
val CSR_ADDR_SEPC: u32     = 0x141
val CSR_ADDR_SCAUSE: u32   = 0x142
val CSR_ADDR_STVAL: u32    = 0x143
val CSR_ADDR_SIP: u32      = 0x144
val CSR_ADDR_SATP: u32     = 0x180

# ============================================================================
# MSTATUS Bit Masks (values depend on XLEN)
# ============================================================================

fn mstatus_mie_mask(xlen: u32) -> i64:
    """MSTATUS MIE mask (bit 3)."""
    if xlen == 32:
        return 0x00000008 as i64
    else:
        return 0x00000008 as i64

fn mstatus_mpie_mask(xlen: u32) -> i64:
    """MSTATUS MPIE mask (bit 7)."""
    if xlen == 32:
        return 0x00000080 as i64
    else:
        return 0x00000080 as i64

fn mstatus_mpp_mask(xlen: u32) -> i64:
    """MSTATUS MPP mask (bits [12:11])."""
    if xlen == 32:
        return 0x00001800 as i64
    else:
        return 0x00001800 as i64

fn mpp_m_mode(xlen: u32) -> i64:
    """MPP = M-mode (0b11)."""
    if xlen == 32:
        return 0x00001800 as i64
    else:
        return 0x00001800 as i64

# ============================================================================
# MIE / MIP Bit Masks
# ============================================================================

val MIP_MSIP_MASK: i64 = 0x00000008   # bit 3 — Machine Software Interrupt
val MIP_MTIP_MASK: i64 = 0x00000080   # bit 7 — Machine Timer Interrupt
val MIP_MEIP_MASK: i64 = 0x00000800   # bit 11 — Machine External Interrupt

# ============================================================================
# SSTATUS Bit Masks
# ============================================================================

fn sstatus_sie_mask(xlen: u32) -> i64:
    """SSTATUS SIE mask (bit 1)."""
    0x00000002 as i64

fn sstatus_spie_mask(xlen: u32) -> i64:
    """SSTATUS SPIE mask (bit 5)."""
    0x00000020 as i64

fn sstatus_spp_mask(xlen: u32) -> i64:
    """SSTATUS SPP mask (bit 8)."""
    0x00000100 as i64

fn sstatus_sum_mask(xlen: u32) -> i64:
    """SSTATUS SUM mask (bit 18)."""
    0x00040000 as i64

fn sstatus_mxr_mask(xlen: u32) -> i64:
    """SSTATUS MXR mask (bit 19)."""
    0x00080000 as i64

fn sstatus_writable(xlen: u32) -> i64:
    """Combined writable mask for SSTATUS: SIE | SPIE | SPP | SUM | MXR."""
    0x000C0122 as i64

# ============================================================================
# SIE / SIP Bit Masks
# ============================================================================

val SIP_SSIP_MASK: i64 = 0x00000002   # bit 1 — Supervisor Software Interrupt
val SIP_STIP_MASK: i64 = 0x00000020   # bit 5 — Supervisor Timer Interrupt
val SIP_SEIP_MASK: i64 = 0x00000200   # bit 9 — Supervisor External Interrupt

# ============================================================================
# SATP Constants (RV64)
# ============================================================================

val SATP_MODE_BARE_64: i64 = 0
val SATP_MODE_SV39_64: i64 = 8
val SATP_MODE_SV48_64: i64 = 9

val SATP_PPN_MASK_64: i64  = 0x00000FFFFFFFFFFF
val SATP_ASID_MASK_64: i64 = 0x0FFFF00000000000

# ============================================================================
# CSR funct3 encodings (from SYSTEM instruction)
# ============================================================================

val FUNCT3_CSRRW: u32  = 0x1
val FUNCT3_CSRRS: u32  = 0x2
val FUNCT3_CSRRC: u32  = 0x3
val FUNCT3_CSRRWI: u32 = 0x5
val FUNCT3_CSRRSI: u32 = 0x6
val FUNCT3_CSRRCI: u32 = 0x7

# ============================================================================
# CSR constant exports for backward compatibility
# ============================================================================

val MSTATUS_MIE_BIT: u32  = 3
val MSTATUS_MPIE_BIT: u32 = 7
val MSTATUS_MPP_LO_BIT: u32 = 11

val SSTATUS_SIE_BIT: u32  = 1
val SSTATUS_SPIE_BIT: u32 = 5
val SSTATUS_SPP_BIT: u32  = 8

