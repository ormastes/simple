# ============================================================================
# RISC-V RTL ALU — XLEN-Parameterized Arithmetic/Logic Unit
# ============================================================================
#
# Unified ALU supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# Pure functions only (combinational logic).
#
# Operations: ADD, SUB, SLL, SLT, SLTU, XOR, SRL, SRA, OR, AND, PASS_B
# RV64 W-suffix:   ADDW, SUBW, SLLW, SRLW, SRAW (operate on low 32 bits, sign-extend)
# ============================================================================

use std.hardware.riscv_rtl.common.pkg.{ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU}
use std.hardware.riscv_rtl.common.pkg.{ALU_XOR, ALU_SRL, ALU_SRA, ALU_OR, ALU_AND}
use std.hardware.riscv_rtl.common.pkg.ALU_PASS_B
use std.hardware.riscv_rtl.common.pkg.{ALU_ADDW, ALU_SUBW, ALU_SLLW, ALU_SRLW, ALU_SRAW}

# ============================================================================
# ALU result bundle (parameterized by scalar type)
# ============================================================================

struct AluResult:
    """Combinational ALU output signals."""
    result: i64     # ALU result (i64 for both RV32 and RV64; RV32 uses lower 32 bits)
    zero: bool      # true when result == 0

# ============================================================================
# Signed comparison helper for i64
# ============================================================================

fn i64_signed_lt(a: i64, b: i64) -> bool:
    """Signed less-than for i64 values."""
    a < b

# ============================================================================
# Logical right shift helper for i64
# ============================================================================

fn i64_logical_srl(value: i64, shamt: i64) -> i64:
    """Logical right shift: fills vacated bits with zero.
    For i64 where >> may be arithmetic, mask off sign-extended bits."""
    if shamt == 0:
        return value
    if shamt >= 64:
        return 0
    val shifted = value >> shamt
    val mask_bits = 64 - shamt
    if mask_bits >= 64:
        return shifted
    val mask = (1 << mask_bits) - 1
    shifted & mask

# ============================================================================
# Arithmetic right shift helper for i64
# ============================================================================

fn i64_sra(value: i64, shamt: i64) -> i64:
    """Arithmetic right shift: replicates sign bit into vacated positions."""
    if shamt == 0:
        return value
    if shamt >= 64:
        if value < 0:
            return -1
        else:
            return 0
    value >> shamt

# ============================================================================
# Sign-extend 32-bit result to 64 bits (for W-suffix ops)
# ============================================================================

fn sign_extend_32_to_64(value: i64) -> i64:
    """Sign-extend bit 31 of a 32-bit value into bits [63:32]."""
    val low32 = value & 0xFFFFFFFF
    val sign_bit = low32 & 0x80000000
    if sign_bit != 0:
        low32 | 0xFFFFFFFF00000000
    else:
        low32

# ============================================================================
# ALU compute — unified for RV32 and RV64
# ============================================================================
#

fn alu_compute(op_a: i64, op_b: i64, alu_op: i64, xlen: u32) -> AluResult:
    """Evaluate the ALU operation on op_a and op_b.
    xlen selects 32-bit or 64-bit behavior."""

    # Shift amount: lower 5 bits for RV32, lower 6 bits for RV64
    val shamt = op_b & ((1 << xlen) - 1)
    val shamt_w = op_b & 0x1F   # W-suffix ops always use 5 bits

    var res: i64 = 0

    if alu_op == ALU_ADD:
        res = op_a + op_b

    else if alu_op == ALU_SUB:
        res = op_a - op_b

    else if alu_op == ALU_SLL:
        res = op_a << shamt

    else if alu_op == ALU_SLT:
        if i64_signed_lt(op_a, op_b):
            res = 1
        else:
            res = 0

    else if alu_op == ALU_SLTU:
        # Unsigned comparison via XOR-flip trick
        val flip: i64 = 0x8000000000000000
        val fa = op_a ^ flip
        val fb = op_b ^ flip
        if fa < fb:
            res = 1
        else:
            res = 0

    else if alu_op == ALU_XOR:
        res = op_a ^ op_b

    else if alu_op == ALU_SRL:
        res = i64_logical_srl(op_a, shamt)

    else if alu_op == ALU_SRA:
        res = i64_sra(op_a, shamt)

    else if alu_op == ALU_OR:
        res = op_a | op_b

    else if alu_op == ALU_AND:
        res = op_a & op_b

    else if alu_op == ALU_PASS_B:
        res = op_b

    # W-suffix operations (RV64 only): operate on low 32 bits, sign-extend result
    else if alu_op == ALU_ADDW:
        val sum = (op_a + op_b) & 0xFFFFFFFF
        res = sign_extend_32_to_64(sum)

    else if alu_op == ALU_SUBW:
        val diff = (op_a - op_b) & 0xFFFFFFFF
        res = sign_extend_32_to_64(diff)

    else if alu_op == ALU_SLLW:
        val shifted = (op_a << shamt_w) & 0xFFFFFFFF
        res = sign_extend_32_to_64(shifted)

    else if alu_op == ALU_SRLW:
        val low32 = op_a & 0xFFFFFFFF
        val shifted = i64_logical_srl(low32, shamt_w)
        res = sign_extend_32_to_64(shifted)

    else if alu_op == ALU_SRAW:
        val low32 = op_a & 0xFFFFFFFF
        val sign_bit = low32 & 0x80000000
        var sval = low32
        if sign_bit != 0:
            sval = low32 | 0xFFFFFFFF00000000
        val shifted = i64_sra(sval, shamt_w)
        res = sign_extend_32_to_64(shifted)

    else:
        # Default: pass B
        res = op_b

    AluResult(result: res, zero: res == 0)

# ============================================================================
# RV32-compatible wrapper (u32 inputs/outputs)
# ============================================================================

struct AluResult32:
    result: u32
    zero: bool

fn alu32_compute(op_a: u32, op_b: u32, alu_op: i64) -> AluResult32:
    """RV32 ALU compute with u32 interface."""
    val res = alu_compute(op_a as i64, op_b as i64, alu_op, 32)
    AluResult32(result: res.result as u32, zero: res.zero)

# ============================================================================
# RV64-compatible wrapper (i64 inputs/outputs)
# ============================================================================

struct AluResult64:
    result: i64
    zero: bool

fn alu64_compute(op_a: i64, op_b: i64, alu_op: i64) -> AluResult64:
    """RV64 ALU compute with i64 interface."""
    val res = alu_compute(op_a, op_b, alu_op, 64)
    AluResult64(result: res.result, zero: res.zero)

# ============================================================================
# Signed comparison helpers for branch evaluation
# ============================================================================

fn u32_signed_lt(a: u32, b: u32) -> bool:
    """Signed less-than for u32 values (two's complement)."""
    val flip: u32 = 0x80000000
    val fa = a ^ flip
    val fb = b ^ flip
    fa < fb

fn u32_signed_ge(a: u32, b: u32) -> bool:
    """Signed greater-than-or-equal for u32."""
    not u32_signed_lt(a, b)

fn i64_signed_ge(a: i64, b: i64) -> bool:
    """Signed greater-than-or-equal for i64."""
    not i64_signed_lt(a, b)

fn i64_unsigned_lt(a: i64, b: i64) -> bool:
    """Unsigned less-than for i64 (two's complement)."""
    val flip: i64 = 0x8000000000000000
    val fa = a ^ flip
    val fb = b ^ flip
    fa < fb

fn i64_unsigned_ge(a: i64, b: i64) -> bool:
    """Unsigned greater-than-or-equal for i64."""
    not i64_unsigned_lt(a, b)

# ============================================================================
# Exports
# ============================================================================

export AluResult, alu_compute
export AluResult32, alu32_compute
export AluResult64, alu64_compute
export i64_signed_lt, i64_signed_ge, i64_unsigned_lt, i64_unsigned_ge
export u32_signed_lt, u32_signed_ge
export i64_logical_srl, i64_sra, sign_extend_32_to_64
