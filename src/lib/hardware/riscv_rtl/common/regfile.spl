# ============================================================================
# RISC-V RTL Register File — XLEN-Parameterized 2R1W, 32 x XLEN
# ============================================================================
#
# Unified register file supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# x0 is hardwired to zero.
# Combinational reads (async), clocked writes (sync).
# Includes direct a0/a1 read ports for semihosting.
#
# Initial values: x2 (sp) = top of 4 KB DMEM.
# ============================================================================

# ============================================================================
# Initial SP values
# ============================================================================

val INIT_SP_32: u32 = 0x00000FFC   # Top of 4 KB data memory (RV32)
val INIT_SP_64: i64 = 0x0000000000000FFC   # Top of 4 KB data memory (RV64)

# ============================================================================
# Register file structs (parameterized by scalar type)
# ============================================================================

struct RegFile:
    """32 x XLEN-bit integer register file (using i64 for both RV32 and RV64)."""
    regs: [i64]

struct RegFile32:
    """32 x 32-bit integer register file (RV32-specific interface)."""
    regs: [u32]

struct RegFile64:
    """32 x 64-bit integer register file (RV64-specific interface)."""
    regs: [i64]

# ============================================================================
# Read result bundles
# ============================================================================

struct RegReadResult:
    """Combinational read port outputs (i64 backend)."""
    rs1_data: i64
    rs2_data: i64
    a0_val: i64    # Direct read of x10 (a0) for semihosting
    a1_val: i64    # Direct read of x11 (a1) for semihosting

struct RegReadResult32:
    """RV32 combinational read port outputs."""
    rs1_data: u32
    rs2_data: u32
    a0_val: u32
    a1_val: u32

struct RegReadResult64:
    """RV64 combinational read port outputs."""
    rs1_data: i64
    rs2_data: i64
    a0_val: i64
    a1_val: i64

# ============================================================================
# Register file creation
# ============================================================================

fn regfile_create(xlen: u32) -> RegFile:
    """Create a register file with initial values.
    x0 = 0 (hardwired), x2 (sp) = INIT_SP, all others = 0."""
    var regs: [i64] = []
    var i = 0
    while i < 32:
        regs = regs + [0]
        i = i + 1
    var rf = RegFile(regs: regs)
    if xlen == 32:
        rf.regs[2] = INIT_SP_32 as i64
    else:
        rf.regs[2] = INIT_SP_64
    rf

fn regfile32_create() -> RegFile32:
    """Create RV32 register file."""
    var regs: [u32] = []
    var i = 0
    while i < 32:
        regs = regs + [0]
        i = i + 1
    var rf = RegFile32(regs: regs)
    rf.regs[2] = INIT_SP_32
    rf

fn regfile64_create() -> RegFile64:
    """Create RV64 register file."""
    var regs: [i64] = []
    var i = 0
    while i < 32:
        regs = regs + [0]
        i = i + 1
    var rf = RegFile64(regs: regs)
    rf.regs[2] = INIT_SP_64
    rf

# ============================================================================
# Combinational read (async)
# ============================================================================

fn regfile_read(rf: RegFile, rs1_addr: u32, rs2_addr: u32) -> RegReadResult:
    """Read two registers plus a0/a1 direct ports.
    x0 always reads as zero (hardwired)."""
    var rs1_data: i64 = 0
    if rs1_addr != 0:
        rs1_data = rf.regs[rs1_addr]

    var rs2_data: i64 = 0
    if rs2_addr != 0:
        rs2_data = rf.regs[rs2_addr]

    RegReadResult(
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rf.regs[10],
        a1_val: rf.regs[11]
    )

fn regfile32_read(rf: RegFile32, rs1_addr: u32, rs2_addr: u32) -> RegReadResult32:
    """RV32 register file read."""
    var rs1_data: u32 = 0
    if rs1_addr != 0:
        rs1_data = rf.regs[rs1_addr]

    var rs2_data: u32 = 0
    if rs2_addr != 0:
        rs2_data = rf.regs[rs2_addr]

    RegReadResult32(
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rf.regs[10],
        a1_val: rf.regs[11]
    )

fn regfile64_read(rf: RegFile64, rs1_addr: u32, rs2_addr: u32) -> RegReadResult64:
    """RV64 register file read."""
    var rs1_data: i64 = 0
    if rs1_addr != 0:
        rs1_data = rf.regs[rs1_addr]

    var rs2_data: i64 = 0
    if rs2_addr != 0:
        rs2_data = rf.regs[rs2_addr]

    RegReadResult64(
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rf.regs[10],
        a1_val: rf.regs[11]
    )

# ============================================================================
# Clocked write (sync)
# ============================================================================

fn regfile_write(rf: RegFile, rd_addr: u32, rd_data: i64, we: bool) -> RegFile:
    """Write to register file. Writes to x0 are silently discarded.
    Returns the updated register file (functional style for RTL)."""
    var new_rf = rf
    if we and rd_addr != 0:
        new_rf.regs[rd_addr] = rd_data
    new_rf

fn regfile32_write(rf: RegFile32, rd_addr: u32, rd_data: u32, we: bool) -> RegFile32:
    """RV32 register file write."""
    var new_rf = rf
    if we and rd_addr != 0:
        new_rf.regs[rd_addr] = rd_data
    new_rf

fn regfile64_write(rf: RegFile64, rd_addr: u32, rd_data: i64, we: bool) -> RegFile64:
    """RV64 register file write."""
    var new_rf = rf
    if we and rd_addr != 0:
        new_rf.regs[rd_addr] = rd_data
    new_rf

# ============================================================================
# Exports
# ============================================================================

export RegFile, regfile_create, regfile_read, regfile_write
export RegFile32, regfile32_create, regfile32_read, regfile32_write
export RegFile64, regfile64_create, regfile64_read, regfile64_write
export RegReadResult, RegReadResult32, RegReadResult64
export INIT_SP_32, INIT_SP_64
