# ============================================================================
# RISC-V RTL Decoder — XLEN-Parameterized Instruction Decoder
# ============================================================================
#
# Unified decoder supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# Pure functions only (combinational).
#
# Extracts all fields from a 32-bit instruction, selects ALU op, generates
# control signals, and sign-extends immediates.
# ============================================================================

use std.hardware.riscv_rtl.common.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.riscv_rtl.common.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM}
use std.hardware.riscv_rtl.common.pkg.{OP_OP_IMM_32, OP_OP_32, OP_AMO}
use std.hardware.riscv_rtl.common.pkg.{ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU}
use std.hardware.riscv_rtl.common.pkg.{ALU_XOR, ALU_SRL, ALU_SRA, ALU_OR, ALU_AND}
use std.hardware.riscv_rtl.common.pkg.ALU_PASS_B
use std.hardware.riscv_rtl.common.pkg.{ALU_ADDW, ALU_SUBW, ALU_SLLW, ALU_SRLW, ALU_SRAW}

# ============================================================================
# Decode result — unified for RV32 and RV64
# ============================================================================

struct DecodeResult:
    """All outputs from the combinational decoder."""
    opcode: u32       # bits [6:0]
    rd: u32           # bits [11:7]
    rs1: u32          # bits [19:15]
    rs2: u32          # bits [24:20]
    funct3: u32       # bits [14:12]
    funct7: u32       # bits [31:25]
    imm: i64          # Sign-extended immediate (64-bit for both RV32 and RV64)
    alu_op: i64       # ALU operation code
    reg_write: bool   # Write-back to register file
    mem_read: bool    # Read from data memory
    mem_write: bool   # Write to data memory
    mem_to_reg: bool  # Load result goes to rd
    alu_src: bool     # true = ALU op_b from immediate; false = from rs2
    branch: bool      # Conditional branch instruction
    jump: bool        # JAL or JALR
    is_word_op: bool  # W-suffix instruction (RV64 only)
    is_amo: bool      # Atomic memory operation (RV64 only)
    is_muldiv: bool   # M extension multiply/divide (RV64 only)
    is_mret: bool     # Machine Return
    is_sret: bool     # Supervisor Return (RV64 only)
    is_sfence_vma: bool  # SFENCE.VMA (RV64 only)

# ============================================================================
# Sign-extension helpers
# ============================================================================

fn sign_extend(value: i64, width: u32) -> i64:
    """Sign-extend a value of the given bit width to 64 bits."""
    val sign_bit: i64 = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill: i64 = -1 << width
        value | fill
    else:
        value

# ============================================================================
# Immediate extraction (all produce i64 sign-extended to 64 bits)
# ============================================================================

fn extract_i_imm(insn: u32) -> i64:
    """I-type immediate: bits [31:20], sign-extended to 64 bits."""
    val raw: i64 = ((insn >> 20) & 0xFFF) as i64
    sign_extend(raw, 12)

fn extract_s_imm(insn: u32) -> i64:
    """S-type immediate: [31:25] | [11:7], sign-extended to 64 bits."""
    val hi = (insn >> 25) & 0x7F
    val lo = (insn >> 7) & 0x1F
    val raw: i64 = ((hi << 5) | lo) as i64
    sign_extend(raw, 12)

fn extract_b_imm(insn: u32) -> i64:
    """B-type immediate: 13-bit, sign-extended, bit[0]=0."""
    val bit12 = (insn >> 31) & 0x1
    val bit10_5 = (insn >> 25) & 0x3F
    val bit4_1 = (insn >> 8) & 0xF
    val bit11 = (insn >> 7) & 0x1
    val raw: i64 = ((bit12 << 12) | (bit11 << 11) | (bit10_5 << 5) | (bit4_1 << 1)) as i64
    sign_extend(raw, 13)

fn extract_u_imm(insn: u32) -> i64:
    """U-type immediate: bits [31:12] shifted left by 12, sign-extended to 64."""
    val raw32 = insn & 0xFFFFF000
    val raw: i64 = raw32 as i64
    sign_extend(raw, 32)

fn extract_j_imm(insn: u32) -> i64:
    """J-type immediate: 21-bit, sign-extended, bit[0]=0."""
    val bit20 = (insn >> 31) & 0x1
    val bit10_1 = (insn >> 21) & 0x3FF
    val bit11 = (insn >> 20) & 0x1
    val bit19_12 = (insn >> 12) & 0xFF
    val raw: i64 = ((bit20 << 20) | (bit19_12 << 12) | (bit11 << 11) | (bit10_1 << 1)) as i64
    sign_extend(raw, 21)

# ============================================================================
# ALU operation selection
# ============================================================================

fn select_alu_op(opcode: u32, funct3: u32, funct7: u32) -> i64:
    """Select ALU operation based on opcode, funct3, and funct7."""

    if opcode == OP_REG:
        # Check for M extension (funct7 == 0x01)
        if funct7 == 0x01:
            return ALU_ADD   # Placeholder; M extension handled separately

        if funct3 == 0x0:
            if (funct7 & 0x20) != 0:
                return ALU_SUB
            else:
                return ALU_ADD
        if funct3 == 0x1: return ALU_SLL
        if funct3 == 0x2: return ALU_SLT
        if funct3 == 0x3: return ALU_SLTU
        if funct3 == 0x4: return ALU_XOR
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRA
            else:
                return ALU_SRL
        if funct3 == 0x6: return ALU_OR
        if funct3 == 0x7: return ALU_AND
        return ALU_ADD

    else if opcode == OP_IMMED:
        if funct3 == 0x0: return ALU_ADD
        if funct3 == 0x1: return ALU_SLL
        if funct3 == 0x2: return ALU_SLT
        if funct3 == 0x3: return ALU_SLTU
        if funct3 == 0x4: return ALU_XOR
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRA
            else:
                return ALU_SRL
        if funct3 == 0x6: return ALU_OR
        if funct3 == 0x7: return ALU_AND
        return ALU_ADD

    else if opcode == OP_OP_32:
        # W-suffix register-register (RV64 only)
        if funct7 == 0x01:
            return ALU_ADDW   # M extension W-suffix placeholder

        if funct3 == 0x0:
            if (funct7 & 0x20) != 0:
                return ALU_SUBW
            else:
                return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    else if opcode == OP_OP_IMM_32:
        # W-suffix register-immediate (RV64 only)
        if funct3 == 0x0: return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    else if opcode == OP_LUI:
        return ALU_PASS_B

    # Default: ADD
    ALU_ADD

# ============================================================================
# Main decode function
# ============================================================================

fn decode_instruction(instruction: u32) -> DecodeResult:
    """Decode a 32-bit RISC-V instruction into all control and data signals."""

    # Field extraction
    val op = instruction & 0x7F
    val rd = (instruction >> 7) & 0x1F
    val f3 = (instruction >> 12) & 0x7
    val rs1 = (instruction >> 15) & 0x1F
    val rs2 = (instruction >> 20) & 0x1F
    val f7 = (instruction >> 25) & 0x7F

    # Immediate extraction based on opcode format
    var imm: i64 = 0
    if op == OP_IMMED or op == OP_LOAD or op == OP_JALR or op == OP_OP_IMM_32:
        imm = extract_i_imm(instruction)
    else if op == OP_STORE:
        imm = extract_s_imm(instruction)
    else if op == OP_BRANCH:
        imm = extract_b_imm(instruction)
    else if op == OP_LUI or op == OP_AUIPC:
        imm = extract_u_imm(instruction)
    else if op == OP_JAL:
        imm = extract_j_imm(instruction)

    # ALU operation
    val alu_op = select_alu_op(op, f3, f7)

    # Control signals
    val is_word = op == OP_OP_IMM_32 or op == OP_OP_32
    val is_amo = op == OP_AMO
    val is_muldiv = (op == OP_REG or op == OP_OP_32) and f7 == 0x01
    val is_mret = instruction == 0x30200073u32
    val is_sret = instruction == 0x10200073u32
    val is_sfence_vma = op == OP_SYSTEM and f7 == 0x09 and f3 == 0x0

    val reg_w = (op == OP_REG or op == OP_IMMED or op == OP_LOAD or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32 or op == OP_OP_32 or op == OP_AMO)
    val m_read = op == OP_LOAD
    val m_write = op == OP_STORE
    val m_to_reg = op == OP_LOAD
    val a_src = (op == OP_IMMED or op == OP_LOAD or op == OP_STORE or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32)
    val br = op == OP_BRANCH
    val jmp = op == OP_JAL or op == OP_JALR

    DecodeResult(
        opcode: op,
        rd: rd,
        rs1: rs1,
        rs2: rs2,
        funct3: f3,
        funct7: f7,
        imm: imm,
        alu_op: alu_op,
        reg_write: reg_w,
        mem_read: m_read,
        mem_write: m_write,
        mem_to_reg: m_to_reg,
        alu_src: a_src,
        branch: br,
        jump: jmp,
        is_word_op: is_word,
        is_amo: is_amo,
        is_muldiv: is_muldiv,
        is_mret: is_mret,
        is_sret: is_sret,
        is_sfence_vma: is_sfence_vma
    )

# ============================================================================
# RV32-compatible aliases (u32 immediate)
# ============================================================================

struct DecodeResult32:
    opcode: u32
    rd: u32
    rs1: u32
    rs2: u32
    funct3: u32
    funct7: u32
    imm: u32          # u32 for RV32
    alu_op: i64
    reg_write: bool
    mem_read: bool
    mem_write: bool
    mem_to_reg: bool
    alu_src: bool
    branch: bool
    jump: bool
    is_word_op: bool
    is_amo: bool
    is_muldiv: bool
    is_mret: bool
    is_sret: bool
    is_sfence_vma: bool

fn decode_instruction32(instruction: u32) -> DecodeResult32:
    """RV32 decode with u32 immediate output."""
    val dec = decode_instruction(instruction)
    DecodeResult32(
        opcode: dec.opcode,
        rd: dec.rd,
        rs1: dec.rs1,
        rs2: dec.rs2,
        funct3: dec.funct3,
        funct7: dec.funct7,
        imm: dec.imm as u32,
        alu_op: dec.alu_op,
        reg_write: dec.reg_write,
        mem_read: dec.mem_read,
        mem_write: dec.mem_write,
        mem_to_reg: dec.mem_to_reg,
        alu_src: dec.alu_src,
        branch: dec.branch,
        jump: dec.jump,
        is_word_op: dec.is_word_op,
        is_amo: dec.is_amo,
        is_muldiv: dec.is_muldiv,
        is_mret: dec.is_mret,
        is_sret: dec.is_sret,
        is_sfence_vma: dec.is_sfence_vma
    )

# ============================================================================
# Legacy RV32 immediate extraction aliases (for backward compatibility)
# ============================================================================

fn extract_i_imm_u32(insn: u32) -> u32:
    """I-type immediate: bits [31:20], sign-extended to 32 bits (RV32)."""
    val raw = (insn >> 20) & 0xFFF
    val sign_bit = 1 << 11
    if (raw & sign_bit) != 0:
        raw | 0xFFFFF000
    else:
        raw

fn extract_s_imm_u32(insn: u32) -> u32:
    """S-type immediate: [31:25] | [11:7], sign-extended to 32 bits (RV32)."""
    val hi = (insn >> 25) & 0x7F
    val lo = (insn >> 7) & 0x1F
    val raw = (hi << 5) | lo
    val sign_bit = 1 << 11
    if (raw & sign_bit) != 0:
        raw | 0xFFFFF000
    else:
        raw

fn extract_b_imm_u32(insn: u32) -> u32:
    """B-type immediate: 13-bit, sign-extended to 32 bits (RV32)."""
    val bit12 = (insn >> 31) & 0x1
    val bit10_5 = (insn >> 25) & 0x3F
    val bit4_1 = (insn >> 8) & 0xF
    val bit11 = (insn >> 7) & 0x1
    val raw = (bit12 << 12) | (bit11 << 11) | (bit10_5 << 5) | (bit4_1 << 1)
    val sign_bit = 1 << 12
    if (raw & sign_bit) != 0:
        raw | 0xFFFFE000
    else:
        raw

fn extract_u_imm_u32(insn: u32) -> u32:
    """U-type immediate: bits [31:12] shifted left by 12 (RV32)."""
    insn & 0xFFFFF000

fn extract_j_imm_u32(insn: u32) -> u32:
    """J-type immediate: 21-bit, sign-extended to 32 bits (RV32)."""
    val bit20 = (insn >> 31) & 0x1
    val bit10_1 = (insn >> 21) & 0x3FF
    val bit11 = (insn >> 20) & 0x1
    val bit19_12 = (insn >> 12) & 0xFF
    val raw = (bit20 << 20) | (bit19_12 << 12) | (bit11 << 11) | (bit10_1 << 1)
    val sign_bit = 1 << 20
    if (raw & sign_bit) != 0:
        raw | 0xFFE00000
    else:
        raw

# ============================================================================
# Sign-extension helper for u32 (RV32 legacy)
# ============================================================================

fn sign_extend_u32(value: u32, width: u32) -> u32:
    """Sign-extend a value of the given bit width to 32 bits (RV32)."""
    val sign_bit = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill = 0xFFFFFFFF << width
        value | fill
    else:
        value

# ============================================================================
# ALU op selection for RV32 (legacy, without W-suffix)
# ============================================================================

fn select_alu_op32(opcode: u32, funct3: u32, funct7: u32) -> i64:
    """Select ALU operation for RV32 (no W-suffix ops)."""
    select_alu_op(opcode, funct3, funct7)

# ============================================================================
# Exports
# ============================================================================

export DecodeResult, decode_instruction
export DecodeResult32, decode_instruction32
export select_alu_op, select_alu_op32
export extract_i_imm, extract_s_imm, extract_b_imm, extract_u_imm, extract_j_imm
export extract_i_imm_u32, extract_s_imm_u32, extract_b_imm_u32, extract_u_imm_u32, extract_j_imm_u32
export sign_extend, sign_extend_u32
