# ============================================================================
# RISC-V RTL CSR S-Mode Extension — XLEN-Parameterized Supervisor CSRs
# ============================================================================
#
# Unified S-mode CSR extension supporting both RV32 (XLEN=32) and RV64 (XLEN=64).
# Extends the M-mode CSR file with supervisor-mode registers required for
# virtual memory (Sv32/Sv39/Sv48) and S-mode trap delegation.
#
# Supported CSRs:
#   S-mode Trap Setup:    sstatus, sie, stvec
#   S-mode Trap Handling: sscratch, sepc, scause, stval, sip
#   S-mode VM:            satp
#   M-mode Delegation:    medeleg, mideleg (M-mode CSRs enabling S-mode traps)
# ============================================================================

use std.hardware.riscv_rtl.common.pkg.{CSR_ADDR_SSTATUS, CSR_ADDR_SIE, CSR_ADDR_STVEC}
use std.hardware.riscv_rtl.common.pkg.{CSR_ADDR_SSCRATCH, CSR_ADDR_SEPC, CSR_ADDR_SCAUSE}
use std.hardware.riscv_rtl.common.pkg.{CSR_ADDR_STVAL, CSR_ADDR_SIP, CSR_ADDR_SATP}
use std.hardware.riscv_rtl.common.pkg.{CSR_ADDR_MEDELEG, CSR_ADDR_MIDELEG}
use std.hardware.riscv_rtl.common.pkg.{sstatus_sie_mask, sstatus_spie_mask, sstatus_spp_mask}
use std.hardware.riscv_rtl.common.pkg.{sstatus_sum_mask, sstatus_mxr_mask, sstatus_writable}
use std.hardware.riscv_rtl.common.pkg.{SIP_SSIP_MASK, SIP_STIP_MASK, SIP_SEIP_MASK}
use std.hardware.riscv_rtl.common.pkg.{SATP_MODE_BARE_64, SATP_MODE_SV39_64, SATP_MODE_SV48_64}
use std.hardware.riscv_rtl.common.pkg.{SATP_PPN_MASK_64, SATP_ASID_MASK_64}

# ============================================================================
# S-mode CSR File Structs
# ============================================================================

struct CsrSMode:
    """Supervisor-mode CSR register file (i64 backend)."""
    sstatus: i64
    sie: i64
    stvec: i64
    sscratch: i64
    sepc: i64
    scause: i64
    stval: i64
    sip: i64
    satp: i64
    medeleg: i64
    mideleg: i64

struct CsrSMode32:
    """RV32 S-mode CSR register file."""
    sstatus: u32
    sie: u32
    stvec: u32
    sscratch: u32
    sepc: u32
    scause: u32
    stval: u32
    sip: u32
    satp: u32
    medeleg: u32
    mideleg: u32

struct CsrSMode64:
    """RV64 S-mode CSR register file."""
    sstatus: i64
    sie: i64
    stvec: i64
    sscratch: i64
    sepc: i64
    scause: i64
    stval: i64
    sip: i64
    satp: i64
    medeleg: i64
    mideleg: i64

# ============================================================================
# SSTATUS constants
# ============================================================================

val SSTATUS_SIE_BIT: u32  = 1
val SSTATUS_SPIE_BIT: u32 = 5
val SSTATUS_SPP_BIT: u32  = 8

# ============================================================================
# Create — initial S-mode CSR state
# ============================================================================

fn csr_s_create() -> CsrSMode:
    """Create initial S-mode CSR state. All registers start at zero."""
    CsrSMode(
        sstatus: 0,
        sie: 0,
        stvec: 0,
        sscratch: 0,
        sepc: 0,
        scause: 0,
        stval: 0,
        sip: 0,
        satp: 0,
        medeleg: 0,
        mideleg: 0
    )

fn csr_s32_create() -> CsrSMode32:
    """Create RV32 S-mode CSR state."""
    CsrSMode32(
        sstatus: 0,
        sie: 0,
        stvec: 0,
        sscratch: 0,
        sepc: 0,
        scause: 0,
        stval: 0,
        sip: 0,
        satp: 0,
        medeleg: 0,
        mideleg: 0
    )

fn csr_s64_create() -> CsrSMode64:
    """Create RV64 S-mode CSR state."""
    CsrSMode64(
        sstatus: 0,
        sie: 0,
        stvec: 0,
        sscratch: 0,
        sepc: 0,
        scause: 0,
        stval: 0,
        sip: 0,
        satp: 0,
        medeleg: 0,
        mideleg: 0
    )

# ============================================================================
# CSR Read
# ============================================================================

fn csr_s_read(smode: CsrSMode, addr: u32) -> i64:
    """Read an S-mode CSR by its 12-bit address."""
    if addr == CSR_ADDR_SSTATUS:
        return smode.sstatus
    if addr == CSR_ADDR_SIE:
        return smode.sie
    if addr == CSR_ADDR_STVEC:
        return smode.stvec
    if addr == CSR_ADDR_SSCRATCH:
        return smode.sscratch
    if addr == CSR_ADDR_SEPC:
        return smode.sepc
    if addr == CSR_ADDR_SCAUSE:
        return smode.scause
    if addr == CSR_ADDR_STVAL:
        return smode.stval
    if addr == CSR_ADDR_SIP:
        return smode.sip
    if addr == CSR_ADDR_SATP:
        return smode.satp
    if addr == CSR_ADDR_MEDELEG:
        return smode.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return smode.mideleg
    0

fn csr_s32_read(smode: CsrSMode32, addr: u32) -> u32:
    """RV32 S-mode CSR read."""
    if addr == CSR_ADDR_SSTATUS:
        return smode.sstatus
    if addr == CSR_ADDR_SIE:
        return smode.sie
    if addr == CSR_ADDR_STVEC:
        return smode.stvec
    if addr == CSR_ADDR_SSCRATCH:
        return smode.sscratch
    if addr == CSR_ADDR_SEPC:
        return smode.sepc
    if addr == CSR_ADDR_SCAUSE:
        return smode.scause
    if addr == CSR_ADDR_STVAL:
        return smode.stval
    if addr == CSR_ADDR_SIP:
        return smode.sip
    if addr == CSR_ADDR_SATP:
        return smode.satp
    if addr == CSR_ADDR_MEDELEG:
        return smode.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return smode.mideleg
    0

fn csr_s64_read(smode: CsrSMode64, addr: u32) -> i64:
    """RV64 S-mode CSR read."""
    if addr == CSR_ADDR_SSTATUS:
        return smode.sstatus
    if addr == CSR_ADDR_SIE:
        return smode.sie
    if addr == CSR_ADDR_STVEC:
        return smode.stvec
    if addr == CSR_ADDR_SSCRATCH:
        return smode.sscratch
    if addr == CSR_ADDR_SEPC:
        return smode.sepc
    if addr == CSR_ADDR_SCAUSE:
        return smode.scause
    if addr == CSR_ADDR_STVAL:
        return smode.stval
    if addr == CSR_ADDR_SIP:
        return smode.sip
    if addr == CSR_ADDR_SATP:
        return smode.satp
    if addr == CSR_ADDR_MEDELEG:
        return smode.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return smode.mideleg
    0

# ============================================================================
# CSR Write
# ============================================================================

fn csr_s_write(smode: CsrSMode, addr: u32, value: i64, xlen: u32) -> CsrSMode:
    """Write a value to an S-mode CSR."""
    var out = smode

    if addr == CSR_ADDR_SSTATUS:
        out.sstatus = value & sstatus_writable(xlen)

    else if addr == CSR_ADDR_SIE:
        out.sie = value

    else if addr == CSR_ADDR_STVEC:
        out.stvec = value

    else if addr == CSR_ADDR_SSCRATCH:
        out.sscratch = value

    else if addr == CSR_ADDR_SEPC:
        out.sepc = value & (-4)

    else if addr == CSR_ADDR_SCAUSE:
        out.scause = value

    else if addr == CSR_ADDR_STVAL:
        out.stval = value

    else if addr == CSR_ADDR_SIP:
        out.sip = (smode.sip & (SIP_STIP_MASK | SIP_SEIP_MASK)) | (value & SIP_SSIP_MASK)

    else if addr == CSR_ADDR_SATP:
        if xlen == 32:
            out.satp = value
        else:
            val mode = (value >> 60) & 0x0F
            if mode == SATP_MODE_BARE_64 or mode == SATP_MODE_SV39_64 or mode == SATP_MODE_SV48_64:
                out.satp = value

    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value

    else if addr == CSR_ADDR_MIDELEG:
        out.mideleg = value

    out

fn csr_s32_write(smode: CsrSMode32, addr: u32, value: u32) -> CsrSMode32:
    """RV32 S-mode CSR write."""
    var out = smode
    if addr == CSR_ADDR_SSTATUS:
        out.sstatus = value & 0x000C0122
    else if addr == CSR_ADDR_SIE:
        out.sie = value
    else if addr == CSR_ADDR_STVEC:
        out.stvec = value
    else if addr == CSR_ADDR_SSCRATCH:
        out.sscratch = value
    else if addr == CSR_ADDR_SEPC:
        out.sepc = value & 0xFFFFFFFC
    else if addr == CSR_ADDR_SCAUSE:
        out.scause = value
    else if addr == CSR_ADDR_STVAL:
        out.stval = value
    else if addr == CSR_ADDR_SIP:
        out.sip = (smode.sip & 0x220) | (value & 0x002)
    else if addr == CSR_ADDR_SATP:
        out.satp = value
    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value
    else if addr == CSR_ADDR_MIDELEG:
        out.mideleg = value
    out

fn csr_s64_write(smode: CsrSMode64, addr: u32, value: i64) -> CsrSMode64:
    """RV64 S-mode CSR write."""
    var out = smode
    if addr == CSR_ADDR_SSTATUS:
        out.sstatus = value & 0x000C0122
    else if addr == CSR_ADDR_SIE:
        out.sie = value
    else if addr == CSR_ADDR_STVEC:
        out.stvec = value
    else if addr == CSR_ADDR_SSCRATCH:
        out.scratch = value
    else if addr == CSR_ADDR_SEPC:
        out.sepc = value & (-2)
    else if addr == CSR_ADDR_SCAUSE:
        out.scause = value
    else if addr == CSR_ADDR_STVAL:
        out.stval = value
    else if addr == CSR_ADDR_SIP:
        out.sip = (smode.sip & (SIP_STIP_MASK | SIP_SEIP_MASK)) | (value & SIP_SSIP_MASK)
    else if addr == CSR_ADDR_SATP:
        val mode = (value >> 60) & 0x0F
        if mode == SATP_MODE_BARE_64 or mode == SATP_MODE_SV39_64 or mode == SATP_MODE_SV48_64:
            out.satp = value
    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value
    else if addr == CSR_ADDR_MIDELEG:
        out.mideleg = value
    out

# ============================================================================
# SATP helpers (RV64)
# ============================================================================

fn satp_extract_mode_64(satp: i64) -> i64:
    """Extract the MODE field from an RV64 SATP value."""
    (satp >> 60) & 0x0F

fn satp_extract_asid_64(satp: i64) -> i64:
    """Extract the ASID field from an RV64 SATP value."""
    (satp >> 44) & 0xFFFF

fn satp_extract_ppn_64(satp: i64) -> i64:
    """Extract the PPN field from an RV64 SATP value."""
    satp & SATP_PPN_MASK_64

fn satp_encode_64(mode: i64, asid: i64, ppn: i64) -> i64:
    """Encode MODE, ASID, and PPN into an RV64 SATP value."""
    (mode & 0x0F) << 60 | (asid & 0xFFFF) << 44 | (ppn & SATP_PPN_MASK_64)

fn csr_s64_satp_mode(smode: CsrSMode64) -> i64:
    satp_extract_mode_64(smode.satp)

fn csr_s64_satp_asid(smode: CsrSMode64) -> i64:
    satp_extract_asid_64(smode.satp)

fn csr_s64_satp_ppn(smode: CsrSMode64) -> i64:
    satp_extract_ppn_64(smode.satp)

fn csr_s64_is_vm_enabled(smode: CsrSMode64) -> bool:
    satp_extract_mode_64(smode.satp) != SATP_MODE_BARE_64

# ============================================================================
# Trap delegation check
# ============================================================================

fn csr_s_is_exception_delegated(smode: CsrSMode, cause: i64) -> bool:
    """Check if an exception cause is delegated to S-mode via medeleg."""
    if cause < 0 or cause >= 64:
        return false
    (smode.medeleg & (1 << cause)) != 0

fn csr_s_is_interrupt_delegated(smode: CsrSMode, cause: i64) -> bool:
    """Check if an interrupt cause is delegated to S-mode via mideleg."""
    if cause < 0 or cause >= 64:
        return false
    (smode.mideleg & (1 << cause)) != 0

fn csr_s64_is_exception_delegated(smode: CsrSMode64, cause: i64) -> bool:
    """RV64 exception delegation check."""
    if cause < 0 or cause >= 64:
        return false
    (smode.medeleg & (1 << cause)) != 0

fn csr_s64_is_interrupt_delegated(smode: CsrSMode64, cause: i64) -> bool:
    """RV64 interrupt delegation check."""
    if cause < 0 or cause >= 64:
        return false
    (smode.mideleg & (1 << cause)) != 0

# ============================================================================
# Spec-facing aliases
# ============================================================================

fn csr_s_init() -> CsrSMode:
    csr_s_create()

fn csr_s_init_32() -> CsrSMode32:
    csr_s32_create()

fn csr_s_init_64() -> CsrSMode64:
    csr_s64_create()

# ============================================================================
# Exports
# ============================================================================

export CsrSMode, csr_s_create, csr_s_read, csr_s_write
export CsrSMode32, csr_s32_create, csr_s32_read, csr_s32_write
export CsrSMode64, csr_s64_create, csr_s64_read, csr_s64_write
export csr_s_is_exception_delegated, csr_s_is_interrupt_delegated
export csr_s64_is_exception_delegated, csr_s64_is_interrupt_delegated
export csr_s64_satp_mode, csr_s64_satp_asid, csr_s64_satp_ppn, csr_s64_is_vm_enabled
export satp_encode_64, satp_extract_mode_64, satp_extract_asid_64, satp_extract_ppn_64
export csr_s_init, csr_s_init_32, csr_s_init_64
export SSTATUS_SIE_BIT, SSTATUS_SPIE_BIT, SSTATUS_SPP_BIT
export SSTATUS_SIE_MASK_64 = 0x00000002, SSTATUS_SPIE_MASK_64 = 0x00000020
export SSTATUS_SPP_MASK_64 = 0x00000100, SSTATUS_SUM_MASK_64 = 0x00040000
export SSTATUS_MXR_MASK_64 = 0x00080000, SSTATUS_WRITABLE_64 = 0x000C0122
export SIP_SSIP_MASK_64 = 0x00000002, SIP_STIP_MASK_64 = 0x00000020, SIP_SEIP_MASK_64 = 0x00000200
