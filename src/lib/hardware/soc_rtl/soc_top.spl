# ============================================================================
# SoC RTL Top-Level — Full RV32I System-on-Chip
# ============================================================================
#
# Wires together the RV32I core, CSR file, trap controller, register file,
# Wishbone interconnect, RAM, boot ROM, UART 16550, CLINT, and mailbox into
# a complete stalled, response-latched SoC.
#
# soc_tick() is THE main simulation entry point.  Each call = 1 clock cycle.
# Each request crosses Sv32 translation and PMP before this module routes its
# physical address to ROM, RAM, CLINT, UART, or mailbox. One response is
# latched for the following core cycle.
#
# VHDL synthesizable subset: u32, bool, [u32], structs only.
# ============================================================================

# -- Clocked core
use std.hardware.rv32i_rtl.core.{CoreState, core_reset, core32_cycle}
use std.hardware.rv32i_rtl.csr.csr_update_mip
use std.hardware.rv32i_rtl.mmu_sv32.ACCESS_FETCH
use std.hardware.rv32i_rtl.memory_access.memory32_reset

# -- Peripherals
use std.hardware.soc_rtl.bootrom.{bootrom_read, BOOTROM_BASE}
use std.hardware.soc_rtl.uart16550.{Uart16550State, uart_create, uart_mmio_read, uart_mmio_read_update, uart_mmio_write, uart_tick}
use std.hardware.soc_rtl.clint.{ClintState, clint_create, clint_mmio_read, clint_mmio_write, clint_tick}
use std.hardware.soc_rtl.ram.{RamState, ram_create, ram_read, ram_write}
use std.hardware.soc_rtl.mailbox.{MailboxState, mailbox_create, mailbox_mmio_read, mailbox_mmio_write}

# -- Wishbone interconnect
use std.hardware.soc_rtl.wb_interconnect.{wb_decode_address, wb_route_read, wb_route_write}
use std.hardware.soc_rtl.wb_interconnect.{WB_SLAVE_ROM, WB_SLAVE_CLINT, WB_SLAVE_UART}
use std.hardware.soc_rtl.wb_interconnect.{WB_SLAVE_RAM, WB_SLAVE_MAILBOX}
use std.hardware.soc_rtl.wb_interconnect.WB_SLAVE_UNMAPPED
use std.hardware.soc_rtl.wb_interconnect.{RAM_BASE, CLINT_BASE, UART_BASE, MB_BASE}

# ============================================================================
# SoC State
# ============================================================================

struct SocState:
    """Full SoC sequential state."""
    core: CoreState
    uart: Uart16550State
    clint: ClintState
    mailbox: MailboxState
    ram: RamState
    response_valid: bool
    response_error: bool
    response_data: u32
    halt_pending: bool

# ============================================================================
# SoC External Ports
# ============================================================================

struct SocPorts:
    """External pin-level signals from the SoC."""
    uart_tx: bool         # UART TX line
    halted: bool          # CPU halted
    char_out: u32         # Mailbox PUTC character
    char_valid: bool      # Mailbox PUTC valid

# ============================================================================
# SoC Tick Result
# ============================================================================

struct SocTickResult:
    """Result of one SoC clock cycle."""
    state: SocState       # Updated SoC state
    ports: SocPorts       # External port values this cycle

# ============================================================================
# Create / Reset
# ============================================================================

fn soc_create(ram_size_words: u32) -> SocState:
    """Create and initialize the full SoC.  PC starts at boot ROM (0x1000)."""
    SocState(
        core: core_reset(BOOTROM_BASE),
        uart: uart_create(),
        clint: clint_create(),
        mailbox: mailbox_create(),
        ram: ram_create(ram_size_words),
        response_valid: false,
        response_error: false,
        response_data: 0,
        halt_pending: false
    )

fn soc_reset(ram_size_words: u32) -> SocState:
    """Reset the SoC — alias for soc_create."""
    soc_create(ram_size_words)

# ============================================================================
# Instruction Fetch — route through Wishbone address map
# ============================================================================

fn soc_fetch_instruction(state: SocState, pc: u32) -> u32:
    """Fetch a 32-bit instruction word at the given PC.
    Routes through the Wishbone address decoder to ROM or RAM."""
    val slave_idx = wb_decode_address(pc)
    if slave_idx == WB_SLAVE_ROM:
        return bootrom_read(pc)
    if slave_idx == WB_SLAVE_RAM:
        val ram_offset = pc - RAM_BASE
        return ram_read(state.ram, ram_offset)
    # Fetching from unmapped/peripheral space returns NOP
    0x00000013

# ============================================================================
# Data Memory Read — route through Wishbone
# ============================================================================

fn soc_mem_read(state: SocState, addr: u32) -> u32:
    """Read a 32-bit word from the data bus via Wishbone address decode."""
    val slave_idx = wb_decode_address(addr)

    var rom_data: u32 = 0
    var clint_data: u32 = 0
    var uart_data: u32 = 0
    var ram_data: u32 = 0
    var mb_data: u32 = 0

    if slave_idx == WB_SLAVE_ROM:
        rom_data = bootrom_read(addr)
    else if slave_idx == WB_SLAVE_CLINT:
        clint_data = clint_mmio_read(state.clint, addr - CLINT_BASE)
    else if slave_idx == WB_SLAVE_UART:
        uart_data = uart_mmio_read(state.uart, addr - UART_BASE)
    else if slave_idx == WB_SLAVE_RAM:
        ram_data = ram_read(state.ram, addr - RAM_BASE)
    else if slave_idx == WB_SLAVE_MAILBOX:
        mb_data = mailbox_mmio_read(state.mailbox, addr - MB_BASE)

    val resp = wb_route_read(slave_idx, addr, rom_data, clint_data, uart_data, ram_data, mb_data, 0)
    resp.rdata

# ============================================================================
# Data Memory Read with Side Effects (UART RX pop)
# ============================================================================

fn soc_mem_read_update(state: SocState, addr: u32) -> SocState:
    """Apply read side-effects (e.g. UART RX FIFO pop)."""
    val slave_idx = wb_decode_address(addr)
    if slave_idx == WB_SLAVE_UART:
        var out = state
        out.uart = uart_mmio_read_update(state.uart, addr - UART_BASE)
        return out
    state

# ============================================================================
# Data Memory Write — route through Wishbone
# ============================================================================

struct SocWriteResult:
    """Result of a data memory write."""
    state: SocState
    char_out: u32
    char_valid: bool
    halt_request: bool

fn soc_mem_write(state: SocState, addr: u32, wdata: u32, width: u32) -> SocWriteResult:
    """Write to data memory via Wishbone address decode."""
    val slave_idx = wb_decode_address(addr)
    val wr = wb_route_write(slave_idx, addr, wdata)
    var out = state
    var char_out: u32 = 0
    var char_valid: bool = false
    var halt_request: bool = false

    if slave_idx == WB_SLAVE_CLINT:
        out.clint = clint_mmio_write(state.clint, wr.offset, wdata)

    else if slave_idx == WB_SLAVE_UART:
        out.uart = uart_mmio_write(state.uart, wr.offset, wdata)

    else if slave_idx == WB_SLAVE_RAM:
        out.ram = ram_write(state.ram, wr.offset, wdata, width)

    else if slave_idx == WB_SLAVE_MAILBOX:
        val mb_result = mailbox_mmio_write(state.mailbox, wr.offset, wdata)
        out.mailbox = mb_result.state
        char_out = mb_result.char_out
        char_valid = mb_result.char_valid
        halt_request = mb_result.halt_request

    # ROM writes are silently ignored

    SocWriteResult(
        state: out,
        char_out: char_out,
        char_valid: char_valid,
        halt_request: halt_request
    )

# ============================================================================
# Physical bus adaptation
# ============================================================================

fn soc_width_from_size(size_bytes: u32) -> u32:
    if size_bytes == 1:
        return 0
    if size_bytes == 2:
        return 1
    2

fn soc_bus_target_valid(slave_idx: u32) -> bool:
    (slave_idx == WB_SLAVE_ROM or slave_idx == WB_SLAVE_CLINT or
        slave_idx == WB_SLAVE_UART or slave_idx == WB_SLAVE_RAM or
        slave_idx == WB_SLAVE_MAILBOX)

fn soc_bus_read(state: SocState, addr: u32, slave_idx: u32,
                size_bytes: u32) -> u32:
    val raw = soc_mem_read(state, addr)
    if slave_idx == WB_SLAVE_ROM or slave_idx == WB_SLAVE_RAM:
        val shifted = raw >> ((addr & 3) * 8)
        if size_bytes == 1:
            return shifted & 0xFF
        if size_bytes == 2:
            return shifted & 0xFFFF
        return shifted
    raw

# ============================================================================
# SoC Tick — one stalled core/bus/peripheral clock
# ============================================================================

fn soc_tick(state: SocState) -> SocTickResult:
    """Advance the clocked RV32 core and latch one physical bus response."""
    var out = state
    var char_out: u32 = 0
    var char_valid = false

    val ct = clint_tick(out.clint)
    out.clint = ct.state
    val ut = uart_tick(out.uart)
    out.uart = ut.state
    out.core.csr_m = csr_update_mip(out.core.csr_m, ct.mtip,
        ct.msip_out, false)

    val drain_halt = out.halt_pending and out.response_valid
    val request_access = out.core.memory.access_type
    val core_result = core32_cycle(out.core, true, out.response_valid,
        out.response_error, out.response_data)
    out.core = core_result.state
    out.response_valid = false
    out.response_error = false
    out.response_data = 0

    if core_result.bus_valid:
        out.response_valid = true
        if core_result.bus_addr < 0 or core_result.bus_addr > 0xFFFFFFFF:
            out.response_error = true
        else:
            val addr = core_result.bus_addr as u32
            val slave_idx = wb_decode_address(addr)
            if (slave_idx == WB_SLAVE_UNMAPPED or
                not soc_bus_target_valid(slave_idx)):
                out.response_error = true
            else if (slave_idx == WB_SLAVE_RAM and
                     (addr - RAM_BASE) + core_result.bus_size >
                        out.ram.size_words * 4):
                out.response_error = true
            else if core_result.bus_is_pte and slave_idx != WB_SLAVE_RAM:
                out.response_error = true
            else if (request_access == ACCESS_FETCH and
                     slave_idx != WB_SLAVE_ROM and
                     slave_idx != WB_SLAVE_RAM):
                out.response_error = true
            else if core_result.bus_atomic and slave_idx != WB_SLAVE_RAM:
                out.response_error = true
            else if core_result.bus_write:
                if slave_idx == WB_SLAVE_ROM:
                    out.response_error = true
                else:
                    val wr = soc_mem_write(out, addr, core_result.bus_wdata,
                        soc_width_from_size(core_result.bus_size))
                    out = wr.state
                    char_out = wr.char_out
                    char_valid = wr.char_valid
                    if wr.halt_request:
                        out.halt_pending = true
            else:
                out.response_data = soc_bus_read(out, addr, slave_idx,
                    core_result.bus_size)
                if request_access != ACCESS_FETCH:
                    out = soc_mem_read_update(out, addr)

    if drain_halt:
        out.core.halt = true
        out.core.memory = memory32_reset()
        out.halt_pending = false

    val ports = SocPorts(
        uart_tx: ut.tx_out != 0,
        halted: out.core.halt,
        char_out: char_out,
        char_valid: char_valid
    )
    SocTickResult(state: out, ports: ports)
