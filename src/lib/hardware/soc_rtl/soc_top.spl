# ============================================================================
# SoC RTL Top-Level — Full RV32I System-on-Chip
# ============================================================================
#
# Wires together the RV32I core, CSR file, trap controller, register file,
# Wishbone interconnect, RAM, boot ROM, UART 16550, CLINT, and mailbox into
# a complete single-cycle SoC.
#
# soc_tick() is THE main simulation entry point.  Each call = 1 clock cycle.
# The pipeline:
#   1.  Fetch instruction (via Wishbone: ROM or RAM)
#   2.  Decode instruction
#   3.  Read registers
#   4.  Compute ALU result
#   5.  Memory access (load/store via Wishbone)
#   6.  CSR operations (CSRRW/S/C when SYSTEM + funct3!=0)
#   7.  Trap entry (ECALL/EBREAK) or MRET
#   8.  Interrupt check and trap entry
#   9.  Write-back to register file
#   10. Update PC (next_pc / trap_pc / mret_pc)
#   11. Tick peripherals (CLINT, UART)
#   12. Update CSR mip from peripheral interrupts
#
# VHDL synthesizable subset: u32, bool, [u32], structs only.
# ============================================================================

# -- Core pipeline
use std.hardware.rv32i_rtl.pkg.{OP_SYSTEM, OP_LOAD, OP_STORE}
use std.hardware.rv32i_rtl.decode.{DecodeResult, decode_instruction}
use std.hardware.rv32i_rtl.alu.{alu_compute}
use std.hardware.rv32i_rtl.regfile.{RegFile, regfile_create, regfile_read, regfile_write}
use std.hardware.rv32i_rtl.lsu.lsu_load
use std.hardware.rv32i_rtl.core.{CoreState, core_reset, core_combinational, core_update}
use std.hardware.rv32i_rtl.protected_core.{CoreProtectedState32, core32_init, core32_cycle}
use std.hardware.rv32i_rtl.protected_core.{core32_set_pending_interrupts, core32_invalidate_reservation}
use std.hardware.rv32i_rtl.protected_core.core32_set_supervisor_pending_interrupts

# -- CSR / Trap
use std.hardware.rv32i_rtl.csr.{CsrFile, CsrRwResult, csr_create, csr_read, csr_rw, csr_tick, csr_update_mip}
use std.hardware.rv32i_rtl.csr.{MSTATUS_MIE_MASK}
use std.hardware.rv32i_rtl.csr.{FUNCT3_CSRRW, FUNCT3_CSRRS, FUNCT3_CSRRC}
use std.hardware.rv32i_rtl.csr.{FUNCT3_CSRRWI, FUNCT3_CSRRSI, FUNCT3_CSRRCI}
use std.hardware.rv32i_rtl.trap.{trap_check_interrupt, trap_enter, trap_exit_mret}
use std.hardware.rv32i_rtl.trap.{CAUSE_ECALL_M, CAUSE_BREAKPOINT}

# -- Peripherals
use std.hardware.soc_rtl.bootrom.{bootrom_read, BOOTROM_BASE}
use std.hardware.soc_rtl.dtb_asset.{SOC_DTB_BASE, SOC_DTB_RAM_SIZE, SOC_DTB_RESERVED_SIZE}
use std.hardware.soc_rtl.dtb_asset.soc_rv32_linux_dtb_for_ram_initrd
use std.hardware.soc_rtl.uart16550.{Uart16550State, uart_create, uart_mmio_read, uart_mmio_read_update, uart_mmio_write, uart_tick, uart_rx_push}
use std.hardware.soc_rtl.clint.{ClintState, clint_create, clint_mmio_read, clint_mmio_write, clint_tick}
use std.hardware.soc_rtl.plic.{PlicState, plic_create, plic_mmio_read, plic_mmio_read_update, plic_mmio_write, plic_set_pending, plic_check_interrupt, plic_check_interrupt_s, PLIC_BASE}
use std.hardware.soc_rtl.ram.{RamState, ram_create, ram_read, ram_write}
use std.hardware.soc_rtl.ram_sparse.{SparseRam, sparse_create, sparse_read, sparse_write, sparse_pages_allocated}
use std.hardware.soc_rtl.mailbox.{MailboxState, mailbox_create, mailbox_mmio_read, mailbox_mmio_write}

# -- Wishbone interconnect
use std.hardware.soc_rtl.wb_interconnect.{wb_decode_address, wb_route_read, wb_route_write}
use std.hardware.soc_rtl.wb_interconnect.{WB_SLAVE_ROM, WB_SLAVE_CLINT, WB_SLAVE_UART}
use std.hardware.soc_rtl.wb_interconnect.{WB_SLAVE_RAM, WB_SLAVE_MAILBOX}
use std.hardware.soc_rtl.wb_interconnect.WB_SLAVE_UNMAPPED
use std.hardware.soc_rtl.wb_interconnect.{RAM_BASE, CLINT_BASE, UART_BASE, MB_BASE}

# ============================================================================
# SoC State
# ============================================================================

struct SocState:
    """Full SoC sequential state.

    RAM is two-tier so the SoC addresses the full 4 GiB space:
      * `ram`     — dense synthesizable [u32] window (BRAM model, low addresses)
      * `sparse`  — page-backed sim model covering the rest of the 4 GiB DRAM
    An access with word index < `ram.size_words` is served by the dense window;
    everything else in the DRAM range is served by `sparse`.  `dram_size` is the
    configured DRAM byte size (u32, up to 0xFFFF_FFFF) that bounds the RAM
    region for address dispatch — it replaces the hard-wired 128 MiB RAM_END
    cap in wb_interconnect for RAM membership."""
    core: CoreState
    csr: CsrFile
    regfile: RegFile
    uart: Uart16550State
    clint: ClintState
    plic: PlicState
    mailbox: MailboxState
    ram: RamState
    sparse: SparseRam
    dram_size: u32
    dtb_size: u32
    dtb_ram_size: u32
    dtb_initrd_start: u32
    dtb_initrd_end: u32

# ============================================================================
# SoC External Ports
# ============================================================================

struct SocPorts:
    """External pin-level signals from the SoC."""
    uart_tx: bool         # UART TX line
    halted: bool          # CPU halted
    char_out: u32         # Mailbox PUTC character
    char_valid: bool      # Mailbox PUTC valid

# ============================================================================
# SoC Tick Result
# ============================================================================

struct SocTickResult:
    """Result of one SoC clock cycle."""
    state: SocState       # Updated SoC state
    ports: SocPorts       # External port values this cycle

# ============================================================================
# Create / Reset
# ============================================================================

# Legacy DRAM window: 128 MiB, matching the historic RAM_BASE..RAM_END range.
val RAM_LEGACY_SIZE: u32 = 0x08000000
val SOC32_SLAVE_PLIC: u32 = 6
val SOC32_PLIC_END: u32 = 0x0FFFFFFF
val SOC32_PLIC_SRC_UART: u32 = 10

fn soc_create(ram_size_words: u32) -> SocState:
    """Create and initialize the full SoC.  PC starts at boot ROM (0x1000).

    The dense window holds `ram_size_words` words; the DRAM region spans the
    legacy 128 MiB so existing behavior (and the rv32 regression probe) is
    byte-identical.  Use `soc_create_bytes` for a full 4 GiB-capable DRAM."""
    SocState(
        core: core_reset(BOOTROM_BASE),
        csr: csr_create(0),
        regfile: regfile_create(),
        uart: uart_create(),
        clint: clint_create(),
        plic: plic_create(),
        mailbox: mailbox_create(),
        ram: ram_create(ram_size_words),
        sparse: sparse_create(RAM_LEGACY_SIZE),
        dram_size: RAM_LEGACY_SIZE,
        dtb_size: SOC_DTB_RESERVED_SIZE as u32,
        dtb_ram_size: RAM_LEGACY_SIZE,
        dtb_initrd_start: 0,
        dtb_initrd_end: 0
    )

fn soc_create_bytes(dram_bytes: u32) -> SocState:
    """Create a SoC whose DRAM spans [RAM_BASE, RAM_BASE + dram_bytes), backed
    entirely by the sparse 4 GiB-capable model.  The dense window is sized to
    zero words so EVERY RAM access routes to `sparse`.  `dram_bytes` may be up
    to 0xFFFF_FFFF (full 4 GiB).  This is the entry point for addressing the
    high (>= 0x8000_0000) space that the dense array cannot physically hold."""
    SocState(
        core: core_reset(BOOTROM_BASE),
        csr: csr_create(0),
        regfile: regfile_create(),
        uart: uart_create(),
        clint: clint_create(),
        plic: plic_create(),
        mailbox: mailbox_create(),
        ram: ram_create(0),
        sparse: sparse_create(dram_bytes),
        dram_size: dram_bytes,
        dtb_size: SOC_DTB_RESERVED_SIZE as u32,
        dtb_ram_size: dram_bytes,
        dtb_initrd_start: 0,
        dtb_initrd_end: 0
    )

fn soc_reset(ram_size_words: u32) -> SocState:
    """Reset the SoC — alias for soc_create."""
    soc_create(ram_size_words)

# ============================================================================
# RAM address dispatch — 4 GiB-safe (extends wb_interconnect's 128 MiB cap)
# ============================================================================

fn soc_addr_in_ram(addr: u32, dram_size: u32) -> bool:
    """True when `addr` is inside the configured DRAM window
    [RAM_BASE, RAM_BASE + dram_size).

    The offset (`addr - RAM_BASE`) is computed ONLY after the lower-bound check,
    so a 4 GiB `dram_size` (where RAM_BASE + dram_size overflows u32) never
    wraps — this comparison is unsigned-safe for the full 0x8000_0000 ..
    0xFFFF_FFFF range.  This is the fix for the historic 128 MiB RAM_END cap:
    high addresses (>= 0x8000_0000, which sign-extend to negative under a naive
    i32 model) are dispatched to RAM instead of decoding as unmapped."""
    if addr < RAM_BASE:
        return false
    (addr - RAM_BASE) < dram_size

fn soc_route(addr: u32, dram_size: u32) -> u32:
    """Decode `addr` to a Wishbone slave index, extending RAM membership to the
    full `dram_size` window.  Peripherals (ROM/CLINT/UART/ETH/Mailbox) keep
    their fixed wb_interconnect ranges — the Mailbox aperture inside RAM is
    honored because wb_decode_address checks it first.  Only the RAM-vs-unmapped
    decision is widened past wb_interconnect's 128 MiB RAM_END."""
    if addr >= PLIC_BASE and addr <= SOC32_PLIC_END:
        return SOC32_SLAVE_PLIC
    val idx = wb_decode_address(addr)
    if idx == WB_SLAVE_RAM or idx == WB_SLAVE_UNMAPPED:
        if soc_addr_in_ram(addr, dram_size):
            return WB_SLAVE_RAM
        return WB_SLAVE_UNMAPPED
    idx

fn soc_ram_read(state: SocState, offset: u32) -> u32:
    """Read a RAM word by byte offset (addr - RAM_BASE).  The dense BRAM window
    serves word indices below its size; the sparse model serves the rest."""
    val word_idx = offset >> 2
    if word_idx < state.ram.size_words:
        return ram_read(state.ram, offset)
    sparse_read(state.sparse, offset)

fn soc_ram_write(state: SocState, offset: u32, wdata: u32, width: u32) -> SocState:
    """Write a RAM word/half/byte by byte offset (addr - RAM_BASE).  Routes to
    the dense window (low addresses) or the sparse model (rest of 4 GiB)."""
    var out = state
    val word_idx = offset >> 2
    if word_idx < state.ram.size_words:
        out.ram = ram_write(state.ram, offset, wdata, width)
    else:
        out.sparse = sparse_write(state.sparse, offset, wdata, width)
    out

fn soc32_in_dtb(state: SocState, addr: u32) -> bool:
    if (addr as u64) < SOC_DTB_BASE:
        return false
    ((addr as u64) - SOC_DTB_BASE) < (state.dtb_size as u64)

fn soc32_dtb_read(state: SocState, addr: u32) -> u32:
    val off = (((addr as u64) - SOC_DTB_BASE) >> 2) << 2
    soc_ram_read(state, (SOC_DTB_BASE as u32) - RAM_BASE + (off as u32))

# ============================================================================
# Instruction Fetch — route through Wishbone address map
# ============================================================================

fn soc_fetch_instruction(state: SocState, pc: u32) -> u32:
    """Fetch a 32-bit instruction word at the given PC.
    Routes through the Wishbone address decoder to ROM or RAM."""
    val slave_idx = soc_route(pc, state.dram_size)
    if slave_idx == WB_SLAVE_ROM:
        return bootrom_read(pc)
    if slave_idx == WB_SLAVE_RAM:
        val ram_offset = pc - RAM_BASE
        return soc_ram_read(state, ram_offset)
    # Fetching from unmapped/peripheral space returns NOP
    0x00000013

# ============================================================================
# Data Memory Read — route through Wishbone
# ============================================================================

fn soc_mem_read(state: SocState, addr: u32) -> u32:
    """Read a 32-bit word from the data bus via Wishbone address decode."""
    if soc32_in_dtb(state, addr):
        return soc32_dtb_read(state, addr)
    val slave_idx = soc_route(addr, state.dram_size)
    if slave_idx == SOC32_SLAVE_PLIC:
        return plic_mmio_read(state.plic, addr - PLIC_BASE)

    var rom_data: u32 = 0
    var clint_data: u32 = 0
    var uart_data: u32 = 0
    var ram_data: u32 = 0
    var mb_data: u32 = 0

    if slave_idx == WB_SLAVE_ROM:
        rom_data = bootrom_read(addr)
    else if slave_idx == WB_SLAVE_CLINT:
        clint_data = clint_mmio_read(state.clint, addr - CLINT_BASE)
    else if slave_idx == WB_SLAVE_UART:
        uart_data = uart_mmio_read(state.uart, addr - UART_BASE)
    else if slave_idx == WB_SLAVE_RAM:
        ram_data = soc_ram_read(state, addr - RAM_BASE)
    else if slave_idx == WB_SLAVE_MAILBOX:
        mb_data = mailbox_mmio_read(state.mailbox, addr - MB_BASE)

    val resp = wb_route_read(slave_idx, addr, rom_data, clint_data, uart_data, ram_data, mb_data, 0)
    resp.rdata

# ============================================================================
# Data Memory Read with Side Effects (UART RX pop)
# ============================================================================

fn soc_mem_read_update(state: SocState, addr: u32) -> SocState:
    """Apply read side-effects (e.g. UART RX FIFO pop)."""
    val slave_idx = soc_route(addr, state.dram_size)
    if slave_idx == WB_SLAVE_UART:
        var out = state
        out.uart = uart_mmio_read_update(state.uart, addr - UART_BASE)
        return out
    if slave_idx == SOC32_SLAVE_PLIC:
        var out = state
        out.plic = plic_mmio_read_update(state.plic, addr - PLIC_BASE)
        return out
    state

# ============================================================================
# Data Memory Write — route through Wishbone
# ============================================================================

struct SocWriteResult:
    """Result of a data memory write."""
    state: SocState
    char_out: u32
    char_valid: bool
    halt_request: bool

fn soc_mem_write(state: SocState, addr: u32, wdata: u32, width: u32) -> SocWriteResult:
    """Write to data memory via Wishbone address decode."""
    if soc32_in_dtb(state, addr):
        return SocWriteResult(state: state, char_out: 0, char_valid: false,
            halt_request: false)
    val slave_idx = soc_route(addr, state.dram_size)
    val wr = wb_route_write(slave_idx, addr, wdata)
    var out = state
    var char_out: u32 = 0
    var char_valid: bool = false
    var halt_request: bool = false

    if slave_idx == SOC32_SLAVE_PLIC:
        out.plic = plic_mmio_write(state.plic, addr - PLIC_BASE, wdata)

    else if slave_idx == WB_SLAVE_CLINT:
        out.clint = clint_mmio_write(state.clint, wr.offset, wdata)

    else if slave_idx == WB_SLAVE_UART:
        out.uart = uart_mmio_write(state.uart, wr.offset, wdata)

    else if slave_idx == WB_SLAVE_RAM:
        # Compute the RAM offset directly from addr (not wr.offset): wb_route_write
        # only knows the 128 MiB RAM_END window, so its offset is unreliable for
        # extended (>= RAM_END) addresses.  addr - RAM_BASE is exact for the full
        # 4 GiB range.
        out = soc_ram_write(out, addr - RAM_BASE, wdata, width)

    else if slave_idx == WB_SLAVE_MAILBOX:
        val mb_result = mailbox_mmio_write(state.mailbox, wr.offset, wdata)
        out.mailbox = mb_result.state
        char_out = mb_result.char_out
        char_valid = mb_result.char_valid
        halt_request = mb_result.halt_request

    # ROM writes are silently ignored

    SocWriteResult(
        state: out,
        char_out: char_out,
        char_valid: char_valid,
        halt_request: halt_request
    )

# ============================================================================
# Helper — is this a CSR instruction?
# ============================================================================

fn is_csr_funct3(funct3: u32) -> bool:
    """Return true if funct3 indicates a CSR read-modify-write instruction."""
    (funct3 == FUNCT3_CSRRW or funct3 == FUNCT3_CSRRS or funct3 == FUNCT3_CSRRC or
     funct3 == FUNCT3_CSRRWI or funct3 == FUNCT3_CSRRSI or funct3 == FUNCT3_CSRRCI)

# ============================================================================
# Helper — is this an MRET instruction?
# ============================================================================

fn is_mret(dec: DecodeResult) -> bool:
    """Return true if the decoded instruction is MRET.
    MRET encoding: funct7=0x18 (0011000), rs2=00010, funct3=0, opcode=SYSTEM.
    The full imm field (bits [31:20]) = 0x302."""
    dec.opcode == OP_SYSTEM and dec.funct3 == 0 and dec.funct7 == 0x18 and dec.rs2 == 2

# ============================================================================
# Helper — is this ECALL?
# ============================================================================

fn is_ecall(dec: DecodeResult) -> bool:
    """Return true if the decoded instruction is ECALL.
    ECALL encoding: imm=0, funct3=0, opcode=SYSTEM."""
    dec.opcode == OP_SYSTEM and dec.funct3 == 0 and dec.funct7 == 0 and dec.rs2 == 0

# ============================================================================
# Helper — is this EBREAK?
# ============================================================================

fn is_ebreak(dec: DecodeResult) -> bool:
    """Return true if the decoded instruction is EBREAK.
    EBREAK encoding: imm=1 (rs2=1), funct3=0, opcode=SYSTEM."""
    dec.opcode == OP_SYSTEM and dec.funct3 == 0 and dec.funct7 == 0 and dec.rs2 == 1

# ============================================================================
# SoC Tick — THE main simulation function
# ============================================================================

fn soc_tick(state: SocState) -> SocTickResult:
    """Execute one clock cycle of the entire SoC.

    This function integrates all modules: core datapath, CSR, traps,
    register file, Wishbone bus, RAM, ROM, UART, CLINT, and mailbox.

    Returns the updated SoC state and external port values."""

    val pc = state.core.pc
    var cur_csr = state.csr
    var cur_rf = state.regfile
    var cur_state = state
    var halted = state.core.halt
    var char_out: u32 = 0
    var char_valid: bool = false
    var uart_tx_bit: u32 = 1
    var trap_clears_res: bool = false   # sync trap entry clears LR/SC reservation

    # If already halted, just tick peripherals and return
    if halted:
        # Tick CLINT
        val ct = clint_tick(cur_state.clint)
        cur_state.clint = ct.state
        # Tick UART
        val ut = uart_tick(cur_state.uart)
        cur_state.uart = ut.state
        uart_tx_bit = ut.tx_out
        val uart_irq_pending = (ut.irq and
            cur_state.plic.claim_complete != SOC32_PLIC_SRC_UART and
            cur_state.plic.claim_complete_s != SOC32_PLIC_SRC_UART)
        cur_state.plic = plic_set_pending(cur_state.plic,
            SOC32_PLIC_SRC_UART, uart_irq_pending)

        val ports = SocPorts(
            uart_tx: uart_tx_bit != 0,
            halted: true,
            char_out: 0,
            char_valid: false
        )
        return SocTickResult(state: cur_state, ports: ports)

    # ── Step 1: Fetch instruction ────────────────────────────────────────
    val insn = soc_fetch_instruction(cur_state, pc)

    # ── Step 2: Decode ───────────────────────────────────────────────────
    val dec = decode_instruction(insn)

    # ── Step 3: Read registers ───────────────────────────────────────────
    val rr = regfile_read(cur_rf, dec.rs1, dec.rs2)
    val rs1_data = rr.rs1_data
    val rs2_data = rr.rs2_data

    # ── Step 4: Core combinational datapath (ALU, branch, next-PC) ──────
    # First, compute dmem_rdata for the combinational path (needed for loads)
    val comb_prelim = core_combinational(state.core, insn, 0, cur_rf)

    # Read data memory at the computed address
    val dmem_rdata = soc_mem_read(cur_state, comb_prelim.dmem_addr)

    # Re-run combinational with actual memory read data
    val comb = core_combinational(state.core, insn, dmem_rdata, cur_rf)

    # ── Step 5: Memory write (store instructions) ────────────────────────
    var next_pc = comb.pc_next
    var do_rd_write = dec.reg_write
    var rd_data = comb.rd_data

    if comb.dmem_we:
        val wr = soc_mem_write(cur_state, comb.dmem_addr, comb.dmem_wdata, comb.dmem_width)
        cur_state = wr.state
        if wr.char_valid:
            char_out = wr.char_out
            char_valid = true
        if wr.halt_request:
            halted = true

    # Apply read side-effects (UART RX pop on load)
    if comb.dmem_re:
        cur_state = soc_mem_read_update(cur_state, comb.dmem_addr)

    # ── Step 6: CSR operations (SYSTEM + funct3 != 0) ───────────────────
    if dec.opcode == OP_SYSTEM and is_csr_funct3(dec.funct3):
        # CSR address is in the immediate field bits [31:20] = dec.imm upper 12
        val csr_addr = (insn >> 20) & 0xFFF

        # For CSRRxI, the source is the zero-extended rs1 field (5-bit immediate)
        var csr_src = rs1_data
        if dec.funct3 >= FUNCT3_CSRRWI:
            csr_src = dec.rs1   # rs1 field used as zimm[4:0]

        val csr_result = csr_rw(cur_csr, csr_addr, csr_src, dec.funct3)
        cur_csr = csr_result.csr

        # CSR read value goes to rd
        rd_data = csr_result.old_value
        do_rd_write = true
        next_pc = pc + 4

    # ── Step 7: WFI / ECALL / EBREAK / MRET ─────────────────────────────
    else if dec.opcode == OP_SYSTEM and dec.funct3 == 0:
        if dec.is_wfi:
            # WFI — wait for interrupt. Same semantics as the rv64 core:
            #   * retire as a NOP (pc <- pc+4) when an enabled interrupt is
            #     already pending (mie & mip != 0) — the step-8 interrupt
            #     take then fires with mepc = wfi+4, so mret resumes AFTER
            #     the wfi (RISC-V: mepc = next instruction);
            #   * retire as a NOP when mstatus.MIE = 0 — the spec allows
            #     WFI to be a no-op, and this avoids a permanent hang when
            #     interrupts are globally disabled;
            #   * otherwise hold pc (architectural stall). Peripherals keep
            #     ticking (steps 11-12), so a future mie&mip match wakes
            #     the core on the cycle it pends.
            val wfi_mie_on = (cur_csr.mstatus & MSTATUS_MIE_MASK) != 0
            val wfi_pending = (cur_csr.mie & cur_csr.mip) != 0
            if wfi_pending or wfi_mie_on == false:
                next_pc = pc + 4
            else:
                next_pc = pc
            do_rd_write = false

        else if is_mret(dec):
            # MRET — restore context from CSRs
            val mret_result = trap_exit_mret(cur_csr)
            cur_csr = mret_result.csr
            next_pc = mret_result.return_pc
            do_rd_write = false

        else if is_ecall(dec):
            # ECALL — enter trap with cause = environment call from M-mode
            val enter_result = trap_enter(cur_csr, pc, CAUSE_ECALL_M, 0)
            cur_csr = enter_result.csr
            next_pc = enter_result.trap_pc
            do_rd_write = false
            trap_clears_res = true

        else if is_ebreak(dec) and state.core.semi_phase == 0:
            # EBREAK outside semihosting sequence — enter trap
            # When semi_phase != 0, the EBREAK is part of the semihosting
            # magic sequence and core_update handles it via the semi_phase FSM
            val enter_result = trap_enter(cur_csr, pc, CAUSE_BREAKPOINT, pc)
            cur_csr = enter_result.csr
            next_pc = enter_result.trap_pc
            do_rd_write = false
            trap_clears_res = true

    # ── Step 8: Interrupt check ──────────────────────────────────────────
    # Check for pending interrupts AFTER instruction execution
    val int_check = trap_check_interrupt(cur_csr)
    if int_check.pending:
        val int_enter = trap_enter(cur_csr, next_pc, int_check.cause, 0)
        cur_csr = int_enter.csr
        next_pc = int_enter.trap_pc

    # ── Step 9: Write-back to register file ──────────────────────────────
    cur_rf = regfile_write(cur_rf, dec.rd, rd_data, do_rd_write)

    # ── Step 10: Update core state (PC, semihosting detection) ───────────
    # core_update handles the semihosting magic sequence FSM (semi_phase).
    # It must run for:
    #   - All non-SYSTEM instructions (normal datapath)
    #   - SYSTEM instructions when semihosting is active (semi_phase != 0),
    #     because the EBREAK in the semihosting sequence is OP_SYSTEM
    var new_core = state.core
    val need_core_update = (dec.opcode != OP_SYSTEM or state.core.semi_phase != 0)
    if need_core_update:
        new_core = core_update(state.core, insn, comb, rr.a0_val, rr.a1_val)
        # core_update computes its own pc_next; override with our trap-aware pc
        # unless semihosting consumed it (semi_phase advanced)
        if state.core.semi_phase == 0:
            new_core.pc = next_pc
        if new_core.halt:
            halted = true
    else:
        # SYSTEM instructions outside semihosting — just update PC
        new_core.pc = next_pc
        new_core.semi_trigger = false

    if halted:
        new_core.halt = true

    # Synchronous trap entry (ECALL/EBREAK) clears the LR/SC reservation
    # (mirrors the rv64 core, which resets atomics state on sync traps).
    if trap_clears_res:
        new_core.res_valid = false
        new_core.res_addr = 0

    cur_state.core = new_core
    cur_state.csr = cur_csr
    cur_state.regfile = cur_rf

    # ── Step 11: Tick peripherals ────────────────────────────────────────
    val ct = clint_tick(cur_state.clint)
    cur_state.clint = ct.state

    val ut = uart_tick(cur_state.uart)
    cur_state.uart = ut.state
    uart_tx_bit = ut.tx_out
    val uart_irq_pending = (ut.irq and
        cur_state.plic.claim_complete != SOC32_PLIC_SRC_UART and
        cur_state.plic.claim_complete_s != SOC32_PLIC_SRC_UART)
    cur_state.plic = plic_set_pending(cur_state.plic,
        SOC32_PLIC_SRC_UART, uart_irq_pending)
    val plic_irq = plic_check_interrupt(cur_state.plic)

    # ── Step 12: Update CSR mip from peripheral interrupts ───────────────
    cur_state.csr = csr_update_mip(cur_state.csr, ct.mtip, ct.msip_out, plic_irq.meip)

    # Tick CSR counters (mcycle, minstret)
    cur_state.csr = csr_tick(cur_state.csr)

    # ── Build output ─────────────────────────────────────────────────────
    val ports = SocPorts(
        uart_tx: uart_tx_bit != 0,
        halted: cur_state.core.halt,
        char_out: char_out,
        char_valid: char_valid
    )

    SocTickResult(state: cur_state, ports: ports)

# ============================================================================
# Protected RV32IMAC SoC path — additive; legacy soc_tick remains unchanged
# ============================================================================

struct SocProtected32State:
    core: CoreProtectedState32
    uart: Uart16550State
    clint: ClintState
    plic: PlicState
    mailbox: MailboxState
    ram: RamState
    sparse: SparseRam
    dram_size: u32
    dtb_size: u32
    dtb_ram_size: u32
    dtb_initrd_start: u32
    dtb_initrd_end: u32
    response_valid: bool
    response_error: bool
    response_data: u32
    supervisor_timer_pending: bool
    supervisor_external_pending: bool

struct SocProtected32TickResult:
    state: SocProtected32State
    ports: SocPorts
    bus_lock: bool

fn soc_protected32_from_legacy(fabric: SocState) -> SocProtected32State:
    SocProtected32State(core: core32_init(BOOTROM_BASE), uart: fabric.uart,
        clint: fabric.clint, plic: fabric.plic, mailbox: fabric.mailbox, ram: fabric.ram,
        sparse: fabric.sparse, dram_size: fabric.dram_size,
        dtb_size: fabric.dtb_size, dtb_ram_size: fabric.dtb_ram_size,
        dtb_initrd_start: fabric.dtb_initrd_start,
        dtb_initrd_end: fabric.dtb_initrd_end,
        response_valid: false, response_error: false, response_data: 0,
        supervisor_timer_pending: false, supervisor_external_pending: false)

fn soc_protected32_create(ram_size_words: u32) -> SocProtected32State:
    soc_protected32_create_with_initrd(ram_size_words, 0, 0)

fn soc_protected32_create_with_initrd(ram_size_words: u32,
                                      initrd_start: u32,
                                      initrd_end: u32) -> SocProtected32State:
    var fabric = soc_create(ram_size_words)
    fabric.sparse = sparse_create(SOC_DTB_RAM_SIZE as u32)
    fabric.dram_size = SOC_DTB_RAM_SIZE as u32
    fabric.dtb_ram_size = SOC_DTB_RAM_SIZE as u32
    fabric.dtb_initrd_start = initrd_start
    fabric.dtb_initrd_end = initrd_end
    fabric.dtb_size = SOC_DTB_RESERVED_SIZE as u32
    soc_protected32_from_legacy(fabric)

fn soc_protected32_create_bytes(dram_bytes: u32) -> SocProtected32State:
    soc_protected32_create_bytes_with_initrd(dram_bytes, 0, 0)

fn soc_protected32_create_bytes_with_initrd(dram_bytes: u32,
                                            initrd_start: u32,
                                            initrd_end: u32) -> SocProtected32State:
    var effective_size = dram_bytes
    if effective_size < SOC_DTB_RAM_SIZE as u32:
        effective_size = SOC_DTB_RAM_SIZE as u32
    var fabric = soc_create_bytes(effective_size)
    fabric.dtb_initrd_start = initrd_start
    fabric.dtb_initrd_end = initrd_end
    fabric.dtb_size = SOC_DTB_RESERVED_SIZE as u32
    soc_protected32_from_legacy(fabric)

fn soc_protected32_sim_preload_dtb(state: SocProtected32State) -> SocProtected32State:
    """Simulation-only asset load; production RAM images preload the same blob."""
    var out = state
    val blob = soc_rv32_linux_dtb_for_ram_initrd(state.dtb_ram_size as u64,
        state.dtb_initrd_start as u64, state.dtb_initrd_end as u64)
    var i: u32 = 0
    while i < blob.len() as u32:
        out.sparse = sparse_write(out.sparse,
            (SOC_DTB_BASE as u32) - RAM_BASE + i, blob[i] as u32, 0)
        i = i + 1
    out

fn soc_protected32_fabric(state: SocProtected32State) -> SocState:
    """Build a transient legacy-fabric view; protected core state stays authoritative."""
    SocState(core: state.core.core, csr: state.core.csr_m, regfile: state.core.rf,
        uart: state.uart, clint: state.clint, plic: state.plic, mailbox: state.mailbox,
        ram: state.ram, sparse: state.sparse, dram_size: state.dram_size,
        dtb_size: state.dtb_size, dtb_ram_size: state.dtb_ram_size,
        dtb_initrd_start: state.dtb_initrd_start,
        dtb_initrd_end: state.dtb_initrd_end)

fn soc_protected32_copy_fabric(state: SocProtected32State,
                               fabric: SocState) -> SocProtected32State:
    var out = state
    out.uart = fabric.uart
    out.clint = fabric.clint
    out.plic = fabric.plic
    out.mailbox = fabric.mailbox
    out.ram = fabric.ram
    out.sparse = fabric.sparse
    out.dtb_size = fabric.dtb_size
    out.dtb_ram_size = fabric.dtb_ram_size
    out.dtb_initrd_start = fabric.dtb_initrd_start
    out.dtb_initrd_end = fabric.dtb_initrd_end
    out

fn soc_protected32_bus_width(size_bytes: u32) -> u32:
    if size_bytes == 4: return 2
    if size_bytes == 2: return 1
    0

fn soc_protected32_read(state: SocProtected32State, addr: u32) -> u32:
    val fabric = soc_protected32_fabric(state)
    val data = soc_mem_read(fabric, addr)
    if soc32_in_dtb(fabric, addr):
        return data >> ((addr & 3) * 8)
    val slave_idx = soc_route(addr, state.dram_size)
    if slave_idx == WB_SLAVE_ROM or slave_idx == WB_SLAVE_RAM:
        return data >> ((addr & 3) * 8)
    data

fn soc_protected32_read_update(state: SocProtected32State,
                               addr: u32) -> SocProtected32State:
    val fabric = soc_mem_read_update(soc_protected32_fabric(state), addr)
    soc_protected32_copy_fabric(state, fabric)

fn soc_protected32_invalidate_reservation(state: SocProtected32State,
                                          physical_address: i64,
                                          size_bytes: u32) -> SocProtected32State:
    var out = state
    out.core = core32_invalidate_reservation(state.core, physical_address, size_bytes)
    out

fn soc_protected32_uart_push_rx(state: SocProtected32State,
                                byte_val: u32) -> SocProtected32State:
    """Latch one host/testbench receive event into the canonical UART FIFO."""
    var out = state
    out.uart = uart_rx_push(state.uart, byte_val)
    out

fn soc_protected32_set_supervisor_interrupts(state: SocProtected32State,
                                             stip: bool,
                                             seip: bool) -> SocProtected32State:
    """Latch platform-owned S interrupt levels without exposing CSR internals."""
    var out = state
    out.supervisor_timer_pending = stip
    out.supervisor_external_pending = seip
    out

fn soc_protected32_tick(state: SocProtected32State) -> SocProtected32TickResult:
    """Advance the protected core and service one accepted physical request."""
    var out = state
    val cycle = core32_cycle(state.core, true, state.response_valid,
        state.response_error, state.response_data)
    out.core = cycle.state
    out.response_valid = false
    out.response_error = false
    out.response_data = 0
    var char_out: u32 = 0
    var char_valid = false

    if cycle.bus_valid:
        out.response_valid = true
        if (cycle.bus_addr < 0 or cycle.bus_addr > 0xFFFFFFFF or
            (cycle.bus_size != 1 and cycle.bus_size != 2 and cycle.bus_size != 4)):
            out.response_error = true
        else:
            val addr = cycle.bus_addr as u32
            val slave_idx = soc_route(addr, out.dram_size)
            val is_dtb = soc32_in_dtb(soc_protected32_fabric(out), addr)
            if (cycle.bus_is_pte and (cycle.bus_write or cycle.bus_size != 4 or
                is_dtb or (slave_idx != WB_SLAVE_ROM and slave_idx != WB_SLAVE_RAM))):
                out.response_error = true
            else if slave_idx == SOC32_SLAVE_PLIC and cycle.bus_size != 4:
                out.response_error = true
            else if cycle.bus_write:
                if is_dtb:
                    out.response_error = true
                else if (slave_idx == WB_SLAVE_CLINT or slave_idx == WB_SLAVE_UART or
                    slave_idx == SOC32_SLAVE_PLIC or
                    slave_idx == WB_SLAVE_RAM or slave_idx == WB_SLAVE_MAILBOX):
                    val written = soc_mem_write(soc_protected32_fabric(out), addr,
                        cycle.bus_wdata, soc_protected32_bus_width(cycle.bus_size))
                    out = soc_protected32_copy_fabric(out, written.state)
                    char_out = written.char_out
                    char_valid = written.char_valid
                    if written.halt_request:
                        out.core.core.halt = true
                else:
                    out.response_error = true
            else:
                if is_dtb:
                    out.response_data = soc_protected32_read(out, addr)
                else if (slave_idx == WB_SLAVE_ROM or slave_idx == WB_SLAVE_CLINT or
                    slave_idx == SOC32_SLAVE_PLIC or
                    slave_idx == WB_SLAVE_UART or slave_idx == WB_SLAVE_RAM or
                    slave_idx == WB_SLAVE_MAILBOX):
                    out.response_data = soc_protected32_read(out, addr)
                    if not cycle.bus_is_pte:
                        out = soc_protected32_read_update(out, addr)
                else:
                    out.response_error = true

    val ct = clint_tick(out.clint)
    out.clint = ct.state
    val ut = uart_tick(out.uart)
    out.uart = ut.state
    val uart_irq_pending = (ut.irq and
        out.plic.claim_complete != SOC32_PLIC_SRC_UART and
        out.plic.claim_complete_s != SOC32_PLIC_SRC_UART)
    out.plic = plic_set_pending(out.plic, SOC32_PLIC_SRC_UART, uart_irq_pending)
    val plic_irq = plic_check_interrupt(out.plic)
    val plic_s_irq = plic_check_interrupt_s(out.plic)
    out.core = core32_set_pending_interrupts(out.core, ct.msip_out, ct.mtip, plic_irq.meip)
    out.core = core32_set_supervisor_pending_interrupts(out.core,
        out.supervisor_timer_pending, out.supervisor_external_pending or plic_s_irq.meip)
    val ports = SocPorts(uart_tx: ut.tx_out != 0, halted: out.core.core.halt,
        char_out: char_out, char_valid: char_valid)
    SocProtected32TickResult(state: out, ports: ports, bus_lock: cycle.bus_lock)
