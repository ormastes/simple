# ============================================================================
# SoC RTL Ethernet DMA Bridge — PS GEM ↔ PL AXI Interface
# ============================================================================
#
# Simplified AXI DMA engine for Ethernet via PS GEM on Zynq K26.
# The PS hardened GEM handles the actual Ethernet MAC/PHY; this DMA bridge
# moves frames between PL memory and PS memory via descriptor rings.
#
# Register map (byte offsets from ETH_DMA_BASE = 0x10010000):
#   0x00: Control  (bit 0 = enable, bit 1 = reset)
#   0x04: Status   (bit 0 = tx_busy, bit 1 = rx_ready, bit 2 = irq_pending)
#   0x08: TX descriptor ring base address
#   0x0C: RX descriptor ring base address
#   0x10: TX head pointer
#   0x14: TX tail pointer
#   0x18: RX head pointer
#   0x1C: RX tail pointer
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

# ============================================================================
# Control register bit masks
# ============================================================================

val ETH_DMA_CTRL_ENABLE: u32 = 0x01   # bit 0: DMA enable
val ETH_DMA_CTRL_RESET: u32  = 0x02   # bit 1: soft reset

# Status register bit masks
val ETH_DMA_STAT_TX_BUSY: u32   = 0x01   # bit 0: TX in progress
val ETH_DMA_STAT_RX_READY: u32  = 0x02   # bit 1: RX data available
val ETH_DMA_STAT_IRQ: u32       = 0x04   # bit 2: interrupt pending

# Descriptor ring size (number of entries)
val ETH_DMA_RING_SIZE: u32 = 16

# ============================================================================
# Ethernet DMA Bridge State
# ============================================================================

struct EthDmaBridgeState:
    """DMA bridge register and descriptor ring state."""
    # Control
    enabled: bool
    reset_pending: bool

    # Descriptor ring base addresses
    tx_desc_addr: u32
    rx_desc_addr: u32

    # Ring pointers (indices into descriptor rings)
    tx_head: u32
    tx_tail: u32
    rx_head: u32
    rx_tail: u32

    # Status flags
    tx_busy: bool
    rx_ready: bool
    irq_pending: bool

    # Last completed RX frame length (for status readback)
    rx_last_length: u32

# ============================================================================
# Tick Result
# ============================================================================

struct EthDmaTickResult:
    """Result of one DMA bridge clock tick."""
    state: EthDmaBridgeState
    tx_signal_ps: bool    # Signal PS GEM to transmit a frame
    rx_completion: bool   # RX descriptor completed (data available)
    irq: bool             # Interrupt request to CPU

# ============================================================================
# Create — initial DMA bridge state
# ============================================================================

fn eth_dma_create() -> EthDmaBridgeState:
    """Create DMA bridge in reset state. All pointers zeroed, disabled."""
    EthDmaBridgeState(
        enabled: false,
        reset_pending: false,
        tx_desc_addr: 0,
        rx_desc_addr: 0,
        tx_head: 0,
        tx_tail: 0,
        rx_head: 0,
        rx_tail: 0,
        tx_busy: false,
        rx_ready: false,
        irq_pending: false,
        rx_last_length: 0
    )

# ============================================================================
# MMIO Read
# ============================================================================

fn eth_dma_mmio_read(state: EthDmaBridgeState, offset: u32) -> u32:
    """Read a DMA bridge register by byte offset.
    0x00: control, 0x04: status, 0x08: tx_desc_addr, 0x0C: rx_desc_addr,
    0x10: tx_head, 0x14: tx_tail, 0x18: rx_head, 0x1C: rx_tail."""

    if offset == 0x00:
        # Control register
        var ctrl: u32 = 0
        if state.enabled:
            ctrl = ctrl | ETH_DMA_CTRL_ENABLE
        if state.reset_pending:
            ctrl = ctrl | ETH_DMA_CTRL_RESET
        return ctrl

    if offset == 0x04:
        # Status register
        var status: u32 = 0
        if state.tx_busy:
            status = status | ETH_DMA_STAT_TX_BUSY
        if state.rx_ready:
            status = status | ETH_DMA_STAT_RX_READY
        if state.irq_pending:
            status = status | ETH_DMA_STAT_IRQ
        return status

    if offset == 0x08:
        return state.tx_desc_addr

    if offset == 0x0C:
        return state.rx_desc_addr

    if offset == 0x10:
        return state.tx_head

    if offset == 0x14:
        return state.tx_tail

    if offset == 0x18:
        return state.rx_head

    if offset == 0x1C:
        return state.rx_tail

    # Unmapped offset
    0

# ============================================================================
# MMIO Write
# ============================================================================

fn eth_dma_mmio_write(state: EthDmaBridgeState, offset: u32, value: u32) -> EthDmaBridgeState:
    """Write a DMA bridge register by byte offset."""
    var out = state

    if offset == 0x00:
        # Control register
        out.enabled = (value & ETH_DMA_CTRL_ENABLE) != 0
        if (value & ETH_DMA_CTRL_RESET) != 0:
            # Soft reset — clear all state but keep descriptor base addresses
            out.tx_head = 0
            out.tx_tail = 0
            out.rx_head = 0
            out.rx_tail = 0
            out.tx_busy = false
            out.rx_ready = false
            out.irq_pending = false
            out.rx_last_length = 0
            out.reset_pending = false
        return out

    if offset == 0x04:
        # Status register — writing clears IRQ (write-1-to-clear for irq bit)
        if (value & ETH_DMA_STAT_IRQ) != 0:
            out.irq_pending = false
        return out

    if offset == 0x08:
        out.tx_desc_addr = value
        return out

    if offset == 0x0C:
        out.rx_desc_addr = value
        return out

    if offset == 0x10:
        out.tx_head = value & 0x0F
        return out

    if offset == 0x14:
        out.tx_tail = value & 0x0F
        return out

    if offset == 0x18:
        out.rx_head = value & 0x0F
        return out

    if offset == 0x1C:
        out.rx_tail = value & 0x0F
        return out

    out

# ============================================================================
# Tick — advance DMA bridge by one clock cycle
# ============================================================================

fn eth_dma_tick(state: EthDmaBridgeState) -> EthDmaTickResult:
    """Advance the DMA bridge by one system clock cycle.
    Checks descriptor ring pointers to determine if TX or RX work is pending.

    TX: If tx_head != tx_tail and not busy, signal PS GEM to send.
    RX: If rx_ready, signal CPU interrupt for receive completion."""

    var out = state
    var tx_signal = false
    var rx_done = false

    if state.enabled == false:
        return EthDmaTickResult(
            state: out,
            tx_signal_ps: false,
            rx_completion: false,
            irq: false
        )

    # TX path: check if there are descriptors to transmit
    if state.tx_busy == false and state.tx_head != state.tx_tail:
        # New TX descriptor available — start transmission
        out.tx_busy = true
        tx_signal = true

    # If TX was busy, simulate single-cycle completion for now
    # (real hardware would take many cycles per frame)
    if state.tx_busy and tx_signal == false:
        out.tx_busy = false
        out.tx_head = (state.tx_head + 1) & 0x0F

    # RX path: check if received frame is ready
    if state.rx_ready:
        rx_done = true
        out.irq_pending = true

    val irq_out = out.irq_pending

    EthDmaTickResult(
        state: out,
        tx_signal_ps: tx_signal,
        rx_completion: rx_done,
        irq: irq_out
    )

# ============================================================================
# Submit TX — queue a frame for transmission
# ============================================================================

fn eth_dma_submit_tx(state: EthDmaBridgeState, desc_addr: u32) -> EthDmaBridgeState:
    """Submit a TX descriptor for transmission.
    Advances the tail pointer to enqueue the descriptor.
    The desc_addr is the physical address of the descriptor in memory."""
    var out = state
    # Advance tail to indicate new descriptor available
    out.tx_tail = (state.tx_tail + 1) & 0x0F
    out

# ============================================================================
# Complete RX — mark a received frame as consumed
# ============================================================================

fn eth_dma_complete_rx(state: EthDmaBridgeState, desc_addr: u32, length: u32) -> EthDmaBridgeState:
    """Complete an RX descriptor — data has been placed at desc_addr.
    Sets rx_ready and records the frame length for CPU readback."""
    var out = state
    out.rx_ready = true
    out.rx_last_length = length
    # Advance RX tail to indicate new data
    out.rx_tail = (state.rx_tail + 1) & 0x0F
    out
