# ============================================================================
# SoC RTL UART 16550 — TX/RX with FIFOs
# ============================================================================
#
# Synthesizable UART 16550 model with 16-byte TX and RX FIFOs, baud rate
# generator, and interrupt support.  All operations are pure functions
# returning new state.
#
# Register map (byte offsets, mimics NS16550A):
#   0x0: RBR (read) / THR (write) / DLL (if DLAB=1)
#   0x1: IER (read/write) / DLM (if DLAB=1)
#   0x2: IIR (read) / FCR (write)
#   0x3: LCR (line control, DLAB in bit 7)
#   0x4: MCR (modem control)
#   0x5: LSR (line status, read-only)
#   0x6: MSR (modem status, read-only; delta bits cleared on read)
#   0x7: SCR (scratch)
#
# VHDL synthesizable subset: u32, bool, fixed-size arrays, structs only.
# ============================================================================

# ============================================================================
# UART Constants
# ============================================================================

val UART_FIFO_SIZE: u32 = 16

# LSR bit masks
val LSR_DR: u32    = 0x01   # bit 0: Data Ready (RX FIFO not empty)
val LSR_THRE: u32  = 0x20   # bit 5: TX Holding Register Empty
val LSR_TEMT: u32  = 0x40   # bit 6: Transmitter Empty

# LCR bit masks
val LCR_DLAB: u32  = 0x80   # bit 7: Divisor Latch Access Bit
val LCR_WLEN_MASK: u32 = 0x03  # bits 1:0: word length (5 + value)

# IER bit masks
val IER_RDI: u32   = 0x01   # bit 0: Received Data Available Interrupt
val IER_THRI: u32  = 0x02   # bit 1: THR Empty Interrupt
val IER_RLSI: u32  = 0x04   # bit 2: Receiver Line Status Interrupt
val IER_MSI: u32   = 0x08   # bit 3: Modem Status Interrupt

# IIR values
val IIR_NO_INT: u32     = 0x01   # No interrupt pending
val IIR_MSI: u32        = 0x00   # Modem status change
val IIR_THRI: u32       = 0x02   # THR empty
val IIR_RDI: u32        = 0x04   # Received data available
val IIR_FIFO_ENABLED: u32 = 0xC0 # FIFO enabled bits [7:6]

# FCR bit masks
val FCR_FIFO_EN: u32   = 0x01   # bit 0: FIFO enable
val FCR_RX_RESET: u32  = 0x02   # bit 1: RX FIFO reset (self-clearing)
val FCR_TX_RESET: u32  = 0x04   # bit 2: TX FIFO reset (self-clearing)
val FCR_TRIGGER_MASK: u32 = 0xC0  # bits 7:6: RX trigger level

# MCR bit masks
val MCR_DTR: u32   = 0x01   # bit 0: Data Terminal Ready
val MCR_RTS: u32   = 0x02   # bit 1: Request To Send
val MCR_OUT1: u32  = 0x04   # bit 2: Aux output 1
val MCR_OUT2: u32  = 0x08   # bit 3: Aux output 2 (irq gate on PC hw; not gated here)
val MCR_LOOP: u32  = 0x10   # bit 4: Loopback mode

# MSR bit masks
val MSR_DCTS: u32  = 0x01   # bit 0: Delta CTS
val MSR_DDSR: u32  = 0x02   # bit 1: Delta DSR
val MSR_TERI: u32  = 0x04   # bit 2: Trailing Edge RI (modeled as delta RI)
val MSR_DDCD: u32  = 0x08   # bit 3: Delta DCD
val MSR_CTS: u32   = 0x10   # bit 4: Clear To Send
val MSR_DSR: u32   = 0x20   # bit 5: Data Set Ready
val MSR_RI: u32    = 0x40   # bit 6: Ring Indicator
val MSR_DCD: u32   = 0x80   # bit 7: Data Carrier Detect

# ============================================================================
# UART State
# ============================================================================

struct Uart16550State:
    """UART 16550 register and FIFO state."""
    # TX FIFO (circular buffer)
    tx_fifo_0: u32
    tx_fifo_1: u32
    tx_fifo_2: u32
    tx_fifo_3: u32
    tx_fifo_4: u32
    tx_fifo_5: u32
    tx_fifo_6: u32
    tx_fifo_7: u32
    tx_fifo_8: u32
    tx_fifo_9: u32
    tx_fifo_10: u32
    tx_fifo_11: u32
    tx_fifo_12: u32
    tx_fifo_13: u32
    tx_fifo_14: u32
    tx_fifo_15: u32
    tx_head: u32
    tx_tail: u32
    tx_count: u32

    # RX FIFO (circular buffer)
    rx_fifo_0: u32
    rx_fifo_1: u32
    rx_fifo_2: u32
    rx_fifo_3: u32
    rx_fifo_4: u32
    rx_fifo_5: u32
    rx_fifo_6: u32
    rx_fifo_7: u32
    rx_fifo_8: u32
    rx_fifo_9: u32
    rx_fifo_10: u32
    rx_fifo_11: u32
    rx_fifo_12: u32
    rx_fifo_13: u32
    rx_fifo_14: u32
    rx_fifo_15: u32
    rx_head: u32
    rx_tail: u32
    rx_count: u32

    # Divisor latch
    dll: u32
    dlm: u32

    # Control/status registers
    lcr: u32
    ier: u32
    iir: u32
    fcr: u32          # FIFO control (bit0 enable, bits 7:6 trigger; reset bits self-clear)
    mcr: u32          # Modem control (DTR/RTS/OUT1/OUT2/LOOP)
    scr: u32          # Scratch register
    msr_inputs: u32   # External modem input lines (MSR_CTS/DSR/RI/DCD bit positions)
    msr_delta: u32    # Latched MSR delta bits 3:0, cleared on MSR read

    # TX shift register state
    tx_shift: u32
    tx_busy: bool
    tx_bit_count: u32
    baud_counter: u32

# ============================================================================
# UART Tick Result
# ============================================================================

struct UartTickResult:
    """Result of one UART clock tick."""
    state: Uart16550State
    tx_out: u32      # Current TX output bit (0 or 1)
    irq: bool        # Interrupt request signal

# ============================================================================
# FIFO Helpers — read/write by index (flat struct, no arrays)
# ============================================================================

fn tx_fifo_get(s: Uart16550State, idx: u32) -> u32:
    """Read TX FIFO at index."""
    if idx == 0:  return s.tx_fifo_0
    if idx == 1:  return s.tx_fifo_1
    if idx == 2:  return s.tx_fifo_2
    if idx == 3:  return s.tx_fifo_3
    if idx == 4:  return s.tx_fifo_4
    if idx == 5:  return s.tx_fifo_5
    if idx == 6:  return s.tx_fifo_6
    if idx == 7:  return s.tx_fifo_7
    if idx == 8:  return s.tx_fifo_8
    if idx == 9:  return s.tx_fifo_9
    if idx == 10: return s.tx_fifo_10
    if idx == 11: return s.tx_fifo_11
    if idx == 12: return s.tx_fifo_12
    if idx == 13: return s.tx_fifo_13
    if idx == 14: return s.tx_fifo_14
    if idx == 15: return s.tx_fifo_15
    0

fn tx_fifo_set(s: Uart16550State, idx: u32, value: u32) -> Uart16550State:
    """Write TX FIFO at index."""
    var out = s
    if idx == 0:  out.tx_fifo_0 = value
    if idx == 1:  out.tx_fifo_1 = value
    if idx == 2:  out.tx_fifo_2 = value
    if idx == 3:  out.tx_fifo_3 = value
    if idx == 4:  out.tx_fifo_4 = value
    if idx == 5:  out.tx_fifo_5 = value
    if idx == 6:  out.tx_fifo_6 = value
    if idx == 7:  out.tx_fifo_7 = value
    if idx == 8:  out.tx_fifo_8 = value
    if idx == 9:  out.tx_fifo_9 = value
    if idx == 10: out.tx_fifo_10 = value
    if idx == 11: out.tx_fifo_11 = value
    if idx == 12: out.tx_fifo_12 = value
    if idx == 13: out.tx_fifo_13 = value
    if idx == 14: out.tx_fifo_14 = value
    if idx == 15: out.tx_fifo_15 = value
    out

fn rx_fifo_get(s: Uart16550State, idx: u32) -> u32:
    """Read RX FIFO at index."""
    if idx == 0:  return s.rx_fifo_0
    if idx == 1:  return s.rx_fifo_1
    if idx == 2:  return s.rx_fifo_2
    if idx == 3:  return s.rx_fifo_3
    if idx == 4:  return s.rx_fifo_4
    if idx == 5:  return s.rx_fifo_5
    if idx == 6:  return s.rx_fifo_6
    if idx == 7:  return s.rx_fifo_7
    if idx == 8:  return s.rx_fifo_8
    if idx == 9:  return s.rx_fifo_9
    if idx == 10: return s.rx_fifo_10
    if idx == 11: return s.rx_fifo_11
    if idx == 12: return s.rx_fifo_12
    if idx == 13: return s.rx_fifo_13
    if idx == 14: return s.rx_fifo_14
    if idx == 15: return s.rx_fifo_15
    0

fn rx_fifo_set(s: Uart16550State, idx: u32, value: u32) -> Uart16550State:
    """Write RX FIFO at index."""
    var out = s
    if idx == 0:  out.rx_fifo_0 = value
    if idx == 1:  out.rx_fifo_1 = value
    if idx == 2:  out.rx_fifo_2 = value
    if idx == 3:  out.rx_fifo_3 = value
    if idx == 4:  out.rx_fifo_4 = value
    if idx == 5:  out.rx_fifo_5 = value
    if idx == 6:  out.rx_fifo_6 = value
    if idx == 7:  out.rx_fifo_7 = value
    if idx == 8:  out.rx_fifo_8 = value
    if idx == 9:  out.rx_fifo_9 = value
    if idx == 10: out.rx_fifo_10 = value
    if idx == 11: out.rx_fifo_11 = value
    if idx == 12: out.rx_fifo_12 = value
    if idx == 13: out.rx_fifo_13 = value
    if idx == 14: out.rx_fifo_14 = value
    if idx == 15: out.rx_fifo_15 = value
    out

# ============================================================================
# Create — initial UART state
# ============================================================================

fn uart_create() -> Uart16550State:
    """Create UART in reset state. TX empty, RX empty, no interrupts."""
    Uart16550State(
        tx_fifo_0: 0, tx_fifo_1: 0, tx_fifo_2: 0, tx_fifo_3: 0,
        tx_fifo_4: 0, tx_fifo_5: 0, tx_fifo_6: 0, tx_fifo_7: 0,
        tx_fifo_8: 0, tx_fifo_9: 0, tx_fifo_10: 0, tx_fifo_11: 0,
        tx_fifo_12: 0, tx_fifo_13: 0, tx_fifo_14: 0, tx_fifo_15: 0,
        tx_head: 0, tx_tail: 0, tx_count: 0,
        rx_fifo_0: 0, rx_fifo_1: 0, rx_fifo_2: 0, rx_fifo_3: 0,
        rx_fifo_4: 0, rx_fifo_5: 0, rx_fifo_6: 0, rx_fifo_7: 0,
        rx_fifo_8: 0, rx_fifo_9: 0, rx_fifo_10: 0, rx_fifo_11: 0,
        rx_fifo_12: 0, rx_fifo_13: 0, rx_fifo_14: 0, rx_fifo_15: 0,
        rx_head: 0, rx_tail: 0, rx_count: 0,
        dll: 1, dlm: 0,
        lcr: 0, ier: 0, iir: IIR_NO_INT,
        fcr: 0, mcr: 0, scr: 0, msr_inputs: 0, msr_delta: 0,
        tx_shift: 0, tx_busy: false, tx_bit_count: 0, baud_counter: 0
    )

# ============================================================================
# Compute LSR (Line Status Register)
# ============================================================================

fn uart_compute_lsr(state: Uart16550State) -> u32:
    """Compute the LSR value from current FIFO state."""
    var lsr: u32 = 0
    # Data Ready: RX FIFO not empty
    if state.rx_count > 0:
        lsr = lsr | LSR_DR
    # TX Holding Register Empty: TX holding/FIFO empty (16550 FIFO-mode semantics)
    if state.tx_count == 0:
        lsr = lsr | LSR_THRE
    # Transmitter Empty: TX FIFO empty and shift register idle
    if state.tx_count == 0 and state.tx_busy == false:
        lsr = lsr | LSR_TEMT
    lsr

# ============================================================================
# Compute MSR (Modem Status Register)
# ============================================================================

fn uart_compute_msr_lines(state: Uart16550State) -> u32:
    """Compute the live MSR line bits (7:4).  In loopback mode (MCR bit 4)
    the modem outputs are folded back: RTS->CTS, DTR->DSR, OUT1->RI, OUT2->DCD.
    Otherwise the external msr_inputs lines are reported."""
    if (state.mcr & MCR_LOOP) != 0:
        var lines: u32 = 0
        if (state.mcr & MCR_RTS) != 0:
            lines = lines | MSR_CTS
        if (state.mcr & MCR_DTR) != 0:
            lines = lines | MSR_DSR
        if (state.mcr & MCR_OUT1) != 0:
            lines = lines | MSR_RI
        if (state.mcr & MCR_OUT2) != 0:
            lines = lines | MSR_DCD
        return lines
    state.msr_inputs & 0xF0

fn uart_compute_msr(state: Uart16550State) -> u32:
    """Compute the MSR value: live lines (7:4) | latched delta bits (3:0)."""
    uart_compute_msr_lines(state) | (state.msr_delta & 0x0F)

fn uart_latch_msr_delta(new_state: Uart16550State, old_lines: u32) -> Uart16550State:
    """Latch MSR delta bits for any line (7:4) that changed vs old_lines
    (capture old_lines via uart_compute_msr_lines BEFORE mutating state).
    TERI is modeled as any RI change (simplification of trailing-edge-only)."""
    val new_lines = uart_compute_msr_lines(new_state)
    var out = new_state
    out.msr_delta = new_state.msr_delta | (((old_lines ^ new_lines) >> 4) & 0x0F)
    out

fn uart_set_modem_inputs(state: Uart16550State, inputs: u32) -> Uart16550State:
    """Drive the external modem input lines (MSR_CTS/DSR/RI/DCD bit positions).
    Latches delta bits for changed lines."""
    val old_lines = uart_compute_msr_lines(state)
    var out = state
    out.msr_inputs = inputs & 0xF0
    out = uart_latch_msr_delta(out, old_lines)
    out

# ============================================================================
# Divisor / Baud
# ============================================================================

fn uart_divisor(state: Uart16550State) -> u32:
    """Current 16-bit baud divisor (DLM:DLL), minimum 1."""
    val d = state.dll | (state.dlm << 8)
    if d == 0:
        return 1
    d

fn uart_baud(state: Uart16550State, clock_hz: u32) -> u32:
    """Computed baud rate = clock / (16 * divisor)."""
    clock_hz / (16 * uart_divisor(state))

fn uart_word_length(state: Uart16550State) -> u32:
    """Programmed word length in bits (5..8) from LCR bits 1:0."""
    5 + (state.lcr & LCR_WLEN_MASK)

# ============================================================================
# Compute IIR (Interrupt Identification Register)
# ============================================================================

fn uart_compute_iir(state: Uart16550State) -> u32:
    """Compute the IIR from current state and interrupt enables.
    Priority: RX data available > THR empty > modem status.
    Bits 7:6 report FIFO-enabled only when FCR bit 0 is set."""
    var fifo_bits: u32 = 0
    if (state.fcr & FCR_FIFO_EN) != 0:
        fifo_bits = IIR_FIFO_ENABLED
    if (state.ier & IER_RDI) != 0 and state.rx_count > 0:
        return IIR_RDI | fifo_bits
    if (state.ier & IER_THRI) != 0 and state.tx_count == 0:
        return IIR_THRI | fifo_bits
    if (state.ier & IER_MSI) != 0 and (state.msr_delta & 0x0F) != 0:
        return IIR_MSI | fifo_bits
    IIR_NO_INT | fifo_bits

fn uart_irq_line(state: Uart16550State) -> bool:
    """Level interrupt output: asserted when IIR reports a pending interrupt
    (IIR bit 0 = 0 means pending)."""
    (uart_compute_iir(state) & 0x01) == 0

# ============================================================================
# MMIO Read
# ============================================================================

fn uart_mmio_read(state: Uart16550State, offset: u32) -> u32:
    """Read a UART register by byte offset.
    offset=0: RBR (rx data) or DLL (if DLAB set)
    offset=1: IER or DLM (if DLAB set)
    offset=2: IIR
    offset=3: LCR
    offset=4: MCR
    offset=5: LSR
    offset=6: MSR
    offset=7: SCR"""
    val dlab = (state.lcr & LCR_DLAB) != 0

    if offset == 0:
        if dlab:
            return state.dll
        # RBR — read from RX FIFO head (data remains until popped by side-effect)
        if state.rx_count > 0:
            return rx_fifo_get(state, state.rx_head) & 0xFF
        return 0

    if offset == 1:
        if dlab:
            return state.dlm
        return state.ier

    if offset == 2:
        return uart_compute_iir(state)

    if offset == 3:
        return state.lcr

    if offset == 4:
        return state.mcr

    if offset == 5:
        return uart_compute_lsr(state)

    if offset == 6:
        return uart_compute_msr(state)

    if offset == 7:
        return state.scr

    0

# ============================================================================
# MMIO Read with Side Effects (pops RX FIFO)
# ============================================================================

fn uart_mmio_read_update(state: Uart16550State, offset: u32) -> Uart16550State:
    """Update state after an MMIO read (pops RX FIFO on RBR read;
    clears MSR delta bits on MSR read)."""
    val dlab = (state.lcr & LCR_DLAB) != 0
    if offset == 0 and dlab == false and state.rx_count > 0:
        var out = state
        out.rx_head = (state.rx_head + 1) & 0xF
        out.rx_count = state.rx_count - 1
        return out
    if offset == 6:
        var out2 = state
        out2.msr_delta = 0
        return out2
    state

# ============================================================================
# MMIO Write
# ============================================================================

fn uart_mmio_write(state: Uart16550State, offset: u32, value: u32) -> Uart16550State:
    """Write a UART register by byte offset.
    offset=0: THR (tx data) or DLL (if DLAB set)
    offset=1: IER or DLM (if DLAB set)
    offset=2: FCR (FIFO control; reset bits self-clear)
    offset=3: LCR
    offset=4: MCR (loopback change latches MSR deltas)
    offset=7: SCR (offsets 5/6 are read-only, writes ignored)"""
    val dlab = (state.lcr & LCR_DLAB) != 0
    var out = state

    if offset == 0:
        if dlab:
            out.dll = value & 0xFF
        else:
            # THR — push byte to TX FIFO
            if state.tx_count < UART_FIFO_SIZE:
                out = tx_fifo_set(out, state.tx_tail, value & 0xFF)
                out.tx_tail = (state.tx_tail + 1) & 0xF
                out.tx_count = state.tx_count + 1
        return out

    if offset == 1:
        if dlab:
            out.dlm = value & 0xFF
        else:
            out.ier = value & 0x0F
        return out

    if offset == 2:
        # FCR — store enable + trigger bits; RX/TX reset bits act then self-clear
        out.fcr = value & (FCR_FIFO_EN | FCR_TRIGGER_MASK)
        if (value & FCR_RX_RESET) != 0:
            out.rx_head = 0
            out.rx_tail = 0
            out.rx_count = 0
        if (value & FCR_TX_RESET) != 0:
            out.tx_head = 0
            out.tx_tail = 0
            out.tx_count = 0
        return out

    if offset == 3:
        out.lcr = value & 0xFF
        return out

    if offset == 4:
        # Entering/leaving loopback can change the reflected MSR lines;
        # capture the old lines BEFORE mutating (struct copies can alias in interp)
        val old_lines = uart_compute_msr_lines(state)
        out.mcr = value & 0x1F
        out = uart_latch_msr_delta(out, old_lines)
        return out

    if offset == 7:
        out.scr = value & 0xFF
        return out

    out

# ============================================================================
# UART Tick — baud rate generator and TX shift
# ============================================================================

fn uart_tick(state: Uart16550State) -> UartTickResult:
    """Advance the UART by one system clock cycle.
    Manages the baud rate counter and shifts out TX data.
    Returns updated state, current TX output bit, and IRQ signal."""
    var out = state
    var tx_out: u32 = 1   # Idle line is high

    # Compute baud divisor (DLL + DLM<<8), minimum 1
    var divisor = state.dll | (state.dlm << 8)
    if divisor == 0:
        divisor = 1

    # Baud counter tick
    var baud_tick: bool = false
    val new_counter = state.baud_counter + 1
    if new_counter >= divisor:
        out.baud_counter = 0
        baud_tick = true
    else:
        out.baud_counter = new_counter

    # TX shift register logic (on baud tick)
    if baud_tick:
        if state.tx_busy:
            # Shift out next bit (LSB first)
            tx_out = state.tx_shift & 1
            out.tx_shift = state.tx_shift >> 1
            out.tx_bit_count = state.tx_bit_count + 1
            # 8-N-1: start(1) + data(8) + stop(1) = 10 bits
            if state.tx_bit_count + 1 >= 10:
                out.tx_busy = false
                out.tx_bit_count = 0
        else:
            # Load next byte from TX FIFO if available
            if state.tx_count > 0:
                val byte_val = tx_fifo_get(state, state.tx_head)
                # Frame: start bit (0) + 8 data bits + stop bit (1)
                # Pack as: [stop][data7..data0][start] = bit9..bit0
                out.tx_shift = (1 << 9) | (byte_val << 1) | 0
                out.tx_busy = true
                out.tx_bit_count = 0
                out.tx_head = (state.tx_head + 1) & 0xF
                out.tx_count = state.tx_count - 1
                tx_out = 0   # Start bit

    # Compute IRQ
    val iir_val = uart_compute_iir(out)
    val irq = (iir_val & 0x01) == 0   # bit 0 = 0 means interrupt pending

    UartTickResult(state: out, tx_out: tx_out, irq: irq)

# ============================================================================
# RX Push — external byte received
# ============================================================================

fn uart_rx_push(state: Uart16550State, byte_val: u32) -> Uart16550State:
    """Push a received byte into the RX FIFO.  Drops the byte if FIFO is full."""
    if state.rx_count >= UART_FIFO_SIZE:
        return state
    var out = rx_fifo_set(state, state.rx_tail, byte_val & 0xFF)
    out.rx_tail = (state.rx_tail + 1) & 0xF
    out.rx_count = state.rx_count + 1
    out

# ============================================================================
# TX Pop — drain one byte from the TX FIFO (host/testbench side)
# ============================================================================

struct UartTxPopResult:
    """Result of popping one byte from the TX FIFO."""
    state: Uart16550State
    byte_val: u32
    valid: bool

fn uart_tx_pop(state: Uart16550State) -> UartTxPopResult:
    """Pop one byte from the TX FIFO without running the serializer.
    valid=false when the FIFO is empty."""
    if state.tx_count == 0:
        return UartTxPopResult(state: state, byte_val: 0, valid: false)
    val b = tx_fifo_get(state, state.tx_head) & 0xFF
    var out = state
    out.tx_head = (state.tx_head + 1) & 0xF
    out.tx_count = state.tx_count - 1
    UartTxPopResult(state: out, byte_val: b, valid: true)
