# ============================================================================
# SoC RTL Wishbone B4 Classic Bus Interconnect
# ============================================================================
#
# Combinational address decoder and data router for the Wishbone B4 classic
# bus.  Maps the QEMU virt memory layout to peripheral slave indices.
#
# Memory map:
#   0x00001000-0x00001FFF  Boot ROM   (4 KB)      — slave 0
#   0x02000000-0x0200FFFF  CLINT      (64 KB)     — slave 1
#   0x0C000000-0x0C3FFFFF  PLIC       (4 MB)      — slave 6
#   0x10000000-0x100000FF  UART0      (256 bytes) — slave 2
#   0x10010000-0x100100FF  ETH DMA    (256 bytes) — slave 5
#   0x80000000-0x87FFFFFF  RAM        (128 MB)    — slave 3
#   0x80FF0000-0x80FF00FF  Mailbox    (256 bytes) — slave 4 (within RAM)
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

use std.hardware.soc_rtl.bootrom.BOOTROM_BASE
use std.hardware.soc_rtl.plic.PLIC_BASE
use std.hardware.rv32i_rtl.pkg.MB_BASE_ADDR

# ============================================================================
# Slave index constants
# ============================================================================

val WB_SLAVE_ROM: u32      = 0
val WB_SLAVE_CLINT: u32    = 1
val WB_SLAVE_UART: u32     = 2
val WB_SLAVE_RAM: u32      = 3
val WB_SLAVE_MAILBOX: u32  = 4
val WB_SLAVE_ETH_DMA: u32  = 5
val WB_SLAVE_PLIC: u32     = 6
val WB_SLAVE_UNMAPPED: u32 = 0xFF

# ============================================================================
# Address range constants
# ============================================================================

val ROM_BASE: u32   = 0x00001000
val ROM_END: u32    = 0x00001FFF

val CLINT_BASE: u32 = 0x02000000
val CLINT_END: u32  = 0x0200FFFF

val PLIC_END: u32   = 0x0C3FFFFF

val UART_BASE: u32  = 0x10000000
val UART_END: u32   = 0x100000FF

val RAM_BASE: u32   = 0x80000000
val RAM_END: u32    = 0x87FFFFFF

val ETH_DMA_BASE: u32 = 0x10010000
val ETH_DMA_END: u32  = 0x100100FF

val MB_BASE: u32    = 0x80FF0000
val MB_END: u32     = 0x80FF00FF

# ============================================================================
# Wishbone Bus Structs
# ============================================================================

struct WbMasterBus:
    """Master → slave signals on the Wishbone bus."""
    addr: u32       # Address
    wdata: u32      # Write data
    we: bool        # Write enable
    re: bool        # Read enable
    width: u32      # Transfer width (0=byte, 1=half, 2=word)
    cyc: bool       # Bus cycle active
    stb: bool       # Strobe (valid transfer)

struct WbSlaveResponse:
    """Slave → master response signals."""
    rdata: u32      # Read data
    ack: bool       # Transfer acknowledged
    err: bool       # Bus error

struct WbInterconnect:
    """Decoded slave selection state for the current bus cycle."""
    slave_idx: u32  # Active slave index

# ============================================================================
# Write result — indicates which slave should handle the write
# ============================================================================

struct WbWriteResult:
    """Result of routing a write through the interconnect."""
    slave_idx: u32  # Target slave
    offset: u32     # Offset within the slave's address range
    wdata: u32      # Data to write

# ============================================================================
# Address Decode
# ============================================================================

fn wb_decode_address(addr: u32) -> u32:
    """Decode a 32-bit address to a slave index.
    Mailbox (within RAM range) is checked BEFORE RAM to avoid misrouting.

    Returns:
      0  = Boot ROM
      1  = CLINT
      2  = UART
      3  = RAM
      4  = Mailbox
      6  = PLIC
      0xFF = unmapped
    """
    # Mailbox is inside RAM range — check first
    if addr >= MB_BASE and addr <= MB_END:
        return WB_SLAVE_MAILBOX

    # Boot ROM
    if addr >= ROM_BASE and addr <= ROM_END:
        return WB_SLAVE_ROM

    # CLINT
    if addr >= CLINT_BASE and addr <= CLINT_END:
        return WB_SLAVE_CLINT

    # PLIC
    if addr >= PLIC_BASE and addr <= PLIC_END:
        return WB_SLAVE_PLIC

    # UART
    if addr >= UART_BASE and addr <= UART_END:
        return WB_SLAVE_UART

    # Ethernet DMA bridge
    if addr >= ETH_DMA_BASE and addr <= ETH_DMA_END:
        return WB_SLAVE_ETH_DMA

    # RAM (general range, mailbox already excluded)
    if addr >= RAM_BASE and addr <= RAM_END:
        return WB_SLAVE_RAM

    WB_SLAVE_UNMAPPED

# ============================================================================
# Read Routing
# ============================================================================

fn wb_route_read(slave_idx: u32, addr: u32, rom_data: u32, clint_data: u32,
                 plic_data: u32, uart_data: u32, ram_data: u32,
                 mb_data: u32, eth_data: u32) -> WbSlaveResponse:
    """Route a read response from the correct slave based on decoded index.
    Each slave's data is pre-read by the caller; this function selects which
    one to return and generates ack/err signals."""

    if slave_idx == WB_SLAVE_ROM:
        return WbSlaveResponse(rdata: rom_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_CLINT:
        return WbSlaveResponse(rdata: clint_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_PLIC:
        return WbSlaveResponse(rdata: plic_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_UART:
        return WbSlaveResponse(rdata: uart_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_RAM:
        return WbSlaveResponse(rdata: ram_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_MAILBOX:
        return WbSlaveResponse(rdata: mb_data, ack: true, err: false)
    if slave_idx == WB_SLAVE_ETH_DMA:
        return WbSlaveResponse(rdata: eth_data, ack: true, err: false)

    # Unmapped — bus error
    WbSlaveResponse(rdata: 0, ack: false, err: true)

# ============================================================================
# Write Routing
# ============================================================================

fn wb_route_write(slave_idx: u32, addr: u32, wdata: u32) -> WbWriteResult:
    """Compute the offset and target for a write transaction.
    The caller uses the returned slave_idx and offset to dispatch
    the write to the appropriate peripheral."""

    if slave_idx == WB_SLAVE_ROM:
        # ROM is read-only; return offset but caller should ignore the write
        val offset = addr - ROM_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_ROM, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_CLINT:
        val offset = addr - CLINT_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_CLINT, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_PLIC:
        val offset = addr - PLIC_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_PLIC, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_UART:
        val offset = addr - UART_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_UART, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_RAM:
        val offset = addr - RAM_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_RAM, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_MAILBOX:
        val offset = addr - MB_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_MAILBOX, offset: offset, wdata: wdata)

    if slave_idx == WB_SLAVE_ETH_DMA:
        val offset = addr - ETH_DMA_BASE
        return WbWriteResult(slave_idx: WB_SLAVE_ETH_DMA, offset: offset, wdata: wdata)

    # Unmapped
    WbWriteResult(slave_idx: WB_SLAVE_UNMAPPED, offset: 0, wdata: wdata)

export WB_SLAVE_ROM
export WB_SLAVE_CLINT
export WB_SLAVE_UART
export WB_SLAVE_RAM
export WB_SLAVE_MAILBOX
export WB_SLAVE_ETH_DMA
export WB_SLAVE_PLIC
export WB_SLAVE_UNMAPPED
export ROM_BASE
export ROM_END
export CLINT_BASE
export CLINT_END
export PLIC_END
export UART_BASE
export UART_END
export RAM_BASE
export RAM_END
export ETH_DMA_BASE
export ETH_DMA_END
export MB_BASE
export MB_END
