# ============================================================================
# SoC RTL PLIC — Platform-Level Interrupt Controller
# ============================================================================
#
# Implements a minimal RISC-V PLIC for 32 interrupt sources and 2 contexts
# (context 0 = M-mode, context 1 = S-mode). All operations return new
# state — suitable for synthesizable RTL.
#
# MMIO layout (base 0x0C000000, standard RISC-V PLIC):
#   0x000000-0x00007F  Priority registers (source 1-31, 4 bytes each)
#   0x001000           Pending bits (32-bit bitmap)
#   0x002000           Enable bits for context 0
#   0x002080           Enable bits for context 1
#   0x200000           Priority threshold for context 0
#   0x200004           Claim/complete for context 0
#   0x201000           Priority threshold for context 1
#   0x201004           Claim/complete for context 1
#
# Source 0 is hardwired to "no interrupt" per the RISC-V spec.
#
# VHDL synthesizable subset: u32, bool, structs only.
# ============================================================================

# ============================================================================
# PLIC Address Constants
# ============================================================================

val PLIC_BASE: u32           = 0x0C000000
val PLIC_PRIORITY_END: u32   = 0x00000080   # 32 sources * 4 bytes
val PLIC_PENDING_OFF: u32    = 0x00001000
val PLIC_ENABLE_OFF: u32     = 0x00002000
val PLIC_S_ENABLE_OFF: u32   = 0x00002080
val PLIC_THRESHOLD_OFF: u32  = 0x00200000
val PLIC_CLAIM_OFF: u32      = 0x00200004
val PLIC_S_THRESHOLD_OFF: u32 = 0x00201000
val PLIC_S_CLAIM_OFF: u32     = 0x00201004

# ============================================================================
# PLIC State
# ============================================================================

struct PlicState:
    """PLIC register file.  32 interrupt sources (source 0 unused)."""
    priority_bit_0: u32   # Three bitplanes encode 3-bit source priorities
    priority_bit_1: u32
    priority_bit_2: u32
    pending: u32          # 32-bit pending bitmap
    input_level: u32      # Current gateway input levels
    enable: u32           # 32-bit enable bitmap for context 0 (M-mode)
    s_enable: u32         # 32-bit enable bitmap for context 1 (S-mode)
    threshold: u32        # Priority threshold for context 0
    s_threshold: u32      # Priority threshold for context 1
    in_service: u32       # Sources claimed by context 0
    s_in_service: u32     # Sources claimed by context 1
    claim_complete: u32   # Last claimed interrupt id
    s_claim_complete: u32 # Last S-context claimed interrupt id

# ============================================================================
# PLIC Check Result
# ============================================================================

struct PlicCheckResult:
    """Result of checking for the highest-priority pending interrupt."""
    source_id: u32   # Winning source id, or 0 if none
    meip: bool       # M-context external interrupt
    s_source_id: u32 # Winning S-context source id, or 0
    seip: bool       # S-context external interrupt

# ============================================================================
# PLIC Claim Result
# ============================================================================

struct PlicClaimResult:
    """Result of claiming the highest-priority interrupt."""
    state: PlicState   # Updated state (pending bit cleared)
    source_id: u32     # Claimed source id, or 0 if none

# ============================================================================
# Create — initial PLIC state
# ============================================================================

@hardware
fn plic_priority_get(state: PlicState, source: u32) -> u32:
    if source == 0 or source >= 32:
        return 0
    val mask: u32 = 1 << source
    var priority: u32 = 0
    if (state.priority_bit_0 & mask) != 0:
        priority = priority | 1
    if (state.priority_bit_1 & mask) != 0:
        priority = priority | 2
    if (state.priority_bit_2 & mask) != 0:
        priority = priority | 4
    priority

@hardware
fn plic_priority_set(state: PlicState, source: u32,
                     priority: u32) -> PlicState:
    if source == 0 or source >= 32:
        return state
    var out = state
    val mask: u32 = 1 << source
    val clear = mask ^ 0xFFFFFFFF
    out.priority_bit_0 = state.priority_bit_0 & clear
    out.priority_bit_1 = state.priority_bit_1 & clear
    out.priority_bit_2 = state.priority_bit_2 & clear
    if (priority & 1) != 0:
        out.priority_bit_0 = out.priority_bit_0 | mask
    if (priority & 2) != 0:
        out.priority_bit_1 = out.priority_bit_1 | mask
    if (priority & 4) != 0:
        out.priority_bit_2 = out.priority_bit_2 | mask
    out

@hardware
fn plic_create() -> PlicState:
    """Create initial PLIC state.  All priorities 0, nothing pending/enabled."""
    PlicState(
        priority_bit_0: 0,
        priority_bit_1: 0,
        priority_bit_2: 0,
        pending: 0,
        input_level: 0,
        enable: 0,
        s_enable: 0,
        threshold: 0,
        s_threshold: 0,
        in_service: 0,
        s_in_service: 0,
        claim_complete: 0,
        s_claim_complete: 0
    )

# ============================================================================
# MMIO Read
# ============================================================================

@hardware
fn plic_mmio_read(state: PlicState, offset: u32) -> u32:
    """Read a PLIC register by byte offset from PLIC base.
    Unknown offsets return 0."""

    # Priority registers: offset 0x000000 .. 0x00007C (source 0-31)
    if offset < PLIC_PRIORITY_END:
        val src = offset >> 2
        if src > 0 and src < 32:
            return plic_priority_get(state, src)
        return 0

    # Pending bits
    if offset == PLIC_PENDING_OFF:
        return state.pending & 0xFFFFFFFE

    # Enable bits for context 0
    if offset == PLIC_ENABLE_OFF:
        return state.enable & 0xFFFFFFFE
    if offset == PLIC_S_ENABLE_OFF:
        return state.s_enable & 0xFFFFFFFE

    # Priority threshold for context 0
    if offset == PLIC_THRESHOLD_OFF:
        return state.threshold
    if offset == PLIC_S_THRESHOLD_OFF:
        return state.s_threshold

    # Claim/complete for context 0 — reading returns the winning source id.
    # NOTE: the actual state mutation (clearing pending bit) is applied by
    # plic_mmio_read_update(), which the SoC top-level must call separately
    # (same pattern as uart_mmio_read_update for UART RX FIFO pop).
    if offset == PLIC_CLAIM_OFF:
        val cr = plic_check_interrupt(state)
        return cr.source_id
    if offset == PLIC_S_CLAIM_OFF:
        val cr = plic_check_interrupt(state)
        return cr.s_source_id

    0

# ============================================================================
# MMIO Read with Side Effects — claim pending-bit clear
# ============================================================================

@hardware
fn plic_mmio_read_update(state: PlicState, offset: u32) -> PlicState:
    """Apply read side-effects.  Only the claim register (0x200004) has a
    side-effect: it atomically claims the highest-priority pending interrupt
    and clears its pending bit.  All other offsets are no-ops."""
    if offset == PLIC_CLAIM_OFF:
        val cr = plic_claim(state)
        return cr.state
    if offset == PLIC_S_CLAIM_OFF:
        val cr = plic_claim_s(state)
        return cr.state
    state

# ============================================================================
# MMIO Write
# ============================================================================

@hardware
fn plic_mmio_write(state: PlicState, offset: u32, value: u32) -> PlicState:
    """Write a PLIC register by byte offset from PLIC base.
    Unknown offsets are silently ignored."""
    var out = state

    # Priority registers
    if offset < PLIC_PRIORITY_END:
        val src = offset >> 2
        if src > 0 and src < 32:
            # Clamp priority to 3 bits (0-7)
            out = plic_priority_set(out, src, value & 0x7)
        return out

    # Pending bits — read-only from software; ignore writes
    if offset == PLIC_PENDING_OFF:
        return out

    # Enable bits for context 0
    if offset == PLIC_ENABLE_OFF:
        out.enable = value & 0xFFFFFFFE
        return out
    if offset == PLIC_S_ENABLE_OFF:
        out.s_enable = value & 0xFFFFFFFE
        return out

    # Priority threshold for context 0
    if offset == PLIC_THRESHOLD_OFF:
        out.threshold = value & 0x7
        return out
    if offset == PLIC_S_THRESHOLD_OFF:
        out.s_threshold = value & 0x7
        return out

    # Claim/complete for context 0 — writing performs a complete
    if offset == PLIC_CLAIM_OFF:
        out = plic_complete(out, value)
        return out
    if offset == PLIC_S_CLAIM_OFF:
        out = plic_complete_s(out, value)
        return out

    out

# ============================================================================
# Set Pending — driven by external interrupt sources
# ============================================================================

@hardware
fn plic_set_pending(state: PlicState, source: u32, pending: bool) -> PlicState:
    """Drive one gateway input, latching accepted requests until claim."""
    if source == 0 or source >= 32:
        return state
    var out = state
    val mask: u32 = 1 << source
    if pending:
        out.input_level = state.input_level | mask
        if ((state.in_service | state.s_in_service) & mask) == 0:
            out.pending = state.pending | mask
    else:
        # Deassertion records the level but cannot withdraw an accepted IP bit.
        out.input_level = state.input_level & (mask ^ 0xFFFFFFFF)
    out

# ============================================================================
# Check Interrupt — find highest-priority enabled pending source
# ============================================================================

@hardware
fn plic_select_context(state: PlicState, supervisor: bool) -> u32:
    """Return one context's highest-priority enabled pending source."""
    var best_src: u32 = 0
    var best_pri: u32 = 0
    val enable = if supervisor: state.s_enable else: state.enable
    val threshold = if supervisor: state.s_threshold else: state.threshold

    var src: u32 = 1
    while src < 32:
        val mask: u32 = 1 << src
        val is_pending = (state.pending & mask) != 0
        val is_enabled = (enable & mask) != 0
        val is_in_service = ((state.in_service | state.s_in_service) & mask) != 0
        if is_pending and is_enabled and not is_in_service:
            val pri = plic_priority_get(state, src)
            if pri > threshold and pri > best_pri:
                best_pri = pri
                best_src = src
        src = src + 1
    best_src

@hardware
fn plic_check_interrupt(state: PlicState) -> PlicCheckResult:
    """Check the independent M and S contexts against shared pending state."""
    val machine = plic_select_context(state, false)
    val supervisor = plic_select_context(state, true)

    PlicCheckResult(
        source_id: machine,
        meip: machine != 0,
        s_source_id: supervisor,
        seip: supervisor != 0
    )

# ============================================================================
# Claim — atomically returns winning source and clears its pending bit
# ============================================================================

@hardware
fn plic_claim(state: PlicState) -> PlicClaimResult:
    """Claim the highest-priority enabled pending interrupt.
    Clears the pending bit of the claimed source.
    Returns source_id=0 if nothing qualifies."""
    val check = plic_check_interrupt(state)
    var out = state
    if check.source_id != 0:
        val mask: u32 = 1 << check.source_id
        out.pending = state.pending & (mask ^ 0xFFFFFFFF)
        out.in_service = state.in_service | mask
        out.claim_complete = check.source_id
    else:
        out.claim_complete = 0
    PlicClaimResult(state: out, source_id: check.source_id)

@hardware
fn plic_claim_s(state: PlicState) -> PlicClaimResult:
    """Claim the S-context winner and clear its shared pending bit."""
    val check = plic_check_interrupt(state)
    var out = state
    if check.s_source_id != 0:
        val mask: u32 = 1 << check.s_source_id
        out.pending = state.pending & (mask ^ 0xFFFFFFFF)
        out.s_in_service = state.s_in_service | mask
        out.s_claim_complete = check.s_source_id
    else:
        out.s_claim_complete = 0
    PlicClaimResult(state: out, source_id: check.s_source_id)

# ============================================================================
# Complete — signal that ISR processing is done for a source
# ============================================================================

@hardware
fn plic_complete(state: PlicState, source: u32) -> PlicState:
    """Complete interrupt handling for the given source.
    Standard PLIC semantics: the completion allows the source to
    re-trigger if it is still asserted.  In this minimal model,
    completion clears the claim_complete register."""
    if source == 0 or source >= 32:
        return state
    var out = state
    val mask: u32 = 1 << source
    val was_in_service = (state.in_service & mask) != 0
    out.in_service = state.in_service & (mask ^ 0xFFFFFFFF)
    out.claim_complete = 0
    if (was_in_service and (out.input_level & mask) != 0 and
        ((out.in_service | out.s_in_service) & mask) == 0):
        out.pending = out.pending | mask
    out

@hardware
fn plic_complete_s(state: PlicState, source: u32) -> PlicState:
    """Complete one S-context claim."""
    if source == 0 or source >= 32:
        return state
    var out = state
    val mask: u32 = 1 << source
    val was_in_service = (state.s_in_service & mask) != 0
    out.s_in_service = state.s_in_service & (mask ^ 0xFFFFFFFF)
    out.s_claim_complete = 0
    if (was_in_service and (out.input_level & mask) != 0 and
        ((out.in_service | out.s_in_service) & mask) == 0):
        out.pending = out.pending | mask
    out
