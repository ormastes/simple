# ============================================================================
# SoC RTL RAM — Synchronous RAM Model
# ============================================================================
#
# Word-addressable synchronous RAM with byte/halfword/word write support.
# Uses [u32] dynamic array for simulation; maps to block RAM in synthesis.
#
# Address convention: all addresses are BYTE addresses relative to RAM base.
# Internally converted to word index (addr >> 2).
#
# Sub-word writes use read-modify-write with byte-enable masking.
#
# VHDL synthesizable subset: u32, bool, [u32] (maps to BRAM), structs only.
# ============================================================================

# ============================================================================
# RAM State
# ============================================================================

struct RamState:
    """Synchronous RAM state."""
    data: [u32]       # Word-addressable memory array
    size_words: u32   # Number of 32-bit words

# ============================================================================
# Create — initialize all zeros
# ============================================================================

fn ram_create(size_words: u32) -> RamState:
    """Create a RAM with the given number of 32-bit words, all initialized to zero."""
    var data: [u32] = []
    var i: u32 = 0
    while i < size_words:
        data = data + [0]
        i = i + 1
    RamState(data: data, size_words: size_words)

# ============================================================================
# Read — word-aligned
# ============================================================================

fn ram_read(state: RamState, addr: u32) -> u32:
    """Read a 32-bit word from RAM at the given byte address (relative to RAM base).
    Address is word-aligned (low 2 bits ignored).
    Returns 0 for out-of-range addresses."""
    val word_idx = addr >> 2
    if word_idx >= state.size_words:
        return 0
    state.data[word_idx]

# ============================================================================
# Write — byte/halfword/word with byte-enable
# ============================================================================

fn ram_write(state: RamState, addr: u32, wdata: u32, width: u32) -> RamState:
    """Write to RAM at the given byte address (relative to RAM base).

    Width encoding (matches funct3[1:0]):
      0 = byte   (8-bit)
      1 = halfword (16-bit)
      2 = word   (32-bit)

    Sub-word writes use read-modify-write with byte-enable masking.
    Returns updated RAM state."""
    val word_idx = addr >> 2
    if word_idx >= state.size_words:
        return state

    var out = state
    val byte_offset = addr & 0x3

    if width == 2:
        # Word write — no masking needed
        out.data[word_idx] = wdata
    else if width == 1:
        # Halfword write — 16-bit aligned
        val old_word = state.data[word_idx]
        val shift = (byte_offset & 0x2) * 8
        val mask = 0x0000FFFF << shift
        val inv_mask = mask ^ 0xFFFFFFFF
        val new_data = (wdata & 0xFFFF) << shift
        out.data[word_idx] = (old_word & inv_mask) | new_data
    else:
        # Byte write
        val old_word = state.data[word_idx]
        val shift = byte_offset * 8
        val mask = 0x000000FF << shift
        val inv_mask = mask ^ 0xFFFFFFFF
        val new_data = (wdata & 0xFF) << shift
        out.data[word_idx] = (old_word & inv_mask) | new_data

    out

# ============================================================================
# Bulk Load — for simulation ELF loading
# ============================================================================

fn ram_load_elf(state: RamState, base_addr: u32, load_data: [u32]) -> RamState:
    """Bulk-load an array of 32-bit words into RAM starting at the given
    byte address (relative to RAM base).  Used for loading ELF program
    sections into simulated RAM.

    Words that fall outside RAM bounds are silently dropped."""
    var out = state
    var start_word = base_addr >> 2
    var i: u32 = 0
    while i < load_data.len():
        val word_idx = start_word + i
        if word_idx < out.size_words:
            out.data[word_idx] = load_data[i]
        i = i + 1
    out

fn ram_load_bytes(state: RamState, base_addr: u32, data: [u8]) -> RamState:
    """Load a byte blob into RAM. Packs bytes into u32 words in LE order
    (RISC-V native). Used for loading DTB blobs into simulated RAM."""
    var out = state
    val start_word = base_addr >> 2
    val data_len = data.len() as u32
    val num_words = (data_len + 3) >> 2
    var w: u32 = 0
    while w < num_words:
        var word: u32 = 0
        var b: u32 = 0
        while b < 4:
            val byte_idx = w * 4 + b
            if byte_idx < data_len:
                word = word | ((data[byte_idx] as u32) << (b * 8))
            b = b + 1
        val word_idx = start_word + w
        if word_idx < out.size_words:
            out.data[word_idx] = word
        w = w + 1
    out
