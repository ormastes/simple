# ============================================================================
# SoC RTL Top-Level — RV64GC System-on-Chip (64-bit)
# ============================================================================
#
# Wires together the RV64GC core, CLINT, UART16550, and RAM into a complete
# single-cycle SoC targeting the QEMU virt memory map.
#
# soc_top_64_tick() is the main simulation entry point.  Each call = 1 cycle.
# Minimal pipeline (interpreter-safe subset):
#   1. Advance CLINT mtime
#   2. Advance core PC by 4 (NOP step when no instruction memory wired)
#
# Full RV64GC pipeline (compiled mode): requires core64_combinational +
# core64_update + full Wishbone64 dispatch (see soc_top.spl for RV32 pattern).
#
# Dependencies:
#   - std.hardware.rv64gc_rtl.core: CoreState64, core64_init
#     (priv_mode field and core64_init fn added by rv64gc core parallel agent)
#   - std.hardware.soc_rtl.clint: ClintState, clint_create, clint_tick
#     (mtime i64 field added by clint upgrade parallel agent)
#   - std.hardware.soc_rtl.ram64: Ram64State, ram64_init
#   - std.hardware.soc_rtl.wb64_interconnect: WbRegion64, Wb64Interconnect,
#     wb64_qemu_virt_regions, wb64_init, wb64_request
#
# VHDL synthesizable subset: i64, bool, [i64], structs only.
# ============================================================================

# -- Core
use std.hardware.rv64gc_rtl.core.{CoreState64, core64_init}

# -- Peripherals
use std.hardware.soc_rtl.clint.{ClintState, clint_create, clint_tick}
use std.hardware.soc_rtl.ram64.{Ram64State, ram64_init}

# -- Wishbone64 interconnect
use std.hardware.soc_rtl.wb64_interconnect.{WbRegion64, Wb64Interconnect, wb64_qemu_virt_regions, wb64_init}

# Reset vector matches QEMU virt boot ROM base
val SOC64_RESET_VECTOR: i64 = 0x1000

# ============================================================================
# SoC64 State
# ============================================================================

struct SocTop64State:
    """Full 64-bit SoC sequential state."""
    core:  CoreState64     # RV64GC core (pc, priv_mode, halt, ...)
    ram:   Ram64State      # DRAM
    clint: ClintState      # CLINT (mtime, mtimecmp, msip)
    ic:    Wb64Interconnect  # Address decode table (read-only after init)

# ============================================================================
# Create / Reset
# ============================================================================

fn soc_top_64_init(dram_size: i64) -> SocTop64State:
    """Create and initialize the full RV64GC SoC.

    - core.pc          = 0x1000  (QEMU virt boot ROM reset vector)
    - core.priv_mode   = 3       (M-mode)
    - ram.size         = dram_size bytes
    - clint initialized with mtime = 0, mtimecmp = max"""
    val regions = wb64_qemu_virt_regions()
    SocTop64State(
        core:  core64_init(SOC64_RESET_VECTOR),
        ram:   ram64_init(dram_size),
        clint: clint_create(),
        ic:    wb64_init(regions)
    )

# ============================================================================
# SoC Tick — one clock cycle
# ============================================================================

fn soc_top_64_tick(soc: SocTop64State) -> SocTop64State:
    """Execute one clock cycle of the RV64GC SoC.

    Minimal interpreter-safe implementation:
      1. Tick CLINT (increments mtime)
      2. Advance PC by 4 (NOP instruction step)

    Full pipeline (compiled mode): add core64_combinational + core64_update
    + Wishbone64 dispatch following the RV32 soc_tick pattern."""
    var out = soc

    # Step 1: Tick CLINT — increments mtime
    val ct = clint_tick(out.clint)
    out.clint = ct.state

    # Step 2: Advance PC (NOP step — boot ROM returns NOP 0x00000013)
    out.core.pc = out.core.pc + 4

    out
